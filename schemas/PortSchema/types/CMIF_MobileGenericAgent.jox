    <JadeMethod name="confirmsOK" id="9b3ba881-30c1-4db6-90cd-f71b13577075">
        <updating/>
        <source>confirmsOK( _userEnteredId : String; errorMess : String io ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2016	cnwndl1	Initial creation

*/

vars
	msg	: String;
	ti : CM_TrackedItem;
	
begin
	if self.myNextTiToAction.id = _userEnteredId then
		if not self.allConfirmedTis.includes(self.myNextTiToAction) then
			self.allConfirmedTis.add(self.myNextTiToAction);
		endif;
		self.myNextTiToAction := null;
		return true;
		
	else
		// check matching id and type.
		foreach ti in self.allTruckTis do
			if ti.id = _userEnteredId and self.myNextTiToAction.cargoTypeDescr = ti.cargoTypeDescr then
				// This the matching one, the user thought they had.
				if self.allConfirmedTis.includes(ti) then
					errorMess := app.getErrorString(Cargo_Id_Already_Used);
					return false;
				endif;
				self.allConfirmedTis.add(ti);
				self.myNextTiToAction := null;
				return true;
			endif;
		endforeach;
	
	endif;
	
	// 34405 no truck if coming from cargo unpack
	if self.myTruck &lt;&gt; null then
		msg := self.myTruck.getDisplayDetails(true);
	endif;
	errorMess := app.getErrorString2(No_Cargo_Id_Match, _userEnteredId, msg );
	
	return false;
	
epilog

end;</source>
        <Parameter name="_userEnteredId" type="String"/>
        <Parameter name="errorMess" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="7c51cf74-9912-4982-8939-406d79c29b4b">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2016	cnwndl1	Initial creation

*/

vars

begin
	//epr TFS 5535 14/8/17
	if app.isBackGroundApp then
		self.doNotShowMsgBox:=true;
	endif;
	
	self.myTerminal := self.getTerminal;
	
	if self.myTerminal = null then
		app.writeLog("self.myTerminal is null, check ini setting: " &amp; RTIniFileSection, LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	self.showState := self.myTerminal.getConfig(ShowVehicleState).Boolean ; 

	self.setUnpackChangeIDValue();
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createCargoCheckForTI" id="659e7819-eec8-4790-bf52-7bf77df785fd">
        <updating/>
        <source>createCargoCheckForTI(_requiredInfo : String; _context : Integer;_ti : CM_TrackedItem; _touched : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2016	cnwma1	Initial creation

*/


vars
	cargoCheck : CM_CargoCheck;
	cargoCheckItem : CM_CargoCheckItem;
	cmifAutoPlan : CMIF_YAAutoPlanNormal;
begin
	
	/*if self.myTrackedItem = null then
		self.findCargo();
	endif;*/
	if _ti = null then
		return;
	endif;
	
	if _touched.trimBlanks = "" then
		return;
	endif;
	
	cargoCheck:= myTerminal.allCargoChecks[_context];

	if cargoCheck &lt;&gt; null then
	
	
		create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
		cmifAutoPlan.attachTI(_ti);
			
		foreach cargoCheckItem in cargoCheck.allCargoCheckItems do
			
			if _requiredInfo = cargoCheckItem.requiredExtraInfo then
				if cargoCheckItem.doesTIMatchMe(cmifAutoPlan) then
					self.updateEquipmentCheckSettings(_ti, cargoCheckItem, _touched);
				endif;
			endif;
		endforeach;	
	endif;

epilog
	delete cmifAutoPlan;
end;</source>
        <Parameter name="_requiredInfo" type="String"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_touched" type="String"/>
    </JadeMethod>
    <JadeMethod name="createNewTrackedItem" id="50f5e356-8580-474b-aa8f-29070073004b">
        <updating/>
        <source>createNewTrackedItem(_parentTi : CM_TrackedItem;
					_cargoType : CM_CargoType;
					_id :String;
					_isoType : CM_ISOType;
					_operator : CM_Operator;
					_commodity : CM_Commodity;
					_imexStatus : CM_IMEXStatus;
					_voyage : CM_Voyage;
					_totalWeight : Decimal;
					_destination,_discharge : CM_Port;
					_quantity : Integer;
					_cargoSubType : CM_Product;
					_carriageTempC,_packTempC ,_packTempF,_colour,
					_mark,_make,_model,_year,_vehicleType  : String;
					_trailerType :CM_TILCType;
					_length,_width,_height : Decimal;_consignee : CM_ConsigneeConsignor; 
					_shippingLine: CM_ShippingLine;
					_tareWeight : Decimal;
					_alternativeId : String;
					_cargoGroupId : String;
					_markNumber : String;
					_remarks : String;
					_isOverlanded : Boolean):CM_TrackedItem updating;		//28.06.2022 navsrk20 TFS 53923
/* 

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 Oct 2016		cnwma1	Initial creation
10 April 2017	cnwam15	TFS 2731 :use raisecmException1 to indicate which field is missing
21 April 2017 	cnwer1	TFS 3760 changed to return the ti we created 
30 may 2017		cnwdap1	TFS 4449 STWR Mark and Mark Number field length addjustments
28.06.2022		navsrk20	Task 53923: Implement shipping line in WS_CargoItemUpdateRequest
26 May 2023		jlika1		TFS 56398 - EUP - OUT - Overlanded Cargo Handling - Web
*/

vars
	term : CM_Terminal;
	cargoType : CM_CargoType;
	id : String;
	pxyTI ,realTi: CM_TrackedItem;
	operator : CM_Operator;
	commodity : CM_Commodity;
	commodityCode : String;
	imex : CM_IMEXStatus;
	voyage : CM_Voyage;
	weightTotal : Decimal [14,4];
	destination : CM_Port;
	discharge : CM_Port;
	subT : CM_SubTerminal;
	isoType : CM_ISOType;
	length : Decimal [14,4];
	width : Decimal [14,4];
	height : Decimal [14,4];
	subCargo : CM_Product;
	carriageTempC : Real;
	packTempC : Real;
	packTempF : Real;
	str : String;
	totalQuantity : Integer;
	shippingLine : CM_ShippingLine;		//28.06.2022 navsrk20 TFS 53923
	txnControlller : CMIF_BBDiscrepancyController;
	newTITxn : CM_TITransaction;
begin
	term := self.myTerminal;
	cargoType := _cargoType;
	if cargoType = null then
		app.raiseCMException(Input_required_field_cargoType,null,null);
		return null;
	endif;

	id := _id;
	if id = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		return null;
	elseif id.length &gt; 20 then
		app.raiseCMException1(Field_Value_Too_Long,"ID","20",null);
		return null;
	endif;
	
	pxyTI := term.createTI(cargoType, true);
	pxyTI.zSetPxyId(id);
	pxyTI.zSetPxyTerminal(term);
	pxyTI.setCargoType(cargoType.id);
	
	operator := _operator;
	if operator = null then
		if self.myUnpackTi &lt;&gt; null then
			operator := self.myUnpackTi.myOperator;
		endif;
	endif;
	
	if operator &lt;&gt; null then
		pxyTI.setMyOperator(operator);
	else
		app.raiseCMException1(Input_required_field_Required,"Operator",null,null);
	endif;
	
	commodity := _commodity;
	if cargoType.defaultCommodityCode &lt;&gt; null then
		commodityCode := cargoType.defaultCommodityCode;
	else
		commodityCode := "MT"; // used in subterminal code further down too.
	endif;
	if commodity &lt;&gt; null then
		commodityCode := commodity.code;
		pxyTI.setCommodity(commodity.code);
	endif;
	
	imex := _imexStatus;
	if imex = null then
		if self.myUnpackTi &lt;&gt; null then
			imex := self.myUnpackTi.getImExStatusObject;
		endif;
	endif;
	if imex &lt;&gt; null then
		pxyTI.setImExStatus( imex.code );
	else
		app.raiseCMException(Input_required_field_Required,"ImexStatus",null);
		return null;
	endif;
	
	voyage := _voyage;
	if voyage &lt;&gt; null then
		pxyTI.setMyVoyage(voyage, app.myPassport);
	endif;
	
	pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
	

	//weightTotal := self.getConvertedWeight;  later
	weightTotal :=_totalWeight;
	if weightTotal &gt; 0 then
		pxyTI.setTotalWeight(weightTotal, null, app.myPassport);
	endif;
	//TFS 56680 jlier1 23/2/23
	if _tareWeight &gt; 0 then
		pxyTI.setWeightTare(_tareWeight);
	endif;

	pxyTI.zSetPxyCompany(term.getDefaultCompanyBank);		
	destination := _destination;
	if destination &lt;&gt; null then
		pxyTI.zSetPxyDestinationPort(destination.code);
	endif;
	
	discharge := _discharge;
	if discharge &lt;&gt; null then
		pxyTI.zSetPxyDischargePort(discharge.code);
	endif;
		
	if app.isSubTerminalsOn(self.myTerminal) then
		subT := term.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																0,	
																TI_IMEX_STATUS_IMPORT,
																commodityCode,
																true); 
		pxyTI.setSubTerminal(subT,null);
	endif;
	
	isoType := _isoType;
	if isoType &lt;&gt; null and pxyTI.isContainer then
		pxyTI.zSetPxyISOType( isoType.code );
	endif;
	
	if _consignee &lt;&gt; null then
	
		pxyTI.zSetPxyConsignee(_consignee.code);
	endif;
	
	length := _length;
	if length &gt; 0 then
		pxyTI.zSetPxyLength( length );
	endif;
	
	width :=_width;
	if width &gt; 0 then
		pxyTI.zSetPxyWidth( width );
	endif;
	
	height := _height;
	if height &gt; 0 then
		pxyTI.zSetPxyHeight( height );
	endif;

	subCargo := _cargoSubType;
	if subCargo &lt;&gt; null then
		pxyTI.zSetPxyProductCode(subCargo.code);
		pxyTI.setMyProduct(subCargo);
	endif;
	
	shippingLine := _shippingLine;				//28.06.2022 navsrk20 TFS 53923
	if shippingLine &lt;&gt; null then				//28.06.2022 navsrk20 TFS 53923
		pxyTI.setMyShippingLine(shippingLine);	//28.06.2022 navsrk20 TFS 53923
	endif;										//28.06.2022 navsrk20 TFS 53923
	
	if ( pxyTI.isContainer &lt;&gt; null and isoType &lt;&gt; null and isoType.isReefer ) or 
	   (subCargo &lt;&gt; null and subCargo.isReefer ) or 
	   ( cargoType &lt;&gt; null and cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.isReefer ) then	
		
		str :=  _carriageTempC;
		if str.trimBlanks = null then
			pxyTI.setTemperature(NULL_TEMPERATURE);
		else
			carriageTempC := str.Real;
			pxyTI.setTemperature(carriageTempC);
		endif;
		
		str :=  _packTempC;
		if str.trimBlanks = null then
			pxyTI.setPackTempC(NULL_TEMPERATURE.String);
		else
			packTempC := str.Real;
			pxyTI.setPackTempC(packTempC.String);
		endif;
		
		str :=  _packTempF;
		if str.trimBlanks = null then
			pxyTI.setPackTempF(NULL_TEMPERATURE.String);
		else
			packTempF := _packTempF.Real;
			pxyTI.setPackTempF(packTempF.String);
		endif;
	endif;
	

	str :=  _colour;
	if str &lt;&gt; null then
		if pxyTI.isKindOf(CM_BreakBulkGeneric) then												
			pxyTI.CM_BreakBulkGeneric.setColour(str);
		elseif pxyTI.isKindOf(CM_Car) then													
			pxyTI.CM_Car.setColour(str);
		endif;
	endif;
	
	//str :=  _mark;							// TFS 4449
	str :=  _mark[1:150];						// TFS 4449
	if str &lt;&gt; null then
		pxyTI.setMark(str);
	endif;
	
	if pxyTI.isKindOf(CM_BreakBulkGeneric) then
		totalQuantity := _quantity;
		if totalQuantity &gt; 0 then
			pxyTI.setTotalQuantity(totalQuantity);
		endif;
	endif;
	

	if pxyTI.isKindOf(CM_Car) then
		str :=  _make.toUpper.trimBlanks;
		if str &lt;&gt; null then
			pxyTI.CM_Car.setMake(str);																							
		endif;
		str := _model.toUpper.trimBlanks;
		if str &lt;&gt; null then
			pxyTI.CM_Car.setModel(str);																							
		endif;
		str := _vehicleType.toUpper.trimBlanks;
		if str &lt;&gt; null then
			pxyTI.CM_Car.setVehicleType(str);																							
		endif;
		str :=  _year.toUpper.trimBlanks;
		if str &lt;&gt; null and str.isInteger then
			pxyTI.CM_Car.setYear(str.Integer);																							
		endif;
	endif;
	

	if pxyTI.isKindOf(CM_TILC) then
		pxyTI.CM_TILC.setMyType( _trailerType);
	endif;
	
	//jlika1 TFS 56398 --&gt;
	pxyTI.zSetPxyAlternativeId(_alternativeId);
	pxyTI.zSetPxyCargoGroupId(_cargoGroupId);
	pxyTI.zSetPxyMarkNumber(_markNumber);
	pxyTI.zSetPxyRemarks(_remarks);
	//jlika1 TFS 56398 &lt;--
	
		
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);	

		
	app.myTrxCA.trxCreateChildTrackedItem(	self.myUnpackTi,	//_container : CM_TrackedItem input;	
												pxyTI,	//_pxyChildTI : CM_TrackedItem input;
												realTi,	//_realChildTI : CM_TrackedItem output;
												app.myPassport	//_passport : CM_Passport input
												);
												
	if (_isOverlanded and realTi &lt;&gt; null) then
		create txnControlller transient;
		txnControlller.type := TRANS_TYPE_OVERLANDED;
		txnControlller.myTrackedItem := realTi;
		app.myTrxCA.trxCreateTITransaction(txnControlller, newTITxn, app.myPassport);
		delete txnControlller;
	endif;

	return realTi;
		
epilog
	
	
end;</source>
        <Parameter name="_parentTi" type="CM_TrackedItem"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="_imexStatus" type="CM_IMEXStatus"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_destination" type="CM_Port"/>
        <Parameter name="_discharge" type="CM_Port"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_carriageTempC" type="String"/>
        <Parameter name="_packTempC" type="String"/>
        <Parameter name="_packTempF" type="String"/>
        <Parameter name="_colour" type="String"/>
        <Parameter name="_mark" type="String"/>
        <Parameter name="_make" type="String"/>
        <Parameter name="_model" type="String"/>
        <Parameter name="_year" type="String"/>
        <Parameter name="_vehicleType" type="String"/>
        <Parameter name="_trailerType" type="CM_TILCType"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_alternativeId" type="String"/>
        <Parameter name="_cargoGroupId" type="String"/>
        <Parameter name="_markNumber" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_isOverlanded" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createToDoCheckForTi" id="1d66cc86-2176-4583-815e-b6c076a9af32">
        <updating/>
        <source>createToDoCheckForTi(_context : Integer;_ti : CM_TrackedItem; _touched : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jan 2023 navhl20 Bug 61949:[61950] STWO - MTN Pack/Unpack container Error-89854

*/

vars
	cargoCheck 		: CM_CargoCheck;
	cargoCheckItem  : CM_CargoCheckItem;
	cmifAutoPlan 	: CMIF_YAAutoPlanNormal;
begin
	if _ti = null then
		return;
	endif;
	
	if _touched.trimBlanks = "" then
		return;
	endif;
	
	cargoCheck:= myTerminal.allCargoChecks[_context];

	if cargoCheck &lt;&gt; null then
		create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
		cmifAutoPlan.attachTI(_ti);
			
		foreach cargoCheckItem in cargoCheck.allCargoCheckItems do
			if cargoCheckItem.doesTIMatchMe(cmifAutoPlan) then
				self.updateEquipmentCheckSettings(_ti, cargoCheckItem, _touched);
			endif;
		endforeach;	
	endif;
epilog
	delete cmifAutoPlan;	
end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_touched" type="String"/>
    </JadeMethod>
    <JadeMethod name="createTruckEvent" id="f2bf621a-c0a2-4291-986e-8f4a6cf27181">
        <source>createTruckEvent(	_vvr : CM_VehicleVisitRecord input;
					_eventType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/04/16    cnwma1	TFS-1486 JMT Mobile Apps - RecRel - Truck Loader Unloader
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	proxyEventTrans,
	realEventTrans : CM_EventTransaction;
	theReturn : Integer;
begin
	if _vvr = null then
		return;
	endif;
	
	proxyEventTrans:=app.createEvent(_eventType,app.actualTimeServer,_vvr.myTerminal,app.myPassport.userCode,true,false,0);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	//epr TFS 4232 2/5/17 default to charged event transaction
	if proxyEventTrans = null then
		return;
	endif;
	proxyEventTrans.CMEVT_TruckEvent.setMyVisit(_vvr);
	
	while true do
		app.myTrxCA.trxCreateEventTransaction(proxyEventTrans, realEventTrans,app.myPassport);
		if  not app.myPassport.trxCompletedOK then
			//epr TFS 4232 moved up so can reuse this method
			if self.doNotShowMsgBox then	
				return;
			endif;
	
			theReturn := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport,20);// ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
				and theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;	
		break;
	endwhile;

epilog
	delete proxyEventTrans;
end;
</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="bca8b9e6-5c23-4a5a-9f1e-e62afd9bd86b">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2019	jlger1	Initial creation

*/

vars

begin
	self.allCargoCheckItemSelections.purge();
	self.allNonCargoCheckItemSelections.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddMoreCargoWLE" id="342f9ab5-5cb3-44fa-8006-faf5717a7ff3">
        <source>doAddMoreCargoWLE(	_ti : CM_TrackedItem;
					_job : CM_RoadJob input;
					_quantity : Integer;
					_weight : Decimal) : CM_WorkListEntry protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/04/2016	cnwma1	TFS-1486 JMT Mobile Apps - RecRel - Truck Loader Unloader
08/04/2024	navbs1  Bug 63516: STWO - Cars released against wrong CRO.
10/07/2024	navdap1	TFS 65129 PRP - Truck Loader app scan the coil throws error message code 79567
16/08/2024	navpw1	TFS: 65623 (65624) - Moved Method to CMIF_MobileGenericAgent so it can be used by Pack Load by Request App

*/

vars
	ti : CM_TrackedItem;
	release, jobRelease : CM_BulkRelease;
	assigned : Boolean;
begin
	ti :=_ti;
	
	if not ti.allBulkReleasesAssigned.isEmpty then 												//08.04.2024 navbs1 #63516
		// TFS 65129 If the cargo item is assigned to the release being loaded, allow it to be scanned and loaded,
		// even if it's not assigned to the current vehicle visit
		jobRelease := _job.getMyBulkRelease;
		assigned := false;
		foreach release in ti.allBulkReleasesAssigned where release = jobRelease do
			assigned := true;
		endforeach;
		if not assigned then
			app.raiseCMException2(ERR_TI_ALREADY_ALLOCATED, ti.id, ti.allBulkReleasesAssigned.first.code, null, null);
			return null;
		endif;
	endif;

	//epr TFS 36605 22/1/18 we should never acknowledge warnings without a user clicking a save dialog
	app.myTrxCA.trxCreateTIRequestForJob( _job, ti,false,_quantity,_weight, app.myPassport ); 		
		
	if app.myPassport.trxCompletedOK then
		return _job.getWLEForTI(ti);
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_RoadJob" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doImportGetJobWLE" id="f2fe9ce7-9a11-44fe-9cb5-1ff19e4308c1">
        <source>doImportGetJobWLE(	_ti : CM_TrackedItem input; 
					_job : CM_VoyageJob output;
					_wle : CM_WorkListEntry output; 
					_toGroundAllowed: Boolean; 
					_raiseError : Boolean;
					_quantity : Integer;
					_weight  : Decimal;
					_target : CM_LocationsController input	//25 Mar 2015	NDL	Par 35884
					) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 March 2016	cnwndl1	Initial creation
29 May	 2017	cnwma1	TFS #4310 ChangeRequest 4310:75664 error when using Lander App
24 July 2019	jlgzm1	TFS 42863 Direct Release Between RORO Voyages and Rail - Break Bulk Bulk
*/

vars
	voyage : CM_Voyage;
	currentLocation : CM_LocationsController;
	rtQueuetask : CM_RTQueueTask;
	rtQueueEntry : CM_RTQueueEntry;
	vehicle : CM_Vehicle;
	wle 	: CM_WorkListEntry;
begin
	//on CM_Exception do null;
	//on CM_Exception do self.validationExHandler(exception,app.myPassport);
	
	//14 June 2016	NDL	TFS 2156 - epr 15/11/16 moved from MOB_HHLanderCargoMove doComplete
	if _target &lt;&gt; null and _target.isVehicle then
		foreach wle in _ti.allWorklistEntries discreteLock do
				if wle.isRoad and wle.getTargetLocation() = _target then
					_wle :=wle;
					return true;
				endif;
		endforeach;
	endif;
	
	
	_job := _ti.getFirstAvailableDischargeJob();
	
	// TFS 42863 start
	if _job &lt;&gt; null and _target &lt;&gt; null and _target.isWagon then
		wle := _ti.getVoyageWLEForJobAndLC(_job, _target);
		if wle &lt;&gt; null then
			_wle := wle;
			return true;
		endif;
	endif;
	// TFS 42863 End
	
	//13 Apr 2015	NDL	Par 36021 - Now that we can use Planned and Non-planned in parallel, we might have a NWNP wle
	// as well as a completed Planned WLE.  DPH did this, i.e. planned and discharged from a LOLO slot, then NWNP'd it back to
	// voyage stack, before NWNP'ing off again. HH failed to find teh NWNP, because it found teh original Job, which it tried to use.
	if _job &lt;&gt; null then
		_wle := _ti.getVoyageWLEForJob(_job);
		if _wle &lt;&gt; null and _wle.isCompleteForJob then
			_job := null;
		endif;
	endif;
	
	//20 May 2010	NDL	Par23603
	if _job = null then
		//_wle := _ti.getVoyageWLEUnactioned( false );
		_wle := _ti.getVoyageWLEForLCUnactioned( false, _target );	//23 Jun 2016	NDL	TFS 2172
		if _wle &lt;&gt; null then
			_job := _wle.job.CM_VoyageJob;
		endif;
		//25 Mar 2015	NDL	Par 35884 - If there is a truck sucker floating around use it before creating a nwnp type.
		if _wle = null and _target &lt;&gt; null and _target.isVehicle then
			vehicle := _target.CM_VehicleController.vehicle;
			_wle := _ti.getIncompleteRoadWleForJob( vehicle, false );
		endif;
		
		// 24/09/2015 cnwma1 PAR #36808
		if _wle = null and _target &lt;&gt; null and _target.isVoyageController then
			//find first discharge wle for RORO job
			foreach wle in _ti.allWorklistEntries discreteLock do
				if not wle.isKindOf(CM_VoyageWLE) then
					continue;
				endif;
				if wle.CM_VoyageWLE.getVoyage &lt;&gt; _target.CM_VoyageController.myVoyage then
					continue;
				endif;
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if not wle.CM_VoyageWLE.isForLoadJob then
					continue;
				endif;
				_wle:=wle;
				break;
			endforeach;
		endif;
		
	endif;
//	if _job = null then
	if _job = null and _wle = null then	//25 Mar 2015	NDL	Par 35884
		currentLocation := _ti.myPrimaryActualLocation;
		voyage := self.myVoyage;
		if currentLocation &lt;&gt; null and voyage &lt;&gt; null then
			if currentLocation = voyage.myShipBlockStack or
			//epr par 34978 2/10/14
				(currentLocation.isKindOf(CM_GeneralCargoController) and currentLocation.CM_GeneralCargoController.myVoyage = voyage) then
				// it is unplanned unworked cargo, on the ship, try autoplaning and queuing it
				//epr par 36325 17/7/15
				self.doQueueUnplannedUnworkedCargo(_ti, _job, _wle,_quantity ,_weight,_target);
				
				//epr TFS 2732 refactored if was NWNP was always ignoring errors and continuing from //25 June 2012	NDL	Par 29745
				if not currentLocation.requiresJob then
					return true;
				endif;
				
				//21 Sep 2012	NDL	Par 30299
				if _ti.myPrimaryQueuedLocation = null and _job = null then
					if _raiseError then
						app.raiseCMException1(Failed_auto_plan,_ti.id.trimBlanks,null,null);
					endif;
					//msgStr := app.getErrorString1(Failed_auto_plan, _ti.id.trimBlanks);
					return false;
				endif;
			elseif currentLocation = voyage.myNotNotifiedStack then
				// this is a piece of cargo we have created on the fly
				if _ti.myVoyage &lt;&gt; null/* and not _ti.myVoyage.isCellularVoyage*/ then  //29/05/2017 cnwma1	 TFS #4310
					// conro or roro, just carry on...
					self.doQueueUnplannedUnworkedCargo(_ti, _job, _wle,_quantity ,_weight,_target);
					//21 Sep 2012	NDL	Par 30299
					if _ti.myPrimaryQueuedLocation = null and _job = null then
						if _raiseError then
							app.raiseCMException1(Failed_auto_plan,_ti.id.trimBlanks,null,null);
						endif;
						//msgStr := Failed_auto_plan.String &amp; " - " &amp; app.getErrorString1(Failed_auto_plan, _ti.id.trimBlanks);
						return false;
					endif;
				endif;
			elseif (currentLocation.isCraneLaneController or currentLocation.isWorkPointLaneController) then
				
				self.doQueueUnplannedUnworkedCargo(_ti, _job, _wle,_quantity ,_weight,_target);
				//21 Sep 2012	NDL	Par 30299
				if _ti.myPrimaryQueuedLocation = null and _job = null then
					if _raiseError then
						app.raiseCMException1(Failed_auto_plan,_ti.id.trimBlanks,null,null);
					endif;
				//	msgStr := app.getErrorString1(Failed_auto_plan, _ti.id.trimBlanks);
					return false;
				endif;
			//11 Jul 2012	NDL	Par 29961
			elseif ( currentLocation.isCraneLaneController  or ( currentLocation.isYardLocation and currentLocation.CM_YardController.isInterchangeAreaLocation )) then 
				if _toGroundAllowed then
					if _ti.isQueued then
						rtQueuetask := _ti.queueTask;
						if rtQueuetask &lt;&gt; null then
							if ( rtQueuetask.status = TASK_UNACTIONED )
							or ( rtQueuetask.isMove and ( rtQueuetask.status = TASK_OFFERED or rtQueuetask.status = TASK_ACCEPTED ))
							then
								rtQueueEntry := rtQueuetask.myEntry;
								if rtQueueEntry &lt;&gt; null 
								and rtQueueEntry.myJob &lt;&gt; null 
								// TFS 4859 and rtQueueEntry.myJob.isVoyageJob then
								and rtQueueEntry.myJob.isVoyageTypeJob() then // TFS 4859
									_job := rtQueueEntry.myJob.CM_VoyageJob;
									_wle := rtQueueEntry.myWorkListEntry;
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	//if _job = null then
	if _job = null and _wle = null then	//25 Mar 2015	NDL	Par 35884
		if _raiseError then
			app.raiseCMException2(ERR_TINOT_MACH_TYPE,_ti.id.trimBlanks, app.getErrorString(NoCompatibleJobFound), null, null); //29/05/2017 cnwma1 TFS #4310
		endif;
		//Error! Not a voyage Job
		//msgStr := ERR_TINOT_MACH_TYPE.String &amp; " - " &amp; app.getErrorString2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks, "Not Import");
		return false;					
	endif;
	
	if _wle = null then
		_wle := _job.getWLEForTI(_ti);
	endif;

	if _raiseError  and _wle = null then
		app.raiseCMException(Work_list_entry_found,null,null);
	endif;
	
	return (_wle &lt;&gt; null);
	

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_toGroundAllowed" type="Boolean"/>
        <Parameter name="_raiseError" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_target" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderDischarge" id="4bd6c1ec-2a0a-4146-b278-3be6e125a937">
        <updating/>
        <source>doLanderDischarge(	_ti : CM_TrackedItem input; 
					_dischargeLocation : CM_LocationsController input;
					_quantity : Integer;
					_weight  : Decimal) : Boolean updating;
/*

Date				Who		Reason
15 November 2016	cnwer1	Initial creation TFS 2732 refactored from method MOB_HHLanderCargoMove doComplete
19 November 2021	jlizm1	TFS 52028 Work hold jobs in handheld app

*/

vars
	currentLocation : CM_LocationsController;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	terminal : CM_Terminal;
	toGroundAllowed : Boolean;
begin
	on CM_Exception do self.validationExHandler(exception,app.myPassport);
	
	if _ti = null then
		 app.raiseCMException(No_Cargo_identified,null,null);
		return false;
	endif;
	
	//09 Jun 2020	NDL	TFS 49176
	if not _ti.isOnShip then
		app.raiseCMException1( Already_site, _ti.id, null, null );
		return false;
	endif;
	
	if _dischargeLocation = null then
		app.raiseCMException(PleaseSelectLocation,null,null);
		return false;
	endif;
	
	currentLocation := _ti.myPrimaryActualLocation;
	if _ti.myPrimaryActualLocation = _dischargeLocation then
		app.raiseCMException2(Cargo_already_located,_ti.id,_dischargeLocation.getFullId(),null,null);
		return false;
	endif;
	
	terminal:= _ti.myTerminal;
	if self.myVoyage = null then
		self.myVoyage := _ti.myVoyage;
	endif;
	
	if _ti.isOnLOLONotNotifiedStack and not _ti.isQueued then
		return self.doLanderDischargeOfNotNotified(_ti, _dischargeLocation);
	endif;
	
	if not self.validateLanderDischarge(_ti, _dischargeLocation) then
		return false;
	endif;
	
	if  _dischargeLocation.isMachineController then
		// ### TFS 51988 07OCT2021 NAVAB1 - Is splitable and is about to be split, because the quantity being moved is less than the quantity of the cargo
		
		if _ti.isShipDishForSplitMerge(_quantity, _dischargeLocation) then // ### TFS 51988 13OCT2021 NAVAB1
			return self.doLanderDischargeToMach4Split(_ti, _dischargeLocation,_quantity,_weight);  // ### TFS 51988 07OCT2021 NAVAB1
		
		else  // ### TFS 51988 07OCT2021 NAVAB1
			return self.doLanderDischargeToMachine(_ti, _dischargeLocation,_quantity,_weight);
		
		endif;
	endif;
	
	if self.dischargeToHHOption &lt;&gt; DiscHHLander_ToMach then
		toGroundAllowed := self.hhLanderGroundingOpt &lt;&gt; NoOpts;
	endif;
	
	if self.myJob &lt;&gt; null and self.myJob.isKindOf(CM_VoyageJob) then
		// Already have a Job, just need to find the appropriate WLE
		wle := _ti.getVoyageWLEForJobAndLC(self.myJob.CM_VoyageJob, _dischargeLocation);
	else
		self.doImportGetJobWLE(_ti, job, wle, toGroundAllowed,false,_quantity,_weight, _dischargeLocation); //epr TFS 4113 26/4/17
	endif;
	
	if not self.moveTI( _ti, null, _dischargeLocation, wle, false, _quantity, _weight, null ) then
		return false;
	endif;
	
	self.setSplitValues( 0, 0, null );
	return true;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dischargeLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderDischargeOfNotNotified" id="6d4482a0-07c4-43de-8e0c-283774eb4f98">
        <updating/>
        <source>doLanderDischargeOfNotNotified( _ti : CM_TrackedItem input;
								_location : CM_LocationsController ):Boolean protected, updating;
/*

Date		Who		Reason
15 November 2016	cnwer1	Initial creation TFS 2732

*/

vars
	machine : CM_Machine;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	errMess : String;

begin

	if not self.doQueueUnnotifiedCargo(_ti, job, wle) then
		return false;
	endif;

	if _location.isMachineController then
	
		machine := _location.CM_MachineController.myMachine;
		app.myPassport.clearErrorsWarnings();
		app.autoPlanAlertOverride(app.myPassport.myTerminal);
		
		app.myTrxUA.trxUpdateShipMoveImport(machine, _ti, wle, job,null,null, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			if self.doNotShowMsgBox then	
				return false;
			endif;
			
			//errMess := app.myPassport.getErrorsAsString;
			errMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
			self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;	
		endif;
		
		self.setSplitValues( 0, 0, null );
		return true;
		
	else

		// no machine involved, straight instant move. 
		wle := null;// going to ground, want to leave it queued, so do not pass in the wle.
		if not self.moveTI( _ti, null, _location, wle, false, 0, 0, null ) then
			return false;
		endif;
		
		return true;
	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderDischargeToGround" id="5f320fe8-ad0a-4221-b95e-e92e51e4a32f">
        <updating/>
        <source>doLanderDischargeToGround(_ti : CM_TrackedItem input; 
					_dischargeLocation : CM_LocationsController input;
					_groundOption  : Integer;
					_quantity : Integer;
					_weight  : Decimal) : Boolean updating;
/*

Date		Who		Reason
10/11/2016	cnwer1	Initial creation TFS
15/01/2017	jlgdap1	TFS 36405 SNO Non-worked non-planned move done via lander was causing an error 4
*/

vars
	currentLocation : CM_LocationsController;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	result: Boolean;
//	invalidJob : Boolean;					// TFS 36405
//	id : String;							// TFS 36405
	
begin
	
	on CM_Exception do self.validationExHandler(exception,app.myPassport);
			
	if _ti = null then
		 app.raiseCMException(No_Cargo_identified,null,null);
		return false;
	endif;
	
	if _dischargeLocation = null then
		app.raiseCMException(PleaseSelectLocation,null,null);
		return false;
	endif;
	
	if self.myVoyage = null then
		self.myVoyage := _ti.myVoyage;
	endif;
	
	currentLocation := _ti.myPrimaryActualLocation;
	if _ti.myPrimaryActualLocation = _dischargeLocation then
		app.raiseCMException2(Cargo_already_located,_ti.id,_dischargeLocation.getFullId(),null,null);
		return false;
	endif;
	
	//requiredCheck := self.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_SHIP_DISC,_ti,subCargo);
	//the checks have to be done in a seperate method before getting here 
	if not self.validateLanderDischarge(_ti, _dischargeLocation) then
		return false;
	endif;
	
	if not self.doImportGetJobWLE( _ti, job, wle, true, true, _quantity, _weight, _dischargeLocation ) then
		return false;
	endif;	
		
	//27 May 2013	NDL	CCMS 2274
	self.setSplitValues( 0, 0, null );
	
	result := self.moveTIToGround(_groundOption, _ti, _dischargeLocation, job, wle, _quantity, _weight);
	
	/* 02 Feb 2018	NDL	TFS 36879 - Migrated up into the CM_TrxControlUpdateAgent::trxLanderDischargeToGround
	//                              which is called in self.moveTIToGround, so its all in one trx...
	// self.moveTIToGround can delete the job and wle if the move was a non-planned non-worked move	// TFS 36405
	// This leads to an invalid object exception in self.rePlanTi below								// TFS 36405
	on Exception do app.handleDeletedObject(exception, job, invalidJob);							// TFS 36405
	id := job.id;																					// TFS 36405
	if invalidJob then																				// TFS 36405
		job := null;																				// TFS 36405
	endif;																							// TFS 36405
	
	if _groundOption = GroundInTransit and not _ti.isQueued and not currentLocation = self.myVoyage.myNotNotifiedStack then	//11 Jul 2012	NDL	Par 29961
		if _ti.isPlanned(PLANNING_MODE) then	//13 Aug 2012	NDL	Par 29961
			self.doPromotePlannedToQueued( _ti, wle );
		else
			self.rePlanTi( _ti, job, _groundOption );
		endif;
	endif;
	*/

	return result;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dischargeLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_groundOption" type="Integer"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderDischargeToMach4Split" id="4cfe27a5-f2e5-40a6-8e79-04111434729c">
        <updating/>
        <source>doLanderDischargeToMach4Split(	_ti : CM_TrackedItem input; 
							_dischargeLocation : CM_LocationsController input;
							_quantity : Integer;
							_weight  : Decimal)  : Boolean updating, protected;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51988
*/

vars
	machine : CM_Machine;
	voyJob : CM_VoyageJob;
	wle : CM_WorkListEntry;
begin
	if _dischargeLocation = null or not _dischargeLocation.isMachineController then
		return false;
	endif;
	
	
	machine := _dischargeLocation.CM_MachineController.myMachine;
	
	app.myPassport.clearErrorsWarnings();

 	voyJob := _ti.getFirstAvailableDischargeJob();
	wle := _ti.getVoyageWLEUnactioned(false);

	
	app.myTrxUA.trxUpdateShipMoveImport4Split(machine, _ti, wle, voyJob,_quantity,_weight, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		if self.doNotShowMsgBox then	
			return false;
		endif;
		
		self.msgBox( app.myPassport.getAllErrorsWarningsAsString, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;
	return true;
epilog	

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dischargeLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderDischargeToMachine" id="73822914-d564-4ac0-aed6-166342aea1a0">
        <updating/>
        <source>doLanderDischargeToMachine(	_ti : CM_TrackedItem input; 
							_dischargeLocation : CM_LocationsController input;
							_quantity : Integer;
							_weight  : Decimal)  : Boolean updating, protected;
/*

Date		Who		Reason
15 November 2016	cnwer1	Initial creation TFS 2732

*/

vars
	machine : CM_Machine;
	voyJob : CM_VoyageJob;
	wle : CM_WorkListEntry;
begin
	if _dischargeLocation = null or not _dischargeLocation.isMachineController then
		return false;
	endif;
	
	
	machine := _dischargeLocation.CM_MachineController.myMachine;
	
	app.myPassport.clearErrorsWarnings();
	app.autoPlanAlertOverride(app.myPassport.myTerminal);
			
	//epr par 35893 CCMS 1411 20/3/15
	app.myTrxUA.trxDischargeCargoAutoPlan(machine,_ti,_quantity, _weight,voyJob, wle,app.myPassport);
	
	if wle = null then
		if   _ti.myPrimaryPlannedLocation = null then
			 app.raiseCMException1(Failed_auto_plan, _ti.id.trimBlanks,null,null);
			 return false;
		endif;
	
		app.raiseCMException(Work_list_entry_found,null,null);
		
		return false;
	endif;
	

	app.myTrxUA.trxUpdateShipMoveImport(machine, _ti, wle, voyJob,_quantity,_weight, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		if self.doNotShowMsgBox then	
			return false;
		endif;
		
		self.msgBox( app.myPassport.getAllErrorsWarningsAsString, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;
	return true;
epilog	

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dischargeLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderDischargeToRail" id="223c8bda-0522-461b-afdc-e1689af9ce5c">
        <updating/>
        <source>doLanderDischargeToRail(_ti : CM_TrackedItem input; 
						_dischargeLocation : CM_LocationsController input;
						_quantity : Integer;
						_weight  : Decimal;
						_effectiveDate : TimeStamp) : Boolean updating;
/*

Date		Who		Reason
26 January 2017	cnwer1	Initial creation TFS
13 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
04 Feb 2025	navhl20 Bug MTN-33956: The moved transaction date/time is not displaying the effective date and time that is set on the wagon
*/

vars
	currentLocation		: CM_LocationsController;
	otherDDWLE,wle		: CM_WorkListEntry;
	job					: CM_Job;					// ### TFS 62857 (62858) 15Mar2024 NAVPW1
	objAss				: CM_Association;
	obj					: Object;
begin
	on CM_Exception do self.validationExHandler(exception,app.myPassport);
	
	if _ti = null then
		 app.raiseCMException(No_Cargo_identified,null,null);
		return false;
	endif;
	
	if _dischargeLocation = null then
		app.raiseCMException(PleaseSelectLocation,null,null);
		return false;
	endif;
	
	currentLocation := _ti.myPrimaryActualLocation;
	if _ti.myPrimaryActualLocation = _dischargeLocation then
		app.raiseCMException2(Cargo_already_located,_ti.id,_dischargeLocation.getFullId(),null,null);
		return false;
	endif;
	
	if _dischargeLocation.isVehicle and not _ti.directDelivery then	
		app.raiseCMException1(Truck_Land_Not_Allowed, _dischargeLocation.getFullId ,null,null);
		
		return false;
	endif;
	
	if _dischargeLocation.isVoyageController and not _ti.directDelivery then	
		app.raiseCMException1(Not_land_directl_voyage, _dischargeLocation.getFullId ,null,null);	
		return false;
	endif;
	
	// ### TFS 62857 (62858) 15Mar2024 NAVPW1
	if app.myRoot.canDo(Sub_RetroWorkOrder) then
		wle := _ti.getRailWLEForLC(false, _dischargeLocation);
		
		if wle = null then
			return false;
		endif;
		
		job := wle.job;
		
		if job = null then
			return false;
		endif;
		
	// ### TFS 62857 (62858) 15Mar2024 NAVPW1
		
	else
		wle:=_ti.getRailWLEForLC(false,_dischargeLocation);
		if _ti.directDelivery then
			if not self.validateLanderDischargeDD(_ti,wle,otherDDWLE,_dischargeLocation) then
				return false;
			endif;
			if wle.getTargetLocation = null and otherDDWLE.getTargetLocation = _dischargeLocation then
				wle := otherDDWLE;
			endif;
		endif;
	endif;
	
	if _effectiveDate &lt;&gt; null then						//13.06.2024 navhl20 #64602
		create objAss transient;						//04.02.2025 navhl20 #33956
		objAss.setValue(_effectiveDate);				//04.02.2025 navhl20 #33956
		obj := objAss;									//04.02.2025 navhl20 #33956
	else												//04.02.2025 navhl20 #33956
		obj := job;
	endif;
	
	if not self.moveTI( _ti, null, _dischargeLocation, wle, false, _quantity, _weight, obj ) then
		return false;
	endif;
	
	self.setSplitValues( 0, 0, null );
	return true;
epilog
	delete objAss;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dischargeLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_effectiveDate" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderDischargeToYard" id="26b9aa2b-c9cb-411e-a4b6-d340ee32eb06">
        <updating/>
        <source>doLanderDischargeToYard(_ti : CM_TrackedItem input; 
						_dischargeLocation : CM_LocationsController input;
						_quantity : Integer;
						_weight  : Decimal) : Boolean updating;
/*

Date		Who		Reason
25 January 2017	cnwer1	Initial creation TFS 1487

*/

vars
	currentLocation : CM_LocationsController;
	wle : CM_WorkListEntry;
	terminal : CM_Terminal;
begin
	on CM_Exception do self.validationExHandler(exception,app.myPassport);
	
	if _ti = null then
		 app.raiseCMException(No_Cargo_identified,null,null);
		return false;
	endif;
	
	if _dischargeLocation = null then
		app.raiseCMException(PleaseSelectLocation,null,null);
		return false;
	endif;
	
	currentLocation := _ti.myPrimaryActualLocation;
	if _ti.myPrimaryActualLocation = _dischargeLocation then
		app.raiseCMException2(Cargo_already_located,_ti.id,_dischargeLocation.getFullId(),null,null);
		return false;
	endif;
	
	//29 Apr 2010	NDL	Par 23945
	if self.myBOL &lt;&gt; null then
		if not self.myBOL.allTrackedItems.includes( _ti ) then
			app.raiseCMException2(Not_part_of_BOL,_ti.id,self.myBOL.number,null,null);
			return false;
		endif;
	endif;
	
	terminal:= _ti.myTerminal;
	if self.myVoyage = null then
		self.myVoyage := _ti.myVoyage;
	endif;
	
	wle := _ti.getVoyageWLEForLCUnactioned( false, _dischargeLocation );	//23 Jun 2016	NDL	TFS 2172
	
	if not self.moveTI( _ti, null, _dischargeLocation, wle, false, _quantity, _weight, null ) then
		return false;
	endif;
	
	self.setSplitValues( 0, 0, null );
	return true;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dischargeLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderDischargeWOJob" id="5aae0531-0331-4821-a9ac-922be6c06b2b">
        <updating/>
        <source>doLanderDischargeWOJob(	_ti 			   : CM_TrackedItem input; 
						_dischargeLocation : CM_LocationsController input;
						_quantity 		   : Integer;
						_weight  		   : Decimal) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	moveController 			: CMIF_MoveController;
	listObject 				: CM_Object;
	ta 						: CM_TerminalArea;
	gridObject				: CM_GridObject;
	requiresJob 			: Boolean;
	wle,
	myWle,
	voyWle					: CM_WorkListEntry;
	result 					: Integer;
	showMoveConfirmation	: Boolean;
	job						: CM_Job;
	currentLocation 		: CM_LocationsController;
begin
	on CM_Exception do self.validationExHandler(exception,app.myPassport);
	
	if _ti = null then
		 app.raiseCMException(No_Cargo_identified,null,null);
		return false;
	endif;
	
	if not _ti.isOnShip then
		app.raiseCMException1( Already_site, _ti.id, null, null );
		return false;
	endif;
	
	if _dischargeLocation = null then
		app.raiseCMException(PleaseSelectLocation,null,null);
		return false;
	endif;
	
	currentLocation := _ti.myPrimaryActualLocation;
	if _ti.myPrimaryActualLocation = _dischargeLocation then
		app.raiseCMException2(Cargo_already_located,_ti.id,_dischargeLocation.getFullId(),null,null);
		return false;
	endif;
	
	if not self.validateLanderDischarge(_ti, _dischargeLocation) then
		return false;
	endif;
	
	if  _dischargeLocation.isMachineController then
		if _ti.isShipDishForSplitMerge(_quantity, _dischargeLocation) then
			return self.doLanderDischargeToMach4Split(_ti, _dischargeLocation,_quantity,_weight);
		else
			return self.doLanderDischargeToMachine(_ti, _dischargeLocation,_quantity,_weight);
		endif;
	endif;
	
	job := self.myJob;
	
	if job.isKindOf(CM_VoyageWorkPointJob) then
		self.myJob := job.CM_VoyageWorkPointJob.myWorkOrderReceiveJob;
	endif;
	
	if self.myJob = null then
		return false;
	endif;
	
	foreach wle in self.myJob.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		if wle.myTrackedItem = _ti then
			myWle := wle;
		endif;
	endforeach;
	
	if not self.moveTI( _ti, null, _dischargeLocation, myWle, false, _quantity, _weight, job ) then
		return false;
	endif;

	self.setSplitValues( 0, 0, null );
	return true;
epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dischargeLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderLoad" id="4e366b9f-783e-41d4-99ed-8697daf3c046">
        <updating/>
        <source>doLanderLoad(	_ti : CM_TrackedItem input;
				_loadLocation : CM_LocationsController input;
				_selectedWle : CM_WorkListEntry input;
				_quantity : Integer;
				_weight  : Decimal) : Boolean  updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
15 Nov 2016	cnwer1	TFS 2732	Initial creation 
31 Jan 2017	cnwma1	TFS #3258	PAR38589 QNS - Pregate cargo loading to vessel
24 Jul 2019	jlgzm1 				Direct Release Between RORO Voyages and Rail - Break Bulk Bulk
01 Oct 2019 jlgka1 	TFS 46600 	PEL1 - Loading break-bulk PreNote to ship using Job Lander
28 Jan 2020	jlgka1	TFS 45987 - JMT - Lander Apps WLE Picker
21 Oct 2021	navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
07 Dec 2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
21 Feb 2022	navdap1	TFS 52801 SAL Direct Delivery - End of Shift Job Transfer
11 Jul 2022	jlizm1	TFS 53960 	Out of sequence load jobs error when target location different than planned
============================================================================*/

vars
	allWles 		  	: CM_WLEArray;
	otherDDWle,
	wle 			  	: CM_WorkListEntry;
	currentLocation   	: CM_LocationsController;
	forceWLESelection 	: Boolean;
	qLocation 			: CM_LocationsController; 
	qwle 				: CM_WorkListEntry;
	isVoyageNonWorked,
	useYardWle 			: Boolean;
	moveController 		: CMIF_MoveController;	//09 May 2017	NDL	TFS 3045
	reserveDetail 		: CM_ReserveDetail;
	bulkRelease 		: CM_BulkRelease;
	context 			: Object;
	tmpWLE				: CM_WorkListEntry; // TFS 42863
begin
	
	on CM_Exception do self.validationExHandler(exception, app.myPassport);
	if _ti = null then
		 app.raiseCMException(No_Cargo_identified,null,null);
		return false;
	endif;
	
	if _loadLocation = null then
		app.raiseCMException(PleaseSelectLocation,null,null);
		return false;
	endif;
	
	if self.myVoyage = null then
		self.myVoyage := _ti.myVoyage;
	endif;
	
	currentLocation := _ti.myPrimaryActualLocation;
	if _ti.myPrimaryActualLocation = _loadLocation then
		app.raiseCMException2(Cargo_already_located,_ti.id,_loadLocation.getFullId(),null,null);
		return false;
	endif;	
		
	create allWles transient;
	if not _ti.getVoyageWLEforLanderLoad(wle,_selectedWle,self.myVoyage,allWles, _loadLocation) then
		if allWles.size &gt; 1 then
			//TIs for direct release could potentially have multiple wles,
			//Try to find one that matches the load location
			foreach tmpWLE in allWles do								// TFS 42863
				if tmpWLE.isDRLinkedByFM and							// TFS 42863
				   tmpWLE.getTargetLocation() = _loadLocation then		// TFS 42863
					wle := tmpWLE;										// TFS 42863
					break;												// TFS 42863
				endif;													// TFS 42863
			endforeach;													// TFS 42863
			if wle = null then
				app.raiseCMException(Must_Select_Job,null,null);
				return false;
			endif;
		endif;
	endif;
	
	if not self.validateLanderLoadLocation(_loadLocation, _ti, wle) then
		return false;
	endif;
	
	if _ti.directDelivery then
		if not self.validateLanderLoadDD(_ti,wle,otherDDWle) then
			return false;
		endif;
		// TFS 52801 Don't swap the WLEs here if the otherDDWle was created after this TI was received - this covers the situation
		// where a planned prenote has been removed from a job while some cargo was still onsite, then planned to a new job along
		// with the onsite cargo. In this case the WLE we want to use is the actual onsite WLE
		//if self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean and otherDDWle.getTargetLocation = _loadLocation then	// TFS 51935	// TFS 52293
		if otherDDWle.job &lt;&gt; null and otherDDWle.job.isDirectDeliveryJob and otherDDWle.getTargetLocation = _loadLocation 		// TFS 51935	// TFS 52293
		and otherDDWle.createdTime &lt; _ti.receivedDT then			// TFS 52801
			wle := otherDDWle;																									// TFS 51935
		elseif wle.getTargetLocation = null and otherDDWle.getTargetLocation = _loadLocation then
			wle := otherDDWle;
		endif;
	endif;
	
	//09 May 2017	NDL	TFS 3045 - derived wle from director task where ti is on release
	if wle = null and _ti.myPrimaryPlannedLocation = null and _selectedWle &lt;&gt; null then
		if _selectedWle.isTiAssignedToResDet( _ti ) then
			wle := _selectedWle;
			create moveController transient;
			moveController.setMyToPrimaryLocation(wle.getTargetLocation);
			moveController.setMyWorkListEntry(wle);
			moveController.setJobForMove(wle.job);
			moveController.setMyTrackedItem(_ti);
			moveController.setMoveMode(PLANNING_MODE);
			moveController.setIsFromWeb(self.isFromWeb); // jlgka1 TFS 46600
			
			while true do
				app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
				if app.myPassport.trxCompletedOK then
					app.myPassport.clearErrorsWarnings();
					break;
				else
					if app.myPassport.noErrors then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				return false;
			endwhile;
		endif;
	endif;
		
	if wle = null then
		// if there isn't a voyage related one, check for a yard wle.
		// If we DON'T find one, that's ok just carry on
		// if we DO find a yard wle targetting a crane transfer area do this as a separate move first.
		// But if we find a yard wle targetting somewhere else, raise an error.
		qwle := _ti.getIncompleteYardWleInRTQueue();
		isVoyageNonWorked:=self.myVoyage.isHOLDSorSHIP();
		
		
		if qwle &lt;&gt; null then
			//07 Aug 2013	NDL	Par 32152
			useYardWle := isVoyageNonWorked and ( _ti.myPrimaryActualLocation.isVehicle or _ti.myPrimaryActualLocation.isWagon );
			
			qLocation := qwle.CM_YardWLE.getTargetLocation;
			//if not qLocation.isCraneLaneController then
			
			//31/01/2017 cnwma1 TFs #3258
			if qwle &lt;&gt; null and useYardWle then
				if qwle.job &lt;&gt; null and qwle.job.isKindOf(CM_RoadJob) then
					if qwle.job.CM_RoadJob.myVehicleVisit &lt;&gt; null then
						if not qwle.job.CM_RoadJob.myVehicleVisit.vehicle.myPrimaryActualLocation.isInsideYard then
							app.raiseCMException2(Receival_Wle_Exists, app.getErrorString(XLAT_Road_operations), _ti.id, null, self);
							return false;
						endif;
					endif;
				endif;
			endif;
				
			if not qLocation.isCraneLaneController and not useYardWle then	//07 Aug 2013	NDL	Par 32152
				app.raiseCMException3(Move_not_permit_while_queued, _loadLocation.getFullId, _ti.id, qLocation.getFullId,null,null);
				return false;
			else
				// shift to the crane transfer area via the yard wle
				//epr  par 33223 3/2/14 changed to use the location entered in the lander not the wle queued location
				return  self.moveTI( _ti, null, _loadLocation, qwle, false, _quantity, _weight, null );   //20/10/2014 cnwma1 PAR #35011
				
			endif;
		else
			
			//epr par  32868 30/10/13
			if _ti.myPrimaryActualLocation.isVehicle and isVoyageNonWorked then
				//find road wle 
				wle:=_ti.getIncompleteRoadWleForJob(_ti.myPrimaryActualLocation.CM_VehicleController.vehicle,true);
				
				//31/01/2017 cnwma1 TFs #3258
				if wle &lt;&gt; null and wle.isKindOf(CM_YardWLE) then
					if wle.job &lt;&gt; null and wle.job.isKindOf(CM_RoadJob) then
						if wle.job.CM_RoadJob.myVehicleVisit &lt;&gt; null then
							if not wle.job.CM_RoadJob.myVehicleVisit.vehicle.myPrimaryActualLocation.isInsideYard then
								app.raiseCMException2(Receival_Wle_Exists, app.getErrorString(XLAT_Road_operations), _ti.id, null, self);
								return false;
							endif;
						endif;
					endif;
				endif;
				
			endif;
		endif;
	endif;
	
	//16 Oct 2013	NDL	Par 32805
	if not self.validateLanderLoadDPH(_ti, _loadLocation ) then
		return false;
	endif;
	
	//27 Nov 2017	NDL	TFS 8026 - So that moving assigned cargo in increments knows who to
	// reassign the cargo to after the split
	context := null;
	if _ti.canSplitTotalQuantity then
		if  wle &lt;&gt; null and wle.myRequest &lt;&gt; null then
			reserveDetail := wle.myRequest.myReserveDetail;
		elseif wle = null and _ti.allReserveDetails.size = 1 then
			reserveDetail :=_ti.allReserveDetails.first;
		endif;
		if reserveDetail &lt;&gt; null then
			bulkRelease :=  reserveDetail.myReserveHeader;
			if bulkRelease = null or not bulkRelease.isShipType then
				reserveDetail := null;
			endif;
		endif;
		if reserveDetail &lt;&gt; null then
			if self.checksState = self.ShipLoadCargo then
				context := reserveDetail;
			elseif self.checksState = self.ShipDischargeCargo then
				if reserveDetail &lt;&gt; null then
					context := bulkRelease;
				endif;
			endif;
		endif;
	endif;
	
	if not self.moveTI( _ti, null, _loadLocation, wle, false, _quantity, _weight, context ) then
		return false;
	endif;
				
	self.setSplitValues( 0, 0, null );
	return true;
	
epilog

	delete allWles;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_loadLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_selectedWle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderLoadToRail" id="c46c0eba-2af2-4d55-967e-29859a3523a0">
        <updating/>
        <source>doLanderLoadToRail(	_ti : CM_TrackedItem input;
					_loadLocation : CM_LocationsController input;
					_selectedWle : CM_WorkListEntry input;
					_quantity : Integer;
					_weight  : Decimal) : Boolean  updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
26 Jan 2017	cnwer1	TFS 2532	Initial creation 
01 Oct 2019 jlgka1 	TFS 46600 	PEL1 - Loading break-bulk PreNote to ship using Job Lander
============================================================================*/

vars
	allWles 			: CM_WLEArray;
	otherDDWle,
	wle 				: CM_WorkListEntry;
	currentLocation 	: CM_LocationsController;
	forceWLESelection 	: Boolean;
	qLocation 			: CM_LocationsController; 
	qwle 				: CM_WorkListEntry;
	isVoyageNonWorked,
	useYardWle 			: Boolean;
	moveController 		: CMIF_MoveController;
	result 				: Integer;
begin
	on CM_Exception do self.validationExHandler(exception,app.myPassport);
	if _ti = null then
		 app.raiseCMException(No_Cargo_identified,null,null);
		return false;
	endif;
	
	if _loadLocation = null then
		app.raiseCMException(PleaseSelectLocation,null,null);
		return false;
	endif;
	
	if self.myVoyage = null then
		self.myVoyage := _ti.myVoyage;
	endif;
	
	currentLocation := _ti.myPrimaryActualLocation;
	if _ti.myPrimaryActualLocation = _loadLocation then
		app.raiseCMException2(Cargo_already_located,_ti.id,_loadLocation.getFullId(),null,null);
		return false;
	endif;	
	
	if not _loadLocation.isWagon then	//27 May 2013	NDL	Part of Boxcar conversion
		 app.raiseCMException(Location_must_rail,null,null);
		 return false;
	endif;
	
	//12 Sep 2013	NDL	Par 32452
	if _loadLocation.CM_WagonController.myWagon.myTrainOutwards &lt;&gt; self.myCurrentWagon.myTrainOutwards then
			app.raiseCMException(Load_locat_must_contr_selec_wa,null,null);
			 return false;
	endif;
	
	create allWles transient;
	if not _ti.getRailWLEForLanderLoad(wle,_selectedWle,self.myCurrentWagon,_loadLocation,allWles) then
		if allWles.size &gt; 1 then
			app.raiseCMException(Must_Select_Job,null,null);
			return false;
		endif;
	endif;	
	
	if _ti.directDelivery then
		if not self.validateLanderLoadDD(_ti,wle,otherDDWle) then
			return false;
		endif;
		if wle.getTargetLocation = null and otherDDWle.getTargetLocation = _loadLocation then
			wle := otherDDWle;
		endif;
	endif;
	
	//02 Feb 2016	NDL	Par 37492
	if wle &lt;&gt; null and wle.myTrackedItem = null then
		// This is a RAIL director task
		create moveController transient;
		moveController.setMyWorkListEntry(wle);
		moveController.setMyToPrimaryLocation(_loadLocation); 
		moveController.setMyTrackedItem(_ti);
		moveController.setIsFromWeb(self.isFromWeb); // jlgka1 TFS 46600
		
		if _quantity &lt;&gt; 0 then
			moveController.setQuantity(_quantity);
		endif;
		if _weight &lt;&gt; 0 then
			moveController.setWeight(_weight);
		endif;
		
		while true do
			app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);			
			
			if not app.myPassport.trxCompletedOK then
				if self.doNotShowMsgBox then	
					return false;
				endif;					
				result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, 20); // 20 = ErrWarnMode_Update + ErrWarnMode_CanAckWarnings
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					moveController.setEffectiveTimeStampOverride(app.actualTimeServer());	//04Sep2012	cnwrs1	Par30321	if the trx is to be retried then setup the effective date again	
					continue;
				endif;
			endif;
			break;
		endwhile;
		
		return result = IDOK;		
	endif;

	if not self.moveTI( _ti, null, _loadLocation, wle, false, _quantity, _weight, null ) then
		return false;
	endif;
		
			
	self.setSplitValues( 0, 0, null );
	return true;
epilog
	delete allWles;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_loadLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_selectedWle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderLoadWOJob" id="8f68af56-857b-4d13-9227-c2c67d460ac0">
        <updating/>
        <source>doLanderLoadWOJob(	_ti 		  : CM_TrackedItem input;
					_loadLocation : CM_LocationsController input;
					_selectedWle  : CM_WorkListEntry input;
					_quantity 	  : Integer;
					_weight  	  : Decimal) : Boolean  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
12 Mar 2024 navhl20 ChangeRequest 62734: EUP | Ship Operations in DD - [54176.060] - [Release] Retrospective Operations
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle,
	myWle			: CM_WorkListEntry;
	job				: CM_Job;
	pxyJob			: CM_VoyageWorkPointJob;
	currentLocation : CM_LocationsController;
begin
	on CM_Exception do self.validationExHandler(exception, app.myPassport);
	if _ti = null then
		 app.raiseCMException(No_Cargo_identified,null,null);
		return false;
	endif;
	
	if _loadLocation = null then
		app.raiseCMException(PleaseSelectLocation,null,null);
		return false;
	endif;
	
	if self.myVoyage = null then
		self.myVoyage := _ti.myVoyage;
	endif;
	
	currentLocation := _ti.myPrimaryActualLocation;
	if _ti.myPrimaryActualLocation = _loadLocation then
		app.raiseCMException2(Cargo_already_located,_ti.id,_loadLocation.getFullId(),null,null);
		return false;
	endif;
	
	job := self.myJob;
	if job.isKindOf(CM_VoyageWorkPointJob) then
		self.myJob := job.CM_VoyageWorkPointJob.myWorkOrderReleaseJob;
	endif;
	
	if self.myJob = null then
		return false;
	endif;
	
	if not self.validateLanderLoadLocation(_loadLocation, _ti, wle) then
		return false;
	endif;
	
	foreach wle in self.myJob.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		if wle.myTrackedItem = _ti then
			myWle := wle;
		endif;
	endforeach;
	
	if myWle = null then							//12.03.2024 navhl20 #62734
		myWle := self.myJob.workListEntries.first;
	endif;
	
	if not self.moveTI( _ti, null, _loadLocation, myWle, false, _quantity, _weight, job ) then
		return false;
	endif;

	self.setSplitValues( 0, 0, null );
	return true;
epilog
	delete pxyJob;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_loadLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_selectedWle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLanderSOB" id="89a9f887-8404-4fbf-ae5c-03e1aee7114a">
        <updating/>
        <source>doLanderSOB(	_ti : CM_TrackedItem input; 
				_sobLocation : CM_LocationsController input;
				_quantity : Integer;
				_weight  : Decimal;
				_isCargoLander: Boolean	//26/10/2022 navmv20 TFS 51643
				) : Boolean updating;
/*

Date		Who		Reason
15 November 2016	cnwer1	Initial creation TFS 2732
26 October  2022    navmv20 Bug 51643: MTN - Cargo Lander Shift on board gives error about not having a job
*/

vars
	wle : CM_VoyageWLE;
begin
	
	on CM_Exception do self.validationExHandler(exception,app.myPassport);
	
	if _ti = null then
		 app.raiseCMException(No_Cargo_identified,null,null);
		return false;
	endif;
	
	
	if _sobLocation = null then
		app.raiseCMException(PleaseSelectLocation,null,null);
		return false;
	endif;
	
	if not self.validateLanderLoadLocation(_sobLocation, _ti, null) then
		return false;
	endif;
	
	wle := _ti.getVoyageWLEForLCUnactioned( false, _sobLocation );
	
	//if not self.validateLanderSOBDetails(_ti,wle,_sobLocation.getFullId) then //26/10/2022 navmv20 TFS 51643
	if not self.validateLanderSOBDetails(_ti,wle,_sobLocation.getFullId,_isCargoLander) then //26/10/2022 navmv20 TFS 51643
		return false;
	endif;
	
	if not self.moveTI( _ti, null, _sobLocation, wle, false, _quantity, _weight, null ) then
		return false;
	endif;
	
	
	self.setSplitValues( 0, 0, null );
	return true;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_sobLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_isCargoLander" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMergeCargo" id="21cec617-11df-43a8-adaf-38b365e32b36">
        <updating/>
        <source>doMergeCargo(_myCargo :CM_Cargo ;allTisToMerge:CM_TISet )  : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2016	cnwns1	Initial creation

*/

vars

//	allTisToMerge : CM_TISet;
	ti : CM_TrackedItem;
	index : Integer;
	theReturn : Integer;
	lCargo :CM_Cargo; 
begin

//	create allTisToMerge transient;
	//foreach index in 2 to self.tblProspects.rows do
	//	if self.tblProspects.accessCell(index, 1).text = "1" then
	//		ti := self.tblProspects.accessRow(index).itemObject.CM_TrackedItem;
	//		if ti &lt;&gt; null then
	//			allTisToMerge.add(ti);
	//		endif;
	//	endif;
	//endforeach;
	
	lCargo := _myCargo;
	if not allTisToMerge.isEmpty and lCargo &lt;&gt; null then
		while true do 
			
			app.myTrxUA.trxMergeBreakBulk(	lCargo,	//_targetTi : CM_BreakBulkGeneric;
											allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
											app.myPassport	//_passport : CM_Passport input
											);
			if app.myPassport.trxCompletedOK then
				return true;
			else
				//epr TFS 2732 21/11/16 
				if self.doNotShowMsgBox then	
					return false;
				endif;
				
				theReturn := app.showErrorWarningDialog(app.getErrorString(Merge_breakbulk), app.myPassport, 4 /*ErrWarnMode_AddUpdate FIX THIS*/ + 16 /*ErrWarnMode_CanAckWarnings FIX THIS*/);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return false;
			endif;
			return false;
		endwhile;
	endif;
		return false;
	
end;</source>
        <Parameter name="_myCargo" type="CM_Cargo"/>
        <Parameter name="allTisToMerge" type="CM_TISet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPackCargo" id="bcc41787-546e-4a09-a9c1-5e5307f46003">
        <source>doPackCargo(	_parentCargo : CM_TrackedItem input;
				_packCargo : CM_TrackedItem input;
				_skipVerifyQuestion : Boolean	
				) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2016	cnwndl1	Initial creation
11 Mar 2019	NDL	TFS 43472 - Move / Pack confirmastion should be for all cargo types including break bulk / bulk
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars
	//amountForm : MOB_HHCargoAmountForm;
	result : Integer;
	quantity	: Integer;
	weight 		: Decimal[14,4];
	mess : String;
	packedCargo : CM_TrackedItem;
	setParentFromChild : Boolean;	//16 Jul 2014	NDL	Par 34571
	reserveDetail : CM_ReserveDetail;
	ti : CM_TrackedItem;
	packedTi : CM_TrackedItem;
	reason :String;
	
	schema : Schema;
	class : Class;
	amountForm : Form;
	byQuantity : Boolean;
	
begin

	//16 Jul 2014	NDL	Par 34571
	setParentFromChild := ( _parentCargo.allChildren.isEmptyOrContainsOnlyEquipment
							and _parentCargo.isStorage
							and self.myPackExportBookingRef = null
							and self.myPackStockBookingRef = null
							);
							
	//16 Jul 2014	NDL	Par 34571
	if not setParentFromChild then
		if ( not _parentCargo.allChildren.isEmptyOrContainsOnlyEquipment
			and self.myPackExportBookingRef = null
			and self.myPackStockBookingRef = null
			and not _packCargo.isEquipment            // 36111
			) then
			// i.e. we already have at least one child, and are just doing a generic pack
			if ( _parentCargo.myVoyage &lt;&gt; _packCargo.myVoyage
				or _parentCargo.dischargePort &lt;&gt; _packCargo.dischargePort
				or _parentCargo.getImExStatus &lt;&gt; _packCargo.getImExStatus
				) then
					//make sure the childrens (delivery details) match the parents
					mess := app.getErrorString2( Voyag_imex_disch_port_child, _packCargo.id, _parentCargo.id );
					self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false);
					return false;
				endif;
		endif;
	endif;
	
	
	if self.allUnpackedTis.includes( _packCargo ) then
		mess := "Re-pack " &amp; _packCargo.id &amp; " into " &amp; _parentCargo.id &amp; "?";
	else
		mess := "Pack " &amp; _packCargo.id &amp; " into " &amp; _parentCargo.id &amp; "?";
	endif;
	if _packCargo.myCargoType.isBreakBulkMulti or _packCargo.myCargoType.isBulkMulti then
	
		if app.isJMTUnitTest then
			quantity := _packCargo.totalQuantity;
			weight := _packCargo.totalWeight;
		elseif  _packCargo.myCargoType.isBreakBulkMulti and _packCargo.totalQuantity = 1 then	//26 Oct 2016	NDL	TFS 2827
			quantity := _packCargo.totalQuantity;
			weight := _packCargo.totalWeight;
		else
			schema := rootSchema.getSchema("MobileUISchema");
			class := schema.getClass("MOB_HHCargoAmountForm");

			create amountForm as class transient;
			amountForm.sendMsgWithParams("setCargoAndMessage", _packCargo, mess);
			
			if amountForm.showModal = IDOK then
				byQuantity := amountForm.getPropertyValue("byQuantity").Boolean;
				if byQuantity then
					quantity:=amountForm.sendMsg("getQuantity").Integer;
				else
					weight :=amountForm.sendMsg("getWeightMovedKgs").Decimal;
				endif;
			else
				return false;
			endif;
		endif;
//	else
	endif;
	
	//11 Mar 2019	NDL	- Moved the following out of the else. Need it for all cargo types.
	if _skipVerifyQuestion then
		//do nothing
	else
		if self.msgBox(mess, app.getErrorString(SHP_Confirm), MsgBox_Yes_No,false) &lt;&gt;  MsgBox_Return_Yes then
			return false;
		endif;
	endif;
//	endif;
	
	//01 Sep 2014	Par 34717 / CCMS 2384
	if self.myBulkRelease &lt;&gt; null then
		//11 Dec 2015	NDL	Par 37288	
		if self.myReserveSelection &lt;&gt; null and self.myReserveSelection.myReserveHeader = self.myBulkRelease then	
			self.validatePackForReserveDetails( self.myReserveSelection, _packCargo, quantity, weight, mess );
			if mess = null then
				reserveDetail := self.myReserveSelection;
			endif;
		else
			reserveDetail := self.getReserveDetailCargoMatches( _packCargo, quantity, weight, mess );//10 Nov 2015	NDL	Par 37092
		endif;
		if reserveDetail = null then
			self.msgBox( app.getErrorString(Cargo_item_release_issue) &amp; mess, app.getErrorString(Error), MsgBox_OK_Only, false );
			return false;
		endif;
	endif;
	
	app.mousePointer:=Window.MousePointer_HourGlass;
	packedCargo:=_packCargo;
	while true do
	
		app.myTrxUA.trxUpdatePackCargo(_parentCargo, packedCargo, quantity, weight, setParentFromChild, self.myBulkRelease, reserveDetail, false,null, app.myPassport);	//19.03.2024 navhl20 #62863

		if app.myPassport.trxCompletedOK() then
		
			//01 Sep 2014	Par 34717 / CCMS 2384
			if reserveDetail &lt;&gt; null then
				if _parentCargo.allChildren.includes(packedCargo) then
					packedTi := packedCargo;
				else
					// packed ti was split off.
					foreach ti in _parentCargo.allChildren do
						if ti.id &lt;&gt; packedCargo.id then
							continue;
						endif;
						if ti.cargoType &lt;&gt; packedCargo.cargoType then
							continue;
						endif;
						if ti.totalQuantity &lt;&gt; packedCargo.totalQuantity then
							continue;
						endif;
						packedTi := ti;
						break;
					endforeach; 
				endif;
				if packedTi &lt;&gt; null then
					app.myTrxUA.trxAddToReserveDetail( reserveDetail, packedTi, app.myPassport );
				endif;
			endif;
			
			break;
			
		else
					
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport,18); // ErrWarnMode_Update + ErrWarnMode_CanAckWarnings
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			break;
		endif;
	endwhile;
	
	if app.myPassport.trxCompletedOK() then
		if self.allUnpackedTis.includes( packedCargo ) then
			self.allUnpackedTis.remove( packedCargo );
		endif;
		return true;
	endif;
	
	return false ;
epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_parentCargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_packCargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_skipVerifyQuestion" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPackLoadByReqAnyIdAmt" id="c420c519-9cdd-411e-8989-61d3fdb4e3b5">
        <updating/>
        <source>doPackLoadByReqAnyIdAmt(	_ti			: CM_TrackedItem input;
							_wle		: CM_WorkListEntry input;
							_quantity	: Integer;
							_weight		: Decimal;
							_context	: Object input) : CM_WorkListEntry updating;
/*

Purpose:			From the Pack Load by Request App this method creates a new wle for an Any Id and Any Amount
					Should be refactored at a later date and merged with the truck loader unloader logic in CMIF_MobileTruckLoaderUnloader::saveChangesLoad

Parameters:			_ti			CM_TrackedItem		The tracked item we need to assign to the wle
					_wle		CM_WorkListEntry	THe original wle we need to use to create a new ti request and wle from
					_quantity	Integer				The quantity to assign to the new wle
					_weight		Decimal				The weight to assign to the new wle
					_context	Object				The context to use for the move transaction

Return Value:		CM_WorkListEntry	The new work list entry that we created for the ti

Date			Who		Reason
16 August 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

vars
	wleToProcess					: CM_WorkListEntry;
	roadReleaseLocationController	: CM_LocationsController;
	anyIdDelReq						: CM_DeliveryRequest;
	moveController					: CMIF_MoveController;
	
begin
	if _wle.job.getWorkOrder() &lt;&gt; null then	//This job is for a work order
		roadReleaseLocationController := _wle.getRoadReleaseLC();
		create moveController transient;
		moveController.setMyWorkListEntry(_wle);
		moveController.setMyToPrimaryLocation(roadReleaseLocationController);
		moveController.setMyTrackedItem(_ti);
		moveController.setQuantity( _quantity);
		moveController.setWeight( _weight);
		app.setContinueCMExceptions(true);
		app.myValUA.valWLEAssignTI(_wle, _ti, moveController, app.myPassport);
		app.setContinueCMExceptions(false);
		
		if app.myPassport.hasErrors then
			return null;
			
		endif;
		
		roadReleaseLocationController := null;
	endif;
	
	wleToProcess := self.doAddMoreCargoWLE(_ti, _wle.job.CM_RoadJob, _quantity, _weight); //Add another wle for the tracked item based off of the original wle, job and request
	
	if app.myPassport.hasErrors then
		return null;
		
	endif;
	
	if wleToProcess = null then
		return null; //An exception should have occurred so return?? As we have failed to create a new wle
		
	endif;
	
	//Get the road release location controller/truck location
	roadReleaseLocationController := wleToProcess.getRoadReleaseLC();
	
	self.moveTI(_ti, null, roadReleaseLocationController, wleToProcess, true, _quantity, _weight, _context); //Move the tracked item
	
	if app.myPassport.hasErrors then
		return null;
		
	endif;
	
	//If the wle is any id get the delivery request from the original wle
	if _wle.isAnyId then
		anyIdDelReq := _wle.myRequest.CM_DeliveryRequest;
	endif;
	
	//If we have a delivery request then update its details from the release
	if anyIdDelReq &lt;&gt; null then
		app.myTrxUA.trxUpdTiFromIsAnyIdRelease(_ti, anyIdDelReq, app.myPassport);
	endif;
	
	if app.myPassport.hasErrors then
		return null;
		
	endif;
	
	return wleToProcess; //Return the new wle that was created
	
epilog
	delete moveController;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_context" type="Object" usage="input"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doPromotePlannedToQueued" id="81933346-b757-4801-9fa3-b64d1f517858">
        <source>doPromotePlannedToQueued(_ti : CM_TrackedItem; _wle : CM_WorkListEntry input);
/*

Date		Who		Reason
15 November 2016	cnwer1	Initial creation TFS 2732

*/

vars

	moveController : CMIF_MoveController;

begin

	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	moveController.setMyToPrimaryLocation(_ti.myPrimaryPlannedLocation);
	moveController.setMyWorkListEntry(_wle);

	// update the cargo item with the queued move
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);

epilog

	delete moveController;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQueueTI" id="25b8700f-fe8c-48c3-b25b-a3920a4cf559">
        <source>doQueueTI(_ti : CM_TrackedItem ; _location : CM_LocationsController ; _quantity : Integer;_weight : Decimal  );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
*/

vars
	moveController 	: CMIF_MoveController;
	moveQuantity 	: Integer;
	moveWeight 		: Decimal [14,4];
begin
	if _ti = null then
		return;
	endif;	
	
	if _ti.isAlreadyQueuedTo(_location) then
		app.raiseCMException3(TI_Already_QueudPlanned_Here,_ti.id,app.getErrorString(Queued),_location.getID, null,_ti);
		return;	
	endif;
		
	create moveController transient;		
		
	if _ti.isBulkByQuantity then	
		if _quantity &lt;&gt; 0 then				
			moveQuantity:=_quantity;
			moveController.setWeight(_weight);	
		elseif _ti.totalQuantity &lt;&gt; 0 then
			moveQuantity:=_ti.totalQuantity;
		endif;
	elseif _ti.isBulkByWeight or _ti.isBulkByVolume then
		if _weight &lt;&gt; 0 then
			moveWeight:=_weight;
		elseif _ti.totalWeight &lt;&gt; 0 then
			moveWeight:=_ti.totalWeight;
		endif;
	endif;
			
	if moveQuantity &lt;&gt; 0 then
		moveController.setQuantity(moveQuantity);
	endif;
	if moveWeight &lt;&gt; 0 then
		moveController.setWeight(moveWeight);
	endif;
									
	moveController.setMyTrackedItem(_ti);
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	moveController.setMyToPrimaryLocation(_location);
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doQueueUnnotifiedCargo" id="41ca452f-1549-4770-a9b9-f47f4844e019">
        <source>doQueueUnnotifiedCargo(  _ti : CM_TrackedItem; _job : CM_VoyageJob output; _wle : CM_WorkListEntry output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars
	ti 			   : CM_TrackedItem;
	plannedLoc,
	targetLocn 	   : CM_LocationsController;
	moveController : CMIF_MoveController;
	tiArray		   : CM_TIArray;
	params 		   : CMIF_AutoplanParams;
	errMess 	   : String;
begin

	ti := _ti;
	
	// no target known, do an autoplan
	create tiArray transient;
	create params transient;
	params.allTrackedItems.add(ti);
	params.moveMode 			 := PLANNING_MODE;
	params.myTerminalArea 		 := null;
	params.showWarningWhenNoPlan := false;
	
	app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
	
	plannedLoc := ti.myPrimaryPlannedLocation;
	
	if plannedLoc &lt;&gt; null then
		targetLocn := plannedLoc;
	endif;
	
	if targetLocn = null then
		//epr TFS 2732 21/11/16
		if self.doNotShowMsgBox then
			app.raiseCMException1(Autoplan_fail,ti.id,null,null);
			return false;
		endif;
		errMess := app.getErrorString1(Autoplan_fail,ti.id);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;	
	endif;
	
	// set up the move controller for a queued move
	create moveController transient;
	moveController.setMyTrackedItem(ti);
	moveController.setMyOriginatingLocation(ti.myPrimaryActualLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	moveController.setMyToPrimaryLocation(targetLocn);
	moveController.transferType := VESSEL_TYPE_LOLO; // CNWAB1 MAY17 0; // 0 = LOLO 1 = RORO TFS 4435
	moveController.isNotNotifiedJob := true;
	moveController.isNonCraneVoyageMove := true; 

	// update the cargo item with the queued move
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		//epr TFS 2732 21/11/16
		if self.doNotShowMsgBox then	
			return false;
		endif;
		//errMess := app.myPassport.getErrorsAsString;
		errMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
		app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
		return false;	
	endif;
	
	//return the job that was created.
	if moveController.myWorkListEntry &lt;&gt; null then
		_wle := moveController.myWorkListEntry;
		_job := _wle.job.CM_VoyageJob;
	endif;
	
	return true;

epilog

	delete moveController;
	delete tiArray;
	delete params;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueueUnplannedUnworkedCargo" id="6b038e1c-0da5-4a29-9432-45db0c2b03d1">
        <source>doQueueUnplannedUnworkedCargo(  _ti : CM_TrackedItem;
								_job : CM_VoyageJob output;
								_wle : CM_WorkListEntry output;
								_quantity : Integer;
								_weight  : Decimal;
								_target : CM_LocationsController input);
/*

Purpose:			

Parameters:			

Return Value:		

Changes

Date		Name	TFS#		Description
============================================================================
07 Mar 2016	cnwndl1				Initial creation
01 Oct 2019 jlgka1 	TFS 46600 	PEL1 - Loading break-bulk PreNote to ship using Job Lander
============================================================================*/
vars
	targetLocn 		: CM_LocationsController;
	moveController 	: CMIF_MoveController;
	tiArray			: CM_TIArray;
	params 			: CMIF_AutoplanParams;	
begin

	//establish our target location			
	//epr par 36325 17/7/15 we have passed in the target use that rather than autoplan 
	if _target &lt;&gt; null then
		targetLocn:=_target;
	else
		if _ti.myPrimaryQueuedLocation &lt;&gt; null then
			targetLocn := _ti.myPrimaryQueuedLocation;
		elseif _ti.myPrimaryPlannedLocation &lt;&gt; null then
			targetLocn := _ti.myPrimaryPlannedLocation;
		else
			// no target known, do an autoplan
			create tiArray transient;
			create params transient;
			params.allTrackedItems.add(_ti);
			params.moveMode := PLANNING_MODE;
			params.myTerminalArea := null;
			params.showWarningWhenNoPlan := false;
			app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
			if _ti.myPrimaryPlannedLocation &lt;&gt; null then
				targetLocn := _ti.myPrimaryPlannedLocation;
			endif;
		endif;
	endif;
	
	if targetLocn = null then
		return;
	endif;
	// set up the move controller for a queued move
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	moveController.setMyToPrimaryLocation(targetLocn);
	moveController.setIsFromWeb(self.isFromWeb); //jlgka1 TFS 46600
	//moveController.transferType := VESSEL_TYPE_RORO; // CNWAB1 MAY17 1; // 0 = LOLO 1 = RORO  TFS 4435
	moveController.setTransferTypeFromJob( _job, VESSEL_TYPE_RORO );	//12 Mar 2018	NDL	TFS 37444
	moveController.isNonCraneVoyageMove := true; 
	//epr par 35862 13/3/15
	moveController.setQuantity(_quantity);
	moveController.setWeight(_weight);
	// update the cargo item with the queued move
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		return;
	endif;
	
	//return the job that was created.
	if moveController.myWorkListEntry &lt;&gt; null then
		_wle := moveController.myWorkListEntry;
		_job := _wle.job.CM_VoyageJob;
	endif;

epilog

	delete moveController;
	delete tiArray;
	delete params;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_target" type="CM_LocationsController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRealTrackedItemCreate" id="c97218bd-b1d5-4faf-b54c-904ff0b8f8d5">
        <source>doRealTrackedItemCreate( _pxyGateEntity : CMGTE_Receival io; _receivalRequestInfo : CM_ReceivalRequestInfo; _ti : CM_TrackedItem output):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	visit : CM_VehicleVisitRecord;
	pxyVVR : CM_VehicleVisitRecord;
	realGateEntity : CMGTE_Entity;
	result : Integer;
	id : String;
	cargoType : Integer;
	term : CM_Terminal;
	
begin

	visit := _pxyGateEntity.myVehicleVisitRecord;
	term := _pxyGateEntity.myTerminal;
	id := _pxyGateEntity.id;
	cargoType := _pxyGateEntity.cargoType;

	while true do
		app.myTrxCA.trxCreateAndActionGateEntity(visit, _pxyGateEntity, _receivalRequestInfo, realGateEntity, app.myPassport);
			
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
		else
			//If there were warnings, give the user a chance to ignore them. 
			if  self.doNotShowMsgBox then
				return false;
			endif;
			//Clear the duplicates if there are any
			app.myPassport.removeDuplicateWarnings();	//05 Mar 2014	NDL	Par 33596
			
			
			
			// don't care about this one.
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.allErrorWarnings.includesErrorCode(WARN_INVALID_LOCN) then
				result := IDOK;
			else
				result := app.showErrorWarningDialog(app.getErrorString(CreateCargo), app.myPassport, 20);	//ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings
			endif;
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

	//06 Mar 2014	NDL	Par 33554
	if realGateEntity &lt;&gt; null and realGateEntity.CMGTE_Receival &lt;&gt; null and realGateEntity.CMGTE_Receival.myTrackedItem &lt;&gt; null then
		_ti := realGateEntity.CMGTE_Receival.myTrackedItem;
	elseif term &lt;&gt; null and id.trimBlanks &lt;&gt; null then
		_ti := term.allOnsiteTIsByCargoTypeId.getAtKey(cargoType,id.toUpper);
	endif;

	return true;

epilog
	
end;</source>
        <Parameter name="_pxyGateEntity" type="CMGTE_Receival" usage="io"/>
        <Parameter name="_receivalRequestInfo" type="CM_ReceivalRequestInfo"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRealTrackedItemUpdate" id="82562601-2b76-449f-88ce-9fcb81fcb8ae">
        <source>doRealTrackedItemUpdate( _proxyTi : CM_TrackedItem input; _toDoTasks : IntegerArray; _addingToDos : BooleanArray) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	result : Integer;
	
begin

	while true do
	
		app.myTrxUA.trxUpdateTIForCargoChecks(	_proxyTi,
												null,
												TI_UPDMODE_NORMAL, 
												null, 
												_toDoTasks,
												_addingToDos,
												app.myPassport	);
		
		if app.myPassport.trxCompletedOK then
			result := IDOK;
			return result;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, 17);	//ErrWarnMode_Add + ErrWarnMode_CanAckWarnings
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return result;
		
	endwhile;
	
	return result;

epilog
	
end;</source>
        <Parameter name="_proxyTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_toDoTasks" type="IntegerArray"/>
        <Parameter name="_addingToDos" type="BooleanArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUnpackCargo" id="2d0eac8e-38cf-467d-bfab-f43708516cde">
        <source>doUnpackCargo(	_unpackCargo : CM_TrackedItem input;
				_location	 : CM_LocationsController input;
				_quantity 	 : Integer;
				_weight 	 : Decimal;
				_unpackTime  : TimeStamp) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2016	cnwndl1	Initial creation	TFS 1593
09 Jan 2024	navma1  Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
17 Sep 2024 navbs1  Bug 65975: Unpack Complete transaction is not updated with retrospective date and time if the job is completed using work order operations app
23 Sep 2024 navsp1  TFS ChangeRequest 65967: CUX | MasterTerminalAPI - Pack and Unpack APIs
*/

vars
	unpackCargo,
	parentCargo : CM_TrackedItem;
	result 		: Integer;
	doRemove 	: Boolean;
	retroDate 	: TimeStamp;
begin
	unpackCargo		  := _unpackCargo;
	if _unpackTime &lt;&gt; null then										//TFS 65967
		retroDate	:= _unpackTime;									//TFS 65967
	else															//TFS 65967
		//Start 17.09.2024 navbs1 #65975	
		parentCargo := unpackCargo.myParent;
		if parentCargo &lt;&gt; null then
			retroDate   := parentCargo.getRetrospectiveDT(CM_WOUnpackJob);
		endif;
		//End 17.09.2024 navbs1 #65975	
	endif;
	
	app.mousePointer  := Window.MousePointer_HourGlass;
	while true do
		app.myTrxUA.trxUpdateUnpackCargo(unpackCargo, _location,_quantity,_weight,false,retroDate, app.myPassport);  //14.03.2024 navhl20 #62861	

		// ### TFS CR 64297 TASK 64298 28MAY2024 NAVAB1
		if app.myPassport.hadDeadlock = true then
			return false;
		endif;

		if app.myPassport.trxCompletedOK() then
			//If its been merged and zombied, remove it from the assignned... otherwise don't - 11 Dec 2015	NDL Par 37288
			if self.myBulkRelease &lt;&gt; null then
				if unpackCargo.hasBeenMerged then
					doRemove := true;
				endif;
				if doRemove then
					app.myTrxUA.trxRemoveReserveSelections( self.myBulkRelease, unpackCargo, app.myPassport );
				endif;
			endif;
		
			break;
			
		else
			//epr TFS 2732 - 21/11/16
			if self.doNotShowMsgBox then	
				return false;
			endif;
			
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport,18); // ErrWarnMode_Update + ErrWarnMode_CanAckWarnings
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			break;
		endif;
	endwhile;
	
	if app.myPassport.trxCompletedOK() then
		if unpackCargo.myCargoType.allowDuplicates then	//02 Sep 2019	NDL	TFS 46364
			// In case its been split and/or merged during the process, we don't want the original, we want the unpacked bit/pile.
			unpackCargo := _location.allTrackedItemsById.getAtKey( unpackCargo.id, unpackCargo.cargoType );
		endif;
		self.allUnpackedTis.addExclusive(unpackCargo );
	endif;
	
	return app.myPassport.trxCompletedOK;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_unpackCargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_location" type="CM_LocationsController" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_unpackTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnpackCargoAgain" id="5e319919-d520-49b1-98ef-d38c87f203e5">
        <source>doUnpackCargoAgain(_unpackCargo : CM_TrackedItem input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars
	mess : String;
//	amountForm : MOB_HHCargoAmountForm;
	result : Integer;
	quantity	: Integer;
	weight 		: Decimal[14,4];
	location : CM_LocationsController;
	tmpFoundHeight : Integer;
	
	schema : Schema;
	class : Class;
	amountForm : Form;
	byQuantity : Boolean;

begin
	mess:=app.getErrorString1(Unpack_again, _unpackCargo.id);

	if _unpackCargo.priorLocation &lt;&gt; null then
		self.myTerminal.findLocationFromString(_unpackCargo.priorLocation, true, location, tmpFoundHeight);
	endif;
	
	if _unpackCargo.myCargoType.isBreakBulkMulti or 
			_unpackCargo.myCargoType.isBulkMulti then
		//create amountForm transient;
		//amountForm.lblInfo.caption:=mess;
		//amountForm.myTrackedItem:=_unpackCargo;
		
		schema := rootSchema.getSchema("MobileUISchema");
		class := schema.getClass("MOB_HHCargoAmountForm");

		create amountForm as class transient;
		amountForm.sendMsgWithParams("setCargoAndMessage", _unpackCargo, mess);
			
		if amountForm.showModal = IDOK then
			byQuantity := amountForm.getPropertyValue("byQuantity").Boolean;
			if byQuantity then
				quantity:=amountForm.sendMsg("getQuantity").Integer;
			else
				weight :=amountForm.sendMsg("getWeightMovedKgs").Decimal;
			endif;
		else
			return false;
		endif;
	else
	
		if self.msgBox(mess, app.getErrorString(SHP_Confirm), MsgBox_Yes_No, false) &lt;&gt;  MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	
	return self.doUnpackCargo(_unpackCargo,location,quantity,weight,null);
epilog
	

end;</source>
        <Parameter name="_unpackCargo" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnqueueTI" id="2d83625c-eeea-477d-97ae-c0859bc7c220">
        <source>doUnqueueTI(_ti : CM_TrackedItem input; _location : CM_LocationsController input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgns1	Initial creation

*/

vars
	moveController : CMIF_MoveController;
begin

	if _ti = null then
		return;
	endif;	

    if not _ti.isAlreadyQueuedTo(_location) then
		app.raiseCMException2(Cargo_not_queued_locatio,_ti.id,_location.getID , null,_ti);
		return;	
	endif;
		
	create moveController transient;
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setMyTrackedItem(_ti);
	moveController.deleteQueuedLocation := _location;
	app.myTrxUA.trxUpdateMoveTIUndo(moveController, app.myPassport);
		
epilog		
	delete moveController;	
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_location" type="CM_LocationsController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findClosestPowerPoint" id="7f83d04b-d4a1-4de0-8507-f31aa1c57b80">
        <updating/>
        <source>findClosestPowerPoint(_ti: CM_TrackedItem) : CM_GapController updating;
/*

Purpose:			Moved from MobileServerSchema::CM_MobileAgent

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2016	cnwmc5	Initial creation

*/

vars
	thePowerPoints : ObjectArray;
	anObject : Object;
	aGapController, closeGap : CM_GapController;

	tiX,tiY,gapX, gapY, totalPoints: Integer;
	aGridController : CM_LocationsController;
begin
	totalPoints := 999999;
	
	aGridController := _ti.getPrimaryLocation(REAL_MODE);
	if aGridController.isKindOf(CM_GridController) then
		tiX := aGridController.CM_GridController.row;
		tiY := aGridController.CM_GridController.column;
	endif;
	
	create thePowerPoints transient;
	if _ti.myTerminalArea.isKindOf(CM_ForkLiftStack) then
		_ti.myTerminalArea.CM_ForkLiftStack.getPowerPoints(thePowerPoints);
	
		foreach anObject in thePowerPoints do
			if anObject.isKindOf(CM_GapController) then
				aGapController := anObject.CM_GapController;
				
				// Find the closest power point to the TI
				// we do this by working out the distance in locations controllers in the row and the column from our TI
				// add the row and column difference together and that is the distance away from us
				if aGapController.row &gt;= tiX then
					gapX := aGapController.row - tiX;
				else
					gapX := tiX - aGapController.row;
				endif;
				if aGapController.column &gt;= tiY then
					gapY := aGapController.column - tiY;
				else
					gapY := tiX - aGapController.column;
				endif;
				if (gapY + gapX) &lt; totalPoints then
					totalPoints := gapY + gapX;
					closeGap := aGapController;
				endif;
			endif;
		endforeach;		
	endif;
	
	return closeGap;
epilog
	delete thePowerPoints;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_GapController"/>
    </JadeMethod>
    <JadeMethod name="findLanderCargo" id="d749d565-3031-4f79-a0ca-4b518c5e80c6">
        <source>findLanderCargo(_cargoId : String; _allTIs : CM_TIArray input);
/*

Date		Who		Reason
23 November 2016	cnwer1	Initial creation TFS 2732

*/

vars

begin
	if self.checksState = self.ShipLoadCargo then
		//epr TFS 2732 22/11/16 refactored to use agent
		self.findLanderLoadCargo(_cargoId,_allTIs);
	endif;
		
	if self.checksState = self.ShipDischargeCargo then
			//epr TFS 2732 22/11/16 refactored to use agent
		self.findLanderDischargeCargo(_cargoId,_allTIs);
	elseif self.checksState = self.ShiftOnBoard then
			//epr TFS 2732 22/11/16 refactored to use agent
		self.findLanderSOBCargo(_cargoId,_allTIs);
			
	endif;
epilog

end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findLanderDischargeCargo" id="320dc19a-fd0a-4eaf-ab75-221a0118300a">
        <source>findLanderDischargeCargo( _cargoId : String; _allTIs : CM_TIArray input ) protected;
/*

Date		Who		Reason
22 November 2016	cnwer1	Initial creation TFS 2732 moved from MOB_HHCargoMove form

*/

vars
	
begin
	if _cargoId = null then
		return;
	endif;
	
	self.findLanderSOBCargo(_cargoId,_allTIs);
			
	if _allTIs.isEmpty  then		
		self.findTIsInTransferArea(_cargoId,_allTIs);		
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findLanderLoadCargo" id="7798c391-8395-4726-b26a-245dc961877a">
        <source>findLanderLoadCargo(_cargoId : String; _allTIs : CM_TIArray input) protected;
/*

Date		Who		Reason
22 Nov 2016	cnwer1	Initial creation TFS 2732 moved from MOB_HHCargoMove form
11 Jun 2019 jlger1 	TFS 45570  
11 Aug 2021 navma1  Bug 51708: Cargo Lander - Search - Not able to search for an export
30 Oct 2024 navma2	MTN-33239 QTS - HHT is taking more timt buffering resulting ops to stopped
*/

vars
	ti,
	firstTi 		: CM_TrackedItem;
	cargoIdLength 	: Integer;						//11 Oct 2010	NDL	Par 25836
	cargoIdReversed : String;					     //11 Oct 2010	NDL	Par 25836
	iter 			: Iterator;
	revDict 		: CM_TIByIdCargoTypeDictRev;	//11 Oct 2010	NDL	Par 25836
	plannedTiArray 	: CM_TIArray;
	location		: CM_LocationsController;
	startObject 	: CM_TrackedItem;
	voyage			: CM_Voyage;
begin
	if _cargoId = null then
		return;
	endif;
	
	cargoIdLength   := _cargoId.length;			//11 Oct 2010	NDL	Par 25836
	cargoIdReversed := _cargoId.reverse;		//11 Oct 2010	NDL	Par 25836
	voyage			:= self.myVoyage;			//30.10.2024 navma1 #MTN-33239
	
	if voyage = null or _allTIs = null then
		return;
	endif;
	
	// 1. On-Site Forward Search
	
	firstTi := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq(_cargoId,null);

	if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = _cargoId then	//11 Oct 2010	NDL	Par 25836
		iter := voyage.allOnsiteTIsByIdCargoType.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
			if ti.id[1:cargoIdLength] &lt;&gt; _cargoId then	//11 Oct 2010	NDL	Par 25836
				break;
			endif;
			//epr TFS 45570 11/7/19 - undid changes for 45110 which broke the job lander and HH lander 
			if not self.isValidLanderCargo(ti) then
				continue;
			endif;
			_allTIs.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
	
	// 2. On-Site Reverse Search
	
	//11 Oct 2010	NDL	Par 25836 - Try reverse 'cargoId' as any piece of the id
	if _allTIs.isEmpty and not voyage.allOnsiteTIsByIdCargoType.isEmpty then
		create revDict transient;
		voyage.allOnsiteTIsByIdCargoType.copy( revDict );
		firstTi := revDict.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := revDict.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				//epr TFS 45570 11/7/19 - undid changes for 45110 which broke the job lander and HH lander 
				if not self.isValidLanderCargo(ti) then
					continue;
				endif;
				_allTIs.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		delete revDict;
	endif;
	
	// 3. Tranship Forward Search
	
	//05 Feb 2013	NDL	Par 31102
	if _allTIs.isEmpty and not voyage.allTranshipTIsExport.isEmpty then
		firstTi := voyage.allTranshipTIsExport.getAtKeyGeq(_cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = _cargoId then
			iter := voyage.allTranshipTIsExport.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; _cargoId then
					break;
				endif;
				//epr TFS 45570 11/7/19 - undid changes for 45110 which broke the job lander and HH lander 
				if not self.isValidLanderCargo(ti) then
					continue;
				endif;
				//14 Mar 2014	NDL	Par 33649
				if voyage.allOnshipTIsByCargoTypeId.includes(ti) then
					continue;
				endif;
				
				_allTIs.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
	
	// 4. Tranship Reverse Search
	
	//cnwrd1 22.3.2013 try reverse look a the tranships par 31335
	if _allTIs.isEmpty and not  voyage.allTranshipTIsExport.isEmpty then
		create revDict transient;
		 voyage.allTranshipTIsExport.copy( revDict );
		firstTi := revDict.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := revDict.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				//epr TFS 45570 11/7/19 - undid changes for 45110 which broke the job lander and HH lander 
				if not self.isValidLanderCargo(ti) then
					continue;
				endif;
				//14 Mar 2014	NDL	Par 33649
				if voyage.allOnshipTIsByCargoTypeId.includes(ti) then
					continue;
				endif;
				_allTIs.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		delete revDict;
	endif;			
	
	// 5. Planned Forward Search
	
	// 34510 DJW 4 July 2014 Has it been planned to a location on my voyage?
	if _allTIs.isEmpty then
		create plannedTiArray transient;
		foreach location in  voyage.allVoyageLocations discreteLock do
			location.getAllPlannedTrackedItems(plannedTiArray, true, true);
			foreach ti in plannedTiArray discreteLock do
				//epr TFS 45570 11/7/19 - undid changes for 45110 which broke the job lander and HH lander 
				if not self.isValidLanderCargo(ti) then
					continue;
				endif;
				if ti.id = _cargoId or ti.id[1:_cargoId.length] = _cargoId then
					_allTIs.add(ti);
				endif;
			endforeach;
		endforeach;
	endif;
	
	// 6. Direct lookup on Terminal for different voyage
	
	//10 Jun 2010	NDL	Par 24286 ( Part of CCMS 1077 )
	if _allTIs.isEmpty then
		// if we don't find it related to the voyage, then check the terminal, in case it has been scanned in
		// and is actually for the wrong voyage, then we can raise an error in the 'populateTrackedItem' method.
		firstTi :=  voyage.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(_cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id = _cargoId then
			if  self.isValidLanderCargo(firstTi) then            //11.08.2021 navma1 #51708
				_allTIs.addExclusive(firstTi);
			endif;
		endif;
	endif;
	
	// 7. On-Site Forward Search on Terminal for alternate Id
	
	//21/4/22 jlier1 TFS 53249
	//check if there are any onsite with the alt id for the voyage
	startObject := voyage.myTerminal.allOnsiteTIsByAlternativeId.getAtKeyGeq(_cargoId);		  //30.10.2024 navma1 #MTN-33239
	if startObject &lt;&gt; null then
		iter := voyage.myTerminal.allOnsiteTIsByAlternativeId.createIterator;
		iter.startAtObject(startObject);
		while iter.next( ti ) do
			if ti.alternativeId[1:cargoIdLength] &lt;&gt; _cargoId then
				break;																			//30.10.2024 navma1 #MTN-33239
			endif;
			
			if ti.getMyOnsiteVoyage &lt;&gt; voyage then
				continue;
			endif;
			if not self.isValidLanderCargo(ti) then
				continue;
			endif;
			_allTIs.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
	
		
epilog
	delete plannedTiArray;
	delete iter;
	delete revDict;	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findLanderLocation" id="f6192b4e-0fb7-4aa6-90ab-3d48cd21a344">
        <source>findLanderLocation(_locationID : String) : CM_LocationsController;
/*

Date		Who		Reason
18 November 2016	cnwer1	Initial creation TFS 2732

*/

vars
	loadString : String;
	foundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
	strs : StringArray;
	pos: Integer;
begin
	if self.myTerminal = null then
		return null;
	endif;
	
	if self.checksState =  self.ShipDischargeCargo then	
		self.myTerminal.findLocationFromString(_locationID, true, foundLC, tmpFoundHeight);	
	else
		if self.myVoyage &lt;&gt; null then		
			// Remove voyage code if present  35530
			if _locationID = self.myVoyage.code&amp;" " then	// 17 Feb 2020	NDL	TFS 48512 Exact match with space on teh end
				loadString := null;
			elseif _locationID.startsWith(self.myVoyage.code&amp;" ") then
				pos := _locationID.pos(" ", 1);
				loadString := _locationID[pos+1:end];
			else				
				loadString := _locationID;
			endif;
			
			create strs transient; //cnwrd1 par 28016 18.8.2011 switched round with the terminal check below as that was finding a voyage with the same name as a slot location
			loadString.getTokensForDelimiter(Space,strs);
			self.myVoyage.findLocation(strs, true, foundLC, tmpFoundHeight);
			
			if foundLC = null then			
				self.myTerminal.findLocationFromString(_locationID, true, foundLC, tmpFoundHeight);
			else
				if foundLC = self.myVoyage.myShipBlockStack and loadString &lt;&gt; self.myVoyage.code then
					foundLC := null;
				endif;
			endif;	
		endif;
		
	endif;
	
	return foundLC;
epilog
	delete strs;
end;</source>
        <Parameter name="_locationID" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="findLanderSOBCargo" id="883729be-371e-4116-b867-17b7cd383504">
        <source>findLanderSOBCargo(_cargoId : String; _allTIs : CM_TIArray input ) protected;
/*

Date		Who		Reason
22/11/2016	cnwer1	Initial creation TFS 2732 moved from MOB_HHCargoMove form
12/06/2019	jlgdap1	TFS 45110 SNO Wrong Container in Cargo List -&gt; Cargo Lander
*/

vars
	voyage : CM_Voyage;
	firstTi : CM_TrackedItem;
	cargoIdLength : Integer;	//11 Oct 2010	NDL	Par 25836
	cargoIdReversed : String;	//11 Oct 2010	NDL	Par 25836
	iter : Iterator;
	ti : CM_TrackedItem;
begin
	if _cargoId = null then
		return;
	endif;
	
	
	cargoIdLength := _cargoId.length;	//11 Oct 2010	NDL	Par 25836
	cargoIdReversed := _cargoId.reverse;	//11 Oct 2010	NDL	Par 25836
	
	voyage := self.myVoyage;
	
	firstTi := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq(_cargoId,null);
	//if firstTi &lt;&gt; null and firstTi.id = cargoId then
	if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = _cargoId then	//11 Oct 2010	NDL	Par 25836
		iter := voyage.allOnshipTIsByIdCargoType.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
			if ti.id[1:cargoIdLength] &lt;&gt; _cargoId then	//11 Oct 2010	NDL	Par 25836
				break;
			endif;
			//epr TFS 45570 11/7/19 - undid changes for 45110 which broke the job lander and HH lander 
			if not self.isValidLanderCargo(ti) then
				continue;
			endif;
	
			_allTIs.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
		
	//11 Oct 2010	NDL	Par 25836 - Try reverse 'cargoId' as any piece of the id
	if _allTIs.isEmpty then
		firstTi := voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				//epr TFS 45570 11/7/19 - undid changes for 45110 which broke the job lander and HH lander 
				if not self.isValidLanderCargo(ti) then
					continue;
				endif;																				
				_allTIs.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	endif;
	
	//21/4/22 jlier1 TFS 53249
	firstTi :=voyage.allOnshipTIsByAlternativeId.getAtKeyGeq(_cargoId);
	if firstTi &lt;&gt; null and firstTi &lt;&gt; null and firstTi.alternativeId[1:cargoIdLength] = _cargoId then
		iter := voyage.allOnshipTIsByAlternativeId.createIterator;
		iter.startAtObject(firstTi);
		while iter.next( ti ) do
			if ti.alternativeId[1:cargoIdLength] &lt;&gt; _cargoId then	//11 Oct 2010	NDL	Par 25836
				break;
			endif;
			//epr TFS 45570 11/7/19 - undid changes for 45110 which broke the job lander and HH lander 
			if not self.isValidLanderCargo(ti) then
				continue;
			endif;
	
			_allTIs.addExclusive(ti);
		endwhile;
		delete iter;
	endif;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findLocationFor" id="03c4ca14-8499-4b04-8d32-a85cd9176737">
        <source>findLocationFor( _ti : CM_TrackedItem; _terminal : CM_Terminal ) : CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

begin

	return app.autoPlanTiYATest(_terminal, null, _ti, false);  

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="findTIsInTransferArea" id="4451ecb8-05ac-474a-965c-44bdc3b8631b">
        <source>findTIsInTransferArea(_cargoId : String; _tiArray :CM_TIArray input) protected;
/*

Date		Who		Reason
22 November 2016	cnwer1	Initial creation TFS 2732

*/

vars

trackedItems : CM_TIArray;
	voyageQueue : CM_VoyageQueue;
	subQueue : CM_RadioTelemetryQueue;
	crane : CM_Crane;
	craneTA : CM_CraneTransferArea;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	cargoIdLength : Integer;	//11 Oct 2010	NDL	Par 25836
	cargoIdReversed : String;	//11 Oct 2010	NDL	Par 25836
	interChangeArea : CM_InterchangeArea;
	workPoint : CM_WorkPoint;
begin
	cargoIdLength := _cargoId.length;
	cargoIdReversed := _cargoId.reverse;
	//need to check any that are grounded in one of the crane transfer areas or associated interchange area.
	create trackedItems transient;
	voyage := self.myVoyage;
	voyageQueue := voyage.myQueue;
	if voyageQueue = null then
		return;
	endif;
	
	foreach subQueue in voyageQueue.allSubQueuesById do : outerLoop	
		if subQueue.isKindOf(CM_VoyageCraneQueue) then
			crane := subQueue.CM_VoyageCraneQueue.crane;
			if crane = null then
				continue;
			endif;
			craneTA := crane.transferArea;
			if craneTA = null then
				continue;
			endif;
			
			trackedItems.clear();
			craneTA.getTIs(trackedItems, null);
			foreach ti in trackedItems do
				if  ti.isChild then
					continue;
				endif;
				if ti.id = _cargoId then
					_tiArray.addExclusive(ti);
					break outerLoop;
				elseif ti.idReversed[1:cargoIdLength] = cargoIdReversed then	//11 Oct 2010	NDL	Par 25836
					_tiArray.addExclusive(ti);
					break outerLoop;
				elseif ti.alternativeId = _cargoId then //21/4/22 jlier1 TFS 53249
					_tiArray.addExclusive(ti);
					break outerLoop;	
				endif;
			endforeach;
			
			interChangeArea := craneTA.myDefaultInterchangeArea;
			if interChangeArea &lt;&gt; null then
				trackedItems.clear();
				interChangeArea.getTIs(trackedItems, null);
				foreach ti in trackedItems do
					if  ti.isChild then
						continue;
					endif;
					if ti.id = _cargoId then
						_tiArray.addExclusive(ti);
						break outerLoop;
					elseif ti.idReversed[1:cargoIdLength] = cargoIdReversed then	//11 Oct 2010	NDL	Par 25836
						_tiArray.addExclusive(ti);
						break outerLoop;
					elseif ti.alternativeId = _cargoId then //21/4/22 jlier1 TFS 53249
						_tiArray.addExclusive(ti);
						break outerLoop;		
					endif;
				endforeach;
			endif;
		//epr CCMS 1033 30/8/11
		elseif 	subQueue.isKindOf(CM_VoyageWorkPointQueue) then
			workPoint:=subQueue.CM_VoyageWorkPointQueue.myWorkPoint;
			if workPoint = null then
				continue;
			endif;
			interChangeArea :=workPoint.myWorkPointInterchangeArea;
			if interChangeArea = null then
				continue;
			endif;
			trackedItems.clear();
			interChangeArea.getTIs(trackedItems, null);
			foreach ti in trackedItems do
				if  ti.isChild then
					continue;
				endif;
				if ti.myVoyage &lt;&gt; voyage then	//03 Jul 2012	NDL	Par 29707 - WPs can share T/As
					continue;
				endif;
				if ti.id = _cargoId then
					_tiArray.addExclusive(ti);
					break outerLoop;
				elseif ti.idReversed[1:cargoIdLength] = cargoIdReversed then	
					_tiArray.addExclusive(ti);
					break outerLoop;
				elseif ti.alternativeId = _cargoId then //21/4/22 jlier1 TFS 53249
						_tiArray.addExclusive(ti);
						break outerLoop;		
				endif;
			endforeach;
		endif;
	endforeach;
		
epilog
	delete trackedItems;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllReceivalRequestInfos" id="8bd25826-57fd-4b12-9175-711709fc2383">
        <source>getAllReceivalRequestInfos( infoSet : CM_ReceivalRequestInfoSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	allRecRequests : CM_RequestArray;
	wleArray : CM_WLEArray;
	wle : CM_WorkListEntry;
	req : CM_Request;
	recReq : CM_ReceivalRequest;
	recReqInfo : CM_ReceivalRequestInfo;
	
begin

	infoSet.clear();
	create allRecRequests transient;
	
	if self.myTruck = null then
		return;
	endif;
	
	create wleArray transient;
	self.myTruck.getAllWLEs(wleArray);
	
	foreach wle in wleArray do
		
		if not wle.isReceipt then
			continue;
		endif;
		
		req := wle.myRequest;
		if req = null then
			continue;
		endif;
		
		if not req.isReceivalType then
			continue;
		endif;
		
		recReq := req.CM_ReceivalRequest;
		if allRecRequests &lt;&gt; null then
			allRecRequests.addExclusive(recReq);
		endif;
		
	endforeach;
	
	foreach req in allRecRequests do
	
		recReq := req.CM_ReceivalRequest;
		foreach recReqInfo in recReq.allReceivalInfo do
			infoSet.add( recReqInfo );
		endforeach;
		
	endforeach;
	
epilog

	delete allRecRequests;
	delete wleArray;

end;</source>
        <Parameter name="infoSet" type="CM_ReceivalRequestInfoSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAnyIdDeliveryRequest" id="983e9329-e4c6-48b3-8b12-fd259259c701">
        <source>getAnyIdDeliveryRequest():CM_DeliveryRequest;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	wle : CM_WorkListEntry;

begin

	if self.allWlesToLoad.size = 1 then
		wle := self.allWlesToLoad.first;
		if wle.isAnyId then
			return wle.myRequest.CM_DeliveryRequest;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="getBRPropsectiveChildCargo" id="929e7b2c-00f6-45de-b329-4c514e538254">
        <source>getBRPropsectiveChildCargo(	_bulkRelease : CM_BulkRelease;
							_reserveSelection : CM_ReserveSelection;
							_stagedYardLocation : CM_LocationsController;
							_targetLocation : CM_LocationsController;
							_tiArray : CM_TIArray io
							) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2017	cnwndl1	Initial creation		TFS 4016
// 11 Jan 2018	cnwrs1	TFS 36603 STW fix locking issue
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	ti : CM_TrackedItem;
	opTerm : CM_OperatorTerminal;
	reserve : CM_ReserveDetail;
	reason : String;
	reserveDetails: CM_ReserveDetailSet;

	allPreStaged : Boolean;
	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	outStandingItemCount : Integer;
	stagedItemCount : Integer;
	onTruckCount : Integer;
	allowOtherReleases: Boolean;
	parentTi : CM_TrackedItem;
	childTi : CM_TrackedItem;
	iter : Iterator;
	cargoType : CM_CargoType;
	startObject : CM_TrackedItem;
	allTis	: CM_TISet; 
begin

	if _tiArray = null then
		return;
	endif;
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	allowOtherReleases := _bulkRelease.allowCargoOnMultipleReleases;
	//16 Oct 2915	NDL	Par 37033 - STW version of staged
	if app.isCargoGroupEnabled then	//09 Feb 2016	NDL	Par 37479
		create tiSet transient;
		if _targetLocation = null and self.myPackTi &lt;&gt; null then
			parentTi := self.myPackTi;
		endif;
		
		if _bulkRelease &lt;&gt; null then	
			if _reserveSelection &lt;&gt; null then
				//11 Dec 2015	NDL	Par 37288
				outStandingItemCount := _reserveSelection.getTotalOutstanding;
				stagedItemCount := _reserveSelection.getTotalStaged(tiSet, firstStagingLC, null);
				//onTruckCount := _reserveSelection.getTotalAssignedInLocation(_targetLocation);
				if _targetLocation &lt;&gt; null then
					onTruckCount := _reserveSelection.getTotalAssignedInLocation(_targetLocation);
				//20 Mar 2017	NDL	TFS 3667
				elseif parentTi &lt;&gt; null then
					foreach childTi in parentTi.allChildren do
						onTruckCount := onTruckCount + childTi.totalQuantity.max(1);
					endforeach;
				endif;
				if outStandingItemCount &gt; 0 and outStandingItemCount = ( stagedItemCount + onTruckCount ) then
					foreach ti in tiSet do
					
						//20 Mar 2017	NDL	TFS 3667
						if parentTi &lt;&gt; null then
							if ti.isChild then
								continue;
							endif;
						endif;
						
						_tiArray.addExclusive( ti );
					endforeach;
					return;
				endif;
				
			else
				outStandingItemCount := _bulkRelease.getTotalOutstanding;
				stagedItemCount := _bulkRelease.getTotalStaged(tiSet, firstStagingLC);
				//onTruckCount := _bulkRelease.getTotalAssignedInLocation(_targetLocation);	//23 Nov 2015	NDL	Par 37153
				if _targetLocation &lt;&gt; null then
					if _reserveSelection &lt;&gt; null then                           //cnwma1 TFS #4017 07/04/2017
						onTruckCount := _reserveSelection.getTotalAssignedInLocation(_targetLocation);
					else
					     foreach reserve in _bulkRelease.allReserveDetails discreteLock do    //cnwma1 TFS #4017 07/04/2017
								if  reserve.isKindOf(CM_ReserveSelection) then
									onTruckCount := onTruckCount + reserve.CM_ReserveSelection.getTotalAssignedInLocation(_targetLocation);
								endif;
						 endforeach;
					endif;
				//20 Mar 2017	NDL	TFS 3667
				elseif parentTi &lt;&gt; null then
					foreach childTi in parentTi.allChildren do
						onTruckCount := onTruckCount + childTi.totalQuantity.max(1);
					endforeach;
				endif;
				if outStandingItemCount &gt; 0 and outStandingItemCount = ( stagedItemCount + onTruckCount ) then
					foreach ti in tiSet do
					
						//20 Mar 2017	NDL	TFS 3667
						if parentTi &lt;&gt; null then
							if ti.isChild then
								continue;
							endif;
						endif;
						
						_tiArray.addExclusive( ti );
					endforeach;
					return;
				endif;
				
			endif;
		endif;
	endif;

	if _stagedYardLocation &lt;&gt; null then
		//all cargo is staged in the interchange area, NO cross-checking is performed
		foreach ti in _stagedYardLocation.allTrackedItems where (not ti.isChild) and (allowOtherReleases or ti.bulkReleaseAssignedCode = null or ti.bulkReleaseAssignedCode = _bulkRelease.code) do	// 1 Nov 2016 cnwmp6 TFS 2858
			if _reserveSelection &lt;&gt; null then
				//If we have a reserve selection and it doesn't match skip it.
				if not ti.testAgainstReserveSelection( _reserveSelection, reason, true, null ) then	//09 Feb 2016	NDL	Par 37479
					continue;
				endif;
			endif;
			_tiArray.addExclusive( ti );
		endforeach;
		return;
		
	endif;
		
	if _bulkRelease = null then
		return;
	endif;
	
	// Release by id or release by type with assigned items
	// get the nominated child cargo
	foreach reserve in _bulkRelease.allReserveDetails discreteLock do
		if _reserveSelection &lt;&gt; null and reserve &lt;&gt; _reserveSelection then	//03 Oct 2016	NDL	TFS 
			continue;
		endif;
		reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in reserve.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			// 30 Apr 2015	NDL	Par 36140 
			if _bulkRelease.isPackingType then
				if ti.isContainer or ti.isChassis then
					//will be associated so as to be a parent not a child.
					continue;
				endif;
			endif;
			if ti.isChild then
				//already packed
				continue;
			endif; 
			if ti.myPrimaryActualLocation = null then
				continue;
			endif;

			if ti.myPrimaryActualLocation = _targetLocation then
				continue;
			elseif ( _targetLocation &lt;&gt; null and _targetLocation.isWagon ) then	//26 Jan 2017	NDL	TFS 3198/2877
				if ti.myPrimaryActualLocation.isWagon
			//	and ( ti.myPrimaryActualLocation.CM_WagonController.myWagon = _targetLocation.CM_WagonController.myWagon )
				and ( ti.myPrimaryActualLocation.CM_WagonController.myWagon.myTrainOutwards = _targetLocation.CM_WagonController.myWagon.myTrainOutwards ) //10 Jun 2020	NDL	TFS 49537
				then
					continue;
				endif;
			endif;
			if _bulkRelease.isRoadType then    // 36127
				if ti.myPrimaryActualLocation.isVehicle then
					continue;
				elseif ti.myPrimaryActualLocation.isTILCController then
					continue;
				endif;
			endif;
			if not ti.isOnSite then
				continue;
			endif;
			_tiArray.addExclusive( ti );
		endforeach;
	endforeach;
	
	//10 Dec 2015	NDL	Par 37288
	if _bulkRelease.isPackingType then
		//packing children
		foreach reserve in _bulkRelease.allReservePackingChildren discreteLock do
			if _reserveSelection &lt;&gt; null and reserve &lt;&gt; _reserveSelection then	//03 Oct 2016	NDL	TFS 
				continue;
			endif;
			reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
			//foreach ti in reserve.allTrackedItems do
			foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
				if ti.isChild then
					//already packed
					continue;
				endif; 
				if ti.myPrimaryActualLocation = null then
					continue;
				endif;
	
				if ti.myPrimaryActualLocation = _targetLocation then
					continue;
				elseif ( _targetLocation &lt;&gt; null and _targetLocation.isWagon ) then	//26 Jan 2017	NDL	TFS 3198/2877
					if ti.myPrimaryActualLocation.isWagon
					and ( ti.myPrimaryActualLocation.CM_WagonController.myWagon = _targetLocation.CM_WagonController.myWagon )
					then
						continue;
					endif;
				endif;
				
				if not ti.isOnSite then
					continue;
				endif;
				_tiArray.addExclusive( ti );
			endforeach;
		endforeach;
	endif;
		
	if _bulkRelease.releaseByType and _tiArray.isEmpty then
		// release by type
		// get the prospective children - i.e. they are for the operator and match the release details
		opTerm := _bulkRelease.myOperatorTerminal;
		if opTerm &lt;&gt; null then
			// PAR 35781 
			if _bulkRelease.isPackingType then
				reserveDetails := _bulkRelease.allReservePackingChildren;
			else
				reserveDetails := _bulkRelease.allReserveDetails;
			endif;
			foreach reserve in reserveDetails discreteLock do
				if _reserveSelection &lt;&gt; null and reserve &lt;&gt; _reserveSelection then	//03 Oct 2016	NDL	TFS 
					continue;
				endif;
				if not reserve.isKindOf( CM_ReserveSelection ) then
					continue;
				endif;
				delete iter;
				iter := opTerm.allOnsiteTIsByCargoTypeId.createIterator;
				cargoType := reserve.CM_ReserveSelection.myCargoType;
				startObject := opTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq(cargoType.id, null);
				if startObject &lt;&gt; null then
					iter.startAtObject(startObject);
					while iter.next(ti) do
						if ti.cargoType &lt;&gt; cargoType.id then
							break;
						endif;
//				foreach ti in opTerm.allOnsiteTIsByCargoTypeId do
						if ti.myPrimaryActualLocation = null then
							continue;
						endif;
						if _bulkRelease.isPackingType then
							if ti.isContainer or ti.isChassis then
								//will be associated so as to be a parent not a child.
								continue;
							endif;
							if ti.isChild then
								//already packed
								continue;
							endif; 
						else
							//20 Mar 2017	NDL	TFS 3667
							if parentTi &lt;&gt; null then
								if ti.isChild then
									continue;
								endif;
							endif;
							
							if _targetLocation &lt;&gt; null then
								if _targetLocation.isWagon and ti.myPrimaryActualLocation.isWagon then
									if ti.myPrimaryActualLocation.CM_WagonController.myWagon = _targetLocation.CM_WagonController.myWagon then
										continue;
									endif;
								else
									if ti.myPrimaryActualLocation = _targetLocation then
										continue;
									endif;
								endif;
							endif;
							
							if _bulkRelease.isRoadType then    // 36127
								if ti.myPrimaryActualLocation.isVehicle then
									continue;
								elseif ti.myPrimaryActualLocation.isTILCController then
									continue;
								endif;
							endif;
						endif;
						if not ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
							continue;
						endif;
						//if (not allowOtherReleases) and ti.bulkReleaseAssignedCode &lt;&gt; _bulkRelease.code then	// 1 Nov 2016 cnwmp6 TFS 2858
						if (not allowOtherReleases) and ti.bulkReleaseAssignedCode &lt;&gt; null and ti.bulkReleaseAssignedCode &lt;&gt; _bulkRelease.code then	//09 Jan 2017	NDL	TFS 3138
						// don't want this one, as reserved for someone else
							continue;
						endif;
						_tiArray.addExclusive( ti );		
					endwhile;
				endif;
			endforeach;
		endif;
		
	endif;

epilog

	delete tiSet;
	delete iter;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection"/>
        <Parameter name="_stagedYardLocation" type="CM_LocationsController"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCargoBasedOnSTW12Rules" id="2fcdab5b-ea02-46b9-ae02-11d37ec0639f">
        <source>getCargoBasedOnSTW12Rules(	_bulkRelease : CM_BulkRelease;
							_selectedResDetail : CM_ReserveDetail;
							_stagedYardLocation : CM_LocationsController io;
							_targetLocation : CM_LocationsController;
							_stwRuleNum : Integer io;
							_tiArray : CM_TIArray io
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2017	cnwndl1	Initial creation	TFS 4016
02 Sep 2021 jlier1	TFS 51879 - called from web do not show msgboxes - changed if not using STW rules call BR::getProspectiveCargo 
23 Jun 2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
05 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars

	ruleNum : Integer;
	autoSelectedStageLC : CM_LocationsController;
	localTiSet : CM_TISet;
	dummyLC : CM_LocationsController;
	ti : CM_TrackedItem;
	resDet : CM_ReserveDetail;
	localResDetSet : CM_ReserveDetailSet;
	selectedResDetail : CM_ReserveDetail;
	dummyCount : Integer;
	dummySet : CM_TISet;
	reserveDetailSet : CM_ReserveDetailSet;
	allFullyLoaded : Boolean;
	stagedTA : CM_TerminalArea;
	allTis	: CM_TISet; 
	count : Integer;		// MTN-34024
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	if not self.myTerminal.getConfig(UseAltSelectRulesTL).Boolean then
		if _stagedYardLocation &lt;&gt; null then
			stagedTA:=_stagedYardLocation.myTerminalArea;
		endif;
		_bulkRelease.getProspectiveCargo(_selectedResDetail,stagedTA,_targetLocation,self.myPackTi, _tiArray, false, null, null, count);	// MTN-34024
		return;
	endif;

	ruleNum := _stwRuleNum;
	
	//21 Jun 2017 NDL	TFS 4016 - Add in the overriding 'show nothing' RULE if what we are looking at is fully loaded/fully packed
	if _selectedResDetail &lt;&gt; null then
		resDet := _selectedResDetail;
		create dummySet transient;
		dummyCount := resDet.getTotalStaged( dummySet, dummyLC, null );
		if dummyCount = 0 and resDet.isFullySPL() then
			//There is nothing staged, and the totals on the truck, OR packed equals the total outstanding.
			return;
		endif;
		
	elseif _bulkRelease &lt;&gt; null then
		if _bulkRelease.isPackingType then
			reserveDetailSet := _bulkRelease.allReservePackingChildren;
		else
			reserveDetailSet := _bulkRelease.allReserveDetails;
		endif;
		if reserveDetailSet.isEmpty then
			//nothing to check.
			allFullyLoaded := false;
		endif;
		create dummySet transient;
		allFullyLoaded := true;
		foreach resDet in reserveDetailSet do
			dummySet.clear();
			dummyCount := resDet.getTotalStaged( dummySet, dummyLC, null );
			if dummyCount &lt;&gt; 0 then
				allFullyLoaded := false;
				break;
			endif;
			if not resDet.isFullySPL() then
				allFullyLoaded := false;
				break;
			endif;
		endforeach;
		if allFullyLoaded then
			//There is nothing staged, and the totals on the truck, OR packed equals the total outstanding.
			return;
		endif;
		
	endif;
	
	if ruleNum = 0 then
		// no rule supplied, try and work it out.
		self.getCargoStagingDispRuleSTW( 	_bulkRelease,	//_bulkRelease : CM_BulkRelease;
											_selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
											autoSelectedStageLC,	//autoSelectedStageArea : CM_LocationsController output;
											ruleNum	//_stwRuleNum : Integer output
											);
		if ruleNum = 0 then
			//Can't establish which rule to use, use the old method
			if not self.doNotShowMsgBox then
				self.msgBox("Criteria doesn't meet one of the twelve rules. Using old default rules.", app.getErrorString(Warning), MsgBox_OK_Only, true);
			endif;
			if _selectedResDetail.isKindOf( CM_ReserveSelection ) then
				self.getBRPropsectiveChildCargo( _bulkRelease, _selectedResDetail.CM_ReserveSelection, _stagedYardLocation, _targetLocation, _tiArray );
			else
				self.getBRPropsectiveChildCargo( _bulkRelease, null, _stagedYardLocation, _targetLocation, _tiArray );
			endif;
			return;
			
		elseif autoSelectedStageLC &lt;&gt; null and autoSelectedStageLC &lt;&gt; _stagedYardLocation then
			_stwRuleNum := ruleNum;	//22 Jun 2017	 NDL 
			_stagedYardLocation := autoSelectedStageLC; 
		endif;
		
	endif;
	
	selectedResDetail := _selectedResDetail;
	if ruleNum.isOneOf(1,2,3,4) and selectedResDetail = null then
		if _bulkRelease.isPackingType then
			selectedResDetail := _bulkRelease.allReservePackingChildren.first;
		else
			selectedResDetail := _bulkRelease.allReserveDetails.first;
		endif;
	endif;
	
	create localTiSet transient;
	create localResDetSet transient;
	
	if ruleNum.isOneOf(2,6,8,10,12) then
		if ruleNum.isOneOf(6,8,10,12) and selectedResDetail = null then
			//We have some sort of error here, we are relying on this being set
			if not self.doNotShowMsgBox then		
				self.msgBox("Was trying to use rule '" &amp; ruleNum.String &amp; "' but no Reserve Selection established. Using old default rules.", app.getErrorString(Warning), MsgBox_OK_Only, true);
			endif;
			if selectedResDetail.isKindOf( CM_ReserveSelection ) then
				self.getBRPropsectiveChildCargo( _bulkRelease, selectedResDetail.CM_ReserveSelection, _stagedYardLocation, _targetLocation, _tiArray );
			else
				self.getBRPropsectiveChildCargo( _bulkRelease, null, _stagedYardLocation, _targetLocation, _tiArray );
			endif;
			return;
		endif;
		if ruleNum = 8 then
			if _stagedYardLocation = null then
				//We have some sort of error here, we are relying on this being set
				if not self.doNotShowMsgBox then	
					self.msgBox("Was trying to use rule '" &amp; ruleNum.String &amp; "' but no Staged Location established. Using old default rules.", app.getErrorString(Warning), MsgBox_OK_Only, true);
				endif;
				if selectedResDetail.isKindOf( CM_ReserveSelection ) then
					self.getBRPropsectiveChildCargo( _bulkRelease, selectedResDetail.CM_ReserveSelection, _stagedYardLocation, _targetLocation, _tiArray );
				else
					self.getBRPropsectiveChildCargo( _bulkRelease, null, _stagedYardLocation, _targetLocation, _tiArray );
				endif;
				return;
			endif;
		endif;
	endif;
	
	if ruleNum = 1 then
		/* If a Release Request has one Detail line (‘Release Item’) and cargo is fully staged into
		one area (‘Child Source Area’) = populate this staging area automatically and only show cargo from
		this location (in the next screen) for this release request only.*/
		selectedResDetail.getTotalStaged( localTiSet, dummyLC, null);
		if not localTiSet.isEmpty then
			localTiSet.copy(_tiArray);
		endif;
		
	elseif ruleNum = 2 then
		/* If a Release Request has one Detail line and cargo is fully staged into different areas = don’t
		populate any area and only show cargo from the staging locations (assigned to the Release), BUT if
		the user selects a staging area manually then do show cargo only from this location for this release request only.*/
		selectedResDetail.getTotalStaged( localTiSet, dummyLC, null);
		if _stagedYardLocation &lt;&gt; null then
			foreach ti in localTiSet do
				if _stagedYardLocation = null or ti.myPrimaryActualLocation = _stagedYardLocation then
					_tiArray.add(ti);	//24 May 2017	NDL - Testing
				endif;
			endforeach;
		else
			if not localTiSet.isEmpty then
				localTiSet.copy(_tiArray);
			endif;
		endif;
	
	elseif ruleNum = 3 then
		/* If a Release Request has one Detail line and cargo is partially staged = don’t populate any area
		and first show cargo assigned to the Release, followed by any available cargo.*/
		selectedResDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in selectedResDetail.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			if not ti.isOnSite then
				continue;
			endif;
			if ti.isChild then
				continue;
			endif;
			
			//25 May 2017	NDL	TFS 4016
			if _bulkRelease.isRoadType then  
				if ti.myPrimaryActualLocation = null then
					continue;
				elseif ti.myPrimaryActualLocation.isVehicle then
					continue;
				elseif ti.myPrimaryActualLocation.isTILCController then
					continue;
				endif;
			elseif _bulkRelease.isRailType then///09 Jun 2020	NDL`TFS 49537
				if ti.myPrimaryActualLocation = null then
					continue;
				elseif ti.myPrimaryActualLocation.isWagon then
					continue;
				endif;
			endif;
			
			//localTiSet.add(ti);
			_tiArray.add(ti);
		endforeach;
		
		if selectedResDetail.isKindOf( CM_ReserveSelection ) then
			selectedResDetail.CM_ReserveSelection.getOtherProspectsForSTW( _stagedYardLocation, localTiSet);
		endif;
		
		foreach ti in localTiSet do
			_tiArray.addExclusive( ti );
		endforeach;
		
	elseif ruleNum = 4 then
		/*If a Release Request has one Detail line and cargo is not staged = don’t populate any area
		and show all available cargo (not yet assigned to any other release).*/
		selectedResDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in selectedResDetail.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			if not ti.isOnSite then
				continue;
			endif;
			if ti.isChild then
				continue;
			endif;
			
			//25 May 2017	NDL	TFS 4016
			if _bulkRelease.isRoadType then  
				if ti.myPrimaryActualLocation = null then
					continue;
				elseif ti.myPrimaryActualLocation.isVehicle then
					continue;
				elseif ti.myPrimaryActualLocation.isTILCController then
					continue;
				endif;
			elseif _bulkRelease.isRailType then//09 Jun 2020	NDL`TFS 49537
				if ti.myPrimaryActualLocation = null then
					continue;
				elseif ti.myPrimaryActualLocation.isWagon then
					continue;
				endif;
			endif;
			
			localTiSet.add(ti);
		endforeach;
		
		if selectedResDetail.isKindOf( CM_ReserveSelection ) then
			selectedResDetail.CM_ReserveSelection.getOtherProspectsForSTW( _stagedYardLocation, localTiSet);
		endif;
		
		if not localTiSet.isEmpty then
			localTiSet.copy(_tiArray);
		endif;
	
	elseif ruleNum = 5 then
		/* If a Release Request has multiple Detail lines and all cargo is fully staged to the same
		area, but no specific Detail line is selected = populate the staging area automatically and
		show all cargo assigned to the release from this location.*/
		if _bulkRelease.isPackingType then
			foreach resDet in _bulkRelease.allReservePackingChildren do
				resDet.getTotalStaged( localTiSet, dummyLC, null);
			endforeach;
		else
			foreach resDet in _bulkRelease.allReserveDetails do
				resDet.getTotalStaged( localTiSet, dummyLC, null);
			endforeach;
		endif;
	//	if not localTiSet.isEmpty then
	//		localTiSet.copy(_tiArray);
	//	endif;
		//25 May 2017	NDL	TFS 4016
		foreach ti in localTiSet do
			if ti.myPrimaryActualLocation &lt;&gt; _stagedYardLocation then
				continue;
			endif;
			_tiArray.addExclusive(ti);
		endforeach;
	
	elseif ruleNum = 6 then
		/*If a Release Request has multiple Detail lines and all cargo is fully staged to the same
		area, but a specific Detail line is selected = populate the staging area automatically and
		show cargo from this location, but only assigned to the selected Detail line.*/
		selectedResDetail.getTotalStaged( localTiSet, dummyLC, null);
	//	if not localTiSet.isEmpty then
	//		localTiSet.copy(_tiArray);
	//	endif;
	//25 May 2017	NDL	TFS 4016
		foreach ti in localTiSet do
			if ti.myPrimaryActualLocation &lt;&gt; _stagedYardLocation then
				continue;
			endif;
			_tiArray.addExclusive(ti);
		endforeach;
	
	elseif ruleNum = 7 then
		/* If a Release Request has multiple Detail lines and all cargo is fully staged to different
		areas (even within one Detail line), but no specific Detail line is selected = don’t populate
		any area and show cargo from all staging locations, but assigned to the Release.*/
		if _bulkRelease.isPackingType then
			foreach resDet in _bulkRelease.allReservePackingChildren do
				resDet.getTotalStaged( localTiSet, dummyLC, null);
			endforeach;
		else
			foreach resDet in _bulkRelease.allReserveDetails do
				resDet.getTotalStaged( localTiSet, dummyLC, null);
			endforeach;
		endif;
		if not localTiSet.isEmpty then
			localTiSet.copy(_tiArray);
		endif;
	
	elseif ruleNum = 8 then
		/* If a Release Request has multiple Detail lines and cargo from each line is fully staged to
		different areas (i.e. one staging area per Detail line), but a specific Detail line is selected
		= populate the relevant staging area and show cargo from this location, but only assigned to the
		selected Detail line.*/
		selectedResDetail.getTotalStaged( localTiSet, dummyLC, null);
		foreach ti in localTiSet do
			if ti.myPrimaryActualLocation &lt;&gt; _stagedYardLocation then
				continue;
			endif;
			_tiArray.addExclusive(ti);
		endforeach;
	
	elseif ruleNum = 9 then
		/*If a Release Request has multiple Detail lines and only some lines are fully staged, but no specific
		Detail line is selected = don’t populate any area and first show cargo assigned to the Release, followed
		by any available cargo (for non-staged Detail lines). */
		if _bulkRelease.isPackingType then
			foreach resDet in _bulkRelease.allReservePackingChildren do
				resDet.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
				//foreach ti in resDet.allTrackedItems do
				foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
					if not ti.isOnSite then
						continue;
					endif;
					if ti.isChild then
						continue;
					endif;
					localTiSet.addNoDuplicates(ti,false);	//24 May 2017 NDL remove potential for 1309
				endforeach;
				if resDet.isKindOf( CM_ReserveSelection ) and not resDet.isFullySPL() then
					localResDetSet.add( resDet );
				endif;
			endforeach;
		else
			foreach resDet in _bulkRelease.allReserveDetails do
				resDet.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
				//foreach ti in resDet.allTrackedItems do
				foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
					if not ti.isOnSite then
						continue;
					endif;
					if ti.isChild then
						continue;
					endif;
					
					//25 May 2017	NDL	TFS 4016
					if _bulkRelease.isRoadType then  
						if ti.myPrimaryActualLocation = null then
							continue;
						elseif ti.myPrimaryActualLocation.isVehicle then
							continue;
						elseif ti.myPrimaryActualLocation.isTILCController then
							continue;
						endif;
					elseif _bulkRelease.isRailType then//09 Jun 2020	NDL`TFS 49537
						if ti.myPrimaryActualLocation = null then
							continue;
						elseif ti.myPrimaryActualLocation.isWagon then
							continue;
						endif;
					endif;
			
					localTiSet.addNoDuplicates(ti,false);	//24 May 2017 NDL remove potential for 1309
				endforeach;
				if resDet.isKindOf( CM_ReserveSelection ) and not resDet.isFullySPL() then
					localResDetSet.add( resDet );
				endif;
			endforeach;
		endif;
		if not localTiSet.isEmpty then
			localTiSet.copy(_tiArray);
		endif;
		
		localTiSet.clear();
		foreach resDet in localResDetSet do
			resDet.CM_ReserveSelection.getOtherProspectsForSTW( null, localTiSet);
		endforeach;
		foreach ti in localTiSet do
			_tiArray.addExclusive(ti);
		endforeach;
	
	elseif ruleNum = 10 then
		/*  If a Release Request has multiple Detail lines and only some lines are fully staged, but a specific
		Detail line (which is fully staged) is selected = show all staged for the selected reserve detail regardless
		of location, but only assigned to the selected Detail line..*/
		selectedResDetail.getTotalStaged( localTiSet, dummyLC, null);
		if not localTiSet.isEmpty then
			localTiSet.copy(_tiArray);
		endif;
	
	elseif ruleNum = 11 then
		/*  If a Release Request has multiple Detail lines, where when no cargo has been staged and no specific
		Detail line is selected  = don’t populate any area and show all available cargo from all Detail lines
		(not yet assigned to any other Release).*/
		if _bulkRelease.isPackingType then
			foreach resDet in _bulkRelease.allReservePackingChildren do
				if resDet.isKindOf( CM_ReserveSelection) then
					resDet.CM_ReserveSelection.getOtherProspectsForSTW( null, localTiSet);
				else
					resDet.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
					//foreach ti in resDet.allTrackedItems do
					foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
						if not ti.isOnSite then
							continue;
						endif;
						if ti.isChild then
							continue;
						endif;
						localTiSet.addNoDuplicates(ti,false);
					endforeach;
				endif;
			endforeach;
		else
			foreach resDet in _bulkRelease.allReserveDetails do
				if resDet.isKindOf( CM_ReserveSelection) then
					resDet.CM_ReserveSelection.getOtherProspectsForSTW( null, localTiSet);
				else
					resDet.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
					//foreach ti in resDet.allTrackedItems do
					foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
						if not ti.isOnSite then
							continue;
						endif;
						if ti.isChild then
							continue;
						endif;
						
						//25 May 2017	NDL	TFS 4016
						if _bulkRelease.isRoadType then  
							if ti.myPrimaryActualLocation = null then
								continue;
							elseif ti.myPrimaryActualLocation.isVehicle then
								continue;
							elseif ti.myPrimaryActualLocation.isTILCController then
								continue;
							endif;
						elseif _bulkRelease.isRailType then//09 Jun 2020	NDL`TFS 49537
							if ti.myPrimaryActualLocation = null then
								continue;
							elseif ti.myPrimaryActualLocation.isWagon then
								continue;
							endif;
						endif;
			
						localTiSet.addNoDuplicates(ti,false);
					endforeach;
				endif;
			endforeach;
		endif;
		if not localTiSet.isEmpty then
			localTiSet.copy(_tiArray);
		endif;
	
	elseif ruleNum = 12 then
		/*  If a Release Request has multiple Detail lines, when no cargo has been staged and a specific Detail
		line is selected  = don’t populate any area and show all available cargo, but only relevant to the
		selected Detail line (not yet assigned to any other Release).*/
		selectedResDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in selectedResDetail.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			if not ti.isOnSite then
				continue;
			endif;
			if ti.isChild then
				continue;
			endif;
			
			//25 May 2017	NDL	TFS 4016
			if _bulkRelease.isRoadType then  
				if ti.myPrimaryActualLocation = null then
					continue;
				elseif ti.myPrimaryActualLocation.isVehicle then
					continue;
				elseif ti.myPrimaryActualLocation.isTILCController then
					continue;
				endif;
			elseif _bulkRelease.isRailType then//09 Jun 2020	NDL`TFS 49537
				if ti.myPrimaryActualLocation = null then
					continue;
				elseif ti.myPrimaryActualLocation.isWagon then
					continue;
				endif;
			endif;
			
			localTiSet.add(ti);
		endforeach;
		
		if selectedResDetail.isKindOf( CM_ReserveSelection ) then
			selectedResDetail.CM_ReserveSelection.getOtherProspectsForSTW( _stagedYardLocation, localTiSet);
		endif;
		
		if not localTiSet.isEmpty then
			localTiSet.copy(_tiArray);
		endif;
		
	endif;
	
epilog

	delete localTiSet;
	delete localResDetSet;
	
	delete dummySet;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_selectedResDetail" type="CM_ReserveDetail"/>
        <Parameter name="_stagedYardLocation" type="CM_LocationsController" usage="io"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_stwRuleNum" type="Integer" usage="io"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCargoStagingDispRuleSTW" id="5c609f1e-0ed1-4e6c-99af-40a3a054e9ba">
        <source>getCargoStagingDispRuleSTW( _bulkRelease : CM_BulkRelease;
							_selectedResDetail : CM_ReserveDetail;
							autoSelectedStageArea : CM_LocationsController output;
							_stwRuleNum : Integer output
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2017	cnwndl1	Initial creation	TFS 4016

*/

vars

	reserveDetail : CM_ReserveDetail;
	firstStagingLC : CM_LocationsController;
	resDetCount : Integer;
	stagedCount : Integer;
	multiTiSet : CM_TISet;
	multiLcSet : CM_LCSet;
	singleTiSet : CM_TISet;
	singleLcSet : CM_LCSet;
	singleFullyStaged : Boolean;
	allFullyStaged : Boolean;
	someFullyStaged : Boolean;

begin

	if _bulkRelease = null then
		return;
	endif;

		/*
May 19th 2017
			Now applies to all releases and pack parents should be ignored in teh reservedetail count.
		
May 12th 2017 version of the rules 		
1. If a Release Request has one Detail line (‘Release Item’) and cargo is fully staged into one area (‘Child Source Area’) = populate
 this staging area automatically and only show cargo from this location (in the next screen) for this release request only.
2. If a Release Request has one Detail line and cargo is fully staged into different areas = don’t populate any area and only show
 cargo from the staging locations (assigned to the Release), BUT if the user selects a staging area manually then do show cargo only
 from this location for this release request only. 
3. If a Release Request has one Detail line and cargo is partially staged = don’t populate any area and first show cargo assigned to
 the Release, followed by any available cargo.
4. If a Release Request has one Detail line and cargo is not staged = don’t populate any area and show all available cargo (not yet
 assigned to any other release).
5. If a Release Request has multiple Detail lines and all cargo is fully staged to the same area, but no specific Detail line is
 selected = populate the staging area automatically and show all cargo assigned to the release from this location.
6. If a Release Request has multiple Detail lines and all cargo is fully staged to the same area, but a specific Detail line is
 selected = populate the staging area automatically and show cargo from this location, but only assigned to the selected Detail line.
7. If a Release Request has multiple Detail lines and all cargo is fully staged to different areas (even within one Detail line),
 but no specific Detail line is selected = don’t populate any area and show cargo from all staging locations, but assigned to the Release.
8. If a Release Request has multiple Detail lines and cargo from each line is fully staged to different areas (i.e. one staging
 area per Detail line), but a specific Detail line is selected = populate the relevant staging area and show cargo from this location,
 but only assigned to the selected Detail line.
9. If a Release Request has multiple Detail lines and only some lines are fully staged, but no specific Detail line is selected = don’t
 populate any area and first show cargo assigned to the Release, followed by any available cargo (for non-staged Detail lines).
10.  If a Release Request has multiple Detail lines and only some lines are fully staged, but a specific Detail line (which is fully
 staged) is selected = show all staged for the selected reserve detail regardless of location, but only assigned to the selected Detail line.
11.  If a Release Request has multiple Detail lines, where when no cargo has been staged and no specific Detail line is selected  = don’t
 populate any area and show all available cargo from all Detail lines (not yet assigned to any other Release).
12.  If a Release Request has multiple Detail lines, when no cargo has been staged and a specific Detail line is selected  = don’t
 populate any area and show all available cargo, but only relevant to the selected Detail line (not yet assigned to any other Release).
				
		*/
		
		
		
			create singleTiSet transient;
			create singleLcSet transient;
			create multiTiSet transient;
			create multiLcSet transient;
				
			if _bulkRelease.isPackingType then
				resDetCount := _bulkRelease.allReservePackingChildren.size;
			else
				resDetCount := _bulkRelease.allReserveDetails.size;
			endif;
			
			
			if resDetCount = 1 then
				// single reserve detail line, rules 1 thru 4 may apply.
				if _bulkRelease.isPackingType then
					reserveDetail := _bulkRelease.allReservePackingChildren.first;
				else
					reserveDetail := _bulkRelease.allReserveDetails.first;
				endif;
				
				stagedCount := reserveDetail.getTotalStaged( singleTiSet, firstStagingLC, singleLcSet );
				singleFullyStaged := reserveDetail.isFullySPL();
				
				//Rule 1.
				if singleLcSet.size = 1 and singleFullyStaged then
					// single reserve detail line
					//fully staged in one area
					autoSelectedStageArea := singleLcSet.first;
					_stwRuleNum := 1;
					
				//Rule 2.
				elseif singleLcSet.size &gt; 1 and singleFullyStaged  then
					// single reserve detail line
					//fully staged over more than one area
					_stwRuleNum := 2;  
					
				//Rule 3.
				elseif stagedCount &gt; 0 and not singleFullyStaged then
					// single reserve detail line
					//partially staged
					_stwRuleNum := 3;
					
				//Rule 4.
				elseif stagedCount = 0 then
					// single reserve detail line
					//nothing staged
					_stwRuleNum := 4;
					
				endif;
				
				
			elseif resDetCount &gt; 1 then
				// multiple reserve detail, rules 5 thru 12 may apply.
				allFullyStaged := true;
				
				if _bulkRelease.isPackingType then
					foreach reserveDetail in _bulkRelease.allReservePackingChildren do
						if not reserveDetail.isFullySPL() then
							allFullyStaged := false;
						else
							someFullyStaged := true;
						endif;
						reserveDetail.getTotalStaged( multiTiSet, firstStagingLC, multiLcSet );
					endforeach;
				else
					foreach reserveDetail in _bulkRelease.allReserveDetails do
						if not reserveDetail.isFullySPL() then
							allFullyStaged := false;
						else
							someFullyStaged := true;
						endif;
						reserveDetail.getTotalStaged( multiTiSet, firstStagingLC, multiLcSet );
					endforeach;
				endif;
				
				if _selectedResDetail &lt;&gt; null then
					_selectedResDetail.getTotalStaged( singleTiSet, firstStagingLC, singleLcSet );
					singleFullyStaged := _selectedResDetail.isFullySPL();
				endif;
				
				//Rule 5.
				if _selectedResDetail = null and allFullyStaged and multiLcSet.size = 1 then
					// multiple reserve detail
					// no reserve detail selected
					// all fully staged to one area
					autoSelectedStageArea := multiLcSet.first;
					_stwRuleNum := 5;
				
				//Rule 6.
				elseif _selectedResDetail &lt;&gt; null and allFullyStaged and multiLcSet.size = 1 then
					// multiple reserve detail
					// reserve detail is selected
					// all fully staged to one area
					autoSelectedStageArea := multiLcSet.first;
					_stwRuleNum := 6; 
				
				//Rule 7.
				elseif _selectedResDetail = null and allFullyStaged and multiLcSet.size &gt; 1 then
					// multiple reserve detail
					// no reserve detail selected
					// all fully staged but to more than one area
					_stwRuleNum := 7; 
				
				//Rule 8.
				elseif _selectedResDetail &lt;&gt; null and allFullyStaged and multiLcSet.size &gt; 1 then
					// multiple reserve detail
					// reserve detail is selected
					// all fully staged but to more than one area
					autoSelectedStageArea := singleLcSet.first;
					_stwRuleNum := 8;
				
				//Rule 9.
				elseif _selectedResDetail = null and someFullyStaged then
					// multiple reserve detail
					// no reserve detail selected
					// Some fully staged
					_stwRuleNum := 9;
				
				//Rule 10.
				elseif _selectedResDetail &lt;&gt; null and singleFullyStaged then
					// multiple reserve detail
					// reserve detail is selected
					// the selected one is fully staged
					_stwRuleNum := 10; 
				
				//Rule 11.
				elseif _selectedResDetail = null and multiTiSet.isEmpty then
					// multiple reserve detail
					// no reserve detail selected
					// nothing staged
					_stwRuleNum := 11;
				
				//Rule 12.
				elseif _selectedResDetail &lt;&gt; null and multiTiSet.isEmpty then
					// multiple reserve detail
					// reserve detail is selected
					// nothing staged
					_stwRuleNum := 12;
				
				endif;
				
			endif;
			
			delete singleTiSet;
			delete singleLcSet;
			delete multiTiSet;
			delete multiLcSet;

epilog

	delete multiTiSet;
	delete multiLcSet;
	delete singleTiSet;
	delete singleLcSet;

end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_selectedResDetail" type="CM_ReserveDetail"/>
        <Parameter name="autoSelectedStageArea" type="CM_LocationsController" usage="output"/>
        <Parameter name="_stwRuleNum" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getEquipCheckContextFromState" id="1ed21755-f7ab-4e4f-a3d1-5319c7920c09">
        <source>getEquipCheckContextFromState() : CM_CargoCheck;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars
	context : Integer;

begin
	if self.checksState = self.ShipDischargeCargo then
		context := CARGO_CHECK_CONTEXT_SHIP_DISC;
	elseif self.checksState = self.ShipLoadCargo then
		context := CARGO_CHECK_CONTEXT_SHIP_LOAD;
	elseif self.checksState = self.GateReceipt then
		context := CARGO_CHECK_CONTEXT_GATE_REC;
	elseif self.checksState = self.GateRelease then
		context := CARGO_CHECK_CONTEXT_GATE_REL;
	elseif self.checksState = self.Yard then
		context := CARGO_CHECK_CONTEXT_YARD;
	elseif self.checksState = self.TruckLoad then
		context := CARGO_CHECK_CONTEXT_TRUKLOAD;
	elseif self.checksState = self.TruckUnload then
		context := CARGO_CHECK_CONTEXT_TRUKUNLOAD;
	elseif self.checksState = self.RailReceipt then	//16 Aug 2010	NDL	Par 25215
		context := CARGO_CHECK_CONTEXT_RAIL_REC;
	elseif self.checksState = self.RailRelease then	//16 Aug 2010	NDL	Par 25215
		context := CARGO_CHECK_CONTEXT_RAIL_REL;
	elseif self.checksState = self.PackCargo then	//04 Jul 2011	NDL	Par 26476
		context := CARGO_CHECK_CONTEXT_PACK;
	elseif self.checksState = self.UnpackCargo then	//04 Jul 2011	NDL	Par 26476
		context := CARGO_CHECK_CONTEXT_UNPACK;
	elseif self.checksState = self.WagonLoad then	//11 Mar 2015	NDL	Par 35828
		context := WAGON_CHECK_CONTEXT_PLACE_OUT;
	elseif self.checksState = self.WagonUnload then	//11 Mar 2015	NDL	Par 35828
		context := WAGON_CHECK_CONTEXT_PLACE_IN;
	elseif self.checksState = self.PackCargoComplete then	//08 Mar 2017	NDl	TFS 3635
		context := CONT_CHECK_CONTEXT_PACK;
	elseif self.checksState = self.UnpackCargoComplete then	//08 Mar 2017	NDl	TFS 3635
		context := CONT_CHECK_CONTEXT_UNPACK;
	endif;
	
	return self.myTerminal.allCargoChecks[context];
epilog

end;</source>
        <ReturnType type="CM_CargoCheck"/>
    </JadeMethod>
    <JadeMethod name="getEquipChkContextFromChkState" id="3d1ed097-8f0f-46e8-a006-f8ab0377e506">
        <source>getEquipChkContextFromChkState():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

begin

	if self.checksState = self.GateReceipt then
		return CARGO_CHECK_CONTEXT_GATE_REC;
	elseif self.checksState = self.GateRelease then
		return CARGO_CHECK_CONTEXT_GATE_REL;
	elseif self.checksState = self.RailReceipt then
		return CARGO_CHECK_CONTEXT_RAIL_REC;
	elseif self.checksState = self.RailRelease then
		return CARGO_CHECK_CONTEXT_RAIL_REL;
	elseif self.checksState = self.ShipDischargeCargo then
		return CARGO_CHECK_CONTEXT_SHIP_DISC;
	elseif self.checksState = self.ShipLoadCargo then
		return CARGO_CHECK_CONTEXT_SHIP_LOAD;
	elseif self.checksState = self.TruckLoad then
		return CARGO_CHECK_CONTEXT_TRUKLOAD;
	elseif self.checksState = self.TruckUnload then
		return CARGO_CHECK_CONTEXT_TRUKUNLOAD;
	elseif self.checksState = self.Yard then
		return CARGO_CHECK_CONTEXT_YARD;
	elseif self.checksState = self.PackCargo then	//04 Jul 2011	NDL	Par 26476
		return CARGO_CHECK_CONTEXT_PACK;
	elseif self.checksState = self.UnpackCargo then	//04 Jul 2011	NDL	Par 26476
		return CARGO_CHECK_CONTEXT_UNPACK;
	elseif self.checksState = self.WagonLoad then	//11 Mar 2015	NDL	Par 35828
		return WAGON_CHECK_CONTEXT_PLACE_OUT;
	elseif self.checksState = self.WagonUnload then	//11 Mar 2015	NDL	Par 35828
		return WAGON_CHECK_CONTEXT_PLACE_IN;
	elseif self.checksState = self.PackCargoComplete then	//08 Mar 2017	NDl	TFS 3635
		return CONT_CHECK_CONTEXT_PACK;
	elseif self.checksState = self.UnpackCargoComplete then	//08 Mar 2017	NDl	TFS 3635
		return CONT_CHECK_CONTEXT_UNPACK;
	else
		return 0;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEquipmentHasICargoChecks" id="9fafd5df-64b1-4414-b9d7-9682c98962c3">
        <source>getEquipmentHasICargoChecks(_obj : CM_Object) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars
	item : CM_TICargoChecks;
begin
	foreach item  in self.allCargoCheckItemSelections do
		if item.myTrackedItem = _obj then
			return true;
		endif;
	endforeach;
	
	foreach item  in self.allNonCargoCheckItemSelections do
		if item.myCheckedObject = _obj then
			return true;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLanderCargoTargetLocation" id="6ca65817-fca5-4f0f-aa63-3984a1224101">
        <source>getLanderCargoTargetLocation(_cargo : CM_TrackedItem input) : String;
/*

Date		Who		Reason
22 November 2016	cnwer1	Initial creation TFS 2732
16/05/2019	JLGNS1	Bug 44555: SNO - Web Service Exception in Job Lander
28 Jan 2020	jlgka1	TFS 45987 - JMT - Lander Apps WLE Picker
*/

vars
	allLoadLCs : CM_LCArray;
	allWles : CM_WLEArray;
	wle : CM_WorkListEntry;
begin
	if _cargo = null then
		return null;
	endif;
	
	if self.checksState = self.ShipLoadCargo then
		create allWles transient;
		_cargo.getVoyageWLEforLanderLoad(wle,null,self.myVoyage,allWles, null);
		if wle &lt;&gt; null then
			if wle.getTargetLocation &lt;&gt; null then					//Bug 44555
				return wle.getTargetLocation.getStowageId(_cargo);
			endif;
		endif;
	elseif self.checksState = self.ShipDischargeCargo then
		return _cargo.getDischargeLocationID();
	elseif self.checksState = self.ShiftOnBoard then
		return _cargo.getSOBLocationID();
	endif;
	
	return null;
epilog
	delete allLoadLCs;
	delete allWles;
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLoadedWleFor" id="efb16799-1f48-45e3-a30b-d7ca18a75c03">
        <source>getLoadedWleFor( _ti : CM_TrackedItem ):CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	wle : CM_WorkListEntry;
	
begin

	iter := self.allLoadedWles.createIterator;
	while iter.next( wle ) do
		if wle.myTrackedItem = _ti then
			return wle;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getMatchingTIsForMerge" id="7d0160d3-c3c9-44d8-9338-de10d0cca8d7">
        <source>getMatchingTIsForMerge(_myCargo : CM_Cargo ; _allTis : CM_TISet io) : Boolean ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2016	cnwns1	Initial creation

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	startObject : Object;
	cargoType : Integer;
	operator : CM_Operator;
	location : CM_LocationsController;
	strArray : StringArray;

begin
	
	_allTis.clear();
	
	if _myCargo &lt;&gt; null
	and _myCargo.myCargoType &lt;&gt; null
	and _myCargo.myCargoType.allowDuplicates
	then

		cargoType := _myCargo.cargoType;
		operator := _myCargo.myOperator;
		location := _myCargo.myPrimaryActualLocation;
		startObject := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType,null);
		
		if startObject &lt;&gt; null then
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			iter.startAtObject( startObject );
			while iter.next( ti ) do
				if ti.cargoType &lt;&gt; cargoType then
					break;
				endif;
				if ti = _myCargo then
					continue;
				endif;
				if ti.myOperator &lt;&gt; operator then
					continue;
				endif;
				if ti.myPrimaryActualLocation &lt;&gt; location then
					continue;
				endif;
				if ti.totalQuantity &lt; 1 then
					continue;
				endif;
				if ti.totalWeight &lt; 1 then
					continue;
				endif;
				_allTis.add(ti);
			endwhile;
		endif;
	
	endif;
	
	if _allTis.isEmpty then
		return false;
	endif;
	
	return true;

	

epilog

	delete iter;
	delete strArray;

end;</source>
        <Parameter name="_myCargo" type="CM_Cargo"/>
        <Parameter name="_allTis" type="CM_TISet" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNextTI" id="198041b4-f08b-4291-9bb0-cda87c2ba7f5">
        <source>getNextTI(_ti : CM_TrackedItem; _reefersOnly, _columnOrder : Boolean) : CM_TrackedItem;
/*

Purpose:			Moved from MobileServerSchema::CM_MobileAgent

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwmc5	Initial creation

** HISTORY **
adm 270509 Par 19504 traverseColumns
dmp 151209 CCMS MES 1007 Any tracked item can now be a reefer, not just containers
*/

vars
	nextLoc : CM_GridController;
	nextTI  : CM_TrackedItem;  // PAR 19783 cnwgb1 27.5.09
	arrIdx  : Integer;
begin
	if _ti &lt;&gt; null then
		if _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation.isKindOf(CM_GridController) then
			arrIdx := _ti.myPrimaryActualLocation.allTrackedItems.indexOf(_ti);
			// if there is another container at the same location that comes after the provided TI in the array then return that one
			while arrIdx &lt; _ti.myPrimaryActualLocation.allTrackedItems.size do
				nextTI := _ti.myPrimaryActualLocation.allTrackedItems[arrIdx + 1];
				//if nextTI &lt;&gt; null and (not _reefersOnly or (nextTI.isKindOf(CM_Container) and nextTI.CM_Container.isReefer)) then // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
				if nextTI &lt;&gt; null and (not _reefersOnly or (nextTI.isReefer)) then // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
					return nextTI;
				endif;
				arrIdx := arrIdx + 1;
			endwhile;
			
			// keep going until we find a next location that has a container in it
			nextLoc := _ti.myPrimaryActualLocation.CM_GridController.getNextController(_columnOrder);
			while nextLoc &lt;&gt; null do
				if nextLoc.allTrackedItems.size &gt; 0 then
					arrIdx := 1;
				// There are situations where the next/previous can refer to a location controller that contains the same
				// containers as the previous/next one. Therefore we want to skip this occurance to the next one without the
				// provided container
					if not nextLoc.allTrackedItems.includes(_ti) then
				// if there is another container at the same location that comes after the provided TI in the array then return that one
						while arrIdx &lt;= nextLoc.allTrackedItems.size do
							nextTI := nextLoc.allTrackedItems[arrIdx];
							//if nextTI &lt;&gt; null and (not _reefersOnly or (nextTI.isKindOf(CM_Container) and nextTI.CM_Container.isReefer)) then  // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
							if nextTI &lt;&gt; null and (not _reefersOnly or (nextTI.isReefer)) then  // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
								return nextTI;
							endif;
							arrIdx := arrIdx + 1;
						endwhile;
					endif;
				endif;
				nextLoc := nextLoc.getNextController(_columnOrder);
			endwhile;
		endif;
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reefersOnly" type="Boolean"/>
        <Parameter name="_columnOrder" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getNextTiToConfirm" id="1130b8e5-4703-41f5-ab2c-ef8cc6b30417">
        <updating/>
        <source>getNextTiToConfirm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	
begin

	self.setMyNextTiToAction( null );

	foreach ti in self.allTruckTis do
		if not self.allConfirmedTis.includes(ti) then
			self.setMyNextTiToAction( ti );
			return;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getOnTruckCargoCount" id="177dcfde-3e58-45b0-b57e-03f122e7d37b">
        <source>getOnTruckCargoCount():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	int : Integer;
	ti : CM_TrackedItem;

begin

	int := self.allLoadedTis.size;
	
	foreach ti in self.allLoadedTis do
		if ti.canSplitTotalQuantity then
			int := int + ( ti.totalQuantity - 1 );
		endif;
	endforeach;
	
	return int;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPreviousTI" id="14c61d8c-2c0d-41ca-99c4-7b5da1e17152">
        <source>getPreviousTI(_ti : CM_TrackedItem; _reefersOnly, _columnOrder : Boolean) : CM_TrackedItem;
/*

Purpose:			Moved from MobileServerSchema::CM_MobileAgent

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwmc5	Initial creation

** HISTORY **
adm 270509 Par 19504 traverseColumns
dmp 151209 CCMS MES 1007 Any tracked tem can now be a reefer, not just containers
*/

vars
	prevLoc : CM_GridController;
	prevTI  : CM_TrackedItem;  // PAR 19783 cnwgb1 27.5.09
	arrIdx  : Integer;
begin
	if _ti &lt;&gt; null then
		if _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation.isKindOf(CM_GridController) then
			arrIdx := _ti.myPrimaryActualLocation.allTrackedItems.indexOf(_ti);
			// if there is another container at the same location that comes after the provided TI in the array then return that one
			while arrIdx &gt; 1 do
				prevTI := _ti.myPrimaryActualLocation.allTrackedItems[arrIdx - 1];
				//if prevTI &lt;&gt; null and (not _reefersOnly or (prevTI.isKindOf(CM_Container) and prevTI.CM_Container.isReefer)) then  // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
				if prevTI &lt;&gt; null and (not _reefersOnly or (prevTI.isReefer)) then  // PAR 19783 cnwgb1 27.5.09														// CCMS 1007
					return prevTI;
				endif;
				arrIdx := arrIdx - 1;
			endwhile;
			
			// keep going until we find a next location that has a container in it
			prevLoc := _ti.myPrimaryActualLocation.CM_GridController.getPreviousController(_columnOrder);
			while prevLoc &lt;&gt; null do
				if prevLoc.allTrackedItems.size &gt; 0 then
					arrIdx := prevLoc.allTrackedItems.size;
				// There are situations where the next/previous can refer to a location controller that contains the same
				// containers as the previous/next one. Therefore we want to skip this occurance to the next one without the
				// provided container
					if not prevLoc.allTrackedItems.includes(_ti) then
						// if there is another container at the same location that comes after the provided TI in the array then return that one
						while arrIdx &gt; 0 do
							prevTI := prevLoc.allTrackedItems[arrIdx];
							//if prevTI &lt;&gt; null and (not _reefersOnly or (prevTI.isKindOf(CM_Container) and prevTI.CM_Container.isReefer)) then  // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
							if prevTI &lt;&gt; null and (not _reefersOnly or (prevTI.isReefer)) then  												 // PAR 19783 cnwgb1 27.5.09	// CCMS 1007
								return prevTI;
							endif;
							arrIdx := arrIdx - 1;
						endwhile;
					endif;
				endif;
				prevLoc := prevLoc.getPreviousController(_columnOrder);
			endwhile;
		endif;
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reefersOnly" type="Boolean"/>
        <Parameter name="_columnOrder" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getReserveDetailCargoMatches" id="517dc06b-f996-4611-a98c-7886146d9744">
        <source>getReserveDetailCargoMatches( _ti : CM_TrackedItem; _quantity : Integer; _weight : Decimal; _reason : String output ):CM_ReserveDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2016	cnwndl1	Initial creation	TFS 1593
18 Dec 2024		navah1	Bug 12555: MTN - Getting an exception in the pack load by request app when using release request by id
*/

vars

	reserveDetail : CM_ReserveDetail;
	ti : CM_TrackedItem;
	desc : String;
	reserveDetails : CM_ReserveDetailSet;

begin

	if self.myBulkRelease = null then
		
		_reason := app.getErrorString(Unknown_bulk_release);	//10 Nov 2015	NDL	Par 37092
		return null;
	endif;

	if self.myBulkRelease.isPackingType then
		//reserveDetails := self.myBulkRelease.allReservePackingChildren;  //18.12.2024 navah1 #12555
		if self.myBulkRelease.releaseByType then						   //18.12.2024 navah1 #12555
			reserveDetails := self.myBulkRelease.allReservePackingChildren;
		else
			reserveDetails := self.myBulkRelease.allReserveDetails;
		endif;
		
	else
		reserveDetails := self.myBulkRelease.allReserveDetails;
	endif;
	
	foreach reserveDetail in reserveDetails do
		if reserveDetail.isKindOf(CM_ReserveTI) then

			_reason := app.getErrorString1(Not_reserve_cargo_items, _ti.id);	//10 Nov 2015	NDL	Par 37092
			ti := reserveDetail.CM_ReserveTI.getTI;	//28 Oct 2014	NDL	Par 35129
			if ti = _ti then
				_reason := null;
				return reserveDetail;
			elseif ti.id = _ti.id and ti.cargoType = _ti.cargoType then	//28 Oct 2014	NDL	Par 35129
				_reason := null;
				return reserveDetail;
			endif;
		endif;
	endforeach;
	foreach reserveDetail in reserveDetails do
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			desc := reserveDetail.CM_ReserveSelection.getTotalRequestedDisplay() &amp; ' x ' &amp; reserveDetail.CM_ReserveSelection.getProductISOTypeDescr();
			if reserveDetail.CM_ReserveSelection.myCargoType = null then
				desc := desc &amp; " " &amp; app.getErrorString(Unspecified_Cargo_Type);
			endif;
			
			if not _ti.testAgainstReserveSelection( reserveDetail.CM_ReserveSelection, _reason, false, null ) then
				_reason := desc &amp; " " &amp; _reason;
				continue;
			else
			
				self.validatePackForReserveDetails( reserveDetail, _ti, _quantity, _weight, _reason );
		
				if _reason = null then
					return reserveDetail;
				endif;
			endif;
		endif;
	endforeach;

	return null;

epilog
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_reason" type="String" usage="output"/>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="getServerPrinters" id="0c4046b1-cac1-4b40-8a6c-68b373ee2838">
        <executionLocation>server</executionLocation>
        <source>getServerPrinters( _printers : StringArray input ) serverExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2016	cnwma1	Initial creation TFS 1488 JMT Mobile Apps - RecRel - Gate Checker

*/

vars

begin

	app.printer.getAllPrinters(_printers);

epilog

end;</source>
        <Parameter name="_printers" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="3c8bcb2b-84ca-4875-8f05-6cbcef8d0a41">
        <updating/>
        <source>getTerminal():CM_Terminal updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 March 2016	cnwndl1	Initial creation
31 March 2021	navmd1	TFS 51047 Reduce log clutter a little by changing levels to Debug

*/

vars
	iniFileName : String;
	strTerminalName : String;
	term : CM_Terminal;
begin

	if self.myInterTerminal &lt;&gt; null then
		app.writeLog("getTerminal is returning myInterTerminal: " &amp; myInterTerminal.name, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return self.myInterTerminal;
	endif;
	
	if self.myTerminal &lt;&gt; null then
		app.writeLog("getTerminal is returning myTerminal: " &amp; myTerminal.name, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return self.myTerminal;
	endif;
	
	
	iniFileName := app.getIniFileName();
	app.writeLog("Inifilename: " &amp; iniFileName, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	if iniFileName &lt;&gt; null then
		strTerminalName := app.getProfileString(iniFileName, RTIniFileSection, MOB_TerminalName, null);
		app.writeLog("strTerminalName: " &amp; strTerminalName, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if strTerminalName &lt;&gt; null then
			term := app.myRoot.allTerminals[strTerminalName];
			app.writeLog("term: " &amp; term.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			if term &lt;&gt; null then
				return term;
			endif;
		endif;
	endif;
	
	app.writeLog("getMyTerminalDO_NOT_USE: " &amp; app.getMyTerminalDO_NOT_USE.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	return app.getMyTerminalDO_NOT_USE;
	
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getToDoTaskForCargoCheck" id="6d3c89a5-1fe5-4b97-9f2c-b2200cd1d6ef">
        <source>getToDoTaskForCargoCheck(_context : Integer; _checkItem : String; _terminal : CM_Terminal) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars
	cargoCheck				: CM_CargoCheck;
	cargoCheckItem, item	: CM_CargoCheckItem;
	todoTask				: CM_ToDoTask;

begin
	cargoCheck := _terminal.allCargoChecks[_context];
	if cargoCheck &lt;&gt; null then
		foreach item in cargoCheck.allCargoCheckItems where item.requiredExtraInfo = _checkItem do
			cargoCheckItem := item;
			break;
		endforeach;
		if cargoCheckItem &lt;&gt; null and cargoCheckItem.myToDoTaskDesc &lt;&gt; null then
			return cargoCheckItem.myToDoTaskDesc.code;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_checkItem" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUnActionedIsAnyIdAnyAmount" id="4cb15ceb-12ce-4252-8c7d-8db10144e414">
        <source>getUnActionedIsAnyIdAnyAmount():CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgndl1	Initial creation	TFS 39950

*/

vars

	wle : CM_WorkListEntry;

begin

	foreach wle in self.allWlesToLoad do
		if wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		if wle.isAnyAmount then
			return wle;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getUnloadedAmountMatching" id="8a5c7c3b-a089-4c72-99c4-9e24fa1295e0">
        <source>getUnloadedAmountMatching( _ti : CM_TrackedItem input; _quantity : Integer output; _weight : Decimal output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2018	jlgndl1	Initial creation	TFS 39769

*/

vars

	vehicleVisitRecord : CM_VehicleVisitRecord;

begin

	if self.myTruck = null then
		return;
	endif;

	vehicleVisitRecord := self.myTruck.getCurrentVisit();
	if vehicleVisitRecord = null then
		return;
	endif;
	
	if _ti = null then
		return;
	endif;

	if (_ti.isBulkByQuantity or _ti.isBulkByWeight or _ti.isBulkByVolume) then
		vehicleVisitRecord.getUnloadedAmountMatching( _ti, _quantity, _weight );
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_quantity" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getVoyageFromCode" id="df4f7a86-61d5-42aa-9d1c-b8a80aca80f1">
        <source>getVoyageFromCode( _voyageCode : String ):CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	voyage : CM_Voyage;
	
begin

	iter := self.allCurrentVoyages.createIterator;
	while iter.next ( voyage ) do
		if _voyageCode = voyage.code then
			return voyage;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getWleForLoadTarget" id="9f4e97a6-e63b-4328-b017-d251a58586df">
        <source>getWleForLoadTarget(	_wagon : CM_Wagon input;
						_roadJob : CM_RoadJob input;
						_cargo : CM_TrackedItem input;
						_reserveDetail : CM_ReserveDetail input) : CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2021	jlier1	Initial creation 51879

*/

vars
	wle,tmpWLE : CM_WorkListEntry;
begin
	if _wagon &lt;&gt; null then
		wle:= _wagon.getWLEforCargo(_cargo,_reserveDetail);
	elseif _roadJob &lt;&gt; null then
		wle := _roadJob.getWLEForTI( _cargo );
		if wle = null then
			foreach tmpWLE in _roadJob.workListEntries discreteLock where tmpWLE.status &lt;&gt; WLE_COMPLETED and tmpWLE.myRequest &lt;&gt; null do  				
				if tmpWLE.myRequest.myOriginatingBulkRelease = self.myBulkRelease then
					if _reserveDetail = null or _reserveDetail = tmpWLE.myRequest.myReserveDetail then	//12 Feb 2016	NDL	Par 37537
						 wle :=tmpWLE;
						 break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	if wle = null  then
		foreach tmpWLE in _cargo.allWorklistEntries discreteLock where tmpWLE.status &lt;&gt; WLE_COMPLETED  do
			wle := tmpWLE;
			break;
		endforeach;
	endif;
	
	return wle;
epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon" usage="input"/>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_cargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="isValidLanderCargo" id="c35f875e-0680-4c8a-9edb-108a46cd5fc8">
        <source>isValidLanderCargo(ti : CM_TrackedItem input) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 July 2019		jlger1	Initial creation 45570
12 Jul 2021 		navmd1	TFS 51231 Restrict valid TIs based on a selected Voyage Transfer Area
16 November 2021	jlizm1	TFS 52028 Work hold jobs in handheld app
30 November 2021	jlizm1	TFS 52456 Job Lander SOB job cargo not found

*/

vars
	voyageJob : CM_VoyageJob;
begin
    if  ti.isChild then
		return false;
	endif;
	//epr TFS 45570 11/7/19 - undid changes for 45110 which broke the job lander and HH lander 
	if  self.checkLanderJobs then
		if self.landerCargoRequiresJob then
			if self.checksState = self.ShipDischargeCargo and ti.dischargeJobNum = null then
				return false;
			endif;
			if self.checksState = self.ShipLoadCargo and ti.loadJobNum = null then
				return false;
			endif;
			
		else
			if self.checksState = self.ShipDischargeCargo and ti.dischargeJobNum &lt;&gt; null then
				return false;
			endif;
			if self.checksState = self.ShipLoadCargo and ti.loadJobNum &lt;&gt; null then
				return false;
			endif;
		endif;
	endif;
	
	if self.myJob &lt;&gt; null and self.myJob.isKindOf(CM_VoyageJob) then
		voyageJob := self.myJob.CM_VoyageJob;
		
		if self.checksState = self.ShipDischargeCargo and not voyageJob.allReceiveTrackedItems.includes(ti) then
			return false;
		endif;
		if self.checksState = self.ShipLoadCargo and not voyageJob.allReleaseTrackeditems.includes(ti) then
			return false;
		endif;
		if self.checksState = self.ShiftOnBoard then
			if not voyageJob.allSOBTrackedItems.includes(ti) then
				if not ti.isSOB or not voyageJob.allReceiveTrackedItems.includes(ti) then
					return false;
				endif;
			endif;
		endif;
	
	endif;
	
	
	// TFS 51231 navmd1 12/07/21 - Restrict valid TIs based on a selected Voyage Transfer Area
	if self.myTransferArea &lt;&gt; null and ti.myTerminalArea &lt;&gt; self.myTransferArea then
		return false;
	endif;
	
	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWaitingOnRequiredChecks" id="29760318-1747-416f-a451-83644f4ce920">
        <source>isWaitingOnRequiredChecks(_context : Integer; _checkObject : CM_Object; _subCargo : CM_TrackedItem output ) : String;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation
10 Nov 2016 cnwer1	TFS 2723 when called from webservice want to return the context it failed on
22 Jan 2023 navhl20 Bug 61949:[61950] STWO - MTN Pack/Unpack container Error-89854
*/

vars
	cargoCheckArray 		: CM_CargoCheckItemArray;
	cargoCheck				: CM_CargoCheck;	
	check 					: CM_CargoCheckItem;
	setting					: CM_TICargoChecks;
	cmifAutoPlan			: CMIF_YAAutoPlan;
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
	checkResult : String;
	isShipLanderSealCheck	: Boolean;
begin

	cargoCheck := self.myTerminal.allCargoChecks[_context];
	
	if cargoCheck &lt;&gt; null then
		cargoCheckArray := cargoCheck.allCargoCheckItems;
	endif;
	
	if cargoCheckArray.size = 0 then
		return null;
	endif;
	
	if _checkObject.isKindOf( CM_TrackedItem ) then
		ti := _checkObject.CM_TrackedItem;
	
	elseif _checkObject.isKindOf( CM_Wagon ) then
		wagon := _checkObject.CM_Wagon;
		
	endif;
	
	//25 Sep 2013	NDL Par 32557 - If this is a chassis that we are loading or unloading
	//then we may need to check its tracked items too
	if _context = CARGO_CHECK_CONTEXT_TRUKUNLOAD or _context = CARGO_CHECK_CONTEXT_TRUKLOAD then
		if ti &lt;&gt; null and ti.isKindOf( CM_TILC ) then
			foreach lc in ti.CM_TILC.allLCs do
				foreach ti in lc.allTrackedItems do
					checkResult:= self.isWaitingOnRequiredChecks( _context, ti, _subCargo );
					if checkResult &lt;&gt; null then
						_subCargo := ti;
						return checkResult;
					endif;
				endforeach;
			endforeach;
		endif;
	endif;

	//cnwjo3 par 24849
	if ti &lt;&gt; null then
		// create an auto plan for checking criteria
		create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
		cmifAutoPlan.attachTI(ti);
		
		isShipLanderSealCheck := self.myTerminal.getConfig(IsShipLanderSealCheck).Boolean;				//22.01.2023 navhl20 #61949[61950]
		foreach check in cargoCheckArray where check.required do
			//jlier1 TFS 58968 21/9/23
			if check.requiredExtraInfo = EXTRA_INFO_QUICK_DAMAGE then
				continue;
			endif;
			setting := self.allCargoCheckItemSelections[ti, check];
			if setting &lt;&gt; null then
				continue;
			endif;
	
			//cnwjo3 par 24849.  no point kicking up a fuss if its required but doesn't actually meet the criteria
			if cmifAutoPlan &lt;&gt; null and not check.doesTIMatchMe(cmifAutoPlan) then
				continue;
			endif;
	
			//cnwjo3 par 24849.  if the required field is seals and its a discharge or load then verify if we want it displayed depending on Terming Config
			if check.requiredExtraInfo = EXTRA_INFO_SEALS then
				if cargoCheck.context.isOneOf(CARGO_CHECK_CONTEXT_SHIP_LOAD, CARGO_CHECK_CONTEXT_SHIP_DISC) then
					if isShipLanderSealCheck = false then												//22.01.2023 navhl20 #61949[61950]
						continue;
					endif;
				endif;
			endif;			
			
			//epr TFS 5532 18/8/17
			if check.requiredExtraInfo &lt;&gt; null then
				return check.requiredExtraInfo;
			elseif check.myToDoTaskDesc &lt;&gt; null then
				return check.myToDoTaskDesc.description;
			endif;
		endforeach;
	
	//11 Mar 2015	NDL	Par 35828
	elseif wagon &lt;&gt; null then
	
		foreach check in cargoCheckArray do
			if check.required then
				setting := self.allNonCargoCheckItemSelections[wagon, check];
				if setting &lt;&gt; null then
					continue;
				endif;		
				//epr TFS 5532 18/8/17
				if check.requiredExtraInfo &lt;&gt; null then
					return check.requiredExtraInfo;
				elseif check.myToDoTaskDesc &lt;&gt; null then
					return check.myToDoTaskDesc.description;
				endif;
			endif;
		endforeach;
		
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_checkObject" type="CM_Object"/>
        <Parameter name="_subCargo" type="CM_TrackedItem" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="moveTI" id="7b4ea877-0d1d-44f8-9e3d-590637a49e64">
        <updating/>
        <source>moveTI(	_ti 				: CM_TrackedItem;
		_targetId 			: String;
		_targetLc 			: CM_LocationsController;
		_wle 				: CM_WorkListEntry;
		_skipVerifyQuestion : Boolean;
		_quantity 			: Integer;
		_weight 			: Decimal;
		_contextObject 		: Object input
		) 					: Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/03/2016	cnwndl1	Initial creation	TFS 1593 Migrated from MobileServerSchema::CM_MobileAgent::moveTI
14/08/2018	jlgdap1	TFS 40003 PEL1 Voyage to Road Moves
02/11/2018	jlgdap1	TFS 41300 PEL1 Unable to load to vessel from truck in Job Lander
10/12/2018	jlgdap1	TFS 42466 PEL1 Wrong Transfer Type is Registered When Loading to Vessel from a Road Truck
07/06/2019	jlgzm1	TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail
05/07/2019	jlgzm1	TFS 42863 MSL - Direct Delivery Between LOLO RORO Voyages and Rail - BreakBulk
01/10/2019 	jlgka1 	TFS 46600 	PEL1 - Loading break-bulk PreNote to ship using Job Lander
11 Oct 2021 jlier1	TFS 51963 removed inaportnet
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
12 Feb 2023 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
*/

vars
	targetLocn			 : CM_LocationsController;
	lcnStr				 : String;
	moveController		 : CMIF_MoveController;
	result				 : Integer;
	foundHeight 		 : Integer;
	rtQueEntry 			 : CM_RTQueueEntry;
	futureMove 			 : CM_FutureMove;
	hideMoveConfirmation : Boolean;
	packToTI 			 : CM_TrackedItem;
	moveQuantity 		 : Integer;
	moveWeight 			 : Decimal [14,4];
	defTrsfrType 		 : Integer;
	job 				 : CM_Job;
	voyageWle, 
	truckWle, 
	wleForController 	 : CM_WorkListEntry;					// TFS 40003
	voyage 			 	 : CM_Voyage;							// TFS 41300
	voyageJob 		 	 : CM_VoyageJob;						// TFS 41300
	prenote 		 	 : CM_TrackedItem;						// TFS 41300
begin

	if _ti = null then
		return false;
	endif;
	
	if _ti &lt;&gt; null then
		if _ti.isOffSite() then
			if self.doNotShowMsgBox then
				app.raiseCMException1(Cargo_offsite_cannot_moved, _ti.id ,null,null);			
			else
				self.msgBox( app.getErrorString1(Cargo_offsite_cannot_moved, _ti.id ), app.getErrorString(Move_error), MsgBox_OK_Only,true);
			endif;
			return false;
		endif;
	endif;

	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	// If the user selected the location from the combo boxes, then we already have the 
	// location controller. However they may have simply typed the location. In that case
	// we have to find the location controller.
	if _targetLc &lt;&gt; null then
		targetLocn := _targetLc;
	else
		app.myPassport.myTerminal.findLocationFromString(_targetId, false, targetLocn, foundHeight);
	endif;

	// An error occurred finding the location controller
	if app.myPassport.hasErrors then
		if not self.doNotShowMsgBox then
			app.msgBox( app.myPassport.getErrorsAndWarningsAsString, app.getErrorString(Move_error), MsgBox_OK_Only);		
		endif;
		return false;
	endif;
	
	if targetLocn &lt;&gt; null then
		lcnStr := targetLocn.getFullId();
	else
		lcnStr := app.getErrorString(Unknown);
		if _wle &lt;&gt;  null and   _wle.isReleaseToPack then
			packToTI:=_wle.getTargetTIForPack;
			if packToTI &lt;&gt; null then
				lcnStr:=packToTI.id;
			endif;
		endif;
	endif;
	
	if targetLocn = null and packToTI = null then
		if self.doNotShowMsgBox then
			app.raiseCMException1(Err_InvalidLocation, _targetId,null,null);
		else
			app.msgBox(app.getErrorString1(Err_InvalidLocation, _targetId), app.getErrorString1(Err_InvalidLocation, _targetId), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		endif;
		return false;
		
	endif;

	//Check the user really wants to do the move...
	hideMoveConfirmation := app.myPassport.myTerminal.getConfig(HhMoveConfirmation).Boolean;
	if not _skipVerifyQuestion and not hideMoveConfirmation then	//03 Jun 2010	NDL Par 23903
		if not self.doNotShowMsgBox then		
			if app.msgBox(app.getErrorString3(UiMoveTrackedItem, app.getErrorString(Move), _ti.id, lcnStr), app.getErrorString(ConfirmMove), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
				return false;
			endif;
		endif;
	endif;
	
	create moveController transient;
	moveController.setMyTrackedItem( _ti);
	moveController.setMyToPrimaryLocation(targetLocn);
	moveController.setMoveMode(REAL_MODE); //Instant moves only in the first release
	moveController.setIsFromWeb(self.isFromWeb); // jlgka1 TFS 46600

	
	//  TFS 4435 SET TRANSFER TYPE - LOLO or RORO, depends on whether this is a load or discharge whether it is source or target location
	if targetLocn.isVoyageController() then
	//	moveController.transferType := targetLocn.getTransferType();
		defTrsfrType := targetLocn.getTransferType();	//12 Mar 2018	NDL	TFS 37444
	else
		if _ti.myPrimaryActualLocation = null then	//11 Jan 2018 NDL	TFS 36413
			if self.doNotShowMsgBox then
				app.raiseCMException1( Cargo_offsite_cannot_moved, _ti.id, null, null );
			else
				app.msgBox(app.getErrorString1( Cargo_offsite_cannot_moved, _ti.id ), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
			endif;
			return false;
		endif;
		//moveController.transferType :=  _ti.myPrimaryActualLocation.getTransferType();
		defTrsfrType := _ti.myPrimaryActualLocation.getTransferType();	//12 Mar 2018	NDL	TFS 37444
	endif;
	
	if _contextObject &lt;&gt; null and _contextObject.isKindOf( CM_DocumentActions) then
		moveController.setMyDocumentActions( _contextObject.CM_DocumentActions );
	endif;
	
	if _contextObject &lt;&gt; null and _contextObject.isKindOf(CM_VoyageWorkPointJob) then					//04.01.2023 navhl20 #61092[61621]
		moveController.myVoyageWPJob := _contextObject.CM_VoyageWorkPointJob;
		moveController.transferType := _contextObject.CM_VoyageWorkPointJob.transferType;
		if _contextObject.CM_VoyageWorkPointJob.retrospectiveDT.isValid then							//11.03.2024 navhl20 #60097
			moveController.retrospectiveDT := _contextObject.CM_VoyageWorkPointJob.retrospectiveDT;
		endif;
	endif;
	
	if _contextObject &lt;&gt; null and _contextObject.isKindOf(CM_RailJob) then					// ### TFS 62857 (62858) 14Mar2024 NAVPW1
		if _contextObject.CM_RailJob.retrospectiveDT.isValid then
			moveController.retrospectiveDT := _contextObject.CM_RailJob.retrospectiveDT;
		endif;
	endif;
	
	if _contextObject &lt;&gt; null and _contextObject.isKindOf(CM_Association) then							//12.02.2023 navhl20 #62093
		moveController.retrospectiveDT := _contextObject.CM_Association.asTimestamp;
	endif;

	//20 May 2013	NDL	CCMS 2274 Break Bulk
	//if _ti &lt;&gt; null and _ti.canSplitTotalQuantity then
	if _ti &lt;&gt; null then
		if _ti.isBulkByQuantity then	
			if _quantity &lt;&gt; 0 then				
				moveQuantity:=_quantity;
				moveController.setWeight(_weight);	//02 Feb 2016	NDL	Par 37492
			elseif _ti.totalQuantity &lt;&gt; 0 then
				moveQuantity:=_ti.totalQuantity;
			endif;
		elseif _ti.isBulkByWeight or _ti.isBulkByVolume then
			if _weight &lt;&gt; 0 then
				moveWeight:=_weight;
			elseif _ti.totalWeight &lt;&gt; 0 then
				moveWeight:=_ti.totalWeight;
			endif;
		endif;
	endif;
	
	
	// 08 Mar 2010	NDL Par 22657
	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		moveController.setJobForMove(_wle.job);
		//25 Mar 2010	NDL Par 23316
		if not _wle.allRTQueueEntries.isEmpty then
			rtQueEntry := _wle.allRTQueueEntries.last;
		elseif _wle.myFutureMove &lt;&gt; null and											// TFS 42840
		   _wle.myFutureMove.myWorkListEntryDR &lt;&gt; null and								// TFS 42840
		   not _wle.myFutureMove.myWorkListEntryDR.allRTQueueEntries.isEmpty then		// TFS 42840
			rtQueEntry := _wle.myFutureMove.myWorkListEntryDR.allRTQueueEntries.last;	// TFS 42840
		endif;
		if rtQueEntry &lt;&gt; null then
			moveController.isRTMultiMove := true;	
			//epr par 36010 14/4/15 seems this just causes issues not needed
			//moveController.myRTQueueEntry := rtQueEntry.getLastRTQueueEntry; //epr par 35702 4/3/15
			moveController.isRadioTelemetryMove := true;
			futureMove := _wle.myFutureMove;
		endif;
	endif;
	
	if _wle &lt;&gt; null then
		wleForController := _wle;																				// TFS 40003
		if _wle.isKindOf(CM_YardWLE) then																		// TFS 40003
			if targetLocn.isKindOf(CM_VehicleController) and  _ti &lt;&gt; null then									// TFS 40003
				voyageWle := _ti.getIncompleteWLE(CM_VoyageWLE);												// TFS 40003
				if voyageWle &lt;&gt; null then																		// TFS 40003
					moveController.setMyWorkListEntry(voyageWle);												// TFS 40003
					moveController.myDDWorkListEntry := _wle;													// TFS 40003
					moveController.myDDJob := _wle.job;															// TFS 40003
					wleForController := voyageWle;																// TFS 40003
				endif;																							// TFS 40003
			elseif targetLocn.isKindOf(CM_GeneralCargoController) and _ti &lt;&gt; null and _ti.wasPrenotified then		// TFS 41300
				voyage := targetLocn.CM_GeneralCargoController.myGCVoyage.myVoyage;									// TFS 41300
				prenote := voyage.myTerminal.allNotifiedTIsByIdCargoType[_ti.id, _ti.cargoType];					// TFS 41300
				if prenote &lt;&gt; null and not prenote.allPlannedFutureMoves.isEmpty then								// TFS 41300
					voyageWle := prenote.allPlannedFutureMoves.first.CM_FutureMovePlanned.myWorkListEntry;			// TFS 41300
					voyageJob := voyageWle.job.CM_VoyageJob;														// TFS 41300
					if voyageWle &lt;&gt; null then																		// TFS 41300
						moveController.setMyWorkListEntry(_wle);													// TFS 41300
						moveController.myDDWorkListEntry := voyageWle;												// TFS 41300
						moveController.myDDJob := voyageWle.job;													// TFS 41300
						wleForController := _wle;																	// TFS 41300
					endif;																							// TFS 41300
				endif;																								// TFS 41300
			endif;																								// TFS 40003
		elseif _wle.isKindOf(CM_VoyageWLE) then																	// TFS 40003
			if targetLocn.isKindOf(CM_VoyageController) and _ti &lt;&gt; null then									// TFS 40003
				truckWle := _ti.getIncompleteWLE(CM_YardWLE);													// TFS 40003
				if truckWle &lt;&gt; null then																		// TFS 40003
					// splittable TIs for Direct release can confuse wles, 
					// get correct one linked through Future Move
					if _wle.isDRLinkedByFM and truckWle &lt;&gt; _wle.getDRLinkedWLE then								// TFS 42863
						truckWle := _wle.getDRLinkedWLE;														// TFS 42863
					endif;																						// TFS 42863
					moveController.myDDWorkListEntry := truckWle;												// TFS 40003
					moveController.myDDJob := truckWle.job;														// TFS 40003
					// TFS 41300 If this is a Pelindo voyage, and we're dealing with a prenoted		// TFS 41300
					// cargo request moving straight from the truck to the ship, swap things around // TFS 41300
					// a bit. Because the cargo's already planned, the WLE we have to start with is	// TFS 41300
					// a voyage WLE, not a truck WLE. We need to swap this and the truck WLE		// TFS 41300
					voyageJob := _wle.job.CM_VoyageJob;												// TFS 41300
					voyage := voyageJob.myVoyage;													// TFS 41300
					if voyage &lt;&gt; null and _ti.wasPrenotified and voyageJob.isVoyageHoldJob and		// TFS 41300
					(voyage.isMTNWOVoyageProcess ) and			// TFS 41300
					voyage.getWorkOrderForVoyCargoRequest &lt;&gt; null  then								// TFS 41300
						moveController.setMyWorkListEntry(truckWle);								// TFS 41300
						moveController.myDDWorkListEntry := _wle;									// TFS 41300
						moveController.myDDJob := _wle.job;											// TFS 41300
						wleForController := truckWle;												// TFS 41300
						
					// TFS 42863
					// if moving splittable cargo want wle to be the yard wle, and ddwle as the voyage
					elseif _ti.canSplitTotalQuantity then
						moveController.setMyWorkListEntry(truckWle);								
						moveController.myDDWorkListEntry := _wle;									
						moveController.myDDJob := _wle.job;											
						wleForController := truckWle;												
					endif;
				endif;																							// TFS 40003
			endif;																								// TFS 40003
		endif;																									// TFS 40003
	endif;
	
	//epr TFS 2732 18/11/16 this method shows a msg box with a warning we can ignore it if flag set
	if not self.doNotShowMsgBox and not hideMoveConfirmation then
		moveController.nonWorkedInstantPreMove();	//01 Aug 2013	NDL	Par 32140
	endif;
	
	if moveController.priority = 888 then		// 28/6/17 MAP TFS4719
		return false;		// user has cancelled attempt to move cargo already planned
	endif;

	if self.isNoChargeMove then
		moveController.isNoChargeMove := true;
	endif;
	
	//12 Mar 2018	NDL	TFS 37444
	if _wle &lt;&gt; null then
		job  := _wle.job;
	endif;
	// TFS 42466 If we're moving straight from truck to voyage, use the 			// TFS 42466
	// voyage job to derive the transfer type										// TFS 42466
	if targetLocn.isVoyageController and moveController.myDDWorkListEntry &lt;&gt; null 	// TFS 42466
	and moveController.myDDJob.isVoyageHoldJob then									// TFS 42466
		job := moveController.myDDJob;												// TFS 42466
	endif;																			// TFS 42466
	moveController.setTransferTypeFromJob( job, defTrsfrType );	//12 Mar 2018	NDL	TFS 37444

	on CM_Exception do null;
	while true do
		moveController.setMyTrackedItem( _ti);
		//moveController.setMyWorkListEntry(_wle);															// TFS 40003
		moveController.setMyWorkListEntry(wleForController);												// TFS 40003
		if moveQuantity &lt;&gt; 0 then
			moveController.setQuantity(moveQuantity);
		endif;
		if moveWeight &lt;&gt; 0 then
			moveController.setWeight(moveWeight);
		endif;
		//Do the move
		app.myTrxUA.trxMoveTrackedItemAndUnQueue(moveController, futureMove, _contextObject, app.myPassport);

		// ### TFS CR 64297 TASK 64298 28MAY2024 NAVAB1
		if app.myPassport.hadDeadlock = true then
			return false;
		endif;
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			//jlier1 TFS 54702 23/9/22 
			if moveController.myTrackedItem &lt;&gt; _ti then
				self.myNewTI :=moveController.myTrackedItem;
			endif;
			return true;
		else
			if self.doNotShowMsgBox then	
				return false;
			endif;
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, 20); // 20 = ErrWarnMode_Update + ErrWarnMode_CanAckWarnings
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
					moveController.setEffectiveTimeStampOverride(app.actualTimeServer());	//04Sep2012	cnwrs1	Par30321	if the trx is to be retried then setup the effective date again	
				continue;
			endif;
		endif;

		return false;
	endwhile;
		
epilog

	delete moveController;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_targetId" type="String"/>
        <Parameter name="_targetLc" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_skipVerifyQuestion" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_contextObject" type="Object" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveTIToGround" id="849bb459-e988-464f-83e9-c2dbf9b715b2">
        <updating/>
        <source>moveTIToGround(_groundOption : Integer;	
						_ti : CM_TrackedItem input;
						groundLocation : CM_LocationsController input;
						_job : CM_VoyageJob;
						_wle : CM_WorkListEntry input;
						_quantity : Integer;
						_weight : Decimal
						) : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 June 2012	cnwndl1	Initial creation	Par 29745
01 Apr 2014	NDl	CCMS 1366
15 Nov 2016	TFS 2732 refactored moved from MOB_HHLanderCargoMove doCompleteGround
*/

vars	
	newId : String;
	quantity : Integer;
	result : Integer;
	weight : Decimal [16,4];
	doSplit : Boolean;
	originalTarget : CM_LocationsController;
	newTi : CM_TrackedItem;
	newJob : CM_VoyageJob;
	existingWle : CM_WorkListEntry;
	newWle : CM_WorkListEntry;
	willMerge : Boolean;	//27 Apr 2016	NDL	TFS 1809

begin

	newTi := groundLocation.allTrackedItemsById.getAtKey( _ti.id, _ti.cargoType );	//27 Apr 2016	NDL	TFS 1809
	willMerge := newTi &lt;&gt; null;	//27 Apr 2016	NDL	TFS 1809


	if _ti.canSplitTotalQuantity or willMerge then	//27 Apr 2016	NDL	TFS 1809
		
		newId := _ti.id;
	
		if _ti.isBulkByWeight or _ti.isBulkByVolume then
			weight := _weight;
			if weight = 0 then
				weight := _ti.totalWeight;
			else
				doSplit := true;
			endif;
		endif;
		quantity := _quantity;
		if quantity = 0 then
			quantity := _ti.totalQuantity;
		endif;
		
		//if ( quantity &lt;&gt; _ti.totalQuantity ) or ( newId &lt;&gt; _ti.id ) or doSplit then
		if ( quantity &lt;&gt; _ti.totalQuantity ) or ( newId &lt;&gt; _ti.id ) or doSplit or willMerge then //27 Apr 2016	NDL	TFS 1809
			//we are trying to do a split
			if _groundOption = GroundInTransit then
			
				//12 Apr 2016	NDL	TFS 1809
				if _wle &lt;&gt; null then
					originalTarget := _wle.getTargetLocation;
					if originalTarget = groundLocation then
						originalTarget := null;
					endif;
				endif;
			
			endif;
			
			//epr par 35862 13/3/15
			if not self.moveTI(_ti,null,groundLocation,_wle,true,quantity, weight, null) then
				return false;
			endif;
			
			//12 Apr 2016	NDL	TFS 1809
			if originalTarget &lt;&gt; null then
			//	newTi := groundLocation.allTrackedItemsById.getAtKey( _ti.id, _ti.cargoType );
				//previous move consumed the wle, queue the new one, or increment the existing move amount if its merged.
				if newTi &lt;&gt; null then					
					if (( _ti.isBulkByWeight or _ti.isBulkByVolume) and newTi.totalWeight &lt;&gt; weight )
					or  (( not _ti.isBulkByWeight and not _ti.isBulkByVolume) and newTi.totalQuantity &lt;&gt; quantity )
					then 
						//the split one from aboove has been merged
						existingWle := newTi.findExistingWleTo( originalTarget );
						if existingWle = null then
							self.doQueueUnplannedUnworkedCargo(newTi, newJob, newWle, quantity, weight, originalTarget);
						else
							if newTi.myCargoType.isBreakBulkMulti then
								app.myTrxUA.trxAmendBreakBulkRTQuantity( existingWle, (existingWle.quantity + quantity), app.myPassport);	
							elseif newTi.myCargoType.isBulkMulti then
								app.myTrxUA.trxAmendBreakBulkRTWeight( existingWle, (existingWle.weight + weight), app.myPassport );
							endif;
						endif;
						
					else
						self.doQueueUnplannedUnworkedCargo(newTi, newJob, newWle, quantity, weight, originalTarget);
					endif;
				endif;
			
				if app.myPassport.hasErrors then
					return false;
				endif;
				
			endif;
			

			self.setSplitValues( 0, 0, null );
			return true;
		endif;
	endif;

	while true do
		app.myTrxUA.trxLanderDischargeToGround(_groundOption, _ti, groundLocation, _job, _wle, app.myPassport);
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			self.setSplitValues( 0, 0, null );
			return true;
		else
			if self.doNotShowMsgBox then	
				return false;
			endif;
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, 20); // ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings)
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_groundOption" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="groundLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveTruckToLane" id="1257c16e-4d1d-4381-adfd-f0eede516313">
        <source>moveTruckToLane( _errorMess : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars
	
begin
	
	app.myTrxUA.trxMoveVehicle(	self.myTruck, self.myGateAreaLaneController, app.myPassport);

	if (not app.myPassport.trxCompletedOK) then
		_errorMess := app.myPassport.getAllErrorsWarningsAsString();
		return false;
	endif;	

	return true;
	
epilog

end;</source>
        <Parameter name="_errorMess" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveTruckToYard" id="28e883ac-17de-4b2f-8d0a-8dd0c4066c7a">
        <source>moveTruckToYard(_errorMess : String output):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars

	yardController : CM_YardController;
	
begin

	if self.myTruck.allRoadJobs.first = null then
		_errorMess := app.getErrorString( Truck_no_jobs );
		return false;
	endif;
	

	
	yardController := self.myTruck.getInTransitToYardLocation();
	if yardController = null then
		_errorMess := app.getErrorString( Unable_find_yard_contro_truck );
		return false;
	endif;
	
	app.myTrxUA.trxMoveVehicle(	self.myTruck, yardController, app.myPassport);

	if (not app.myPassport.trxCompletedOK) then
		_errorMess := app.myPassport.getAllErrorsWarningsAsString();
		return false;
	endif;	

	return true;
	
epilog

end;</source>
        <Parameter name="_errorMess" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="msgBox" id="ca2f1c11-7328-4234-bffa-e7ae1f129d3c">
        <source>msgBox(msg, title : String; flags: Integer; alertOption : Boolean ): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2016	cnwndl1	Initial creation

*/

vars
	form : Form;
	
	schema : Schema;
	class : Class;
	obj : Object;
	exObj	: CM_Exception;
begin
	
	if app.isJMTUnitTest then	//08 Jan 2016	NDL	Par 37288
		schema := rootSchema.getSchema("JMTUnitTest");
		class := schema.getClass("UT_UnitTest");
		create obj as class transient;
		obj.sendMsgWithParams("assertTrueMsg",false,"CMIF_MobileGenericAgent::msgBox error = " &amp; msg);
		return 0;
	endif;

	form := app.activeForm();
	schema := rootSchema.getSchema("MobileUISchema");
	class := schema.getClass("MOB_HandHeldForm");
	if form.isKindOf(class) then
		return form.sendMsgWithParams("msgBox", msg, title, flags, alertOption ).Integer;
	else
		return app.msgBox(msg, title, flags);
	endif;

epilog

	delete obj;

end;</source>
        <access>protected</access>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <Parameter name="alertOption" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rePlanTi" id="e23870fd-128b-4ec3-bce1-a16725152687">
        <source>rePlanTi( _trackedItem : CM_TrackedItem; _job : CM_Job; _inTransit : Integer ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2016	cnwndl1	Initial creation

*/

vars

	tiArray	: CM_TIArray;
	str		: String;
	result	: Integer;
	ti		: CM_TrackedItem;
	params : CMIF_AutoplanParams;

begin

	create tiArray transient;
	create params transient;
	
	if _trackedItem = null then
		return 0;
	endif;
	
	if _trackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		result := self.unPlanTi( _trackedItem );
		if result &lt;&gt; IDOK then
			return result;
		endif;
	endif;
	
	params.allTrackedItems.add(_trackedItem);
	params.moveMode := QUEUE_MODE;
	params.myTerminalArea := null;
	params.myJob := _job;	//30 Mar 2010	NDL	Par 23486
	params.showWarningWhenNoPlan := true;
	params.isHHInTransitMove := ( _inTransit = GroundInTransit );	//11 Sep 2017	NDL	TFS 6887
		
	while true do
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			result := IDOK;
			break;
		else
			//epr TFS 2732 21/11/16
			if self.doNotShowMsgBox then	
				return result;
			endif;
			
			result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, 20); //ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	
		
	return result;

epilog

	delete tiArray;
	delete params;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_inTransit" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
