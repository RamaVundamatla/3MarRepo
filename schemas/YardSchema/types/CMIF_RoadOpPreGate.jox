    <JadeMethod name="canProceed" id="82ba0b2a-123e-4b3c-b39d-1059d023af5d">
        <source>canProceed(_vehicle :CM_Vehicle; _menu :MenuItem): Boolean;
// ---------------------------------------------------------------------------
// Created:     15 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/10/2009	cnwcs5		par 20800 - exceptions due to deleted gate
// ---------------------------------------------------------------------------
vars
	job				:CM_RoadJob;
	gate			:CM_Gate;
	location		:CM_GateAreaLaneController;
	gateArea		:CM_GateArea;
	invalidObject	:Boolean;
begin
	if not inheritMethod(_vehicle, _menu) then 
		return false; 
	endif;
	
	if _menu.userObject.isKindOf (CM_GateAreaLaneController) then
		// gate lane item
		location := _menu.userObject.CM_GateAreaLaneController;
	elseif _menu.userObject = self then
		// proceed menu
		return true;
	else 
		// lost
		return false;
	endif;
	
	// always moving current vehicle
	job := _vehicle.allRoadJobs.first.CM_RoadJob;
	
	if job = null then 
		return false;
	endif;
	
	// only show those gate lanes that belong to the gate for the current road job
	gate 		:= job.myGate;
	
	on Exception do app.handleDeletedObject (exception, location, invalidObject);	// par 20800
	
	gateArea	:= location.myTerminalArea.CM_GateArea; 
	
	// if location has been deleted the exception handler will return execution to here
	if invalidObject then	// par 20800
		return false;		// par 20800
	endif;					// par 20800
	
	if gate &lt;&gt; null and gate.hasGateArea_IN (gateArea) then 
		return true;
	endif;
	
	return false; 
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_menu" type="MenuItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeProceedOptionsEnabled" id="d43ba772-87f8-401c-96af-088637b3667d">
        <source>changeProceedOptionsEnabled();
/*
Purpose:			
Return Value:		

Date			Who		Reason
24 August 2006	cnwer1	Initial creation - PAR#xxxx
17 August 2009	cnwcs5	ccms 1061 - road ops form changes
12/10/2009		cnwcs5	par 20800 - exceptions due to deleted gates
*/
vars
	obj 			: Object;
	menu 			: MenuItem;
	glc 			: CM_GateAreaLaneController;
	invalidObject	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, glc, invalidObject);	// par 20800
	
	foreach obj in self.allMenuItems do
		menu := obj.MenuItem;
		
		if menu.name &lt;&gt; YRD_RoadOperationsForm::mnuProceed.name or			// not proceeed menu
			not menu.userObject.isKindOf(CM_GateAreaLaneController) then	// not for gate lane
			continue;
		endif;
		
		glc := menu.userObject.CM_GateAreaLaneController;
		
		menu.enabled := not glc.isUnavailable and glc.isIn and not glc.hasVehicles; 
		
		// if glc is invalid our exception handler will resume here
		if invalidObject then					// par 20800
			self.allMenuItems.remove (menu);	// par 20800
			delete menu;						// par 20800
			invalidObject := false;				// par 20800
		endif;									// par 20800
	endforeach;
epilog

end;</source>
    </JadeMethod>
