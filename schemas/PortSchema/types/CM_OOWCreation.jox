    <JadeMethod name="init" id="1f6641ec-e1eb-41cc-8605-7992c6520f10">
        <updating/>
        <source>init(_bay : CM_BayVoyage; _deck : Integer; _subOrder : Integer; _order : Integer; _get40 : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		28 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _bay = null then
		return;
	endif;
	if _get40 then
		self.id := "(" &amp; _bay.idBay40 &amp; ")";
	else
		self.id := _bay.id;
	endif;
	self.myBay := _bay;
	self.myVoyageStructure := _bay.myCellularVoyageStructure;
	self.ordinalDeck := _deck;
	self.order := _order;
	self.orderType := _subOrder;
end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <Parameter name="_deck" type="Integer"/>
        <Parameter name="_subOrder" type="Integer"/>
        <Parameter name="_order" type="Integer"/>
        <Parameter name="_get40" type="Boolean"/>
    </JadeMethod>
