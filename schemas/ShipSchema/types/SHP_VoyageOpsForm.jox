end;</source>
    </JadeMethod>
    <JadeMethod name="runImportTasks" id="0aaa1d1b-a9ee-46ac-8a03-269e64d6c33d">
        <updating/>
        <source>runImportTasks() updating;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxRunImportTasksOnShip(self.myCurrentVoyage, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Run Import Tasks', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="setColours" id="d967a61e-6971-4949-a3cc-47fc61b368df">
        <updating/>
        <source>setColours() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/02/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars

begin
	if self.xmlColourPlanned = 0 then
		self.xmlColourPlanned := self.ColourYellowLight;
	endif;
	if self.xmlColourNonPlanned = 0 then
		self.xmlColourNonPlanned := self.ColourYellowLight;
	endif;
	if self.xmlColourOnShip = 0 then
		self.xmlColourOnShip := self.ColourBlueLight;
	endif;
	self.clrPlanned.ignoreSkin := true;
	self.clrNonPlanned.ignoreSkin := true;
	self.clrOnShip.ignoreSkin := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="c5c58986-2ebe-4a0b-ba62-21021bd8d874">
