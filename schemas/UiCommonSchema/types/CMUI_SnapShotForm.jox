        <updating/>
        <source>doRefresh() updating, protected;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/


vars

begin
	inheritMethod();

	self.doQuery();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetSnapShots" id="bafc7a3d-19d1-4e4a-a59d-e11342d857e1">
        <updating/>
        <source>doResetSnapShots() updating;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars
	allEditSnapShots : CM_SnapShotSet;
	pxySnapShot : CM_TISnapShot;
	theReturn : Integer;
begin

	if self.tblData.allSelectedObjects.isEmpty then
		//nothing selected
		app.msgBox("Select an item to reset.", app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;

	create allEditSnapShots transient;
	self.tblData.allSelectedObjects.copy(allEditSnapShots);

	while true do
		app.myTrxUA.trxUpdateResetSnapShots(allEditSnapShots, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog("Update Snap Shot", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	delete allEditSnapShots;
end;</source>
    </JadeMethod>
