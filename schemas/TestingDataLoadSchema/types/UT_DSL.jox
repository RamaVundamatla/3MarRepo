		delete wharf;
		commitTransaction;
	endforeach;
	
	//allBulkTiTransactions
	foreach bulkTITransactionAudit in term.allBulkTiTransactions do
		beginTransaction;
		delete bulkTITransactionAudit;
		commitTransaction;
	endforeach;
	
	//allDelays
	delayColl := term.getPropertyValue (CM_Terminal::allDelays.name).CM_DelayByStartDTDict;
	foreach delay in delayColl do
		beginTransaction;
		delete delay;
		commitTransaction;
	endforeach;
	
	//allEDIPartiesBySenderCode
	foreach ediParty in term.allEDIPartiesBySenderCode do
		beginTransaction;
		delete ediParty;
		commitTransaction;
	endforeach;
	
	//CM_EventRequestNotification
	foreach eventRequestNotification in term.allEventRequestNotifyByCargoID do
		beginTransaction;
		delete eventRequestNotification;
		commitTransaction;
	endforeach;
	
	//allEventRequestStopsByCargoID
	foreach eventRequestStops in term.allEventRequestStopsByCargoID do
		beginTransaction;
		delete eventRequestStops;
		commitTransaction;
	endforeach;
	
	//allHMSSavedConflictReports
	foreach hmsSavedConflictReport in term.allHMSSavedConflictReports do
		beginTransaction;
		delete hmsSavedConflictReport;
		commitTransaction;
	endforeach;
	
	//allInTransitTIsFromByToTypeId
	//allInTransitTIsToByFromTypeId
	foreach ti in term.allInTransitTIsFromByToTypeId do
		self.deleteTrackedItem(ti, true);
	endforeach;
	foreach ti in term.allInTransitTIsToByFromTypeId do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	//allInterTerminalConfigs
	foreach interTerminalConfig in term.allInterTerminalConfigs reversed do
		beginTransaction;
		delete interTerminalConfig;
		commitTransaction;
	endforeach;
	
	//allJobPriorities
	foreach jobPriority in term.allJobPriorities do
		beginTransaction;
		delete jobPriority;
		commitTransaction;
	endforeach;
	
	//allKiosksByCode
	foreach kiosk in term.allKiosksByCode do
		beginTransaction;
		delete kiosk;
		commitTransaction;
	endforeach;
	
	//allLogChkScaleByBatchNo
	//allLogChkScaleByDt
	foreach logCheckScaleHdr in term.allLogChkScaleByBatchNo do
		beginTransaction;
		delete logCheckScaleHdr;
		commitTransaction;
	endforeach;
	
	//allLogScalingHdrsUnmatched
	foreach logScalingHdr in term.allLogScalingHdrsUnmatched do
		beginTransaction;
		delete logScalingHdr;
		commitTransaction;
	endforeach;
	
	//allPinNos
	foreach pinNo in term.allPinNos do
		beginTransaction;
		delete pinNo;
		commitTransaction;
	endforeach;
	
	//allPinsEmbargoed
	foreach pinNo in term.allPinsEmbargoed do
		beginTransaction;
		delete pinNo;
		commitTransaction;
	endforeach;
	
	//allReeferConnectTIs
	if not term.allReeferConnectTIs.isEmpty then
		create emptyTis transient;
		app.myTrxUA.trxUpdateReeferConnectList(emptyTis, app.myPassport);
		delete emptyTis;
	endif;
	
	//allSOHFixups
	foreach sOHFixupHdr in term.allSOHFixups do
		beginTransaction;
		delete sOHFixupHdr;
		commitTransaction;
	endforeach;
	
	//allStockOrderHeaders
	foreach stockOrderHeader in term.allStockOrderHeaders do
		beginTransaction;
		delete stockOrderHeader;
		commitTransaction;
	endforeach;
	
	//allSubTerminals
	foreach subTerminal in term.allSubTerminals do
		self.deleteSubTerminal(subTerminal.code);
	endforeach;
	
	foreach systemAlert in term.allSystemAlertsByDateTime do
		beginTransaction;
		delete systemAlert;
		commitTransaction;
	endforeach;
	
	//allTerminologyHdrs
	foreach terminologyHdr in term.allTerminologyHdrs do
		beginTransaction;
		delete terminologyHdr;
		commitTransaction;
	endforeach;
	
	//allTimeSlotByDate
	foreach timeSlot in term.allTimeSlotByDate do
		beginTransaction;
		delete timeSlot;
		commitTransaction;
	endforeach;
	
	//allTimeSlotStd
	foreach timeSlotStd in term.allTimeSlotStd do
		beginTransaction;
		delete timeSlotStd;
		commitTransaction;
	endforeach;
	
	//allToDoTaskTemplates
	foreach toDoTemplate in term.allToDoTaskTemplates do
		beginTransaction;
		delete toDoTemplate;
		commitTransaction;
	endforeach;
	
	//allVoyagePlanningCodes
	foreach voyagePlanningCode in term.allVoyagePlanningCodes do
		beginTransaction;
		delete voyagePlanningCode;
		commitTransaction;
	endforeach;
	
	//allWeighBridgeByDocketNo
	//allWeighBridgeByWeighNo
	foreach logDocketData in term.allLogDocketDataByDocketNo do
		beginTransaction;
		delete logDocketData;
		commitTransaction;
	endforeach;
	
	//moveMaps
	foreach moveMap in term.moveMaps do
		beginTransaction;
		delete moveMap;
		commitTransaction;
	endforeach;
	
	//allMTThresholds
	foreach mTThreshold in term.allMTThresholds do
		beginTransaction;
		delete mTThreshold;
		commitTransaction;
	endforeach;
	
	beginTransaction;
	
	obj := term.myLocationStatistics;
	if obj &lt;&gt; null then
		delete obj;
	endif;
	obj := term.myRTVehicleConfig;
	if obj &lt;&gt; null then
		delete obj;
	endif;
	delete term.myRailJobSheet;
	delete term.myRoadJobSheet;
	obj :=  term.myStorageConfig;
	if obj &lt;&gt; null then
		delete obj;
	endif;
	delete term.myYardJobSheet;
	delete term.radioTelemetry;
	delete term.myAutoCargoIdCont;
	commitTransaction;
	
	beginTransaction;
	term.allRTAllocationCriteriaTypes.clear();
//	term.allSelectedProformaQueryProps.clear();
	term.allTerminalsForRelease.clear();
	term.allTerminalsForVoyageInland.clear();
	term.chilledTIsOffPower.clear();
	term.setPropertyValue("myCalendar",null);
	term.allDefrostReefers.clear();
	commitTransaction;
	
	//chuck some code in here to find any/all invalid references to the term....
	
	foreach bgpDirCont in BGP_DirectoryController.instances do
		if bgpDirCont.myTerminal = term then
			beginTransaction;
			delete bgpDirCont;
			commitTransaction;
		endif;
	endforeach;
	
	foreach bgpListenCont in BGP_RFIDListenController.instances do
		if bgpListenCont.myTerminal = term then
			beginTransaction;
			delete bgpListenCont;
			commitTransaction;
		endif;
	endforeach;
	
	create objArray transient;
	BGP_Request.allInstances(objArray, null, true);
	iter := objArray.createIterator;
	while iter.next( obj ) do
		bgpRequest := obj.BGP_Request;
		if bgpRequest.myTerminal = term then
			beginTransaction;
			delete bgpRequest;
			commitTransaction;
		endif;
	endwhile;
	delete iter;
	objArray.clear();
	
	foreach bgpSpecificReportRequest in BGP_SpecificReportRequest.instances do
		if bgpSpecificReportRequest.allTerminals.includes(term) then
			beginTransaction;
			if bgpSpecificReportRequest.allTerminals.size = 1 then
				delete bgpSpecificReportRequest;
			else
				bgpSpecificReportRequest.allTerminals.remove(term);
			endif;
			commitTransaction;
		endif;
	endforeach;
	
	foreach bgpTCPClient in BGP_TCPClient.instances do
		if bgpTCPClient.myTerminal = term then
			beginTransaction;
			delete bgpTCPClient;
			commitTransaction;
		endif;
	endforeach;
	
	objArray.clear();
	CM_ActivityHistory.allInstances(objArray, null, true);
	iter := objArray.createIterator;
	while iter.next( obj ) do
		actHistory := obj.CM_ActivityHistory;
		if actHistory.myTerminalNoInverse = term then
			beginTransaction;
			delete actHistory;
			commitTransaction;
		endif;
	endwhile;
	delete iter;
	
	objArray.clear();
	CMGTE_Entity.allInstances(objArray, null, true);
	iter := objArray.createIterator;
	while iter.next( obj ) do
		gateEntity := obj.CMGTE_Entity;
		if gateEntity.myTransferToTerminal = term then
			beginTransaction;
			delete gateEntity;
			commitTransaction;
		endif;
	endwhile;
	delete iter;
	
	foreach attributeArea in CM_AttributeArea.instances do
		if attributeArea.myTerminal = term then
			beginTransaction;
			delete attributeArea;
			commitTransaction;
		endif;
	endforeach;
	
	objArray.clear();
	CM_AutoTask.allInstances(objArray, null, true);
	iter := objArray.createIterator;
	while iter.next( obj ) do
		autoTask := obj.CM_AutoTask;
		if autoTask.myTerminal = term then
			beginTransaction;
			delete autoTask;
			commitTransaction;
		endif;
	endwhile;
	delete iter;
	
	objArray.clear();
	CM_BOL.allInstances(objArray, null, true);
	iter := objArray.createIterator;
	while iter.next( obj ) do
		bol := obj.CM_BOL;
		if bol.myTerminal = term then
			beginTransaction;
			delete bol;
			commitTransaction;
		endif;
	endwhile;
	delete iter;
	
	objArray.clear();
	CM_BulkRelease.allInstances(objArray, null, true);
	iter := objArray.createIterator;
	while iter.next( obj ) do
		bulkRelease := obj.CM_BulkRelease;
		if bulkRelease.myTransferToTerminal = term then
			beginTransaction;
			bulkRelease.setPropertyValue("myTransferToTerminal",null);
			commitTransaction;
		endif;
	endwhile;
	delete iter;
	
	objArray.clear();
	CM_Discrepancy.allInstances(objArray, null, true);
	iter := objArray.createIterator;
	while iter.next( obj ) do
		discrepancy := obj.CM_Discrepancy;
		if discrepancy.terminal = term then
			beginTransaction;
			delete discrepancy;
			commitTransaction;
		endif;
	endwhile;
	delete iter;
	
	foreach dutyDocTerminalRoot in CM_DutyDocTerminalRoot.instances do
		if dutyDocTerminalRoot.myTerminal = term then
			beginTransaction;
			delete dutyDocTerminalRoot;
			commitTransaction;
		endif;
	endforeach;
	
	foreach ediBOLOutLogTI in CM_EDIBOLOutLogTI.instances do
		if ediBOLOutLogTI.myTerminal = term then
			beginTransaction;
			delete ediBOLOutLogTI;
			commitTransaction;
		endif;
	endforeach;
	
	foreach ediDataBOLOutLog in CM_EDIDataBOLOutLog.instances do
		if ediDataBOLOutLog.myTerminal = term then
			beginTransaction;
			delete ediDataBOLOutLog;
			commitTransaction;
		endif;
	endforeach;
	
	foreach formConfigForm in CM_FormConfigForm.instances do
		if formConfigForm.myTerminal = term then
			beginTransaction;
			delete formConfigForm;
			commitTransaction;
		endif;
	endforeach;
	
	objArray.clear();
	CM_FutureMove.allInstances(objArray, null, true);
	iter := objArray.createIterator;
	while iter.next( obj ) do
		futureMove := obj.CM_FutureMove;
		if futureMove.myTerminal = term then
			beginTransaction;
			delete futureMove;
			commitTransaction;
		endif;
	endwhile;
	delete iter;
	
	foreach invoice in CM_Invoice.instances do
		if invoice.myTerminal = term then
			self.deleteInvoice( invoice );
		endif;
	endforeach;
	
	foreach objUpgraderCAMSTrx in CM_ObjectUpgraderCAMSTrx.instances do
		if objUpgraderCAMSTrx.myTerminal = term then
			beginTransaction;
			delete objUpgraderCAMSTrx;
			commitTransaction;
		endif;
	endforeach;
	
	foreach job in CM_PackJob.instances do
		if job.CM_PackJob.myTerminal = term then
			self.deleteJob( job );
		endif;
	endforeach;
	
	foreach job in CM_RailJob.instances do
		if job.CM_RailJob.myTerminal = term then
			self.deleteJob( job );
		endif;
	endforeach;
	
	foreach job in CM_RoadJob.instances do
		if job.CM_RoadJob.myTerminal = term then
			self.deleteJob( job );
		endif;
	endforeach;
	
	foreach job in CM_UnpackJob.instances do
		if job.CM_UnpackJob.myTerminal = term then
			self.deleteJob( job );
		endif;
	endforeach;
	
	foreach job in CM_ToDoJob.instances do
		if job.CM_ToDoJob.myTerminal = term then
			self.deleteJob( job );
		endif;
	endforeach;
	
	foreach job in CM_YardInternalJob.instances do
		if job.CM_YardInternalJob.myTerminal = term then
			self.deleteJob( job );
		endif;
	endforeach;
	
	
	
	foreach packageSailing in CM_PackageSailing.instances do
		if packageSailing.myTerminal = term then
			beginTransaction;
			delete packageSailing;
			commitTransaction;
		elseif packageSailing.myTerminalCams = term then
			beginTransaction;
			delete packageSailing;
			commitTransaction;
		endif;
	endforeach;
	
	foreach rtQueueArbiter in CM_RTQueueArbiter.instances do
		if rtQueueArbiter.myTerminal = term then
			beginTransaction;
			delete rtQueueArbiter;
			commitTransaction;
		endif;
	endforeach;
	
	objArray.clear();
	CM_RemoteDataManager.allInstances(objArray, null, true);
	iter := objArray.createIterator;
	while iter.next( obj ) do
		remoteDataManager := obj.CM_RemoteDataManager;
		if remoteDataManager.myTerminal = term then
			beginTransaction;
			delete futureMove;
			commitTransaction;
		endif;
	endwhile;
	delete iter;
	
	foreach terminalRef in CM_Terminal.instances do
		if terminalRef.allTerminalsForRelease.includes(term) then
			beginTransaction;
			terminalRef.allTerminalsForRelease.remove(term);
			commitTransaction;
		endif;
		if terminalRef.allTerminalsForVoyageInland.includes(term) then
			beginTransaction;
			terminalRef.allTerminalsForVoyageInland.remove(term);
			commitTransaction;
		endif;
	endforeach;
	
	foreach terminalTIsByBR in CM_TerminalTIsByBR.instances do
		if terminalTIsByBR.myTerminal = term then
			beginTransaction;
			delete terminalTIsByBR;
			commitTransaction;
		endif;
	endforeach;
	
	foreach testDataRTDevice in CM_TestDataRTDevice.instances do
		if testDataRTDevice.myTerminal = term then
			beginTransaction;
			delete testDataRTDevice;
			commitTransaction;
		endif;
	endforeach;
	
	foreach stockOrderHeaderGeneric in CM_StockOrderHeaderGeneric.instances do
		if stockOrderHeaderGeneric.myTransferTerminal = term then
			beginTransaction;
			delete stockOrderHeaderGeneric;
			commitTransaction;
		endif;
	endforeach;
	
	foreach xmlSession in CM_XMLSession.instances do
		if xmlSession.myTerminal = term then
			beginTransaction;
			delete xmlSession;
			commitTransaction;
		endif;
	endforeach;
	
	foreach yardRequest in CM_YardRequest.instances do
		if yardRequest.myTransferToTerminal = term then
			beginTransaction;
			delete yardRequest;
			commitTransaction;
		endif;
	endforeach;
	
	foreach harbour in HMS_Harbour.instances do
		if harbour.myDefaultTerminal = term then
			beginTransaction;
			harbour.setDefaultTerminal( null );
			commitTransaction;
		endif;
		if harbour.allTerminalsByCode.includes( term ) then
			beginTransaction;
			foreach region in harbour.allRegions do
				foreach movePath in region.allMovementPaths do
					delete movePath;
				endforeach;
			endforeach;
			commitTransaction;
			if harbour.allTerminalsByCode.size = 1 then
				beginTransaction;
				delete harbour;
				commitTransaction;
			else
				beginTransaction;
				harbour.allTerminalsByCode.remove( term );
				commitTransaction;
			endif;
		endif;
	endforeach;
	
	// 26/05/2016 cnwmh5
	beginTransaction;
	foreach cmqfFilterRpts in CMQF_FilterReports.instances do
		cmqfFilterRpts.allTerminals.removeIfPresent(term);	
	endforeach;
	commitTransaction;
	
	obj := term.myEdiConfig;
	if obj &lt;&gt; null then
		self.deleteEDIConfig( obj.CM_EDIConfig );
	endif;
	
	if not fromUnitTestMethod then 
		term.inspectModal();
	endif;
	termName := term.code;
	
	
	if not fromUnitTestMethod then 
		if app.msgBox("Delete " &amp; termName, "Sure??", MsgBox_Yes_No ) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;
	
	beginTransaction;
	delete term;
	commitTransaction;
	
	if not fromUnitTestMethod then 
		app.msgBox(termName &amp; " terminal successfully deleted.", "The End",MsgBox_OK_Only);
	else
		app.writeLog(termName &amp; " terminal successfully deleted.", LogINFO);
	endif;

epilog

	app.isGarbageCollectionProcess := false;
	delete objArray;
	delete emptyTis;
	delete iter;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="packCompleteContainer" id="ec8de8a7-6f7f-42df-a070-def2fceee942">
        <source>packCompleteContainer(_ti : CM_Container);
// 15/08/2013	cnwjre1
// 19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
vars
	pxyTI	: CM_TrackedItem;
	packRelease : CM_BulkRelease;
begin

	//self.opts.addAssoc(UTTI_BulkRelease, "PackRel1"); //Must be a pack request
	//15 Dec 2015	NDL	Par 37288
	if self.opts.includesKey(UTTI_BulkRelease) then
		if self.opts.obj(UTTI_BulkRelease) &lt;&gt; null then
			packRelease := self.opts.obj(UTTI_BulkRelease).CM_BulkRelease;
			self.assertNotNullMsg(packRelease, 'Pack request (' &amp; self.opts.str(UTTI_BulkRelease) &amp; ') not found.');
		endif;
	endif;

	pxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
	app.myTrxUA.trxUpdateTIPackComplete(pxyTI, packRelease, null, app.myPassport);	//19.03.2024 navhl20 #62863
	self.checkTrxResult();

epilog
	delete pxyTI;
end;</source>
        <Parameter name="_ti" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="packContainer" id="221d2dc0-4442-4447-a043-80068a6645c2">
        <source>packContainer(_ti: CM_Container io; _packTIs: CM_TIArray);
//27 November 2008	cnwdw1	
//+cnwml2 MSL CCMS 1017
vars
	unpackTIs: CM_TIArray;
	moveController: CMIF_MoveController;
	pxyTI, child: CM_TrackedItem;
begin
	create unpackTIs transient;
	create moveController transient;
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	pxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
	foreach child in _packTIs do
		pxyTI.setWeightCargo(pxyTI.weightCargo + child.totalWeight);
		pxyTI.setTotalWeight(pxyTI.totalWeight + child.totalWeight, null, app.myPassport);	// cnwdap1 08/07/2013
		pxyTI.setMyCargoVolume(pxyTI.getMyCargoVolume + child.getMyTotalVolume);	//#25592 08/11/20110
	endforeach;
	
	//23 Jul 2013	NDL	Par 32023 - DPH automatically add any child hazards to the parent.
	pxyTI.updateHazardsWhenPacking( _packTIs );
	
	app.myTrxUA.trxUpdatePackUnpack(moveController, false, _packTIs, unpackTIs, false, pxyTI, app.myPassport);
	checkTrxResult();

epilog
	delete moveController;
	delete unpackTIs;
	delete pxyTI;
end;</source>
        <Parameter name="_ti" type="CM_Container" usage="io"/>
        <Parameter name="_packTIs" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="planGCTisLOLO" id="e56ad4b8-6076-43e9-9a98-3ecc8c9c68bc">
        <updating/>
        <source>planGCTisLOLO(_tis : CM_TIArray io; _lcs : CM_LCArray) updating;
/*
Purpose:			
Date				Who			Reason
01/11/2011			cnwmh5 		Initial creation
*/

vars
	moveController	: CMIF_MoveController;
	result	: Integer;
	tmpErr	: CM_Error;
	tmpString : String;
	tmpTi	:	CM_TrackedItem;
	index	: Integer;
begin
	create moveController transient;

	moveController.isRehandleMove := false;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;
	moveController.mySlotRequest := _lcs.first.CM_SlotController.mySlotRequestLoad;
	if _tis.size &gt; 1 then
		tmpTi := _tis[1];
		index := _tis.size;
		while index &gt; 1 do
			moveController.allOtherTrackedItems.add(_tis[index]);
			index := index - 1;
		endwhile;
		_tis.clear();
		_tis.add(tmpTi);
	endif;
	app.myPassport.setWarningsIgnored(true);

	// ### BULK LOAD PLAN
	if self.opts.includesKey("LikeDragAndDrop") then
		moveController.setMyTrackedItem(_tis[1].CM_TrackedItem);
		app.myTrxUA.trxMoveTrackedItemAssignToJob(moveController, app.myPassport);
	else
		app.myTrxUA.trxMoveTIsAUTOAssignToJob(_tis, _lcs, moveController, app.myPassport);
	endif;
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="io"/>
        <Parameter name="_lcs" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="planItemBackToShip" id="8b61dd48-5d61-48da-b015-33ec4e3a2606">
        <source>planItemBackToShip(_cargo : CM_TrackedItem; _slotController : CM_SlotController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwmh5	Initial creation

*/

vars

	moveController		: CMIF_MoveController;
	wle 				: CM_VoyageWLE;

begin

	create moveController transient;
	moveController.setMyTrackedItem(_cargo);
	moveController.setMyToPrimaryLocation(_slotController);
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isForcedMove := true;
	moveController.isSystemMove := true;
	moveController.isRehandleMove := true;
	moveController.isDLRLoadWithOutDischarge := true;
	moveController.mySlotRequest := _slotController.mySlotRequestLoad;
	
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	wle := _slotController.mySlotRequestLoad.allWorkListEntries.last.CM_VoyageWLE;
	if wle &lt;&gt; null then
		beginTransaction;
		_cargo.allPlannedFutureMoves.last.setMyWorkListEntry(wle, false);
		wle.setMyTrackedItem(_cargo);
		wle.setLocations(wle.locationSource, moveController.mySlotRequest.myBay.id.String &amp; moveController.mySlotRequest.id);
		commitTransaction;
	endif;

epilog
	
	delete moveController;
	
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_slotController" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="planLoadItem" id="51ba1a11-f034-4030-b82e-b8c02bff6fb6">
        <updating/>
        <source>planLoadItem(_voyage : CM_Voyage io; _craneId : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2010	cnwdap1	Initial creation
*/
vars
	tmpOptionsUsed 		: IntegerArray;
	allJobs 			: CM_JobArray;
	controller			: CMIF_ShipPlanningController;
	mode				: Integer;
	jobSheet			: CM_VoyageJobSheet;
	job					: CM_Job;
	planAcrossTermArea	: Boolean;
	planIfStops			: Boolean;
	planFromRowEnds		: Boolean;
	useWeights			: Boolean;
	planAcrossTermCol	: Boolean;
	ignoreWarnings		: Boolean;
	planTwinLift		: Boolean;
	height				: Integer;
	weightAve			: Integer;
	weightPC			: Integer;
	numRowSep			: Integer;

begin
	create tmpOptionsUsed transient;
	create allJobs transient;
	create controller transient;
	mode := 3; //this is job mode voyage is 1 crane is 2
	jobSheet := _voyage.allJobSheets[_craneId];    ///"CRN1"];
	app.writeLog('_craneId: ' &amp; _craneId &amp; Tab &amp; "jobSheet: " &amp; jobSheet.String, LogINFO);
	
	//there's only one job
	beginTransaction;
	foreach job in _voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isDischarge then
			continue;
		endif;
		allJobs.add(job);
		// set "loaded to operations" flag
		job.setPropertyValue("isLoadedToOperations", true);
	endforeach;
	commitTransaction;
	app.writeLog("allJobs: " &amp; allJobs.size.String, LogINFO);
	
	/* the options that could be included
		VoyageFullPlanThirdHeight
		VoyageFullPlanGroundHeight
		VoyageFullPlanOSVoyage
		VoyageFullPlanOSDischPort
	*/
	
	//not sure why this sets the config when the chk box changes value?
	app.myTrxUA.trxUpdateTerminalConfig(self.getTerminal, AutoLoadPlanAt3Height,false, app.myPassport );
	planAcrossTermArea := true;
	
	controller.init(	self.getTerminal,
						mode, 
						allJobs, 
						jobSheet,
						_voyage,
						planIfStops,
						tmpOptionsUsed, 
						height, 
						planFromRowEnds,
						numRowSep,
						null,
						useWeights,
						weightAve,
						weightPC,
						planAcrossTermArea,
						planAcrossTermCol,
						ignoreWarnings,
						planTwinLift	);
					
	controller.initQuery();
	controller.doQuery(null);

epilog
	delete tmpOptionsUsed;
	delete allJobs;
	delete controller;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_craneId" type="String"/>
    </JadeMethod>
    <JadeMethod name="planTIsLOLO" id="f5c25fb6-3e2b-437c-a1ed-901857398913">
        <source>planTIsLOLO(_tiArray : CM_TIArray; _slots : CM_SlotControllerArray; _voyage : CM_Voyage; _deleteStops : Boolean);

/*

Purpose:		Plan TI's to Ship

Date			Who		Reason
25/03/2014		cnwmh5	Initial creation

*/

vars

	ti							: CM_TrackedItem;
	moveController 				: CMIF_MoveController;

	theTIs						: CM_TIArray;
	lcs							: CM_LCArray;

	index						: Integer;
	ignoreWarnings				: Boolean;
	warningsAcknowledged		: Boolean;

begin

	ignoreWarnings := not self.opts.bool("DontIgnoreWarnings");						// 22/07/2015 cnwmh5
	warningsAcknowledged := self.opts.bool("WarningsAcknowledged");

	if _slots = null or _slots.isEmpty() then
		return;
	endif;

	create theTIs transient;
	if _tiArray &lt;&gt; null then
		_tiArray.copy(theTIs);
	endif;
	
	// if empty the sue any ti's assigned to voyage and aren't planned / queued
	if theTIs.isEmpty() then
		if _voyage = null then
			return;
		endif;
	
		index := 1;
		foreach ti in _voyage.allOnsiteTIsByIdCargoType do
			if not ti.isOnShip and  not ti.isPlanned(PLANNING_MODE) and not ti.isQueued() then
				theTIs.add(ti);
				index := index + 1;
			endif;
			if index &gt; _slots.size then
				break;
			endif;
		endforeach;
		
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in theTIs do	
		self.updateTI(ti);
		if _deleteStops then
			self.deleteStops(ti);
		endif;
	endforeach;

	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create lcs transient;
	_slots.copy(lcs);
	
	create moveController transient;
	moveController.isRehandleMove := true;
	moveController.mySlotRequest := _slots.first.mySlotRequestLoad;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;
	
	app.myPassport.setWarningsIgnored(ignoreWarnings);
	app.myPassport.setWarningsAcknowledged(warningsAcknowledged);			// 22/07/2015 cnwmh5

	// ### BULK LOAD PLAN
	app.myTrxUA.trxMoveTIsAUTOAssignToJob(theTIs, lcs, moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	app.myPassport.setWarningsIgnored(false);						// 22/07/2015 cnwmh5
	app.myPassport.setWarningsAcknowledged(false);

	delete lcs;
	delete theTIs;
	delete moveController;
	
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <Parameter name="_slots" type="CM_SlotControllerArray"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deleteStops" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="planTIsRORO" id="6d97927b-4e30-4097-b41c-6ee80ebd822e">
        <updating/>
        <source>planTIsRORO(_tis : CM_TIArray; _lcs : CM_LCArray; _primeReq : CM_RORORequest) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	moveController	: CMIF_MoveController;
	result	: Integer;
	theSlotRequest : CM_RORORequest;
	tmpErr	: CM_Error;
	tmpString : String;
begin
	create moveController transient;

	moveController.isRehandleMove := false;
