    <JadeMethod name="initQryReportForRunner" id="9f566d64-7e3d-4caf-b955-00d8bd624376">
        <updating/>
        <source>initQryReportForRunner(_menuEntity: CM_QryReport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation

*/
vars
	jrwReport		: JadeReportWriterReport;
	newState		: String;

begin
	self.myQryReport := _menuEntity;
	self.setState(newState);
	
	//self.myEntTableDef := app.myController.getEntTableDef(_menuEntity.getETDefName());
	self.myEntTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs.getAtKey(_menuEntity.getETDefName());

