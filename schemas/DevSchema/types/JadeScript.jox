    <JadeMethod name="eprTestBulkAreaTestFull" id="d2ba292c-6a02-41da-955a-42da1badf003">
        <source>eprTestBulkAreaTestFull();
/*

Date		Who		Reason
01 April 2014	cnwer1	Initial creation PAR

*/

vars
	bs  : CM_BlockStack;
		allTisByCargoType : DynaDictionary;
	iter : Iterator;
	tmpTI,
	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
begin
	
	bs :="2353.2789".asOid.CM_BlockStack;
	cargoType:="2083.653".asOid.CM_CargoType; //widgets
	
	cargoSubType:=null;
	cargoSubType:="4069.14433".asOid.CM_Product; //rebar 20gr60
	cargoType:=cargoSubType.myCargoType;
	
	create allTisByCargoType transient;
	allTisByCargoType.setMembership(CM_TrackedItem);
	allTisByCargoType.addMemberKey(CM_TrackedItem::myCargoType.name,false,false);
	allTisByCargoType.addMemberKey(CM_TrackedItem::myProduct.name,false,false);
	allTisByCargoType.endKeys(true);
	
	bs.myLocationsController.allTrackedItems.copy(allTisByCargoType);
	iter := allTisByCargoType.createIterator;
	allTisByCargoType.startKeyGeq(cargoType,cargoSubType,iter);
	while iter.next(tmpTI) do
		if tmpTI.myCargoType &lt;&gt; cargoType then
			break;
		endif;
		
		if tmpTI.myProduct &lt;&gt; cargoSubType then
			break;
		endif;
		
		write tmpTI.id;
		
	endwhile;
epilog
	delete allTisByCargoType;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestCCRequest" id="010e320e-391d-4f15-8ac4-75420481cda3">
