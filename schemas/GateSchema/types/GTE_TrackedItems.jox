    <JadeMethod name="doBtnRetrieve" id="aac712f6-0980-48df-a5e4-473aa18178c0">
        <updating/>
        <source>doBtnRetrieve() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
/****Changes

Date		Name	TFS#			Description
============================================================================
16/12/2009	cnwmh5	PAR #21921 		Remove setting of checkISOGroup
============================================================================*/

vars
	anObject : Object;
	idx, theRow : Integer;
begin
	app.mousePointer 	:= Window.MousePointer_HourGlass;
	
	self.isEmptyOnly 	:= self.tblInput.getValueByName(ETRow_MtRelease).Boolean;
	self.includeOnShip 	:= self.tblInput.getValueByName(ETRow_IncludeOnShip).Boolean;
		
	///self.checkISOGroup := self.tblInput.getValueByName(ETRow_DoISOGroupCheck).Boolean;	// 16/12/2009 cnwmh5 #21921
	
	//al other filter criteria attributes set on combo click methods
	self.doFilter();
	
	foreach idx in 2 to self.tblList.rows do
		anObject := self.tblList.accessRow(idx).itemObject;
		theRow := 0;
		
		self.tblListAll.findObjectInRow(anObject, theRow);
	
		if theRow &gt; 0 then
			self.tblListAll.removeItem(theRow);
		endif;
	 endforeach;
	 

epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doChkFilterClick" id="9718bd2c-f125-466c-b6d8-a3b9379a0a0d">
        <updating/>
        <source>doChkFilterClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
/****Changes

Date		Name	TFS#		Description
============================================================================
16/12/2009	cnwmh5	PAR #21921  Add stuff for iso type group
16/01/2018	jlgka1	41708		Add Bill Of Lading.
15/03/2019	jlgka1	43807		Fixed bug of floating combo box. 
								Add "not isReleaseByType" to the condition.	
============================================================================*/
begin
	
	if self.chkUseFilter.value then
		self.tblInput.showRowByName(ETRow_OperatorCode,false);
		self.tblInput.showRowByName(ETRow_VoyageCode,false);
		self.tblInput.showRowByName(ETRow_ImexStatusString,false);
		self.tblInput.showRowByName(ETRow_MtRelease,false);
		self.tblInput.showRowByName(ETRow_IsoType,false);
		self.tblInput.showRowByName(ETRow_IncludeOnShip,false);
		//jlgka1 TFS 41708 --&gt;
	//	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean and not self.isReleaseByType then
		if self.useTotReqAllowedFld and not self.isReleaseByType then	//28 Aug 2019	NDL	TFS 46118
			self.tblInput.showRowByName(ETRow_BillOfLading,false);
		endif;
		//jlgka1 TFS 41708 &lt;--
		self.tblInput.showRowByName(ETRow_Mark,false);	//28 Aug 2019	NDL	TFS 46118
		
		// cnwrd1 par 22789  shifted some stuff into this section as it seemed the more correct tiem to do it.
		self.cmbISOType.setObject(self.myISOType);
					
		self.cmbImEx.listIndex := 1;
		self.cmbOperator.listIndex := 1;
		self.cmbVoyage.listIndex := 1;		
		self.tblInput.setValueByControlName(self.cmbISOType.name,self.cmbISOType.text);
		//self.tblInput.setValueByControlName(self.cmbISOGroup.name, self.cmbISOType.text);	// 16/12/2009 cnwmh5 #21921
		self.cmbISOType_lostFocus(self.cmbISOType); // cnwrd1 par 22789 15/3/2010 refilter ISO group if iso type selected
		self.tblInput.setValueByControlName(self.cmbISOGroup.name, self.cmbISOGroup.text);	// cnwrd1 par 22789 15/3/2010 think we meant this rather than above.
		
		//-cnwml2 PAR22789
		//self.tblInput.setValueByControlName(self.cmbImEx.name,self.cmbImEx.text);
		//self.tblInput.setValueByControlName(self.cmbOperator.name,self.cmbOperator.text);
		//self.tblInput.setValueByControlName(self.cmbVoyage.name,self.cmbVoyage.text);
		
		//+cnwml2 PAR22789
		
		if self.myIMEXStatus = null then	//11 Jan 2018	NDL	TFS 36415
			self.cmbImEx.listIndex := -1;
		else
			self.tblInput.setValueByControlName(self.cmbImEx.name,self.myIMEXStatus.description);
			self.cmbImEx.listObject := self.myIMEXStatus;
		endif;
		if self.myOperator &lt;&gt; null then
			self.tblInput.setValueByControlName(self.cmbOperator.name,self.myOperator.code);
			self.cmbOperator.listObject := self.myOperator;
		else
			self.tblInput.setValueByControlName(self.cmbOperator.name,self.cmbOperator.text);
		endif;
		
		if self.myVoyage &lt;&gt; null then
			self.tblInput.setValueByControlName(self.cmbVoyage.name,self.myVoyage.code);
			self.cmbVoyage.listObject := self.myVoyage;
		else
			self.tblInput.setValueByControlName(self.cmbVoyage.name,self.cmbVoyage.text);
		endif;
		if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean and not self.isReleaseByType then	
			if self.myBOLIn &lt;&gt; null then
				self.tblInput.setValueByControlName(self.cmbBOLAnyId.name,self.myBOLIn.number);
				self.cmbBOLAnyId.listObject := self.myBOLIn;
			else
				self.tblInput.setValueByControlName(self.cmbBOLAnyId.name,self.cmbBOLAnyId.text);
			endif;
		else
			self.cmbBOLAnyId.visible := false;	
		endif;
	else
		self.tblInput.hideRowByName(ETRow_OperatorCode,false);
		self.tblInput.hideRowByName(ETRow_VoyageCode,false);
		self.tblInput.hideRowByName(ETRow_ImexStatusString,false);
		self.tblInput.hideRowByName(ETRow_MtRelease,false);
		self.tblInput.hideRowByName(ETRow_IsoType,false);
		self.tblInput.hideRowByName(ETRow_IncludeOnShip, false);
		//jlgka1 TFS 41708 --&gt;
		if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean and not self.isReleaseByType then
			self.tblInput.hideRowByName(ETRow_BillOfLading,false);
		else
			self.cmbBOLAnyId.visible := false;
		endif;
		//jlgka1 TFS 41708 &lt;--
		
		self.tblInput.hideRowByName(ETRow_Mark,false);	//28 Aug 2019	NDL	TFS 46118
		
//		self.cmbISOType.listObject := self.myISOType;
		
		//self.cmbISOGroup.listObject := self.myISOGroup;		// 16/12/2009 cnwmh5 #21921

		self.myOperator 	:= null;
		self.myVoyage 		:= null;
		self.isEmptyOnly 	:= true;
		self.includeOnShip 	:= false;		
		
		self.myAssistant.comboBoxISOTypeGroup(cmbISOGroup, self.myISOGroup); //have to refill ISO group here as it may have been limited from the ISO type selection in below mode. // cnwrd1 par 22789 15/3/2010
	endif;
	self.filterForCargo := self.chkUseFilter.value;
	self.tblInput.resetSize();
	self.doResize(); // cnwrd1 par 22789 15/3/2010
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboVoyageBuild" id="dfbb4803-e4a2-4bd7-b9cc-4e05c165fd69">
        <source>doComboVoyageBuild();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCombo : CMUI_ComboBox;
	aVoyage : CM_Voyage;
	theVoyages : CM_VoyageSet;
begin

	create theVoyages transient;
	
	theCombo := self.cmbVoyage;
	theCombo.clear;
	
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages,true, false);
	
	foreach aVoyage in theVoyages do
		theCombo.addItemObject(aVoyage.code,aVoyage);
	endforeach;

	theCombo.sorted := false;
	
	theCombo.addItemAt("All",1)	;
	
	if self.myVoyage &lt;&gt; null then
	// ### PAR 10264. is possible that the voyage has departed and so is not in the combo list.
		if theCombo.findObject(self.myVoyage) = -1 then 
			theCombo.addItemObject(self.myVoyage.code,self.myVoyage);
		endif;
	endif;
	
	theCombo.listObject := self.myVoyage;
		
epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilter" id="a744824a-4f8a-430a-baeb-e237ae6f4723">
        <source>doFilter();
/*
----------   ----------  --------------------------------------------------
Created:	26 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	self.tblListAll.rows := self.tblListAll.fixedRows;
	self.tblListAll.allSelectedObjects.clear();
	if self.myVoyage &lt;&gt; null then
		if self.includeOnShip then
			self.doFilterDict(self.myVoyage.allOnshipTIsByCargoTypeId, self.tblListAll);
		endif;
		self.doFilterDict(self.myVoyage.allOnsiteTIsByCargoTypeId, self.tblListAll);
	else
		self.doFilterDict(self.myTerminal.allOnsiteTIsByCargoTypeId, self.tblListAll);
	endif;
	
	
epilog
	endLoad;
	
end;

</source>
    </JadeMethod>
    <JadeMethod name="doFilterDict" id="0663f0c8-592e-44d1-a44a-edf2920bbc78">
        <source>doFilterDict(_dict			: CM_TIByCargoTypeIdDict;
			_tbl 			: CM_BaseTable input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 September 2006 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#			Description
============================================================================
16/12/2009	cnwmh5	PAR #21921 		Change filtering for myISOType and add
									filtering for myISOGroup
16/01/2019	jlgka1	41708			Add Filtering of myFilterBOL (Bill of Lading).
04/07/2022  navsj20 53862   		EUP - WMS - Damage Recording Extra Details
22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
============================================================================*/
vars
	ti				: CM_TrackedItem;
	iter			: Iterator;
	idStrKey,
	str				: String;
	cargoType,
	cargoTypeKey	: Integer;
	user			: CM_User;
begin

	beginLoad;
	cargoType := self.currentCargoType;
	iter 	  := _dict.createIterator;
	user	  := app.myPassport.myUser;
	
	_dict.startKeyGeq(cargoType, null, iter);
	
	while iter.next(ti) do
		iter.getCurrentKeys(cargoTypeKey,idStrKey); //MTN-35226
		if cargoType &lt;&gt; null and cargoTypeKey &lt;&gt; cargoType then
			break;
		endif;
		
		// 16/12/2009 cnwmh5 - Start
		// Filter based on myISOType contents
		if self.myISOType &lt;&gt; null and self.myISOGroup = null then
			if ti.getISOType &lt;&gt; self.myISOType.code then
				continue;
			endif;
		endif;
		
		// Filter based on myISOGroup contents
		if self.myISOGroup &lt;&gt; null then
			if ti.isoTypeGroupDesc &lt;&gt; self.myISOGroup.code then
				if ti.getISOTypeGroup &lt;&gt; self.myISOGroup then
					continue;
				endif;
			endif;
		endif;
		// 16/12/2009 cnwmh5 - End
		
		if self.myOperator &lt;&gt; null then
			if self.myOperator.code.trimBlanks &lt;&gt; ti.operatorCode.trimBlanks then
				if self.myOperatorGroup &lt;&gt; null then
					if (not self.myOperatorGroup.allOperators.includes(ti.myOperator)) then
						continue;
					endif;
				else
					continue;
				endif;
			endif;
		endif;
		
		if self.myIMEXStatus &lt;&gt; null and ti.getImExStatus() &lt;&gt; self.myIMEXStatus.code then
			continue;
		endif;
		
		if self.myFiltDestination &lt;&gt; null and ti.destinationPort &lt;&gt; self.myFiltDestination.code then
			continue;
		endif;
		
		if self.myFiltFreightFwdr &lt;&gt; null and ti.freightForwarderCode &lt;&gt; self.myFiltFreightFwdr.code then
			continue;
		endif;
		
		//jlgka1 TFS 41708 --&gt;		
		if self.myBOLIn &lt;&gt; null then
			if ti.billOfLading &lt;&gt; self.myBOLIn.number then
				continue;
			endif;
		endif;
		//jlgka1 TFS 41708 &lt;--
		
		//th2 for PAR 14847
		//th2 PAR 14915 - consignee match if null
		//th2 PAR 14915 - 08/10/07 - original change backed out as requested
		if self.myFiltConsignee &lt;&gt; null and ti.consignee &lt;&gt; self.myFiltConsignee.code then
			continue;
		endif;
		
		if cargoType = TI_CargoType_Container then
			if self.isEmptyOnly and ti.CM_Container.isFull then
				continue;
			endif;
			if not self.allMTGrades.isEmpty then
				if not self.allMTGrades.includes(ti.CM_Container.availabilityGrade) then
					continue;
				endif;
			endif;
		endif;
		
		//PAR 4666 dont display allocated ti's
		if not allowReleaseAllocated then  // we allow already held items if we are searching from a waybill release // cnwrd1 par 22901 15.3.2010
			if ti.isHeldForRelease or ti.releaseRequest &lt;&gt; null then
				continue;
			endif;
		endif;
		
		if self.useTotReqAllowedFld and self.myBOLIn &lt;&gt; null and ti.billOfLading &lt;&gt; self.myBOLIn.number then	//NDL 28 Aug 2019
			continue;
		endif;
		
		//28 Aug 2019	NDL	TFS 46118
		if self.filterMark &lt;&gt; null then
			if ti.mark &lt;&gt; self.filterMark then
				continue;
			endif;
		endif;
		
		// START 04/07/2022 navsj20 TFS 53862
		if ti.hasStopsToBePrevented(StopPreventRelReqDamRefused) then
			continue;
		endif;
		// END 04/07/2022  navsj20 TFS 53862
		
		// ### JIRA 34756 27MAY2025 NAVAB1
		if user.canDo(self.myTerminal, Sub_CustomDocuments) then
			//22/08/2023	navkc1	CR 59610 Task 59611 --&gt;
			if ti.hasStopsToBePrevented(StopPreventRelReqAssign) then
				continue;
			endif;
		endif;
		
		str := self.getTiDisplay( ti );	//28 Aug 2019	NDL	TFS 46118
		_tbl.accessRow(_tbl.addItem(str)).itemObject := ti;
	endwhile;
	

epilog
	endLoad;
	delete iter;
end;

</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_TIByCargoTypeIdDict"/>
        <Parameter name="_tbl" type="CM_BaseTable" usage="input"/>
    </JadeMethod>
