        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbGateArea_click(combobox: ComboBox input) updating;

/*
Date			Who		Reason
27 August 2009	cnwar2	Initial creation

*/
vars

begin 
	
	self.myCurrentTableItem.SOPTM_RFIDTagReader.doCmbAreasClick();
	
	combobox.parent.CM_EntryTable.setValueByControlName(self.cmbGateLane.name, self.cmbGateLane.text);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbGateArea_lostFocus" id="3f641a65-283e-4646-920c-bf9c23501cdc">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbGateArea_lostFocus(combobox: ComboBox input) updating;

/*
Date			Who		Reason
27 August 2009	cnwar2	Initial creation
10/09/2009		cnwcs5	ccms1061 - fix problem where lanes don't get cleared out if you clear the gate area combo
*/
vars
	
begin 
	if combobox.parent.isKindOf(CM_EntryTable) then
		combobox.parent.CM_EntryTable.setValueByControlName(combobox.name, combobox.text);
		
		// we don't get a click event id we clear out the combo so we will do our processing here
		if combobox.text = null then
			self.myCurrentTableItem.SOPTM_RFIDTagReader.doCmbAreasClick();
	
			combobox.parent.CM_EntryTable.setValueByControlName(self.cmbGateLane.name, self.cmbGateLane.text);
		endif;
		
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbGateLane_displayEntry" id="a75b98b2-7c72-401f-8b1d-82b811e8773f">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbGateLane_displayEntry(combobox: ComboBox input; obj: CM_LocationsController; lstIndex: Integer):String updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
12/11/2009	cnwcs5		removed app.writeStatement
23/02/2010	cnwcs5		changed CM_GateLaneController to CM_GateAreaLaneController
*/
vars

begin
	if obj.isKindOf(CM_LaneController) then
		// don't show the default outward gate for an admin gate
		// temporary till we handle outward admin gate
		if obj.isKindOf (CM_GateAreaLaneController) and
			obj.CM_GateAreaLaneController.isAGateLane and
			not obj.CM_GateAreaLaneController.isIn then 
			return null;
		endif;
		return obj.CM_LaneController.getLaneId;
	else
		return obj.CM_LocationsController.getID;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="CM_LocationsController"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
