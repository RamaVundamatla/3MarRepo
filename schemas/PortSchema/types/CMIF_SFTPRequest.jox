    </JadeMethod>
    <JadeMethod name="processDirlist" id="1ffd4854-08dd-4df9-8497-0684be2fe914">
        <updating/>
        <source>processDirlist(_inputStr : String) updating;
//
// 24 Oct 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//
vars
	strDate : String;
	fileName : String;
	mth : String;
	mM : Integer;
	dD : Integer;
	yY : Integer;
	hh : String;
	mm : String;
	dt : TimeStamp;
	tmpDate : Date;
	tmpTime : Time;
	dtStr : CMIF_DateString;
	msg : String;
	obj : Object;
begin
	
/*	if _inputStr[5:6] = "******" then
		strDate := _inputStr.String[44:end].cnEcRemoveSubstring(Lf).cnEcRemoveSubstring(Cr);
		fileName := strDate[14:end].trimBlanks;
	else
		strDate := _inputStr.String[43:end].cnEcRemoveSubstring(Lf).cnEcRemoveSubstring(Cr);
		fileName := strDate[14:end].trimBlanks;
	endif; */
	
	//19 Aug 2021	NDL	TFS 51800 - This only sorts out finding where the Month portion of the string starts using
	// the existing assumptions. I.e. It doesn't address the situation where a date may be in another language,
	// or where the date format differs.
	strDate := self.getTextFromDateOnwards( _inputStr );
	fileName := strDate[14:end].trimBlanks;
	
	foreach obj in self.allFilesList do
		dtStr := obj.CMIF_DateString;
		if dtStr.str = fileName then
			return;
		endif;
	endforeach;
	mth := strDate[1:3];
	dD := strDate[5:2].Integer;
	hh := strDate[8:2];
	mm := strDate[11:2];
	mM := self.convertMthNameToNumber(mth);
	yY := tmpDate.year;
	tmpTime.setTime(hh.Integer, mm.Integer, 0, 0);
	dt.setTime(tmpTime);
	tmpDate.setDate(dD, mM, yY);
	dt.setDate(tmpDate);
	msg := '035 get date '&amp;dD.String&amp;'/'&amp;mM.String&amp;'/'&amp;yY.String&amp;' '&amp;hh&amp;'.'&amp;mm&amp;' '&amp;dt.String;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
	create dtStr transient;
	dtStr.dt := dt;
	dtStr.str := fileName;
	self.allFilesList.add(dtStr);
epilog

end;</source>
        <Parameter name="_inputStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="processEdiSFTPGet" id="59f95ae4-d190-4a96-8cef-1839d498bdb6">
        <updating/>
        <source>processEdiSFTPGet() : Boolean updating;
//
// 03 Mar 2014	cmwrs1 par 33631
//
//11 Jun 2014	cnwrs1	Par 34062 add useProxy to FTP Get/Put
//26 May 2014 	ccms 34183 process files in created date time
//19 Aug 2015	cnwrs1	Par 36758 fix directory skip, add alert when file delete fails
//20 Aug 2015	cnwrs1	Par 36795 enable a file to be read and deleted in one session
//24 Aug 2015	cnwrs1	Par 36815 enable FTP get to continue after a failed file delete by saving off the fileNames
//15 Nov 2017	jlgkpd1	TFS 7462 - Allow for optional port number to be specified in the server name
//17 Sep 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//09 Dec 2019	jlgrs1	TFS 46528 password or private key are required
//17 Dec 2019	jlggb1	TFS 46528 Remove unnecessary wait
//03 Oct 2022	navmd1	TFS 52179 Return false if we had an error getting the remote server file list
//13 Mar 2023	navmd1	TFS 57047 Fix up confusing log messages and multiple slashes when accessing source folder
//
constants
	CCHex : Character = #CC.Character;
vars
	sftpEntity : CM_SFTPEntity;
	ftp : CnFtp;
	file : File;
	resultStr : String;
	resultInt : Integer;
	mask : String;
	fileInfo : Binary;
	fileName : String;
	isDirectory : Boolean;
	notFirstTime : Boolean;
	lastModified : TimeStamp;
	result : String;
	singleFileCopy : Boolean;
	fileNameArray : StringArray;
	attributes : String;
	filesize : Integer;
	oa : ObjectArray;
	obj : Object;
	hadError : Boolean;
	str : String;
	command : String;
	length : Integer;
	msg : String;
	foundFiles : Boolean;
	foundDirectory : Boolean;
begin
	sftpEntity := self.mySFTPEntity.CM_SFTPEntity;
	singleFileCopy := sftpEntity.getSingleFileCopy;
	
	msg := 'Term='&amp;self.myTerminal.code&amp;" FTP "&amp;sftpEntity.id&amp;" from "&amp;self.sourceDirectory&amp;" to "&amp;self.destinationDirectory;
	app.writeLog(msg, LogINFO);
	msg := '050 get directory for '&amp;self.sourceDirectory;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
	
	self.functionType := SFTP_LISTDIR;
	
	msg := '060 set waiting to 1 ';
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
	
//	command := 'ls /'&amp;sftpEntity.sourceDirectory&amp;' -trp'; //'dir /'&amp;sftpEntity.sourceDirectory&amp;' /OD /b';	// ls -trp	// sftpEntity.publicKey sftpEntity.passPhrase
//			hadError := self.emSSH_RemoteCommandSync(self, sftpEntity.getServerNameForConnect(), sftpEntity.userId, sftpEntity.password, sftpEntity.port.String, command, null, sftpEntity.privateKey, null, timeOut, result);
//	hadError := self.emSFTP_ListDir(self, sftpEntity.getServerNameForConnect(), sftpEntity.userId, sftpEntity.password, sftpEntity.port, sftpEntity.sourceDirectory, null, sftpEntity.privateKey, null, self.getInstanceIdForObjectXX(self), result);
//	msg := ' 090 hadError='&amp;hadError.String&amp;' result='&amp;result;
//	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;process.String&amp;' '&amp;app.cnGetServerTime.formatAsYYYYMMDDHHMMSSMMM&amp;msg, LogDebug3);
//	if hadError then
//		app.raiseCMException1(Error_Display, result, null, null);// cnwdb2	PAR 35364
//	endif;

	msg := 'SFTP_LISTDIR '&amp;self.sourceDirectory;
	app.writeLog(msg, LogINFO);	
	msg := " 065 emSFTP_ListDir host="&amp;self.host&amp;' userId='&amp;self.userId&amp;' password length='&amp;self.password.length.String&amp;' port='&amp;self.port.String&amp;' destDir='&amp;self.sourceDirectory&amp;' publicKey=null'&amp;' privateKey length='&amp;self.privateKey.length.String&amp;' passPhrase length='&amp;self.passPhrase.length.String&amp;' subscriberOid=null';
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
	
	hadError := self.emSFTP_ListDir(self, self.host, self.userId, self.password, self.port, self.sourceDirectory, null, self.privateKey, self.passPhrase, null, result);
	
	msg := '070 hadError='&amp;hadError.String&amp;' result='&amp;result;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
	
	if hadError then
		app.raiseCMException1(Error_Display, result, null, null);
	else
		// emSFTP_ListDir is an async call, and relies on sending notifcations. In the even that it takes too long, or the notifications are lost, lets start a timer to abort, and tidy up.
		self.beginTimer(self.timeOut * 1000, Timer_OneShot, CMIF_SFTPRequest.EVENT_TIMEOUT);	// TFS 52179 navmd1 30/09/2022
	endif;
epilog
	msg := '075 epilog '&amp;' self='&amp;self.String;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
	
	return not hadError;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processFiles" id="ce7f396c-b370-4636-8a59-93b13314c8b7">
        <updating/>
        <source>processFiles() updating;
//
// 24 Oct 2019	jlgrs1	TFS 46087 JMT implement SFTP.
// 09 Dec 2019	jlgrs1	TFS 46528 password or private key are required
// 13 Mar 2023	navmd1	TFS 57047 Refactor and fix double slashes
//
vars
	hadError : Boolean;
	result : String;
	msg : String;
	dtStr : CMIF_DateString;
	obj : Object;
	dyna : DynaDictionary;
	iter : Iterator;
begin
	msg := '015 got directory list ' &amp; 'functionType=' &amp; self.functionType.String &amp; ' size=' &amp; self.allFilesList.size.String;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;process.String&amp;' '&amp;msg, LogDEBUG);

	create dyna transient;
	dyna.setMembership(CMIF_DateString);
	dyna.addMemberKey(CMIF_DateString::dt.name, false, false);
	dyna.endKeys(true);
	self.allFilesList.copy(dyna);
	
	iter := dyna.createIterator;
	while iter.next(dtStr) do
		msg := '025 get first.next list date=' &amp; dtStr.dt.String &amp; ' fileName=' &amp; dtStr.str;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;process.String&amp;' '&amp;msg, LogDEBUG);
		
		self.functionType := SFTP_READ;
		self.sourceFile := self.sourceDirectory &amp; dtStr.str;
		self.destFile := self.destinationDirectory &amp; '\' &amp; dtStr.str;
		msg := 'Copy file ' &amp; self.sourceFile &amp; ' to ' &amp; self.destFile;
		app.writeLog(msg, LogINFO);
		
		msg := " 033 emSFTP_ReadFileSync host=" &amp; self.host &amp; ' userId=' &amp; self.userId &amp; ' password length=' &amp; self.password.length.String &amp; ' port=' &amp; self.port.String &amp; ' sourceFile=' &amp; self.sourceFile &amp; ' destFile='
			&amp; self.destFile &amp; ' publicKey=null' &amp; ' privateKey length=' &amp; self.privateKey.length.String &amp; ' passPhrase length=' &amp; self.passPhrase.length.String &amp; ' subscriberOid=null' &amp; ' timeout='&amp;timeOut.String;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
		
		hadError := self.emSFTP_ReadFileSync(self, self.host, self.userId, self.password, self.port, self.sourceFile, self.destFile, null, self.privateKey, self.passPhrase, null, timeOut, result);
		msg := '035 hadError='&amp;hadError.String&amp;' result='&amp;result;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;process.String&amp;' '&amp;msg, LogDEBUG);
		
		if hadError then
			app.raiseCMException1(Error_Display, result, null, null);// cnwdb2	PAR 35364
		endif;
		
		msg := 'Remove file '&amp;self.sourceFile;
		app.writeLog(msg, LogINFO);
		self.functionType := SFTP_REMOVE;
		msg := " 045 emSFTP_RemoveFile host=" &amp; self.host &amp; ' userId=' &amp; self.userId &amp; ' password length=' &amp; self.password.length.String &amp; ' port=' &amp; self.port.String &amp; ' sourceFile=' &amp; self.sourceFile &amp; ' publicKey=null'
			&amp; ' privateKey length=' &amp; self.privateKey.length.String &amp; ' passPhrase length=' &amp; self.passPhrase.length.String &amp; ' subscriberOid=null';
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
		
		hadError := self.emSFTP_RemoveFile(global, self.host, self.userId, self.password, self.port, self.sourceFile, null, self.privateKey, self.passPhrase, null, result);
		msg := '045 hadError='&amp;hadError.String&amp;' result='&amp;result;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;process.String&amp;msg, LogDEBUG);
		if hadError then
			app.raiseCMException1(Error_Display, result, null, null);// cnwdb2	PAR 35364
		endif;
	endwhile;
	
	msg := '050 end of processing';
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;process.String&amp;' '&amp;msg, LogDEBUG);
epilog
	self.functionType := SFTP_END;
	msg := '055 epilog';
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;process.String&amp;' '&amp;msg, LogDEBUG);
	
	delete iter;
	delete dyna;
	self.allFilesList.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="6e783469-9571-48ff-b422-d81e0d8a2e48">
        <updating/>
        <source>timerEvent(_eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 September 2022	navmd1	Initial creation TFS 52179
28 January 2025		jlizm1	MTN 33057 Increase logging to identitfy sftp halting

*/

vars
	ediRequest		: BGP_EdiFTPGet;
	errCode			: Integer;
	errTxt,
	result			: String;
begin
	if _eventTag = CMIF_SFTPRequest.EVENT_TIMEOUT then
		// Bail and tidy up
		app.writeLog(method.qualifiedName &amp; " Timeout timer fired", LogERROR);
		
		// Try and kill the SSH thread (may not work)
		self.emSSH_TerminateThread(self, 'any', result);
		app.writeLog(method.qualifiedName &amp; " SSH TerminateThread Result: " &amp; result, LogWARN);
		
		// Same as the BGP action, lets raise an alert
		create ediRequest transient;
		on Exception do app.alertExceptionHandler(exception, null, ediRequest.getErrorDesc(), errCode, errTxt, true, true);
		// Raise an exception
		app.raiseCMException2(ERR_SFTP_DIRLIST_TIMEOUT, self.mySFTPEntity.id, self.timeOut.String, null, null);
		on Exception do null;
		
		self.fin();
		delete self;
	endif;
epilog
	delete ediRequest;
end;</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="68cdde2f-3087-45e8-b289-7fd289d24c7b">
        <updating/>
        <source>userNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
//
// 17 Sep 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//
vars
	msg : String;
	str : String;
begin
	msg := '010 eventType='&amp;_eventType.String&amp;' theObject='&amp;_theObject.String&amp;' eventTag='&amp;_eventTag.String&amp;' userInfo='&amp;_userInfo.String&amp;' self='&amp;self.String;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
	if _eventType = SFTP_CMD_EVENT_STDOUT then
		if self.functionType = SFTP_LISTDIR then
			self.directoryListing := self.directoryListing &amp; _userInfo.String;
			if _userInfo.String[1:1] &lt;&gt; 'd' then
				//str := _userInfo.String[56:end];
				self.processDirlist(_userInfo.String);
			endif;
		endif;
	elseif _eventType = SFTP_CMD_EVENT_EOJ then
		msg := '020 set  eventType='&amp;_eventType.String&amp;' theObject='&amp;_theObject.String&amp;' eventTag='&amp;_eventTag.String&amp;' userInfo='&amp;_userInfo.String&amp;' self='&amp;self.String;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
		if self.functionType = SFTP_LISTDIR then
			
			self.endTimer(CMIF_SFTPRequest.EVENT_TIMEOUT);		// TFS 52179 navmd1 30/09/2022
			self.processFiles();
		
			msg := '025 str='&amp;str;
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
			self.fin();
			delete self;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
</Class>
