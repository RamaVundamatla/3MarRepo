    <DbClassMap file="cmenu"/>
    <JadeMethod name="addToUserMenuFromMenu" id="4b346b6b-7ec8-4cc8-952d-22903d988d17">
        <source>addToUserMenuFromMenu(_menuRoot: CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	sharedLock(self);

	self.myMenuItem.addToUserMenuRoot(_menuRoot);
	
	inheritMethod(_menuRoot);


end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllChildHeaders" id="58139ed8-896d-4c7f-af35-71deac2f8620">
        <source>getAllChildHeaders(_subHeaders : CM_MenuUserHdrSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars
	subHdrs 		: CM_MenuUserHdr;
	menuEntity		: CM_MenuEntity;
	menuUserItem	: CM_MenuUserItem;
begin
	foreach menuEntity in self.allChildren discreteLock where menuEntity.isMenuUserItem() do
		menuUserItem := menuEntity.CM_MenuUserItem;
		if menuUserItem.isHeader() then
			subHdrs := menuUserItem.CM_MenuUserHdr;
			_subHeaders.add(subHdrs);
			subHdrs.getAllChildHeaders(_subHeaders);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_subHeaders" type="CM_MenuUserHdrSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getItemsWithNoChildren" id="8703dddb-0a64-456c-96ab-7e009cc3d509">
        <source>getItemsWithNoChildren(_delSet: CM_MenuEntitySet input);
// ---------------------------------------------------------------------------
// Created:     16 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.allChildren.isEmpty then
		_delSet.add(self);
	else
		inheritMethod(_delSet);
	endif;

end;</source>
        <Parameter name="_delSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hasDtlChildren" id="118b8ed3-575d-492c-9865-c1318dfd9a46">
        <source>hasDtlChildren() : Boolean;
// ---------------------------------------------------------------------------
// Created:     02 September 2003	cnwth2
//
// Purpose:     Since we can have headers within headers, this recursive call
//				will tell you if a tree is empty of children that arn't headers.
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity		: CM_MenuEntity;
	hasDtlChild		: Boolean;
begin
	foreach menuEntity in self.allChildren do
		if CM_MenuUserHdr.hasInstance(menuEntity) then
			hasDtlChild := menuEntity.CM_MenuUserHdr.hasDtlChildren;
			if (not hasDtlChild) then
				continue;
			else
				break;
			endif;
		endif;
		//we've hit something thats not a header - must be detail child
		hasDtlChild := true;
		break;
	endforeach;

epilog
	return hasDtlChild;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBGPReportHeader" id="a3100178-cc04-4e35-b297-31d58ea682da">
        <source>isBGPReportHeader() : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 January 2003		cnwth2	
//
// Purpose:     Loops 'up' through parents until the root is found. 
//				If its a CM_MenuRootUserBackgroundReps then true.
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity	: CM_MenuEntity;
	parent		: CM_MenuEntity;
	rootFound	: Boolean;
begin
	menuEntity := self;
	rootFound := false;
	while not rootFound do
		parent := menuEntity.myParent;
		if parent &lt;&gt; null then
			if parent.isKindOf(CM_MenuRootUserBackgroundReps) then
				rootFound := true;
				break;
			else
				menuEntity := parent;
			endif;	
		else
			break;
		endif;
	endwhile;

	return rootFound;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isHeader" id="7411d668-4e79-4c18-a4fb-3d8f41c2491a">
