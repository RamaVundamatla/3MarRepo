    <JadeMethod name="adjustEndX" id="51f7e9c0-c856-493e-afe0-6f2ebd6579ee">
        <updating/>
        <source>adjustEndX(_theTI : CM_TrackedItem; _x1 : Real io) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	return 1;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
