    <DbClassMap file="jssxs_transient"/>
    <JadeMethod name="trxCreateDictionary" id="9ab0deed-b076-4010-b398-3135ecf25a49">
        <updating/>
        <source>trxCreateDictionary(pTheRoot:JSSRoot input;
					pDictionaryName:String;
					pTheNewDictionary:JSSWordDictionary output): String updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		Transaction method to create a Dictionary object.
//
// Parameters:	The object (Parent) that performs the create.
//              The keys and property values of the entity to be created.
//				The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message
//				is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Validate the request.

	if pTheRoot = null then
		return self.agentSetError("No root object selected to create from.");
	endif;

	// Start the Transaction.

	beginTransaction;

	// Perform the operation.

	self.lastError := pTheRoot.createWordDictionary(pDictionaryName, pTheNewDictionary);

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pTheRoot" type="JSSRoot" usage="input"/>
        <Parameter name="pDictionaryName" type="String"/>
        <Parameter name="pTheNewDictionary" type="JSSWordDictionary" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxCreateWord" id="f6bbef41-3e6d-4afe-aae3-a9baf5e052d7">
        <updating/>
        <source>trxCreateWord(	pTheDictionary:JSSWordDictionary io;
				pWordName:String;
				pTheNewWord:JSSWord output): String updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		Transaction method to create a Dictionary Word object.
//
// Parameters:	The object (Parent) that performs the create.
//              The keys and property values of the entity to be created.
//				The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message
//				is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Validate the request.

	if pTheDictionary = null then
		return self.agentSetError("No Dictionary selected to create from.");
	endif;

	// Start the Transaction.

	beginTransaction;

	// Perform the operation.

	self.lastError := pTheDictionary.createWord(pWordName, pTheNewWord);

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pTheDictionary" type="JSSWordDictionary" usage="io"/>
        <Parameter name="pWordName" type="String"/>
        <Parameter name="pTheNewWord" type="JSSWord" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteDictionary" id="8ae086b1-289c-4893-8cd2-71990799db94">
        <updating/>
        <source>trxDeleteDictionary(pTheDictionaryToDelete:JSSWordDictionary io):String updating;
// --------------------------------------------------------------------------------
// Purpose:		Transaction to delete a dictionary.
//
// Parameters:	The object to be deleted. This will be set to null by the delete.
//
// Returns:		Null if the transaction is successful, otherwise an error message
//				is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Validate the request.

	if pTheDictionaryToDelete = null then
		return self.agentSetError("No Dictionary selected to delete  ");
	endif;

	// Start the transaction
	beginTransaction;

	// If the owner object is invalid, then we want our exception handlers to
	// return a message saying so.  After registering the object and a message
	// here, if any subsequent invalid object exceptions occur, the exception
	// handler will then find the registered object and set the "errorMsg"
	// property on the app class.  Therefore, by checking this errorMsg value
	// after performing an operation on the object (app.getLastError), the
	// appropriate error message can be returned for the exception.

	// If a validation method is used, then this step shouldn't be necessary
	// here, since the object will already have been validated.
	self.agentRegisterObjectAndError(pTheDictionaryToDelete, "Invalid Dictionary object.");
	
	// The delete will do nothing if the reference is already null.
	delete pTheDictionaryToDelete;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pTheDictionaryToDelete" type="JSSWordDictionary" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteWord" id="9a92d6b9-8f78-4918-a018-cdad635dd97f">
        <updating/>
        <source>trxDeleteWord(pTheWordToDelete:JSSWord io):String updating;
// --------------------------------------------------------------------------------
// Purpose:		Transaction to delete a Word from a dictionary.
//
// Parameters:	The object to be deleted. This will be set to null by the delete.
//
// Returns:		Null if the transaction is successful, otherwise an error message
//				is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Validate the request.

	if pTheWordToDelete = null then
		return self.agentSetError("No Dictionary Word selected to delete.");
	endif;

	// Start the transaction
	beginTransaction;

	// If the owner object is invalid, then we want our exception handlers to
	// return a message saying so.  After registering the object and a message
	// here, if any subsequent invalid object exceptions occur, the exception
	// handler will then find the registered object and set the "errorMsg"
	// property on the app class.  Therefore, by checking this errorMsg value
	// after performing an operation on the object (app.getLastError), the
	// appropriate error message can be returned for the exception.

	// If a validation method is used, then this step shouldn't be necessary
	// here, since the object will already have been validated.
	self.agentRegisterObjectAndError(pTheWordToDelete, "Invalid Dictionary Word object.");
	
	// The delete will do nothing if the reference is already null.
	delete pTheWordToDelete;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pTheWordToDelete" type="JSSWord" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateDictionary" id="51ec913b-074b-4540-b4d8-d42d699cd7db">
        <updating/>
        <source>trxUpdateDictionary(pTheDictionary:JSSWordDictionary input;
					pRequiredEdition:Integer;
					pTheRoot:JSSRoot;
					pDictionaryName:String): String updating; 
// --------------------------------------------------------------------------------
// Purpose:		Transaction method to update a Dictionary object.
//
// Parameters:	The object being updated, and its key and property values.
//              If pRequiredEdition is greater than zero, the transaction will
//				check that the latest edition of the object is equal to
//				pRequiredEdition. If not, then an 'Object out-of-date' message
//				will be returned.
//
// Returns:		Null if the transaction is successful, otherwise an error message
//				is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Validate the request.

	if pTheDictionary = null then
		return self.agentSetError("No Dictionary selected to update");
	endif;

	// If the owner object is invalid, then we want our exception handlers to
	// return a message saying so.  After registering the object and a message
	// here, if any subsequent invalid object exceptions occur, the exception
	// handler will then find the registered object and set the 'errorMsg'
	// property on the app class.  Therefore, by checking this errorMsg value
	// after performing an operation on the object (app.getLastError), the
	// appropriate error message can be returned for the exception.
	self.agentRegisterObjectAndError(pTheDictionary, "Invalid Dictionary Object.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against pRequiredEdition.
	// This lock will be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) because we're
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pTheDictionary);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pTheDictionary.edition &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out-of-date.
			self.agentSetError("The dictionary is out-of-date - please select it again and retry the update.");
		endif;
	endif;

	// If we're still error free, then perform the operation.
	if self.lastError = null then
		errorMessage	:=	pTheDictionary.updateMe(pDictionaryName, pTheRoot);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pTheDictionary" type="JSSWordDictionary" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pTheRoot" type="JSSRoot"/>
        <Parameter name="pDictionaryName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWord" id="e1a6a049-7b54-4b96-ac80-c8b5682ce12a">
        <updating/>
        <source>trxUpdateWord(	pTheWord:JSSWord io;
				pRequiredEdition:Integer;
				pTheDictionary:JSSWordDictionary;
				pName:String): String updating; 
// --------------------------------------------------------------------------------
// Purpose:		Transaction method to update a Dictionary Word object.
//
// Parameters:	The object being updated, and its key and property values.
//              If pRequiredEdition is greater than zero, the transaction will
//				check that the latest edition of the object is equal to
//				pRequiredEdition. If not, then an 'Object out-of-date' message
//				will be returned.
//
// Returns:		Null if the transaction is successful, otherwise an error message
//				is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Validate the request.

	if pTheWord = null then
		return self.agentSetError("No Dictionary Word selected to update");
	endif;

	// If the owner object is invalid, then we want our exception handlers to
	// return a message saying so.  After registering the object and a message
	// here, if any subsequent invalid object exceptions occur, the exception
	// handler will then find the registered object and set the 'errorMsg'
	// property on the app class.  Therefore, by checking this errorMsg value
	// after performing an operation on the object (app.getLastError), the
	// appropriate error message can be returned for the exception.
	self.agentRegisterObjectAndError(pTheWord, "Invalid Dictionary Word Object.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against pRequiredEdition.
	// This lock will be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) because we're
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pTheWord);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pTheWord.edition &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out-of-date.
			self.agentSetError('Object is out-of-date.');
		endif;
	endif;

	// If we're still error free, then perform the operation.
	if self.lastError = null then
		errorMessage := pTheWord.updateMe(pTheDictionary, pName);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pTheWord" type="JSSWord" usage="io"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pTheDictionary" type="JSSWordDictionary"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
