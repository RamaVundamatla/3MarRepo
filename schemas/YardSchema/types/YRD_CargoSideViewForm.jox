    <JadeMethod name="doQuery" id="c1470d05-861b-4387-a0ca-479d7e4ba68b">
        <updating/>
        <source>doQuery(_viewMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants	
	MinRowsShown  = 6;
vars
	cdc					: YRD_ContainerDrawingController;	//: YRD_CargoBayDrawingController;
	currentLC			: CM_GridController;
	tmpDkbGridArea	:	YRD_ContainerGridAreaDockBar;
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	minRow,maxRow,
	minCol,
	maxCol,diffCols,
	padByCols 			: Integer;
	lc					: CM_LocationsController;
	isEndView : Boolean;
begin
	isEndView := self.optViewEnd.value; // PAR 25634
	
	tmpDkbGridArea	:= self.dkbGridAreasSide;
	tmpDkbGridArea.setHLabelDetails(0, false);
	tmpDkbGridArea.setVLabelDetails(0, false);
	tmpDkbGridArea.isForEndView:=isEndView; // PAR 25634
	tmpDkbGridArea.postCreate();
	tmpDkbGridArea.left :=10;
	tmpDkbGridArea.myDrawingFrame.myDragSelectFrame.visible := true;
	tmpDkbGridArea.borderStyle:=Frame.BorderStyle_Single;
	// when able add labels as virtual to CMUI_GridAreaDockBar and
	// make dkbGridArea.myScrollableFrame protected
	tmpScrollableFrame := tmpDkbGridArea.myScrollableFrame;
	tmpScrollableFrame.labels := ScrollBars_Both;
	
	//create cdc transient;
	cdc:=tmpDkbGridArea.myDrawingController;
	self.setMyCurrentDrawingController(cdc);
	cdc.showDrawingFrame(false);
	
	//get min max rows 
	if self.myTrackedItem.myPrimaryActualLocation.isKindOf(CM_GridController) then
		currentLC:=self.myTrackedItem.myPrimaryActualLocation.CM_GridController;
		foreach lc in self.myTrackedItem.allLocations do
			self.allLCs.addNoDuplicates(lc.CM_GridController,false);
		endforeach;
		
		if isEndView then  // PAR 25634
			minCol:=self.allLCs.first.CM_GridController.column;
			maxCol:=self.allLCs.last.CM_GridController.column;
			minRow:= currentLC.getMyGridArea.allGridRows.first.row;
			maxRow:=currentLC.getMyGridArea.allGridRows.last.row;
		else  // PAR 25634
			minCol:=currentLC.getMyGridArea.allGridColumns.first.column;
			maxCol:=currentLC.getMyGridArea.allGridColumns.last.column;
			minRow:= self.allLCs.first.CM_GridController.row - 1;
			if minRow &lt; currentLC.getMyGridArea.allGridRows.first.row then
				minRow := currentLC.getMyGridArea.allGridRows.first.row;
			endif;
			maxRow:=minRow + 2;
			if maxRow &gt; currentLC.getMyGridArea.allGridRows.last.row then
				maxRow := currentLC.getMyGridArea.allGridRows.last.row;
			endif;
		endif;
		
	/*	diffCols:= (maxRow - minRow) + 1;
		if diffCols &lt; MinRowsShown then
			padByCols:=MinRowsShown-diffCols;
			//pad out cols a bit 
			if currentLC.row - padByCols &lt; currentLC.myGridColumn.allControllersByRow.first.row then
				minRow:=currentLC.myGridColumn.allControllersByRow.first.row;
				maxRow:=minRow+(MinRowsShown-1);
			else
				minRow:=minRow - padByCols;
				maxRow:=maxRow+ padByCols;
			endif;
		endif;*/
	endif;
	
	
	cdc.setScale(CMUI_GridDrawingController.ScaleFactor_3, true, true);
	cdc.setFlip(self.xmlFlipH,self.xmlFlipV); // PAR 25634
	if cdc.isKindOf(YRD_CargoBayDrawingController) then
		self.allLCs.copy(cdc.YRD_CargoBayDrawingController.allLCs);
	endif;
	cdc.useSelectorObjects:=true;
	cdc.allSelectorTIs.add(self.myTrackedItem);
	
	cdc.setRange(minRow, maxRow, minCol,maxCol);
	cdc.init(self.allLCs.first.CM_GridController.myTerminalArea,null);
	cdc.setViewMode(_viewMode);
	cdc.clearAllSelectedObjects();
	self.allOverstowingTIs.copy(cdc.allSelectedObjects);
	cdc.autoMask := false;
	cdc.changeBackColor(self.backColor     );//self.defYardBackColSelected);
	cdc.drawSelf(false);
	if cdc.myHighlighter &lt;&gt; null then // PAR 25634
		cdc.myHighlighter.durationInSeconds:=0;
	endif;
	
	cdc.startHighlighter();
	cdc.notableObjectsClear();
	cdc.notableObjectAdd(self.allLCs.first.CM_GridController.myTerminalArea);
	cdc.doCentreOnSelectedObject();// PAR 25634
	tmpDkbGridArea.myDrawingController.showDrawingFrame(true);
	tmpDkbGridArea.cnEcResizeContents();
	self.refreshNow();
	
epilog

end;</source>
        <Parameter name="_viewMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="f2850563-e98a-4202-b9c6-700a887c25e0">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpController	: YRD_ContainerDrawingController;
	anObj			: Object;
	tmpVM			: Integer;
	wasYALOC		: Boolean;
	hght, wdth		: Real;
begin
	inheritMethod();
	tmpController := self.myDrawingController;
	
	tmpVM := tmpController.viewMode;
	
	if tmpVM &lt;&gt; 0 then
		tmpController.setViewMode(tmpVM);
	else
		tmpController.setViewMode(VIEW_VOYAGE);
	endif;
	//tmpController.YRD_CargoBayDrawingController.drawSelfOverstow(self.frmYard, allLCs, useSelector, wdth, hght);
	
	//self.resizeForm(self.dkbGridAreas.myScrollableFrame,wdth, hght);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="738a9ceb-5840-43a2-a3be-84cb04da7679">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     20 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	roomLeft : Real;
	osTextHeight : Real;
	
begin
	inheritMethod();
	
	self.dkbGridAreasSide.cnEcResizeContents();
	self.dkbGridAreasSide.top := self.frmToolbar.clientHeight + 4;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="072dfe2b-2081-4fba-8ce6-5326e0ff406a">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		// PAR 25634
// ---------------------------------------------------------------------------

vars
	theXML		: String;
	
begin
	theXML := inheritMethod();

	theXML := theXML &amp; global.formatAsXML("EndVIEW",self.optViewEnd.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML("FlipH",self.dkbGridAreasSide.myDrawingController.flipHorizontal.Integer.String);
	theXML := theXML &amp; global.formatAsXML("FlipV",self.dkbGridAreasSide.myDrawingController.flipVertically.Integer.String);
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="af8ac938-d789-4d03-8792-9d139c5ffe31">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//// PAR 25634
// Purpose:		Get the user preferences from the user details for this form
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;

 //	theXMLValue := theXML.cnEcGetTagValueOfName("EndVIEW");

epilog

end;</source>
    </JadeMethod>
