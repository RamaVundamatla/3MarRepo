    <JadeMethod name="doSaveStops" id="90772848-47f6-4fcc-974b-045525eb170d">
        <source>doSaveStops(_cargoId : String;
			_addresses			: CM_StringArray;
			_cmifEventReq : CMIF_EventRequestController input;
			_currentRequestPxy : CM_EventRequestStops) protected;
/*

Date		Who		Reason
01 May 2014	cnwer1	Initial creation PAR
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
*/

vars
	
	pxyRequestStops : CM_EventRequestStops;	
	numberPxyStops,
	i : Integer;
	stop : CM_StopsTable;
	isAdd, isRemove : Boolean;
	additionalInfo 	: String;
	expiryDate 		: Date;
	user : CM_User;
	pxyRow : Integer;
	hasMatchingPxyRow : Boolean;
begin
	if _currentRequestPxy &lt;&gt; null then
		self.tblStops.findObjectInRow(_currentRequestPxy.myStopsTable,pxyRow);
		if pxyRow &gt; 0 then
			hasMatchingPxyRow:=self.tblStops.accessCell(pxyRow,self.addClearCol).text &lt;&gt; null;
		endif;
	endif;
	
	i:=1;
	while i &lt; self.tblStops.rows do
		additionalInfo:=null;
		expiryDate:=null;
		i:=i+1;
		stop:=self.tblStops.accessRow(i).itemObject.CM_StopsTable;
		isAdd:=self.tblStops.accessCell(i,self.addClearCol).text = self.addText;
		isRemove:=self.tblStops.accessCell(i,self.addClearCol).text =self.clearText;
		
		if not isAdd and not isRemove then
			continue;
		endif;
		
		if isRemove then
			additionalInfo:= self.tblStops.accessCell(i,self.additionInfoCol).text;
			expiryDate:=self.tblStops.accessCell(i,self.clearanceExpiryCol).text.asDateJMT;
		endif;
		
		if _currentRequestPxy &lt;&gt; null 
			and (self.myCurrentEventRequest.myStopsTable = stop
			or not hasMatchingPxyRow)
			
			and not _cmifEventReq.allPxyCargoUpdateRequests.includes(_currentRequestPxy) 
			then
			pxyRequestStops:=_currentRequestPxy;
			user:=self.myCurrentEventRequest.myUser;
		else
			
	
			create pxyRequestStops transient;
			user:=app.myPassport.myUser;
		endif;
		
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeStops,
												_addresses,
												self.txtTrxRemarks.text	,
												_cargoId,
												user,
												self.cmbCargoType.listObject.CM_CargoType,
												self.cmbOrganisation.listObject.CM_Organisation,
												self.myTerminal,
												EventRequestPending,
												isRemove,
												self.chkNotify.value,												
												self.txtRef.text,
												self.chkAutoCleanup.value,
												stop,
												additionalInfo,
												expiryDate,
												pxyRequestStops.isEDI,
												null,null,null,
												null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
												null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
												null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,   // 16/01/2017 cnwma1 TFS #2885
												null,  // 16/01/2017 cnwma1 TFS #2885
												null); // 16/01/2017 cnwma1 TFS #2885
												
												
		_cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
		numberPxyStops:=numberPxyStops + 1;
	endwhile;
	
	if numberPxyStops = 0 then
		app.raiseCMException(Input_required_field_stpRequst, ETRow_Stops, null);
	endif;
epilog	
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_cmifEventReq" type="CMIF_EventRequestController" usage="input"/>
        <Parameter name="_currentRequestPxy" type="CM_EventRequestStops"/>
    </JadeMethod>
    <JadeMethod name="doSaveToDo" id="8df37265-55a7-4e92-b6a6-cce8d9a9676f">
        <source>doSaveToDo(_cargoId : String;
			_addresses			: CM_StringArray;
			_cmifEventReq : CMIF_EventRequestController input;
			_currentRequestPxy : CM_EventRequestStops) protected;
/*

Date		Who		Reason
05 May 2014	cnwer1	Initial creation PAR
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message

*/

vars

	pxyRequestStops : CM_EventRequestStops;
	numberPxyToDo,
	i : Integer;
	toDoTask : CM_ToDoTaskDesc;
	isAdd, isRemove : Boolean;
	user : CM_User;
	pxyRow : Integer;
	hasMatchingPxyRow : Boolean;
	toDoRemarks : String;
begin
	if _currentRequestPxy &lt;&gt; null then
		self.tblStops.findObjectInRow(_currentRequestPxy.myStopsTable,pxyRow);
		if pxyRow &gt; 0 then
			hasMatchingPxyRow:=self.tblStops.accessCell(pxyRow,self.addClearCol).text &lt;&gt; null;
		endif;
	endif;
	
	numberPxyToDo:=0;
	i:=1;
	while i &lt; self.tblToDo.rows do
	
		i:=i+1;
		toDoTask:=self.tblToDo.accessRow(i).itemObject.CM_ToDoTaskDesc;
		isAdd:=self.tblToDo.accessCell(i,self.addClearCol).text = self.addText;
		isRemove:=self.tblToDo.accessCell(i,self.addClearCol).text =self.clearText;
		toDoRemarks := self.tblToDo.accessCell(i,toDoRemarksCol).text;	//07 Oct 2015	NDL	Par 37011
		
		if not isAdd and not isRemove then
			continue;
		endif;
		
		if _currentRequestPxy &lt;&gt; null 
			and (self.myCurrentEventRequest.myToDoTaskDesc = toDoTask
			or not hasMatchingPxyRow)
			
			and not _cmifEventReq.allPxyCargoUpdateRequests.includes(_currentRequestPxy) 
			then
			pxyRequestStops:=_currentRequestPxy;
			user:=self.myCurrentEventRequest.myUser;
		else
			
	
			create pxyRequestStops transient;
			user:=app.myPassport.myUser;
		endif;
		
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeToDo,
												_addresses,
												self.txtTrxRemarks.text	,
												_cargoId,
												user,
												self.cmbCargoType.listObject.CM_CargoType,
												self.cmbOrganisation.listObject.CM_Organisation,
												self.myTerminal,
												EventRequestPending,
												isRemove,
												self.chkNotify.value,												
												self.txtRef.text,
												self.chkAutoCleanup.value,
												null,
												null,
												null,
												pxyRequestStops.isEDI,
												toDoTask,null,null,
												null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
												toDoRemarks,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
												null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
												null,  // 16/01/2017 cnwma1 TFS #2885
												null,  // 16/01/2017 cnwma1 TFS #2885
												null); // 16/01/2017 cnwma1 TFS #2885
												
												
		_cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
		numberPxyToDo:=numberPxyToDo+1;
	endwhile;

	if numberPxyToDo = 0 then
		app.raiseCMException(Input_required_field_toDo, ETRow_Stops, null); // cnwdb2	PAR 35364
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_cmifEventReq" type="CMIF_EventRequestController" usage="input"/>
        <Parameter name="_currentRequestPxy" type="CM_EventRequestStops"/>
    </JadeMethod>
    <JadeMethod name="doSaveWeightCertified" id="9f49ce21-2b2a-465a-b211-9786b4d845d9">
        <source>doSaveWeightCertified(	_cargoId : String;
						_addresses			: CM_StringArray;
						_cmifEventReq : CMIF_EventRequestController input;
						_currentRequestPxy : CM_EventRequestStops) protected;
/*

Date		Who		Reason
04/02/2016	cnwer1	Initial creation PAR
05/05/2016	cnwdap1	TFS #1699 Verified Gross Mass changes
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
29/05/2018 	JLGNS1	Bug 38876: Cargo Update Request - Total Weight issues
*/

vars
	pxyRequestStops : CM_EventRequestStops;	
	user : CM_User;
begin

	
	if _currentRequestPxy &lt;&gt; null 	then
		pxyRequestStops:=_currentRequestPxy;
		user:=self.myCurrentEventRequest.myUser;
	else
		

		create pxyRequestStops transient;
		user:=app.myPassport.myUser;
	endif;
		
	pxyRequestStops.setProxyRequestStops(	EventRequestTypeWeight,
											_addresses,
											self.txtTrxRemarks.text	,
											_cargoId,
											user,
											self.cmbCargoType.listObject.CM_CargoType,
											self.cmbOrganisation.listObject.CM_Organisation,
											self.myTerminal,
											EventRequestPending,
											false,
											self.chkNotify.value,												
											self.txtRef.text,
											self.chkAutoCleanup.value,
											null,
											null,
											null,
											pxyRequestStops.isEDI,
											null,null, self.txtRemarks.text.trimBlanks,
											null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
											null,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
											null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
											null,   // 16/01/2017 cnwma1 TFS #2885
											null,   // 16/01/2017 cnwma1 TFS #2885
											null    // 16/01/2017 cnwma1 TFS #2885
											);
										
	//pxyRequestStops.setProxyWeightCertified(self.tblWeight.getConvertedValue(),self.chkIsCertified.value);	// TFS #1699
	pxyRequestStops.setProxyWeightCertified(	self.tblWeight.getConvertedValue(),								// TFS #1699
												self.chkIsCertified.value,										// TFS #1699
												self.txtAuthName.text.trimBlanks.toUpper,				//Bug 38876				
												self.txtCertName.text.trimBlanks.toUpper	);			//Bug 38876
											//	self.cmbAuthName.text.trimBlanks.toUpper,						// TFS #1699
											//	self.cmbCertName.text.trimBlanks.toUpper	);					// TFS #1699
											
	_cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_cmifEventReq" type="CMIF_EventRequestController" usage="input"/>
        <Parameter name="_currentRequestPxy" type="CM_EventRequestStops"/>
    </JadeMethod>
    <JadeMethod name="doSelectRecipients" id="45a75d22-a7b9-48c4-b057-e303ebbaa59c">
        <source>doSelectRecipients();
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
//30 Aug 2017  cnwma1 TFS #5845 POL - Error in testing 8.5.1.090 Cargo Notification request #4643 
//--------------------------------------------------
vars
	origAddresses,
	str : String;
	selected : CM_EmailEntityByTypeNameDict;
	emailController	: CMIF_EmailTemplateController;
	form			: CMUI_RecipientSelector;
	toA,
	ccA,
	bccA	: String;
	
begin
	
	create form transient;
	create emailController transient;
	
	self.setNavigatorHeading(form.caption);
	form.myEmailController := emailController;
	form.setMyTerminal(self.myTerminal); // 30.08.2017 cnwma1 TFS #5845
	form.mode := CMUI_RecipientSelector.Mode_To;
	form.centreWindow;
	form.showModal;

	origAddresses := self.txtRecipients.text;
	
	if form.modalResult = IDOK then
		toA 	:= emailController.allToAddresses.getAddresses();
		ccA 	:= emailController.allCcAddresses.getAddresses();
		bccA	:= emailController.allBccAddresses.getAddresses();
		
		if toA &lt;&gt; null then
			str := toA &amp; ';';
		endif;
		
		if ccA &lt;&gt; null then
			str := str &amp; ccA &amp; ';';
		endif;
		
		if bccA &lt;&gt; null then
			str := str &amp; bccA &amp; ';';
		endif;
	endif;

	if str.length &gt; 1 then
		if origAddresses &lt;&gt; null then
			if app.msgBox(app.getErrorString(ConcatenateEmailAddresses), 'Email Recipients', MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
				self.txtRecipients.text := origAddresses &amp; '; ' &amp; str;
			endif;
		else
			self.txtRecipients.text := str;
		endif;
	endif;	
epilog
	delete selected;
	delete emailController;
end;</source>
    </JadeMethod>
    <JadeMethod name="getEmailAddresses" id="00271b48-dddf-4a66-9bc9-13f3afcffa19">
        <source>getEmailAddresses( _addressArray : CM_StringArray input );
//--------------------------------------------------
// Created:	20 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	delimiters		: String;
	address			: String;
	addresses		: String;
	cnStringArray	: CnStringArray;

begin
	// cnwrl1 10/03/2010 PAR 22853 - start of coding

	// The potential delimiters are semicolons and comma and strip all spaces out of the addresses.
	create cnStringArray transient;
	delimiters	:= SemiColon &amp; CNEC_COMMA;
	addresses	:= self.txtRecipients.text;
	addresses.cnUnbust( delimiters, cnStringArray, true );
	foreach address in cnStringArray where address &lt;&gt; null do
		address.cnEcRemoveCrLf;
		_addressArray.add( address );
	endforeach;
	
epilog
	delete cnStringArray;
	
end;
</source>
        <Parameter name="_addressArray" type="CM_StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRunTimes" id="898547e1-54f0-436b-b56f-ca2be4d37d3f">
        <source>getRunTimes(_timeArray : TimeArray input);
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	lstCnt,
	cnt : Integer;
	str : String;
	localTime: TimeStamp;
begin

	//List box is sorted ascending
	//time will be added in the correct order
	lstCnt := self.lstTime.listCount();
	while cnt &lt; lstCnt do
		cnt := cnt + 1;
		str := self.lstTime.itemText[cnt];
		localTime.setTime(str.Time);
		_timeArray.add(self.localToSystemTime(localTime).Time);	// 17/6/16 cnwmp6 TFS 488 - Multi timezone support
	endwhile;
	
end;</source>
        <Parameter name="_timeArray" type="TimeArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadEventRequest" id="a585da74-76ee-405b-adc4-67cbdd39fe56">
        <updating/>
        <source>loadEventRequest() protected, updating;
/*

Date		Who		Reason
02 May 2014	cnwer1	Initial creation PAR
06 May 2016	cnwdap1	TFS #1699 verified Gross Mass changes
29/05/2018 	JLGNS1	Bug 38876: Cargo Update Request - Total Weight issues
13/10/2022  navsks20 Bug 55098: PNL - Cargo Update Request - Notify check box/Email Recipients
*/

vars
	email : CM_EventRequestEmail;
	user	: CM_User;
	time : Time;
	systemTime: TimeStamp;
//	weighAuth : CM_WeighAuthority;	//23 Aug 2017	NDL	TFS 5803	//Bug 38876
begin
	user:=app.getMyUser();
	if self.myCurrentEventRequest = null then
		self.cmbUpdateType.setIndexForItemData(EventRequestTypeStops);
		self.cmbOrganisation.setObject( user.myOrganisation);
		self.txtRecipients.text := user.getEmailAddress();	
		
		email := user.allEventRequestEmail[EventRequestTypeStops];
	else
		self.cmbUpdateType.setIndexForItemData(self.myCurrentEventRequest.type);
		
		self.txtCargoIDs.text:= self.myCurrentEventRequest.cargoId;
		self.txtTrxRemarks.text:=self.myCurrentEventRequest.remarks;
		self.txtRef.text:=self.myCurrentEventRequest.reference;
		if self.myCurrentEventRequest.myOrganisation &lt;&gt; null then
			self.cmbOrganisation.setObject(self.myCurrentEventRequest.myOrganisation);
		endif;
		self.txtRecipients.text := self.myCurrentEventRequest.getEmailAddresses(null);
		self.chkAutoCleanup.value := self.myCurrentEventRequest.autoCleanup;
		//self.chkNotify.value := self.txtRecipients.text &lt;&gt; null;	//13.10.2022 navsks20 TFS 55098
		self.chkNotify.value := self.myCurrentEventRequest.isNotify; //13.10.2022 navsks20 TFS 55098
		email := self.myCurrentEventRequest.myEventRequestEmail;
		self.loadStops();
		self.loadToDoTasks();
		self.cmbGrade.listObject:=self.myCurrentEventRequest.myGrade;
		self.txtRemarks.text:=self.myCurrentEventRequest.cargoRemarks;
		self.chkIsCertified.value:=self.myCurrentEventRequest.isWeightCertified;
		self.tblWeight.setValueDefault(self.myCurrentEventRequest.totalWeight.asStringJMT);
	//	self.txtWeghtName.text := self.myCurrentEventRequest.weightCertifiedName;				// TFS #1699
		
		
	endif;
	self.doChangeUpdateType();
	
	//23 Aug 2017	NDL	TFS 5803
	/*	Bug 38876
	weighAuth := null;
	if self.myCurrentEventRequest &lt;&gt; null
	and self.myCurrentEventRequest.weightCertifiedName &lt;&gt; null
	and self.myCurrentEventRequest.reference &lt;&gt; null then
		weighAuth := app.myRoot.allWeighAuthorities.getAtKey(self.myCurrentEventRequest.reference,self.myCurrentEventRequest.weightCertifiedName);
	endif;
	if weighAuth = null then
		self.cmbCertName.listIndex := -1;
		self.cmbCertName.lostFocus( self.cmbCertName );
	else
		self.cmbCertName.listIndex := self.cmbCertName.findStringExact( 1, weighAuth.certifiedName );
		self.myAssistant.listWeighAuthorityPersons( self.cmbAuthName, self.myTerminal, weighAuth.certifiedName );
		self.cmbAuthName.listIndex := self.cmbAuthName.findStringExact( 1, weighAuth.authorisedName );
		
	endif;
	*/
	if self.myCurrentEventRequest &lt;&gt; null 	then									//Bug 38876
		self.txtCertName.text :=	self.myCurrentEventRequest.reference;			//Bug 38876
		self.txtAuthName.text := 	self.myCurrentEventRequest.weightCertifiedName;	//Bug 38876
	endif;																			//Bug 38876
		
	if email &lt;&gt; null then
		foreach time in email.allRunTimes do
			systemTime.setTime(time);
			self.lstTime.addItem(self.systemToLocalTime(systemTime).Time.currentLocaleFormatJMT);	// 17/6/16 cnwmp6 TFS 488 - Multi timezone support
		endforeach;		
	endif;
		
	if self.myCurrentEventRequest &lt;&gt; null then
		self.cmbCargoType.listObject:=self.myCurrentEventRequest.myCargoType;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadStops" id="5534a6ab-81e7-43ff-8510-0690f2b02e9e">
        <source>loadStops() protected;
/*

Date		Who		Reason
02 May 2014	cnwer1	Initial creation PAR
//20/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
*/

vars
	stopRequest : CM_EventRequestStops;
	foundRow : Integer;
begin

	stopRequest:=self.myCurrentEventRequest;
	if stopRequest.myStopsTable = null then
		return;
	endif;
	self.tblStops.findObjectInRow(stopRequest.myStopsTable,foundRow);
	if foundRow &gt; 1 then
		self.tblStops.accessCell(foundRow,self.additionInfoCol).text:=stopRequest.additionalRequiredInfo;
		if stopRequest.isClear then
			self.tblStops.accessCell(foundRow,self.addClearCol).comboIndex:=3;
			self.tblStops.accessCell(foundRow,self.addClearCol).text := clearText;	//ChangeRequest 46721
			
			self.tblStops.accessCell(foundRow,self.clearanceExpiryCol).text:=stopRequest.clearanceExpiryDate.asStringJMT;		
			self.tblStops.accessCell(foundRow,self.clearanceExpiryCol).cellControl:=self.txtExpiryDate;	
		else
			self.tblStops.accessCell(foundRow,self.addClearCol).comboIndex:=2;
			self.tblStops.accessCell(foundRow,self.addClearCol).text := addText;	//ChangeRequest 46721
		endif;
	endif;
	
	
	self.tblStops.sortColumn[1]:=self.addClearCol;
	self.tblStops.sortAsc[1]:=false;
	self.tblStops.resort;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadToDoTasks" id="a5b3c5e1-1e3e-4267-92d2-9015839fdd26">
        <source>loadToDoTasks() protected;
/*

Date		Who		Reason
05 May 2014	cnwer1	Initial creation PAR

*/

vars
	stopRequest : CM_EventRequestStops;
	foundRow : Integer;
begin

	stopRequest:=self.myCurrentEventRequest;
	if stopRequest.myToDoTaskDesc = null then
		return;
	endif;
	self.tblToDo.findObjectInRow(stopRequest.myToDoTaskDesc,foundRow);
	if foundRow &gt; 1 then
		if stopRequest.isClear then
			self.tblToDo.accessCell(foundRow,self.addClearCol).comboIndex:=3;
		else
			self.tblToDo.accessCell(foundRow,self.addClearCol).comboIndex:=2;
			self.tblToDo.accessCell(foundRow,self.toDoRemarksCol).text:=stopRequest.toDoRemarks;	//07 Oct 2915	NDL	Par 37011
		endif;
	endif;
	self.tblToDo.sortColumn[1]:=self.addClearCol;
	self.tblToDo.sortAsc[1]:=false;
	self.tblToDo.resort;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="6a916eba-f834-455b-8a9f-b8705fc30b85">
        <source>setEnableObjects();
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
//--------------------------------------------------
// 14/12/2010 	cnwcs5	ccms mes 1112 / par 24464
vars
	str : String;
	enabledFields : Boolean;
begin
	enabledFields:=self.myCurrentEventRequest = null;

		// 'Enter the cargo ids and select the requests you would like actioned. '
	//	str := app.getErrorString( LblEventrequest_NewRequest );
	
	self.txtCargoIDs.enabled := enabledFields;
	self.tblStops.userInputEnabled := enabledFields;
	self.tblToDo.userInputEnabled:=enabledFields;
	self.cmbGrade.enabled:=enabledFields;
	self.txtRemarks.enabled:=enabledFields;
	self.cmbUpdateType.enabled:=enabledFields;
	self.cmbCargoType.enabled := enabledFields;
	self.cmbOrganisation.enabled := enabledFields;
	
	
	if self.myCurrentEventRequest &lt;&gt; null then
		if self.myCurrentEventRequest.status = EventRequestEmailed then
			// 'This request cannot be updated because it has already been processed and the notification has been sent.'
			str := app.getErrorString( LblEventRequest_Emailed );
		elseif self.myCurrentEventRequest.status = EventRequestActioned or
			self.myCurrentEventRequest.status = EventRequestCargoDeleted then		// 14/12/2010 	cnwcs5	ccms mes 1112 / par 24464
			// 'This request has already been actioned. Only the email recipients and remarks can be updated.'
			str := app.getErrorString( LblEventRequest_Actioned );
		elseif self.myCurrentEventRequest.status = EventRequestMatched then
			// what title string ends up for these ones - if any exist?
			self.cmbOrganisation.enabled := true;
		
		else
			self.txtCargoIDs.enabled := true;
			self.tblStops.userInputEnabled := true;
			self.tblToDo.userInputEnabled:=true;
			self.cmbGrade.enabled:=true;
			self.cmbCargoType.enabled := true;
			self.cmbOrganisation.enabled := true;
		
		
			str :=  app.getErrorString( LblEventrequest_Enabled );
		endif;
	endif;

	//self.lblEventRequest.caption := str;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5b90e593-f470-49f2-8634-90f989fcd023">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
01 May 2014	cnwer1	Initial creation PAR

*/

vars
		cargoType : CM_CargoType;
begin
	if self.myCurrentEventRequest &lt;&gt; null then
		cargoType:= self.myCurrentEventRequest.myCargoType.CM_CargoType;
	else
		cargoType:=app.myPassport.getDefaultCargoType();
	endif;
	
	self.myAssistant.comboBoxCargoUpdateRequestType(self.cmbUpdateType);
	
	
	addClearCol :=2;
	toDoRemarksCol := 3;
	addText:=app.getErrorString(Add_Caption);
	clearText:=app.getErrorString(Clear);
	self.setupStops();
	self.setupToDo();
	self.myAssistant.comboBoxMTGrade(self.cmbGrade,null);
	
	self.timeMask.insertMode := false;	
	self.timeMask.setTime(self.systemToLocalTime(app.actualTimeServer).time());	// 18/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	self.tblWeight.setup(Type_Weight, self.backColor);
	self.tblWeight.tabKey := J_key_Tab;
	
	self.loadEventRequest();
	self.setEnableObjects();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupStops" id="7df47861-2ae7-40c9-8a2f-4c1d89399f63">
        <updating/>
        <source>setupStops() protected, updating;
/*

Date		Who		Reason
01 May 2014	cnwer1	Initial creation PAR
// tfs 2708 cnwns1 26/09/16 PAR38242 POL - query on permissions
*/

vars
	stopsTables : CM_StopsTableByIdDict; 
	stopTable : CM_StopsTable;
	
begin
//	stopsTables := app.getMyUser.getStopsToViewForTerminal(self.myTerminal);TFS 2708
	stopsTables := app.getMyUser.getStopsToMaintForTerminal(self.myTerminal);
	
	
	
	self.tblStops.columns:=4;
	self.tblStops.fixedRows:=1;
	self.tblStops.rows:=1;
	self.tblStops.fixedColumns:=0;
	self.tblStops.accessCell(1,1).text:=app.getErrorString(Stop) &amp; Tab &amp; addText &amp; "/" &amp;  clearText &amp; Tab &amp; app.getErrorString(Additional_info) &amp; Tab &amp; app.getErrorString(Clearance_Expiry_Date);
	
	
	additionInfoCol:=3;
	clearanceExpiryCol:=4;
	self.tblStops.accessColumn(self.additionInfoCol).inputType:=Table.InputType_TextBox;
	self.tblStops.accessColumn(addClearCol).inputType:=Table.InputType_ComboBox;
	self.tblStops.accessColumn(addClearCol).comboList:="" &amp; Tab &amp; addText &amp; Tab &amp;  clearText;
	
	
	
	foreach stopTable in stopsTables where stopTable.isAvailable do
		self.tblStops.addItemObject(stopTable,stopTable.code &amp; " - " &amp; stopTable.heading );
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupToDo" id="9d237cd0-9350-400f-9005-a7d37c7ea713">
        <source>setupToDo() protected;
/*

Date		Who		Reason
05 May 2014	cnwer1	Initial creation PAR

*/

vars
	toDoTasks : CM_ToDoTaskDescByCode; 
	toDoTask  : CM_ToDoTaskDesc;
begin
	
	create toDoTasks transient;
	
	app.getMyUser.getToDoTasksAddRemoveForTerm(self.myTerminal,toDoTasks);
	
	self.tblToDo.columns			  := 3;
	self.tblToDo.sortColumn[1]		  := 1; 		// ### TFS  #56634[54259] 22NOV2022 NAVAB1
	self.tblToDo.fixedRows			  := 1;
	self.tblToDo.rows				  := 1;
	self.tblToDo.fixedColumns		  := 0 ;
	self.tblToDo.accessCell(1,1).text := app.getErrorString(CM_To_Do_Task) &amp; Tab &amp; addText &amp; "/" &amp;  clearText &amp; Tab &amp; app.getErrorString(Remarks);
	self.tblToDo.accessColumn(addClearCol).inputType	:=	Table.InputType_ComboBox;
	self.tblToDo.accessColumn(addClearCol).comboList	:=	"" &amp; Tab &amp; addText &amp; Tab &amp;  clearText;
	self.tblToDo.accessColumn(toDoRemarksCol).inputType :=	Table.InputType_TextBox;
	
	foreach toDoTask in toDoTasks  where toDoTask.type = TODO_TYPE_GROUP_TI do 	// ### TFS  #56634[54259] 22NOV2022 NAVAB1
		self.tblToDo.addItemObject(toDoTask, toDoTask.description );
	endforeach;

epilog
	delete toDoTasks;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblStops_lostFocus" id="256e31aa-6680-4dcf-bef1-7a166f9728af">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStops_lostFocus(table: Table input) updating;
/*

Date		Who		Reason
02 May 2014	cnwer1	Initial creation PAR

*/

vars
		stop : CM_StopsTable;
begin
		
	if table.column = self.addClearCol and table.accessCell(table.row, self.addClearCol).text = self.clearText then
		if table.accessCell(table.row, self.addClearCol).text = self.clearText then
			stop:= table.accessRow(table.row).itemObject.CM_StopsTable;
		//	if stop.requiresInfo then
			//	table.accessCell(table.row,self.additionInfoCol).inputType:=Table.InputType_TextBox;
		//	endif;
		
			table.accessCell(table.row,self.clearanceExpiryCol).cellControl:=self.txtExpiryDate;	
		else
		//	table.accessCell(table.row,self.additionInfoCol).inputType:=Table.InputType_None;
			table.accessCell(table.row,self.clearanceExpiryCol).cellControl:=null;
			table.accessCell(table.row,self.clearanceExpiryCol).inputType:=Table.InputType_None;	
		endif;
	endif;
	
		
	if table.column = self.clearanceExpiryCol and table.accessCell(table.row, self.addClearCol).text = self.clearText then
		table.accessCell(table.row,table.column ).text:=table.accessCell(table.row,table.column ).cellControl.CMUI_DateMask.getDate.asStringJMT;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblStops_queryRowColChg" id="dca02445-d935-48c8-b448-047403139820">
        <controlMethod name="Table::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStops_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Date		Who		Reason
02 May 2014	cnwer1	Initial creation PAR

*/

vars
	stop : CM_StopsTable;
begin
	
	if table.column = self.addClearCol then
		if table.accessCell(table.row,self.addClearCol).text = self.clearText then
			stop:= table.accessRow(table.row).itemObject.CM_StopsTable;
			//if stop.requiresInfo then
			//	table.accessCell(table.row,self.additionInfoCol).inputType:=Table.InputType_TextBox;
			//endif;
		
			table.accessCell(table.row,self.clearanceExpiryCol).cellControl:=self.txtExpiryDate;	
		else
			//table.accessCell(table.row,self.additionInfoCol).inputType:=Table.InputType_None;
			table.accessCell(table.row,self.clearanceExpiryCol).cellControl:=null;
			table.accessCell(table.row,self.clearanceExpiryCol).inputType:=Table.InputType_None;	
		endif;
	endif;
	
	if table.column = self.clearanceExpiryCol and table.accessCell(table.row,self.addClearCol).text = self.clearText then
		
		table.accessCell(table.row,table.column ).text:=table.accessCell(table.row,table.column ).cellControl.CMUI_DateMask.getDate.asStringJMT;
	endif;
	
	
	if newCol = self.clearanceExpiryCol and table.accessCell(newRow,self.addClearCol).text = self.clearText then
		self.txtExpiryDate.text:=table.accessCell(newRow,newCol ).text;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b85e3d2c-ef18-4a46-8e5e-8b2b93a19f83">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 August 2017 09:59:33.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019635, locale);
	btnCancel.translateCaption(Xlat_0019636, locale);
	btnRecipients.translateBubbleHelp(Xlat_0019637, locale);
	btnRecipients.translateCaption(Xlat_0019638, locale);
	btnSave.translateCaption(Xlat_0019639, locale);
	btnSaveNext.translateCaption(Xlat_0019640, locale);
	btnTimeAdd.translateCaption(Xlat_0019641, locale);
	btnTimeRemove.translateCaption(Xlat_0019642, locale);
	lblAutoCleanup.translateCaption(Xlat_0019643, locale);
	lblCargoIDs.translateCaption(Xlat_0019644, locale);
	lblCargoRemarks.translateCaption(Xlat_0019645, locale);
	lblCargoType.translateCaption(Xlat_0019646, locale);
	lblCertName.translateCaption(Xlat_0021231, locale);
	lblGrade.translateCaption(Xlat_0019647, locale);
	lblIsCertified.translateCaption(Xlat_0021163, locale);
	lblNotify.translateCaption(Xlat_0019648, locale);
	lblOrg.translateCaption(Xlat_0019649, locale);
	lblRecipients.translateCaption(Xlat_0019650, locale);
	lblRef.translateCaption(Xlat_0019651, locale);
	lblReference.translateCaption(Xlat_0022058, locale);
	lblStops.translateCaption(Xlat_0019652, locale);
	lblTimes.translateCaption(Xlat_0019653, locale);
	lblToDo.translateCaption(Xlat_0019654, locale);
	lblTrxRemarks.translateCaption(Xlat_0019655, locale);
	lblUpdateType.translateCaption(Xlat_0019656, locale);
	lblWeight.translateCaption(Xlat_0021164, locale);
	txtExpiryDate.translateBubbleHelp(Xlat_0019657, locale);
	txtRecipients.translateBubbleHelp(Xlat_0019658, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateAdditionalRequiredInfo" id="f111af94-90e4-4c64-b511-e6ccb54300b7">
        <updating/>
        <source>validateAdditionalRequiredInfo() : Boolean updating, protected;

/*
Purpose:	This method will validate the additonal required information field for the following:
			1) Can only be applied to 1 stop at a time (since it needs to populate different fields on the TI).
			2) Only applies if the stop selected has the requiresInfo set - which is only required on clearing a stop.
			
Date				Who		Reason
18 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
*/
	
vars
	tempStr			: String;
	object			: Object;
	stopsTable		: CM_StopsTable;
	
begin
	
	return true;
	/*// if no stops have been selected ignore here as this will be validated later.
	if self.lstTableRequest.allSelectedObjects.isEmpty then
		return true;
	endif;

	// if the add function has been selected then the additional required info must be null.
	if self.optAdd.value then
		if self.txtReqInfo.text.trimBlanks = null then
			// should always be the case because of the doOptClearChange method!
			return true;
		endif;
		tempStr	:= app.getString( ReqInfo_Not_Needed_To_Add_Stop );
		app.msgBox(	tempStr, app.getErrorString( Error ), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return false;
	endif;
	
	// if only one stop selected for clearing then check that its requiresInfo
	if self.lstTableRequest.allSelectedObjects.size = 1 then
		stopsTable	:= self.lstTableRequest.allSelectedObjects.first.CM_StopsTable;
		if stopsTable.requiresInfo then
			if self.txtReqInfo.text.trimBlanks &lt;&gt; null then
				return true;
			endif;
			// then additonal required information must be supplied
			tempStr	:= app.getString( Selected_Stop_MustHave_ReqInfo, stopsTable.heading );
			app.msgBox(	tempStr, app.getErrorString( Error ), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			return false;
		else
			if self.txtReqInfo.text.trimBlanks = null then
				return true;
			endif;
			// additonal info should not be supplied
			tempStr	:= app.getString( Selected_Stop_NotHave_ReqInfo, stopsTable.heading );
			app.msgBox(	tempStr, app.getErrorString( Error ), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			return false;
		endif;
		return true;			// should never get to here!
	endif;
	
	// NOTE: The validation done on CM_EventRequestStops is ONLY done for the first stopTable selected
	// because of this if multiple stops have been selected then none of them can required addition information
	foreach object in self.lstTableRequest.allSelectedObjects do : object_loop
		stopsTable	:= object.CM_StopsTable;
		if not stopsTable.requiresInfo then
			continue object_loop;
		endif;
		tempStr	:= app.getString( Cannot_Apply_To_MultipleStops );
		app.msgBox(	tempStr, app.getErrorString( Error ), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return false;
	endforeach object_loop;
	
	return true;				// if get to here then is OK
	*/
epilog
	
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateEmailAddresses" id="b2d57b6f-cedc-4055-b6a7-5a6881026856">
        <source>validateEmailAddresses() : Boolean protected;
//17 September 2010	cnwml2
//+cnwml2 PAR25743

vars
	delimiters		: String;
	address			: String;
	addresses		: String;
	cnStringArray	: CnStringArray;
begin
	create cnStringArray transient;
	delimiters	:= SemiColon &amp; CNEC_COMMA;
	addresses	:= self.txtRecipients.text;
	addresses.cnUnbust( delimiters, cnStringArray, true );
	foreach address in cnStringArray where address &lt;&gt; null do
		address.cnEcRemoveCrLf;
		if address.length &gt; 50 then		//50 is the limit for a CM_StringArray class
			app.msgBox(	app.getErrorString1(EmailStringTooLong, address) &amp; CrLf &amp; app.getString(AddressSeperator), app.getErrorString( Error ), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			return false;
		endif;
	endforeach;
	
	return true;
epilog
	delete cnStringArray;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
