    <JadeMethod name="b_Cancel_click" id="d39dd3dd-9a72-4504-9a52-2fdfb187d364">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_Cancel_click(btn: Button input) updating;

vars

begin
	terminate;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_Clear_click" id="9abf4980-f86d-4569-82e7-9357e1b2731d">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_Clear_click(btn: Button input) updating;

vars

begin

	app.mousePointer := Window.MousePointer_HourGlass;
	clearAll;
epilog

	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_DeleteSystem_click" id="ebfb6d6e-bfa7-463e-9dd7-60a01d598b6d">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_DeleteSystem_click(btn: Button input) updating;

vars

	environment : Environments;

begin
	environment := lbx_System.itemObject [lbx_System.listIndex].Environments;
	if environment &lt;&gt; null then
		v_tcpHandler.delClassAndMethodDescriptions(environment);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_Extract_click" id="a8c0b5fe-152f-4fa8-bf6e-91075a9063a0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_Extract_click(btn: Button input) updating;

vars
	filename : String;
	result   : Integer;
begin
	result := app.msgBox('About to unload all Class and Method names and numbers' &amp; CrLf &amp;
	                     "'Yes' - to continue" , 'Class and Method extract', MsgBox_Yes_No);
	                     
	if result &lt;&gt; MsgBox_Return_Yes then 
		return;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
	filename := app.getJadeInstallDir &amp; '\jomstats.txt';
	currentSchema._dumpClassAndMethodNumbers(filename, true, true, true);
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_Listen_click" id="ba19e1ed-f65e-4d3c-80ea-9eda3e514ff8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_Listen_click(btn: Button input) updating;

vars
	time : Time;
begin
	if b_Listen.caption  = 'Listening' then
		b_Listen.caption  := 'Listen';
		v_tcpHandler.shutdownListen;
		sl_Status.caption := time.String &amp; ' ' &amp; v_tcpHandler.message;
		endLoad;
	else
		b_Listen.caption  := 'Listening';
		clearAll;
		v_tcpHandler.setupListen(tbx_Host.text.trimBlanks, tbx_Port.text.trimBlanks.Integer);
		sl_Status.caption := time.String &amp; ' ' &amp; v_tcpHandler.message;
		beginLoad;
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_LoadSystem_click" id="ae9c34c5-5fdc-4e84-bd3f-4fa1bf1b7464">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_LoadSystem_click(btn: Button input) updating;

vars

begin
	v_tcpHandler.loadClassAndMethodDescriptions;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_Monitor_click" id="276b3b66-7f37-4f2d-985a-df92ce28c879">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_Monitor_click(btn: Button input) updating;

vars

begin
	tbx_CacheCon.text := '';
	getMonitorStatistics;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_Print_click" id="d1a6fb3e-5654-4d20-ac8e-791591f95912">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_Print_click(btn: Button input) updating;
constants

vars

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	printOutput;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_Refresh_click" id="0d954bb2-83e7-4c15-b253-74595216ce23">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_Refresh_click(btn: Button input) updating;
constants

vars
	time : Time;
begin

	refreshTables(true);
	if sht_Control.isMySheetVisible then
		sht_Statistics.showMySheet;
	endif;
	l_freeInc.caption       := v_tcpHandler.incrementBeginNoteCount.String;
	l_free.caption          := v_tcpHandler.beginNoteCount.String;
	l_serverInc.caption     := v_tcpHandler.incrementServerExecutionCount.String;
	l_serverEx.caption      := v_tcpHandler.serverExecutionCount.String;
	l_TransInc.caption      := v_tcpHandler.incrementTransactionCount.String;
	l_Trans.caption         := v_tcpHandler.transactionCount.String;
	l_CauseEventInc.caption := v_tcpHandler.incrementCauseEventCount.String;
	l_CauseEvent.caption    := v_tcpHandler.causeEventCount.String;
	v_tcpHandler.clearIncrementCounts;

	sl_Status.caption := time.String &amp; ' Total messages received ' &amp; 
	                     v_tcpHandler.messageCount.String &amp; 
	                     '  time - ' &amp; (v_tcpHandler.lastTime - v_tcpHandler.startTime).String &amp; 
	                     ' , interval CPU - ' &amp; ((v_tcpHandler.lastCPUTime - v_tcpHandler.startCPUTime) / 1000).userNumberFormat($MilliSeconds) &amp;
	                     ' , total CPU for Node - '    &amp; (v_tcpHandler.lastCPUTime / 1000).userNumberFormat($MilliSeconds);
	v_tcpHandler.startCPUTime := v_tcpHandler.lastCPUTime;
epilog

end;</source>
