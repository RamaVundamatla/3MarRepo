    <JadeMethod name="fillCapacityandOtherDetails" id="84b8af19-0224-436a-877c-abc05766e4fb">
        <updating/>
        <source>fillCapacityandOtherDetails(blockController : CM_BlockController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2022	navra1	Initial creation - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022

*/

vars
	stackStatus : 	CMIF_XpsStackStatus;
	ti			: 	CM_TrackedItem;
	term		:	CM_Terminal;
	mt			:	CM_MeasurementType;

begin
	if self.isKindOf(CMIF_XpsStackStatus) then
		stackStatus := self.CMIF_XpsStackStatus;
		if blockController &lt;&gt; null then
			ti := blockController .allTrackedItems.first;
		endif;
		
		if ti = null then		//this should not happen
			return;
		endif;
		
		term := ti.myTerminal;
		stackStatus.derived_capacity := blockController.getCurrentCapacity();
		
		if ti.isBulkByWeight() then			
			if term &lt;&gt; null then
				mt := term.getDefaultMeasurementForType(Type_Weight);
				if mt &lt;&gt; null then
					stackStatus.measurement_unit_type := mt.measurementType; 
					stackStatus.derived_measure_unit := mt.shortName;
				else
					stackStatus.measurement_unit_type := "Weight"; 
				
				endif;
			endif;
		
		elseif ti.isBulkByVolume() then			
			if term &lt;&gt; null then
				mt := term.getDefaultMeasurementForType(Type_Volume);
				if mt &lt;&gt; null then
					stackStatus.measurement_unit_type := mt.measurementType; 
					stackStatus.derived_measure_unit := mt.shortName;
				else
					stackStatus.measurement_unit_type := "Volume"; 
				endif;
			endif;		
		else  // containers, vehicles and break bulk
			stackStatus.measurement_unit_type := "Quantity"; 
			stackStatus.derived_measure_unit := "QTY"; 
		endif;
		
	
	endif;

epilog

end;</source>
        <Parameter name="blockController" type="CM_BlockController"/>
    </JadeMethod>
    <JadeMethod name="generateCpxGKey" id="28ea39bf-75d6-4d72-b5b2-70c98b554f50">
        <source>generateCpxGKey(): Integer64;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/

vars
	licenseInt      : Integer64;
	key        		: String;
begin
	
	if app.myRoot.licenseName &lt;&gt; null then
		licenseInt   := app.myRoot.licenseName.getStringValueAsInteger64;
	endif;
	
	key := app.myRoot.systemMode.String &amp; licenseInt.String;
	
	return key.Integer64;
epilog

end;

</source>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="generateFullGKey" id="bfb4d180-ecbd-4e8e-aad3-73ffcd716367">
        <source>generateFullGKey(_any : Any; _prefix : String): Integer64;
/*
Purpose:			

Date		Who		Reason
08DEC2021	NAVAB1	TFS 51853

13JAN2022 - Integer64 can handle upto 19 digits, if the instance is in the 10s of millions then we end up with 20 digits. So have removed including the license name which can be 4-5 digits.
			This will not be a problem since the consumer automatically adds the complex id to the gkey to produce a pkey that is unique. 
			The complex id sent by MTN is the root companyCode which is unique across all systems
*/


vars
	oidFormatted,
	termOid,
	key, licenseStr        		: String;
	licenseInt 		: Integer64;
	termIdStr,
	objIdStr 	    : String;
begin
	
	if _any = null then
		return 0;
	endif;
 // ### TFS 51855 13JAN2022 NAVAB1	if app.myRoot.licenseName &lt;&gt; null then
 // ### TFS 51855 13JAN2022 NAVAB1		licenseStr := _prefix &amp; app.myRoot.licenseName;  // ### TFS 51855 14DEC2021 NAVAB1 - prefix added because there are 2 records in N4 for trains IN and OUT
 // ### TFS 51855 13JAN2022 NAVAB1		licenseInt   := licenseStr.getStringValueAsInteger64;
 // ### TFS 51855 13JAN2022 NAVAB1	endif;
		
	
	objIdStr    := self.getFullObjectId(_any);
	
	if self.isTermRequired(_any) then
		termOid 	:= self.termOid;
		termIdStr   := self.getObjectId(termOid);
	endif;
	
	if termIdStr &lt;&gt; null then
		oidFormatted := termIdStr &amp; objIdStr;
	else
		oidFormatted := objIdStr;
	endif;
	
	if _prefix &lt;&gt; null then // ### TFS 52914 25FEB2022 NAVAB1
		licenseInt   := _prefix.getStringValueAsInteger64;   // ### TFS 52914 25FEB2022 NAVAB1 - prefix added because there are 2 records in N4 for trains IN and OUT
	endif;
	
	key := app.myRoot.systemMode.String &amp; licenseInt.String &amp; oidFormatted;
	

	return key.Integer64;
epilog

end;

</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_prefix" type="String"/>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="getFullObjectId" id="ef5007b9-5e6c-47dd-9296-10fa9508267a">
        <source>getFullObjectId(_any : Any):String;
/*
Purpose:	Use class number and instance to generate a unique Id		

Date		Who		Reason
08DEC2021	NAVAB1	TFS 51853
*/

vars
	id  : String;
	str : String;
	idx : Integer;
	obj : CM_Object;
begin
	if _any.isKindOf(CM_Object) then
		obj    := _any.CM_Object;
		str	   := obj.getOidAsString();
	
	elseif _any.isKindOf(String) then
		str := _any.String;

	endif;

	id := str.cnRemoveChars(".");


	return id;
end;</source>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeapTypeClassification" id="c5a1f27e-8870-4f54-8a02-7c67267be082">
        <source>getHeapTypeClassification(_blockStack : Any) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2022	navra1	Initial creation - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022


*/

vars	
	blockController	:	CM_BlockController;
	ti 				:	CM_TrackedItem;
	
begin
	if _blockStack &lt;&gt; null then		
		if _blockStack.isKindOf(CM_BlockStack) then	//it should be
			blockController := _blockStack.CM_BlockStack.getLocationsController.CM_BlockController;
			if blockController &lt;&gt; null then
				ti := blockController.allTrackedItems.first;
				if ti.isCar() then
					return "CAR";
				elseif ti.isChassis() then
					return "CHASSIS";
				elseif ti.isContainer() then
					return "CONTAINER";
				else
					return "CARGO";
				endif;
			endif;
		endif;
	endif;
	
	return "";

epilog

end;</source>
        <Parameter name="_blockStack" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMachine" id="79af095e-4194-48c6-aff5-bd162fe41548">
        <source>getMachine(_any : Any):CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/

vars
	machine		: CM_Machine;
	wle		    : CM_WorkListEntry;
	term  		: CM_Terminal;
	job         : CM_Job;
	machId : String;
	cranes : CM_MachineSet;
	wp : CM_WorkPoint;
begin

	if _any.isKindOf(CM_VoyageWLE) then
		wle 	:= _any.CM_WorkListEntry;
		job     := wle.job;	
		machId := job.CM_VoyageJob.craneId; // ### TFS 51853 27AUG2021 NAVAB1
	elseif _any.isKindOf(CM_YardWLE) then
		wle := _any.CM_WorkListEntry;
		job     := wle.job;	
		machId := wle.getWorkingMachineID();
	elseif _any.isKindOf(CM_YardJob) then // ### TFS 52914 03MAR2022 NAVAB1
		job := _any.CM_YardJob; // ### TFS 52914 03MAR2022 NAVAB1
	elseif _any.isKindOf(CM_VoyageJob) then
		job     := _any.CM_VoyageJob;
		machId := job.CM_VoyageJob.craneId; // ### TFS 51853 27AUG2021 NAVAB1
	elseif _any.isKindOf(CM_Delay) then // ### TFS 53569 10MAY2022 NAVAB1
		return _any.CM_Delay.myMachine; // ### TFS 53569 10MAY2022 NAVAB1
	endif;
	
	if job &lt;&gt; null then
		term 		:= job.getMyTerminal();
	endif;
	
	if  term &lt;&gt; null then
		if job.isKindOf(CM_VoyageJob) then
 // ### TFS 51853 27AUG2021 NAVAB1		return term.machines[job.CM_VoyageJob.craneId].CM_Machine;
			if job.isVoyageHoldJob() then // ### TFS 53105 13JUN2022 NAVAB1
				wp := term.allWorkPointsByCode[machId]; // ### TFS 53105 13JUN2022 NAVAB1
				return wp; // ### TFS 53105 13JUN2022 NAVAB1
			elseif job.isVoyageROROJob() then // ### TFS 53105 13JUN2022 NAVAB1
				wp := term.allWorkPointsByCode[machId]; // ### TFS 53105 13JUN2022 NAVAB1
				return wp; // ### TFS 53105 13JUN2022 NAVAB1
			
			else
				return term.machines[machId].CM_Machine;
			endif;
		elseif job.isRoadJob then
			return term.machines[machId].CM_Machine; // ### TFS 51853 27AUG2021 NAVAB1
		elseif job.isRail() then
			machine := term.machines[machId].CM_Machine;
		endif;
	endif;
	
	return machine;
epilog
	delete cranes;
end;</source>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getObjectId" id="d48cb9a2-ee3a-44c3-bfaf-31e7758ab791">
        <source>getObjectId(_any : Any):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	id  : String;
	str : String;
	idx : Integer;
	obj : CM_Object;
begin
	if _any.isKindOf(CM_Object) then
		obj    := _any.CM_Object;
		id	   := obj.cnGetInstanceId64(obj).String;
	
	elseif _any.isKindOf(String) then
		str := _any.String;
		idx := str.pos('.',1);
		id  := str[idx+1:str.length];
	endif;
	
	return id;
end;</source>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="dfbd5882-61df-463b-82c1-62723875731b">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView : CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
*/

vars

begin

	if 	_ewsOpsView.myTerminal &lt;&gt; null then
		self.termOid := _ewsOpsView.myTerminal.getOidAsString;
	endif;
	
	self.oid := _ewsOpsView.objectOid; // ### TFS 51853 09DEC2021 NAVAB1
	
	if self.oid = null  // ### TFS 51853 09DEC2021 NAVAB1 this is needed by the API for Snap Shots
	and _any.isKindOf(Object) then
		self.oid := _any.Object.getOidString();			
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivityPrefix" id="f858932d-a641-43e3-bee2-276e87f9d078">
        <updating/>
        <source>initializeForActivityPrefix(_any: Any; _ewsOpsView : CM_EWSActivityOpsview; _prefix : String) updating;
/*
Purpose:			

Date		Who		Reason
14DEC2021	NAVAB1	TFS 51855
*/

vars

begin

	if 	_ewsOpsView.myTerminal &lt;&gt; null then
		self.termOid := _ewsOpsView.myTerminal.getOidAsString;
	endif;
	
	self.oid := _ewsOpsView.objectOid; // ### TFS 51853 09DEC2021 NAVAB1
	
	if self.oid = null  // ### TFS 51853 09DEC2021 NAVAB1 this is needed by the API for Snap Shots
	and _any.isKindOf(Object) then
		self.oid := _any.Object.getOidString();			
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_prefix" type="String"/>
    </JadeMethod>
    <JadeMethod name="isTermRequired" id="2c300aef-c5d4-42b2-96be-c4c52dc0ae9a">
        <source>isTermRequired(_any :Any):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/
vars

	
begin
	if self.termOid = null then
		return false;
	endif;
	
	if _any.isKindOf(CM_Terminal)
	or _any.isKindOf(CM_Operator)
	or _any.isKindOf(CM_Carrier) // ### TFS 51853 08DEC2021 NAVAB1
	or _any.isKindOf(CM_Vessel)
	or _any.isKindOf(CM_DelayType)
	or _any.isKindOf(CM_Root)
	or _any.isKindOf(CM_WagonClass) // ### TFS 51855 10JAN2022 NAVAB1
	or _any.isKindOf(CM_ISOType) // ### TFS 51855 24JAN2022 NAVAB1
	or _any.isKindOf(CM_Trade) then
		return false;
	endif;

	return true;
end;
</source>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="n4BerthOrientation" id="c9d34e3b-239d-47a6-be0f-d5745e220d0f">
        <source>n4BerthOrientation(_shipSide : Integer):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars

begin
	if _shipSide = 0 then
		return  self.Berth_Orient_Unkown;
	elseif _shipSide = 1 then
		return self.Berth_Orient_PortSide;
	elseif _shipSide = 2 then
		return  self.Berth_Orient_StarBoard;
	endif;
epilog

end;</source>
        <Parameter name="_shipSide" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4BlockType" id="1171109a-dee1-4e28-87dc-e74aeb43bd0f">
        <source>n4BlockType(_area : CM_TerminalArea) : String;
/*
Purpose:			

Date		Who		Reason
08 February 2022	navab1	TFS 51854

block_type_enum:
BUFFER_HEAP
STRADDLE
HEAP 
TRANSTAINER 
FORKLIFT
LOGICAL

WHEELED_HEAP
BUILDING
WAREHOUSE_HEAP_OUTSIDE
WAREHOUSE_STACKED_INSIDE
WAREHOUSE_HEAP_INSIDE
*/

vars

begin
	if _area.isKindOf(CM_GridArea) then
		if _area.isStraddleStack() then
			return "STRADDLE";
		elseif _area.isForkliftStack() then
			return "FORKLIFT";
		// TFS 53369 elseif _area.isBlockStack()  then
		// TFS 53369	return "HEAP";
		endif;
	elseif _area.myType.isLogicalDeleteArea() then
		return "LOGICAL";
	elseif _area.type = TA_TYPE_REPAIR then
		return "TRANSTAINER";
	elseif _area.isBlockStack() then
		if _area.isTransferArea() then
			return "BUFFER_HEAP";
		endif;
		
		return "HEAP";
	endif;
	
epilog

end;</source>
        <Parameter name="_area" type="CM_TerminalArea"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4CHEKind" id="bb052416-594d-4868-bf9b-2ff8e5064204">
        <source>n4CHEKind(_machine : CM_Machine) : String;
/*
Purpose:			

Date		Who		Reason
17 December 2021	navab1	TFS 51855

RST - Reach Stacker
RTG - Rubber Tyred Gantry
ITV - Internal Truck Vehicle (IMV)
RMG - Rail Mounted Gantry
QC - Quay Crane
SC - Straddle Carrier

ASC - Auto Straddle
MAN - Person
*/

vars

begin
	if _machine = null then
		return "";
	endif;
	
	if _machine.machineType = MACHINETYPE_FORK_LIFT then
		return "RST";
	elseif _machine.machineType = MACHINETYPE_RTG then
		return "RTG";
	elseif _machine.machineType = MACHINETYPE_RMG then
		return "RMG";
	elseif _machine.machineType = MACHINETYPE_IMV then
		return "ITV";
	elseif _machine.machineType = MACHINETYPE_PORTAINER_CRANE then
		return "QC";
	elseif _machine.machineType = MACHINETYPE_STRADDLE then
		return "SC";
	elseif _machine.machineType = MACHINETYPE_TOP_LIFT then
		return "RST";
	elseif _machine.machineType = MACHINETYPE_TRUCK_TRACTOR then
		return "ITV";
	elseif _machine.machineType = MACHINETYPE_SIDE_LOADER then
		return "RST";
	endif;
	
	
	
	
	
	return "";
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4CarrierLocation" id="a810a6c1-5cc9-4d9c-a7f2-453f4ca5b9a8">
        <source>n4CarrierLocation(_wle : CM_WorkListEntry; _field : String) : String;
/*
Purpose:			

Date		Who		Reason
26 August 2021	navab1	TFS 51853
*/

vars
	train : CM_Train;
begin
	if _wle.isKindOf(CM_VoyageWLE) then
		if _field = "carrier_loctype" then
			return self.Carrier_Loc_Vessel;
		elseif _field = "carrier_locid" then
			return _wle.CM_VoyageWLE.getMyVoyageObject().code[1:16]; // ### TFS 51855 11JAN2022 NAVAB1 add length truncation
		endif;
	elseif _wle.isKindOf(CM_YardWLE) then // ### TFS 51853 27AUG2021 NAVAB1
		if _wle.CM_YardWLE.job.isRoadJob() then // ### TFS 51853 27AUG2021 NAVAB1
			if _field = "carrier_loctype" then // ### TFS 51853 27AUG2021 NAVAB1
				return self.Carrier_Loc_Truck; // ### TFS 51853 27AUG2021 NAVAB1
			elseif _field = "carrier_locid" then // ### TFS 51853 27AUG2021 NAVAB1
				return _wle.job.CM_RoadJob.myVehicleVisit.regNumber; // ### TFS 51853 27AUG2021 NAVAB1
			endif;
		elseif _wle.CM_YardWLE.job.isRail() then 	
			//navra1 - TFS-51855 17th May 2022 - Check and fill for rail jobs
			if _field = "carrier_loctype" then 		
				return self.Carrier_mode_Train;		
			elseif _field = "carrier_locid" then
				/*  // ### TFS 51855 24MAY2022 NAVAB1
				if _wle.CM_YardWLE.job.isRelease() then	
					return _wle.CM_YardWLE.job.CM_RailJob.getMyTrain().code &amp; CMIF_OpsViewTables.Prefix_Outbound;	
				else 
					return _wle.CM_YardWLE.job.CM_RailJob.getMyTrain().code &amp; CMIF_OpsViewTables.Prefix_Inbound;
				endif;
				Now */
				train := _wle.CM_YardWLE.job.CM_RailJob.getMyTrain();
				if train &lt;&gt; null then
					if _wle.CM_YardWLE.job.isRelease() then	
						return train.code &amp; CMIF_OpsViewTables.Prefix_Outbound;	
					else 
						return train.code &amp; CMIF_OpsViewTables.Prefix_Inbound;
					endif;
				
				endif;
			endif;
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4Category" id="5b348685-ba07-4fdf-af1e-018888ec2e97">
        <source>n4Category(_imexStatus : Integer) : String;
/*
Purpose:			

Date		Who		Reason
26 August 2021	navab1	TFS 51853
*/

vars

begin
	if _imexStatus = TI_IMEX_STATUS_EXPORT then
		return self.Category_Export;
	elseif _imexStatus = TI_IMEX_STATUS_IMPORT then
		return self.Category_Import;
	elseif _imexStatus = TI_IMEX_STATUS_TRANSHIP then
		return self.Category_TShip;
	elseif _imexStatus = TI_IMEX_STATUS_STORAGE then
		return self.Category_Storage;
	elseif _imexStatus = TI_IMEX_STATUS_REMAINONBOARD then
		return self.Category_ROB;
	endif;
epilog

end;</source>
        <Parameter name="_imexStatus" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4FreightKind" id="06264d05-de52-4dbc-9815-a7de62c05872">
        <source>n4FreightKind(ti : CM_TrackedItem) : String;
/*
Purpose:			

Date		Who		Reason
15 December 2021	navab1	TFS 51855
20 July 	2022	navra1	TFS 53111 - Send super type for GC and MT/FCL for containers
29 July 	2022	navra1	TFS 53111 - Return BBK as freight kind if not container(GC)
*/

vars

begin
	if ti.isKindOf(CM_Container) then
		if ti.CM_Container.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			return self.FreightKind_MT;
		elseif ti.CM_Container.contentsStatus = TI_CONTENTS_STATUS_FCL then
			return self.FreightKind_FCL;
		elseif ti.CM_Container.contentsStatus = TI_CONTENTS_STATUS_LCL then
			return self.FreightKind_LCL;
		endif;
	else
		return self.FreightKind_BBK;
	endif;	
epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4IsoTypeDetails" id="501c1c81-8234-41d4-8aea-536b40cd5f9b">
        <source>n4IsoTypeDetails( _isoType : CM_ISOType;_field : String):Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/

vars
	any : Any;
begin
	if _field = "gkey_IsoType" then
		return self.generateFullGKey(_isoType, "");
	elseif _field = CMIF_RefEquipType::description.name then // ### TFS 51853 31Aug2021 NAVPW1
		return _isoType.description[1:40];
	elseif _field = "id" then
		return _isoType.code;
	elseif _field = CMIF_RefEquipType::iso_group.name then // ### TFS 51853 31Aug2021 NAVPW1
		if _isoType.myISOTypeGroup &lt;&gt; null then
			return _isoType.myISOTypeGroup.code;
		else
			return "";
		endif;
	elseif _field = CMIF_RefEquipType::nominal_length.name // ### TFS 51853 31Aug2021 NAVPW1
	or _field = CMIF_RefEquipType::basic_length.name // ### TFS 51853 31Aug2021 NAVPW1
	or _field = CMIF_RefEquipType::length_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
		if _isoType.is20ftLong then
			if _field = CMIF_RefEquipType::nominal_length.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "NOM20";
			elseif _field = CMIF_RefEquipType::basic_length.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "BASIC20";
			elseif _field = CMIF_RefEquipType::length_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "6068";
			endif;
			
		elseif _isoType.is30ftLong then
			if _field = CMIF_RefEquipType::nominal_length.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "NOM30";
			elseif _field = CMIF_RefEquipType::basic_length.name  then // ### TFS 51853 31Aug2021 NAVPW1
				return "BASIC20";
			elseif _field = CMIF_RefEquipType::length_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "6068";
			endif;
		elseif _isoType.is40ftLong then
			if _field = CMIF_RefEquipType::nominal_length.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "NOM40";
			elseif _field = CMIF_RefEquipType::basic_length.name  then // ### TFS 51853 31Aug2021 NAVPW1
				return "BASIC40";
			elseif _field = CMIF_RefEquipType::length_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "12192";
			endif;
		elseif _isoType.is45ftLong then
			if _field = CMIF_RefEquipType::nominal_length.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "NOM45";
			elseif _field = CMIF_RefEquipType::basic_length.name  then // ### TFS 51853 31Aug2021 NAVPW1
				return "BASIC40";
			elseif _field = CMIF_RefEquipType::length_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "12192";
			endif;
		
		elseif _isoType.is53ftLong then
			if _field = CMIF_RefEquipType::nominal_length.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "NOM53";
			elseif _field = CMIF_RefEquipType::basic_length.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "BASIC40";
			elseif _field = CMIF_RefEquipType::length_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return "12192";
			endif;
		endif;
	elseif _field = CMIF_RefEquipType::nominal_height.name // ### TFS 51853 31Aug2021 NAVPW1 
	or     _field = CMIF_RefEquipType::height_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
		if _isoType.is8ftHigh then
			if _field = CMIF_RefEquipType::nominal_height.name then // ### TFS 51853 31Aug2021 NAVPW1
				return  "NOM80";
			elseif _field = CMIF_RefEquipType::height_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return 2438;
			endif;
		elseif _isoType.is8ft6High then
			if _field = CMIF_RefEquipType::nominal_height.name then // ### TFS 51853 31Aug2021 NAVPW1
				return  "NOM86";
			elseif _field = CMIF_RefEquipType::height_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return 2591;
			endif;
		elseif _isoType.is9ft6High then
			if _field = CMIF_RefEquipType::nominal_height.name then // ### TFS 51853 31Aug2021 NAVPW1
				return  "NOM96";
			elseif _field = CMIF_RefEquipType::height_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return 2895;
			endif;
		elseif _isoType.is4ftHigh then
			if _field = CMIF_RefEquipType::nominal_height.name then // ### TFS 51853 31Aug2021 NAVPW1
				return  "NOM40";
			elseif _field = CMIF_RefEquipType::height_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return 1219;
			endif;
		elseif _isoType.is4ft3High then
			if _field = CMIF_RefEquipType::nominal_height.name then // ### TFS 51853 31Aug2021 NAVPW1
				return  "NOM43";
			elseif _field = CMIF_RefEquipType::height_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
				return 1295;
			endif;
		endif;
	
	elseif _field = CMIF_RefEquipType::classStr.name then // ### TFS 51853 31Aug2021 NAVPW1
		if _isoType.isContainer then
			return "CONTAINER";
		endif;	
	
	elseif _field = CMIF_RefEquipType::safe_weight_kg.name then // ### TFS 51853 31Aug2021 NAVPW1
			return 	_isoType.maxTotalWeight;
		elseif _field = CMIF_RefEquipType::tare_weight_kg.name then // ### TFS 51853 31Aug2021 NAVPW1
			return 	 _isoType.tareKilos;
		elseif _field = CMIF_RefEquipType::width_mm.name then // ### TFS 51853 31Aug2021 NAVPW1
			return "2438";
    elseif _field = CMIF_RefEquipType::life_cycle_state.name then // ### TFS 51853 31Aug2021 NAVPW1
		return 	 self.n4LifeCycleState(_isoType);
	endif;
	
	return any;
epilog

end;</source>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="n4LifeCycleState" id="13595701-48dd-4e48-9618-add523a02c54">
        <source>n4LifeCycleState(_any : Any):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	trade 		: CM_Trade;
	operator    : CM_Operator;
	machine     : CM_Machine;
	delayType	: CM_DelayType;
	state		: String;
	isoType     : CM_ISOType;
	carrier 	: CM_Carrier;
	gridLC 		: CM_GridController;
	gridCol 	: CM_GridColumn;
	gridArea 	: CM_GridArea;
	con 		: CM_ConsigneeConsignor;
	workPoint	: CM_WorkPoint;
	cargoType	: CM_CargoType;
begin
	if _any.isKindOf(CM_Trade) then
		trade := _any.CM_Trade;
		if trade.isNotAvailableForEntry then
			return Life_Cycle_State_OBS;
		else
			return Life_Cycle_State_ACT;
		endif;
	elseif _any.isKindOf(CM_DelayType) then
	
		delayType := _any.CM_DelayType;
		if delayType.isNotAvailableForEntry then
			return Life_Cycle_State_OBS;
		else
			return Life_Cycle_State_ACT;
		endif;
	elseif _any.isKindOf(CM_Machine) then
	
		machine := _any.CM_Machine;
		if machine.isNotAvailableForEntry then
			return Life_Cycle_State_OBS;
		else
			return Life_Cycle_State_ACT;
		endif;
	//navsp1 03Jun2022 TFS#53104
	elseif _any.isKindOf(CM_WorkPoint) then	
		workPoint := _any.CM_WorkPoint;
		if workPoint.isNotAvailableForEntry then
			return Life_Cycle_State_OBS;
		else
			return Life_Cycle_State_ACT;
		endif;
	elseif _any.isKindOf(CM_Operator)then
		operator := _any.CM_Operator;
		if operator.isNotAvailableForEntry then
			return Life_Cycle_State_OBS;
		else
			return Life_Cycle_State_ACT;
		endif;
	 // ### TFS 53105 31MAY2022 NAVAB1
	elseif _any.isKindOf(CM_ConsigneeConsignor)then
		con := _any.CM_ConsigneeConsignor;
		if con.isNotAvailableForEntry then
			return Life_Cycle_State_OBS;
		else
			return Life_Cycle_State_ACT;
		endif;
	 // ### TFS 51853 26AUG2021 NAVAB1
	elseif _any.isKindOf(CM_Carrier)then
		carrier := _any.CM_Carrier;
		if carrier.isNotAvailableForEntry then
			return Life_Cycle_State_OBS;
		else
			return Life_Cycle_State_ACT;
		endif;
	elseif _any.isKindOf(CM_ISOType)then
		isoType := _any.CM_ISOType;
		if isoType.isNotAvailableForEntry then
			return Life_Cycle_State_OBS;
		else
			return Life_Cycle_State_ACT;
		endif;
	elseif _any.isKindOf(CM_GridController)then // ### TFS 51854 08FEB2022 NAVAB1
		gridLC := _any.CM_GridController; // ### TFS 51854 08FEB2022 NAVAB1
		/*if gridLC.amIAvailable() then // ### TFS 51854 08FEB2022 NAVAB1
			return Life_Cycle_State_ACT; // ### TFS 51854 08FEB2022 NAVAB1
		else
			return Life_Cycle_State_OBS; // ### TFS 51854 08FEB2022 NAVAB1
		endif;*/ 					 //TFS#53369 NAVSP1 27APR2022
		return Life_Cycle_State_ACT; //TFS#53369 NAVSP1 27APR2022
	elseif _any.isKindOf(CM_GridColumn)then // ### TFS 51854 08FEB2022 NAVAB1
		gridCol := _any.CM_GridColumn; // ### TFS 51854 08FEB2022 NAVAB1
		/*if gridCol.isInUse() then // ### TFS 51854 08FEB2022 NAVAB1
			return Life_Cycle_State_ACT; // ### TFS 51854 08FEB2022 NAVAB1
		else
			return Life_Cycle_State_OBS; // ### TFS 51854 08FEB2022 NAVAB1
		endif;*/					 //TFS#53369 NAVSP1 27APR2022
		return Life_Cycle_State_ACT; //TFS#53369 NAVSP1 27APR2022
	elseif _any.isKindOf(CM_GridArea)then // ### TFS 51854 08FEB2022 NAVAB1
		return Life_Cycle_State_ACT; // ### TFS 51854 08FEB2022 NAVAB1
	elseif _any.isKindOf(CM_BlockStack)then // ### TFS 53369 12APR2022 NAVAB1
		return Life_Cycle_State_ACT; // ### TFS 53369 12APR2022 NAVAB1		
	elseif _any.isKindOf(CM_CargoType) then 		//navra1 - 17th June 2022 - TFS-53105
		cargoType:=_any.CM_CargoType;				//navra1 - 17th June 2022 - TFS-53105
		if cargoType.isNotAvailableForEntry then	//navra1 - 17th June 2022 - TFS-53105
			return Life_Cycle_State_OBS;			//navra1 - 17th June 2022 - TFS-53105
		else										//navra1 - 17th June 2022 - TFS-53105
			return Life_Cycle_State_ACT;			//navra1 - 17th June 2022 - TFS-53105
		endif;										//navra1 - 17th June 2022 - TFS-53105
	endif;
	
	return "";
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4LocationType" id="b1e6a2dd-a5bd-456b-bbd5-708fa923932c">
        <source>n4LocationType(_locnType : String) : String;
/*
Purpose:			

Date		Who		Reason
15 December 2021	navab1	TFS 51855
*/

vars

begin
	if _locnType = GROSSAREA_SHIP then
		return self.LocationType_Vessel;
	elseif _locnType = GROSSAREA_NOWHERE then
		return "";
	elseif _locnType = GROSSAREA_RAIL then
		return self.LocationType_RailCar; // ### TFS 51855 26MAY2022 NAVAB1
	elseif _locnType = GROSSAREA_ROAD then
		return self.LocationType_Truck;
		
	endif;
	
	return self.LocationType_Yard; 
epilog

end;</source>
        <Parameter name="_locnType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4MoveKind" id="163575b0-2266-46c7-ada2-53a73fbcd40f">
        <source>n4MoveKind(_any : Any):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	value 		: String;
	wle			: CM_WorkListEntry;
	voyageWle   : CM_VoyageWLE;
	yardWLE : CM_YardWLE;
	slotRequest : CM_SlotRequest;
	voyageReq : CM_VoyageRequest;
	move : CM_Move;
	slocnType, tlocnType, moveKind : String;
	lc : CM_LocationsController;
begin
	
	if _any.isKindOf(CM_VoyageWLE) then
		voyageWle := _any.CM_VoyageWLE;
		
		if voyageWle.myRequest &lt;&gt; null and voyageWle.myRequest.isKindOf(CM_SlotRequest) then
			slotRequest :=  voyageWle.myRequest.CM_SlotRequest;
			if slotRequest.moveType = DISCHARGE_MOVETYPE then
				return self.Move_Kind_Discharge;
			elseif slotRequest.moveType = LOAD_MOVETYPE then
				return self.Move_Kind_Load;
			elseif slotRequest.moveType = SOB_MOVETYPE then
				return self.Move_Kind_Sob;
			elseif slotRequest.moveType = DLR_MOVETYPE then  
				if slotRequest.isLoad then // ### TFS 51855 27JAN2022 NAVAB1
					return self.Move_Kind_Load; // ### TFS 51855 27JAN2022 NAVAB1
				elseif slotRequest.isDischarge then // ### TFS 51855 27JAN2022 NAVAB1
					return self.Move_Kind_Discharge; // ### TFS 51855 27JAN2022 NAVAB1
				endif;
				return self.Move_Kind_Unkown;
			endif;
		 // ### TFS 53105 02JUN2022 NAVAB1
		elseif voyageWle.myRequest &lt;&gt; null and voyageWle.myRequest.isKindOf(CM_VoyageRequest) then // RORO and HOLD jobs 
			voyageReq :=  voyageWle.myRequest.CM_VoyageRequest;
			if voyageReq.moveType = DISCHARGE_MOVETYPE then
				return self.Move_Kind_Discharge;
			elseif voyageReq.moveType = LOAD_MOVETYPE then
				return self.Move_Kind_Load;
			elseif voyageReq.moveType = SOB_MOVETYPE then
				return self.Move_Kind_Sob;
			elseif voyageReq.moveType = DLR_MOVETYPE then  
				if voyageReq.isLoad then
					return self.Move_Kind_Load; 
				elseif voyageReq.isDischarge then
					return self.Move_Kind_Discharge;
				endif;
				return self.Move_Kind_Unkown;
			endif;

		endif;
	elseif _any.isKindOf(CM_YardWLE) then // ### TFS 51853 27AUG2021 NAVAB1
		wle := _any.CM_YardWLE; // ### TFS 51853 27AUG2021 NAVAB1
		if wle.job.isRoadJob then // ### TFS 51853 27AUG2021 NAVAB1
			if wle.isReceipt then // ### TFS 51853 27AUG2021 NAVAB1
				return self.Move_Kind_Received; // ### TFS 51853 27AUG2021 NAVAB1
			else
				return self.Move_Kind_Delivered; // ### TFS 51853 27AUG2021 NAVAB1
			
			endif;
		elseif wle.job.isRail then // ### TFS 51853 15DEC2021 NAVAB1
			if wle.isReceipt then // ### TFS 51853 15DEC2021 NAVAB1
				return self.Move_Kind_DischargeRail; // ### TFS 51853 15DEC2021 NAVAB1
			else
				return self.Move_Kind_LoadRail; // ### TFS 51853 15DEC2021 NAVAB1
			
			endif;
		endif;
	elseif _any.isKindOf(CM_Move) then // ### TFS 51853 15DEC2021 NAVAB1
		move := _any.CM_Move;
		
		slocnType := move.getInvMoveSourceString();
		tlocnType := move.getInvMoveTargetString();
		
		//navra1- 7th Sep 2022 - TFS 51855
		if slocnType = null then	//If you could not determine the source location			//navra1- 7th Sep 2022 - TFS 51855
			//If the move involves a voyage and is a crane move, it is either a load 			//navra1- 7th Sep 2022 - TFS 51855
			//or a discharge, but if the IMEX is IMPORT, it is a discharge, so the source		//navra1- 7th Sep 2022 - TFS 51855
			//is from the ship																	//navra1- 7th Sep 2022 - TFS 51855
			if move.getVoyage() &lt;&gt; null and move.isCraneMove() and								//navra1- 7th Sep 2022 - TFS 51855
						move.imExStatus = TI_IMEX_STATUS_IMPORT then							//navra1- 7th Sep 2022 - TFS 51855
				slocnType := GROSSAREA_SHIP;													//navra1- 7th Sep 2022 - TFS 51855
			endif;																				//navra1- 7th Sep 2022 - TFS 51855
		endif;																					//navra1- 7th Sep 2022 - TFS 51855
		
		if slocnType = GROSSAREA_SHIP then
			if tlocnType = GROSSAREA_SHIP then // ### TFS 51855 31JAN2022 NAVAB1
				return self.Move_Kind_Sob; // ### TFS 51855 31JAN2022 NAVAB1
			else // ### TFS 51855 31JAN2022 NAVAB1
				return self.Move_Kind_Discharge;
			endif;
		elseif tlocnType = GROSSAREA_SHIP then
			return self.Move_Kind_Load;
		elseif slocnType = GROSSAREA_ROAD then
			return self.Move_Kind_Received;
		elseif tlocnType = GROSSAREA_ROAD then
			return self.Move_Kind_Delivered;
		elseif slocnType = GROSSAREA_RAIL then
			return self.Move_Kind_DischargeRail; // ### TFS 51855 17MAY2022 NAVAB1
		elseif tlocnType = GROSSAREA_RAIL then
			return self.Move_Kind_LoadRail; // ### TFS 51855 17MAY2022 NAVAB1
		else // source is the yard, 'move' will be a pickup so target is a machine. getInvMoveSourceString() has  returned the yard terminal area and getInvMoveTargetString() return blank.
		
			lc := move.getSourceLocationsController(); // ### TFS 51855 14FEB2022 NAVAB1
			if lc &lt;&gt; null  and lc.isYardLocation() then // ### TFS 51855 14FEB2022 NAVAB1	
			
				// Use is there a load WLE that tells us where the TI went?
				moveKind := move.getLoadMoveKindFromWLE(self);
				if moveKind &lt;&gt; "" then
					return moveKind;
				else

					// Is it a yard to yard move?
					lc := move.getTargetLocationsController();
					if lc &lt;&gt; null  and lc.isYardLocation() then 
						if move.isOverStow then // ### TFS 53569 13MAY2022 NAVAB1
							return self.Move_Kind_Shift; // ### TFS 53569 13MAY2022 NAVAB1
						else
							return self.Move_Kind_Yard;//navra1 TFS-53069 May 11th 2022
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	return value;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4MoveSeq" id="8ed12402-dd91-4a2c-92ac-ec64afccfea3">
        <source>n4MoveSeq(_hmsMove : HMS_VoyageMovement):Integer64;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/
vars
	hmsVoyageData : HMS_VoyageData;
	seq           : Integer64;
begin

	if	_hmsMove.myHMSVoyageData &lt;&gt; null then
		hmsVoyageData := _hmsMove.myHMSVoyageData;		
		if hmsVoyageData.allVoyageMovements.includes(_hmsMove) then
			seq := hmsVoyageData.allVoyageMovements.indexOf(_hmsMove);
		endif;
	endif;
	
	return seq;
end;
</source>
        <Parameter name="_hmsMove" type="HMS_VoyageMovement"/>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="n4MoveStage" id="f4c6c2e4-a765-4d23-a86b-e86d48a09095">
        <source>n4MoveStage(_any : Any):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

Valid Values in N4:

PLANNED
CARRY_READY
CARRY_COMPLETE
CARRY_UNDERWAY
COMPLETE
PUT_COMPLETE

*/

vars
	value 		: String;
	wle			: CM_WorkListEntry;
	slotRequest : CM_SlotRequest;

begin
	
	if _any.isKindOf(CM_WorkListEntry) then
		
		wle := _any.CM_WorkListEntry;
		
		if wle.status = WLE_UNACTIONED then
			return	self.Move_Stage_Planned;
		elseif wle.status = WLE_PART_COMPLETE then // ### TFS 51855 26JAN2022 NAVAB1
			/*navra1 - 5th April 2022 - TFS 53028
			if wle.myRequest.isSlotRequest() then
				slotRequest := wle.myRequest.CM_SlotRequest;
				if slotRequest.isDischarge then
					return self.Move_Stage_Complete;
				endif;
			endif;
			//navra1 - 5th April 2022 - TFS 53028*/
			return self.Move_Stage_UnderWay; // ### TFS 51855 26JAN2022 NAVAB1
		elseif wle.status = WLE_ASSIGNED then // ### TFS 51855 26JAN2022 NAVAB1
			return self.Move_Stage_UnderWay; // ### TFS 51855 26JAN2022 NAVAB1
		elseif wle.status = WLE_COMPLETED then
			return self.Move_Stage_Complete; // ### TFS 51855 26JAN2022 NAVAB1
		endif;	
		
	endif;
	
	return value;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4StackStatusChars" id="a6fed483-daf8-476a-8ec7-ed3c6f99fd26">
        <source>n4StackStatusChars(_gridLC : CM_LocationsController) : String;
/*
Purpose:

Date		Who		Reason
22 April 2022	navab1	TFS 53369
30MAY2022 navsp1  TFS#53700 - Refactoring
*/
constants
	IMPEDIMENT_CHAR_INDEX = 0;
	TIER_LIMIT_CHAR_INDEX = 1;
	REEFER_CHAR_INDEX = 2;
	MEN_WORKING_CHAR_INDEX = 3;
	CHASSIS_CHAR_INDEX = 4;
	PROTECTED_CHAR_INDEX = 5;
	TP_TRANSFER_TYPE_CHAR_INDEX = 6;
	SEGREGATION_CHAR_INDEX = 7;
	LONG_TP_CHAR_INDEX = 8;
	TP_SPECIAL_INDEX = 9;
	CHAR_LENGTH = 10;

	DEFAULT_STATUS_CHAR = ' ';

	MEN_WORKING = 'M';
	MEN_NOT_WORKING = 'W';
	THREE_TEU = '3';

	TIER_HIGH_1 = '1';
	TIER_HIGH_2 = '2';
	TIER_HIGH_3 = '3';
	TIER_HIGH_4 = '4';
	TIER_HIGH_5 = '5';
	TIER_HIGH_6 = '6';
	TIER_HIGH_7 = '7';
	TIER_HIGH_8 = '8';
	TIER_HIGH_9 = '9';
	TIER_HIGH_A = 'A';
	TIER_HIGH_B = 'B';
	TIER_HIGH_C = 'C';
	TIER_HIGH_D = 'D';
	TIER_HIGH_E = 'E';
	TIER_HIGH_F = 'F';
	TIER_HIGH_G = 'G';
	TIER_HIGH_H = 'H';
	TIER_HIGH_I = 'I';
	TIER_HIGH_J = 'J';
	DEFAULT_TIER_LIMIT = 0;
	TIER_LIMIT_1 = 1;
	TIER_LIMIT_2 = 2;
	TIER_LIMIT_3 = 3;
	TIER_LIMIT_4 = 4;
	TIER_LIMIT_5 = 5;
	TIER_LIMIT_6 = 6;
	TIER_LIMIT_7 = 7;
	TIER_LIMIT_8 = 8;
	TIER_LIMIT_9 = 9;

	ROADWAY = 'R';
	HYDRANT = 'H';
	BUILDING = 'B';
	AISLE = 'A';
	POLE = 'P';
	TEMP_BLOCKED = 'X';
	TP_EXTENDED = 'T';
	ONLY_20 = '2';
	ONLY_45 = '5';
	PREFERRED_45 = '6';

	NO_DELIVERY = 'C';
	NO_EMPTY_DELIVERY = 'D';
	NO_RECEIVE_DELIVERY = 'E';
	DELIVER_FIRST = 'F';

	TP_RACK = 'R';
	TP_DIRECTEXCHANGE = 'D';
	TP_GROUNDED = ' ';

		// used for TP_SPECIAL_INDEX
	TP_CHARGING = 'C';
	TP_CHARGING_NOT = 'N';
vars
	statusChar : String;
	stackLC : CM_StackController;
begin
	statusChar := "           ";
	//navsp1 30MAY2022  Restriction moved out
	if _gridLC.hasRestrictions(LABOUR_RESTRICTION) then
			statusChar := statusChar[1:MEN_WORKING_CHAR_INDEX] &amp; MEN_WORKING &amp; statusChar[MEN_WORKING_CHAR_INDEX + 2:end];
		//navra1 - TFS 53369 - 4th May 2022
		//else
			//statusChar := statusChar[1:MEN_WORKING_CHAR_INDEX] &amp; MEN_NOT_WORKING &amp; statusChar[MEN_WORKING_CHAR_INDEX + 2:end];
	endif;
	if _gridLC.isGridLocation() then //navsp1 30MAY2022 TFS#53700
	
		
		// Restriction moved out of this check

		statusChar := statusChar[1:TIER_LIMIT_CHAR_INDEX] &amp; _gridLC.getMaxStackingHeight().String &amp; statusChar[TIER_LIMIT_CHAR_INDEX + 2:end];
		//statusChar := statusChar[1:REEFER_CHAR_INDEX] &amp; _gridLC.getMaxStackingHeight().String &amp; statusChar[REEFER_CHAR_INDEX + 2:end];	//navra1 - TFS 53369 - 4th May 2022
		
		if _gridLC.isKindOf(CM_StackController) then
			stackLC := _gridLC.CM_StackController;
			
			
			if stackLC.hasPower() then // ### TFS 53369 05MAY2022 NAVAB1
				statusChar := statusChar[1:REEFER_CHAR_INDEX] &amp; _gridLC.getMaxStackingHeight().String &amp; statusChar[REEFER_CHAR_INDEX + 2:end];//navra1 - TFS 53369 - 4th May 2022
			endif;		
			
			if stackLC.usage = BUILDING_USE then
				statusChar := BUILDING &amp; statusChar[IMPEDIMENT_CHAR_INDEX + 2:end];
			elseif stackLC.usage = LIGHT_TOWER_USE then
				statusChar := POLE &amp; statusChar[IMPEDIMENT_CHAR_INDEX + 2:end];
			elseif not stackLC.amIAvailable() then
				statusChar := TEMP_BLOCKED &amp; statusChar[IMPEDIMENT_CHAR_INDEX + 2:end];
			endif;
		endif;
		
		if _gridLC.isGap() then
			statusChar := AISLE &amp; statusChar[IMPEDIMENT_CHAR_INDEX + 2:end];
		endif;
		
		if _gridLC.is20ft then
			statusChar := ONLY_20 &amp; statusChar[IMPEDIMENT_CHAR_INDEX + 2:end];
		elseif _gridLC.is45ft then
			statusChar := ONLY_45 &amp; statusChar[IMPEDIMENT_CHAR_INDEX + 2:end];
		
		endif;
		
	endif;
	
	return statusChar;
epilog

end;</source>
        <Parameter name="_gridLC" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4StageId" id="5476a57a-f148-4dc9-9d6c-376a1b1d9654">
        <source>n4StageId(_vvr : CM_VehicleVisitRecord) : String;
/*
Purpose:			

Date		Who		Reason
01MAR2022	NAVAB1	TFS 52914
*/


vars
	veh	: CM_Vehicle;
	stageType : Integer;
begin
	if _vvr = null then
		return "";
	endif;
	
	veh := _vvr.vehicle;
	
	if veh = null then
		return "";
	endif;
	
	stageType := veh.getCurrentStageType();
	if stageType = VisitRecord_Arrive_PGate_In then
		return "ingate";
	elseif stageType = VisitRecord_Yard then
		return "yard";
	elseif stageType = VisitRecord_Arrive_PGate_Out then
		return "outgate";
	elseif stageType = VisitRecord_Arrive_AGate then
		return "ingate";
	elseif stageType = VisitRecord_Trouble then
		return "ingate";
	endif;
	
	return "";
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4SubType" id="bb39d24d-7af3-40a1-9978-94c6b2e02601">
        <source>n4SubType(_wle : CM_WorkListEntry) : String;
/*
Purpose:			

Date		Who		Reason
26 August 2021	navab1	TFS 51853
*/

vars
	ti : CM_TrackedItem;
begin
	ti := _wle.myTrackedItem;
	
	
	if _wle.isReceipt then
		if ti.isEmpty() then
			return "RM"; // Receive Empty
		else
			if ti.isExport then
				return "RE"; // Receive Export
			else
				return "RI";  // Receive Import
			endif;

		endif;
	else
		if ti.isEmpty() then
			return "DM"; // Receive Empty
		else
			if ti.isExport then
				return "DE"; // Receive Export
			else
				return "DI";  // Receive Import
			endif;

		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4TrainStatus" id="265e96d3-ff3b-440c-954f-ba7db84fd397">
        <source>n4TrainStatus(_train : CM_Train; _inward : Boolean) : String;
/*
Purpose:			

Date		Who		Reason
10 December 2021	navab1	TFS 51853

N4 Valid values:

10CREATED
20INBOUND
30ARRIVED
40WORKING
50COMPLETE
60DEPARTED
70CLOSED
80CANCELED


*/

vars

begin
	 // ### TFS 52914 02MAR2022 NAVAB1 - these are in a particular order, do not change.
	//if _train.status = _train.isInBound() then								//navsp1 17MAY2022 TFS#53619
	if _train.status = TrainStatus_Inbound then									//navsp1 17MAY2022 TFS#53619
		return CMIF_OpsViewTables.Train_Visit_Inbound;
	//elseif _train.isWorking(_inward) then // ### TFS 52914 02MAR2022 NAVAB1	//navsp1 17MAY2022 TFS#53619
	elseif _train.status = TrainStatus_Working then								//navsp1 17MAY2022 TFS#53619
		return CMIF_OpsViewTables.Train_Visit_Working;
	//elseif _train.hasDeparted() then											//navsp1 17MAY2022 TFS#53619
	elseif _train.status = TrainStatus_Departed then							//navsp1 17MAY2022 TFS#53619
		return CMIF_OpsViewTables.Train_Visit_Departed;
	//elseif _train.isComplete(_inward) then // ### TFS 52914 02MAR2022 NAVAB1	//navsp1 17MAY2022 TFS#53619
	elseif _train.status = TrainStatus_Complete then							//navsp1 17MAY2022 TFS#53619
		return CMIF_OpsViewTables.Train_Visit_Complete;
	//elseif _train.hasArrived() then											//navsp1 17MAY2022 TFS#53619
	elseif _train.status = TrainStatus_Arrived then								//navsp1 17MAY2022 TFS#53619
		return CMIF_OpsViewTables.Train_Visit_Arrived;
	elseif _train.status = TrainStatus_Closed then								//navsp1 17MAY2022 TFS#53619
			return CMIF_OpsViewTables.Train_Visit_Closed;						//navsp1 17MAY2022 TFS#53619
	elseif _train.status = TrainStatus_Cancelled then							//navsp1 17MAY2022 TFS#53619
		return CMIF_OpsViewTables.Train_Visit_Cancelled;						//navsp1 17MAY2022 TFS#53619
	endif;

	return CMIF_OpsViewTables.Train_Visit_Created;

epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_inward" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4TransitState" id="074b6f4d-7398-44eb-9ef2-38f1c27d5b35">
        <source>n4TransitState(_ti : CM_TrackedItem) : String;
/*
Purpose:	

S10_ADVISED
S20_INBOUND		
S30_ECIN
S40_YARD
S50_ECOUT
S60_LOADED
S70_DEPARTED
S99_RETIRED

Date		Who		Reason
20 December 2021	navab1	TFS 51855
*/

vars
	lc : CM_LocationsController;
begin
	if _ti = null then
		return "";
	endif;
	

	if _ti.isZombie() then // ### TFS 53105 13JUN2022 NAVAB1
		return "S99_RETIRED"; // ### TFS 53105 13JUN2022 NAVAB1
	elseif _ti.isOffSite() then
		return "S70_DEPARTED";
	elseif _ti.releasedTransportMode &lt;&gt; 0 then
		return "S60_LOADED";
	elseif _ti.isOnTransport() or _ti.isOnTrailer() then
		lc := _ti.myPrimaryActualLocation; // ### TFS 51855 25MAY2022 NAVAB1
		if _ti.getRailWLEForLC(true, lc) &lt;&gt; null then // is on transport, does it have a rail load job? // ### TFS 51855 25MAY2022 NAVAB1
			return "S60_LOADED"; // ### TFS 51855 25MAY2022 NAVAB1
		elseif _ti.getRoadReleaseJob(null) &lt;&gt; null then // is on transport, does it have a road load job? // ### TFS 51855 25MAY2022 NAVAB1
			return "S60_LOADED"; // ### TFS 51855 25MAY2022 NAVAB1
		else // ### TFS 51855 25MAY2022 NAVAB1
			if _ti.isTransportWorking() then // ### TFS 53105 08JUN2022 NAVAB1
				if _ti.releasedTransportMode = 0 then
					return "S20_INBOUND";
				else
					return "S60_LOADED";
				endif;
			else // ### TFS 53105 08JUN2022 NAVAB1
				return "S20_INBOUND"; // ### TFS 53105 17JUN2022 NAVAB1
 // ### TFS 53105 17JUN2022 NAVAB1				return "S10_ADVISED"; // ### TFS 53105 08JUN2022 NAVAB1
			endif;
		endif;
	elseif _ti.isOnSite then
		return "S40_YARD";
	elseif _ti.isPreNote then
		if _ti.receiptTransportMode = TI_TRANSMODE_SHIP then // ### TFS 53105 29JUL2022 NAVAB1
			return "S20_INBOUND"; // ### TFS 53105 29JUL2022 NAVAB1
		else // ### TFS 53105 29JUL2022 NAVAB1
			return "S10_ADVISED";
		
		endif;
	endif;
	
	return "";
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4TruckVisitStatus" id="bc1e139f-012f-47fc-9f80-09278e75b231">
        <source>n4TruckVisitStatus(_vvr : CM_VehicleVisitRecord input) : String;
/*
Purpose:			

Date		Who		Reason
26 August 2021	navab1	TFS 51853
*/

vars

begin
	if _vvr.status = CM_VehicleVisitRecord.Status_Cancelled then
		return CMIF_OpsViewTables.Truck_Visit_Cancel;
	elseif _vvr.status = CM_VehicleVisitRecord.Status_Complete then
		return CMIF_OpsViewTables.Truck_Visit_Complete;
	elseif _vvr.status = CM_VehicleVisitRecord.Status_Trouble then
		return CMIF_OpsViewTables.Truck_Visit_Cancel;
	elseif _vvr.status = CM_VehicleVisitRecord.Status_Unactioned then
		return CMIF_OpsViewTables.Truck_Visit_Ok;
	elseif _vvr.status = CM_VehicleVisitRecord.Status_Unverified then // Default status
		return CMIF_OpsViewTables.Truck_Visit_Ok;
	elseif _vvr.status = CM_VehicleVisitRecord.Status_Yard then
		return CMIF_OpsViewTables.Truck_Visit_Ok;
		
	endif;
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4VisitState" id="2717b2ce-704e-44a7-a0cb-36c156af59ff">
        <source>n4VisitState(_ti : CM_TrackedItem) : String;
/*
Purpose:			

Date		Who		Reason
20 December 2021	navab1	TFS 51855
*/

vars

begin
	if _ti = null then
		return "";
	endif;
	
	if _ti.isOffSite() then
		return "3DEPARTED";
	elseif _ti.isOnSite then
		return "1ACTIVE";
	elseif _ti.isOnShip then  // ### TFS 51855 24JAN2022 NAVAB1
	/* // ### TFS 53105 29JUL2022 NAVAB1
		if _ti.myVoyage.isStatusWorking() then // ### TFS 53105 08JUN2022 NAVAB1
			return "1ACTIVE";  // ### TFS 51855 24JAN2022 NAVAB1
		else
			return "2ADVISED"; // ### TFS 53105 08JUN2022 NAVAB1
		endif;
		*/
		return "1ACTIVE";  // ### TFS 53105 29JUL2022 NAVAB1 always ACTIVE even when just created.
	elseif _ti.isPreNote then
		if _ti.receiptTransportMode = TI_TRANSMODE_SHIP then // ### TFS 53105 29JUL2022 NAVAB1
			return "1ACTIVE"; // ### TFS 53105 29JUL2022 NAVAB1
		else // ### TFS 53105 29JUL2022 NAVAB1
			return "2ADVISED";
		endif;
	endif;
	
	return "";
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4VoyageClassification" id="06ee11cc-1543-436a-a75a-ae3d2552dbf3">
        <source>n4VoyageClassification(_voyage : CM_Voyage):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/
vars
	
begin
	if _voyage.myHMSVoyageData &lt;&gt; null  // ### TFS 53105 17JUN2022 NAVAB1
	and _voyage.myHMSVoyageData.myVesselType &lt;&gt; null then // ### TFS 53105 17JUN2022 NAVAB1
		return _voyage.myHMSVoyageData.myVesselType.code; // ### TFS 53105 17JUN2022 NAVAB1
	else
		if _voyage.isBarge then
			return self.CLASS_FEEDER;
		else
			return self.CLASS_DEEPSEA;
		endif;
	endif;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4VoyageStatus" id="bf53bb66-2624-48c0-9e36-9e87a74834dc">
        <source>n4VoyageStatus(_status : Integer): String;
/*

10CREATED
20INBOUND
30ARRIVED
40WORKING
50COMPLETE
60DEPARTED
70CLOSED
80CANCELED

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
12 APR 2022 NAVAB1 TFS 53411 - added departure status and also added the Work Order voyage statuses so that bothe voyage processes are covered.
*/
vars
	status : String;
begin

	if _status =  Voyage_Status_Pending then 
		return "10CREATED"; // ### TFS 51855 09FEB2022 NAVAB1
	elseif _status =  Voyage_Status_Arrived then 
		return "30ARRIVED"; // ### TFS 51855 09FEB2022 NAVAB1
	elseif _status =  Voyage_Status_Loading then
		return "40WORKING"; // ### TFS 51855 09FEB2022 NAVAB1
	elseif _status = Voyage_Status_LoadComplete then
		return "50COMPLETE"; // ### TFS 51855 09FEB2022 NAVAB1
	elseif _status = Voyage_Status_Closed then
		return "50COMPLETE"; // ### TFS 51855 09FEB2022 NAVAB1
	elseif _status = Voyage_Status_Cancelled then 
		return "80CANCELED"; // ### TFS 51855 09FEB2022 NAVAB1
	elseif _status = Voyage_Status_Departed then // ### TFS 53411 12APR2022 NAVAB1
		return "60DEPARTED"; // ### TFS 53411 12APR2022 NAVAB1
	elseif _status = Voyage_Status_Archived then 
		return "ARCHIVED";
	endif;
	
	
end;
</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="n4VoyageStatusWO" id="d9fbd963-12d2-41e6-9a99-a129e102f26c">
        <source>n4VoyageStatusWO(_status : Integer): String;
/*

10CREATED
20INBOUND
30ARRIVED
40WORKING
50COMPLETE
60DEPARTED
70CLOSED
80CANCELED

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 APR 2022 NAVAB1 TFS 53411 - added departure status and also added the Work Order voyage statuses so that bothe voyage processes are covered.
*/
vars
	status : String;
begin

	if _status &lt;= Voyage_Status_VoyageApproved then 
		return "10CREATED"; 
	elseif _status =  Voyage_Status_VoyageArrived then 
		return "30ARRIVED"; 
	elseif _status &lt;= Voyage_Status_ServTaxInvGen then
		return "40WORKING"; 
	elseif _status = Voyage_Status_VesselDeparted then 
		return "60DEPARTED"; 
	elseif _status = Voyage_Status_VesselArchived then 
		return "ARCHIVED";
	elseif _status = Voyage_Status_VoyCancelled then 
		return "80CANCELED"; 
	endif;
	
	
end;
</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
