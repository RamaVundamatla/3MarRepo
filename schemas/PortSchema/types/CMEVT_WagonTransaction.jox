Return Value:		

Date		Who		Reason
22 February 2021	navndl1	Initial creation	TFS 50835

*/

vars

begin
	return CM_TISnapShot;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getSourceTA" id="e6901dba-f32c-406e-968b-640e02851b1d">
        <source>getSourceTA() : CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2021	navndl1	Initial creation	TFS 50964 - ASPA reportwriter use

*/

vars

	strs : StringArray;
	str : String;
	ta : CM_TerminalArea;

begin

	if self.sourceLocn = null then
		return null;
	endif;
	
	create strs transient;
	self.sourceLocn.getTokensForDelimiter(Space,strs);
	str := strs[1].toUpper; 
	ta := self.getTerminal.allTerminalAreas[str];
	
	return ta;
	
epilog

	delete strs;

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getTIDescription" id="20f1c492-fc45-478f-aab1-43fe416b0b77">
        <source>getTIDescription() : String;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by cnwab1
//
/*

Date		Who		Reason
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
05 Dec 2024 navma1	 MTN-33567 MTN - Charges Are Not Created When adding Events
*/

vars
	invalidObject 	: Boolean;
	returnVal		: String;
	ti				: CM_TrackedItem;
begin
	
	ti := self.myTrackedItem;
	
	if ti = null then
		return "&lt;" &amp; app.getErrorString(Unknown) &amp; "&gt;";
	endif;

	on Exception do app.handleDeletedObject(exception,ti,invalidObject);

	returnVal := ti.myCargoType.description &amp; " " &amp; ti.id;
	
	if invalidObject then
		return "&lt;" &amp; app.getErrorString(Unknown) &amp; "&gt;";
	else
		return returnVal;
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
