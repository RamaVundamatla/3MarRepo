        <source>lbxVoyTerminals_gotFocus(listbox: ListBox input) updating;
//--------------------------------------------------------------
//Created: 07 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if lbxVoyTerminals.listIndex &lt; 0 
	and lbxVoyTerminals.listCount &gt; 0 then // added re par 11552
