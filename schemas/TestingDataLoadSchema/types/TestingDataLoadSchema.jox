    <JadeMethod name="getInputDate" id="d6283082-393f-4546-b543-8b0fe4918a68">
        <source>getInputDate(_date : Date io; _text : String) : Boolean;

/*

Purpose:		Gets an input date	


Date			Who		Reason
27/02/2013		cnwmh5	Initial creation

*/

vars

	inputStr						: String;
	captionTxt						: String;

begin

	captionTxt := "Date Error";
	if _text.trimBlanks() &lt;&gt; null then
		captionTxt := _text.trimBlanks() &amp; " " &amp; captionTxt;
	endif;

	inputStr := _date.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		app.msgBox("Cancelling", captionTxt, MsgBox_OK_Only + MsgBox_Information_Icon);
		return true;
	endif;

	// return the date
	if inputStr.trimBlanks().length = 10 then
		_date := inputStr.trimBlanks().Date;
	elseif inputStr.trimBlanks().length = 8 then
		_date := (inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date;
	endif;
	
	if not _date.isValid() then
		app.msgBox("Cancelling", captionTxt, MsgBox_OK_Only + MsgBox_Information_Icon);
		return true;
	endif;

	return false;
	
epilog

end;</source>
        <Parameter name="_date" type="Date" usage="io"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNextRunDate" id="c52a64d5-f73c-4f18-ad4d-8ff72f1023d9">
        <source>getNextRunDate(_currentTimeStamp : TimeStamp io; _runDaysOfWeekArray, _runTimesArray : StringArray) : Integer;

/*

Purpose:		Get the date and dayOfWeekIndex for the next run date	

Date		Who		Reason
01 April 2011	cnwmh5	Initial creation

*/

vars

	dayOfWeek		: Integer;
	dayOfWeekIndex	: Integer;
	
begin
	
	// check the run day of week.  If empty then use today, if in array use this else workout when next one will be
	if not _runDaysOfWeekArray.isEmpty() then
		while true do
			dayOfWeek := _currentTimeStamp.date.dayOfWeek();
			dayOfWeekIndex := _runDaysOfWeekArray.indexOf(dayOfWeek.String);
			if dayOfWeekIndex &gt; 0 then
				break;
			endif;
			_currentTimeStamp := _currentTimeStamp.addDays(1);
		endwhile;
	else
		dayOfWeekIndex := _currentTimeStamp.date.dayOfWeek();
	endif;
	
	return dayOfWeekIndex;
	
epilog

end;</source>
        <Parameter name="_currentTimeStamp" type="TimeStamp" usage="io"/>
        <Parameter name="_runDaysOfWeekArray" type="StringArray"/>
        <Parameter name="_runTimesArray" type="StringArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getProfile" id="a3024f18-744c-486b-9bd9-e6da9be9d5c4">
        <source>getProfile(_name: String; _profile: UT_Profile output);
//05 April 2009	cnwdw1	
//
vars
	portSchema: Schema;
	profileClass: Class;
begin
	portSchema := rootSchema.getSchema("PortSchema");
	if portSchema &lt;&gt; null then
		profileClass := portSchema.getClass("UT_Profile"&amp;_name);
		if profileClass &lt;&gt; null then
			create _profile as profileClass transient;
			_profile.initialize();
		endif;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_profile" type="UT_Profile" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSystemName" id="1fc85327-f242-4e32-8a5c-231f9089ae75">
        <source>getSystemName(_systemNameType : Integer) : String;

/*

Purpose:		Return the System Name	
				0 - full name 		e.g. 8.1.1 CNWWMAST
				1 - Alpha			e.g. CNWWMAST
				2 - Numeric			e.g. 8.1.1

Date			Who		Reason
26 June 2012	cnwmh5	Initial creation

*/
vars

	systemName 			: String;

begin
	
	systemName := app.myRoot.getConfig(SystemTitle).String;
	
	if _systemNameType = 0 then
		// do nothing
	elseif _systemNameType = 1 then
		systemName := systemName[systemName.pos(" ", 1) + 1:end].trimBlanks();
	elseif _systemNameType = 2 then
		systemName := systemName[1:systemName.pos(" ", 1)].trimBlanks();
	endif;
	
	return systemName;
	
epilog

end;</source>
        <Parameter name="_systemNameType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTSForNextScheduledRun" id="532177ca-7321-4e4d-97ce-89bc7edd9f4e">
        <source>getTSForNextScheduledRun(_currentTimeStamp : TimeStamp; _runDayOfWeekArray, _runTimesArray : StringArray) : TimeStamp;

/*

Purpose:		Get the next scheduled run date and time	

Date			Who		Reason
01 April 2011	cnwmh5	Initial creation

*/
constants
	
	DEFAULT_TIME = "05:00:00".Time;
	
vars

	dayOfWeekIndex	: Integer;
	currentTS		: TimeStamp;
	runTime			: String;

begin

	currentTS := _currentTimeStamp;

	// get the date for the next day of the week
	dayOfWeekIndex := self.getNextRunDate(currentTS, _runDayOfWeekArray, _runTimesArray);
	
	// get the time to run
	if _runTimesArray.isEmpty() then
		currentTS.setTime(DEFAULT_TIME);
	else
		if dayOfWeekIndex &gt; _runTimesArray.size then
			runTime := _runTimesArray[1];
		else
			runTime := _runTimesArray[dayOfWeekIndex];
		endif;
		if runTime = null or not runTime.Time.isValid() then
			currentTS.setTime(DEFAULT_TIME);
		else
			currentTS.setTime(runTime.Time);
		endif;
		if _currentTimeStamp.date = currentTS.date and _currentTimeStamp.time &gt; currentTS.time then
			currentTS := currentTS.addDays(1);
			self.getNextRunDate(currentTS, _runDayOfWeekArray, _runTimesArray);
		endif;
	endif;
	
	return currentTS;	

epilog

end;</source>
        <Parameter name="_currentTimeStamp" type="TimeStamp"/>
        <Parameter name="_runDayOfWeekArray" type="StringArray"/>
        <Parameter name="_runTimesArray" type="StringArray"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getThinClientCommandLine" id="a5f32158-b86b-4caa-947b-fbd7567781b2">
        <source>getThinClientCommandLine(): String;
constants
	UserDelimiter	: String	= 'endJade';
	
vars
	commandLine,
	userData	: String;
	userStart,
	pos			: Integer;

begin
	commandLine := process.getCommandLine();	
    pos := 1;
    pos := commandLine.pos(UserDelimiter, pos);
	if pos = 0 then												// Allow for managed environments where endJade is all lower case
		pos := 1;
		pos := commandLine.pos(UserDelimiter.toLower, pos);
	endif;
    if pos &gt; 0 then
    	userStart	:= pos + UserDelimiter.length + 1;
    	if commandLine.length &gt;= userStart then
	    	userData := commandLine[userStart : end];
	    endif;
	endif;
	return userData;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleFileTruncatedRec" id="7f37837f-fea2-43d2-808e-4f0e2709df1a">
        <source>handleFileTruncatedRec(_exc : Exception) : Integer;

/*

Purpose:		Handle Record truncated to maxRecordSize characters error

Date			Who		Reason
17/03/2015		cnwmh5	Initial creation

*/

vars
	returnVal				: Integer;
begin

	returnVal := Ex_Pass_Back;

	if _exc.errorCode = 5011 then
		returnVal := Ex_Resume_Next;	
	endif;

	return returnVal;
	
epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
