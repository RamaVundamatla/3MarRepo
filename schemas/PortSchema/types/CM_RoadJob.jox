//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin 
	return self.allWorkingDeviceIDs.cnEcIsNotEmpty();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
