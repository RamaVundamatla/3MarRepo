    <JadeMethod name="setupForm" id="56310d0b-e759-45a2-ad48-9ef61d9eebf6">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	index : Integer;
	control : Control;

begin

	
	
	self.tblReeferWalkBlocks.columns := 1;
	self.tblReeferWalkBlocks.fixedColumns := 0;
	self.tblReeferWalkBlocks.rows := 1;
	self.tblReeferWalkBlocks.fixedRows := 1;
	self.tblReeferWalkBlocks.setCellText( 1, 1, app.getErrorString( Block_name ) );
	self.tblReeferWalkBlocks.selectMode := CM_DataTable.SelectMode_Single;
	
	self.mulWalkPositions.formDisplayEntryMethodName := SOP_ReeferWalkPathForm::displayWalkPositionAvail.name;
	self.mulWalkPositions.mySelectedListBox.formDisplayEntryMethodName := SOP_ReeferWalkPathForm::displayWalkPositionSel.name;
	self.mulWalkPositions.availableHeading := app.getErrorString(All_Positions);
	self.mulWalkPositions.selectedHeading := app.getErrorString(Selected_positions_order);
	self.mulWalkPositions.mySelectedListBox.sorted := false;
	self.mulWalkPositions.setVisibleButtons(true,true,true);
	self.mulWalkPositions.multiSelect := ListBox.MultiSelect_Extended;
	
	inheritMethod();
	
	self.minimumWidth := 572;
	self.minimumHeight := 675;
	
	self.handleMenusForModalDisplay();
	
	self.populateCmbGriddedAreas();
	self.doClickCmbGriddedArea();
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblReeferWalkBlocks_click" id="12edded0-3d1a-4ba6-9d94-b12ab2f197fc">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReeferWalkBlocks_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	rowIndex : Integer;

begin

	
	if self.myProxyReeferBlock &lt;&gt; null then
		delete self.myProxyReeferBlock;
		self.myProxyReeferBlock := null;
	endif;

	rowIndex := self.tblReeferWalkBlocks.row;
	self.mySelectedReeferBlock := self.tblReeferWalkBlocks.accessRow( rowIndex ).itemObject.CM_ReeferBlock;
	
	if self.mySelectedReeferBlock &lt;&gt; null then
		self.myProxyReeferBlock := app.createUpdateProxy( self.mySelectedReeferBlock ).CM_ReeferBlock;
		self.populateReeferWalkPositions();
	endif;
	
	self.setButtons();

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="fe9bd512-ed4f-4e73-b9f8-77c8f0c2c0e5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 July 2020 09:07:34.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023958, locale);
	btnAdd.translateCaption(Xlat_0023959, locale);
	btnDelete.translateCaption(Xlat_0023960, locale);
	btnUpdate.translateCaption(Xlat_0023961, locale);
	lblGridArea.translateCaption(Xlat_0023962, locale);
	lblName.translateCaption(Xlat_0023963, locale);
	lblSelect.translateCaption(Xlat_0023964, locale);
	mulWalkPositions.translateCaption(Xlat_0023965, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="959fdaec-71d7-44ef-8084-a3bcb5a030e8">
        <controlMethod name="Form::unload"/>
