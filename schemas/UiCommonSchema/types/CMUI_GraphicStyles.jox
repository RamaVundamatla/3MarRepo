    <JadeMethod name="setControlsForProxy" id="be84e186-1885-4c17-b3a1-e0361485a362">
        <source>setControlsForProxy();
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/

vars

begin
	if self.myCurrentDeckItemLayout = null then
		return;
	endif;
	
	self.doDrawFrameDemos(self.myCurrentDeckItemLayout.drawWidth,self.myCurrentDeckItemLayout.drawLineColour,self.myCurrentDeckItemLayout.drawFillColour); //draw the "insides" of the frames
	self.doLoadSelectedControls();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setToolbars" id="15b1d484-6397-4edd-8688-9e1e7dbf48fc">
        <source>setToolbars();
/*
Date		    Who			Reason
06 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	deckToolbar, fillToolbar, lineToolbar : CMUI_Toolbar;
begin
	
	
	
	deckToolbar := self.frmToolbar;
	fillToolbar := self.toolbarFillStyle;
	lineToolbar := self.toolbarLineStyle;		
	
	deckToolbar.visible := true;		
		
	fillToolbar.visible := true;	
	fillToolbar.top := 13;	
	fillToolbar.distanceFromRight := 1;
	fillToolbar.left := 2;	
	fillToolbar.bevelColor := self.backColor;		
	
	lineToolbar.visible := true;
	lineToolbar.top := 14;	
	lineToolbar.left := 2;
	lineToolbar.distanceFromRight := 1;	
	lineToolbar.bevelColor := self.backColor;	
	
	toolbarLineWidth.visible := true;
	toolbarLineWidth.top := 45;	
	toolbarLineWidth.left := 2;
	toolbarLineWidth.distanceFromRight := 1;	
	toolbarLineWidth.bevelColor := self.backColor;	

	self.doLoadSelectedControls();	//select the styles of the fills and lines, according to the settings of the proxy

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f93cc0e4-eead-4820-828d-b46513bba147">
        <updating/>
        <source>setupForm() updating;
/*
Date		    Who			Reason
04 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	inheritMethod();
	
	self.caption := self.myCurrentDeckItemLayout.code &amp; " - " &amp; self.caption;
	
	self.toolbarStyle	:= self.ToolbarStyle_ShowAllowHide;
	self.showToolbar 	:= true;	
	
	self.height := self.FORM_HEIGHT;
	self.width := self.FORM_WIDTH;
	self.borderStyle := 1;
	
	self.grpFillStyle.top := 4;
	self.grpFillStyle.left := 4;
	self.grpLineStyle.top := self.grpFillStyle.top + self.grpFillStyle.height + 3;
	self.grpLineStyle.left := self.grpFillStyle.left;
	
	self.addFormsToCollection();	
	self.addButtonsToForm();
	
	self.mnuFile.visible := false;
	self.mnuHelp.visible := false;
	self.mnuOptions.visible := false;
	self.mnuWindows.visible := false;
	self.mnuTerminal.visible := false;
	self.mnuView1.visible := false;
	
	self.backColor := self.frmToolbar.backColor;	
	
	self.setupFrames();
	self.doIgnoreSkin(); // PAR 27595
	self.doDrawFrameDemos(self.myCurrentDeckItemLayout.drawWidth,self.myCurrentDeckItemLayout.drawLineColour,self.myCurrentDeckItemLayout.drawFillColour); //draw the "insides" of the frames
	
	self.beginNotification(self, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFrames" id="da93ae48-8763-41e1-b2c5-534acd077ef7">
        <source>setupFrames();
/*
Date		    Who			Reason
07 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	frm : CMUI_Frame;
	cntrl : Control;
begin
	
	foreach cntrl in self.allControlsByName where cntrl.isA(CMUI_Frame) and cntrl.parent.isA(CMUI_GroupBox) do
		frm:=cntrl.CMUI_Frame;
		frm.bevelInner := 2;
		frm.bevelInnerWidth := 1;		
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8d1103a4-298f-4a84-a46c-2b669f8d9f1f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:41:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016064, locale);
	btnLineWidth1.translateCaption(Xlat_0016065, locale);
	btnLineWidth2.translateCaption(Xlat_0016066, locale);
	btnLineWidth3.translateCaption(Xlat_0016067, locale);
	btnLineWidth4.translateCaption(Xlat_0016068, locale);
//	frmFillStyle1.translateCaption(Xlat_0023268, locale);
//	frmFillStyle2.translateCaption(Xlat_0023269, locale);
//	frmFillStyle3.translateCaption(Xlat_0023270, locale);
//	frmFillStyle4.translateCaption(Xlat_0023271, locale);
//	frmFillStyle5.translateCaption(Xlat_0023272, locale);
//	frmFillStyle6.translateCaption(Xlat_0023273, locale);
//	frmFillStyle7.translateCaption(Xlat_0023274, locale);
	frmFillStyle8.translateCaption(Xlat_0016069, locale);
//	frmLineStyle1.translateCaption(Xlat_0023275, locale);
//	frmLineStyle2.translateCaption(Xlat_0023276, locale);
//	frmLineStyle3.translateCaption(Xlat_0023277, locale);
//	frmLineStyle4.translateCaption(Xlat_0023278, locale);
//	frmLineStyle5.translateCaption(Xlat_0023279, locale);
	frmLineStyle6.translateCaption(Xlat_0016070, locale);
	grpFillStyle.translateCaption(Xlat_0016071, locale);
	grpLineStyle.translateCaption(Xlat_0016072, locale);
	lblLineWidth.translateCaption(Xlat_0016073, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="c87e0f4e-310d-4fc0-83bc-ebd1cd1c3987">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/

vars

begin
	if self.myParentForm &lt;&gt; null then
		self.myParentForm.setPropertyValue("myUIStylesFrame",null);
		
		// PAR 27595
		if self.myParentForm.myParentForm &lt;&gt; null then
			self.myParentForm.myParentForm.setPropertyValue("myUIStylesFrame",null); 
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="efaef3d5-ebeb-4d66-b037-46312a6bd645">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/

vars
	
begin
	if eventType = EVENT_RORO_ITEM_SELECT then
		self.myCurrentDeckItemLayout := userInfo.CM_DeckItemLayout;
		self.setControlsForProxy();
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
