    <JadeMethod name="visible" id="4d6061c2-0fbc-49fe-b4db-f9cd17628555">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>visible(set: Boolean; value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     26 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

// PARYSS 22035 - isInPainter not returning correct value in painter
// so resize is called which results in an error - RJS Jul01
//	if (not self.isInPainter) then
//	endif;
//  .... so check process.type instead ...
	if process.type = '2' or 	// A non-development process (that is, a user application running from a non-production mode database)
	   process.type = '3' or	// A production process (that is, a user application running from a production mode database)
	   process.type = '4' then	// JADE Debugger

		if set and value then
			self.cnEcResizeContents();
		endif;
	   	
	endif;

	inheritMethod(set, value);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="414b9826-c24c-4e2c-81f0-c38afd4b0b31">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 14/09/2009	cnwcs5		According to Doug we are not using fixed3D for tables anymore
vars

begin
//	self.msSelectRows := true; // DEFAULT

/*
if process.isCnwab1 then	

	self.beginNotification(self, SelectionEvent, Response_Continuous, 33);
	self.msNotificationStarted := true;
endif;	
*/	
	inheritMethod(cntrl, persistCntrl);

/*
	if lockRight or stretchWidth then
 		self.distanceFromRight := persistCntrl.parent.width - persistCntrl.width - persistCntrl.left;
 	endif;

	if lockBottom or stretchHeight then
		self.distanceFromBottom := persistCntrl.parent.height - persistCntrl.height - persistCntrl.top;
	endif;
*/
	self.fixed3D := false;	// cnwcs5 - 14/09/2009
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <DevControlTypes name="CM_BaseTable">
        <bitmap></bitmap>
        <windowClass>AlTable</windowClass>
        <DevControlProperties name="allowDrag">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Rows</value>
                <value>2 - Columns</value>
                <value>3 - Both</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="allowResize">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - any</value>
                <value>1 - Column Width Resize Only</value>
                <value>2 - Row Height Resize Only</value>
                <value>3 - No resize allowed</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="autoSize">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Row</value>
                <value>2 - Column</value>
                <value>3 - Both</value>
                <value>4 - Column Minimum</value>
                <value>5 - Both, column Minimum</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="backBrush">
            <cntrlType>picture</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrushStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - tile</value>
                <value>1 - stretch</value>
                <value>2 - center</value>
                <value>3 - stretch proportional</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="backColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderColorSingle">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="borderStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Fixed single</value>
                <value>2 - Sizable</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="bubbleHelp">
            <cntrlType>multilined-string</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="columns">
            <cntrlType>integer</cntrlType>
