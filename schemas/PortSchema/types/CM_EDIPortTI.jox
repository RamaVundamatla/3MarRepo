<Class name="CM_EDIPortTI" id="f026dd13-37ba-475e-ae95-fbe53e63907c">
    <superclass name="CM_EDIVoyageConsistTI"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <CompAttribute name="allTranshipPortCodes" id="3422a1f9-0511-4784-ac7e-c0f937ca6bee">
        <type name="StringArray"/>
    </CompAttribute>
    <JadeMethod name="addTranshipPortCodes" id="d7d51d53-a8b6-4016-95d0-eeedabbd4a0c">
        <source>addTranshipPortCodes(_value: String);
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 14 September 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 14/09/2010	cnwsh3		PAR25736 - moved code from CM_EDIDFieldMapping.assignValueSpecial here.
//----------------------------------------------------------------------
vars
	len,
	pos 		: Integer;
	portCode,
	delimiter	: String;
begin
	if _value = null then
		return;
	endif;
	len := _value.length;
	pos := 1;
	while true do
		portCode := _value.getDelimitedToken(pos, ' ', delimiter);
		self.allTranshipPortCodes.add(portCode);
		if pos &gt; len then
			break;
		endif;
	endwhile;
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="e122f9ea-13a3-45f2-a017-7363568a1576">
        <source>canUserSet(_propName: String): Boolean;

vars

begin
	if _propName = CM_EDIPortTI::allTranshipPortCodes.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="650dfbed-cb16-42dd-9efa-3ad8cf6e13c8">
        <updating/>
        <source>create() updating;

vars

begin
	self.messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
	self.messageNum := 1;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4a1259b3-0db9-4ee0-9fab-4038677ff825">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

vars
	str : String;
	strReturn : String;
begin
	if _attrName = ETRow_TranshipPortCodes then
		foreach str in self.allTranshipPortCodes do
			if strReturn = null then
				strReturn := str;	
			else
				strReturn := strReturn &amp; ";" &amp; str;
			endif;
		endforeach;
		return strReturn;
	endif;
	return inheritMethod(_attrName, _short);
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="0d2a5f8e-1fed-47f5-8781-53ccad6670f3">
        <source>getMyTIDisplayDefName(): String;

vars

begin
	return inheritMethod();
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueSpecial" id="6d4dab0b-30c1-448a-8059-f88e57b6a36d">
        <source>getValueSpecial(_propName: String; _xlationOperator: CM_Operator): String;
//
// 16 Jan 2012	MSL CCMS 1009 PAR 29024
//
vars
	str : String;
	returnValue : String;
begin
	if _propName = ETRow_TranshipPortCodes then  //PAR25736 cnwsh3 14/09/2010 - an earlier piece of code relating to tranship port codes moved here
		if self.allTranshipPortCodes &lt;&gt; null then
			foreach str in self.allTranshipPortCodes do
				if returnValue = null then
					returnValue := str;
				else
					returnValue := returnValue &amp; ' '&amp; str;
				endif;
			endforeach;
		endif;
		return returnValue;
	else
		return inheritMethod(_propName, _xlationOperator);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processAttributeDependencies" id="f2125587-fa4e-4f5c-87a2-0145bb9553a7">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// Date			Who		Reason
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars

begin
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	if _reset then 
		if self.myEDIData.isKindOf(CM_EDIDataVoyage) then
			_ediUserDefinedAssist.currentPortPosition := null;
		endif;
	else
		if self.myEDIData.isKindOf(CM_EDIDataVoyage) then
	//		if self.voyageCode = null then			// cnwrl1 10/06/2010 PAR 24299 - what it was
			if self.getVoyageCode() = null then
	//			self.voyageCode := _ediUserDefinedAssist.currentVoyageCode;	// cnwrl1 10/06/2010 PAR 24299 - what it was
				self.setVoyageCode( _ediUserDefinedAssist.currentVoyageCode );
			endif;
			_ediUserDefinedAssist.currentPortPosition := _ediUserDefinedAssist.currentPortPosition + 1;
			self.position := _ediUserDefinedAssist.currentPortPosition;
		endif;
	endif;
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="51adb828-9b37-4fa2-955e-2b9183e7fb0d">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// 30 Apr 2012	 cnwrs1	Parxxxx
//
vars

begin
	inheritMethod(_proxyEDITI);
	self.allTranshipPortCodes.clear;
	_proxyEDITI.allTranshipPortCodes.copy(self.allTranshipPortCodes);
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setTranshipPortCodes" id="77b5838f-c276-4c0d-9eb9-0a5f6dee6558">
        <source>setTranshipPortCodes(_codes: String);
//
// 30 Apr 2012	 cnwrs1	Parxxxx
//
vars
	len,
	pos 		: Integer;
	portCode,
	delimiter	: String;
begin
	if _codes = null then
		return;
	endif;
	self.allTranshipPortCodes.clear;
	len := _codes.length;
	pos := 1;
	while true do
		portCode := _codes.getDelimitedToken(pos, ';', delimiter);
		if portCode &lt;&gt; null and
		   not self.allTranshipPortCodes.includes(portCode) then
			self.allTranshipPortCodes.add(portCode);
		endif;
		if pos &gt; len then
			break;
		endif;
	endwhile;
end;
</source>
        <Parameter name="_codes" type="String"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="8c09f69c-1efa-4d89-984b-0eeb3f170359">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
*/
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
