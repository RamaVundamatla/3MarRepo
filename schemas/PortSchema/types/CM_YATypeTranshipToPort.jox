    <JadeMethod name="getAllCriteriaValues" id="b7871287-6d82-428d-b9ff-28b31c75092f">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs : CM_ObjectArray);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation
17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
*/

vars

begin
	
	app.myRoot.allActiveDestinations.copy(_allCriteriaValues);


epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="3488a67e-9ee0-47bf-910e-b5edb51a53f3">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/

vars

begin
	_criteriaObject := app.myRoot.allPorts[_ti.dischargePort];
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValuesForVoyage" id="8b0746df-37a9-423e-8cce-96fadf62ac80">
        <source>getCriteriaValuesForVoyage(_voyage: CM_Voyage; _criteriaValues: ObjectSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/



vars
	
	transhipPort 	: CM_Port;
	portRotation : CM_PortRotation;
	
begin
	
	
	_criteriaValues.clear();
	
	if _voyage = null then 
		return;
	endif;
	
	foreach portRotation in _voyage.allPortRotations discreteLock where not portRotation.allTranshipPorts.isEmpty() do
		foreach transhipPort in portRotation.allTranshipPorts discreteLock do			
			if not _criteriaValues.includes(transhipPort) and app.myRoot.allActiveDestinations.includes(transhipPort) then									
				_criteriaValues.add( transhipPort );
			endif;
		endforeach;
	endforeach;

epilog
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_criteriaValues" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValuesVoyDischarge" id="e805b1b0-ac2f-49af-b327-356a96730517">
        <source>getCriteriaValuesVoyDischarge(_dischargePort: CM_Port; _voyage: CM_Voyage; _criteriaValues: ObjectSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/

vars
	port : CM_Port;
	portRotation	: CM_PortRotation;
begin
	_criteriaValues.clear;
	if _voyage = null then 
		self.getAllCriteriaValues(app.getMyTerminalDO_NOT_USE(),_criteriaValues,YAFilterOpt_None, null);	//cnwmc5 - PAR 31255
		return;
	endif;
	if _dischargePort &lt;&gt; null then
		foreach portRotation in	_voyage.allPortRotations discreteLock where portRotation.myPort=_dischargePort do
			foreach port in portRotation.allTranshipPorts discreteLock where app.myRoot.allActiveDestinations.includes(port) do
				if not _criteriaValues.includes(port) then									//+cnwml2	PAR21370
					_criteriaValues.add( port );
				endif;
			endforeach;
		endforeach;
	else
		self.getCriteriaValuesForVoyage(_voyage,_criteriaValues);
	endif;

epilog

end;</source>
        <Parameter name="_dischargePort" type="CM_Port"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_criteriaValues" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="e40c3e5e-7238-420a-b740-40373cda5f8b">
        <source>getDataDisplay(pDataObj: CM_YAData): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/

vars

begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);

epilog

end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionWithData" id="e9a4ea8e-78b5-45d0-9f5b-79cafe1978dd">
        <source>getDescriptionWithData(_dataObj: CM_YAData): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/

vars

begin
	//return self.getTypeName() &amp; ": " &amp; self.getDataDisplay(_dataObj);
	return self.description &amp; ": " &amp; self.getDataDisplay(_dataObj);	//09 Oct 2013	NDL	Par 32456

epilog

end;</source>
        <Parameter name="_dataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
