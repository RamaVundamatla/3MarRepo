    <JadeMethod name="handleMouseDownEvent" id="da4fa89d-7eb9-4644-ad6a-d2415d789b4a">
        <updating/>
        <source>handleMouseDownEvent(button: Integer; shift: Integer; x: Real; y: Real) updating;
vars
	pnt	: CMUI_GridPoint;
	frame : Frame;
begin
	self.myGridArea.allSelectedPoints.clear();

	foreach pnt in self.allGridPointsByRow do
		self.myGridArea.allSelectedPoints.add(pnt);
	endforeach;
	
	self.myGridArea.drawSelf();

	if button = 2 then
		frame := self.myGridArea.myGridAreaFrame;
// 		PAR 9036 changed this slightly		
//		self.myGridArea.myGridAreaFrame.form.SOP_TerminalAreaDefForm.showGridFrameContextMenu(x.Integer, y.Integer, true);
		frame.form.SOP_TerminalAreaDefForm.showGridFrameContextMenu(x.Integer, y.Integer, false);
	else
		self.myGridArea.myGridAreaFrame.form.SOP_TerminalAreaDefForm.setButtonPenLabels();
	endif;
end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="maxWidth" id="bec4a02a-650f-4326-832d-b189dd8126d1">
        <methodInvocation>mapping</methodInvocation>
        <source>maxWidth(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpGridPoint	: CMUI_GridPoint;
	theWidth			: Integer;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	foreach tmpGridPoint in self.allGridPointsByRow do
		theWidth := tmpGridPoint.SOP_GridPoint.myGridController.width.Integer.max(1);	//minimum display width of 1;
		_value := _value.max(theWidth);
	endforeach;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
