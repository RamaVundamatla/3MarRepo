    <JadeMethod name="utlCreateProduct" id="d4d7c43c-2669-4fb9-8604-d12881b97f6b">
        <source>utlCreateProduct(_proxyProduct :CM_Product; _newProduct:CM_Product output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave 		: Boolean;
	product			: CM_Product;
	operator		: CM_Operator;
	newCode,
	typeCode		: CM_ProductAttributeCode;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valProduct(_proxyProduct);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newProduct as _proxyProduct.class persistent;
	_newProduct.setForCreate(_proxyProduct);
	
	if (not _passport.noErrors) then
		return;
	endif;
	//copy any new type codes to all other products for this produt's operator
	//N.B may have to do this for other product attributes that have codes in the future (ie.myHeightString etc.)
	if _newProduct.myType &lt;&gt; null
	and _newProduct.myOperator &lt;&gt; null then
		operator := _newProduct.myOperator;
		foreach typeCode in _newProduct.myType.allCodes do : codeLoop
			foreach product in operator.allProducts do : productLoop
				if product.myType = null then
					continue productLoop;
				endif;
				
				if (not product.myType.allCodes.includesKey(typeCode.code)) then
					//create code and add it
					create newCode persistent;
					newCode.setCode(typeCode.code);
					newCode.setDescription(typeCode.description);
					newCode.setNotAvailableForEntry(typeCode.notAvailableForEntry);
					product.myType.allCodes.add(newCode);
				endif;
			endforeach;	
		endforeach;
	endif;
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newProduct);
	endif;
	//navsp1 01Jun2022 TFS#53104
	if _passport.noErrors then
		if _passport.isOpsViewEnabled(null) then
			_newProduct.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE, BGP_OpsViewWSRequest.OPS_TYPE_CARGOSUBTYPE, _newProduct);
		endif;
	endif;
	
end;</source>
        <Parameter name="_proxyProduct" type="CM_Product"/>
        <Parameter name="_newProduct" type="CM_Product" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
