    <JadeMethod name="comboBoxOutDeckGridArea" id="22a5f687-ee75-4c2c-8a7a-b8ac66e864db">
        <source>comboBoxOutDeckGridArea(_cmb: CMUI_ComboBox input; _level: Integer; _type: Integer; _yaDeckingOptions: CM_YADeckingOptions);
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	cmbData	: Integer;
	idx		: Integer;
begin
	_cmb.clear;
	if _level &lt;&gt; DeckingLevel_TA then
		_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt0), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt0 - DeckingMenuOffset_Out));
	endif;

	_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt1), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt1 - DeckingMenuOffset_Out));
	_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt2), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt2 - DeckingMenuOffset_Out));
	_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt3), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt3 - DeckingMenuOffset_Out));
	_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt4), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt4 - DeckingMenuOffset_Out));

	if _type = TA_TYPE_FORK_LIFT_STACK then
		_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt5), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt5 - DeckingMenuOffset_Out));
		_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt6), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt6 - DeckingMenuOffset_Out));
		_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt7), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt7 - DeckingMenuOffset_Out));
		_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt8), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt8 - DeckingMenuOffset_Out));
	endif;
	
	_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt9), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt9 - DeckingMenuOffset_Out));
	_cmb.addItemWithData(app.getDeckingOutCaption(DeckingMenu_Out_Opt10), app.getDeckingOptionFromMenuIndex(DeckingMenu_Out_Opt10 - DeckingMenuOffset_Out));

	if _yaDeckingOptions &lt;&gt; null then
		foreach idx in 1 to _cmb.listCount do
			cmbData := _cmb.itemData[idx];
			if cmbData = _yaDeckingOptions.outOptionType then
				_cmb.listIndex := idx;	
				break;
			endif;			
		endforeach;
				
	else
		if _level = DeckingLevel_TA then
			_cmb.text := app.getDeckingOutCaption(DeckingMenu_Out_Opt10);	
		endif;
	endif;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_yaDeckingOptions" type="CM_YADeckingOptions"/>
    </JadeMethod>
