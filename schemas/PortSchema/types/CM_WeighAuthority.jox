    <JadeMethod name="getDisplayStringForAttribute" id="a535a38f-e7f7-449c-b711-f79d2b37865c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars

begin
	if _attrName = ETRow_WeightCertifiedBy then
		return self.certifiedName;
	elseif _attrName = ETRow_WeightAuthorisedBy then
		return self.authorisedName;
	elseif _attrName = ETRow_AddressLine1 then
		return self.address1;
	elseif _attrName = ETRow_AddressLine2 then
		return self.address2;
	elseif _attrName = ETRow_AddressLine3 then
		return self.address3;
	elseif _attrName = ETRow_EmailAddress then
		return self.email1;
	elseif _attrName = ETRow_EmailAddress2 then
		return self.email2;
	elseif _attrName = ETRow_Phone then
		return self.phone1;
	elseif _attrName = ETRow_Phone2 then
		return self.phone2;
	elseif _attrName = ETRow_SolasMethod then
		return self.solasMethod;
	elseif _attrName = ETRow_NotAvailableForEntry then
		return self.notAvailableForUse.cnEcGetYesNo;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyName" id="988c5949-b8fb-45ca-8af8-da77b0e66fdc">
        <source>getKeyName() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars

begin
	return self.certifiedName &amp; self.authorisedName;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e0c50a92-d207-4e5d-a332-280e2d88feae">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/08/2017	jlgdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	pxyWeighAuth : CM_WeighAuthority;
	authTerm, pxyAuthTerm : CM_WeighAuthTerminal;
	completedOK : Boolean;

begin
	pxyWeighAuth := inheritMethod();
	
	foreach authTerm in self.allWeighAuthTerminals do
		pxyAuthTerm := authTerm.pxyCreateUpdateProxy();
		pxyAuthTerm.setForCreate(authTerm.isDefaultForTerminal, pxyWeighAuth, authTerm.myTerminal);
	endforeach;
	
	completedOK := true;
	return pxyWeighAuth;
epilog
	if not completedOK then
		delete pxyWeighAuth;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3f75f051-b867-4439-803f-a093407fb4dc">
        <updating/>
        <source>setForCreate(_pxyWeighAuthority : CM_WeighAuthority; _authTerms : ObjectArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2017	cnwdap1		Initial creation TFS 4492 / 2523 SNO / CPL VERMAS Changes
//
vars

begin
	self.setForUpdate(_pxyWeighAuthority, _authTerms);
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_pxyWeighAuthority" type="CM_WeighAuthority"/>
        <Parameter name="_authTerms" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="555dddf8-a629-4eff-8853-a6a767831770">
        <updating/>
        <source>setForUpdate(_pxyAuthority : CM_WeighAuthority; _authTerms : ObjectArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/06/2017	cnwdap1		Initial creation TFS 4492 / 2523 SNO/CPL VERMAS and VGM changes
// 27 Aug 2018	jlgrh7 TFS #40088 STWO - Ticket 39091: Voyage Planning Codes do not show in terminal Admin
//
vars
	terminalsToRemove : ObjectArray;
	obj : Object;
	terminal : CM_Terminal;
	authTerm, pxyAuthTerm : CM_WeighAuthTerminal;
	includes : Boolean;

begin
	self.address1 := _pxyAuthority.address1;
	self.address2 := _pxyAuthority.address2;
	self.address3 := _pxyAuthority.address3;
	self.authorisedName := _pxyAuthority.authorisedName;
	self.certifiedName := _pxyAuthority.certifiedName;
	self.email1 := _pxyAuthority.email1;
	self.email2 := _pxyAuthority.email2;
	self.phone1 := _pxyAuthority.phone1;
	self.phone2 := _pxyAuthority.phone2;
	self.solasMethod := _pxyAuthority.solasMethod;
	self.notAvailableForUse := _pxyAuthority.notAvailableForUse;			//+TFS40088
	// do authorised terminal updates
	create terminalsToRemove transient;
	foreach obj in _authTerms do
		pxyAuthTerm := obj.CM_WeighAuthTerminal;
		authTerm := self.allWeighAuthTerminals[pxyAuthTerm.myTerminal];
		if authTerm = null then
			create authTerm;
			authTerm.setForCreate(pxyAuthTerm.isDefaultForTerminal, self, pxyAuthTerm.myTerminal);
		elseif pxyAuthTerm.isDefaultForTerminal &lt;&gt; authTerm.isDefaultForTerminal then
			authTerm.setIsDefaultForTerminal(pxyAuthTerm.isDefaultForTerminal);
		endif;
	endforeach;
	// now check for ones we don't need any more
	foreach authTerm in self.allWeighAuthTerminals do
		includes := false;
		foreach obj in _authTerms do
			pxyAuthTerm := obj.CM_WeighAuthTerminal;
			if pxyAuthTerm.myTerminal = authTerm.myTerminal then
				includes := true;
				break;
			endif;
		endforeach;
		if not includes then
			terminalsToRemove.add(authTerm);
		endif;
	endforeach;
	
	terminalsToRemove.purge;			// get rid of the ones we don't want any more
	
epilog
	delete terminalsToRemove;
end;</source>
        <Parameter name="_pxyAuthority" type="CM_WeighAuthority"/>
        <Parameter name="_authTerms" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ba1c80ce-3509-4fac-82a6-a500b2cbb771">
        <updating/>
        <source>setProxy(	_authorisedName : String;
			_certifiedName : String;
			_address1, _address2, _address3 : String;
			_email1, _email2 : String;
			_phone1, _phone2 : String;
			_solasMethod : String;
			_notAvailableForUse : Boolean	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2017	cnwdap1		Initial creation TFS 4492 / 2523 SNO / CPL VERMAS updates
//
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.address1			:= _address1;
	self.address2			:= _address2;
	self.address3			:= _address3;
	self.authorisedName		:= _authorisedName;
	self.certifiedName		:= _certifiedName;
	self.email1				:= _email1;
	self.email2				:= _email2;
	self.phone1				:= _phone1;
	self.phone2				:= _phone2;
	self.solasMethod		:= _solasMethod;
	self.notAvailableForUse	:= _notAvailableForUse;
epilog

end;</source>
        <Parameter name="_authorisedName" type="String"/>
        <Parameter name="_certifiedName" type="String"/>
        <Parameter name="_address1" type="String"/>
        <Parameter name="_address2" type="String"/>
        <Parameter name="_address3" type="String"/>
        <Parameter name="_email1" type="String"/>
        <Parameter name="_email2" type="String"/>
        <Parameter name="_phone1" type="String"/>
        <Parameter name="_phone2" type="String"/>
        <Parameter name="_solasMethod" type="String"/>
        <Parameter name="_notAvailableForUse" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateFromVGMDetails" id="38f4face-526c-490b-a39f-d5347da8db78">
        <updating/>
        <source>updateFromVGMDetails(_vgmDetails : CM_VGMDetails;_mailAddWithSepChar: String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2017	jlgdap1		Initial creation TFS 4492 SNO VERMAS Changes
//	27 June 2018	jlgrh7 	TFS #39152 VERMAS Message Failures - String Too Long
constants
	RecEscapChc  = "?";
vars
	addressArray : HugeStringArray;										//+TFS39152
begin	
	/*if self.address1 &lt;&gt; _vgmDetails.vgmMail and _vgmDetails.vgmMail &lt;&gt; null then				//-TFS39152
		self.address1 := _vgmDetails.vgmMail;
	endif;*/
	create addressArray transient;
	_mailAddWithSepChar.getTokensForDelimiterHuge(RecEscapChc,addressArray);					//+TFS39152
	if addressArray.size &gt; 0 and self.address1&lt;&gt;addressArray[1] then
		self.address1 := addressArray[1];
	endif;
	if addressArray.size &gt; 1 and self.address2&lt;&gt;addressArray[2] then
		self.address2 := addressArray[2];
	endif;
	if addressArray.size &gt; 2 and self.address3&lt;&gt;addressArray[3] then
		 self.address3 := addressArray[3];
	endif;
	if self.email1 &lt;&gt; _vgmDetails.vgmElectronicMail and _vgmDetails.vgmElectronicMail &lt;&gt; null then
		self.email1 := _vgmDetails.vgmElectronicMail;
	endif;
	if self.phone1 &lt;&gt; _vgmDetails.vgmTelephone and _vgmDetails.vgmTelephone &lt;&gt; null then
		self.phone1 := _vgmDetails.vgmTelephone;
	endif;
	if self.phone2 &lt;&gt; _vgmDetails.vgmPhone and _vgmDetails.vgmPhone &lt;&gt; null then
		self.phone2 := _vgmDetails.vgmPhone;
	endif;
	if self.solasMethod &lt;&gt; _vgmDetails.vgmCommsType and _vgmDetails.vgmCommsType &lt;&gt; null then
		self.solasMethod := _vgmDetails.vgmCommsType;
	endif;
epilog
	delete addressArray;				//+TFS39152
end;</source>
        <Parameter name="_vgmDetails" type="CM_VGMDetails"/>
        <Parameter name="_mailAddWithSepChar" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="54a34974-57c1-43fd-8905-3f3f52b61f32">
        <source>validateForCreate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2017	cnwdap1		Initial creation TFS 4492 / 2523 SNO / CPL VERMAS Changes
//
vars

begin
	if app.myRoot.allWeighAuthorities[ self.certifiedName, self.authorisedName ] &lt;&gt; null then
		app.raiseCMException1(Weigh_Authority_Already_Exists, self.certifiedName &amp; self.authorisedName, null, null);
		return;
	endif; 

	self.validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a40b78d7-8d79-417f-a585-264830a3f2a9">
        <source>validateForDelete();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2017	cnwdap1		Initial creation TFS 4492/2523 SNO/CPL VERMAS Changes
//
vars
	authTerm : CM_WeighAuthTerminal;

begin
	foreach authTerm in self.allWeighAuthTerminals do
		if not authTerm.allVGMDetails.isEmpty then
			app.raiseCMException2(Cannot_Delete_Weigh_Auth, self.certifiedName &amp; self.authorisedName, authTerm.myTerminal.code, null, null);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="f32b224c-cf9c-43e7-b73a-f13ccf2d1b0d">
        <source>validateForUpdate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2017	cnwdap1		Initial creation TFS 4492 / 2523 SNO / CPL VERMAS Changes
//
vars
	weighAuth : CM_WeighAuthority;
	thisWeighAuth : CM_WeighAuthority;

begin
	if self.isTransient then
		thisWeighAuth := app.myProxyManager.getRealObject(self).CM_WeighAuthority;
	else
		thisWeighAuth := self;
	endif;
	weighAuth := app.myRoot.allWeighAuthorities[ self.certifiedName, self.authorisedName ];
	if weighAuth &lt;&gt; null and weighAuth &lt;&gt; thisWeighAuth then
		app.raiseCMException1(Weigh_Authority_Already_Exists, self.certifiedName &amp; self.authorisedName, null, null);
		return;
	endif; 

	self.validateMe;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="0d28a7e2-f389-4afd-969e-df2735b57041">
        <source>validateMe();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars

begin
	if self.certifiedName = null or self.authorisedName = null then
		app.raiseCMException(Cert_And_Auth_Name_Reqd, null, null);
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
