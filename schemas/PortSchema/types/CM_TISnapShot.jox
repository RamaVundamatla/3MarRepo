        <Parameter name="_transitStatus" type="Integer"/>
        <Parameter name="_isotype" type="String"/>
        <Parameter name="_billOfLading" type="String"/>
        <Parameter name="_cargoGroupId" type="String"/>
        <Parameter name="_cargoSubtypeCode" type="String"/>
        <Parameter name="_cargoSubtypeDescription" type="String"/>
        <Parameter name="_cargoTypeCode" type="String"/>
        <Parameter name="_cargoTypeDescription" type="String"/>
        <Parameter name="_colour" type="String"/>
        <Parameter name="_customsAgentCode" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_destinationPortCode" type="String"/>
        <Parameter name="_destinationPortDescription" type="String"/>
