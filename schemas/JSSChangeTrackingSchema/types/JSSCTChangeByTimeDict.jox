    <JadeMethod name="setInitializing" id="2f71d0c2-7159-4c64-998c-9519db6d2697">
        <lockReceiver/>
        <updating/>
        <source>setInitializing(value: Boolean) updating;

vars

begin
	if initializing &lt;&gt; value then
		initializing := value;
	endif;
end;
</source>
        <Parameter name="value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsDelete" id="41cb97e3-ef04-4f01-9e56-cef80b72027e">
