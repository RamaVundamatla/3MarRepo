    <JadeMethod name="isPattern" id="1e306b91-99db-44c0-b03b-e58d4a0863b1">
        <source>isPattern(_pattern: CMIF_YAPattern io): Boolean;
//28 August 2008	cnwdw1	
//	return true if
vars
begin
	_pattern.setType(CMIF_YAPattern.YAPattern_Hazardous);
	return _pattern.hasHazardous;
end;</source>
        <Parameter name="_pattern" type="CMIF_YAPattern" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="cd344d9e-70fa-4bad-90ae-337565835ed7">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	if _criteria.myYAData.CM_YADataString.value = _propertyValue or
	   _criteria.myYAData.CM_YADataString.value = null then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
