    <JadeMethod name="setupForm" id="4b17c27d-2a9e-4e81-b7b9-f8744906f06d">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
09 August 2023 navmv20 CR 59391 Task 59417: COO Maint Include Changes
07 Aug 2023 navmv20 CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues
*/

vars
	cmifOwnershipChangeDtl : CMIF_OwnershipChangeDetail; //19/07/2023 navmv20 CR 58239 Task 58241
	detailSet : CM_OwnershipChangeDetailSet; //19/07/2023 navmv20 CR 58239 Task 58241
	pxyOwnershipDetail : CM_OwnershipChangeDetail; //19/07/2023 navmv20 CR 58239 Task 58241
	ti : CM_TrackedItem; //19/07/2023 navmv20 CR 58239 Task 58241
	now : TimeStamp;
begin
	inheritMethod();
	self.doMeasurementVolume(); //27/01/2025	navkc1 JIRA Bug MTN-33535
	self.doMeasurementWeight(); //27/01/2025	navkc1 JIRA Bug MTN-33535
	self.handleMenusForModalDisplay();
	self.doCmbIncoTerm();
	self.doCmbNewOperator();
	self.doCmbCurrentOperator();
	self.doCmbNewOpDebtorInvContracts();							//navra1 - TFS 64874 - 14th Aug 2024
	self.doCmbFreightFwdr();
	self.doCmbStorageOperator();
	self.initTblCOODetail(ETDef_OwnershipChangeMaint);
	if self.updateMode then	
		self.displayHeader();
		self.displayDetails();
		self.startNotifications();
		if self.myOwnershipChange.allDetails.isEmpty then
			self.cmbCurrentOperator.enabled := true;
		else
			self.cmbCurrentOperator.enabled := false;
		endif;
	else
		now := self.systemToLocalTime(app.actualTimeAppServer);
		self.mskCOOFromStart.setDate(now.date);
		self.mskCOOFromStartTime.setTime(now.time);
	endif;
	
	//self.btnClear.enabled := false; //25/06/2024	navkc1 CR 64823 Task 64824
	setCaption(self.caption);
	
	self.tblData.userInputEnabled := true;
	//self.displayStatus(); //09/08/2023 navmv20 CR 59391 Task 59417
	//19/07/2023 navmv20 CR 58239 Task 58241 - start
	if self.mode = Cargo_Review_Mode then
		self.createPxyDetails();
		self.setOperatorCargoReview(); //07/08/2023 navmv20 CR 59440 Task 59441
		self.enableForCargoReview(); // ### TFS BUG 64115 13MAY2024 NAVAB1
	endif;
	self.displayStatus(); //09/08/2023 navmv20 CR 59391 Task 59417
	//19/07/2023 navmv20 CR 58239 Task 58241- end
	if self.myTerminal.getConfig(CooSplitOperator).Boolean then
		self.cmbNewOperator.listIndex := self.cmbNewOperator.findObject(self.cmbCurrentOperator.listObject);
		self.cmbNewOperator.enabled := false;
	endif;
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
	
	self.doPermissions(); // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
	self.doSetSelectAll();    //20.07.2024 navrv30 Bug 64858
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showMessage" id="b43aebf7-8701-4e8b-ae3b-038aed81c620">
        <source>showMessage(_message : String; _time : Integer; _position : Integer);
/*
Purpose:			

Date		Who		Reason
05 June 2024	navab1	CR 64164 TASK 64180
*/

vars
	option, timeRemaining, x1, frmwidth, frmheight : Integer;
begin
	self.frmMessage.zOrder(1);
	
	frmwidth := self.frmMessage.width.Integer;
	frmheight := self.frmMessage.height.Integer;
	
	if _position = self.Position_CenteredInParent then
		self.frmMessage.centreWindow();
	elseif _position = self.Position_TopCentered or _position = 0 then
		x1 := ((self.width - frmwidth) / 2).Integer;
		self.frmMessage.move(x1,20,frmwidth, frmheight);
	elseif _position = self.Position_TopLeft then
		x1 := 20;
		self.frmMessage.move(x1,20,frmwidth, frmheight);
	elseif _position = self.Position_TopRight then
		x1 :=  self.width.Integer -frmwidth - 20;
		self.frmMessage.move(x1,20,frmwidth, frmheight);
	endif;
	
	self.frmMessage.visible := true;
	self.lblMessage.caption :=_message;
	
	if self.getTimerStatus(self.Timer_UpdateDetail, option, timeRemaining) then
		self.endTimer(self.Timer_UpdateDetail);
	endif;
	
	self.beginTimer(_time, Timer_OneShot,self.Timer_UpdateDetail);

epilog

end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_time" type="Integer"/>
        <Parameter name="_position" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startNotifications" id="bdcb2170-36df-4f28-882a-7e69bbf5bcd9">
