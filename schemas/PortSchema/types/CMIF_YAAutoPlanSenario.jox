    <JadeMethod name="isAttributeTrue" id="0e0fdce3-1d49-4033-a3db-d8c6ca517c6c">
        <source>isAttributeTrue(attribToTest: Integer): Boolean;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if  attribToTest = TI_Attrib_RequiresPower then
		return self.requiresPower;
		
	elseif attribToTest = TI_Attrib_IsForty then
		return self.is40;
	elseif attribToTest = TI_Attrib_IsFortyFive then
		return self.is45;
	elseif attribToTest = TI_Attrib_IsThirty then
		return self.is30;
	elseif attribToTest = TI_Attrib_IsFiftyThree then
		return self.is53;	
	endif;
	
	app.writeStatement( 'UNKNOWN ATTRIBUTE DEFINED FOR SENEARIO');
	return inheritMethod(attribToTest);


end;</source>
        <Parameter name="attribToTest" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvGrade_Compare" id="2db35a5e-3083-45a7-bec0-72450859e780">
        <source>isAvGrade_Compare(mtGrade: Object; grade: Integer): Boolean;
begin
	return mtGrade.CM_MTGrade.code = grade;
end;</source>
        <Parameter name="mtGrade" type="Object"/>
        <Parameter name="grade" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvGrade_Match" id="403050f0-1cc1-49ed-bad6-362ad9969dd4">
        <source>isAvGrade_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------
vars
	mtGrade		: Object;
begin

	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanSenario::isAvGrade_Compare, self.availabilityGrade);
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvailable_Match" id="58cb4b0f-82ba-40de-8e73-a768a20d5f51">
