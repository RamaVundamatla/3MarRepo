    <JadeMethod name="doDataComparison" id="bd47f5e9-4b75-4a9a-925f-2fbbfcb8369d">
        <source>doDataComparison(_yaData: SelfType): Boolean;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
vars

	obj	: Object;

begin

	if self.allObjects.isEmpty() then
		return true;
	endif;
	
	foreach obj in _yaData.allObjects do
		if self.allObjects.includes(obj) then
			return true;
		endif;
	endforeach;
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
	// handle comparison with CMIF_YACriteriaPriority instances which are CM_YADataPattern and have no allObjects but have .pattern instead
	if _yaData.isKindOf(CM_YADataPattern) then
		return self.doDataComparisonWithResolution(_yaData);
	endif;

	return false;
end;</source>
        <Parameter name="_yaData" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataComparisonWithResolution" id="c85cc266-0c54-4e6e-a412-3d9cb72a40d7">
        <source>doDataComparisonWithResolution(_yaData: CM_YAData): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 August 2008	consw1	Initial creation

*/

vars
	obj	 		: Object;
	objSet		: ObjectSet;
	yaPattern	: CM_YADataPattern;

begin

	if self.allObjects.isEmpty() then
		return true;
	endif;

	if _yaData.isKindOf(CM_YADataPattern) then
		yaPattern := _yaData.CM_YADataPattern;
		create objSet transient;
		yaPattern.myCriteriaType.resolvePattern(yaPattern.pattern, objSet, true);
		foreach obj in objSet do
			if self.allObjects.includes(obj) then
				return true;
			endif;
		endforeach;
		return false;
	endif;

	foreach obj in _yaData.CM_YADataObjects.allObjects do
		if self.allObjects.includes(obj) then
			return true;
		endif;
	endforeach;

	return false;
	
epilog
	delete objSet;
end;</source>
        <Parameter name="_yaData" type="CM_YAData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="cb5aa68c-44e2-4f32-ad6c-64a86d4eae1e">
        <source>getDataDisplay(_criteriaType: CM_YACriteriaType) : String;
//30 July 2008	cnwdw1	
//
/*

Date		Who		Reason
18 Sep 2009	cnwkpd1	PAR #20703 - Handle deleted objects by ignoring them in the display string
*/

vars
	dataObject: Object;
	displayString: String;
	invalid			: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, dataObject, invalid);	//PAR #20703
	
	foreach dataObject in self.allObjects do
		displayString := displayString &amp; _criteriaType.getDisplay(dataObject) &amp; ", ";
	endforeach;
	
	if displayString &lt;&gt; null then
		displayString := displayString[1:displayString.length-2];
	endif;

	return displayString;
end;</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <ReturnType type="String"/>
    </JadeMethod>
