end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2f889014-9974-468c-b60a-c1bc0f6ca4eb">
        <source>pxyCreateUpdateProxy(): SelfType;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 12/05/2015	cnwdap1	PAR #36206 TFS 324/334 Graphical Representation of Special Stow

vars
	proxySpecialStow : CM_SpecialStow;
	completedOK		: Boolean;
begin
	proxySpecialStow := inheritMethod();
	
	if self.myDrawingAttribute &lt;&gt; null then														// PAR #36206
		proxySpecialStow.myDrawingAttribute := self.myDrawingAttribute.pxyCreateUpdateProxy();	// PAR #36206
	endif;																						// PAR #36206
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxySpecialStow;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxySpecialStow;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="62625eba-46fb-4418-9788-865af6ba4dac">
        <updating/>
        <source>setForCreate(pProxySpecialStow : CM_SpecialStow)updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	pProxySpecialStow.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxySpecialStow);
	
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pProxySpecialStow" type="CM_SpecialStow"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1d0b88f6-7dab-4a17-814e-bcdbdec88209">
        <updating/>
        <source>setForUpdate(pProxySpecialStow : CM_SpecialStow) updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.code := pProxySpecialStow.code.trimBlanks;
	self.description := pProxySpecialStow.description.trimBlanks;
end;</source>
        <Parameter name="pProxySpecialStow" type="CM_SpecialStow"/>
    </JadeMethod>
