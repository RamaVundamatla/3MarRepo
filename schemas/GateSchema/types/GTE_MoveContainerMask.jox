    <JadeMethod name="click" id="10f4ad0a-ba68-4049-a95b-3406596ceb6b">
        <updating/>
        <source>click(jadeMask: JadeMask input) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
//	inheritMethod(jadeMask);

	self.myTruckLayoutFrame.moveSelectedContainer(self);

end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="8c6986bd-14de-4f03-8ef6-301e5365543f">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: GTE_MoveContainerMask input; persistCntrl: Control) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     20 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isInPainter then
		return;
	endif;

	cntrl.borderStyle		:= self.BorderStyle_None;
	cntrl.transparentColor	:= app.convertRGBToColor(214, 211, 206);	
	cntrl.transparent		:= true;

end;</source>
        <Parameter name="cntrl" type="GTE_MoveContainerMask" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
