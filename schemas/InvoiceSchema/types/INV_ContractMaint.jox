    <JadeMethod name="setupForm" id="d35889e7-2610-488c-b125-242ba0cd0e63">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jan 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint
28 Feb 2023 navtnr20 Bug 56766: EUP - Active flag cannot be updated on Invoice Contract
12 Apr 2023 navmk20	 Bug 57311: MTN - Contract Screens Not Saving Columns
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
20 Dec 2024	navlw1 	JIRA-33308: EUP | Contract Active flag issue while copying a contract
*/

vars

begin
	inheritMethod();						// 12/4/2023 navmk20 TFS 57311
	//self.handleMenusForModalDisplay();	// 12/4/2023 navmk20 TFS 57311
	self.doPermissions();
	self.doLoadDebtor();
	self.initTblContractMaint(ETDef_ContractDetails);
	if self.updateMode then
		self.populateContractdt();
		self.tblDisplayRow();
		self.handleContractDetails();
	endif;
	
	// navlw1 #JIRA-33308
	/*if self.chkPrimary.value then		//28-02-2023 navtnr20 56766
		self.chkActive.value := true;
		/* // ### TFS BUG 60627 15NOV2023 NAVAB1
		self.chkActive.enabled := false; 
	else	
		self.chkActive.enabled := true;
		*/
	//endif;
	
	self.setCaption(self.caption &amp; self.myCurrentBank.code);	 // ### TFS BUG 58106 23MAY2023 NAVAB1
	self.zOrder(1); //16/10/2023	navmv20	Bug 60893
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
epilog

end;</source>
    </JadeMethod>
