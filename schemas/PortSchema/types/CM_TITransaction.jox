    <JadeMethod name="cloneForTrackedItemRefs" id="8db72b22-b450-4e8a-8d00-7484f0bc07b0">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti : CM_TrackedItem; _orginalTransaction : CM_TITransaction) updating, protected;
