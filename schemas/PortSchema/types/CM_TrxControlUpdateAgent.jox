    <JadeMethod name="trxUpdYardActivityActionTime" id="c7bdfd71-510d-4388-8c2c-9588907bac9e">
        <updating/>
        <source>trxUpdYardActivityActionTime(	_reals : CM_YardActivityDict input;
								_newActionTime : TimeStamp;
								_passport : CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	yardActivity : CM_YardActivity;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	beginTransaction;
	
	foreach yardActivity in _reals do
	
		reserveLock( yardActivity );
	
		app.myUtilityUA.utlUpdYardActivityActionTime( yardActivity, _newActionTime, _passport);
		
		if _passport.hasErrors then
			break;
		endif;
	
	endforeach;

epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
