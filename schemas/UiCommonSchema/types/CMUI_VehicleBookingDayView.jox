    <JadeMethod name="displayFromSelector" id="4c0d1161-dc40-453c-a924-38c8d106797e">
        <updating/>
        <source>displayFromSelector(_allVBSSlots : Collection) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navlw1	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW - Part2

*/

vars
	slotItem : CM_VehicleBookingTimeSlot;
	indexLine : Integer;
	objArray : CM_VehicleBookingTimeSlotById;
begin
	self.isSelectorQuery := true;
	self.setupMyEntTableDef();
	create objArray transient;
	_allVBSSlots.copy(objArray);
	foreach slotItem in objArray do
		indexLine += 1;
		self.addBookingSlotToTable( slotItem, true, indexLine, null );
	endforeach;
epilog
	delete objArray;
end;</source>
        <Parameter name="_allVBSSlots" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="4115fc44-6636-4d10-bfe5-dcaf39870232">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navlw1	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW - Part2

*/

vars

begin
	displayFromSelector(_resultCollection);
epilog

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displaycellText" id="1b8909a5-154b-4312-a4fe-0c05471f668c">
        <source>displaycellText( _row : Integer; _column : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation

*/

vars

	tableCell : JadeTableCell;
	listBox : CMUI_ListBox;
	index : Integer;
	str : String;
	
begin

	if _row &lt;= self.tblBookings.fixedRows then
		return;
	endif;
	if _column &lt;= self.tblBookings.fixedColumns then
		return;
	endif;
		
	tableCell := self.tblBookings.accessCell(_row,_column);
	listBox := tableCell.cellControl.CMUI_ListBox;
	if listBox &lt;&gt; null then
	
		foreach index in 1 to listBox.listCount do
			if str = null then
				str := listBox.itemText[index];
			else
				str := str &amp; CrLf &amp; listBox.itemText[index];
			endif;
		endforeach;
		
	endif;
	
	self.tblBookings.setCellText(_row,_column,str);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBackNext" id="47707a4d-6f51-4826-bd07-f878f29137a0">
        <updating/>
        <source>doBackNext( incr : Integer ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2010	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	date : Date;
	systemTS : TimeStamp;
begin

	date := null;
//	systemTS.setDateTime(self.year, self.month,self.day,0,0,0,0); 	// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//	date := self.systemToLocalTime(systemTS).date();				// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//13 Dec 2016	NDL	TFS 	STET - we are only adding one to what ever is alreday displayed, dont convert to something else first.
	date.setDate( self.day, self.month, self.year);
	if not date.isValid then
		return;
	endif;

	if incr = -1 then
		if self.cmbPeriod.text = ByDay then
			date := date - 1;
		elseif self.cmbPeriod.text = ByMonth then
			date := date.cnEcAddMonths( -1 );
		endif;
	
	elseif incr = 1 then
		if self.cmbPeriod.text = ByDay then
			date := date + 1;
		elseif self.cmbPeriod.text = ByMonth then
			date := date.cnEcAddMonths( 1 );
		endif;
	
	endif;
	
	self.txtDate.setDate(date);
	self.doChangeDate( true );

epilog

end;</source>
        <Parameter name="incr" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangeDate" id="d3795e67-498d-4021-89b5-d3b9bd91276b">
        <updating/>
        <source>doChangeDate(_forceRefresh : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	localTS : TimeStamp;
	date : Date;
	refreshNeeded : Boolean;
begin
	localTS.cnEcSetDateAndTime(txtDate.getDate,TimeStartOfDay);// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	date := self.localToSystemTime(localTS).date();

	if date.isValid then
	
		if self.year &lt;&gt; date.year then
			self.year := date.year;
			refreshNeeded := true;
		endif;
		if self.month &lt;&gt; date.month then
			self.year := date.year;
			self.month := date.month;
			refreshNeeded := true;
		endif;
		if self.day &lt;&gt; date.day then
			self.day := date.day;
			refreshNeeded := true;
		endif;
		
		if refreshNeeded or _forceRefresh then
			self.doRefreshBookings();
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_forceRefresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeMonth" id="b486781a-1f30-45d6-94d6-7a45b693885a">
