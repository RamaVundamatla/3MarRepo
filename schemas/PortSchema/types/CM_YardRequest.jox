    <JadeMethod name="setBulkRelease" id="10076537-f515-4ace-91d0-d67d4c51fca6">
        <updating/>
        <source>setBulkRelease(_value: CM_BulkRelease) updating;
//----------------------------------------------------------------
//	Created:	23 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_value);
	
	if _value &lt;&gt; null then
		self.myTransferToTerminal := _value.myTransferToTerminal;
