/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 January 2023	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/


vars
	yaType : CM_YATypeToDoTasks;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pToDoTaskDesc);
	endif;
	
	//remove todo task from selector
	if _passport.noErrors then
		app.myRoot.todoTaskQueryPropertyRemove(pToDoTaskDesc, _passport);
	endif;
	
	if _passport.noErrors then
		yaType := CM_YATypeToDoTasks.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(pToDoTaskDesc);
		endif;
		pToDoTaskDesc.erase(NORMAL_ERASE);
	endif;
epilog
	return;

end;</source>
