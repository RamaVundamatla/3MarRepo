    <JadeMethod name="openListen" id="6c17d7fc-4dd0-465a-90e3-1fc99a9a634a">
        <updating/>
        <source>openListen() updating;


vars

	port		: Integer;
	agent		: BGP_TCPClient;
	
begin
	create self.myTcpMsg;
	agent := BGP_TCPClient.lastInstance;
	
	if agent &lt;&gt; null then
		port := agent.tcpIpPort;
		self.logMonitor("Port found " &amp; port.String);
	endif;
	
	if port = null then
		read port;
	endif;
	
	self.myTcpMsg.cnListen(port, self.myTcpMsg);
	self.staMain.caption := "Listening for connection on port " &amp; port.String;
end;</source>
    </JadeMethod>
