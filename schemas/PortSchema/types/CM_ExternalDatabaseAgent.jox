    <JadeMethod name="abortTrans" id="7f956101-5154-4799-81a1-cf7c62d70ee8">
        <updating/>
        <source>abortTrans(_type : String) updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	transFinish : TimeStamp;
	secs : Integer;
	gotNotInTransStateException : Boolean;

begin
	on Exception do self.localAbortTransExHandler(exception, gotNotInTransStateException);

	self.myExternalDatabase.abortExternalTransaction;

	if not gotNotInTransStateException then
		secs := self.transStartTs.getSecondsInInterval(transFinish);
		self.log(_type &amp; " - Aborted transaction.  " &amp; self.getThenResetTransStats);
	endif;
end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="beginTrans" id="7ea6b261-010c-4548-b13b-37bdcb1957a4">
        <updating/>
        <source>beginTrans() updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	transStart : TimeStamp;

begin
	self.resetNumChanges;
	self.transStartTs := transStart;
	
	self.myExternalDatabase.beginExternalTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildAllStoredProcedures" id="e8580922-1d16-40c1-8685-2f84d80782f5">
        <updating/>
        <source>buildAllStoredProcedures(_extractDef : CM_DataDumpExtractDef io) : Boolean updating;
/*
Purpose:			Called when the Definition has been changed
					We remove all stored procedures and then rebuild them with
					the new definitions.
					The Jade method source is re generated

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2010	conkc1	Initial creation

PAR 24641
*/
vars
	extractClass      : CM_DataDumpExtractClass;
	sqlStoredProcName : String;
	sqlTable          : String;
	exceptionString   : String;
	sqlDropString     : String;
	sqlInsertString   : String;
	sqlUpdateString   : String;
	sqlDeleteString   : String;
	jadeInsertString  : String;
	jadeUpdateString  : String;
	jadeDeleteString  : String;
	deleteStoredProc  : String;

	gotException      : Boolean;
begin

	on Exception do self.handleStoredProcExceptions(exception, gotException, exceptionString); 

	self.sqlStoredProcIndex := 1;
	foreach extractClass in _extractDef.allDataDumpExtractClasses do
		//
		// Do SQL procedures
		//
		
		sqlTable          := extractClass.sqlTableName;
		sqlStoredProcName := sqlTable &amp; self.StoredProcInsert;
		sqlDropString     := self.buildDropStoredProcString(sqlStoredProcName);
		exceptionString   := sqlDropString;
		self.myExternalDatabase.executeSQL(sqlDropString);

		sqlStoredProcName := sqlTable &amp; self.StoredProcUpdate;
		sqlDropString     := self.buildDropStoredProcString(sqlStoredProcName);
		exceptionString   := sqlDropString;
		self.myExternalDatabase.executeSQL(sqlDropString);

		sqlStoredProcName := sqlTable &amp; self.StoredProcDelete;
		sqlDropString     := self.buildDropStoredProcString(sqlStoredProcName);
		exceptionString   := sqlDropString;
		self.myExternalDatabase.executeSQL(sqlDropString);
		
		sqlStoredProcName := sqlTable &amp; self.StoredProcUpdateDelete;
		sqlDropString     := self.buildDropStoredProcString(sqlStoredProcName);
		exceptionString   := sqlDropString;
		self.myExternalDatabase.executeSQL(sqlDropString);

		sqlInsertString   := self.buildCreateStoredProcInsert(extractClass);
		exceptionString   := sqlInsertString;
		self.myExternalDatabase.executeSQL(sqlInsertString);

		sqlUpdateString   := self.buildCreateStoredProcUpdate(extractClass);
		exceptionString   := sqlUpdateString;
		self.myExternalDatabase.executeSQL(sqlUpdateString);
		
		if extractClass.deleteAction = CM_DataDumpExtractClass.DeleteOpt_SendAll then
			sqlDeleteString   := self.buildCreateStoredProcDelete(extractClass);
			exceptionString   := sqlDeleteString;
			deleteStoredProc  := self.StoredProcDelete;
			self.myExternalDatabase.executeSQL(sqlDeleteString);

		elseif extractClass.deleteAction = CM_DataDumpExtractClass.DeleteOpt_UpdateFlag then
			sqlDeleteString   := self.buildCreateStoredProcUpdateDel(extractClass);
			deleteStoredProc  := self.StoredProcUpdateDelete;
			exceptionString   := sqlDeleteString;
			self.myExternalDatabase.executeSQL(sqlDeleteString);
			
		else
			// no action required - 
		endif;
		
		//
		// Do Jade methods
		//

		jadeInsertString := self.buildExternalMethodCallInsert(extractClass, self.StoredProcInsert, "C");
		self.sqlStoredProcIndex := self.sqlStoredProcIndex + 1;
		jadeUpdateString := self.buildExternalMethodCallInsert(extractClass, self.StoredProcUpdate, "U");
		self.sqlStoredProcIndex := self.sqlStoredProcIndex + 1;
		jadeDeleteString := self.buildExternalMethodCallDelete(extractClass, deleteStoredProc);
		self.sqlStoredProcIndex := self.sqlStoredProcIndex + 1;
		beginTransaction;
		extractClass.setJadeSources(jadeInsertString, jadeUpdateString, jadeDeleteString);
		extractClass.setStoredProcSources(sqlInsertString, sqlUpdateString, sqlDeleteString);
		commitTransaction;
	endforeach;
	// Now completed OK set modified to false
	beginTransaction;
	_extractDef.setDefinitionModified(false);
	commitTransaction;

	return true;

epilog
	if gotException = true then
		self.raiseAlert(extractClass.className &amp; ":" &amp; extractClass.sqlTableName);
	endif;
end;</source>
        <Parameter name="_extractDef" type="CM_DataDumpExtractDef" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildAssignmentStrForExtMethod" id="ffc85d34-afa6-4499-9466-775a8d98801e">
        <source>buildAssignmentStrForExtMethod(_extractClass : CM_DataDumpExtractClass; _extDBFeature : CM_ExternalDBFeatureDict io; _class : Class; _subClassName : String; _tabs : String; _assignmentString : String io; _debugAssignmentString : String io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	#cnwdz2	 26049
23/03/2015		cnwrd1	par 32871 more logging
*/

vars
	feature          : CM_DataDumpFeature;
	featureName      : String;
	maxLength        : Boolean;
	length           : Integer;
	scaleFactor      : Integer;
	type             : String;
	validateTimeMethod : String;
	featuresToDelete : CM_ExternalDBFeatureDict;
	featureSubClass	 : Class;
	
begin
	create featuresToDelete transient;
	
	foreach feature in _extDBFeature do
		if _class.findProperty(feature.featureName) = null and _class.findMethod(feature.featureName) = null then
			continue;			
		endif;
		
		if feature.subClassName &lt;&gt; null then
			featureSubClass := currentSchema.getClass(feature.subClassName);
			if not _class.inheritsFrom(featureSubClass) then
				continue;
			endif;
		endif;
		
		//
		// Have to use sendMsg and getPropertyValue for protected items
		//
		if feature.returnValueIsAnObject = true then
		
			if feature.isProtected = true then

				if feature.isFeatureMethod() then				
					featureName := "self.sendMsgWithParams('" &amp; feature.featureName &amp; "').Object" &amp; feature.getFeatureType(null,length, scaleFactor, maxLength);
				else
					featureName := "self.getPropertyValue('" &amp; feature.featureName &amp; "').Object";
				endif;
			else
				if _subClassName &lt;&gt; null then
					featureName := "self." &amp; _subClassName &amp; "." &amp; feature.featureName;
				else
					featureName := "self." &amp; feature.featureName;
				endif;
			endif;

			_assignmentString := _assignmentString &amp; _tabs &amp; feature.featureName.padBlanks(30) &amp; " := " &amp;
								"app.dataDumpBuildOIDValue(" &amp; _extractClass.myDataDumpExtractDef.oidFormat.String &amp; ", " &amp; featureName &amp; ")." &amp;
								_extractClass.myDataDumpExtractDef.getOIDCasting() &amp; ";" &amp; CrLf; //cnwrd1 36135 log sqlparams
			
		_debugAssignmentString := _debugAssignmentString &amp; Tab &amp; "sqlCallInfo := sqlCallInfo &amp; '" &amp; feature.featureName.padBlanks(30) 
						&amp; " = " &amp; "' &amp; app.dataDumpBuildOIDValue(2, " &amp; featureName &amp; ").asStringJMT &amp; CrLf;" &amp; CrLf;			
	
		else
			type := feature.getFeatureType(null,length, scaleFactor, maxLength);
			//
			// Ensure that the date and time is valid  - for SQL Server Version 2005 and below date and times are treated as DateTime (timestamp)
			//
			if _extractClass.myDataDumpExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 then //29/06/2010 cnwdz2 24829
				if type = "TimeStamp" then //10/09/2010 cnwdz2 25697 26764
					validateTimeMethod := "." &amp; TimeStamp::getValidSQLTimeStamp2005.name;
				elseif type = "Time" then
					validateTimeMethod := "." &amp; Time::getValidSQLTime.name;
				elseif type = "Date" then
					validateTimeMethod := "." &amp; Date::getValidSQLDate.name;
				else
					validateTimeMethod := null;
				endif;
			else
				if type = "TimeStamp" then //10/09/2010 cnwdz2 25697
					validateTimeMethod := "." &amp; TimeStamp::getValidSQLTimeStamp2005.name;
				elseif type = "Time" then
					validateTimeMethod := "." &amp; Time::getValidSQLTime2005.name;
				elseif type = "Date" then
					validateTimeMethod := "." &amp; Date::getValidSQLDate2005.name;
				else
					validateTimeMethod := null;
				endif;
			endif;
			
			if feature.isProtected = true then
			
				if feature.isFeatureMethod() then
					featureName := "self.sendMsgWithParams('" &amp; feature.featureName &amp; "')." &amp; type;
				else
					//
					// Getting Decimals via getProperty - drop length and precision
					//
					if type.startsWith("Decimal") then
						featureName := "self.getPropertyValue('" &amp; feature.featureName &amp; "').Decimal";
					else
						featureName := "self.getPropertyValue('" &amp; feature.featureName &amp; "')." &amp; type;
					endif;
				endif;
				_assignmentString := _assignmentString &amp; _tabs &amp; feature.featureName.padBlanks(30) &amp; " := " &amp; featureName &amp; validateTimeMethod &amp; ";" &amp; CrLf;
				
				_debugAssignmentString := _debugAssignmentString &amp; Tab &amp; "sqlCallInfo := sqlCallInfo &amp; '" &amp; feature.featureName.padBlanks(30) &amp; " = ' &amp; " &amp; featureName &amp; validateTimeMethod  &amp; ".asStringJMT  &amp; CrLf;" &amp; CrLf;			
			else
				if _subClassName &lt;&gt; null then
					_assignmentString := _assignmentString &amp; _tabs &amp; feature.featureName.padBlanks(30) &amp; " := " &amp;
									"self." &amp; _subClassName &amp; "." &amp; feature.featureName &amp; validateTimeMethod &amp; ";" &amp; CrLf;
									
					_debugAssignmentString := _debugAssignmentString &amp; Tab &amp; "sqlCallInfo := sqlCallInfo &amp; '" &amp; feature.featureName.padBlanks(30) &amp; " = ' &amp; " &amp;  "self." &amp; _subClassName &amp; "." &amp; feature.featureName  &amp; validateTimeMethod  &amp; ".asStringJMT  &amp; CrLf;" &amp; CrLf;												
				else
					_assignmentString := _assignmentString &amp; _tabs &amp; feature.featureName.padBlanks(30) &amp; " := " &amp;
									"self." &amp; feature.featureName &amp; validateTimeMethod &amp; ";" &amp; CrLf;
					
					_debugAssignmentString := _debugAssignmentString &amp; Tab &amp; "sqlCallInfo := sqlCallInfo &amp; '" &amp; feature.featureName.padBlanks(30)&amp; " = ' &amp; " &amp;  "self." &amp; feature.featureName  &amp; validateTimeMethod  &amp; ".asStringJMT  &amp; CrLf;" &amp; CrLf;																					
				endif;
			endif;
		endif;	
		
		if _subClassName = null then
			featuresToDelete.add(feature);
		endif;
	endforeach;
	
	if _subClassName = null then
		foreach feature in featuresToDelete do
			_extDBFeature.removeIfPresent(feature);
		endforeach;
	endif;
epilog
	delete featuresToDelete;
end;</source>
        <access>protected</access>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_extDBFeature" type="CM_ExternalDBFeatureDict" usage="io"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_subClassName" type="String"/>
        <Parameter name="_tabs" type="String"/>
        <Parameter name="_assignmentString" type="String" usage="io"/>
        <Parameter name="_debugAssignmentString" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="buildCreateStoredProcDelete" id="05c64fc8-535f-4021-a647-be2f421525f5">
        <updating/>
        <source>buildCreateStoredProcDelete(_extractClass : CM_DataDumpExtractClass) : String updating;
/*
Purpose:			Generate a Stored Procedure to delete Row

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2010	conkc1	Initial creation

PAR 24641
*/
constants

	CREATE1     : String = "CREATE PROCEDURE[dbo].[";
	DATEComment : String = " -- ";
	DELETE1     : String = Tab &amp; "as " &amp; CrLf &amp; Tab &amp; "begin";
	DELETE2     : String = Tab &amp; "declare @_result int" &amp; CrLf &amp; Tab &amp; "set nocount on" &amp; CrLf &amp; Tab &amp; "set @_result = 0" &amp; CrLf;
	DELETE3     : String = Tab &amp; "delete from ";
	WHERE       : String = Tab &amp; "where ";
	LOGICLine1  : String = Tab &amp; CrLf &amp; Tab &amp; "set @_result=@@error" &amp; CrLf;
	LOGICLine2  : String = Tab &amp; "if @_result &lt;&gt; 0 " &amp; CrLf;
	LOGICLine3  : String = Tab &amp; "begin" &amp; CrLf;
	LOGICLine4  : String = Tab &amp; "if @_result = 2627" &amp; CrLf;
	LOGICLine5  : String = Tab &amp; Tab &amp; "set @_result = 3254" &amp; CrLf;
	LOGICLine6  : String = Tab &amp; "end" &amp; CrLf;
	LOGICLine7  : String = Tab &amp; "return @_result" &amp; CrLf &amp; "end";	

vars

	today            : TimeStamp;
	whereString      : String;
	procedureName    : String;
	deleteStoredProc : String;
	parameterString  : String;

	extractDef       : CM_DataDumpExtractDef;
begin

	procedureName := StoredProcPrefix &amp; _extractClass.sqlTableName &amp; StoredProcDelete;
	extractDef    := _extractClass.myDataDumpExtractDef;

	whereString   := WHERE &amp; buildOIDParamsForWhere(extractDef);

	deleteStoredProc := CREATE1 &amp; procedureName &amp; "]" &amp; CrLf &amp; DATEComment &amp; today.String &amp; CrLf;

	parameterString := Tab &amp; "@" &amp; extractDef.oidColumnName &amp; app.getOIDSQLFormat(extractDef.oidFormat, false);
	
	deleteStoredProc := deleteStoredProc &amp; parameterString &amp; DELETE1 &amp; CrLf &amp; Tab &amp; CrLf;
	deleteStoredProc := deleteStoredProc &amp; DELETE2 &amp; DELETE3 &amp; _extractClass.sqlTableName &amp; CrLf &amp; whereString;
	deleteStoredProc := deleteStoredProc &amp; LOGICLine1 &amp; LOGICLine2 &amp; LOGICLine3 &amp; LOGICLine4 &amp;
						LOGICLine5 &amp; LOGICLine6 &amp; LOGICLine7;
	
	return deleteStoredProc;
epilog

end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildCreateStoredProcInsert" id="775ce58d-09ed-4fe9-a9eb-c25d2cb4442e">
        <updating/>
        <source>buildCreateStoredProcInsert(_extractClass : CM_DataDumpExtractClass) : String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2010	conkc1	Initial creation

PAR 24641
*/
constants
	CREATE1       : String = "CREATE PROCEDURE[dbo].[";
	CONTROLParam  : String = Tab &amp; "@jversion [varchar](10), " &amp; CrLf &amp;
							 Tab &amp; "@juniqueIdentifier [bigint]," &amp; CrLf &amp;
							 Tab &amp; "@jlastUpdated [datetime2]";
	CONTROLColumn : String = Tab &amp; "[jversion]," &amp; CrLf &amp;
							 Tab &amp; "[juniqueIdentifier]," &amp; CrLf &amp;
							 Tab &amp; "[jlastUpdated]";
	CONTROLValue  : String = Tab &amp; "@jversion, " &amp; CrLf &amp;
							 Tab &amp; "@juniqueIdentifier," &amp; CrLf &amp;
							 Tab &amp; "@jlastUpdated";
	DATEComment   : String = " -- ";
	INSERT1       : String = Tab &amp; "as " &amp; CrLf &amp; Tab &amp; "begin";
	INSERT2       : String = Tab &amp; "declare @_result int" &amp; CrLf &amp; CrLf &amp; Tab &amp; "set nocount on" &amp; CrLf &amp; CrLf &amp; Tab &amp; "insert into[";
	INSERT3       : String = Tab &amp; ")" &amp; CrLf &amp; Tab &amp; " values (" &amp; CrLf;
	LOGICLine1    : String = Tab &amp; ")" &amp; CrLf &amp; Tab &amp; "set @_result=@@error" &amp; CrLf;
	LOGICLine2    : String = Tab &amp; "if @_result &lt;&gt; 0 " &amp; CrLf;
	LOGICLine3    : String = Tab &amp; "begin" &amp; CrLf;
	LOGICLine4    : String = Tab &amp; "if @_result = 2627" &amp; CrLf;
	LOGICLine5    : String = Tab &amp; "-- duplicated key" &amp; CrLf;
	LOGICLine6    : String = Tab &amp; Tab &amp; "set @_result = 3258" &amp; CrLf &amp; Tab &amp; "else" &amp; CrLf;
	LOGICLine7    : String = Tab &amp; "-- misc exception" &amp; CrLf &amp; Tab &amp; Tab &amp; "set @_result = 3254" &amp; CrLf &amp; Tab &amp; "end" &amp; CrLf;
	LOGICLine8    : String = Tab &amp; "return @_result" &amp; CrLf &amp; "end";	

vars

	today            : TimeStamp;
	sqlColumn        : CM_DataDumpSQLColumn;
	sqlDataType      : CM_DataDumpSQLDataType;

	procedureName    : String;
	insertStoredProc : String;
	parameterString  : String;
	columnString     : String;
	valueString      : String;
	ps               : String;
	cs               : String;
	vs               : String;
	numberOfColumns  : Integer;
	count            : Integer;
begin

	procedureName := StoredProcPrefix &amp; _extractClass.sqlTableName &amp; StoredProcInsert;
	insertStoredProc := CREATE1 &amp; procedureName &amp; "]" &amp; CrLf &amp; DATEComment &amp; today.String &amp; CrLf;
	//
	//  Check if we are building code for the Control Table
	//
	if _extractClass.sqlTableName = ControlTableName then
		parameterString := CONTROLParam &amp; CrLf;
		columnString    := CONTROLColumn &amp; CrLf;
		valueString     := CONTROLValue &amp; CrLf;
	else
		self.buildOptColsStoredProcInsert(_extractClass, parameterString, columnString, valueString);
	
		numberOfColumns := _extractClass.allDataDumpSQLColumns.size;
		
		foreach sqlColumn in _extractClass.allDataDumpSQLColumns do
	
			ps     := Tab &amp; "@" &amp; sqlColumn.name &amp; " " &amp; sqlColumn.buildSQLDataType(false);
			cs     := Tab &amp; "[" &amp; sqlColumn.name &amp; "]";
			vs     := Tab &amp; "@" &amp; sqlColumn.name;
			count  := count + 1;
			if count &lt; numberOfColumns then
				ps := ps &amp; ',';
				cs := cs &amp; ',';
				vs := vs &amp; ',';
			endif;
			ps := ps &amp; CrLf;
			cs := cs &amp; CrLf;
			vs := vs &amp; CrLf;
			parameterString := parameterString &amp; ps;
			columnString    := columnString &amp; cs;
			valueString     := valueString &amp; vs;
	
		endforeach;
	endif;

	insertStoredProc := insertStoredProc &amp; parameterString &amp; INSERT1 &amp; CrLf &amp; Tab &amp; CrLf;
	insertStoredProc := insertStoredProc &amp; INSERT2 &amp; _extractClass.sqlTableName &amp; "](" &amp; CrLf &amp; columnString &amp; INSERT3 &amp; valueString;
	insertStoredProc := insertStoredProc &amp; LOGICLine1 &amp; LOGICLine2 &amp; LOGICLine3 &amp; LOGICLine4 &amp;
						LOGICLine5 &amp; LOGICLine6 &amp; LOGICLine7 &amp; LOGICLine8;
	
	return insertStoredProc;
epilog

end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildCreateStoredProcUpdate" id="5740a01b-43b2-45f1-8b15-e249f2e9fcb4">
        <updating/>
        <source>buildCreateStoredProcUpdate(_extractClass : CM_DataDumpExtractClass) : String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2010	conkc1	Initial creation

PAR 24641
*/
constants

	CREATE1       : String = "CREATE PROCEDURE[dbo].[";
	CONTROLParam  : String = Tab &amp; "@jversion [varchar](10), " &amp; CrLf &amp;
							 Tab &amp; "@juniqueIdentifier [bigint]," &amp; CrLf &amp;
							 Tab &amp; "@jlastUpdated [datetime2]";
	CONTROLSet    : String = Tab &amp; "[jversion] = @jversion, " &amp; CrLf &amp;
							 Tab &amp; "[juniqueIdentifier] = @juniqueIdentifier," &amp; CrLf &amp;
							 Tab &amp; "[jlastUpdated] = @jlastUpdated";
	DATEComment   : String = " -- ";
	UPDATE1       : String = Tab &amp; "as " &amp; CrLf &amp; Tab &amp; "begin";
	UPDATE2       : String = Tab &amp; "declare @_result int,  @rowcount int" &amp; CrLf &amp; CrLf &amp; Tab &amp; "set nocount on" &amp; CrLf &amp; CrLf &amp; Tab &amp; "update[";
	WHERE         : String = Tab &amp; "where ";
	LOGICLine1    : String = Tab &amp; CrLf &amp; Tab &amp; "select @_result=@@error, @rowcount=@@rowcount" &amp; CrLf;
	LOGICLine2    : String = Tab &amp; "if @_result &lt;&gt; 0 " &amp; CrLf;
	LOGICLine3    : String = Tab &amp; "begin" &amp; CrLf;
	LOGICLine4    : String = Tab &amp; "if @_result = 2627" &amp; CrLf;
	LOGICLine5    : String = Tab &amp; Tab &amp; "set @_result = 3254" &amp; CrLf &amp; Tab &amp; "end else if @rowcount = 0" &amp; CrLf;
	LOGICLine6    : String = Tab &amp; Tab &amp; "set @_result = 3259" &amp; CrLf &amp; Tab &amp; "else if @rowcount &lt;&gt; 1 " &amp; CrLf;
	LOGICLine7    : String = Tab &amp; Tab &amp; "set @_result = 3260" &amp; CrLf;
	LOGICLine8    : String = Tab &amp; "return @_result" &amp; CrLf &amp; "end";	

vars

	today            : TimeStamp;
	sqlColumn        : CM_DataDumpSQLColumn;
	extractDef       : CM_DataDumpExtractDef;

	whereString      : String;
	procedureName    : String;
	updateStoredProc : String;
	parameterString  : String;
	setString        : String;
	ps               : String;
	ss               : String;
	numberOfColumns  : Integer;
	count            : Integer;
begin

	procedureName := StoredProcPrefix &amp; _extractClass.sqlTableName &amp; StoredProcUpdate;
	extractDef    := _extractClass.myDataDumpExtractDef;

	updateStoredProc := CREATE1 &amp; procedureName &amp; "]" &amp; CrLf &amp; DATEComment &amp; today.String &amp; CrLf;

	if _extractClass.sqlTableName = ControlTableName then
		parameterString := CONTROLParam &amp; CrLf;
		setString       := CONTROLSet &amp; CrLf;
	else
	
		whereString      := WHERE &amp; buildOIDParamsForWhere(extractDef);
		numberOfColumns  := _extractClass.allDataDumpSQLColumns.size;
		
		buildOptColsStoredProcUpdate(_extractClass, parameterString, setString);
	
		foreach sqlColumn in _extractClass.allDataDumpSQLColumns do
	
			ps     := Tab &amp; "@" &amp; sqlColumn.name &amp; " " &amp; sqlColumn.buildSQLDataType(false);
			ss     := Tab &amp; ("[" &amp; sqlColumn.name &amp; "]").padBlanks(30) &amp; " = @" &amp; sqlColumn.name;
	
			count  := count + 1;
			if count &lt; numberOfColumns then
				ps := ps &amp; ',';
				ss := ss &amp; ',';
			endif;
			ps := ps &amp; CrLf;
			ss := ss &amp; CrLf;
			parameterString := parameterString &amp; ps;
			setString       := setString &amp; ss;
	
		endforeach;
	endif;

	updateStoredProc := updateStoredProc &amp; parameterString &amp; UPDATE1 &amp; CrLf &amp; Tab &amp; CrLf;
	updateStoredProc := updateStoredProc &amp; UPDATE2 &amp; _extractClass.sqlTableName &amp; "] set " &amp; CrLf &amp; setString &amp; CrLf &amp; whereString;
	updateStoredProc := updateStoredProc &amp; LOGICLine1 &amp; LOGICLine2 &amp; LOGICLine3 &amp; LOGICLine4 &amp;
						LOGICLine5 &amp; LOGICLine6 &amp; LOGICLine7 &amp; LOGICLine8;
	
	return updateStoredProc;
epilog

end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildCreateStoredProcUpdateDel" id="c9105537-870f-42ae-9f31-ccac04fadbfc">
        <updating/>
        <source>buildCreateStoredProcUpdateDel(_extractClass : CM_DataDumpExtractClass) : String updating;
/*
Purpose:			Build stored procedure for updating the delete column in the SQL table

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2010	conkc1	Initial creation

PAR 24641
*/
constants

	CREATE1     : String = "CREATE PROCEDURE[dbo].[";
	DATEComment : String = " -- ";
	UPDATE1     : String = Tab &amp; "as " &amp; CrLf &amp; Tab &amp; "begin";
	UPDATE2     : String = Tab &amp; "declare @_result int,  @rowcount int" &amp; CrLf &amp; CrLf &amp; Tab &amp; "set nocount on" &amp; CrLf &amp; CrLf &amp; Tab &amp; "update[";
	WHERE       : String = Tab &amp; "where ";
	LOGICLine1  : String = Tab &amp; CrLf &amp; Tab &amp; "select @_result=@@error, @rowcount=@@rowcount" &amp; CrLf;
	LOGICLine2  : String = Tab &amp; "if @_result &lt;&gt; 0 " &amp; CrLf;
	LOGICLine3  : String = Tab &amp; "begin" &amp; CrLf;
	LOGICLine4  : String = Tab &amp; "if @_result = 2627" &amp; CrLf;
	LOGICLine5  : String = Tab &amp; Tab &amp; "set @_result = 3254" &amp; CrLf &amp; Tab &amp; "end else if @rowcount = 0" &amp; CrLf;
	LOGICLine6  : String = Tab &amp; Tab &amp; "set @_result = 3259" &amp; CrLf &amp; Tab &amp; "else if @rowcount &lt;&gt; 1 " &amp; CrLf;
	LOGICLine7  : String = Tab &amp; Tab &amp; "set @_result = 3260" &amp; CrLf;
	LOGICLine8  : String = Tab &amp; "return @_result" &amp; CrLf &amp; "end";	

vars

	today            : TimeStamp;
	extractDef       : CM_DataDumpExtractDef;
	oidFormat        : Integer; 
	sqlFormat        : String;
	whereString      : String;
	procedureName    : String;
	updateStoredProc : String;
	parameterString  : String;
	setString        : String;
	numberOfColumns  : Integer;

begin

	procedureName := StoredProcPrefix &amp; _extractClass.sqlTableName &amp; StoredProcUpdateDelete;
	extractDef    := _extractClass.myDataDumpExtractDef;
	
	oidFormat := _extractClass.myDataDumpExtractDef.oidFormat;
	sqlFormat := app.getOIDSQLFormat(oidFormat, false) &amp; ",";

	buildOptColsStoredProcUpdate(_extractClass, parameterString, setString);

	if parameterString[parameterString.length - 2 : end] = "," &amp; CrLf then
		parameterString[parameterString.length - 2 : 1] := " ";
	endif;
	if setString[setString.length - 2 : end] = "," &amp; CrLf then
		setString[setString.length - 2 : end] := " ";
	endif;

	whereString      := WHERE &amp; buildOIDParamsForWhere(extractDef);
	updateStoredProc := CREATE1 &amp; procedureName &amp; "]" &amp; CrLf &amp; DATEComment &amp; today.String &amp; CrLf;
	numberOfColumns  := _extractClass.allDataDumpSQLColumns.size;

	updateStoredProc := updateStoredProc &amp; parameterString &amp; UPDATE1 &amp; CrLf &amp; Tab &amp; CrLf;
	updateStoredProc := updateStoredProc &amp; UPDATE2 &amp; _extractClass.sqlTableName &amp; "] set " &amp; CrLf &amp; setString &amp; CrLf &amp; whereString;
	updateStoredProc := updateStoredProc &amp; LOGICLine1 &amp; LOGICLine2 &amp; LOGICLine3 &amp; LOGICLine4 &amp;
						LOGICLine5 &amp; LOGICLine6 &amp; LOGICLine7 &amp; LOGICLine8;
	
	return updateStoredProc;
epilog

end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildCreateTableString" id="f30807e6-93df-4d47-a94f-58a2f756ee92">
        <updating/>
        <source>buildCreateTableString(_extractClass : CM_DataDumpExtractClass) : String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2010	conkc1	Initial creation
12 April 2024	navra1	BUG 62508 - GPHA - Data Extract : Inconsistency between SQL Table Definition and Jade SQL Mapping / .fmt file

PAR 24641
*/
constants
	CREATE1 : String = "CREATE TABLE [dbo].[";
vars
	sqlColumn       : CM_DataDumpSQLColumn;
	sqlDataType     : CM_DataDumpSQLDataType;
	createString    : String;
	columnString    : String;
	numberOfColumns : Integer;
	count           : Integer;
	columnPosDict       : CM_SQLColumnByOrdinalPosDict;
	sqlColumnDeleteAction,
	sqlColumnExportedTimestamp,
	sqlColumnLastOperation, 
	sqlColumnOid, 
	sqlColumnCheck:CM_DataDumpSQLColumn;
	colNo:Integer;
	highestNumber : Integer;
	dateTime         : String;
begin

	createString := CREATE1 &amp; _extractClass.sqlTableName &amp; "](" &amp; CrLf;
	
	create columnPosDict transient;
	
	create sqlColumnOid transient;
	sqlColumnOid.setupOptionalColumns(_extractClass.myDataDumpExtractDef.oidColumnName, _extractClass.oidColumnPos, 1);
	columnPosDict.add(sqlColumnOid);
	
	 if _extractClass.deleteActionColumnName &lt;&gt; null then
		create sqlColumnDeleteAction transient;
		sqlColumnDeleteAction.setupOptionalColumns(_extractClass.deleteActionColumnName, _extractClass.deleteActionColumnPos, 0);
		columnPosDict.add(sqlColumnDeleteAction);
	 endif;
	 
	 if  _extractClass.exportedTimestampColumnName &lt;&gt; null then
		create sqlColumnExportedTimestamp transient;
		sqlColumnExportedTimestamp.setupOptionalColumns(_extractClass.exportedTimestampColumnName, _extractClass.exportedTimestampColumnPos, 0);
		columnPosDict.add(sqlColumnExportedTimestamp);
	 endif;
	 
	 if _extractClass.lastOperationColumnName &lt;&gt; null then
		create sqlColumnLastOperation transient;
		sqlColumnLastOperation.setupOptionalColumns(_extractClass.lastOperationColumnName, _extractClass.lastOperationColumnPos, 0);
		columnPosDict.add(sqlColumnLastOperation);
	 endif;
	 
	 //create dictionary
	foreach sqlColumn in _extractClass.allDataDumpSQLColumns do		
		if columnPosDict[sqlColumn.sqlColumnOrdinalPosition] = null then
			columnPosDict.add(sqlColumn);
		endif;
	endforeach;
	
	numberOfColumns := columnPosDict.size;
	
	foreach sqlColumn in columnPosDict do
		columnString := null;
		if sqlColumn.sqlColumnOrdinalPosition = _extractClass.deleteActionColumnPos then
			columnString := columnString &amp; Tab &amp; "[" &amp; _extractClass.deleteActionColumnName &amp; "] [bit] NULL";
		elseif sqlColumn.sqlColumnOrdinalPosition =  _extractClass.exportedTimestampColumnPos then
			if _extractClass.myDataDumpExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 then 
				dateTime := CM_DataDumpSQLDataType.SQLDateTime2;
			else
				dateTime := CM_DataDumpSQLDataType.SQLDateTime;
			endif;
			columnString := columnString &amp; Tab &amp; "[" &amp; _extractClass.exportedTimestampColumnName &amp; "] [" &amp; dateTime &amp; "] NULL";
		elseif sqlColumn.sqlColumnOrdinalPosition = _extractClass.lastOperationColumnPos then
			columnString := columnString &amp; Tab &amp; "[" &amp; _extractClass.lastOperationColumnName &amp; "] [nchar] NULL";
		elseif sqlColumn.sqlColumnOrdinalPosition = _extractClass.oidColumnPos then
			columnString := columnString &amp; Tab &amp; self.buildOIDParamsForTableCreate(_extractClass.myDataDumpExtractDef);
			if columnString.endsWith (",") then
				columnString := columnString[1:columnString.length - 1];
			endif;
		else
			columnString := Tab &amp; "[" &amp; sqlColumn.name &amp; "] " &amp; sqlColumn.buildSQLDataType(true) &amp; " NULL";
		endif;
		
		count := count + 1;
		if count &lt; numberOfColumns then
			columnString := columnString &amp; ',';
		else		//this is the last, should not end with a comma
			if columnString.endsWith (",") then
				columnString := columnString[1:columnString.length - 1];
			endif;
		endif;
		columnString := columnString &amp; CrLf;
		createString := createString &amp; columnString;				
	endforeach;
	
	createString := createString &amp; ")";
	
	app.writeLog("The generated SQL create statement is : "  &amp; createString, LogINFO);

	return createString;
epilog
	
	delete sqlColumnOid;
	delete sqlColumnDeleteAction;
	delete sqlColumnExportedTimestamp;
	delete sqlColumnLastOperation;
	delete columnPosDict;
	
end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildCreateTableString_old" id="0bf45f78-aab8-4121-ba65-ef97e18a2fa3">
        <updating/>
        <source>buildCreateTableString_old(_extractClass : CM_DataDumpExtractClass) : String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2010	conkc1	Initial creation

PAR 24641
*/
constants
	CREATE1 : String = "CREATE TABLE [dbo].[";
vars
	sqlColumn       : CM_DataDumpSQLColumn;
	sqlDataType     : CM_DataDumpSQLDataType;
	createString    : String;
	columnString    : String;
	numberOfColumns : Integer;
	count           : Integer;
begin

	createString := CREATE1 &amp; _extractClass.sqlTableName &amp; "](" &amp; CrLf;
	
	numberOfColumns := _extractClass.allDataDumpSQLColumns.size;
	
	createString := createString &amp; self.buildOIDParamsForTableCreate(_extractClass.myDataDumpExtractDef);
	createString := createString &amp; self.buildOptColsTableCreate(_extractClass);

	foreach sqlColumn in _extractClass.allDataDumpSQLColumns do

		columnString := Tab &amp; "[" &amp; sqlColumn.name &amp; "] " &amp; sqlColumn.buildSQLDataType(true) &amp; " NULL";
		count := count + 1;
		if count &lt; numberOfColumns then
			columnString := columnString &amp; ',';
		endif;
		columnString := columnString &amp; CrLf;
		createString := createString &amp; columnString;

	endforeach;
	
	createString := createString &amp; ")";

	return createString;
epilog

end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildDropStoredProcString" id="3591f9c5-9f29-4151-8f99-201d14fb1ae8">
        <updating/>
        <source>buildDropStoredProcString(_procName : String) : String updating;
/*

Purpose:			Generate a Drop String for a Stored Procedure

Parameters:			table name

Return Value:		SQL DROP String

Date			Who		Reason
22 April 2010	conkc1	Initial creation

PAR 24641
*/
constants
	DROP1   : String = "IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[";
	DROP2   : String = "]') AND type in (N'P', N'PC'))";
	DROP3   : String = "DROP PROCEDURE [dbo].[";
	DROP4   : String = "]";

vars
	dropString    : String;
	procedureName : String;
begin

	procedureName := self.StoredProcPrefix &amp; _procName;

	dropString := DROP1 &amp; procedureName &amp; DROP2 &amp; CrLf &amp; DROP3 &amp; procedureName &amp; DROP4;
	return dropString;
epilog

end;</source>
        <Parameter name="_procName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildDropTableString" id="6c7a6d9e-404a-407d-8c0f-30b8b2179035">
        <updating/>
        <source>buildDropTableString(_tableName : String) : String updating;
/*

Purpose:			Generate a Drop String for a Table

Parameters:			table name

Return Value:		SQL DROP String

Date			Who		Reason
22 April 2010	conkc1	Initial creation

PAR 24641
*/
constants
	DROP1   : String = "IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[";
	DROP2   : String = "]') AND type in (N'U'))";
	DROP3   : String = "DROP TABLE [dbo].[";
	DROP4   : String = "]";

vars
	dropString : String;
begin
	dropString := DROP1 &amp; _tableName &amp; DROP2 &amp; CrLf &amp; DROP3 &amp; _tableName &amp; DROP4;
	return dropString;
epilog

end;</source>
        <Parameter name="_tableName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildExternalMethodCallDelete" id="81bc3c3f-205e-49d8-9a17-587fea1cc3fa">
        <updating/>
        <source>buildExternalMethodCallDelete(_extractClass : CM_DataDumpExtractClass io;
							  _sqlProc      : String) : String updating;
/*
Purpose:		Builds jade code to call SQL for delete action
				Can be either actual delete or updating the delete column to true in SQL

Parameters:			

Return Value:		

Date			Who		Reason
05 May			2010	conkc1	Initial creation

PAR 24641
23/03/2015		cnwrd1	par 32871 more logging
*/
constants
	MethodLine1 : String = "(o : ";
	MethodLine2 : String = " io; externalDatabase : JMT_SQLNative; _extractionAgent : CM_DataDumpExtractionAgent io";
	MethodLine3 : String = ") : Integer updating;" &amp; CrLf;
	MethodLine4 : String = "vars" &amp; CrLf &amp; Tab &amp; "today : TimeStamp;" &amp; CrLf &amp; 
	                       Tab &amp; "__errorCode : Integer;" &amp; CrLf &amp; 
						   "// -- Generated ";
	MethodLine5 : String = "begin " &amp; CrLf &amp; Tab &amp; "on Exception do _extractionAgent.handleExceptionFromTransientM(exception, o, __errorCode);" &amp; CrLf &amp;
							Tab &amp; "on LockException do app.cnGlobalLockExceptionHandler(exception);" &amp; CrLf &amp; CrLf;
	MethodLine6 : String = "end;";
	CALL1       : String = Tab &amp; "return externalDatabase.jmt_callStoredProcGeneric(";
	INSERT3     : String = Tab &amp; Tab &amp; ")" &amp; CrLf &amp; Tab &amp; " values (" &amp; CrLf;
	
vars

	procedureName    : String;
	methodName       : String;
	parameterString  : String;
	varString        : String;
	assignmentString : String;
	returnString     : String;
	jadeFormat       : String;
	oidFormat        : Integer; 
	today            : TimeStamp;
	debugAssignmentStringTmp,
	debugAssignmentString : String;
begin
	procedureName   := StoredProcPrefix &amp; _extractClass.sqlTableName;
	methodName      := procedureName[1 : 30];

	returnString    := methodName &amp; MethodLine1 &amp; _extractClass.className &amp; 
	                   MethodLine2 &amp; MethodLine3 &amp; MethodLine4 &amp; today.String &amp; CrLf;

	if _extractClass.deleteAction = CM_DataDumpExtractClass.DeleteOpt_SendAll or _extractClass.deleteAction = CM_DataDumpExtractClass.DeleteOpt_SendNo then

		oidFormat := _extractClass.myDataDumpExtractDef.oidFormat;
		jadeFormat := app.getOIDExportFormat(oidFormat);

		varString        := Tab &amp; _extractClass.myDataDumpExtractDef.oidColumnName.padBlanks(30) &amp; " : " &amp; jadeFormat &amp; ";" &amp; CrLf;
		parameterString  :=  _extractClass.myDataDumpExtractDef.oidColumnName;
	
		assignmentString := Tab &amp; _extractClass.myDataDumpExtractDef.oidColumnName  &amp; " := " &amp; 
						"app.dataDumpBuildOIDValue(" &amp; _extractClass.myDataDumpExtractDef.oidFormat.String &amp; ", o)." &amp;
						_extractClass.myDataDumpExtractDef.getOIDCasting &amp; ";" &amp; CrLf;

	elseif _extractClass.deleteAction = CM_DataDumpExtractClass.DeleteOpt_UpdateFlag then
	
		buildOptColsExternalMethodCall(_extractClass, varString, assignmentString, parameterString, debugAssignmentString, "D");
		if parameterString[parameterString.length - 2 : end] = "," &amp; CrLf then
			parameterString[parameterString.length - 2 : 1] := " ";
		endif;
	endif;

	returnString := returnString &amp; varString &amp; CrLf &amp; MethodLine5 &amp; CrLf &amp; assignmentString;

	parameterString := CrLf &amp; CALL1 &amp; '"' &amp; procedureName &amp; _sqlProc &amp; '",' &amp; " " &amp; self.sqlStoredProcIndex.String &amp; ", " &amp; parameterString;

	returnString := returnString &amp; parameterString &amp;");" &amp; CrLf &amp; MethodLine6;
	return returnString;

epilog

end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass" usage="io"/>
        <Parameter name="_sqlProc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildExternalMethodCallInsert" id="bb19ccc8-3240-46a3-908d-5bb1edad155a">
        <updating/>
        <source>buildExternalMethodCallInsert(_extractClass : CM_DataDumpExtractClass io;
							  _sqlProc      : String;
							  _action       : String) : String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2010	conkc1	Initial creation

PAR 24641
23/03/2015		cnwrd1	par 32871 more logging
23/11/2017		jlgdap1	TFS 7511 LNX Issues with attributes with the same names in subclasses not being extracted
*/
constants
	MethodLine1 : String = "(o : ";
	MethodLine2 : String = " io; externalDatabase : JMT_SQLNative; _extractionAgent : CM_DataDumpExtractionAgent io";
	MethodLine3 : String = ") : Integer updating;" &amp; CrLf;
	MethodLine4 : String = "constants" &amp; CrLf &amp; Tab &amp; 
						   "NullDate : Date = null;" &amp; CrLf &amp; Tab &amp;
						   "NullTime : Time = null;" &amp; CrLf &amp; Tab &amp;
						   "NullTimeStamp : TimeStamp = null;" &amp; CrLf &amp;
						   "vars" &amp; CrLf &amp; 
						   Tab &amp; "today : TimeStamp;" &amp; CrLf &amp; 
						   Tab &amp; "result : Integer;" &amp; CrLf &amp; 
						   Tab &amp; "sqlCallInfo : String;" &amp; CrLf &amp; 
						   Tab &amp; "__errorCode : Integer;" &amp; CrLf &amp;
						   "// -- Generated ";
	MethodLine5 : String = "begin " &amp; CrLf &amp; 
	                       Tab &amp; "on Exception do _extractionAgent.handleExceptionFromTransientM(exception, o, __errorCode);" &amp; CrLf &amp; 
						   Tab &amp; "on ODBCException do app.handleODBCCreate(exception, result);" &amp; CrLf &amp;
						   Tab &amp; "on LockException do app.cnGlobalLockExceptionHandler(exception);" &amp; CrLf &amp; CrLf;
	MethodLine6 : String = Tab &amp; "return result;" &amp; CrLf &amp; 
						   "epilog" &amp; CrLf &amp;
						   "end;";						   
	MethodLine7	: String = Tab &amp; "sqlCallInfo := sqlCallInfo ";
	MethodLine8 : String = "&amp; 'procedure name : ' &amp; '";
	MethodLine9 : String = "&amp; 'parameters : '";
	MethodLine10 : String = Tab &amp; '_extractionAgent.sqlCallInfo := sqlCallInfo;' &amp; CrLf;
	CALL1       : String = Tab &amp; "result := externalDatabase.jmt_callStoredProcGeneric(";
	INSERT3     : String = Tab &amp; Tab &amp; ")" &amp; CrLf &amp; Tab &amp; " values (" &amp; CrLf;
	
vars

	sqlColumn        : CM_DataDumpSQLColumn;
	feature          : CM_DataDumpFeature;

	procedureName    : String;
	methodName       : String;
	parameterString  : String;
	varString        : String;
	assignmentStringTmp,
	assignmentString : String;
	debugAssignmentStringTmp,
	debugAssignmentString : String;
	optParamString   : String;
	returnString     : String;
	subClassName     : String;
	tabs             : String;
	propertyType     : String;
	maxLength        : Boolean;
	length           : Integer;
	scaleFactor      : Integer;
	numberOfColumns  : Integer;
	count            : Integer;
	extDBFeature     : CM_ExternalDBFeatureDict;
    featureName      : String;
	today            : TimeStamp;
	
	dataDumpClass    : CM_DataDumpClass;
	subClasses       :ClassColl;
	subClass,
	class		     : Class;
	
	subFeatureName 	: String;						// TFS 7511
	subClassFeature : CM_DataDumpFeature;			// TFS 7511
	iter 			: Iterator;						// TFS 7511
begin

	create extDBFeature transient;

	procedureName   := StoredProcPrefix &amp; _extractClass.sqlTableName;
	methodName      := procedureName[1 : 30];

	returnString    := methodName &amp; MethodLine1 &amp; _extractClass.className &amp; 
	                   MethodLine2 &amp; MethodLine3 &amp; MethodLine4 &amp; today.String &amp; CrLf;

	buildOptColsExternalMethodCall(_extractClass, varString, assignmentString, optParamString, debugAssignmentString, _action);

	
	foreach sqlColumn in _extractClass.allDataDumpSQLColumns do

		varString := varString &amp; Tab &amp; sqlColumn.myDataDumpFeature.featureName.padBlanks(30) &amp; " : ";
		//
		//  Decimals returned from a method have no length so we use the SQL user defined lengths
		//  If these do not match the actual SQL Database a run time error will occur
		//
		if sqlColumn.myDataDumpSQLDataType.name = CM_DataDumpSQLDataType.SQLDecimal then
			varString := varString &amp; "Decimal[" &amp; sqlColumn.length.String &amp; ", " &amp; sqlColumn.decimalDigits.String &amp; "];" &amp; CrLf;
		else
			propertyType := sqlColumn.myDataDumpFeature.getFeatureType(_extractClass.myDataDumpExtractDef.oidFormat,length, scaleFactor, maxLength);
			if _extractClass.myDataDumpExtractDef.sqlServerVersion &lt;&gt; CM_DataDumpExtractDef.SQLVersion2008 then //29/06/2010 cnwdz2 24829
				if propertyType = "Date" or propertyType = "Time" then
					propertyType := "TimeStamp";
				endif;
			endif;
			varString := varString &amp;  propertyType &amp; ";" &amp; CrLf;
		endif;
	
		subFeatureName := sqlColumn.myDataDumpFeature.featureName;													// TFS 7511
		iter := sqlColumn.myDataDumpFeature.myDataDumpClass.allDataDumpFeatures.createIterator;						// TFS 7511
		sqlColumn.myDataDumpFeature.myDataDumpClass.allDataDumpFeatures.startKeyGeq(subFeatureName, null, iter);	// TFS 7511
		while iter.next(subClassFeature) do																			// TFS 7511
			if subClassFeature.featureName &lt;&gt; subFeatureName then													// TFS 7511
				break;																								// TFS 7511
			endif;																									// TFS 7511
			//extDBFeature.add(sqlColumn.myDataDumpFeature);														// TFS 7511
			extDBFeature.add(subClassFeature);																		// TFS 7511
		endwhile;																									// TFS 7511
		delete iter;																								// TFS 7511

	endforeach;	

	returnString := returnString &amp; varString &amp; CrLf &amp; MethodLine5;
	
	returnString := returnString  &amp; MethodLine7 &amp; MethodLine8 &amp; methodName &amp; "' &amp; CrLf;" &amp; CrLf ;
	returnString := returnString  &amp; MethodLine7 &amp; MethodLine9 &amp; " &amp; CrLf;" &amp; CrLf ;
	
	tabs := Tab;
		
	assignmentString := assignmentString &amp; _extractClass.buildInitialiseDateTime(false);
	
	dataDumpClass := _extractClass.myDataDumpClass;
	class         := dataDumpClass.myClass;
	
	//26/10/2010 cnwdz2 26049
	//create assignment string for the class
	self.buildAssignmentStrForExtMethod(_extractClass,extDBFeature,class,null,tabs,assignmentString,debugAssignmentStringTmp);
	
	debugAssignmentString := debugAssignmentString &amp; debugAssignmentStringTmp;

	//26/10/2010 cnwdz2 26049
	create subClasses transient;
	class.allSubclasses(subClasses);
	tabs := Tab &amp; Tab;
	foreach subClass in subClasses do	
		assignmentStringTmp := null;
		debugAssignmentStringTmp := null;
		self.buildAssignmentStrForExtMethod(_extractClass,extDBFeature, subClass, subClass.name, tabs, assignmentStringTmp,debugAssignmentStringTmp);
		if assignmentStringTmp &lt;&gt; null then
			if subClassName &lt;&gt; null then
				assignmentString := assignmentString &amp; Tab &amp; "elseif ";
				debugAssignmentString := debugAssignmentString &amp; Tab &amp; "elseif ";
			else
				assignmentString := assignmentString &amp; CrLf &amp; Tab &amp; "if ";
				debugAssignmentString := debugAssignmentString &amp; CrLf &amp; Tab &amp; "if ";
			endif;
			
			subClassName     := subClass.name;
// PAR 33412			assignmentString := assignmentString &amp; Tab &amp; "self.isKindOf(" &amp; subClassName &amp; ") then" &amp; CrLf;
			assignmentString := assignmentString &amp; Tab &amp; "self.class.name = " &amp; subClassName &amp; ".name then" &amp; CrLf; // PAR 33412
			debugAssignmentString := debugAssignmentString &amp; Tab &amp; "self.class.name = " &amp; subClassName &amp; ".name then" &amp; CrLf; // PAR 33412
			assignmentString := assignmentString &amp; assignmentStringTmp;
			debugAssignmentString := debugAssignmentString &amp; debugAssignmentStringTmp;
		endif;
	endforeach;
	
	if subClassName &lt;&gt; null then
		assignmentString := assignmentString &amp; Tab &amp; "endif;";
		debugAssignmentString := debugAssignmentString &amp; Tab &amp; "endif;";
	endif;

	
	assignmentString := assignmentString &amp; CrLf;

	returnString := returnString &amp; assignmentString;
	
	debugAssignmentString := debugAssignmentString &amp; CrLf;
	
	returnString := returnString &amp; debugAssignmentString;
	
	returnString := returnString &amp; MethodLine10;

	parameterString := CrLf &amp; CALL1 &amp; '"' &amp; procedureName &amp; _sqlProc &amp; '",' &amp; " " &amp; self.sqlStoredProcIndex.String &amp; ", " &amp; CrLf &amp; optParamString;

	numberOfColumns := _extractClass.allDataDumpSQLColumns.size;
	//
	// Build parameter string for method call
	//
	foreach sqlColumn in _extractClass.allDataDumpSQLColumns do

		parameterString := parameterString &amp; Tab &amp; Tab &amp; sqlColumn.myDataDumpFeature.featureName;

		count  := count + 1;
		if count &lt; numberOfColumns then
			parameterString := parameterString &amp; ',' &amp; CrLf;
		endif;

	endforeach;

	returnString := returnString &amp; parameterString &amp;");" &amp; CrLf &amp; MethodLine6;
	//app.raiseCMException(1,null,null);

	
	return returnString;

epilog
	delete subClasses;
	delete extDBFeature;

end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass" usage="io"/>
        <Parameter name="_sqlProc" type="String"/>
        <Parameter name="_action" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildGetColumnPosStoredProc" id="2a6fdc56-e19e-49bb-b258-babed9bd46b5">
        <updating/>
        <source>buildGetColumnPosStoredProc() : String updating;
/*

Purpose:			Stored Procedure is used to retrieve the Column position within
					the SQL table for the given table and Column name.
					This is required if we are to extract data for bulk loading

Parameters:			

Return Value:		Stored Procedure source


Date			Who		Reason
27 May 2010		conkc1	Initial creation

PAR 24641
*/
constants
	CREATEProc     : String = "CREATE PROCEDURE[dbo].[jmt_getColumnOrdinalPosition]"; 
	COMMENT        : String = "-- ";
	VARIBLES       : String = Tab &amp; "@tableName nvarchar(128)," &amp; CrLf &amp;
							  Tab &amp; "@columnName nvarchar(128)";
	DECLARATIONS   : String = Tab &amp; "as " &amp; CrLf &amp; "begin" &amp; CrLf &amp;
							  Tab &amp; "declare @_result int" &amp; CrLf &amp;
							  Tab &amp; "declare @_position int";
	SETNOCOUNT     : String = "set nocount on";
	SELECT         : String = "SELECT @_position = ORDINAL_POSITION FROM INFORMATION_SCHEMA.COLUMNS";
	WHERE          : String = Tab &amp; "WHERE TABLE_NAME = @tableName and COLUMN_NAME = @columnName";
	CODE1          : String = Tab &amp; "if @@ROWCOUNT = 0 or @@error &lt;&gt; 0" &amp; CrLf &amp;
							  Tab &amp; Tab &amp; "set @_result = 9999" &amp; CrLf &amp;
							  Tab &amp; "else" &amp; CrLf &amp;
							  Tab &amp; Tab &amp; "set @_result = @_position" &amp; CrLf &amp;
							  Tab &amp; "end" &amp; CrLf &amp;
							  "return @_result";

vars
	today   : TimeStamp;
begin
	return CREATEProc &amp; CrLf &amp; COMMENT &amp; today.String &amp; CrLf &amp; 
						VARIBLES &amp; CrLf &amp; DECLARATIONS &amp; CrLf &amp; SETNOCOUNT &amp; CrLf &amp;
						SELECT &amp; CrLf &amp; WHERE &amp; CrLf &amp; CODE1;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildJMTControlTableString" id="c08c927b-fd88-4589-8e8a-239cd020f3eb">
        <updating/>
        <source>buildJMTControlTableString(_tableName : String) : String updating;
/*
Purpose:			Builds string to Create JMT_Control table for SQL
					As of 23 June 2010 - this feature has not yet been implemented - next release

Parameters:			Table name - Constant ControlTableName

Return Value:		Source for SQL Create Table

Date				Who		Reason
27 May 2010			conkc1	Initial creation

PAR 24641
*/
constants

	CREATE1 : String = "CREATE TABLE [dbo].[";
	COMMENT : String = "-- ";
	Row1    : String = Tab &amp; "[jversion] [varchar](10) NULL,";
	Row2    : String = Tab &amp; "[juniqueIdentifier] [bigint] NULL,";
	Row3    : String = Tab &amp; "[jlastUpdated] [datetime2] NULL";
	Primary : String = ") ON [PRIMARY]";
vars

	createString    : String;
	today           : TimeStamp;

begin

	createString := CREATE1 &amp; _tableName &amp; "](" &amp; CrLf &amp;
					COMMENT &amp; today.String &amp; CrLf &amp; Row1 &amp; CrLf &amp; 
					Row2 &amp; CrLf &amp; Row3 &amp; CrLf &amp; Primary;


	return createString;
epilog

end;</source>
        <Parameter name="_tableName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildOIDParamsForTableCreate" id="dbba0f1f-5167-4515-8cc7-ee22024fd252">
        <updating/>
        <source>buildOIDParamsForTableCreate(_extractDef : CM_DataDumpExtractDef) : String updating;
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	conkc1	Initial creation

PAR 24641
*/
vars

	columnString    : String;
	oidFormat       : Integer; 
	format          : String;
begin

	oidFormat := _extractDef.oidFormat; 
	format := app.getOIDSQLFormat(oidFormat, true);
	columnString := Tab &amp; "[" &amp; _extractDef.oidColumnName &amp; "] " &amp; format &amp; " PRIMARY KEY,";

	return columnString;

epilog

end;</source>
        <Parameter name="_extractDef" type="CM_DataDumpExtractDef"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildOIDParamsForWhere" id="ae4e16d5-95af-497c-943e-93383fd8f377">
        <updating/>
        <source>buildOIDParamsForWhere(_extractDef : CM_DataDumpExtractDef) : String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2010	conkc1	Initial creation

PAR 24641
*/
vars

	whereString    : String;
	oidFormat      : Integer; 
begin

	oidFormat := _extractDef.oidFormat; 

	if oidFormat = CM_DataDumpExtractDef.OIDFormatHex or
	   oidFormat = CM_DataDumpExtractDef.OIDFormatString then
		whereString   := "[" &amp; _extractDef.oidColumnName &amp; "]" &amp; "=@" &amp; _extractDef.oidColumnName;
	elseif  oidFormat = CM_DataDumpExtractDef.OIDFormatIntegers then
		whereString   := "[" &amp; _extractDef.oidColumnName &amp; ClassID &amp; "]" &amp; "=@" &amp; _extractDef.oidColumnName &amp; ClassID &amp; " and "; 
		whereString   := whereString &amp; "[" &amp; _extractDef.oidColumnName &amp; InstID &amp; "]" &amp; "=@" &amp; _extractDef.oidColumnName &amp; InstID;
	else
		whereString := "invalid oidFormat - '" &amp; oidFormat.String;
	endif;

	return whereString;

epilog

end;</source>
        <Parameter name="_extractDef" type="CM_DataDumpExtractDef"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildOptColsExternalMethodCall" id="6f901c2d-c417-466f-8872-54bf6b856c14">
        <updating/>
        <source>buildOptColsExternalMethodCall(_extractClass   : CM_DataDumpExtractClass;
							_varString         : String output;
							_assignmentString  : String output;
							_parameterString   : String output;
							_debugAssignmentString : String output;
							_action            : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2010	conkc1	Initial creation

PAR 24641
23/03/2015		cnwrd1	par 32871 more logging
*/
vars

	varString        : String;
	assignmentString : String;
	parameterString  : String;
	debugAssignmentString : String;
	jadeFormat       : String;
	oidFormat        : Integer; 
begin

	oidFormat := _extractClass.myDataDumpExtractDef.oidFormat;
	jadeFormat := app.getOIDExportFormat(oidFormat);

	varString        := Tab &amp; _extractClass.myDataDumpExtractDef.oidColumnName.padBlanks(30) &amp; " : " &amp; jadeFormat &amp; ";" &amp; CrLf;
	assignmentString := Tab &amp; _extractClass.myDataDumpExtractDef.oidColumnName  &amp; " := " &amp; 
						"app.dataDumpBuildOIDValue(" &amp; _extractClass.myDataDumpExtractDef.oidFormat.String &amp; ", o)." &amp;
						_extractClass.myDataDumpExtractDef.getOIDCasting &amp; ";" &amp; CrLf;
	parameterString  := Tab &amp; Tab &amp; _extractClass.myDataDumpExtractDef.oidColumnName &amp; "," &amp; CrLf;	
	debugAssignmentString := Tab &amp; "sqlCallInfo := sqlCallInfo &amp; '" &amp; _extractClass.myDataDumpExtractDef.oidColumnName &amp; " = ' &amp; " &amp; 
									"app.dataDumpBuildOIDValue(2, o).asStringJMT &amp; CrLf ;" &amp; CrLf; //cnwrd1 36135 log sqlparams
												
												
	if _extractClass.deleteActionColumnName = null and
	   _extractClass.exportedTimestampColumnName = null and
	   _extractClass.lastOperationColumnName = null then
	   return;
	endif;
	
	if _extractClass.deleteActionColumnName &lt;&gt; null then
		varString        := varString &amp; Tab &amp; _extractClass.deleteActionColumnName.padBlanks(30) &amp; " : " &amp; "Boolean;" &amp; CrLf;
		if _action = "D" then
			assignmentString := assignmentString &amp; Tab &amp; _extractClass.deleteActionColumnName  &amp; " := " &amp; "true;" &amp; CrLf;
			debugAssignmentString := debugAssignmentString &amp; Tab &amp; "sqlCallInfo := sqlCallInfo &amp; '" &amp; _extractClass.deleteActionColumnName  &amp; " = " &amp; "true'  &amp; CrLf;" &amp; CrLf;
		else
			assignmentString := assignmentString &amp; Tab &amp; _extractClass.deleteActionColumnName  &amp; " := " &amp; "false;" &amp; CrLf;
			debugAssignmentString := debugAssignmentString &amp; Tab &amp; "sqlCallInfo := sqlCallInfo &amp; '" &amp; _extractClass.deleteActionColumnName  &amp; " = " &amp; "false'  &amp; CrLf;" &amp; CrLf;
		endif;
		parameterString  := parameterString &amp; Tab &amp; Tab &amp; _extractClass.deleteActionColumnName &amp; "," &amp; CrLf;
	endif;

	if _extractClass.exportedTimestampColumnName &lt;&gt; null then
		varString        := varString &amp; Tab &amp; _extractClass.exportedTimestampColumnName.padBlanks(30) &amp; " : " &amp; "TimeStamp;" &amp; CrLf;
		//14/06/2011 cnwdz2 27712
		assignmentString := assignmentString &amp; Tab &amp; _extractClass.exportedTimestampColumnName  &amp; " := " &amp; "today." &amp; TimeStamp::getValidSQLTimeStamp2005.name &amp; ";" &amp; CrLf;
		
		debugAssignmentString := debugAssignmentString &amp; Tab &amp; "sqlCallInfo := sqlCallInfo &amp; '" &amp; _extractClass.exportedTimestampColumnName  &amp; " = '" &amp; " &amp; today." &amp; TimeStamp::getValidSQLTimeStamp2005.name &amp;        ".String  &amp; CrLf;" &amp; CrLf;
		
		
		parameterString  := parameterString &amp; Tab &amp; Tab &amp; _extractClass.exportedTimestampColumnName &amp; "," &amp; CrLf;
	endif;

	if _extractClass.lastOperationColumnName &lt;&gt; null then
		varString        := varString &amp; Tab &amp; _extractClass.lastOperationColumnName.padBlanks(30) &amp; " : " &amp; "Character;" &amp; CrLf;
		assignmentString := assignmentString &amp; Tab &amp; _extractClass.lastOperationColumnName &amp; " := " &amp; '"' &amp; _action &amp; '"' &amp; ";" &amp; CrLf;
	
		debugAssignmentString := debugAssignmentString &amp; Tab &amp; "sqlCallInfo := sqlCallInfo &amp; '" &amp; _extractClass.lastOperationColumnName &amp; " = " &amp; _action &amp; "' &amp; CrLf;" &amp; CrLf ;			
		
		parameterString  := parameterString &amp; Tab &amp; Tab &amp; _extractClass.lastOperationColumnName &amp; "," &amp; CrLf;
	endif;

	return;
epilog
	_varString         := varString;
	_assignmentString  := assignmentString;
	_parameterString   := parameterString;
	_debugAssignmentString := debugAssignmentString;
end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_varString" type="String" usage="output"/>
        <Parameter name="_assignmentString" type="String" usage="output"/>
        <Parameter name="_parameterString" type="String" usage="output"/>
        <Parameter name="_debugAssignmentString" type="String" usage="output"/>
        <Parameter name="_action" type="String"/>
    </JadeMethod>
    <JadeMethod name="buildOptColsStoredProcInsert" id="56f89532-4afd-4efa-9c5a-a69a020e2398">
        <updating/>
        <source>buildOptColsStoredProcInsert(_extractClass   : CM_DataDumpExtractClass;
							_parameterString : String output;
							_columnString    : String output;
							_valueString     : String output) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2010	conkc1	Initial creation

PAR 24641
*/
vars
	parameterString  : String;
	columnString     : String;
	valueString      : String;
	sqlFormat        : String;
	oidFormat        : Integer; 
	extractDef       : CM_DataDumpExtractDef;
	dateTime         : String;
begin
	extractDef := _extractClass.myDataDumpExtractDef;

	oidFormat := extractDef.oidFormat;
	sqlFormat := app.getOIDSQLFormat(oidFormat, false) &amp; ",";

	parameterString := Tab &amp; "@" &amp; extractDef.oidColumnName &amp; " " &amp; sqlFormat &amp; CrLf;
	columnString    := Tab &amp; "[" &amp; extractDef.oidColumnName &amp; "]," &amp; CrLf;
	valueString     := Tab &amp; "@" &amp; extractDef.oidColumnName &amp; "," &amp; CrLf;

	if _extractClass.deleteActionColumnName = null and
	   _extractClass.exportedTimestampColumnName = null and
	   _extractClass.lastOperationColumnName = null then
	   return;
	endif;
	
	if _extractClass.deleteActionColumnName &lt;&gt; null then
		parameterString := parameterString &amp; Tab &amp; "@" &amp; _extractClass.deleteActionColumnName &amp; " " &amp; "bit," &amp; CrLf;
		columnString    := columnString &amp; Tab &amp; "[" &amp; _extractClass.deleteActionColumnName &amp; "]," &amp; CrLf;
		valueString     := valueString &amp; Tab &amp; "@" &amp; _extractClass.deleteActionColumnName &amp; "," &amp; CrLf;
	endif;

	if _extractClass.exportedTimestampColumnName &lt;&gt; null then
		if extractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 then 
			dateTime := CM_DataDumpSQLDataType.SQLDateTime2;
		else
			dateTime := CM_DataDumpSQLDataType.SQLDateTime;
		endif;
		parameterString := parameterString &amp; Tab &amp; "@" &amp; _extractClass.exportedTimestampColumnName &amp; " " &amp; dateTime &amp; "," &amp; CrLf;
		columnString    := columnString &amp; Tab &amp; "[" &amp; _extractClass.exportedTimestampColumnName &amp; "]," &amp; CrLf;
		valueString     := valueString &amp; Tab &amp; "@" &amp; _extractClass.exportedTimestampColumnName &amp; "," &amp; CrLf;
	endif;

	if _extractClass.lastOperationColumnName &lt;&gt; null then
		parameterString := parameterString &amp; Tab &amp; "@" &amp; _extractClass.lastOperationColumnName &amp; " " &amp; "nvarchar," &amp; CrLf;
		columnString    := columnString &amp; Tab &amp; "[" &amp; _extractClass.lastOperationColumnName &amp; "]," &amp; CrLf;
		valueString     := valueString &amp; Tab &amp; "@" &amp; _extractClass.lastOperationColumnName &amp; "," &amp; CrLf;
	endif;
	
	return;
epilog
	_parameterString := parameterString;
	_columnString    := columnString;
	_valueString     := valueString;
end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_parameterString" type="String" usage="output"/>
        <Parameter name="_columnString" type="String" usage="output"/>
        <Parameter name="_valueString" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="buildOptColsStoredProcUpdate" id="1a17d26d-3dd4-4e0a-a74f-f96a835d4ab2">
        <updating/>
        <source>buildOptColsStoredProcUpdate(_extractClass   : CM_DataDumpExtractClass;
							_parameterString : String output;
							_setString       : String output) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2010	conkc1	Initial creation

PAR 24641
*/
vars
	parameterString  : String;
	setString        : String;
	sqlFormat        : String;
	oidFormat        : Integer; 
	extractDef       : CM_DataDumpExtractDef;
	dateTime         : String;
begin
	extractDef := _extractClass.myDataDumpExtractDef; 
	oidFormat := extractDef.oidFormat;
	sqlFormat := app.getOIDSQLFormat(oidFormat, false) &amp; ",";

	parameterString := Tab &amp; "@" &amp; extractDef.oidColumnName &amp; " " &amp; sqlFormat &amp; CrLf;
	setString       := Tab &amp; ("[" &amp; extractDef.oidColumnName &amp; "]").padBlanks(30) &amp;
					" = @" &amp; extractDef.oidColumnName &amp; "," &amp; CrLf;

	if _extractClass.deleteActionColumnName = null and
	   _extractClass.exportedTimestampColumnName = null and
	   _extractClass.lastOperationColumnName = null then
	   return;
	endif;
	
	if _extractClass.deleteActionColumnName &lt;&gt; null then
		parameterString := parameterString &amp; Tab &amp; "@" &amp; _extractClass.deleteActionColumnName &amp; " " &amp; "bit," &amp; CrLf;
		setString       := setString &amp; Tab &amp; ("[" &amp; _extractClass.deleteActionColumnName &amp; "]").padBlanks(30) &amp; 
						" = @" &amp; _extractClass.deleteActionColumnName &amp; "," &amp; CrLf;
	endif;

	if _extractClass.exportedTimestampColumnName &lt;&gt; null then
		if extractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 then 
			dateTime := CM_DataDumpSQLDataType.SQLDateTime2;
		else
			dateTime := CM_DataDumpSQLDataType.SQLDateTime;
		endif;
		
		parameterString := parameterString &amp; Tab &amp; "@" &amp; _extractClass.exportedTimestampColumnName &amp; " " &amp; dateTime &amp; "," &amp; CrLf;
		setString       := setString &amp; Tab &amp; ("[" &amp; _extractClass.exportedTimestampColumnName &amp; "]").padBlanks(30) &amp; 
						" = @" &amp; _extractClass.exportedTimestampColumnName &amp; "," &amp; CrLf;
	endif;

	if _extractClass.lastOperationColumnName &lt;&gt; null then
		parameterString := parameterString &amp; Tab &amp; "@" &amp; _extractClass.lastOperationColumnName &amp; " " &amp; "nvarchar," &amp; CrLf;
		setString       := setString &amp; Tab &amp; ("[" &amp; _extractClass.lastOperationColumnName &amp; "]").padBlanks(30) &amp; 
						" = @" &amp; _extractClass.lastOperationColumnName &amp; "," &amp; CrLf;
	endif;
	
	return;
epilog
	_parameterString := parameterString;
	_setString       := setString;

end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_parameterString" type="String" usage="output"/>
        <Parameter name="_setString" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="buildOptColsTableCreate" id="dff50893-ef63-4a83-bc04-24715a3a250d">
        <updating/>
        <source>buildOptColsTableCreate(_extractClass : CM_DataDumpExtractClass) : String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2010	conkc1	Initial creation

PAR 24641
*/
vars
	columnString    : String;
	oidFormat       : Integer; 
	extractDef       : CM_DataDumpExtractDef;
	dateTime         : String;
begin
	extractDef := _extractClass.myDataDumpExtractDef; 
	if _extractClass.deleteActionColumnName = null and
	   _extractClass.exportedTimestampColumnName = null and
	   _extractClass.lastOperationColumnName = null then
	   return null;
	endif;
	
	if _extractClass.deleteActionColumnName &lt;&gt; null then
		columnString := columnString &amp; Tab &amp; "[" &amp; _extractClass.deleteActionColumnName &amp; "] [bit] NULL," &amp; CrLf;
	endif;

	if _extractClass.exportedTimestampColumnName &lt;&gt; null then
		if extractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 then 
			dateTime := CM_DataDumpSQLDataType.SQLDateTime2;
		else
			dateTime := CM_DataDumpSQLDataType.SQLDateTime;
		endif;
		columnString := columnString &amp; Tab &amp; "[" &amp; _extractClass.exportedTimestampColumnName &amp; "] [" &amp; dateTime &amp; "] NULL," &amp; CrLf;
	endif;

	if _extractClass.lastOperationColumnName &lt;&gt; null then
		columnString := columnString &amp; Tab &amp; "[" &amp; _extractClass.lastOperationColumnName &amp; "] [nchar] NULL," &amp; CrLf;
	endif;

	columnString := CrLf &amp; columnString;

	return columnString;

epilog

end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="closeDb" id="134a506e-4b35-4b6f-8afc-0f54078f7839">
        <updating/>
        <source>closeDb() updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
//09 Dec 2015	cnwrs1	Par37170 - SQL Native not recovering from SQL shutdown
begin
	self.initialiseClassDetails();

	if self.myExternalDatabase &lt;&gt; null then
		self.myExternalDatabase.close();
	endif;
epilog	
	delete self.myExternalDatabase;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="closeSQLStatementFile" id="c45cc0eb-9632-406e-bdd0-c3eebecfc21b">
        <updating/>
        <source>closeSQLStatementFile(_newClass: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     08 November 2003 by cnwrs1
// ---------------------------------------------------------------------------

vars

begin
	if self.mySQLStatementFile &lt;&gt; null then
		self.mySQLStatementFile.close;
		delete self.mySQLStatementFile;
		self.mySQLStatementFile := null;
		self.sqlStatementFileLineCount := 0;
	endif;
	if _newClass then
		self.sqlStatementFileNumber := 0;
	endif;
end;</source>
        <Parameter name="_newClass" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="commitTrans" id="4586c108-16ba-41ad-89da-df75ea0494c0">
        <updating/>
        <source>commitTrans(_type : String) updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
// PAR 24641
begin
	self.myExternalDatabase.commitExternalTransaction;

	self.log(_type &amp; " - Committed transaction.  " &amp; self.getThenResetTransStats);
end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="createExternalObjAttribute" id="a79ea47e-af03-4b21-b0e1-df87b39c5c92">
        <source>createExternalObjAttribute(_attr: ExternalPrimAttribute) : CM_ExternalObjectAttribute protected;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	extObjAttr : CM_ExternalObjectAttribute;

begin
	create extObjAttr transient;
	extObjAttr.setForCreate(_attr);
	self.allExternalObjAttributes.add(extObjAttr);
	
	return extObjAttr;
end;</source>
        <access>protected</access>
        <Parameter name="_attr" type="ExternalPrimAttribute"/>
