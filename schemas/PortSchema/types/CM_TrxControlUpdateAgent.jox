    <JadeMethod name="trxCompleteRTQueueEntry" id="9d493872-65fd-44b3-9f21-721eca0abf7f">
        <updating/>
        <source>trxCompleteRTQueueEntry(	_rtQueueTask: CM_RTQueueTask input; 
							_completeAllTasks : Boolean;
							_completePickupAndSetdown : Boolean;
							_taskMachine,
							_imvMachine : CM_Machine input; 
							_moveQuantity : Integer;
							_moveWeight : Decimal;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2011	cnwer1	Initial creation

*/

vars
	rtQueueTask : CM_RTQueueTask;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	beginTransaction;

	
	if _completeAllTasks then
		app.myUtilityUA.utlUpdateQueueTaskStatus(_rtQueueTask,TASK_COMPLETE);
	else
		
		if _rtQueueTask.taskType = TASK_BREAKBULK then
			//need to create new task for the pickup
			app.myUtilityUA.utlBreakBulkMasterAccept(_rtQueueTask,rtQueueTask);
			
			if _passport.hasErrors then
				return;
			endif;
			
			//rtQueueTask return will be the pickup task get the setdown if we want to complete the
			// pickup and setdown
			if _completePickupAndSetdown then
				rtQueueTask:=rtQueueTask.myEntry.getDirectorOrSetDownTask();
			endif;
			
		else
			rtQueueTask:=_rtQueueTask;
		endif;	
		
		app.myUtilityUA.utlCompleteRTQueueTask(rtQueueTask ,_taskMachine,_imvMachine , _moveQuantity ,_moveWeight,_passport);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_completeAllTasks" type="Boolean"/>
        <Parameter name="_completePickupAndSetdown" type="Boolean"/>
        <Parameter name="_taskMachine" type="CM_Machine" usage="input"/>
        <Parameter name="_imvMachine" type="CM_Machine" usage="input"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
