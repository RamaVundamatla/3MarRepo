<Class name="CM_RORORampExternalVessel" id="e7e50e0a-4fe9-4ca8-92e6-c341506a28cd">
    <superclass name="CM_RORORampExternal"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="myROROStructure" id="417f7c4c-bc9d-4cec-81b0-e1520f051d01">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_ROROVesselStructure"/>
        <access>readonly</access>
        <Inverse name="CM_ROROVesselStructure::allRamps"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVesselStructuralElement" id="81491796-f683-447c-a324-3d2657011bde">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_VesselStructuralElements"/>
        <access>readonly</access>
        <Inverse name="CM_VesselStructuralElements::allRamps"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneMySelf" id="e8cf855b-9816-4b0d-a51a-5f5cc4b335ba">
        <source>cloneMySelf(_newStructure : CM_VesselStructuralElements) : CM_RORORampExternalVessel ;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	deckItem : CM_DeckItem;
	newMe : SelfType;
begin
	newMe := self.cloneSelf(false);


	newMe.myDeck := null; // no deck as in external
	newMe.myLayout := null; // no layout - not drawn
	newMe.myRampPosition := self.myRampPosition;
	//newMe.myROROStructure := _newStructure;
	newMe.myVesselStructuralElement := _newStructure;
	
	return newMe;
epilog

end;</source>
        <Parameter name="_newStructure" type="CM_VesselStructuralElements"/>
        <ReturnType type="CM_RORORampExternalVessel"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelfForVoyage" id="b3cdcbd5-5893-490a-93ee-af351a55f321">
        <source>cloneMySelfForVoyage(	_newStructure : CM_VoyageStructuralElements;
						_transient : Boolean): CM_RORORampExternalVoyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	newRamp : CM_RORORampExternalVoyage;
begin
	newRamp := self.cloneSelfAs(CM_RORORampExternalVoyage,_transient).CM_RORORampExternalVoyage;
	newRamp.setMyVoyageStructure(_newStructure);
	
	return newRamp;
epilog

end;</source>
        <Parameter name="_newStructure" type="CM_VoyageStructuralElements"/>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_RORORampExternalVoyage"/>
    </JadeMethod>
    <JadeMethod name="delete" id="b5c11029-1f45-48f5-9d2b-49d12458967a">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.isTransient then
		return;
	endif;
	
	if self.myVesselStructuralElement &lt;&gt; null then
		self.myVesselStructuralElement.causeEvent(EVENT_DECK_ITEM_DELETE,false,self);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditParent" id="f195feb1-4e4f-46a4-af1c-2965cb0cf727">
        <source>getAuditParent(): CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin

	if self.myVesselStructuralElement = null then
		return null;
	endif;
	
	
	return self.myVesselStructuralElement.myVessel;

epilog

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getStructure" id="d91d3fba-0565-4d94-804c-236b3f2e09b3">
        <source>getStructure(): CM_VesselStructuralElements;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myVesselStructuralElement;

epilog

end;</source>
        <ReturnType type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="23309265-a8e0-4568-bd7e-61b0b9e13a2f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxyRampExternalVessel : SelfType;
	completedOK		: Boolean;
	
begin
	pxyRampExternalVessel:= inheritMethod();
	
	//pxyRampExternalVessel.myROROStructure:=self.myROROStructure;
	pxyRampExternalVessel.myVesselStructuralElement:=self.myVesselStructuralElement;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRampExternalVessel;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRampExternalVessel;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4b54df20-83ed-43fa-8e9c-db5aa6b94a6f">
        <updating/>
        <source>setForUpdate(_proxyRORORamp: SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031
20 June 2011	cnwer1	added auditing
*/

vars
	vessel : CM_Vessel;
	beforeAuditText,
	afterAuditText	: String;
	realStructure : CM_VesselStructuralElements;
begin

	realStructure:=_proxyRORORamp.myVesselStructuralElement;
	
	if  realStructure &lt;&gt; null then
		beforeAuditText:=realStructure.getAuditText;
	endif;
	
	inheritMethod(_proxyRORORamp,_passport);

	self.myVesselStructuralElement:=realStructure;

	if self.myVesselStructuralElement &lt;&gt; null then
		
		//CCMS 1116 added auditing - attached audits to vesssel
		vessel:= self.myVesselStructuralElement.myVessel;
		afterAuditText:=self.myVesselStructuralElement.getAuditText;
		app.myAA.auditUpdateTrx(vessel,beforeAuditText, afterAuditText);
		
	
		if _proxyRORORamp.pxyGetRealObject =null then
			self.myVesselStructuralElement.causeEvent(EVENT_DECK_ITEM_CREATE,false,self);
		else
			self.myVesselStructuralElement.causeEvent(EVENT_DECK_ITEM_UPDATE,false,self);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxyRORORamp" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyROROStructure" id="7693d6df-ed1a-427b-b9ac-4d02381e8119">
        <updating/>
        <source>setMyROROStructure(_value : CM_VesselStructuralElements) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.myVesselStructuralElement:=_value;
epilog

end;</source>
        <Parameter name="_value" type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="setMyVesselStructElements" id="af2d4d86-46dd-4d97-b5fb-0cfd0688a765">
        <updating/>
        <source>setMyVesselStructElements( _vesStructElement : CM_VesselStructuralElements) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2013	cnwrd1	Initial creation

*/

vars

begin
	if not _vesStructElement.isKindOf(CM_VesselStructuralElements) then //cnwrd1 par 31874
	// ONLY STORE SECTIONS ON THE CELLULAR STRUCTURE NOT THE RORO STRUCTURE
		app.raiseCMException2(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,null,null);
		return;
	endif;
	
	self.myVesselStructuralElement :=_vesStructElement;
epilog

end;</source>
        <Parameter name="_vesStructElement" type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="fbb0dcab-dd45-4175-848a-acd08a90e6ee">
        <source>validateUpdate(_passport: CM_Passport);

/*

Purpose:		Validate ramp code	

Parameters:			

Return Value:		


Date			Who		Reason
18 October 2011	cnwmh5	Initial creation #28440

*/

vars
	realRamp		: CM_RORORampExternalVessel;
	ramp			: CM_RORORampExternalVessel;
begin
	inheritMethod(_passport);
	
	if self.myVesselStructuralElement &lt;&gt; null then
		
		realRamp := self.pxyGetRealObject();
		ramp := self.myVesselStructuralElement.allRamps[self.code];
		if ramp &lt;&gt; null and ramp &lt;&gt; realRamp then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
		endif;
	
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
