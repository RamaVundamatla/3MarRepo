    <JadeMethod name="setProxyExchangeData" id="841df96b-243a-4cab-8786-8cb1265e200a">
        <updating/>
        <source>setProxyExchangeData(_starboardBerthed : Boolean; 
					_pilotOnBoardDT,
					_labourOB,
					_labourOS:TimeStamp;
					_dateAvailable:Date;
					_shipExchangeDT,
					_shipExchangeCompleteDT,
					_departTargetDT	: TimeStamp;
					_totalTimeInPort:Decimal;
					_nonChargeTime:Decimal;
					_stopChargingAt:String;
					_loadRate:Decimal;
					_dischargeRate:Decimal;
					_status : Integer;
					_pilotReturnDT : TimeStamp;
					_anchorDownDT : TimeStamp;
					_checkShipLanderSeals : Boolean;
					_voyageProcess : CM_VoyageProcess	) updating;		// TFS 37427
//-----------------------------------------
// Created: August 2005 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 15/03/2018	jlgdap1		TFS 37427 PEL1 Voyage Status Enhancements
vars

begin
	self.starboardBerthed		:=	_starboardBerthed;
	self.labourOnBoard			:=	_labourOB;
	self.labourOnShore			:=	_labourOS;
	self.dateFirstAvailable		:=	_dateAvailable;
	self.shipExchangeDate		:=	_shipExchangeDT;
	self.shipExchangeCompleteDT	:=	_shipExchangeCompleteDT;
	self.pilotOnBoardDT			:=	_pilotOnBoardDT;
	self.departTargetDT			:=	_departTargetDT;
	self.totalTimeInPort		:=	_totalTimeInPort;
	self.nonChargeTime			:=	_nonChargeTime;
	self.stopChargingAt			:=	_stopChargingAt;
	self.loadRate				:=	_loadRate;
	self.dischargeRate			:=	_dischargeRate;
	if _status &lt;&gt; Voyage_Status_Archived then		//cnwmc5 - 26 July 2013 - PAR 31714
		self.status				:=	_status;
	endif;
	// KPI MODULE CCMS 1002. AKB2007SEP
	self.shipAnchorDownDT := _anchorDownDT;
	self.shipPilotReturnDT := _pilotReturnDT;
	
	self.myVoyageProcess		:= _voyageProcess;			// TFS 37427
	
	//cnwer1 8/12/09 PAR 21806 CCMS 1900
	global.setExtraData(self.allStateData,self,IsShipLanderSealCheck,_checkShipLanderSeals);
	
end;</source>
        <Parameter name="_starboardBerthed" type="Boolean"/>
