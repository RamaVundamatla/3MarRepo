begin
	//return app.getString(SubTerminal_GC);
	return "Sub-Terminal"; //09 Oct 2013	NDL	Par 32456
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="0957aada-ca7d-47c7-8120-e200ae2c1f66">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
begin
	return _cmifAutoPlan.isSubTerminal_Match(_yaData);
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="8167c104-b83a-48df-8e2e-1ee44b272df9">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars
	subTerm		: CM_SubTerminal;

begin
//	subTerm := _ti.mySubTerminal;
	
	if _tiTrx &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		subTerm := _tiTrx.mySubTerminal;
	else
		subTerm := _ti.mySubTerminal;
	endif;
	
	// specific value - 31221 handle wild cards as well
	if _criteria.myYAData.CM_YADataObjects.matchesStorage(subTerm) then
		return true;
	endif;
	
	// default value
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
