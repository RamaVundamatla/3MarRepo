    <JadeMethod name="doCmbBayBuild" id="36ffa2d5-2b5b-458e-b553-63c18bbdecad">
        <source>doCmbBayBuild(_structure : CM_CellularVoyageStructure) protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aBay : CM_BayVoyage;
begin
	self.cmbBays.clear;
	if _structure = null then
		return;
	endif;
	
	self.cmbBays.sorted := false;

	foreach aBay in _structure.allBayVoyagesByOrdinal do
		self.cmbBays.addItemObject(aBay.id, aBay);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_structure" type="CM_CellularVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="doCmbCargoTypeBuild" id="6d11de8b-1502-43eb-9ccb-2ef8c50d3696">
        <source>doCmbCargoTypeBuild();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
21 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
					Fixed display of Cargo Type colour

*/

vars
	aCargo : CM_CargoType;
	idx : Integer;
	tmpCombo	: CMUI_ComboBox;
	colour			: Integer;
	
begin
	tmpCombo := self.cmbCargoType;
	tmpCombo.clear;
	tmpCombo.sorted := true;

	idx := tmpCombo.addItem('');
	tmpCombo.itemBackColor[idx] := White;
	tmpCombo.itemForeColor[idx] := Black;

	foreach aCargo in app.myRoot.allCargoTypesById do
		// from 31981 skip not-available-for-entry cargo types
		if aCargo.isNotAvailableForEntry then
			continue;
		endif;
		idx := tmpCombo.addItem(aCargo.description);
		tmpCombo.itemObject[idx] := aCargo;
		
		colour := aCargo.getDrawColour;				// PAR #16753
		tmpCombo.itemBackColor[idx] := colour;
		tmpCombo.itemForeColor[idx] := colour.getInverseColour();

		if aCargo.classNameToCreate = CM_Container.name then
			tmpCombo.listIndex := idx;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCargoTypeDefault" id="7e1e4061-24db-4240-a0cd-3b7049a30e08">
        <source>doCmbCargoTypeDefault();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	foreach idx in 1 to self.cmbCargoType.listCount() do
		if self.cmbCargoType.itemObject[idx].CM_CargoType.classNameToCreate = "CM_Container" then
			self.cmbCargoType.listIndex := idx;
			self.cmbCargoType.backColor := self.cmbCargoType.itemBackColor[self.cmbCargoType.listIndex];
			self.cmbCargoType.foreColor := self.cmbCargoType.itemForeColor[self.cmbCargoType.listIndex];
			break;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCommodityBuild" id="cae93f0d-5cde-4dea-9c91-c75d60e04971">
        <source>doCmbCommodityBuild();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aCommodity : CM_CommodityGroup;
	idx : Integer;
	tmpCombo	: CMUI_ComboBox;

begin
	tmpCombo := self.cmbCommodity;

	tmpCombo.clear;
	tmpCombo.sorted := true;

	idx := tmpCombo.addItem('');
	tmpCombo.itemBackColor[idx] := White;
	tmpCombo.itemForeColor[idx] := Black;

	foreach aCommodity in app.myRoot.allCommodityGroups do
		if aCommodity.isAvailableForEntry then // this has the wrong label it is actually NOT available
			continue;
		endif;
		idx := tmpCombo.addItem(aCommodity.code &amp; " " &amp; aCommodity.description);
		tmpCombo.itemObject[idx] := aCommodity;
		tmpCombo.itemBackColor[idx] := aCommodity.colour;
		tmpCombo.itemForeColor[idx] := aCommodity.colour.getInverseColour();
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbJobBuild" id="8d2fccb9-79d5-4901-a1ab-e7e6ee98ce08">
        <updating/>
        <source>doCmbJobBuild() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/08/2016		cnwma1		 2557:SPT - Missing Planned Location on Sequence Sheets- Issue not fixed from previous TFS
// ---------------------------------------------------------------------------

vars
	idx			: Integer;
	aVoyage		: CM_Voyage;
	theVoyageJS	: CM_VoyageJobSheet;
	aCrane		: CM_Machine;
	theJob		: CM_Job;
	aVoyageJob	: CM_VoyageJob;
	jobNumber	: Integer;
	maxJobNumber: Integer;

begin

	self.cmbJob.clear;
	self.cmbJob.sorted := true;
	//epr par 33070 30/12/13
	if self.displayMode = ShpDisplayMode_ColCodeDisch then 
		self.chkOutOfSequence.value := false;
		self.chkOutOfSequence.enabled:=false;
	elseif  self.displayMode = ShpDisplayMode_ColCodeLoad then 
		self.chkOutOfSequence.enabled:=true;
		self.chkOutOfSequence.value := self.myCurrentVoyage.createOutOfSequenceLoadJobs(); //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;
	//Moved to form Painter.  Style has been changed as per PAR6791 27112003
	//Changed back to Style_DropDown - can't add jobs in other styles	JC 28/11/2003
	self.cmbJob.style := ComboBox.Style_DropDown;  //ComboBox.Style_DropDown;

	self.cmbJob.maxLength := 30; // max job number length
	
	aVoyage := self.myCurrentVoyage;
	if aVoyage = null then
		return;
	endif;
	
	aCrane := self.cmbCrane.listObject.CM_Machine;
	if aCrane &lt;&gt; null then
		theVoyageJS :=  aVoyage.allJobSheets[aCrane.id.trimBlanks];
	endif;

	maxJobNumber := aVoyage.getNextJobNumber(theVoyageJS, aCrane.CM_Crane.IF_VoyageWorkPoint).Integer;
	
	if theVoyageJS = null then
		//foreach theJob in aVoyage.allVoyageJobs do  25/08/2016 cnwma1 TFS#2557
// TFS 3272		foreach theJob in aVoyage.allVoyageJobs where not theJob.isKindOf(CM_VoyageROROJob) do //25/08/2016 cnwma1 TFS#2557
		foreach theJob in aVoyage.allVoyageJobs where theJob.isVoyageJob() do // TFS 3272 only LOLO jobs
			aVoyageJob := theJob.CM_VoyageJob;
			if aVoyageJob.myJobSheet = null then
				jobNumber := aVoyageJob.jobNum.extractNumber.Integer;
				if jobNumber &gt; maxJobNumber then
					maxJobNumber := jobNumber;
				endif;
				
				if self.displayMode = ShpDisplayMode_ColCodeDisch then 
					if aVoyageJob.isDischarge  
					  or aVoyageJob.jobType = JOB_TYPE_USER
					  or aVoyageJob.jobType = JOB_TYPE_SOB then
						idx := self.cmbJob.addItem(aVoyageJob.jobNum);
						self.cmbJob.itemObject[idx] := theJob;
					endif;
				endif;
				if self.displayMode = ShpDisplayMode_ColCodeLoad then
					if not aVoyageJob.isDischarge 
					or aVoyageJob.jobType = JOB_TYPE_USER
					or aVoyageJob.jobType = JOB_TYPE_SOB then
						idx := self.cmbJob.addItem(aVoyageJob.jobNum);
						self.cmbJob.itemObject[idx] := theJob;
					endif;
				endif;
			endif;		
		endforeach;
	else
	
		foreach theJob in theVoyageJS.allJobsByOrder do
			aVoyageJob := theJob.CM_VoyageJob;
			jobNumber := aVoyageJob.jobNum.extractNumber.Integer;
			if jobNumber &gt; maxJobNumber then
				maxJobNumber := jobNumber;
			endif;
			if self.displayMode = ShpDisplayMode_ColCodeDisch then 
				if aVoyageJob.isDischarge  
				or aVoyageJob.jobType = JOB_TYPE_USER
				or aVoyageJob.jobType = JOB_TYPE_SOB then
					idx := self.cmbJob.addItem(aVoyageJob.jobNum);
					self.cmbJob.itemObject[idx] := theJob;
				endif;
			endif;
			if self.displayMode = ShpDisplayMode_ColCodeLoad then
				if not aVoyageJob.isDischarge 
				or aVoyageJob.jobType = JOB_TYPE_USER
				or aVoyageJob.jobType = JOB_TYPE_SOB then
					idx := self.cmbJob.addItem(aVoyageJob.jobNum);
					self.cmbJob.itemObject[idx] := theJob;
				endif;
			endif;
		
		endforeach;
	endif;
	
	


	self.cmbJob.listIndex := -1;	

	//auto job number generation CCMS 1369

	if maxJobNumber &lt; 10 and app.myRoot.client = Client_CentrePort then
		self.cmbJob.text := maxJobNumber.String.padLeadingZeros(2);
	else
		self.cmbJob.text := maxJobNumber.asStringJMT;
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbJobClick" id="2e6af62d-c980-4878-a613-77546ded98f1">
        <updating/>
        <source>doCmbJobClick(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpJob 			: CM_VoyageJob;
	tmpDrawController	: SHP_BayDrawingController;
	tmpHatchLidJob	: CM_VoyageHatchLidJob;
	tmpHatchLid		: CM_HatchLid;
	tmpRequest		: CM_SlotRequest;
	tmpSlot			: CM_SlotController;
	inLoadMode		: Boolean;
	
begin
	if combobox.listObject = null then
		return;
	endif;
	tmpJob := combobox.listObject.CM_VoyageJob;
	self.setCurrentJob(tmpJob);

	if tmpJob = null then
		return;
	endif;

	inLoadMode := (self.displayMode = ShpDisplayMode_ColCodeLoad);

	self.myBayDrawingController.selectObjectsForJob(tmpJob, inLoadMode, true);
		
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbPortDisBuild" id="b2ddf963-1d97-434d-b4bc-1c7b255c1a91">
        <source>doCmbPortDisBuild();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aPort, listPort : CM_Port;
	idx : Integer;
	tmpCombo	: CMUI_ComboBox;
	portCmbOrderDescrFirst : Boolean;
	invalidPort: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, aPort, invalidPort);
	
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	tmpCombo := self.cmbPortDis;
	listPort := tmpCombo.listObject.CM_Port;
	tmpCombo.clear;
	
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	tmpCombo.sorted := false; //ccms 1058 cnwer1 11/5/09

	idx := tmpCombo.addItem('');
	tmpCombo.itemBackColor[idx] := White;
	tmpCombo.itemForeColor[idx] := Black;

	foreach aPort in self.myCurrentVoyage.allPorts do
		idx := tmpCombo.addItem(aPort.getDisplayFormatted(portCmbOrderDescrFirst));
		if invalidPort then
			invalidPort := false;
			continue;
		endif;
		tmpCombo.itemObject[idx] := aPort;
		tmpCombo.itemBackColor[idx] := aPort.colour;
		tmpCombo.itemForeColor[idx] := aPort.colour.getInverseColour();
	endforeach;
	if tmpCombo.findObject(listPort) &gt; 0 then // PAR 14579
		tmpCombo.listObject := listPort;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbPortDisDefault" id="a2546af7-eb3e-41ac-8557-71aeb31786c5">
        <source>doCmbPortDisDefault() ;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aPort : CM_Port;
begin
	//aPort := app.myRoot.allPorts[self.myTerminal.getConfig(PortDestCode).String.trimBlanks];
	aPort := app.myRoot.allPorts[self.myTerminal.getConfig(PortDestCode).String.trimBlanks];
	self.cmbPortDis.listIndex := self.cmbPortDis.findObject(aPort);
	if self.cmbPortDis.listIndex &gt; 0 then
		self.cmbPortDis.backColor := self.cmbPortDis.itemBackColor[self.cmbPortDis.listIndex];
		self.cmbPortDis.foreColor := self.cmbPortDis.itemForeColor[self.cmbPortDis.listIndex];
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doContextMenuAssignRelease" id="73933901-6d50-4c3d-8527-73a7ef06d1ef">
        <updating/>
        <source>doContextMenuAssignRelease(slotRequest : CM_SlotRequest input) updating;
// Build a context menu of bulk releases that can be used for current voyage
/* Changes

Date		Name	TFS#	Description
============================================================================
23/12/2019	jlgka1	48113	JMT - LOLO Planning Load Release Request Info.
							To make sure that the macro information and the sub menu caption are both in sync 
							use the same method to manage the caption format.
14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
============================================================================*/
vars
	contextSlot : CM_SlotRequest;
	assignReleaseMenu : MenuItem; 
	assignReleaseSubMenu : MenuItem;
	bulkReleases : CM_BulkReleaseByTypeStCodeDict;
	bulkRelease	: CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	iter : Iterator;
	typeKey,
	statusKey			: Integer;
	codeKey				: String;
	dtKey				: TimeStamp;
	
begin
	contextSlot := findContextSlot(slotRequest); 
	if contextSlot &lt;&gt; null then
		assignReleaseMenu := self.mnuAssignRelease.loadMenu(1);  
		assignReleaseMenu.visible := true;
		assignReleaseMenu.enabled := true;
		assignReleaseMenu.caption := "Assign Release";
		assignReleaseMenu.userObject := contextSlot;
		self.allVoyAreaMenuItems.add(assignReleaseMenu);
		
		// Find all relevent BulkReleases
		//bulkReleases := app.getMyTerminal.allBulkReleaseByTypeByStByCd; //- cnwmd1, Par 20643
		bulkReleases := self.myTerminal.allBulkReleaseByTypeByStByCd; //+ cnwmd1, Par 20643
		iter := bulkReleases.createIterator();
		bulkReleases.startKeyGeq(BR_TYPE_SHIP, BR_ACTIVE, null, null, iter);
		while iter.next(bulkRelease) do 
			iter.getCurrentKeys(typeKey,statusKey,codeKey,dtKey); //MTN-35226
			if typeKey &lt;&gt; BR_TYPE_SHIP or statusKey &lt;&gt; BR_ACTIVE then
				break;
			endif;
			// Only want bulk release for current voyage
			if bulkRelease.myVoyage = self.myCurrentVoyage and
					bulkRelease.myDischargePort &lt;&gt; null and
					//bulkRelease.myOperator &lt;&gt; null then
					( bulkRelease.myOperator &lt;&gt; null or bulkRelease.myOperatorGroup &lt;&gt; null )	//12 Mar 2012	NDL	Par 29248
					then
				foreach reserveDetail in bulkRelease.allReserveDetails do
					if reserveDetail.isKindOf(CM_ReserveSelection) then
						assignReleaseSubMenu := assignReleaseMenu.loadSubMenu(self.allVoyAreaMenuItems.size+1);	
						
						//jlgka1 TFS 48113 --&gt;						
						assignReleaseSubMenu.caption := reserveDetail.setExtraInfoCaption(bulkRelease, reserveDetail);
						/*
						isoCode := reserveDetail.getISOTypeCode();     // PAR 25283
						if isoCode = "" then
							isoCode := reserveDetail.getISOGroupCode();
						endif;						
						
						if  bulkRelease.myOperator &lt;&gt; null then
							assignReleaseSubMenu.caption := 
								bulkRelease.getOperatorCode() &amp; " " &amp; 
								isoCode &amp; " " &amp;
								bulkRelease.myDischargePort.code &amp; " " &amp; 
								"(" &amp; bulkRelease.code &amp; ")";
						else	//12 Mar 2012	NDL	Par 29248
							assignReleaseSubMenu.caption := 
								bulkRelease.myOperatorGroup.code &amp; " " &amp; 
								isoCode &amp; " " &amp;
								bulkRelease.myDischargePort.code &amp; " " &amp; 
								"(" &amp; bulkRelease.code &amp; ")";
						endif;
						location := reserveDetail.getLocationLC();		// PAR 18617
						if location &lt;&gt; null then
							assignReleaseSubMenu.caption := assignReleaseSubMenu.caption &amp; " " &amp; location.getID();
						endif;*/
						//jlgka1 TFS 48113 &lt;--
						assignReleaseSubMenu.visible := true;
						assignReleaseSubMenu.setEventMapping(MenuItem::click.name,SHP_VoyageAreaForm2::doMnuAssignRelease_click.name);
						assignReleaseSubMenu.userObject := reserveDetail;
						self.allVoyAreaMenuItems.add(assignReleaseSubMenu);
					endif;
				endforeach;
			endif;
		endwhile;
		
		if self.allVoyAreaMenuItems.size = 1 then
			// No context found so remove the menu
			self.allVoyAreaMenuItems.purge;
		endif;
		
	endif;	
epilog
	delete iter; //epr par 18417 3/11/08
end;
</source>
        <Parameter name="slotRequest" type="CM_SlotRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doContextMenuBuild" id="554dfd83-78e0-4e27-80ea-96d257a3863f">
        <updating/>
        <source>doContextMenuBuild(cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	theObj	: Object;
	theJob : CM_VoyageJob;
	lTI : CM_TrackedItem;
	theSlotController : CM_SlotController;
	tis : CM_TIArray;	amLinked : Boolean;
	theRequest : CM_SlotRequest;
	mcRequest : CM_Request;
	tmpPlanMode	: Boolean;
	tmpBayFrame	: SHP_BayDrawingFrame;
begin
	tmpPlanMode := (self.workingMode = WorkMode_Plan);

	self.saveX := (cntrl.left + x).rounded;
	self.saveY := (cntrl.top + y).rounded;

	if SHP_BayDrawingFrame.hasInstance(cntrl) then
		tmpBayFrame := cntrl.SHP_BayDrawingFrame;
		theObj := tmpBayFrame.getObjectForPosition(x, y);
	endif;
	self.mnuCreateQuickTI.visible := app.isSpecial;
	self.doTurnOffContextMenus();
	self.mnuGridFlipH.visible := true;
	self.mnuGridFlipV.visible := true;
	self.mnuGridPlanDischarge.userObject := null;
	self.mnuGridSelectAreas.visible := true;
	
//	if self.myBayDrawingController.myConfig.shipSelectByHolds then
	if self.selectMode = self.SelectModeHold then
		self.mnuGridSelectAreas.caption := "&amp;Select Holds...";
	else
		self.mnuGridSelectAreas.caption := "&amp;Select Bays...";
	endif;
//	self.mnuGridLink.visible := (self.viewModeBay = ShpViewMode_ColCodeDisch or  self.viewModeBay = ShpViewMode_ColCodeLoad);
	self.mnuGridNewJob.visible := false;
	if theObj &lt;&gt; null and tmpBayFrame &lt;&gt; null then
		self.mnuGridNewJob.visible := (self.workingMode = WorkMode_Job);
		self.mnuGridNewJob.userObject := tmpBayFrame.myBay;
	endif;
	self.mnuGridShuffle.caption := "&amp;Shuffle Cargo Order...";
	self.mnuGridBigFont.visible := true;
//	if self.myCurrentDrawingController &lt;&gt; null then		// 27/7/16 cnwmp6 TFS 1601
//		self.mnuGridSelector.visible := true;
//		self.mnuGridSelectorClear.visible := (not self.myCurrentDrawingController.allSelectorTIs.isEmpty);
//	else
		self.mnuGridSelector.visible := false;
		self.mnuGridSelectorClear.visible := false;
//	endif;
//	self.mnuGridNewJobSeed.visible := (self.workingMode = WorkMode_Job);
	// Turned this off. CCMS 1384
	self.mnuGridNewJobSeed.visible := false;
	
	if theObj &lt;&gt; null then
		if theObj.isKindOf(CM_SlotController) then
			theSlotController := theObj.CM_SlotController;
			
			self.mnuGridShuffle.visible := 
					((self.displayMode = ShpDisplayMode_Actual or self.displayMode = ShpDisplayMode_EDI) and 
					theSlotController.allTrackedItemsById.size &gt; 1);
			if self.mnuGridShuffle.visible = false then
				self.mnuGridShuffle.visible := (self.displayMode = ShpDisplayMode_ColCodeLoad and theSlotController.allPlannedFutureMoves.size &gt; 1);
			endif;
			// PAR 21939foreach lTI in theSlotController.allTrackedItemsById do
			// PAR 21939	self.doBuildMnuContainer(lTI);
			// PAR 21939endforeach;
			
			// PAR 21939 look at actual and proposed
			if self.displayMode = ShpDisplayMode_Actual then
				foreach lTI in theSlotController.allTrackedItemsById do
					self.doBuildMnuContainer(lTI);
				endforeach;
			elseif self.displayMode = ShpDisplayMode_Proposed then
				create tis transient;
				theSlotController.getProposedTIs(tis);
				foreach lTI in tis do
					self.doBuildMnuContainer(lTI);
				endforeach;
			endif;
			
			
			if self.displayMode = ShpDisplayMode_ColCodeLoad then

				self.mnuGridLocateLoadList.visible := true;
				self.mnuGridLocateYardRow.visible := true;
				theRequest := theSlotController.mySlotRequestLoad;
				if theRequest &lt;&gt; null then

					theJob := theRequest.myJob.CM_VoyageJob;
					//_bayPoint.colLoadMyJobIsComplete := theRequest.myJob.isJobComplete;

					self.doContextMenuAssignRelease(theRequest);
					
					self.doContextMenuReverseMenu(theRequest);
					// Only if there is a link
					amLinked := theRequest.isLinked(); // PAR 28968 mySlotRequestDLRSOBDischarge &lt;&gt; null;
					self.mnuGridReLink.visible := amLinked;
					self.mnuGridDeLink.visible := amLinked;
					self.mnuGridLink.visible := not amLinked;
					self.mnuGridLinkMain.visible := self.mnuGridReLink.visible;
					if self.workingMode = WorkMode_Plan and theRequest &lt;&gt; null and theRequest.myJob &lt;&gt; null then
						self.mnuGridFullAutoPlan.visible := true;
						self.mnuGridFullAutoPlan.userObject := theRequest.myJob;
						self.mnuGridFullAutoPlan.caption := "Auto Load Plan Job " &amp; theRequest.myJob.CM_VoyageJob.jobNum &amp; "...";
						
					endif;
					
					if self.workingMode = WorkMode_Plan  //ccms 1303
						and theRequest &lt;&gt; null 
						and theRequest.myJob &lt;&gt; null 
						and theRequest.myJob.isAllowOutOfOrderLoading 
						and theRequest.getFirstAllocation &lt;&gt; null then
							self.mnuAllocateCargo.visible := true;
							self.mnuAllocateCargo.userObject := theRequest.myJob;
							self.mnuAllocateCargo.caption := app.getErrorString1(Manage_allocated_cargo, theRequest.myJob.CM_VoyageJob.jobNum  );
					endif;
					
					if self.workingMode = WorkMode_Plan and 
					   app.myMoveController &lt;&gt; null and
					   app.myMoveController.myTrackedItem &lt;&gt; null then
						self.mnuGridPlanDischarge.visible := amLinked and theRequest.isSOB;
					
						if (not self.mnuGridPlanDischarge.visible) then
							mcRequest := app.myMoveController.mySlotRequest;
							self.mnuGridPlanDischarge.visible :=  mcRequest &lt;&gt; null 
																			and not mcRequest.isReleaseType() // PAR 28968
																			and mcRequest.isSOB and theRequest.isSOB;
						else
							mcRequest := theRequest.getLinkedRequest(false); // mySlotRequestDLRSOBDischarge;
							self.mnuGridPlanDischarge.visible := not theRequest.hasTIsOfMode(PLANNING_MODE);
						endif;
	
						if self.mnuGridPlanDischarge.visible then
							self.mnuGridPlanDischarge.caption := "Planned &amp;SOB from " &amp; mcRequest.getLC().getFullId(); // PAR 28968 mySlotController.getFullId();
							self.mnuGridPlanDischarge.userObject := theSlotController;
							app.myMoveController.setMyOriginatingLocation(mcRequest.getLC()); // PAR 28968 mySlotController);
						endif;
					else
						self.mnuGridPlanDischarge.visible := false;
					endif;
				endif;
			endif;
			if self.displayMode = ShpDisplayMode_ColCodeDisch then
				theRequest := theSlotController.mySlotRequestDischarge;
				if theRequest &lt;&gt; null then

					theJob := theRequest.myJob.CM_VoyageJob;

					// Only if there is a link
					amLinked := theRequest.isLinked(); // PAR 28968 mySlotRequestDLRSOBLoad &lt;&gt; null;
					self.mnuGridReLink.visible := amLinked;
					self.mnuGridDeLink.visible := amLinked;
					self.mnuGridLink.visible := not amLinked;
					self.mnuGridSelectCargo.visible := theSlotController.allTrackedItems.size &gt; 1; //theRequest.allWorkListEntries.size &gt; 1;
					if self.mnuGridSelectCargo.visible then
						self.mnuGridSelectCargo.userObject := theRequest;
					else
						self.mnuGridSelectCargo.userObject := null;
					endif;
				endif;
			endif;
			
			// ###########
			// UNPLAN MENU - note there is also an unplan TI in the cargo sub menu
			if self.displayMode = ShpDisplayMode_ColCodeLoad or 
			   self.displayMode = ShpDisplayMode_ColCodeDisch then
				self.mnuGridUnplanBay.visible := theSlotController.myBayVoyage.hasPlannedTIs(self.displayMode = ShpDisplayMode_ColCodeLoad);
				if self.mnuGridUnplanBay.visible then
					self.mnuGridUnplanBay.userObject := theSlotController.myBayVoyage;
					self.mnuGridUnplan.visible := true;
				endif;
				self.mnuGridUnplanSlot.visible := theSlotController.hasPlannedTIs(self.displayMode = ShpDisplayMode_ColCodeLoad);
				if self.mnuGridUnplanSlot.visible then
					self.mnuGridUnplanSlot.userObject := theSlotController;
					self.mnuGridUnplan.visible := true;
				endif;
				if theJob &lt;&gt; null then
					self.mnuGridUnplanJob.visible := theJob.hasPlannedTIs(self.displayMode = ShpDisplayMode_ColCodeLoad);
					if self.mnuGridUnplanJob.visible then
						self.mnuGridUnplanJob.userObject := theJob;
						self.mnuGridUnplan.visible := true;
					endif;
				endif;
			endif;
			// ##################
			// AUTO PLAN DISCHARGE MENU
			// if this slot has TIs and is Discharge colour coded then allow auto plan discharge
			self.mnuGridAutoplanSlot.visible := (tmpPlanMode and not theSlotController.allTrackedItems.isEmpty and theSlotController.mySlotRequestDischarge &lt;&gt; null);
			if self.mnuGridAutoplanSlot.visible then
				self.mnuGridAutoplan.visible  := true;
				self.mnuGridAutoplanSlot.enabled := true;
				self.mnuGridAutoplanSlot.userObject := theSlotController.mySlotRequestDischarge;
			endif;
			self.mnuGridAutoplanBay.visible := self.mnuGridAutoplanSlot.visible 
									or (tmpPlanMode and theSlotController.myBayVoyage.hasTIsToDischarge());
			if self.mnuGridAutoplanBay.visible then
				self.mnuGridAutoplan.visible  := true;
				self.mnuGridAutoplanBay.userObject := theSlotController.myBayVoyage;
			endif;
			if theJob &lt;&gt; null then
				self.mnuGridAutoplanJob.visible := (tmpPlanMode and theJob.hasTIsToDischarge());
				if self.mnuGridAutoplanJob.visible then
					self.mnuGridAutoplan.visible  := true;
					self.mnuGridAutoplanJob.userObject := theJob;
				endif;
			endif;
		else
		// hatch lid point
		endif;
	endif;
	
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	// Summarise menu options are only enabled if display mode is actual and have correct permissions.
	// Has been defaulted to invisible in doTurnOffContextMenus.
	if self.bAllowSummaryDefn and self.displayMode = ShpDisplayMode_Actual then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if a container is actually selected.
		self.mnuSummariseSelected.visible	:=	self.myCurrentDrawingController &lt;&gt; null and
												not self.myCurrentDrawingController.allSelectedObjects.isEmpty;
	endif;
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	self.doBuildMnuZoom(self.mnuZoomSub);
	self.mnuGridLinkMain.visible := (self.mnuGridReLink.visible or self.mnuGridDeLink.visible or self.mnuGridLink.visible);

	self.mnuGridAreaContext.enabled := false;
	self.mnuGridPrint.caption := "Print...";
	/*
	if self.myCurrentVoyage.allHolds.size = self.allSelectedHolds.size then
		self.mnuGridPrint.caption := "Print A4 - All Holds";
	else
		self.mnuGridPrint.caption := "Print A4 - " &amp; self.allSelectedHolds.getShortDescription();
	endif;
	*/
	self.mnuGridPrint.visible 	:= true;
//	return self.showContextMenu(mnuGridAreaContext, cntrl, conwin, mouse, x, y);
	return self.showContextMenu(mnuGridAreaContext, cntrl, conwin, mouse, self.saveX,self.saveY);
epilog

 delete tis;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doContextMenuReverseMenu" id="36665b46-8b07-45a1-9888-a6a5b903417d">
        <updating/>
        <source>doContextMenuReverseMenu(_theRequest : CM_SlotRequest input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	 isInteg, showOnlyDoorDirections : Boolean;
begin
	//epr TFS 7006 27/9/17
	showOnlyDoorDirections := self.myTerminal.getConfig(ShowOnlyDoorDirections).Boolean; // PAR 8190
	
	self.mnuGridReverse.visible := true;
	if _theRequest.myJob &lt;&gt; null and _theRequest.myJob.isJobComplete then
		self.mnuGridReverse.visible := false;
		return;
	endif;

	if showOnlyDoorDirections then // PAR 9623
		isInteg := false; // PAR 9623
	else
		isInteg := _theRequest.isIntegral();	
	endif;	

	// epr TFS 7006 29/9/17 	
	if isInteg then
		// MOTORS		
		self.mnuGridReverse.caption := app.getErrorString(Motor_direction);		

		self.mnuGridReverse.helpKeyword  := "MOTOR";
		self.mnuGridRevDoorsAft.caption:=app.getErrorString(Motor_AftDir);
		self.mnuGridRevDoorsForward.caption:=app.getErrorString(Motor_forward);
		
	else	
		self.mnuGridReverse.helpKeyword  := "DOOR";
		self.mnuGridReverse.caption := app.getErrorString(Door_directions);		
		self.mnuGridRevDoorsAft.caption:=app.getErrorString(Doors_Aft);
		self.mnuGridRevDoorsForward.caption:=app.getErrorString(Doors_forward);
	endif;

	
	self.mnuGridReverse.userObject := _theRequest; // so we can update if clicked.
end;</source>
        <Parameter name="_theRequest" type="CM_SlotRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDisplayJobAllocCargoForm" id="2230df97-24da-43e5-8277-190f6f9d5e31">
        <source>doDisplayJobAllocCargoForm( _job : CM_VoyageJob );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2012	cnwrd1	Initial creation

*/

vars

	form	: SHP_VoyAllocJobCargoMaintForm;
	anAlloc 	: CM_YardAllocation;
	aRequest : CM_Request;
begin

	if _job = null then
		return;
	endif;
	
	form := app.loadForm(	SHP_VoyAllocJobCargoMaintForm, 
							self.myAssistant.class, 
							false, false, false, 
							self.myTerminal, null).SHP_VoyAllocJobCargoMaintForm;
														
	// If user fails security we don't want to show a null form.
	if form &lt;&gt; null then
		aRequest := _job.allRequests.first;
		if aRequest &lt;&gt; null then
			anAlloc := aRequest.getFirstAllocation();
		else
			return;
		endif;
	
		form.initForJob( _job.allAssignedCargoForAlloc, anAlloc, _job);
		form.show();

	endif;

epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="doDropFromGridAreaForm" id="a858b49b-e8f2-493d-b854-3a501b0c487c">
        <updating/>
        <source>doDropFromGridAreaForm(frame: SHP_BayDrawingFrame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	aSlotController : CM_SlotController;
	aLabel, moveString : String;
	jobOne, jobTwo : CM_Job;
	tmpDrawController	: SHP_BayDrawingController;
	tmpMoveController	: CMIF_MoveController;
	moveControllerMoveMode,
	drawControllerMoveMode	: Integer;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	tmpMoveController := app.myMoveController;
	
	if tmpMoveController = null then
		return;
	endif;
	if tmpMoveController.myTrackedItem = null then
		return;
	endif;

	tmpObj := frame.getObjectForPosition(x.Integer, y.Integer);
	if tmpObj = null or (tmpObj &lt;&gt; null and (not CM_SlotController.hasInstance(tmpObj))) then
		return;
	endif;
	
	tmpDrawController	:=	self.myBayDrawingController;
	tmpMoveController.ignoreWeightValidation	:=	self.chkIgnoreWeightV.value;	// cnwdad1 02/08/2010 - PAR #24045.

	moveControllerMoveMode := tmpMoveController.moveMode;
	drawControllerMoveMode := tmpDrawController.moveMode;
	
	aSlotController := tmpObj.CM_SlotController;
	tmpMoveController.setMyToPrimaryLocation(aSlotController); // AKB2005SEPT added to allow to use 'isMoveAnExportRePlan' below when setting the slot req.

	if moveControllerMoveMode = REAL_MODE then
		tmpMoveController.mySlotRequest := null;
		tmpMoveController.setMyWorkListEntry(null);
	elseif moveControllerMoveMode = PLANNING_MODE then
		if tmpMoveController.myTrackedItem.isRehandle and 
		   self.displayMode = ShpDisplayMode_ColCodeLoad then
			tmpMoveController.mySlotRequest := aSlotController.mySlotRequestLoad;
		elseif   self.displayMode = ShpDisplayMode_ColCodeLoad 
		and not  tmpMoveController.isMoveAnExportRePlan()  // AKB2005SEPT do not set 
		and not  tmpMoveController.myTrackedItem.isSOB then // PAR 11196 - AKB2006JAN do not set 
			tmpMoveController.mySlotRequest := aSlotController.mySlotRequestLoad; // AKB2005JUL
		endif;
	endif;

	// if a planning drop check that there is a request and a job
	if moveControllerMoveMode &lt;&gt; drawControllerMoveMode then
		if moveControllerMoveMode = QUEUE_MODE then
			app.msgBox("Cannot drag drop in Queue mode.","Dragging From " &amp; aLabel &amp; " Error",
							MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		if drawControllerMoveMode = REAL_MODE then
			moveString := "Instant Mode";
		elseif drawControllerMoveMode = PLANNING_MODE then
			moveString := "Planning Mode";
		endif;
		aLabel := win.name;
		app.msgBox("Dragging in different modes." &amp; Cr &amp; "Please reset the dragging mode in " &amp; aLabel &amp; " to be " &amp; moveString &amp; ".","Dragging From " &amp; aLabel &amp; " Error",
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;		
	if moveControllerMoveMode = PLANNING_MODE then
	
	
		// if we are dropping in planning mode then this must be a load.
		if self.displayMode = ShpDisplayMode_ColCodeDisch then
			app.msgBox("Cannot drop in Discharge Colour Coding Planning mode.", "Planned Discharge Drag Drop Error",
							MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		else
			if aSlotController.mySlotRequestLoad = null then
				app.msgBox("Cannot drop in planning mode.There is no load colour coding for slot " &amp; aSlotController.getFullId &amp; ".", "Planned Load Drag Drop Error",
								MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			else
			
				if aSlotController.mySlotRequestLoad.myBulkReleaseReserveDetail &lt;&gt; null then  //cnwrd1 par 31027 16.1.13
					app.raiseCMException1(Slot_alread_alloca_releas_requ, aSlotController.mySlotRequestLoad.myBulkReleaseReserveDetail.myReserveHeader.code , null, null); 
				endif;
			
				jobOne := aSlotController.mySlotRequestLoad.myJob;
				if tmpMoveController.mySlotRequest &lt;&gt; null then
					jobTwo :=  tmpMoveController.mySlotRequest.myJob;
				endif;
				if jobOne = null then
					app.msgBox("Cannot drop in planning mode. There is no job defined for the load colour coding for slot " 
								&amp; aSlotController.getFullId &amp; ".", "Planned Load Drag Drop Error",
									MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return;
				else
					if jobTwo &lt;&gt; jobOne and jobTwo &lt;&gt; null then
						app.msgBox("Cannot drop in planning mode. Cannot drag " &amp; tmpMoveController.myTrackedItem.id
								&amp; " between job " &amp; jobTwo.id 
								&amp; " and job " &amp; jobOne.id &amp; ".", "Planned Load Drag Drop Error",
										MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
						return;
					endif;
				endif;
			endif;
		endif;
	endif;

	self.moveTrackedItemTarget(aSlotController); 
	tmpMoveController.ignoreWeightValidation	:=	false;		// cnwdad1 02/08/2010 - PAR #24045.
epilog
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
end;</source>
        <Parameter name="frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doEnableEDI" id="1ec5a905-1c84-4b36-a783-6431d115cf24">
        <updating/>
        <source>doEnableEDI() updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.hideShowViewModes(true);
	self.hideShowPens(false, false);
	
	self.frmToolbar2.visible := true;

	self.btnColorCodeDish.enabled	:= false;
	self.btnColorCodeLoad.enabled	:= false;

	self.btnSaveBase.visible 	:= false;
	self.btnDelete.visible		:= false;
	self.btnEdit.visible		:= false;	
	
	self.cmbCargoType.visible	:=	false;
	self.cmbCommodity.visible	:=	false;
	self.cmbPortDis.visible		:=	false;
	self.txtWeight.visible		:=	false;		// cnwdad1 30/07/2010 - PAR #24045.
	self.chkIgnoreWeightV.visible :=	false;	// cnwdad1 30/07/2010 - PAR #24045.

	self.cmbCrane.visible := false;
	self.cmbJob.visible := false;

	self.mnuDisplay.enabled := true; 
	self.frmStatusLine.myFrameDisplayMode.enabled := true; 

	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableJob" id="62b7e6ad-8fd6-414c-a1e0-7bfb481c3755">
        <updating/>
        <source>doEnableJob() updating;
