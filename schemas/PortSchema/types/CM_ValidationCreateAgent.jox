    <JadeMethod name="valAS400CreateDocket" id="aa1806eb-6437-4862-9af5-2a753ae552d8">
        <source>valAS400CreateDocket(_array : HugeStringArray input; _lineNo : Integer; _fileLoad : CM_AS400FileLoad);

vars

begin

	if _fileLoad = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'File Load' , null, null);
		app.raiseCMException(Input_required_field_fileLoad , null, null); // cnwdb2	PAR 35364
	endif;

	if _array.size &lt;&gt; 43 then
		app.raiseCMException1(IncorrectNumberOfFields, _lineNo.String, null, null);
	endif;

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_lineNo" type="Integer"/>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad"/>
    </JadeMethod>
    <JadeMethod name="valAS400CreateLog" id="caf5c258-45e1-4b28-a44b-94d34b34c482">
        <source>valAS400CreateLog(_array : HugeStringArray io; _fileLoad : CM_AS400FileLoad);

vars

	docket		: CM_AS400Docket;
	docketId	: String;

begin

	if _fileLoad = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'File Load' , null, null);
		app.raiseCMException(Input_required_field_fileLoad , null, null); // cnwdb2	PAR 35364
	endif;

	if _array.size &lt;&gt; 9 then
		app.raiseCMException1(IncorrectNumberOfFields, null , null, null);
	endif;
	
	docketId := _array[1].trimBlanks;	
	docket := _fileLoad.allDockets[docketId];
	if docket = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Docket' , null, null);
		app.raiseCMException(Input_required_field_docket, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="io"/>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad"/>
    </JadeMethod>
    <JadeMethod name="valAS400FileLoad" id="84b5d5bf-d2ba-4cfe-83ed-4ab3533eb129">
        <source>valAS400FileLoad(_id, _docketFile, _logFile, _terminal : String; _root : CM_AS400Root);

vars

	docketFile	: File;
	logFile		: File;	

	

begin

	if _root.allFileLoads[_id] &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, "the specified id is already in use and therefore ", null, null, null);
	endif;
	
	if app.myRoot.allTerminals[_terminal] = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _root = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Root', null, null);
		app.raiseCMException(Input_required_field_root, null, null);
	endif;

	create docketFile transient;
	docketFile.kind := File.Kind_Unknown_Text;	// 26/2/16 cnwmp6 PAR 36286 unicode version
	docketFile.mode := File.Mode_Input;
	docketFile.shareMode := File.Share_Read;
	docketFile.fileName := _docketFile;
	if not docketFile.isAvailable then 
		app.raiseCMException1(FileUnavailable, _docketFile, null, null);
	endif;
	
	create logFile transient;
	logFile.kind := File.Kind_Unknown_Text;	// 26/2/16 cnwmp6 PAR 36286 unicode version
	logFile.mode := File.Mode_Input;
	logFile.shareMode := File.Share_Read;
	logFile.fileName := _logFile;
	if not logFile.isAvailable then 
		app.raiseCMException1(FileUnavailable, _logFile, null, null);
	endif;
	
epilog

	delete logFile;
	delete docketFile;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_docketFile" type="String"/>
        <Parameter name="_logFile" type="String"/>
        <Parameter name="_terminal" type="String"/>
        <Parameter name="_root" type="CM_AS400Root"/>
    </JadeMethod>
