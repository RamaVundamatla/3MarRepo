    <JadeMethod name="getStdControlHeight" id="c7f3c52d-c3af-4dae-9338-52f1cb3f0e21">
        <source>getStdControlHeight():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	//24 Feb 2015	NDL	Par 35604
	if self.useHHResizeCode then
		return self.getTextHeight("TEST") + ( 2 * self.resizedMargin );
	endif;

	//epr par 33025 20/11/13
	if app.myVMAgent &lt;&gt; null then
		return self.btnOne.getTextHeight("TEST") + 6; // + (10);
	endif;
	
	return 21;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTrucksFromBulkRelease" id="09744c6d-0a43-4d6e-856f-3325eb8756b7">
        <source>getTrucksFromBulkRelease( selectedBulkRelease : CM_BulkRelease; truckArray : CM_VehicleArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	req : CM_Request;
	roadJob : CM_RoadJob;
	truck : CM_Vehicle;

begin

	if selectedBulkRelease &lt;&gt; null then
		foreach req in selectedBulkRelease.allRequestsBeingActioned do
			if req.myJob = null or not req.myJob.isRoadJob then
				//Not a road job
				continue;
			endif;
			roadJob := req.myJob.CM_RoadJob;
			if roadJob.isCompleteForExit then
				// already completed
				continue;
			endif;
			if roadJob.myVehicleVisit = null or not roadJob.myVehicleVisit.isIncomplete then
				// NOT incomplete
				continue;
			endif;
			truck := roadJob.myVehicle;
			if truck &lt;&gt; null then
				truckArray.addExclusive( truck );
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="selectedBulkRelease" type="CM_BulkRelease"/>
        <Parameter name="truckArray" type="CM_VehicleArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="goBackToFirst" id="28fe02cb-e713-43ae-b80e-a0cb13235292">
        <updating/>
        <source>goBackToFirst( _formClass : Class ) : Form updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	form : Form;
		
begin

	self.getSessionAgent.cleanBackPreviousFormsTo( _formClass );
	
	create form as _formClass transient; 
	self.setSessionParameters();
	
	form.show();
	unloadForm;
	
	return form;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_formClass" type="Class"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="goBackToFirstOf" id="be93fcc2-b8a6-45d3-8c10-868365cc74a6">
        <updating/>
        <source>goBackToFirstOf( _formClassSet : ClassSet ) : Form updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/08/2015	cnwndl1	Initial creation	Par 36782
15/10/2019	jlgdap1	TFS 47009 STWR Unpack in Pack/Load by Request returns to wrong place
*/

vars

	form : Form;
	classFound : Class;
		
begin

	classFound := self.getSessionAgent.cleanBackPrevFormsToFirstOf( _formClassSet );
	
	if classFound = null then
		//classFound := MOB_HandHeldMenuForm;		// TFS 47009
		classFound := self.class;					// TFS 47009
	endif;
	
	create form as classFound transient; 
	self.setSessionParameters();
	
	form.show();
	unloadForm;
	
	return form;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_formClassSet" type="ClassSet"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="goToFormSetBackForm" id="70fa6503-9d51-4d4d-8204-afd35cc777f4">
        <updating/>
        <source>goToFormSetBackForm( _toFormClass : Class; _backToFormClass : Class)  : Form updating, protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

	form : Form;

begin

	form := self.gotoForm( _toFormClass, false);
 	
	if _backToFormClass &lt;&gt; null then
		// if we have set this, it means that should we press back we expect to be taken back to
		// the nominated form rather than the one we necessarily came from.
		self.getSessionAgent.cleanBackFormsMoreRecentThan( _backToFormClass );
	endif;
	
	return form;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_toFormClass" type="Class"/>
        <Parameter name="_backToFormClass" type="Class"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="gotoForm" id="4803ef79-0daa-48ae-9446-264f2156ef68">
        <updating/>
        <source>gotoForm(formClass : Class; goingBack : Boolean)  : Form updating, protected;

vars
	form : Form;
begin
	create form as formClass transient; 
	self.setSessionParameters();
	if not goingBack then
		if self.getSessionAgent.peekAtPreviousForm = formClass then
			// This means that we are actually going back, just through a method other than the back button
			// so we will need to pop off the final form (self). This prevents circular movement through the menus
			// that could result in the previous forms array growing huge and the user having to go back through a
			// large number of forms before getting back to the menu
			self.getSessionAgent.getPreviousForm(); // pops the calling form off the stack
		else
			self.getSessionAgent.addPreviousForm(self.class);
		endif;
	endif;
	
	app.writeLog(form.name, LogINFO); //cnwrd1 par 28868 9.1.2012
	form.show();
	//27 Feb 2015	NDL	Par 35604
	if self.useHHResizeCode or self.isKindOf(MOB_HandHeldLogonForm) then
		form.top := self.top;
		form.left := self.left;
		form.width := self.width;
		form.height := self.height;
		form.resize;
	endif;
	unloadForm;
	
	//15 Sep 2015	NDL	Par 36900
	if app.myMobileGUIAgent &lt;&gt; null then
		app.myMobileGUIAgent.setCurrentForm( formClass );
	endif;
	
	return form;
end;
</source>
        <access>protected</access>
        <Parameter name="formClass" type="Class"/>
        <Parameter name="goingBack" type="Boolean"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="gotoHomeForm" id="53eb1d22-7a09-4a59-a629-45fcae001bc8">
        <updating/>
        <source>gotoHomeForm() updating;
//16 September 2008	cnwdw1	
//
vars
	
begin
	if self.getSessionAgent.allAvailableForms.size = 0 then
		self.msgBox("You do not have permission to view any of the Handheld forms. Returning to login screen","No Permissions", MsgBox_OK_Only, false);
		self.gotoForm(MOB_HandHeldLogonForm,true);
	elseif self.getSessionAgent.allAvailableForms.size = 1 then
		self.gotoForm(self.getSessionAgent.allAvailableForms[1].Class, false);
	else
		self.gotoForm(app.myMobileGUIAgent.myHomeForm, false);
	endif;
end;</source>
    </JadeMethod>
