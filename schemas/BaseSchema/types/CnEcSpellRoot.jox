    <JadeMethod name="bulkExport" id="af4551e2-58a5-4e90-b3be-a676041e8692">
        <source>bulkExport(pTargetFileObj:File input);
// --------------------------------------------------------------------------------
// Purpose:		Exports all Spell Words to a disk file.
//
// Parameters:	pTargetFileObj - The name of the target file for the export.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/08/2001	cnwdad1		Change to receive the target file from the requesting
//							method instead of instantiating it from this method.
// --------------------------------------------------------------------------------
vars
	word		: CnEcSpellWord;
	
begin
	foreach word in self.allSpellWords do
		pTargetFileObj.writeLine(word.name);
	endforeach;
end;</source>
        <Parameter name="pTargetFileObj" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bulkLoad" id="c81db73d-893b-4496-a339-9c238cb6816f">
        <updating/>
        <source>bulkLoad(pSourceFileObj:File) updating;
// --------------------------------------------------------------------------------
// Purpose:		Imports all Spell Words from a disk file.
//
// Parameters:	pSourceFileObj - The name of the source file for the import.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/08/2001	cnwdad1		Change to receive the source file from the requesting
//							method instead of instantiating it from this method.
// 27/08/2001	cnwdad1		Added a progress dialog to the load process.
// --------------------------------------------------------------------------------
vars
	fileRecord			: String;
	wordToCheck			: String;
	wordToCheckLower	: String;
	spellWordObj		: CnEcSpellWord;
	lineLength			: Integer;
	charPosition		: Integer;
	wordCharacter		: Character;
	theProgressFormObj	: CnEcProgressForm;
	fileLength			: Integer;
	partsDone			: Integer;
	messageResponse		: Integer;
	isAbortLoad			: Boolean;
	
begin
	fileLength	:=	pSourceFileObj.fileLength();
	create theProgressFormObj;
	theProgressFormObj.startProgress("Loading " &amp; pSourceFileObj.fileName &amp; "...", fileLength);
	theProgressFormObj.show();
	partsDone	:=	0;
	isAbortLoad	:=	false;

	beginTransaction;
	
	while (not pSourceFileObj.endOfFile()) do
		fileRecord	:=	pSourceFileObj.readLine();
		lineLength	:=	fileRecord.length;
		partsDone	:=	partsDone + lineLength;
		
		foreach charPosition in 1 to lineLength do
			wordCharacter	:=	fileRecord[charPosition];
			
			if wordCharacter.isAlpha then
				wordToCheck	:=	wordToCheck &amp; wordCharacter;
				
				if charPosition = lineLength then
					// To allow write of last word if necessary.
				else
					// If the character is still alpha, we are building a wordToCheck
					// so skip the rest.
					continue;
				endif;
			endif;
			
			if wordToCheck.length &gt; 0 then
				// If we have a word, convert it to lower case.
				wordToCheckLower := wordToCheck.toLower();
				
				// if we don't know the word add it	 	 
				if self.allSpellWords.getAtKey(wordToCheckLower) = null then				
					self.spellwordCreate(self, wordToCheckLower, spellWordObj);																			
				else
					// We have a word we recognise, so do nothing.
				endif;
			endif;
			
			// Just in case we have just processed a word, clear it out and go around again.
			wordToCheck	:=	"";		
		endforeach;
		
		theProgressFormObj.updateProgress(partsDone);

		if theProgressFormObj.isCancelled then
			theProgressFormObj.visible	:=	false;
			
			messageResponse	:=	app.msgBox(	"Do you wish to discard the words already loaded ?",
											"Cancel Import",
											MsgBox_Question_Mark_Icon + MsgBox_Yes_No_Cancel);
			
			if messageResponse = MsgBox_Return_Yes then
				isAbortLoad	:=	true;
				break;
			elseif messageResponse = MsgBox_Return_No then
				isAbortLoad	:=	false;
				break;
			else
				// The user must have cancelled the load, so just continue with the load.
				theProgressFormObj.visible	:=	true;
				theProgressFormObj.resetCancelFlag();
			endif;
		endif;
	endwhile;
	
	theProgressFormObj.updateProgress(fileLength);
	
	commitTransaction;
epilog
	if theProgressFormObj &lt;&gt; null then
		theProgressFormObj.unload();
		delete theProgressFormObj;
	endif;
end;</source>
        <Parameter name="pSourceFileObj" type="File"/>
    </JadeMethod>
    <JadeMethod name="spellwordCreate" id="865cb1b9-9754-40c8-ba5e-4faff4923d81">
        <updating/>
        <source>spellwordCreate(pSpellRootObj:CnEcSpellRoot;
				pName:String;
				pNewSpellWordObj : CnEcSpellWord output): String updating; 

// This method created by JediMethodGenerator at 17:00:46 on 07 June 2001
// It will create a SpellWord Object.

vars
	errorMessage	: String;
	spellWordObj	: CnEcSpellWord;

begin
	create spellWordObj;

	errorMessage		:=	spellWordObj.initializeMe(pSpellRootObj, pName);
	pNewSpellWordObj	:=	spellWordObj;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pSpellRootObj" type="CnEcSpellRoot"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pNewSpellWordObj" type="CnEcSpellWord" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
