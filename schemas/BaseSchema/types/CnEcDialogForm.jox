    <JadeMethod name="load" id="8f1a134f-0a77-4e23-bc7a-ea582570e8e8">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
