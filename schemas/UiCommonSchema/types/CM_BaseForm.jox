    <JadeMethod name="mnuFileChangePassword_click" id="f90d1e15-be61-498a-be52-e1372f99e285">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileChangePassword_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
// ---------------------------------------------------------------------------
// 04 Feb 2025	navah1	Story 14660: MTN - New option to disable users from changing their own passwords
vars
	user : CM_User;							//05.02.2025 navah1 #14660
begin  
	user := app.getMyUser();    			//05.02.2025 navah1 #14660
	if not user.canChangePassword() then 	//05.02.2025 navah1 #14660
		// app.raiseCMException1(NoPermission, "change password for '" &amp; user.code &amp; "'.", null, null);
		app.raiseCMException1(PasswordChangeProhibited, user.code, null, null); //17.02.2025 navah1 #14660
		return;
	endif;
	app.loadForm(CMUI_ChangePassword, null, false, true, true, null, null);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
