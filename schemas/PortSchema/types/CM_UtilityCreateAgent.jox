        <source>utlCreateWpOperatingHrs(_pxyWpOperatingHrs : CM_WorkPointOperatingHours input; _realWpOperatingHrs : CM_WorkPointOperatingHours output; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	voyage : CM_Voyage;
	term : CM_Terminal;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValCA.valWpOperatingHrs(_pxyWpOperatingHrs, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create _realWpOperatingHrs;
