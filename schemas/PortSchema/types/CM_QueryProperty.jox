    <JadeMethod name="setValuesFromList" id="8669d5b3-057e-415a-b024-d671f7ca553f">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*
Purpose:		TFS 7821	
Date				Who			Reason
NOVEMBER 2017		CNWAB1		Initial creation
*/


vars
	str				: String;
	numRows,
	idx				: Integer;
	objSet			: ObjectSet;
	obj			: Object;
begin

	create objSet transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			obj := _tbl.accessRow(idx).itemObject;
			objSet.add(obj);
		endif;
	endforeach;
	
	_op.setSearchValue(objSet);
	
epilog
	delete objSet;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
