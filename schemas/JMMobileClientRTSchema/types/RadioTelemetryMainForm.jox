    <JadeMethod name="doAcceptTask" id="08193a18-f0a7-4846-b887-ee4347eba398">
        <updating/>
        <source>doAcceptTask() : Boolean protected, updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars

	errorStr		: String;
	
begin

	if not app.myRTGuiAgent.acceptTask(self.aState, errorStr) then
		self.showMessage(errorStr, true);
		return false;
	endif;
	
	self.updateFromState();
	return true;


end;</source>
