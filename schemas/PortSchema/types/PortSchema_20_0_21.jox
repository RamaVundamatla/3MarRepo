    <JadeMethod name="createWOVoyageProcess" id="296c4ab0-3414-41c6-8c91-055918a71f36">
        <source>createWOVoyageProcess(_controller: CnEcReleaseController);
/*

Purpose:			create singleton CM_VoyageProcessWO, and transfer all existing voyage statuses
					from the existing CM_VoyageProcessPEL1 instance

Parameters:			

Return Value:		

Date				Who		Reason
21 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars
	converting 		: Boolean;
	pxyProcess, 
	realProcess, 
	pelProcess, 
	defaultProcess 	: CM_VoyageProcess;
	statusObj 		: CM_Object;
	pxyStatus 		: CM_VoyageStatus;
	statuses 		: CM_ObjectSetActual;
	voyages 		: CM_VoyageSet;
	voy 			: CM_Voyage;
begin
	converting := app.isConverting;
	app.isConverting := true;
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Initializing MTN Work Order voyage process", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initializing MTN Work Order voyage process") ;	
	endif;
	
	
	defaultProcess := CM_VoyageProcessDefault.firstInstance;
	if defaultProcess &lt;&gt; null then
		// rename default voyage process
		beginTransaction;
		defaultProcess.setPropertyValue("code", "MTN");
		defaultProcess.setDescription("MTN Default");
		commitTransaction;
	endif;
	
	if CM_VoyageProcessWO.instances.isEmpty then 
		// create singleton voyage process object
		create pxyProcess as CM_VoyageProcessWO transient;
		pxyProcess.setProxy(VoyageProcessWO, "MTN Work Orders",null,null,null,null, null, null);
		
		beginTransaction;
		app.myUtilityCA.utlCreateVoyageProcess(pxyProcess, realProcess, app.myPassport);
		if not app.myPassport.noErrors then
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageProcessWO!!!", LogINFO);
			return;
		endif;
		
		// copy voyage status from pelindo voyage process to wo voyage process
		pelProcess := CM_VoyageProcessPEL1.firstInstance;
		if pelProcess &lt;&gt; null then
			create statuses transient;
			pelProcess.allStatusesById.copy(statuses);
			
			foreach statusObj in statuses do
				pxyStatus := statusObj.pxyCreateUpdateProxy().CM_VoyageStatus;
				pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, pxyStatus.description, realProcess, null, pxyStatus.reportToRun,false);
				app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
				delete pxyStatus;
			endforeach;
		endif;
		commitTransaction;
		if pelProcess &lt;&gt; null then
			// transfer any existing voyages
			create voyages transient;
			pelProcess.allVoyages.copy(voyages);
			foreach voy in voyages do
				beginTransaction;
				voy.setPropertyValue("myVoyageProcess", CM_VoyageProcessWO.firstInstance);
				commitTransaction;
			endforeach;
		endif;
	else
		app.writeLog(method.qualifiedName &amp; " MTN Work Order voyage process already exists", LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(" MTN Work Order voyage process already exists") ;	
		endif;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Initializing MTN Work Order voyage process COMPLETE", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initializing MTN Work Order voyage process COMPLETE") ;	
	endif;	
	
	self.addScriptRun(method.name);
	
epilog
	delete pxyProcess;
	delete pxyStatus;
	delete statuses;
	delete voyages;
	app.isConverting := converting;
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
