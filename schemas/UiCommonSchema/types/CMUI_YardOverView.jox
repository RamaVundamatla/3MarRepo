    <JadeMethod name="doBtnAddDimensionClick" id="5c0c835c-95e1-4065-a7e1-18818ccc9f0e">
        <source>doBtnAddDimensionClick();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theReturn,theRow, b, idx : Integer;
begin
	b := self.tblDim.rows - self.tblDim.fixedRows + 1;
		idx := self.tblDim.addItem(b.String &amp; Tab &amp; 0.String &amp; Tab &amp; 0.String);
		self.tblDim.accessCell(idx,self.COLUMN_X).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		self.tblDim.accessCell(idx,self.COLUMN_Y).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDeleteDimensionClick" id="598eedd2-2362-4439-81ab-0654ac60feb3">
        <source>doBtnDeleteDimensionClick();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theReturn,theRow, theX, theY, idx : Integer;
begin
	if self.tblDim.row &gt; self.tblDim.fixedRows then
		if self.tblDim.rows = 6 then
			app.msgBox("Cannot have less than 5 points","Remove Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		theRow := self.tblDim.row;
		
		
		theX := self.tblDim.accessCell(theRow,self.COLUMN_X).text.Integer;
		theY := self.tblDim.accessCell(theRow,self.COLUMN_Y).text.Integer;
		theReturn := app.msgBox("Remove Point " &amp; (theRow - 1).String &amp; ", " &amp; theX.String &amp; "/" &amp; theY.String &amp; "?", "Remove Confirmation", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_Yes then
			self.tblDim.deleteRow(theRow);
			foreach idx in 2 to self.tblDim.rows do
				self.tblDim.accessCell(idx,1).text := (idx - 1).String;
			endforeach;
		endif;
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSaveClick" id="eab61eb3-6b52-4954-8ee9-9dedd2a2bf7c">
        <updating/>
        <source>doBtnSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	clrArray : IntegerArray;
	idx : Integer;
	theTable : Table;
begin
	create clrArray transient;
	theTable := self.frmLegend.myLegendTable;
	
	foreach idx in 1 to theTable.rows do
		clrArray.add(theTable.accessCell(idx,1).backColor);
	endforeach;
	
	app.myTrxUA.trxUpdateRootTALevels(clrArray,app.myPassport);

	self.yardStackColours.clear;
	app.myRoot.coloursForTALevels.copy(self.yardStackColours);
	
	self.frmColours.visible := false;
	self.frmLegend.myLegendTable.bubbleHelp := self.ColourHelp;
	self.doBuildTableLegend();
	self.doDrawGraphics();
epilog
	delete clrArray;


end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSaveDimensionClick" id="b351c758-1c62-4095-984f-836d5280abe9">
        <updating/>
        <source>doBtnSaveDimensionClick() updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars

	pxyLayoutGraphic : CM_LayoutGraphic;
	theArea : CM_TerminalArea;
	idx : Integer;
	aPoint : Point;
	thePoints : PointArray;
	theX, theY : Integer;
	ls : Boolean;
	
begin
	if self.cmbAreas.listObject = null then
		return;
	endif;
	
	theArea := self.cmbAreas.listObject.CM_TerminalArea;
	create thePoints transient;
	
	foreach idx in 2 to self.tblDim.rows do
		theX := self.tblDim.accessCell(idx,COLUMN_X).text.Integer;
		theY := self.tblDim.accessCell(idx,COLUMN_Y).text.Integer;
		aPoint.set(theX,theY);
		thePoints.add(aPoint);
	endforeach;
	
	if thePoints.isEmpty then
		return;
	endif;
	
	if thePoints.size &lt; 5 then
		thePoints.add(thePoints.first);
	endif;
	
	app.cmsBeginLoad(ls);
	pxyLayoutGraphic := theArea.myLayoutGraphic.pxyCreateUpdateProxy();
	app.cmsEndLoad(ls);
	pxyLayoutGraphic.setProxy(0,0,theArea,pxyLayoutGraphic.drawLineColour,0,0,0,thePoints,pxyLayoutGraphic.label,self.myTerminal);
	app.myTrxUA.trxUpdateLayoutGraphic(pxyLayoutGraphic,app.myPassport);
	
	if app.myPassport.hasErrorsOrWarnings = false then
		self.doRefresh();
		self.cmbAreas.listIndex := -1;
		global.beep;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyLayoutGraphic;
	delete thePoints;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuZoom" id="3bf707e9-3646-47f3-ae6b-4c3366e600ba">
        <source>doBuildMnuZoom();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption	: String;
	mnuChild	: MenuItem;
	mnuIndex 	: Integer;
begin
	self.mnuContext.visible := true;
	self.mnuContext.enabled := true;

	self.mnuZoom.visible := true;

	self.doBuildMnuZoomSub(0.5, 1);
	self.doBuildMnuZoomSub(0.75, 2);
	self.doBuildMnuZoomSub(1.0, 3);
	self.doBuildMnuZoomSub(1.25, 4);
	self.doBuildMnuZoomSub(1.5, 5);
	self.doBuildMnuZoomSub(1.75, 6);
	self.doBuildMnuZoomSub(2.0, 7);
	self.doBuildMnuZoomSub(4.0, 8);
	self.doBuildMnuZoomSub(6.0, 9);
	self.doBuildMnuZoomSub(8, 10);

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuZoomSub" id="47014649-74b7-4f57-b286-43bcf1b446bc">
        <source>doBuildMnuZoomSub(_scale : Decimal; _index : Integer);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption	: String;
	mnuChild	: MenuItem;
	mnuIndex 	: Integer;
begin
	lFactor := self.xmlScaleFactor;

	lCaption := "View At " &amp; _scale.String &amp; " Scale" ;
	mnuChild := mnuZoom.getMenuItem(_index); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuZoom.loadSubMenu(_index); // Clone menu
	endif;
	mnuChild.caption := lCaption;
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := _scale.String;
	if lFactor = _scale then
		mnuChild.checked := true;
	else
		mnuChild.checked := false;
	endif;

end;</source>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
