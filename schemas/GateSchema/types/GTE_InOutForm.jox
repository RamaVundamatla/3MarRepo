    <JadeMethod name="cmbTI_lostFocus" id="3f93c088-1171-4b24-a244-b6b0f737dd6b">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTI_lostFocus(combobox: GTE_ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     15 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	str					: String;
	sheet				: GTE_Sheet;
	tiId				: String;
	ti					: CM_TrackedItem;
	cargoType			: CM_CargoType;
	mainTbl, extraTbl	: CM_EntryTable;			
	assistant			: GTE_Assistant;
begin
	self.setCellTextFromControl(combobox.mySheet, combobox, combobox.text);

	if combobox.text &lt;&gt; null then		//GD Xpose 1138 25Jul01 prefill known data
		app.mousePointer := MousePointer_HourGlass;
		sheet := combobox.mySheet;

		// Redisplay delivery reason, which may have been hidden for Import items
		//	RDD PAR 1312 / PWL 832 27/8/2001
		mainTbl 	:= sheet.myTblMain;
		extraTbl 	:= sheet.myTblExtra;
		assistant := self.myAssistant.GTE_Assistant;
		assistant.mainExtraShowRow(mainTbl, extraTbl, ETRow_DeliveryReason);	//'deliveryReason');
		
		tiId := combobox.text;
		sheet.setSubHeading(tiId);
		
		cargoType := sheet.getCargoType();
		if cargoType &lt;&gt; null then
			ti := self.myTerminal.allOnsiteTIsByIdCargoType[tiId, cargoType.id];
			
			if ti &lt;&gt; null then
				self.setValuesFromReleaseTI(ti, sheet);
				//self.setDefaultsFromObject(sheet, ti);				
			endif;
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="combobox" type="GTE_ComboBox" usage="input"/>
    </JadeMethod>
