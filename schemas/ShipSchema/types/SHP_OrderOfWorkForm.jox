    <JadeMethod name="setupForm" id="68413df1-323d-453f-99a5-36fb90e6a1fb">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		December  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin
	self.usesQueryFrame := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.staStatusBar.visible := true;
	self.getXMLSettingsForSetup(); // PAR 16427 2 May 2008 cnwgb1
	self.setLengthReportingOptions(); // PAR
	self.useTableInfo := true;
	self.useTableSorting := false;
	inheritMethod();
	
	self.frmPrnQuery.visible := false;
	self.mnuColumnOrganiser.visible := false;
	self.initCraneSheets();
	
	self.updateMoveButtons(null);
	self.initTable();
	self.initInfo();

	self.btnAlloc.enabled := false;
		
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnTBNew.enabled:= false;
		self.btnTBEdit.enabled:= false;
		self.btnDelete.enabled:= false;
		self.btnTBLoadToOps.enabled:= false;
		self.btnTBPosition.enabled:= false;
		self.btnTBRenumber.enabled:= false;
		self.btnTBMoveUp.enabled:= false;
		self.btnTBMoveDown.enabled:= false;
		self.btnAlloc.enabled:= false;
		self.btnOOWCreation.enabled:= false;
		self.btnPlanGuide.enabled:= false;
	endif;
	
end;</source>
    </JadeMethod>
