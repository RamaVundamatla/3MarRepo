    <JadeMethod name="getRequest" id="af971dcc-c2f2-4ffa-8a44-c7860d924b0d">
        <source>getRequest():CM_Request;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2023	navhl20	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
12 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
*/

vars

begin
	if self.allRequests.isNotEmpty() then
		return self.allRequests.first;
	endif;
	return null;
epilog

