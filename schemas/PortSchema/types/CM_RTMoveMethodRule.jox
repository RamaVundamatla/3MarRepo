    <JadeMethod name="buildDirectorQueueTask" id="eda26cac-73e1-452b-ac33-6c917483ebe0">
        <source>buildDirectorQueueTask(_arbiter : CM_RTQueueArbiter input;
				_machineGrpType : CM_MachineTypeGroup input);


/*

Purpose:			
//cnwrd1 par 25681 18.11.2010 multi machine director moves

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwrd1	Initial creation

*/


vars

	sourceLC,
	targetLC : CM_LocationsController;
	directorTask: CM_RTQueueTask;
	sourceMachineTypeGrp,
	targetMachineTypeGrp : Integer;
begin

	if _machineGrpType.type = MACHINETYPEGRP_SOURCEIC or
		_machineGrpType.type = MACHINETYPEGRP_TARGETIC or
		_machineGrpType.type = MACHINETYPEGRP_MAFI then //jlier1 TFS 54701 19/9/22
		return;
	endif;

	self.getTaskDetails(_arbiter,_machineGrpType,true,sourceLC,sourceMachineTypeGrp);
	self.getTaskDetails(_arbiter,_machineGrpType,false,targetLC,targetMachineTypeGrp);
	
	_arbiter.entry.machineTypeGroup := _machineGrpType.type;
	_arbiter.entry.setMyRTMoveMethodRule(self);

	create directorTask;
	directorTask.machineTypeGroup:=_machineGrpType.type;
	directorTask.setDetails(	sourceLC,
						targetLC,
						TASK_UNACTIONED,
						TASK_DIRECTOR,
						null);
	
	directorTask.setMyBestPickTI(_arbiter.myBestPickTI); //jlier1 MTN-35637 17/9/25
	_arbiter.entry.addTask(directorTask);
	
epilog

end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_machineGrpType" type="CM_MachineTypeGroup" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildDirectorQueueTasks" id="e87f14c5-16ff-4a1e-bab9-29d9e10e3fcf">
        <source>buildDirectorQueueTasks(_arbiter : CM_RTQueueArbiter input;
				_machineGrpType : CM_MachineTypeGroup input);


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2010	cnwrd1	Initial creation

*/


/*
	- Business Rules to keep in mind RTG type machine grps can only be the source or target
		i.e. can't be a middle man
	- IMVs can have stuff put on them in Interchange areas or RTG Interchange areas or in the source area 

*/
vars

	sourceLC,
	targetLC : CM_LocationsController;
	taskPickup,
	taskSetdown,
	moveTask: CM_RTQueueTask;
	sourceMachineTypeGrp,
	targetMachineTypeGrp : Integer;
begin

	if _machineGrpType.type = MACHINETYPEGRP_SOURCEIC or
		_machineGrpType.type = MACHINETYPEGRP_TARGETIC or
		_machineGrpType.type = MACHINETYPEGRP_MAFI then //jlier1 TFS 54701 19/9/22
		return;
	endif;

	self.getTaskDetails(_arbiter,_machineGrpType,true,sourceLC,sourceMachineTypeGrp);
	self.getTaskDetails(_arbiter,_machineGrpType,false,targetLC,targetMachineTypeGrp);
	
	_arbiter.entry.machineTypeGroup := _machineGrpType.type;
	_arbiter.entry.setMyRTMoveMethodRule(self);
	if _machineGrpType.type = MACHINETYPEGRP_IMV then
		//write "move";
		create moveTask;
		moveTask.machineTypeGroup:=_machineGrpType.type;
		moveTask.setDetails(	sourceLC,
							targetLC,
							TASK_UNACTIONED,
							TASK_MOVE,
							_arbiter.ti);
							
		_arbiter.entry.addTask(moveTask);
	else
		
		create taskPickup;
		create taskSetdown;
 
		taskPickup.setDetails(	sourceLC,
								targetLC,
								TASK_UNACTIONED,
								TASK_DIRECTOR,
								null);							
								
		taskPickup.machineTypeGroup:=sourceMachineTypeGrp;
		taskPickup.setMyBestPickTI(_arbiter.myBestPickTI); //jlier1 MTN-35637 17/9/25
		_arbiter.entry.addTask(taskPickup);
	  
		taskSetdown.setDetails(	sourceLC,
								targetLC,
								TASK_UNACTIONED,
								TASK_SETDOWN,
								null);
		taskSetdown.machineTypeGroup:=targetMachineTypeGrp;						
	
		_arbiter.entry.addTask(taskSetdown);
		
		//write "Pickup &amp; Setdown";
	endif;

epilog

end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_machineGrpType" type="CM_MachineTypeGroup" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildQueueTasks" id="c1c8daa6-60e2-472d-9d78-8bdc8cada7a4">
        <source>buildQueueTasks(_arbiter : CM_RTQueueArbiter input;
				_machineGrpType : CM_MachineTypeGroup input;
				_createBreakBulkMaster : Boolean);

/*
	- Business Rules to keep in mind RTG type machine grps can only be the source or target
		i.e. can't be a middle man
	- IMVs can have stuff put on them in Interchange areas or RTG Interchange areas or in the source area 

	17 Feb 2015 cnwer1 	PAR 35702 CCMS 2457 - multi machine break bulk  moves
*/
vars

	sourceLC,
	targetLC : CM_LocationsController;
	taskPickup,
	taskSetdown,
	moveTask: CM_RTQueueTask;
	sourceMachineTypeGrp,
	targetMachineTypeGrp : Integer;
	rtqEntry : CM_RTQueueEntry;
begin

	if _machineGrpType.type = MACHINETYPEGRP_SOURCEIC or
		_machineGrpType.type = MACHINETYPEGRP_TARGETIC or
		_machineGrpType.type = MACHINETYPEGRP_MAFI then //jlier1 TFS 54700 14/9/22
		return;
	endif;

	self.getTaskDetails(_arbiter,_machineGrpType,true,sourceLC,sourceMachineTypeGrp);
	self.getTaskDetails(_arbiter,_machineGrpType,false,targetLC,targetMachineTypeGrp);
	
	_arbiter.entry.machineTypeGroup := _machineGrpType.type;
	_arbiter.entry.setMyRTMoveMethodRule(self);
	
	
	
	
	if _machineGrpType.type = MACHINETYPEGRP_IMV  then
		//write "move";
		create moveTask;
		moveTask.machineTypeGroup:=_machineGrpType.type;
		moveTask.setDetails(	sourceLC,
							targetLC,
							TASK_UNACTIONED,
							TASK_MOVE,
							_arbiter.ti);
							
		_arbiter.entry.addTask(moveTask);
	else
		//epr par 35702 ccms 2457 17/2/15
		if _createBreakBulkMaster then
			create taskPickup;
			taskPickup.setDetails(	sourceLC,
						targetLC,
						TASK_UNACTIONED,
						TASK_BREAKBULK,
						_arbiter.ti);
			taskPickup.machineTypeGroup:=targetMachineTypeGrp;
			_arbiter.entry.addTask(taskPickup);
			return;
		endif;	
		
		rtqEntry := _arbiter.entry;	
		if rtqEntry.isPlanOnPickup and rtqEntry.getPreviousRelatedEntry() = null and rtqEntry.allTasks.size = 1 then
			//already have a pickup task so create a setdown.
			create taskSetdown;
			taskSetdown.setDetails(	sourceLC,
									targetLC,
									TASK_UNACTIONED,
									TASK_SETDOWN,
									_arbiter.ti);
			taskSetdown.machineTypeGroup:=targetMachineTypeGrp;						
		
			_arbiter.entry.addTask(taskSetdown);
		else
			
			create taskPickup;
			create taskSetdown;
	 
			taskPickup.setDetails(	sourceLC,
									targetLC,
									TASK_UNACTIONED,
									TASK_PICKUP,
									_arbiter.ti);
			taskPickup.machineTypeGroup:=sourceMachineTypeGrp;
			_arbiter.entry.addTask(taskPickup);
		  
			taskSetdown.setDetails(	sourceLC,
									targetLC,
									TASK_UNACTIONED,
									TASK_SETDOWN,
									_arbiter.ti);
			taskSetdown.machineTypeGroup:=targetMachineTypeGrp;						
		
			_arbiter.entry.addTask(taskSetdown);
		endif;
		//write "Pickup &amp; Setdown";
	endif;

epilog

end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_machineGrpType" type="CM_MachineTypeGroup" usage="input"/>
        <Parameter name="_createBreakBulkMaster" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="compareRTMoveMethodRule" id="e8c37b77-f44b-47a6-b996-79c60bd858f8">
        <source>compareRTMoveMethodRule(	_machineTypeGrpArray : CM_MachineTypeGroupArray) : Boolean;
/*

Purpose:			has a machine type grp array as a parameter 
					if myRTMoveMethod starts with the machine type grps in the array then returns true 
					else will return false;

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2010	cnwer1	Initial creation

*/

vars
	iter1,
	iter2 : Iterator;
	machineTypGrp1,
	machineTypGrp2 : CM_MachineTypeGroup;
begin

	iter1:=_machineTypeGrpArray.createIterator;
	iter2:=self.myRTMoveMethod.allMachineTypeGroups.createIterator; 
	
	while iter1.next(machineTypGrp1) do
		while iter2.next(machineTypGrp2) do
			if machineTypGrp1 &lt;&gt; machineTypGrp2 then
				return false;
			endif;
		
		endwhile;
	
	endwhile;
	
	return true;
epilog
	delete iter1;
	delete iter2;
end;</source>
        <Parameter name="_machineTypeGrpArray" type="CM_MachineTypeGroupArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="48bc03ef-2b38-4818-8c5d-bd8d606f1e5a">
        <source>getDisplayDetails(_short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwer1	Initial creation

*/

vars

begin
	if self.shortDescription  &lt;&gt; null then
		return self.shortDescription; 
	else
		return self.myRTMoveMethod.description;
		
	endif;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2709efd8-a383-4d6f-a36a-6ec3815b4058">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwer1	Initial creation

*/

vars

begin
	if _attrName = ETRow_IsDefault then
		return self.isDefault.getYes;
	elseif _attrName = ETRow_MoveMethod then
		return self.myRTMoveMethod.description;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTAForInterchangeArea" id="083c29ff-0874-489e-afb4-161aa99ef6df">
        <source>getTAForInterchangeArea(_location : CM_LocationsController; _job : CM_Job;_wle : CM_WorkListEntry; _taskLocation : CM_LocationsController output; _myICArea : CM_InterchangeArea; 
		_taskMachineGroupType : Integer io; _machineGrpType : CM_MachineTypeGroup input);

/*

Purpose:	Get the Terminal Area for and Interchange Area		

Date			Who		Reason
22/08/2012		cnwmh5	Initial creation
29/10/2019		jlgdap1	TFS 47079 PRP Rlease Qty Issue
15 Jul 2025 	navbs1	Bug 34967: MSL - Wrong Target showed in RTQ when we move one unit from Railway Track to Yard Grid when changing the default Move Method
*/

vars
	voyageJob				: CM_VoyageJob;
	roroJob					: CM_VoyageROROJob;
	workPoint				: CM_WorkPoint;
	crane					: CM_Crane;
	ta						: CM_TerminalArea;
	icArea					: CM_YardInterchangeArea;
begin
	
	if _location.isKindOf(CM_GridController) and  _location.CM_GridController.myAssocGridInterchangeArea &lt;&gt; null then
		_taskLocation := _location.CM_GridController.myAssocGridInterchangeArea.getDefaultLane;
	elseif _myICArea &lt;&gt; null then
		_taskLocation := _myICArea.getDefaultLane;
	else
		
		ta := _location.getMyTerminalArea();
		//epr par 24917 7/7/10
		if ta = null and _location.isKindOf(CM_SlotController) then
			voyageJob := _job.CM_VoyageJob;
			crane := voyageJob.getJobCrane;
			if crane &lt;&gt; null then
				ta := crane.transferArea;
			endif;
		endif;
		
		//04 Mar 2011	NDL	Par 26988
		if ta = null and _location.isKindOf(CM_ShipBlockController) then
			roroJob := _job.CM_VoyageROROJob;
			crane := roroJob.myVoyage.getCraneWithNoJS();
			if crane &lt;&gt; null then
				ta := crane.transferArea;
			else
				// no ramp crane queue set up for this move....
				app.raiseCMException1(ERR_NO_RORO_QUEUE, roroJob.myVoyage.code,null,roroJob);
				return;
			endif;
		endif;
		
		// 20/08/2012 cnwmh5 #30194
		if ta = null and _location.isKindOf(CM_ROROSlotController) then
			voyageJob := _job.CM_VoyageJob;
			workPoint := voyageJob.getWorkPointObject().CM_WorkPoint;
			if workPoint &lt;&gt; null then
				ta := workPoint.myWorkPointInterchangeArea;
			endif;
		endif;
									
		//epr par 25241 30/7/10
		
		//jlier1 35614 8/8/25 - if it is a receipt (source is truck) and we want the source IC then get the Road Gate interchange or if the target is the truck and it wants the target IC then get the Road Gate interchage)
		if _job.isKindOf(CM_RoadJob) and ((_wle &lt;&gt; null and _wle.isReceipt and _taskMachineGroupType = MACHINETYPEGRP_SOURCEIC) or (_wle &lt;&gt; null and not _wle.isReceipt and _taskMachineGroupType = MACHINETYPEGRP_TARGETIC)) then //
				//jlier1 MTN-34595 20/5/25
				icArea := _job.CM_RoadJob.getOverride_YardICArea;
				if icArea = null then
					if _job.CM_RoadJob.myGate &lt;&gt; null then
						icArea:=_job.CM_RoadJob.myGate.myDefaultInterchangeArea.CM_YardInterchangeArea;
					endif;
				endif;
				
				if icArea &lt;&gt; null then
					_taskLocation:= icArea.getFirstAvailalableLane();
				else
					_taskLocation:=_location;	
				endif;
		
		elseif ta &lt;&gt; null and ta.isKindOf(CM_InterchangeArea) then
			_taskLocation:=ta.CM_InterchangeArea.getDefaultLane;
		else
			if (_job.isRail and ta.isRail) 							// TFS 47079	//15.07.2025 navbs1 #34967
			or (_job.isYardInternalJob and ta.isRail) then							//15.07.2025 navbs1 #34967
				_taskLocation := ta.CM_Rail.myTransferArea.myLocationsController;	// TFS 47079
			// else use the default interchange area
			//if ta &lt;&gt; null and ta.myDefaultInterchangeArea &lt;&gt; null then			// TFS 47079
			elseif ta &lt;&gt; null and ta.myDefaultInterchangeArea &lt;&gt; null then			// TFS 47079
					_taskLocation:=ta.myDefaultInterchangeArea.getDefaultLane;
			else
				//else use the first
				if ta &lt;&gt; null and ta.allAssociatedInterchangeAreas.size &gt; 0 then
					_taskLocation:=ta.allAssociatedInterchangeAreas.first.getDefaultLane;
				else
					_taskLocation:=_location;
					_taskMachineGroupType:= _machineGrpType.type;
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_taskLocation" type="CM_LocationsController" usage="output"/>
        <Parameter name="_myICArea" type="CM_InterchangeArea"/>
        <Parameter name="_taskMachineGroupType" type="Integer" usage="io"/>
        <Parameter name="_machineGrpType" type="CM_MachineTypeGroup" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTaskDetails" id="aa9ea4a5-5324-42f1-a648-91a301400eba">
        <source>getTaskDetails(_arbiter : CM_RTQueueArbiter; _machineGrpType : CM_MachineTypeGroup input; _isSource : Boolean; _taskLocation : CM_LocationsController output; _taskMachineGroupType : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Feb 2010	cnwer1	Initial creation
25 Jun 2010 cnwer1	PAR 24502
30 Jul 2010 cnwer1 	PAR 25241 - for source IC or target IC where the ta they are in is an interchange area use that area
08 Aug 2025 jlier1 35614 
*/

vars
	iter		 : Iterator;
	machineTypeGrp : CM_MachineTypeGroup;
begin

	iter:=self.myRTMoveMethod.allMachineTypeGroups.createIterator;
	
	iter.startAtIndex(_arbiter.currentMachineTypeGrpIndex);
	//iter.startAtObject(_machineGrpType);
	
	if _isSource then
		_taskLocation:=_arbiter.sourceLocation;
		iter.back(machineTypeGrp);
		if not iter.back(machineTypeGrp) then
			machineTypeGrp:=null;
		endif;
	else
		_taskLocation:=_arbiter.targetLocation;
		iter.next(machineTypeGrp);
		if not iter.next(machineTypeGrp) then
			machineTypeGrp:=null;
		endif;
	endif;
	
	_taskMachineGroupType:= _machineGrpType.type;
	if _machineGrpType.type = MACHINETYPEGRP_IMV then
		//source location must be an RTG area get the IC Area
		if _isSource then
			_taskLocation:=_arbiter.sourceLocation.getMyLaneController;
		else
			_taskLocation:=_arbiter.targetLocation.getMyLaneController;
		endif;
	endif;
	//get source
	if machineTypeGrp &lt;&gt; null then
		if machineTypeGrp.type = MACHINETYPEGRP_SOURCEIC then
			_taskMachineGroupType:=MACHINETYPEGRP_SOURCEIC;
			if _arbiter.sourceLocation.isKindOf(CM_RTGController) then
				if self.mySourceICArea &lt;&gt; null then
					_taskLocation:=self.mySourceICArea.allGridControllersByRowColumn[1,_arbiter.sourceLocation.CM_GridController.column];
				else
					_taskLocation:=_arbiter.sourceLocation.getMyLaneController;
				endif;
			else
				
				self.getTAForInterchangeArea(_arbiter.sourceLocation, _arbiter.job,_arbiter.wle, _taskLocation, self.mySourceICArea, _taskMachineGroupType, _machineGrpType);    // 22/08/2012 cnwmh5 #30194

			endif;
		elseif machineTypeGrp.type = MACHINETYPEGRP_TARGETIC then
			_taskMachineGroupType:=MACHINETYPEGRP_TARGETIC;
			if _arbiter.targetLocation &lt;&gt; null then
				if _arbiter.targetLocation.isKindOf(CM_RTGController) then
					if self.myTargetICArea &lt;&gt; null then
						_taskLocation:=self.myTargetICArea.allGridControllersByRowColumn[1,_arbiter.targetLocation.CM_GridController.column];
					else
						_taskLocation:=_arbiter.targetLocation.getMyLaneController;
					endif;
				else
					self.getTAForInterchangeArea(_arbiter.targetLocation, _arbiter.job,_arbiter.wle, _taskLocation, self.myTargetICArea, _taskMachineGroupType, _machineGrpType);   // 22/08/2012 cnwmh5 #30194

				endif;
			endif;
		elseif machineTypeGrp.type = MACHINETYPEGRP_IMV then
			_taskLocation:=null;
			_taskMachineGroupType:=MACHINETYPEGRP_IMV;
		elseif machineTypeGrp.type = MACHINETYPEGRP_MAFI then //jlier1 TFS 54701 19/9/22
			_taskMachineGroupType:=MACHINETYPEGRP_MAFI;
		endif;
	endif;
epilog
	delete iter;

end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter"/>
        <Parameter name="_machineGrpType" type="CM_MachineTypeGroup" usage="input"/>
        <Parameter name="_isSource" type="Boolean"/>
        <Parameter name="_taskLocation" type="CM_LocationsController" usage="output"/>
        <Parameter name="_taskMachineGroupType" type="Integer" usage="output"/>
    </JadeMethod>
