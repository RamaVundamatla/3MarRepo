    <JadeMethod name="tblDataDisplayRow" id="f9dfc8df-36f2-43ee-90b1-2cda7fcf0ad0">
        <source>tblDataDisplayRow(table: Table input; obj: Object): String;
// ---------------------------------------------------------------------------
// Created:     26 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;
		
begin

	if (not obj.CM_Object.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;

	return obj.CM_Object.getAttributeStringForDefArray(table.CM_DataTable.allTblDataEntRows);
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
