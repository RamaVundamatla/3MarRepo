    <JadeMethod name="getVoyageArrivalDate" id="070747a2-3d23-4b8a-8386-79932e61141f">
        <source>getVoyageArrivalDate():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142
21/07/2014	cnwjre1 34580 extend to get from cargo if not on receipt
*/

vars
	date	: Date;
begin

	date := null;
	if self.myTrackedItem &lt;&gt; null and
	   self.myTrackedItem.myVoyage &lt;&gt; null and
	   self.myTrackedItem.myVoyage.arrivedDT.Date.isValid then
		date := self.myTrackedItem.myVoyage.arrivedDT.Date;
	endif;

	if date = null and
	   self.myCashReceipt &lt;&gt; null then
		date := self.myCashReceipt.getVoyageArrivalDate();
	endif;

	return date;

epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getVoyageArrivalDateLocalTZ" id="411f215f-f04d-48c7-8d82-7822a10f61ea">
        <source>getVoyageArrivalDateLocalTZ():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2016	cnwns1	Initial creation
// 27 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	date	: Date;
begin

	date := null;
	if self.myTrackedItem &lt;&gt; null and
	   self.myTrackedItem.myVoyage &lt;&gt; null and
	   self.myTrackedItem.myVoyage.arrivedDT.Date.isValid then
		date := self.systemToLocalTime(self.myTrackedItem.myVoyage.arrivedDT).Date;
	endif;

	if date = null and
	   self.myCashReceipt &lt;&gt; null then
		date := self.myCashReceipt.getVoyageArrivalDateLocalTZ();
	endif;

	return date;

epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
