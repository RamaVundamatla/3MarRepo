    <JadeMethod name="getDefaultMeasurementForType" id="3ee85e80-fecb-46a8-8c7b-110604b5dae5">
        <source>getDefaultMeasurementForType(_type : String) : CM_MeasurementType;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/02/2013	cnwdap1	Initial creation PAR #31155 CCNS SFW 1321 Imperial Measurements
*/
vars

begin

	if _type = Type_Height
	or _type = Type_Width
	or _type = Type_Length
	then
		//05 Sep 2013	NDL	Par 32413 - Can be different at Product level
		// but not at system level.
		return self.myRoot.allDefaultMeasurementTypes[Type_Linear];
	
	else
		return self.myRoot.allDefaultMeasurementTypes[_type];
	
	endif;
epilog

end;</source>
