    <JadeMethod name="doDelete" id="3b8893ab-f41c-4839-ad8c-1ed13d6240f2">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	invalidObj : Boolean;
begin

 on Exception do app.handleDeletedObject(exception, self.myObject.CM_LogLength, invalidObj); // cnwrd1 3.11.08 par 18090
 
	app.myTrxDA.trxDeleteLogLength(self.myObject.CM_LogLength, app.myPassport);
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="fda885ca-4f1c-4cac-8603-25b0eeabd7f0">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyLength, newLength : CM_LogLength;
begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_LogLength transient;
	endif;
	
	proxyLength := self.myForm.myProxyObject.CM_LogLength;
	
	proxyLength.setProxy(	self.myForm.tblInput1.getValueByName('code').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
							self.myForm.tblInput1.getValueByName('description').String,
							self.myForm.tblInput1.getValueByName('notAvailableForEntry').Boolean,
							self.myObject.CM_LogLength.myCodeGroupLogSpecs);
							
	if app.getMyUser.canDo(self.myForm.myTerminal, PmLogLengthSortCode) then
		proxyLength.setSortKey(self.myForm.tblInput1.getValueByName('sortKey').Decimal);
	endif;
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateLogLength(proxyLength, newLength,app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := newLength;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateLogLength(proxyLength, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject := proxyLength;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPeerClass" id="5b8721a6-5971-4538-88c2-f61af3f77338">
