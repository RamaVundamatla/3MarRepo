    <JadeMethod name="utlCreateVoyageStatus" id="1ff6e6b6-0c9e-4293-b4d7-ffcd9477f72a">
        <source>utlCreateVoyageStatus(_pxyVoyageStatus : CM_VoyageStatus; _newVoyageStatus : CM_VoyageStatus output; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valVoyageStatus(_pxyVoyageStatus, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newVoyageStatus as _pxyVoyageStatus.class persistent;
	_newVoyageStatus.setForCreate(_pxyVoyageStatus);
	
