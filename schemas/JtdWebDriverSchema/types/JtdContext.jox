    <JadeMethod name="jtdCreateDriverProfiles" id="032e1172-0293-4a4a-8f9b-228a8f458f18">
        <source>jtdCreateDriverProfiles(dpDict : JtdDriverProfileNameDict input;
	includeMethodsWithZeroCalls : Boolean);

// it is the caller's responsibility to clear dpDict if required
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	dp : JtdDriverProfile;
	n, len : Integer;
	s : String;
	
begin
	
	s := self.jtdMyProfileTextMethod.text.trimBlanks;
	
	len := s.length;
	
	if len &lt; 1 then
		return;
	endif;

	n := 1;
		
	while true do
		n := s.pos(JtdDriverProfile.JtdTagBeginProfile, n);
		
		if n &lt; 1 then
			break;
		endif;
		
		create dp transient;
		dp.jtdSetFromString(s[n : end], includeMethodsWithZeroCalls);
		dpDict.add(dp);
		
		n := n + JtdDriverProfile.JtdTagBeginProfile.length;
		
		if n &gt;= len then
			break;
		endif;
	endwhile;
end;</source>
        <Parameter name="dpDict" type="JtdDriverProfileNameDict" usage="input"/>
        <Parameter name="includeMethodsWithZeroCalls" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdCreateTrxGeneratorRecursive" id="77bdc628-781f-4a66-aaa9-e7b712ab5bc5">
        <updating/>
        <source>jtdCreateTrxGeneratorRecursive(cls : Class) updating, protected;

vars
	rootCls, subCls : Class;
	trxGen : JtdTransactionGenerator;
	trxMth : JtdTrxGenMethodDesc;
	mth : Method;
	
begin
	if cls = null then
		return;
	endif;
	
	rootCls := cls.rootType;
	
	if rootCls &lt;&gt; JtdTransactionGenerator and (not rootCls.inheritsFrom(JtdTransactionGenerator)) then
		return;
	endif;

	if not rootCls.abstract then
		trxGen := self.jtdAllTrxGeneratorsByClassName[rootCls.name];

		if trxGen = null then
			create trxGen as rootCls transient;
			self.jtdAllTrxGeneratorsByClassName.putAtKey(rootCls.name, trxGen);
		endif;
		
		if trxGen &lt;&gt; null then
			foreach mth in rootCls.jtdGetMethods do
				create trxMth transient;
				trxMth.jtdUpdateForCreate(rootCls.name, mth.name, trxGen);
				self.jtdAllTrxGenMethodDescs.add(trxMth);
			endforeach;
		endif;
	endif;
	
	foreach subCls in cls.jtdGetSubclasses do
		self.jtdCreateTrxGeneratorRecursive(subCls);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="cls" type="Class"/>
    </JadeMethod>
    <JadeMethod name="jtdEndAllClocks" id="1af1f3ed-ba43-4733-b8d5-8a40bcfab51f">
        <updating/>
        <source>jtdEndAllClocks() : Integer updating;

vars
	n : Integer;
	
begin
	n := app.clock;
	
	self.jtdGenEndClock := n;
	self.jtdTrxEndClock := n;
	
	return n;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdEndAllRunningClocks" id="13bedbf8-e41f-4325-aaea-dc8567e52682">
        <updating/>
        <source>jtdEndAllRunningClocks() : Integer updating;

vars
	n : Integer;
	
begin
	n := app.clock;

	if self.jtdGenStartClock &lt;= 0 then
		self.jtdClearGenClock;
	elseif self.jtdGenEndClock &lt;= 0 then
		self.jtdGenEndClock := n;
	endif;

	if self.jtdTrxStartClock &lt;= 0 then
		self.jtdClearTrxClock;
	elseif self.jtdTrxEndClock &lt;= 0 then
		self.jtdTrxEndClock := n;
	endif;
	
	return n;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdEndGenClock" id="8cc2bea4-59d2-4898-bfaf-4ee7f1e8209a">
        <updating/>
        <source>jtdEndGenClock() : Real updating;

begin
	self.jtdGenEndClock := app.clock;
	return self.jtdGetGenerationSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdEndTrxClock" id="d2a32506-6ce7-45eb-8798-1770c3d78779">
        <updating/>
        <source>jtdEndTrxClock() : Real updating;

begin
	self.jtdTrxEndClock := app.clock;
	return self.jtdGetTransactionSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdErrorMsg" id="ecb7fd14-21bb-4afe-b590-c27d1083a944">
        <source>jtdErrorMsg(msg : String; fatal : Boolean);

begin
	if fatal then
		app.msgBox(msg &amp; CrLf &amp; CrLf &amp; "The transaction driver will terminate.",
			"Fatal Error", MsgBox_OK_Only);
		terminate;
		return;
	endif;
		
	app.msgBox(msg, "Error", MsgBox_OK_Only);
end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="fatal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdFinalize" id="95396b89-0ba9-4745-bd47-3139a16f45b4">
        <updating/>
        <source>jtdFinalize() updating, protected;

vars
	e : JtdErrorMessage;
	g : JtdTransactionGenerator;
	d : JtdTrxGenMethodDesc;
	
begin
	foreach d in self.jtdAllTrxGenMethodDescs do
		// guard in case someone else has already deleted it
		if d &lt;&gt; null and global.isValidObject(d) then
			delete d;
		endif;
	endforeach;

	foreach g in self.jtdAllTrxGeneratorsByClassName do
		// guard in case someone else has already deleted it
		if g &lt;&gt; null and global.isValidObject(g) then
			delete g;
		endif;
	endforeach;
		
	foreach e in self.jtdAllErrorMessages do
		// guard in case someone else has already deleted it
		if e &lt;&gt; null and global.isValidObject(e) then
			delete e;
		endif;
	endforeach;
	
	if self.jtdMyDriverProfile &lt;&gt; null and global.isValidObject(self.jtdMyDriverProfile) then
		delete self.jtdMyDriverProfile;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdGetCPUDetails" id="ea00d69b-5d9e-4225-9275-ddeca8980afd">
        <source>jtdGetCPUDetails(localDetails, thinDetails : String output) protected;

constants
	HKEY_CLASSES_ROOT       : Integer = #80000000;
	HKEY_CURRENT_USER       : Integer = #80000001;
	HKEY_LOCAL_MACHINE      : Integer = #80000002;
	HKEY_USERS              : Integer = #80000003;
	HKEY_PERFORMANCE_DATA   : Integer = #80000004;
	HKEY_CURRENT_CONFIG     : Integer = #80000005;
	HKEY_DYN_DATA           : Integer = #80000006;
	PROCESSOR_INTEL_386     : Integer = 386;
	PROCESSOR_INTEL_486     : Integer = 486;
    PROCESSOR_INTEL_PENTIUM : Integer = 586;
    PROCESSOR_MIPS_R4000    : Integer = 4000;
    PROCESSOR_ALPHA_21064   : Integer = 21064;
 
vars
	sysInfo    : Binary;
	hKey       : Integer;
	subKey     : String[256];
	valueName  : String[256];
	data       : Binary[256]; 
	openKey    : Integer;
	result     : Integer; 
	openResult : Integer;
	length     : Integer;
	dwNumCPUs  : Integer;
	dwCPUType  : Integer;
	unicode    : Boolean;
	s          : String;
  
begin
	localDetails := null;
	thinDetails := null;

	unicode := app.isUnicode;

	// Get local machine details first.
	// If we're running thin client, this will get details for the app server.
	
	hKey := HKEY_LOCAL_MACHINE;
	subKey := "HARDWARE\DESCRIPTION\System\CentralProcessor\0";
	data := null; 
	data[255 : 1] := 0.Binary;
	length := 255;
	valueName := "~MHz";
	sysInfo := null;
	sysInfo[32 : 1] := 0.Binary;
	
	if unicode then
		openResult := call jtdRegOpenKeyWLocalMachine(hKey, subKey, openKey);
		result := call jtdRegQueryValueWLocalMachine(openKey, valueName, null, null, data, length);
	else
		openResult := call jtdRegOpenKeyALocalMachine(hKey, subKey, openKey);
		result := call jtdRegQueryValueALocalMachine(openKey, valueName, null, null, data, length);
	endif;

	result := call jtdRegCloseKeyLocalMachine(openKey);

	call jtdGetSystemInfoLocalMachine(sysInfo);
	
	dwNumCPUs := sysInfo[21 : 4].Integer;
	dwCPUType := sysInfo[25 : 4].Integer;

	if dwNumCPUs &gt; 1 then
		s := dwNumCPUs.String &amp; " x ";
	else
		s := null;
	endif;

	if dwCPUType = PROCESSOR_INTEL_386 then
		s := s &amp; "i386 ";
	elseif dwCPUType = PROCESSOR_INTEL_486 then
		s := s &amp; "i486 ";
	elseif dwCPUType = PROCESSOR_INTEL_PENTIUM then
		s := s &amp; "Pentium ";
	else
		s := s &amp; "Non-Intel ";
	endif;
	
	localDetails := s &amp; data.Binary[1 : 4].Integer.String;

	// If we're running thin client, get details for the thin client machine.
	// Otherwise a null string will be returned for the thin client details.
	
	if not process.isUsingThinClient then
		return;
	endif;
	
	// Re-initialize parameter values in case prior calls changed them
	hKey := HKEY_LOCAL_MACHINE;
	subKey := "HARDWARE\DESCRIPTION\System\CentralProcessor\0";
	data := null; 
	data[255 : 1] := 0.Binary;
	length := 255;
	valueName := "~MHz";
	sysInfo := null;
	sysInfo[32 : 1] := 0.Binary;
	
	if unicode then
		openResult := call jtdRegOpenKeyWThinClient(hKey, subKey, openKey);
		result := call jtdRegQueryValueWThinClient(openKey, valueName, null, null, data, length);
	else
		openResult := call jtdRegOpenKeyAThinClient(hKey, subKey, openKey);
		result := call jtdRegQueryValueAThinClient(openKey, valueName, null, null, data, length);
	endif;

	result := call jtdRegCloseKeyThinClient(openKey);

	call jtdGetSystemInfoThinClient(sysInfo);
	
	dwNumCPUs := sysInfo[21 : 4].Integer;
	dwCPUType := sysInfo[25 : 4].Integer;

	if dwNumCPUs &gt; 1 then
		s := dwNumCPUs.String &amp; " x ";
	else
		s := null;
	endif;

	if dwCPUType = PROCESSOR_INTEL_386 then
		s := s &amp; "i386 ";
	elseif dwCPUType = PROCESSOR_INTEL_486 then
		s := s &amp; "i486 ";
	elseif dwCPUType = PROCESSOR_INTEL_PENTIUM then
		s := s &amp; "Pentium ";
	else
		s := s &amp; "Non-Intel ";
	endif;
	
	thinDetails := s &amp; data.Binary[1 : 4].Integer.String;
end;</source>
        <access>protected</access>
        <Parameter name="localDetails" type="String" usage="output"/>
        <Parameter name="thinDetails" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="jtdGetCommandLine" id="ff1a3027-e9cd-4f6a-8dbc-5bbeb9f83328">
        <source>jtdGetCommandLine() : String;

begin
	if app.isUnicode then
		return call jtdGetCommandLineW;
	endif;
	return call jtdGetCommandLineA;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetDefaultAutoPingInterval" id="be9d2f6c-b8dc-460b-a7fa-bdde8030f90c">
        <source>jtdGetDefaultAutoPingInterval() : Integer protected;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	n, startPos : Integer;
	s : String;
	
begin
	
	s := self.jtdMyProfileTextMethod.text.trimBlanks;
	
	if s = null then
		return 0;
	endif;

	n := s.pos(JtdDriverProfile.JtdTagDefaultAutoPingInterval, 1);
	
	if n &lt; 1 then
		return 0;
	endif;
	
	startPos := s.pos(' ', n);
	
	if startPos &lt;= n then
		return 0;
	endif;
	
	n := s.pos(';', startPos);
	
	if n &lt;= startPos then
		return 0;
	endif;
	
	return s[startPos : n - startPos].trimBlanks.Integer;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
