    <JadeMethod name="doNext" id="49a8f47c-21c6-446d-a9c1-44f6cba71530">
        <updating/>
        <source>doNext( errMsg : String output):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	train : CM_Train;
	wagonVisit : CM_Wagon;
	
begin

	self.myMobileGenericAgent.setMyCurrentTrain(null);
	self.myMobileGenericAgent.setMyCurrentWagon(null);
	self.myMobileGenericAgent.setChecksState(0);
	
	wagonVisit := self.cmbWagon.listObject.CM_Wagon;
	if wagonVisit = null then
		errMsg := self.lblWagon.caption;
		return false;
	endif; 
	
	if not self.optDischarge.value and not self.optLoad.value then
		errMsg := app.getErrorString2( Please_select_one_of_2, self.optDischarge.caption, self.optLoad.caption );
		return false;
	endif;
	
	train := self.cmbTrain.listObject.CM_Train;
	self.myMobileGenericAgent.setMyCurrentTrain(train);
	self.myMobileGenericAgent.setMyCurrentWagon(wagonVisit);
	
	if self.optDischarge.value then
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.RailReceipt);
	elseif self.optLoad.value then
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.RailRelease);
	else
		errMsg := "Invalid state - see developer";
		return false;
	endif;
	
	self.gotoForm( MOB_HHLanderRailCargoMove, false );
	
	return true;
	
	
epilog

end;</source>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="bcab7ad8-fa35-490b-851f-49b877b039fd">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	top : Real;
	width : Real;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	top := self.resizedMargin;
	width := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.cmbTrain.visible := true;
	endif;
	self.cmbTrain.move( self.resizedMargin,
						top,
						width,
						stdHeight );
						 
	
	top := top + self.cmbTrain.height + self.resizedMargin;
	
	if _initialSetup then
		self.cmbWagon.visible := true;
	endif;
	self.cmbWagon.move(	self.resizedMargin,
						top,
						width,
						stdHeight );
	
	
	top := top + self.cmbWagon.height + self.resizedMargin; 
	width := (( width / 3 ) * 2 );
	if _initialSetup then
		self.optDischarge.visible := true;
	endif;
	self.optDischarge.move( self.resizedMargin,
							top,
							width,
							stdHeight );
	
	
	top := top + self.optDischarge.height + self.resizedMargin;
	if _initialSetup then
		self.optLoad.visible := true;
	endif;
	self.optLoad.move(	self.resizedMargin,
						top,
						width,
						stdHeight );
							 
	top := top + self.optLoad.height + self.resizedMargin;

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="166f5d13-4ac3-4146-9563-27181186260b">
