        <Parameter name="_transportID" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTDT30Segment" id="e791ba6e-039a-4063-9e55-3f4bb9338484">
        <source>makeTDT30Segment(	_protocol :CM_CamProtocol; 
					_group :HugeStringArray input; 
					_ref, 
					_mode,
					_means, 
					_carrier, 
					_carrierQual, 
					_carrierAgency, 
					_direction, //null
					_excess, //null
					_transportMeansID, 
					_transportQual, 
					_transportAgency, //null
					_transportID :String ) :String protected;
/*
Purpose:	Make a TDT+30 segment
Parameters:	_ref	- conveyance reference number
			_mode 	- mode of transport
			

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
22 Jan 2018	jlgrs1	TFS 36713 SNO Structure error in COARRI
25 Sep 2018	jlggb1	TFS 40947 SNO Correction to 36713 
*/
constants
	MESSAGE	= "TDT";
	STAGE = "30";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			STAGE;
			
	if _ref = null and _mode = null and _means = null and 
		_carrier = null and _carrierQual = null and _carrierAgency = null and
		_direction = null and _excess = null and 
		_transportMeansID = null and _transportQual = null and _transportAgency = null and _transportID = null then
		// because the TDT+30 must be the first segment in group 5 we need to allow for a dummy segment
		// TDT+30'
		msg := msg &amp; singleQuote;
	else
		msg := msg &amp; plus &amp; 
				_ref &amp; plus &amp;
				_mode &amp; plus &amp; 
				_means &amp; plus &amp;
				_carrier;
				
		if _carrierQual &lt;&gt; null then
			msg := msg &amp; colon &amp; _carrierQual;
		endif;
	
		if _carrierQual &lt;&gt; null and _carrierAgency &lt;&gt; null then
			msg := msg &amp; colon &amp; _carrierAgency;
		endif;
		
		msg := msg &amp; plus &amp; 
				_direction &amp; plus &amp;
				_excess &amp; plus &amp;
				_transportMeansID;
				
		if _transportQual &lt;&gt; null then
			msg := msg &amp; colon &amp; _transportQual &amp; colon &amp; _transportAgency &amp; colon &amp; _transportID;
		endif;
		
		msg := msg &amp; singleQuote;
	endif;
	
	if _group &lt;&gt; null then
	//	_group.add (msg[1:62]);
		_group.add (msg);	//26 May 2020	NDL	TFS 49370
	endif;
	
	return msg;
epilog

end;</source>
