    <JadeMethod name="displayDimensions" id="444db67c-293e-4d4b-9a47-21396fe1e756">
        <updating/>
        <source>displayDimensions() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/02/2010	cnwdap1	Initial creation
04/03/2010	cnwdap1	PAR #22741 Correct call to getToDoTaskForCargoCheck - was using myCargoCheckItem.name
*/
vars
	taskDesc	: Integer;
	toDo		: CM_ToDoTask;

begin
	if self.myTrackedItem &lt;&gt; null then
		self.txtLength.text		:= self.myTrackedItem.length.asStringMeasurementJMT;
		self.txtWidth.text		:= self.myTrackedItem.width.asStringMeasurementJMT;
		self.txtHeight.text		:= self.myTrackedItem.height.asStringMeasurementJMT;
		
		// 37244 if called from todo task completion, myCargoCheckItem will be null
		if self.myCargoCheckItem &lt;&gt; null then
			// check for a to do task
			taskDesc := self.myMobileGenericAgent.getToDoTaskForCargoCheck(self.context, self.myCargoCheckItem.requiredExtraInfo, self.myTerminal);
			if taskDesc &lt;&gt; null then
				// does the tracked item have a to do task that matches this description?
				foreach toDo in self.myTrackedItem.allToDoTasksToDo do
					if toDo.toDoTaskDesc.code = taskDesc then
						chkAddToDo.value := true;
					endif;
				endforeach;
			endif;
		endif;			
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="13aff824-f605-417a-86f5-7109385a137d">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604
04 Feb 2016	NDL	Par 37513

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	halfWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;
	index : Integer;
	textBoxWidth : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	halfWidth := ( stdWidth - self.resizedMargin ) / 2;
	stdHeight := self.getStdControlHeight;
	textBoxWidth := stdHeight * 5;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	cLeft := self.resizedMargin;
	tabIndex := 4000;
	
	if _initialSetup then
		self.lblLength.setAndIncrementTabIndex( tabIndex );
		self.lblLength.visible := true;
	endif;
	self.lblLength.move( 	cLeft,
							cTop,
							halfWidth,
							cHeight );
							
	cLeft := halfWidth + ( self.resizedMargin * 2);
	if _initialSetup then
		self.txtLength.setAndIncrementTabIndex( tabIndex );
		self.txtLength.visible := true;
	endif;
	self.txtLength.move( 	cLeft,
							cTop,
							textBoxWidth,
							cHeight );
								
	cLeft := self.resizedMargin;
	cTop := cTop + self.lblLength.height + self.resizedMargin;
	
	
	if _initialSetup then
		self.lblWidth.setAndIncrementTabIndex( tabIndex );
		self.lblWidth.visible := true;
	endif;
	self.lblWidth.move( 	cLeft,
							cTop,
							halfWidth,
							cHeight );
							
	cLeft := halfWidth + ( self.resizedMargin * 2);
	if _initialSetup then
		self.txtWidth.setAndIncrementTabIndex( tabIndex );
		self.txtWidth.visible := true;
	endif;
	self.txtWidth.move( 	cLeft,
							cTop,
							textBoxWidth,
							cHeight );
								
	cLeft := self.resizedMargin;
	cTop := cTop + self.lblWidth.height + self.resizedMargin;

	
	if _initialSetup then
		self.lblHeight.setAndIncrementTabIndex( tabIndex );
		self.lblHeight.visible := true;
	endif;
	self.lblHeight.move( 	cLeft,
							cTop,
							halfWidth,
							cHeight );
							
	cLeft := halfWidth + ( self.resizedMargin * 2);
	if _initialSetup then
		self.txtHeight.setAndIncrementTabIndex( tabIndex );
		self.txtHeight.visible := true;
	endif;
	self.txtHeight.move( 	cLeft,
							cTop,
							textBoxWidth,
							cHeight );
	
	cTop := cTop + self.lblHeight.height + self.resizedMargin;
	cLeft := halfWidth / 2;
	if _initialSetup then
		self.chkAddToDo.setAndIncrementTabIndex( tabIndex );
	endif;
	self.chkAddToDo.move( 	cLeft,
							cTop,
							halfWidth,
							cHeight );
	
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="2dbdaf73-0941-48c2-978b-ead36bdada31">
        <updating/>
        <source>doSave() : Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/02/2010	cnwdap1	Initial creation
04/03/2010	cnwdap1	PAR #22741 New parameter for updateGenCargoDimensions so we know whether to add or remove the to do task
*/
vars
	sessionAgent	: CM_MobileAgent;
	errors			: String;
	toDoTaskCode	: Integer;
	addingToDo		: Boolean;
	addCompRemTodo	: Integer;	// 1 = add, 2 = complete, 3 = remove 16 Mar 2016	NDL TFS 1673

begin
	app.mousePointer := self.MousePointer_HourGlass;

	sessionAgent := self.getSessionAgent;
	if sessionAgent.getMyProxyObject = null then
		return false;
	endif;
	
	// 37244 this code from cargo check, not from to-do task completion
	if self.myToDoTaskDesc = null then
		toDoTaskCode 	:= self.myMobileGenericAgent.getToDoTaskForCargoCheck(CARGO_CHECK_CONTEXT_GATE_REC, EXTRA_INFO_DIMENSION, self.myTerminal);
	//	addingToDo		:= self.chkAddToDo.value;
		//16 Mar 2016	NDL TFS 1673
		if self.chkAddToDo.value then
			addCompRemTodo := 1;
		else
			addCompRemTodo := 3;
		endif;
	else
		//16 Mar 2016	NDL TFS 1673
		toDoTaskCode := self.myToDoTaskDesc.code;
		addCompRemTodo := 2;
	endif;
	
	if sessionAgent.updateGenCargoDimensions(	self.txtLength.text.trimBlanks.Decimal,
												self.txtWidth.text.trimBlanks.Decimal,
												self.txtHeight.text.trimBlanks.Decimal,
												toDoTaskCode,
												addCompRemTodo	) then
		if errors &lt;&gt; null then
			self.msgBox(errors, "Error", MsgBox_OK_Only, false);
			return false;
		endif;
		
		return true;
	else
		return false;
	endif;
	
epilog
	app.mousePointer := self.MousePointer_Default;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="eeb95c39-e5c1-4869-97be-82ae9ecaac4c">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2010	cnwdap1	Initial creation
*/
vars

begin
	if self.doSave() then
		if self.myToDoTaskDesc = null then
			self.doBackButtonClick();
		else
			self.getSessionAgent().setMyProxy( null ); // delete the proxy TI
			self.unloadForm();
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="02ebd8b1-6cb0-4f13-9f1f-98b36daa6dc0">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2010	cnwdap1	Initial creation
*/
vars

begin
	// 37244 from to-do task completion
	if self.myToDoTaskDesc = null then
		self.doBackButtonClick();
	else
		self.getSessionAgent().setMyProxy( null ); // delete any proxy TI
		self.unloadForm();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTrackedItem" id="f7f894f0-1706-4a56-a164-2654e58c93c5">
        <updating/>
        <source>setTrackedItem(_value : CM_TrackedItem) updating;
//  37244 set myTrackedItem directly without affecting anything else
vars

begin
	self.myTrackedItem := _value;
end;
</source>
        <Parameter name="_value" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="c950d58b-4f13-46d7-9b2d-cca248a0ffc2">
        <updating/>
        <source>setupControls() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/02/2010	cnwdap1	Initial creation
31/03/2010	cnwdap1	PAR #22741 expand to do task checking for all contexts
*/
vars

	context		: Integer;
	cargoCheck	: CM_CargoCheck;
	item		: CM_CargoCheckItem;

begin
	self.lblLength.visible := true;
	self.txtLength.visible := true;
	self.lblWidth.visible := true;
	self.txtWidth.visible := true;
	self.lblHeight.visible := true;
	self.txtHeight.visible := true;

	// to do task checkbox is only visible if the cargo check item has a to do task associated with it
	//cargoCheck := self.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_GATE_REC];	// PAR #22741
	cargoCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();		// PAR #22741
	if cargoCheck &lt;&gt; null then
		foreach item in cargoCheck.allCargoCheckItems discreteLock where item.requiredExtraInfo = EXTRA_INFO_DIMENSION do	//31 May 2012	NDL Par 29038
			if item.myToDoTaskDesc &lt;&gt; null then
				self.chkAddToDo.visible	:= true;
			endif;
		endforeach;
	endif;
	
	self.doResizeControls(true);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8d99be85-b01a-4e22-8723-2841e934a2a3">
        <updating/>
        <source>setupForm() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2010	cnwdap1	Initial creation
*/
vars

begin

	// 37244 from to-do task completion tracked item has already been setup
	if self.myTrackedItem = null then
		self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	endif;
	app.myMobileAgent.setMyProxy( self.myTrackedItem );
	app.myMobileAgent.setMySelectedTI(self.myTrackedItem);
	
	inheritMethod();
	
	// 37244 from to-do task completion
	if self.myToDoTaskDesc = null and
	   self.myMobileGenericAgent.stringField1 &lt;&gt; null then
		self.context := self.myMobileGenericAgent.stringField1[1:2].Integer;
		self.myCargoCheckItem := self.myMobileGenericAgent.stringField1[3:end].asOid.CM_CargoCheckItem;
		self.myMobileGenericAgent.setStringField1(null);
	endif;

	if self.myToDoTaskDesc = null then
		self.setupCmdButtons( 2, app.getErrorString(Save), BACK_BUTTON, null, null, null );
	else
	// 37244 from to-do task completion
		self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
		if self.myTrackedItem &lt;&gt; null then
			self.caption := self.caption &amp; " " &amp; self.myTrackedItem.id;
		endif;
	endif;
	self.setupControls();
	self.displayDimensions();
	self.txtLength.setFocus();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="dfe0c016-1ddc-43c3-9496-d77a1a840054">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014403, locale);
	chkAddToDo.translateCaption(Xlat_0014404, locale);
	lblHeight.translateCaption(Xlat_0014405, locale);
	lblLength.translateCaption(Xlat_0014406, locale);
	lblWidth.translateCaption(Xlat_0014407, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
