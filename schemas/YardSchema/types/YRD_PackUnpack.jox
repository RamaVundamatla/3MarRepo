vars
	tiSelected	: CM_TrackedItem;

begin

	// checking whether ti was changed. #26401 29/11/2010
	tiSelected := self.cmbTrackedItem.listObject.CM_TrackedItem;
	if (tiSelected = self.myTI) and 
	   (self.cmbCargoType.listObject &lt;&gt; null)	// #27213 29/03/2011. when cargo type is deleted, trackedItem wull be deleted, too.
	then
		return;	// ti not changed, do nothing and exit.
	endif;

	/*This code below moved back to doDisplayTrackedItem(), as it was before. cnwvu1 #26401 29/11/21010
	//+cnwml2 PAR25328
	//if self.myTI &lt;&gt; self.cmbTrackedItem.listObject.CM_TrackedItem then
		//self.allPackedItems.clear();
		//self.allUnpackedItems.clear();
	//endif;
	*/
	
/*	if self.cmbCargoType.listObject = null then		// #27213 29/03/2011. when cargo type is deleted, trackedItem wull be deleted, too. I.e. self.myTI = null.
		tiSelected := null;
		self.cmbTrackedItem.listObject := null;
		self.cmbrackedItem.text := null;
	endif;*/
	
	self.doComboTrackedItemLostFocus(combobox);
	
epilog
	self.myTI := tiSelected;	//#26401 29/11/2010
	
end;</source>
