    <JadeMethod name="actionWOGrouping" id="08f2ddad-1912-4042-a5a0-0cc6ade88fa7">
        <updating/>
        <source>actionWOGrouping(_voyage 		: CM_Voyage;
				 _woSet			: CM_WorkOrderDtlSet io;
				 _dynaDict		: DynaDictionary io;
				 _workorderDtl  : CM_WorkOrderDtl)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2023	navma1 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
06 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	grpCriteria		: Integer;
	propName		: String;
begin
	
	_dynaDict.setMembership(CM_TrackedItem);  
	
	
	foreach  grpCriteria in self.allGroupingCriteria do
		propName    := self.getPropertyNameForGrpCriteria(grpCriteria,_workorderDtl);	//06.05.2024 navhl20 #63971
		
		_dynaDict.addMemberKey(propName, false, true);
	
	endforeach;
	
	_dynaDict.endKeys(true);
	
	_voyage.allOnshipTIsByCargoTypeId.tryCopy(_dynaDict);
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_woSet" type="CM_WorkOrderDtlSet" usage="io"/>
        <Parameter name="_dynaDict" type="DynaDictionary" usage="io"/>
        <Parameter name="_workorderDtl" type="CM_WorkOrderDtl"/>
    </JadeMethod>
