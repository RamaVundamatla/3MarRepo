    <JadeMethod name="getMyCarrier" id="fc51b72b-3640-4922-8065-1a825e232dda">
        <source>getMyCarrier():CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_Carrier;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myCarrier;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
