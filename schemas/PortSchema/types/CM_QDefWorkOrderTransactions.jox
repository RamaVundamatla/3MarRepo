	//qProp.allocationAttribute := YACriteriaType_ImexStatus;
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStrConsignMethod persistent;
	qProp.CM_QStrConsignMethod.setType(CONSIGNEE);
	qProp.set('Cargo Consignee', CM_WOTransaction::getCargoConsignees.name, self.className);
	//qProp.allocationAttribute := YACriteriaType_Consignee;
