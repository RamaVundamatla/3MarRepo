    <JadeMethod name="translateForm" id="d2aa5581-5f4f-4c36-869b-b5bf6c9897ed">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 June 2025 09:48:32.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0027090, locale);
	btnCancel.translateCaption(Xlat_0027091, locale);
	btnSave.translateCaption(Xlat_0027092, locale);
	lblCurrentStatus.translateCaption(Xlat_0027093, locale);
	lblNewStatus.translateCaption(Xlat_0027094, locale);
end;</source>
    </JadeMethod>
