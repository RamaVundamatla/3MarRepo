    <JadeMethod name="initializeForActivity" id="450cafab-79a0-4921-9550-f70a16c5a8ce">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
03 December 2021	navab1	TFS 51853
*/

vars
	terminal : CM_Terminal;
	
begin
	inheritMethod(_any, _ewsOpsView);

	self.tableName          := self.Argo_yard;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then 
		self.gkey           	:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	terminal := _any.CM_Terminal; // ### TFS 53369 03MAY2022 NAVAB1
	terminal.initializeForActivity(_ewsOpsView,self);  // ### TFS 53369 03MAY2022 NAVAB1
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
