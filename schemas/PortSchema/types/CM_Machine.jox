    <JadeMethod name="checkAndResetStatus" id="f80874a6-6ce9-455e-a030-d6baf359be6d">
        <updating/>
        <source>checkAndResetStatus() updating;
// -------------------------------------------
// Created 02 June 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	
	//epr par 33706
	if self.status = null then
		self.setMachineStatus(STATUS_IDLE, "", false);
		return;
	endif;
	
	
	if self.status.status &lt;&gt; STATUS_IDLE then
		if self.status.status = STATUS_OFFLINE then
			self.setMachineStatus(STATUS_RESTORE, "", false);
		else
			self.setMachineStatus(STATUS_IDLE, "", false);
		endif;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="checkCanJoinQueue" id="744c9e4a-f77b-48fb-85a9-56f4a9d3344f">
        <source>checkCanJoinQueue();
//Can we be added to a Queue?
begin

	if not self.hasRadioTelemetry then
		//-------------
		//If NO R/T, then quit.
		//-------------
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_MACH_NO_RT, id, null, null);
		return;
	endif;
	
	if self.isNotAvailableForEntry then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(NotAvailableForEntry, app.getErrorString(Machine) &amp; ' (' &amp; self.id &amp; ') ', null, null);
		return;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkCanRemoveFromQueue" id="c63fc109-9c78-444c-8712-3a197ccdc23d">
        <source>checkCanRemoveFromQueue(_queue : CM_RadioTelemetryQueue) : Boolean;
//Does work so machine can release from queue
begin
	//--------------
	//Is machine busy?
	//--------------

	if status = null then
		return true;
	endif;
	if status.status &lt;&gt; STATUS_IDLE and self.currentQueueTask &lt;&gt; null then
		//--------------------
		// If machine is on set down task, then let em move.
		//--------------------
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkMachineCoverage" id="6d991cb0-cf94-460b-99fb-2f0a5d12cd08">
        <source>checkMachineCoverage(_queue : CM_RadioTelemetryQueue) ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwer1	Initial creation

*/

vars

begin
	if _queue = null then
		return;
	endif;
	if  self.isTransient and
			(self.machineType &lt;&gt; MACHINETYPE_RTG and
								self.machineType &lt;&gt; MACHINETYPE_RMG) then
		return;
	endif;
	
	_queue.updateMachineCoverage();
epilog

end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="checkTwinCarryTwoTasks" id="d5f9a5cc-46e9-4155-b56b-0741bb2120c4">
        <source>checkTwinCarryTwoTasks(_firstPickupTask ,
						_secondPickupTask :CM_RTQueueTask;
						_raiseException : Boolean;
						_errorString : String io) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwer1	Initial creation

*/

vars
	loc1,loc2 : CM_LocationsController;
	isPrior,
	isNext     : Boolean; //whether the first task loc is prior to the next or after if both false not even next to each other
	theTotalWeight : Decimal [12,0];
	twinWeightDiff,
	direction	: Integer;
	reasonString : String;
	firstTI,
	secondTI	: CM_TrackedItem;
begin
	firstTI:=_firstPickupTask.ti;
	secondTI:=_secondPickupTask.ti;
	
	if  firstTI &lt;&gt; null  and secondTI &lt;&gt; null  then
		if firstTI.myCargoType.isCheckMaxLift then
			theTotalWeight:=firstTI.totalWeight + secondTI.totalWeight;
			if theTotalWeight &gt; self.maxLiftWeight then
				if _raiseException then
					app.raiseCMException5(MACH_MAX_LIFT_WEIGHT_TWIN,self.id.trimRight,self.maxLiftWeight.asStringWeightJMT,firstTI.id,secondTI.id ,theTotalWeight.asStringWeightJMT(),null,null); 
				endif;
				return false;  		
			endif;
		endif;
		//trackeditem could be null if it is a director task
		if self.weightDifference &lt;&gt; null  then
			//twinWeightDiff:=(_firstPickupTask.ti.weight - _secondPickupTask.ti.weight).abs.Integer;					//-cnwml2 MSL CCMS 1017
			twinWeightDiff := (firstTI.totalWeight - secondTI.totalWeight).abs.Integer;			//+cnwml2 MSL CCMS 1017
			if twinWeightDiff &gt;  self.weightDifference then
				if  _raiseException then
				
					app.raiseCMException1(ERR_MACH_MAX_TWIN_WEIGHT, self.id, null, null);	
				endif;
				return false;
			endif;
		endif;
		
		//imvs don't care if the container is overstowed because the RTG will sort that out
		if  self.machineType &lt;&gt; MACHINETYPE_IMV  then
			if firstTI.isOverStowed(REAL_MODE) then 
				if  _raiseException then
					app.raiseCMException3(ERR_TWIN_LIFT_OVERSTOW,firstTI.id,secondTI.id,firstTI.id,null, null);	
				endif;
				return false;
			elseif secondTI.isOverStowed(REAL_MODE) then
				if  _raiseException then
					app.raiseCMException3(ERR_TWIN_LIFT_OVERSTOW,firstTI.id,secondTI.id,secondTI.id,null,null);	
				endif;
				return false;
			endif;
		endif;
	endif;
	//this is checking the source locations 
	/*	epr par 20701 3/11/09
		for imv machines it is a twin carry the source boxes can be put on seperately at 2 different locations so can ignore for IMVS
		still have to check the target location
	*/
	if self.machineType = MACHINETYPE_IMV then
		loc1:=_firstPickupTask.targetLocation;
		loc2:=_secondPickupTask.targetLocation;
	else
		loc1:=_firstPickupTask.sourceLocation;
		loc2:=_secondPickupTask.sourceLocation;
	endif;
	
	if loc1.isKindOf(CM_GridController) then
		isPrior:=loc1.CM_GridController.myNextController = loc2;
		isNext:=loc1.CM_GridController.myPreviousController = loc2;
		if (not isPrior) and  (not isNext) then
			//do a default check can be a gridded loc that behaves like a block stack i.e. a buffer yard interchange area 
			
			return loc1.canTwinLiftWithLocation(loc2,firstTI,secondTI,REAL_MODE,direction,_errorString);
		endif;
	else
		isPrior :=true;
	endif;
	
	
	if isPrior then
		if loc1 &lt;&gt; null then
			return loc1.canTwinLiftWithLocation(loc2,firstTI,secondTI,REAL_MODE,direction,_errorString);
		else
			//hack
			_errorString:="not null";
			return false;
		endif;
	elseif isNext then
		if loc2 &lt;&gt; null then
			return loc2.canTwinLiftWithLocation(loc1,secondTI,firstTI,REAL_MODE,direction,_errorString);
		else
			//hack
			_errorString:="not null";
			return false;
		endif;
	endif;
	
	
	
	
	return true;
	

epilog

end;</source>
        <Parameter name="_firstPickupTask" type="CM_RTQueueTask"/>
        <Parameter name="_secondPickupTask" type="CM_RTQueueTask"/>
        <Parameter name="_raiseException" type="Boolean"/>
        <Parameter name="_errorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkWorkzonePhysicalEnd" id="9fc3cb01-b569-4602-b284-f475cd4a414f">
        <source>checkWorkzonePhysicalEnd() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
	startCol,endCol : CM_RTGColumn;
	taMaster  		: CM_TerminalAreaMaster;
	toRemove	: ObjectSet;
	obj			: Object;
	rtgLane		: CM_RTGLane;
	ta 			: CM_TerminalArea;
	taIter		: Iterator;
	result		: Boolean;
begin
	if self.myPhysicalStartBay = null or
		self.myPhysicalEndBay = null then
		return false;
	endif;

	create toRemove transient;
	self.getWorkzoneStartEndColumns(startCol,endCol,taMaster);
	
	
		
	if self.myPhysicalEndBay.myGridArea = endCol.myGridArea then	
		//check the physical start bay isn't after the start of the workzone
		if endCol.myGridArea.allGridColumns.indexOf(self.myPhysicalEndBay) &lt; endCol.myGridArea.allGridColumns.indexOf(endCol) then
			self.getWorkzoneLocsFromColumn(endCol.myGridArea,self.myPhysicalEndBay,toRemove);
		endif;
	else
		//get the rtgLane 
		rtgLane:=self.myPhysicalEndBay.myGridArea.allTerminalAreaGroups.first.CM_RTGLane;
		if rtgLane &lt;&gt; null then
			if rtgLane.allTAsByTypeId.indexOf(self.myPhysicalEndBay.myGridArea) &lt; rtgLane.allTAsByTypeId.indexOf(endCol.myGridArea) then
				delete taIter;
				taIter:=rtgLane.allTAsByTypeId.createIterator;
				while taIter.back(ta) do
					self.getWorkzoneLocsUpToColumn(ta,self.myPhysicalEndBay,toRemove);
					
					if self.myPhysicalEndBay.myGridArea = ta then
						break;
					endif;
				endwhile;
			endif;
		endif;
	endif;
	
	
	foreach obj in toRemove do
		if 	self.allWorkzoneLocations.includes(obj.CM_GridController) then
			result:=true;
			self.allWorkzoneLocations.remove(obj.CM_GridController);
		endif;
	endforeach;
	
	return result;
epilog
	delete toRemove;
	delete taIter;
end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkWorkzonePhysicalStart" id="37ded129-273c-4fa9-9b13-41a42bc0b6dd">
        <source>checkWorkzonePhysicalStart() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
	startCol,endCol : CM_RTGColumn;
	taMaster  		: CM_TerminalAreaMaster;
	toRemove	: ObjectSet;
	obj			: Object;
	rtgLane		: CM_RTGLane;
	ta 			: CM_TerminalArea;
	taIter		: Iterator;
	result : Boolean;
begin
	create toRemove transient;
	self.getWorkzoneStartEndColumns(startCol,endCol,taMaster);
	
	if startCol = null or 
		endCol = null then
		return false;
	endif;
	
	if self.myPhysicalStartBay = null or
		self.myPhysicalEndBay = null then
		
		return false;
	endif;
		
	if self.myPhysicalStartBay.myGridArea = startCol.myGridArea then	
		//check the physical start bay isn't after the start of the workzone
		if startCol.myGridArea.allGridColumns.indexOf(self.myPhysicalStartBay) &gt; startCol.myGridArea.allGridColumns.indexOf(startCol) then
			self.getWorkzoneLocsUpToColumn(startCol.myGridArea,self.myPhysicalStartBay,toRemove);
		endif;
	else
		//get the rtgLane 
		rtgLane:=self.myPhysicalStartBay.myGridArea.allTerminalAreaGroups.first.CM_RTGLane;
		if rtgLane &lt;&gt; null then
			if rtgLane.allTAsByTypeId.indexOf(self.myPhysicalStartBay.myGridArea) &gt; rtgLane.allTAsByTypeId.indexOf(startCol.myGridArea) then
				delete taIter;
				taIter:=rtgLane.allTAsByTypeId.createIterator;
				while taIter.next(ta) do
					self.getWorkzoneLocsUpToColumn(ta,self.myPhysicalStartBay,toRemove);
					
					if self.myPhysicalStartBay.myGridArea = ta then
						break;
					endif;
				endwhile;
			endif;
		endif;
	endif;
	
	
	foreach obj in toRemove do
		if 	self.allWorkzoneLocations.includes(obj.CM_GridController) then
			result:=true;
			self.allWorkzoneLocations.remove(obj.CM_GridController);
		endif;
	endforeach;
	
	return result;
epilog
	delete toRemove;
	delete taIter;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkWorkzoneTerminalArea" id="1bbf3f96-63d7-4fe5-968e-01053e88a791">
        <source>checkWorkzoneTerminalArea() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
taMaster  		: CM_TerminalAreaMaster;
	taIter,
	wzIter		: Iterator;
	toRemove	: ObjectSet;
	obj			: Object;
	gridController : CM_GridController;
	result		: Boolean;
begin
	if self.allWorkzoneLocations.size = 0 then
		return false; 
	endif;
	create toRemove transient;
	self.allWorkzoneLocations.copy(toRemove);
	
	taIter:=self.allowedTAMasters.createIterator;
	wzIter:=self.allWorkzoneLocations.createIterator;
	while taIter.next(taMaster) do
		if not taMaster.isKindOf(CM_TerminalArea) then
			continue;
		endif;
		wzIter.reset;
		self.allWorkzoneLocations.startKeyGeq(taMaster.CM_TerminalArea,null,null,wzIter);
		while wzIter.next(gridController) do
			if gridController.getMyGridArea &lt;&gt; taMaster then
				break;
			endif;
			toRemove.remove(gridController);
		endwhile;
	endwhile;
	
	foreach obj in toRemove do
		if 	self.allWorkzoneLocations.includes(obj.CM_GridController) then
			result :=true;
			self.allWorkzoneLocations.remove(obj.CM_GridController);
		endif;
	endforeach;

	return result;
epilog
	delete toRemove;
	delete taIter;
	delete wzIter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkWorkzoneUpdates" id="e3e7cac1-617d-48d2-aa5c-673ba002f2cc">
        <source>checkWorkzoneUpdates();
/*

Purpose:	//if the ta access has updated or the physical limits have updated then will need to change the workzones		

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
	hasChanged : Boolean;
begin
	
	if self.allWorkzoneLocations.isEmpty then
		return;
	endif;
	
	hasChanged:=self.checkWorkzoneTerminalArea();
	
	hasChanged:=hasChanged or self.checkWorkzonePhysicalStart();
	
	hasChanged:=hasChanged or self.checkWorkzonePhysicalEnd();
	
	if hasChanged then
		self.checkMachineCoverage(self.myPrimaryQueue);
		//cnwjo3 par 24124.  If workzones have changed we should fire notification
		self.causeEvent(self.myTerminal.getTerminalEvent(Event_Mach_Workzone_Update),false,self);
	endif;
	
epilog

	
end;</source>
    </JadeMethod>
    <JadeMethod name="cleanupRejectedTasks" id="f77f43fd-70bb-46b0-872b-8020141858b2">
        <updating/>
        <source>cleanupRejectedTasks(_rtQueueTaskArray : CM_RTQueueTaskArray) updating;
//Goes looking for tasks that are deleted under us, and removes them from
//the array.
vars

	rtQueueTask : CM_RTQueueTask;

begin

	foreach rtQueueTask in _rtQueueTaskArray do
		if self.rejectedRTQueueTasks.includes(rtQueueTask) then
			self.rejectedRTQueueTasks.remove(rtQueueTask);
			app.myEventManager.createSingleObjInfoNoteEvt(rtQueueTask.queue , self.myTerminal.getTerminalEvent(Event_Update_Queue_Entry), rtQueueTask.myEntry );
		endif;	
	endforeach;	

end;</source>
        <Parameter name="_rtQueueTaskArray" type="CM_RTQueueTaskArray"/>
    </JadeMethod>
    <JadeMethod name="clearWebsession" id="6f662b17-a85b-4fc9-b317-8e6ad4107e9f">
        <source>clearWebsession() protected;
/*

Purpose:			Remove any 'old' web sessions after a machine is 'reset to login'

Parameters:			

Return Value:		

Date			Who		Reason
16 August 2021	navmd1	Initial creation TFS 51226

*/

vars
	schema		: Schema;
	class		: Class;
	obj			: Object;
	machine		: CM_Machine;
	n			: Node;
	proc		: Process;
	sessionId	: String;
begin
	schema := currentSchema.getSchema(WebServicesSchemaName);	// This only works because WebServicesSchema is a subclass of UICommon!
	if schema &lt;&gt; null then
		class := schema.getClass("SWebServiceSchema");
		if class = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "WebServiceSchema not found, unable to clear web sessions");
			return;
		endif;
		
		foreach obj in class.instances do
			machine := obj.getPropertyValue("myCurrentMachine").CM_Machine;
			if machine = self then
				// I'd much rather be using WebSession.removeSession() here, but that doesn't work outside Jades 'WebService' framework
				sessionId := obj.getPropertyValue('_encryptedSessionId').String;
				app.writeLog(app.myPassport.myUser.code &amp; " is forcing off Old Web Session " &amp; sessionId, LogWARN);
				delete obj;
			endif;
		endforeach;
		
		// Clear the machine "user" from any web processes
		foreach n in system.nodes do
			foreach proc in n.processes do
				if proc.persistentApp.name = JMTWebService then
					if proc.userCode = self.code then
						app.writeLog(method.qualifiedName &amp; " Resetting process (" &amp; self.cnGetInstanceId(proc).String &amp; ") usercode to default", LogTRACE);
						proc.changeUserCode(proc.signOnUserCode);
					endif;
				endif;
			endforeach;
		endforeach;
	
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearWorkzone" id="42fbaff0-0305-40c2-ad9c-b61b58ab03d0">
        <source>clearWorkzone();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwer1	Initial creation

*/

vars

begin
	self.allWorkzoneLocations.clear;
	
	if self.myTerminal &lt;&gt; null then
		self.causeEvent(self.myTerminal.getTerminalEvent(Event_Mach_Workzone_Update),false,self);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcGetDuplicate" id="4ebd240e-69c6-486f-8126-42f6c2e88305">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2014	cnwndl1	Initial creation

*/

vars

	oidTable : CnEcOidTable;
	id : String;
	machine : CM_Machine;
	terminalOid : String;
	xmlObj : CnEcXmlStructureInstance;
	xmlObj2 : CnEcXmlStructureInstance;
	currentOidValue : String;
	obj : Object;
	termObj : CM_Terminal;

begin

	id := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "id" ).String;
	
	if id &lt;&gt; null then
		xmlObj	:=	pInput.findStructure("myTerminal");
		if xmlObj &lt;&gt; null then
			xmlObj2	:=	xmlObj.findStructure("OID");
			if xmlObj2 &lt;&gt; null then
				terminalOid := xmlObj2.tagData;
				if terminalOid &lt;&gt; null then
					//grubby, grubby, but should be OK if Hubble being used correctly.
					if not CnEcOidTable.instances.isEmpty then
						oidTable := CnEcOidTable.lastInstance;
					endif;
					if oidTable &lt;&gt; null then
						obj := oidTable.getObject(terminalOid);
					endif;
					if obj &lt;&gt; null and obj.isKindOf(CM_Terminal) then
						termObj := obj.CM_Terminal; 
					endif;
				endif;
			endif;
		endif;
		
		if termObj &lt;&gt; null then
			machine := termObj.machines.getAtKey( id );
		endif;
	
	endif;
	
	
	
epilog

	return machine;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="currentQueueTask" id="b38c05f5-de80-44a6-846f-a2215e0b6219">
        <methodInvocation>mapping</methodInvocation>
        <source>currentQueueTask(set : Boolean; _value : CM_RTQueueTask io) mapping;
// ---------------------------------------------------------------------------
// Created:		03 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	qTask : CM_RTQueueTask;
begin
	if set then
		return;
	endif;
	
	foreach qTask in self.allCurrentQueueTasks discreteLock do
		if qTask.status = TASK_ACCEPTED then
			_value:=qTask;
			return;
		endif;
		
	endforeach;
	_value := self.allCurrentQueueTasks.first;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_RTQueueTask" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deQueue" id="8b256d2b-66eb-439c-892b-e3de4dbf178c">
        <updating/>
        <source>deQueue() updating;
//Rewritten for PAR 3692 10/9/00 AJA
//This removes the machine from all primary and secondary queues
//Note that it is unconditional: check the machine is not logged on first
//It is also non-negotiable, so we do not raise any exceptions in this code.
vars
	q : CM_RadioTelemetryQueue;
begin
	exclusiveLock(self);

	self.myPrimaryQueue := null;
	self.allQueues.clear;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="4745ca87-f27e-46e4-a3f9-3d3d3955e5e7">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2021	jlgndl1	Initial creation

*/

vars
	
begin
	
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelayedMoveToQueue" id="4021de6d-533a-4d13-be27-3d72af33fdfc">
        <updating/>
        <source>doDelayedMoveToQueue() updating;
// -------------------------------------------
// Created 04 July 2005 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
20 Apr 2009	cnwkpd1	PAR #19405 - Change to preserve next queue reference
					if the machine is not yet ready to be released from
					its primary queue
11 Jun 2009	cnwkpd1	PAR #19844 - Handle possible null myPrimaryQueue

*/

vars
	terminal 		: CM_Terminal;

begin

	if self.myNextPrimaryQueue = null then
		return;
	endif;

	// PAR #19405 - If we're not ready to be released, then do nothing
	if self.myPrimaryQueue &lt;&gt; null and not self.myPrimaryQueue.releaseMachine(self) then		// PAR #19844
		return;
	endif;
	
	self.addToQueue(self.myNextPrimaryQueue, true, 0);
	self.myNextPrimaryQueue := null;

	self.causeEvent(EVENT_MACHQUEUE_ALTERED, false, null);
	terminal := self.myTerminal;
	if terminal &lt;&gt; null then
		self.causeEvent(terminal.getTerminalEvent(RTMachine_Update_Event), false, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="cbc1ba40-3a57-47ec-b943-8ecc971f2e05">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//Nuke the mchine.
//21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
vars
	iter   : Iterator;
	cmqfCK : CMQF_CraneKPI;
begin
	exclusiveLock(self);
	//----------------
	//Remove ourselves from the Queue
	//----------------
	self.deQueue();

	//-------------
	//Nuke the status object
	//-------------
	if self.status &lt;&gt; null then
		delete self.status;
	endif;
	
	//21/09/2020 cnwma1 TFS #49906
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
									 BGP_OpsViewWSRequest.OPS_TYPE_MACHINE,
									 self);

	endif;
	//21/09/2020 cnwma1 TFS #49906
	
	self.myTerminal := null;
	self.myOwner    := null;			//15 May 2018	NDL	TFS 38570

	iter := CMQF_CraneKPI.instances.createIterator;
	while iter.next(cmqfCK) do
		if cmqfCK.allCranes.includes(self) then
			cmqfCK.allCranes.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	inheritMethod(_eraseLevel);

epilog
	delete iter;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="executeAcceptTasks" id="321295ad-13e2-45e2-bb8d-38e538122eb3">
        <updating/>
        <source>executeAcceptTasks(_mediator: CM_RTConnectMediator input) updating;
//Machine is indicating it wishes to proceed with currentQueueTask(s)
/*

Date		Who		Reason
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed method, changed to process all tasks
29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	thisTask,
	task : CM_RTQueueTask;
	
begin
	exclusiveLock(self);

	if self.currentQueueTask = null and _mediator &lt;&gt; null  then //epr TFS 995 17/5/17
		//an exception has destroyed the linkages. Rebuild.	
		_mediator.patchupTask();
	endif;
	if self.currentQueueTask = null then
		app.raiseCMException1(ERR_NO_OBJECT, "Accept Task - Machine has no currentQueueTask.", null, null);
		return;
	endif;


	
	//epr par 25917 1/10/10
	if self.machineStatus = STATUS_IDLE then
		self.setMachineStatus(STATUS_ASSIGNED  , "", false);
	endif;
	
	// PAR #18743 - process all tasks
	foreach thisTask in self.allCurrentQueueTasks do
		thisTask.setStatus(TASK_ACCEPTED);
		if thisTask.ti &lt;&gt; null then
			//Cause an update on the TI
			self.updateObjectEdition(thisTask.ti);	// par 30292
		endif;
	endforeach;
	

epilog
		
end;</source>
        <Parameter name="_mediator" type="CM_RTConnectMediator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executeGetNextTask" id="01d758ab-9254-4223-be17-300794f9be65">
        <updating/>
        <source>executeGetNextTask(_lookForTwinTask : Boolean ) : CM_RTQueueTask updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
10 May 2017	cnwer1	TFS 995 	Initial creation moved code block from executeGetTasks
25 Jul 2019	jlgka1 	TFS	45711 	MSL - IMV after GET NEXT not visible on the machine tablet (web app)
============================================================================*/

vars
	isAllocatedTask : Boolean;
	task  			: CM_RTQueueTask;
	messageLogger	: CM_MachineRTQueueEntryLogger;
	rtQ				: CM_RadioTelemetryQueue;
	errorCodes 		: IntegerArray;
	alertStr1,
 	alertStr2		: String;
	int 			: Integer;
	twinTask		: CM_RTQueueTask;
	twinEntry		: CM_RTQueueEntry;
	aMsg			: String;
	entry			: CM_RTQueueEntry; 	//jlgka1 TFS 45711
	job				: CM_Job;			//jlgka1 TFS 45711
	eachEntry		: CM_RTQueueEntry;	//jlgka1 TFS 45711
	eachTask		: CM_RTQueueTask;	//jlgka1 TFS 45711
begin
	exclusiveLock(self);
	
	create messageLogger transient;
	messageLogger.myMachine:=self;
	
	if self.myNextPrimaryQueue &lt;&gt; null then
 		self.doDelayedMoveToQueue();
	endif;
	//The system has decided to log a search, this is set 
	//automatically by not finding a task last time.
	//------------------
	if self.logSearchNoTask then
 		self.logSearch := true;
	endif;

	if self.myPrimaryQueue = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_MACH_NO_QUEUE, self.id.trimBlanks, null, null);
		return null;
	endif;
	//---------------
	//Clear out the ref.
	//---------------
	self.workingInQueue := null;
	//----------------
	//Make sure the queue is running
	//----------------
	if self.myPrimaryQueue.status &lt;&gt; QSTATUS_RUNNING then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_QUEUE_HELD, self.myPrimaryQueue.id.trimRight, null, null);
		return null;
	endif;

	if self.currentQueueTask &lt;&gt; null then
		self.fixupCompleteCurrentTask();
	endif;
	//----------------
	//Re-test the current Queue task status
	//----------------
	if self.currentQueueTask &lt;&gt; null and not self.isMultiLift then //epr CCMS 1391 warehouse VMT app
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_MACH_BUSY, self.id.trimBlanks, currentQueueTask.myEntry.id, null, null);
		return null;
	endif;
	//----------------
	//We dont have a task, make sure our status is valid here
	//----------------
	self.checkAndResetStatus();
	if not self.loggedOn then
		app.raiseCMException(ERR_MS_NOT_LOGGED_ON, null, null);
		return null;
	endif;

	if self.logSearch = true then
		self.addLogEntry("Machine Id " &amp; id.trimRight &amp; " logging display for locating the next available task");
	endif;
	//----------------
	//Are we scheduled to do the next forced task??, (by control...)
	//----------------

	if self.hasAllocatedQueueTasks then
		isAllocatedTask := true;
		task :=  self.allAllocatedQueueTasks.first;
		exclusiveLock(task);
		//--------------------
		//Test that the task is STILL UNACTIONED (someone else may have grabbed it!)
		//--------------------
		//if task.status &lt;&gt; TASK_UNACTIONED and task.status &lt;&gt; TASK_ALLOCATED and task.machine &lt;&gt; self then
		if task.status &lt;&gt; TASK_ALLOCATED then
			if task.machine &lt;&gt; self then
				self.addLogEntry("Machine Id " &amp; id.trimRight &amp; " next allocated task is already complete!");
			else
				self.addLogEntry("Machine Id " &amp; id.trimRight &amp; "allocated task is not allocate any more!");
			endif;
			//------------------
			//Clear out the reference
			//------------------
			task.intendedMachine := null;
			if isLockedByMe(task) then
				unlock(task);
			endif;
		endif;
	else

		self.myPrimaryQueue.getATaskForMachine(task, self, messageLogger);
		if task &lt;&gt; null then
			self.workingInQueue := self.myPrimaryQueue;
		else
			//------------------
			//Secondary queues exist, ask each one.
			//------------------

			foreach rtQ in self.allQueues discreteLock do
				rtQ.getATaskForMachine(task, self, messageLogger);
				if task &lt;&gt; null then
					self.workingInQueue := rtQ;
					break;
				endif;
			endforeach;
		endif;
	endif;

	if task = null then
		
		// Basically we have to store up reasons for not selecting tasks and
		// display them if we can't find a task rather than just say no tasks.
		// Can't use exceptions or warnings as these would halt the commit using our 
		// standard exception handlers.
		// The alertsArray is only created if needed.
		//self.logSearch and 
		if 	messageLogger.allMessages.size &gt; null then
			create errorCodes transient;	//14 Sep 2012	NDL	Par 30366
			foreach alertStr1 in messageLogger.allMessages do
				if alertStr2 = null then
					alertStr2 := alertStr1;
				else
					alertStr2 := alertStr2 &amp; CrLf &amp; alertStr1;
				endif;
			endforeach;
			if alertStr2 &lt;&gt; null then
				//app.raiseCMException1(Machine_Logger_Errors, alertStr2, null, null);
				
				//13 Sep 2012	NDL	Par 30366
				errorCodes.add(Machine_Logger_Errors);
				foreach int in messageLogger.allErrorCodesUsed do
					errorCodes.add(int);
				endforeach;
				
				app.raiseMultiReasonExcOrWarning( errorCodes, alertStr2, false, null,  null );
				
				return null;
			endif;
		endif;
		app.raiseCMException(No_Tasks, null, null);
		return null;
	endif;
	
	// PAR #18743 - If the machine is a twin Lift, the mediator has been set up as
	// allowing twin tasks (must be running in Voice interface), and the task has a twinnable Queue Entry,
	// then get its task for us.  This must be done before the primary task is assigned, otherwise
	// the "machine busy" error will prevent it being found
	if _lookForTwinTask and self.isTwinLift then
		twinEntry := task.myEntry.getTwinnableEntry();
		
		// There is a possible twinnable entry
		if twinEntry &lt;&gt; null then
			// Check it's not locked by someone else
			if tryLock(twinEntry, Reserve_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			
				// PAR #28383 - If the primary task was an Allocated one, and its twinnable entry
				// is currently Held, then restore the twinnable entry's status to allow it to
				// be assigned as a twin to this Machine
				if isAllocatedTask and twinEntry.status = ENTRY_USER_HELD then
					twinEntry.restoreTaskStatuses();
				endif;
				
				// Get the task for this machine
				twinEntry.getATaskForMachine(twinTask, self,null,null, messageLogger);
				
				//cnwrd1 32293
				if not self.canBeAllocatedMixedTasks and twinTask &lt;&gt; null and task.taskType &lt;&gt; twinTask.taskType then
					//tasks of different type we cant process them in this configuration
					twinTask := null;
				endif;
			endif;
		endif;
	endif;
	
	//---------------
	//We have the task. Tell it to hookup to the machine
	//---------------
	task.setMachine(self);
	if isAllocatedTask then	
		//---------------
		//deref the allocated task, we are all linked properly now...
		//---------------
		task.intendedMachine := null;
	endif;
	//-------------
	//Update the history
	//-------------
	
	//epr par 25873 29/9/10
	if self.machineStatus = STATUS_IDLE then
		self.setMachineStatus(STATUS_ASSIGNED , "", false);
	endif;
	if isAllocatedTask then
		//---------------
		//They GET NO CHOICE, its do this, or NOTHING!
		//---------------
		task.setStatus(TASK_ACCEPTED);
	else
		task.setStatus(TASK_OFFERED);
	endif;

	// PAR #18743 - If we have found a twin task, then attach it to the machine as well
	if twinTask &lt;&gt; null then
		//epr CCMS HAT 2200 par 30678 found should check twin task weight etc before offering
		if self.checkTwinCarryTwoTasks(task,twinTask,false,aMsg) then
			twinTask.setMachine(self);
			twinTask.setStatus(TASK_OFFERED);
			
			// If the primary task was allocated to this machine, then we need to auto-accept the 
			// twin task as well
			if isAllocatedTask then	
				twinTask.intendedMachine := null;
				twinTask.setStatus(TASK_ACCEPTED);
			endif;
		endif;
	endif;		
	//jlgka1 TFS 45711 --&gt;
	task.updateObjectEdition(self);
	entry := task.myEntry;
	job   := entry.myJob;	
	foreach eachEntry in job.allEntries do
		eachEntry.updateObjectEdition(eachEntry);
		foreach eachTask in eachEntry.allTasks do
			eachTask.updateObjectEdition(eachTask);
		endforeach;
	endforeach;	
	//jlgka1 TFS 45711 &lt;--
	
	return  task;
		
epilog

	delete messageLogger;
	delete errorCodes;	//14 Sep 2012	NDL	Par 30366

	if isLockedByMe(self) then
		unlock(self);
	endif;

end;</source>
        <Parameter name="_lookForTwinTask" type="Boolean"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="executeGetTasks" id="3aa89d3f-2088-4b39-9f07-28eb92086cf0">
        <updating/>
        <source>executeGetTasks(_mediator: CM_RTConnectMediator input;
				_lookForTwinTask : Boolean) : Integer updating;

/*

Purpose:			Get the next available task(s) for the receiver machine

Parameters:			RT mediator
					Whether to look for a twinnable task or not

Return Value:		Integer value depending on whether the task found was allocated or not


Date		Who		Reason
12 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed method
08 Jul 2009	cnwkpd1	PAR #20230 - Added lookForTwinTask parameter to allow this to be defeated 
					during Director task processing
18 Oct 2011	cnwkpd1	PAR #28383 - CCMS 2030 - Added functionality to allow held twin tasks to be 
					allocated to a machine, by allocating the first of a pair of Held twinnable tasks
					
*/

vars
	task			: CM_RTQueueTask;
begin
	exclusiveLock(self);
	_mediator.task := null;	//This added! DQ 10/dec 2003
	//------------------
	
	//epr TFS 995 refactored code block into method that doesn't need mediator
	task:=self.executeGetNextTask(_lookForTwinTask and self.isTwinLift and _mediator.canBeAllocatedTwinTasks);
	_mediator.task := task;
	if task &lt;&gt; null then
		if task.status = TASK_ACCEPTED then
			return 1;
		elseif task.status = TASK_OFFERED then
			return 2;
		endif;
	endif;
	return 0;
		
epilog

	if isLockedByMe(self) then
		unlock(self);
	endif;
end;</source>
        <Parameter name="_mediator" type="CM_RTConnectMediator" usage="input"/>
        <Parameter name="_lookForTwinTask" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="executeLogoff" id="ebf47586-0c19-4826-bf06-147a6b5cce6a">
        <updating/>
        <source>executeLogoff() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
19 March 2007	cnwer1	CCMS 1032 - refactored - got rid of mediator parameter that was never referenced

*/


vars

	theStatus : Integer;

begin

	// Do it regardless please.
	//if self.machineStatus = STATUS_OFFLINE then
//		return;
//	endif;
	
	exclusiveLock(self);
	
	// must do before user is nulled out
	self.addLogOffToHistory();

	self.workingInQueue := null;
	//epr par 14210 3/7/08 by setting this it sets machineStatus to OFFLINE however we want to do it in setMachineStatus to send the note
	//loggedOn := false; 
	user := null;
	
	if not self.hasRadioTelemetry then	//06 Apr 2016	NDL	TFS 1667
		// to allow for STW hand Held Staging
		loggedOn := false;
		return;
	endif;
	
	if self.machineStatus = STATUS_OFFLINE then
		return;
	endif;
	
	self.setMachineStatus(STATUS_OFFLINE , "", false);
epilog

	if isLockedByMe(self) then
		unlock(self);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="executeLogon" id="4b162fae-a3c6-4c1b-b179-c5a811b0a31c">
        <updating/>
        <source>executeLogon(_user : CM_User) updating;


vars

begin
	//------------------
	//Every new logon, clear the rejected tasks
	//------------------
	exclusiveLock(self);
	if rejectedRTQueueTasks.size &gt; 0 then
		rejectedRTQueueTasks.clear;
	endif;
	if currentQueueTask &lt;&gt;  null then
		//Remove the machine
		currentQueueTask.removeMachine();		
	endif;
	self.setLoggedOn(true);
	if not self.hasRadioTelemetry then	//06 Apr 2016	NDL	TFS 1667
		// to allow use from Hand Held for STW
	else
		self.setMachineStatus(STATUS_IDLE, "", true);
	endif;
	user := _user;
	addLogOnToHistory();
epilog
	if isLockedByMe(self) then
		unlock(self);
	endif;
end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="executePickupSingleTask" id="2c5cc14a-2062-4a2a-9580-e77b4014022b">
        <updating/>
        <source>executePickupSingleTask(_task 			: CM_RTQueueTask input;
						_moveQuantity	: Integer;
						_moveWeight 	: Decimal;
						_tandemTI 		: CM_TrackedItem;
						_passport 		: CM_Passport input)updating;
/*

Date		Who		Reason
07 August 2014	cnwer1	Initial creation CCMS 1391 VMT for warehouse needed to be able to pickup single task
                         refactored this block out of the body of pickupTask which iterates through all the machines working tasks

*/

vars
	setdownTask,
	imvTask			: CM_RTQueueTask;	
	histEntry,
	imvHistory		: CM_MachineMoveHistory;	
	ti				: CM_TrackedItem;
	isOverStow		: Boolean;
	moveTransaction : CM_Move;
	sourceLocation  : CM_LocationsController;
	imvMachine 		: CM_Machine;
	wle 			: CM_WorkListEntry;
begin
	if _task = null then
		return;
	endif;
	
	if not _task.isPickUp then
		return;
	endif;
	
	exclusiveLock(_task);
	exclusiveLock(_task.myEntry);
	
	ti 			:= _task.ti;
	isOverStow 	:= _task.isOverstowTask;
	
	//epr par 35156 7/11/14
	if ti &lt;&gt; null then
		self.canMachineMoveBreakBulkWeight(ti,_moveQuantity,_moveWeight);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _task &lt;&gt; null and ti&lt;&gt; null then
		sourceLocation := ti.myPrimaryActualLocation;
		if sourceLocation.isKindOf(CM_MachineController) then
			imvMachine := sourceLocation.CM_MachineController.myMachine;
			if not imvMachine.isIMV then
				imvMachine:=null;
			endif;
		endif;	
	endif;
		
	app.myUtilityUA.utlAutoResequenceOnPickup(self,_task.myEntry,_passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	setdownTask := _task.getNextMachineTask(); //redo this here		
	if _task.isPlanOnPickupNoTarget and not isOverStow then//cnwrd1 par 26734 CCMS 2014 plan on pickup
		ti.autoPlanOnPickup( _task.myEntry.myWorkListEntry ,_passport);//need to autoplan this box NOW. This should autoplan and create setdown &amp; other tasks as needed
		setdownTask := _task.getNextMachineTask(); //redo this here			
		setdownTask.setStatusPending();
		setdownTask.setMachine(self);

	endif; 
	
	if not self.validatePickupTask(_task,setdownTask) then//cnwer1 5/2/08 refactored code block into below method // PAR 26948 - Moved to after resequence
		return;
	endif;
	//epr par 35702 15/3/15
	wle:= _task.myEntry.myWorkListEntry;
	if _task.isBreakBulkMove and wle &lt;&gt; null and wle.quantity = 0 and wle.weight = 0 then
		//epr par 35702 9/3/15
		if ti.myCargoType.isBreakBulkMulti then
			app.myUtilityUA.utlAmendBreakBulkRTQuantity(wle,_moveQuantity,_passport);
			
		elseif ti.myCargoType.isBulkMulti then
			app.myUtilityUA.utlAmendBulkRTWeight(wle,_moveWeight,_passport);
		endif;
		if _passport.hasErrors then
			return;
		endif;
	endif;
	
	histEntry 	:= self.addMoveToHistoryTask(_task);	
	self.setMyLastKnowLocation(_task.sourceLocation);	
	
	if _tandemTI = null then
		//moveTransaction	:= ti.moveToLocation(self.myMachineController, null, wle, self, REAL_MODE, false, true, isOverStow, true, true,   false, _moveQuantity,_moveWeight,_passport); //cnwrd1 ccms 2274 quantities
		moveTransaction	:= ti.moveToLocation(self.myMachineController, null, wle, self, REAL_MODE, false, true, isOverStow, true, true,   false, _moveQuantity,_moveWeight,null,null,null,_passport);		// TFS 2651
	else
		moveTransaction	:= ti.moveToLocationTandem(self.myMachineController, _tandemTI, null, wle, self, REAL_MODE, false, true, isOverStow, true, true,   app.myPassport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _task.isBreakBulkMove or (_task.ti.myCargoType.isBreakBulkMulti or _task.ti.myCargoType.isBulkMulti) then
			
		if _task.myEntry.myBreakBulkMaster &lt;&gt; null then
			if _task.myEntry.isBulkMove then
				//set weight and addToWeightMoved
				_task.myEntry.myBreakBulkMaster.addToWeightMoved(_moveWeight);
				_task.myEntry.setWeight(_moveWeight);
			else
				//should be not null..
				_task.myEntry.myBreakBulkMaster.addToTotalMoved( _moveQuantity);
				_task.myEntry.setQuantity(_moveQuantity);
			endif;
		endif;
		
		if  moveTransaction &lt;&gt; null and moveTransaction.myTrackedItem &lt;&gt; _task.ti then
			//we have split some Breakbulk
			_task.ti := moveTransaction.myTrackedItem ;
			setdownTask := _task.myEntry.getDirectorOrSetDownTask();
			if setdownTask &lt;&gt; null then
				setdownTask.ti := _task.ti;
			endif;
		endif;	
	endif;
	
	_task.setStatus(TASK_COMPLETE);	//Pickup complete
	
	histEntry.setMyMoveTransaction(moveTransaction);
	
	//epr par 35702 2/3/15 
	imvTask 	:= _task.myEntry.getPreviousEntryFirstMoveTask();//cnwrd1 par 25681 22.11.2010 ++
	if imvMachine &lt;&gt; null and imvTask &lt;&gt; null and imvTask.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
		//epr par 35702 2/3/15 changes for breakbulk only complete task when cargo is moved off the IMV
		if imvTask.ti &lt;&gt; null and imvTask.ti.myPrimaryActualLocation &lt;&gt; imvMachine.myMachineController then
			// Complete the IMV task
			imvTask.setStatus(TASK_COMPLETE);
		endif;
		// Add move history for IMV - pass in other machine pickup task
		imvHistory := imvMachine.addMoveToHistoryTask(_task); 
		if imvHistory &lt;&gt; null then  // Link IMV history to the TI transaction as well
			imvHistory.setMyMoveTransaction (moveTransaction);
		endif;
		// epr par 30548 11/10/12 if machines primary q or sub q of the primary is not the tasks q send note tell imv to refresh
		if  imvMachine.myPrimaryQueue &lt;&gt; null and not imvMachine.myPrimaryQueue.includesQueue(imvTask.queue) then
			imvMachine.causeEvent(Event_Mach_RT_Refresh, false, null);
		endif;
		
		// If no more tasks for IMV then make sure the machine is now idle
		if imvMachine.allCurrentQueueTasks.size = null then
			if imvMachine.machineStatus = STATUS_WORKING then
				app.myUtilityUA.utlUpdateMachineStatus(imvMachine, STATUS_IDLE  , "", false, _passport);
			endif;
		endif;
	endif;
	
	//--------------
	//Link to the next task.
	//--------------
	setdownTask.setMachine(self);	//Establishes our ref to currentQueueTask
	// Move this to the end because deferred updates means that if anything goes wrong we
	// don't want this set.
	setdownTask.setStatus(TASK_WORKING);	//setdown task is now working...
	
epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <Parameter name="_tandemTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePickupTask" id="b96eb322-005e-432d-948e-1111ab959a6b">
        <updating/>
        <source>executePickupTask( _tandemTI : CM_TrackedItem;
					_moveQuantity: Integer;
					_moveWeight : Decimal) updating;

/*

Purpose:			Called when the machine has "picked UP" the pickup task.

Parameters:			Optional tandem lift TI

Return Value:		None


Date		Who		Reason
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
22/11/2010	cnwcs5	par 23714/ccms 1132 - move IMV task handling to this method so we can link it to the TI history 
11/08/14	cnwer1	CCMS 1391 VMT for warehouse needed to be able to pickup single task
                         refactored this block out of the body of pickupTask into pickupSingleTask which iterates through all the machines working tasks
16/10/2019	JLGNS1	ChangeRequest 46451: JMT - Tandem Lift moves - Order of selecting and set down items using Vehicle App
*/



vars
	thisTask		: CM_RTQueueTask;
	allCurrentTasks : CM_RTQueueTaskArray;
begin
	exclusiveLock(self);
	//thisTask := currentQueueTask;

	if allCurrentWorkingQueueTasks.size = null then
		//just return 
		//app.raiseCMException2(MethodWithNullParam, method.name, "No currentQueueTask", null, null);
		return;
	endif;

	//copied into transient dict because allCurrentWorkingQueueTasks changes as the task status changes
	create allCurrentTasks transient;
	foreach thisTask in allCurrentQueueTasks do					//ChangeRequest 46451
		if allCurrentWorkingQueueTasks.includes(thisTask) then	//ChangeRequest 46451
			allCurrentTasks.add(thisTask);						//ChangeRequest 46451
		endif;													//ChangeRequest 46451
	endforeach;	
		
	self.setMachineStatus(STATUS_WORKING , "", false);
	foreach thisTask in allCurrentTasks discreteLock do
		//refactored block into own method for CCMS 1391 VMT for warehouse
		self.executePickupSingleTask(thisTask,_moveQuantity,_moveWeight,_tandemTI,app.myPassport);
		if  app.myPassport.hasErrors then
			return;
		endif;
	endforeach;


epilog
	delete allCurrentTasks;

end;</source>
        <Parameter name="_tandemTI" type="CM_TrackedItem"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="executeSetDownShipLander" id="3f5c1286-a08f-4104-be90-4c6b32730097">
        <updating/>
        <source>executeSetDownShipLander(_thisTask	: CM_RTQueueTask) updating;
//Called when the Move has been completed, and the setDown task has been done.
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	thisTask			: CM_RTQueueTask;
	ignoreValidation,
	isOverStow			: Boolean;
	ti					: CM_TrackedItem;
	wle					: CM_WorkListEntry;
	histEntry : CM_MachineMoveHistory;	
	moveTransaction : CM_Move;
	crane : CM_Crane;
	laneLC : CM_LocationsController;
	laneId : String;
	invalid				: Boolean;
	wp : CM_WorkPoint;	//13 Jul 2012	NDL	Par 30039
	
begin

//	process.profiler.reset();
//	process.profiler.fileName := 'c:\dumps\jadeProf.log';
//	process.profiler.start();
	
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	exclusiveLock(self);
	thisTask := _thisTask;

	if thisTask = null then
		return;
	endif;

	exclusiveLock(thisTask);
	exclusiveLock(thisTask.myEntry);

	//This is the set-down task
	histEntry := self.addMoveToHistoryTask(thisTask);
	thisTask.intendedMachine := null;
	ti := thisTask.ti;
	isOverStow := thisTask.isOverstowTask;
	app.myPassport.clearErrorsWarnings();
	
	ignoreValidation := (thisTask.myEntry.overRideFlags &lt;&gt; 0);
	wle := thisTask.myEntry.myWorkListEntry;
	
	//really dave changed this
	crane := thisTask.myEntry.getJobCrane();
	if crane = null then
		//13 Jul 2012	NDL	Par 30039
		wp := thisTask.myEntry.getJobWorkPoint();
		if wp &lt;&gt; null then
			laneLC := wp.getDefaultDischargeLane(true);
		else
			laneLC := null;
		endif;
	else
		laneLC :=crane.transferArea.loadLanes.first;
		// crane.transferArea.getLaneLC(laneId);
	endif;
	if laneLC = null then
		//--------------
		//Invalid location
		//--------------
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN, laneId, null, null);
		return;
	endif;

	//---------------
	//Update the Tasks' location with the ref of the new lane.
	//---------------
	
	// commented out for fixing later
	//if self.isIMV then //cnwrd1 par 25624 3.7.2012  - for IMV (for all?) we want to set down to the crane  - no real set down to the crane lane happens for IMV - straigth to the crane!
	//if self.isIMV and crane &lt;&gt; null then	//13 Jul 2012	NDL	Par 30039
//		thisTask.setTargetLocation(crane.myMachineController);
	//else
		thisTask.setTargetLocation(laneLC);
//	endif;
	//thisTask.setTargetLocation(laneLC);
	
	// ### MOVE THE TI TO THE CRANE LANE PLEASE
	//moveTransaction := ti.moveToLocation(thisTask.targetLocation, null, wle, self, REAL_MODE, true, true, isOverStow, true, false, false, null,null,app.myPassport);		// TFS 2651
	moveTransaction := ti.moveToLocation(thisTask.targetLocation, null, wle, self, REAL_MODE, true, true, isOverStow, true, false, false, null,null,null,null,null,app.myPassport);	// TFS 2651
	

	histEntry.setMyMoveTransaction(moveTransaction);
		
	if app.myPassport.hasErrors then
		return;
	endif;
	
//	if global.isValidObject(thisTask) then
	if thisTask &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, thisTask, invalid);
		// Disestablish reference to task so overstow tasks can be picked up
		thisTask.setMachine(null);
		on Exception do null;
	endif;
 
	//Nothing else to do in same entry. Quit (99% of cases)
	self.setMachineStatus(STATUS_IDLE  , "", false);

epilog


end;</source>
        <Parameter name="_thisTask" type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="executeSetDownSingleTask" id="44b7ee8f-2408-4ec3-84c5-25249ee08b5d">
        <updating/>
        <source>executeSetDownSingleTask( 	_task : CM_RTQueueTask input;
							_tandemTI : CM_TrackedItem;
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
11 August 2014	cnwer1	Initial creation CCMS 1391 VMT for warehouse needed to be able to pickup single task
                         refactored this block out of the body of pickupTask which iterates through all the machines working tasks
*/

vars
	quantity : Integer;
	weight 				: Decimal[14,4];
	imvMachine			: CM_Machine;
	nextTask,
	directorTask,
	setdownTask,
	imvTask				: CM_RTQueueTask;
	imvHistory,
	histEntry 			: CM_MachineMoveHistory;
	targetLocation	: CM_LocationsController;
	ti					: CM_TrackedItem;
	wle					: CM_WorkListEntry;
	
	invalidNextTask,
	invalidThisTask,
	isRevertedDirector,
	ignoreValidation,
	invalidWLE,
	isOverStow			: Boolean;
	moveTransaction 	: CM_Move;
begin
	if _task = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, nextTask, invalidNextTask);//1/12/2008 cnwdz2 par 18491 
	on Exception do app.handleDeletedObject(exception, _task, invalidThisTask);		// PAR #18743
	on Exception do app.handleDeletedObject(exception, wle, invalidWLE);
	
	exclusiveLock(_task);
	exclusiveLock(_task.myEntry);
	//epr par 31705 19/6/13
	quantity:= _task.myEntry.quantity;
	weight:=0;
	if _task.myEntry.isBulkMove then
		weight:=_task.myEntry.weight;
	endif;
	
	if not _task.isSetDown then
		return; //epr CCMS 1391 warehouse if machine is multi lift can call this to setdown all which could have a mixture of unactioned pickup and setdown tasks
	endif;
	//-------------
	//SPECIAL TEST, there maybe more to do here!!!
	//-------------
	nextTask := _task.getNextMachineTask;
	//special check, test to see if there are any unactioned DIRECTOR tasks
	directorTask := _task.myEntry.getTaskOfType(TASK_DIRECTOR, null);
		
	//This is the set-down task
	histEntry := self.addMoveToHistoryTask(_task);

	targetLocation := _task.targetLocation;	
	if targetLocation = null then
		return; //didn't raise exception on purpose just want to skip over machine initiated tasks which have no target when doing setdown all tasks
	endif;
	
	if targetLocation.isKindOf(CM_MachineController) then
		imvMachine := targetLocation.CM_MachineController.myMachine;
	endif;
	// -----------------------
	// create IMV pickup history - do it after the other machine set-down which is correct order
	// -----------------------
	if imvMachine &lt;&gt; null then
		imvHistory	:= null;
		//imvTask 	:= thisTask.myEntry.getNextEntryFirstTask(); //cnwrd1 par 25681 22.11.2010 --
		imvTask 	:= _task.myEntry.getNextEntryFirstMoveTask();//cnwrd1 par 25681 22.11.2010 ++
		// task should have already been accepted in calling method
		if imvTask &lt;&gt; null and imvTask.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			// The IMV task is offered to another machine, reject that offer
			if imvTask.machine &lt;&gt; null and imvTask.machine &lt;&gt; imvMachine then
				app.myUtilityUA.utlRejectTask(imvTask.machine, imvTask,true, _passport);
				if _passport.hasErrors then
					return;
				endif;
			endif;
			
			app.myUtilityUA.utlChangeTaskStatus(imvTask,imvMachine,TASK_WORKING,_passport);	
			
			if imvTask.machine = imvMachine  then
				// Create move history for IMV - pass in other machine setdown task
				imvHistory := imvMachine.addMoveToHistoryTask(_task);
				
				// epr par 30548 11/10/12 if machines primary q or sub q of the primary is not the tasks q send note tell imv to refresh
				if  not imvMachine.myPrimaryQueue.includesQueue(imvTask.queue) then
					imvMachine.causeEvent(Event_Mach_RT_Refresh, false, null);
				endif;			
			endif;
			
			if imvMachine.machineStatus &lt;&gt; STATUS_WORKING then
				app.myUtilityUA.utlUpdateMachineStatus(imvMachine, STATUS_WORKING  , "", false, _passport);
				if _passport.hasErrors then
					return;
				endif;
			endif;
		endif;
	endif;
	// 22/11/2010 cnwcs5 par 23714/ccms 1132 - end

	//ccms 1750 cnwrd1 23.12.2008
	// update my last known location and timestamp
	self.setMyLastKnowLocation(_task.targetLocation);
	
	_task.intendedMachine := null;
	ti := _task.ti;
	isOverStow := _task.isOverstowTask;
	
	ignoreValidation := (_task.myEntry.overRideFlags &lt;&gt; 0);
	wle := _task.myEntry.myWorkListEntry;
	on Exception do app.handleDeletedObject(exception, wle, invalidWLE);
	invalidWLE := false;// PAR #27650 cnwrd1 1.6.2011		
	wle.edition;// PAR #27650 cnwrd1 1.6.2011		
	if not invalidWLE and wle.myTrackedItem = null and directorTask &lt;&gt; null then
		if directorTask.status = TASK_UNACTIONED then
			wle := null;
			isRevertedDirector := true;
		endif;
	endif;

	//cnwjo3, par 24180
	if targetLocation &lt;&gt; null then			// PAR 25693
		self.myLastTA := targetLocation.getMyTerminalArea;
	endif;
	
	if _tandemTI = null then	// 04/04/2008 cnwar2 #16380
		//moveTransaction := ti.moveToLocation(targetLocation, null, wle, self, REAL_MODE, ignoreValidation, true, isOverStow, true, false,   false,quantity, weight,_passport);	// TFS 2651
		moveTransaction := ti.moveToLocation(targetLocation, null, wle, self, REAL_MODE, ignoreValidation, true, isOverStow, true, false,   false,quantity, weight,null,null,null,_passport);	// TFS 2651
	else
		moveTransaction	:= ti.moveToLocationTandem(targetLocation, _tandemTI, null, wle, self, REAL_MODE, ignoreValidation, true, isOverStow, true, false,  _passport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
			
	if _task.isBreakBulkMove then		
		//epr par 31743 10/6/13
		if moveTransaction &lt;&gt; null and moveTransaction.myTrackedItem &lt;&gt; _task.ti then
			//we have split some Breakbulk
			_task.ti := moveTransaction.myTrackedItem ;
		endif;
	endif;
	
	if app.myPassport.hasWarnings() and not app.myPassport.warningsAcknowledged then
		return;
	endif;
	
	histEntry.setMyMoveTransaction(moveTransaction);			
	// 22/11/2010 cnwcs5 par 23714/ccms 1132 - start
	if imvHistory &lt;&gt; null then
		imvHistory.setMyMoveTransaction (moveTransaction);
	endif;
	// 22/11/2010 cnwcs5 par 23714/ccms 1132 - end
	if isRevertedDirector then
		_task.setStatusComplete();
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
		
	// Disestablish reference to task so overstow tasks can be picked up
	if _task &lt;&gt; null then
		_task.setMachine(null);
	endif;
	if nextTask &lt;&gt; null then
		if nextTask.taskType &lt;&gt; TASK_PICKUP then
			//A worry! Nothing to do after the pickup!
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC, queueId, null, null);
			return;
		endif;
		//--------------
		//Link to the next task. (will be a pickup task)
		//--------------
		nextTask.setMachine(self);	//Establishes our ref to currentQueueTask
		//epr par 25917 1/10/10
		if self.machineStatus = STATUS_IDLE then
			self.setMachineStatus(STATUS_ASSIGNED, null, false);		// PAR #19148
		endif;
		//////////////////////
		// Possible overstow containers require that the intermediate locations are set to
		// which is executed in the setStatus(TASK_ACCEPTED). Code has been modified so that
		// status transition from PENDING to ACCEPTED is allowed. STG 28 SEP 99
		//////////////////////
		if nextTask.taskType = TASK_PICKUP and nextTask.status = TASK_PENDING then
			nextTask.setStatus(TASK_ACCEPTED);	
		endif;
		//--------------
		//Set the workinginQueue if its not = default queue
		//--------------
		if nextTask.queue &lt;&gt; self.myPrimaryQueue then
			self.workingInQueue := nextTask.queue;
		endif;
		//--------------
		//Pickup is automaticaly working
		//--------------
		nextTask.setStatus(TASK_WORKING);
	endif;
	
	if nextTask = null or invalidNextTask then
		if directorTask &lt;&gt; null then
			//-----------------
			//Damn, there IS an unactioned Director, send that back to em!
			//-----------------
			//--------------
			//Link to the the director task.
			//--------------
			directorTask.setMachine(self);	//Establishes our ref to currentQueueTask
			//mediator.task := directorTask;
			//Set to automaticaly working
			directorTask.setStatus(TASK_OFFERED);
			directorTask.setStatus(TASK_ACCEPTED);
		endif;
		
	endif;
		//move to queue last
	self.doDelayedMoveToQueue();
	
epilog
	if self.allCurrentQueueTasks.size = null then
		if not _passport.hasErrors then
			// Update machine status
			self.setMachineStatus(STATUS_IDLE  , "", false);
		endif;
	endif;
end;</source>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_tandemTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executeSetDownTask" id="b33b3441-1f56-4523-a428-315c5f35c740">
        <updating/>
        <source>executeSetDownTask( _tandemTI : CM_TrackedItem; _imvMachine :CM_Machine input) updating;

/*

Purpose:			Called when the Move has been completed, and the setDown task has been done.

Parameters:			Optional tandem TI

Return Value:		None


Date		Who		Reason
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed method
17 Mar 2009	cnwkpd1	PAR #19148 - Need to set machine status back to Working when
					overstoe Pickuip task is automatically assigned
22/11/2010	cnwcs5	par 23714/ccms 1132 - move IMV history creation to this method so we can link it to the TI transaction 
17/8/2014	cnwer1	CCMS 1391 - refactored code block within iteration to its own method so user can setdown a specific task not just all the 
					machines current tasks
*/

vars
	thisTask,task			: CM_RTQueueTask;
	invalidThisTask,
	invalidWLE				: Boolean;
	wle 					: CM_WorkListEntry;
	allCurrentTasks 	: CM_RTQueueTaskArray;
begin
	on Exception do app.handleDeletedObject(exception, thisTask, invalidThisTask);		// PAR #18743
	on Exception do app.handleDeletedObject(exception, wle, invalidWLE);		// PAR #27650 cnwrd1 1.6.2011
	
	
	exclusiveLock(self);
	//epr ccms 1099 for tandem setting down it is important we set down in the order of the array
	create allCurrentTasks transient;
	
	foreach task in self.allCurrentQueueTasks where task.isWorkingOrAccepted do
		allCurrentTasks.add(task);	
	endforeach;
	
	if allCurrentTasks.size  = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No currentQueueTask", null, null);
		return;
	endif;

	foreach thisTask in allCurrentTasks discreteLock do
		/*epr CCMS 1391 Warehouse VMT refactored code block into own method so could just setdown a specific task not all the 
			current tasks
		*/
		//epr TFS 3272 changed queue while working a task
		if self.myPrimaryQueue &lt;&gt; thisTask.myEntry.myQueue then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myPrimaryQueue , self.myTerminal.getTerminalEvent(Event_Update_Queue_Entry), thisTask.myEntry );		
		endif;
		
		self.executeSetDownSingleTask(thisTask,_tandemTI,app.myPassport);
	endforeach;
	
	
	
epilog
	delete allCurrentTasks;
//	if isLockedByMe(self) then	- KPD - removed as it has no effect, cause we're in tran state
//		unlock(self);
//	endif;
end;</source>
        <Parameter name="_tandemTI" type="CM_TrackedItem"/>
        <Parameter name="_imvMachine" type="CM_Machine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findCurrentWorkingTaskForTI" id="94974965-2f24-4f72-b793-634c4c213e85">
        <source>findCurrentWorkingTaskForTI(_type :Integer; _ti :CM_TrackedItem):CM_RTQueueTask;
// ---------------------------------------------------------------------------
// Created:     06 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	task,
	result	:CM_RTQueueTask;
begin
	foreach task in self.allCurrentWorkingQueueTasks do
		if task.taskType = _type and
			task.ti = _ti then
			result := task;
			break;
		endif;
	endforeach;
	
	return result;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="findDriverMoveCargo" id="24dde8f9-ff38-4274-8826-bdb417c43c0b">
        <source>findDriverMoveCargo(_cargoId : String; _allCargo : CM_TIArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2017	jlger1	Initial creation 5784
11/07/2025		naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
*/

vars
	allCargoTypes : IntegerArray;
	cargoTypeObj	: CM_CargoType;
	cargoType  		: Integer;
	iter 			: Iterator;
	ti 				: CM_TrackedItem;
	foundTI			: Boolean;
	reverseId,
	keyId	: String;
	keyType	: Integer;
begin
	if _cargoId = null then
		return;
	endif;
	
	create allCargoTypes transient;
	foreach cargoTypeObj in self.allAllowedCargoTypes do
			allCargoTypes.add(cargoTypeObj.id);
	endforeach;
	
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	app.setContinueCMExceptions(true);
	foreach cargoType in allCargoTypes do
		delete iter;
		foundTI := false;
		iter:= self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
		self.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(cargoType,_cargoId, iter);
		while iter.next(ti) do	
			iter.getCurrentKeys(keyType,keyId);  //MTN-35226
			if cargoType &lt;&gt; TI_CargoType_Null and keyType &lt;&gt; cargoType then
				// Changed so ti is ignored but search doesn't stop until the id doesn't match.
				// Was missing out items where the supplied key was short. ie 4 characters.
				break;
			endif;
			if 	(not keyId.startsWith(_cargoId)) then
				break;
			endif;
			
			if self.validateForMove(null,ti,false) then		
				foundTI:=true;
				_allCargo.addExclusive(ti);
			endif;
		endwhile;
		
		reverseId:=_cargoId.reverse;
		if not foundTI  then
			delete iter;
			iter:=self.myTerminal.allOnsiteTIsByCargoTypeIdRev.createIterator;
			self.myTerminal.allOnsiteTIsByCargoTypeIdRev.startKeyGeq(cargoType,reverseId, iter);
			while iter.next(ti) do
				iter.getCurrentKeys(keyType,keyId); //MTN-35226
				if cargoType &lt;&gt; TI_CargoType_Null and keyType &lt;&gt; cargoType then
					// Changed so ti is ignored but search doesn't stop until the id doesn't match.
					// Was missing out items where the supplied key was short. ie 4 characters.
					break;
				endif;
				if 	(not keyId.startsWith(reverseId)) then
					break;
				endif;
				
				if self.validateForMove(null,ti,false) then		
					foundTI:=true;
					_allCargo.addExclusive(ti);
				endif;
			endwhile;	
		endif;		
	endforeach;
epilog
	delete iter;
	delete allCargoTypes;
end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_allCargo" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findLastMoveForTI" id="68df5c1c-7f1d-4668-8910-cac18e8acb45">
        <source>findLastMoveForTI( _thTI : CM_TrackedItem) : CM_MachineMoveHistory;
/*
Purpose:		To find the last PICKUP in the machine history for the TI		
Parameters:			
Return Value:		

Date			Who		Reason
28 April 2010	cnwrd1	Initial creation
//cnwrd1 par 23997 28.4.2010
01/11/2010		cnwcs5	par 25803/ccms 1132 - look tor pickup not move
*/
constants
	MAGIC_NUMBER	= 1000;
vars
	moveHist,
	result 		: CM_MachineMoveHistory;
	history		: CM_MachineHistory;
	iter 		: Iterator;
	count		: Integer;
begin
	iter := self.history.createIterator();
	
	while iter.back(history) do 
		if not history.isKindOf(CM_MachineMoveHistory) then
			continue;
		endif;
		// look for pickups not moves
		if  history.type &lt;&gt; history.Type_PickUp then	// 01/11/2010 cnwcs5 par 25803/ccms 1132
			continue;
		endif;
		
		moveHist := history.CM_MachineMoveHistory;
		
		if moveHist.cargoType = _thTI.cargoType and moveHist.tiId =  _thTI.id then
			// found it
			result := moveHist;
			break;
		endif;
		
		count := count + 1;				// 06/12/2010 cnwcs5 par 25803/ccms 1132
		
		if count &gt;= MAGIC_NUMBER then	// 06/12/2010 cnwcs5 par 25803/ccms 1132
			break;						// 06/12/2010 cnwcs5 par 25803/ccms 1132
		endif;							// 06/12/2010 cnwcs5 par 25803/ccms 1132
	endwhile;
	
	return result;
	
epilog
	delete iter;
end;
</source>
        <Parameter name="_thTI" type="CM_TrackedItem"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="478556f6-5ddb-4bab-9d14-32cebc93e217">
        <source>findLocation(_strs : StringArray; _noException : Boolean; _foundLC : CM_LocationsController io; _foundHeight : Integer io);
// ---------------------------------------------------------------------------
// Created:			05 July 2001 by cnwdwq1
// Purpose:			Return my locationsController, ignore the rest of the strings.     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	_foundLC := self.myMachineController;
	_foundHeight := NULLINDEX;
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findOtherTwinTask" id="7f39a2c0-6e58-46d4-a3d0-7299e1d79b31">
        <source>findOtherTwinTask(_currentTask : CM_RTQueueTask input) : CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 October 2009	cnwer1	Initial creation

*/

vars
	twinTask : CM_RTQueueTask;
	errorString : String;
begin
	if (not self.machineType = MACHINETYPE_IMV and not self.isTwinLift()) then
		return null;
	endif;
	
	if _currentTask = null then
		return null;
	endif;
	
	foreach twinTask in self.allCurrentQueueTasks do
		//can't just assume that this is a twin task for imvs actually have to check
		if twinTask &lt;&gt; _currentTask then
			if self.checkTwinCarryTwoTasks(_currentTask,twinTask,false,errorString) then
				return twinTask;
			endif;
		endif;
	endforeach;
	
	// Got to here, then there's no twin task
	return null;
epilog

end;</source>
        <Parameter name="_currentTask" type="CM_RTQueueTask" usage="input"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="findPriorMoveHistoryForTI" id="f53cf2bf-0168-48ff-82d4-8385a68248d0">
        <source>findPriorMoveHistoryForTI(_type :Integer; _ti :CM_TrackedItem):CM_MachineMoveHistory;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	MAGIC_NUMBER = 1000;
vars
	moveHistory, directorHistory,
	result 		: CM_MachineMoveHistory;
	history		: CM_MachineHistory;
	infoHistory	: CM_MachineInfoHistory;
	iter 		: Iterator;
	count		: Integer;
begin
	iter := self.history.createIterator();
	
	while iter.back(history) do 		
		if not history.isKindOf(CM_MachineMoveHistory) then
			continue;
		endif;
		
		// look for history of same type
		if  history.type &lt;&gt; _type then	
			continue;
		endif;
		
		moveHistory := history.CM_MachineMoveHistory;
		
		if moveHistory.isEndOfLift then
			// we don't want anything for a prior lift
			break;
		endif;
		
		if moveHistory.cargoType = _ti.cargoType and moveHistory.tiId =  _ti.id then
			if moveHistory.myNextHistory &lt;&gt; null then
				// uh oh - already got a next history.  we have gone back too far
				break;
			endif;
			// found it
			result := moveHistory;
			break;
		endif;
		
		// 
		if _type = CM_MachineHistory.Type_AcceptMove and moveHistory.isDirectorTask and moveHistory.myNextHistory = null then
			// we have found a director task that has not been picked up
			directorHistory := moveHistory;
		endif;
		
		if count &gt; MAGIC_NUMBER then
			break;	// we are not going to find it
		endif;
		
		count := count + 1;
	endwhile;
	
	if directorHistory &lt;&gt; null then
		result := directorHistory;
	endif;
	
	return result;
	
epilog
	delete iter;
end;
</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="findPriorMoveHistoryForTask" id="346f6abf-62ef-47e3-ada1-07f470847d1b">
        <source>findPriorMoveHistoryForTask(_type :Integer; _task :CM_RTQueueTask):CM_MachineMoveHistory;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	moveHistory,
	result 		: CM_MachineMoveHistory;
	history		: CM_MachineHistory;
	iter 		: Iterator;
begin
	iter 		:= self.history.createIterator();
	// we want the most recent entry of the type for the task  For example, if a task were accepted,
	// rejected and then accepted again, we want the second accept, not the first
	while iter.back(history) do 	
		if history.createdTime &lt; _task.createdTime then
			// not possible to find history before task created.
			break;
		endif;
		if not history.isKindOf(CM_MachineMoveHistory) then
			continue;
		endif;
		// look for history of same type
		if  history.type &lt;&gt; _type then	
			continue;
		endif;
		
		moveHistory := history.CM_MachineMoveHistory;
		
		if moveHistory.isForTask (_task) then
			// found it
			result := moveHistory;
			break;
		endif;
	endwhile;
	
	return result;
epilog
	delete iter;
end;
</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="fixupCompleteCurrentTask" id="c771ab62-5403-4fc3-8028-d568539e5348">
        <updating/>
        <source>fixupCompleteCurrentTask() updating;

/*

Date		Who		Reason
11 Jun 2009	cnwkpd1	PAR #19844 - Handle possible null myPrimaryQueue

*/

vars
	alert			: CM_SystemAlert;
	queueString		: String;
	
begin
	if self.currentQueueTask = null then
		return;
	endif;
	//-------------------
	//Still doing a task!
	//-------------------
	//Check to see if there has been a stuff-up, that is, the task's entry is
	//status == complete. Somehow, this machine may not have cleared itself up.
	//If this is the case, then do so now, then continue.
	//-------------------
	if self.currentQueueTask.myEntry.status &lt;&gt; ENTRY_COMPLETE then
		return;
	endif;
	if self.currentQueueTask.status &lt;&gt; TASK_COMPLETE then
		return;
	endif;
	//------------------
	//OK, Task is still lying around. Clean it up from machine.
	//------------------
	self.currentQueueTask.setMachine(null);	//Inverses look after us.

	create alert;
	if self.myPrimaryQueue &lt;&gt; null then
		queueString := " in Queue " &amp; self.myPrimaryQueue.id;
	endif;
	alert.details := "Machine " &amp; self.id.trimRight &amp; queueString &amp; " was still assigned a task. The system has cleaned up.";
	alert.setSeverity(SEVERE_INFO);
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAllAvailableQueues" id="9b4cbd23-e599-4ae0-a73f-a0ad3d77f331">
        <source>getAllAvailableQueues(_queues : Collection input);
/*

Date		Who		Reason
17 May 2017	cnwer1	Initial creation TFS 995 refactored out of MobileServerSchema::CM_ValidationRTAgent::valFindAllAvailableQueues

*/

vars
	terminal : CM_Terminal;
	radioTel		: CM_RadioTelemetry;
	masterQueue 	: CM_MasterQueue;
	machine 		: CM_Machine;
begin
	terminal:=self.getMyTerminal();
	radioTel := terminal.radioTelemetry;
	if radioTel = null then
		return;
	endif;
	masterQueue	:= radioTel.masterQueue;
	machine:=self;
	masterQueue.getAllQueuesForMachineTA(machine, _queues);
epilog

end;</source>
        <Parameter name="_queues" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllAvailableQueuesTasks" id="5a263784-1b6d-4b6e-b28a-e59b96a856dc">
        <source>getAllAvailableQueuesTasks(_availableTasks : CM_RTQueueTaskArray input);
/*

Date		Who		Reason
18 May 2017	cnwer1	Initial creation TFS 995
16 Oct 2024 navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
*/

vars
	iter 				: Iterator;
	allEntries 			: CM_RTQueueEntryArray;
	queue 				: CM_RadioTelemetryQueue;
	queueEntry 			: CM_RTQueueEntry;
	queueTask 			: CM_RTQueueTask;
	invalidObject 		: Boolean;
	objectEdition 		: Integer;
	vehicleConfig 		: CM_RTVehicleConfig;
	ostowTIs			: CM_TIArray;
	sideAccessDirection : Integer;
	primaryQueue		: CM_RadioTelemetryQueue;
begin
	on Exception do app.handleDeletedObject(exception,queueEntry,invalidObject);
	
	self.allAllocatedQueueTasks.copy(_availableTasks);
	//has tasks allocated must do those first
	if _availableTasks.first &lt;&gt; null then
		return;
	endif;
	
	app.sendHeartbeatIfRequired();	//16 Feb 2021	NDL	TFS 50488
	
	vehicleConfig := self.myTerminal.getRTVehicleConfigForObject(self);
	primaryQueue  := self.myPrimaryQueue;
	
	create ostowTIs transient;
	
	if primaryQueue &lt;&gt; null then
		allEntries := primaryQueue.allEntries.cloneSelf(true);
		iter       := allEntries.createIterator;
		
		while iter.next(queueEntry) do
			invalidObject := false;
			objectEdition := queueEntry.edition;
			if invalidObject then
				continue;
			endif; 
			
			app.sendHeartbeatIfRequired();	//16 Feb 2021	NDL	TFS 50488
			
			queueTask:=queueEntry.getFirstUncompletedTask;
			if queueTask = null then
				continue;
			endif;
			
			if vehicleConfig &lt;&gt; null and vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_NONE then	
				ostowTIs.clear;
				queueTask.getAllOverstowedTIs(ostowTIs,sideAccessDirection,self);
				if ostowTIs.first &lt;&gt; null then
					continue;
				endif;				
			endif;
			
			if not queueTask.queryMachineAssign(self,true,false,true,false,true,null)then
				continue;
			endif;
			
			_availableTasks.add(queueTask);
			
		endwhile;
		
	endif;
	
	foreach queue in self.allQueues discreteLock do
		if queue = primaryQueue then
			continue;
		endif;
		delete iter;
		delete allEntries;
		allEntries  := queue.allEntries.cloneSelf(true);
		iter		:= allEntries.createIterator;
		
		while iter.next(queueEntry) do
			invalidObject := false;
			objectEdition:=queueEntry.edition;
			if invalidObject then
				continue;
			endif; 
			
			queueTask:=queueEntry.getFirstUncompletedTask;
			if queueTask = null then
				continue;
			endif;
			
			app.sendHeartbeatIfRequired();	//16 Feb 2021	NDL	TFS 50488
			
			if vehicleConfig &lt;&gt; null and vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_NONE then
				ostowTIs.clear;
				queueTask.getAllOverstowedTIs(ostowTIs,sideAccessDirection,self);
				if ostowTIs.first &lt;&gt; null then
					continue;
				endif;				
			endif;
			
			if not queueTask.queryMachineAssign(self,true,false,true,false,true,null)then
				continue;
			endif;
			
			_availableTasks.add(queueTask);
		endwhile;	
	endforeach;
	
epilog
	delete allEntries;
	delete iter;
	delete ostowTIs;
end;</source>
        <Parameter name="_availableTasks" type="CM_RTQueueTaskArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllFaultResponsesSQL" id="2eca030b-9a6c-45f9-a6df-ea32b93a6a95">
        <source>getAllFaultResponsesSQL():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2021	navndl1	Initial creation	TFS 51926

*/

vars

	faultResponse : CM_FaultResponse;
	faultResponseStr : String;

begin

	foreach	faultResponse in self.allFaultResponses discreteLock do
 
 		if faultResponseStr = null then
			faultResponseStr := faultResponse.oidAsBin;
		else
			faultResponseStr := faultResponseStr &amp; "," &amp; faultResponse.oidAsBin;
		endif;

	endforeach;
	
	return faultResponseStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllFaultsSQL" id="5d0dfb58-1cc4-4ee3-9301-9682e5554943">
        <source>getAllFaultsSQL():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2021	navndl1	Initial creation	TFS 51926

*/

vars

	fault : CM_Fault;
	faultStr : String;

begin

	foreach	fault in self.allFaults discreteLock do
 
 		if faultStr = null then
			faultStr := fault.oidAsBin;
		else
			faultStr := faultStr &amp; "," &amp; fault.oidAsBin;
		endif;

	endforeach;
	
	return faultStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllowedTATypes" id="4d4b7bf2-c5b3-4b49-98dc-8508211699d9">
        <source>getAllowedTATypes(_coll : Collection input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation 53022

*/

vars
	taMaster : CM_TerminalAreaMaster;
begin
	if _coll = null then
		return;
	endif;
	
	foreach taMaster in self.allowedTAMasters discreteLock  do 
		if taMaster.myType = null then
			continue;
		endif;
		if not _coll.includes(taMaster.myType) then
			_coll.add(taMaster.myType);
		endif;
	endforeach;
epilog	

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCMIFMachineWorkzone" id="590f2224-0f33-494a-9752-03f5569aa0a7">
        <source>getCMIFMachineWorkzone(): CMIF_MachineWorkzone;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwer1	Initial creation

*/

vars
	taMaster :CM_TerminalAreaMaster;
	cmifMachineWorkzone : CMIF_MachineWorkzone;
	startCol,endCol : CM_RTGColumn;
begin
	
	
	if self.allWorkzoneLocations.isEmpty then
		//if no begin end columns then find out what RTG Lane they are in	
		self.getWorkzoneDefault(startCol,endCol,taMaster);
	else
		self.getWorkzoneStartEndColumns(startCol,endCol,taMaster);
	endif;
	
	
	if startCol &lt;&gt; null and endCol &lt;&gt; null	 then	
		create cmifMachineWorkzone transient;
		cmifMachineWorkzone.myMachine:=self;
		cmifMachineWorkzone.myStartColumn:=startCol;
		cmifMachineWorkzone.myEndColumn:=endCol;
		cmifMachineWorkzone.myRTGLane:=taMaster;
	endif;
	return cmifMachineWorkzone;

	



epilog

end;</source>
        <ReturnType type="CMIF_MachineWorkzone"/>
    </JadeMethod>
    <JadeMethod name="getCanSwapTasks" id="f042ce66-8e0d-4ac1-ae83-f6104bfdb3ba">
        <source>getCanSwapTasks(_config 		: CM_RTVehicleConfig input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation 52595

*/

vars

	realTask1, 
	realTask2 	: CM_RTQueueTask;
	allErrors : CM_ErrorSet;
	error : CM_Error;
begin
	if self.allCurrentQueueTasks.size &lt;&gt; 2 then
		return false;
	endif;

	if _config = null or not _config.allowChangeSetdown then
		return false;
	endif;
	
	if not self.isTandemLift then
		return true;
	endif;
		
	realTask1 := self.allCurrentQueueTasks[1];
	realTask2 := self.allCurrentQueueTasks[2];
	
	if realTask1.targetLocation = realTask2.targetLocation then
		return true;
	endif;
	
	
	
	if realTask1.myEntry.myJob.isRoadJob and realTask2.myEntry.myJob.isRoadJob then	
		if realTask1.ti &lt;&gt; null and realTask2.ti &lt;&gt; null then
			//jlier1 JIRA-36155 14/10/25
			create allErrors transient;
			app.myPassport.allErrorWarnings.copyNoDuplicates(allErrors,false);
			foreach error in allErrors do
				error.setMyErrorPassport(null);
			endforeach;
			
			app.myPassport.errorsToIgnore.add(ERR_TI_ALREADY_ALLOCATED);
			app.myPassport.errorsToIgnore.add(TI_TestReqOnOtherRelease);
			
			app.myTrxUA.trxCheckTiAgaintRequest(realTask1.ti,realTask2.getTaskRequest,app.myPassport);
			if not app.myPassport.noErrorsIgnored then
				return false;
			endif;
			
			app.myTrxUA.trxCheckTiAgaintRequest(realTask2.ti,realTask1.getTaskRequest,app.myPassport);			
			if not app.myPassport.noErrorsIgnored then
				return false;
			endif;	
		else
			return false;
		endif;
	endif;

	
	return true;
epilog

	if allErrors &lt;&gt; null then
		app.myPassport.clearErrorsWarnings();
		app.myPassport.clearErrorsToIgnore();
		app.myPassport.addErrorsFromSet(allErrors);
		delete allErrors;
	endif;

end;</source>
        <Parameter name="_config" type="CM_RTVehicleConfig" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoAsJSON" id="e5673dde-d4af-40dd-b52f-56e04c48576a">
        <source>getCargoAsJSON(_allCargo : Collection input;
				_primaryRows : EntTableRowArray input;
				_secondaryRows : EntTableRowArray input) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 jlier1 TFS 52595
*/
constants
	Machine = "machine";
    OID = "oid";
    Tasks = "tasks";
	ID = "id";
	PrimaryFields = "primaryFields";
    SecondaryFields = "secondaryFields";
	Cargo = "cargo";
	IsBulk = "isBulk";
    Info = "info";
	IsHaz = "isHaz";
    IsChilled = "isChilled";
	 IDHighLightPos = "idHighlightPos";
    OverstowTICount = "overstowedTICount";
	IsConnected = "isConnected";
vars
	jdoMachine,
	jdoCargo, jdoSecondary, jdoPrimary: JadeDynamicObject;
	allJDOCargo: JadeDynamicObjectArray;
	cargo : CM_TrackedItem;
	entTableRow : EntTableRow;
	value 		: String;
	transients 		: ObjectSet;
	json 		: String;
	iter 		: Iterator;
	accessDirection : Integer;
	allOStowTIs 	: CM_TIArray;
	task : CM_RTQueueTask;
	targetLocation,
	targetLocationExtra: String;
begin
	if _allCargo = null then
		return null;
	endif;
	
	create allOStowTIs transient;
	create transients transient;
	create jdoMachine transient;
	jdoMachine.addProperty(Machine,String);
	jdoMachine.setPropertyValue(Machine,self.id);
	jdoMachine.addProperty(CM_Machine::status.name,String);
	jdoMachine.setPropertyValue(CM_Machine::status.name,self.statusStr);
	jdoMachine.addProperty(Cargo,JadeDynamicObjectArray);
	jdoMachine.addProperty(OID,String);
	jdoMachine.setPropertyValue(OID,self.getOidAsString);
	
	transients.add(jdoMachine);
	create allJDOCargo transient;
	transients.add(allJDOCargo);
	iter:=_allCargo.createIterator;
	while iter.next(cargo) do
		create jdoCargo transient;
		transients.add(jdoCargo);
		jdoCargo.addProperty(ID,String);
		jdoCargo.setPropertyValue(ID,cargo.id);
		jdoCargo.addProperty(OID,String);
		jdoCargo.setPropertyValue(OID,cargo.getOidAsString);		
		if cargo.myCargoType.allowDuplicates then
			jdoCargo.addProperty(IsBulk,Boolean);
			jdoCargo.setPropertyValue(IsBulk,true);
		endif;
		if cargo.isContainer then
			jdoCargo.addProperty(Info,String);
			jdoCargo.setPropertyValue(Info,cargo.getISOType);
			
		endif;
		if cargo.isHazardous then
			jdoCargo.addProperty(IsHaz,Boolean);
			jdoCargo.setPropertyValue(IsHaz,true);
			
		endif;
		if cargo.isChilled or cargo.isReefer then
			jdoCargo.addProperty(IsChilled,Boolean);
			jdoCargo.setPropertyValue(IsChilled,true);
			jdoCargo.addProperty(IsConnected,Boolean);
			jdoCargo.setPropertyValue(IsConnected,cargo.isConnected);
		endif;
			//epr 31/5/21 - should always return source
		jdoCargo.addProperty(CM_RTQueueTask::sourceLocationId.name,String);
		jdoCargo.setPropertyValue(CM_RTQueueTask::sourceLocationId.name,cargo.locationId);
		
		
		if cargo.id.length &gt; 4 then
			jdoCargo.addProperty(IDHighLightPos,Integer);
			jdoCargo.setPropertyValue(IDHighLightPos,(cargo.id.length-3));
		endif;
		allOStowTIs.clear;
		cargo.getAllOverstowedTIs(allOStowTIs,false,accessDirection,self);	
		if allOStowTIs.first &lt;&gt; null then
			jdoCargo.addProperty(OverstowTICount,String);
			jdoCargo.setPropertyValue(OverstowTICount,allOStowTIs.size.asStringJMT);
		endif;
		
		//jlier1 TFS 53023 22/4/22
		task:=cargo.getQueueTask;
		if task &lt;&gt; null then
			jdoCargo.addProperty(CM_RTQueueTask::status.name,Integer);
			jdoCargo.setPropertyValue(CM_RTQueueTask::status.name,task.status);
			jdoCargo.addProperty(CM_RTQueueTask::targetLocationId.name,String);
			targetLocation:=task.getTargetLocationForMachine(null,targetLocationExtra);
			if targetLocation = null then
				targetLocation:=cargo.plannedLocnId;
			endif;
			jdoCargo.setPropertyValue(CM_RTQueueTask::targetLocationId.name,targetLocation);
			if task.isSetDown then
				task:=task.getPreviousTask;
				jdoCargo.setPropertyValue(CM_RTQueueTask::sourceLocationId.name,task.sourceLocationId);
			endif;
			
		endif;
			
		if _primaryRows &lt;&gt; null then
			create jdoPrimary transient;
			transients.add(jdoPrimary);
			jdoCargo.addProperty(PrimaryFields,JadeDynamicObject);
			jdoCargo.setPropertyValue(PrimaryFields,jdoPrimary);
			foreach entTableRow in _primaryRows discreteLock do	
				if entTableRow.name = ETRow_Hazard then
					value:=cargo.isHazardous.getYesNo;
				elseif entTableRow.name = ETRow_Info then
					value:=null;
				else
					value:=cargo.getDisplayStringForAttribute(entTableRow.name,false  );
				endif;
				
				if value = null then
					value:='-';
				endif;
				jdoPrimary.addProperty(entTableRow.name,String);
				jdoPrimary.setPropertyValue(entTableRow.name,value);
										
			endforeach;
		endif;
		if _secondaryRows &lt;&gt; null then
			create jdoSecondary transient;
			transients.add(jdoSecondary);
			jdoCargo.addProperty(SecondaryFields,JadeDynamicObject);
			jdoCargo.setPropertyValue(SecondaryFields,jdoSecondary);
			foreach entTableRow in _secondaryRows discreteLock do				
				if entTableRow.name = ETRow_Hazard then
					value:=cargo.isHazardous.getYesNo;
				elseif entTableRow.name = ETRow_Info then
					value:=null;
				else
					value:=cargo.getDisplayStringForAttribute(entTableRow.name,false  );
				endif;
				if value = null then
					value:='-';
				endif;
				jdoSecondary.addProperty(entTableRow.name,String);
				jdoSecondary.setPropertyValue(entTableRow.name,value);						
			endforeach;
		
		endif;
		
		
		allJDOCargo.add(jdoCargo);
	
	endwhile;
	
	jdoMachine.setPropertyValue(Cargo,allJDOCargo);
	
	jdoMachine.deserializeJSON(json);
	
	return json;
	
epilog
	delete iter;
	delete allOStowTIs;
	
	if transients &lt;&gt; null then
		transients.purge;
	endif;
	delete transients;

end;</source>
        <Parameter name="_allCargo" type="Collection" usage="input"/>
        <Parameter name="_primaryRows" type="EntTableRowArray" usage="input"/>
        <Parameter name="_secondaryRows" type="EntTableRowArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoWeightOnMachine" id="b3c04822-7163-4243-8ac1-5299a92ac050">
        <source>getCargoWeightOnMachine(_ignoreTI : CM_TrackedItem ) : Decimal;
/*

Date		Who		Reason
25 August 2014	cnwer1	Initial creation CCMS 1391 warehouse VMT

*/

vars
	ti : CM_TrackedItem;
	iter : Iterator;
	cargoWeight : Decimal[14,4];
begin

	if self.myMachineController = null then
		return null;
	endif;
	
	iter:=self.myMachineController.allTrackedItems.createIterator;
	while iter.next(ti) do
		if ti = _ignoreTI then
			continue;
		endif;
		
		if not ti.myCargoType.isCheckMaxLift then
			continue;
		endif;
		
		cargoWeight:=cargoWeight + ti.totalWeight;		
	endwhile;
	
	return cargoWeight;
epilog
	delete iter;
end;</source>
        <Parameter name="_ignoreTI" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCraneTargetMoveRate" id="f617904b-6165-4486-abc8-a9a961adac73">
        <source>getCraneTargetMoveRate():CM_CraneMoveRates;

/*

Purpose:			
		Available for Report Writer. Re-implemented on CM_Crane
Parameters:			

Return Value:		


Date		Who		Reason
10 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

begin

	return null;

epilog

end;</source>
        <ReturnType type="CM_CraneMoveRates"/>
    </JadeMethod>
    <JadeMethod name="getCurrentTwinTask" id="675394e7-65c8-4798-99a3-8430cad7f714">
        <source>getCurrentTwinTask(): CM_RTQueueTask;

/*

Purpose:			Get current twin task for machine (if there is one)

Parameters:			None

Return Value:		Current twin task


Date		Who		Reason
26 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	currentTask,
	twinTask 		: CM_RTQueueTask;
	
begin
	if not self.isTwinLift() and not self.isTandemLift() then //cnwrd1 par 25048 5.7.2011
		return null;
	endif;
	
	currentTask := self.currentQueueTask;
	if currentTask = null then
		return null;
	endif;
	
	foreach twinTask in self.allCurrentQueueTasks do
		if twinTask &lt;&gt; currentTask then
			return twinTask;
		endif;
	endforeach;
	
	// Got to here, then there's no twin task
	return null;
	
	
epilog

end;
</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getDelaysForEdit" id="0038d4a7-a69e-4900-a8b4-af09b636aa6e">
        <source>getDelaysForEdit(_delays : CM_DelayByStartDTDict input);
/*

Date		Who		Reason
24 August 2016	cnwer1	Initial creation TFS 2528

*/

vars
	 delayTypeGroup	: CM_DelayTypeGroup;
	 delay : CM_Delay;
	 filterDate	: TimeStamp;
begin
	if _delays = null then
		return;
	endif;
	
	delayTypeGroup := self.myTerminal.getConfig(HhDelayTypeGroup).CM_DelayTypeGroup;
	filterDate := app.actualTimeServer().addHours(-24);	// 24 hours back
	
	
	
	foreach delay in self.allDelays do
		if delayTypeGroup &lt;&gt; null then
			if not delayTypeGroup.allDelayTypes.includes(delay.myDelayType) then
				continue;
			endif;
		endif;
		//epr 17/5/17 when customer never enters the actual end date then it showed all the machine delays
		// check the estimated when actual end date/time is null
		if delay.endDT &lt;&gt; null then
			if delay.endDT &lt; filterDate then
				continue;
			endif;
		elseif delay.estEndDT &lt;&gt; null then
			if delay.estEndDT &lt; filterDate then
				continue;
			endif;
		endif;
		_delays.add(delay);
	endforeach;
epilog

end;</source>
        <Parameter name="_delays" type="CM_DelayByStartDTDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDirectorCargoAsJSON" id="ad9391d4-5a7e-4e5f-88c4-bb230941f5f6">
        <source>getDirectorCargoAsJSON( _cargoId : String;
						_twinCargoId : String;
						_index : Integer;
						_limit : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 jlier1 TFS 52595
20 Mar 2023 jlier1  57064       Refactored JSON returned - changes so numbers are returned as numbers, timestamp and  measurement fields as objects
17/9/25		jlier1 MTN-35637   - changes to how best pick gets the ti - now ordered by attributes of Ti - numOverstows &amp;  bestPickDT
*/

vars
	allCargo 	: CM_TIArray;
	result		: CM_TIArray;
	machConfig 	: CM_RTVehicleConfig;
	iter 		: Iterator;
	cargo 		: CM_TrackedItem;
	count 		: Integer;
	cmifVehicleAppJSON : CMIF_VehicleAppJSON;
	bestPickForSource : Boolean;
	dynaDict : DynaDictionary;
begin
	machConfig:=self.myTerminal.getRTVehicleConfigForObject(self);
	if machConfig = null then
		return null;
	endif;

	create allCargo transient;
	create result transient;
	
	self.getDirectorTaskCargo(_cargoId,_twinCargoId,allCargo);
	bestPickForSource:=self.myTerminal.getConfig(GateBestPickForSource).Boolean;	
	//if best pick for source then 
	if bestPickForSource then
		create dynaDict transient;
		dynaDict.setMembership(CM_TrackedItem);
		dynaDict.addMemberKey(CM_TrackedItem::numOverstows.name,false,false);
		dynaDict.addMemberKey(CM_TrackedItem::bestPickDT.name,false,false);			
		dynaDict.endKeys(true);
		allCargo.copy(dynaDict);
		iter:=dynaDict.createIterator;
	else
		iter := allCargo.createIterator;		
	endif;
	
	while iter.next(cargo) and count &lt; ((_index-1) + _limit) do	
	
		count := count + 1;
		if _index &gt; 1 then
			if count &lt; _index then
				continue;
			endif;
		endif;		
		
		result.add(cargo);
	endwhile;
		
	create cmifVehicleAppJSON transient;
	return cmifVehicleAppJSON.getDirectorCargoAsJSON(self,result);
	
epilog
	delete allCargo;
	delete result;
	delete iter;
	delete cmifVehicleAppJSON;
	delete dynaDict;
end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_twinCargoId" type="String"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_limit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDirectorTaskCargo" id="f3307f2a-9f51-4b78-b468-f799f9e6a7b9">
        <source>getDirectorTaskCargo(	_cargoId : String;
						_twinCargoId : String;
						_allDirectorCargo : CM_TIArray input) : CM_RTQueueTask;
/*

Date		Who		Reason
24 May 2017	cnwer1	Initial creation TFS 995 vmt generic refactoring

*/

vars
	task,
	twinDirectorTask,
	directorTask : CM_RTQueueTask;
	pickupTask 	: CM_RTQueueTask;
	twinTI 		: CM_TrackedItem;
begin
	if allCurrentWorkingQueueTasks.isEmpty then
		return null;
	endif;
	
	foreach task in self.allCurrentWorkingQueueTasks discreteLock do
		//if directorTask = null then
			if task.taskType = TASK_DIRECTOR and
				task.ti = null then
				if directorTask = null then
					directorTask := task;
				else
					twinDirectorTask := task;
				endif;
				
			endif;
		//endif;
		if task.ti &lt;&gt; null then
			twinTI:= task.ti;
		endif;
		
	endforeach;
	
	
	if directorTask = null then
		return null;
	endif;
	
	//epr TFS 6863 14/9/17 search by id
	directorTask.getDirectorTaskCargo(_cargoId,_allDirectorCargo,twinTI);
	
	if twinDirectorTask &lt;&gt; null and (_twinCargoId &lt;&gt; null or 
		(_cargoId = null and _twinCargoId = null )) then
		twinDirectorTask.getDirectorTaskCargo(_twinCargoId,_allDirectorCargo,null);
	endif;
	
	return directorTask;
epilog

end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_twinCargoId" type="String"/>
        <Parameter name="_allDirectorCargo" type="CM_TIArray" usage="input"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="410afeb4-f44d-473f-8732-98717c667460">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.id;
	else
		return '('&amp;self.id &amp; ")  " &amp; self.description;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="09dd3390-738d-474a-a85c-35b00576a76a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// -------------------------------------------
// Created 17 February 2005 by cnwdvb1
// -------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Apr 2014	cnwdb2		PAR #33977  
//02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
// ---------------------------------------------------------------------------
vars
	tmpLC	:	CM_LocationsController;
	tmpStr 	: 	String;
	type : String;					
	str	: String;					
	value : Decimal [23,10];
begin

	//PAR #33977 cnwdb2 17.04.2014 Start
	if _attrName = ETRow_RfidTag then 
		if myRFIDTag &lt;&gt; null then
			return myRFIDTag.code  ;
		endif ;
		return "" ; 
		
	elseif _attrName  = ETRow_JobSeed then
		return getJobSeedString() ; 
		
	/*elseif _attrName = ETRow_JobTypeBoomUp then 
		return*/ 
	

	elseif _attrName = ETRow_RadioTelemetryDevice then
		return self.getRTDeviceId();
		
	//ccms 1750 cnwrd1 23.12.2008	start
	elseif _attrName = ETRow_LastKnownLocation then
		return self.getLastKnowLocationString;
		
	elseif _attrName = ETRow_LastKnownTimestamp then
		if self.lastKnownTimeStamp = null then
			return '';
		else
			return self.lastKnownTimeStamp.asStringJMT;	
		endif;
	elseif _attrName =  ETRow_MachineType then
		return self.machineTypeString;
	elseif _attrName = ETRow_MaxLiftWeight then
		return self.maxLiftWeight.Integer.asStringJMT;
	elseif _attrName = ETRow_NotAvailableForEntry  then
		return self.isNotAvailableForEntry.asStringJMT;
	elseif _attrName = ETRow_WeightDifference then	//11 Jun 2010	NDL Par 24108
		return self.weightDifference.asStringJMT;
	elseif _attrName = ETRow_MachineLiftType then
		return global.getMachLiftTypeDescFromCode(self.machineLiftType);
	elseif _attrName = ETRow_Owner then	//15 May 2018	NDL	TFS 38570
		if self.myOwner = null then
			return null;
		endif;
		return self.myOwner.name;
	elseif _attrName = ETRow_ExternalRef then   //02.10.2018 cnwma1 TFS #41234
		return self.externalRef;
	elseif _attrName.isMeasurementType then											
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);				

	endif;
	
	return inheritMethod(_attrName, _short);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="eaad98a4-3852-440c-bee3-109dc36043c0">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;

vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Description), DC_Label, 1, self);
	block.addNewItem(self.description, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Available), DC_Label, 1, self);
	block.addNewItem(app.getYesNo(self.available), DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Radio_Telemetry), DC_Label, 1, self);
	block.addNewItem(app.getYesNo(self.hasRadioTelemetry), DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Transferable), DC_Label, 1, self);
	block.addNewItem(app.getYesNo(self.isTransferable), DC_Data, 1, self);

	if self.user &lt;&gt; null then					
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_User_GC), DC_Label, 1, self.user);
		block.addNewItem(self.user.code, DC_Data, 1, self.user);
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getGrossRunningHours" id="be450d99-9830-46cf-bd67-492027e42a68">
        <source>getGrossRunningHours(_startTS, _endTS :TimeStamp; _userId :String):Integer;
// ---------------------------------------------------------------------------
// Created:     03 November 2010 by cnwcs5
// Purpose:     Report Writer Method
// Parameters:  None
// Returns:     Gross Running hours in seconds for a date range/user
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------
vars
	result, duration	:Integer;
	logStart, logEnd	:TimeStamp;
	iter				:Iterator;
	coll				:CM_MachineHistoryByDateTime;
	type				:Integer;
	history				:CM_MachineHistory;
	logHistory			:CM_MachineLogOnOffHistory;
begin
	// looking for logon/logoff history items that span the date range
	coll := self.history;
	iter := coll.createIterator;
	
	coll.startKeyLeq (_endTS, iter);
	
	while iter.back (history) do
		if not history.canBeUsedInKPIReporting then
			// we have gone back B$ the history supports KPI reporting
			// this stops us having to handle data in the incorrect format
			break;
		endif;
		
		if history.dateTime &lt; _startTS then
			break;
		endif;
		
		type := history.type;
		
		if type &lt;&gt; CM_MachineHistory.Type_LogOn and
			type &lt;&gt; CM_MachineHistory.Type_LogOff then
			continue;
		endif;
		
		if _userId &lt;&gt; null and history.userId &lt;&gt; _userId then
			continue;
		endif;
				
		if type = CM_MachineHistory.Type_LogOn then
			// find how long they were logged on for.  it will be either next logoff time
			// or if they do not logoff during our time range it will be the end of our time range
			logStart 	:= history.dateTime;
			logHistory 	:= history.myNextHistory.CM_MachineLogOnOffHistory;	// logoff
			
			if logHistory &lt;&gt; null and logHistory.dateTime &lt; logEnd then
				logEnd 	:= logHistory.dateTime;	// logoff time
			else
				logEnd	:= _endTS;
			endif;
			// end TS will be earlier of logoff time and the end of our time range
		else
			// logoff - only interested if they logged on before the start of our range
			logHistory 	:= history.myPriorHistory.CM_MachineLogOnOffHistory;	// logon
			
			if logHistory &lt;&gt; null and logHistory.dateTime &gt;= _startTS then
				// we will already have dealt with the logon
				continue;
			endif;
			// they must have logged on before the start of our timeframe
			logStart 	:= _startTS;
			logEnd 		:= history.dateTime;	// logoff time	
		endif;
		
		duration 	:= logStart.getDifferenceInSeconds (logEnd).rounded; 
		result 		:= result + duration;
	endwhile;
	
	return result;

epilog
	delete iter;		// PAR #26678
		
end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_userId" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
