    <JadeMethod name="tblWLEChange" id="5973593b-b692-4c85-a839-abcb0c2cb8ae">
        <updating/>
        <source>tblWLEChange(_newRow : Integer) updating;
//--------------------------------------------------------------
//Created: 20 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : CM_Object;
begin
	
	self.myCurrentWLE := null;		
	self.myCurrentTrackedItem := null;
	
	if _newRow &lt;= self.tblWorkEntries.fixedRows then
		if CM_Object.hasInstance(self.myCurrentListObject) then
			if global.isValidObject(self.myCurrentListObject) then
				self.displayExtraInfoForObj(self.myCurrentListObject);
				self.setNavigator(self.myCurrentListObject);	
				self.setStatusBarCaption();
				self.tblWorkEntries.clearAllSelected();
			else
				self.setMyCurrentListObjects(null);
			endif;
		endif;
		return;
	endif;
	
	obj := self.tblWorkEntries.accessRow(_newRow).itemObject.CM_Object;
	
	if not global.isValidObject(obj) then
		return;
	endif;
	
	if obj.isKindOf(CM_WorkListEntry) then
		self.myCurrentWLE := obj.CM_WorkListEntry;
	elseif obj.isKindOf(CM_TrackedItem) then
		self.myCurrentTrackedItem := obj.CM_TrackedItem;		
	endif;
	
	if self.myCurrentWLE &lt;&gt; null then
		self.myCurrentTrackedItem := self.myCurrentWLE.myTrackedItem;
	endif;
	
	self.displayExtraInfoForObj(obj);
	self.setNavigator(obj);	
	self.setStatusBarCaption();

	
end;</source>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWLEDragDropEvent" id="bb0ff42f-f1e0-4b36-abbb-0c65fa333d4f">
        <updating/>
        <source>tblWLEDragDropEvent(table: Table input; win: Window input; x: Real; y: Real) updating, protected;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if win.isKindOf(CMUI_GridAreaForm) or
		win.isKindOf(CMUI_GridAreaDrawingFrame) or
	   win.isKindOf(CMUI_GridAreaFrame) or
	   win.isKindOf(CM_DataTable) then
		self.tblWLEReceiveDrop();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblWLEMouseMoveEvent" id="7e36187c-4495-41a4-abd3-a851451e9c9e">
        <updating/>
        <source>tblWLEMouseMoveEvent(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
begin

	if self.myCurrentWLE = null and self.myCurrentTrackedItem = null then
		return;
	endif;

	// check drag/drop detected
	if button &lt;&gt; 1 or (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then
	   return;
	endif;

	self.origXPos := 0;
	self.origYPos := 0;	
	
	// check there is a trackedItem to move
	if self.myCurrentWLE &lt;&gt; null then
		theTI := self.myCurrentWLE.myTrackedItem;
	endif;
	
	if theTI = null then
		theTI := self.myCurrentTrackedItem;
	endif;
	
	if theTI = null then
		return;
	endif;

	app.myDraggedTrackedItem := theTI;
	self.dragTrackedItem(theTI, self.myCurrentWLE, self.tblWorkEntries);
	self.tblWorkEntries.row := self.tblWorkEntries.fixedRows; //PAR 17940
	self.myCurrentWLE := null;
	self.myCurrentTrackedItem := null;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblWLEReceiveDrop" id="783e12bb-f8dd-4eff-a52c-f99055d0102c">
        <updating/>
        <source>tblWLEReceiveDrop() updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	
	if self.myCurrentWLE = null then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;

	if (not global.isValidObject(self.myCurrentWLE)) then
		self.tblWLEChange(null);
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;	
	
	app.mousePointer := MousePointer_HourGlass;
	
	if self.myCurrentWLE.isReceipt then
		//selected wle is a receipt, they could be sending it back to the vehicle
		self.moveTrackedItem(self.getLocationController(), self.myCurrentWLE);
	else //selected wle is a release
		self.assignTIToReleaseRequest(self.myCurrentWLE);
	endif;
	
	// This get done via notifications
	//self.tblWLEUpdateWle(self.myCurrentWLE, self.Mode_Update);	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
