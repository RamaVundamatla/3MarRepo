// ---------------------------------------------------------------------------
// Created:		31 January 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.devNames.clear;
	
	self.devNames.add("Russell Sargent"); 
	self.devNames.add("Mohamed Adwy"); 
	self.devNames.add("Dave Patrick"); 
	self.devNames.add("Emmet Ryan"); 
	self.devNames.add("Nelson Lipinski"); 
	self.devNames.add("Adam Richards"); 
	self.devNames.add("Roc Huang"); 
	self.devNames.add("Nick Stott"); 
	self.devNames.add("Michael Portis"); 
	
end;</source>
    </JadeMethod>
