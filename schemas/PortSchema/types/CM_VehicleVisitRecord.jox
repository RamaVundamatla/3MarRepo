        <updating/>
        <source>setProxyCorrectedInfo(_driverCode : String; _carrier : CM_Carrier; _subCarrier : CM_Carrier; _regNumber : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jan 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
17 May 2024	navdap1	TFS 63871 EUP | FR - 59098 - Departed Transport Correction - Driver Details Not Required
*/

vars
begin
	if _carrier &lt;&gt; null then
		self.carrierCode := _carrier.code;
	endif;
	if _subCarrier &lt;&gt; null then
		self.subCarrierCode := _subCarrier.code;
	endif;
	self.driverCode := _driverCode;			// TFS 63871
	self.driversName := _driverCode;		// TFS 63871
	self.regNumber := _regNumber;
epilog

end;</source>
