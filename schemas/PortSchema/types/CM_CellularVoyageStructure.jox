    </JadeMethod>
    <JadeMethod name="getOOWCreationDetail" id="4cb16374-5743-4994-a587-42ecdcdfd4d9">
        <source>getOOWCreationDetail(_bay : CM_BayVoyage; _deck, _order : Integer; _get40 : Boolean; _createNew : Boolean; _getLoad : Boolean; _getSOB : Boolean) : CM_OOWCreationDetail;
// ---------------------------------------------------------------------------
// Created:		08 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx, theOrder  : Integer;
	trgOOWC, oowc, returnOOWC : CM_OOWCreation;
begin
	foreach oowc in self.allOOWCreations do
		if oowc.myBay = _bay 
//		and oowc.CM_OOWCreationDetail.is40 = _get40 // PAR 16415 CCMS 1029
		and oowc.CM_OOWCreationDetail.getIs40() = _get40
		and (oowc.CM_OOWCreationDetail.isDischarge() &lt;&gt; _getLoad)
		and (oowc.CM_OOWCreationDetail.isSOB() = _getSOB)
		and oowc.ordinalDeck = _deck then
			returnOOWC := oowc;
			break;
		endif;
	endforeach;
	
	if returnOOWC = null and _createNew then
		create returnOOWC as CM_OOWCreationDetail;
		returnOOWC.setMyVoyageStructure(self);
		theOrder := _order;
//##
		trgOOWC := self.allOOWCreations.getAtKeyGeq(_order,0);
		if trgOOWC &lt;&gt; null 
		and trgOOWC.order = _order then
			returnOOWC.incrementYourOrder(trgOOWC, true);
			theOrder := returnOOWC.order;
		endif;

//###




		returnOOWC.init(_bay,_deck,1,theOrder, _get40);
	endif;
	return returnOOWC.CM_OOWCreationDetail;
end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <Parameter name="_deck" type="Integer"/>
        <Parameter name="_order" type="Integer"/>
        <Parameter name="_get40" type="Boolean"/>
        <Parameter name="_createNew" type="Boolean"/>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_getSOB" type="Boolean"/>
        <ReturnType type="CM_OOWCreationDetail"/>
    </JadeMethod>
    <JadeMethod name="getOOWCreationOrder" id="f1b92a28-aa72-4a9f-8aba-1dcb780b6e1a">
        <source>getOOWCreationOrder(_bay : CM_BayVoyage) : Integer;
// ---------------------------------------------------------------------------
// Created:		08 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		Get the first OOWCreation order for the bay. If no OOWC for the bay get next order in line.
//
// ---------------------------------------------------------------------------
vars
	idx, lastOrder, theOrder  : Integer;
	oowc : CM_OOWCreation;
begin
	foreach oowc in self.allOOWCreations do
		if oowc.myBay = _bay then
			theOrder := oowc.order;
			return theOrder;
		endif;
	endforeach;
	
	foreach oowc in self.allOOWCreations do
		if oowc.myBay.ordinalBay &gt; _bay.ordinalBay then
			theOrder := lastOrder;
			if theOrder = 0 then
				theOrder := 1;
			endif;
			return theOrder;
		endif;
		lastOrder := oowc.order;
	endforeach;
	
	return lastOrder;
end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getOOWCreationPopController" id="e8478b52-50bd-4496-a42a-f62f6fa22635">
        <source>getOOWCreationPopController(_controller : CMIF_OOWCreationAutoUpdate input);
// ---------------------------------------------------------------------------
// Created:		03 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	oowc : CM_OOWCreation;
	oowcd : CM_OOWCreationDetail;
	crPC : Integer;
	anObj : Object;
	crane  : CM_Crane;
	aJS : CM_VoyageJobSheet;
begin
	if _controller = null then
		return;
	endif;
	
	_controller.myCellularStructure := self;
	
	// ### work out the total items
	foreach oowc in self.allOOWCreations do
		oowcd := oowc.CM_OOWCreationDetail;
		
		_controller.totalItems := _controller.totalItems + oowcd.getTotalItems();
		
		if oowcd.myCraneJobSheet &lt;&gt; null then
			crane := oowcd.myCraneJobSheet.getMyCrane;
			// ### record the cranes in the correct order
			if crane &lt;&gt; null 
			and not _controller.allCranes.includes(crane) then
				_controller.allCranes.add(crane);
				
				// add up all the target rates so that we can get a percentage for allocating work
				_controller.totalRate := _controller.totalRate + crane.targetRatePH;
			endif;
		endif;
	endforeach;
	
	// ### extra cranes
	foreach aJS in self.myVoyage.allJobSheetsInOrder do
		crane :=aJS.getMyCrane;
		// ### record the cranes in the correct order
		if crane &lt;&gt; null 
		and not _controller.allCranes.includes(crane) then
			_controller.allCranes.add(crane);
			// add up all the target rates so that we can get a percentage for allocating work
			_controller.totalRate := _controller.totalRate + crane.targetRatePH;
		endif;

	endforeach;
	
	if _controller.allCranes.size &gt; 1 and _controller.totalRate = 0 then
		app.raiseCMException(CraneTargetRateNotSet, null, null);
		return;
	endif;
	
	foreach anObj in _controller.allCranes do
		crane:=anObj.CM_Crane;
		//epr par 30708 6/12/12
		if  _controller.totalRate &gt; 0 then
			// ### get the cranes percentage of work based on its lift rate
			crPC := ( (crane.targetRatePH / _controller.totalRate) * 100 ).rounded();
		else
			crPC:=0;
		endif;
		_controller.craneRatePC.add(crPC);
		
	endforeach;	
	
	if _controller.craneRatePC.size &gt; 0 then
		_controller.craneRatePC[_controller.craneRatePC.size] := 100;
	endif;
epilog
end;</source>
        <Parameter name="_controller" type="CMIF_OOWCreationAutoUpdate" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getOOWOrderFor40" id="fbe3e32f-7f5a-4196-964e-e6527e39e609">
        <source>getOOWOrderFor40(_isDisch : Boolean; _craneType : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		31 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
//					PAR 12768 changed 99 to 10
// ---------------------------------------------------------------------------
vars
	jps : CM_JobPriorityByCrPriJobDict;
	aJP : CM_JobPriority;
begin
	create jps transient;
	self.myVoyage.getJobPriorities(jps);

	foreach aJP in jps discreteLock where aJP.craneType = _craneType  do
		if (aJP.isDischarge = _isDisch) then
			if aJP.is40() then
				return 0; // 40's are first
			else
				return 10; // 40's are last
			endif;
		endif;
	endforeach;
	
	return 10; // default	
epilog
	delete jps;
end;</source>
        <Parameter name="_isDisch" type="Boolean"/>
        <Parameter name="_craneType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getOOWSameJobFor2040" id="99cfd185-2a0c-47a9-b6d3-92cad1d543b0">
        <source>getOOWSameJobFor2040(_isDisch : Boolean; _craneType : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:		31 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	jps : CM_JobPriorityByCrPriJobDict;
	aJP : CM_JobPriority;
	got20, got40 : Boolean;
	lastPri : Integer;
begin
	create jps transient;
	self.myVoyage.getJobPriorities(jps);

	foreach aJP in jps discreteLock where aJP.craneType = _craneType  do
		if (aJP.isDischarge &lt;&gt; _isDisch) then
			continue;
		endif;

		if lastPri &lt;&gt; 0 and lastPri &lt;&gt; aJP.priority then
			return (got20 and got40);
		endif;
		if aJP.is40() then
			got40 := true;
		else
			got20 := true;
		endif;
		lastPri := aJP.priority;
	endforeach;

	return (got20 and got40);
	
	return false; // default	
epilog
	delete jps;
end;</source>
        <Parameter name="_isDisch" type="Boolean"/>
        <Parameter name="_craneType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getOOWSameJobForSOBDisch" id="056d9b30-406f-4063-8d4b-e2f29e2e46ce">
        <source>getOOWSameJobForSOBDisch( _craneType : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:		15 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	jps : CM_JobPriorityByCrPriJobDict;
	aJP : CM_JobPriority;
	gotDIS, gotSOB : Boolean;
	lastPri : Integer;
begin
	create jps transient;
	self.myVoyage.getJobPriorities(jps);

	foreach aJP in jps discreteLock where aJP.craneType = _craneType  do
		if aJP.isLoad() then
			continue;
		endif;

		if lastPri &lt;&gt; 0 and lastPri &lt;&gt; aJP.priority then
			return (gotDIS and gotSOB);
		endif;
		if aJP.isDischarge() then
			gotDIS := true;
		endif;
		if aJP.isSOB() then
			gotSOB := true;
		endif;
		lastPri := aJP.priority;
	endforeach;

	return (gotDIS and gotSOB);
epilog
	delete jps;


end;</source>
        <Parameter name="_craneType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPhysicalBayOrder" id="e52a50d0-ba32-46fa-86c3-2a0e8830c2bb">
        <source>getPhysicalBayOrder() : String;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBayDef : CM_BayVoyage;
	theString : String;
begin

	foreach aBayDef in self.allBayVoyagesByOrdinal do
		theString := theString &amp; aBayDef.id.trimBlanks &amp; " " ;
	endforeach;

	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlanningGuideForBay" id="7bd30c58-f6dc-44ab-a29a-567409cb17d8">
        <source>getPlanningGuideForBay(guide : CMIF_PlanningGuideBay input);
/*
 ------------------------------------------------------------------------
Created:			21 November 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
---------------------------------------------------------------------------
*/
vars
	bayVoyage : CM_BayVoyage;
begin

	if guide = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'guide', null, null);
	endif;
	//---------------------
	//Clear the structure, it gets passed in multiple times (for each bay)
	//---------------------
	guide.clear();
	//---------------------
	//Locate the requested bay
	//---------------------
	bayVoyage := self.allBayVoyagesById[guide.id];
	if bayVoyage = null then
		bayVoyage := self.allBayVoyagesById40[guide.id];
		guide.is40Bay	:= (bayVoyage &lt;&gt; null);
	endif;
	if bayVoyage = null then
		app.raiseCMException1(ERR_INVALID_BAY, guide.id, null, null);
		return;
	endif;
	//--------------------
	//Ask the bay to give us its goodies
	//--------------------
	bayVoyage.getPlanningGuide(guide);
end;</source>
        <Parameter name="guide" type="CMIF_PlanningGuideBay" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProposedBayPlanTIs" id="8f85cdee-3ac8-431c-bc5d-322d2cf6010f">
        <source>getProposedBayPlanTIs(_proposedDict: CM_TIByCargoTypeIdDict input);
//----------------------------------------------------------------
//	Created:	23 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	bayVoyage		: CM_BayVoyage;
	sc				: CM_SlotController;
	tis				: CM_TIArray;
	ti				: CM_TrackedItem;
	int				: Integer;
begin
	create tis transient;
	
	foreach bayVoyage in self.allBayVoyagesByOrdinal do
		
		foreach sc in bayVoyage.allSlotControllersByOrdinal do
			//start with empty
			tis.clear;
			//get SC's proposed tis
			sc.getProposedTIs(tis);
			if tis.isEmpty() then	//par 27733 cnwrs1 17 june 2011
				sc.getProposedBulkRelease(tis);
			endif;
			foreach ti in tis do
				if not _proposedDict.includesKey(ti.cargoType, ti.id) then
					//add to dict
					_proposedDict.add(ti);
				endif;
			endforeach;
			
		endforeach;
	
	endforeach;

epilog
	delete tis; 
end;</source>
        <Parameter name="_proposedDict" type="CM_TIByCargoTypeIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSectionByPosition" id="28a6be2d-6b6c-49e8-9c6e-98324ca69cb4">
        <source>getSectionByPosition(_pos : Decimal; _variance : Decimal) : CM_VesselSection;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	tmpSect : CM_VesselSection;
	pos : Decimal[12,2];
begin
	pos := _pos - _variance;
	
	tmpSect := self.myVoyage.myStructuralElements.allSectionsByPosition.getAtKeyGeq(pos);
	
	if tmpSect &lt;&gt; null then
		if tmpSect.position &lt;= (_pos + _variance) then
			return tmpSect;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_pos" type="Decimal"/>
        <Parameter name="_variance" type="Decimal"/>
        <ReturnType type="CM_VesselSection"/>
    </JadeMethod>
    <JadeMethod name="getTEUCapacity" id="22bfc75b-e82d-46c1-acb5-50304fe7ff13">
        <source>getTEUCapacity() : Integer;
// ---------------------------------------------------------------------------
// Created:     14 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	teu : Integer;
	slot : CM_SlotDefn;
begin
	foreach aBay in self.allBayVoyagesByOrdinal discreteLock do
		foreach slot in aBay.allSlotsByOrdinal  discreteLock where slot.unavailable = false do
			
		teu := teu + 1;
		endforeach;
	endforeach;
	
	return teu;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalColourCode" id="222fec19-da83-4b24-9e34-b271633e99cb">
        <source>getTotalColourCode(_getLoad : Boolean; _includeDLR : Boolean; _checkJob : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aBayVoyage : CM_BayVoyage;	
	aSlotReq : CM_SlotRequest;
	moveType, tot : Integer;
	iter01 : Iterator;
begin
	
	foreach aBayVoyage in self.allBayVoyagesByOrdinal do
		iter01 := aBayVoyage.allSlotRequestByMoveType.createIterator();
		
		while iter01.next(aSlotReq) do
			if aSlotReq.isLoad  = _getLoad then
				if _checkJob then
					if (aSlotReq.myJob &lt;&gt; null) then
						tot := tot + 1;
					endif;
				else
					tot := tot + 1;
				endif;
			endif;
		endwhile;
		if _includeDLR then
			while iter01.next(aSlotReq) do
				if aSlotReq.moveType = DLR_MOVETYPE 
				//and (_checkJob and (aSlotReq.myJob &lt;&gt; null))
				and aSlotReq.isLoad = _getLoad then
					if _checkJob then
						if (aSlotReq.myJob &lt;&gt; null) then
							tot := tot + 1;
						endif;
					else
						tot := tot + 1;
					endif;
				endif;
			endwhile;
		endif;
			
		delete iter01;
		
	endforeach;
	
	return tot;
epilog
	delete iter01;
end;</source>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_includeDLR" type="Boolean"/>
        <Parameter name="_checkJob" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalPlanned" id="fbb2eea9-5fda-44bc-9dd9-de43205b19e5">
        <source>getTotalPlanned(_getLoad : Boolean; _includeDLR : Boolean) : Integer;
/*
Purpose:			
Date				Who			Reason
JANUARY 2015		CNWAB1		Initial creation
*/

vars
	aBayVoyage : CM_BayVoyage;	
	aSlotReq : CM_SlotRequest;
	moveType, tot : Integer;
	iter01 : Iterator;
begin
	
	foreach aBayVoyage in self.allBayVoyagesByOrdinal do
		iter01 := aBayVoyage.allSlotRequestByMoveType.createIterator();
		
		while iter01.next(aSlotReq) do
			if aSlotReq.isLoad  = _getLoad then
				if (aSlotReq.myJob &lt;&gt; null) then
						if aSlotReq.isPlanned() then
							tot := tot + 1;
						endif;
				endif;
			endif;
		endwhile;
		if _includeDLR then
			while iter01.next(aSlotReq) do
				if aSlotReq.moveType = DLR_MOVETYPE 
				and aSlotReq.myJob &lt;&gt; null
				and aSlotReq.isLoad = _getLoad then
						if aSlotReq.isPlanned() then
							tot := tot + 1;
						endif;
				endif;
			endwhile;
		endif;
			
		delete iter01;
		
	endforeach;
	
	return tot;
epilog
	delete iter01;
end;</source>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_includeDLR" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLGridDefinition" id="f0c80772-d025-4b64-a299-1a7e11935ad7">
        <source>getXMLGridDefinition() : Binary; // serverExecution; // please leave this non serverExecution. There is a problem with the hatchLid OIDs in the XML
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		FOR VOYAGES. This creates a single string with XML tags that 
//				descibe the hold, bay, cells, tiers, slots and hatch lids of 
//				a vessel.  It is used to draw voyages on screen. Basically 
//				the columns and rows.
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aHold			: CM_Hold;
	aBay			: CM_Bay;
	xml				: String;
	colour1			: Integer;
	colour2			: Integer;
	theCol			: Integer;
	theRow			: Integer;
	currentColour	: Integer;
	colEnd			: Integer;
	rowStart		: Integer;
	rowEnd			: Integer;
	colEndRows		: Integer;
	numBays			: Integer;
	
begin
	// these are used for the hold colours to give us a checker board effect
	// this '4' will be 6 if there are triple bays
	colour1 := 14671839; //Yellow;
	colour2 := 12566463; //Red;
	if self.hasTripleBays() then
		colEndRows := 6;
	else
		colEndRows := 4;
	endif;
	
	numBays := self.allBayVoyagesByOrdinal.size();
	
	if numBays &lt;= 12 then
		colEnd := numBays;
	else
		colEnd := (numBays / colEndRows).Integer + 1;
	endif;
	
	rowStart := 1;
	rowEnd := colEndRows;
	
	theRow := 0;
	theCol := 0;
	
	beginLoad;
	
	currentColour := colour1;
	
	foreach aHold in self.allHolds do
		theCol := theCol + 1;
		
		if theCol &gt; colEnd then
			currentColour := colour2;
			theCol := 1;
			rowStart := rowStart + colEndRows;
			rowEnd := rowStart + colEndRows - 1;
		endif;
		
		theRow := rowStart;

		if currentColour &lt;&gt; colour1 then
			currentColour := colour1;
		else
			currentColour := colour2;
		endif;

		foreach aBay in aHold.allBays do
			xml := xml &amp; aBay.getGridDefinitionXML(theRow, theCol, currentColour);
			theRow := theRow + 2;
		endforeach;
	endforeach;

	endLoad;	
// cnwdad1 25/02/2009 - PAR #18366.
//	return xml.compress;
	return xml.compressToBinary(Binary.Compression_ZLib);
epilog
	endLoad;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getXMLGridSideProfile" id="bf0e8c2a-9c81-4fe3-b492-b1006d4a3506">
        <source>getXMLGridSideProfile(_clear : Boolean;_mode : Integer; _theHolds : ObjectArray;_flipH : Boolean) : Binary; // serverExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
// ---------------------------------------------------------------------------
constants
	Mode_BayDefn = 1;
	Mode_BayAct = 2;
	Mode_BayPro = 3;
	Mode_ColCodeLoad = 4;
	Mode_ColCodeDisch = 5;
vars
	ls : Boolean;
	aBay : CM_Bay;
	xml, sml, tml : String;
	aSlot : CM_SlotDefn;
	aSlotDefVoy : CM_SlotDefnVoyage;
	aTier : CM_TierDefn;
	aTierOrdinal : Integer;
	theHold : CM_Hold;
	tierLabels,tierLabelsUD, tierLabelsRightThru : StringArray;
	aTierLabel,theTierThruOD,theTierThruUD, afterbay : String;
	theTierThruODPos, theUDTierAdjustment, numTLabelsOD, numTLabelsUD, numTLabels : Integer;
	totalLoadCC, totalDischCC, theCL, theCD, theJL, theJD , totalBays: Integer;
	theColumn : Integer;
	bayOffset : Integer; // Par 26350 - Use instaed of ordinalBay which doesn't match index when bays have been deleted
begin
	
	if _flipH then
		if not _clear
		and self.xmlSideProfilePort &lt;&gt; null then
			return self.xmlSideProfilePort;
		endif;
	else
		if not _clear
		and self.xmlSideProfileStarboard &lt;&gt; null then
			return self.xmlSideProfileStarboard;
		endif;
	endif;
	// ####################
	// Get all the tier ordinals
	create tierLabels transient;
	create tierLabelsUD transient;
	create tierLabelsRightThru transient;
	// the tiers on deck and under deck start at 1, but the tier labels are different oD and UD. The same labels are used through the ship
	// so we need a row number for our grid area so we put each possible tier labels into an array and later we 
	// use that to decide the tiers row, as far as our grid area is concerned
	//totalBays := self.allBayVoyagesByOrdinal.size;
	
	foreach aBay in self.allBayVoyagesByOrdinal do
		totalBays := totalBays+1;
		foreach aTier in aBay.allTiersOnDeck do
			aTierLabel := aTier.id;
			if not tierLabels.includes(aTierLabel) then
				if not tierLabelsUD.includes(aTierLabel) then // PAR 17603
					tierLabels.add(aTierLabel);
					numTLabelsOD := numTLabelsOD+1;				
				endif;
			endif;
		endforeach;
		foreach aTier in aBay.allTiersUnderDeck do
			aTierLabel := aTier.id;
			if not tierLabels.includes(aTierLabel) then // PAR 17603
				if not tierLabelsUD.includes(aTierLabel) then
					tierLabelsUD.add(aTierLabel);
					numTLabelsUD := numTLabelsUD+1;								
				endif;
			endif;
		endforeach;
	endforeach;	
	
	// try to work out which tier runs right through the whole of on deck
	tierLabels.cnEcSort(true);
	foreach aTierLabel in tierLabels do : outerLoop
		foreach aBay in self.allBayVoyagesByOrdinal do
			if not aBay.allTiersOnDeckByLabel.isEmpty and aBay.allTiersOnDeckByLabel[aTierLabel] = null then
				continue outerLoop;
			endif;
		endforeach;
		if not tierLabelsRightThru.includes(aTierLabel) then
			tierLabelsRightThru.add(aTierLabel);
			theTierThruOD := aTierLabel;			
		endif;
	endforeach;

//	theTierThruOD := tierLabelsRightThru.last;
	theTierThruODPos := tierLabels.indexOf(theTierThruOD);
//	theUDTierAdjustment := tierLabels.size - theTierThruODPos;
	theUDTierAdjustment := numTLabelsOD - theTierThruODPos;

	// sort the OD and the UD labels and put into 1 array
	tierLabelsUD.cnEcSort(true);
	tierLabelsUD.copy(tierLabels);
	numTLabels := numTLabelsUD + numTLabelsOD;
	
	app.cmsBeginLoad(ls);
	
	aBay := self.allBayVoyagesById[self.bridgeAfterBay];
	if aBay &lt;&gt; null then
		bayOffset := self.allBayVoyagesByOrdinal.indexOf(aBay.CM_BayVoyage);	//25 Nov 2010	NDL Par 26350
		if _flipH then
		//	afterbay := (aBay.ordinalBay + 1).String;		//25 Nov 2010	NDL Par 26350
			afterbay := (bayOffset + 1).String;		//25 Nov 2010	NDL Par 26350
		else
		//	afterbay := (totalBays - aBay.ordinalBay + 1).String;		//25 Nov 2010	NDL Par 26350
			afterbay := (totalBays - bayOffset + 1).String;		//25 Nov 2010	NDL Par 26350
		endif;
	else
		if self.allBayVoyagesByOrdinal.isEmpty then
			afterbay := "0";
		else
			afterbay := self.allBayVoyagesByOrdinal.last.id;
		endif;
	endif;
	
	xml := "&lt;GA&gt;&lt;GO&gt;0101&lt;/GO&gt;&lt;lb&gt;Profile&lt;/lb&gt;&lt;TR&gt;" &amp;
	       numTLabels.String &amp; "&lt;/TR&gt;&lt;TC&gt;" &amp; totalBays.String &amp; "&lt;/TC&gt;&lt;AB&gt;" &amp; afterbay  &amp; "&lt;/AB&gt;&lt;RLS&gt;"; 

	foreach aTierLabel in tierLabels do
		xml := xml &amp; "&lt;RL&gt;" &amp; aTierLabel &amp; "&lt;/RL&gt;";
		if tierLabelsUD.includes(aTierLabel) then
			xml := xml &amp; "&lt;OD&gt;N&lt;/OD&gt;";
		else
			xml := xml &amp; "&lt;OD&gt;Y&lt;/OD&gt;";
		endif;
	endforeach;
	xml := xml &amp; "&lt;/RLS&gt;&lt;CLS&gt;";
	
	if _flipH then
		foreach aBay in self.allBayVoyagesByOrdinal  do
			if aBay.myHold &lt;&gt; theHold and theHold &lt;&gt; null then
				xml := xml &amp; "&lt;AL&gt;0.25&lt;/AL&gt;";
			else
				xml := xml &amp; "&lt;AL&gt;0&lt;/AL&gt;";
			endif;
			xml := xml &amp; "&lt;CL&gt;" &amp; aBay.id &amp; "&lt;/CL&gt;";
			xml := xml &amp; "&lt;OSC&gt;" &amp; aBay.onShipCrane.String &amp; "&lt;/OSC&gt;";
			
			theHold := aBay.myHold;
		endforeach;
	else
		foreach aBay in self.allBayVoyagesByOrdinal reversed do
			if aBay.myHold &lt;&gt; theHold and theHold &lt;&gt; null then
				xml := xml &amp; "&lt;AL&gt;0.25&lt;/AL&gt;";
			else
				xml := xml &amp; "&lt;AL&gt;0&lt;/AL&gt;";
			endif;
			xml := xml &amp; "&lt;CL&gt;" &amp; aBay.id &amp; "&lt;/CL&gt;";
			xml := xml &amp; "&lt;OSC&gt;" &amp; aBay.onShipCrane.String &amp; "&lt;/OSC&gt;";
			theHold := aBay.myHold;
		endforeach;
	endif;
	xml := xml &amp; "&lt;/CLS&gt;";
	
	foreach aBay in self.allBayVoyagesByOrdinal  do
		// each tier within the bay is a grid point in the grid area
		bayOffset := self.allBayVoyagesByOrdinal.indexOf(aBay.CM_BayVoyage);	//25 Nov 2010	NDL Par 26350
		// #### ON DECK
		foreach aTier in aBay.allTiersOnDeck do
			aTierLabel := aTier.id.trimBlanks;
			if _flipH then
				//theColumn := aBay.ordinalBay;	//25 Nov 2010	NDL Par 26350
				theColumn := bayOffset;	//25 Nov 2010	NDL Par 26350
			else
				//theColumn := ((totalBays - aBay.ordinalBay) + 1);	//25 Nov 2010	NDL Par 26350
				theColumn := ((totalBays - bayOffset) + 1);	//25 Nov 2010	NDL Par 26350
			endif;		
			xml := xml &amp; aTier.getXMLGridSideProfile(tierLabels.indexOf(aTierLabel),theColumn);
		endforeach;
		// ## UNDER DECK
		foreach aTier in aBay.allTiersUnderDeck do
			aTierLabel := aTier.id;
			if _flipH then
				//theColumn := aBay.ordinalBay;	//25 Nov 2010	NDL Par 26350
				theColumn := bayOffset;	//25 Nov 2010	NDL Par 26350
			else
				//theColumn := ((totalBays - aBay.ordinalBay) + 1);	//25 Nov 2010	NDL Par 26350
				theColumn := ((totalBays - bayOffset) + 1);	//25 Nov 2010	NDL Par 26350
			endif;
			//tml := aTier.getXMLGridSideProfile( (tierLabels.indexOf(aTierLabel) - theUDTierAdjustment),theColumn);
			tml := aTier.getXMLGridSideProfile(tierLabels.indexOf(aTierLabel),theColumn);	//25 Nov 2010	NDL Par 26350 - not drawing all tirs when a common OD tier not found.
			
			xml := xml &amp; tml;
		endforeach;
	endforeach;	
	xml := xml &amp; "&lt;/GA&gt;";
	app.cmsEndLoad(ls);
	
// cnwdad1 25/02/2009 - PAR #18366.
//	return xml.compress;
	return xml.compressToBinary(Binary.Compression_ZLib);
epilog
	app.cmsEndLoad(ls);			// 08/04/2011 cnwmh5 #27347
	delete tierLabels;
	delete tierLabelsUD;
	delete tierLabelsRightThru;
end;</source>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_theHolds" type="ObjectArray"/>
        <Parameter name="_flipH" type="Boolean"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="hasOOWCreationGotJobs" id="39adb9ec-1f35-4f9c-acdb-c8adc6cac597">
        <source>hasOOWCreationGotJobs() : Boolean;
// ---------------------------------------------------------------------------
// Created:		30 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	oowc : CM_OOWCreation;
begin
	foreach oowc in self.allOOWCreations do
		if not oowc.allJobs.isEmpty then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTripleBays" id="70040a8e-09e7-4ae2-8004-cb1bc53ef84f">
        <source>hasTripleBays() : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
begin
	foreach aBay in self.allBayVoyagesByOrdinal do
		if aBay.bayType = BAY_TYPE_TRIPLE then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasVoyageStartedPlanning" id="793d701f-aeb1-4f3e-97a1-7b611a52d399">
        <source>hasVoyageStartedPlanning(_mess : String io; errorCodes : IntegerArray input) : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2006 By Andrew Bishop cnwab1
//
// Purpose:		They can have Jobs and SlotRequests, but nothing else.
//
// ---------------------------------------------------------------------------
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	aBay : CM_BayVoyage;
	sc : CM_SlotController;
	aJob : CM_Job;
begin
	if self.myVoyage.allVoyageJobs.isEmpty then
		return false;
	endif;
	
	if self.myVoyage.allJobSheets.isEmpty then
		//_mess := _mess &amp; "Voyage has no cranes allocated. Cannot produce OOW." &amp; Cr; //- cnwmd1, Par 20524
		_mess := _mess &amp; app.getErrorString(Voyage_cranes_alloca_cannot_pr) &amp; Cr;
		errorCodes.add(Voyage_cranes_alloca_cannot_pr);	//13 Sep 2012	NDL	Par 30366
	endif;
	if self.myVoyage.departedDT.isValid() 
	and app.actualTimeServer &gt; self.myVoyage.departedDT  then	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		//_mess := _mess &amp; "Voyage has departed (" &amp; self.myVoyage.departedDT.date.shortFormatJMT() &amp; ")" &amp; Cr; //- cnwmd1, Par 20524
		_mess := _mess &amp; app.getErrorString1(Voyage_departed,self.myVoyage.departedDT.date.shortFormatJMT()) &amp; Cr;
		errorCodes.add(Voyage_departed);	//13 Sep 2012	NDL	Par 30366
	endif;
	
	foreach aJob in self.myVoyage.allVoyageJobs where aJob.status &lt;&gt; JOB_UNACTIONED do
		//_mess := _mess &amp;  "Voyage has (part) completed jobs." &amp; Cr; //- cnwmd1, Par 20524
		_mess := _mess &amp;  app.getErrorString(Voyage_part_complet_jobs) &amp; Cr;
		errorCodes.add(Voyage_part_complet_jobs);	//13 Sep 2012	NDL	Par 30366
		break;
	endforeach;
	
	foreach aBay in self.allBayVoyagesByOrdinal do : outerLoop
		foreach sc in aBay.allSlotControllersByOrdinal do
			if sc.hasPlannedTIs(true) or sc.hasPlannedTIs(false) then
				//_mess := _mess &amp; "Voyage has planned moves (" &amp; sc.getFullId() &amp; ")." &amp; Cr; //- cnwmd1, Par 20524
				_mess := _mess &amp; app.getErrorString1(Voyage_planned_moves, sc.getFullId()) &amp; Cr;
				errorCodes.add(Voyage_planned_moves);	//13 Sep 2012	NDL	Par 30366
				break outerLoop;
			endif;
			if not sc.allQueuedFutureMoves.isEmpty then
				//_mess := _mess &amp; "Voyage has queued moves." &amp; Cr; //- cnwmd1, Par 20524
				_mess := _mess &amp; app.getErrorString(Voyage_queued_moves) &amp; Cr;
				errorCodes.add(Voyage_queued_moves);	//13 Sep 2012	NDL	Par 30366
				break outerLoop;
			endif;
			
		endforeach;
	endforeach;
	if _mess = null then
		return false;
	else
		return true;
	endif;
end;</source>
        <Parameter name="_mess" type="String" usage="io"/>
        <Parameter name="errorCodes" type="IntegerArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasVoyageWorkStarted" id="996bbb1c-a25f-4f8c-8f1a-d7d99fe4469f">
        <source>hasVoyageWorkStarted() : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		if they have done any colour coding or defined any jobs then they have started working the ship
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_BayVoyage;
begin
	if not self.myVoyage.allVoyageJobs.isEmpty then
		return true;
	endif;
	
	foreach aBay in self.allBayVoyagesByOrdinal do
		if not aBay.allSlotRequestByMoveType.isEmpty then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="identity" id="18a40833-45a6-4e9c-9c29-e9fb6d12aa35">
        <source>identity(): String;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myVoyage.identity();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isLoadedToOperations" id="abecfa79-86d7-4b78-a7aa-22524c6ebf4c">
        <source>isLoadedToOperations() : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		Have we any jobs loaded to the ship ops screen
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	job : CM_Job;
begin
	foreach job in self.myVoyage.allVoyageJobs do
		if job.CM_VoyageJob.isLoadedToOperations then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOOWCraneBefore" id="12d31d03-1bfd-4814-89df-7dcf459eb92b">
        <source>isOOWCraneBefore(_first, _second : CM_VoyageJobSheet) : Boolean;
// ---------------------------------------------------------------------------
// Created:		10 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		is 1st before 2nd
//
// ---------------------------------------------------------------------------
vars
	aJS : CM_VoyageJobSheet;
	oowc : CM_OOWCreationDetail;
	aCrane : CM_Crane;
begin

	foreach oowc in self.allOOWCreations  reversed do
		aJS := oowc.myCraneJobSheet;
		if aJS &lt;&gt; null then
			if aJS = _first then
				return false;
			endif;
			if aJS = _second then
				return true;
			endif;
		endif;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="_first" type="CM_VoyageJobSheet"/>
        <Parameter name="_second" type="CM_VoyageJobSheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lookupBayVoyage" id="ea2b1b50-ccb4-431a-b2fd-59db64670403">
        <source>lookupBayVoyage(_bayId : String) : CM_BayVoyage;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27 September 2002	DQ	We now store the bayVoyages here, and have dicts. This has been 
//													altered to look for an id of a bay
// ---------------------------------------------------------------------------

vars
	bv : CM_BayVoyage;
begin
	bv := self.allBayVoyagesById[_bayId];
	if bv &lt;&gt; null then
		return bv;
	endif;
	return self.allBayVoyagesById40[_bayId];
end;</source>
        <Parameter name="_bayId" type="String"/>
        <ReturnType type="CM_BayVoyage"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9ed2eabf-7bcb-44ff-a738-c1e87f8ba6df">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return inheritMethod();

	// ########################################################################
	// ########################################################################
	// ### DO NOT CALL THE HOLD/BAY/CELL/TIER/SLOT/LIDS proxy creation from here. 
	// ### Certain forms do not need the structure proxied. So it is done locally.
	// ########################################################################
	// ########################################################################
	
end;

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy
	
	/* moved to pxyCreateUpdateProxyStructure
	foreach aHold in self.allHolds do
		pHold := aHold.pxyCreateUpdateProxy();
		
		pHold.CM_VoyageHold.setProxy(proxyVoyage,pHold.ordinalHold);
	endforeach;

	foreach realBayVoyage in self.allBayVoyagesById do

		pxyBayVoyage := realBayVoyage.pxyCreateUpdateProxy;
		pxyBayVoyage.setMyVoyage(proxyVoyage);
		
		// use the ordinal of the real hold to get the proxy hold
		if realBayVoyage.myHold &lt;&gt; null then
			pHold := proxyVoyage.allHolds[realBayVoyage.myHold.ordinalHold];
			// set the proxy bay into the proxy hold
			pxyBayVoyage.setMyHold(pHold);
		endif;
		// &lt;&lt;&lt;&lt; HATCHLID STUFF
		// ############################
		// HATCH LIDS - 'addBayVoyage' needs the voyage and hold set on the bay before it will work
		foreach aLid in pxyBayVoyage.allHatchLids do
			aLid.CM_HatchLidVoyage.addBayVoyage(pxyBayVoyage);
		endforeach;
	endforeach;

	previousBayVoyage := null;
	// link up our proxy bays to each other
	foreach pxyBayVoyage in proxyVoyage.allBayVoyagesByOrdinal do //allBayVoyagesById do
		if previousBayVoyage &lt;&gt; null then
			previousBayVoyage.setMyAftBay(pxyBayVoyage);
		endif;
		previousBayVoyage := pxyBayVoyage;
	endforeach;
	
	// link up our proxy slots to each other
	foreach pxyBayVoyage in proxyVoyage.allBayVoyagesByOrdinal do
		//need aftBays to be set - can't do this step in loop above 
		pxyBayVoyage.updateSlotLinks();
	endforeach;
*/</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxyStructure" id="93d2c515-404c-4974-947d-628090ea5d9e">
        <source>pxyCreateUpdateProxyStructure(_proxyStructure : CM_CellularVoyageStructure); // see reference from CM_Voyage::pxyCreateUpdateProxyStructure
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		Create proxy holds, lids, bays, cells, tiers and slots seperately so that the voyage call screen loads quicker for edit.
//				
// ---------------------------------------------------------------------------
vars
	aLid : CM_HatchLid;
	pxyBayVoyage,realBayVoyage,previousBayVoyage:CM_BayVoyage;
	aHold,pHold : CM_Hold;	
begin

	
	foreach aHold in self.allHolds do
		pHold := aHold.pxyCreateUpdateProxy();
		
		pHold.CM_VoyageHold.setProxy(_proxyStructure,pHold.ordinalHold);
	endforeach;

	foreach realBayVoyage in self.allBayVoyagesById do

		pxyBayVoyage := realBayVoyage.pxyCreateUpdateProxy;
		pxyBayVoyage.setMyVoyageStructure(_proxyStructure);
		
		// use the ordinal of the real hold to get the proxy hold
		if realBayVoyage.myHold &lt;&gt; null then
			pHold := _proxyStructure.allHolds[realBayVoyage.myHold.ordinalHold];
			// set the proxy bay into the proxy hold
			pxyBayVoyage.setMyHold(pHold);
		endif;
		// &lt;&lt;&lt;&lt; HATCHLID STUFF
		// ############################
		// HATCH LIDS - 'addBayVoyage' needs the voyage and hold set on the bay before it will work
		foreach aLid in pxyBayVoyage.allHatchLids do
			aLid.CM_HatchLidVoyage.addBayVoyage(pxyBayVoyage);
		endforeach;
	endforeach;

	previousBayVoyage := null;
	// link up our proxy bays to each other
	foreach pxyBayVoyage in _proxyStructure.allBayVoyagesByOrdinal do //allBayVoyagesById do
		if previousBayVoyage &lt;&gt; null then
			previousBayVoyage.setMyAftBay(pxyBayVoyage);
		endif;
		previousBayVoyage := pxyBayVoyage;
	endforeach;
	
	// link up our proxy slots to each other
	foreach pxyBayVoyage in _proxyStructure.allBayVoyagesByOrdinal do
		//need aftBays to be set - can't do this step in loop above 
		pxyBayVoyage.updateSlotLinks();
	endforeach;
end;</source>
        <Parameter name="_proxyStructure" type="CM_CellularVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="reAdjustIfSplitHold" id="a38f3a50-f2da-4198-a00d-b51c25206695">
        <updating/>
        <source>reAdjustIfSplitHold(_controller :CMIF_OOWCreationAutoUpdate;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		20 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		if we have split colour coding across holds then we ought to switch 
//					the colour coding in the hold that was split between the cranes involved.
//
//					We do this because discharges are done first and then loads
//					if we split the work the last thing the first crane wants to do is discharge, 
//					BUT the first thing the 2nd crane wants to do is load. It cannot load because the discharge has not been done.
//
// ---------------------------------------------------------------------------
vars
	crane1, crane2 : CM_Crane;
	oow1, oow2 : CM_OOWCreation;
	js1, js2 : CM_VoyageJobSheet;
	vj1, vj2 : CM_VoyageJob;
	bay1, bay2 : CM_Bay;
	theHold : CM_Hold;
	oows1, oows2 : CM_OOWCreationByOrdinal;
	anObj : Object;
	idx, idNx, ennd, oowOrd : Integer;
	bf1, bf2, af1, af2 : Integer;
begin
	if _controller = null then
		return;
	endif;
	
	if not _controller.splitHolds then
		return;
	endif;
	
	if _controller.allCranes.isEmpty then
		return;
	endif;
	
	create oows1 transient;
	create oows2 transient;
	
	ennd := _controller.allCranes.size;
	
	foreach idx in 1 to ennd do
		idNx := idx + 1;
		oows1.clear;
		oows2.clear;
		
		if idNx &gt; ennd then
			break;
		endif;
		
		crane1 := _controller.allCranes[idx].CM_Crane;
		crane2 := _controller.allCranes[idNx].CM_Crane;
		
		js1 := self.myVoyage.allJobSheets[crane1.id];
		js2 := self.myVoyage.allJobSheets[crane2.id];
		
		
		oow1 := js1.allOOWCreations.last;
		oow2 := js2.allOOWCreations.first;
	
		if oow1 = null  or oow2 = null then
			return;
		endif;
		// The last on one crane is in the same hold to the next crane
		if oow1.myBay.myHold = oow2.myBay.myHold then
			theHold := oow1.myBay.myHold;
			oowOrd := 0;
			foreach oow1 in js1.allOOWCreations do
				if oow1.myBay.myHold = theHold then
					if oowOrd = 0 then
						oowOrd := oow1.order; // we need to remember the first ordinal, so that we can re use the ordinals to number the ordinals after the switch
					endif;
					oow1.setJobSheet(null);
					oow1.setOrder(oow1.order + 90000); // add 90000 to stop duplicate errors
					oows1.add(oow1.CM_OOWCreationDetail);
				endif;
			endforeach;

			foreach oow2 in js2.allOOWCreations do
				if oow2.myBay.myHold = theHold then
					oow2.setJobSheet(null);
					oow2.setOrder(oow2.order + 90000); // add 90000 to stop duplicate errors
					oows2.add(oow2.CM_OOWCreationDetail);
				endif;
			endforeach;
			
			bf1 := js1.getTotalOOWItems();
			bf2 := js2.getTotalOOWItems();
			
			// switch the OOWs from this hold between the 2 job sheets 
			foreach oow2 in oows2 do
				oow2.setJobSheet(js1);
				oow2.setOrder(oowOrd);
				oowOrd := oowOrd + 100;
			endforeach;

			foreach oow1 in oows1 do
				oow1.setJobSheet(js2);
				
				oow1.setOrder(oowOrd);
				oowOrd := oowOrd + 100;
			endforeach;
			af1 := js1.getTotalOOWItems();
			af2 := js2.getTotalOOWItems();
			
		endif;
		
	endforeach;
epilog
	delete oows1;
	delete oows2;
end;</source>
        <Parameter name="_controller" type="CMIF_OOWCreationAutoUpdate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="reOrderOOWForCreate" id="612a2dc3-fba0-451d-aa81-22ae308b31e7">
        <source>reOrderOOWForCreate();
// ---------------------------------------------------------------------------
// Created:		22 May 2006 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
vars
	aCrane : CM_Crane;
	incr, idx, st, en, craneType : Integer;
	holdOrd, bayOrd, loadDischOrd, deckOrd, ord2040, jsOrd : Integer;
	lastBay,aBay : CM_BayVoyage;
	aHold, lastDischHold : CM_Hold;
	isTL, isDisch, isLoad,  isSOB, craneJnt2040L, craneJnt2040D, lastOOWwasDischarge, isCraneReversed : Boolean;
	oowc : CM_OOWCreation;
	newOrder : CM_OOWCreationByHoldDeckBayDct;
	lastOrdDeck, lastOrdHold : Integer;
begin
	create newOrder transient;
	st := 999999;
	lastOrdDeck := -1;
	
	foreach oowc in self.allOOWCreations do
		holdOrd := 0;
		bayOrd := 0;
		loadDischOrd := 0;
		deckOrd := 0;
		ord2040	 := 0;
		aHold := null;
		craneType := oowc.getCraneType();
		craneJnt2040L := self.getOOWSameJobFor2040(false,craneType);
		craneJnt2040D := self.getOOWSameJobFor2040(true,craneType);
		isCraneReversed := oowc.isCraneReversed();
		isDisch := oowc.CM_OOWCreationDetail.isDischarge();
		isLoad := oowc.CM_OOWCreationDetail.isLoad();
		isSOB := oowc.CM_OOWCreationDetail.isSOB();
		if lastOrdDeck &lt;&gt; -1 and oowc.ordinalDeck &lt;&gt; lastOrdDeck then
			lastDischHold := null; // RESET if change deck or hold
		endif;
		
		aBay := oowc.myBay;
		if aBay &lt;&gt; null then

			aHold := aBay.myHold;
			lastOrdHold := 0;
			if aHold &lt;&gt; null then
				if oowc.myCraneJobSheet = null then
					holdOrd := aHold.ordinalHold;
					if lastOrdHold &lt;&gt; holdOrd then
						lastDischHold := null; // RESET if change deck or hold
					endif;
					lastOrdHold := holdOrd;
					
					jsOrd := 1;
				else
					jsOrd := self.myVoyage.allJobSheetsInOrder.indexOf(oowc.myCraneJobSheet);
					holdOrd := oowc.myCraneJobSheet.getHoldOrdinalForOOW(aHold.ordinalHold); // handles reversing the ordinal if crane is working in reverse
				endif;
			else
				continue;
			endif;
			
			// ### if this is a load and the last discharge job was for the same bay then do the bays in this hold in reverse (to save moving the crane)
			lastOOWwasDischarge := false;
			if isLoad then // is LOAD
				lastOOWwasDischarge := (aHold = lastDischHold);
			endif;
//			lastOOWwasDischarge := false;
			if isCraneReversed then // PAR 13052
				lastOOWwasDischarge := not lastOOWwasDischarge;
			endif;
			bayOrd := aBay.getBayOrdinalForOOW(lastOOWwasDischarge);// 1 or 2 //ordinalBay;
		else
			continue;
		endif;
		
		if isDisch or isSOB then
			lastDischHold := aHold;
		endif;
		if oowc.CM_OOWCreationDetail.is40 then
			// PAR 15581 - basically if this is a TL crane, but because of the defn of the bay TL cannot be done, treat as a SL so that the 40 goes first
			if (craneType = JobTypePriority_Crane2 and not oowc.isTwinLiftCapable()) then
				if isSOB then
					ord2040 := self.getOOWOrderFor40(true,JobTypePriority_Crane1); // 0 or 10
				else
					ord2040 := self.getOOWOrderFor40(isDisch,JobTypePriority_Crane1); // 0 or 10
				endif;
			else
				if isSOB then
					ord2040 := self.getOOWOrderFor40(true,craneType); // 0 or 10
				else
					ord2040 := self.getOOWOrderFor40(isDisch,craneType); // 0 or 10
				endif;
			
			endif;
			if craneType = JobTypePriority_Crane1 and (isDisch or isSOB)  and craneJnt2040D then // Single lift and joint discharge jobs
				// do not change bay ordinal for 40
			elseif craneType = JobTypePriority_Crane1 and isLoad and craneJnt2040L then // Single lift and joint load jobs
				// do not change bay ordinal for 40
			else
				bayOrd := ord2040;
			endif;
		else
			ord2040 := 1;
		endif;
		
		if isDisch or isSOB then 
			loadDischOrd := 1;
			if oowc.ordinalDeck = DeckUnderDeck then
				deckOrd := 200 + ord2040;
			else
				deckOrd := 100 + ord2040;
			endif;

		else
			loadDischOrd := 2;
			if oowc.ordinalDeck = DeckUnderDeck then
				deckOrd := 100; // + ord2040;
			else
				deckOrd := 200; // + ord2040;
			endif;
		endif;
		

		st := st.min(oowc.order);
		en := en.max(oowc.order);
		
		loadDischOrd := ((loadDischOrd * 1000) + deckOrd + bayOrd);
		// ### sort into Hold, Discharge then Load, Deck, Bay order
		holdOrd := (jsOrd * 10000) + holdOrd;
		

		
		newOrder.putAtKey(holdOrd,loadDischOrd,ord2040,oowc);
		lastOrdDeck := oowc.ordinalDeck;
	endforeach;

	idx := 9000000;
	foreach oowc in newOrder do
		oowc.setOrder(idx);
		idx := idx + 1;
	endforeach;

	idx := 100;
	incr := 100;
	foreach oowc in newOrder do
		oowc.setOrder(idx);
		idx := idx + incr;
	endforeach;


epilog
	delete newOrder;
end;</source>
    </JadeMethod>
    <JadeMethod name="reOrderOOWForCreateOLD" id="b980467b-ba36-4a0b-8a30-90ea32e12f2c">
        <source>reOrderOOWForCreateOLD();
// ---------------------------------------------------------------------------
// Created:		22 May 2006 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
vars
	aCrane : CM_Crane;
	incr, idx, st, en, hOrd, bOrd, dOrd : Integer;
	lastBay,aBay : CM_BayVoyage;
	aHold : CM_Hold;
	isTL : Boolean;
	oowc : CM_OOWCreation;
	newOrder : CM_OOWCreationByHoldDeckBayDct;
begin
	create newOrder transient;
	st := 999999;
	foreach oowc in self.allOOWCreations do
		bOrd := 0;
		hOrd := 0;
		dOrd := 0;
		
		aBay := oowc.myBay;
		if aBay &lt;&gt; null then
			bOrd := aBay.ordinalBay;
			aHold := aBay.myHold;
			if aHold &lt;&gt; null then
				hOrd := aHold.ordinalHold;
			else
				continue;
			endif;
		else
			continue;
		endif;
		if oowc.ordinalDeck = 1 then
			dOrd := 2;
		else
			dOrd := 1;
		endif;

		if oowc.CM_OOWCreationDetail.is40 then
			hOrd := 999;
		endif;
		
		st := st.min(oowc.order);
		en := en.max(oowc.order);
		newOrder.putAtKey(bOrd,dOrd,hOrd,oowc);
		
	endforeach;

	idx := 9000000;
	foreach oowc in newOrder do
		oowc.setOrder(idx);
		idx := idx + 1;
	endforeach;

	idx := 100;
	incr := 100;
	foreach oowc in newOrder do
		oowc.setOrder(idx);
		idx := idx + incr;
	endforeach;


epilog
	delete newOrder;
end;</source>
    </JadeMethod>
    <JadeMethod name="reOrderOOWForCreateOLD2" id="281183ab-eaf9-429a-a3f8-47f702de3cf0">
        <source>reOrderOOWForCreateOLD2();
// ---------------------------------------------------------------------------
// Created:		22 May 2006 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
vars
	aCrane : CM_Crane;
	incr, idx, st, en, hOrd, bOrd, dOrd : Integer;
	lastBay,aBay : CM_BayVoyage;
	aHold : CM_Hold;
	isTL, isDisch : Boolean;
	oowc : CM_OOWCreation;
	newOrder : CM_OOWCreationByHoldDeckBayDct;
begin
	create newOrder transient;
	st := 999999;
	foreach oowc in self.allOOWCreations do
		bOrd := 0;
		hOrd := 0;
		dOrd := 0;
		
		aBay := oowc.myBay;
		if aBay &lt;&gt; null then
			bOrd := aBay.ordinalBay;
			aHold := aBay.myHold;
			if aHold &lt;&gt; null then
				hOrd := aHold.ordinalHold;
			else
				continue;
			endif;
		else
			continue;
		endif;
		
		isDisch := oowc.CM_OOWCreationDetail.isDischarge();

		if oowc.CM_OOWCreationDetail.is40 then
			hOrd := self.getOOWOrderFor40(isDisch,oowc.getCraneType());
		endif;

		if oowc.ordinalDeck = 1 then // UNDER DECK
			if isDisch then
				dOrd := 200 + hOrd;
			else
				dOrd := 100 + hOrd;
			endif;
		else // ON DECK
			if isDisch then
				dOrd := 100 + hOrd;
			else
				dOrd := 200 + hOrd;
			endif;
		endif;

		if isDisch then
			hOrd := 2;
		else
			hOrd := 1;
		endif;
		
		
		st := st.min(oowc.order);
		en := en.max(oowc.order);
		newOrder.putAtKey(bOrd,dOrd,hOrd,oowc);
		
	endforeach;

	idx := 9000000;
	foreach oowc in newOrder do
		oowc.setOrder(idx);
		idx := idx + 1;
	endforeach;

	idx := 100;
	incr := 100;
	foreach oowc in newOrder do
		oowc.setOrder(idx);
		idx := idx + incr;
	endforeach;


epilog
	delete newOrder;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDrawingDefinition" id="9ed8b9b3-54d3-4008-a3a2-37a70e881f9c">
        <source>setDrawingDefinition() :Binary;
// ---------------------------------------------------------------------------
// Created:     10 September 2003 by cnwrs2
//
// Purpose:      Get and stores the XML, compressed, that is used to draw the voyage in the GUI - Voyage Planning form
// ---------------------------------------------------------------------------
vars

begin

	return self.getXMLGridDefinition();

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8128f143-a636-4c82-87c0-6a0972185aee">
        <updating/>
        <source>setForCreate(_proxyVoyage: CM_CellularVoyageStructure; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/10/2011	cnwmh5		#28444 - Change so on a create gets vessel's tank and section details if the exist
// 27/03/2013	PJS			PAR # 31232 - Voyage rationalisation
// ---------------------------------------------------------------------------

vars
	vessel					: CM_Vessel;
	cellularStructure 		: CM_CellularVesselStructure;
begin

	inheritMethod(_proxyVoyage, _passport);
	
	// This lot is set in self.setForCreateInternal() from the vessel
	// so don't overwrite them
	if self.bridgeAfterBay = null then
		self.bridgeAfterBay := _proxyVoyage.bridgeAfterBay;
	endif;

	if self.isoHalfHeights = null then
		self.isoHalfHeights := _proxyVoyage.isoHalfHeights;
	endif;
	if self.use40Id = null then
		self.use40Id := _proxyVoyage.use40Id;
	endif;
	if self.useBayCellTierNumbering = null then
		self.useBayCellTierNumbering := _proxyVoyage.useBayCellTierNumbering;
	endif;
	//	self.setType(_proxyVoyage.type);	// PAR 21745 CCMS MES 1031  // 31232
		
	// on create set the planning side to the berthing side
	self.isStarboardPlanned := self.myVoyage.starboardBerthed;

	vessel:=app.myRoot.allVessels[self.myVoyage.vesselCode];
epilog
end;</source>
        <Parameter name="_proxyVoyage" type="CM_CellularVoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="a13d9e43-5d66-47e0-ae3b-5ba5ac66ba0f">
        <updating/>
        <source>setForCreateInternal(_vesselStructure : CM_CellularVesselStructure; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
// Purpose:     	Create the voyage.
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	16 Jan 2003		DWQ		Completely re-hashed, now called exclusively 
//from the Vessel object (CM_Vessel::createVoyage)
//
// 27 Mar 2013	PJS			PAR # 31232
// ---------------------------------------------------------------------------
vars
begin
	
	//--------------------
	//Copy over vessel specific stuff
	//--------------------
	if _vesselStructure = null then
		return;
	endif;
	
	self.bridgeAfterBay := _vesselStructure.bridgeAfterBay;
	self.isoHalfHeights := _vesselStructure.isoHalfHeights;
	self.use40Id := _vesselStructure.use40Id;
	self.useBayCellTierNumbering := _vesselStructure.useBayCellTierNumbering;
	//epr par 27566 20/5/2011 
	//self.setType(_vesselStructure.myVessel.structureType);	// PAR 21745 CCMS MES 1031 // 31232
	
end;</source>
        <Parameter name="_vesselStructure" type="CM_CellularVesselStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCellular" id="052b4e23-5ccd-445c-9dc0-4e2848648dd4">
        <updating/>
        <source>setForUpdateCellular(_hasStructure, _includeStructure : Boolean;_proxyVoyage : CM_CellularVoyageStructure; _passport : CM_Passport input) updating;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
//-----------------------------------------
// Use to update only the cellular data including structures
// 27 Mar 2013		PJS		PAR # 31232
vars

begin

	if _hasStructure
	and self.allBayVoyagesByOrdinal.isEmpty then
		self.createPlanningStructures(null);
	else							//cnwas3 par23535
		self.bridgeAfterBay := _proxyVoyage.bridgeAfterBay;
		self.use40Id := _proxyVoyage.use40Id;
		self.isoHalfHeights := _proxyVoyage.isoHalfHeights;
	//	self.setType(_proxyVoyage.type);	// PAR 21745 CCMS MES 1031   // 31232
	endif;

	// only update the planning side if we are not actually working the voyage
	if (not self.isLoadedToOperations()) then
		self.isStarboardPlanned := self.myVoyage.starboardBerthed;
	endif;	
	
	if _includeStructure then
		self.setForUpdateStructure(_proxyVoyage, false, _passport);
	endif;
	
end;</source>
        <Parameter name="_hasStructure" type="Boolean"/>
        <Parameter name="_includeStructure" type="Boolean"/>
        <Parameter name="_proxyVoyage" type="CM_CellularVoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateStructure" id="01b738f8-80e0-42fe-87e5-b6fa8ef69d01">
        <updating/>
        <source>setForUpdateStructure(_proxyVoyage : CM_CellularVoyageStructure; _deleteStructure : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		Seperated out so that updates of the dates, codes and descriptions from Ship Call are faster
// ---------------------------------------------------------------------------
vars
	theBayVoyage : CM_BayVoyage;
	theProxyBay,realBay : CM_Bay;
	delLids : ObjectArray;
	pxyLid, realLid : CM_HatchLid;
	proxyHold,aHold : CM_Hold;
	isDelete : Boolean;
begin

	// the proxy voyage has its own proxy holds. Use them to create real holds for this real voyage
	foreach proxyHold in _proxyVoyage.allHolds do
		if self.allHolds[proxyHold.ordinalHold] = null then
			create aHold as CM_VoyageHold;
			aHold.CM_VoyageHold.setProxy(self,proxyHold.ordinalHold);
		endif;
	endforeach;

	//epr par 37218 7/1/16
	foreach realBay in self.allBayVoyagesById do		
		realBay.setOrdinalBayOff( CM_Bay.BayOrdinalOffset );	
	endforeach;
	
	//need to check this for empty because the real could be updated in setForUpdate and
	//the proxy's collection will still be empty
	if not _proxyVoyage.allBayVoyagesByOrdinal.isEmpty then
		// update each of the bays through the TRX Util layer
		foreach theProxyBay in _proxyVoyage.allBayVoyagesByOrdinal do
			if theProxyBay.pxyIsProxy then // UPDATE
				app.myUtilityUA.utlUpdateBay(true,theProxyBay,app.myPassport); //epr 37218 7/1/16 skip edition we have already updated bays ordinal to avoid a 1310
			endif;
		endforeach;
		// DELETE bays
		foreach realBay in self.allBayVoyagesByOrdinal do
			isDelete := (realBay.pxyGetProxyObject = null);
			if isDelete then
				app.myUtilityDA.utlDeleteBay(realBay,app.myPassport);
			endif;
		endforeach;
		// create each of the bays through the TRX Util layer
		foreach theProxyBay in _proxyVoyage.allBayVoyagesByOrdinal do
			if not theProxyBay.pxyIsProxy then // CREATE
				app.myUtilityCA.utlCreateBay(theProxyBay,realBay,self,app.myPassport);
			endif;
		endforeach;
// PAR 33644	elseif self.myVoyage.isNonPlannedVoyage
	elseif not self.myVoyage.structureIncludesLOLO()
	or _deleteStructure then // or self.isNonWorkedVoyage then PAR 11076/11157/8727 structures are needed if it's planned
		// DELETE bays only if nonPlanned or asked to CCMS 1009
		foreach realBay in self.allBayVoyagesByOrdinal do
			isDelete := (realBay.pxyGetProxyObject = null);
			if isDelete then
				app.myUtilityDA.utlDeleteBay(realBay,app.myPassport);
			endif;
		endforeach;
	endif;
	
	self.updateBayLinks();

	// PAR 8129. Having re linked the bays, now re link the slots in the bays. This was being done as par tof the bay update above
	foreach realBay in self.allBayVoyagesByOrdinal do
		realBay.updateSlotLinks();
		realBay.setSequenceNums();
	endforeach;

	//-------------------------
	//If the bayCellTier number changes, re-do the slot ids
	//-------------------------
	if self.useBayCellTierNumbering &lt;&gt; _proxyVoyage.useBayCellTierNumbering then
		self.useBayCellTierNumbering := _proxyVoyage.useBayCellTierNumbering;
		//----------------
		//We have to reset the Id's
		//----------------
		foreach theBayVoyage in self.allBayVoyagesByOrdinal do
			theBayVoyage.setSlotIds;
		endforeach;
	endif;

	// the LIDS to be deleted will have no proxy link
	create delLids transient;
	foreach realLid in self.allHatchLids do
		if realLid.pxyGetProxyObject = null then
			delLids.add(realLid);
		endif;
	endforeach;
	delLids.purge();

	if _proxyVoyage.allHatchLids.isEmpty = false then
		foreach pxyLid in _proxyVoyage.allHatchLids do
			if pxyLid.isKindOf(CM_HatchLidVoyage) then
				realLid := pxyLid.pxyGetRealObject();

				if realLid = null then //not pxyLid.pxyIsProxy then
					app.myUtilityCA.utlCreateHatchLid(pxyLid,realLid,self,app.myPassport);
					if not app.myPassport.noErrors then
						break;
					endif;
				else // added this in so that hatchlid could be assigned to a bay during update of lid
					realLid.setForUpdate(pxyLid,_passport);
				endif;
			endif;
		endforeach;
	endif;

	self.setOutboardSlots();
	self.xmlSideProfilePort := self.getXMLGridSideProfile(true, ShpDisplayMode_Defn, null, true);
	self.xmlSideProfileStarboard := self.getXMLGridSideProfile(true, ShpDisplayMode_Defn, null, false);

	//JC removed - used in old ship planning 3/8/2004  AKB said so.
	//self.setDrawingDefinition(); // this is the XML, compressed, that is used to draw the voyage in the GUI - Voyage Planning form
epilog
	delete delLids;

end;</source>
        <Parameter name="_proxyVoyage" type="CM_CellularVoyageStructure"/>
        <Parameter name="_deleteStructure" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOutboardSlots" id="dbf82ec0-aafd-4cf0-a234-25dbdf46f0fc">
        <updating/>
        <source>setOutboardSlots() updating;
/*
------------------------------------------------------------------------
Created:			04 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	bay : CM_Bay;
begin
	foreach bay in self.allBayVoyagesByOrdinal do
		bay.setOutboardSlots();
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyCellularVoyage" id="0a976b3d-d6c0-4197-81ec-e879c4901825">
        <updating/>
        <source>setProxyCellularVoyage(_bridgeAfterBay : String; _isoVessel, _use40Id, _useBayCellTierNumbering : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.bridgeAfterBay := _bridgeAfterBay;
	self.isoHalfHeights := _isoVessel;
