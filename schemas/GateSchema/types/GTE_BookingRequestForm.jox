        <updating/>
        <source>mnuTblViewContext_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2016	cnwma1	Initial creation
13/12/2016			cnwma1	Tfs #3059*:Context menu causing 1090 error on Bookings Screen
*/

vars
	tmpMenu				: MenuItem;
begin
		tmpMenu			:=	self.mnuViewBKItemAudits;
		tmpMenu.enabled:=false;
		if self.tblBookingItems.allSelectedObjects.first.CM_Object &lt;&gt; null then   //13/12/2016 cnwma1 TFS #3059
			tmpMenu.enabled:=true;
			tmpMenu.caption	:=	"View Audits for " &amp; self.tblBookingItems.allSelectedObjects.first.CM_Object.auditIdDisplay;
		endif;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
