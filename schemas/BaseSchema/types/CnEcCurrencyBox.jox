        <type name="CurrencyFormat"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="cnEcDate" id="58a40ccf-423c-4231-8dce-736d527dadb3">
        <source>cnEcDate(): Date;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Purpose:		This reimplementation returns a null value since a date value is
//				not relevant in the context of this control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return null;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcDecimal" id="6df8fc7e-ebb4-4e39-8f98-a020a8d01480">
        <source>cnEcDecimal(): Decimal;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as a Decimal value.
//
// Parameters:	None
//
// Returns:		The decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myCurrencyFormat &lt;&gt; null then 
		return self.text.cnEcAsNumeric(self.myCurrencyFormat).Decimal;
	else
		return self.text.cnEcAsNumeric(null).Decimal;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcInteger" id="2266a1e3-974f-4a73-a136-c47e2487948f">
        <source>cnEcInteger(): Integer;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as an Integer value.
//
// Parameters:	None
//
// Returns:		The integer value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.cnEcAsNumeric(self.myCurrencyFormat).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
