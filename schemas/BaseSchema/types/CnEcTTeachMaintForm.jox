    <JadeMethod name="btnSaveActivity1_click" id="78c0e31c-e0fb-48b6-8110-318b1e4f01a4">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSaveActivity1_click(juice: JadeMask input) updating;

vars
	ok : Boolean;
begin
	ok := doActivitySave();

	if ok = true then
		picPlinthActivity.visible	:= true;
		lstLessons.enabled 			:= true;
		lstActivities.enabled 		:= true;
		self.doPreviewText(true);
	endif;
end;</source>
        <Parameter name="juice" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSaveLesson1_click" id="fd906a49-d231-4677-a6ee-7f9a5bcec978">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSaveLesson1_click(juice: JadeMask input) updating;

vars
 	ok : Boolean;
begin
	ok := self.doLessonSave();

	if ok = true then
		lstLessons.enabled 			:= true;
		lstActivities.enabled 		:= true;
		picPlinthActivity.visible 	:= false;
	endif;
end;</source>
        <Parameter name="juice" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkCheckHasAValue_click" id="8204477f-00b2-4127-b209-b2b621a13b1a">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkCheckHasAValue_click(checkbox: CheckBox input) updating;

begin
	chkHasAValue.enabled := checkbox.value;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkCheckIsEnabled_click" id="943c879b-b83f-4ee8-9a1c-20a124c00f85">
