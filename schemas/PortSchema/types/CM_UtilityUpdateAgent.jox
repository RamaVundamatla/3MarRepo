    <JadeMethod name="utlUpdateInOutFlexiGateEntity" id="c86ce30b-1406-485f-ae8d-055878fc25ff">
        <updating/>
        <source>utlUpdateInOutFlexiGateEntity(_vvr : CM_VehicleVisitRecord input; _pxyGTE : CMGTE_Entity input; 	_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     September 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
//15 May 2025	jlier1	Initial creation MTN-34221 - moved validation to before trx

vars
	realGate, 
	pxySub, 
	realSub			: CMGTE_Entity;
	purgeArray 		: ObjectArray;
	tranNum 		: String;	
	doValidation 	: Boolean;
begin
		
	
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	
	if _vvr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Vehicle Visit Record is null');
		return;
	endif;
	if _vvr.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Vehicle Visit Record is transient');
		return;
	endif;
	
	if _pxyGTE = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'pxyGTE is null');
		return;
	endif;

	// UPDATE
	realGate :=  _pxyGTE.pxyGetRealObject();
	if realGate &lt;&gt; null then
		realGate := self.getRealObjectAndEditionCheck(_pxyGTE, 'Flexi Gate', _passport).CMGTE_Entity;
	endif;
	
	tranNum := _pxyGTE.tranNumber;
	if tranNum = null then
		tranNum := _vvr.getNextTranNumForFlexiGate(); 
	endif;
	
	if realGate = null then
		create realGate as _pxyGTE.class persistent;
		realGate.setForCreate(_pxyGTE, _vvr);
		realGate.setTranNumber(tranNum);
	else
		realGate.setForUpdate(_pxyGTE, _vvr);
	endif;
	
	realGate.setForUpdateErrorsFromPassport(_vvr, _passport);
	create purgeArray transient;
	
	foreach realSub in realGate.allChildren discreteLock do
		pxySub :=  realSub.pxyGetProxyObject();
		if pxySub = null then
			purgeArray.add(realSub);
		endif;
	endforeach;
		
	purgeArray.purge();
		
	// SUB ITEMS - GENERATORS and CHILDREN
	foreach pxySub in _pxyGTE.allChildren discreteLock do
							
		// UPDATE
		realSub :=  pxySub.pxyGetRealObject();
		if realSub &lt;&gt; null then
			realSub := self.getRealObjectAndEditionCheck(pxySub, 'Flexi Gate', _passport).CMGTE_Entity;
		endif;
		if realSub = null then
			create realSub as pxySub.class persistent;
			realSub.setForCreateIfSubItem(pxySub, realGate, tranNum);
		else
			realSub.setForUpdate(pxySub, null);
		endif;
		realSub.setForUpdateErrorsFromPassport(_vvr, _passport);
		realSub.setMyVehicleVisit(null); // dettach
		
	endforeach;

	_vvr.updateJobQueueOrder(null,null);

	if _vvr &lt;&gt; null then
		_vvr.causeEvent(_vvr.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, _vvr);
	endif;

epilog
	
	delete purgeArray;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyGTE" type="CMGTE_Entity" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInOutFlexiGateStatus" id="ea879020-0b70-4038-a6c6-3ea0cf83dfba">
        <updating/>
        <source>utlUpdateInOutFlexiGateStatus(_vvr : CM_VehicleVisitRecord input; _newStatus : Integer; 	_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     October 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------


vars
	pxyGate, realGate, pxySub, realSub		: CMGTE_Entity;
	expectedEdition	: Integer;
	tmpTerm : CM_Terminal;
	tranNum : String;
	
	doValidation : Boolean;
begin
	doValidation := true; // will be configurable
	
	
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	_vvr.validateChangeStatus(_newStatus);
	
	
	if _passport.hasErrors() then
		return;
	endif;
	if _vvr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Vehicle Visit Record is null');
		return;
	endif;
	if _vvr.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Vehicle Visit Record is transient');
		return;
	endif;

	_vvr.updateStatus(_newStatus);

	if _vvr &lt;&gt; null then
		_vvr.causeEvent(_vvr.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, _vvr);
	endif;

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInstructionIssued" id="db382b20-a59e-4d7c-bd2f-0daf5363a4ea">
        <source>utlUpdateInstructionIssued(_pxyInstructionIssued : CM_InstructionsIssued io;
						_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	realInstructionIssued		: CM_InstructionsIssued;
	expectedEdition 		: Integer;
	terminal : CM_Terminal;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyInstructionIssued, 'InstructionIssued proxy');
	
	_pxyInstructionIssued.pxyGetRealObjectAndEdition(realInstructionIssued, expectedEdition);
	self.raiseExceptionIfNull(realInstructionIssued, 'InstructionIssued Type');
	
	_pxyInstructionIssued.validateForUpdate();
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInstructionIssued, true);
	endif;
	
	realInstructionIssued.setForUpdate(_pxyInstructionIssued);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInstructionIssued, false);
	endif;
	
	if _passport.noErrors and _passport.myTerminal &lt;&gt; null then
		if realInstructionIssued.myParent &lt;&gt; null then
			self.updateObjectEdition(realInstructionIssued.myParent);
			//jlier1 29/5/25 MTN-34591 
			if realInstructionIssued.myParent.isKindOf(CM_WorkOrder) then
				terminal:=realInstructionIssued.myParent.getMyTerminal;
				if terminal &lt;&gt; null then
					app.myEventManager.createSingleObjInfoNoteEvt(realInstructionIssued.myParent, terminal.getTerminalEvent(Event_WorkOrder_Update),  realInstructionIssued.myParent);
				endif;
			endif;
			
			self.myUpdateAuditAgent.audUpdateGeneric(realInstructionIssued,false);
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_pxyInstructionIssued" type="CM_InstructionsIssued" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
