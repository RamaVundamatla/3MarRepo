<Class name="CM_ReeferMonitor" id="38b2039f-9129-4265-b017-b5d80913d218">
    <superclass name="CM_TITransaction"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="query"/>
    <PrimAttribute name="firstConnectDT" id="1c7c9555-e42a-4eb2-8b54-e7bdbd04b8af">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="lastDisconnectDT" id="ca5d0efb-fb88-4dcd-aac4-c538d72c32f3">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getFirstConnectDTLocalTZ" id="85c9c272-b9a1-4d6a-8157-546a46dfb61b">
        <source>getFirstConnectDTLocalTZ(): TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.firstConnectDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLastDisconnectDTLocalTZ" id="227778b4-af2d-4151-8438-866ac8a65c51">
        <source>getLastDisconnectDTLocalTZ(): TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.lastDisconnectDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="7548ec4f-58cf-4f6d-9936-66016c0a7bf7">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;
//----------------------------------------------------------------
//	Created:	23 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(pTI, _tiTransCntrl);

	if CM_Container.hasInstance(pTI) then
		self.firstConnectDT := pTI.CM_Container.getFirstConnectDT;
		self.lastDisconnectDT := pTI.CM_Container.getLastDisconnectDT;
	endif;

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
</Class>
