    <JadeMethod name="processSAPAutoEstReq" id="10d42373-22d8-40cc-a1e8-1a1b4846eca9">
        <source>processSAPAutoEstReq(_cashRec : CM_CashReceipt);
/*

Purpose:
	37189.001 Perform Credit Check for Auto-Collection Customer 
	WSDL 1.1: Auto-Collection - Credit Limit + Hold Amount
	PaymentType_AutoCollection	
Return Value:		

Date		Who		Reason
12 Jul 2018	jlgrs1	ChangeRequest 38630: PEL1 - SAP Credit Check Interfaces
*/
vars
	bgpRequest : BGP_ExternalWSRequest;
	proxyBGPRequest : BGP_SAPWSRequest;
begin
	
	if not _cashRec.isAutoCollection then  // Only Auto Collection
		return;
	endif;
	
	if _cashRec.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then
		return;
	endif;
	
	if not _cashRec.allSapRequests.isEmpty  then
		return;
	endif;
	
	create proxyBGPRequest transient;
	proxyBGPRequest.myWorkOrder	  := self;
	proxyBGPRequest.myCashReceipt := _cashRec;
	proxyBGPRequest.setTerminal( _cashRec.myTerminal);
	proxyBGPRequest.isSAPAutoEstReq := true;
	
	if process.isInTransactionState then 
		app.myUtilityCA.utlCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
	else 
		app.myTrxCA.trxCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
	endif;
epilog
	delete proxyBGPRequest;
end;</source>
        <Parameter name="_cashRec" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="processSAPCancelEstimate" id="9ae048a6-4e6d-4697-a809-3ea7d0c7058f">
        <source>processSAPCancelEstimate(_cashRec : CM_CashReceipt);
/*

Purpose:			
	37189.009 Cancel Estimation
	WSDL 1.10: Auto-Collection - Estimation Cancellation
	PaymentType_AutoCollection
Parameters:			

Return Value:		

Date		Who		Reason
25/06/2018  cnwma1	ChangeRequest 38635: PEL1 - SAP Cancellations
30 Aug 2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
*/

vars
	bgpRequest : BGP_ExternalWSRequest;
	proxyBGPRequest : BGP_SAPWSRequest;
begin
	
	if not _cashRec.isAutoCollection then  // Only AutoCollection ,But Needs Check later /*Pending39698*/
		return;
	endif;
	
	create proxyBGPRequest transient;
	proxyBGPRequest.myWorkOrder := self;
	proxyBGPRequest.setTerminal(self.myTerminal);
	proxyBGPRequest.myCashReceipt := _cashRec;
	proxyBGPRequest.isSAPCancelEstimate := true;
	//epr TFS 44045 25/3/19
	proxyBGPRequest.isManual := self.taskStatus = WO_STATUS_CANCELLED
								or self.taskStatus = WO_STATUS_NOTAPPROVED; //else its an automatic update from change of work order details
	
	if process.isInTransactionState then 
		app.myUtilityCA.utlCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
		if not proxyBGPRequest.isManual then
			app.myUtilityUA.utlSapEstimateResponse(self,WO_STATUS_PENDING,false,app.myPassport);
		endif;
	else 
		app.myTrxCA.trxCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
		if not proxyBGPRequest.isManual then
			app.myTrxUA.trxSapEstimateResponse(self,WO_STATUS_PENDING,false,app.myPassport);
		endif;
	endif;
epilog
	delete proxyBGPRequest;
end;</source>
        <Parameter name="_cashRec" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="processSAPPostBillEstReq" id="e8736f01-7458-4558-a508-93c5c7468d28">
        <source>processSAPPostBillEstReq(_cashRec : CM_CashReceipt);
/*

Purpose:	
	37189.003 Perform Credit Check for Post-Billing Customer
	WSDL 1.6: Post-Billing - Credit Limit
	PaymentType_PostPay	
Return Value:		

Date		Who		Reason
12 Jul 2018	jlgrs1	ChangeRequest 38630: PEL1 - SAP Credit Check Interfaces
*/
vars
	bgpRequest : BGP_ExternalWSRequest;
	proxyBGPRequest : BGP_SAPWSRequest;
begin
	
	if not _cashRec.isPostPay then // Only Post Pay
		return;
	endif;
	
	if _cashRec.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then
		return;
	endif;
	
	if not _cashRec.allSapRequests.isEmpty  then
		return;
	endif;
	
	create proxyBGPRequest transient;
	proxyBGPRequest.myWorkOrder := self;
	proxyBGPRequest.isSAPPostBillEstReq := true;
	proxyBGPRequest.myCashReceipt := _cashRec;
	proxyBGPRequest.setTerminal( _cashRec.myTerminal);
	if process.isInTransactionState then 
		app.myUtilityCA.utlCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
	else 
		app.myTrxCA.trxCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
	endif;
epilog
	delete proxyBGPRequest;
end;</source>
        <Parameter name="_cashRec" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="processSAPPreBillCheckLimit" id="f401b21a-3ebb-4b23-85ca-5a27b0688260">
        <source>processSAPPreBillCheckLimit(_cashRec : CM_CashReceipt);

/*

Purpose:			
	37189.002 Perform Credit Check for Pre-Billing Customer
	WSDL 1.4: Pre-Billing - Credit Limit + Billing Payment Process
	PaymentType_PrePay
Parameters:			

Return Value:		


Date		Who		Reason
23 Jan 2019 cnwma1	ChangeRequest 42943: PEL1 - Recheck Finance for WSDL 1.4 on Web Portal

*/

vars
	bgpRequest 		: BGP_ExternalWSRequest;
	proxyBGPRequest : BGP_SAPWSRequest;
	now     		: TimeStamp;
	msg				: String;
begin
	
	
	if not _cashRec.isPrePay then // Only Pre Pay
		return;
	endif;
	
	if _cashRec.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then
		return;
	endif;
	
	if not _cashRec.allSapRequests.isEmpty  then
		return;
	endif;
	
	if _cashRec.myCashInvoice = null then
		return;
	endif;	
	
	if not _cashRec.myCashInvoice.prependDT.isValid then
		return;
	endif;
	
	now := app.actualTimeServer; 
	if _cashRec.myCashInvoice.prependDT.differenceInHoursReal(now) &gt; 24 then
		return;
	endif;
	
	msg:=  method.qualifiedName            &amp; 
		   ' ' &amp; BGP_SAPWSRequest.WSDL14   &amp; 
		   ' ' &amp; "Work Order :"            &amp; self.id &amp;
		   ' ' &amp; "CashReceipt : "     	   &amp; _cashRec.externalInvoiceNumber;
	app.writeLog(msg,LogINFO);

	create proxyBGPRequest transient;
	proxyBGPRequest.myWorkOrder	  := self;
	proxyBGPRequest.myCashReceipt := _cashRec;
	proxyBGPRequest.setTerminal( _cashRec.myTerminal);
	proxyBGPRequest.isSAPPreBillCheckLimitReq := true;
	
	if process.isInTransactionState then 
		app.myUtilityCA.utlCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
	else 
		app.myTrxCA.trxCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
	endif;
epilog

end;</source>
        <Parameter name="_cashRec" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="processSAPRequest" id="8459b0d9-e52e-4202-befb-af624c67be18">
        <source>processSAPRequest(_isCancel : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		
Payment Type Constants:
PaymentType_None = 0
PaymentType_AutoCollection = 1
PaymentType_PostPay = 3
PaymentType_PrePay = 2
PaymentType_NoCharge = 4

Work Order Status :
WO_STATUS_USERENTRY
WO_STATUS_PENDING
WO_STATUS_APPROVED
WO_STATUS_CANCELLED
WO_STATUS_COMPLETE
Date		Who		Reason
01 Aug 2018	cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
*/
vars
	cashRec		: CM_CashReceipt;
begin
	return;
	
	// We need To send a Request for each Cash Receipt ,
	// Currently Only Voyage Cargo Request could have more than one Receipt,
	// If the Same debtor has more than one voyage cargo request ex: Diffrent cargo Types all of them will have only 1 cash Receipt because they will be grouped by Debtor
	// We need to have PaymentStatus on the CashReceipt to mark the cash Receipt as "Credit Checked =1" if we have a success response , by default this should be "Credit Check Pending =0"
	//
	if self.allCashReceipts.isEmpty then
		return;
	endif;
	
	foreach cashRec in self.allCashReceipts do
		self.createSAPRequest(cashRec,_isCancel);
	endforeach;
epilog

end;</source>
        <Parameter name="_isCancel" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="0ae58189-b368-4240-bfc6-be8f4c3192ee">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
05 August 2009	cnwmd1	Initial creation
20 Apr 2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when trying to create the proxy
26 May 2022		navma1	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
*/

vars
	proxy 			: SelfType;
	wodtl,
	pxyWodtl 		: CM_WorkOrderDtl;
	completedOK		: Boolean;
	
begin
	
	proxy := inheritMethod();
	
	proxy.userCode       := self.userCode;	
	proxy.myOrganisation := self.myOrganisation;
	proxy.myTerminal     := self.myTerminal;
	
	self.allEmailAddresses.copy(  proxy.allEmailAddresses);
	
	if self.isKindOf(CM_WorkOrderTI) then
		self.CM_WorkOrderTI.allTIs.copyNoDuplicates(proxy.CM_WorkOrderTI.allTIs,false); 	//26.05.2022 navma1 #53038
	endif;
	
	self.pxyCreateUpdateProxyWODtls(proxy);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxyWODtls" id="0ecfc89f-1243-4ab3-8bb0-c6bd049697e7">
        <source>pxyCreateUpdateProxyWODtls(_proxyWorkOrder : SelfType io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwmd1	Initial creation

*/

vars
	wodtl, pxyWodtl : CM_WorkOrderDtl;
begin
	foreach wodtl in self.allWoDtls do
	//	create pxyWodtl as wodtl.class transient; //22 May 2019 TFS 44774  - transient leak
		pxyWodtl := wodtl.pxyCreateUpdateProxy();
		pxyWodtl.setParent(_proxyWorkOrder);
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_proxyWorkOrder" type="SelfType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="requireFinanceApproval" id="0af77745-13ab-404f-be22-fd5a51c0c388">
        <source>requireFinanceApproval():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	woTaskType : CM_WorkOrderDetailType;
	wod        : CM_WorkOrderDtl;
begin
	
	wod := self.allWoDtls.first;
	
	woTaskType := app.myRoot.allWorkOrderTaskTypes[self.getWorkOrderMode,wod.detailType];
	
	if woTaskType &lt;&gt; null then
		return woTaskType.requiresApproval;
	endif;	
	
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
