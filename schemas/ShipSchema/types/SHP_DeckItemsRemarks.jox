    <JadeMethod name="doBtnExportCSV" id="86b56708-02c1-431a-b5f4-711129c7be7d">
        <source>doBtnExportCSV();
/*
Date		    Who			Reason
26 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	
begin
	if self.tblRemarks.rows &lt;= self.tblRemarks.fixedRows then
		//app.raiseCMException(ERR_NoDataToExtract, app.getErrorString(Table_data), self.tblRemarks);
		return;
	endif;
	
	self.tblRemarks.outputAsCSV(app.getErrorString(Deckremarks)&amp; self.myCurrentDeck.code &amp; ".csv");

	
epilog

end;</source>
    </JadeMethod>
