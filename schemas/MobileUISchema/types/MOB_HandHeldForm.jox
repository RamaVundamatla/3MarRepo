    <JadeMethod name="getLocationSummary" id="29d5413a-01c2-4a99-8f10-6fe6a2b67f73">
        <source>getLocationSummary(_tiSet: CM_TISet): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2016	cnwndl1	Initial creation  TFS 3037 / 2369 - moved up from lower class

*/

vars

	locationArray : CM_LCArray;
	location : CM_LocationsController;
	integerArray : IntegerArray;
	ti : CM_TrackedItem;
	indexOf : Integer;
	retStr : String;
	index : Integer;

begin

	create locationArray transient;
	create integerArray transient;
	
	foreach ti in _tiSet do
		location := ti.myPrimaryActualLocation;
		if location &lt;&gt; null then
			indexOf := locationArray.indexOf( location );
			if indexOf &lt; 1 then
				locationArray.add( location );
				integerArray.add(1);
			else
				integerArray[indexOf] := integerArray[indexOf] + 1;
			endif;
		endif;
	endforeach;
	
	if locationArray.isEmpty then
		return null;
	endif;
	
	foreach index in 1 to locationArray.size do
		if index = 1 then
			retStr := locationArray[index].CM_LocationsController.getFullId &amp; "(x" &amp; integerArray[index].String &amp; ")";
		else
			retStr := retStr &amp; " " &amp; locationArray[index].CM_LocationsController.getFullId &amp; "(x" &amp; integerArray[index].String &amp; ")";
		endif;
	endforeach;
	
	return retStr;

epilog

	delete locationArray;
	delete integerArray;

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNonStagedAvailSTW" id="9a4e4626-4c9d-4638-ac1b-b5a85cf01694">
        <source>getNonStagedAvailSTW( _reserveSelection : CM_ReserveSelection; _tiSet : CM_TISet input; allowOtherReleases : Boolean; _bulkRelease : CM_BulkRelease ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2016	cnwndl1	Initial creation	TFS 1684 - Looking for better performance

*/

vars

	cargoType : CM_CargoType;
	iter : Iterator;
	startTi : CM_TrackedItem;
	ti : CM_TrackedItem;
	reason : String;
	opTerm : CM_OperatorTerminal;
	product : CM_Product;
	xtraReleaseCriteria : CM_ReleaseByTypeCriteria;
	criteria : CM_YACriteria;
	cargoId : String;
	cargoGroupId : String;
	cg : CM_CargoGroup;
	localDict : CM_TIByCargoTypeIdDict;
	skipAttributes : IntegerArray;	//11 Jan 2016	NDL	TFS 3189/2876

begin

	if _bulkRelease = null then
		return;
	endif;
	
	if _reserveSelection = null then
		return;
	endif;
	
	if _tiSet = null then
		return;
	endif;

	opTerm := _bulkRelease.myOperatorTerminal;
	if opTerm = null then
		return;
	endif;

	cargoType := _reserveSelection.getCargoType;
	if cargoType = null then
		return;
	endif;
	
	product := _reserveSelection.myProduct;
	
	//OK see if we have any extra criteria that we can really use.
	xtraReleaseCriteria:= _reserveSelection.myReleaseCriteria;
	if xtraReleaseCriteria &lt;&gt; null then
		criteria := xtraReleaseCriteria.getCriteriaFor(YACriteriaType_ID);
		if criteria &lt;&gt; null then
			cargoId := criteria.getDisplayForYAMTableColumn;
		endif;
		criteria := xtraReleaseCriteria.getCriteriaFor(YACriteriaType_CargoGroup);
		if criteria &lt;&gt; null then
			cargoGroupId := criteria.getDisplayForYAMTableColumn;
		endif;
	endif;
	
	// Find / build the best collection of ti's to use and start an iterator
	if cargoGroupId &lt;&gt; null then
		cg := self.myTerminal.allCargoGroupsByIdCargoType.getAtKeyGeq( cargoGroupId , null ).CM_CargoGroup;
		if cg &lt;&gt; null and cg.id = cargoGroupId then
			// we  have a cargo group to use, get a collection of the on-site cargo from it.
			create localDict transient;	
			iter := cg.allAssignedTrackedItems.createIterator;
			while iter.next(ti) do
				if not ti.isOnSite then
					continue;
				endif;
				if ti.isNotified or ti.myPrimaryActualLocation = null then
					continue;
				endif;
				localDict.add(ti);
			endwhile;
			delete iter;
			
			if not localDict.isEmpty then
				//there is some potential data, start an iterator
				iter := localDict.createIterator;
				startTi := localDict.getAtKeyGeq( cargoType.id, cargoId);
		
			endif;
			
		endif;
	
	else
		iter := opTerm.allOnsiteTIsByCargoTypeId.createIterator;
		startTi := opTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType.id, cargoId);
		
	endif;
		
	if startTi &lt;&gt; null and startTi.myCargoType = cargoType then
	
		//11 Jan 2016	NDL	TFS 3189/2876
		if _bulkRelease.isShipType then
			//testing against the reserve selection needs to ignore Voyage, Discharge Port and IMEX,
			//because these are unconditionally reset when assigned to the ship release during staging
			create skipAttributes transient;
			skipAttributes.add( YACriteriaType_Voyage );
			skipAttributes.add( YACriteriaType_DischargePort );
			skipAttributes.add( YACriteriaType_ImexStatus );
		endif;
		
		// ok we have an iterator and a tracked item to start from
		iter.startAtObject( startTi );
		while iter.next(ti) do
			if ti.myCargoType &lt;&gt; cargoType then	// check the cargo type.
				break;
			endif;
			if cargoId &lt;&gt; null then // if we found a cargo id in teh xtra criteria on the reserve selection check it
				if cargoId &lt;&gt; ti.id then
					break;
				endif;
			endif;
			if product &lt;&gt; null then	// if we found a product on the reserve selection, check it
				if ti.myProduct &lt;&gt; product then
					continue;
				endif;
			endif;
			if not ti.testAgainstReserveSelection( _reserveSelection, reason, true, skipAttributes ) then
				continue;
			endif;
			if not allowOtherReleases and not ti.allBulkReleasesAssigned.isEmpty then
				if ti.allBulkReleasesAssigned.size = 1 and ti.allBulkReleasesAssigned.first = _bulkRelease then
					//that's OK.
				else
					continue;
				endif;
			endif;
			if ti.isStagedFor( _bulkRelease ) then	//22 Mar 2016	NDL	
				continue;
			endif;
			if ti.isAvailableToStageFor(  _bulkRelease ) then
				_tiSet.addNoDuplicates( ti, false );
			endif;
		endwhile;
	endif;
	

epilog

	delete localDict;
	delete iter;
	delete skipAttributes;

end;</source>
        <access>protected</access>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="allowOtherReleases" type="Boolean"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getScrollingButtonHeight" id="2dd76a32-88bb-4445-8d17-fbc0e532c14d">
        <source>getScrollingButtonHeight():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	vHeight : Integer;

begin

	if not self.useHHResizeCode then
		vHeight := 45;
	
	else
		vHeight := ( self.getTextHeight("TEST" ) * 3 ).Integer + self.resizedMargin;
	
	endif;
	
	return vHeight;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
