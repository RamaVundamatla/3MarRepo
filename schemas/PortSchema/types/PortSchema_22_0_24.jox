    <JadeMethod name="updateWoDtlTransportMode" id="9b3404d0-bae7-4ace-af9f-667500adac16">
        <source>updateWoDtlTransportMode(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date	    Who		Reason
21 Dec 2022	navdp20 ChangeRequest 56661:[56013] - Add Transport Mode to Receive and Release work orders

*/

vars
	wodRel : CM_WodRelease;
	wodRec : CM_WodReceive;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Update Transport Mode", LogINFO); 
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Transport Mode") ;	
	endif;
	
	beginTransaction;
		foreach wodRel in CM_WodRelease.instances  do
			wodRel.setTransportMode(TI_TRANSMODE_ROAD);
		endforeach;
		
		foreach wodRec in CM_WodReceive.instances  do
			wodRec.setTransportMode(TI_TRANSMODE_ROAD);
		endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Transport Mode updated Complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Transport Mode updated Complete");
	endif;

	self.addScriptRun(method.name);
epilog

end;
</source>
