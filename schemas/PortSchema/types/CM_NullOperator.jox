<Class name="CM_NullOperator" id="e9b201a0-dd6c-43e1-8624-f4ade098cd1e">
    <superclass name="CM_Operator"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="setProxyForNullOperator" id="6b23a85c-9f8f-430c-8107-3130170c3ba6">
        <updating/>
        <source>setProxyForNullOperator() updating;

constants
	Star = '*';
vars
	tempString: String;
	len,i: Integer;
begin

	self.raiseExceptionIfNotTransient(method);
	len := CM_Operator.getProperty("code").getLength;
	len := len - 1; //allow for null character
	//-----------------
	//Build the key (*****...s)
	//-----------------
	foreach i in 1 to len do
		tempString := tempString &amp; Star;
	endforeach;
	self.code := tempString;
	self.colour := White;
	self.description := "Null Operator";
	self.reeferReadingsPerDay := 0;
	self.myRoot := app.myRoot;
	
end;</source>
    </JadeMethod>
</Class>
