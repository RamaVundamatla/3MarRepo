<CollClass name="Btree">
    <JadeMethod name="jtdGetRandomMember" id="7ba00026-dcf9-4937-884c-01cb081de371">
        <source>jtdGetRandomMember() : MemberType;

vars
	needEndLoad : Boolean;
	memberObj : MemberType;
	indx, selfSize : Integer;
	iter : Iterator;
	
begin
	if process.isInTransactionState or process.isInLoadState then
		needEndLoad := false;
	else
		beginLoad;
		needEndLoad := true;
	endif;

	sharedLock(self);

	selfSize := self.size;
	if selfSize &lt; 1 then
		return null;
	endif;

	indx := app.random(selfSize);
	if indx &lt; 1 then
		// belts and braces
		indx := 1;
	elseif indx &gt; selfSize then
		// belts and braces
		indx := selfSize;
	endif;
	
	iter := self.createIterator;
	iter.startAtIndex(indx);

	memberObj := null;
	while iter.next(memberObj) do
		break;
	endwhile;
	
	return memberObj;
	
epilog
	if needEndLoad then
		endLoad;
	endif;
	
	delete iter;
end;</source>
        <ReturnType type="MemberType"/>
    </JadeMethod>
</CollClass>
