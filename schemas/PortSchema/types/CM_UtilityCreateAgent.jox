        <updating/>
        <source>utlCreateBulkYACandidates(_pxyResults : CM_BulkYACandidateResults; _realResults : CM_BulkYACandidateResults output; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars

begin
