    <JadeMethod name="doSave" id="0b1e48e7-3560-4156-93cc-20de931c2926">
        <updating/>
        <source>doSave() : Boolean updating, protected;
/* ---------------------------------------------------------------------------
Created:	12 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
12/03/2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
06/03/2014		cnwdap1	PAR #33638 Correct measuremetn field usage
22/10/2019		jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
------------------------------------------------------------------------------*/
vars
	realMaster,
	pxyMaster		: CM_TIMasterGenerator;
	id,
	description		: String;
	operator 		: CM_Operator;
	owner	 		: CM_Operator;	
	isoType			: CM_ISOType;
	generatorType	: CM_GeneratorType;
	//tareWeight		: Integer;						// PAR #31155
	tareWeight		: Decimal [23,10];					// PAR #31155
	createOnSite	: Boolean;
	initialLocation	: CM_LocationsController;
	allStopTables 	: CM_StopsTableByIdDict;
	allToDoTasks 	: CM_ToDoTaskDescByCode;
	result			: Integer;
	errors 			: String;
	damage 			: CM_DamageInstance;
	objectArray		: CM_ObjectArray;
	weightType		: CM_MeasurementType;				// PAR #31155;
begin

	beginLoad;
	if self.isEdit then
		pxyMaster := app.createUpdateProxy(self.myTiMaster).CM_TIMasterGenerator;
	else
		create pxyMaster transient;
	endif;
	endLoad;
	
	id :=self.txtID.text;
	description :=self.txtDescription.text;

	if cmbOperator.listIndex &gt; 0 then
		operator := self.cmbOperator.itemObject[cmbOperator.listIndex].CM_Operator;
	endif;
	if cmbOwner.listIndex &gt; 0 then
		owner := self.cmbOwner.itemObject[cmbOwner.listIndex].CM_Operator;
	endif;
	
	if cmbISOType.listIndex &gt; 0 then
		isoType := self.cmbISOType.itemObject[cmbISOType.listIndex].CM_ISOType;
	endif;
	if cmbGeneratorType.listIndex &gt; 0 then
		generatorType := self.cmbGeneratorType.itemObject[cmbGeneratorType.listIndex].CM_GeneratorType;
	endif;

	//tareWeight := self.txtWeight.text.Integer;														// PAR #31155
	//weightType := app.getDefaultMeasurementForType(Type_Weight);										// PAR #31155	// PAR #33638
	//tareWeight := app.convertMeasurementForStorage(weightType.shortName, self.txtWeight.text.Decimal);// PAR #31155	// PAR #33638
	tareWeight := self.txtWeight.getConvertedValue();																	// PAR #33638
	
	create allStopTables transient;
	self.lstTblStops.allSelectedObjects.copy(allStopTables);
	
	create allToDoTasks transient;
	self.lstTblToDoTasks.allSelectedObjects.copy(allToDoTasks);
	
	create objectArray transient;
	if self.isDamageFormInitialised then
		foreach damage in pxyMaster.allDamageInstancesByPos do
			if not self.allDamageInstancesByPos.includes(damage) then
				//pxyMaster.allDamageInstancesByPos.removeIfPresent(damage);
				delete damage;  //cnwjo3 par 21463
				objectArray.add(damage);
			endif;
		endforeach;
	endif;
	pxyMaster.setForProxyMasterGenSet( id, description, operator, owner,  isoType, generatorType, tareWeight, allStopTables, allToDoTasks );
	self.setDamageParent(pxyMaster);
	//self.tblDamage.setProxyFromTable(pxyMaster,errors);
	
	if pxyMaster = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;
	
	while true do
		if not self.isEdit then
			app.myTrxCA.trxCreateTIMasterGenerator( pxyMaster, realMaster, createOnSite, app.myPassport );
		else
			app.myTrxUA.trxUpdateTIMasterGenerator(pxyMaster, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then	
			result := app.showErrorWarningDialog('Create Master Item', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			self.setAllErrorWarnings(app.myPassport);	
			if app.myPassport.noErrors and  result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		else
			self.clearErrorWarnings();
			if self.isEdit then				
			else
				self.myTiMaster := realMaster;
			endif;
			
			if self.myParentForm.isA(CMUI_TIMasterForm) then // TFS 46767 - 31/10/2019 - enable autocreation for 100
				self.myParentForm.CMUI_TIMasterForm.setMyCurrentTiMaster(self.myTiMaster);
			endif; // &lt;-- TFS 46767
			self.btnDamage.enabled := true;	// cnwrd1 par 20799 27/10/09

			return true;
		endif;
		break;
	endwhile;
	
	return false;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	pxyMaster.allDamageInstancesByPos.purge();
	delete pxyMaster;	
	objectArray.purge();
	delete objectArray;
	self.allDamageInstancesByPos.purge();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
