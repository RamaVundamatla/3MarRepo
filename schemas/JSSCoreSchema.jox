    <Library name="advapi32" id="cef1d09f-b8d9-4f64-9ee7-f71b1c06e4df"/>
    <Library name="urlencode" id="92e143b1-4194-46c6-a8f0-d94cb13cb71d"/>
    <Library name="wininet" id="4fe179db-741f-41fd-add9-bd1c94614edc"/>
    <Function name="httpOpenRequest" id="8117e0fc-ec00-4e78-955b-12a2c0b605fc">
        <entrypoint>HttpOpenRequestA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="wininet"/>
        <source>httpOpenRequest(
			pInternetHandle: Integer; 
			pVerb: String; 
			pObjectName: String; 
			pVersion: String; 
			pReferer: String; 
			pAcceptTypes: Integer; 
			pFlags: Integer; 
			pContext: Integer): Integer is "HttpOpenRequestA" in "wininet";</source>
        <Parameter name="pInternetHandle" type="Integer"/>
        <Parameter name="pVerb" type="String"/>
        <Parameter name="pObjectName" type="String"/>
        <Parameter name="pVersion" type="String"/>
        <Parameter name="pReferer" type="String"/>
        <Parameter name="pAcceptTypes" type="Integer"/>
        <Parameter name="pFlags" type="Integer"/>
        <Parameter name="pContext" type="Integer"/>
        <ReturnType type="Integer"/>
    </Function>
    <Function name="httpQueryInfo" id="e6d0e581-52e0-4afd-8fbf-fd425f67698c">
        <entrypoint>HttpQueryInfoA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="wininet"/>
        <source>httpQueryInfo(
			pInternetHandle: Integer; 
			pInfoLevel: Integer; 
			pBuffer: String [4096] io; 
			pBufferLength: Integer io; 
			pIndex: Integer io): Boolean is "HttpQueryInfoA" in "wininet";</source>
        <Parameter name="pInternetHandle" type="Integer"/>
        <Parameter name="pInfoLevel" type="Integer"/>
        <Parameter name="pBuffer" type="String" length="4096" usage="io"/>
        <Parameter name="pBufferLength" type="Integer" usage="io"/>
        <Parameter name="pIndex" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </Function>
    <Function name="httpSendRequest" id="26f7d5b9-620c-47c1-b2d9-c5bbaf95ea0f">
        <entrypoint>HttpSendRequestA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="wininet"/>
        <source>httpSendRequest(
			pInternetHandle: Integer; 
			pHeaders: String; 
			pHeadersLength: Integer; 
			pOptional: String; 
			pOptionalLength: Integer): Boolean is "HttpSendRequestA" in "wininet";</source>
        <Parameter name="pInternetHandle" type="Integer"/>
        <Parameter name="pHeaders" type="String"/>
        <Parameter name="pHeadersLength" type="Integer"/>
        <Parameter name="pOptional" type="String"/>
        <Parameter name="pOptionalLength" type="Integer"/>
        <ReturnType type="Boolean"/>
    </Function>
    <Function name="httpSendRequestEx" id="500cad60-016c-40f3-996b-b13ba95911c9">
        <entrypoint>HttpSendRequestExA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="wininet"/>
        <source>httpSendRequestEx(
			pInternetHandle: Integer; 
			pBuffersIn: Integer; 
			pBuffersOut: Binary [4096] output; 
			pFlags: Integer; 
			pContext: Integer): Boolean is "HttpSendRequestExA" in "wininet";</source>
        <Parameter name="pInternetHandle" type="Integer"/>
        <Parameter name="pBuffersIn" type="Integer"/>
        <Parameter name="pBuffersOut" type="Binary" length="4096" usage="output"/>
        <Parameter name="pFlags" type="Integer"/>
        <Parameter name="pContext" type="Integer"/>
        <ReturnType type="Boolean"/>
    </Function>
    <Function name="internetCheckConnection" id="bef75248-bcfd-483a-bb24-82799f2f369c">
        <entrypoint>InternetCheckConnectionA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="wininet"/>
        <source>internetCheckConnection(pUrl : String; pFlags : Integer; pReserved : Integer) : Boolean is InternetCheckConnectionA in wininet;</source>
        <Parameter name="pUrl" type="String"/>
        <Parameter name="pFlags" type="Integer"/>
        <Parameter name="pReserved" type="Integer"/>
        <ReturnType type="Boolean"/>
    </Function>
