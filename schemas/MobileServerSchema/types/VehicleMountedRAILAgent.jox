        <source>setDetails(_terminal: CM_Terminal; _user: CM_User; _rtDevice: CM_RadioTelemetryDevice; _machine: CM_Machine; _rtQueue: CM_RadioTelemetryQueue) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwer1	Initial creation

*/

vars

begin
	inheritMethod(_terminal, _user, _rtDevice, _machine, _rtQueue);
	self.resetNotes;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_rtDevice" type="CM_RadioTelemetryDevice"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_rtQueue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
