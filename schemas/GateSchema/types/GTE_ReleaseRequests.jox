    <JadeMethod name="cmbISOType_click" id="5703f38d-3ab3-47ed-90b7-8e2a463a3242">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbISOType_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 October 2025		jlizm1	Initial creation MTN 36255 Rotabox Assign Release To Vessel

*/

vars
	isoType : CM_ISOType;
	
begin
		
	isoType := combobox.listObject.CM_ISOType;
	if isoType = null then
		return;
	endif;
	
	if isoType.isRotatable then
		self.tblEntry.showRowByName(ETRow_CargoTypeCodeForCntnt, false);
		self.tblEntry.showRowByName(ETRow_CargoSubTypeCodeForCntnt, false);
	else
		self.tblEntry.hideRowByName(ETRow_CargoTypeCodeForCntnt, false);
		self.tblEntry.hideRowByName(ETRow_CargoSubTypeCodeForCntnt, false);
	endif;
	
epilog

end;</source>
