    <JadeMethod name="concatWithCommaDelimeter" id="ca9c71ee-73e1-4708-b7b6-0a30e82c12d5">
        <source>concatWithCommaDelimeter(tmpStr : String io; strToJoin : String);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 June 2024
TFS#		: 64524
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
   /*
   if tmpStr = null then
		tmpStr := strToJoin;
	elseif tmpStr.pos(strToJoin, 1) = 0 then
		tmpStr := tmpStr &amp; ', ' &amp; strToJoin;
	endif;
	*/
	
	tmpStr.addStringToList(strToJoin, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
end;
</source>
