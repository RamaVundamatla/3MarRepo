    <JadeMethod name="doUserNotify" id="683f5bbe-5d6c-4893-a219-00195f4a23fd">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	if eventType = ITSMachine.ReceiveMessageFromJMT and theObject = self.myMachine then
		self.doReceiveMessage(userInfo.String);
	
	elseif eventType = ITSServerControl.START_MACHINE and theObject = global then
		self.doSendLogon();  //log on, log off.  cause some deadlocks
		self.doSendLogoff();
	
	elseif eventType = ITSServerControl.STOP_MACHINE and theObject = global then
		self.unloadForm();
	
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="findQueueEntryRow" id="3d98ccc0-a310-4613-ba19-605ffadba861">
        <source>findQueueEntryRow(_queueEntryId : Integer) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	queueIdCol,
	row				: Integer;
	table			: Table;
	
begin
	queueIdCol := self.getQueueEntryIdColumn();
	if queueIdCol = null then
		return null;
	endif;
	
	table := self.tblQueueEntries;
	
	foreach row in 2 to table.rows do
		if table.getCellText(row, queueIdCol).Integer = _queueEntryId then
			return row;
		endif;
	endforeach;
	
	return null;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_queueEntryId" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueueEntryIdColumn" id="4151bd81-e2af-4091-ba2d-6e342bfb4bcb">
        <source>getQueueEntryIdColumn() : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	column			: Integer;
	table			: Table;
	
begin
	table := self.tblQueueEntries;
	
	foreach column in 1 to table.columns do
		if table.getCellText(1, column) = XML_Tag_QueueEntryId then
			return column;
		endif;
	endforeach;
	
	return null;
	
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedEntryForColumnName" id="f38c2d40-274e-4e00-99b3-d72d26404d0b">
        <source>getSelectedEntryForColumnName(_columnName : String) : String protected;

/*

Purpose:			Return the value from the cell in the selected row of the table with the 
					passed in column header

Parameters:			

Return Value:		


Date		Who		Reason
19 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	foundColumn		: Boolean;
	column			: Integer;
	table			: Table;
	
begin
	table := self.tblQueueEntries;
	
	// If there's no row selected, return null
	if table.row &lt;= table.fixedRows then
		return null;
	endif;
	
	// Find the column
	foreach column in 1 to table.columns do
		if table.getCellText(1, column) = _columnName then
			foundColumn := true;
			break;
		endif;
	endforeach;
	
	if not foundColumn then
		return null;
	endif;
	
	return table.getCellText(table.row, column);
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_columnName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedQueueEntryId" id="4b1f1b68-990f-49da-a6c8-bab0e15aac9e">
        <source>getSelectedQueueEntryId() : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	
begin
	return self.getSelectedEntryForColumnName(XML_Tag_QueueEntryId).Integer;
	

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
