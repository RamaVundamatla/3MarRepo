    <JadeMethod name="uDeleteCargoGroupsInTerminal" id="46b65b04-b150-434d-95cb-c4619d828549">
        <source>uDeleteCargoGroupsInTerminal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2018	jlgndl1	Initial creation

*/

vars

	terminalName : String;
	terminal : CM_Terminal;
	trackedItemId: String;
	tiSet		: CM_TISet;
	ti : Object;
begin

	terminalName := "Enter Terminal Name";
	read terminalName;
	terminal := app.myRoot.allTerminals[terminalName];
	if terminal &lt;&gt; null then

		create tiSet transient;
		foreach ti in terminal.allCargoGroupsByIdCargoType do
			if not ti.CM_CargoGroup.isComplete then
				continue;
			endif;
			if not ti.CM_CargoGroup.allAssignedTrackedItems.isEmpty then
				continue;
			endif;
			tiSet.add( ti.CM_TrackedItem );
		endforeach;
		
		if not tiSet.isEmpty then
			foreach ti in tiSet reversed do
				self.deleteTrackedItem(ti, false);
			endforeach;
		endif;
	
	endif;
	
epilog

	delete tiSet;
	
end;</source>
    </JadeMethod>
