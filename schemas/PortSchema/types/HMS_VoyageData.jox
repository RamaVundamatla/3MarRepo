    <JadeMethod name="hasArrivalMovement" id="e312cfe0-cf37-4332-bc31-4472fe6c5228">
        <source>hasArrivalMovement(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 October 2024	navcs2	MTN-32967 POB - QSHIPS - Completed Arrival Movements Get Updated and Revert to Planned

*/

vars
	voyageMov		: HMS_VoyageMovement;
begin
	foreach voyageMov in self.allVoyageMovements do	
		if voyageMov.isArrival then
			return true;	
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
