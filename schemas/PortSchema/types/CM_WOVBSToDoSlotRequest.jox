<Class name="CM_WOVBSToDoSlotRequest" id="bf40c68f-e4dc-44c2-8ce0-3a26dddf1dcf">
    <superclass name="CM_WOToDoRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="allVBSSlots" id="71deaa93-9b53-4f15-ae48-607b1ae3c73e">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_VehicleBookingTimeSlotById"/>
        <access>readonly</access>
        <Inverse name="CM_VehicleBookingTimeSlot::allWorkOrderRequests"/>
    </ExplicitInverseRef>
    <JadeMethod name="createWLEs" id="0689b39c-b445-46d4-bdd7-159c4bdaeabd">
        <source>createWLEs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	aWLE			:	CM_WOVBSToDoSlotWLE;
	vbsSlot			:	CM_VehicleBookingTimeSlot;
	toDoTask		: 	CM_ToDoTask;
	iter			: 	Iterator;
begin
	iter := self.myJob.CM_WOToDoVBSSlotJob.allVBSSlots.createIterator();
	
	while iter.next(vbsSlot) do
		create aWLE persistent;
		aWLE.setForCreate(self.myJob, self); 
		aWLE.setVBSlot(vbsSlot);
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="89cf39a2-6bed-4913-99a0-acbc75d02f46">
        <updating/>
        <source>setForCreateInternal(_myJob: CM_WOToDoTaskJob; _toDoInternalJobParam: CMIF_WorkOrderJobParams) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs (Task 54263)

*/

vars

begin
	inheritMethod(_myJob, _toDoInternalJobParam);
	
	self.myJob.CM_WOToDoVBSSlotJob.allVBSSlots.copy(self.allVBSSlots);
epilog

end;</source>
        <Parameter name="_myJob" type="CM_WOToDoTaskJob"/>
        <Parameter name="_toDoInternalJobParam" type="CMIF_WorkOrderJobParams"/>
    </JadeMethod>
</Class>
