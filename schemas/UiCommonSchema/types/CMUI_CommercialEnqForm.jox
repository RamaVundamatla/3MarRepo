	tmpSheet.accessCell(1,16/*10*/).mergeCells := Table.MergeCells_Merge;
	tmpSheet.accessCell(1,16/*10*/).text := "Export";
	tmpSheet.accessCell(1,16/*10*/).alignment := Table.Alignment_Center;
//Row 2	black line	
	tmpSheet.accessRow(2).backColor := Gray;
	tmpSheet.accessRow(2).height := 1;
	tmpSheet.accessCell(2, 1).text := "";
//Row 3	
	tmpSheet.accessCell(3,9/*6*/).mergeCells := Table.MergeCells_NotAvailable;
	tmpSheet.accessCell(3,2).mergeCells := Table.MergeCells_MergeSelectable;
	tmpSheet.accessCell(3,2).text := "Full";
	tmpSheet.accessCell(3,2).alignment := Table.Alignment_Center;	
	tmpSheet.accessCell(3,9/*6*/).mergeCells := Table.MergeCells_Available;
	tmpSheet.accessCell(3,16/*10*/).mergeCells := Table.MergeCells_NotAvailable;
	tmpSheet.accessCell(3,9/*6*/).mergeCells := Table.MergeCells_MergeSelectable;
	tmpSheet.accessCell(3,9/*6*/).text := "Empty";
	tmpSheet.accessCell(3,9/*6*/).alignment := Table.Alignment_Center;
	tmpSheet.accessCell(3,16/*10*/).mergeCells := Table.MergeCells_Available;
	tmpSheet.accessCell(3,26/*14*/).mergeCells := Table.MergeCells_NotAvailable;
	tmpSheet.accessCell(3,16/*10*/).mergeCells := Table.MergeCells_MergeSelectable;
	tmpSheet.accessCell(3,16/*10*/).text := "Full";
	tmpSheet.accessCell(3,16/*10*/).alignment := Table.Alignment_Center;
	tmpSheet.accessCell(3,23/*14*/).mergeCells := Table.MergeCells_Available;
	tmpSheet.accessCell(3,23/*14*/).mergeCells := Table.MergeCells_Merge;
	tmpSheet.accessCell(3,23/*14*/).text := "Empty";
	tmpSheet.accessCell(3,23/*14*/).alignment := Table.Alignment_Center;
//Row 4
	tmpSheet.accessRow(4).backColor := Gray;
	tmpSheet.accessRow(4).height := 1;
	tmpSheet.accessCell(4, 1).text := "";
//Row 5
	tmpSheet.accessCell(5,1).text := 
		Tab &amp;
		'20' &amp; Tab &amp;
		'40' &amp; Tab &amp;
		'30' &amp; Tab &amp;
		'45' &amp; Tab &amp;
		'53' &amp; Tab &amp;
		'Oth' &amp; Tab &amp;
		'TEU' &amp; Tab &amp;
		'20' &amp; Tab &amp;
		'40' &amp; Tab &amp;
		'30' &amp; Tab &amp;
		'45' &amp; Tab &amp;
		'53' &amp; Tab &amp;
		'Oth' &amp; Tab &amp;
		'TEU' &amp; Tab &amp;
		'20' &amp; Tab &amp;
		'40' &amp; Tab &amp;
		'30' &amp; Tab &amp;
		'45' &amp; Tab &amp;
		'53' &amp; Tab &amp;
		'Oth' &amp; Tab &amp;
		'TEU' &amp; Tab &amp;
		'20' &amp; Tab &amp;
		'40' &amp; Tab &amp;
		'30' &amp; Tab &amp;
		'45' &amp; Tab &amp;
		'53' &amp; Tab &amp;
		'Oth' &amp; Tab &amp;
		'TEU' &amp; Tab ;
//Row 6
	tmpSheet.accessRow(6).backColor := Gray;
	tmpSheet.accessRow(6).height := 1;
	tmpSheet.accessCell(6, 1).text := "";
	
	self.columnsVisibilityForISOType();	//	Hides or hows columns for sheets 1 and 2. ccms 1029	cnwvu1	16 May 2008
	
	// OtherCargo Sheet (3) --------------------------------------------
	tmpSheet := self.tblData.accessSheet(3);
	tmpSheet.visible := true;
	tmpSheet.caption := 'Other Cargo Activity';
	tmpSheet.columns := 6;
	tmpSheet.fixedRows := 2;
	tmpSheet.fixedColumns := 0;
	tmpSheet.accessRow(1).fontBold := true;
	tmpSheet.accessCell(1,1).text := 
		'Cargo Type' &amp; Tab &amp; Tab &amp; Tab &amp;
		'Weight'&amp; Tab &amp;
		'Quantity' &amp; Tab &amp;
		'Volume';
	tmpSheet.accessRow(2).backColor := Gray;
	tmpSheet.accessRow(2).height := 1;
	tmpSheet.accessCell(2, 1).text := "";
	
	tmpSheet.gridBottom := false;
	
	tmpSheet.accessColumn(1).fontBold := true;
	tmpSheet.accessColumn(4).alignment := Table.Alignment_Right;
	tmpSheet.accessColumn(5).alignment := Table.Alignment_Right;
	tmpSheet.accessColumn(6).alignment := Table.Alignment_Right;

	self.mnuContextColourLegend.visible := false;
	self.mnuColumnOrganiser.visible := false;
end;</source>
