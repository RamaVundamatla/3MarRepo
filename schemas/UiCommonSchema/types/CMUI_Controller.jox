    <JadeMethod name="createMenuAction" id="b640b978-ea39-4b73-b49b-4921a3b6aa57">
        <source>createMenuAction(pValue : Integer; pObject : Object; 
				pParent : CMUI_MenuAction;
				pTerminal : CM_Terminal) : CMUI_MenuAction;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuDtl		: CM_MenuDtlNav;
	menuAction	: CMUI_MenuAction;
	tmpMenuUserItem	: CM_MenuUserItem;
	tmpMenuUserDtl	: CM_MenuUserDtl;
	tmpMenuRoot		: CM_MenuRoot;

begin

	menuDtl := app.myRoot.myMenuRoot.allMenuDtlsByPermValue[pValue];
	if menuDtl = null then
		menuDtl := app.myRoot.myMenuRootForSysEntities.allMenuDtlsByPermValue[pValue];
	endif;
		
	if menuDtl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No menuItem found for (' &amp; pValue.String &amp; ')');
		return menuAction;
	endif;
	
	// When opening a form from another form pParent is relates to
	// that parent form.  Here we attempt to find the correct item
	// for the window being opened (so that it appears in the correct
	// place in the navigator.
	if pParent &lt;&gt; null then
		tmpMenuUserDtl := pParent.myMenuUserDtl;
		if global.isValidObject(tmpMenuUserDtl) then
			tmpMenuRoot := tmpMenuUserDtl.myMenuRoot;
			if tmpMenuRoot &lt;&gt; null then
				tmpMenuUserItem := tmpMenuRoot.allMenuUserItemsWithAMenuItem[menuDtl];
			endif;
		endif;
	endif;

	create menuAction transient;
	if tmpMenuUserItem = null then
		menuAction.setFromController(menuDtl, pParent, pTerminal);
	else
		menuAction.setFromController(menuDtl, tmpMenuUserItem, pTerminal);
	endif;
	app.causeEvent(CMUI_NavObject_Add, true, menuAction);

	return menuAction;
	
end;</source>
        <Parameter name="pValue" type="Integer"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pParent" type="CMUI_MenuAction"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <ReturnType type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="createMenuAction2" id="7adc52e6-4f5a-4000-a036-e6ae229393f4">
        <source>createMenuAction2(pValue : Integer;  pObject : Object; 
				 pParent : CMUI_MenuAction;pTerminal : CM_Terminal) : CMUI_MenuAction;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuDtl		: CM_MenuDtlNav;
	menuAction	: CMUI_MenuAction;
begin

	menuDtl := app.myRoot.myMenuRoot.allMenuDtlsByPermValue[pValue];
	if menuDtl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No menuItem found for (' &amp; pValue.String &amp; ')');
		return menuAction;
	endif;
	pParent.inspect;
	menuAction := pParent.allChildren.first.CMUI_MenuAction;
	if menuAction = null then
		create menuAction transient;
		menuAction.setFromController(menuDtl,pParent,pTerminal);
		app.causeEvent(CMUI_NavObject_Add, true, menuAction);
	endif;

	return menuAction;
	
end;</source>
        <Parameter name="pValue" type="Integer"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pParent" type="CMUI_MenuAction"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <ReturnType type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="createMenuAction3" id="07df9d1e-4572-42a5-a3ba-7d7a85fd9dd8">
        <source>createMenuAction3(pValue : Integer; pTerminal : CM_Terminal) : CMUI_MenuAction;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwdf1
//
// Purpose:    create and config the menuAction associated with the SOP_TableMaintForm,if
//             if has already been open, simply return its masterMenuAction. The menuAction
//             being returned will be used to create of show the form itself.  
// ---------------------------------------------------------------------------
vars
	menuDtl		: CM_MenuDtlNav;
	menuAction	: CMUI_MenuAction;
    menuUserDtl : CM_MenuUserDtl;
	sysRoot		: CM_MenuRootForUser;
	usingSystemMenu	: Boolean;
	tmpUser		: CM_User;
	tmpUserTerminal	: CM_UserTerminal;
begin
	tmpUser := app.getMyUser();
	
	/*
	Always open a new copy of the form.  This does not work
	anyway as it does not jump to the right object and
	it can get confused between system items and terminal items
	
	form := app.getForm('SOP_TableMaintForm').CM_BaseForm;
	if form &lt;&gt; null then
		menuAction := form.myMasterMenuAction;
	endif;
	if menuAction &lt;&gt; null then
		return menuAction;
	endif;
	*/

	if pValue = PmAdmTabledefineView then
		menuDtl := app.myRoot.myMenuRoot.allMenuDtlsByPermValue[pValue];
	elseif pValue = PmAdmSystemTableView then
		usingSystemMenu := true;
		menuDtl := app.myRoot.myMenuRootForSysEntities.allMenuDtlsByPermValue[pValue];
	else
		// try terminal menus first
		menuDtl := app.myRoot.myMenuRoot.allMenuDtlsByPermValue[pValue];
		if menuDtl = null then
			// if not found try on system menu
			usingSystemMenu := true;
			menuDtl := app.myRoot.myMenuRootForSysEntities.allMenuDtlsByPermValue[pValue];
		endif;
	endif;

	if menuDtl = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'No menuItem found for (' &amp; pValue.String &amp; ')');
		return menuAction;
	endif;	
	sysRoot := tmpUser.myMenuRootForSysEntities;	// 37017 this can be null, the user may not have a system role

	if pTerminal = null or usingSystemMenu then
		if sysRoot &lt;&gt; null then				// 37017
			menuUserDtl := sysRoot.allMenuUserItemsWithAMenuItem[menuDtl].CM_MenuUserDtl;
		endif;
	else
		tmpUserTerminal := tmpUser.getUserTerminal(pTerminal);
		if tmpUserTerminal = null then
			return null;
		endif;
		menuUserDtl := tmpUserTerminal.myMenuRoot.allMenuUserItemsWithAMenuItem[menuDtl].CM_MenuUserDtl;
	endif;

    if menuUserDtl = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'No menuUserDtlForTM found for (' &amp; pValue.String &amp; ')');
		return null;		
	endif;
	
	create menuAction transient;
	menuAction.setFromMenuDtl(menuUserDtl, menuUserDtl.myMenuItem.CM_MenuDtlNav);
	app.causeEvent(CMUI_NavObject_Add, true, menuAction);		
	return menuAction;
	
end;</source>
        <Parameter name="pValue" type="Integer"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <ReturnType type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="createNavObject" id="b77c3f97-bf22-49f6-aed1-7ce342022092">
        <source>createNavObject(pCode : String; pObject : Object; 
				pParent : CMUI_NavigatorObject;
				pTerminal : CM_Terminal) : CMUI_NavigatorObject;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObjDef	: CM_NavObjectDef;
	navObj		: CMUI_NavigatorObject;

begin

//process.debug;
	navObjDef := app.myRoot.allNavObjectDefs[pCode];
	if navObjDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No NavObjDef found for (' &amp; pCode &amp; ')');
		return navObj;
	endif;

	create navObj transient;
	navObj.set(pCode, pParent, pObject, pTerminal, self);
	if navObj &lt;&gt; null then
		navObj.setFromNavObjDef(navObjDef);
		app.causeEvent(CMUI_NavObject_Add, true, navObj);
	endif;

	return navObj;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pParent" type="CMUI_NavigatorObject"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <ReturnType type="CMUI_NavigatorObject"/>
    </JadeMethod>
