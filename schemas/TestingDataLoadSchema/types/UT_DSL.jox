    <JadeMethod name="machineTaskRequestTwin" id="694e2936-cc7f-4480-8abc-da9882d405d3">
        <source>machineTaskRequestTwin(_machine: CM_Machine) : CM_RTQueueTask protected;
/*

Purpose:			Execute a get next task for the passed in machine, allowing twin
					tasks to be allocated if possible

Parameters:			Machine

Return Value:		First task found for the machine

Date		Who		Reason
21 Oct 2011	cnwkpd1	PAR #28383 - Allocating Held twin tasks to a machine

*/

vars
	mediator 		: CM_RadioTelemetryMediator;
	
begin
	create mediator transient;
	mediator.machine := _machine;
	mediator.canBeAllocatedTwinTasks := true;
	app.myTrxRT.trxRequestTask(mediator, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return mediator.task;
	
epilog
	delete mediator;
	
end;</source>
        <access>protected</access>
