    </JadeMethod>
    <JadeMethod name="setSuperClassDetailsForProxy" id="46ed88ef-4b46-45aa-83fc-d5c19c3e3ff3">
        <updating/>
        <source>setSuperClassDetailsForProxy(_code, _description : String; _notAvailableForEntry :Boolean; _codeGroup : CM_CodeGroup) updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.code 			:= _code.trimBlanks.toUpper; //PAR 10280
	self.description 	:= _description.trimRight;
	self.notAvailableForEntry := _notAvailableForEntry;
	self.myCodeGroup	:= _codeGroup;

end;</source>
        <access>protected</access>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_codeGroup" type="CM_CodeGroup"/>
    </JadeMethod>
