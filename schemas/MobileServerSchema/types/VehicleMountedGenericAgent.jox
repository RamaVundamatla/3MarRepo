        <source>initialiseForNewRequest(_errorMsgs : DTO_HandHeldGateErrorDict input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2010	cnwer1	Initial creation

*/

vars

begin
	
	app.myPassport.setWarningsIgnored(self.myRTVehicleConfig.ignoreWarnings);
	app.myPassport.setWarningsAcknowledged(true);

epilog

end;</source>
