<CollClass name="BGP_ControllersByNameDict" id="3e2da21a-8833-4dac-88c3-297ee48e69ae">
    <duplicatesAllowed/>
    <memberType name="BGP_Controller"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <MemberKey>
        <property name="BGP_Controller::name"/>
    </MemberKey>
    <JadeMethod name="getControllerOfType" id="6a0df07d-eac2-4295-b423-64e0f38e609c">
        <source>getControllerOfType(_type : Class) : BGP_Controller;
// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
// -------------------------------------------
vars

	controller	: BGP_Controller;

begin

	foreach controller in self where controller.class = _type do
		if not controller.isSetup then
			return controller;
		endif;
	endforeach;


end;</source>
        <Parameter name="_type" type="Class"/>
        <ReturnType type="BGP_Controller"/>
    </JadeMethod>
</CollClass>
