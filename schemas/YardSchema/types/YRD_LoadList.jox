    <JadeMethod name="quitSummaryMode" id="68dec73b-5f10-49de-82f6-452b31fe678d">
        <updating/>
        <source>quitSummaryMode()updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//08 Dec 2011	NDL	Par 28797
vars

begin
	if self.mode &lt;&gt; self.Mode_SummarySelection then
		return;
	endif;

	self.statusStub := "";
	self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; " 0";

	self.resetShowAllRows(self.tblPlanned);
	self.resetShowAllRows(self.tblData);
	self.resetShowAllRows(self.tblAll);
	self.btnQuitSmmryMode.helpKeyword := "";
	
	self.btnQuitSmmryMode.enabled := false;
	self.mode := self.Mode_Enquire;
	self.updateShtCaptions();
	self.doFldMainClick();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="removeInvalidObjectFromTblAll" id="bd87b5b2-de2b-477b-88a3-6b35f80f98a1">
        <source>removeInvalidObjectFromTblAll( _ti : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2011	cnwndl1	Initial creation	Par 28797

*/

vars
	keyValue,	key1,	key2,	key3,	key4,	key5,	key6,	key7,	key8,	key9,	key10,	key11,	key12,	key13,	key14,	key15	: Any; // Max number of keys is 15
	displayStr,
	propName : String;
	sortType,
	numKeys	: Integer;
	iter	: Iterator;
	ti		: CM_TrackedItem;
	dict : CM_ExtKeyDynaDictionary;
	sa : StringArray;
begin

	if _ti = null then
		return;
	endif;

	dict := self.tblAll.allTableObjects;
	if dict = null or dict.isEmpty then
		return;
	endif;
	
	iter := dict.createIterator ();
	iter.startAtObject(_ti);
	while iter.next (ti) do
		if ti = _ti then
			break;
		endif;
		return;
	endwhile;
	
	sa := dict.getPropertyValue("allKeys").StringArray;
	if sa &lt;&gt; null then
		numKeys := sa.size;
	endif;
	
	if numKeys = 1 then
		dict.getIteratorKeys(key1,iter);
		dict.removeKeyEntry(key1, _ti);
	elseif numKeys = 2 then
		dict.getIteratorKeys(key1, key2,iter);
		dict.removeKeyEntry(key1, key2, _ti);
	elseif numKeys = 3 then
		dict.getIteratorKeys(key1, key2, key3 ,iter);
		dict.removeKeyEntry(key1, key2, key3 , _ti);
	elseif numKeys = 4 then
		dict.getIteratorKeys(key1, key2, key3, key4,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, _ti);
	elseif numKeys = 5 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, _ti);
	elseif numKeys = 6 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, _ti);
	elseif numKeys = 7 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, _ti);
	elseif numKeys = 8 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, _ti);
	elseif numKeys = 9 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, _ti);
	elseif numKeys = 10 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, _ti);
	elseif numKeys = 11 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, _ti);
	elseif numKeys = 12 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, _ti);
	elseif numKeys = 13 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, _ti);
	elseif numKeys = 14 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14, _ti);
	elseif numKeys = 15 then
		dict.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14, key15,iter);
		dict.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14, key15, _ti);
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="resetDestinations" id="70cea6c4-01fb-4808-8364-5350264c5cad">
        <source>resetDestinations();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwndl1	Initial creation

*/

vars
	aPort : CM_Port;
	portDict : CM_PortByCodeDict;
	portCmbOrderDescrFirst : Boolean;
	ls : Boolean;
begin
	create portDict transient;
	
	lstPorts.clearTable();

	app.myRoot.allActiveDestinations.copy(portDict);
	
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	app.cmsBeginLoad(ls);
	foreach aPort in portDict do
		if not chkAllPorts.value then
			if not aPort.bIsRail then
				continue;
			endif;
		endif;
		self.lstPorts.addItemObject(aPort.getDisplayFormatted(portCmbOrderDescrFirst), aPort);
	endforeach;
	app.cmsEndLoad(ls);
	self.lstPorts.setSelected(null);
	
	//self.lstPorts.userInputEnabled := false;
epilog
	delete portDict;
	endLoad;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetShowAllRows" id="cb6cb1fe-d2ab-4979-abc3-856d1bd632a8">
        <source>resetShowAllRows(_table: CM_DataTable input);
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intRow		: Integer;
begin

	foreach intRow in 1 to _table.rows do
		_table.accessRow(intRow).visible := true;
	endforeach;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetSummaryCriteria" id="c19caae3-2e73-4558-a744-11997265cd19">
        <source>resetSummaryCriteria();
//----------------------------------------------------------------
//	Created:	29 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 08/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 
vars
	filter	: CMQF_TrainLoadListSummary;
begin

	filter := self.mySummaryFilterTrain;
	
	filter.allCargoTypes.clear;
	filter.allOperators.clear;
	filter.allPortsDischarge.clear;
	if self.myQuery &lt;&gt; null then									// PAR #23794
		self.myQuery.CMQF_TrainLoadListTIs.allOnShipVoyages.clear;	//03 Nov 2009	NDL	Par 21519
	endif;
	filter.allTIs.clear();	//03 Nov 2009	NDL	Par 21519
	filter.allWLEs.clear();	// PAR #23794

	filter.setMyTrain( self.myCurrentTrain );
	self.lstCargoTypes.allSelectedObjects.copy(filter.allCargoTypes);
	self.lstOperators.allSelectedObjects.copy(filter.allOperators);
	self.lstPorts.allSelectedObjects.copy(filter.allPortsDischarge);
	
	if self.myQuery &lt;&gt; null then									// PAR #23794
		self.lstVoyages.allSelectedObjects.copy(self.myQuery.CMQF_TrainLoadListTIs.allOnShipVoyages);	//03 Nov 2009	NDL	Par 21519
	endif;	

end;</source>
    </JadeMethod>
    <JadeMethod name="resortTableObjects" id="16f9648c-03c2-4710-80df-dacaa6285726">
        <updating/>
        <source>resortTableObjects(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	09 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	numRows,
	idx : Integer;
	obj : Object;
begin

	_theTable.initTableObjectsDynaDict(CM_TrackedItem, _theTable.myEntTableDef.allEntTableRows.size);
	
	idx := _theTable.fixedRows;
	_theTable.rows := idx;

	foreach obj in _theTable.allTableObjects do
		if CM_TrackedItem.hasInstance(obj) then
			self.doQueryAddItem(_theTable, 0, obj.CM_TrackedItem, null);
		endif;
	endforeach;

	self.doTblDataRenumberItems(_theTable, 0);
	
	if global.isValidObject(self.myCurrentTrackedItem) then
		_theTable.selectObject(self.myCurrentTrackedItem, false);
	else
		self.myCurrentTrackedItem := null;
	endif;
		
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectAll" id="18152070-af5c-482f-8f04-0756492dd348">
        <source>selectAll();
// ---------------------------------------------------------------------------
// Created:		19 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//08 Dec 2011	NDL	Par 28797
vars
	theTable : CM_DataTable;
begin
	if self.fldMain.topSheet = self.shtNonplanned then
		theTable := self.tblData;
	elseif self.fldMain.topSheet = self.shtPlanned then
		theTable := self.tblPlanned;
	elseif self.fldMain.topSheet = self.shtSummary then
		theTable := self.tblSummary;
	elseif self.fldMain.topSheet = self.shtAll then
		theTable := self.tblAll;
	endif;

	if self.mnuContextSelectAll.caption = app.getErrorString(SelectAll) then
		if self.fldMain.topSheet = self.shtSummary then
			self.selectAllSummary();
		else
			theTable.selectAll();
		endif;
		
		
		self.btnSelectAllTIs.bubbleHelp := app.getErrorString(SHP_UnSelect_Al);
		self.mnuContextSelectAll.caption := app.getErrorString(SHP_UnSelect_Al);
	else
		//theTable.deselectAll(); AER 17821
		self.btnSelectAllTIs.bubbleHelp := app.getErrorString(SelectAll);
		self.mnuContextSelectAll.caption := app.getErrorString(SelectAll);
	endif;

	//update the status caption
	self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblData.allSelectedObjects.size.asStringJMT;

end;</source>
    </JadeMethod>
    <JadeMethod name="selectAllSummary" id="84d8d2a7-c9d4-47f8-8cee-68193ef82507">
        <source>selectAllSummary();
// ---------------------------------------------------------------------------
// Created:		23 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;
	numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	theTable := self.tblSummary;
	numRows := theTable.rows;
	theTable.allSelectedObjects.clear();

	foreach rowIdx in theTable.fixedRows to numRows do
		jRow := theTable.accessRow(rowIdx);
		if not jRow.visible then
			//only select visible rows PAR 11045
			continue;
		endif;
		if jRow.itemObject = null then
			continue;
		endif;
		if jRow.itemObject.CMIF_LoadListSummaryObject.isoGroupingKey = null then
			continue;
		endif;
		
		jRow.selected := true;
		if jRow.itemObject &lt;&gt; null then
			theTable.allSelectedObjects.add(jRow.itemObject);
		endif;
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="203b1695-84b0-4d1e-954b-e0f642a8cef5">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//08 Dec 2011	NDL	Par 28797
vars
	tmpBackColor		: Integer;
	
begin
	
	inheritMethod(_colorControl);
	tmpBackColor := self.backColor;

	self.fldMain.backColor := tmpBackColor;
	self.shtPlanned.backColor := tmpBackColor;
	self.shtSummary.backColor := tmpBackColor;
	self.shtNonplanned.backColor := tmpBackColor;
	self.shtAll.backColor := tmpBackColor;
	self.frmPreferences.backColor := tmpBackColor;
	self.setColorsForTable(self.tblPlanned);
	self.setColorsForTable(self.tblPlannedInfo);
	self.setColorsForTable(self.tblAll);
		
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setColours" id="fd4aee88-db7c-4313-80bb-2bdd5f8eda13">
        <updating/>
        <source>setColours() updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.xmlColourPlanned = 0 then
		self.xmlColourPlanned := self.ColourYellowLight;
	endif;
	if self.xmlColourNonPlanned = 0 then
		self.xmlColourNonPlanned := self.ColourYellowLight;
	endif;
	if self.xmlColourOnTrain = 0 then
		self.xmlColourOnTrain := self.ColourBlueLight;
	endif;
	self.clrPlanned.ignoreSkin := true;
	self.clrNonPlanned.ignoreSkin := true;
	self.clrOnTrain.ignoreSkin := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultKeyCodes" id="ee2b9f72-c0f5-4df2-84e2-036b3034cd43">
