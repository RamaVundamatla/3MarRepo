    <JadeMethod name="addWord" id="14af0f0f-9442-4d31-85fc-46b0b35ad009">
        <source>addWord() protected;
// --------------------------------------------------------------------------------
// Created:		23 June 2001 by cnwdad1
//
// Purpose:		Adds a word to the spelling dictionary.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wordObj			: CnEcSpellWord;
	spellRootObj	: CnEcSpellRoot;
	newWord			: String;
	errorMessage	: String;
	
begin
	newWord	:=	txtEditWord.cnEcString().toLower();
	
	if newWord &lt;&gt; null then
		spellRootObj	:=	app.myBaseRoot.getSpellRoot();
		
		errorMessage	:=	self.aMyTA.trxSpellWordCreate(	spellRootObj,
															spellRootObj,
															newWord,
															wordObj);
		
		if errorMessage = null then
			tblSpellDict.clearAllSelected();
			self.selectWord();
		else
			app.msgBox(errorMessage, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnA_click" id="6128f0bf-93cd-4bc8-b214-77f8ba2d6655">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnA_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		23 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.setStartRow(jadeMask.name[jadeMask.name.length]);
	txtStartFrom.text	:=	null;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
