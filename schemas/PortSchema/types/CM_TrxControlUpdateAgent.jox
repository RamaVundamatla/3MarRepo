    <JadeMethod name="trxInvoiceCopy" id="e8016110-ddcf-48b3-b451-5f9b620ef0f8">
        <updating/>
        <source>trxInvoiceCopy(_pendingCMIF : CMIF_InvoiceStatus input;
				_newReserveStatus : Integer;
				_pendingInv : CM_Invoice output;
				_passport : CM_Passport input
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Oct 2018 cnwma1	ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice

*/

vars
	orginalInvoice : CM_Invoice;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	if _pendingCMIF &lt;&gt; null then	
		orginalInvoice := _pendingCMIF.myInvoice;
	endif;
	
	if orginalInvoice = null then
		app.raiseCMException(Invoice_selected,null,null);
		return;
	endif;
	
	if not orginalInvoice.allCashPayments.isEmpty then
		app.raiseCMException(Not_copy_invoic_that_paymen,null,null);
	endif;
	beginTransaction;
	orginalInvoice.doCopyProcessing(_pendingCMIF,
									_newReserveStatus,
									_pendingInv,
									_passport
									);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pendingCMIF" type="CMIF_InvoiceStatus" usage="input"/>
        <Parameter name="_newReserveStatus" type="Integer"/>
        <Parameter name="_pendingInv" type="CM_Invoice" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxInvoiceGeneration" id="e62fa61b-5389-49f2-bdeb-a36bd9197c66">
        <updating/>
        <source>trxInvoiceGeneration( _invoiceGenerationAgent : CM_InvoiceGenerationAgent input; _passport : CM_Passport input ) updating;
/* ---------------------------------------------------------------------------
Created:	17 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
		
	beginTransaction;
	app.myUtilityUA.utlInvoiceGeneration( _invoiceGenerationAgent, _passport );

epilog	
