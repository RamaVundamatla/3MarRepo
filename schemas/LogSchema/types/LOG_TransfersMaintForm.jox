    </JadeMethod>
    <JadeMethod name="getAvailableLocations" id="8dfedf5b-f0f6-4bd7-abd9-2323d0e3a699">
        <source>getAvailableLocations() protected;

vars

	grade			: CM_LogGrade;
	type			: CM_LogType;
	treatment		: CM_LogTreatment;
	length			: CM_LogLength;
	operator		: CM_Operator;
	species			: CM_LogSpecies;
	logArea			: CM_LogArea;
	logController	: CM_LogController;
	tmpLCSearch		: CMIF_SearchTypes;

	prevSelection	: String; //24 Sep 2008	cnwdz2	PAR 17987

begin
	if self.selection = LOGLOCATDOCKET then		// 17/09/2008 cnwar2 #17957 (CCMS1095)
		self.getAvailableLocationsDockets();
		return;
	endif;
	
	/*
	Date		Who		Reason
	24 Sep 2008	cnwdz2	PAR 17987 - get previously selected to location
	*/
	self.allToLocations.clear;
	prevSelection := self.cmbTOLocation.text;
	
	if self.selection &lt;&gt; LOGID and self.mySelectedDocketDef = null then 
		return;
	endif;
	
	self.tblActionData.setValueByName(ETRow_Location, null);
	operator := getSupplier();
	species := getLogSpecies();
	grade := getLogGrade();	
	getActionFormRemaining(treatment, type, length);
	
	if operator = null and
	   species = null and
	   grade = null and
	   type = null and
	   treatment = null and
	   length = null then
	   	self.myTerminal.getLocationsForType(TA_TYPE_LOGAREA, false, self.allToLocations);
	else
		create tmpLCSearch transient;
		tmpLCSearch.myOperator := operator;
		tmpLCSearch.mySpecies := species;
		tmpLCSearch.myGrade := grade;
		tmpLCSearch.myType := type;
		tmpLCSearch.myTreatment := treatment;
		tmpLCSearch.myLength := length;
		self.myTerminal.availableLocationsForType(tmpLCSearch, self.allToLocations, TA_TYPE_LOGAREA);
	endif;

	self.myAssistant.comboBoxAddLocationsWithNull(self.cmbTOLocation, self.allToLocations);
	/*
	Date		Who		Reason
	24 Sep 2008	cnwdz2	PAR 17987 - save previously selected to location
	*/
	if self.cmbTOLocation.findStringExact(1,prevSelection) &lt;&gt; -1 then
		self.cmbTOLocation.text := prevSelection;
		self.tblActionData.setValueByName(ETRow_Location, prevSelection);	
	else
		self.tblActionData.setValueByName(ETRow_Location, null);	
	endif;

epilog
	
//	process.profilerStop();
//	process.profilerReport('d:\cnwxmast\logs\getAvail.log');
	delete tmpLCSearch;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAvailableLocationsDockets" id="96cf933b-6960-4e0b-b341-c904348404c4">
        <source>getAvailableLocationsDockets() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2008	cnwar2	Initial creation

*/

vars

	grade			: CM_LogGrade;
	type			: CM_LogType;
	treatment		: CM_LogTreatment;
	length			: CM_LogLength;
	operator		: CM_Operator;
	species			: CM_LogSpecies;
	logArea			: CM_LogArea;
	logController	: CM_LogController;
	tmpLCSearch		: CMIF_SearchTypes;
	tmpLocs			: CM_LCByIdExtKeyDict;
	tmpLocation		: CM_LocationsController;
	tmpLogDef		: CMIF_DocketLogDef;
	idx,	
	theColumn,
	numRows			: Integer;
	cell			: JadeTableCell;
	firstTime		: Boolean;
	
	prevSelection	: String; //24 Sep 2008	cnwdz2	PAR 17987

begin
	/*
	Date		Who		Reason
	24 Sep 2008	cnwdz2	PAR 17987 - get previously selected to location
	*/
	self.allToLocations.clear;
	prevSelection := self.cmbTOLocation.text;
	
	create tmpLCSearch transient;
	create tmpLocs transient;
	
	firstTime	:= true;
	numRows 	:= self.tblSelectData.rows;
	theColumn 	:= self.tblSelectData.getColumnByRowName(ETRow_SelectedDocket);
	if theColumn &lt;&gt; 0 then
		foreach idx in 2 to numRows do
			cell :=	self.tblSelectData.accessCell(idx, theColumn);
			if cell.text.Integer.Boolean = true then
				// loop through checked rows
				tmpLogDef := self.tblSelectData.accessRow(idx).itemObject.CMIF_DocketLogDef;
				if tmpLogDef &lt;&gt; null then
					operator 	:= tmpLogDef.myOperator;
					species 	:= tmpLogDef.getSpeciesReference;
					grade 		:= tmpLogDef.getGradeReference;
					treatment	:= tmpLogDef.getTreatmentReference;
					type		:= tmpLogDef.getTypeReference;
					length		:= tmpLogDef.getLengthReference;
					
					if operator = null and
					   species = null and
					   grade = null and
					   type = null and
					   treatment = null and
					   length = null then
						self.myTerminal.getLocationsForType(TA_TYPE_LOGAREA, false, tmpLocs);
					else					
						tmpLCSearch.myOperator 	:= operator;
						tmpLCSearch.mySpecies 	:= species;
						tmpLCSearch.myGrade		:= grade;
						tmpLCSearch.myType 		:= type;
						tmpLCSearch.myTreatment	:= treatment;
						tmpLCSearch.myLength 	:= length;
						self.myTerminal.availableLocationsForType(tmpLCSearch, tmpLocs, TA_TYPE_LOGAREA);
					endif;
				endif;
				
				if firstTime then
					tmpLocs.copy(self.allToLocations);
					firstTime := false;
				endif;		
				foreach tmpLocation in self.allToLocations do
					if not tmpLocs.includes(tmpLocation) then
						self.allToLocations.remove(tmpLocation);
					endif;
				endforeach;
			endif;
					
		endforeach;
	endif;

	self.myAssistant.comboBoxAddLocationsWithNull(self.cmbTOLocation, self.allToLocations);
	/*
	Date		Who		Reason
	24 Sep 2008	cnwdz2	PAR 17987 - save previously selected to location
	*/
	if self.cmbTOLocation.findStringExact(1,prevSelection) &lt;&gt; -1 then
		self.cmbTOLocation.text := prevSelection;
		self.tblActionData.setValueByName(ETRow_Location, prevSelection);	
	else
		self.tblActionData.setValueByName(ETRow_Location, null);	
	endif;

epilog
	delete tmpLCSearch;
	delete tmpLocs;	
end;</source>
        <access>protected</access>
    </JadeMethod>
