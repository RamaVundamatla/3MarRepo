    <JadeMethod name="utlCreateCargoCheck" id="e46915b9-16a9-4582-b1de-885e23e98b69">
        <source>utlCreateCargoCheck(	_proxyCargoCheck : CM_CargoCheck; 
						_newCargoCheck   : CM_CargoCheck output; 
						_passport 		 : CM_Passport input	);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	cancelSave : Boolean;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCargoCheck(_proxyCargoCheck);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create _newCargoCheck as _proxyCargoCheck.class persistent;
	_newCargoCheck.setForCreate(_proxyCargoCheck, app.myPassport);
	
	/*
	31.03.2025 navma1 #MTN-34387
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newCargoCheck);
	endif;
	*/
end;</source>
