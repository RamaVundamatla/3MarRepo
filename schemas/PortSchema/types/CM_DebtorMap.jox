    <JadeMethod name="validateForUpdate" id="14eb62d9-93c7-457f-af00-5f84729e2adb">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
//09 Feb 2016	NDL	Par 37504
// ---------------------------------------------------------------------------

vars

	str : String;

begin

	if self.myServiceBroker &lt;&gt; null then
		str := self.myServiceBroker.getDescription;
	else
		str := "Unknown";
	endif;

	
	if self.myDebtorNode = null then
		app.raiseCMException2(No_associated_debtor, "Debtor Map", str, null, null );
	endif;

end;</source>
