<CollClass name="CM_KPICargoByTerminalDT" id="29a6b951-1cb9-469f-9439-51d9002f510c">
    <loadFactor>66</loadFactor>
    <memberType name="CM_KPICargoEntity"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="statistic"/>
    <MemberKey>
        <property name="CM_KPI::myTerminal"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_KPI::dateTime"/>
    </MemberKey>
    <JadeMethod name="getAllTIsForCargoMonth" id="ea819f01-76b3-4da2-aa6c-9dacbd947665">
        <source>getAllTIsForCargoMonth(_terminal : CM_Terminal;_month : TimeStamp; _contLength : Integer; _tiSet : ObjectArray input);
/*

Date		    Who			Reason
18 February 2011	cnwas3	  Initial creation
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars	
	iter  					: Iterator;
	cargoEntity 			: CM_KPICargoEntity;	
	idx 					: Integer;
	numItems,numQty 		: Integer;
	numVolume, numWeight 	: Decimal[23,5];
	now,month 				: TimeStamp;
	
begin	
	if _tiSet = null then
		return;
	endif;
	
	now := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	month := _month.cnEcGetBeginningOfMonth();
	
	iter := self.createIterator();
	cargoEntity := self.getAtKeyGeq(_terminal,month);
	if cargoEntity = null or _terminal &lt;&gt; cargoEntity.myTerminal then
		return;
	endif;
	iter.startAtObject(cargoEntity);
	while iter.next(cargoEntity) and 
		(_terminal = cargoEntity.myTerminal) and
		(cargoEntity.dateTime.date.year() = month.date.year()) and
		(cargoEntity.dateTime &lt;= now and cargoEntity.dateTime.date.month() = month.date.month()) do
				cargoEntity.getAllTrackedItems(_contLength,_tiSet);	
	endwhile;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_month" type="TimeStamp"/>
        <Parameter name="_contLength" type="Integer"/>
        <Parameter name="_tiSet" type="ObjectArray" usage="input"/>
    </JadeMethod>
</CollClass>
