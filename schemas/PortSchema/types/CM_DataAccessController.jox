    <JadeMethod name="compareDataControllerObjs" id="a0afb397-e139-44d8-9fc7-a4cffe0d8444">
        <source>compareDataControllerObjs(_dac : CM_DataAccessController) : Boolean;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	obj	: CM_Object;

begin

	foreach obj in self.allObjects do
		if not _dac.allObjects.includes(obj) then
			return false;
		endif;
	endforeach;
	return true;


end;</source>
        <Parameter name="_dac" type="CM_DataAccessController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
