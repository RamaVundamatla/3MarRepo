/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2016	cnwns1	Initial creation

*/

vars
	timezone : CMIF_TimeZoneInfo;
begin

	if combobox.parent.isKindOf(CM_EntryTable) then
		combobox.parent.CM_EntryTable.setValueByControlName(combobox.name, combobox.text);
		if combobox.listIndex &gt; 0 then	//27 Oct 2016	NDL	TFS 2879
			timezone := combobox.itemObject[combobox.listIndex].CMIF_TimeZoneInfo;
			if timezone &lt;&gt; null then	//27 Oct 2016	NDL	TFS 2879
				self.myCurrentTableItem.SOPTM_Terminal.myIntFaceConfig.timeZoneID := timezone.id;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
