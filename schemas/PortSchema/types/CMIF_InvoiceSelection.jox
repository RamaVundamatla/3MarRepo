    <JadeMethod name="checkInvDebtorSeparation" id="19881d2b-7d4f-40f8-a650-a731a26166d6">
        <source>checkInvDebtorSeparation(_invoice : CM_Invoice) : Boolean;
/*

Purpose:			Checks if the debtor has invoice separation criteria

Parameters:			_invoice	CM_Invoice	Contains the invocie we can get the type from and check if we have a separation for the debtor on the invoice

Return Value:		Boolean	Representing whether we have separation criteria or not

Date				Who		Reason
29 August 2022		navpw1	Initial creation TFS: 54565 (54384) 29Aug2022 NAVPW1
01 November 2022	navpw1	TFS: 55285 - Added a lookup for the default debtor (RDT) in case a config exists for this debtor but not the debtor we are searching for
26 January 2024		navdap1	TFS 61951 removed releaseRequest unused local variable

TFS BUG 56925 06MAR2023 NAVAB1 - Do not use the trackeditem reference it is only set for 'suspense' invoices. We already have the correct values set on SELF and then the invoice also will have the values to be compared.
*/

vars
	surchargesAndExemptions 	: CM_InvoiceTypeSurchargeExempt;
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;
	trackedItem					: CM_TrackedItem;
	
begin
	surchargesAndExemptions := self.myInvoiceType.mySurchargeAndExemptions;
	
	if surchargesAndExemptions = null then
		return false;
		
	endif;
	
	if self.myBank &lt;&gt; null
	and self.myBank &lt;&gt; _invoice.bank then
		return false;
	endif;
	
	if self.myTerminal &lt;&gt; null
	and self.myTerminal &lt;&gt; _invoice.bank.terminal then
		return false;
	endif;
	
	if self.paymentType &lt;&gt; _invoice.paymentType then
		return false;
	endif;
	
	invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.debtor];
	
	if invoiceTypeDebtorSeparation = null then
		//Check default debtor
		invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.myBank.rootDebtor];
		if invoiceTypeDebtorSeparation = null then
			return false;
		endif;
		
	endif;
	
	//Do matching checks
	if self.voyageGroupCode &lt;&gt; null 
	and invoiceTypeDebtorSeparation.separatedByVoyageGroup
	and	self.voyageGroupCode.trimRight &lt;&gt; _invoice.voyageGroupCode.trimRight then
		return false;
	endif;
	
	if self.voyageCode &lt;&gt; null 
	and invoiceTypeDebtorSeparation.separatedByVoyage
	and	self.voyageCode.trimRight &lt;&gt; _invoice.voyageCode.trimRight then
		return false;
	endif;	

	trackedItem := _invoice.myTrackedItem;
	
	if self.trackedItemId &lt;&gt; null
	and invoiceTypeDebtorSeparation.separatedByCargoId
	then
		if trackedItem &lt;&gt; null then
			if self.trackedItemId.trimRight &lt;&gt; trackedItem.id then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	if self.cargoGroupId &lt;&gt; null
	and invoiceTypeDebtorSeparation.separatedByCargoGroupId
	then
// ### TFS BUG 56925 06MAR2023 NAVAB1		if trackedItem &lt;&gt; null and trackedItem.myCargoGroup &lt;&gt; null then
// ### TFS BUG 56925 06MAR2023 NAVAB1			if self.cargoGroupId.trimRight &lt;&gt; trackedItem.getMyCargoGroupId then
		if _invoice.myCargoGroup &lt;&gt; null then // ### TFS BUG 56925 06MAR2023 NAVAB1
			if self.cargoGroupId.trimRight &lt;&gt; _invoice.myCargoGroup.id then // ### TFS BUG 56925 06MAR2023 NAVAB1
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	if self.bookingReference &lt;&gt; null
	and invoiceTypeDebtorSeparation.separatedByBooking
	then
// ### TFS BUG 56925 06MAR2023 NAVAB1		if trackedItem &lt;&gt; null then
// ### TFS BUG 56925 06MAR2023 NAVAB1			if self.bookingReference.trimRight &lt;&gt; trackedItem.bookingReference then	
		if _invoice.myBookingRef &lt;&gt; null then // ### TFS BUG 56925 06MAR2023 NAVAB1
			if _invoice.myBookingRef.bookingReference &lt;&gt; self.bookingReference then // ### TFS BUG 56925 06MAR2023 NAVAB1
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	if self.releaseRequest &lt;&gt; null
	and invoiceTypeDebtorSeparation.separatedByReleaseRequest
	then
 /* ### TFS BUG 56925 06MAR2023 NAVAB1		
		if trackedItem &lt;&gt; null then
			
			releaseRequest := trackedItem.allBulkReleasesReleased.first;
			
			if releaseRequest = null then
				releaseRequest := trackedItem.allBulkReleasesAssigned.first;
			endif;
			
			if releaseRequest = null then
				return false;
			endif;
			*/
		if _invoice.myReleaseRequest &lt;&gt; null then // ### TFS BUG 56925 06MAR2023 NAVAB1
			if self.releaseRequest &lt;&gt; _invoice.myReleaseRequest then // ### TFS BUG 56925 06MAR2023 NAVAB1
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	if self.bolNumber &lt;&gt; null 
	and invoiceTypeDebtorSeparation.separatedByBillOfLading
	then
// ### TFS BUG 56925 06MAR2023 NAVAB1		if trackedItem &lt;&gt; null then	
		if _invoice.myBOL &lt;&gt; null then
			// ### TFS BUG 56925 06MAR2023 NAVAB1 if self.bolNumber.trimRight &lt;&gt; trackedItem.billOfLading then
			if self.bolNumber.trimRight &lt;&gt; _invoice.myBOL.number then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	// ### TFS BUG 56925 06MAR2023 NAVAB1
	if self.poNumber &lt;&gt; null 
	and invoiceTypeDebtorSeparation.separatedByPONumber	then
		if _invoice.purchaseOrderNumber &lt;&gt; null then
			if self.poNumber.trimRight &lt;&gt; _invoice.purchaseOrderNumber then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="fd1db27b-c172-4d9a-a62f-fe2f75eb3ce7">
        <updating/>
        <source>create() updating;

vars

begin
	status := CM_Invoice.INVOICE_ALL_STATUS;
end;</source>
    </JadeMethod>
    <JadeMethod name="hasinvDebtorSeparation" id="6e9ca80e-30a2-4719-8e21-650f203eb918">
        <source>hasinvDebtorSeparation() : Boolean;
/*

Purpose:			Checks whether we have debtor separations based on the invoice type

Parameters:			NONE

Return Value:		Boolean	Representing whether we have debtor separations or not

Date				Who		Reason
29 August 2022		navpw1	Initial creation TFS: 54565 (54384)
01 November 2022	navpw1	TFS: 55285 - Added a lookup for the default debtor (RDT) in case a config exists for this debtor but not the debtor we are searching for
*/

vars
	surchargesAndExemptions 	: CM_InvoiceTypeSurchargeExempt;
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;
	
begin
	if self.myInvoiceType = null then
		return false;
	endif;

	surchargesAndExemptions := self.myInvoiceType.mySurchargeAndExemptions;
	
	if surchargesAndExemptions = null then
		return false;
		
	endif;
	
	invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.debtor];
	
	if invoiceTypeDebtorSeparation = null then
		//Check default debtor
		if self.myBank &lt;&gt; null then
			invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.myBank.rootDebtor];
		endif;
		
	endif;
	
	if invoiceTypeDebtorSeparation &lt;&gt; null then
		return true;
		
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateSelectionParameters" id="a44680d2-3efc-43cd-bdee-8a5aaf5984ea">
        <updating/>
        <source>populateSelectionParameters(_tran: CM_TITransaction; _isManual : Boolean; _voyageCode, _tiId, _bolNumber : String) updating;
/*

Purpose:			Populates the selection parameters on the class from the transaction and other data passed in

Parameters:			_tran		CM_TITransaction	The transaction to use to populate the selection criteria
					_isManual	Boolean				Whether the invoice is manual or not
					_voyageCode	String				The voyage code to use to populate the selection criteria
					_tiId		String				The tracked item id to use to populate the selection criteria
					_bolNumber	String				The bol number to use to populate the selection criteria

Return Value:		NONE

Date				Who		Reason
29 August 2022		navpw1	Initial creation TFS: 54565 (54384)
01 November 2022	navpw1	TFS: 55285 - Added a lookup for the default debtor (RDT) in case a config exists for this debtor but not the debtor we are searching for
26 January 2024		navdap1	TFS 61951 Jade Upgrade Source Compare - renamed local variable releaseRequest (so it's not the same as an attribute)
*/

vars
	surchargesAndExemptions 	: CM_InvoiceTypeSurchargeExempt;
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;
	voyage						: CM_Voyage;
	trackedItem					: CM_TrackedItem;
	relReq						: CM_BulkRelease;
	
begin
	surchargesAndExemptions := self.myInvoiceType.mySurchargeAndExemptions;
	
	if surchargesAndExemptions = null then
		return;
	endif;
	
	invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.debtor];
	
	if invoiceTypeDebtorSeparation = null then
		//Check default debtor
		invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.myBank.rootDebtor];
		if invoiceTypeDebtorSeparation = null then
			return;
		endif;
		
	endif;
	
	trackedItem := _tran.myTrackedItem;
	
	if invoiceTypeDebtorSeparation.separatedByVoyage then
		if _isManual then
			self.voyageCode := _voyageCode;
		else
			if _tran &lt;&gt; null then
				//and tran.myTrackedItem.myVoyage &lt;&gt; null then
				// 29752 sometimes using export voyage not import for tranships
				//  	transaction voyage has already been adjusted for tranships
				// modified for 29957 to keep the ability to change TI voyage and re-evaluate invoice line to new invoice (based on the new voyage)
				//		only use the transaction voyage for a tranship
				if trackedItem &lt;&gt; null then
					if trackedItem.isTranshipItem then
						voyage := _tran.getVoyage();
						if voyage &lt;&gt; null then
							self.voyageCode := voyage.code;
						endif;
					elseif trackedItem.myVoyage &lt;&gt; null then
						self.voyageCode := trackedItem.myVoyage.code;
					endif;
				endif;
			endif;
		endif;
		
	endif;
	
	if invoiceTypeDebtorSeparation.separatedByVoyageGroup then
		if _tran &lt;&gt; null then
			if trackedItem &lt;&gt; null then
				if trackedItem.isTranshipItem then
					voyage := _tran.getVoyage();
					if voyage &lt;&gt; null then
						self.voyageGroupCode := voyage.voyageGroupCode;
					endif;
				elseif trackedItem.myVoyage &lt;&gt; null then
					self.voyageGroupCode := trackedItem.myVoyage.voyageGroupCode;
				endif;
			endif;
		endif;
		
	endif;
	
	if invoiceTypeDebtorSeparation.separatedByCargoId then
		if _isManual then
			self.trackedItemId := _tiId;
		else
			if _tran &lt;&gt; null and
			   trackedItem &lt;&gt; null then
				// TFS 5397 For Merge transactions where one TI is being merged into another
				// (NOT the same ID), we want the search to look for an invoice line for
				// the TI we're merging into
				if _tran.isKindOf(CM_Merge)
				and ((trackedItem.totalWeight = null and trackedItem.isBulkByWeight)
				or (trackedItem.totalVolume = null and trackedItem.isBulkByVolume))
				and _tran.CM_Merge.getOtherTrackedItem &lt;&gt; null then
					self.trackedItemId := _tran.CM_Merge.getOtherTrackedItem.id;
				else
					self.trackedItemId := trackedItem.id;
				endif;
			endif;
		endif;
		
	endif;
	
	if invoiceTypeDebtorSeparation.separatedByCargoGroupId then
		if _tran &lt;&gt; null and
		   trackedItem &lt;&gt; null and trackedItem.myCargoGroup &lt;&gt; null
		then
			self.cargoGroupId := trackedItem.getMyCargoGroupId;
		endif;
		
	endif;
	
	if invoiceTypeDebtorSeparation.separatedByBillOfLading then
		if _isManual then
			self.bolNumber := _bolNumber;
		else
			if _tran &lt;&gt; null and trackedItem &lt;&gt; null then
				self.bolNumber := trackedItem.billOfLading;
			endif;
		endif;
		
	endif;
	
	if invoiceTypeDebtorSeparation.separatedByBooking then
		if _tran &lt;&gt; null and trackedItem &lt;&gt; null then
			self.bookingReference := trackedItem.bookingReference;
		endif;
		
	endif;
	
	if invoiceTypeDebtorSeparation.separatedByReleaseRequest then
		if _tran &lt;&gt; null and trackedItem &lt;&gt; null then
			relReq := trackedItem.allBulkReleasesReleased.first;
			
			if relReq = null then
				relReq := trackedItem.allBulkReleasesAssigned.first;
			endif;
			
			self.releaseRequest := relReq;
		endif;
		
	endif;
	
	 // ### BUG 56925 07MAR2023 NAVAB1
	if invoiceTypeDebtorSeparation.separatedByPONumber then
		if trackedItem &lt;&gt; null then
			self.poNumber := trackedItem.purchaseOrder;
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <Parameter name="_isManual" type="Boolean"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_bolNumber" type="String"/>
    </JadeMethod>
</Class>
