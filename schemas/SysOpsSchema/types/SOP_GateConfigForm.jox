    <JadeMethod name="txtDriverInstr_mouseDown" id="857d37f1-5c2d-4ed4-9032-ca5ea92a9eea">
        <controlMethod name="TextBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDriverInstr_mouseDown(textbox: TextBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2012	cnwndl1	Initial creation	Par 30689

*/

vars

begin

	if button = 2 then
		app.printReportDotMatrixLineUp( textbox.text.trimBlanks );
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
