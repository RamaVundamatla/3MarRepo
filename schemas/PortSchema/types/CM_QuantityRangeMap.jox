    <JadeMethod name="initFromServiceBroker" id="49477531-c6e5-4136-93d3-128a9f04d5b0">
        <source>initFromServiceBroker(_sb : CM_ServiceBroker);
// ---------------------------------------------------------------------------
// Created:		02 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		THIS IS NEEDED for the 753 upgrade
//
// ---------------------------------------------------------------------------
vars
begin
	if _sb = null then
		return;
	endif;
	
// TFS 40620	self.allInvoiceLineMaps.clear;
// TFS 40620	self.allInvoiceLinesUsed.clear;
	self.allRegisteredMethods.clear;
	
// TFS 40620	_sb.invoiceLineDescMap.copy(self.allInvoiceLineMaps);
// TFS 40620	_sb.invoiceLineDescs.copy(self.allInvoiceLinesUsed);
	_sb.allRegisteredMethods.copy(self.allRegisteredMethods);
end;</source>
