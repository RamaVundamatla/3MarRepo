    <JadeMethod name="machineTaskRequest" id="ac8449f7-8c4a-4481-bf3c-fbaa8b3c496e">
        <source>machineTaskRequest(_machine: CM_Machine): CM_RTQueueTask protected;
//07 January 2009	cnwdw1	
//
vars
	mediator : CM_RadioTelemetryMediator;
begin
	create mediator transient;
	mediator.machine := _machine;
	app.myTrxRT.trxRequestTask(mediator, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings(); 
	return mediator.task;
epilog
	delete mediator;
end;</source>
