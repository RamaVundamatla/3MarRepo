<GUIClass name="CMUI_ComboYACriteriaType" id="653617c7-962e-4eee-9abe-0c99040c7ad8">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myYACriteriaControl" id="84369e72-660e-4895-80a2-05e6ee375716">
        <embedded/>
        <type name="CMUI_BaseControl"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="click" id="37a55bc9-3dda-4ad2-9444-817f04b13f8d">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(combobox: ComboBox input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod(combobox);
	self.myYACriteriaControl.doCriteriaTypeSelected();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayEntry" id="47a6f9a4-0206-4645-a5bc-51dd7708d9db">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer): String updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		04 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	criteriaTypeObj	: CM_YACriteriaType;
	
begin
	inheritMethod(combobox, obj, lstIndex);
	
	criteriaTypeObj	:=	obj.CM_YACriteriaType;
	
//	if criteriaTypeObj.isNotAvailableForEntry then
//		return null;
//	endif;

	if criteriaTypeObj.isUsed then
		return criteriaTypeObj.description;
	else
		return null;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setCriteriaControl" id="78a2faf0-76da-44e1-ae05-ef60338d7b98">
        <updating/>
        <source>setCriteriaControl(pYACControlObj:CMUI_BaseControl) updating;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Purpose:		Sets a reference to the parent Yard Allocation Criteria control.
//
// Parameters:	pYACControlObj - A reference to the parent Yard Allocation Criteria control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myYACriteriaControl	:=	pYACControlObj;
end;</source>
        <Parameter name="pYACControlObj" type="CMUI_BaseControl"/>
    </JadeMethod>
