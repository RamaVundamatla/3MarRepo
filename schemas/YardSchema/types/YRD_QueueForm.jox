    <JadeMethod name="doBroadCastMessage" id="c18a352b-9950-42c4-a9e7-291b61425ad3">
        <source>doBroadCastMessage(_isQueue : Boolean);

// cnwdvb1 25 March 2003 

vars

	rtQueue : CM_RadioTelemetryQueue;
	machine	: CM_Machine;
	message	: String;
	machines : CM_MachineByIdDict;
begin
	message:=readBroadcastMessage();
	if message = null then
		return;
	endif;
	//epr TFS 4620 16/6/17 changes for Vehicle Apps now if machine was logged on they will see the message in the machine history
	create machines transient;
	
	if _isQueue then
		if not CM_RadioTelemetryQueue.hasInstance(self.lstQueues.listObject) then
			return;
		endif;
		rtQueue := self.lstQueues.listObject.CM_RadioTelemetryQueue;
		if rtQueue = null then
			return;
		endif;
		
		self.allViewedMachines.copy(machines);
				
	else
		self.getSelectedMachines(machines);

	endif;
	
	app.myTrxUA.trxSendMachineMessage(machines,message,app.myPassport);

epilog 
	delete machines;
end;</source>
        <Parameter name="_isQueue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeRTMoveMethodRule" id="c76b2164-d928-4a8f-bd6b-d2ca7984c4e5">
        <updating/>
        <source>doChangeRTMoveMethodRule(_newMoveMethodRule : CM_RTMoveMethodRule) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2010	cnwer1	Initial creation

*/

vars
	theReturn : Integer;
	objArray : ObjectArray;
	obj 	: Object;
	invalidObj : Boolean;
	theTask 	: CM_RTQueueTask;
	theEntry : CM_RTQueueEntry;
begin
	
	create objArray transient;
	self.tblQEntries.allSelectedObjects.copy(objArray);
	
	on Exception do app.handleDeletedObject(exception, theTask,invalidObj);
	foreach obj in objArray do
		invalidObj := false;  
			
		theTask := obj.CM_RTQueueTask;
		theEntry := theTask.myEntry;  
		if invalidObj then  
			continue;
		endif;

		while true do
			app.myTrxUA.trxChangeRTEntryMoveRule(theEntry,_newMoveMethodRule,app.myPassport);
			if not app.myPassport.trxCompletedOK then		
				theReturn := app.showErrorWarningDialog(app.getErrorString1(Change_move_method_rule,theTask.tiId), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endforeach;
epilog
	delete objArray;
end;</source>
        <Parameter name="_newMoveMethodRule" type="CM_RTMoveMethodRule"/>
    </JadeMethod>
    <JadeMethod name="doEntryAutoPlan" id="b91ac399-59a3-4101-825a-4c5043486d04">
        <updating/>
        <source>doEntryAutoPlan() updating;

/*

Purpose:	autoplan the cargo. 
For POP without a target should do the ti.autoplanon pickup code, else just run the autoplanner and use the same code as amend target location.		

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwrd1	Initial creation
ccms 2014
*/

vars
	wleSet : CM_WLESet;
begin

	if self.myCurrentTask.isPlanOnPickupNoTarget then
		// need to do new ti.autoplan on pickup code here
		create wleSet transient;
		wleSet.add(self.myCurrentTask.myEntry.myWorkListEntry);
		while true do
			app.myTrxUA.trxAutoPlanOnPickupMultipleTIs(wleSet, app.myPassport);
			if self.doTransactionLoopCompleted(app.getErrorString(Autoplan)) then
				break;
			endif;
		endwhile; 
	else
		// need to autoplan and then amend target locaiton
	endif;
	
	
epilog
	delete wleSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFindMachine" id="b2c20b1c-66bb-4f4b-a081-7be183decdaf">
        <updating/>
        <source>doFindMachine(pId : String) updating;
// ---------------------------------------------------------------------------
// Created:     17 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theMachine	: CM_Machine;
	idx			: Integer;
		
begin

	if pId = self.mnuQueueFindMachine.caption then
		return;
	endif;
	theMachine := self.myTerminal.machines[pId];
	
	if theMachine = null then
		// need an exception here
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '  invalid machine ' &amp; pId);
		return;
	endif;
	
	idx := lstQueues.findObject(theMachine.myPrimaryQueue);
	if idx &lt;= 0 then
		// need an exception here
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '  machine not found');
		return;
	endif;
	
	
	lstQueues.itemExpanded[idx] := true;
	lstQueues.listIndex := idx;
	self.lstQueues.itemSelected[idx] := true;
	self.lstQueues.click(self.lstQueues);
	//lstQueues.listIndex := idx;
	//self.lstQueues.itemSelected[idx]:=true;
	self.showQueueThumbnail(lstQueues.listObject);
		
end;</source>
        <Parameter name="pId" type="String"/>
    </JadeMethod>
    <JadeMethod name="doForceWeigh" id="80af53ce-7373-4bf1-be6d-7cb025fe3789">
        <updating/>
        <source>doForceWeigh() updating;
// -------------------------------------------
// Created 14 July 2004 by cnwdvb1
// -------------------------------------------
vars

	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin

	app.mousePointer := MousePointer_HourGlass;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxForceTrackedItemWeigh(self.myCurrentTask, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			app.msgBox('Forced weigh successfully initiated', 'Forced Weigh', MsgBox_OK_Only + MsgBox_Information_Icon);
			break;
		else
			theResult := app.showErrorWarningDialog('Forced weigh', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doIMVTaskShift" id="8fc91044-a91f-4ff8-8005-dfaf4cd8bdc3">
        <updating/>
        <source>doIMVTaskShift( _machine : CM_Machine) updating;
 
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
22 April 2010	cnwrd1	Initial creation
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	loadStateSet : Boolean;
	lReturn : Integer;
	lRealTask, lProxyTask : CM_RTQueueTask;
	lResult : Boolean;
	lIgnoreWarnings:Boolean;
begin

	//cnwrd1 par 31382 IMV work when not loged on.
	if not _machine.loggedOn  and not _machine.myTerminal.getConfig(AllowIMVWorkRTLoggedOff).Boolean then //cnwrd1 for par 31382 then
		lReturn :=  app.msgBox(app.getErrorString1(ERR_MACH_NOTLOGGED, _machine.id),"IMV Switch",MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon);
		if lReturn = MsgBox_Return_No then
			return;
		endif;
	endif;

	lRealTask := self.tblQEntries.accessRow(self.tblQEntries.row).itemObject.CM_RTQueueTask;
	app.cmsBeginLoad(loadStateSet);
	lProxyTask := lRealTask.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadStateSet);
	lProxyTask.setProxyAllocMachine(_machine, lRealTask.myEntry, lRealTask.sourceLocation, lRealTask.targetLocation, lRealTask.ti);
	
	//epr par 23174 17/3/10 needed to be in a loop to give users a chance to respond to warnings
	while true do
		app.myTrxUA.trxUpdateTaskSwitchIMV(lProxyTask,app.myPassport);
	//	delete lProxyTask;
		if not app.myPassport.trxCompletedOK then
			lReturn:=app.showErrorWarningDialog('IMV Switch', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   lReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		else
			self.clearErrorWarnings();
			self.showQueueThumbnail(lstQueues.listObject);
			break;
		endif;
		break;
	endwhile;
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	delete lProxyTask;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="doLoadAlertsScreen" id="2d0edad0-ab5b-4b95-a0c2-81057111abc0">
        <source>doLoadAlertsScreen();

// cnwdvb1 14 April 2003 

vars
	task				: CM_RTQueueTask;
	entry				: CM_RTQueueEntry;
begin

	task := self.myCurrentTask;
	entry := self.myCurrentEntry;
	if task = null or entry = null then
		return;
	endif;
		
	if not entry.alerts.size &gt; 0 then
		return;
	endif;
	
	app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, entry.alerts);
end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadContainerEnqForm" id="366f036c-f865-42b6-9494-6a6d0ed4f1a9">
        <source>doLoadContainerEnqForm();

// cnwdvb1 27 March 2003 

vars

	containerEnq		: CM_ContainerEnqForm;
	menuAction			: CMUI_MenuAction;
	container			: CM_Object;
	task				: CM_RTQueueTask;
	
begin

	task := self.myCurrentTask;

	if not global.isValidObject(task) then
		return;
	endif;
	container := task.ti;

	if container = null then
		return;
	endif;
	
	menuAction := app.myController.createMenuAction(PmAdmCargoEnquiryView, null, 
									self.myMasterMenuAction, self.myTerminal);
	if menuAction &lt;&gt; null then
		containerEnq := menuAction.goToObject(null, null, false, null).CM_ContainerEnqForm;
		if containerEnq &lt;&gt; null then
			containerEnq.showWithObject(container, true, false);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadNewQueueForm" id="a23ecf35-c968-4ecf-81c6-a1d1e6bbb42f">
        <source>doLoadNewQueueForm(_queue : CM_RadioTelemetryQueue);

// cnwdvb1 18 March 2003 

vars

	rtQueueMaintForm	: YRD_RTQueueMaintForm;
	menuAction			: CMUI_MenuAction;
	
begin

	if _queue &lt;&gt; null then
		if _queue.isSystemDefinedQueue() and not app.isSpecial() then
			// This needs a properly defined exception
			app.raiseCMException(Canno_edit_syste_defin_radio_t, null, null);
			return;
		endif;
		menuAction := app.myController.createMenuAction(PmAdmQueue_createView, null, 
										self.myMasterMenuAction, self.myTerminal);
		if menuAction &lt;&gt; null then
			rtQueueMaintForm := menuAction.goToObject(null, null, false, null).YRD_RTQueueMaintForm;
			if rtQueueMaintForm &lt;&gt; null then
				rtQueueMaintForm.showWithObject(_queue, true, false);
			endif;
		endif;
	else
		
		rtQueueMaintForm := app.loadForm(YRD_RTQueueMaintForm, YRD_Assistant, false, false, false, self.myTerminal, null).YRD_RTQueueMaintForm;
		
		if rtQueueMaintForm = null then
			return;
		endif;
		rtQueueMaintForm.show();
		rtQueueMaintForm.centreWindow();
		
	endif;
end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="doLstQueuesContextMenu" id="c4b3f806-d743-442f-a77e-f849dd6de7b0">
        <updating/>
        <source>doLstQueuesContextMenu(_cntrl: ListBox input; _conwin: Window input; _mouse: Boolean; _x, _y: Integer):Boolean updating, protected;
// -------------------------------------------
// Created 15 March 2004 by cnwdvb1
vars

	x1 : Real;
	y1 : Real;

begin

	// TFS 2198 CNWAB1
	// TFS 52945 NAVCS2 22/03/2022
	if not self.canMaintainRTQueue then
		return false;
	endif;


	x1 := _x;
	y1 := _y;
	if (not _mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if _cntrl.listIndex &lt; 0 then
	        y1 := 5;
	    else
	        y1 := _cntrl.positionTop(_cntrl.listIndex);
	    endif;
	endif;

	_cntrl.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.doShowMnuQueue(x1.Integer, y1.Integer);
	
	return false;                  // cancel further processing

end;</source>
        <access>protected</access>
        <Parameter name="_cntrl" type="ListBox" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLstQueuesDrapDrop" id="163329b1-54b6-47ab-9e3e-43bbcc229987">
        <updating/>
        <source>doLstQueuesDrapDrop(_listbox: YRD_QueueListBox input; _win: Window input; _x, _y : Real) updating, protected;
// -------------------------------------------
// Created 15 March 2004 by cnwdvb1
// -------------------------------------------
vars
	lObj 			: Object;
	lMachine		: CM_Machine; 
	lQueue			: CM_RadioTelemetryQueue;
	dragListIndex	: Integer;
	machines		: CM_MachineSet;
	rtQEntry 		: CM_RTQueueEntry;
	index : Integer;
begin

	_listbox.dragMode := DragMode_None;
	
	dragListIndex := _listbox.dragListIndex;

	if dragListIndex = -1 or dragListIndex = 0 then
		return;
	endif;
	lObj :=  _listbox.itemObject[dragListIndex];

	if lObj.isKindOf(CM_RadioTelemetryQueue) then
		lQueue := lObj.CM_RadioTelemetryQueue;
	elseif lObj.isKindOf(CM_RTQueueEntry) then
		lQueue := lObj.CM_RTQueueEntry.myQueue;
	endif;
	
	lObj := _win.userObject;
	if lObj &lt;&gt; null then
		if lObj.isKindOf(CM_Machine) then
			create machines transient; // adm 160909 Par 20550
			self.getSelectedMachines(machines);
			if machines.size &gt; 1 then
				self.doMoveMachines(lQueue);
			else
				lMachine := lObj.CM_Machine;
				self.doMoveMachine(lMachine,lQueue);
			endif;
			
			 //06 May 2016	NDL	TFS 1959
			foreach index in 1 to _listbox.listCount do
				if  _listbox.itemObject[index] = lQueue then
					_listbox.itemSelected[index] := true;
				else
					_listbox.itemSelected[index] := false;
				endif;
			endforeach;
			self.showQueueThumbnail(lQueue);
			
		else
			self.moveQueueMulti(lObj, _listbox.dragListIndex);	//17 July 2014	NDL	Par 25646
		endif;
	else
		if _win = self.tblQEntries then
			self.allSelectedRTQEntries.clear();
			foreach lObj in self.tblQEntries.allSelectedObjects do
				if lObj.isKindOf(CM_RTQueueTask) then
					self.allSelectedRTQEntries.add(lObj.CM_RTQueueTask.myEntry);
				endif;
			endforeach;
			
			self.moveQueueMulti(self.allSelectedRTQEntries.first,  _listbox.dragListIndex);	
			
		endif;
	endif;
epilog
	delete machines;
end;</source>
        <access>protected</access>
        <Parameter name="_listbox" type="YRD_QueueListBox" usage="input"/>
        <Parameter name="_win" type="Window" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doLstQueuesMouseMove" id="7de55bb1-e152-4d26-91a0-a03b11488105">
        <updating/>
        <source>doLstQueuesMouseMove(_listbox: YRD_QueueListBox input; _button: Integer; _shift: Integer; _x, _y: Real) updating, protected;
// -------------------------------------------
// Created 15 March 2004 by cnwdvb1
// -------------------------------------------
vars
	obj	: Object;
begin
	if _button = Window.MouseButton_Left then
		if app.dragDetected(_x, _y, self.origXPos, self.origYPos) then		
			// initiate a drag/drop
			obj := self.myFromListObject;
			//_listbox.startDrag();
			_listbox.dragMode := DragMode_Drag;
			if obj.isKindOf(CM_VoyageCraneQueue) then
				_listbox.dragCursor := self.picCraneIco.picture;
			elseif obj.isKindOf(CM_VoyageQueue) then
				_listbox.dragCursor := self.picVoyageIco.picture;
			elseif obj.isKindOf(CM_SubQueue) then
				_listbox.dragCursor := self.picQueueIco.picture;
			elseif obj.isKindOf(CM_RTQueueEntry) then
				_listbox.dragCursor := self.picEntryIco.picture;
				//epr 36240 2/6/15 problem with a quick drag selecting more than 1 entry to move	
				//self.getSelectedInListQueues(obj.CM_RTQueueEntry);
			endif;
			_listbox.userObject := obj;
			
			self.lstQueues.enableEvent('mouseMove', false); 
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_listbox" type="YRD_QueueListBox" usage="input"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_shift" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doMachineClick" id="4b9761d9-545c-4ddb-8ec7-f1c8d58b275a">
        <source>doMachineClick() protected;
// -------------------------------------------
// Created 08 December 2003 by cnwdvb1
// -------------------------------------------
/*

12 Feb 2000  CNWER1    CCMS 1032 changed to show more than one tasks for machine if they are twin lifting for example
18 May 2011	cnwkpd1	PAR #27579 - Added new parameter _addAtEnd to showTasksForQueueEntry, for performance

*/

vars

	machine : CM_Machine;
	task	: CM_RTQueueTask;
	invalidTask : Boolean;
	count 		: Integer;
begin

	if (not getCurrentMachine(machine)) then
		return;
	endif;
	
	tblQEntries.rows := tblQEntries.fixedRows;
	
	on Exception do app.handleDeletedObject(exception, task,invalidTask );
	
	count:=1;
/*	if machine.hasWorkingTasks then
		
		foreach task in machine.allCurrentWorkingQueueTasks do
			self.showTasksForQueueEntry(task.myEntry, count, true);		// PAR #27579
			count:=count+1;
		endforeach;
	else*/
		foreach task in machine.allCurrentQueueTasks do
			self.showTasksForQueueEntry(task.myEntry, count, true);		// PAR #27579
			count:=count+1;
		endforeach;
	//endif;

	foreach task in machine.allAllocatedQueueTasks do
		if task.status = TASK_ALLOCATED then
			self.showTasksForQueueEntry(task.myEntry, count, true);		
			count:=count+1;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMachineShowDetails" id="55f78ec2-18bd-4d66-b5de-597de8bfce26">
        <source>doMachineShowDetails();
// ---------------------------------------------------------------------------
// Created:     18 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
