    <JadeMethod name="getTotalReq" id="04a51387-525d-4875-8bc7-72f80dda92f9">
        <source>getTotalReq(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
*/

vars
	req 	: CM_Request;
	relDtl	: CM_ReserveDetail;
	relReq	: CM_BulkRelease;
begin
	req := self.allRequests.first;
	relDtl := req.myReserveDetail;									//25.03.2024 navhl20 #62300
	if relDtl &lt;&gt; null then											//25.03.2024 navhl20 #62300
		relReq := relDtl.myReserveHeader;
	endif;
	if relReq &lt;&gt; null then
		relDtl := relReq.allReserveDetails.first;
	endif;
	if relDtl &lt;&gt; null and relDtl.isKindOf(CM_ReserveSelection) &lt;&gt; null then
		return relDtl.totalRequested.String;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
