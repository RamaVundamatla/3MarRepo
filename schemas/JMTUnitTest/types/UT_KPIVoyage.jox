    <JadeMethod name="setOnshipRehandles" id="28d1ea40-7133-4b80-ba63-7426330f9330">
        <updating/>
        <source>setOnshipRehandles(_voyage : String) updating;
/*
Purpose:			
Date		Who		Reason
17 February 2015	NAVAB1	Initial creation
*/

vars
	voyage : CM_Voyage;
	voyageDeck : CM_DeckVoyage;
	gcDefn : CM_ROROGCDefnVoyage;
	gcLC : CM_ROROGCController;
	slotDefn : CM_ROROSlotDefnVoyage;
	slotLC : CM_ROROSlotController;
	theSlot : CM_LocationsController;
	locnDefn : CM_ROROLocnDefnVoyage;
	ti, pxyTi : CM_TrackedItem;
	tsController : CMIF_TranshipTIController;
	idx : Integer;
	tis : CM_TIArray;
	strs : StringArray;
	
	ta : CM_TerminalArea;
begin
	voyage := self.getVoyage(_voyage);
	voyageDeck:=voyage.myROROStructure.allDecksByCode[DECK1];
	
	// ### RORO GC TS DLR SOB
	create tsController transient;
	tsController.myExportVoyage := voyage.myTerminal.allVoyagesByCode.getAtKeyGeq("UTVOYAGE1",null);
	tsController.myExportDisPort := tsController.myExportVoyage.allPorts.first;
	
	gcDefn := voyage.myROROStructure.allROROGCDefnByCode["DD1003G"].CM_ROROGCDefnVoyage;
	gcLC := gcDefn.myGCController;
	
	foreach ti in gcLC.allTrackedItems discreteLock do
		idx := idx + 1;
		beginLoad;	
		pxyTi := ti.pxyCreateUpdateProxy();
		endLoad;
		
		if idx &lt; 6 then
			app.myTrxUA.trxUpdateTITransitStatus(pxyTi,TI_TransitStatusSOB,app.myPassport);
		elseif idx &lt; 11 then
			app.myTrxUA.trxUpdateTITransitStatus(pxyTi,TI_TransitStatusDLR,app.myPassport);
		elseif idx &lt; 21 then
			tsController.allTrackedItems.add(ti);
		else
			delete pxyTi;
			break;
		endif;
	
		delete pxyTi;
	endforeach;

	// ### RORO Tranship Containers
	create tis transient;
	locnDefn := voyage.myROROStructure.allROROLocnDefnByCode[voyageDeck,"AUTOLOCN1"].CM_ROROLocnDefnVoyage;
	locnDefn.getAllTIs(REAL_MODE,tis,true);
	
	foreach ti in tis discreteLock do
		tsController.allTrackedItems.add(ti);
	endforeach;
	
	self.makeTrackedItemTranship(tsController);
	

	// ### RORO SOB Containers
	locnDefn := voyage.myROROStructure.allROROLocnDefnByCode[voyageDeck,"AUTOLOCN2"].CM_ROROLocnDefnVoyage;
	locnDefn.getAllTIs(REAL_MODE,tis,true);
	foreach ti in tis discreteLock do
		beginLoad;	
		pxyTi := ti.pxyCreateUpdateProxy();
		endLoad;
		
		app.myTrxUA.trxUpdateTITransitStatus(pxyTi,TI_TransitStatusSOB,app.myPassport);
	
		delete pxyTi;
	endforeach;
		

	// ### RORO SOB Containers
	locnDefn := voyage.myROROStructure.allROROLocnDefnByCode[voyageDeck,"AUTOLOCN3"].CM_ROROLocnDefnVoyage;
	locnDefn.getAllTIs(REAL_MODE,tis,true);
	foreach ti in tis discreteLock do
		beginLoad;	
		pxyTi := ti.pxyCreateUpdateProxy();
		endLoad;
		
		app.myTrxUA.trxUpdateTITransitStatus(pxyTi,TI_TransitStatusDLR,app.myPassport);
	
		delete pxyTi;
	endforeach;
	
	
	create strs transient;
	
	// ### LOLO DLR Container
	strs.clear;
	strs.add("010688");
	voyage.findLocation(strs, false, theSlot, idx);
	
	foreach ti in theSlot.allTrackedItems discreteLock do

		self.editIMEXStatus(ti,TI_IMEX_STATUS_REMAINONBOARD,false);
		self.editTRANSITStatus(ti,TI_TransitStatusDLR);
	endforeach;
	// ### LOLO DLR Container
	strs.clear;
	strs.add("010684");
	voyage.findLocation(strs, false, theSlot, idx);
	
	foreach ti in theSlot.allTrackedItems discreteLock do
		
		self.editIMEXStatus(ti,TI_IMEX_STATUS_REMAINONBOARD,false);
		self.editTRANSITStatus(ti,TI_TransitStatusDLR);
	endforeach;
	
	// ### LOLO SOB Containers
	strs.clear;
	strs.add("010488");
	voyage.findLocation(strs, false, theSlot, idx);
	
	foreach ti in theSlot.allTrackedItems discreteLock do
		
		self.editIMEXStatus(ti,TI_IMEX_STATUS_REMAINONBOARD,false);
		self.editTRANSITStatus(ti,TI_TransitStatusSOB);
	endforeach;
	
	
	// ### LOLO SOB Containers
	strs.clear;
	strs.add("010484");
	voyage.findLocation(strs, false, theSlot, idx);
	
	foreach ti in theSlot.allTrackedItems discreteLock do
		self.editIMEXStatus(ti,TI_IMEX_STATUS_REMAINONBOARD,false);
		self.editTRANSITStatus(ti,TI_TransitStatusSOB);
	endforeach;
	
	
	
	// ### LOLO TS Containers
	tsController.allTrackedItems.clear();
	strs.clear;
	strs.add("010288");
	voyage.findLocation(strs, false, theSlot, idx);
	
	foreach ti in theSlot.allTrackedItems discreteLock do
		tsController.allTrackedItems.add(ti);
	endforeach;

	strs.clear;
	strs.add("010284");
	voyage.findLocation(strs, false, theSlot, idx);
	
	foreach ti in theSlot.allTrackedItems discreteLock do
		tsController.allTrackedItems.add(ti);
	endforeach;

	strs.clear;
	strs.add("010686");
	voyage.findLocation(strs, false, theSlot, idx);
	
	foreach ti in theSlot.allTrackedItems discreteLock do
		tsController.allTrackedItems.add(ti);
	endforeach;
	

	strs.clear;
	strs.add("010682");
	voyage.findLocation(strs, false, theSlot, idx);
	
	foreach ti in theSlot.allTrackedItems discreteLock do
		tsController.allTrackedItems.add(ti);
	endforeach;
	
	self.makeTrackedItemTranship(tsController);
	
	ta := voyage.myTerminal.allTerminalAreas["UTBISH"];
	
	idx := 0;
	tsController.allTrackedItems.clear();
	foreach ti in ta.CM_BlockStack.myLocationsController.allTrackedItems discreteLock do
		idx := idx + 1;
		
		if idx &lt; 21 then
			self.editIMEXStatus(ti,TI_IMEX_STATUS_REMAINONBOARD,false);
			self.editTRANSITStatus(ti,TI_TransitStatusDLR);
		elseif idx &lt; 41 then
			self.editIMEXStatus(ti,TI_IMEX_STATUS_IMPORT,false);
			tsController.allTrackedItems.add(ti);
		else
			break;
		endif;
	endforeach;
	
	self.makeTrackedItemTranship(tsController);
	
epilog
	delete strs;
	delete tsController;
	delete tis;
end;</source>
        <Parameter name="_voyage" type="String"/>
    </JadeMethod>
    <JadeMethod name="tMain" id="19827ab7-4fc7-4838-8cf2-f09a274c9ace">
        <updating/>
        <source>tMain() updating;
// CNWMA1
// ---------------------------------------------------------------------------
// Created:     31 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyage : CM_Voyage;
begin

	self.uMain();

	voyage := self.getVoyage("UTBISH1");

	self.moveAllCargo();
	
	self.updateKPI();
	
	self.uCreateDelay();
	self.updateKPI();
	
	self.createExtraMovesDetails(voyage);
	
	self.checkKPIs(voyage);	
	
	self.checkWPOpHrMethods( voyage );	//10 Apr 2012	NDL	Par 29369
	
	// do a BGP Style KPI
//	self.uKPIBGP();
	
epilog
	self.opts.purge();
end;</source>
