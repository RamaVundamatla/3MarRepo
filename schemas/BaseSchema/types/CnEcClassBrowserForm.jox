end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuPopupInspect_click" id="ebe8594e-3a62-46b5-b5d2-e50b203cecbb">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuPopupInspect_click(menuItem: MenuItem input) updating;
