    <JadeMethod name="translateForm" id="3ed39377-c429-42f4-b81f-c614bb0c380d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 September 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019328, locale);
	btnCopyCancel.translateBubbleHelp(Xlat_0019329, locale);
	btnCopyCancel.translateCaption(Xlat_0019330, locale);
	btnCopySave.translateBubbleHelp(Xlat_0019331, locale);
	btnCopySave.translateCaption(Xlat_0019332, locale);
	lblCharge.translateCaption(Xlat_0019335, locale);
	lblCopy.translateCaption(Xlat_0019333, locale);
	lblCopy2.translateCaption(Xlat_0019334, locale);
end;</source>
    </JadeMethod>
