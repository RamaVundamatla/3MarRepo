    <JadeMethod name="hasHeightRestriction" id="7582038d-4047-4475-b950-b86db47dd17d">
        <source>hasHeightRestriction(_height : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     02 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if (_height &gt;= self.availability - 2 or _height = 0) then
		if self.availability &gt; 2 then
		return true;
		endif;
	endif;
	
	return false;

end;</source>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvailable" id="cf60f29c-ca3c-4b5c-8010-a9044405baaf">
        <source>isAvailable(targetHeight : Integer; control: CMIF_MoveController) : 	Boolean;

vars
	restrictedFromHeight : Integer;
	tmpTarget : Integer;
	reason : String;
	retValue : Boolean;
	currentMaxHeightForPad : Integer;
begin
	if not self.amIAvailable then
		return false;
	endif;
	if targetHeight &lt; 0 then
		//------------------
		//If no target height, then assume its going on top of whatever is there...
		//Autoplanning DOES populate the height, so we dont get a problem.
		//------------------
		
		if control &lt;&gt; null then // PAR 18682 CCMS 1055 SFW AND PAR 17886
			tmpTarget := self.allTrackedItems.size +1;
			if self.allTrackedItems.includes(control.myTrackedItem) then // take away any backends, if 40 is being moved 1 location left.
				tmpTarget := tmpTarget - 1;
			endif;
		else
			tmpTarget := self.allTrackedItems.size +1;
		endif;
	else
		tmpTarget := targetHeight;
	endif;
	//------------------
	//Calculate the restricted from height, 
	//------------------
/*	restrictedFromHeight := self.availability - PAD_USER_UNAVAILABLE;
	if restrictedFromHeight &lt;= 0 then
		return true;
	endif;
	if tmpTarget &lt; restrictedFromHeight then
		return true;
	endif;
	return false; */
	
	//08 Sep 2020	NDL	TFS 49984 - New check must run after the existing stuff.
	retValue := false;
	
	restrictedFromHeight := self.availability - PAD_USER_UNAVAILABLE;
	if restrictedFromHeight &lt;= 0 then
		retValue := true;
	elseif tmpTarget &lt; restrictedFromHeight then
		retValue := true;
	endif;
	
	if retValue = true then
		currentMaxHeightForPad := self.getCurrentMaxHeightForPad( reason );
		if currentMaxHeightForPad &lt;&gt; 0 and currentMaxHeightForPad &lt; tmpTarget then
			retValue := false;
		endif;
	endif;
	
	return retValue;
end;</source>
        <Parameter name="targetHeight" type="Integer"/>
        <Parameter name="control" type="CMIF_MoveController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBlocked" id="e50b19c6-3837-4360-a376-880047b99891">
        <source>isBlocked(): Boolean;
/*
Purpose:		// TFS 53369 22APR2022 NAVAB1			

Date		Who		Reason
22 April 2022	navab1	TFS 51855
*/

vars

begin
	if self.amIAvailable = false then
		return true;
	endif;
	
	if self.usage = BUILDING_USE 
	or self.usage = LIGHT_TOWER_USE then
		return true;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDifferentTo" id="76733581-c77c-4c84-8048-a6c8d25f6ae5">
        <source>isDifferentTo(pOther: CM_StackController): Boolean;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.availability &lt;&gt; pOther.availability or
	   self.usage &lt;&gt; pOther.usage then
	   	return true;
	endif;
	
	return inheritMethod(pOther);

end;</source>
        <Parameter name="pOther" type="CM_StackController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
