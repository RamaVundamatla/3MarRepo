    <JadeMethod name="doTblDataContextMenu" id="23f9db38-03c1-470c-9a1d-16be3a37dfc3">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/
vars
	snapShot	: CM_TISnapShot;
	
begin
	
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;
	endif;
	
	self.mnuColourLegends.visible := true; // TFS 40336
	

	return self.showContextMenu(self.mnuContext,cntrl,conwin,mouse,x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateSnapShot" id="2380a801-2dd7-4b85-a884-0470aeb9a3b0">
        <updating/>
        <source>doUpdateSnapShot() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2018	jlgab1	Initial creation

*/

vars
	obj : Object;
	snapShot, pxySnapShot : CM_TISnapShot;
	realsnapshots : CM_SnapShotSet;
	entTableRow : EntTableRow;
	theReturn : Integer;
	ti : CM_TrackedItem;
begin
	if self.cmbProperties.listObject = null then
		app.msgBox("Please Select a Property to Update With", app.getErrorString(Confirmation),MsgBox_OK_Only);
		return;
	endif;
	if self.tblData.allSelectedObjects.isEmpty() then
		app.msgBox("Please Select a Snap Shot to Update", app.getErrorString(Confirmation),MsgBox_OK_Only);
		return;
	endif;
	
	app.mousePointer := 1;
	entTableRow := self.cmbProperties.listObject.EntTableRow;
	
	create realsnapshots transient;
	
	foreach obj in self.tblData.allSelectedObjects 	discreteLock do
		snapShot :=obj.CM_TISnapShot;
		ti := snapShot.myTrackedItem;
		
		if ti.hasBeenMerged() then // ZOMBIE
			continue;
		endif;
		
		realsnapshots.add(snapShot);
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateSnapShotFromCargo(entTableRow,realsnapshots, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
//			self.doPropertySelected();
			break;
		else
			theReturn := app.showErrorWarningDialog("Update Snap Shot", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete realsnapshots;
end;</source>
    </JadeMethod>
