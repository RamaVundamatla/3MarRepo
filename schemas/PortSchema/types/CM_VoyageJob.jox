vars

begin

	self.setTransferType( 0 ); //LOLO Transfer Type

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createStopStartTransaction" id="30b73706-7852-4dde-9db0-12ab03a48487">
        <source>createStopStartTransaction(_action: Integer; _ts: TimeStamp; _obj : CM_Object); 		//23.09.2024  navbs1  #12445
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
30 Oct 2024 navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
*/

vars
	woTrans			: CM_WOTransaction;
	woJobTrans		: CM_WOJobDetail;
	woDtl			: CM_WorkOrderDtl;
	eventType,
	woTransType,
	cargoTransType,
	vvrType 		: Integer;
	isStart 		: Boolean;
begin
	
	// Get the type based on the action
	self.getTypesToCreate(_action, eventType, vvrType, woTransType, cargoTransType);
	
	isStart := _action = Job_Action_Start or _action = Job_Action_Resume;
	
	// Create WO Transaction
	woDtl := self.getMyWorkOrderDtl();
	if woDtl &lt;&gt; null then
		woTrans := woDtl.createWOTransaction(woTransType, null, null);
		if woTrans &lt;&gt; null then
			woJobTrans := woTrans.CM_WOJobDetail;
			woJobTrans.setJobActionDetails(self, isStart, _ts);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="deleteAllRRPs" id="c47b191a-56ef-4211-a8a5-b35cf24f6bbd">
        <updating/>
        <source>deleteAllRRPs()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2020	jlgndl1	Initial creation	TFS 47004

*/

vars

	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	invalidWle: Boolean;
	invalidTi : Boolean;
	isRRP : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, wle, invalidWle );
	on Exception do app.handleDeletedObject( exception, ti, invalidTi );

	foreach wle in self.workListEntries do
		ti := wle.myTrackedItem;
		if invalidWle then
			invalidWle := false;
			continue;
		endif;
		if ti &lt;&gt; null then
			isRRP := ti.isRRP; // It is a placeholder
			if invalidTi then
				invalidTi := false;
				continue;
			endif;
			if isRRP then
				ti.erase(NORMAL_ERASE);
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPlanningGetNextPointInSeq" id="53153ee4-1f04-4f0e-98e3-534dfe5f418d">
        <source>doPlanningGetNextPointInSeq(_thePrevRequest : CM_SlotRequest) : CM_SlotRequest;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theRequest 		: CM_Request;
	theSlotRequest	: CM_SlotRequest;
	anObject		: Object;
	getNext			: Boolean;
	iter01			: Iterator;
	dyna			: DynaDictionary;
	
begin	
	create dyna transient;
	
	dyna.setMembership(CM_SlotRequest);

	if self.myVoyage.starboardBerthed then
		if self.isTwinLift then
			dyna.addMemberKey(CM_SlotRequest::numSeqStarboardTwinCustom.name, false, true);
			dyna.addMemberKey(CM_SlotRequest::mySlotController.name &amp; '.' &amp; CM_SlotController::myBayVoyage.name &amp; '.' &amp; CM_BayVoyage::ordinalBay.name, false, true);
		else
			dyna.addMemberKey(CM_SlotRequest::numSeqStarboardCustom.name, false, true);
		endif;
	else
		if self.isTwinLift then
			dyna.addMemberKey(CM_SlotRequest::numSeqPortTwinCustom.name, false, false);
			dyna.addMemberKey(CM_SlotRequest::mySlotController.name &amp; '.' &amp; CM_SlotController::myBayVoyage.name &amp; '.' &amp; CM_BayVoyage::ordinalBay.name, false, true);
		else
			dyna.addMemberKey(CM_SlotRequest::numSeqPortCustom.name, false, false);
		endif;
	endif;
	
	dyna.endKeys(true);
	
	// sort the requests into the correct order
	self.allRequests.copy(dyna);
	
	// go to the passed in request
	iter01 := dyna.createIterator();
	iter01.startAtObject(_thePrevRequest);
	// get the next item, that is not already planned
	while iter01.next(anObject) do
		if _thePrevRequest &lt;&gt; anObject then
			theSlotRequest := anObject.CM_SlotRequest;
			if theSlotRequest.getAttrIsDischarge() then
				if not theSlotRequest.hasTIsOfMode(PLANNING_MODE) then
					break;
				endif;
			elseif theSlotRequest.getAttrIsLoad() then
				if not theSlotRequest.hasTIsOfMode(PLANNING_MODE) then
					break;
				endif;
			endif;
			theSlotRequest := null;
		endif;
	endwhile;
	return theSlotRequest;
epilog
	delete dyna;
	delete iter01;
end;</source>
        <Parameter name="_thePrevRequest" type="CM_SlotRequest"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="doSortEmptyReqsInToSeqOrder" id="0cfd8783-4120-43af-9270-0cc013446630">
        <source>doSortEmptyReqsInToSeqOrder(_reqs : Array input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 October 2012	cnwrd1	Initial creation

*/

vars
	theReq : CM_Request;
	isStarboard : Boolean;
	aWLE : CM_WorkListEntry;
	wleSorter :	CM_VoyageWLEDynaDict;
	iter : Iterator;
	aQuantity : Integer;
begin
	create wleSorter transient;
	
	isStarboard := self.myVoyage.starboardBerthed;
	wleSorter.init(self.myVoyage, self);
	
	foreach aWLE in self.workListEntries do
		wleSorter.add(aWLE);
	endforeach;

	_reqs.clear;
	iter := wleSorter.createIterator();
	while iter.next(aWLE) do
		theReq := aWLE.myRequest;
		if theReq.isKindOf(CM_RORORequest) then
		
			if not _reqs.includes(theReq) and  theReq.CM_RORORequest.myROROController.allTrackedItems.size = 0 then
				_reqs.add(theReq);
			endif;
		else	
			if not _reqs.includes(theReq) and  theReq.CM_SlotRequest.mySlotController.allTrackedItems.size = 0 then
				_reqs.add(theReq);
			endif;
		endif;
	endwhile;	
epilog
	delete iter;
	delete wleSorter;
end;</source>
        <Parameter name="_reqs" type="Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSortReqsInToSeqOrder" id="b65854e5-34f2-424a-8eac-875983500db5">
        <source>doSortReqsInToSeqOrder(_reqs : Array input);
/* ---------------------------------------------------------------------------
// Created:		December 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
17 Aug 2011	cnwer1	changed input paramter to array instead of CM_SlotRequestArray
*/
vars
	theReq : CM_Request;
	isStarboard : Boolean;
	aWLE : CM_WorkListEntry;
	wleSorter :	CM_VoyageWLEDynaDict;
	iter : Iterator;
begin


	create wleSorter transient;
	
	isStarboard := self.myVoyage.starboardBerthed;
	wleSorter.init(self.myVoyage, self);
	
	foreach aWLE in self.workListEntries do
		if aWLE.CM_VoyageWLE.isSOBLoad then // TFS 678	CCMS 2520
			continue; // TFS 678	CCMS 2520
		endif; // TFS 678	CCMS 2520
		
		wleSorter.add(aWLE);
	endforeach;

	_reqs.clear;
	iter := wleSorter.createIterator();
	while iter.next(aWLE) do
		theReq := aWLE.myRequest;

		if not _reqs.includes(theReq) then
			_reqs.add(theReq);
		endif;
	endwhile;	
epilog
	delete iter;
	delete wleSorter;
end;</source>
        <Parameter name="_reqs" type="Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enqueueJob" id="fa7dad61-6e3c-45c1-90c6-997b7cb1ab61">
        <source>enqueueJob() ;
//Works to queue a job
vars
	wle	: CM_WorkListEntry;
	arbiter	: CM_RTQueueArbiter;
	
begin
	//epr par 36229 17/7/17 removed references to RadioTelemetryEnabled 
	//For each WLE (a unit of work), ask it to enqueue itself
	//(Note, this can be called from that level if required.
	//--------------
	create arbiter;
	arbiter.job := self;

	foreach wle in workListEntries do
		arbiter.reset();
		wle.enqueueWLE(arbiter);
	endforeach;

	self.setEntryOverrideFlag();
	
epilog
	arbiter.erase(0);

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="1c288f70-e21d-4ea2-b8b3-bbfd76726740">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
*/

vars
	allReqs			  :	CM_RequestSet;
	tRequest		  :	CM_Request;
	wle				  :	CM_WorkListEntry;
	theSlotController : CM_LocationsController;
	invalid 		  : Boolean;
	ed				  : Integer;
	
begin
	app.writeVoyageLog(self, "Job Delete");  // PAR 31878 - logging

	exclusiveLock(self);
	
	// if any of my TIs are planned then unplan them now, then dismantle me and delete me!
	self.unplanFutureMove(PLANNING_MODE, null, app.myPassport);
	//-----------------------------------------------------------
	// Remove itself from the Order of Work that it belongs to.
	//-----------------------------------------------------------
	//--------------------------
	// Remove the slot requests
	//--------------------------
	create allReqs transient;

	self.allRequests.copy(allReqs);

	on Exception do app.handleDeletedObject(exception, tRequest, invalid);
	
	//break request-job links
	while allReqs.size &gt; 0 do
		tRequest := allReqs.last();
		
		theSlotController := tRequest.getVoyageController;

		if _eraseLevel = FORCED_ERASE then
			invalid := false;
			// Dereference request to check if it is valid
			ed := tRequest.edition();
			
			if invalid then
				allReqs.remove(tRequest);
				delete tRequest;
				continue;
			endif;
		endif;

		// ################################
		// This will update the display on screen of this slot
		if theSlotController &lt;&gt; null then
			self.myVoyage.causeEvent(self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, theSlotController);
		endif;

		self.removeRequest(tRequest); 
		allReqs.remove(tRequest);
	endwhile;
	
	if self.myJobSheet &lt;&gt; null then
		self.myJobSheet.removeJob(self);
	endif;
	
	//21/09/2020 cnwma1 TFS #49906
	if app.myPassport.noErrors then
		if app.myPassport.isOpsViewEnabled(self.myTerminal) then
			self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,self);
		endif;
	endif;
	//21/09/2020 cnwma1 TFS #49906
	
	inheritMethod(_eraseLevel);

epilog
	delete allReqs;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findSequenceObjForRequest" id="7c2f494f-a6ed-4a9d-abbc-46dffadfeea0">
        <source>findSequenceObjForRequest(_allLiftsObj:ObjectArray; _slotRequestObj:CM_SlotRequest):CMIF_CustomSequenceObject protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2006 by cnwdad1
//
// Purpose:		Scans the specified ObjectArray (presumed to contain Custom Sequence
//				Objects), and matches is Request reference against the Slot Request
//				parameter - if the two match, a reference to the Custom Sequence
//				Object is returned.
//
// Parameters:	_allLiftsObj - A reference to the array of CSOs.
//				_slotRequestObj - A reference to the Slot Request to match.
//
// Returns:		A reference to the matching Custom Sequence Object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementObj	: Object;
	sequenceObj	: CMIF_CustomSequenceObject;
	
begin
	foreach elementObj in _allLiftsObj do
		sequenceObj	:=	elementObj.CMIF_CustomSequenceObject;
		
		if sequenceObj.myRequest = _slotRequestObj then
			return sequenceObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_allLiftsObj" type="ObjectArray"/>
        <Parameter name="_slotRequestObj" type="CM_SlotRequest"/>
        <ReturnType type="CMIF_CustomSequenceObject"/>
    </JadeMethod>
    <JadeMethod name="findTIById" id="75e914f5-53c9-4355-82fb-830c6d80e830">
        <source>findTIById(_cargoId : String) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	iter : Iterator;
	ti 	: CM_TrackedItem;
begin
	if self.isDischarge then
		iter := self.allReceiveTrackedItems.createIterator;
	else
		iter := self.allReleaseTrackeditems.createIterator;
	endif;
	
	while iter.next(ti) do
		if ti.id = _cargoId then
			return ti;
		endif;
	endwhile;

	delete iter;
	iter := self.allSOBTrackedItems.createIterator;
	while iter.next(ti) do
		if ti.id = _cargoId then
			return ti;
		endif;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getAdditionalRemarks" id="8124c856-e9fd-4805-bbc4-7de7fd9e2e63">
        <source>getAdditionalRemarks(): String;
//----------------------------------------------------------------
//	Created:	07 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	strRemarks		: String;
begin

	if not self.isDischarge
	and self.isRehandle then
		//remarks contain discharge job numbers
		strRemarks := self.getDLRDischargeRemarks();
	elseif self.isDischarge then
		//remarks show consignees for full boxes
		strRemarks := self.getFullImportRemarks();
	endif;

	return strRemarks;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="163933fc-a804-469d-a97f-39a05e4b3ba4">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	req : CM_Request;
begin

	
	foreach req in self.allRequests do
		req.getAllWLEs(_wleArray);
	endforeach;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAutoRemarks" id="9636cbc4-4dda-487b-b7f3-9df70e1d30c0">
        <updating/>
        <source>getAutoRemarks() : String updating;
/* ---------------------------------------------------------------------------
// Created:		a long long time ago 
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
23 Aug 2011		cnwer1		CCMS 1033 giving a breakdown of break bulk totals by cargo type
// ---------------------------------------------------------------------------*/
vars
	theRemarks : String;
	jobTotals : CMIF_JobTITotals;
	bblkTotal : CM_Association;
	iter : Iterator;
	is30Included, is45Included, is53Included : Boolean;
begin
	is30Included	:= self.myTerminal.getConfig (Is30IncludedForReports).Integer = ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
	is45Included	:= self.myTerminal.getConfig (Is45IncludedForReports).Integer = ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
	is53Included	:= self.myTerminal.getConfig (Is53IncludedForReports).Integer= ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342

	create jobTotals transient;
	self.getJobTITotals(jobTotals);

	if jobTotals.numReefer &gt; 0 then
		 theRemarks := theRemarks &amp; jobTotals.numReefer.String &amp; " reefer";
	endif;
	
	// PAR 16415 CCMS 1029
	if jobTotals.numFiftyThree &gt; 0 and is53Included then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		 theRemarks := theRemarks &amp; jobTotals.numFiftyThree.String &amp; " 53'";
	endif;
	if jobTotals.numThirtyFoot &gt; 0 and is30Included then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		 theRemarks := theRemarks &amp; jobTotals.numThirtyFoot.String &amp; " 30'";
	endif;
	if jobTotals.numFortyFive &gt; 0 and is45Included then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		 theRemarks := theRemarks &amp; jobTotals.numFortyFive.String &amp; " 45'";
	endif;
	
	if jobTotals.numReeferRH &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numReeferRH.String &amp; " reefer R/H";
	endif;
		
	if jobTotals.numChilled &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numChilled.String &amp; " chilled";
	endif;
	
	if jobTotals.numChilledRH &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numChilledRH.String &amp; " chilled R/H";
	endif;
	
	if jobTotals.numChilledSOB &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numChilledSOB.String &amp; " chilled SOB";
	endif;
	
	if jobTotals.numFantainer &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numFantainer.String &amp; " fantainers";
	endif;
	
	if jobTotals.numFantainerRH &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numFantainerRH.String &amp; " fantainer R/H";
	endif;
	if jobTotals.numFantainerSOB &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numFantainerSOB.String &amp; " fantainer SOB";
	endif;
	// PAR 7685 from here
	if jobTotals.numOD &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numOD.String &amp; " Over Dimensioned";
	endif;
	if jobTotals.numODRH &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numODRH.String &amp; " Over Dimensioned R/H";
	endif;
	
	if jobTotals.numODSOB &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numODSOB.String &amp; " Over Dimensioned SOB";
	endif;
	// PAR 7685 to here
	/* PAR 31756
	if jobTotals.numTimber &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numTimber.String &amp; " timber";
	endif;
	
	if jobTotals.numTimberRH &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numTimberRH.String &amp; " timber R/H";
	endif;
	if jobTotals.numTimberSOB &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numTimberSOB.String &amp; " timber SOB";
	endif;
	*/
	
	if jobTotals.allBBLKTotals.size &gt; 0 then
		iter:=jobTotals.allBBLKTotals.createIterator;
		while iter.next(bblkTotal) do
			if theRemarks &lt;&gt; "" then 
				theRemarks := theRemarks &amp; ", ";
			endif;
			theRemarks := theRemarks &amp; bblkTotal.asInteger.String &amp; "x" &amp; iter.getCurrentKey(1).asStringJMT;
		endwhile;
	endif;
	
	if jobTotals.allBBLKTotalsRH.size &gt; 0 then
		iter:=jobTotals.allBBLKTotalsRH.createIterator;
		while iter.next(bblkTotal) do
			if theRemarks &lt;&gt; "" then 
				theRemarks := theRemarks &amp; ", ";
			endif;
			theRemarks := theRemarks &amp; bblkTotal.asInteger.String &amp; "x" &amp; iter.getCurrentKey(1).asStringJMT;
		endwhile;
	endif;
	
	if jobTotals.allBBLKTotalsSOB.size &gt; 0 then
		iter:=jobTotals.allBBLKTotalsSOB.createIterator;
		while iter.next(bblkTotal) do
			if theRemarks &lt;&gt; "" then 
				theRemarks := theRemarks &amp; ", ";
			endif;
			theRemarks := theRemarks &amp; bblkTotal.asInteger.String &amp; "x" &amp; iter.getCurrentKey(1).asStringJMT;
		endwhile;
	endif;
	/* PAR 31756
	if jobTotals.numBBLKRH &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		
		theRemarks := theRemarks &amp; jobTotals.numBBLKRH.String &amp; " bbulk R/H";
	endif;

	if jobTotals.numBBLKSOB &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numBBLKSOB.String &amp; " bbulk SOB";
	endif;
	
	if jobTotals.numMisc &gt; 0 then 
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numMisc.String &amp; " Misc";
	endif;
	if jobTotals.numMiscRH &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numMiscRH.String &amp; " Misc R/H";
	endif;
	if jobTotals.numMiscSOB &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numMiscSOB.String &amp; " Misc SOB";
	endif;
	*/
	if jobTotals.numTS20 &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numTS20.String &amp; " T/S 20";
	endif;
	if jobTotals.numTS40 &gt; 0 then
		if theRemarks &lt;&gt; "" then 
			theRemarks := theRemarks &amp; ", ";
		endif;
		theRemarks := theRemarks &amp; jobTotals.numTS40.String &amp; " T/S 40";
	endif;

	return theRemarks;
epilog
	delete jobTotals;
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBayArray" id="24a5d022-92bc-4a49-af2e-a2edf867a868">
        <source>getBayArray(_bays : CM_BayArray input);
// ---------------------------------------------------------------------------
// Created:		14 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	bay1, bay2 : CM_Bay;
begin
	self.getBays(bay1, bay2);
	
	if bay1 &lt;&gt; null then
		_bays.add(bay1);
	endif;
	if bay2 &lt;&gt; null then
		_bays.add(bay2);
	endif;
end;</source>
        <Parameter name="_bays" type="CM_BayArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBays" id="2ebfb1cc-8199-4572-8c38-61574415403d">
        <source>getBays(_bayOne : CM_Bay output; _bayTwo : CM_Bay output);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 10/02/2017	cnwdap1		TFS 3220 LNX Voyage Operations Enhancements
vars
	aSlotRequest : CM_SlotRequest;
	aReq : CM_Request;
	theBay : CM_Bay;
begin
	if not self.allRequests.first.isKindOf(CM_SlotRequest) then		// TFS 3220
		return;														// TFS 3220
	endif;															// TFS 3220
	
	foreach aReq in self.allRequests do
		aSlotRequest := aReq.CM_SlotRequest;
		theBay := aSlotRequest.myBay;
		if theBay = null then
			theBay := aSlotRequest.mySlotController.myBayVoyage;
		endif;
		
		if _bayOne = null then
			_bayOne := theBay;
		elseif theBay &lt;&gt; _bayOne then
			_bayTwo := theBay;
			break;
		endif;
	endforeach;
	if self.allRequests.size = 0 then
		_bayOne:=self.myVoyage.lookupBayVoyage(self.bayId);
	endif;
	 // PAR 8111 added. Make sure that the bays are in ordinal order.
	if _bayTwo &lt;&gt; null then 
		if _bayOne.ordinalBay &gt; _bayTwo.ordinalBay then
			theBay := _bayOne;
			_bayOne := _bayTwo;
			_bayTwo := theBay;
		endif;
		
	endif;

//	if self.hasFortyFootRequests() and not self.isSOB then // PAR 8881 was before now moved after PAR 8111
	if ( self.hasFortyFootRequests() or self.hasFortyFiveFootRequests() or self.hasFiftyThreeFootRequests() ) and not self.isSOB then // 08 Apr 2010 NDL	Par 22526
		if _bayOne = null then
			return;
		endif;
		_bayTwo := _bayOne.myAftBay;
	endif;
	
end;</source>
        <Parameter name="_bayOne" type="CM_Bay" usage="output"/>
        <Parameter name="_bayTwo" type="CM_Bay" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getBaysSecondOrdinalDeck" id="7c1e3c20-26ee-48c2-81b3-5c1e05ab4ec3">
        <source>getBaysSecondOrdinalDeck(_bay : CM_BayVoyage) : Integer;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aRequest : CM_Request;
	aSlotReq : CM_SlotRequest;
begin
	foreach aRequest in self.allRequests do
		aSlotReq := aRequest.CM_SlotRequest;
		if aSlotReq.myBay = _bay then
			return aSlotReq.ordinalDeck;
		endif;
		
	endforeach;
	return -1;
end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCageWithLashTotal" id="47a338fb-cb37-42cc-b336-9e026a9ef1db">
        <source>getCageWithLashTotal( _totalWithCage : Integer output );

/*
 ------------------------------------------------------------------------
Created:			26 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	req : CM_Request;
	slotReq : CM_SlotRequest;
	wles : CM_WLESet;
	wle : CM_WorkListEntry;
	voyageWLE : CM_VoyageWLE;
	tiArray : CM_TIArray;
	mode : Integer;
	allRequestsSet : CM_RequestSet;
	bayVoyage : CM_BayVoyage;
	tier : CM_TierDefn;
	lashTier : Integer;
begin

	_totalWithCage := 0;

	/* epr CCMS 1033 4/8/11 changed to use the lashFromTier for the bay of the job
		before it was a param passed in
		getCageLashTotal passed in lashFromTier from the voyage job bay i.e. what this method now does
		the rest passed in -1 which meant all on deck tiers  were lashed
	 */
	 
	 if self.jobType &lt;&gt; JOB_TYPE_DISCHARGE and
		self.jobType &lt;&gt; JOB_TYPE_LOAD and
		self.jobType &lt;&gt; JOB_TYPE_SOB then
		return;
	endif;
	 
	bayVoyage := self.myVoyage.lookupBayVoyage(self.bayId);
	if bayVoyage = null then
		return;	
	endif;

	if bayVoyage.lashFromTier.trimBlanks = null then
	  //No lash from set, ignore and return
		return;
	endif;	
	
	tier := bayVoyage.allTiersOnDeckByLabel[bayVoyage.lashFromTier];
	if tier = null then
		return;
	endif;
	lashTier := tier.ordinal;
	
	create tiArray transient;
	create allRequestsSet transient;
			
	
	self.allRequests.copy(allRequestsSet);

	foreach req in allRequestsSet do
		if not req.isKindOf(CM_SlotRequest) then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Found a request that is NOT a slot Request!');
			return;		
		endif;
		slotReq := req.CM_SlotRequest;
		if slotReq.ordinalDeck &lt;&gt; DeckOnDeck then
			//Underdeck request, ignore
			continue;
		endif;
		//------------------
		//Always get WLE's, and add HISTORICAL data for worked Jobs
		//------------------
		
		wles := slotReq.allWorkListEntries;
		
		//----------------
		//Is this GTE target tier?
		//----------------
		if slotReq.ordinalTier &lt; lashTier then
			continue;
		endif;
		//----------------
		//Interested in this.. Continue
		//----------------
		foreach wle in wles do
			voyageWLE := wle.CM_VoyageWLE;
			if voyageWLE.status = WLE_COMPLETED then
				//If WLE is completed, we have some HISTORICAL data
				//We ADD this to the system totals.
				_totalWithCage := _totalWithCage +1;
			endif;				
		endforeach;
		
		//----------------
		//Unworked, get data from actual number of TI's in Request
		//Get ALL TI's for this Request (there may be more than 1)
		//----------------
		
		if (self.jobType = JOB_TYPE_DISCHARGE or 	self.jobType = JOB_TYPE_SOB) then
			mode := REAL_MODE;
		else				
			mode := PLANNING_MODE;
		endif;

		if slotReq.mySlotController &lt;&gt; null then
			tiArray.clear; // PAR 10032
			slotReq.mySlotController.getTIs(tiArray, mode, true);
			_totalWithCage := _totalWithCage + tiArray.size;
		endif;
	endforeach;
epilog
	delete tiArray;
	delete allRequestsSet;
end;</source>
        <Parameter name="_totalWithCage" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCandHStats" id="6131dbe3-6fcf-4ec9-81ee-b387abd192ee">
        <updating/>
        <source>getCandHStats(_aCandHRpt : CMIF_CandHRpt input; progress : CMS_Progress io) updating;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	wle 				: CM_WorkListEntry;
	i, numLash, tot 	:Integer;
	totals 				: CMIF_JobTITotals;
	dlCode 				: String;
	summaryTLG			: CMIF_CandHTradeLineGeo;
begin
	if self.myVoyage.myDefaultLineGroupDebtor = null then	// or not global.isValidObject(self.myVoyage.myDefaultLineGroupDebtor) then - inversed
		app.setContinueCMExceptions(true);
		app.raiseCMException2(ERR_INVALID_VALUE, "Voyage Default Line Group Debtor",  self.myVoyage.code &amp; " Does not have a Default Line Group Debtor. Use Voyage definition to specify one.", null, null);
		return;
	endif;

	summaryTLG	:= _aCandHRpt.getSummaryTLGfromLGD(self.myVoyage.myDefaultLineGroupDebtor, true);
	
	if numOfLids &lt;&gt; 0 then
		summaryTLG.hatchCoverMoves := summaryTLG.hatchCoverMoves  + numOfLids;
	endif;
	progress.setAction("Getting Work List Entries for " &amp; jobNum );
	progress.progress.partsInJob := self.workListEntries.size;
	

	
	foreach wle in self.workListEntries do
		wle.getCandHStats(_aCandHRpt, progress);
		i := i + 1;
		progress.progress.partsDone := i;
	endforeach;

	if _aCandHRpt.myOperator &lt;&gt; null
	and  _aCandHRpt.myOperator &lt;&gt; self.myVoyage.myOperator then
		return;	
	endif;

	create totals transient;
	self.getJobTITotals(totals);

	if ordinalDeck = DeckOnDeck then
		self.getCageWithLashTotal(numLash);
		if (numLash &lt;&gt; 0) then
			summaryTLG.lashWithCage := summaryTLG.lashWithCage + numLash;
		endif;
		tot := totals.numFull + totals.numEmpty + totals.numFullRH + totals.numEmptyRH + totals.numFullSOB + totals.numEmptySOB;
		if ( jobType = JOB_TYPE_SOB ) then
			if (  (2*tot - numLash) &gt; 0 ) then
				summaryTLG.lashWithOutCage := summaryTLG.lashWithOutCage + (2*tot - numLash);
			endif;
		else
			if ( (tot - numLash) &gt; 0 ) then
				summaryTLG.lashWithOutCage := summaryTLG.lashWithOutCage + (tot - numLash);
			endif;
		endif;
	endif;
epilog
	delete totals;
end;</source>
        <Parameter name="_aCandHRpt" type="CMIF_CandHRpt" usage="input"/>
        <Parameter name="progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
