    <JadeMethod name="doStateGrid" id="a0864160-395f-479f-bc99-c6aba0815447">
        <source>doStateGrid();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars

begin
	self.doStateNormal();
	
	self.dkcBottom.visible := false;
	
	self.dkcBottom.allowDocking := self.dkcBottom.AllowDocking_AllVertical;
	self.dkcBottom.alignContainer := self.dkcBottom.AlignContainer_AllVertical;
	
	self.dkcTop.allowDocking := self.dkcBottom.AllowDocking_AllVertical;
	self.dkcTop.alignContainer := self.dkcBottom.AlignContainer_AllVertical;
	
	self.dkcTop.left := 0;
	
	self.dkcBottom.left := self.dkcMain.width / 2;
	self.dkcBottom.visible := true;
	
	self.frmSelectorButtons.top := self.cmbAttr.top + self.cmbAttr.height + 5;
	self.frmSelectorButtons.left := self.cmbAttr.left;
	self.frmSelectorButtons.parentAspect := self.frmSelectorButtons.ParentAspect_None;
	
	self.tblCriteria.top := self.frmSelectorButtons.top + self.frmSelectorButtons.height + 5;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doStateNormal" id="bf836f12-448d-43e2-90b0-42b9d51ab94e">
        <source>doStateNormal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars

begin
	// Set the bottom ones to visible false so the top ones stick to the top
	self.dkcTop.visible := true;
	self.dkcBottom.visible := false;
	self.dkcGrouping.visible := false;
	self.dkcCustomDocument.visible := false;
	
	self.dkcSelector.parent := self.dkcTop;
	self.dkcGrouping.parent := self.dkcTop;
	self.dkcCargo.parent := self.dkcBottom;
	self.dkcCustomDocument.parent := self.dkcBottom;
	
	self.dkcTop.top := 0;
	
	self.dkcSelector.alignContainer := self.dkcTop.AlignContainer_AllHorizontal;
	self.dkcGrouping.alignContainer := self.dkcTop.AlignContainer_AllHorizontal;
	self.dkcCargo.alignContainer := self.dkcTop.AlignContainer_AllHorizontal;
	self.dkcCustomDocument.alignContainer := self.dkcTop.AlignContainer_AllHorizontal;
	
	self.dkcTop.alignContainer := self.dkcTop.AlignContainer_AllHorizontal;
	self.dkcBottom.alignContainer := self.dkcTop.AlignContainer_AllHorizontal;
	
	self.dkcSelector.top := 0;
	self.dkcGrouping.top := self.dkcTop.height / 2;
	self.dkcGrouping.visible := true;
	
	self.dkcCargo.top := 0;
	self.dkcCustomDocument.top := self.dkcBottom.height / 2;
	self.dkcCustomDocument.visible := self.btnShowTblSummary.value;
	
	self.dkcBottom.top := self.dkcMain.clientHeight() / 2;
	self.dkcBottom.visible := true;
	
	self.dkcGrouping.minimumWidth := 0;
	self.dkcCargo.minimumWidth := 0;
	self.dkcCustomDocument.minimumWidth := 0;
	
	// Reposition the controls back to default
	self.frmSelectorButtons.top := 5;
	self.frmSelectorButtons.parentRightOffset := 0;
	self.frmSelectorButtons.parentAspect := self.frmSelectorButtons.ParentAspect_AnchorRight;
	
	self.tblCriteria.top := self.cmbAttr.top + self.cmbAttr.height + 10;
	
	self.btnSearch.top := 3;
	self.btnSearch.parentRightOffset := self.tblCriteria.parentRightOffset;
	self.btnSearch.parentAspect := self.btnSearch.ParentAspect_AnchorRight;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doStateVertical" id="d04bf6b7-f833-42e4-b3e2-d32ae9efbf13">
        <source>doStateVertical();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars

begin
	self.doStateNormal();
	
	self.dkcBottom.visible := false;
	
	self.dkcTop.alignContainer := self.dkcTop.AlignContainer_AllVertical;
	self.dkcSelector.alignContainer := self.dkcTop.AlignContainer_AllVertical;
	self.dkcGrouping.alignContainer := self.dkcTop.AlignContainer_AllVertical;
	
	self.dkcBottom.alignContainer := self.dkcBottom.AlignContainer_AllVertical;
	self.dkcCargo.alignContainer := self.dkcBottom.AlignContainer_AllVertical;
	self.dkcCustomDocument.alignContainer  := self.dkcBottom.AlignContainer_AllVertical;
	
	self.dkcTop.left := 0;
	
	self.dkcSelector.left := 0;
	self.dkcGrouping.left := self.dkcTop.clientWidth() / 2;
	self.dkcCargo.left := 0;
	self.dkcCustomDocument.left := self.dkcBottom.clientWidth() / 2;
	
	self.dkcBottom.left := self.dkcMain.width / 2;
	self.dkcBottom.visible := true;
	
	self.dkcGrouping.minimumWidth := 400;
	self.dkcCargo.minimumWidth := 400;
	self.dkcCustomDocument.minimumWidth := 425;
	
	// Reposition controls to fit in view
	self.frmSelectorButtons.top := self.cmbAttr.top + self.cmbAttr.height + 5;
	self.frmSelectorButtons.left := self.cmbAttr.left;
	self.frmSelectorButtons.parentAspect := self.frmSelectorButtons.ParentAspect_None;
	
	self.tblCriteria.top := self.frmSelectorButtons.top + self.frmSelectorButtons.height + 5;
	
	self.btnSearch.top := 3;
	self.btnSearch.parentRightOffset := 3;
	self.btnSearch.parentAspect := self.btnSearch.ParentAspect_AnchorRight;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTableFilter" id="2cd026b2-7841-46ae-b5af-0db0497ace18">
        <source>doTableFilter(_table : CM_DataTable input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2023	navkc1	CR 60429 Task 60446: UI - Cargo Review UI Changes - FIlter and Totals

*/

vars
	filterText : String;
begin
	
	if _table = self.tblCargo then
		//filterText := self.txtFilterCargo.text;
		//25/06/2024	navkc1 CR 64823 Task 64824
		if self.frmTableFilterCargo &lt;&gt; null then
			filterText := self.frmTableFilterCargo.txtFilterBox.text;
		endif;
	elseif _table = self.tblCargoGrouped then
		//filterText := self.txtFilterGroup.text;
		//25/06/2024	navkc1 CR 64823 Task 64824
		if self.frmTableFilterGroup &lt;&gt; null then
			filterText := self.frmTableFilterGroup.txtFilterBox.text;
		endif;
	elseif _table = self.tblCustomDocument then
		//filterText := self.txtFilterCustDoc.text;
		//25/06/2024	navkc1 CR 64823 Task 64824
		if self.frmTableFilterCustDoc &lt;&gt; null then
			filterText := self.frmTableFilterCustDoc.txtFilterBox.text;
		endif;
	endif;
	
	_table.filterRowHasText(filterText);
	
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTxtArgFind" id="f3deaff6-3fb1-43a1-beb4-8c0afac83c58">
        <source>doTxtArgFind();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars
	
	findText	: String;
	tbl : CMUI_ListTable;
	rowIndex : Integer;
	colIndex : Integer;
	checkBoxColumn : Integer;
	checkText : String;
	length : Integer;
	
begin
	findText := txtArgFind.text.trimBlanks.toUpper;
	length := findText.length;
	
	if findText = null then
		return;
	endif;
	
	tbl:= self.tblArgument;
	checkBoxColumn := tbl.getChkBoxColumn;

	foreach rowIndex in 1 to tbl.rows do
		if tbl.accessRow( rowIndex ).visible then
			foreach colIndex in 1 to tbl.columns where colIndex &lt;&gt; checkBoxColumn do
				checkText := tbl.accessCell( rowIndex, colIndex ).text.trimBlanks;
				if findText = checkText[1:length] then
					break;
				endif;
			endforeach;
			if findText = checkText[1:length] then
				tbl.row := rowIndex;
				tbl.topRow := rowIndex;
				break;
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="evaluateUpDown" id="36f97dbf-8d8a-4b37-b7e2-81bff07e8ee0">
        <source>evaluateUpDown() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason

*/

vars
	criteriaLine : CM_SelectorCriteriaLine;
begin
	self.btnDown.enabled := false;	
	self.btnUp.enabled := false;	
		
	criteriaLine := self.tblCriteria.accessRow(self.tblCriteria.row).itemObject.CM_SelectorCriteriaLine;
	
	if criteriaLine = null or not self.tblCriteria.accessRow(self.tblCriteria.row).selected then
		return;
	endif;
	
	if self.tblCriteria.rows = self.tblCriteria.fixedRows + 1 then
		return; // There is only one row, so can't move up or down
	elseif self.tblCriteria.row = self.tblCriteria.rows then
		self.btnUp.enabled := true;
	elseif self.tblCriteria.row = self.tblCriteria.fixedRows + 1 then
		self.btnDown.enabled := true;
	else
		self.btnDown.enabled := true;	
		self.btnUp.enabled := true;
	endif;

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="executeQuery" id="c0ff45a7-2694-42aa-bf92-a0a179751c58">
        <source>executeQuery() : Integer protected;
// ---------------------------------------------------------------------------
// Created:     26 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	startTime			: TimeStamp;
begin

		
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	startTime := app.actualTimeServer;
	app.lockKeeperNotifyStartActivity(startTime, method, null, 'Selector criteria: ' &amp; self.myCriteriaLineHolder.getFullDescription(), app.myPassport);

	self.myCargoGroupQuery.myEnqController.doQuery(self.myQDef);

epilog
	app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	
	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		return app.myPassport.myCMIFMonitor.monitorReturnValue;	
	else
		return null;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllTisForCustDocSummary" id="31b22ef3-5e9f-43bd-9064-ce31d6ee7ecf">
        <source>getAllTisForCustDocSummary(_isTblCargoGroup : Boolean; _tiSet : CM_TISet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/02/2023	navkc1 CR 62580 Task 62581: UI - Road Exit Custom Document Details

*/

vars
	jdo 		: JadeDynamicObject;
	index 		: Integer;
	type 		: Type;
	value 		: Any;
	jdoArray 	: JadeDynamicObjectArray;
	
begin
	if _isTblCargoGroup then
		create jdoArray transient;
		self.tblCargoGrouped.allSelectedObjects.copy(jdoArray);
		
		foreach jdo in jdoArray do
			if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then
				value.Collection.copy(_tiSet);
			endif;
		endforeach;
	else
		self.tblCargo.allSelectedObjects.copy(_tiSet);
	endif;

epilog

	if _isTblCargoGroup then
		delete jdoArray;
	endif;
end;</source>
        <Parameter name="_isTblCargoGroup" type="Boolean"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTISet" id="2c77e14d-a94a-4846-a945-e5106124079c">
        <source>getTISet(_tiSet: CM_TISet io;_ti: CM_TrackedItem; _operator: CM_Operator io; _compareTi : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo

*/

vars
	found : Boolean;
begin
	_operator:= self.compareOperators(_operator,_compareTi);
	if _ti.isOnSiteOnShip() then
		_tiSet.add(_ti);
		found := true;
	endif;
epilog
	return found;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_operator" type="CM_Operator" usage="io"/>
        <Parameter name="_compareTi" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="4b2a99a3-6600-4134-9e17-b8b45ae337d3">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2022	jlier1	Initial creation 53515

*/

vars
	xmlStr : String;
	groupingRowsXML,
	addtionalRowXML : String;
	entTableRow : EntTableRow;
	criteLineHolderXML : String;
begin
	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.tblCargo.getXmlStrForColumns(true);

	foreach entTableRow in self.allGroupingRows do
		groupingRowsXML := groupingRowsXML &amp; global.formatAsXML(CM_DataTable.XMLTag_Column, entTableRow.name);
	endforeach;
	
	xmlStr := xmlStr &amp; global.formatAsXML(XMLTag_Grouping, groupingRowsXML);
	
	
	foreach entTableRow in self.allAdditionalRows do
		addtionalRowXML := addtionalRowXML &amp; global.formatAsXML(CM_DataTable.XMLTag_Column, entTableRow.name);
	endforeach;
	xmlStr := xmlStr &amp; global.formatAsXML(XMLTag_Additional, addtionalRowXML);
	
	criteLineHolderXML:= self.myCriteriaLineHolder.getXMLStringForSave;
	criteLineHolderXML:=criteLineHolderXML.replace("root",self.XMLTag_Criteria);
	xmlStr := xmlStr &amp; criteLineHolderXML;
	
	//02/10/2023	navkc1	CR 60423 Task 60763
	xmlStr := xmlStr &amp; global.formatAsXML(self.btnShowSelector.name, self.btnShowSelector.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(self.btnShowTblSummary.name, self.btnShowTblSummary.value.String);	
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.btnGrid.name, self.btnGrid.value.String);	
	xmlStr := xmlStr &amp; global.formatAsXML(self.btnVertical.name, self.btnVertical.value.String);	
	xmlStr := xmlStr &amp; global.formatAsXML(self.btnHorizontal.name, self.btnHorizontal.value.String);	
	
	return xmlStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="b03ca7e5-0174-4e9c-b75c-986c725c3d97">
        <source>getXMLSettingsForSetup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	jlier1	Initial creation 53515

*/

vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue, entName : String;
	pos : Integer;
	entRowName : EntTableRow;
	criteriaLine			: CM_SelectorCriteriaLine;
	idx	: Integer;
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;

	theXMLValue:= theXML.cnEcGetTagValueOfName(XMLTag_Grouping);
	
	if theXMLValue &lt;&gt; null then
		pos := 1;
		while (pos &gt; 0) do
			entName := theXMLValue.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_Column, pos);
			entRowName:=self.allGroupingRowsAvailable.getEntRowNamed(entName);
			if entRowName &lt;&gt; null then
				self.allGroupingRows.add(entRowName);
			endif;
		endwhile;
		if self.frmToolbar.showCaptions then
			self.setEntRowsLabel(self.lblGroupedBy,self.allGroupingRows,5);
		else
			self.setEntRowsLabel(self.lblGroupedBy,self.allGroupingRows,3);
		endif;
	endif;
	
	theXMLValue:= theXML.cnEcGetTagValueOfName(XMLTag_Additional);
	
	if theXMLValue &lt;&gt; null then
		pos := 1;
		while (pos &gt; 0) do
			entName := theXMLValue.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_Column, pos);
			entRowName:=self.allAdditionalRowsAvailable.getEntRowNamed(entName);
			if entRowName &lt;&gt; null then
				self.allAdditionalRows.add(entRowName);
			endif;
		endwhile;
		 if self.frmToolbar.showCaptions then
			self.setEntRowsLabel(self.lblAdditional,self.allAdditionalRows,5);
		else
			self.setEntRowsLabel(self.lblAdditional,self.allAdditionalRows,2);
		endif;
	endif;

	theXMLValue:= theXML.cnEcGetTagValueOfName(self.XMLTag_Criteria);
	if theXMLValue &lt;&gt; null then
		self.myCriteriaLineHolder.createCriteriaLinesFromXML(global.formatAsXML(self.XMLTag_Criteria,  theXMLValue),self.myQDef);
		//default the terminal to self terminal
		criteriaLine:=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myTerminal.name);
		if criteriaLine &lt;&gt; null and criteriaLine.myQueryOperator.getSearchValue.CM_Terminal &lt;&gt; self.myTerminal then
			criteriaLine.myQueryOperator.setSearchValue(self.myTerminal);	
		endif;
		
		foreach criteriaLine in self.myCriteriaLineHolder.allCriteriaLines discreteLock do
			idx := self.tblCriteria.addItemObject(criteriaLine, criteriaLine.getDescriptionString);
			self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
		endforeach;
	endif;
	
	//02/10/2023	navkc1	CR 60423 Task 60763
	self.btnShowSelector.value := theXML.cnEcGetTagValueOfName(self.btnShowSelector.name).Boolean;
	if self.btnShowSelector.value = false then
		self.btnShowSelector.click(self.btnShowSelector);
	endif;
	
	self.btnShowTblSummary.value := theXML.cnEcGetTagValueOfName(self.btnShowTblSummary.name).Boolean;
	if self.btnShowTblSummary.value = false then
		self.btnShowTblSummary.click(self.btnShowTblSummary);
	endif;
	
	self.btnGrid.value := theXML.cnEcGetTagValueOfName(self.btnGrid.name).Boolean;
	if self.btnGrid.value = true then
		self.btnGrid.click(self.btnGrid);
	endif;
	
	self.btnHorizontal.value := theXML.cnEcGetTagValueOfName(self.btnHorizontal.name).Boolean;
	if self.btnHorizontal.value = true then
		self.btnHorizontal.click(self.btnHorizontal);
	endif;
	
	self.btnVertical.value := theXML.cnEcGetTagValueOfName(self.btnVertical.name).Boolean;
	if self.btnVertical.value = true then
		self.btnVertical.click(self.btnVertical);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initCustDocTable" id="b4c18407-52ee-436e-920e-32bcce5c024c">
        <source>initCustDocTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60764: UI - Cargo Review Cust Doc Summary

*/

vars
	tbl		: CM_DataTable;
	text	: String;
begin
	
	tbl := self.tblCustomDocument;
	
	tbl.columns := 12;
	tbl.fixedRows := 1;
	
	tbl.selectMode:= Table.SelectMode_WholeRows;
	tbl.selectionType := CM_DataTable.SelectionType_Row;
	tbl.multiSelect := CM_DataTable.MultiSelect_Simple;
	
	// Inward Cust Doc details
	text := "Customs In Type Code";
	tbl.accessCell(1, 1).text :=  text;
	text := "Customs In Code";
	tbl.accessCell(1, 2).text :=  text;
	text := "Customs In Date Type";
	tbl.accessCell(1, 3).text :=  text;
	
	// Pending
	text := "Customs Pending Qty";
	tbl.accessCell(1, 4).text :=  text;
	text := "Customs Pending Volume";
	tbl.accessCell(1, 5).text :=  text;
	text := "Customs Pending Weight";
	tbl.accessCell(1, 6).text :=  text;
	
	// Outward Cust Doc details
	text := "Customs Out Type Code";
	tbl.accessCell(1, 7).text :=  text;
	text := "Customs Out Code";
	tbl.accessCell(1, 8).text :=  text;
	
	// Cleared
	text := "Customs Out Date Time";
	tbl.accessCell(1, 9).text :=  text;
	text := "Customs Cleared Qty";
	tbl.accessCell(1, 10).text :=  text;
	text := "Customs Cleared Volume";
	tbl.accessCell(1, 11).text :=  text;
	text := "Customs Cleared Weight";
	tbl.accessCell(1, 12).text :=  text;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isCriteriaUpdate" id="ec782cda-7042-44a7-a0f4-d9a7e4440e79">
        <source>isCriteriaUpdate() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2025	navrv30	MTN 34823 MTN | Cargo Review Auto Update Selector

*/

vars
	criteriaLine 		: CM_SelectorCriteriaLine;
	criteriaHolder			: CM_QueryCriteriaLineHolder;
	tblSheet				: JadeTableSheet;
	persistentProp			: CM_QueryProperty;
	row : Integer;
	controlSearchDescription, criteriaSearchDescription, argumentStr : String;
begin
	persistentProp		:= self.cmbAttr.listObject.CM_QueryProperty;
	if persistentProp = null then
		return CMUI_CargoReview.Mode_Unchanged;
	endif;

	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);
	criteriaHolder := self.myCriteriaLineHolder;
	criteriaLine := criteriaHolder.allCriteriaByPropertyName[persistentProp.propertyName, persistentProp.propertyClassName];
	
	//criteriaLine := self.tblCriteria.accessRow(self.tblCriteria.row).itemObject.CM_SelectorCriteriaLine;
	
	
	tblSheet.findRowObject(criteriaLine, row);
	if row &gt; 0 and row &lt;= tblSheet.rows then
		tblSheet.row := row;
	else
		tblSheet.row := tblSheet.rows;
	endif;
	
	if criteriaLine &lt;&gt; null then
		criteriaSearchDescription := criteriaLine.getDescriptionString();
	else
		return CMUI_CargoReview.Mode_Add;
	endif;
	
	if self.cmbArgument.visible then
		argumentStr := self.cmbArgument.text;
	elseif self.lblargList.visible then
		argumentStr := self.lblargList.caption;
	elseif self.txtFromDate.visible then
		argumentStr:= self.txtFromDate.text &amp; " and " &amp; self.txtToDate.text;
	elseif self.txtArgumentFrom.visible then
		argumentStr := self.txtArgumentFrom.text;
	endif;
	
	controlSearchDescription := self.cmbAttr.text &amp; " " &amp; self.cmbOperator.text &amp; " " &amp; argumentStr;
	
	if  controlSearchDescription &lt;&gt; criteriaSearchDescription then
		return CMUI_CargoReview.Mode_Update;
	endif;
	
	return CMUI_CargoReview.Mode_Unchanged;

	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadAttrCombo" id="318898b3-084f-4f3f-95cc-64a2f08e422b">
        <source>loadAttrCombo() protected;
// ---------------------------------------------------------------------------
// Created:     06 May 2022	
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
	qProp	: CM_QueryProperty;
	terminology : String;	
	theCargoBOLType : CM_CargoBOLType;
	index : Integer;	
begin
	self.cmbAttr.clear();
	self.frmArgument.visible := false;
	
	theCargoBOLType := app.myRoot.getCargoBOLTypeForId(self.myQDef.mode);

	foreach qProp in self.myQDef.allQueryProperties discreteLock do			
		if not qProp.canBeViewed(app.myPassport) then
			continue;
		endif;

		if not qProp.propertyAvailableInCombo() then
			continue;
		endif;
		
		if qProp.propertyName = CM_TrackedItem::mySubTerminal.name then
			if not app.isSubTerminalsLicensed then
				continue;
			endif;
		endif;
		
		terminology := app.getTerminologyAlternate(theCargoBOLType, null, qProp.niceName , CM_TermExpressionSingular, qProp.niceName) ;	//Roch
		index := self.cmbAttr.addItem(terminology);
		self.cmbAttr.itemObject[index] := qProp;
		self.cmbAttr.itemBackColor[index] := qProp.getPerformanceColour;	
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadOperationCombo" id="8204debc-144f-4e73-8c81-252997eebf18">
        <updating/>
        <source>loadOperationCombo(_qProp : CM_QueryProperty) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	qOperator	: CM_QueryOperator;
	idx			: Integer;
begin

	cmbOperator.clear;
	foreach qOperator in _qProp.allAllowedOperators discreteLock do
		idx := cmbOperator.addItem(qOperator.description);
		cmbOperator.itemObject[idx] := qOperator;
	endforeach;
	
	qOperator := _qProp.getDefaultOperator;
	cmbOperator.listObject := qOperator;
	cmbOperator.text := qOperator.description;

end;</source>
        <access>protected</access>
        <Parameter name="_qProp" type="CM_QueryProperty"/>
    </JadeMethod>
