    <JadeMethod name="xmlQueueEntryAndCargo" id="a5f74d23-c39c-4518-b97a-8d7ad7852f96">
        <source>xmlQueueEntryAndCargo() : String;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	cargoId			: String;
	queueEntryId	: String;

begin
	cargoId			:= self.txtCargo.text.trimBlanks();
	queueEntryId	:= self.txtQueueEntry.text.trimBlanks();
	
	if cargoId = null then
		if queueEntryId = null then
			return "&lt;queueEntryId&gt;&lt;/queueEntryId&gt;&lt;cargoId&gt;&lt;/cargoId&gt;";
		endif;
		return "&lt;queueEntryId&gt;" &amp; queueEntryId &amp; "&lt;/queueEntryId&gt;&lt;cargoId/&gt;";
	elseif queueEntryId = null then
		return "&lt;queueEntryId/&gt;&lt;cargoId&gt;" &amp; cargoId &amp; "&lt;/cargoId&gt;";
	endif;
	
	return "&lt;queueEntryId&gt;" &amp; queueEntryId &amp; "&lt;/queueEntryId&gt;&lt;cargoId&gt;" &amp; cargoId &amp; "&lt;/cargoId&gt;";
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
