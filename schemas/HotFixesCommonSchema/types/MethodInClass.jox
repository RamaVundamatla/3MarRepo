    <JadeMethod name="checkAppJSMethod" id="10d0201d-197b-4cc3-9a3c-bd3da6f47804">
        <source>checkAppJSMethod(_myRealMethod : Method) : Method;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2013	cnwmc5	Initial creation		PAR 32864

*/

vars
	methInCls		: MethodInClass;
	meth			: Method;
	
	pos				: Integer;
	methName		: String;
begin
	pos := 1;
	
	//Get the relXXX_parXXXXX method name
	foreach methInCls in self.myClassInSchema.allMethodsInClass do
		if methInCls.name.cnContains('_') and methInCls.name.toUpper().scanUntil('_', pos) = ('REL' &amp; CM_Version.VERSION.replaceString('.', '')) then
			methName := methInCls.name;
			break;
		endif;
	endforeach;
	
	//Must be using appJadeScript for something else, so return..
	if methName = null then
		return _myRealMethod;
	endif;
	
	//Check that it is referenced in me..
	if not _myRealMethod.getSource().cnContains(methName) then
		app.msgBox('The appJadeScript method does not contain: ' &amp; methName, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return null;
	endif;
	
	return _myRealMethod;
epilog

end;</source>
        <Parameter name="_myRealMethod" type="Method"/>
        <ReturnType type="Method"/>
    </JadeMethod>
    <JadeMethod name="getMethodInJADE" id="499f8324-1232-4cb0-8a2e-fd1674ebf847">
        <source>getMethodInJADE( _isPrimitiveType : Boolean ) : Method;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	class	: Class;
	mthd	: Method;
	cls		: ClassInSchema;
	isPrimitiveType : Boolean;
	schema	: Schema;
	scm		: SchemaInPatch;
	primNamesDict	: PrimTypeNDict;
	primType		: PrimType;
	methodNameDict	: MethodNDict;
	
begin

	cls := self.myClassInSchema;

	if not _isPrimitiveType then
	
		class := cls.getClassInJADE( isPrimitiveType );
		if class = null then
			return null;
		endif;
		mthd := class.getMethod( self.name );

	else
	
		scm		:= cls.getMySchemaInPatch;
		schema	:= scm.getSchemaInJADE();
		primNamesDict :=  schema.getPropertyValue("primitives").PrimTypeNDict;
		primType:= primNamesDict[cls.name];
		if primType = null then // ClassInSchema::validatePrimitiveType found this before, so, it cannot be null
			app.raiseUnexpectedProgramError( class.name, method.name, 'PrimitiveType not found' );
			return null;
		endif;
		methodNameDict := primType.getPropertyValue("methods").MethodNDict;
		mthd := methodNameDict[self.name];

	endif;
	
	//cnwmc5 - 6 Nov 2013 - PAR 32864
	if mthd &lt;&gt; null and class &lt;&gt; null then
		if class.name = 'JadeScript' and mthd.name = 'appJadeScript' then
			return self.checkAppJSMethod(mthd);
		endif;
	endif;
	
	if mthd = null then
		app.msgBox('The method not found - ' &amp; self.name, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;

	return mthd;

end;</source>
        <Parameter name="_isPrimitiveType" type="Boolean"/>
        <ReturnType type="Method"/>
    </JadeMethod>
    <JadeMethod name="set" id="9a755dc5-b1f8-4fc6-b0c0-781f84756ab1">
        <updating/>
        <source>set( _name: String ) updating;
// created by cnwvu1 on 11/03/2007
vars

begin

	self.name				:= _name;
	self.dateOfLastEdition	:= app.actualTimeServer();
	
end;
</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ff45913d-4e37-47c8-8163-fc781084625f">
        <updating/>
        <source>setForCreate( _name: String; _classInSchema: ClassInSchema ) updating;
// created by cnwvu1 on 11/03/2007
vars

begin

	self.set( _name  );
	self.myClassInSchema := _classInSchema;

end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_classInSchema" type="ClassInSchema"/>
    </JadeMethod>
    <JadeMethod name="validate" id="934cc900-c0e1-4917-96ed-b77bc52c4ff9">
        <source>validate( _isPrimitiveType : Boolean ) : Boolean;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	mthd : Method;
	
begin
	
	
	mthd := self.getMethodInJADE( _isPrimitiveType );
	if mthd = null then
		app.writeLogMessage('Method  ' &amp; self.name &amp; ' - not found.');
		return false;
	else
		app.writeLogMessage('Method   ' &amp; self.name &amp; ' - ok.');
	endif;
		
	return true;
	
end;
</source>
        <Parameter name="_isPrimitiveType" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
