    <JadeMethod name="getDisplayStringForAttribute" id="879a7e85-933f-4652-b79b-b42a54406fb5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

// Created by cnwdvb1 on 04 September 2006

vars

begin

	if _attrName = ETRow_FromTerminalAreaType then
		if self.myFromTAType &lt;&gt; null then
			return self.myFromTAType.description;
		endif;
		return 'Any';
	elseif _attrName = ETRow_ToTerminalAreaType then
		if self.myToTAType &lt;&gt; null then
			return self.myToTAType.description;
		endif;
		return 'Any';
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="a1e548a2-89cd-4504-8616-31899f06a4ac">
        <source>getName(): String;

// Created by cnwdvb1 on 18 September 2006

vars

begin
	
	return inheritMethod &amp; ' ' &amp; self.getDisplayStringForAttribute(ETRow_FromTerminalAreaType, false) &amp; ' / ' &amp; 
	self.getDisplayStringForAttribute(ETRow_ToTerminalAreaType, false);


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isRuleRTGToRTGSameLane" id="38cd3952-d625-4b4d-badb-6290410f9399">
        <source>isRuleRTGToRTGSameLane(_sourceLocation, _targetLocation : CM_LocationsController) : Boolean;

// Created by cnwdvb1 on 30 August 2006

vars

begin
	
	if self.myFromTAType &lt;&gt; null and self.myToTAType &lt;&gt; null and
	(self.myFromTAType.type = TA_TYPE_RTG and self.myToTAType.type = TA_TYPE_RTG) then
		if _sourceLocation.isKindOf(CM_RTGController) and _targetLocation.isKindOf(CM_RTGController) then
			//epr CCMS 1076 19/8/2009 this will now just be the column
			if _sourceLocation.CM_RTGController.myGridColumn = _targetLocation.CM_RTGController.myGridColumn then
				return true;
			endif;
		endif;
	endif;
	
	return false;

end;</source>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTATypeRule" id="ec18595c-a3d0-4600-9b06-215482137208">
        <source>isTATypeRule(): Boolean;

// Created by cnwdvb1 on 05 September 2006

vars

begin
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d4166257-0a35-4a8e-8f7c-14f602e3b67e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 February 2010	cnwer1	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	pxyRTQueueMultiRuleTAType : CM_RTQueueMultiRuleTAType;
	completedOK		: Boolean;
begin
	pxyRTQueueMultiRuleTAType:= inheritMethod();
	pxyRTQueueMultiRuleTAType.myFromTAType:=self.myFromTAType;
	pxyRTQueueMultiRuleTAType.myToTAType:=self.myToTAType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRTQueueMultiRuleTAType;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRTQueueMultiRuleTAType;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForProxyTAType" id="922a6127-0d9b-4440-890d-7c8e4d5ba512">
        <updating/>
        <source>setForProxyTAType(_fromTAType, _toTAType : CM_TerminalAreaType;_terminal : CM_Terminal) updating;

// Created by cnwdvb1 on 29 August 2006

vars

begin

	self.myFromTAType	:= _fromTAType;
	self.myToTAType		:= _toTAType;
	
	self.setForProxy( _terminal);

end;</source>
        <Parameter name="_fromTAType" type="CM_TerminalAreaType"/>
        <Parameter name="_toTAType" type="CM_TerminalAreaType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="91cdfe71-6421-48c4-9c83-8f5cac71f6dc">
        <updating/>
        <source>setForUpdate(_pxyRTQueueMultiRule: CM_RTQueueMultiRuleTAType) updating;

// Created by cnwdvb1 on 29 August 2006

vars

begin

	self.myFromTAType	:= _pxyRTQueueMultiRule.myFromTAType;
	self.myToTAType		:= _pxyRTQueueMultiRule.myToTAType;
	inheritMethod(_pxyRTQueueMultiRule);

end;</source>
        <Parameter name="_pxyRTQueueMultiRule" type="CM_RTQueueMultiRuleTAType"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="8046504e-3e1a-40e4-b271-ae8eb259ca71">
        <source>validateUpdate(_passport: CM_Passport input);

// Created by cnwdvb1 on 05 September 2006

vars

	rule,
	realRule : SelfType;

begin
	inheritMethod(_passport);
	if self.myFromTAType = null and self.myToTAType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'either the From Terminal Area Type or To Terminal Area Type', null, null);
		app.raiseCMException(Input_required_field_frmTrmAre, null, null); // cnwdb2	PAR 35364
	endif;
	
	rule := self.myTerminal.allRTQueueMultiRuleTATypes[self.myFromTAType, self.myToTAType];
	
	realRule := self.pxyGetRealObject();
	
	if rule &lt;&gt; null and rule &lt;&gt; realRule then
		app.raiseCMException2(ERR_INVALID_VALUE, "From Terminal Area Type and To Terminal Area Type","A Rule already exists with the same configuration", null, null);
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
