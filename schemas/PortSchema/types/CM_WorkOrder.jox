    <JadeMethod name="getInstructionsForContext" id="55612784-c3b7-4dd1-8382-380e0c8b94c4">
        <source>getInstructionsForContext(_instructions   : CM_InstructionsIssuedSet io;
						  _passingObject  : Object;
						  _context		  : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2023	navma1  ChangeRequest 60066: FR 53127 | EUP - Additional Operational Instructions on the Order (Web)
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	woDtl : CM_WorkOrderDtl;
begin
	
	_instructions.tryAddIfNotNull(self.myInstructions);
	
	foreach woDtl in self.allWoDtls  discreteLock do								//28.05.2024 navma1 #64224
		woDtl.getInstructionsForContext(_instructions,_passingObject,_context);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
