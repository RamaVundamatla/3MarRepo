    <JadeMethod name="getTreeDescription" id="fbbd3ee3-cbb3-4a08-880f-231c01b5f7dd">
        <source>getTreeDescription(): String;
//--------------------------------------------------
// Created:	16 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
begin
	if self.isRehandle then
		if self.isRelease then
			str := "DLR L ";
		else
			str := "DLR D ";
		endif;
	elseif self.isSOB then
		str := "SOB ";
	elseif self.isRelease then
		str := 'Export '; 
	elseif self.isExportReturn then
		str := 'Export Return '; 		
	else
		str := 'Import '; 
	endif;
	
	str := str &amp; " " &amp; self.jobNum.trimBlanks;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeightValidationValues" id="db62ff4d-a1ae-4e2b-abc9-8243a6f37f04">
        <source>getWeightValidationValues( _source : String output; _crane : CM_Crane output; _maxLiftWeightTL : Integer output; _maxTwinLiftDiff : Integer output);
/* ---------------------------------------------------------------------------
Created:     15 June 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason	Par 24108

------------------------------------------------------------------------------*/
vars

	maxLiftWeightTL : Integer;
	maxTwinLiftDiff : Integer;
	
begin

	_maxTwinLiftDiff := self.myTerminal.getConfig(MaxCraneWeightDiffForTL).Integer;
	_source := self.myTerminal.name;
	
	_crane := self.getJobCrane();
	if _crane &lt;&gt; null then
		_maxLiftWeightTL := _crane.maxLiftWeightTL;
		if _crane.weightDifference &gt; 0 then
			_maxTwinLiftDiff := _crane.weightDifference.Integer;
			_source := _crane.description;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_source" type="String" usage="output"/>
        <Parameter name="_crane" type="CM_Crane" usage="output"/>
        <Parameter name="_maxLiftWeightTL" type="Integer" usage="output"/>
        <Parameter name="_maxTwinLiftDiff" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getWorkPointObject" id="f5abf79a-436d-48d5-8f7b-488649350eae">
        <source>getWorkPointObject() : CM_Object;
/*
Purpose:			
Date		Who		Reason
12 August 2011	cnwab1	Initial creation
*/

vars
	workPoint : CM_Object;
begin
	if self.craneId = null then
		return null;
	endif;
	workPoint := self.myTerminal.allWorkPointsByCode[self.craneId];
	
	if workPoint &lt;&gt; null then
		return workPoint;
	endif;
	workPoint := self.myTerminal.machines[self.craneId];
	
	if workPoint &lt;&gt; null then
		return workPoint;
	endif;

		return null;
epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
