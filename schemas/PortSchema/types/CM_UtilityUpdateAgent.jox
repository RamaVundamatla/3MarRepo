        <source>utlUpdateMenuUserReportEmail(_pxyEmailTemplate : CM_EmailTemplate input;
							_menuUserReport : CM_MenuUserReport input;
							_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     17 November 2003	cnwth2
//
// Purpose:     
//			 
