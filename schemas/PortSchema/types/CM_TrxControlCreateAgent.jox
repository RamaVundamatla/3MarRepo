    <JadeMethod name="trxCreateExtWebService" id="a3f1e814-f5d0-40b8-9629-e29c96011e4a">
        <updating/>
        <source>trxCreateExtWebService(_proxyExtWebService : CM_ExternalWebServiceDef input; _realExtWebService : CM_ExternalWebServiceDef output; _passport : CM_Passport input) updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(false);
	beginTransaction;
