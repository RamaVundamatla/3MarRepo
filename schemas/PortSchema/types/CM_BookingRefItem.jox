    <JadeMethod name="addToReason" id="0366dc2c-fe2c-4cd7-8420-2e4cfa9ebb72">
        <source>addToReason(_reason : String io; _error : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2024	navra1	Initial creation for //navra1 - CR 63764/Task 64227 - 22nd May 2024

*/

vars

begin
	if _error = null then
		return;
	endif;
	
	if _reason &lt;&gt; null then
		_reason := _reason &amp; Comma &amp; _error;
	else
		_reason := _error;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reason" type="String" usage="io"/>
        <Parameter name="_error" type="String"/>
    </JadeMethod>
