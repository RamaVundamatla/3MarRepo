<Class name="CM_QIntegerCO2Property" id="e6649315-0f48-466e-a336-4598688d0eee">
    <superclass name="CM_QIntegerProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
