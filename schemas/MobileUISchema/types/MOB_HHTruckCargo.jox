    <JadeMethod name="cmbSubCargo_lostFocus" id="2df869ba-08d2-4485-9612-d2f645864ec2">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSubCargo_lostFocus(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	subCargo : CM_Product;

begin

	subCargo := self.cmbSubCargo.listObject.CM_Product;
	
	if subCargo &lt;&gt; null and subCargo.isReefer then
		if self.myEntTableDef = null or ( self.myEntTableDef.name &lt;&gt; ETDef_GeneralCargoReefer ) then
			self.resetEntTableIfRequired( null );
		endif;
	endif;
	
	if subCargo &lt;&gt; null and 		//cnwas3 par 23956
	   self.myEntTableDef &lt;&gt; null and		
	   self.myEntTableDef.name = ETDef_GeneralCargo then	
		//self.hideAttributeRows(null, subCargo);
		self.hideAttributeRows(subCargo.myCargoType, subCargo);
	endif;	
	
	self.cmbSubCargo.listIndex := self.cmbSubCargo.findObject(subCargo);
	self.tblCargo.setValueByControlName(combobox.name, combobox.text);
		
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
