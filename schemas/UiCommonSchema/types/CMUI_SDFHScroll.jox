<GUIClass name="CMUI_SDFHScroll" id="0ac3495d-6cab-46a7-9298-5d03cc75eb53">
    <superclass name="CMUI_HScroll"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="mySDF" id="efba32c9-1d6d-471c-84c3-1cef208f50e8">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CMUI_ScrollableDrawingFrame"/>
        <access>readonly</access>
        <Inverse name="CMUI_ScrollableDrawingFrame::myHScroll"/>
    </ExplicitInverseRef>
    <JadeMethod name="change" id="3cc33cef-c980-4ef3-8be7-7c4c807eb139">
        <updating/>
        <source>change(scroll: ScrollBar input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(scroll);
	self.mySDF.setFocus();

end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isSelectable" id="1befdfad-e110-42ea-a7f7-786c7bc5a176">
        <source>isSelectable(): Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	return 	inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="scrolled" id="a801ffbe-5820-4fea-8c94-d89d0f787be5">
        <updating/>
        <source>scrolled(scroll: ScrollBar input; scrollBar: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.mySDF &lt;&gt; null then
		self.mySDF.scrollControl(ScrollBar_Horizontal, scroll.value);
	endif;

end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
