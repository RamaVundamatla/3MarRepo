    <JadeMethod name="doObjectVolatilityConversion" id="3e4e893c-ab59-48fa-9ccd-09228f7d7f4c">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	struct			: CM_VoyageStructure;
	
begin
	inheritMethod(_converter, _logIndent);
	
	_converter.doChangeVolatilityOfObject(self.allVoyageLocations, _logIndent);
	
	struct := self.myCellularVoyageStructure;
	if struct &lt;&gt; null then
		//_converter.logMessage("Processing collections for " &amp; struct.String, _logIndent);				navma1 14.01.2025
		self.myCellularVoyageStructure.doObjectVolatilityConversion(_converter, _logIndent + 1);
		//_converter.logMessage("Finished processing collections for " &amp; struct.String, _logIndent);    navma1 14.01.2025 
	endif;
	
	
epilog

end;</source>
