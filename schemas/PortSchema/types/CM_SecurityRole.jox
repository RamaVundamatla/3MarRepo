    <JadeMethod name="addAllEventTypes" id="2fdb2f6f-dd6b-467a-8622-e3d424efcc10">
        <source>addAllEventTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2020	jlgndl1	Initial creation	TFS 48784

*/

vars

	eventType : CM_EventType;

begin

	foreach eventType in app.myRoot.allEventTypesByType do
		if not self.allEventTypes.includes( eventType ) then
			self.allEventTypes.add( eventType );
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="addAllPermissions" id="4079500e-b932-4e41-a63e-c8c9420a5115">
        <source>addAllPermissions(_permAgent : CM_PermissionAgent);
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpPermAgent	: CM_PermissionAgent;

begin

	if _permAgent = null then
		create tmpPermAgent transient;
		tmpPermAgent.populatePermissionDict(true, false, 0);
		tmpPermAgent.setAllPermissionValues(true);
	else
		tmpPermAgent := _permAgent;
	endif;
	
	tmpPermAgent.getPermissionValues(self.permissions, self.isSystemSecurityRole, true);

epilog
	if _permAgent = null then
		delete tmpPermAgent;
	endif;
end;</source>
        <Parameter name="_permAgent" type="CM_PermissionAgent"/>
    </JadeMethod>
    <JadeMethod name="addAllQryReports" id="2ef98539-c054-423f-97ee-1d855c630a96">
        <source>addAllQryReports();
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Mar 2016	cnwkpd1		Tracker 586684 - JMTRelease application fails if there 
//							are unprocessed BGP report requests present
// ---------------------------------------------------------------------------
vars
	sysRep	: CM_QryReportSystem;
	userRep	: CM_QryReportUser;

begin
	foreach sysRep in CM_QryReportSystem.instances where sysRep.menuId &lt;&gt; null do
		if (not self.allQryReports.includes(sysRep)) then
			self.allQryReports.add(sysRep);
		endif;
	endforeach;

	foreach userRep in CM_QryReportUser.instances where userRep.menuId &lt;&gt; null do
		if (not self.allQryReports.includes(userRep)) then
			self.allQryReports.add(userRep);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="addAllStopTables" id="6389509c-1ad3-437e-b9a8-ac4fee6cfe0e">
        <source>addAllStopTables();
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStopTable	: CM_StopsTable;
	
begin
	foreach tmpStopTable in app.myRoot.allStopsTable do 
		if (not self.allStopsMaint.includes(tmpStopTable)) then
			self.allStopsMaint.add(tmpStopTable);
		endif;
		if (not self.allStopsView.includes(tmpStopTable)) then
			self.allStopsView.add(tmpStopTable);
		endif;
// cnwdad1 03/06/2010 - CCMS 1129.
		if (not self.allStopsCancel.includes(tmpStopTable)) then
			self.allStopsCancel.add(tmpStopTable);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="addAllToDoTasks" id="03d23803-0b2e-4e64-a59c-c76360b1c207">
        <source>addAllToDoTasks();
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toDoDesc	: CM_ToDoTaskDesc;
begin

	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions do
		if (not self.allToDoTasksAddRemove.includes(toDoDesc)) then
			self.allToDoTasksAddRemove.add(toDoDesc);
		endif;
		if (not self.allToDoTasksComplete.includes(toDoDesc)) then
			self.allToDoTasksComplete.add(toDoDesc);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="addAllTransactionTypes" id="3e7c9e62-ca93-4b95-adc9-22856c20ff84">
        <source>addAllTransactionTypes();
//-----------------------------------------
// Created: February 2006 By: cnwgd1
//-----------------------------------------
vars
	tmpTransType : CM_TransactionType;
	
begin

	foreach tmpTransType in app.myRoot.allTransactionTypes do
		if (not self.allTransactionTypesForEvents.includes(tmpTransType)) then
			self.allTransactionTypesForEvents.add(tmpTransType);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="addRoleAndChildrenToCombo" id="6d6e9390-3aa8-4d01-a8dc-1aed48d89136">
        <source>addRoleAndChildrenToCombo(_cmb : ComboBox input);
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	child	: CM_SecurityRole;	
begin

	idx := _cmb.addItem(self.name);
	_cmb.itemObject[idx] := self;

	foreach child in self.allChildRoles do
		child.addRoleAndChildrenToCombo(_cmb);
	endforeach;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addRoleAndChildrenToDict" id="7d1c9424-2acc-4819-a0a4-27147354eb23">
        <source>addRoleAndChildrenToDict(_secRoles : CM_SecurityRoleDict input);
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	child	: CM_SecurityRole;	
begin

	_secRoles.add(self);

	foreach child in self.allChildRoles do
		child.addRoleAndChildrenToDict(_secRoles);
	endforeach;
end;</source>
        <Parameter name="_secRoles" type="CM_SecurityRoleDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addRptResetRptMenus" id="ff3f2e18-1ba9-42b7-941d-9fca4cc05e40">
        <source>addRptResetRptMenus(_qryReport : CM_QryReportUser; _totalParts : Integer; _numDone : Integer io);
// -------------------------------------------
// Created 20 September 2004 by cnwdvb1
// -------------------------------------------
vars

	userTerminal	: CM_UserTerminal;
	updateMon		: Boolean;
begin

//	getting the parent roles has been shifted to calling method so that update is not called multple times for a parent
//	if self.myParentRole &lt;&gt; null then
//		self.myParentRole.addRptResetRptMenus(_qryReport, _totalParts, _numDone);
//	endif;
	
	
	self.addUserQryReport(_qryReport);
	updateMon := app.myPassport.myCMIFMonitor &lt;&gt; null;
	

	foreach userTerminal in self.allUserTerminals do
		_numDone := _numDone + 1;
		if updateMon
		and (_numDone mod 10 = 0) then
			app.myPassport.myCMIFMonitor.updateProgress('Adding report to security roles', _totalParts, _numDone);
		endif;
		

		userTerminal.addNewReport(_qryReport);
		//checkReportMenuAgainstSecurity();
	endforeach;

end;</source>
        <Parameter name="_qryReport" type="CM_QryReportUser"/>
        <Parameter name="_totalParts" type="Integer"/>
        <Parameter name="_numDone" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addUserQryReport" id="4d23cc93-b685-438d-a399-3e777be2935b">
        <source>addUserQryReport(_userRep : CM_QryReportUser) : Boolean;
// -------------------------------------------
// Created 17 September 2004 by cnwdvb1
// -------------------------------------------
begin

	if (not self.allQryReports.includes(_userRep)) then
		self.allQryReports.add(_userRep);
		return true;
	endif;
	return false;

end;</source>
        <Parameter name="_userRep" type="CM_QryReportUser"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
