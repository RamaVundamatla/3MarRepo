    <JadeMethod name="doFrameClick" id="9651b91b-dadf-4e78-85f3-0842bbac8098">
        <updating/>
        <source>doFrameClick(_frame : Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.clearAll(false);
	self.drawMark(_frame);
	self.drawMarkAI(_frame);

epilog

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawMark" id="9b5b0de8-80d9-4fe6-8569-0c13f6c28601">
        <updating/>
        <source>drawMark(_frame : Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     19 June 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	pos : Integer;
begin
	pos := self.getPositionForFrame(_frame);


	if self.positions[pos] &lt;&gt; null then
		app.msgBox("Try again POS: " &amp; pos.String, "Oops", MsgBox_Information_Icon);
		self.inspectModal;
		return;
	endif;
	
	if self.drawCross then
		self.positions[pos] := Cross;
	else
		self.positions[pos] := Nought;
	endif;
	
	_frame.autoRedraw := true;

	if self.drawCross then
		_frame.drawPictureAt(self.picCross.picture,1,1);
	else
		_frame.drawPictureAt(self.picNought.picture,1,1);
	endif;
	
	self.drawCross := not self.drawCross;
	
	if self.hasWinningLine(Nought) then
		self.drawWidth := 8;
		self.drawLine(self.x1,self.y1,self.x2, self.y2, Red);
		app.msgBox("Naughts Win!", "Winner", MsgBox_Information_Icon);
		self.clearAll(true);
	endif;
epilog

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawMarkAI" id="2ee70342-32cd-47a8-af87-7fade7719327">
        <updating/>
        <source>drawMarkAI(_frame : Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pos : Integer;
	nextAIPos : Integer;
	frame : Frame;
begin

	//pos := self.getPositionFromFrame(_frame);
	if not self.drawCross then
		return;
	endif;
	
	nextAIPos := self.getNextAIPos();

	if nextAIPos &gt; 0 then
		frame := self.getFrameForPosition(nextAIPos);
		self.drawMark(frame);
	else
		if self.noWinner() then
			app.msgBox("No Winner", "On Dear", MsgBox_Exclamation_Mark_Icon);
		else
			app.msgBox("Cannot compute next position!", "Brainless Idiot", MsgBox_Exclamation_Mark_Icon);
		endif;
		self.clearAll(true);
	endif;

	if self.hasWinningLine(Cross) then
		self.drawWidth := 8;
		self.drawLine(self.x1,self.y1,self.x2, self.y2, Red);
		app.msgBox("Cross Win!", "Winner", MsgBox_Information_Icon);
		self.clearAll(true);
	endif;

epilog

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
    </JadeMethod>
