    <JadeMethod name="activate" id="baaece64-03b6-4361-ad4a-7e55e60644e5">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
// ---------------------------------------------------------------------------
// Created:     06 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin


	app.setMyTerminal(self.myTerminal);
	if self.myTerminal = null then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp;  ' *** myTerminal is null for ' &amp; self.String);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="btnHelp_clickX" id="fbbcf005-cf41-452b-8fad-2d63f5b50ade">
        <updating/>
        <source>btnHelp_clickX( btn: Button input ) updating;

//	RD 2 v 00: copies in CMS_Modal, CMS_MainForm, CMS_PlainModal
//	RD 18 vii 00: replaced with app method
//	RD 18 xii 00: replaced with btnHelp_mouseUp

begin
	if self.helpKeyword.length = 0 then
		self.helpKeyword := self.name;
	endif;
	app.helpShowHelp( self );
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnHelp_mouseUp" id="9e2e1966-9a22-4098-8c6d-adf1b1d0c607">
        <updating/>
        <source>btnHelp_mouseUp( btn : Button input; button, shift : Integer; x, y : Real ) updating;

vars

begin
	if button = 2 then	// right-click
		// do nothing
	else				// left click (or middle-click)
		if self.helpKeyword.length = 0 then
			self.helpKeyword := self.name;
		endif;
		app.helpShowHelp( self );
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="checkSecurity" id="07cf3892-51a5-4f09-b4d1-aadd14c1c79f">
        <source>checkSecurity(permissionCode:Integer; permLabel:String):Boolean;

vars

begin
	// AKB PAR 3736 - 24Jan2001 added. Has the user got  access?
	if not app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE, permissionCode) then

		app.msgBox(app.getErrorString1(VB_SECMOVE,permLabel) ,
										"Application Security",
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);

		return false;
	else
		return true;
	endif;

end;</source>
        <Parameter name="permissionCode" type="Integer"/>
        <Parameter name="permLabel" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogin" id="ccc0fb53-2bf4-4a5d-8c12-a8e8c0e34b44">
        <updating/>
        <source>doLogin() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	logon : CMS_Logon;
	form : Form;

begin

	while app.formsCount &gt; 1 do
		form := app.forms(1);
		form.unloadForm;
	endwhile;

	create logon;
	logon.userObject := self;   // My ID in case of trouble
	logon.showModal;            // Will not return here unless satisfied
								// but may unload me if unhappy.
	if logon.modalResult &lt;&gt; 0 then          // user canned out withot login
		self.menuFileExit_click(menuFileExit);               // Bye bye
		return false;
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
