    <JadeMethod name="getDescriptionForCamsDAM" id="c855aa93-7746-452d-b25b-89983e05519c">
        <source>getDescriptionForCamsDAM():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2019	jlgndl1	Initial creation	TFS 
24 June 2022 	navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details

*/

vars

	str	: String;
	damageDefinitionDesc : String;
	dsLevel	 : String;		//28 June 2022 navhl20 TFS 53862
	
begin
	
	if self.myDamageDefinition &lt;&gt; null then
		damageDefinitionDesc:= self.myDamageDefinition.description;
	endif;
	
	//Start 28 June 2022 navhl20 TFS 53862
	if self.myDamageSeverity &lt;&gt; null then
		dsLevel := self.myDamageSeverity.level.String;
	endif;
	//End 28 June 2022 navhl20 TFS 53862

	if self.myDamagePosition = null then
		//str := app.getDamageDescrForLoc(self.damageLocation) &amp; ' has ' &amp; damageDefinitionDesc&amp; '(' &amp; self.severity.String &amp; ')';			//24 June 2022 navhl20 TFS 53862
		str := app.getDamageDescrForLoc(self.damageLocation) &amp; ' has ' &amp; damageDefinitionDesc&amp; '(' &amp; dsLevel &amp; ')';			//24 June 2022 navhl20 TFS 53862
	else
		//str := app.getDamageDescrForPosition(self.myDamagePosition) &amp; ' has ' &amp; damageDefinitionDesc &amp; '(' &amp; self.severity.String &amp; ')';	//24 June 2022 navhl20 TFS 53862
		str := app.getDamageDescrForPosition(self.myDamagePosition) &amp; ' has ' &amp; damageDefinitionDesc &amp; '(' &amp; dsLevel &amp; ')';	//24 June 2022 navhl20 TFS 53862
	endif;
	
	return str[1:35];	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c536ec12-9a61-48c9-98bd-ba6272c00072">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 31/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 24 June 2022 navhl20		TFS 53862 EUP - WMS - Damage Recording Extra Details
//----------------------------------------------------------------------
vars
	measurementType : CM_MeasurementType;
	terminal : CM_Terminal;
begin
	if _attrName = ETRow_DamagePosition then
		if self.myDamagePosition &lt;&gt; null then
			return self.myDamagePosition.code;		// 06.07.2022 navak20 TFS 53862
		endif;
	
	// 06.07.2022 navak20 TFS 53862
	/*elseif _attrName = ETRow_DamageSeverity then
		return self.severity.String;*/
	// 06.07.2022 navak20 TFS 53862
	elseif _attrName = ETRow_IsNewDamage then
		return self.isNewDamage.getYesNo();
	elseif _attrName = ETRow_Quantity then
		return self.quantity.String;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	elseif _attrName = ETRow_IsRepaired then
		return self.repaired.getYesNo();
	elseif _attrName = ETRow_DamageCode then
		if self.myDamageDefinition &lt;&gt; null then
			return self.myDamageDefinition.code;
		endif;
		
	//Start 06.07.2022 navak20 TFS 53862	
	elseif _attrName = ETRow_Damage then
		if self.myDamageDefinition&lt;&gt; null then
			return self.myDamageDefinition.code.String;
		endif;
	elseif	_attrName = ETRow_Status then
		return app.damageStatusEnumToString(self.status);
	elseif _attrName = ETRow_Responsible then
		if self.myDamageParty &lt;&gt; null then
			return self.myDamageParty.code.String;
		endif;
	elseif	_attrName = ETRow_Location then
		if self.myDamagePlace &lt;&gt; null then
			return self.myDamagePlace.code.String;
		endif;
	elseif _attrName = ETRow_DamageSeverityDefault then  // ### TFS BUG 58862 27JUN2023 NAVAB1
		if self.myDamageSeverity &lt;&gt; null then
			return self.myDamageSeverity.description;
		endif;
	elseif _attrName = ETRow_DamageSeverity then
		if self.myDamageSeverity &lt;&gt; null then
// ### TFS 55240 28OCT2022 NAVAB1			return self.myDamageSeverity.level.String;
			return self.myDamageSeverity.code;// ### TFS 55240 28OCT2022 NAVAB1
		endif;
	elseif	_attrName = ETRow_DamageReason then
		if self.myDamageReason &lt;&gt; null then
			return self.myDamageReason.code.String;
		endif;
	elseif	_attrName = ETRow_DamageDateTime then
		if self.damageDateTime &lt;&gt; null then
			return self.damageDateTime.String;
		endif;
	elseif	_attrName = ETRow_DamageSize then
		if self.damageSize &lt;&gt; null then
			// ### TFS BUG 58861 27JUN2023 NAVAB1
			terminal := self.getMyTerminal();
			if terminal &lt;&gt; null then
				measurementType := terminal.getConfig(DamageSizeDMType).CM_MeasurementType;	
			endif;
			if measurementType = null then
				measurementType := app.myRoot.getDefaultMeasurementForType(Type_Length);
			endif;
			
			if measurementType &lt;&gt; null then
				return measurementType.convertMeasurementForDisplay(self.damageSize) &amp; " " &amp; measurementType.shortName;
			else
				return self.damageSize.String;
			endif;
		endif;
	elseif	_attrName = ETRow_DamageRemarks then
		return self.remarks;
	elseif	_attrName = ETRow_RepairedReason then
		if self.myRepairReason &lt;&gt; null then
			return self.myRepairReason.code.String;
		endif;
	elseif	_attrName = ETRow_RepairedRemarks then
		return self.repairRemarks;
	elseif	_attrName = ETRow_RepairedDateTime then
		if self.repairedDateTime &lt;&gt; null then
			return self.repairedDateTime.String;
		endif;
	//End 06.07.2022 navak20 TFS 53862
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="da04aed8-6ed1-4a8b-b321-c553963de46c">
        <source>getMyTerminal(): CM_Terminal;

/*

Purpose:		// ### TFS BUG 58861 27JUN2023 NAVAB1	

Parameters:			

Return Value:		


Date		Who		Reason
27 June 2023	navab1	Initial creation

*/

vars

begin
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.myTerminal;
	endif;
	if self.mySubject &lt;&gt; null then
		return self.mySubject.getMyTerminal();
	endif;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
