    <JadeMethod name="getDepartureTimeFromBerth" id="e6a627d7-becf-4a15-9968-687bd90d1a05">
        <source>getDepartureTimeFromBerth(_berth : HMS_Berth) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     04 April 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBerth	: HMS_Berth;
begin

	tmpBerth := self.getMyBerth();
	if tmpBerth = _berth then
		// we are after the time that we left the to berth
		if self.myNextMovement &lt;&gt; null then
			return self.arrivalTimeAtToRegion.addMinutes(self.myNextMovement.waitingTime);
		endif;
		// if next movement is null (e.g. departure to SEA) then just return
		// time arrived at the next point
		return self.arrivalTimeAtToRegion;
	endif;
	
	tmpBerth := self.getMyBerthPrevious();
	if tmpBerth = _berth then
		return self.departureTimeFromFromRegion;
	endif;
	
	app.raiseUnexpectedProgramError(class.name, method.name, 'Movement ' &amp; self.String &amp; ' has no berth (' &amp; _berth.code &amp; ')');
	
	return null;

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="798dbb6e-ab8d-465c-8832-c489b5033dd2">
