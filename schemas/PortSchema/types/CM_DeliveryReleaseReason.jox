    <JadeMethod name="pxyCreateUpdateProxy" id="7fbf7b46-7bbb-425d-b8cf-30ca84012d22">
        <source>pxyCreateUpdateProxy(): SelfType;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyDrayOff : CM_DeliveryReleaseReason;
	completedOK		: Boolean;
begin
	proxyDrayOff := inheritMethod();
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyDrayOff;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyDrayOff;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="700fdad6-c1a7-4b36-8130-b31294ea99db">
        <updating/>
        <source>setForCreate(pProxyDrayOff : CM_DeliveryReleaseReason)updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	pProxyDrayOff.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyDrayOff);
	
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pProxyDrayOff" type="CM_DeliveryReleaseReason"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5ca90b37-299f-48a8-98e2-743bc4e9ec6b">
        <updating/>
        <source>setForUpdate(pProxyDrayOff : CM_DeliveryReleaseReason) updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.id := pProxyDrayOff.id;
	self.description := pProxyDrayOff.description.trimBlanks;
end;</source>
        <Parameter name="pProxyDrayOff" type="CM_DeliveryReleaseReason"/>
    </JadeMethod>
