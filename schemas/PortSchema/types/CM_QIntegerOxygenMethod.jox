    <JadeMethod name="translateToDisplayValue" id="d435f229-b79d-4c7f-9ced-7812ffa57588">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
vars

begin
	if _value.Integer &lt;&gt; NULL_INTEGER then
		return _value.String;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
