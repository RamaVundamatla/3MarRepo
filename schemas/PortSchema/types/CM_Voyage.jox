    <JadeMethod name="haveVoyAllocTranship" id="1a44ccf1-1b5c-4f10-a96a-840b8ad7ef54">
        <source>haveVoyAllocTranship() : Boolean;
// ---------------------------------------------------------------------------
// Created:     26 October 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PATR 26133 NEW
// ---------------------------------------------------------------------------

vars
	yaCriteria : CM_YACriteria;
	yaCriType : CM_YACriteriaType;
	voyYAConfig : CM_VoyageAllocationConfig;
begin
	voyYAConfig := self.allVoyageAllocationConfigs.first.CM_VoyageAllocationConfig;
	if voyYAConfig &lt;&gt; null then
		if voyYAConfig.allOpCriteria &lt;&gt; null then
			foreach yaCriType in voyYAConfig.allOpCriteria  discreteLock do
				if yaCriType.type = YACriteriaType_IsTransShip then
					return true;
				endif;
			endforeach;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
