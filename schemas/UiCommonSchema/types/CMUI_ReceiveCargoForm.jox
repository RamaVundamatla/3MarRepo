    <JadeMethod name="getControlForAttributeType" id="d5c2c201-49ac-428b-a36a-c2c9b4bc9edd">
        <source>getControlForAttributeType(_name : String) : CMUI_FieldFrame protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2018	jlger1	Initial creation tfs 7756

*/

vars

begin
	if _name = ETRow_MyWidth then
		return self.tblWidth;
	elseif _name = ETRow_MyHeight then
		return self.tblHeight;
	elseif _name = ETRow_MyLength then
		return self.tblLength;
	elseif _name = ETRow_MyLengthString then
		return self.txtLengthText;
	elseif _name = ETRow_MyHeightString then
		return self.txtHeightText;
	elseif _name = ETRow_MyWidthString then
		return self.txtWidthText;
	elseif _name = ETRow_MyWeight then
		return self.tblWeight;
	elseif _name = ETRow_MyVolume then
		return self.tblVolume;
	elseif _name = ETRow_MyQuantity then
		return self.txtQuantity;
	elseif _name = ETRow_MyType then
		return self.txtDimType;
	elseif _name = ETRow_MyDensity then
		return self.tblDensity;	
	endif;
	
	return null;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CMUI_FieldFrame"/>
    </JadeMethod>
