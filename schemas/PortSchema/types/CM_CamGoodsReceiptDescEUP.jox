    <JadeMethod name="getMyWebServiceAgentClass" id="d4e3d77b-da5c-4036-91b7-d9d6e6ac0d47">
        <source>getMyWebServiceAgentClass(): Class;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

