<Class name="CMIF_HMS_MovementEdit" id="b4b3b9b2-7d40-44e5-9831-46e75f63d79d">
    <superclass name="CMIF_HMS_StackChange"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ImplicitInverseRef name="appliesToMovement" id="1e4bd33f-a893-4664-b8b3-2b7874f79cf9">
        <embedded/>
        <type name="CMIF_HMS_WorkingMovement"/>
    </ImplicitInverseRef>
    <JadeMethod name="applyChange" id="8067ef42-7aa0-4eec-acb8-bf1e23f1b75b">
        <updating/>
        <source>applyChange() updating;

vars

begin
	// Update references to next and previous verisons of the movement
	self.appliesToMovement.versionPrevious := self.versionPrevious.CMIF_HMS_WorkingMovement;

 	// Remove versionPrevious from its parent voyage collection of allWorkingMovements
 	self.appliesToMovement.versionPrevious.myVoyageForDisplay := null;
 	// Add movement to its parent voyage collection of allWorkingMovements
 	self.appliesToMovement.myVoyageForDisplay := self.appliesToMovement.myWorkingVoyage;


 	// Remove movement versionPrevious from the controller's allMovementsInViewByDT collection
    self.appliesToMovement.versionPrevious.myViewControllerCurrent := null;
 	// Add movement to the controller's allMovementsInViewByDT collection
    self.appliesToMovement.myViewControllerCurrent := self.ofViewController;

 	// Update views
 	self.ofViewController.view_NewSelectedMovement(self.appliesToMovement, false);
end;</source>
    </JadeMethod>
    <JadeMethod name="getMyWorkingMovement" id="12df7106-cbaf-49d4-873c-cab8d7323ad4">
        <source>getMyWorkingMovement(): CMIF_HMS_WorkingMovement;
//--------------------------------------------------
// Created:	20 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.appliesToMovement;

end;</source>
        <ReturnType type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="undoChange" id="423ec67d-c3bf-496f-9027-c3b3161a9eb1">
        <updating/>
        <source>undoChange() updating;

vars

begin
	// Update references to next and previous verisons of the movement
	appliesToMovement.versionPrevious:=versionPrevious.CMIF_HMS_WorkingMovement;

 	// Remove movement from its parent voyage collection of allWorkingMovements
 	appliesToMovement.myVoyageForDisplay:=null;
 	// Add versionPrevious to its parent voyage collection of allWorkingMovements
	appliesToMovement.versionPrevious.myVoyageForDisplay:=appliesToMovement.myWorkingVoyage;


 	// Remove movement to the controller's allMovementsInViewByDT collection
    appliesToMovement.myViewControllerCurrent:=null;
    // Add movement versionPrevious to the controller's allMovementsInViewByDT collection
    appliesToMovement.versionPrevious.myViewControllerCurrent:=ofViewController;


    // Update views
 	ofViewController.view_NewSelectedMovement(appliesToMovement.versionPrevious, false);
end;</source>
    </JadeMethod>
</Class>
