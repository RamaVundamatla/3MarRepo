    <JadeMethod name="addNonSealCheck" id="1c5cea35-0cf4-4576-8df0-b82bfa8ae484">
        <source>addNonSealCheck( _ti : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 October 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	jrwSealCheckDetail : CM_JRWSealCheckDetailLine;
	proxyTi : CM_TrackedItem;
	tiWithSealTIs : CM_TrackedItem; 
	sealTi : CM_SealTI;
	loadState : Boolean;
	index : Integer;
	added : Boolean;
	
begin

	// only want to add these lines if we don't already have a line for the ti.
	// only called when we select a voyage.
	if self.allTisProcessed.getAtKey( _ti.cargoType, _ti.id ) &lt;&gt; null then
		return;
	endif;
	
	if not self.imexStatuses.isEmpty then
		if not self.imexStatuses.includes( _ti.getImExStatus ) then
			return;
		endif;
	endif;
	
	if self.receiptTransportMode &lt;&gt; 0 then
		if _ti.receiptTransportMode &lt;&gt; self.receiptTransportMode then
			return;
		endif;
	endif;

	if _ti.allSeals.isEmpty then
		// create proxy in case the TI hasn't been converted to use SealTis.
		app.cmsBeginLoad(loadState);
		proxyTi := _ti.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		tiWithSealTIs := proxyTi;
	else
		tiWithSealTIs := _ti;
	endif;
	
	if tiWithSealTIs.allSeals.isEmpty then
		if self.unMatchedOnly then
			// no sealTis means no seal value notified, can't be unmatched.
			return;
		endif;
		if self.sealType &lt;&gt; null then
			// looking for a specific seal type..
			return;
		endif;
		create jrwSealCheckDetail transient;
		jrwSealCheckDetail.setDetailsFromSealTi( _ti, 1, null );
		self.allJRWSealCheckDetailLines.add( jrwSealCheckDetail );
		added := true;
	else
		foreach sealTi in tiWithSealTIs.allSeals do
			if self.unMatchedOnly then
				if sealTi.getSealValueAsString = null then
					// no seal value notified, can't be unmatched.
					continue;
				else
					// has a value and wasn't checked, must be unmatched
				endif;
			endif;
			if self.sealType &lt;&gt; null and sealTi.sealType &lt;&gt; self.sealType then
				// looking for a specific seal type and this isn't it
				continue;
			endif;
			index := index + 1;
			create jrwSealCheckDetail transient;
			jrwSealCheckDetail.setDetailsFromSealTi( _ti, index,  sealTi );
			self.allJRWSealCheckDetailLines.add( jrwSealCheckDetail );
			added := true;
		endforeach;
	endif;
	
	if added then
		self.allTisProcessed.add( _ti );
	endif;
	
epilog

	delete proxyTi;
	app.cmsEndLoad(loadState);
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addSealCheck" id="6a1b1bfd-ab23-4fdd-9487-62c10a8f1821">
        <updating/>
        <source>addSealCheck( _trxFilter : CMQF_SealCheckTransactions; _sealCheck : CM_SealCheck ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	index : Integer;
	sealCheckDetail : CM_SealCheckDetail;
	jrwSealCheckDetail : CM_JRWSealCheckDetailLine;
	added : Boolean;
	ti : CM_TrackedItem;
	
begin

	foreach sealCheckDetail in _sealCheck.allSealCheckDetails do
		if _trxFilter.unMatchedOnly then
			if not sealCheckDetail.isUnMatched then
				continue;
			endif;
		endif;
		if _trxFilter.sealType &lt;&gt; null then
			if sealCheckDetail.sealType &lt;&gt; _trxFilter.sealType then
				continue;
			endif;
		endif;
		
		index := index + 1;
		create jrwSealCheckDetail transient;
		jrwSealCheckDetail.setDetails( index, sealCheckDetail );
		self.allJRWSealCheckDetailLines.add( jrwSealCheckDetail );
		added := true;
	endforeach;
	
	if added then
		ti := _sealCheck.myTrackedItem;
		if ti &lt;&gt; null then
			if self.allTisProcessed.getAtKey( ti.cargoType, ti.id ) = null then
				self.allTisProcessed.add( ti );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_trxFilter" type="CMQF_SealCheckTransactions"/>
        <Parameter name="_sealCheck" type="CM_SealCheck"/>
    </JadeMethod>
    <JadeMethod name="delete" id="000f06a1-6967-4441-bf1a-86366728e677">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

begin
	
	if not self.allJRWSealCheckDetailLines.isEmpty then
		self.allJRWSealCheckDetailLines.purge();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDateRangeParamString" id="08349e52-4c2e-4dd3-9dd3-b76839df689c">
        <source>getDateRangeParamString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 October 2010	cnwndl1	Initial creation	Par 25608

*/

vars

begin

	if self.endDate.isValid and self.startDate.isValid then
		// both dates.
		return self.startDate.asStringJMT &amp; " - " &amp; self.endDate.asStringJMT;
	elseif self.startDate.isValid then
		// start date only
		return app.getErrorString(CM_From) &amp; " " &amp; self.startDate.asStringJMT;
	elseif self.endDate.isValid then
		//end date only
		return app.getErrorString(CM_To) &amp; " " &amp; self.endDate.asStringJMT;
	else
		return app.getErrorString(AnyString);
	endif;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getImexParamString" id="833db460-4445-4d78-a6d7-6f24cb63e2bc">
        <source>getImexParamString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	imexStatus : Integer;
	str : String;
	
begin

	if self.imexStatuses.isEmpty then
		return app.getErrorString(AnyString);
	else
		foreach imexStatus in self.imexStatuses do
			if str = null then
				str := app.getIMEXStringFromIMEXStatus( imexStatus );
			else
				str := str &amp; ", " &amp; app.getIMEXStringFromIMEXStatus( imexStatus );
			endif;
		endforeach;
		str := str  &amp; " " &amp; app.getErrorString(Only);
		return str;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReceiptTransportParamString" id="ad940956-2eb8-4af0-8328-c23aa721cbe0">
        <source>getReceiptTransportParamString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

begin

	if self.receiptTransportMode = 0 then
		return app.getErrorString(AnyString);
	else
		return app.transModeToString(self.receiptTransportMode) &amp; " " &amp; app.getErrorString(Only);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
