    <ImplicitInverseRef name="btnCancel" id="88658bab-f53b-4c35-b501-3a4671e50938">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOK" id="50302d4b-1b20-406b-aac2-2f7581b7586d">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblName" id="4084621b-5042-49ec-aa80-a8a4039e59f3">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtName" id="f1ece4ca-5843-402c-b277-150041984a60">
