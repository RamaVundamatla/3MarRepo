    <JadeMethod name="clearAllSelectedItems" id="a08a7b87-e663-44ac-a6e3-daf7a11fff8f">
        <source>clearAllSelectedItems();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Jun 2009	consw1	Initial creation

*/

vars
	wasWagonSelected : Boolean;
	
begin
	wasWagonSelected := self.isWagonSelected();

	inheritMethod();

	if wasWagonSelected then
		//  Redraw wheels to highlight wagon no longer selected
		self.redrawWheels();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="a184868a-75c9-4fb4-b260-9b66191e8ba2">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.scaleXFactor	:= 1;
	self.scaleYFactor	:= 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawColumnLabel" id="0d14cb29-619e-4227-8a7c-2133c3eb1b2f">
        <source>drawColumnLabel(caption : String; x1 : Real);
// ---------------------------------------------------------------------------
// Created:      31 July 2003 by cnwsgp1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	lY : Real;
	lX : Real;
	frame : CMUI_ScrollableLabelsFrame;
	gridFrame : CMUI_GridAreaFrame;
	theCaption : String;

begin
	if self.singleWagonOnly then
		// don't show column labels for a single wagon display
		return;
	endif;
	frame := self.mySDF.myHLabels;
	frame.fontSize := frame.drawFontSize;
	
	gridFrame := self.myGridAreaFrame;

	theCaption := self.getColumnLabel();

	lX := x1 + ((gridFrame.width) div 2) - (frame.getTextExtent(theCaption) div 2);
	lY := (frame.height div 2) - (frame.getTextHeight(theCaption) div 2);
	frame.drawTextAt(theCaption, lX + 1, lY + 1, White);
	frame.drawTextAt(theCaption, lX, lY, Black);
end;</source>
        <Parameter name="caption" type="String"/>
        <Parameter name="x1" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawGridArea" id="7dd71290-49eb-4b18-8264-c33846a7b49c">
        <updating/>
        <source>drawGridArea() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 12/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	tmpFrame		: CMUI_GridAreaFrame;
	lWheelWidth, lWheelTop, lWheelLeft, lLabelLeft: Real;	
	lFactor 		: Integer;
	gridPoint		: CMUI_GridPoint;
	lNow 			: TimeStamp;
	lTotalColums 	: Integer;
	str 			: String;
	filterTrain		: CM_Train;
	timberPos		: Real;
	tmpY : Real;
begin
	tmpFrame := self.myGridAreaFrame;

	if tmpFrame = null then
		return;
	endif;
	
	tmpFrame.clearGraphics();
	self.drawSpecialBefore();
	tmpFrame.caption := null;
	tmpFrame.fontName := "Arial";
	tmpFrame.fontSize := 10;
	tmpFrame.backColor := Red; //self.colourBack;
	tmpFrame.drawStyle := tmpFrame.DrawStyle_Solid;

	if self.myWagon = null and self.myRailLine &lt;&gt; null then
		tmpFrame.width := self.totalPointWidth;
		tmpFrame.height := self.totalPointHeight;
		tmpFrame.drawTextAlign := Window.DrawTextAlign_Center;
		str := self.myRailLine.getIdString &amp; " " &amp; self.getColumnLabel();
		tmpY := tmpFrame.height / 3; // AKB2009SEP
		if self.scaleYFactor &lt; 2 then // AKB2009SEP
			tmpY := tmpY - 5; // AKB2009SEP
		endif;
		tmpFrame.drawTextAt(str, tmpFrame.width div 2, tmpY,  Black);
	endif;
	
	// sgp 11 August 2003 : draw line regardless of whether there is a wagon 
	// but only if it is not a single wagon display
	if not self.singleWagonOnly then
		tmpFrame.drawWidth := 2;
		if tmpFrame.width &gt; 500 then
			tmpFrame.drawFilledRectangle(0,totalPointHeight - 10, tmpFrame.width - 1,totalPointHeight - 9 , Track_Brown);
		else
			tmpFrame.drawFilledRectangle(0,totalPointHeight - 10, 500, totalPointHeight - 9 , Track_Brown);
		endif;
		timberPos := 6;
		while timberPos &lt; 500 or timberPos &lt; tmpFrame.width do
			tmpFrame.drawFilledRectangle(timberPos,totalPointHeight - 9, timberPos + 6, totalPointHeight - 8 , Track_Brown);
			timberPos := timberPos + 18;
		endwhile;
	endif;

	lTotalColums := self.allGridColumns.size;
	foreach gridPoint in self.allGridPoints do
		if gridPoint.isKindOf(YRD_WagonWheels) then
			if gridPoint.column = 1 or gridPoint.column =  lTotalColums then
				gridPoint.drawSelf(tmpFrame);
			endif;
		else
			if gridPoint.column = 1 then
				if gridPoint.isKindOf(YRD_WagonBody) then
					gridPoint.YRD_WagonBody.drawBody(tmpFrame);
				endif;
			endif;
			gridPoint.drawSelf(tmpFrame);
		endif;
	endforeach;

	self.drawSpecialAfter();

epilog


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawRowLabel" id="49b4682c-4213-4300-8267-8d5b41cd5263">
        <source>drawRowLabel(y1 : Real);
// ---------------------------------------------------------------------------
// Created:      31 July 2003 by cnwsgp1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 24/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 10 Oct 2022 	navhl20 	ChangeRequest 54281: EUP - Wagon Track Planning
// ---------------------------------------------------------------------------
vars
	lX : Real;
	lY : Real;
	frame : CMUI_ScrollableLabelsFrame;
	caption : String;
	gridFrame : CMUI_GridAreaFrame;
	isPlanned : Boolean;		//10.10.2022 navhl20 TFS 54281
begin
	if self.singleWagonOnly then
		// don't show row labels for a single wagon display
		return;
	endif;

	if self.myTrain &lt;&gt; null then
		if self.mySDF.allGridAreasByRowColumn.last.row &gt; 1 then
			caption := self.myTrain.code;
		endif;
	elseif self.myRailLine &lt;&gt; null then
		caption := self.myRailLine.getIdString();
		//Start 10.10.2022 navhl20 TFS 54281
		if self.myRailLine.allPlannedFutureMoves.size &gt; 0 then
			isPlanned := true;
		endif;
		//End 10.10.2022 navhl20 TFS 54281
	endif;

	if caption = null then
		return;
	endif;

	frame := self.mySDF.myVLabels;
	frame.fontSize := frame.drawFontSize;
	
	gridFrame := self.myGridAreaFrame;

	lX := (frame.width div 2) - (frame.getTextExtent(caption) div 2);
	lY := y1 + ((gridFrame.height) div 2) - (frame.getTextHeight(caption) div 2);
	frame.drawTextAt(caption, lX + 1, lY + 1, White);
	frame.drawTextAt(caption, lX, lY, Black);
	//Start 10.10.2022 navhl20 TFS 54281
	if isPlanned then
		frame.drawTextAt("P", lX, lY-15 , Green);
	endif;
	//End 10.10.2022 navhl20 TFS 54281
end;</source>
        <Parameter name="y1" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCargoCountForBoxcarGraphic" id="5ab5a091-1ed8-4fe4-be0b-0f12d05948ac">
        <source>getCargoCountForBoxcarGraphic( _displayMode : Integer ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2013	cnwndl1	Initial creation	Par 32174

*/

vars

begin

	if self.myWagon = null or not self.isBoxcar then
		return 0;
	endif;
	
	return self.myWagon.getCargoCountForBoxcarGraphic(_displayMode);

epilog

end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColumnLabel" id="75cc739e-1e3a-4200-a68b-f1d0b1423eb1">
        <source>getColumnLabel() : String;

/*

Purpose:		Get column label

Parameters:			

Return Value:		


Date			Who		Reason
22 May 2009		consw1	PAR19710 - SFW1067 Rail Simplifications

*/

vars
	
begin
	return self.getWagonPosition.stringWithLeadingZeros(2);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonPosition" id="1101fb3a-8870-4c63-b71f-d7c39cb988b8">
        <source>getWagonPosition() : Integer;

/*

Purpose:		Get the position of the wagon as it is displayed in the rail line / train

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2009	consw1	PAR19710 - SFW1067 Rail Simplifications

*/

vars
	
begin
	if self.flipHorizontal then
		return self.mySDF.allGridAreasByRowColumn.last.column + 1 - self.column;
	endif;

	return self.column;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
