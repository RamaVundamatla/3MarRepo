    <JadeMethod name="trxUpdatePreNotes" id="ac496e12-7f72-42ae-a46f-38cda299b4ff">
        <updating/>
        <source>trxUpdatePreNotes(pIntFaceArray : CMIF_TIObjectArray; _isValidate : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     Takes an array of CM_InterfaceObjects (all members should be CM_IntFaceReceival)
//				and creates pre-notified tracked items from these.
//
// Parameters:  The array of interface objects.
//
// Returns:     True if successful.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Dec 2024	navma1		MTN-33676 NXL - Update Prenotes Doesn't use Deferred Updates 
// ---------------------------------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	beginTransaction;

	_passport.useTIDictDeferUpdate 		  := true;			//16.12.2024 navma1 #MTN-33676
	_passport.useTITransactionDeferUpdate := true;			//16.12.2024 navma1 #MTN-33676
	
	app.myUtilityUA.utlUpdatePreNotes(pIntFaceArray, _isValidate, true, _passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();						//16.12.2024 navma1 #MTN-33676
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
