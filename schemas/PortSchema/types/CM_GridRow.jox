    <JadeMethod name="getExtraInfo" id="4f56f846-3c0e-4a6c-b1ab-2b641686f021">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	yalDict : 	CM_YardAllocationsByCodeDict;
	aGridController : CM_GridController;
	yal : CM_YardAllocation;
begin
	create yalDict transient;

	block := _dataContainer.addNewBlock;
	block.addNewItem("Row", DC_Label, 1, self);
	block.addNewItem(self.myGridArea.id &amp; " Row " &amp; self.label , DC_Data, 1, self);

	
	foreach aGridController in self.allControllersByColumn do
		// CCMS 1013
		//foreach yal in aGridController.allYardAllocations do
		foreach yal in aGridController.allYardAllocations where yal.includeInYardDisplays() do
			yalDict.addNoDuplicates(yal,false);
		endforeach;
	endforeach;
	
	foreach yal in yalDict do
		block := _dataContainer.addNewBlock;
		block.addNewItem("Yard Allocation", DC_MoreInfo, 1, self);

		yal.getExtraInfo(_dataContainer);
	endforeach;
epilog 
	delete yalDict;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
