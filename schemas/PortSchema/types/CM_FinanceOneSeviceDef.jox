    <JadeMethod name="createFinanceOneSettings" id="befde78b-ce93-4f96-80e8-d08be36397f3">
        <source>createFinanceOneSettings(_usePresentationClient : Boolean): MTNFO_Settings;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 March 2023		jlier1	Initial creation 56856
24 September 2024	navmd1	TFS 66210 Fixed up StringArray transient leak

*/

vars
	tokens : StringArray;
	financeOneSettings: MTNFO_Settings;
	
begin
    create financeOneSettings transient;
	financeOneSettings.usePresentationClient:=_usePresentationClient;
	financeOneSettings.userName:=self.userCode.StringUtf8;
	financeOneSettings.password:=self.getPwForUse(null).StringUtf8;
	tokens:=self.baseEndpoint.getTokens();
	financeOneSettings.host:=tokens.first.StringUtf8;
	if tokens.size = 2 then
		financeOneSettings.port:=tokens.last.Integer;
	endif;
	
	return financeOneSettings;
epilog
	delete tokens;
end;
</source>
        <Parameter name="_usePresentationClient" type="Boolean"/>
        <ReturnType type="MTNFO_Settings"/>
    </JadeMethod>
    <JadeMethod name="doConnectionTest" id="7b4b45f4-cd9f-4811-9759-c81ac312eb73">
        <source>doConnectionTest(_result: String output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 March 2023		jlier1	Initial creation 56856
23 September 2024	navmd1	TFS 66210 Swap return object for output parameters to make it place nicer with JADE

*/

vars
	financeOneClient : MTNFO_Client;
	financeOneSettings : MTNFO_Settings;
	financeOneHelper : CMIF_FinanceOneHelper;
	logFileName : String;
	exMsg, errMsg, succMsg : StringUtf8;
begin
	create financeOneHelper transient;

	create financeOneClient transient;
	financeOneClient.usePresentationClient:=financeOneHelper.usePresentationClient;
	financeOneSettings:=createFinanceOneSettings(financeOneHelper.usePresentationClient);
	logFileName:=financeOneHelper.getLogFileName;
	financeOneClient.sendInvoices(financeOneSettings,null,logFileName.StringUtf8, exMsg, errMsg, succMsg);
	
	if exMsg = null  then
		_result:="Successfully got Authentication from " &amp; self.name &amp;  " Host: " &amp; financeOneSettings.host.String &amp; " Port: " &amp; financeOneSettings.port.String;
		return true;
	endif;
	
	_result:="Failed to get Authentication from "  &amp; self.name &amp;  " Host: " &amp; financeOneSettings.host.String &amp; " Port: " &amp; financeOneSettings.port.String &amp; " return error " &amp; exMsg.String;
	return false;
	
	
epilog
	delete financeOneSettings;
	delete financeOneClient;
	delete financeOneHelper;
end;</source>
        <Parameter name="_result" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
