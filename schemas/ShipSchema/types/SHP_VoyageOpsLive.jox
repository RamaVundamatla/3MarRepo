    <JadeMethod name="getAllSelectedTIs" id="951585e8-f9d4-4d0b-bd15-b965e5c214b2">
        <source>getAllSelectedTIs(_tiSet : CM_TISet input; _all : Boolean; _table : CM_DataTable input);
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

vars
	rowIdx,
	rows : Integer;
	obj : Object;
begin
	
	if _tiSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiSet passed to method');
		return;
	endif;

	if _table = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _table passed to method');
		return;
	endif;	

	if _all then
		rows := _table.rows;
		foreach rowIdx in 2 to rows do
			obj := _table.accessRow(rowIdx).itemObject;
			if obj = null then
				continue;
			endif;
			_tiSet.add(obj.CM_TrackedItem);			
		endforeach;		
	else
		foreach obj in _table.allSelectedObjects do
			_tiSet.add(obj.CM_TrackedItem);			
		endforeach;	
	endif;
	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBottomTable" id="08490718-a5f6-4322-ad64-91a7d86448f8">
        <source>getBottomTable(_topTable : CM_DataTable) : CM_DataTable;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 August 2024		jlizm1	Initial creation TFS 65704 children of discharged mafi not automatically removed from table

*/

vars

begin
	if _topTable = null then
		return null;
	elseif _topTable = self.tblAllCargoTop then
		return self.tblAllCargoBottom;
	elseif _topTable = self.tblBookingTop then
		return self.tblBookingBottom;
	elseif _topTable = self.tblHazardousTop then
		return self.tblHazardousBottom;
	elseif _topTable = self.tblMAFITop then
		return self.tblMAFIBottom;
	elseif _topTable = self.tblReefersTop then
		return self.tblReefersBottom;
	elseif _topTable = self.tblTrailersTop then
		return self.tblTrailersBottom;
	endif;

	return null;
	
epilog

end;</source>
        <Parameter name="_topTable" type="CM_DataTable"/>
        <ReturnType type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="getCaption" id="2c8ca582-158b-4418-a059-2a516e63186d">
        <source>getCaption(str : String) : String;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

vars
	vess 	: CM_Vessel;
	caption : String;
begin
	
	if self.myCurrentVoyage = null then
		return "";
	endif;

	vess := self.myCurrentVoyage.getMyVessel();
	if vess &lt;&gt; null then
		caption := str &amp; " " &amp; vess.structureTypeString;
	endif;
		caption := str &amp; " " &amp; self.myCurrentVoyage.getId.trimBlanks;
		return caption;
epilog

end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
