    <JadeMethod name="translateForm" id="63377f57-dd40-4752-8d42-a37a2afd39c6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 February 2017 09:19:33.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021892, locale);
	btnCancel.translateCaption(Xlat_0021893, locale);
	btnSave.translateCaption(Xlat_0021894, locale);
	lblShift.translateCaption(Xlat_0021895, locale);
	lblShiftEndDate.translateCaption(Xlat_0021896, locale);
	lblShiftRemarks.translateCaption(Xlat_0021897, locale);
	lblShiftStartDate.translateCaption(Xlat_0021898, locale);
	lblVoyage.translateCaption(Xlat_0021899, locale);
	mnuContext.translateCaption(Xlat_0021900, locale);
	mnuInspectObject.translateCaption(Xlat_0021901, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="1371b96e-29c3-4b05-a396-bd4707c9c777">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date		Who		Reason
17 February 2017	cnwab1	Initial creation
*/

vars
	job : CM_VoyageJob;
	event, idx : Integer;
    str : String;
begin

	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = VoyageJob_Update_Event then
		if userInfo.isKindOf(CM_VoyageJob) then
			job := userInfo.CM_VoyageJob;
			if job &lt;&gt; null and job.myVoyage &lt;&gt; self.myCurrentVoyage then
				return;
			endif;
			
			self.tblData.updateItemObject(job, self.colorRow1, self.colorRow2, app.myPassport);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
