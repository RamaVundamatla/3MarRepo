    <JadeMethod name="btnClose_click" id="e4ae80ef-da8b-4abd-8370-2b23a6726d67">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnGetResults_click" id="0e5eb3ab-a4b2-4961-81c1-4c8232ddadf6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGetResults_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg("Analyzing Test results...");
	self.doAnalysis();
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAnalysis" id="39470af5-bd25-486f-888f-c13036bdc3ee">
        <updating/>
        <source>doAnalysis() updating;
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Purpose:		Initiates a web test.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testResult			: CnEcWebTestResult;
	resultIterator		: Iterator;
	startDateTime		: TimeStamp;
	endDateTime			: TimeStamp;
	msgCount			: Integer;
	timeTotal			: Decimal[12,3];
	timeShortest		: Decimal[12,3];
	timeLongest			: Decimal[12,3];
	sizeTotal			: Integer;
	sizeSmallest		: Integer;
	sizeLargest			: Integer;
	timeDifference		: Decimal[12,3];
	messageSize			: Integer;
	isFirstIteration	: Boolean;

begin
	startDateTime.setDate(txtDateStart.text.trimBlanks.Date);
	startDateTime.setTime(txtTimeStart.text.trimBlanks.Time);
	endDateTime.setDate(txtDateEnd.text.trimBlanks.Date);
	endDateTime.setTime(txtTimeEnd.text.trimBlanks.Time);

	if (not startDateTime.time.isValid) then
		self.aError	:=	"The start time is not a valid Time.";
		return;
	endif;

	if (not startDateTime.date.isValid) then
		self.aError	:=	"The start date is not a valid Date.";
		return;
	endif;

	if (not endDateTime.time.isValid) then
		self.aError	:=	"The end time is not a valid Time.";
		return;
	endif;

	if (not endDateTime.date.isValid) then
		self.aError	:=	"The end date is not a valid Date.";
		return;
	endif;

	if startDateTime &gt; endDateTime then
		self.aError	:=	"The start date/time cannot be later than the end date/time.";
		return;
	endif;

	self.aTimeStampFrom	:=	startDateTime;
	self.aTimeStampTo	:=	endDateTime;
	self.aMsgCount		:=	0;
	self.aTimeAverage	:=	0;
	self.aTimeShortest	:=	0;
	self.aTimeLongest	:=	0;
	self.aSizeAverage	:=	0;
	self.aSizeSmallest	:=	0;
	self.aSizeLargest	:=	0;

	resultIterator		:=	app.myBaseRoot.allWebTestResults.createIterator();
	app.myBaseRoot.allWebTestResults.startKeyGeq(startDateTime, null, resultIterator);
	isFirstIteration	:=	true;

	while resultIterator.next(testResult) do
		if testResult.timeRequested &gt; endDateTime then
			break;
		endif;

		msgCount	:=	msgCount + 1;

		timeDifference	:=	testResult.timeRequested.cnEcDiff(testResult.timeReceived) / 1000;
		messageSize		:=	testResult.resultData.length;

		if isFirstIteration then
			timeShortest		:=	timeDifference;
			timeLongest			:=	timeDifference;
			sizeSmallest		:=	messageSize;
			sizeLargest			:=	messageSize;
			isFirstIteration	:=	false;
		endif;

		timeTotal	:=	timeTotal + timeDifference;

		if timeDifference &lt; timeShortest then
			timeShortest	:=	timeDifference;
		endif;

		if timeDifference &gt; timeLongest then
			timeLongest	:=	timeDifference;
		endif;

		sizeTotal	:=	sizeTotal + messageSize;

		if messageSize &lt; sizeSmallest then
			sizeSmallest	:=	messageSize;
		endif;

		if messageSize &gt; sizeLargest then
			sizeLargest	:=	messageSize;
		endif;
	endwhile;

	if msgCount &gt; 0 then
		self.aMsgCount		:=	msgCount;
		self.aTimeAverage	:=	(timeTotal / msgCount);
		self.aTimeShortest	:=	timeShortest;
		self.aTimeLongest	:=	timeLongest;
		self.aSizeAverage	:=	(sizeTotal div msgCount);
		self.aSizeSmallest	:=	sizeSmallest;
		self.aSizeLargest	:=	sizeLargest;
	endif;
epilog
	delete resultIterator;
	self.doShowAnalysisResults();
	self.doShowError();
end;</source>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="2a7e0055-659f-4e8b-a970-1ef6362d557e">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimeStamp	: TimeStamp;

begin
	centreWindow();
	self.aTimeStampFrom	:=	currentTimeStamp;
	self.aTimeStampFrom.setTime("00:00:00".Time);
	self.aTimeStampTo	:=	currentTimeStamp;
	self.doMoveControls();
	self.doShowAnalysisResults();
	self.statusMsg(null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveControls" id="726cc206-ba6c-43f3-bf47-b3fa14621d35">
        <source>doMoveControls() protected;
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Purpose:		Resizes the receiver's child controls, typically after the receiver
//				itself has been resized.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	picBusy.move((staStatusLine.width - picBusy.width - 7), 1, picBusy.width, picBusy.height);
	picReady.move((staStatusLine.width - picReady.width - 7), 1, picReady.width, picReady.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowAnalysisResults" id="5cf802ee-7fb2-4ef1-ac6e-743b70c4c580">
        <source>doShowAnalysisResults();
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Purpose:		Updates the analysis results lables etc.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	lblScanRange.caption	:=	"From " &amp; self.aTimeStampFrom.date.shortFormat &amp;
								", " &amp; self.aTimeStampFrom.time.String &amp;
								" to " &amp; self.aTimeStampTo.date.shortFormat &amp;
								", " &amp; self.aTimeStampTo.time.String;

	txtMsgCount.text		:=	self.aMsgCount.userNumberFormat($CNEC_NO_DECIMALS_LEADING_ZERO);
	txtTimeAverage.text		:=	self.aTimeAverage.userNumberFormat($CNEC_DECIMAL3_LEADING_ZERO);
	txtTimeShortest.text	:=	self.aTimeShortest.userNumberFormat($CNEC_DECIMAL3_LEADING_ZERO);
	txtTimeLongest.text		:=	self.aTimeLongest.userNumberFormat($CNEC_DECIMAL3_LEADING_ZERO);
	txtSizeAverage.text		:=	self.aSizeAverage.userNumberFormat($CNEC_NO_DECIMALS_LEADING_ZERO);
	txtSizeSmallest.text	:=	self.aSizeSmallest.userNumberFormat($CNEC_NO_DECIMALS_LEADING_ZERO);
	txtSizeLargest.text		:=	self.aSizeLargest.userNumberFormat($CNEC_NO_DECIMALS_LEADING_ZERO);

	txtTimeStart.text		:=	self.aTimeStampFrom.time.String;
	txtDateStart.setDate(self.aTimeStampFrom.date);
	txtTimeEnd.text			:=	self.aTimeStampTo.time.String;
	txtDateEnd.setDate(self.aTimeStampTo.date);
end;</source>
    </JadeMethod>
    <JadeMethod name="resize" id="f0a1e293-66d3-42a8-8016-7aa375a5f1c2">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doMoveControls();
end;</source>
    </JadeMethod>
    <JadeMethod name="statusMsg" id="2478d266-eca9-4d94-b42e-a2543df0317b">
        <source>statusMsg(pMessage: String) protected;
// --------------------------------------------------------------------------------
// Created:		06 June 2000 by cnwdad1
//
// Purpose:		Displays a message on the status bar, and sets/resets the cursor (Busy/Idle).
//
// Parameters:	String - The message to be displayed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (pMessage.trimBlanks().length = 0) then
		picBusy.visible			:=	false;
		picReady.visible		:=	true;
		staStatusLine.caption	:=	"Ready.";
		app.mousePointer		:=	Idle;
	else
		app.mousePointer		:=	Busy;
		picReady.visible		:=	false;
		picBusy.visible			:=	true;
		staStatusLine.caption	:=	pMessage;
		picBusy.refreshNow();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
</GUIClass>
