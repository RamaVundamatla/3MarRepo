	self.assertNotNullMsg(reserveDetail, "reserveDetail | " &amp; testHeader);
	
	//Create VVR
	_terminalUTHelper.opts.purge;
	_terminalUTHelper.opts.addAssoc(UT_OPTS_Consignee, _consignee1.code);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_IsMT, true);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_AssertChecks, false);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_IgnoreTrxWarning, false);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_BestPick, false);
	
	vvr := _terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	/*
	** Assert
	*/
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Cleanup
	*/
	self.deleteReleaseRequest(UT_ReleaseRequest2);
	
	//Delete previous cargo
	
	vehicleName := UT_TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	tiSet.clear;
	
	self.logMessagePw(testHeader &amp; "Finished Test", LogINFO);
	
