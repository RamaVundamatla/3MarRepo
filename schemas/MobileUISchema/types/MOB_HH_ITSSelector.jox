    <JadeMethod name="isValidTruckForAction" id="ebb097e9-b7da-41b4-9c53-1797590bb6bd">
        <source>isValidTruckForAction( _truck : CM_Vehicle io; _visitRecord : CM_VehicleVisitRecord; errMsg : String output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2010	cnwndl1	Initial creation	CCMS OPO 1867

*/

vars

	ti : CM_TrackedItem;
	interTermJob : CM_InterTermVehicleJob;
	
begin

	if _truck &lt;&gt; null and not _truck.locationsController.allTrackedItems.isEmpty then
		// we have cargo on board, make sure it is only 'inter terminal moves'.
		// if not we have to reject it.
		interTermJob := _truck.getInterTerminalJob();
		if interTermJob = null or interTermJob.allInterTerminalMoves.isEmpty then
			// none of this cargo is inter terminal.
			errMsg := app.getErrorString(Interterminal_mix_not_allowed);
			_truck := null;
			return;
		endif;
		
		foreach ti in _truck.locationsController.allTrackedItems do
			if not interTermJob.includesMoveForTi( ti ) then
				// this piece of cargo is not inter terminal
				errMsg := app.getErrorString(Interterminal_mix_not_allowed);
				_truck := null;
				return;
			endif;
		endforeach;
	endif;
	
	if _visitRecord &lt;&gt; null and _visitRecord.isWorked then
		errMsg := app.getErrorString(Truck_visit_record_worked);
		_truck := null;
	endif;
	
epilog


end;</source>
        <Parameter name="_truck" type="CM_Vehicle" usage="io"/>
        <Parameter name="_visitRecord" type="CM_VehicleVisitRecord"/>
        <Parameter name="errMsg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="populateTerminals" id="b9824208-ee22-4459-9264-5bf3cc64de13">
        <updating/>
        <source>populateTerminals() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	conkc1	Initial creation

*/

vars

	terminal : CM_Terminal;
	index    : Integer;
	
begin

	self.cmbTerminal.addItem('&lt;' &amp; lblTerminal.caption &amp; '&gt;');

	foreach terminal in app.myRoot.allTerminals do
		if terminal.allUserTerminals[app.myPassport.myUser.code] = null then
			continue;
		endif;
		index := self.cmbTerminal.addItem(terminal.code);
		self.cmbTerminal.itemObject[index] := terminal;
	endforeach;

	self.cmbTerminal.listIndex := 1;
	
	if self.myMobileGenericAgent.myInterTerminal &lt;&gt; null then
		index := self.cmbTerminal.findObject( self.myMobileGenericAgent.myInterTerminal );
		if index &gt; 0 then
			self.cmbTerminal.listIndex := index;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="61c989ba-0128-4918-b042-1b56cb16af7f">
        <updating/>
        <source>setupControls() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 February 2010	conkc1	Initial creation

*/

vars

	truck : CM_Vehicle;
	
begin

	self.doResizeControls(true);
						
	truck := self.myMobileGenericAgent.myTruck;
	if truck &lt;&gt; null then
		self.tbxVehicle.text := truck.regNumber;
		if truck.state = null then
			self.txtState.text := lblState.caption.toUpper;
		else
			self.txtState.text := truck.state;
		endif;
	else
		self.tbxVehicle.text := lblVehicle.caption.toUpper;
		self.txtState.text := lblState.caption.toUpper;
	endif;
	
	if self.myUser &lt;&gt; null then
		tbxUser.text := self.myUser.code;
	endif;
						
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5deb7ad6-0126-4f04-9aa4-ffd08e60f4ce">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	conkc1	Initial creation

*/

vars

begin
	inheritMethod();

	self.setupCmdButtons( 3, app.getErrorString(Load), app.getErrorString(Unload), app.getErrorString(Menu), null, null );
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myUser := app.getMyUser;
	
	self.setupControls();
	self.populateTerminals();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
