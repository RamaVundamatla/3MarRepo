    <JadeMethod name="getIdBayCellTier" id="b79cc23c-cbcb-460b-a400-d933e4d6bfe1">
        <source>getIdBayCellTier(_ti : CM_TrackedItem) : String;
/*
Purpose:			
Date		Who		Reason
20 March 2014	cnwab1	Initial creation
*/

vars

begin
	if _ti = null then
		return self.getBayId(_ti) &amp; self.cellId &amp; self.tierId;
	else
		return self.myBayVoyage.id &amp; self.cellId &amp; self.tierId;
	endif;
epilog

