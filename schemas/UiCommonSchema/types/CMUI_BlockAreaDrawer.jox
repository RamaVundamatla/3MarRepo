    <JadeMethod name="drawLocationText" id="55588ba6-8b3d-4ad1-9375-7e9912ec3928">
        <source>drawLocationText(location : CM_IrregularBlockController; count : Integer; colour : Integer) protected;
//30 May 2008	cnwdw1	/*
/*Date		      Who		Reason
18 June 2008	cnwdz2	    Par16978 - Add a colour parameter to set text colour.
*/

vars
	topLeft, bottomRight : Point; 
	offsetX, offsetY, labelWidth, labelHeight, numCellsX,numCellsY : Integer;
	saveFontSize : Real;
	label : String;
	labelType : Integer;
begin
	saveFontSize := self.myDrawingFrame.drawFontSize;
	labelType := self.myDrawingFrame.getLabelContentsType;	//22 Jul 2020	NDL	TFS 49775
	
	if labelType = 0 then
		label := location.getID();  // PAR 32308
	elseif labelType = 1 then		//22 Jul 2020	NDL	TFS 49775 - Default Max Cap
		label := 'x' &amp; location.getDefaultCapacityAsStr;
	elseif labelType = 2 then		//22 Jul 2020	NDL	TFS 49775 - Default Max Wt
		label := location.getMaxWeightDisplayAsStr;
	elseif labelType = 3 then		//22 Jul 2020	NDL	TFS 49775 - YA Max Cap
		label := 'x' &amp; location.getYACapacityStr;
	endif;
	
	numCellsX := (location.region.last.x - location.region.first.x) + 1;
	numCellsY := (location.region.last.y - location.region.first.y) + 1;

	labelWidth := self.cellSize.x * numCellsX;
	labelHeight := self.cellSize.y * numCellsY;

	
	if labelWidth &gt;= labelHeight then
		topLeft := cellToPixel(location.region.first);
		bottomRight := cellToPixel(location.region.last.add(1, 1));
		offsetX := ((bottomRight.x - topLeft.x) / 2).Integer;
		offsetY := ((bottomRight.y - topLeft.y) / 5).Integer; // PAR 32308
// TFS 51393		self.myDrawingFrame.drawTextAlign := Window.DrawTextAlign_Center;
// TFS 51393		self.myDrawingFrame.getTextDrawFontSizeForWidth(label, labelWidth - (2 * self.scaleFactor)); // PAR 32308
		self.myDrawingFrame.drawTextAlign := Window.DrawTextAlign_Left;// TFS 51393
		self.myDrawingFrame.getTextDrawFontSizeForWidthHgt(label, labelWidth,labelHeight);// TFS 51393
		self.myDrawingFrame.drawTextRotation := 0;
		self.myDrawingFrame.drawTextCharRotation := 0;
// TFS 51393		self.myDrawingFrame.drawTextAt(label, topLeft.x + offsetX, topLeft.y, colour);
		self.myDrawingFrame.drawTextAt(label, topLeft.x, topLeft.y, colour);// TFS 51393
		
		if count &gt; 0 then
			self.myDrawingFrame.drawTextAlign := Window.DrawTextAlign_Right;
			offsetY := self.myDrawingFrame.drawTextHeight("1").Integer + 5;
			offsetX := 10;
			self.myDrawingFrame.drawTextAlign := Window.DrawTextAlign_Left;
			if self.scaleFactor &gt; 2 then
			
				self.myDrawingFrame.drawFontSize := 8;
				self.myDrawingFrame.drawTextAt(count.String, topLeft.x, bottomRight.y - 12, colour);
			endif;
		endif;
	else
		self.myDrawingFrame.drawTextAlign := Window.DrawTextAlign_Left;
		if count &gt; 0 then
			label := label &amp; " - " &amp; count.String;
		endif;
		self.myDrawingFrame.getTextDrawFontSizeForWidth(label, labelHeight); // PAR 32308
		self.myDrawingFrame.drawTextRotation := 270;
		self.myDrawingFrame.drawTextCharRotation := 270;
		topLeft := cellToPixel(location.region.first);
		bottomRight := cellToPixel(location.region.last.add(1, 1));
		offsetX := ((bottomRight.x - topLeft.x) / 2).Integer;
		offsetY := ((bottomRight.y - topLeft.y) / 5).Integer; // PAR 32308
		self.myDrawingFrame.drawTextAt(label, bottomRight.x + 5, topLeft.y, colour);
	endif;
	
	self.myDrawingFrame.drawFontSize := saveFontSize;

end;</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
        <Parameter name="count" type="Integer"/>
        <Parameter name="colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLocations" id="16ffe9c7-f359-4199-9b9e-b0c2a7c62d49">
        <source>drawLocations() protected;
// Draw all the regions in this area
vars
	location: CM_LocationsController;
begin
	self.allDrawnObjects.clear(); // PAR 32308
	
	foreach location in myTerminalArea.allLocationsControllers do
		self.drawLocation(location.CM_IrregularBlockController, true);
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawRegion" id="618aa124-4eef-4014-9484-6257dd709c90">
        <source>drawRegion(region : PointArray) protected;
// draw the region 
vars
	topLeft, bottomRight: Point;
	colour : Integer;
begin
	if self.isSelected(region.first) then
		colour := colourSelectedCell;
	else
		colour := colourCell;
	endif;

	topLeft := cellToPixel(region.first);
	bottomRight := cellToPixel(region.last.add(1, 1));
	self.myDrawingFrame.drawWidth := 1;
	self.myDrawingFrame.drawSolidRectangle(topLeft.x, topLeft.y, bottomRight.x-gridLineWidth, bottomRight.y-gridLineWidth, colour);
end;
</source>
        <access>protected</access>
        <Parameter name="region" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="drawRuler" id="f1514bd1-f4fb-40a9-a32b-04a28621bb64">
        <source>drawRuler() protected;
// Draw Ruler
vars
	x, y : Integer;
	textHeight : Integer;
begin
	self.myHLabels.drawTextAlign := Window.DrawTextAlign_Center;
	self.myHLabels.drawFontSize := 6;
	textHeight := self.myHLabels.drawTextHeight("1").Integer;
	y := self.myHLabels.clientHeight - textHeight - 3;
	foreach x in 1 to self.columns do
		self.myHLabels.drawTextAt(x.String, (cellSize.x + gridLineWidth) * x , y, Black);
	endforeach;
	self.myVLabels.drawTextAlign := Window.DrawTextAlign_Right;
	self.myVLabels.drawFontSize := 6;
	x := self.myVLabels.clientWidth - 3;
	foreach y in 1 to self.rows do
		self.myVLabels.drawTextAt(y.String, x, (cellSize.y + gridLineWidth) * y - (textHeight / 2), Black);
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="823c2ae4-85e3-4e75-a563-ec7fd680914c">
        <updating/>
        <source>drawSelf(_clearSelected: Boolean) updating;
// Redraw the area
vars

begin
	self.clearAllGraphics();
	self.allDrawnObjects.clear(); // PAR 32308
	self.setFrameSize();
	self.initializeYardAllocations();
	self.initialiseCells();
	self.drawRuler();
	self.drawLabels();
	self.deselectAll();
	self.drawGrid(1, self.myTerminalArea.columns, 1, self.myTerminalArea.rows);
	self.drawCells();
	self.drawLocations();
	self.drawGridBorder();

	inheritMethod(_clearSelected);
end;
</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
