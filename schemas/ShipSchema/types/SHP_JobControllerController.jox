    <JadeMethod name="isBeforeCurrentTime" id="b6c3c992-b39f-44dd-a6ce-187d4f817b30">
        <source>isBeforeCurrentTime(_x1,_x2 : Real) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 January 2007	cnwer1	Initial creation - PAR#xxxx
03 May 	   2007 EPR		PAR 13986 - they actually want to move jobs before current time	
*/
vars
	x : Real;
begin
	x:=self.getCurrentTimeX;
	if _x1 &lt; x or _x2 &lt; x then
		return false;
	endif;

	return false;
epilog

