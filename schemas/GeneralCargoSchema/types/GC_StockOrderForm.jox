    <JadeMethod name="setColIndexsTblDataDetail" id="e2fc5c0b-67ba-4f31-bf14-87d7aed9571c">
        <updating/>
        <source>setColIndexsTblDataDetail()updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblDataDetail;
	
	
	self.colCargoType	:= tmpTable.getColumnByRowName(ETRow_MyCargoType);
	self.colLineType		:= tmpTable.getColumnByRowName(ETRow_LineType);
	
	self.colQuantityId	:= tmpTable.getColumnByRowName(ETRow_RequiredID);
	self.colProduct		:= tmpTable.getColumnByRowName(ETRow_MyProduct);
//	self.		:= tmpTable.getColumnByRowName(ETRow_NoFulfilled);
end;</source>
