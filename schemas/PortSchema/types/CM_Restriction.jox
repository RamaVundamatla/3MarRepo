    <JadeMethod name="validateLocationControllers" id="393e8b7a-9d6f-4f67-9ad0-87b880d5f518">
        <source>validateLocationControllers(pTA : CM_TerminalArea; pLocationControllers : CM_LCArray) protected;
// ---------------------------------------------------------------------------
// Created:     13 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lController	: CM_LocationsController;

begin

	if pTA = null then
		// Assume that this error will have been caught by validateTerminalArea
		return;
	endif;

//	if (not pTA.testAreWeTogether(pLocationControllers)) then
//		app.raiseCMException(ERR_CONTROLLERS_NOT_CONTIGUOUS, null, null);
//		return;
//	endif;

	foreach lController in pLocationControllers do
		if lController.hasRestrictions(LABOUR_RESTRICTION) then
			app.raiseCMException(ERR_LC_HAS_RESTS, null, null);
			break;
		endif;
		if lController.hasRestrictions(LOCATION_RESTRICTION) then
			if lController.isKindOf(CM_YardController) and self.isKindOf(CM_LocationRestriction) then
				if not lController.CM_YardController.myLocationRestriction.id = self.CM_LocationRestriction.id then
					app.raiseCMException(ERR_LC_HAS_RESTS, null, null);
					break;
				endif;
			endif;
		endif;
	endforeach;	
	
end;</source>
        <access>protected</access>
        <Parameter name="pTA" type="CM_TerminalArea"/>
        <Parameter name="pLocationControllers" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="validateTerminalArea" id="e7e31826-4b36-49f3-900e-d902af67ec9f">
        <source>validateTerminalArea(pTA : CM_TerminalArea) protected;
// ---------------------------------------------------------------------------
// Created:     13 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	if pTA = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Terminal Area", null, null);
		app.raiseCMException(Input_required_field_termArea, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if (not pTA.canHaveRestrictions()) then
		app.raiseCMException1(ERR_TA_NO_REST, pTA.typeString, null, null);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pTA" type="CM_TerminalArea"/>
    </JadeMethod>
</Class>
