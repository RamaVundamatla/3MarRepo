    <JadeMethod name="btnCancel_click" id="9cb79bba-a8c8-465c-8fa1-03a9a436c4c8">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: CMUI_Button input) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.unloadForm();
end;</source>
        <Parameter name="btn" type="CMUI_Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="60fa0b9f-b821-464f-92c2-b6bb1179fbd6">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: CMUI_Button input) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.isFormChanged then
		if not self.askUserToAbandonChanges( true ) then
			return;
		endif;
	endif;
	
	self.doDelete();
	self.doEnableControls();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="CMUI_Button" usage="input"/>
    </JadeMethod>
