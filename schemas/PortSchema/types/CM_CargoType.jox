    <JadeMethod name="setDefaultValue" id="80071b47-a5be-43d4-8769-d2b2742e96a1">
        <updating/>
        <source>setDefaultValue(_attrName : String; _value : Any) updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2002		cnwth2	
//
// Purpose:     Used in conjunction with setProxy to set default values on self. Uses table values
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if not self.isTransient then
		app.raiseCMException2(MethodCalledForNonTransient, method.name, self.class.String, null, null);
		return;
	endif;
	
	if _attrName = ETRow_MyWidthString then
		self.defaultWidthString := _value.String;
	elseif _attrName = ETRow_MyHeightString then
		self.defaultHeightString := _value.String;
	elseif _attrName = ETRow_MyLengthString then
		self.defaultLengthString := _value.String;
			
	elseif _attrName = ETRow_MyWidth then
		self.defaultWidth := _value.Integer;
	elseif _attrName = ETRow_MyHeight then
		self.defaultHeight := _value.Integer;
	elseif _attrName = ETRow_MyLength then
		self.defaultLength := _value.Integer;
	
	elseif _attrName = ETRow_MyQuantity then
		self.defaultQuantity := _value.Integer;
	elseif _attrName = ETRow_MyVolume then
		self.defaultVolume := _value.Decimal;
	elseif _attrName = ETRow_MyDensity then
		self.defaultDensity := _value.Integer;
	elseif _attrName = ETRow_MyWeight then
		self.defaultWeight := _value.Decimal; //cnwrd1 ccms 1060 12.1.09
	
	elseif _attrName = ETRow_MyType then
		self.defaultType := _value.String;
	endif;
	
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsForCargoGroup" id="426c7cff-4744-424a-b6ad-741b87a1950f">
        <updating/>
        <source>setDefaultsForCargoGroup() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	str : String;

begin

	if self.allCommodities &lt;&gt; null then
		self.allCommodities.clear;
	endif;
	self.allDamageDefinitionCodes.clear();
	self.allDamagePositions.clear();
	self.allSealTypes.clear();
	
	self.allowAutoVolumeCalc := false;	//10 Jun 2016	NDL	TFS 214
	self.allowAutoWeightCalc := false;	//18 Jan 2018	NDL	TFS 36697
	self.allowDuplicates := false;
	self.canWeightBeCertified := false;
	self.chgToStorageOnUnpack := false;
	self.saveLocationActivity := false;	//13 Apr 2021	NDL	TFS 50906
	
	self.classNameToCreate := CM_CargoGroup.name;
	
	self.createBOL := false;
	self.density := 0.0;
	self.isBulkProduct := false;
	self.showDamageCodes := false;
	
	self.teuMultiplier := -1;
	self.trackByMeasureType := 0;
	self.useTareCargoWeight := false;
	
	self.mainFormFilterView := "CargoGroup";
	self.maintFormTblDataDef := ETDef_CargoGroupData;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setExtraAttributesSystem" id="b3121399-6661-4c38-b9eb-e4c356f354bc">
        <updating/>
        <source>setExtraAttributesSystem(_isWeighable, _isCheckMaxLift, _showDamageCodes, _createBOL,_isDynamicallyCreated, _isNotAvailableForEntry : Boolean; _selectedCommodities : CM_CommodityByCodeDict; _selectedDamagePos , _selectedDamageCodes : CM_ObjectSet input; 
						_useTareCargoWeight : Boolean; _canWeightBeCertified : Boolean; _includeInStorageCalc : Boolean; _tiBehaviourType : CM_TIBehaviourType; 
						_selectedSealTypes : CM_SealTypeSet; _colour : Integer;_requiresWeighing : Boolean; _autoTareCargoWeightCalc : Boolean) updating;

vars

begin

	self.isWeighable 	:= _isWeighable;
	self.isCheckMaxLift	:= _isCheckMaxLift;
	self.showDamageCodes := _showDamageCodes;
	self.isDynamicallyCreated := _isDynamicallyCreated;
	self.createBOL := _createBOL; //ccms1100 cnwrs1 Mar 2008
	self.isNotAvailableForEntry := _isNotAvailableForEntry;	// PAR 17904, CCMS 1080 May 2008
	self.useTareCargoWeight := _useTareCargoWeight;						//+cnwml2 MSL CCMS 1017
	self.canWeightBeCertified := _canWeightBeCertified;					//+cnwml2 MSL CCMS 1017
	self.includeInStorageProcess := _includeInStorageCalc;	// PAR 22253 17/02/2010
	self.colour := _colour; // PAR 34947
	self.requiresWeighing:=_requiresWeighing; //epr TFS  44965 2/8/19
	
	self.autoTareCargoWeightCalc := _autoTareCargoWeightCalc;		//navra1 - TFS 63624 - 15th Apr 2024
	if not self.useTareCargoWeight then								//navra1 - TFS 63624 - 15th Apr 2024
		self.autoTareCargoWeightCalc := false;						//navra1 - TFS 63624 - 15th Apr 2024
	endif;															//navra1 - TFS 63624 - 15th Apr 2024
	
	
	if self.allCommodities &lt;&gt; null then		// PAR 21659 17/02/2010 cnwvu1
		self.allCommodities.clear;
	endif;
	if _selectedCommodities &lt;&gt; null then 	// PAR 21659 17/02/2010 cnwvu1
		_selectedCommodities.copy(self.allCommodities);
	endif;
	
	if self.allDamagePositions &lt;&gt; null then	// PAR 22394 18/02/2010
		self.allDamagePositions.clear();
	endif;
	if _selectedDamagePos &lt;&gt; null then //20982 - Can be called when initialising a new database so can be null - cnwsh3
		_selectedDamagePos.copy(self.allDamagePositions);
	endif;
	
	if self.allDamageDefinitionCodes &lt;&gt; null then	// PAR 22394 18/02/2010
		self.allDamageDefinitionCodes.clear();
	endif;
	if _selectedDamageCodes &lt;&gt; null then
		_selectedDamageCodes.copy(self.allDamageDefinitionCodes);
	endif;
	
	//29 Nov 2011	NDL	Par 28761
	if self.allSealTypes &lt;&gt; null then
		self.allSealTypes.clear;
	endif;
	//29 Sep 2010	NDL	Par 25608
	if _selectedSealTypes &lt;&gt; null then
		_selectedSealTypes.copy(self.allSealTypes);
	endif;
	
	myRoot 				:= app.myRoot;
	
	self.myTIBehaviourType := _tiBehaviourType;  //cnwjo3 ccms 1018

end;</source>
        <Parameter name="_isWeighable" type="Boolean"/>
        <Parameter name="_isCheckMaxLift" type="Boolean"/>
        <Parameter name="_showDamageCodes" type="Boolean"/>
        <Parameter name="_createBOL" type="Boolean"/>
        <Parameter name="_isDynamicallyCreated" type="Boolean"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_selectedCommodities" type="CM_CommodityByCodeDict"/>
        <Parameter name="_selectedDamagePos" type="CM_ObjectSet" usage="input"/>
        <Parameter name="_selectedDamageCodes" type="CM_ObjectSet" usage="input"/>
        <Parameter name="_useTareCargoWeight" type="Boolean"/>
        <Parameter name="_canWeightBeCertified" type="Boolean"/>
        <Parameter name="_includeInStorageCalc" type="Boolean"/>
        <Parameter name="_tiBehaviourType" type="CM_TIBehaviourType"/>
        <Parameter name="_selectedSealTypes" type="CM_SealTypeSet"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_requiresWeighing" type="Boolean"/>
        <Parameter name="_autoTareCargoWeightCalc" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3ac64c3a-4086-48d2-a276-16cbdeaa3082">
        <updating/>
        <source>setForCreate(pProxyCargoType : CM_CargoType) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setForUpdate(pProxyCargoType);
	self.myRoot := pProxyCargoType.myRoot;

end;</source>
        <Parameter name="pProxyCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ce40c9f2-d705-4699-a2f2-51d9a30bc0ef">
        <updating/>
        <source>setForUpdate(_proxy: CM_CargoType) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 20/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
// 07/03/2019	jlgdap1		TFS 41570 PNL No PIN for a cargo type
// 02/04/2020   cnwma1      Bug 49030: ASPA Default Weight Measurement Types
// 17/05/2022   navds20     ChangeRequest 53504: EUP - Cargo Uniqueness - PortSchema
// 09/08/2022   navds20		ChangeRequest 54219: EUP - Cargo Group to be mandatory
// 11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators
// 06/09/2024	jlizm1		TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references
vars

	doSetProdAutoWeightCalc : Boolean;
	product					: CM_Product;
	needsRefresh 			: Boolean;
	pxyRecipe 				: CM_Recipe;
	realRecipe				: CM_Recipe;
	recipesToDelete 		: CM_RecipeSet;

begin

	//03 Apr 2019	NDL	TFS 44194
	if self.abbreviation &lt;&gt; _proxy.abbreviation
	or self.description &lt;&gt; _proxy.description
	then
		needsRefresh := true;
	endif;

	// DVB changed 07/11/05 Not used. See behaviour type.	
	self.classNameToCreate 	    := _proxy.classNameToCreate;
	self.myTIBehaviourType      := _proxy.myTIBehaviourType;
	self.myDefaultHandlingType  := _proxy.myDefaultHandlingType;
	self.myDefHandlingSubType 	:= _proxy.myDefHandlingSubType;	//31 Mar 2017	NDL	TFS 3414
	
	self.allAttributesOnProduct.clear();
	_proxy.allAttributesOnProduct.copy(self.allAttributesOnProduct);
	self.colour 				:= _proxy.colour;
	
	self.defaultWidthString 	:= _proxy.defaultWidthString;
	self.defaultHeightString 	:= _proxy.defaultHeightString;
	self.defaultLengthString 	:= _proxy.defaultLengthString;
	
	self.defaultWidth 			:= _proxy.defaultWidth;
	self.defaultHeight			:= _proxy.defaultHeight;
	self.defaultLength		 	:= _proxy.defaultLength;
	
	self.defaultQuantity 		:= _proxy.defaultQuantity;
	self.defaultVolume 			:= _proxy.defaultVolume;
	self.defaultDensity 		:= _proxy.defaultDensity;
	self.defaultWeight 			:= _proxy.defaultWeight;
	
	self.defaultType 			:= _proxy.defaultType;
	
	self.allowAutoVolumeCalc	:= _proxy.allowAutoVolumeCalc;		//10 Jun 2016	NDL	TFS 2141
	self.isCargoGroupRequired 	:= _proxy.isCargoGroupRequired;     //09/08/2022 navds20 TFS 54219
	self.allowMultiOperators	:= _proxy.allowMultiOperators; //11/07/2023 navmv20 CR 58244 Task 58245
	self.externalReference		:= _proxy.externalReference;
	
	//29 Jan 2018	NDL	TFS 36697
	if ( self.allowAutoWeightCalc	&lt;&gt; _proxy.allowAutoWeightCalc )
	and ( _proxy.allowAutoWeightCalc = true )
	and ( _proxy.useTareCargoWeight = true )
	and ( _proxy.allowDuplicates = true )
	then
		doSetProdAutoWeightCalc := true;
	endif;
	self.allowAutoWeightCalc	:= _proxy.allowAutoWeightCalc;		//18 Jan 2018	NDL	TFS 36697
	self.allowDuplicates		:= _proxy.allowDuplicates;
	self.isWeighable			:= _proxy.isWeighable;
	self.requiresWeighing		:= _proxy.requiresWeighing;			//05 Jul 2019	NDL	TFS 44965
	self.saveLocationActivity 	:= _proxy.saveLocationActivity;		//13 Apr 2021	NDL	TFS 50906
	
	//CCMS 2274 if breakbulk cargo can be split then don't allow weight to be certified 
	if self.myClassToCreate = CM_BreakBulkGeneric and self.allowDuplicates then
		self.canWeightBeCertified :=false;
	else		
		self.canWeightBeCertified := _proxy.canWeightBeCertified;			//+cnwml2 MSL CCMS 1017
	endif;
	
	self.isCheckMaxLift			:= _proxy.isCheckMaxLift;
	self.includeInStorageProcess:= _proxy.includeInStorageProcess;
	self.showDamageCodes		:= _proxy.showDamageCodes;
	self.isBulkProduct			:= _proxy.isBulkProduct;					// R Barr 2/11/2006 Comalco
	self.isDynamicallyCreated	:= _proxy.isDynamicallyCreated; 			// AER Nelson 12/05/2008
	self.productType 			:= _proxy.productType;
	self.isShownInGateInOut		:= _proxy.isShownInGateInOut;
	self.chgToStorageOnUnpack	:= _proxy.chgToStorageOnUnpack;				//24 Apr 2015	NDL	Par 36111

	self.createBOL 				:= _proxy.createBOL;
	
	self.isCommodityRequired	:= _proxy.isCommodityRequired;
	self.defaultCommodityCode	:= _proxy.defaultCommodityCode;
	self.isNotAvailableForEntry	:= _proxy.isNotAvailableForEntry;
	self.useCargoGroupForUniqueness := _proxy.useCargoGroupForUniqueness; 	//17/05/2022 navds20  53504
	self.useCargoSubtypeForUniqueness := _proxy.useCargoSubtypeForUniqueness; // 01/05/2023 jlizm1 TFS 55453
	
	self.allTerminals.clear();												//PAR 17904, CCMS 1080 May 2009
	_proxy.allTerminals.copy(self.allTerminals);

	self.allCommodities.clear();											//PAR 17904, CCMS 1080 May 2009
	_proxy.allCommodities.copy(self.allCommodities);
	
	// CCMS SFW1066  - Recording Damage Details Changes. cnwsh3. 27/7/2009
	self.allDamageDefinitionCodes.clear();
	_proxy.allDamageDefinitionCodes.copy(self.allDamageDefinitionCodes);
	
	// CCMS SFW1066  - Recording Damage Details Changes. cnwsh3. 27/7/2009
	self.allDamagePositions.clear();
	_proxy.allDamagePositions.copy(self.allDamagePositions);
	
	//+cnwml2 PAR23715 SFW CCMS 1131
	self.allSealTypes.clear();
	_proxy.allSealTypes.copy(self.allSealTypes);
	
	self.useTareCargoWeight := _proxy.useTareCargoWeight;					//+cnwml2 MSL CCMS 1017
	
	self.autoTareCargoWeightCalc := _proxy.autoTareCargoWeightCalc;					//navra1 - TFS 63624 - 15th Apr 2024
	
	inheritMethod(_proxy);

	// Should be afted inherited method. ccms 1080 May 2009 cnwvu1
	self.isSubCargoTypeRequired	:= _proxy.isSubCargoTypeRequired;	 //mapping method uses self.isSystemCargoBOLType that is setup in inheritedMethod()
	self.trackByMeasureType		:= _proxy.trackByMeasureType;					        //PAR #33606
	if self.isBulk then                                                                 //02.04.2020 cnwma1 #49030
		self.myWeightMeasurementType	:= _proxy.myWeightMeasurementType;				//PAR #33606
		self.myVolumeMeasurementType	:= _proxy.myVolumeMeasurementType;				//PAR #33606
	else
		self.myWeightMeasurementType := null;
		self.myVolumeMeasurementType := null;
	endif;
	
	self.setForUpdateTEUSettings(_proxy.teuMultiplier, _proxy.teuConversion); // PAR 33532
	
	//02 Jun 2015	NDL	Par 36338
	if self.productType = ProductType_CargoGroup then
		self.setDefaultsForCargoGroup();
	endif;
	
	//29 Jan 2018	NDL	TFS 36697 - default behaviour is turn them all on, when it is changed.
	if doSetProdAutoWeightCalc then
		foreach product in self.allProducts do
			product.setAutoWeightCalculate( true );
		endforeach;
	endif;
	
	self.canGeneratePIN := _proxy.canGeneratePIN;				// TFS 41570
	
	//03 Apr 2019	NDL	TFS 44194
	if needsRefresh then
		if app.myAlternateDict &lt;&gt; null then
			app.myAlternateDict.setCargoTypeDictNeedsRefresh;
		endif;
	endif;
	
	//21 May 2021	NDL	TFS 51243 - get a collection of all of the current recipes
	create recipesToDelete transient;
	self.allRecipes.copy( recipesToDelete );
	
	//21 May 2021	NDL	TFS 51243 - update the ones that have proxies and remove thr reals from the to be deleted collection
	foreach pxyRecipe in _proxy.allRecipes do
		realRecipe := pxyRecipe.pxyGetRealObject();
		if realRecipe = null then
			create realRecipe persistent;
			realRecipe.setForCreate( pxyRecipe, self );
		else
			recipesToDelete.remove( realRecipe );
			realRecipe.setForUpdate( pxyRecipe, self );
		endif;	
	endforeach;
	
	recipesToDelete.purge();	//21 May 2021	NDL	TFS 51243 - the ones that are left should be deleted.
	
epilog
	delete recipesToDelete;	//21 May 2021	NDL	TFS 51243
end;</source>
        <Parameter name="_proxy" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateTEUSettings" id="6acb8bff-a66c-4746-8630-879718a1a58c">
        <updating/>
        <source>setForUpdateTEUSettings(_multi : Integer; _conversion : DecimalArray) updating;
/*
Purpose:			
Date		Who		Reason
05 March 2015	cnwab1	Initial creation
28 July 2022	navsrk20	ChangeRequest 53917: MTN - Cargo Types TEUs for GC
*/

vars

begin

	self.teuMultiplier := _multi;

	if _conversion = null or _conversion.isEmpty then
		//epr TFS 2290 7/7/16
		if self.isContainer() then
			self.teuConversion[TEUConversionIndex20] := 1;
			self.teuConversion[TEUConversionIndex30] := 2;
			self.teuConversion[TEUConversionIndex40] := 2;
			self.teuConversion[TEUConversionIndex45] := 2;
			self.teuConversion[TEUConversionIndex53] := 2;
		//Start 28.07.2022 navsrk20 TFS 53917
		elseif self.isBreakBulk then
			self.teuConversion[TEUConversionIndexGCBreakBulk] := 1;
		elseif self.isBulk then
			self.teuConversion[TEUConversionIndexGCBulk] := 1;
		//End 28.07.2022 navsrk20 TFS 53917
		else	
			self.teuConversion[TEUConversionIndexGC] := 1; // default
		endif;
	else
		self.teuConversion.clear();
		_conversion.copy(self.teuConversion);
		
	endif;
epilog

end;</source>
        <Parameter name="_multi" type="Integer"/>
        <Parameter name="_conversion" type="DecimalArray"/>
    </JadeMethod>
    <JadeMethod name="setIsCommodityRequired" id="dcf90d5f-3e67-4f50-9160-8f6681b4dcac">
        <updating/>
        <source>setIsCommodityRequired(_value : Boolean) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/10/2009	cnwdap1	PAR #20964 Initial creation
*/
vars

begin
	self.isCommodityRequired := _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsDynamicallyCreated" id="d590c53d-121d-47fe-b8a4-c90b30fdd88e">
        <updating/>
        <source>setIsDynamicallyCreated(_value : Boolean)updating;
/*
	Created on 12 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	isDynamicallyCreated := _value;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsSubCargoTypeRequired" id="61f08abf-e898-4617-ab54-81d2e7afb377">
        <updating/>
        <source>setIsSubCargoTypeRequired(_value : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2023	navsp1	Initial creation TFS Bug 58664: EUP - Cargo Type track as Cargo Group - should not support SubTypes

*/

vars

begin
	self.isSubCargoTypeRequired	:= _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyDrawingAttribute" id="811ec9ea-58d4-41e7-b903-c8ee686a0046">
