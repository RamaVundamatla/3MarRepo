    <JadeMethod name="getMyParentNamed" id="a63d2d34-2bf1-4f99-9344-95b305b5ae8b">
        <source>getMyParentNamed(_name: String): Form;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2021	navndl1	Initial creation	TFS 50837

*/

vars

	edition : Integer;
	invalid : Boolean;

begin

	if self.myParentForm &lt;&gt; null then
		
		on Exception do app.handleDeletedObject( exception, self.myParentForm, invalid );
		edition := self.myParentForm.edition;
		if invalid then
			return null;
		endif;
		
		if self.myParentForm.name = _name then
			return self.myParentForm;
			
		elseif self.myParentForm.isKindOf( CM_BaseForm ) then 
			return self.myParentForm.getMyParentNamed( _name );
			
		endif;
		
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="f486c8df-b294-4ac0-b04a-9a54a89d5bbf">
