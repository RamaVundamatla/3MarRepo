    <JadeMethod name="setMyTrackedItem" id="234f4126-e0df-4294-93b8-8b2af70f4f52">
        <updating/>
        <source>setMyTrackedItem(_ti: CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwrd1	Initial creation

*/

vars
begin
	
	self.myTrackedItem := _ti;
	
	self.createTiToDoTask(); // create the todo on the tracked item if we dont have one already

epilog

end;

</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
