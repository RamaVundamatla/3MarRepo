    <JadeMethod name="doRefresh" id="57a86f4e-2dc6-4551-8dd8-76c52f1e36e9">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 April 2004	cnwth2
//
// Purpose:     re-populates all comboboxes - should also re-select any items to their original value etc.
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpProduct			: CM_Product;
	tmpCargoType		: CM_CargoType;
	tmpTransMode,
	tmpProcessOpt,
	tmpStatus			: Integer;
	lineDescr,
	tmpId				: String;
	cmb					: CMUI_ComboBox;
	ls					: Boolean;
begin
	app.mousePointer := Busy;
	app.cmsBeginLoad(ls);
	inheritMethod();
	
//	self.myAssistant.comboBoxOperator(self.cmbFiltOp, self.cmbFiltOp.listObject.CM_Operator, null);
	self.cmbFiltOp.setObject(self.cmbFiltOp.listObject);
	
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage, self.cmbVoyage.listObject.CM_Voyage,
											true,
											false,
											false,
											false,
											true,
											false,
											true,
											false,
											false);
	
	
		// lorcan - replacing port combobox - 11/4/2006
	self.cmbDisPort.myTerminal := self.myTerminal;// so text for port is displayed in correct order from config
	self.cmbDisPort.myAssistant := self.myAssistant;
	self.cmbDisPort.showAllDestinations := true;
//	self.myAssistant.comboBoxDischarge(self.cmbDisPort, self.cmbVoyage.listObject.CM_Voyage, self.cmbDisPort.listObject.CM_Port);
	
	self.cmbOperator.setObject(self.cmbOperator.myObject);
//	self.myAssistant.comboBoxOperator(self.cmbOperator, self.cmbOperator.listObject.CM_Operator, null);
	// HJG 14/12/04 CCMS1235 combox type changed 
	//self.myAssistant.comboBoxConsignor(self.cmbConsignee, self.cmbConsignee.listObject.CM_ConsigneeConsignor);
	//self.myAssistant.comboBoxConsignor(self.cmbConsignor, self.cmbConsignor.listObject.CM_ConsigneeConsignor);
	self.cmbConsignee.setObject(self.cmbConsignee.myObject.CM_ConsigneeConsignor);
	self.cmbConsignor.setObject(self.cmbConsignor.myObject.CM_ConsigneeConsignor);
	cmb := self.cmbTransportMode;
	if cmb.listIndex &gt; 0 then
		tmpTransMode := cmb.itemData[cmb.listIndex];
	endif;
	self.myAssistant.comboBoxTransportModes(cmb, tmpTransMode);
	
	cmb := self.cmbFiltStatus;
	if cmb.listIndex &gt; 0 then
		tmpStatus := cmb.itemData[cmb.listIndex];
	endif;
	self.myAssistant.comboBoxStkOrdFulfilledStatus(cmb, tmpStatus);
	
	cmb := self.cmbFiltProcess;
	if cmb.listIndex &gt; 0 then
		tmpProcessOpt := cmb.itemData[cmb.listIndex];
	endif;	
	self.myAssistant.comboBoxProcessOption(cmb, tmpProcessOpt);
	
	//combos on the detail entry frame
	self.myAssistant.comboBoxOperator(self.cmbOpDetail, self.cmbOpDetail.listObject.CM_Operator, null);
	
	cmb := self.cmbProcessOpt; 
	if cmb.listIndex &gt; 0 then
		tmpProcessOpt := cmb.itemData[cmb.listIndex];
	endif;	
	self.myAssistant.comboBoxProcessOption(cmb, tmpProcessOpt);
	
epilog
	endLoad;
	app.mousePointer := Idle;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveDetailLine" id="2a094ac6-a2d6-4781-a5e5-53cd3082a611">
        <updating/>
        <source>doRemoveDetailLine() updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	orderLine	: CM_StockOrderLine;
	row,
	numRows		: Integer;
	tbl			: CM_DataTable;
	objSet		: CM_ObjectSet;
	obj			: Object;
begin

	
	tbl := self.tblDataDetail;
	row := self.tblDataDetail.row;
	numRows := tbl.rows;

	if tbl.fixedRows &gt;= numRows  then 
		return;
	endif;

	if tbl.accessRow(row).itemObject = null then 
		tbl.removeItem(row);
	else
		obj	:= tbl.accessRow(row).itemObject ;
		tbl.removeItem(row);
	endif;

/*
	create objSet transient;
	tbl := self.tblDataDetail;
	numRows := tbl.rows;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		if (not tbl.accessRow(row).selected) then
			continue;
		endif;
		
		obj := tbl.accessedRow.itemObject;
		if not CM_StockOrderLine.hasInstance(obj) then
			continue;
		endif;
		
		objSet.add(obj);
	endforeach;

	foreach obj in objSet do
		self.tblDataDetail.removeItemObject(obj);
		self.allDetailObjects.remove(obj);
	endforeach;
	
epilog
	delete objSet;*/
end;</source>
    </JadeMethod>
