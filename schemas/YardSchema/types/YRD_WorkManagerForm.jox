vars

begin
	self.tblSchedule.top := self.frmToolbar.top + self.frmToolbar.height + 1;
	self.tblSchedule.height := self.tblSummary.top - self.tblSchedule.top - 1;

	inheritMethod();

	
	self.fldSearch.top := self.frmQueryToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1
epilog

