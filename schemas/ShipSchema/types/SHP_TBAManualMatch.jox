    <JadeMethod name="translateForm" id="e142450e-5ad3-41b3-b207-ed88f2d08fc5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 November 2019 08:32:57.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023775, locale);
	btnCancel.translateCaption(Xlat_0023776, locale);
	btnMatch.translateBubbleHelp(Xlat_0023777, locale);
	btnMatch.translateCaption(Xlat_0023778, locale);
	btnSelectAll.translateBubbleHelp(Xlat_0023779, locale);
	btnSelectAll.translateCaption(Xlat_0023780, locale);
	chkBooking.translateCaption(Xlat_0023781, locale);
	chkCommodity.translateCaption(Xlat_0023782, locale);
	chkHazardDetails.translateCaption(Xlat_0023783, locale);
	chkISOType.translateCaption(Xlat_0023784, locale);
	chkOperator.translateCaption(Xlat_0023785, locale);
	chkOverDimension.translateCaption(Xlat_0023786, locale);
	chkReeferDetails.translateCaption(Xlat_0023787, locale);
	chkTotalWeight.translateCaption(Xlat_0023788, locale);
	lblBooking.translateCaption(Xlat_0023789, locale);
	lblCommodity.translateCaption(Xlat_0023790, locale);
	lblDescription1.translateCaption(Xlat_0023791, locale);
	lblDescription2.translateCaption(Xlat_0023792, locale);
	lblHazardDetails.translateCaption(Xlat_0023793, locale);
	lblISOType.translateCaption(Xlat_0023794, locale);
	lblOperator.translateCaption(Xlat_0023795, locale);
	lblOverDimension.translateCaption(Xlat_0023796, locale);
	lblReeferDetails.translateCaption(Xlat_0023797, locale);
	lblTBAId.translateCaption(Xlat_0023798, locale);
	lblTotalWeight.translateCaption(Xlat_0023799, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0023800, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0023801, locale);
	mnuContext.translateCaption(Xlat_0023802, locale);
	mnuInspect.translateCaption(Xlat_0023803, locale);
end;</source>
