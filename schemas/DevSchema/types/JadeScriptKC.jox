<Class name="JadeScriptKC" id="cb762dde-6df5-4bb8-a4a3-e081be3a15a3">
    <superclass name="JadeScript"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="getAllReportViews" id="5a972671-22ec-440f-b565-e0b300976802">
        <source>getAllReportViews();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2023	navkc1	Initial creation

*/

vars
	rwSchema			: Schema;
	jrwClass			: Class;
	jrwTypeDefClass		: Class;
	jrwFieldDefClass	: Class;
	jrwFeatureDefClass	: Class;
	
	allViews,
	allTypes,
	allFeatures			: MemberKeyDictionary;
	
	root				: Object;
	view				: Object;
	typeDef				: Object;
	fieldDef			: Object;
	featureDef			: Object;
	
	found				: Boolean;
	
	class				: String;
	attr				: String;
	
begin
	
	rwSchema 				:= rootSchema.getSchema("JadeReportWriterSchema");
	root					:= rwSchema.getClass("JRDRoot").firstInstance();
	
	if root = null then
		return;
	endif;
	
	class 	:= "CM_InvoiceContract";
	attr 	:= "contractId";
	
	jrwClass				:= rwSchema.getClass("JRDReportingView");
	jrwTypeDefClass			:= rwSchema.getClass("JRDReportingTypeDefn");
	jrwFieldDefClass 		:= rwSchema.getClass("JRDReportingFieldDefn");
	jrwFeatureDefClass		:= rwSchema.getClass("JRDReportingFeatureDefn");
	
	allViews := root.getPropertyValue("allReportingViews").MemberKeyDictionary;
	
	foreach view in allViews discreteLock do : viewloop
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		foreach typeDef in allTypes discreteLock do : typeloop
			if typeDef.getPropertyValue("typeName").String &lt;&gt; class then
				continue;
			endif;
			allFeatures := typeDef.getPropertyValue("allReportingFields").MemberKeyDictionary;
			
			found := false;
			foreach featureDef in allFeatures discreteLock do : featureLoop
				if not featureDef.isKindOf(jrwFeatureDefClass) then
					continue;
				endif;
				if featureDef.getPropertyValue("featureName").String = attr then
					found := true;
					write "Found";
					write Tab &amp; view.getPropertyValue("name").String;
					write Tab &amp; typeDef.getPropertyValue("typeName").String;
					write Tab &amp; featureDef.getPropertyValue("featureName").String;
					
					break typeloop;
				endif;
			endforeach;
			
			if not found then
				// Add
			endif;
			
		endforeach;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getTermConfig" id="115daa8e-3eba-490e-9419-a9bd3ec06bdc">
        <source>getTermConfig();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2022	navkc1	Initial creation

*/

vars
	nvPair			: CM_NameValuePair;
	terminal		: CM_Terminal;
	del,
	cre				: Boolean;
begin
	terminal := "2351.1570".asOid().CM_Terminal;
	
	
	//del := true;
	cre := true;
	
	beginTransaction;
		//delete "".asOid();
		//terminal.allOnePortStatuses.rebuild();
		
		if del then
			terminal.allOnePortStatuses.purge();
		endif;
		
		if cre then
			create nvPair persistent;
			nvPair.createNewPair("Booked", MovementStatus_Planned.String &amp; "|1");
			terminal.addOnePortStatus(nvPair);
			
			create nvPair persistent;
			nvPair.createNewPair("Cancelled", MovementStatus_Cancelled.String &amp; "|1");
			terminal.addOnePortStatus(nvPair);
			
			create nvPair persistent;
			nvPair.createNewPair("Completed", MovementStatus_Actual.String &amp; "|1");
			terminal.addOnePortStatus(nvPair);
			
			create nvPair persistent;
			nvPair.createNewPair("Confirmed", MovementStatus_Actual.String &amp; "|1");
			terminal.addOnePortStatus(nvPair);
		endif;
		
	commitTransaction;
	
	terminal.inspect();
	
	//write terminal.getConfig(CashRoadExitChkServices);
	//write terminal.isUsingDefaultProcessJMT();
	//process.debug();
	
epilog

end;</source>
    </JadeMethod>
</Class>
