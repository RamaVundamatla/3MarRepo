    <JadeMethod name="doUpdateFromLoadList" id="d649201e-e1e2-4f62-9d5e-46ef3324d42c">
        <updating/>
        <source>doUpdateFromLoadList() updating;
//----------------------------------------------------------------
//	Created:	Jan 2006 cnwrs1
//
//----------------------------------------------------------------
/*
Date		Who		Reason
23 Nov 2011	cnwkpd1	PAR #28731 - fix transient leaks
20 Jun 2012	cnwrs1	Par 31625 DPH Load list changes
02 May 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
07 Sep 2017	jlgdap1	TFS 6876 SNO Cargo Comparison Issues
22/03/2018 	JLGNS1	Bug 37745: SPT - Seal Numbers not loading as Vent Seals from Load List
06 July 2018 jlgrh7 TFS #38887	SNO - Re: 38076 Cargo Comparison and seal issue
3/09/2018 	JLGNS1	Bug 40108: SNO - Re: Cargo comparison of TS not in terminal yet
*/
vars
	updateFields : StringArray;
	tiUpdate 		: ObjectArray;
	tiSet 			: CM_TISet;
	obj 			: Object;
	ediTI 			: CM_EDITrackedItem;
	llcTi 			: CM_EDILoadListComparisonTI;	
	ediLLTI			: CM_EDILoadListTI;
	ediLLTIUser		: CM_EDICargoTI;
	pxyTI 			: CM_TrackedItem;
	subTerminalObj	: CM_SubTerminal;
	passport 		: CM_Passport;
	tbl 			: CM_DataTable;
	numRows,
	row,
	result 			: Integer;
	updateSelected,
	updBol,
	updBookingRef,
	updCA,
	updCargoType,
	updCommodity,
	updConsignee,
	updConsignor,
	updDestPort,
	updDischPort,
	updFreightForwarder,
	updHumidity,
	updISOCode,
	updOperator,
	updSealCustoms,
	updSealNum,
	updSealNumberVent,
	updSealShipper,
	updSealTerminalOperator,
	updSealUnknown,
	updTemp,
	updTranship, 				//cnwrs1 CCMS 1137 15 June 2010
	updTranshipBOLId,			//cnwrs1 CCMS 1137 08 June 2010
	updTranshipBookingRef,		//cnwrs1 CCMS 1137 08 June 2010
	updTranshipDischPort,		//cnwrs1 CCMS 1137 08 June 2010
	updTranshipPortsList,		//cnwrs1 CCMS 1137 08 June 2010
	updTranshipVoyageCode,		//cnwrs1 CCMS 1137 08 June 2010
	updVent,
	updVoyageCode,			//26 Apr 2010	NDL	Par 23912
	updWaterCooled,
	updWeight,
	updIsWeightCertified,		// TFS #1699
	updWeightCertName,			// TFS #1699
	updWeightCertRef,			// TFS #1699
	viewingOnboardImportVoyage 	: Boolean;
	rtnValue 					: Boolean;
	isSubTermOn					: Boolean;
	str 						: String;
	controller 					: CMIF_TranshipTIController;
	transhipSelected 			: Boolean;
	portCode 					: String; //cnwrs1 CCMS 1137 06 July 2010
	port 						: CM_Port;
	realTI 						: CM_TrackedItem;
	updSpecialStow : Boolean;
	certName, certRef			: String;					// TFS 6876
begin
	app.mousePointer := Busy;	//cnwrs1 CCMS 1137 01 July 2010
	passport	:=	app.myPassport;
	isSubTermOn	:=	app.isSubTerminalsOn(self.myTerminal);
	
	create tiUpdate transient;
	tbl := self.tblData;
	numRows := tbl.rows;
	
	//get a list of CM_EDILoadListComparisonTI to be updated
	// the llc or the DB or both lines for the same ti maybe selected
	foreach row in tbl.fixedRows + 1 to numRows do
		if (not tbl.accessRow(row).selected) then
			continue;
		endif;
		
		obj := tbl.accessRow(row).itemObject;
		if not obj.isKindOf(CM_EDILoadListComparisonTI) then
			foreach ediTI in myLLCAgent.allDiscrepancyTIs do
				if CM_EDITrackedItem.hasInstance(obj)
				and ediTI.id = obj.CM_EDITrackedItem.id
				then
					obj := ediTI;
					break;
				endif;
			endforeach;
		endif;
		if not tiUpdate.includes(obj) then
			tiUpdate.add(obj);
		endif;
	endforeach;
	
	if tiUpdate.size &lt; 1 then
		// no tis selected for update
		app.msgBox(app.getErrorString1(NothingSelected, app.getErrorString(TrackedItems)) ,self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	create updateFields transient;
	self.getTranshipFields(updateFields);
	foreach str in updateFields do
		if str = ETRow_TranshipVoyage then	// 26 Apr 2010	NDL Par 23912
			updTranshipVoyageCode := true;
			transhipSelected := true;
		endif;
		if str = ETRow_TranshipDischargePort then	// 26 Apr 2010	NDL Par 23912
			updTranshipDischPort := true;
			transhipSelected := true;
		endif;
		if str = ETRow_TranshipBookingRef then	// 26 Apr 2010	NDL Par 23912
			updTranshipBookingRef := true;
			transhipSelected := true;
		endif;
		if str = ETRow_TranshipBOLId then		//cnwrs1 CCMS 1137 28 June 2010
			updTranshipBOLId := true;
			transhipSelected := true;
		endif;
		if str = ETRow_TranshipToPort then		//cnwrs1 CCMS 1137 28 June 2010
			updTranshipPortsList := true;
			transhipSelected := true;
		endif;
	endforeach;
	updateFields.clear;
	self.getUpdateFields(updateFields);
	foreach str in updateFields do
		// select the update options
		if str = ETRow_Bol then
			updBol := true;
			updateSelected := true;
		endif;
		if str = ETRow_BookingRef then
			updBookingRef := true;
			updateSelected := true;
		endif;
		if str = ETRow_CargoType then		// 10/02/2009 cnwar2 CCMS1797 (PAR18881)
			updCargoType := true;
			updateSelected := true;
		endif;
		if str = ETRow_Commodity then
			updCommodity := true;
			updateSelected := true;
		endif;
		if str = ETRow_Consignee then		//ccms 1915 - PAR 22271
			updConsignee := true;
			updateSelected := true;
		endif;
		if str = ETRow_Consignor then
			updConsignor := true;
			updateSelected := true;
		endif;
		if str = ETRow_ControlledAtmosphere then
			updCA := true;
			updateSelected := true;
		endif;
		if str = ETRow_SealCustoms then
			updSealCustoms := true;
			updateSelected := true;
		endif;
		if str = ETRow_DestinationPort then
			updDestPort := true;
			updateSelected := true;
		endif;
		if str = ETRow_DischargePort then
			updDischPort := true;
			updateSelected := true;
		endif;
		if str = ETRow_FreightForwarder then
			updFreightForwarder := true;
			updateSelected := true;
		endif;
		if str = ETRow_Humidity then		//JMT1550 - Adding Humidity
			updHumidity := true;
			updateSelected := true;
		endif;
		if str = ETRow_IsoType then
			updISOCode := true;
			updateSelected := true;
		endif;
		if str = ETRow_OperatorCode then
			updOperator := true;
			updateSelected := true;
		endif;
		if str = ETRow_SealNum then
			updSealNum := true;
			updateSelected := true;
		endif;
		if str = ETRow_SealShipper then
			updSealShipper := true;
			updateSelected := true;
		endif;
		//if str = ETRow_SealTerminalOperator then																					//- TFS 38887 
		if str = ETRow_SealNumTerminalOperator then																				//+TFS 38887
			updSealTerminalOperator := true;
			updateSelected := true;
		endif;
		if str = ETRow_SealNumUnknown then		//Bug 37745
			updSealUnknown := true;
			updateSelected := true;
		endif;
		if str = ETRow_Temperature then
			updTemp := true;
			updateSelected := true;
		endif;
		if str = ETRow_TotalWeight then
			updWeight := true;
			updateSelected := true;
		endif;
		if str = ETRow_SealNumberVent then
			updSealNumberVent := true;
			updateSelected := true;
		endif;
		if str = ETRow_Vent then
			updVent := true;
			updateSelected := true;
		endif;
		if str = ETRow_SpecialStow then
			updSpecialStow := true;
			updateSelected := true;
		endif;
		if str = ETRow_VoyageCode then	// 26 Apr 2010	NDL Par 23912				// 24/08/2011 cnwmh5 #27963
			updVoyageCode := true;
			updateSelected := true;
		endif;
		if str = ETRow_IsWaterCooled then
			updWaterCooled := true;
			updateSelected := true;
		endif;
		if str = ETRow_IsWeightCertified then						// TFS #1699
			updIsWeightCertified := true;							// TFS #1699
			updateSelected := true;									// TFS #1699
		endif;														// TFS #1699
		if str = ETRow_WeightCertifiedName then						// TFS #1699
			updWeightCertName := true;								// TFS #1699
			updateSelected := true;									// TFS #1699
		endif;														// TFS #1699
		if str = ETRow_WeightCertifiedReference then				// TFS #1699
			updWeightCertRef := true;								// TFS #1699
			updateSelected := true;									// TFS #1699
		endif;														// TFS #1699		
	//cnwrs1 CCMS 1137 08 June 2010
//		if str = ETRow_Tranship then	// 26 Apr 2010	NDL Par 23912
//			updTranship := true;
//			updateSelected := true;
//		endif;
	endforeach;
	
	if not updateSelected and
	   not transhipSelected then	//cnwrs1 CCMS 1137 15 June 2010then
		// no update action selected
		app.msgBox(app.getErrorString1(NothingSelected, app.getErrorString(UpdateSettings)) ,self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if self.chkTranshipAdd.value then
		updTranship := true;	
	endif;
	// update the selected tis with the selected fields
	create tiSet transient;
	foreach obj in tiUpdate do
		if (not CM_EDILoadListComparisonTI.hasInstance(obj)) then
			continue;
		endif;
		
		llcTi := obj.CM_EDILoadListComparisonTI;
		pxyTI := app.createUpdateProxy(llcTi.myTrackedItem).CM_TrackedItem;
		tiSet.add(pxyTI);
		
		if CM_EDILoadListTI.hasInstance(llcTi.myDiscrepancyEDITI) then
			ediLLTI := llcTi.myDiscrepancyEDITI.CM_EDILoadListTI;
			
			if updBol then
				pxyTI.setPxyFromNamedFields(ediLLTI.bol, CM_TrackedItem::billOfLading.name);
			endif;
			if updBookingRef then
				pxyTI.setPxyFromNamedFields(ediLLTI.bookingRef, CM_TrackedItem::bookingReference.name); //ccms1137 13 July 2010 cnwrs1
			endif;
			if updCargoType then	// 10/02/2009 cnwar2 CCMS1797 (PAR18881)
				pxyTI.setPxyFromNamedFields(ediLLTI.cargoType, CM_TrackedItem::cargoType.name);
			endif;
			if updCA then 
				pxyTI.setPxyFromNamedFields(ediLLTI.carbonDioxide, CM_Container::getCarbonDioxide.name);
				pxyTI.setPxyFromNamedFields(ediLLTI.oxygen, CM_Container::getOxygen.name);
				pxyTI.setPxyFromNamedFields(ediLLTI.curtainsIn, CM_Container::getCurtainsIn.name);
			endif;
			if updCommodity then
				pxyTI.setPxyFromNamedFields(ediLLTI.commodity[1:4], CM_TrackedItem::commodity.name);
			endif;
			if updConsignee then								//ccms 1915
				//pxyTI.setPxyFromNamedFields(ediLLTI.consignee, CM_TrackedItem::consignee.name);
				pxyTI.setPxyFromNamedFields(ediLLTI.consignee[1:5], CM_TrackedItem::consignee.name);//28 Jan 2011	NDL	26318
			endif;
			if updConsignor then
				pxyTI.setPxyFromNamedFields(ediLLTI.consignor[1:5], CM_TrackedItem::consignor.name);
			endif;
			if updSpecialStow then
				pxyTI.setPxyFromNamedFields(ediLLTI.specialStowage[1:5], CM_TrackedItem::specialStow.name);
			endif;
			// PAR 12246 Change destination
			if updDestPort then
				//pxyTI.setPxyFromNamedFields(ediLLTI.destinationPort, CM_TrackedItem::destinationPort.name);
				pxyTI.setPxyFromNamedFields(ediLLTI.destinationPort[1:5], CM_TrackedItem::destinationPort.name);//28 Jan 2011	NDL	26318
			endif;
			if updDischPort then
				realTI := pxyTI.pxyGetRealObject();
				if realTI.isTranshipItem then
					if self.comparisonMode = LOAD_COMPARISON
					and realTI.isTranshipInbound()	//31 Dec 2018	NDL	TFS 42333
					then //PAR25362 cnwsh3 15/09/2010
						//If the real TI is onboard the import voyage and the form is viewing the load list 
						//(ie. not the discharge list) side, we want to update the CM_TrackedItem.myTranshipDetail instead
						//of the CM_TrackedItems.dischargePort. The update to the tranship detail occurs later on in this method 
						//using tranship update so set these to true and make sure we use the correct port code. This is discharge 
						//port on the load list TI NOT the tranship discharge port on the Load List TI. 
						updTranshipDischPort := true;
						transhipSelected := true;
						viewingOnboardImportVoyage := true;
						updTranship := true;
					else
						//pxyTI.setPxyFromNamedFields(ediLLTI.dischargePort, CM_TrackedItem::dischargePort.name);
						pxyTI.setPxyFromNamedFields(ediLLTI.dischargePort[1:5], CM_TrackedItem::dischargePort.name);//28 Jan 2011	NDL	26318
					endif;
				else
					//pxyTI.setPxyFromNamedFields(ediLLTI.dischargePort, CM_TrackedItem::dischargePort.name);
					pxyTI.setPxyFromNamedFields(ediLLTI.dischargePort[1:5], CM_TrackedItem::dischargePort.name);//28 Jan 2011	NDL	26318
				endif;				
			endif;
			if updFreightForwarder then
				pxyTI.setPxyFromNamedFields(ediLLTI.freightForwarder[1:5], CM_TrackedItem::freightForwarderCode.name);
			endif;
			if updHumidity then//JMT1550 - Adding Humidity
				pxyTI.setPxyFromNamedFields(ediLLTI.humidity, CM_Container::getHumidity.name);
			endif;
			if updISOCode then
				pxyTI.setPxyFromNamedFields(ediLLTI.isoType, CM_Container::isoType.name);
			endif;
			if updOperator then
				//pxyTI.setPxyFromNamedFields(ediLLTI.operatorCode, CM_TrackedItem::operatorCode.name);
				pxyTI.setPxyFromNamedFields(ediLLTI.operatorCode[1:4], CM_TrackedItem::operatorCode.name);//28 Jan 2011	NDL	26318
			endif;
			if updSealNum then  //ccms1690 cnwrs1 mar 2008
				//pxyTI.setPxyFromNamedFields(ediLLTI.sealNum, CM_Container::sealNum.name);
				pxyTI.setPxyFromNamedFields(ediLLTI.sealNum, SealNum);	//17 Sep 2010	NDL	Par 25608
			endif;
			if updSealCustoms then
				pxyTI.setPxyFromNamedFields(ediLLTI.sealCustoms, SealNumCustoms);
			endif;
			if updSealNumberVent then
				pxyTI.setPxyFromNamedFields(ediLLTI.sealNumberVent, SealNumVent);
			endif;
			if updSealShipper then
				pxyTI.setPxyFromNamedFields(ediLLTI.sealShipper, SealNumShippers);
			endif;
			if updSealTerminalOperator then
				pxyTI.setPxyFromNamedFields(ediLLTI.sealTerminalOperator, SealNumTerminalOperator);
			endif;
			if updSealUnknown then
				pxyTI.setPxyFromNamedFields(ediLLTI.sealUnknown, SealNumUnknown);
			endif;
			if updTemp then
				pxyTI.setPxyFromNamedFields(ediLLTI.temperature, CM_Container::getTemperature.name);
			endif;
			if updVent then
				pxyTI.setPxyFromNamedFields(ediLLTI.vent, CM_Container::getVentilation.name);
			endif;
			if updVoyageCode then	// 26 Apr 2010	NDL Par 23912
				//if its a tranship and still on the import voyage then only update the Export voyage								// 40108
				realTI := pxyTI.pxyGetRealObject();																					// 40108
				if realTI.isTranshipItem and self.comparisonMode = LOAD_COMPARISON and realTI.myVoyage = realTI.myImportVoyage then // 40108
					pxyTI.setTranshipExportVoyage( ediLLTI.myEDIData.getVoyageCode ,passport );										// 40108
				else																												// 40108
					pxyTI.setPxyFromNamedFields(ediLLTI.getDisplayStringForAttribute(ETRow_VoyageCode, false), CM_TrackedItem::voyageCode.name);
				endif;																												// 40108
			endif;
			if updWaterCooled then
				pxyTI.setPxyFromNamedFields(ediLLTI.cooledType, CM_Container::getCoolingType.name);
			endif;
			if updWeight then
				pxyTI.setPxyFromNamedFields(ediLLTI.weight, CM_TrackedItem::totalWeight.name);
			endif;
			if updIsWeightCertified then																						// TFS #1699
				pxyTI.setPxyFromNamedFields(ediLLTI.isWeightCertified, CM_TrackedItem::isWeightCertified.name);					// TFS #1699
			endif;																												// TFS #1699
			//if updWeightCertName then																							// TFS #1699
			//	pxyTI.setPxyFromNamedFields(ediLLTI.weightCertifiedName, CM_TrackedItem::weightCertifiedName.name);				// TFS #1699
			//endif;																												// TFS #1699
			//if updWeightCertRef then																							// TFS #1699
			//	pxyTI.setPxyFromNamedFields(ediLLTI.weightCertifiedReference, CM_TrackedItem::weightCertifiedReference.name);	// TFS #1699
			//endif;																												// TFS #1699
			// TFS 6876 Correct the handling of weight certified name and reference - these are now mapped on CM_TrackedItem
			if updWeightCertName or updWeightCertRef then
				certName := null;
				certRef := null;
				if updWeightCertName then
					certName := ediLLTI.weightCertifiedName;
				else
					certName := llcTi.myTrackedItem.weightCertifiedName;
				endif;
				if updWeightCertRef then
					certRef := ediLLTI.weightCertifiedReference;
				else
					certRef := llcTi.myTrackedItem.weightCertifiedReference;
				endif;
				pxyTI.setMyVGMDetails(certRef, certName, llcTi.vgmAuthSignature, llcTi.vgmCommsType, llcTi.vgmDocumentDetails,
										llcTi.vgmEDITransmission, llcTi.vgmElectronicMail, llcTi.vgmMail, llcTi.vgmPhone,
										llcTi.vgmTelefax, llcTi.vgmTelephone, llcTi.vgmDocsIssuedDT, llcTi.vgmDeterminationDT, null);
			endif;
			// TFS 6876 end
			//cnwrs1 CCMS 1137 08 June 2010
		elseif CM_EDICargoTI.hasInstance(llcTi.myDiscrepancyEDITI) then
			ediLLTIUser := llcTi.myDiscrepancyEDITI.CM_EDICargoTI;
			if updBol then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.bol, CM_TrackedItem::billOfLading.name);
			endif;
			if updBookingRef then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.bookingRef, CM_TrackedItem::bookingReference.name);
			endif;
			if updCargoType then	// 10/02/2009 cnwar2 CCMS1797 (PAR18881)
				pxyTI.setPxyFromNamedFields(ediLLTIUser.cargoType, CM_TrackedItem::cargoType.name);
			endif;
			if updCA then 
				pxyTI.setPxyFromNamedFields(ediLLTIUser.carbonDioxide, CM_Container::getCarbonDioxide.name);
				pxyTI.setPxyFromNamedFields(ediLLTIUser.oxygen, CM_Container::getOxygen.name);
//				pxyTI.setPxyFromNamedFields(ediLLTIUser.curtainsIn, CM_Container::getCurtainsIn.name);
			endif;
			if updCommodity then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.commodity[1:4], CM_TrackedItem::commodity.name);//28 Jan 2011	NDL	26318
			endif;
			if updConsignee then								//ccms 1915
				pxyTI.setPxyFromNamedFields(ediLLTIUser.consignee[1:5], CM_TrackedItem::consignee.name);//28 Jan 2011	NDL	26318
			endif;
			if updConsignor then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.consignor[1:5], CM_TrackedItem::consignor.name);
			endif;
			// PAR 12246 Change destination
			if updDestPort then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.destinationPort, CM_TrackedItem::destinationPort.name);	//28 Jan 2011	NDL	26318
			endif;
			if updDischPort then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.dischargePort[1:5], CM_TrackedItem::dischargePort.name);	//28 Jan 2011	NDL	26318
			endif;
			if updFreightForwarder then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.freightForwarder[1:5], CM_TrackedItem::freightForwarderCode.name);
			endif;
			if updHumidity then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.humidity, CM_Container::getHumidity.name);
			endif;
			if updISOCode then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.isoType, CM_Container::isoType.name);
			endif;
			if updOperator then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.operatorCode[1:4], CM_TrackedItem::operatorCode.name);	//28 Jan 2011	NDL	26318
			endif;
			if updSealNum then //ccms1690 cnwrs1 mar 2008
				pxyTI.setPxyFromNamedFields(ediLLTIUser.sealNum, SealNum);	//17 Sep 2010	NDL	Par 25608
			endif;
			if updSealCustoms then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.sealCustoms, SealNumCustoms);
			endif;
			if updSealNumberVent then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.sealNumberVent, SealNumVent);
			endif;
			if updSealShipper then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.sealShipper, SealNumShippers);
			endif;
			if updSealTerminalOperator then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.sealTerminalOperator, SealNumTerminalOperator);
			endif;
			if updSealUnknown then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.sealUnknown, SealNumUnknown);
			endif;
			if updTemp then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.temperature, CM_Container::getTemperature.name);
			endif;
			if updVent then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.vent, CM_Container::getVentilation.name);
			endif;
			if updVoyageCode then	// 26 Apr 2010	NDL Par 23912
				pxyTI.setPxyFromNamedFields(ediLLTIUser.getVoyageCode(), CM_TrackedItem::voyageCode.name);
			endif;
			if updWaterCooled then
//				pxyTI.setPxyFromNamedFields(ediLLTIUser.cooledType, CM_Container::getCoolingType.name);
			endif;
			if updWeight then
				pxyTI.setPxyFromNamedFields(ediLLTIUser.weight, CM_TrackedItem::totalWeight.name);
			endif;
			if updIsWeightCertified then																						// TFS #1699
				pxyTI.setPxyFromNamedFields(ediLLTIUser.isWeightCertified, CM_TrackedItem::isWeightCertified.name);				// TFS #1699
			endif;																												// TFS #1699
			//if updWeightCertName then																							// TFS #1699
			//	pxyTI.setPxyFromNamedFields(ediLLTI.weightCertifiedName, CM_TrackedItem::weightCertifiedName.name);				// TFS #1699
			//endif;																											// TFS #1699
			//if updWeightCertRef then																							// TFS #1699
			//	pxyTI.setPxyFromNamedFields(ediLLTI.weightCertifiedReference, CM_TrackedItem::weightCertifiedReference.name);	// TFS #1699
			//endif;																											// TFS #1699
			// TFS 6876 Correct the handling of weight certified name and reference - these are now mapped on CM_TrackedItem
			if updWeightCertName or updWeightCertRef then
				certName := null;
				certRef := null;
				if updWeightCertName then
					certName := ediLLTIUser.weightCertifiedName;
				else
					certName := llcTi.myTrackedItem.weightCertifiedName;
				endif;
				if updWeightCertRef then
					certRef := ediLLTIUser.weightCertifiedReference;
				else
					certRef := llcTi.myTrackedItem.weightCertifiedReference;
				endif;
				pxyTI.setMyVGMDetails(certRef, certName, llcTi.vgmAuthSignature, llcTi.vgmCommsType, llcTi.vgmDocumentDetails,
										llcTi.vgmEDITransmission, llcTi.vgmElectronicMail, llcTi.vgmMail, llcTi.vgmPhone,
										llcTi.vgmTelefax, llcTi.vgmTelephone, llcTi.vgmDocsIssuedDT, llcTi.vgmDeterminationDT, null);
			endif;
			// TFS 6876 end
		endif;
		
// cnwdad1 07/08/2009 - PAR #20432.
		if isSubTermOn then
			if llcTi.myDiscrepancyEDITI.subTerminalCode &lt;&gt; null then
				subTerminalObj	:=	pxyTI.myTerminal.allSubTerminals[llcTi.myDiscrepancyEDITI.subTerminalCode];
				
				if subTerminalObj &lt;&gt; null then
					pxyTI.setSubTerminal(subTerminalObj,null);
				endif;
			endif;
			
			if pxyTI.mySubTerminal = null then
				pxyTI.setSubTerminalDefaultFromTerm(pxyTI.myTerminal);
			endif;
		endif;
	endforeach;

	while true do
		// Par 15187 Break transaction up into batches to reduce contention.
		//app.myTrxUA.trxUpdateTrackedItems(tiSet, TI_UPDMODE_NORMAL, null, passport);
		app.myTrxUA.trxUpdateTrackedItemsBatch(tiSet, TI_UPDMODE_NORMAL, null, passport);
		
		if app.myPassport.trxCompletedOK() then
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Update From Cargo List', passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors() and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		rtnValue := false;
		break;
	endwhile;

	if tiSet &lt;&gt; null then //cnwrs1 CCMS 1137 15 June 2010
		tiSet.purge();
//		delete tiSet;
	endif;

	//now we do the tranships cnwrs1 CCMS 1137 15 June 2010
	if updTranship then 
		foreach obj in tiUpdate do
			if (not CM_EDILoadListComparisonTI.hasInstance(obj)) then
				continue;
			endif;
			
			llcTi := obj.CM_EDILoadListComparisonTI;
			if CM_EDILoadListTI.hasInstance(llcTi.myDiscrepancyEDITI) then		//par 25136 cnwrs1 22 jul 2010 
				ediLLTI := llcTi.myDiscrepancyEDITI.CM_EDILoadListTI;
				if llcTi.myTrackedItem.isTranshipItem then //update the tranship details
					pxyTI := app.createUpdateProxy(llcTi.myTrackedItem).CM_TrackedItem;
					tiSet.add(pxyTI);
					if updTranshipVoyageCode then
						pxyTI.setTranshipExportVoyage(ediLLTI.getTranshipVoyageCode(), app.myPassport);		//par 25136 cnwrs1 22 jul 2010 
					endif;
					//PAR25362 15/09/2010 cnwsh3 - Identified earlier we are viewing Load comparison mode and dealing with a tranship item that is onboard the inbound (import) voyage.
					//We therefore need to update the tranship discharge port on the tranship details instead of the tracked item's discharge port.
					if updTranshipDischPort then
						if viewingOnboardImportVoyage then 
							pxyTI.myTranshipDetail.setMyDischargePort(app.myRoot.allPorts[ediLLTI.dischargePort]);
						else
							pxyTI.myTranshipDetail.setMyDischargePort(ediLLTI.getTranshipDischargePort);
						endif;
					endif;
					if updTranshipBookingRef then
						pxyTI.myTranshipDetail.setExportBookingReference(ediLLTI.transhipBookingRef);
					endif;
					if updTranshipBOLId then
						pxyTI.myTranshipDetail.setExportBOL(ediLLTI.transhipBOLId); //cnwrs1 16 July 2010 ccms 1137
					endif;
					if updTranshipPortsList then
						foreach portCode in ediLLTI.transhipPortCodes do //cnwrs1 CCMS 1137 01 July 2010
							port := app.myRoot.allPorts[portCode];
							if port &lt;&gt; null then
								pxyTI.myTranshipDetail.transhipToPorts.add(port); //cnwrs1 CCMS 1137 01 July 2010
							endif;
						endforeach;
					endif;
				else //make it a tranship
					create controller transient;
					//cnwrs1 CCMS 1137 01 July 2010
					ediLLTI.myEDIData.CM_EDIDataLoadList.setControllerFromEDITIs(controller, ediLLTI, llcTi.myTrackedItem, updTranshipVoyageCode, updTranshipDischPort, updTranshipBookingRef, updTranshipBOLId, updTranshipPortsList);
					while true do
						app.myTrxCA.trxCreateTrackeditemsTranShip(controller, app.myPassport);
						if app.myPassport.trxCompletedOK() then
							rtnValue := true;
							break;
						else
							result := app.showErrorWarningDialog('Create Tranship From Cargo List', passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
							if app.myPassport.noErrors() and
							   result = IDOK then
								// there must have just been warnings that the user has acknoledged so ..
								app.myPassport.warningsAcknowledged	:= true;
								continue;
							endif;
							
						endif;
						rtnValue := false;
						break;
					endwhile;
			
					if app.myPassport.trxCompletedOK() then
						rtnValue := true;
		//				break;
	/*				else //ccms1137 13 July 2010 cnwrs1
						result := app.showErrorWarningDialog('Update From Load List', passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
						if app.myPassport.noErrors() and
						   result = IDOK then
							// there must have just been warnings that the user has acknoledged so ..
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
						self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
						rtnValue := false;
						break;*/
					endif;
				endif;
			endif;
		endforeach;

		if tiSet.size &gt; 0 then //ccms 1137 cnwrs1 13 July 2010
			while true do
				app.myTrxUA.trxUpdateTrackedItemsBatch(tiSet, TI_UPDMODE_NORMAL, null, passport);
				
				if app.myPassport.trxCompletedOK() then
					rtnValue := true;
					break;
				else
					result := app.showErrorWarningDialog('Update From Cargo List', passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors() and
					   result = IDOK then
						// there must have just been warnings that the user has acknowledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				endif;
				rtnValue := false;
				break;
			endwhile;
		endif;
	endif;

	self.doShowView(self.cmbView.text,false);
	self.reDoNotes();
epilog
	delete tiUpdate;
	delete controller;
	if tiSet &lt;&gt; null then
		tiSet.purge();
		delete tiSet;
	endif;
	delete updateFields;		// PAR #28731
	app.mousePointer := Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="getCargoCompareNameFor" id="f3ef0de5-5472-4d7b-b10a-48876bc1d7c7">
        <source>getCargoCompareNameFor(_givenName : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2024	navra1	Initial creation for //navra1 - MTN-33038 - 14th Oct 2024

*/

vars

begin
	if _givenName = "bol" then
		return app.getString(BillOfLading).toLower();
	elseif _givenName = "bookingref" then
		return "booking";
	elseif _givenName = "cargotype" then
		return "cargo type";
	elseif _givenName = "commodity" then
		return "commodity";
	elseif _givenName = "consignee" then
		return "consignee";
	elseif _givenName = "consignor" then
		return "consignor";
	elseif _givenName = "controlledatmosphere" then
		return "controlled atmosphere";
	elseif _givenName = "sealcustoms" then
		return "customs seal number";
	elseif _givenName = "destinationport" then
		return "destination";		
	elseif _givenName = "dischargeport" then
		return "discharge port";
	elseif _givenName = "freightforwarder" then
		return "freight forwarder";
	elseif _givenName = "hazardous" then
		return "hazards";		
	elseif _givenName = "humidity" then
		return "humidity";
	elseif _givenName = "isogroup" then
		return "iso group";
	elseif _givenName = "isotype" then
		return "iso type";		
	elseif _givenName = "isweightcertified" then
		return "is certified weight";
	elseif _givenName = "operatorcode" then
		return "operator";
	elseif _givenName = "outofgauge" then
		return "over dimensional";		
	elseif _givenName = "sealnum" then
		return "seal number";
	elseif _givenName = "sealshipper" then
		return "shippers seal number";
	elseif _givenName = "temperature" then
		return "temperature";		
	elseif _givenName = "totalweight" then
		return "total weight";
	//elseif _givenName = "tranship" then					//navra1 - MTN-33532 - 29th Nov 2024
		//return "tranship";								//navra1 - MTN-33532 - 29th Nov 2024
	elseif _givenName = "transhipvoyagecode" then			//navra1 - MTN-33532 - 29th Nov 2024
		return "tranship";									//navra1 - MTN-33532 - 29th Nov 2024
	elseif _givenName = "sealnumbervent" then
		return "vent seal number";		
	elseif _givenName = "sealnumterminaloperator" then
		return "terminal operator seal";
	elseif _givenName = "sealnumunknown" then
		return "unknown seal";
	elseif _givenName = "vent" then
		return "ventilation  ";		
	elseif _givenName = "weightcertifiedname" then
		return "weight certifying person";
	elseif _givenName = "weightcertifiedreference" then
		return "weight certifying authority";
	elseif _givenName = "iswatercooled" then
		return "water cooled";		
	elseif _givenName = "specialstow" then
		return "special stowage";
	elseif _givenName = "containerlength" then
		return "container length";
	elseif _givenName = "contentsstatus" then
		return "contents statuses";		
	endif;
	
epilog

end;</source>
        <Parameter name="_givenName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
