    <JadeMethod name="tblQEntries_dblClick" id="41f74d92-e82e-44cd-8fe7-b6863678716d">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblQEntries_dblClick(table: Table input) updating;

// cnwdvb1 31 March 2003 
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------
// 20/11/2012	cnwdap1		PAR #30762 CCMS QNS 2233 show reason for RT task being held
vars
	invalidQueueEntry : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentEntry, invalidQueueEntry);
	
	if table.column = self.getColumnIndex(ETRow_Alerts) then
		self.doLoadAlertsScreen();
	elseif table.column = self.getColumnIndex(ETRow_Assigned) then
		//21/01/2011 cnwdz2 25174
		if self.myCurrentEntry = null then
			return;
		endif;
		//24/08/2011 cnwdz2 27295
		self.myCurrentEntry.edition();
		if invalidQueueEntry then
			return;
		endif;
		
		if self.myCurrentEntry.hasMachineCoverage then
			self.doLoadContainerEnqForm();
		else
			self.doQueryTaskMachineCoverage();
		endif;
	elseif table.column = self.getColumnIndex(ETRow_TaskStatus) then	// PAR #30762
		if self.myCurrentEntry = null then								// PAR #30762
			return;														// PAR #30762
		endif;															// PAR #30762
		self.myCurrentEntry.edition();									// PAR #30762
		if invalidQueueEntry then										// PAR #30762
			return;														// PAR #30762
		endif;															// PAR #30762
		self.doShowHeldReason();										// PAR #30762
	else
		self.doLoadContainerEnqForm();
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblQEntries_mouseDown" id="a4f975d2-74d9-4e3e-9409-164e50bd821c">
