    <JadeMethod name="trxToggleCamProtocolHold" id="9f2d6485-8044-4d60-8eb0-dc20d47e74e7">
        <updating/>
        <source>trxToggleCamProtocolHold(_camProtocol: CM_CamProtocol; _passport: CM_Passport input) updating;
vars
	camObject	: CM_Object;
	status		: Integer;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	if _camProtocol.onHold then
		status := CAM_IDLESTATUS;
	else
		status := CAM_HOLDSTATUS;
	endif;
	if self.tryLock(_camProtocol, Exclusive_Lock, Transaction_Duration, 120000) then //par 21450 wait 2 minute in case cams bgp is running
		beginTransaction;
		camObject := _camProtocol;
		app.myUtilityUA.utlUpdateCamObjectStatus(camObject, status, _passport);
	endif;
epilog
	if self.isLockedByMe(_camProtocol) then
		self.unlock(_camProtocol);
	endif;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxTransferCompletedJobs" id="55946c59-0e34-4ecb-88dd-98c9a1e62015">
        <updating/>
        <source>trxTransferCompletedJobs(_fromJob : CM_VoyageJob; _toJob : CM_VoyageJob; _requests : CM_RequestSet; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		16 September 2010 by cnwjo3
//
// Purpose:		par 23366 ccms 1178
//
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	beginTransaction;
	//then utility agent
	app.myUtilityUA.utlTransferCompletedJobs(_fromJob, _toJob, _requests, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_fromJob" type="CM_VoyageJob"/>
        <Parameter name="_toJob" type="CM_VoyageJob"/>
        <Parameter name="_requests" type="CM_RequestSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxTransferToBOL" id="615ff8e4-eacf-4f26-aa75-14cfa53e6fea">
        <updating/>
        <source>trxTransferToBOL(	_newBol 	   : CM_BOLIn input;
					_newOperator   : CM_Operator;
					_newConsignee  : CM_ConsigneeConsignor;
					_tis 		   : CM_TIArray;
					_tiToSplit     : CM_Cargo io;
					_newId 		   : String;
					_splitWeight   : Decimal;
					_splitQuantity : Integer;
					_passport 	   : CM_Passport input
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Apr 2016	cnwndl1	Initial creation	TFS 1903
07 Jun 2016	 NDL    Now we have to allow for cargo splits (not just bol splits, as per ABs new requirements in TFS 1904)
15 Dec 2022 navma1	Defect 55852: MTN - 1090 exception while loading a Ship Manifest and BOL via EDI
*/

vars

	ti 			: CM_TrackedItem;
	pxyTi 		: CM_TrackedItem;
	proxyColl 	: CM_TISet;
	tfrTis 		: CM_TIArray;
	newTi 		: CM_TrackedItem;
	newTiIds 	: StringArray;
	fromBol 	: CM_BOL;
	txnParams 	: CMIF_TITransactionController;	//06 Nov 2019	NDL	TFS 47100
	bolTrans 	: CM_BOLTransaction;			//06 Nov 2019	NDL	TFS 47100
	tiTrans 	: CM_TITransaction;				//06 Nov 2019	NDL	TFS 47100

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	app.myValUA.valTransferToBol( _newBol, _tis, _passport );
	
	if _passport.hasErrors then
		return;
	endif;
	
	create tfrTis transient;
	if _tiToSplit = null then
		_tis.copy(tfrTis);
	else
		//split some off then put it in the collection to go to another BOL.
		create newTiIds transient;
		newTiIds.add( _newId );
		app.myValUA.valBreakBulkSplitManual( _tiToSplit.CM_Cargo, newTiIds, _splitQuantity, _splitWeight, _passport );
		if _passport.hasErrors then
			return;
		endif;
	endif;
	
	create proxyColl transient;

	beginTransaction;
	
	if _tiToSplit &lt;&gt; null then
		//we are splitting off a single cargo item during a BOL transfer
		app.myUtilityUA.utlSplitBreakBulkToNewID(	_tiToSplit,
													_newId,
													newTi,
													_splitQuantity,	//_quantity : Integer;
													_splitWeight,	//_weight : Decimal;
													_tiToSplit.myOperator, //_operator : CM_Operator;
													true,	//_includeStops : Boolean;
													true,	//_includeToDo : Boolean;
													true,	//_includeDamage : Boolean;
													true,	//_includeHaz : Boolean;
													null, 
													_passport	//_passport : CM_Passport input
													);
		if _passport.hasErrors then
			return;
		endif;
		if newTi.myReceivalBOL &lt;&gt; _tiToSplit.myReceivalBOL then
			newTi.setMyReceivalBOL( _tiToSplit.myReceivalBOL );
		endif;
		if _passport.hasErrors then
			return;
		endif;
		tfrTis.add( newTi );
	endif;
	
	foreach ti in tfrTis do
	
		if fromBol = null then
			fromBol := ti.myReceivalBOL;
		endif;

		if _passport.hasErrors then
			break;
		endif;
		
		pxyTi := ti.pxyCreateUpdateProxy();
		
		if _passport.hasErrors then
			break;
		endif;
		
		proxyColl.add (pxyTi);
		pxyTi.setMyReceivalBOL( _newBol.CM_BOLIn );
		pxyTi.zSetPxyBillOfLading( _newBol.number );
		if _newOperator &lt;&gt; null then
			pxyTi.setMyOperator( _newOperator );
		endif;
		if _newConsignee &lt;&gt; null then
			pxyTi.setConsignee( _newConsignee.code, null, _passport );
		endif;
		
		if _passport.hasErrors then
			break;
		endif;
		
		app.myUtilityUA.utlUpdateTrackedItem(pxyTi, null, TI_UPDMODE_NORMAL, null, null, null, _passport);
		
		if _passport.hasErrors then
			break;
		endif;
		
		//06 Nov 2019	NDL	TFS 47100
		create txnParams transient;
		txnParams.type 		:= TRANS_TYPE_BOL_CARGO_TFR;
		txnParams.userId 	:= _passport.userCode;
		txnParams.dateTime 	:= app.serverTimestampAtTrxStart;
		
		tiTrans := ti.createTransaction(txnParams, _passport).CM_TITransaction;
		
		delete txnParams;
	endforeach;
	
	//06 Nov 2019	NDL	TFS 47100
	if _passport.noErrors and fromBol &lt;&gt; null then
		create txnParams transient;
		txnParams.type 		:= TRANS_TYPE_BOL_TFRD;
		txnParams.userId 	:= _passport.userCode;
		txnParams.dateTime 	:= app.serverTimestampAtTrxStart;
		
		bolTrans := fromBol.createTransaction(txnParams, _passport).CM_BOLTransaction;
		bolTrans.CM_BOLTransferred.setTransferredDetails( fromBol, _newBol, tfrTis );
		
		if bolTrans &lt;&gt; null then					//15.12.2022 navma1 #55852
			bolTrans.createCharge();
		endif;
		
		delete txnParams;
	endif;

epilog
	if proxyColl &lt;&gt; null then
		proxyColl.purge;
	endif;
	delete proxyColl;
	delete tfrTis;
	delete newTiIds;
	delete txnParams;	//06 Nov 2019	NDL	TFS 47100
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_newBol" type="CM_BOLIn" usage="input"/>
        <Parameter name="_newOperator" type="CM_Operator"/>
        <Parameter name="_newConsignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_tiToSplit" type="CM_Cargo" usage="io"/>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_splitWeight" type="Decimal"/>
        <Parameter name="_splitQuantity" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxTransferVoyageJobsToCrane" id="8e78f419-1360-4ce6-9c60-c82a67824514">
        <updating/>
        <source>trxTransferVoyageJobsToCrane(_alljobs : Boolean; // TFS 8158
							_voyageJobs : CM_VoyageJobArray; 
							_jobsWithWarnings : CM_VoyageJobArray input;
							_newVoyageJobSheet : CM_VoyageJobSheet;
							_mode : Integer;
							_selectedRequests : CM_RequestSet;
							_selectedWLES : CM_WLESet; // TFS 3646
							_newJobNum : String;
							_moveJob : Boolean; // PAR 25968
							_targetJob : CM_VoyageJob;
							_passport : CM_Passport input) : String updating;
//-----------------------------------------
// Created: 2 September 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpJob : CM_VoyageJob;
	errorSet : CM_ErrorSet;
	alertCreated : Boolean;
	newJob : CM_VoyageJob;
	jobInfoStr : String;
	nextNewJobNum : String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	self.raiseExceptionIfNull(_newVoyageJobSheet, app.getErrorString(VoyageJobSheet));
	exclusiveLock(_newVoyageJobSheet);

	// so only 1 note sent from the move controller
	app.myEventManager.setMultiTransactionTrx();

	create errorSet transient;
	
	nextNewJobNum := _newJobNum;	//10 May 2012	NDL	Par 29528
	
	foreach tmpJob in _voyageJobs do
		exclusiveLock(tmpJob);
	//	newJob := null;	// ### PAR 23070
		newJob := _targetJob;

		beginTransaction;
	
		if _mode = QUEUE_MODE then // User wants the jobs unqueue
			tmpJob.unqueueRequestsWLEs(_selectedRequests, _passport);
		elseif _mode = PLANNING_MODE then // User wants the jobs unplanned and unqueued
			tmpJob.unqueueRequestsWLEs(_selectedRequests, _passport);
			tmpJob.unplanFutureMove(_mode, _selectedRequests, _passport);  //CCMS 1178 PAR 23366
		elseif _mode = UNPLAN_MODE then
			//we may want to unplan.  not sure
			tmpJob.unplanFutureMove(PLANNING_MODE, _selectedRequests, _passport);  //CCMS 1178 PAR 23366
		endif;		
		
		if _passport.noErrors() then
			//app.myUtilityUA.utlUpdateJobTransOnJobSheet(tmpJob, _newVoyageJobSheet, newJob, _mode, _selectedRequests, _newJobNum,  _moveJob, _passport);
			app.myUtilityUA.utlUpdateJobTransOnJobSheet(_alljobs, tmpJob, _newVoyageJobSheet, newJob, _mode, _selectedRequests,_selectedWLES,  nextNewJobNum,  _moveJob, _targetJob, _passport);//CCMS 1178 PAR 23366
		endif;

		if _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
			
			// ### PAR 23070
			if newJob &lt;&gt; null then
				//10 May 2012	NDL	Par 29528
				if _newVoyageJobSheet &lt;&gt; null then
					nextNewJobNum := _newVoyageJobSheet.allJobsByJobNum.getNextJobID();
				endif;
				
				if jobInfoStr = null then
					jobInfoStr := app.getErrorString2(TransVoyageJobToCrane_NewJob,newJob.jobNum,tmpJob.jobNum);
				else
					jobInfoStr := jobInfoStr &amp; CrLf &amp; app.getErrorString2(TransVoyageJobToCrane_NewJob,newJob.jobNum,tmpJob.jobNum);
				endif;
			endif;
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert(app.getErrorString2(ERR_VoyageTransToCrane,tmpJob.getTreeDescription(),_newVoyageJobSheet.crane),_passport.allErrorWarnings);
				alertCreated := true;
			elseif _passport.hasWarnings then
				//add job so it gets re-processed in order
				_jobsWithWarnings.add(tmpJob);
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();				
		endif;
	endforeach;

	if _passport.noErrors() 
	and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);

	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, app.getErrorString(JobTransferToCrane), null, self);
	endif;
	
	return jobInfoStr;
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
end;</source>
        <Parameter name="_alljobs" type="Boolean"/>
        <Parameter name="_voyageJobs" type="CM_VoyageJobArray"/>
        <Parameter name="_jobsWithWarnings" type="CM_VoyageJobArray" usage="input"/>
        <Parameter name="_newVoyageJobSheet" type="CM_VoyageJobSheet"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
        <Parameter name="_selectedWLES" type="CM_WLESet"/>
        <Parameter name="_newJobNum" type="String"/>
        <Parameter name="_moveJob" type="Boolean"/>
        <Parameter name="_targetJob" type="CM_VoyageJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
