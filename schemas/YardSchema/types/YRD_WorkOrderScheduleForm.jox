    <JadeMethod name="timerEvent" id="0a59d3b5-e26a-42eb-975b-9968a0a244e9">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	leftColumn : Integer;
	topRow : Integer;
	
begin

	
	self.timerTS := null;
	
	self.doSave();
	
	leftColumn := self.tblSchedule.leftColumn;
	topRow := self.tblSchedule.topRow;

	self.loadSchedule();
	self.loadSummary();
	
	self.tblSchedule.leftColumn := leftColumn;
	self.tblSchedule.topRow := topRow;
	
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerSetup" id="7600614b-b3d8-417c-ae6e-b88abbbe7baf">
        <updating/>
        <source>timerSetup() updating;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

constants
	OneDayOfMilliseconds = 86400000;
vars
	delay : Integer;
	row : Integer;
	rowDT : TimeStamp;

begin
	self.timerClear();
	
	row := self.tblSchedule.fixedRows + 1;
	
	while row &lt;= self.tblSchedule.rows do
		rowDT := self.getScheduledDT(row);
		if rowDT &gt; self.currentTS then
			self.timerTS := rowDT;
			delay := (self.timerTS - self.currentTS).getMilliseconds().min(OneDayOfMilliseconds).Integer;
			self.beginTimer(delay, Timer_OneShot, self.TimerDT);
			return;
		endif;
		row := row + 1;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3198730c-a467-43bd-8008-c87a0b8cc846">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012866, locale);
	btnAddDates.translateCaption(Xlat_0012867, locale);
	lblJobId.translateCaption(Xlat_0012868, locale);
	lblTask.translateCaption(Xlat_0012869, locale);
	mnuAction.translateCaption(Xlat_0013894, locale);
	mnuActionAll.translateCaption(Xlat_0013895, locale);
	mnuActionSome.translateCaption(Xlat_0013896, locale);
	mnuActionThese.translateCaption(Xlat_0013897, locale);
	mnuAddDates.translateCaption(Xlat_0013898, locale);
	mnuDateColumn.translateCaption(Xlat_0013899, locale);
	mnuScheduleAction.translateCaption(Xlat_0013900, locale);
end;</source>
    </JadeMethod>
