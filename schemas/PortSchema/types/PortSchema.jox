//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iniFileName	: String;

begin

	iniFileName := self.getIniFileNameAppServer();
	return self.getProfileStringAppServer(iniFileName, 'JadeLog', 'LogDirectory', null);

end;</source>
