    <JadeMethod name="tClearBOLNumber" id="563ef653-3953-44b9-a512-06db5b6c3097">
        <source>tClearBOLNumber();
// cnwmp6
/*

Purpose:			Test par 33654 clearing billOfLading with an existing myReceivalBOL

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2014	cnwjre1	Initial creation

*/

vars
	cargo1,
	cargo2		: CM_TrackedItem;
	ti			: CM_TrackedItem;
	operator	: CM_Operator;
	bol1		: CM_BOL;
	vessel		: CM_Vessel;
	voyage		: CM_Voyage;
	terminal	: CM_Terminal;
	type 		: CM_TerminalAreaType;
	blockStack  : CM_BlockStack;
	count		: Integer;
	bolNum1,
	bolNum2		: String;
begin
	
	operator := self.getOperator("PON");
	terminal := self.getTerminal();
	
	vessel := self.addVesselWithHolds("UT_VHOLDX", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDX", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);

	self.deleteBOL("BOL001", null);
	bol1 := self.addBOL("BOL001", voyage, operator, null, terminal );
	
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack &lt;&gt; null, "Block Stack UT_BS1 not found...");

	cargo1 := self.addContainerAtLocation( "BOLU111222", operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	cargo2 := self.addContainerAtLocation( "BOLU222333", operator, "22G1", "GENL", TI_IMEX_STATUS_EXPORT, blockStack.allLocationsControllers.first);
	
	// set the required properties directly
	beginTransaction;
	cargo1.setMyVoyage(voyage, app.myPassport);
	cargo2.setMyVoyage(voyage, app.myPassport);
	cargo1.setReceiptTransportMode(TI_TRANSMODE_SHIP);
	cargo2.setReceiptTransportMode(TI_TRANSMODE_SHIP);
	cargo1.setBOL(bol1.number);
	cargo2.setBOL(bol1.number);
	commitTransaction;
	
	if cargo1.myReceivalBOL &lt;&gt; null then
		bolNum1 := cargo1.myReceivalBOL.number;
	endif;
	
	if cargo2.myReceivalBOL &lt;&gt; null then
		bolNum2 := cargo2.myReceivalBOL.number;
	endif;
	
	self.assertEqualMsg("BOL001", bolNum1, "First cargo receival BOL");
	self.assertEqualMsg("BOL001", bolNum2, "Second cargo receival BOL");
	
	foreach ti in bol1.allTrackedItems do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 2, "BOL tracked items");
	
	// clear the BOL directly
	beginTransaction;
	cargo1.setBOL("");
	cargo2.setBOL("");
	commitTransaction;
	// without the 33654 fix, get the '75007. An input is required for the Docket No. field.' error

	self.assertEqualMsg(null, cargo1.billOfLading, "First cargo billOfLading not cleared");
	self.assertEqualMsg(null, cargo2.billOfLading, "Second cargo billOfLading not cleared");
	self.assertEqualMsg(null, cargo1.myReceivalBOL, "First cargo BOL not cleared");
	self.assertEqualMsg(null, cargo2.myReceivalBOL, "Second cargo BOL not cleared");
	
	count := 0;
	foreach ti in bol1.allTrackedItems do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 0, "BOL not empty");

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tPAR21907_CustomsReference" id="7640a13b-530f-4e7c-94e2-978721e2e331">
        <source>tPAR21907_CustomsReference();
// cnwrs1 - for emails - December 2009
// check that the CM_TrackedItem field customsReference can be updated correctly.

constants
	ContainerId1	= 'PAR21907_1';	
vars
	testStr			: String;
	tempStr			: String;
	container		: CM_Container;
	
begin
	testStr	:= ContainerId1 &amp; Space &amp; ETRow_CustomsReference;		// what we want to load.
	
	self.deleteContainer( ContainerId1 );	
	container	:= self.getTrackedItem( ContainerId1 ).CM_Container;
	self.assertIsDeleted( container );
	
	// and add the container with required values.
	self.opts.addAssoc( ETRow_CustomsReference, testStr );
	container	:= self.addContainerOpts(	ContainerId1,
										'2200',
										'WOOL',
										self.getOperator( self.getProfileSetting( UT_Profile.P_OPERATOR ).asString)).CM_Container;
	
	container	:= self.getTrackedItem( ContainerId1 ).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	self.assertNotNullMsg( container, tempStr );
	
	tempStr	:= 'Customer Reference not set correctly to ' &amp; testStr;
	self.assertEqualMsg( container.customsReference, testStr, tempStr );
	
epilog
	
end;
</source>
    </JadeMethod>
</Class>
