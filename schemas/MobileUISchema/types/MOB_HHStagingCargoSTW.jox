    <JadeMethod name="doResizeControls" id="fa0a43fa-5236-498c-9b4e-4cf759b4d94d">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;
	folderHeight : Real;
	buttonWidth : Real;
	index : Integer;
	menuButton : MOB_Button;
	buttonHeight : Integer;
	buttonTop : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	inheritMethod(_initialSetup);
	
	if _initialSetup then
		self.cmbRelItems.visible := true;
	endif;
	self.cmbRelItems.move(	self.resizedMargin,
							cTop,
							cWidth,
							cHeight
							);
	
	cTop := self.cmbRelItems.top + self.cmbRelItems.height + self.resizedMargin;
	if _initialSetup then
		self.txtReserveDesc.setAndIncrementTabIndex( tabIndex );
		self.txtReserveDesc.visible := true;
	endif;
	self.txtReserveDesc.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight * 2 ); 
								
	cTop := cTop + self.txtReserveDesc.height + self.resizedMargin;
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	folderHeight := self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin;
	self.fldCargo.move(	self.resizedMargin,
						cTop,
						self.clientWidth - 4,
						folderHeight
						);
						
	self.frmStaged.move(	1,
							1,
							self.shtStaged.width - self.resizedMargin,
							self.shtSelected.height - ( self.btnOne.height + ( self.resizedMargin * 2) )
							);
							
	self.frmSelected.move(	1,
							1,
							self.shtSelected.width - self.resizedMargin,
							self.shtSelected.height - ( self.btnOne.height + ( self.resizedMargin * 2) )
							);
	self.frmAvailable.move(	1,
							1,
							self.shtAvailable.width - self.resizedMargin,
							self.shtAvailable.height - ( stdHeight + ( self.resizedMargin * 2) )
							);
	//15 Mar 2016	NDL	TFS 1484
	cTop := self.frmAvailable.top + self.frmAvailable.height + self.resizedMargin;
	if _initialSetup then
		self.cmbTargetArea.parent := shtAvailable;
		self.cmbTargetArea.setAndIncrementTabIndex( tabIndex );
		self.cmbTargetArea.visible := true;
		self.populateTargetArea( self.myTargetLocation );
	endif;
	self.cmbTargetArea.move( self.resizedMargin,
							 cTop,
							 self.shtAvailable.width - self.resizedMargin,
							 stdHeight );
	
	//06 Apr 2016	NDL	TFS 1667
	cTop := self.frmSelected.top + self.frmSelected.height + self.resizedMargin;
	if _initialSetup then
		self.btnStageAll.parent := shtSelected;
		self.btnStageAll.setAndIncrementTabIndex( tabIndex );
		self.btnStageAll.visible := false;
	endif;
	self.btnStageAll.move(	self.resizedMargin,
							cTop,
							self.btnOne.width,
							self.btnOne.height );
							
	//21 Sep 2016	NDL TFS 2647 / 2001
	if _initialSetup then
		self.btnDocActions.parent := shtSelected;
		self.btnDocActions.setAndIncrementTabIndex( tabIndex );
		self.btnDocActions.visible := false;
	endif;
	self.btnDocActions.move(	self.resizedMargin + self.btnStageAll.width + self.resizedMargin,
								cTop,
								self.btnOne.width,
								self.btnOne.height );
	
						
	cTop := self.fldCargo.top + self.fldCargo.height + self.resizedMargin;
	if _initialSetup then
		self.lblTotals.setAndIncrementTabIndex( tabIndex );
		self.lblTotals.visible := true;
	endif;
	self.lblTotals.move( 	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	if self.availableCount &gt; 0 then
		buttonHeight := self.getScrollingButtonHeight();
		self.btnAvailTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar( self.availableCount, self.frmAvailable, self.btnAvailTemp.height, self.scrAvailable );
		
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.availableCount do
			menuButton := self.btnAvailTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnAvailTemp.fontSize;	//07 Apr 2015	NDL	Par 35990
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	endif;
	
	if self.selectedCount &gt; 0 then
		buttonHeight := self.getScrollingButtonHeight();
		self.btnSelectedTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar( self.selectedCount, self.frmSelected, self.btnSelectedTemp.height, self.scrSelected );
		
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.selectedCount do
			menuButton := self.btnSelectedTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnSelectedTemp.fontSize;	
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	endif;
	
	if self.stagedCount &gt; 0 then
		buttonHeight := self.getScrollingButtonHeight();
		self.btnStagedTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar( self.stagedCount, self.frmStaged, self.btnStagedTemp.height, self.scrStaged );
	
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.stagedCount do
			menuButton := self.btnStagedTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnStagedTemp.fontSize;	//07 Apr 2015	NDL	Par 35990
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
		
	endif;
								
	self.lblNoAvailable.move( 	self.resizedMargin,
								1,
								self.frmAvailable.width-2,
								stdHeight );
								
	self.lblNoSelected.move( 	self.resizedMargin,
								1,
								self.frmSelected.width-2,
								stdHeight );
								
	self.lblNoStaged.move( 	self.resizedMargin,
							1,
							self.frmStaged.width-2,
							stdHeight );
								
//	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doStageAll" id="fa1eb597-2f30-4500-abd1-e6a617acdb8e">
        <updating/>
        <source>doStageAll(_reserveDetail: CM_ReserveDetail input;
						_tis : CM_TISet) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgrh7	Initial creation TFS38573

*/

vars
	ti 							: CM_TrackedItem;
	tmpTi 					: CM_TrackedItem;
	futureMove		: CM_FutureMove;
	targetLocation 	: CM_LocationsController;
	stagedAreas 		: CM_LCSet;
	amountForm		: MOB_HHCargoAmountForm;
	errMess 									: String;
	reason 										: String;
	skipAttributes						: IntegerArray;
	foundAnotherRelease 		: Boolean;
	warning 									: String;
	quantity									: Integer;
	weight										: Decimal [16,4];
	totalQuantity							: Integer;
	totalWeight							: Decimal [16,4];
	
begin
	//validations Start
	if self.myTargetLocation = null then																//common validations for all tis
		errMess := app.getErrorString(No_Target_location_found);
		return ;
	endif;
	if self.myBulkRelease = null then
		errMess := app.getErrorString(No_release_item_selected);
		return ;
	endif;
		
	if _reserveDetail = null then
		errMess := app.getErrorString(No_release_item_selected);
		return ;
	endif;
	
	if not self.warnedMultiRel then	//05 May 2016	NDL	TFS 1936 (reset if target area changes)
			foreach tmpTi in self.myTargetLocation.allTrackedItems do
				if not self.myBulkRelease.allTrackedItemsAssigned.includes(tmpTi) then
					foundAnotherRelease := true;
					break;
				endif;
			endforeach;
			if not foundAnotherRelease then
				foreach futureMove in self.myTargetLocation.allQueuedFutureMoves do
					tmpTi := futureMove.getTrackedItem;
					if tmpTi &lt;&gt; null then
						if not self.myBulkRelease.allTrackedItemsAssigned.includes(tmpTi) then
							foundAnotherRelease := true;
							break;
						endif;
					endif;
				endforeach;
			endif;
				
			if foundAnotherRelease then
				warning := app.getErrorString(Stagi_area_alrea_conta_cargo_a);
				//if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No, true ) &lt;&gt; MsgBox_Return_Yes then
				//09 Nov 2015	NDL	Par 37152
				//if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Default_Second, true ) &lt;&gt; MsgBox_Return_Yes then
				//	return;
				//endif;
				if not self.acceptedWarning( warning , self.warnedMultiRel ) then	//05 May 2016	NDL	TFS 1936
					return ;
				endif;	
			endif;
	endif;
		
	create stagedAreas transient;
		
	if not self.myBulkRelease.validateStagedToOneArea( stagedAreas ) then		// need this to build the 'stagedAreas' even if 'warnedMultiArea' already set
		if not self.warnedMultiArea and not self.warnedNoPrimArea then	//05 &amp; 09  May 2016	NDL	TFS 1936
			warning := app.getErrorString(Releas_staged_multip_areas_con);
		//	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No, true ) &lt;&gt; MsgBox_Return_Yes then
		//		return;
		//	endif;
			if not self.acceptedWarning( warning, self.warnedMultiArea ) then	//05 May 2016	NDL	TFS 1936
				return ;
			endif;
		endif;
	endif;
		
	if not self.warnedNoPrimArea and not self.warnedMultiArea then	//05 &amp; 09 May 2016	NDL	TFS 1936
		if stagedAreas.size = 1 and stagedAreas.first &lt;&gt; self.myTargetLocation then
				warning := app.getErrorString2(This_relea_curre_stage_into_su, stagedAreas.first.getFullId, self.myTargetLocation.getFullId);
			//	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No, true ) &lt;&gt; MsgBox_Return_Yes then
			//		return;
			//	endif;
				if not self.acceptedWarning( warning, self.warnedNoPrimArea ) then	//05 May 2016	NDL	TFS 1936
					return ;
				endif;
		endif;
	endif;
			
	if not self.warnedFullyStaged and not self.warnedOverStaged then	//05 &amp; 09 May 2016	TFS 1936
			if _reserveDetail.isFullyStaged then
				warning := app.getErrorString(Relea_item_alrea_fully_stage_w );
				//if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No, true ) &lt;&gt; MsgBox_Return_Yes then
				//09 Nov 2015	NDL	Par 37152
			//	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Default_Second, true ) &lt;&gt; MsgBox_Return_Yes then
			//		return;
			//	endif;
				if not self.acceptedWarning( warning , self.warnedFullyStaged ) then	//05 May 2016	NDL	TFS 1936
					return ;
				endif;
			endif;
	endif;
	
	if _reserveDetail.isKindOf(CM_ReserveSelection) then
			//11 Jan 2017	NDL	TFS 3189/2876
			if self.myBulkRelease.isShipType then
				//testing against the reserve selection needs to ignore Voyage, Discharge Port and IMEX,
				//because these are unconditionally reset when assigned to the ship release during staging
				create skipAttributes transient;
				skipAttributes.add( YACriteriaType_Voyage );
				skipAttributes.add( YACriteriaType_DischargePort );
				skipAttributes.add( YACriteriaType_ImexStatus );
			endif;
	endif;
	
	foreach ti in _tis do																									//each ti validation
		if ti = null then
			errMess :=  app.getErrorString(NO_Cargo_found);
		endif;
		
		if _reserveDetail.isKindOf(CM_ReserveSelection) then
			if not ti.testAgainstReserveSelection( _reserveDetail.CM_ReserveSelection, reason, false, skipAttributes ) then
				errMess := app.getErrorString2(Warn_Request_Line_Match, reason, ti.id);
				return ;
			endif;
		endif;
		
		if ( ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti ) and ( ti.totalQuantity &gt; 1 or not ti.myCargoType.isBulkByQuantity ) then	// To Get All Selected Tis total Quantity/ Weight for over-staged valdiation
			create amountForm transient;
			amountForm.lblInfo.caption := app.getErrorString2( MoveToTarget , ti.id, self.myTargetLocation.getFullId );
			amountForm.myTrackedItem := ti;
			if amountForm.showModal = IDOK then
				if amountForm.byQuantity then
					quantity := amountForm.getQuantity;
					totalQuantity := totalQuantity +quantity;
				else
					weight := amountForm.getWeightMovedKgs;
					totalWeight := totalWeight + weight;
				endif;
			else
				return ;
			endif;
		else
			totalQuantity := totalQuantity + ti.totalQuantity;	
		endif;
	endforeach;
	//Validation for total selected tis' quantity against (release tis's total quantity - staged tis's quantity)
	if not self.warnedFullyStaged and not self.warnedOverStaged then	//05 &amp; 09 May 2016	TFS 1936											
				if _reserveDetail.wouldBeOverStaged( null, totalQuantity, totalWeight ) then
					warning := app.getErrorString1(Will_OverStage, _reserveDetail.getDescription );
				//	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Default_Second, true ) &lt;&gt; MsgBox_Return_Yes then
				//		return;
				//	endif;
					if not self.acceptedWarning( warning , self.warnedOverStaged ) then	//05 May 2016	NDL	TFS 1936
						return ;
					endif;
				endif;
	endif;
	 targetLocation := self.myTargetLocation;
	//For the whole tis' transaction now
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxStageMultiCargoForRelease(_tis, _reserveDetail,targetLocation, app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		errMess := null;
	else
		errMess := app.myPassport.getAllErrorsWarningsAsString;	
		return ;	
	endif;
	
epilog
	delete stagedAreas;
	delete skipAttributes;

	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
	else
		//09 Nov 2015	NDL	Par 37152
		self.txtCargoId.text := null;
		self.convertedAltId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216
		self.convertedCargoId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216					
		self.txtCargoId.setFocus();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_tis" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="findCargoInList" id="e2c6a52a-ee7f-48ca-ac03-de9ea009aa17">
        <updating/>
        <source>findCargoInList()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2014	cnwndl1	Initial creation
10/03/2016	cnwdap1	PAR #37488 Allow search on alternaitive id as well as id
*/

vars

	altIdStr : String;	//08 Jul 2016	NDL	TFS 2275 / 2216
	cargoIdStr : String;	//08 Jul 2016	NDL	TFS 2275 / 2216
	buttonNumber : Integer;
	size : Integer;
	baseButton : MOB_Button;
	menuButton : MOB_Button;
	ti : CM_TrackedItem;
	scroll: ScrollBar;
	frame : MOB_Frame;
	value : Real;
	offset : Integer;
	
	buttonHeight : Integer;	//26 Apr 2016	NDL	TFS 1889

begin

	cargoIdStr := self.convertedCargoId;	//08 Jul 2016	NDL	TFS 2275 / 2216
	if cargoIdStr = null then
		return;
	endif;
	
	altIdStr := self.convertedAltId;	//08 Jul 2016	NDL	TFS 2275 / 2216
	
	if self.fldCargo.topSheet = self.shtAvailable then
		baseButton := self.btnAvailTemp;
		size := self.availableCount;
		scroll := self.scrAvailable;
		frame := self.frmAvailable;
	elseif self.fldCargo.topSheet = self.shtSelected then
		baseButton := self.btnSelectedTemp;
		size := self.selectedCount;
		scroll := self.scrSelected;
		frame := self.frmSelected;
	elseif self.fldCargo.topSheet = self.shtStaged then
		baseButton := self.btnStagedTemp;
		size := self.stagedCount;
		scroll := self.scrStaged;
		frame := self.frmStaged;
	endif;
	
	buttonHeight := self.getScrollingButtonHeight();	//26 Apr 2016	NDL	TFS 1889
	
	foreach buttonNumber in 1 to size do
		menuButton := baseButton.getControl( buttonNumber ).MOB_Button;
		if menuButton &lt;&gt; null then
		//	if buttonNumber = 1 then
		//		offset := menuButton.top.Integer; // in case its already scrolled
		//	endif;
			ti := menuButton.userObject.CM_TrackedItem;
			//if ti.id = text then												// PAR #37488
			if ti.id = cargoIdStr or ti.alternativeId = altIdStr then						// PAR #37488
			//	scroll.value := menuButton.top.Integer - offset;
				scroll.value := ( (buttonNumber - 1) * (buttonHeight + self.resizedMargin) );	//26 Apr 2016	NDL	TFS 1889
				self.setMenuScrollStart( scroll, baseButton, frame, size );
				menuButton.setFocus();
				return;
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fldCargo_querySheetChg" id="51d32246-84bb-4010-b6ff-a139df68705b">
        <controlMethod name="Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldCargo_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2016	cnwndl1	Initial creation	TFS 1667

*/

vars

	reserveDetail : CM_ReserveDetail;
	showDocActions : Boolean;

begin

	reserveDetail := self.getReserveDetail();
	if reserveDetail &lt;&gt; null and reserveDetail.myReserveDetailActions &lt;&gt; null then
		showDocActions := reserveDetail.myReserveDetailActions.hasActions();
	endif;

	if self.myTargetLocation = null then
		self.btnStageAll.visible := false;
		self.btnDocActions.visible := false; //20 Sep 2016	NDL	TFS 2647 / 2001
		if newSheet = self.shtAvailable then
			self.cmbTargetArea.parent := self.shtAvailable;
		elseif newSheet = self.shtSelected then
			self.cmbTargetArea.parent := self.shtSelected;
		endif;
	else
		self.btnStageAll.visible := true;
		self.btnDocActions.visible := showDocActions;	//21 Sep 2016	NDL TFS 2647 / 2001
		self.cmbTargetArea.parent := self.shtAvailable;
		//20 Sep 2016	NDL	TFS 2647 / 2001
		if newSheet = self.shtSelected then
			self.btnDocActions.parent := self.shtSelected;	
		elseif newSheet = self.shtStaged then
			self.btnDocActions.parent := self.shtStaged;
		endif;
	endif;
	
	self.txtCargoId.setFocus();	//19 Apr 2016	NDL	TFS 1868
	
	return true;

epilog

end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReserveDetail" id="2b36b958-6cec-4724-a1a5-eb6e909fab9c">
        <source>getReserveDetail():CM_ReserveDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation

*/

vars

	reserveDetail : CM_ReserveDetail;

begin

	if self.myBulkRelease.isRoadType and self.myBulkRelease.allReserveDetails.size = 1 then	
		reserveDetail := self.myBulkRelease.allReserveDetails.first;
	else
		reserveDetail := self.cmbRelItems.listObject.CM_ReserveDetail;
	endif;
	
	return reserveDetail;

epilog

end;</source>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
