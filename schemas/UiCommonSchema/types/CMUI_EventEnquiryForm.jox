        <source>doOpenBookingRefDiscrep( _obj : CMEVT_BookingRefDiscrep );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

begin

	if _obj = null then
		return;
	endif;
	self.myAssistant.showBookingRefDiscrep(_obj, null, null, self.myMasterMenuAction, self.myTerminal);

epilog

end;</source>
