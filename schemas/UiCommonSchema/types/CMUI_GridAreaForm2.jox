    <JadeMethod name="doZoom" id="1c8aa013-35c6-46f1-b0ad-eae9dad2133b">
        <updating/>
        <source>doZoom(pFactor : Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     Implement in subclass`
// ---------------------------------------------------------------------------
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	endTime,
	startTime	: TimeStamp;
	x, y		: Real;
	oldFactor	: Real;
	tmpDkbGridArea	: CMUI_GridAreaDockBar;

begin

	self.mousePointer := Window.MousePointer_HourGlass;
	
	//tmpFrame := self.dkbGridArea.myScrollableFrame;
	//tmpFrame.visible := false;
	tmpDkbGridArea := self.dkbGridArea;
	
	tmpDkbGridArea.getPositionAsPercentage(self.saveX, self.saveY, x, y);

	startTime := app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.myCurrentDrawingController.doZoom(pFactor);
	self.xmlZoomFactor := pFactor;

	tmpDkbGridArea.scrollToFromPercentage(x, y);

	//tmpFrame.visible := true;

	endTime := app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.frmStatusLine.myFrameCaption.caption := (startTime.cnEcDiff(endTime) / 1000).Integer.String &amp; " Seconds to Zoom";

epilog 
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
