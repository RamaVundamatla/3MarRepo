        <source>showVoyageDischargeButton() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwer1	Initial creation

*/

vars

begin
	//epr par 33423 CCMS 2330 now visible in get next mode
	
	if self.isEnquiryMode then
		self.btnVoyDischarge.visible:=false;
		return;
	endif;
		
	self.btnVoyDischarge.visible:=  app.myVMAgent.myRTQueue.isKindOf(CM_VoyageQueue) and app.myVMAgent.myRTQueue.CM_VoyageQueue.getDischargeMachinesMode = CM_VoyageCraneQueue.ActAsShipLander ;	

	self.repositionButtons();  //cnwrd1 par 26442 26.11.2010 - need to reposition the buttons if we change the visibility of one.
	
