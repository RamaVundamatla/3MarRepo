    <JadeMethod name="getTrackedItems" id="6e385f8f-ef30-43db-8e1d-92667b956b40">
        <source>getTrackedItems(_strArray : StringArray input) protected;

// cnwdvb1 20 November 2002 

vars

	ti		: CM_Log;
	iter	: Iterator;

begin

	_strArray.clear();
	iter := self.allTrackedItems.createIterator;
	while iter.next(ti) do
		_strArray.add(ti.id);
	endwhile;
epilog

	delete iter;
end;</source>
