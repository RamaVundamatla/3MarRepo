    <JadeMethod name="clearNonYardAllocsFromTermColl" id="c1443e82-3a9b-46e1-83c5-2922a0ed76c3">
        <source>clearNonYardAllocsFromTermColl(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	navndl1	Initial creation	TFS 49952

*/

vars

	ya : CM_YardAllocation;
	countTerm : Integer;
	class : Class;
	classes : ClassColl;
	obj : Object;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Clearing Non 'Yard Allocations' from the allYardAllocations collection on Terminal", LogINFO);
	
	create classes transient;
	
	classes.add( CM_InvoiceAllocation );
	classes.add( CM_InvoiceCargoAllocation );
	classes.add( CM_InvoiceInventoryAllocation );

	beginTransaction;
	foreach class in classes do
		countTerm := 0;
		foreach obj in class.instances do
			ya := obj.CM_YardAllocation;
			if ya.myTerminal &lt;&gt; null then	
				ya.setTerminal(null);
				countTerm := countTerm + 1;
			endif;
		endforeach;
		if countTerm &gt; 0 then
			app.writeLog(method.qualifiedName &amp; " Cleared 'myTerminal' for " &amp; countTerm.String &amp; " " &amp; class.name &amp; " objects", LogINFO);
		else
			app.writeLog(method.qualifiedName &amp; " no " &amp; class.name &amp; " objects found that required 'myTerminal' to be cleared", LogINFO);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Clearing Non 'Yard Allocations' from the allYardAllocations collection on Terminal - Complete", LogINFO);
	self.addScriptRun(method.name);
	
epilog

	delete classes;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="clearOffSiteFuturePlans" id="10ed004c-ec20-4883-ae70-36f094dd8e3a">
        <source>clearOffSiteFuturePlans( _updController : CnEcReleaseController );
/*

Purpose:			

Parameters:			Cargo on Trains and Trucks could previously be moved off-site while
					they were still planned to on-site yard locations.
					Subsequent attempts to change the on-site Terminal Area definition were
					then thwarted by these planned mopves that could not be deleted by the users.
					Warnings are now issued, during Wagon departing and Gating out, and if ignored
					the planned future moves are deleted during the off-site move.
					
					This method is to find and clean up the pre-existing instances of this.

Return Value:		

Date		Who		Reason
30 June 2021	navndl1	Initial creation	TFS 51421

*/

vars

	offSitePlanned : CM_TISet;
	objArray : ObjectArray;
	lcIter : Iterator;
	lcObj : Object;
	lc : CM_LocationsController;
	fmIter : Iterator;
	fm : CM_FutureMove;
	ti : CM_TrackedItem;

begin

	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Clearing Furture Planned Moves for Off-site Cargo", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Clearing Furture Planned Moves for Off-site Cargo") ;	
	endif;

	create offSitePlanned transient;
	create objArray transient;
	
	CM_YardController.allInstances( objArray, 0, true );
	
	lcIter := objArray.createIterator;
	while lcIter.next( lcObj ) do
		lc := lcObj.CM_LocationsController;
		fmIter := lc.allPlannedFutureMoves.createIterator;
		while fmIter.next( fm ) do
			ti := fm.getTrackedItem;
			if ti = null or not ti.isOffSite then
				continue;
			endif;
			offSitePlanned.addNoDuplicates( ti, false );
		endwhile;
		delete fmIter;
	endwhile;
	
	foreach ti in offSitePlanned do
		app.myPassport.setMyTerminal( ti.myTerminal );
		beginTransaction;
		ti.allPlannedFutureMoves.purge;
		commitTransaction;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Clearing Furture Planned Moves for Off-site Cargo complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Clearing Furture Planned Moves for Off-site Cargo complete") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete lcIter;
	delete fmIter;
	delete objArray;
	delete offSitePlanned;

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAllCTNToSC" id="b4925ff2-c35a-4818-982d-382099da70c3">
        <source>convertAllCTNToSC(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	cargoType : CM_CargoBOLType;	
	objArr 		: ObjectArray;
	obj			: CM_StopsTable;
	stopCriteria,criteria	: CM_StopCriteria;
	objSet	: ObjectSet;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " On Stops Table", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" On Stops Table") ;	
	endif;
	
	create objArr transient;
	CM_StopsTable.allInstances(objArr, 0, true);
	
	beginTransaction;
	foreach obj in objArr as CM_StopsTable do
	
		criteria := obj.myStopCriteria;
		if criteria &lt;&gt; null then
			criteria.setPropertyValue("myStopTable",null);
			delete criteria;
		endif;
		 
	
		if obj.allCargoTypesNew &lt;&gt; null and obj.allCargoTypesNew.size &gt; 0 then		
			obj.allCargoTypesNew.rebuild();

			create objSet transient;				
			foreach cargoType in obj.allCargoTypesNew do											
					objSet.add(cargoType);			
			endforeach;
			create stopCriteria transient;
			stopCriteria.createStopCriteria(objSet, YACriteriaType_CargoType,stopCriteria);
			stopCriteria.setProxyBaseData(obj);
			create criteria persistent;
			criteria.setForCreate(stopCriteria);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " On Stops Table", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" On Stops Table") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	abortTransaction;
	delete objSet;
	delete objArr;
	delete stopCriteria;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAllDamageSeverity" id="fbb83038-09e2-4ea4-b4fa-4e352671b04a">
        <source>convertAllDamageSeverity(_controller : CnEcReleaseController);
/*

Purpose:	this must be run AFTER populateDamageSeverties()		

Parameters:			

Return Value:		

Date		Who		Reason
 // ### TFS 55311 03NOV2022 NAVAB1
*/

vars
	objArr 		: ObjectArray;
	damage			: CM_DamageInstance;
	objSet	: ObjectSet;
	severity, default : CM_DamageSeverity;
	root : CM_Root;
	term, defterm : CM_Terminal;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Severity on Damage Instances", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Severity on Damage Instances") ;	
	endif;
	
	root := CM_Root.firstInstance;
	
	// Damage can be on master object (fleet file) which are system based. The UI in the Fleet Maint just gets the first terminal on the user, we will use the last on root.
	defterm := root.allTerminals.last;

	
	create objArr transient;
	CM_DamageInstance.allInstances(objArr, 0, true);
	
	beginTransaction;
	foreach damage in objArr as CM_DamageInstance do
	
		if damage.myDamageSeverity = null then
			if damage.mySubject &lt;&gt; null then // Tracked Item, Wagon, Fleet File; null subject is because it has been deleted.
				term := damage.mySubject.getMyTerminal();
			endif;
			
			if term = null then // probably the fleet file
				term := defterm;
			endif;
			
			if term &lt;&gt; null then
				
				severity := term.allDamageSeverities[damage.severity.String];
				
				if severity &lt;&gt; null then
					damage.setPropertyValue("myDamageSeverity", severity);
				endif;
			endif;
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Convert Severity on Damage Instances", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Severity on Damage Instances") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	abortTransaction;
	delete objSet;
	delete objArr;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAllMutexes" id="636df3f4-fd61-4526-9fbb-be18808c072a">
        <source>convertAllMutexes(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2021	navndl1	Initial creation	TFS 51142

*/

vars

	objArray : ObjectArray;
	root : CM_Root;
	term : CM_Terminal;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert BGP Mutexes", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert BGP Mutexes") ;	
	endif;
	
	create objArray transient;
	BGP_Mutex.allInstances( objArray, 0, true );
	
	root := app.myRoot;
	
	beginTransaction;
	if not objArray.isEmpty then
		objArray.purge();
	endif;
	
	root.addUpdateRootMutexes();
	
	foreach term in root.allTerminals do
		term.addUpdateTerminalMutexes();
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all BGP Mutexes converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all BGP Mutexes converted") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete objArray;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAllRTVehicleConfigs" id="01fbd673-ef98-48aa-ab3b-ff4408796e6f">
        <source>convertAllRTVehicleConfigs(_controller: CnEcReleaseController);
/*

Purpose:			Rename all RT Config EntTableView objects to include a separator between Terminal Code and Machine Type Code.
					So things like SCT + 2 and SCT2 don't run into conflicts.
					(so that then becomes SCT/2 which isn't the same as SCT2)

Parameters:			

Return Value:		

Date				Who		Reason
17 February 2023	navmd1	Initial creation TFS 56666 SNO - 1310 when creating new Terminal level RT Config

*/

constants
	UpdateMode = true;
vars
	oa 			: ObjectArray;
	machConfig 	: CM_RTTermMachTypeConfig;
	machType	: CM_MachineType;
	config		: CM_RTVehicleConfig;
	views		: StringArray;
	kvPair		: String;
	pos			: Integer;
	oldName,
	newName,
	viewName,
	propName	: String;
	etView		: EntTableView;
	term		: CM_Terminal;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Renaming RT Vehicle Config Views", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Renaming RT Vehicle Config Views") ;	
	endif;
	
	create views transient;
	views.add("myPrimaryCargoFields|primary cargo");
	views.add("myPrimaryDirectorFields|primary director");
	views.add("myPrimaryTaskFields|primary tasks");
	
	views.add("mySecondaryCargoFields|secondary cargo");
	views.add("mySecondaryDirectorFields|secondary director");
	views.add("mySecondaryTaskFields|secondary tasks");
	
	views.add("myVisibleCargoFields|cargo view");
	views.add("myVisibleDirectorFields|director view");
	views.add("myVisibleTaskFields|task view");	
	
	create oa transient;
	CM_RTVehicleConfig.allInstances(oa, 0, false);
	
	beginTransaction;
	foreach config in oa as CM_RTVehicleConfig do
		
		// 3 types of config to 'deal' with (in order)
		
		// 1. Machine Level
		if config.myMachine &lt;&gt; null then
			term := config.myMachine.myTerminal;
			
			app.writeLog("Converting Machine Level Config: [" &amp; term.code &amp; "] " &amp; config.myMachine.code, LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry(" Converting Machine Level Config: [" &amp; term.code &amp; "] " &amp; config.myMachine.code);
			endif;
			
		// 2. Terminal Level
		elseif config.myTerminal &lt;&gt; null then
			term := config.myTerminal;
			
			app.writeLog("Converting Terminal Level Config: [" &amp; term.code &amp; "]", LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry(" Converting Terminal Level Config: [" &amp; term.code &amp; "]");
			endif;
			
		// 3. Machine Type Level
		elseif config.myTerminalMachineType &lt;&gt; null then
			machConfig := config.myTerminalMachineType;
			machType := config.myTerminalMachineType.myMachineType;
			term := config.myTerminalMachineType.myTerminal;
			
			// Dmast has some crap in it... on the off chance customers do as well ...
			if term = null or machType = null then
				app.writeLog("BAD DATA for CM_RTTermMachTypeConfig " &amp; machConfig.getOidAsString &amp; ", skipping", LogERROR);
				if _controller &lt;&gt; null then
					_controller.logEntry(" BAD DATA for CM_RTTermMachTypeConfig " &amp; machConfig.getOidAsString &amp; ", skipping");
				endif;
				continue;
			endif;
		
			app.writeLog("Converting Machine Type Level Config: [" &amp; term.code &amp; "] " &amp; machType.description, LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry(" Converting Machine Type Level Config: [" &amp; term.code &amp; "] " &amp; machType.description);
			endif;
		
		else
			// Bad Data!
			// Lets record it if it gets this far
			app.writeLog("BAD DATA for CM_RTVehicleConfig " &amp; config.getOidAsString &amp; ", skipping", LogERROR);
			if _controller &lt;&gt; null then
				_controller.logEntry(" BAD DATA for CM_RTVehicleConfig " &amp; config.getOidAsString &amp; ", skipping");
			endif;
			continue;
		endif;
		
		// Actually, this will run after getUniqueViewName has been updated, so we can offload the hard work of working out the new name to it
		// Meaning that we can handle all 3 configs in the same way :O
		
		foreach kvPair in views do
			pos := 1;
			propName := kvPair.cnGetToken(pos, "|");
			viewName := kvPair.cnGetToken(pos, "|");
			
			// Make sure the view is populated, skip if its not
			etView := config.getPropertyValue(propName).EntTableView;
			if etView = null then
				continue;
			endif;
		
			oldName := etView.name;
			newName := config.getUniqueViewName() &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; viewName;	// eg, SCT/2/primary cargo vs SCT2/primary cargo
			
			app.writeLog(Tab &amp; "Renaming [" &amp; oldName &amp; "] to [" &amp; newName &amp; "]", LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry(" " &amp; Tab &amp; "Renaming [" &amp; oldName &amp; "] to [" &amp; newName &amp; "]");
			endif;
			
			etView.set(newName, etView.description, etView.myEntTableDef);
		endforeach;
		
		// No need to do hook codes, as they are only on the Terminal level config, and thats just the Terminal Code!
		// Plus their names don't seem to need to be unique
		
	endforeach;
	
	if UpdateMode then
		commitTransaction;
	else
		// addScriptRun goes into transaction state :\
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " all RT Vehicle Config Views Renamed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all RT Vehicle Config Views Renamed") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	abortTransaction;
	
	delete views;
	delete oa;
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertBOLTypeAbbrv" id="087f384d-2c9d-4d09-89df-44c0529a8888">
        <source>convertBOLTypeAbbrv(_controller : CnEcReleaseController);
/*

Purpose:	There are 3 system CM_BOLType. Two of them have the same abbreviation as 2 system CM_CargoType. 
			This creates an issue in the new stop YA criteria, which contain CM_CargoType and CM_BOLType, 
			because if the 2 CM_BOLType are selected, it is the CM_CargoType that is saved.	
			Changing the abbreviation of the system CM_BOLTypes.
			We are not sure how many, if any, clients use CM_BOLTypes on stops; and those that do may have created CM_CargoTypes called LOGD or GEND, but the risk is very small.

Parameters:			

Return Value:		

Date		Who		Reason
25OCT2022	navab1	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	bolType : CM_BOLType;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " CM_BOLType", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" On Stops Table") ;	
	endif;
	
	bolType := app.myRoot.allBOLTypes[BOLType_Log];
	if bolType &lt;&gt; null then
		beginTransaction;
		bolType.setPropertyValue("abbreviation","LOGD");
		commitTransaction;
	endif;
	bolType := app.myRoot.allBOLTypes[BOLType_GeneralDocket];
	if bolType &lt;&gt; null then
		beginTransaction;
		bolType.setPropertyValue("abbreviation","GEND");
		commitTransaction;
	endif;

	app.writeLog(method.qualifiedName &amp; " COMPLETE CM_BOLType", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" COMPLETE CM_BOLType") ;
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertDIStatus" id="027ae514-6bb8-41d8-85c7-284ea15024e8">
        <source>convertDIStatus(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	terminal : CM_Terminal;
	dInstance	:CM_DamageInstance;
	objArr 		: ObjectArray;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Damage Status", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Damage Status") ;	
	endif;
	
	create objArr transient;
	CM_DamageInstance.allInstances(objArr, 0, true);
	
	beginTransaction;
	
	foreach dInstance in objArr as CM_DamageInstance do
		if dInstance.repaired then
			dInstance.setStatus(DamageStatusRepaired);
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all Damage Status converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all Damage Status converted") ;
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertEDIDataXlationOperator" id="03eb5023-4b47-4961-b016-2c283cf011f7">
        <source>convertEDIDataXlationOperator(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading

*/

vars
	root  			     : CM_Root;
	terminal			 : CM_Terminal;
	ediData				 : CM_EDIData;
	xlationOperatorCode	 : String;
	stateData 			 : CM_StateData;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting xlationOperatorCode to be stored into CM_EDIData::xlationOperatorCode attribute", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting xlationOperatorCode to be stored into CM_EDIData::xlationOperatorCode attribute") ;	
	endif;
	
	root := app.myRoot;
	
	beginTransaction;
	
	foreach terminal in root.allTerminals  do 
		foreach ediData in terminal.myEdiConfig.ediDatas do
			
			if ediData.allExtraData.isEmpty then
				continue;
			endif;
			
			/*
			1- ETRow_XlateOperatorCode
			*/
			stateData			:= null;
			xlationOperatorCode := null;
			
			stateData 			:= ediData.allExtraData[ETRow_XlateOperatorCode];
			
			if stateData &lt;&gt; null then
				xlationOperatorCode	:= stateData.getValue().String;
				ediData.zSetXlationOperatorCode(xlationOperatorCode[1:4]);
				
				delete  stateData;
			endif;		
			
		endforeach;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Converting xlationOperatorCode to be stored into CM_EDIData::xlationOperatorCode attribute complete", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting xlationOperatorCode to be stored into CM_EDIData::xlationOperatorCode attribute complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertEDITIExtraData" id="6a407f9f-3539-4ac9-9cc6-bd024cbd6e4e">
        <source>convertEDITIExtraData(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading

*/

vars
	ediTi					: CM_EDITrackedItem;	
	ediData  			    : CM_EDIData;
	extraVoyageCode,
	extraCommodity,
	extralClientRef1,
	extraClientRef2,
	extraVehicle,
	extraSalesOrderNo		: String;
	root					: CM_Root;
	term					: CM_Terminal;
	extaData 			 	: CM_StateData;
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting CM_EDITrackedItem.allExtraData to be stored into rawDataVoyageCode,rawDataCommodity,clientRef1,clientRef2,vehicle and clientRef ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting CM_EDITrackedItem.allExtraData to be stored into rawDataVoyageCode,rawDataCommodity,clientRef1,clientRef2,vehicle and clientRef") ;	
	endif;
	
	root := app.myRoot;
	
	beginTransaction;
	
	foreach term in root.allTerminals  do 
		foreach ediData in term.myEdiConfig.ediDatas do
			foreach ediTi in ediData.allEDITrackedItems do 
				if ediTi.getAllExtraData.isEmpty then
					continue;
				endif;
				
				
				/*
				1- Key = ETRow_VoyageCode , CM_EDITrackedItem::rawDataVoyageCode
				*/
				extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[ETRow_VoyageCode];
				if extaData &lt;&gt; null then
					extraVoyageCode := extaData.getValue().String;
					ediTi.saveRawVoyageCode(extraVoyageCode);
					delete  extaData;
				endif;
				
				/*
				2- Key = ETRow_Commodity , CM_EDITrackedItem::rawDataCommodity
				*/
				extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[ETRow_Commodity];
				if extaData &lt;&gt; null then
					extraCommodity := extaData.getValue().String;
					ediTi.saveRawCommodityCode(extraCommodity);
					delete  extaData;
				endif;
				
				if ediTi.isKindOf(CM_EDIBOLHdrTI) then
					/*
					3- Key = CM_BOL::clientRef1.name , CM_EDIBOLHdrTI::clientRef2 
					*/
					extaData						:= null;
					extaData 					    := ediTi.getAllExtraData[CM_BOL::clientRef1.name];
					if extaData &lt;&gt; null  then
						extralClientRef1 := extaData.getValue().String;
						ediTi.CM_EDIBOLHdrTI.setServiceOrderNbr(extralClientRef1);
						delete  extaData;
					endif;
					
					/*
					4-Key = CM_BOL::clientRef2.name , CM_EDIBOLHdrTI::clientRef2
					*/
					extaData						:= null;
					extaData 					    := ediTi.getAllExtraData[CM_BOL::clientRef2.name];
					if extaData &lt;&gt; null  then
						extraClientRef2 := extaData.getValue().String;
						ediTi.CM_EDIBOLHdrTI.setPONbr(extraClientRef2);
						delete  extaData;
					endif;
					
					/*
					5- Key = CM_BOL::vehicle.name , CM_EDIBOLHdrTI::vehicle
					*/
					extaData						:= null;
					extaData 					    := ediTi.getAllExtraData[CM_BOL::vehicle.name];
					if extaData &lt;&gt; null   then
						extraVehicle := extaData.getValue().String;
						ediTi.CM_EDIBOLHdrTI.setVehicle(extraVehicle);
						delete  extaData;
					endif;
				endif;
				
				if ediTi.isKindOf(CM_EDICargoTI) then
					/*
					6- Key = ETRow_SalesOrderNbr , CM_EDICargoTI::clientRef
					*/
					extaData						:= null;
					extaData 					    := ediTi.getAllExtraData[ETRow_SalesOrderNbr];
					if extaData &lt;&gt; null   then
						extraSalesOrderNo := extaData.getValue().String;
						ediTi.CM_EDICargoTI.setSalesOrderNbr(extraSalesOrderNo);
						delete  extaData;
					endif;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Converting CM_EDITrackedItem.allExtraData to be stored into rawDataVoyageCode,rawDataCommodity,clientRef1,clientRef2,vehicle and clientRef complete", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting CM_EDITrackedItem.allExtraData to be stored into rawDataVoyageCode,rawDataCommodity,clientRef1,clientRef2,vehicle and clientRef complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertIndextoLineNumber" id="4de9d898-14f8-43b5-a75a-6eba8ecd8976">
        <updating/>
        <source>convertIndextoLineNumber(_controller: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level

*/

vars
	reserveSelection : CM_ReserveSelection;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Convert Index to LineNumber", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Convert Index to LineNumber") ;	
	endif;
	beginTransaction;
		foreach reserveSelection in CM_ReserveSelection.instances do
			if reserveSelection.lineNumber = null and reserveSelection.myReserveHeader &lt;&gt; null then
				reserveSelection.setLineNumber(reserveSelection.myReserveHeader.allReserveDetails.indexOf(reserveSelection));
			endif;
		endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all line numbers converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all line numberss converted");
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
