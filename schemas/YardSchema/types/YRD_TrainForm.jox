    <JadeMethod name="doTransitWagons" id="94bd853e-6549-4a75-9715-f598d8c2d1f4">
        <updating/>
        <source>doTransitWagons(_status : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwndl1	Initial creation

*/

vars
theReturn : Integer;
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_WagonSet;
	tmpStr : String;	
begin


	create objArray transient;
	
	foreach obj in self.tblWagons.allSelectedObjects discreteLock do
		wagon := obj.CM_Wagon;
		objArray.add(wagon);
		if tmpStr = null then
			tmpStr := wagon.id;
		else
			tmpStr := tmpStr &amp; ", " &amp; wagon.id;
		endif;
	endforeach;
	
	if warnedOfNoSelectedData(objArray,app.getErrorString(Wagon) ) then
		return;
	endif;

	if _status = TI_IMEX_STATUS_REMAINONBOARD then
		if app.msgBox(app.getErrorString1(Please_Confirm_Intransit, tmpStr), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	elseif _status = TI_IMEX_STATUS_EXPORT then
		if app.msgBox(app.getErrorString1(Please_Confirm_Not_Intransit, tmpStr), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWagonInTransit(objArray, _status, app.myPassport); // TI_IMEX_STATUS_TRANSIT
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog
	delete objArray;
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUpdateWagonConfirmToRail" id="8be9ad71-4515-41b3-ae59-e92b1a8f7c9d">
        <updating/>
        <source>doUpdateWagonConfirmToRail() updating;
// ---------------------------------------------------------------------------
// Created:     08 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wagMoveController : CMIF_WagonMoveController;
	theRailLine :CM_RailLine;
	theRail : CM_Rail;
	pos, theReturn : Integer;
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_WagonArray;
	tmpStr : String;
	tmpStr3 : String;
begin

	if not self.selectWagonFromRange() then
		return;
	endif;
	
	create objArray transient;
	
	if self.tblWagons.allSelectedObjects.isEmpty() then
		self.tblWagons.selectAll();
	endif;
	
	// PAR 20594 - make sure that the selected items are confirmed in the train order
	foreach wagon in self.mySelectedTrain.allWagonsByOrderInward discreteLock do
		if self.tblWagons.allSelectedObjects.includes(wagon) then
			objArray.add(wagon);
			if tmpStr = null then
				tmpStr := wagon.id;
			else
				tmpStr := tmpStr &amp; ", " &amp; wagon.id;
			endif;
		endif;
	endforeach;
	
	if objArray.isEmpty() then
		return;
	endif;

	theRail := self.cmbAreas.listObject.CM_Rail;
	if theRail = null then
		app.msgBox(app.getErrorString(Must_enter_rail_positio), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	theRailLine := self.cmbPosition.listObject.CM_RailLine;
	
	if theRailLine = null then
		app.msgBox(app.getErrorString(Must_enter_rail_positio), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	pos := self.cmbPosition.itemData[self.cmbPosition.listIndex];
	
	if app.msgBox(app.getErrorString2(Pleas_confi_that_want_confi_ra, tmpStr, theRailLine.getDisplayDetails(false)), app.getErrorString(Move_rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	//26 Aug 2020	NDL	TFS 49950
	foreach wagon in objArray do
		if wagon.confirmed then
			if tmpStr3 = null then
				tmpStr3 := wagon.id;
			else
				tmpStr3 := tmpStr3 &amp; ", " &amp; wagon.id;
			endif;
		endif;
	endforeach;
	if tmpStr3 &lt;&gt; null then
		tmpStr := app.getErrorString2( Wagons_Already_confirm, tmpStr3, app.getErrorString( Inward ) );
		tmpStr := tmpStr &amp; CrLf &amp; app.getErrorString( These_will_ignored );
		app.msgBox( tmpStr, app.getErrorString(Wagon_confirmation), MsgBox_Exclamation_Mark_Icon);
	endif;


	app.mousePointer := Window.MousePointer_HourGlass;
	create wagMoveController transient;
	wagMoveController.myTargetRailLine := theRailLine;
	wagMoveController.targetPosition := pos;
	objArray.copy( wagMoveController.allWagons);
	wagMoveController.doAutoPlanOfCargo := (app.msgBox(app.getErrorString(Want_autop_cargo_into_yard), app.getErrorString(DO_AUTOPLAN_YA) &amp; '?',MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes);
	wagMoveController.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	
	app.myPassport.setWarningsIgnored(false);	//18 Dec 2009	NDL Par 22035
	
	while true do

		app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveController,  app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Train_confirmation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	self.frmConfirmIN.visible := false;

epilog
	delete wagMoveController;
	delete objArray;

	
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doWagonConfirm" id="472db984-7dbe-4b7a-84c3-cc43e6ef638c">
        <updating/>
        <source>doWagonConfirm(_inward : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
theReturn : Integer;
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_WagonArray;
	tmpStr,tmpStr2, areaStr : String;	
	control : CMIF_WagonMoveController;
	tmpStr3 : String;
	msg : String;
begin
	if _inward then
		areaStr := app.getErrorString(Inward_Rail);
	else
		areaStr := app.getErrorString(Outward_Rail);
	endif;
	


	create objArray transient;
	create control transient;
	
	foreach obj in self.tblWagons.allSelectedObjects discreteLock do
	
		wagon := obj.CM_Wagon;
		
		if wagon.myRailLine = null then
			if tmpStr2 = null then
				tmpStr2 := wagon.id;
			else
				tmpStr2 := tmpStr2 &amp; ", " &amp; wagon.id;
			endif;
			continue;
		endif;
		
		objArray.add(wagon);
		if tmpStr = null then
			tmpStr := wagon.id;
		else
			tmpStr := tmpStr &amp; ", " &amp; wagon.id;
		endif;
		
		//08 Jun 2020	NDL	TFS 49498
		if ( _inward and wagon.confirmed )
		or ( not _inward and wagon.confirmedOutwards )
		then
			if tmpStr3 = null then
				tmpStr3 := wagon.id;
			else
				tmpStr3 := tmpStr3 &amp; ", " &amp; wagon.id;
			endif;
		endif;
		
	endforeach;
	
	//08 Jun 2020	NDL	TFS 49498
	if tmpStr3 &lt;&gt; null then
		if _inward then
			msg := app.getErrorString2( Wagons_Already_confirm, tmpStr3, app.getErrorString( Inward ) );
		else
			msg := app.getErrorString2( Wagons_Already_confirm, tmpStr3, app.getErrorString( Outward ) );
		endif;
		app.msgBox( msg, app.getErrorString(Wagon_confirmation), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if tmpStr2 &lt;&gt; null then
		app.msgBox(app.getErrorString1(Canno_confi_they_have_been_ass, tmpStr2), app.getErrorString(Wagon_confirmation), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if objArray.isEmpty() then
		return;
	endif;

	if app.msgBox(app.getErrorString2(Pleas_confi_that_want_confi_wa, tmpStr, areaStr), app.getErrorString(Wagon_confirmation), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;

	if _inward then //Par 21041
		// PAR 20531
		control.doAutoPlanOfCargo := (app.msgBox(app.getErrorString(Want_autop_cargo_into_yard), app.getErrorString(DO_AUTOPLAN_YA) &amp; '?',MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes);
	endif;
	
	control.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	
	while true do
		app.myTrxUA.trxUpdateWagonConfirm(objArray, _inward, control, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog
	delete objArray;
	delete control;
end;</source>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doWagonUnplan" id="21818818-8418-4459-a625-19f4320f0332">
        <updating/>
        <source>doWagonUnplan() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	moveController  : CMIF_WagonMoveController;
	wagon			: CM_Wagon;
	result,
	int				: Integer;
	str				: String;
begin
	foreach wagon in self.tblWagons.allSelectedObjects as CM_Wagon do
		if str = "" then
			str := wagon.id;
		else
			str := str &amp; Comma &amp; wagon.id; 
		endif;
	endforeach;
	int := app.msgBox(app.getErrorString1(Sure_that_want_unplan_wagons,str), app.getErrorString(Warning), MsgBox_OK_Cancel);
	if int &lt;&gt; MsgBox_Return_OK then
		return;
	else
		create moveController transient;
		foreach wagon in self.tblWagons.allSelectedObjects as CM_Wagon do
			moveController.allWagons.add(wagon);
		endforeach;
		moveController.setMoveMode(UNPLAN_MODE);
		while true do
			app.myTrxUA.trxMoveWagons(moveController, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
			else
				result := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ...
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
epilog
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="doWagonUpDown" id="6c3b7f4f-b0c6-4d92-abab-4a61100be55f">
        <updating/>
        <source>doWagonUpDown(_up : Boolean) updating;

/*

Purpose:		Move selected wagons 1 position (relative the wagons' positions on the train).

Parameters:		_up: true to move towards the head of the train, false to move towards the tail of the train

Return Value:		


Date		Who		Reason
18 Jun 2009	consw1	Par 20001 - Initial creation
*/

vars
	moveController : CMIF_WagonMoveController;
	selectedWagons : CM_WagonSet;
	wagonsOnTrain : CM_WagonArray;
	wagon : CM_Wagon;
	wagonForDrop : CM_Wagon;
	wagonNextAdjacent : CM_Wagon;
	
begin
	if self.mySelectedTrain = null or self.tblWagons.allSelectedObjects.isEmpty then
		return;
	endif;

	create selectedWagons transient;
	self.tblWagons.allSelectedObjects.copy(selectedWagons);

	//  Tidy up any left over move controllers

	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	endif;
	app.myMoveController := null;
	if global.isValidObject(app.myWagonMoveController) then
		delete app.myWagonMoveController;
	endif;

	create moveController transient;	
	app.myWagonMoveController := moveController;
	moveController.isFromTrain := true;
	moveController.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837

	//  Do the moves using the starting order of the wagons on train to avoid side effects

	create wagonsOnTrain transient;
	if self.optDirInTB.value then
		self.mySelectedTrain.allWagonsByOrderInward.copy(wagonsOnTrain);
	else
		self.mySelectedTrain.allWagonsByOrderOutward.copy(wagonsOnTrain);
	endif;

	if _up then
		foreach wagon in wagonsOnTrain do
			if selectedWagons.includes(wagon) then
				moveController.allWagons.add(wagon);
			else
				if not moveController.allWagons.isEmpty then
					if wagonForDrop = null then
						// already at the head of the train
						moveController.allWagons.clear();
					else
						self.wagonReceiveDrop(wagonForDrop);
						create moveController transient;	
						app.myWagonMoveController := moveController;
						moveController.isFromTrain := true;
					endif;
				endif;
				wagonForDrop := wagon;
			endif;
		endforeach;
		if not moveController.allWagons.isEmpty and wagonForDrop &lt;&gt; null then
			self.wagonReceiveDrop(wagonForDrop);
		endif;
	else
		foreach wagon in wagonsOnTrain reversed do
			if selectedWagons.includes(wagon) then
				moveController.allWagons.insert(1, wagon);
			else
				if not moveController.allWagons.isEmpty then
					if wagonNextAdjacent = null then
						// already at the end of the train
						wagonNextAdjacent := moveController.allWagons.first;
						moveController.allWagons.clear();
					else
						self.wagonReceiveDrop(wagonForDrop);
						create moveController transient;	
						app.myWagonMoveController := moveController;
						moveController.isFromTrain := true;
					endif;
				endif;
				wagonForDrop := wagonNextAdjacent;
				wagonNextAdjacent := wagon;
			endif;
		endforeach;
		if not moveController.allWagons.isEmpty and wagonNextAdjacent &lt;&gt; null then
			self.wagonReceiveDrop(wagonForDrop);
		endif;
	endif;
	
epilog
	delete app.myWagonMoveController;
	delete selectedWagons;
	delete wagonsOnTrain;
end;</source>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dragWagon" id="e8319778-4275-4723-961c-197c4d60fffa">
        <updating/>
        <source>dragWagon() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 24/08/2022 	navsj20		ChangeRequest 54281: EUP - Wagon Track Planning

// ---------------------------------------------------------------------------
vars
	moveController	: CMIF_WagonMoveController;
	picture			: Picture;

begin
	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	endif;

	app.myMoveController := null;
	
	if global.isValidObject(app.myWagonMoveController) then
		delete app.myWagonMoveController;
	endif;

	create moveController transient;	
	app.myWagonMoveController := moveController;
	
	moveController.isFromTrain := true;
	moveController.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	moveController.setMoveMode(self.getMoveMode);	//24 Aug 2022	navsj20	TFS 54281

	self.tblWagons.allSelectedObjects.copy(moveController.allWagons);

	if moveController.allWagons.isEmpty then
		delete app.myWagonMoveController;
		return;
	endif;
	
	self.tblWagons.dragMode := DragMode_Drag;
	
	create picture transient;
	self.setPictureDragCursor(picture);
	if picture &lt;&gt; null then
		self.tblWagons.dragCursor := picture.picture;
	endif;
	
	self.tblWagons.dragCursor := self.picMvWagon.picture;
	// START 24 Aug 2022	navsj20	TFS 54281
	if self.moveModeForm = PLANNING_MODE then
		self.tblWagons.dragCursor := self.picMvWagonPln.picture;
	endif;
	// END 24 Aug 2022	navsj20	TFS 54281
	
epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;
</source>
    </JadeMethod>
