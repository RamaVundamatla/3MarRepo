    <JadeMethod name="getLinkedBookingIds" id="ea0999e9-e6ff-4e33-baed-0f64b3d6bc5d">
        <source>getLinkedBookingIds(_dinaDict : DynaDictionary input; _linkedIdArray : StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2017	cnwndl1	Initial creation TFS 3703
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/

vars
	bookingIDs		: StringArray;
	iter : Iterator;
	ediTI : CM_EDITrackedItem;
	ediBookRefItem : CM_EDIBookingItemTI;
	allIDsString : String;
	idString : String;
begin
	create bookingIDs transient;
	if _dinaDict = null or _dinaDict.isEmpty then
		return;
	endif;
	
	iter := _dinaDict.createIterator;

	while iter.next(ediTI) do
		if ediTI.isKindOf(CM_EDIBookingItemTI) then
			ediBookRefItem := ediTI.CM_EDIBookingItemTI;
			allIDsString := ediBookRefItem.linkedBookingIDs.trimBlanks;
			if allIDsString = null then
				continue;
			endif;
			allIDsString := allIDsString.cnEcFindReplace( SingleQuote, DoubleQuote, false );
			bookingIDs.clear();
			allIDsString.csvToStringArray( bookingIDs, Space.Character );
			if bookingIDs.isEmpty then
				continue;
			endif;
			foreach idString in bookingIDs do
				if not _linkedIdArray.includes( idString ) then
					_linkedIdArray.add( idString );
				endif;
			endforeach;
		endif;
	endwhile;
epilog
	delete bookingIDs;
	delete iter;
end;</source>
        <Parameter name="_dinaDict" type="DynaDictionary" usage="input"/>
        <Parameter name="_linkedIdArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isCoparnFile" id="7afb1a4b-81a0-490a-8e1e-a0a87b29941a">
        <source>isCoparnFile(_ediData : CM_EDIData) : Boolean;
/*

Purpose:			Returns true if data is from a coparn file

Parameters:			_ediData : the data being worked on

Return Value:		true if edi data is a coparn file

Date			Who		Reason
02 May 2019		jlgzm1	TFS 43425 SNO append new bookings rather than replace

*/
vars
	file : CM_EDIFile;
	result : Boolean;
begin
	file := _ediData.myEDIFile;

	if file &lt;&gt; null and file.myEDIFileType &lt;&gt; null then
		result := file.myEDIFileType.type = EDIFileType_Coparn;
	endif;
	
	return result;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForEDIMode" id="220b2925-7fc1-4658-8304-83bdaef173ce">
        <source>isValidForEDIMode(_realBookingRef : CM_BookingRef; _ediBookingHeaderTI : CM_EDIBookingHeaderTI; _ediMode : String; _extraInfo : String output) : Boolean protected;
//
// Par21718 cnwrs1 dec 2009
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	ediIsOlder	: Boolean;
	tmpEdiMode	: String;
begin

	//checking whether EDI file is not old
	if _realBookingRef = null then	// EDI date time is always valid - there is no date time at all
		ediIsOlder := false;
		
	elseif _realBookingRef.ediFileIssueDateTime = null then	//// EDI date time is always valid - there is no date time at all
		ediIsOlder := false;
	
	elseif _ediBookingHeaderTI.ediFileIssueDateTime = null then	//assume that _ediBookingRefTI &lt;&gt; null always. 
		ediIsOlder := false;
	else	//when both dates &lt;&gt; null
		ediIsOlder := _realBookingRef.ediFileIssueDateTime &gt; _ediBookingHeaderTI.ediFileIssueDateTime;
	endif;
	
	if _ediMode = CM_EDITrackedItem.EDI_ACTION_ADD then
		tmpEdiMode := app.getErrorString(EDIData_ModeADD);
	elseif _ediMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then
		tmpEdiMode := app.getErrorString(EDIData_ModeUPDATE);
	else
		tmpEdiMode := app.getErrorString(EDIData_ModeDELETE);
	endif;

	// prepare extraInfo for audit information (CM_AuditObjectInformation)
	if ediIsOlder then		// cannot load EDI file - it is older than current _realBookingRef.ediFileIssueDateTime

		_extraInfo := app.getErrorString1(EDIModeIgnored, tmpEdiMode) &amp;" "
					&amp; app.getErrorString3(EDIFileIsOlderThanCurrent, _ediBookingHeaderTI.myEDIData.fileName, _ediBookingHeaderTI.ediFileIssueDateTime.asStringJMT(), _realBookingRef.ediFileIssueDateTime.asStringJMT() );
	else // can load EDI file - it is fresh or there are issue dates = null
	
		_extraInfo := app.getErrorString(EDIMode) &amp;" "&amp; tmpEdiMode &amp; ". "
					&amp; app.getErrorString2(EDIFileNameCreatedDateTime, _ediBookingHeaderTI.myEDIData.fileName, _ediBookingHeaderTI.ediFileIssueDateTime.asStringJMT() );
	endif;
	return not ediIsOlder;	// when ediIsOlder - cannot load EDI
end;</source>
        <access>protected</access>
        <Parameter name="_realBookingRef" type="CM_BookingRef"/>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_ediMode" type="String"/>
        <Parameter name="_extraInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processEDIReleaseRequestTIs" id="506b9356-fe49-48c9-a16a-5b57fc23151e">
        <source>processEDIReleaseRequestTIs(_verifyOnly : Boolean; _allReleaseRequestTIs : CM_EDITIById input;  _passport : CM_Passport input)  : Boolean protected;
/*

Date		Who		Reason
24 June 2015	cnwer1	PAR 36534 TFS 371 Initial creation PAR 301 handling to do with the handling of empties
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	releaseEDIData 	: CM_EDIDataReleaseRequest;
	clonedEDITI,
	ediTI 			: CM_EDITrackedItem;
	iter,
	iter2  			: Iterator;
	result 			: Boolean;
	ediData : CM_EDIData;
	error : CM_Error;
begin
	if _allReleaseRequestTIs = null or _allReleaseRequestTIs.isEmpty then
		return false;
	endif;
	ediData := _allReleaseRequestTIs.first.myEDIData;
	releaseEDIData := self.cloneSelfAs(CM_EDIDataReleaseRequest, true).CM_EDIDataReleaseRequest;
	releaseEDIData.setEDIConfig(ediData.ediConfig);
//	releaseEDIData.myOperator := self.myOperator;
	releaseEDIData.setOperator(self.myOperator);
	foreach ediTI in _allReleaseRequestTIs do
		clonedEDITI := ediTI.cloneSelf(true);
		clonedEDITI.setMyEDIData(releaseEDIData);
		clonedEDITI.setMyEDIConfig(releaseEDIData.ediConfig);
	endforeach;
	if _verifyOnly then
		releaseEDIData.verifyEDIDataTIs(_passport);		
	else
		releaseEDIData.loadDB(false, _passport);	
	endif;

	result := _passport.hasErrors;
	iter := _allReleaseRequestTIs.createIterator;
	iter2 := releaseEDIData.allEDITrackedItems.createIterator;
	while iter.next(ediTI) do
		iter2.next(clonedEDITI);
		
		app.myTrxUA.trxUpdateEDITIStatus(ediTI, clonedEDITI.status, _passport);
		if _passport.allErrorWarnings.size &gt; 0 then
			foreach error in _passport.allErrorWarnings do
				if error.myUserObject = clonedEDITI then
					error.setMyUserObject(ediTI);
				endif;
			endforeach;
		endif;
	endwhile;
	
	return result;
epilog
	delete releaseEDIData;
	delete iter;
	delete iter2;
end;</source>
        <access>protected</access>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_allReleaseRequestTIs" type="CM_EDITIById" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processEDITI" id="121e0c23-de9d-429a-bfd3-1427560ed712">
        <updating/>
        <source>processEDITI(_ediBookingHeaderTI : CM_EDIBookingHeaderTI input; _cmifBookingRef : CMIF_BookingRef io; _cmifEDIBookingRef : CMIF_EDIBookingRef io; _verifyOnly : Boolean; _noErrors, _errors, _warnings : Boolean io; _passport: CM_Passport input) protected, updating;
//
// par 26223 cnwrs1 8 Nov 2010
//
//this method process a single EDI Ti and exists so the code onkly eists once

// 26 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094 - change of parameters
// 01 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	terminal : CM_Terminal;
begin
	terminal := self.getMyTerminal;
	
	if _verifyOnly then 
		if _passport.noErrors and _passport.noWarnings then
			app.myTrxUA.trxUpdateEDITIStatus(_ediBookingHeaderTI, CM_EDITrackedItem.EDI_STATUS_VERIFIED, _passport);
			
			_noErrors := true;
		else
			if _passport.noErrors then
				app.myTrxUA.trxUpdateEDITIStatus(_ediBookingHeaderTI, CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS, _passport);
				_warnings := true;
			else
				app.myTrxUA.trxUpdateEDITIStatus(_ediBookingHeaderTI, CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS, _passport);
				_errors := true;
			endif;
		endif;
	else 
		if not _passport.noErrors then 				//Got Errors
			app.myTrxUA.trxUpdateEDITIStatus(_ediBookingHeaderTI, CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS, _passport);
			_errors := true;
		else																	//No Errors
			// go to trx
			self.processingBookingRefTrx(_cmifBookingRef, _ediBookingHeaderTI, _cmifEDIBookingRef, terminal, _passport);
			
			if _passport.noErrors then
				app.myTrxUA.trxUpdateEDITIStatus(_ediBookingHeaderTI, CM_EDITrackedItem.EDI_STATUS_DBLOADED, _passport);
				_noErrors := true;
			else
				app.myTrxUA.trxUpdateEDITIStatus(_ediBookingHeaderTI, CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS, _passport);
				_errors := true;
			endif;
		endif;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI" usage="input"/>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef" usage="io"/>
        <Parameter name="_cmifEDIBookingRef" type="CMIF_EDIBookingRef" usage="io"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_noErrors" type="Boolean" usage="io"/>
        <Parameter name="_errors" type="Boolean" usage="io"/>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processEDITIs" id="769df5d6-9d1e-47a6-9543-5defad4a16db">
        <updating/>
        <source>processEDITIs(_allEDITIs : CM_EDITIById; _verifyOnly : Boolean; _passport: CM_Passport input; _allMatchedBRItems : CM_BookingRefItemDict io) updating;
/*
//
// par 26223 cnwrs1 8 Nov 2010
//

// This method goes thru all the EDI TIs and builds the booking ref and its item then either validates it anmd set the tio status or
// validates it loads it thru the TRX and set the reqiured status 

Date		Who		TFS			Reason
------------------------------------------------------------------------------------------------------------------------------------
14/07/2011	cnwcs5	par26557 - ensure errors userObject is set to correct EDI tracked items and not booking/booking reference
09 Dec 2011	cnwrs1	CCMS POL 2122 / PAR 28696 - add myparent to sort table
02 Jul 2012	cnwrs1	Par 29927 	EDI Booking Item replace not working
12 Oct 2012	cnwrs1	Par 30446 	booking not being created by getting dbloaded status
05/04/2013	cnwcs5	CCMS POL 2097 / par 31259
26 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094 - change of parameters
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fail
29 Jun 2015	cnwer1	PAR 36534 	TFS 371 301 release of empties - also creating release requests
08 Oct 2015	cnwrs1	Par 36863  	make EDI consistant times when refreshing progress bar
19 Jan 2016	cnwrs1	Par 37427 	reallow booking partial loading to work
13 May 2016	cnwns1	TFS 488  	Multi Timezone Support
25 Oct 2016	cnwmp6	Par 38302 	stop failed EDI booking being continually reprocessed
31 Oct 2016	cnwrs1	TFS 2896  	HSD Sequence are no booking item numbers.
10 Nov 2017	jlgrs1	TFS 5705  	SNO - EDIDataBooking Prenote release Req
15 Dec 2017	jlgrs1	TFS 8281  	SNO - 
27 Mar 2019 jlgsl4	TFS 44030  	SNO - enforce callsign check for multiple translations
02 May 2019	jlgzm1	TFS 43425 	SNO - Append new bookings rather than replace
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
06 Nov 2019	jlgzm1	TFS 47229	SNO Update COPARN messgaes appending not replacing
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
------------------------------------------------------------------------------------------------------------------------------------
*/
vars
	terminal 					: CM_Terminal;
	ediBookingHeaderTI,
	ediBookingHeaderTI_Previous : CM_EDIBookingHeaderTI;
	ediBookingItemTI 			: CM_EDIBookingItemTI;
	realBookingRef, 
	pxyBookingRef 				: CM_BookingRef;
	cmifEDIBookingRef 			: CMIF_EDIBookingRef;
	cmifBookingRef 				: CMIF_BookingRef;
	cmifBookingRefItem			: CMIF_BookingRefItem;
	dinaDict 					: DynaDictionary;
	iter 						: Iterator;
	ediTI 						: CM_EDITrackedItem;
	todo, done 					: Integer;
	foundMatch					: Boolean;
	operator 					: CM_Operator;
	voyage 						: CM_Voyage;
	voyageCode, newVoyageCode 	: String;
	noErrors 					: Boolean; 
	warnings, errors 			: Boolean;
//	tmpStatus 					: Integer;
	errorSet 					: CM_ErrorSet;
	ediUserObjects				: DynaDictionary;
	pxyBookingRefItem			: CM_BookingRefItem;
	tmpHazards					: ObjectArray;				// 25/02/2013 cnwmh5 #31192
	allReleaseRequestTIs		: CM_EDITIById;
	progressTS 					: TimeStamp;
	progressStr					: String;
	allToDoRemarks 				: CM_EDITISet;	//10 Oct 2016	NDL	TFS 2001 / 2792
	ediToDoRemarksTI 			: CM_EDITaskRemarkRelBookTI;	//10 Oct 2016	NDL	TFS 2001 / 2792
	allHazDetails 				: CM_EDITISet;	//21 Nov 2016	NDL	TFS 2843 / 2604
	allEdiSorted 				: CM_EDITIArray;	//13 Mar 2017	NDl	TFS 3703
	linkedIdArray 				: StringArray;	//13 Mar 2017	NDl	TFS 3703
	ediData 					: CM_EDIData;
	ediFile 					: CM_EDIFile;			//TFS 43425
	isCoparn 					: Boolean;				//TFS 43425
	senderCode 					: String;			//TFS 43425
	coparnRules 				: CM_EDIPartyCoparnRules;	//TFS 43425
begin
	// Arm our base exception handlers
//	on Exception do validationExceptionHandler(exception, _passport);
	
	progressTS := app.actualTimeServer();	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	_passport.clearErrorsWarnings();
	
	terminal := self.getMyTerminal();
	
	ediData := _allEDITIs.first.myEDIData;
	isCoparn := self.isCoparnFile(ediData); // tfs43425
	
	if _verifyOnly then
		progressStr := "Verifying EDI Booking References";
	else
		progressStr := "Creating/Updating EDI Booking References";
	endif;
	
	app.setContinueCMExceptions(true);
	
	done := 0;
	todo := _allEDITIs.size;
	
	// par 26557 - create collection to link booking/booking items with their corresponding 
	// edi tracked items
	create ediUserObjects transient;
	ediUserObjects.setMembership (CM_EDITrackedItem);
	ediUserObjects.addExternalKey (CM_Object, null, false, false);	// will be CM_BookingrRf or CM_BookingRefItem
	ediUserObjects.endKeys (false);
	
	create errorSet transient;
	create cmifEDIBookingRef transient;	// creating new one for next portion
	create dinaDict transient;
	create tmpHazards transient;
	create allReleaseRequestTIs transient;
	create allToDoRemarks transient;
	create allHazDetails transient; //21 Nov 2016	NDL	TFS 2843 / 2604
	
	dinaDict.setMembership(CM_EDITrackedItem);
	dinaDict.addMemberKey(CM_EDITrackedItem::id.name, false, false);
	dinaDict.addMemberKey(CM_EDITrackedItem::myParent.name, false, false);
	dinaDict.addMemberKey(CM_EDITrackedItem::messageNum.name, false, false);
	dinaDict.endKeys(true);
	
	_allEDITIs.copy(dinaDict); // initial sort based on dina dict keys.
	
	//13 Mar 2017	NDL	TFS 3703 - look for interdependant links between stock bookings and exports
	create linkedIdArray transient;
	self.getLinkedBookingIds( dinaDict, linkedIdArray );
	
	if linkedIdArray.isEmpty then	//13 Mar 2017	NDL	TFS 3703
		// no additional sorting required.
		iter := dinaDict.createIterator;
	else
		//13 Mar 2017	NDL	TFS 3703
		create allEdiSorted transient;
		self.sortLinkedToStart(dinaDict, linkedIdArray, allEdiSorted);
		iter := allEdiSorted.createIterator;
	endif;
	
	ediData.updateProgress(progressTS, progressStr, todo, done, true, _passport);
	
	while iter.next(ediTI) do
		done := done + 1;
		ediData.updateProgress(progressTS, progressStr, todo, done, false, _passport);
		
		if ediTI.isKindOf(CM_EDIBookingHeaderTI) then
			ediBookingHeaderTI := ediTI.CM_EDIBookingHeaderTI;
		
			if ediBookingHeaderTI.status = CM_EDIFile.EDI_STATUS_DBLOADED then
//				noErrors := true;
				continue;
			endif;
			
			// tfs 43425 start
			// get rules first time round only
			if isCoparn and senderCode = null then
				senderCode := ediBookingHeaderTI.senderCode;
				coparnRules := ediData.getEDIPartyCoparnRules(senderCode);
				if coparnRules &lt;&gt; null then
					self.appendBookings := coparnRules.appendNewBookings;
				endif;
			endif;
			// tfs 43425 end
			
			operator := app.myRoot.allOperators[ediBookingHeaderTI.operatorCode];	//par26681 cnwrs1 31 dec 2010
			
			if self.status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL or
			   self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS then
				//par 26195 cnwrs1 23 nov 2010
				if ediBookingHeaderTI.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or
				   ediBookingHeaderTI.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or
				   ediBookingHeaderTI.status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS then
					voyageCode 	:= ediBookingHeaderTI.getVoyageCode();
					voyage 		:= terminal.lookupVoyage(voyageCode, null, false);
					
					if voyage = null and
					   operator &lt;&gt; null then	//par26681 cnwrs1 31 dec 2010 // TFS 44030 replaced 2 nulls below with Lloyds and callsign
						newVoyageCode := operator.getXlationSystemCode_Voyage(voyageCode, ediBookingHeaderTI.vesselName, ediBookingHeaderTI.lloydsNumber, ediBookingHeaderTI.callsign, foundMatch); // TFS 44030
						if newVoyageCode &lt;&gt; null and voyageCode &lt;&gt; newVoyageCode then
							beginTransaction;
							ediBookingHeaderTI.setVoyageCode(newVoyageCode);
							commitTransaction;
						endif;
					endif;
				endif;
			endif;	
			if ediBookingHeaderTI_Previous = null or	// the first iteration
				ediBookingHeaderTI_Previous = ediBookingHeaderTI then
				// there is multi booking ref, i.e. several containers on a booking ref. Should be the same cmifBookingRef 
				// creation CMIF_BookingRef or updating existing one.
			
				self.setupBookingHeader(ediBookingHeaderTI, cmifEDIBookingRef, realBookingRef, cmifBookingRef, ediBookingHeaderTI_Previous); //cnwrs1 par 26223 8 nov 2010    //!!!!!!!!!!!!!!!!!!!!!!!!!!!!  Line 133
				_allMatchedBRItems.clear;		//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
				pxyBookingRef := cmifBookingRef.myProxyBookingRef;
				
				if ediBookingHeaderTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then	// TFS 47229
					// only append if is an Add, Updates should replace
					cmifBookingRef.appendBookings := self.appendBookings; // tfs43425
				endif;
				
				if ediBookingHeaderTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
					self.verifyEDITIBookingHeader(ediBookingHeaderTI, pxyBookingRef, voyage, _passport);
//					if not _passport.noErrors then	//13 Mar 2012	cnwrs1	Par 29260 unit test failing
//						errors := true;
//					endif;
				endif;
				// we may have errors reported with a userObject of the CMIF or the booking - keep record of which EDI TI they relate to
				self.setCrossReference (ediUserObjects, cmifEDIBookingRef, ediBookingHeaderTI);
				self.setCrossReference (ediUserObjects, pxyBookingRef, ediBookingHeaderTI);
				
				continue;	// go on until other cmifBookingRef is created
			else			// when there is a change in the bookingheader
				self.processEDITI(ediBookingHeaderTI_Previous, cmifBookingRef, cmifEDIBookingRef, _verifyOnly, noErrors, errors, warnings, _passport);						//!!!!!!!!!!!!!!!!!!!!!!!!!!!!!  Line 149
				
				_passport.moveErrorsToSet(errorSet); //save off all current errors
				
				delete cmifEDIBookingRef;
				// now process new booking ref
				create cmifEDIBookingRef transient;	// creating new one for next portion
				self.setupBookingHeader(ediBookingHeaderTI, cmifEDIBookingRef, realBookingRef, cmifBookingRef, ediBookingHeaderTI_Previous); //cnwrs1 par 26223 8 nov 2010				//!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Line 156
				pxyBookingRef := cmifBookingRef.myProxyBookingRef;
				
				if ediBookingHeaderTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then // TFS 47229
					// only append if is an Add, Updates should replace
					cmifBookingRef.appendBookings := self.appendBookings; // tfs43425
				endif;
				
				if ediBookingHeaderTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
					self.verifyEDITIBookingHeader(ediBookingHeaderTI, pxyBookingRef, voyage, _passport);
					if not _passport.noErrors then	//13 Mar 2012	cnwrs1	Par 29260 unit test failing
						errors := true;
					endif;
				endif;
				
				// we may have errors reported with a userObject of the CMIF or the booking - keep record of which EDI TI they relate to
				self.setCrossReference (ediUserObjects, cmifEDIBookingRef, ediBookingHeaderTI);
				self.setCrossReference (ediUserObjects, pxyBookingRef, ediBookingHeaderTI);
			endif;
		elseif ediTI.isKindOf(CM_EDIBookingItemTI) then
			ediBookingItemTI := ediTI.CM_EDIBookingItemTI;
			
			// 26/02/2013 cnwmh5 #31192
			if tmpHazards &lt;&gt; null then
				tmpHazards.purge();
			endif;
			ediBookingItemTI.getProxyHazards(ediBookingItemTI.imCodes, tmpHazards, false);  			// true);  // 17/03/2014 cnwmh5 #33648

			if ediBookingHeaderTI = null or 
			   ediBookingHeaderTI.status = CM_EDIFile.EDI_STATUS_DBLOADED then
				continue;
			endif;
			// booking item validation 
			self.verifyEDITIBookingItem1(ediBookingHeaderTI, ediBookingItemTI, _passport);
			
			operator := app.myRoot.allOperators[ediBookingHeaderTI.operatorCode];
			
			// more booking item validation
			ediBookingItemTI.validateLinkedBookingIDs(ediBookingHeaderTI, terminal, operator, voyage);
			
			cmifBookingRefItem := self.setupBookingItem(ediBookingItemTI, realBookingRef, cmifBookingRef, _allMatchedBRItems); //cnwrs1 par 26223 8 nov 2010		//!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Line 189
            
			pxyBookingRef 		:= cmifBookingRef.myProxyBookingRef;
			// some validation errors are raised against the proxy booking item - we need to cross reference it.
			// the booking item proxy will be the last one created - relying on dictionary key of creation time
			pxyBookingRefItem	:= pxyBookingRef.allBookingRefItems.last;
			
			// more booking item validation using CMIF_BookingRef
			self.verifyEDITIBookingItem2(ediBookingHeaderTI, ediBookingItemTI, pxyBookingRef, realBookingRef, cmifBookingRef, _passport);

			// we may have errors reported with a userObject of the CMIF or the booking - keep record of which EDI TI they relate to
			self.setCrossReference (ediUserObjects, cmifBookingRefItem, ediBookingItemTI);

			if pxyBookingRefItem &lt;&gt; null then
				self.setCrossReference (ediUserObjects, pxyBookingRefItem, ediBookingItemTI);
			endif;
		elseif ediTI.isKindOf(CM_EDITaskRemarkRelBookTI) then	//10 Oct 2016	NDL	TFS 2001 / 2792
			allToDoRemarks.add( ediTI );
		elseif ediTI.isKindOf(CM_EDIHazDetailsTI) then	//21 Nov 2016	NDL	TFS 2843 / 2604
			allHazDetails.add( ediTI );
		endif;
		//epr TFS 371 24/6/15 301 handling to do with the handling of empties
		if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
			allReleaseRequestTIs.add(ediTI);
		endif;
	endwhile;
	
	ediData.updateProgress(progressTS, progressStr, todo, done, true, _passport);
	
	//10 Oct 2016	NDL	TFS 2001 / 2792
	if not allToDoRemarks.isEmpty then
		self.verifyToDoEDITIs( allToDoRemarks, cmifBookingRef );
	endif;
	
	//21 Nov 2016	NDL	TFS 2843 / 2604
	if not allHazDetails.isEmpty then
		self.verifyHazEDITIs( allHazDetails, cmifBookingRef );
	endif;
	
	if ediBookingHeaderTI_Previous &lt;&gt; null and	// the last item in the loop wasn't processed - just proceed cmifBookingRef and exit
	   ediBookingHeaderTI_Previous.status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED then
		self.processEDITI(ediBookingHeaderTI_Previous, cmifBookingRef, cmifEDIBookingRef, _verifyOnly, noErrors, errors, warnings, _passport);
	endif;
	
	//epr TFS 371 24/6/15 301 handling to do with the handling of empties
	if ediBookingHeaderTI = null then
		noErrors := true;
	endif;
	//epr TFS 371 24/6/15 301 handling to do with the handling of empties
	if self.processEDIReleaseRequestTIs(_verifyOnly,allReleaseRequestTIs,_passport) then
		errors := true;
		noErrors := false;
	endif;	
	
	_passport.addErrorsFromSet(errorSet);	//restore current errors back to
	self.updateErrorUserObjects(_passport.allErrorWarnings, ediUserObjects);	// par 26557
	
	//epr par 37090 23/10/15
//	tmpStatus:=self.getStatusAfterVerifyOrDBLoad(_verifyOnly,_passport);
// cnwrs1 put this back
	if _passport.hasErrors then
		errors := true;
		noErrors := false;
	endif;

	self.setEDITIStatusFromErrors(_verifyOnly, _passport);
epilog
	delete iter;
	delete dinaDict;
	delete cmifEDIBookingRef;
	delete errorSet;
	
	if tmpHazards &lt;&gt; null then
		tmpHazards.purge;
		delete tmpHazards;
	endif;
	
	delete ediUserObjects;
	delete allReleaseRequestTIs;
	delete allToDoRemarks;
	delete allHazDetails; //21 Nov 2016	NDL	TFS 2843 / 2604
	delete allEdiSorted;
	delete linkedIdArray;
end;
</source>
        <Parameter name="_allEDITIs" type="CM_EDITIById"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_allMatchedBRItems" type="CM_BookingRefItemDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processingBookingRefCreateTrx" id="fbc24b99-46ba-485e-882d-3e78ca0d6206">
        <updating/>
        <source>processingBookingRefCreateTrx(_cmifBookingRef : CMIF_BookingRef input; _ediBookingHeaderTI : CM_EDIBookingHeaderTI; _extraInfo: String; _terminal : CM_Terminal; _passport : CM_Passport input) updating, protected;
//
// par21719 cnwrs1 dec 2009
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	realBookingRef : CM_BookingRef;
	realReleaseObj : CM_BulkRelease;
	pxyReleaseObj : CM_BulkRelease;

begin

	pxyReleaseObj := _cmifBookingRef.createReleaseProxyFromEDIBook(_ediBookingHeaderTI.releaseRequestNumber, _ediBookingHeaderTI.subTerminalCode, _cmifBookingRef, _terminal);
	app.myTrxCA.trxCreateBookingBulkRel_CMIF(_cmifBookingRef,null, _passport, null, realBookingRef, pxyReleaseObj, realReleaseObj, _extraInfo);

epilog
	if pxyReleaseObj &lt;&gt; null then
		delete pxyReleaseObj;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_extraInfo" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processingBookingRefTrx" id="137c8435-2e4b-4fab-942a-62785fd70483">
        <updating/>
        <source>processingBookingRefTrx(_cmifBookingRef : CMIF_BookingRef input; _ediBookingHeaderTI : CM_EDIBookingHeaderTI;_cmifAgent : CMIF_EDIBookingRef input; _terminal : CM_Terminal; _passport : CM_Passport input) updating, protected;
//
// par21718 cnwrs1 dec 2009
//
// 03/04/2012	cnwcs5	par 29326 - send email if booking cannot be deleted in file (only do this once)
// 08/08/2012	cnwcs5	par 30042 - make email on delete of non-existent booking conditional
//13 May 2015	cnwrs1	Par 36099 - never create an error when deleting EDI booking ref
//20 May 2015   cnwma1  Par 36183 - JH - HSD COPARN updates reducing booking items are not been applied to the booking reducing - High
//09 jun 2015   cnwma1  Par 36409 - EDI tracker 547170# BGP_Generic Controller, system alerts EDI controller (4) . (object Not Found)
//28 Oct 2016	cnwrs1	TFS 2896 - add booking id to 89805 error
//31 Oct 2016	cnwrs1	TFS 2896 - HSD Sequence are no booking item numbers.
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	ediAction 			: String;
	cmifBookingRefItem 	: CMIF_BookingRefItem; //cnwrs1 CCMS 1882 25 May 2010
	realBookingRef 		: CM_BookingRef;
	expectedEdition		: Integer;
	extraInfo 			: String;
	subject, message,
	strType				: String;				// par 29326 - april 2012
	ediFile				: CM_EDIFile;			// par 29326 - april 2012
	ediData				: CM_EDIData;			// par 29326 - april 2012
	ediFileType			: CM_EDIFileType;		// par 29326 - april 2012
	objItems,objItemsDel: ObjectArray;
	bookingItem	    	: Object;
	bkRefItem			: CM_BookingRefItem;
	deleteMissingItems  : Boolean;
	errSeq,errID	    : String;
	isInvalid : Boolean;
begin
	app.myPassport.setWarningsIgnored(true); //cnwrs1 19 May 2010 unit test stopped working
	
	if _cmifBookingRef.allCMIF_BRItems.size &gt; 1 then
		_cmifBookingRef.myProxyBookingRef.setIsMultiItem(true);
	endif;
	_cmifBookingRef.myProxyBookingRef.pxyGetRealObjectAndEdition(realBookingRef, expectedEdition);
	
	
	//----------------------------------------------------------------------------
	// 						processing in EDI action mode 
	//----------------------------------------------------------------------------

	ediAction := _cmifBookingRef.getEDIAction(); 

	if ediAction = CM_EDITrackedItem.EDI_ACTION_ADD or			
		ediAction = CM_EDITrackedItem.EDI_ACTION_UPDATE then	
	
		if self.isValidForEDIMode(realBookingRef, _ediBookingHeaderTI, ediAction, extraInfo) then
			if realBookingRef &lt;&gt; null then	
				// if realBookingRef exists, then replace it regardless  of what the mode on the edi tracked item is
				if app.myRoot.isClientJadeMaster or app.myRoot.isClientPortOtago then  // 18-05-2015 cnwma1 PAR #36183
//					if _ediBookingHeaderTI.operatorCode &lt;&gt; "HSD" then
						app.myTrxUA.trxUpdateBookingRefMulti(_cmifBookingRef, _passport, _ediBookingHeaderTI);
//					endif;
				else
					app.myTrxUA.trxUpdateBookingRefMulti(_cmifBookingRef, _passport, _ediBookingHeaderTI);
				endif;
				// Delete Missing HSD Items for Otago
/*				if app.myRoot.isClientJadeMaster or app.myRoot.isClientPortOtago then  // 18-05-2015 cnwma1 PAR #36183
					if _ediBookingHeaderTI.operatorCode = "HSD" then 
						create objItems transient;   	 // 18-05-2015 cnwma1 PAR #36183
						create objItemsDel transient;  	 // 18-05-2015 cnwma1 PAR #36183
						foreach  bookingItem in self.allEDITrackedItems do // 18-05-2015 cnwma1 PAR #36183
							if bookingItem.isKindOf(CM_EDIBookingItemTI) then
								objItems.add(bookingItem);
							endif;	
						endforeach;
						if realBookingRef&lt;&gt; null then				 // 18-05-2015 cnwma1 PAR #36183
							if realBookingRef.isSequenced() then
								if _cmifBookingRef.allCMIF_BRItems.size &gt;1 then
									if _cmifBookingRef.allCMIF_BRItems.size &lt;&gt; objItems.size then
										ediAction := CM_EDITrackedItem.EDI_ACTION_DELETE;
										deleteMissingItems := true;
									endif;
								endif;
								if deleteMissingItems  then
									realBookingRef.allBookingRefItems.copy(objItemsDel);					 // 18-05-2015 cnwma1 PAR #36183
									foreach bookingItem in objItems do												 // 18-05-2015 cnwma1 PAR #36183
										foreach bkRefItem in realBookingRef.allBookingRefItems    do
											if bookingItem.CM_EDIBookingItemTI.sequence = bkRefItem.sequence  then
												//if  not bkRefItem.allTIs.size &gt; 0 then						//09/06/2015 cnwma1 PAR#36409
													objItemsDel.remove(bkRefItem);
													break;
												//endif;
											endif;
										endforeach;
									endforeach;
									app.myTrxUA.trxUpdateBookingRefMulti(_cmifBookingRef, _passport, _ediBookingHeaderTI);
									foreach bookingItem in objItemsDel do							              // 18-05-2015 cnwma1 PAR #36183
										on Exception do app.handleDeletedObject(exception, bookingItem, isInvalid);		//09/06/2015 cnwma1 PAR#36409
										if bookingItem &lt;&gt;  null then														//09/06/2015 cnwma1 PAR#36409
											message := bookingItem.asStringJMT;
											if not isInvalid then										//09/06/2015 cnwma1 PAR#36409
												if not bookingItem.CM_BookingRefItem.allTIs.size &gt; 0 then
													app.myTrxDA.trxDeleteEDIBookingRefItem(bookingItem.CM_BookingRefItem, extraInfo, _passport); //delete the booking item
												else
													//app.raiseCMException1( EDI_Action_Is_Invalid, ediAction, ETRow_MessageMode, null );
													errSeq := "Booking "&amp;bookingItem.CM_BookingRefItem.myBookingReference.bookingReference&amp;" Seq "&amp;bookingItem.CM_BookingRefItem.sequence;
													errID := bookingItem.CM_BookingRefItem.allTIs.first.id;
													errID :=  errID ;										
												endif;
											endif;
										endif;
									endforeach;
									if errSeq &lt;&gt; null then
										app.raiseCMException2(CannotDeleteBRItem2, errSeq, errID, "", null );
									endif;
								else
									app.myTrxUA.trxUpdateBookingRefMulti(_cmifBookingRef, _passport, _ediBookingHeaderTI);
								endif;
							endif;
						endif;
					endif;
				endif;*/
				// End Delete Missing HSD Items for Otago
			else
				self.processingBookingRefCreateTrx(_cmifBookingRef, _ediBookingHeaderTI, extraInfo, _terminal, _passport);
			endif;
		else	
			// cannot load EDI file, because EDI is older - just create a CM_AuditObjectInformation
			app.myTrxCA.trxCreateAuditInformation(realBookingRef, extraInfo, _passport);
		endif;
	
	elseif ediAction = CM_EDITrackedItem.EDI_ACTION_DELETE then	// MES1008 JMH 29/9/09
		if realBookingRef &lt;&gt; null then 
		
			if self.isValidForEDIMode(realBookingRef, _ediBookingHeaderTI, ediAction, extraInfo) then
							
				if realBookingRef.isSequenced() then
					foreach cmifBookingRefItem in _cmifBookingRef.allCMIF_BRItems do  
						if cmifBookingRefItem.myRealBookingRefItem &lt;&gt; null then
							if not cmifBookingRefItem.myRealBookingRefItem.allTIs.size &gt; 0 then
								if cmifBookingRefItem.sequence = cmifBookingRefItem.myRealBookingRefItem.sequence then
									app.myTrxDA.trxDeleteEDIBookingRefItem(cmifBookingRefItem.myRealBookingRefItem, extraInfo, _passport); //delete the booking item
								endif;
							else
								errSeq := "Booking "&amp;cmifBookingRefItem.myRealBookingRefItem.myBookingReference.bookingReference&amp;" Seq "&amp;cmifBookingRefItem.sequence;
								errID := cmifBookingRefItem.myRealBookingRefItem.allTIs.first.id;
								app.raiseCMException2(CannotDeleteBRItem2, errSeq, errID,"",  null);
							endif;
						endif;
					endforeach;
					if realBookingRef.allBookingRefItems.size = 0 then
						app.myTrxDA.trxDeleteEDIBookingRef(realBookingRef, extraInfo, _passport);	
					endif;
				else
					app.myTrxDA.trxDeleteEDIBookingRef(realBookingRef, extraInfo, _passport); //delete the booking ref
				endif;
			else	
				// cannot load EDI file, because EDI is older - just create a CM_AuditObjectInformation
				app.myTrxCA.trxCreateAuditInformation(realBookingRef, extraInfo, _passport);
			endif;
		else  
			// par 30042 - make email when no booking found to delete conditional
			if _terminal.getConfig (EdiBookingEmailNoDelete).Boolean then 
				// par 29326 - send email if we get a delete message and we can't find the booking to delete it
				// we have a delete message but we have not found a booking to delete
				// send an email to the supporters email address saying this has happened.
				subject := 'Booking ' &amp; _ediBookingHeaderTI.id &amp; ' for operator ' &amp; _ediBookingHeaderTI.operatorCode &amp; ' could not be deleted by EDI';
				
				ediData	:= _ediBookingHeaderTI.myEDIData;
				
				if ediData &lt;&gt; null then
					ediFile := ediData.myEDIFile;
				endif;
				
				if ediFile &lt;&gt; null then
					ediFileType := ediFile.myEDIFileType;
					
					if ediFileType &lt;&gt; null then
						strType := ediFileType.name;
					else
						strType := '&lt;Unknown file type&gt;';
					endif;
					
					message	:= strType &amp; ' ' &amp; ediFile.fileName &amp; ' loaded ' &amp; ediFile.fileCreatedTs.asStringJMT;
				endif;
				
				app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(BGP_Processing), 
														app.myRoot.getConfig(AutoSupportEmailAddress).String,	
														app.myRoot.getConfig(AutoSendersEmailAddress).String,
														null, null, 
														subject, message, 
														null, null, null, null, 
														EmailSource_System,  null, _passport);
			endif;
		endif;
		
	else
		app.raiseCMException1( EDI_Action_Is_Invalid, ediAction, ETRow_MessageMode, null );
	endif;
epilog
	if objItems &lt;&gt; null then
		delete objItems;
	endif;
	if objItemsDel &lt;&gt; null then
		delete objItemsDel;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_cmifAgent" type="CMIF_EDIBookingRef" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
