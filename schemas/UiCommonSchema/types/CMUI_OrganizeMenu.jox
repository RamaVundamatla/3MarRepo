        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstBox_mouseMove(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     24 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
begin
	if button = 1 and app.dragDetected(x, y, self.origXPos, self.origYPos) then
		if button = 1 and listbox.listIndex &gt;= 1 then
			self.dragMode := DragMode_Drag;
		endif;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
