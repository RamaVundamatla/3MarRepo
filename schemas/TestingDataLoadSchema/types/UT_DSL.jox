    <JadeMethod name="deleteDamage" id="2ef1c129-11aa-4852-bbd5-86f8457128c9">
        <source>deleteDamage(_damageId : String);

/*

Purpose:		Delete a Damage	

Date			Who		Reason
14/12/2011		cnwmh5	Initial creation

*/

vars

	damage			: CM_DamageDefinitionCode;
	cargoType		: CM_CargoType;
	damageInstance	: CM_DamageInstance;
	
begin

	damage := app.myRoot.allDamageDefinitionCodes[_damageId];
	if damage &lt;&gt; null then
		beginTransaction;															// 18/09/2012 cnwmh5
		foreach cargoType in damage.allCargoTypes do
			if cargoType.allDamageDefinitionCodes.includes(damage) then
				cargoType.allDamageDefinitionCodes.remove(damage);
			endif;
		endforeach;
		commitTransaction;
		// 15/07/2016 cnwmh5 - need to check to see if there is any cargo that has this damage type
		beginTransaction;
		foreach damageInstance in damage.allDamageInstancesByDamagePos do
			delete damageInstance;
		endforeach;		
		commitTransaction;
		app.myTrxDA.trxDeleteDamageDefCode(damage, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_damageId" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteDamagePosition" id="e1777690-b951-4447-ac86-350484802a2c">
        <source>deleteDamagePosition(_damagePositionCode : String);
//  Created by cnwsh3
//	Date 23 July 2009
//
// Implemented version: 7.7.3

//----------------------------------------------------------------------
// 20/06/2012	cnwmh5	Change so that removes all active cargo types
vars
	damagePos : CM_DamagePosition;
	root : CM_Root;
	cargoType : CM_CargoType;
	damageInstance  : CM_DamageInstance;
begin
	root := CM_Root.firstInstance();
	damagePos := root.allDamagePositionsByCode[_damagePositionCode];
	//app.myPassport.setWarningsIgnored(true);
	if damagePos &lt;&gt; null then
		
		beginTransaction;
		foreach cargoType in app.myRoot.allCargoTypesById do
			if cargoType.allDamagePositions.includes(damagePos) then
				cargoType.allDamagePositions.remove(damagePos);
			endif;
		endforeach;
		
		// 16/03/2016 cnwmh5 - Remove damaage from ti's then delete damange instance
		foreach damageInstance in damagePos.allDamageInstances do
			delete damageInstance;
		endforeach;

		commitTransaction;
		
		app.myTrxDA.trxDeleteDamagePosition(damagePos, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
epilog
end;</source>
        <Parameter name="_damagePositionCode" type="String"/>
    </JadeMethod>
