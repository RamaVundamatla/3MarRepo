    <JadeMethod name="getBOL" id="e9d2bc9f-ea7a-4f6f-a72d-1192ac66e0c7">
        <source>getBOL(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	returnStr : String;

begin
	
	if self.myReserveSelection &lt;&gt; null then
		if self.myReserveSelection.myBOLIn &lt;&gt; null then
			returnStr := self.myReserveSelection.myBOLIn.number;
		endif;
	endif;
	if returnStr = null then
		if self.myRequest &lt;&gt; null and self.myRequest.getBOL &lt;&gt; null then
			returnStr := self.myRequest.getBOL.number;
		endif;
	endif;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="119cff1b-e5ff-4f9e-94aa-b7b1ceea2011">
        <source>getCargoType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	ct : CM_CargoType;
	returnStr : String;

begin
	
	if self.myReserveSelection &lt;&gt; null then
		ct := self.myReserveSelection.getCargoType;
	endif;
	if ct = null then
		if self.myRequest &lt;&gt; null then
			ct := self.myRequest.getCargoType;
		endif;
	endif;
	
	if ct &lt;&gt; null then
		returnStr := ct.description;
	endif;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
