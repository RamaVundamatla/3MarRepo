// ---------------------------------------------------------------------------
// Created:		12 October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myChildQuantityMap.validateInvLineDescUsedTranMap(_invLineDesc) then
		return true;
	endif;
	
	return false;
end;</source>
