    <JadeMethod name="isContainerLength_Match" id="c8254226-7c91-4b8b-9919-8479cc3d5c30">
        <source>isContainerLength_Match(_yaData: CM_YADataObjects): Boolean;
//29 August 2008	cnwdw1	
//
vars
	containerLength : CMIF_ContainerLength;
begin

	if not self.myTrackedItem.isContainer() then
		return false;
	endif;
	
	create containerLength transient;
	self.myTrackedItem.getContainerLength(containerLength);
	
	// Only priorities will be empty.
	if containerLength.length &lt;&gt; 0 and _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isContainerLength_Compare, containerLength);

epilog
	delete containerLength;
end;</source>
