    <JadeMethod name="addWarningFullPassport" id="b25a1b14-0efa-4554-90fe-6b92763f70c1">
        <updating/>
        <source>addWarningFullPassport(pErrorCode : Integer; pText, pField : String; pObject : Object; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
