    <JadeMethod name="setForUpdate" id="02707aed-8be4-4b1d-b561-55c4289d2e48">
        <updating/>
        <source>setForUpdate(pProxyRestriction : CM_Restriction) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	pProxyRestriction.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.colour 		:= pProxyRestriction.colour;
	self.userCode		:= pProxyRestriction.userCode;
	self.comment		:= pProxyRestriction.comment.trimBlanks;

end;</source>
        <Parameter name="pProxyRestriction" type="CM_Restriction"/>
    </JadeMethod>
    <JadeMethod name="validate" id="1ddd34ea-5db3-4727-b6f8-3cc3750599b1">
        <source>validate();
// -------------------------------------------
// Created 03 August 2004 by cnwdvb1
// -------------------------------------------
vars

	tmpUser	: CM_User;
	tmpTA	: CM_TerminalArea;

begin

	
	tmpUser := app.myRoot.allUsers[self.userCode.toUpper];
	if tmpUser = null and self.userCode &lt;&gt; SUPERUSER_Str then
		app.raiseCMException1(ERR_REST_INV_USER, self.userCode, null, null);
	endif;

end;</source>
    </JadeMethod>
