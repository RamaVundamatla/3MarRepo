    <JadeMethod name="resetColl" id="a3a04e55-18f9-44f0-bbab-32b090f7af2e">
        <source>resetColl() protected;
// -------------------------------------------
// Created 24 September 2003 by cnwdvb1
// -------------------------------------------
vars

	iter 	: Iterator;
	entity	: CM_EmailEntity;

begin

	self.allEmailAddresses.clear();
	iter := app.myRoot.allEmailEntities.createIterator();
	while iter.next(entity) do
		if entity.type = Email_Address then
			self.allEmailAddresses.add(entity.CM_EmailAddress2);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="b7eb6931-18ec-4e93-845e-521204a9a39d">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.tblInput1.hideRowByName(ETRow_Groups, false);
	theForm.tblInput1.hideRowByName(ETRow_CamsProtocols, false);
	
//	self.setupCmbAutoReply(theForm.cmbAutoReply);
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_EmailAddress);
		theForm.tblInput1.enableRowByName(ETRow_Title);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_EmailAddress2);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_EmailAddress);
		theForm.tblInput1.enableRowByName(ETRow_Title);
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="04bc26ee-6653-4e1a-9db2-eda497919aab">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.showRowByName(ETRow_Groups, false);
	theForm.tblInput1.showRowByName(ETRow_CamsProtocols, false);
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="0e564b81-b345-47af-9834-3672430569df">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_EmailAddressMaintTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_EmailAddress, false);
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_EmailAddressMaint);
	theForm.shtTblInput1.visible := true;
	theForm.myAssistant.comboBoxAutoReply(theForm.cmbAutoReply);
	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="19911033-b5fe-431f-9c43-c5c535fe4b80">
        <updating/>
        <source>showThumbnail(pEmailAddress: CM_EmailAddress2) updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setTableFromObject(pEmailAddress, null);
	theForm.tblInput1.setValueByName(ETRow_EmailAddress, pEmailAddress.emailAddress);
	theForm.tblInput1.setValueByName(ETRow_Title,	pEmailAddress.name);
	theForm.tblInput1.setValueByName(ETRow_CamsProtocols, pEmailAddress.getDisplayStringForAttribute(ETRow_CamsProtocols, false));
	theForm.tblInput1.setValueByName(ETRow_Groups,	pEmailAddress.getDisplayStringForAttribute(ETRow_Groups, false));
	
	theForm.cmbAutoReply.setIndexForItemData(pEmailAddress.autoReplyOption);
	theForm.tblInput1.setValueByName(ETRow_AutoReplyOption,	theForm.cmbAutoReply.text);

end;</source>
        <Parameter name="pEmailAddress" type="CM_EmailAddress2"/>
    </JadeMethod>
</Class>
