    <JadeWebServicesMethod name="getGateCheckerDetails" id="25e1d7f0-d114-4435-b17f-fa4979311a6f">
        <source>getGateCheckerDetails(_request : WS_GateCheckerQueryRequest) : WS_GateCheckerResponse webService;

/*
Purpose:			
Date				Who			Reason
25 Feb 2016 cnwma1   TFS 1488 JMT Mobile Apps - RecRel -  Gate Checker
25 Jul 2016 cnwma1   TFS 2273 JMT - Mobile Apps - Gate Checker Issues
16 Apr 2018 jlgmd1	 TFS 37997 MSL - Gate Checker - web application
*/
vars
response			  	: WS_GateCheckerResponse;
	completedOK			  	: Boolean;
	gateCheckerController 	: CMIF_MobileGateChecker;
	terminal 			  	: CM_Terminal;
	ti 					  	: CM_TrackedItem;
	wle 				  	: CM_WorkListEntry;
	wsTI 				  	: WS_TrackedItem;
	truck 				  	: CM_Vehicle;
	gate 				  	: CM_Gate;
	wleArray 			  	: CM_WLEArray;
	gateLane			  	: CM_LocationsController;
	idx						: Integer;
	gateArea				: CM_TerminalArea;
	errMsg					: String;
	glc 					: CM_GateAreaLaneController;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	app.checkCurrentUserHasAccess(PmHandHeldGateChecker);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if _request.vehicle = null then     //cnwma1 25/07/2016 TFS #2273
		app.raiseCMException1(Enter_truck, null, null, null);
		completedOK := true;
		return response;
	endif;
	// SETUP RESPONSE
	terminal := app.myPassport.myTerminal;

	//Setup Gate Lane 
	//gate := terminal.allGates[_request.gate];
	idx := _request.lane.pos("Lane",1) - 1;			// TFS 37997 jlgmd1 16/04/2018
	// getTAFromClassString does a lazy match, and returns the first one it finds, so to try and avoid matching the wrong one
	// lets help it out a bit by setting its start index to our lane name.
	gateArea := terminal.getTAFromClassString(_request.lane ,idx,CM_GateArea);
	if gateArea = null then
		app.raiseCMException1(Lane_not_found, _request.lane, null, null);
		completedOK := true;
		return response;
	endif;
	
	foreach  gateLane in gateArea.allLocationsControllers do
	 if gateLane.isKindOf(CM_GateAreaLaneController) then
		if gateLane.getNiceName = _request.lane then
			glc:= gateLane.CM_GateAreaLaneController;
			break;
		endif;
	 endif;
	endforeach;
	
	// While GateAreaLaneControllers can be null, in this situation it shouldn't be, unless we haven't been able to find it for some reason
	if glc = null then															// TFS 37997 jlgmd1 16/04/2018
		app.raiseCMException1(Lane_not_found, _request.lane, null, null);		// TFS 37997 jlgmd1 16/04/2018
		completedOK := true;													// TFS 37997 jlgmd1 16/04/2018
		return response;														// TFS 37997 jlgmd1 16/04/2018
	endif;																		// TFS 37997 jlgmd1 16/04/2018
	
	create gateCheckerController transient;
	gateCheckerController.setMyTerminal(terminal);
	
	//if glc &lt;&gt; null then
		gateCheckerController.setGateAreaLaneController( glc, true );
	//endif;
	
/*	if not gateCheckerController.checkFindAndAssignTrailer(_request.vehicle.toUpper) then   // 02/08/2016 cnwma1 TFS #2273
		completedOK := true;
		return response;
	endif;
*/
	gateCheckerController.setTruck( gateCheckerController.findTruck( errMsg,_request.vehicle.toUpper, false ) );

	if gateCheckerController.myTruck = null then
		completedOK := true;
		return response;
	endif;

	if gateCheckerController.myTruck.visitRecords.isEmpty then
		
		app.raiseCMException(Truck_has_no_visit_record,null,null); //22/02/2016 cnwma1 TFS #2761
		completedOK := true;
		return response;
	endif;

	if gateCheckerController.myTruck.myPrimaryActualLocation &lt;&gt; null and 
		gateCheckerController.myTruck.myPrimaryActualLocation.isKindOf(CM_GateAreaLaneController) then	
		//Truck Already in Lane
	else

		if not gateCheckerController.moveTruckToLane(errMsg) then
			completedOK := true;
			return response;
		endif;
	endif;
	
	foreach ti in gateCheckerController.allTruckTis discreteLock do
	
		if ti = null then
			continue;
		endif;
		
		create wsTI transient;
		wsTI.setProxyFromObject(ti);
		response.allTrackedItems.add(wsTI); 
	endforeach;
	
	// Got to here, everything is ok

	completedOK := true;
	return response;
	
epilog
	if gateCheckerController &lt;&gt; null then
		gateCheckerController.clearAll();
		gateCheckerController.setGateAreaLaneController(null, true);	// reset lane controller
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	delete gateCheckerController;
	delete wleArray;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_GateCheckerQueryRequest"/>
        <ReturnType type="WS_GateCheckerResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getGates" id="58de17fc-1486-4935-ada8-963a70e9b839">
        <source>getGates(request: WS_GatesRequest) : WS_GatesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2013	cnwmc5	Initial creation	KEA Mobile

*/

vars
	response	: WS_GatesResponse;
	completedOK	: Boolean;
	
	cmGate		: CM_Gate;
	wsGateArray	: WS_GateArray;
	wsGate		: WS_Gate;
	
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create wsGateArray transient;
	
	foreach cmGate in app.myPassport.myTerminal.allGates do
	
		if not cmGate.hasPGateAreas then    //25/07/2016 cnwma1 TFS 2273 
			continue;
		endif;
		
		create wsGate transient;
		wsGate.setProxyFromObject(cmGate);
		wsGateArray.add(wsGate);
	endforeach;
	
	response.addAllsGate(wsGateArray);
	
	completedOK := true;
	return response;
epilog	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
		delete wsGateArray;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_GatesRequest"/>
        <ReturnType type="WS_GatesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getGeneratorTypes" id="c258d97f-a167-449a-855d-302a7d89048b">
        <source>getGeneratorTypes() : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_CodeResponse;
	completedOK : Boolean;
	genType : CM_GeneratorType;
	failedDAC : CM_DataAccessController;
	passport : CM_Passport;
	wsGenType : WS_Code;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	passport := app.myPassport;
	
	foreach genType in app.myRoot.allGeneratorTypes discreteLock do
		if not genType.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		create wsGenType transient;
		wsGenType.setProxyDetails(genType, genType.code, genType.description);
		response.allCodes.add(wsGenType);
	endforeach;
	
	// Got to here, everything is OK
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getGlobalVoyageActual" id="afe2b6f3-c02b-45a4-ac5a-debfb42caa72">
        <source>getGlobalVoyageActual() : WS_VoyageGlobalResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
05 Sep 2008 cnwkao1	modified

*/

vars
	response		: WS_VoyageGlobalResponse;
	completedOK		: Boolean;

	proxyVoyageGlobal		: WS_VoyageGlobal;
	
	iter			: Iterator;
	voyGlobal				: CM_VoyageGlobal;
	today			: Date;
		
	thePassport		: CM_Passport;
	failedDAC		: CM_DataAccessController;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	iter  := app.myRoot.allVoyagesGlobal.createIterator();
	
	while iter.next(voyGlobal) do	
		if (not voyGlobal.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			continue;
		endif;
	
		create proxyVoyageGlobal transient;
		proxyVoyageGlobal.setProxyFromObject(voyGlobal);
		response.allVoyageGlobals.add(proxyVoyageGlobal);
		
	endwhile;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up local transients
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getGlobalVoyageActual</wsdlName>
        <ReturnType type="WS_VoyageGlobalResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getGlobalVoyageAllocated" id="6154e6e2-4be8-47dc-84ae-db9390a74879">
        <source>getGlobalVoyageAllocated() : WS_VoyageGlobalResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
					PAR #19257

*/

vars
	response		: WS_VoyageGlobalResponse;
	completedOK		: Boolean;
	voyDict		: CM_VoyageGlobalByCodeDict;
	proxyVoyageGlobal		: WS_VoyageGlobal;

	voyGlobal				: CM_VoyageGlobal;
	today			: Date;
		
	thePassport		: CM_Passport;
	failedDAC		: CM_DataAccessController;
	terminalSet     : CM_TerminalSet;
	passport        : CM_Passport;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	
	create terminalSet transient;
	terminalSet.add(passport.myTerminal);
		
	voyDict := app.myRoot.allVoyagesGlobal;
	
	foreach voyGlobal in voyDict where voyGlobal.hasStructureOfType(LogStructure) do	
		if (not voyGlobal.canUserAccessSelf(null, failedDAC, passport)) then
			continue;
		endif;
	
	if voyGlobal.hasCurrentVoyageForTerminals(terminalSet) then
		create proxyVoyageGlobal transient;
		proxyVoyageGlobal.setProxyFromObject(voyGlobal);
		response.allVoyageGlobals.add(proxyVoyageGlobal);
		endif;
		
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getGlobalVoyageAllocated</wsdlName>
        <ReturnType type="WS_VoyageGlobalResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getGridAreaContents" id="20cbc4d4-66f4-474d-9834-007aa4d5cef1">
        <source>getGridAreaContents(wsGridArea : WS_GridArea) : WS_GridAreaContentsResponse webService;
// ---------------------------------------------------------------------------
// Created:     MARCH 2011 ANDREW BISHOP
// ---------------------------------------------------------------------------
// Status: 	
// Purpose:	Silverlight Prototype Operation. 
//       
// ---------------------------------------------------------------------------

vars
	response		: WS_GridAreaContentsResponse;
	completedOK		: Boolean;
	user			: CM_User;
	aTerminal	: CM_Terminal;
	terminalArea : CM_TerminalArea;
	theGA : CM_GridArea;
	wsGR : WS_GridRow;
	theGR : CM_GridRow;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	// Populate list of Terminals
	user := app.getMyUser();
	aTerminal := app.myPassport.myTerminal;
	terminalArea := aTerminal.allTerminalAreas[wsGridArea.code];
	if not terminalArea.isKindOf(CM_GridArea) then
	completedOK := true;
		return null;
	endif;
	theGA := terminalArea.CM_GridArea;
	
	if not (theGA.isForkliftStack() or theGA.isRTGArea() or theGA.isStraddleStack()) then
	completedOK := true;
		return  null;
	endif;
	
	foreach theGR in theGA.allGridRows discreteLock do
		create wsGR transient;
		wsGR.setProxyFromObject(theGR);
		response.allGridRows.add(wsGR);
	endforeach;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="wsGridArea" type="WS_GridArea"/>
        <ReturnType type="WS_GridAreaContentsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getHMSBerths" id="dbe97610-7817-4cbe-add9-f1653c4e678e">
        <source>getHMSBerths() : WS_HMSBerthsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2018	jlger1	Initial creation tfs 37665 webportal pelindo marine initial request

*/

vars
	response : WS_HMSBerthsResponse;
	completedOK : Boolean;
	harbour 	:  HMS_Harbour;
	berth : HMS_Berth;
	wsBerth : WS_HMSBerth;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	
	if app.myPassport.myTerminal = null then
		completedOK:=true;
		return null;
	endif;
	
	harbour:= app.myPassport.myTerminal.myHarbour;
	
	if harbour = null then
		app.raiseCMException(HMSNoHarbourForTerminal,null,null);
		completedOK:=true;
		return null;
	endif;
		
	
	foreach berth in harbour.allBerths discreteLock do
		create wsBerth transient;
		wsBerth.setProxyFromObject(berth);
		response.allHMSBerths.add(wsBerth);
	endforeach;
	
	completedOK := true;
	return response;
	
	
epilog
	
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_HMSBerthsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getHMSBerthsForShift" id="261c7c9d-2139-4a98-9ade-578a03ae3da1">
        <source>getHMSBerthsForShift(_voyage : String) : WS_HMSBerthsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2018	jlger1	Initial creation 42159 	- if the berth is same as cargo request they don't need a permit
													- otherwise they need the permit

*/

vars
	response : WS_HMSBerthsResponse;
	completedOK : Boolean;
	harbour 	:  HMS_Harbour;
	berth : HMS_Berth;
	wsBerth : WS_HMSBerth;
	voyage : CM_Voyage;
	cargoRequest : CM_WodVoyageCargoRequest;
	cargoRequestBerth : HMS_Berth;
	shiftPermit : CM_WodPermitRequest;
	workOrder : CM_WodShiftMovement;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	
	if app.myPassport.myTerminal = null then
		completedOK:=true;
		return null;
	endif;
	
	harbour:= app.myPassport.myTerminal.myHarbour;
	
	if harbour = null then
		app.raiseCMException(HMSNoHarbourForTerminal,null,null);
		completedOK:=true;
		return null;
	endif;
		
	voyage:= app.myPassport.getObjectOfTypeFromOid(_voyage,CM_Voyage).CM_Voyage;
	if voyage = null then
		workOrder:=app.myPassport.getObjectOfTypeFromOid(_voyage,CM_WodShiftMovement).CM_WodShiftMovement;
		
		if workOrder = null then
			app.raiseCMException1(Voyage_not_found,_voyage,null,null);
			completedOK := true;
			return response;
		endif;
		voyage:=workOrder.getMyVoyageObject;
	endif;
	
	
	cargoRequest:=voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
	if cargoRequest &lt;&gt; null then
		cargoRequestBerth:=cargoRequest.getMyBerth;
	endif;
	if workOrder &lt;&gt; null then 
		shiftPermit:= workOrder.myRelatedPermitRequest;
	else
		shiftPermit:=voyage.allWorkOrders.getWODPermitForDetailType(WO_TASK_SHIFTMOVEMENT,WO_STATUS_COMPLETE).CM_WodPermitRequest;
	endif;
	
	foreach berth in harbour.allBerths discreteLock do
		
		if shiftPermit = null then
			if berth.isLogicalBerth or 
				berth = cargoRequestBerth or
				not berth.requiresLengthOfTime then //epr TFS 42396 11/12/18 
		
				create wsBerth transient;
				wsBerth.setProxyFromObject(berth);
				response.allHMSBerths.add(wsBerth);
			endif;
		else
			//if shiftPermit &lt;&gt; null then
				create wsBerth transient;
				wsBerth.setProxyFromObject(berth);
				response.allHMSBerths.add(wsBerth);			
			//endif;		
		endif;
	endforeach;
	
	completedOK := true;
	return response;
	
	
epilog
	
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_voyage" type="String"/>
        <ReturnType type="WS_HMSBerthsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getHMSResourceTypes" id="eec7d5a0-13ed-4c88-899b-f00c7160c889">
        <source>getHMSResourceTypes(_request : WS_HMSResourceTypesRequest) : WS_HMSResourceTypesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/04/2018	jlger1	Initial creation tfs 37665 webportal pelindo marine initial request
30/08/2018	jlgdap1	TFS 40488 PEL1 Resources for Shift Movements
01/10/2021	jlier1	TFS 51963 - changes voyage process
*/

vars
	response : WS_HMSResourceTypesResponse;
	completedOK : Boolean;
	voyage : CM_Voyage;
	voyageStatus : CM_VoyageStatus;
	hmsResource : HMS_Resource;
	hmsResourceType : HMS_ResourceType;
	harbour 	: HMS_Harbour;
	wsResourceType : WS_HMSResourceType;
	terminal : CM_Terminal;
	processHarbour : CM_ProcessHarbour;
	berth 		: HMS_Berth;
	movement   : HMS_VoyageMovement;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	
	if app.myPassport.myTerminal = null then
		completedOK:=true;
		return null;
	endif;
		
	voyage := app.myPassport.getObjectOfTypeFromOid(_request.voyage,CM_Voyage).CM_Voyage;
	if voyage = null then
		completedOK:=true;
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	if terminal = null then
		completedOK:=true;
		return response;
	endif;
	
	harbour:= terminal.myHarbour;
	
	if harbour = null then
		app.raiseCMException(HMSNoHarbourForTerminal,null,null);
		completedOK:=true;
		return null;
	endif;
	
	//epr TFS 39306 21/6/18
	if _request.berth &lt;&gt; null then
		berth := app.myPassport.getObjectOfTypeFromOid(_request.berth,HMS_Berth).HMS_Berth;
		if berth &lt;&gt; null and  not harbour.allBerths.includes(berth) then
			berth:=null;
		endif;
	endif;
	
	if _request.workOrderType = null then
	
		voyageStatus := app.myRoot.allVoyageStatuses[voyage.status];
		
		if  voyageStatus = null then
			completedOK:=true;
			return response;
		endif;
		
		//epr TFS 41539 - they could be at one of these status and updating the work order		
		if voyageStatus.isInitialMarineServiceStatus then
			if voyage.myVoyageProcess.isMTNWOProcess then	//jlier1 TFS 51963 1/10/21			
				voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_ServicesPending];			
			endif;
			if berth = null then
				movement:=voyage.getMovementArrival;
				if movement &lt;&gt; null then
					berth:= movement.getMyBerth;
				endif;
			endif;
		else//if voyageStatus.isDepartureMarineService then
			if voyage.myVoyageProcess.isMTNWOProcess then	//jlier1 TFS 51963 1/10/21			
				voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_DepServPending];			
			endif;
			if berth = null then
				movement:=voyage.getMovementDeparture;
				if movement &lt;&gt; null then
					berth:= movement.getMyBerthPrevious;
				endif;
			endif;
		endif;		
		
		
		response.createResourceTypesForStatus(voyageStatus,berth);
	elseif _request.workOrderType = WO_TASK_SHIFTMOVEMENT then
		// TFS 40488 Resources to use are now on Voyage Process Harbour,
		// instead of using resources from the voyage status
		if voyage.myVoyageProcess = null then
			completedOK:=true;
			return response;
		endif;
		
		processHarbour:= voyage.myVoyageProcess.allProcessHarbours[voyage.myVoyageProcess,harbour];
		if processHarbour = null then
			completedOK:=true;
			return response;
		endif;
		if not processHarbour.allHMSResourcesForShift.isEmpty then
			response.createResourcesForShift(processHarbour, berth);
		endif;
		// TFS 40488 end
	elseif _request.workOrderType = WO_TASK_EXTENSION then	//18 Feb 2019	NDL	TFS 43374
		if voyage.myVoyageProcess = null then
			completedOK:=true;
			return response;
		endif;
		
		processHarbour:= voyage.myVoyageProcess.allProcessHarbours[voyage.myVoyageProcess,harbour];
		if processHarbour = null then
			completedOK:=true;
			return response;
		endif;
		//19 Feb 2019	NDL TFS 43374
		if not processHarbour.allHMSResourcesForExt.isEmpty then
			response.createResourcesForExt( processHarbour );
		endif;
		
	elseif _request.workOrderType = WO_TASK_WATER then
		
		if voyage.myVoyageProcess = null then
			completedOK:=true;
			return response;
		endif;
		
		processHarbour:= voyage.myVoyageProcess.allProcessHarbours[voyage.myVoyageProcess,harbour];
		if processHarbour = null then
			completedOK:=true;
			return response;
		endif;
		
		if processHarbour.myHMSResourceForWater &lt;&gt; null then
			create wsResourceType transient;
			wsResourceType.setProxyFromObject(processHarbour.myHMSResourceForWater);
			response.allHMSResourceTypes.add(wsResourceType);
		endif;
	elseif _request.workOrderType = WO_TASK_CARGOREQUEST 
	or _request.workOrderType = WO_TASK_CARGOINITIAL then // TFS 40127
		
		if voyage.myVoyageProcess = null then
			completedOK:=true;
			return response;
		endif;
		
		processHarbour:= voyage.myVoyageProcess.allProcessHarbours[voyage.myVoyageProcess,harbour];
		if processHarbour = null then
			completedOK:=true;
			return response;
		endif;
		
		//23 Nov 2018	NDL	TFS 41980
		if not processHarbour.allHMSResourceTypeForEquip.isEmpty then
			response.createResourcesForEquip( processHarbour );
		endif;
		
	endif;
	completedOK := true;
	return response;
	
	
epilog
	
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_HMSResourceTypesRequest"/>
        <ReturnType type="WS_HMSResourceTypesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getHMSResourceTypesForReports" id="12127efa-0e96-4fa4-9e49-5962c9783d5f">
        <source>getHMSResourceTypesForReports() : WS_HMSResourceTypesResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_HMSResourceTypesResponse;
