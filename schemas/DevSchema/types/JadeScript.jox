Date		Who		Reason
11 November 2013	cnwer1	Initial creation PAR

*/

vars
	i : String;
		trailingNum		: String;
	lastNum	,nextLogId		: String;
begin 
	
	i :="012342343201";
	
	
	//i:="123456734589019876565234567890";
	/*trailingNum := i.getTrailingIntegerString();
//	write trailingNum;
	lastNum :=  i.getTrailingInteger().String;
	lastNum := (lastNum.Integer + 1).String;
	//write lastNum;
	if trailingNum.length &gt; lastNum.length then
		//write trailingNum[1:trailingNum.length - lastNum.length];//           .cnEcStripAtEnd(lastNum); //012
		nextLogId:= trailingNum[1:trailingNum.length - lastNum.length] &amp; lastNum;
		nextLogId :=  i[1:(i.length-trailingNum.length)  ] &amp;  nextLogId;//lastNum.padZeros(trailingNum.length));
	else
		nextLogId := (i.cnEcStripAtEnd(trailingNum) &amp; lastNum);			
	endif;	
	
	write nextLogId;*/
	
	
	write i.incrementID(1);
	i:= "dsfs3423dfsf";
	write i.incrementID(1);
	i:="eprt324324ff345";
	write i.incrementID(1);

epilog

end;</source>
    </JadeMethod>
