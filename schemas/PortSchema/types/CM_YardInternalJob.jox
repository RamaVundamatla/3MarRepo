    <JadeMethod name="addTI" id="211810af-eb6e-4537-aaff-c78c7493f2e2">
        <updating/>
        <source>addTI(ti : CM_TrackedItem input; req : CM_YardRequest) updating;
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	isReceipt	:	Boolean;
begin

	exclusiveLock(self);

	if ( ti = null or req = null) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_TI_LINK_PARAM, null, null);
		return;	
	endif;

	sharedLock(req);
	exclusiveLock(ti);

	if self.isSwapJob then
		if self = ti.jobYardSwap then
			//Is already ok
			return;
		endif;
	elseif self.isDoorJob then
		if self = ti.jobYardDoor then
			return;
		endif;
	else
	//cnwrd1 par 22240 2.2.2010 
		//if self = ti.jobYardInternal then
		if ti.allJobYardInternals.includes(self) then //cnwrd1 par 22240 2.2.2010 ++
			//Is already ok
			return;
		endif;
	endif;

	self.linkToTI(ti);
	self.updateObjectEdition(self);	// par 30292
	
	// PAR 11770 Lorcan Send note so screens can update
	app.myEventManager.createSingleObjInfoNoteEvt(self, app.myPassport.myTerminal.getTerminalEvent(RoadJob_Update_Event), self);
end;</source>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="req" type="CM_YardRequest"/>
    </JadeMethod>
    <JadeMethod name="addToJobSheet" id="17562c5c-5bf4-42ed-a54e-876f9b94901f">
        <updating/>
        <source>addToJobSheet() updating;

vars
	jobSheet : CM_YardJobSheet;
begin
	//------------
	//Add the ourselves to terminal's jobSheet
	//------------
	jobSheet := self.myTerminal.myYardJobSheet;

	if jobSheet = null then	//Padding for disasters, this object is only created in terminal constructor.
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null yardJobSheet. Contact Developer.');
	endif;
	jobSheet.addJob(self, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="areAllTIsInQueuedLocn" id="840259a3-18d8-46a8-b249-81502759e196">
        <source>areAllTIsInQueuedLocn(): Boolean;
//Returns TRUE if all TI's are in their queued location for this job.
//This means that the users have moved the TI's some other way.
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle	:	CM_WorkListEntry;
	ti	:	CM_TrackedItem;
	isInQueued :	Boolean;
	iter	:	Iterator;
	tmpRealLC,
	tmpQueueLC	: CM_LocationsController;
	futureMove	: CM_FutureMove;
	
begin
	//------------------
	//Are our tracked items ALL in the locations they are QUEUED TO?
	//------------------
	
	isInQueued := false;
	iter := self.workListEntries.createIterator;
	while iter.next(wle) do
		futureMove	:= wle.myFutureMove;
		
		if futureMove &lt;&gt; null and futureMove.moveType &lt;&gt; TI_FutureMoveQueued then
			futureMove := null;
		endif;
		
		ti	:= wle.myTrackedItem;
		if ti &lt;&gt; null and futureMove &lt;&gt; null then
			//----------------------
			//If TI is in the queued location, or the Queued location is NULL 
			//(which means its been cleared already), then nuke it. We cannot pick it up
			//----------------------
			tmpRealLC := ti.getPrimaryLocation(REAL_MODE);
			if tmpRealLC = null then
				isInQueued := true;
				continue;
			endif;
			tmpQueueLC := futureMove.getPrimaryLocation();
			if tmpRealLC = tmpQueueLC or
			   tmpQueueLC = null then
				if tmpRealLC.getParent.isKindOf(CM_Machine) then
					//--------------
					//If TI is on a machine, then it has not reached its queued location as yet.
					//--------------
					break;
				endif;
				isInQueued := true;
			else
				//Over-write, we have found one not ok!
				isInQueued := false;
				break;
			endif;
		else
			//This one is not assigned (ie, its a director task)
			isInQueued := false;
			break;
		endif;
	endwhile;	
	//----------------
	//If they are all in queued locn, then they have been 
	//moved by something other than queue processes!
	//----------------
	return isInQueued;
epilog
	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkReceiptsNotQueued" id="dc74d264-83a1-4b68-9c28-89ab0277da65">
        <source>checkReceiptsNotQueued(_wleToIgnore : CM_WorkListEntry): Boolean;
//--------------------------------------------------
// Created:	09 December 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	return false;

end;</source>
        <Parameter name="_wleToIgnore" type="CM_WorkListEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cleanup" id="9ac6534b-80df-413a-b6d0-5efcfa219bba">
        <updating/>
        <source>cleanup(numCleaned :	Integer io) updating;
//Does whatever its gotta do for the queue to remove it
//In this case, the Queue can DELETE this, as its now crap.
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars

begin
	if self.status = JOB_COMPLETE then
		numCleaned := numCleaned +1;
		self.erase(0);
		return;
	endif;
	if 	self.allEntries.isEmpty and self.type &lt;&gt; Depot_Request then
		numCleaned := numCleaned +1;
		self.erase(0);
		return;
	endif;
	if self.areAllTIsInQueuedLocn() then
		numCleaned := numCleaned +1;
		self.erase(0);
		return;
	endif;

	//This will cause updated event for YRD_RequestInternalMoveForm
	if self.type = Depot_Request or self.type = Controller_Strip then
		self.updateObjectEdition(self);	// par 30292
	endif;	
end;</source>
        <Parameter name="numCleaned" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createReleaseWLEs" id="1a47ac96-9c86-4e2c-832f-80abb93409a3">
        <updating/>
        <source>createReleaseWLEs() updating;
//On the job, once the request is setup, we create the required
//worklistEntries.
vars
	req : CM_Request;
begin
	req := self.allRequests.first;
	if not req.isKindOf(CM_YardMoveRequest) then
		return;
	endif;
	//------------
	//Create the appropriate WLEs
	//------------
	req.createWLEs();
end;</source>
    </JadeMethod>
    <JadeMethod name="createWLE" id="fb639300-00c8-4323-a292-9acb3b797f6f">
        <updating/>
        <source>createWLE(ti:CM_TrackedItem input;	aWLE:CM_YardWLE io) updating;
//Takes a TI, and creates the WLE on the job, returns the WLE.
vars
	reqst	:	CM_Request;
	req	:	CM_TIRequest;
	lController : CM_LocationsController;
begin
	//------------
	//Create the appropriate WLE
	//------------
	reqst := self.allRequests.first;
	create aWLE;
	if not reqst.isKindOf(CM_TIRequest) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Request not expected type');
		return;
	endif;
	req := reqst.CM_TIRequest;
	aWLE.setForCreate(self, req);
	aWLE.setMyTrackedItem(ti); 
	//---------------
	//Call method to establish the ti/job link
	//---------------
	self.linkToTI(ti);

	aWLE.ghostTrackedItem := null;

end;</source>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="aWLE" type="CM_YardWLE" usage="io"/>
    </JadeMethod>
    <JadeMethod name="enqueueJob" id="2e1efee6-a321-4ca2-bbc8-4b433c39ad56">
        <source>enqueueJob();
//Works to queue a job. Because this is a job created by a Machine SWAP,
//we need to furnish the source and target locations to the arbiter.
vars
	wle	: CM_WorkListEntry;
	arbiter	: CM_RTQueueArbiter;
	
begin
	//epr par 36229 17/7/17 removed references to RadioTelemetryEnabled 
	//--------------
	//For each WLE (a unit of work), ask it to enqueue itself
	//(Note, this can be called from that level if required.
	//--------------
	create arbiter;
	arbiter.job := self;
	// ##########

	// ###########

	foreach wle in workListEntries do
		arbiter.reset();
		wle.enqueueWLE(arbiter);
		if arbiter.allRTQueueEntries.isEmpty() and arbiter.ti = null then //cnwrd1 par 22331 16.02.2010
			app.raiseCMWarning(Request_failed_auto_plan, null, null,null);
		endif;	
	endforeach;

epilog
	//epr par 35013 21/11/2014 if rt not enabled
	if arbiter &lt;&gt; null then
		arbiter.erase(0);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="enqueueJobDeliveryToLocation" id="5e1027b6-7b7e-4dea-93e1-3e9dcbf0472c">
        <source>enqueueJobDeliveryToLocation(_toTermArea : CM_BlockStack);
//Wraps a call to do the entire job in one hit.

vars
	lc	: 	CM_LocationsController;
	wle	:	CM_WorkListEntry;
begin
	inheritMethod(_toTermArea);
	foreach wle in self.workListEntries do
		// 09/02/2010	cnwjre1	CCMS 1101 method parameter changed from TA to LC
		lc := _toTermArea.getMyLocationsController;
		wle.enqueueWLEDeliveryToLocation(lc);
	endforeach;
end;</source>
        <Parameter name="_toTermArea" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="enqueueJobInternal" id="1c1e8222-879b-4da1-b1ae-30edea243b09">
        <updating/>
        <source>enqueueJobInternal(_yardInternalJobParam : CMIF_YardWorkJobParams) updating;
/*
 ------------------------------------------------------------------------
Created:			27 August 2002 by cnwdwq1
Purpose:			called when we need to enqueue an Internal job (i.e, a strip or repeating job)
Parameters:		None
Returns:			Nothing
Changed On	Changed By	Reason
----------	----------	---------------------------------------------------------------------------------------
20/11/2012	cnwdap1		PAR #30762 CCMS QNS 2233 Set entry status to system held if yard job says to hold tasks
---------------------------------------------------------------------------------------------------------------
*/
vars
	sourceTa,
	targetTa 		: CM_TerminalArea;
	sourceLocation	: CM_LocationsController;
	arbiter			: CM_RTQueueArbiter;
	queue 			: CM_RadioTelemetryQueue;
	aWLE			: CM_WorkListEntry;
	rule			: CM_RTQueueMultiRule;
	request 		: CM_Request;
begin
	if _yardInternalJobParam.addToQueue = false then
		return;
	endif;
	//------------
	//Setup the arbiter, and enqueue
	//------------
	create arbiter transient;
	arbiter.ignoreExtraChecks := true;
	//arbiter.setForUpdate(null, self, _yardInternalJobParam.mySourceLocation, _yardInternalJobParam.myTargetLocation, queue, null,self.myTerminal);
	
	if _yardInternalJobParam.myQueueToAddTo = null then
	// This will get done inside processMachineMoves.
	//	queue := arbiter.getQueue();
	else
		queue := _yardInternalJobParam.myQueueToAddTo;
	endif;
	arbiter.setForUpdate(null, self, _yardInternalJobParam.mySourceLocation, _yardInternalJobParam.myTargetLocation, queue, null,self.myTerminal);
	//-----------
	//Create the Queue Entries for the Job
	//-----------
	
	foreach aWLE in self.workListEntries do
		arbiter.wle := aWLE;
		arbiter.queue := queue;
		arbiter.setMyRTMoveMethodRule(null);
		// 23098 add best pick option
		sourceTa := _yardInternalJobParam.mySourceTA;
		if sourceTa &lt;&gt; null and
		   aWLE.isBestPick then
			sourceLocation := null;
			arbiter.enqueueRequest(sourceLocation);
		else
			
			request := self.allRequests.first;
			
			if arbiter.sourceLocation = null and  //cnwrd1 6.12.2010 par 26509 multimachine director tasks
				request.isKindOf(CM_YardMoveRequest) then
				sourceLocation := request.CM_YardMoveRequest.mySourceLocation;
				arbiter.sourceLocation := sourceLocation;
			endif;	
		
			//epr par 25373 13/8/10
			if arbiter.sourceLocation = null or arbiter.targetLocation = null then
				if _yardInternalJobParam.mySourceLocation &lt;&gt; null then
					sourceTa:=	_yardInternalJobParam.mySourceLocation.getMachineRuleTerminalArea;
				endif;
				if _yardInternalJobParam.myTargetLocation &lt;&gt; null then
					targetTa:=_yardInternalJobParam.myTargetLocation.getMachineRuleTerminalArea;
				else
					targetTa:=_yardInternalJobParam.myTargetTA;
				endif;
				if sourceTa &lt;&gt; null and targetTa &lt;&gt; null then
					rule := self.myTerminal.allRTQueueMultiRuleTATypes[sourceTa.myType, targetTa.myType];
				endif;
				//if rule &lt;&gt; null then
				if rule &lt;&gt; null and not rule.isDisabled then							// 24/08/2012 cnwmh5
					arbiter.setMyRTMoveMethodRule(rule.getDefaultRTMoveMethodRule);
					arbiter.myRTMoveMethod :=arbiter.myRTMoveMethodRule.myRTMoveMethod;
				endif;
			endif;
			arbiter.processMachineMoves();
		endif;

		//---------------
		//Default to held if required
		//---------------
		if _yardInternalJobParam.defaultQueueToHeld = true then
		   	if arbiter.entry &lt;&gt; null then
		   		arbiter.entry.setEntryStatusUserHeld();		// PAR #30762
		   	endif;
		 else
			// CCMS 1309 DVB changed 15/02/2005
		 	if	arbiter.sourceLocation.hasRestrictions(LABOUR_RESTRICTION) or
				(arbiter.targetLocation &lt;&gt; null and arbiter.targetLocation.hasRestrictions(LABOUR_RESTRICTION))  then
					arbiter.entry.setEntryStatus(QSTATUS_HELD);
				
			endif;
		endif;
	endforeach;
epilog

	if arbiter &lt;&gt; null then
		arbiter.erase(0);
	endif;
end;</source>
        <Parameter name="_yardInternalJobParam" type="CMIF_YardWorkJobParams"/>
    </JadeMethod>
    <JadeMethod name="erase" id="736e2d51-3df0-44ad-a5a1-b851099295aa">
        <updating/>
        <source>erase(_eraseLevel:	Integer) updating;
//Re-implementation of super-class method.
//Erase level is ignored.
/*

Date				Who		Reason
19 May 2010			cnwkpd1	PAR #20728 - remove isValidObject calls for performance
09 October 2023		jlizm1	Initial creation TFS 59730 Kiosk Load Sequence

*/

vars
	wle		:	CM_WorkListEntry;
	wles 	: CM_WLEArray;
	req 	: CM_Request;
	invalid	: Boolean;
	control : CMIF_MoveController;
	
begin

	create wles transient;
	self.workListEntries.copy(wles);
	
	//09 Mar 2012	NDL	Par 28671
	
	on Exception do app.handleDeletedObject(exception, wle, invalid);
	if self.status = JOB_PART_COMPLETE or self.status = JOB_UNACTIONED then
		foreach wle in wles do
			if wle.status = WLE_UNACTIONED then
				if wle.myFutureMove &lt;&gt; null then
					wle.myFutureMove.erase(NORMAL_ERASE);
				endif;
			endif;
			if wle &lt;&gt; null then
				invalid := false;
				wle.causeEvent(self.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, wle);
				if not invalid then
					delete wle;
				endif;
			endif;
		endforeach;
	endif;
	
	
	if self.status = JOB_UNACTIONED or self.status = JOB_COMPLETE  or self.allEntries.size = 0 then
		//Carry on.
	else
		//-----------------
		//Attempt a status update, to ensure we are REALLY not up to date
		//-----------------
		self.updateStatus();
	endif;
	exclusiveLock(self);
	
	foreach req in self.allRequests do
		req.processDeleteForWO();
	endforeach;

	//-----------------
	//Nuke the WLE's
	//-----------------
//	on Exception do app.handleDeletedObject(exception, wle, invalid);
	
	while workListEntries.size &gt; 0 do : outerLoop
		wle := workListEntries.first;
		exclusiveLock(wle);
		//---------------
		//Tell WLE to deref from the TI
		//---------------
		wle.eraseFromTI();
		
		//---------------
		//Tell WLE to deref from the Queue
		//---------------
		while wle.allRTQueueEntries.isEmpty = false do
			wle.allRTQueueEntries.last.deleteEntry( false, null);			
			if app.myPassport &lt;&gt; null then // AKB2003FEB
				if app.myPassport.hasErrors then // AKB2003FEB
					break outerLoop; // AKB2003FEB
				endif;
			endif;
		endwhile;
		
		
		if wle &lt;&gt; null then
			invalid := false;
			wle.causeEvent(self.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, wle);
			if not invalid then
				
				delete wle;
			endif;
		endif;
	endwhile;
	
	on Exception do null;
	
	if app.myPassport &lt;&gt; null then // AKB2003FEB
		if app.myPassport.hasErrors then // AKB2003FEB
			return;
		endif;
	endif;

	req := self.allRequests.first;
	if req &lt;&gt; null then
		delete req;
	endif;
	if selectionMacro &lt;&gt; null then
		delete selectionMacro;
	endif;
	self.selectedTIs.clear;
	//------------
	//Remove ourselves from SwapJobSheet on terminal
	//------------
	inheritMethod(_eraseLevel);
	
epilog
	delete wles;
	
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
