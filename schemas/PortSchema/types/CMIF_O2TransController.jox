    </ImplicitInverseRef>
    <JadeMethod name="setFromTransaction" id="9487e5f1-3b90-4805-b372-05aca9aee794">
        <updating/>
        <source>setFromTransaction(_txn : CM_O2ReadingTransaction) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
