    <JadeMethod name="pxyCreateUpdateProxy" id="040d79ca-a95b-4ed7-8b7c-a00aac1c1b28">
        <source>pxyCreateUpdateProxy() : SelfType;
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
vars
	proxyDebtorInvLineType	: CM_DebtorInvLineType;
begin
	proxyDebtorInvLineType := inheritMethod();
	proxyDebtorInvLineType.myDebtor := self.myDebtor;
	proxyDebtorInvLineType.myInvoiceLineType := self.myInvoiceLineType;
	proxyDebtorInvLineType.otherCode := self.otherCode;

	return proxyDebtorInvLineType;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f572801e-8099-4837-9b47-eaa6b6c739d0">
        <updating/>
        <source>setForCreate(_proxyDebtorInvLineType : CM_DebtorInvLineType; _passport : CM_Passport input) updating;
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
begin
	_proxyDebtorInvLineType.raiseExceptionIfNotTransient(method);

	self.setForUpdate(_proxyDebtorInvLineType);
//	set any properties which are only to be done from create, not update
end;</source>
        <Parameter name="_proxyDebtorInvLineType" type="CM_DebtorInvLineType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="179a5cca-4523-4740-92a4-5d773b7b424a">
        <updating/>
        <source>setForUpdate(_proxyDebtorInvLineType : CM_DebtorInvLineType) updating;
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
begin
	self.otherCode := _proxyDebtorInvLineType.otherCode;
	self.myDebtor := _proxyDebtorInvLineType.myDebtor;
	self.myInvoiceLineType := _proxyDebtorInvLineType.myInvoiceLineType;
end;</source>
        <Parameter name="_proxyDebtorInvLineType" type="CM_DebtorInvLineType"/>
    </JadeMethod>
