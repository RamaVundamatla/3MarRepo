end;</source>
        <Parameter name="value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromTemplate" id="2fd35b45-36d9-47df-8bb1-b347fa51e0f2">
        <source>setDefaultsFromTemplate(intCargoType : Integer output;
						product : CM_Product output;
						mark : String output;
						location : CM_LocationsController output;
						strOperator	: String output;
						weight : Decimal output);
					
/*
	Created on 17 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	ti : CM_TrackedItem;
	cmifRec	: CMIF_Receival;
begin
	if myTemplateCMIF &lt;&gt; null then
		if myTemplateCMIF.myTrackedItem &lt;&gt; null then
			ti 				:= myTemplateCMIF.myTrackedItem;
			intCargoType 	:= ti.myCargoType.id;
			product 		:= ti.myProduct;
			mark 			:= ti.mark;
			strOperator 	:= ti.operatorCode;
			//weight 			:= ti.weight;				//-cnwml2 MSL CCMS 1017
			weight			:= ti.totalWeight;				//+cnwml2 MSL CCMS 1017
		elseif myTemplateCMIF.myCMIFReceival &lt;&gt; null then
			cmifRec 	:= myTemplateCMIF.myCMIFReceival;
			intCargoType 	:= cmifRec.cargoType;
			product 		:= cmifRec.myProduct;
			mark 			:= cmifRec.mark;
			strOperator 	:= cmifRec.operatorCode;
			weight			:= cmifRec.weight;
		endif;
		location := myTemplateCMIF.myNewLocation;
	endif;

end;</source>
        <Parameter name="intCargoType" type="Integer" usage="output"/>
        <Parameter name="product" type="CM_Product" usage="output"/>
        <Parameter name="mark" type="String" usage="output"/>
        <Parameter name="location" type="CM_LocationsController" usage="output"/>
        <Parameter name="strOperator" type="String" usage="output"/>
        <Parameter name="weight" type="Decimal" usage="output"/>
    </JadeMethod>
