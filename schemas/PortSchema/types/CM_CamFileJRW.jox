        <source>setJRWCamTransaction(_jrwCamTransaction : CM_JRWCamTransaction) updating;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

begin
	myJRWCamTransaction := _jrwCamTransaction;
end;
</source>
