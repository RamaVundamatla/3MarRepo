    <JadeMethod name="getSealNumbersOnly" id="08cc2250-1c51-42a1-8565-4aa013154076">
        <source>getSealNumbersOnly() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 October 2023		jlizm1	Initial creation TFS 59986 reporting seal numbers on trucks

*/

vars

	iter 		: Iterator;
	truckSeal 	: CM_TruckSeal;
	str 		: String;
	value 		: String;

begin

	iter := self.allTruckSeals.createIterator;
	while iter.next( truckSeal ) do
		value := truckSeal.getSealValueAsString().trimBlanks;
		if value = null then
			continue;
		endif;
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; value;
	endwhile;
	
	return str;

epilog

	delete iter;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSealsDetailCurrentForReport" id="4da7a8ef-c8ad-4131-ad36-1083d0b9cbf0">
        <source>getSealsDetailCurrentForReport() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 October 2023		jlizm1	Initial creation TFS 59986 reporting seal numbers on trucks

*/

vars

	iter 		: Iterator;
	truckSeal 	: CM_TruckSeal;
	str 		: String;
	value 		: String;

begin

	iter := self.allTruckSeals.createIterator;
	
	while iter.next( truckSeal ) do
		value := truckSeal.getSealValueAsString().trimBlanks;
		if value = null then
			continue;
		endif;
		
		value := truckSeal.sealType &amp; "=" &amp; value;
		
		if str &lt;&gt; null then
			str := str &amp; " : ";
		endif;
		
		str := str &amp; value;
	endwhile;
	
	return str;

epilog

	delete iter;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
