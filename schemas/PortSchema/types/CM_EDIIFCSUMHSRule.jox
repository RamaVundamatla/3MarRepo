    <JadeMethod name="getFunctionDescription" id="5c621845-4040-4d17-b536-c73004847c5c">
        <source>getFunctionDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 Aug 2024		navlw1	TFS 65152: NSW | IFCSUM Enhancements
01 Oct 2024		navdap1	MTN-32965 NSW | FR - Unable to View or Update EDI Party Rule After Adding an HS Code Mapping to IFCSUM tab
*/

constants
MaxLength =  100;
vars
	display : String;
	code : CM_HarmonizedSystem;		// MTN-32965
begin
	if self.hsCode &lt;&gt; null then
		code := app.myRoot.allHSCodesActive[self.hsCode];			// MTN-32965
		if code &lt;&gt; null then
			display:= code.id &amp; Space &amp; Hyphen &amp; Space &amp;  code.description[1:MaxLength];
		endif;
		return display;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getItem" id="0fbcffe5-afde-4ce2-b710-125a313b4916">
        <source>getItem(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements

*/

vars
	cargo 	: CM_CargoType;
	prod	: CM_Product;
begin
	if self.cargoType &lt;&gt; null and self.cargoSubType &lt;&gt; null then
		// get the cargoType
		cargo := app.myRoot.allCargoTypesById[self.cargoType];
		if cargo &lt;&gt; null and cargo.allProducts.isNotEmpty then
			foreach prod in cargo.allProducts where prod.code = self.cargoSubType do
				return prod.code &amp; '  ' &amp; prod.description;
			endforeach;
		endif;
	endif;
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="950c4d07-333e-4ea4-bcde-f5aae981a1ca">
        <source>getValue(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements

*/

vars

begin
	if self.cargoType &lt;&gt; null then
		return app.myRoot.allCargoTypesById[self.cargoType].description;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
