	app.myTrxDA.trxDeleteSealType(pObj.CM_SealType, app.myPassport);

end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="c496f017-716e-41a3-a504-42c5a202f590">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
					cnwml2 	PAR23715 SFW CCMS 1131
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks

*/

vars
	
	proxySealType	: CM_SealType;
	code			: String;
	description 	: String;
	theForm			: SOP_TableMaintForm;
	theCargoTypes	: CM_CargoTypeSet;
	theWagonClasses	: CM_WagonClassByCodeDict;
	allowMulti		: Boolean;
	showSeal		: Boolean;
	notAv			: Boolean;
	savePrev		: Boolean;
	truckSeal		: Boolean;
	
begin
  	theForm := self.myForm; 
	code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	description := theForm.tblInput1.getValueByName(ETRow_Description).String;
	allowMulti	:= theForm.tblInput1.getValueByName(ETRow_AllowMultipleSealNo).Boolean;
	showSeal	:= theForm.tblInput1.getValueByName(ETRow_ShowSealIfPres).Boolean;
	notAv		:= theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	savePrev	:= theForm.tblInput1.getValueByName(ETRow_SavePreviousSeal).Boolean;
	truckSeal	:= theForm.tblInput1.getValueByName(ETRow_TruckSeal).Boolean;				// TFS 57098
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_SealType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	create theCargoTypes transient;
	theForm.mulSelect1.getSelected(theCargoTypes);
	
	create theWagonClasses transient;					// TFS 57098
	theForm.mulSelect2.getSelected(theWagonClasses);	// TFS 57098
	
	proxySealType := theForm.myProxyObject.CM_SealType;
	proxySealType.setProxy(code, description, theCargoTypes, allowMulti, notAv, showSeal, savePrev, truckSeal);
	proxySealType.setWagonClasses(theWagonClasses);		// TFS 57098
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateSealType(proxySealType, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateSealType(proxySealType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
epilog
	delete	theCargoTypes;
	delete theWagonClasses;
	  
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
