    <JadeMethod name="checkFieldNotNull" id="0e1794cd-da7d-4856-abfb-6a513d003f9f">
        <source>checkFieldNotNull();
// -----------------------------------------------------------------------------
// Created:		24 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.fromId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'From Id', 'fromId', null);
		app.raiseCMException(Input_required_field_frmId, 'fromId', null); // cnwdb2	PAR 35364


	endif;
	if self.toId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'To Id', 'toId', null);
		app.raiseCMException(Input_required_field_toID, 'toId', null);
	endif;
end;</source>
    </JadeMethod>
