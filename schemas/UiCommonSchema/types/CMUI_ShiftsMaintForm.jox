    <JadeMethod name="initTblShiftDays" id="076b76c3-763a-486e-9d3f-35b8d527bdea">
        <updating/>
        <source>initTblShiftDays()updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	theTable : CM_DataTable;
	entTableDef	: EntTableDef;
begin
		self.tblShift.columns := 6;
		self.tblShift.rows := 1;
		self.tblShift.fixed3D := false;
		self.tblShift.selectMode := Table.SelectMode_CurrentRow;

		self.tblShift.accessColumn(1).width := 100;	
		self.tblShift.accessColumn(2).width := 140;	
		self.tblShift.accessColumn(3).width := 140;	
		self.tblShift.accessColumn(4).width := 100;	
		
		self.tblShift.column := 1;
		self.tblShift.text := "Day";
		self.tblShift.column := 2;
		self.tblShift.text := "Shift Start";
		self.tblShift.column := 3;
		self.tblShift.text := "Shift End";
		self.tblShift.column := 4;
		self.tblShift.text := "Total Hours";
		self.tblShift.column := 5;
