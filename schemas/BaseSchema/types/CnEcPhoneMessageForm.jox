    <JadeMethod name="doFormLoad" id="43837ab4-f15f-41ac-bd91-f5328e4269f9">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Sets up for form details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();

	// Load email addressees from the Aoraki LDAP server...

	self.loadEmailAddresses();

	// Finally, initialize the controls etc.

	self.doSetDefaults();
	self.doShowStatus(null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="6621561f-3864-4164-9ba3-8666e6b66852">
        <updating/>
        <source>doFormUpdate():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Actions the form, in this case by sending the email message.
//
// Parameters:	None
//
// Returns:		A flag to indicate the success of the email (note that this may
//				still have failed, and will be trapped in the "userNotify" event).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	smtpConnectObj	: CnSmtpConnection;
	comments		: String;
	addressFrom		: String;
	addressTo		: String;

begin
	self.doShowStatus("Creating message...");

	// Create SMTP Control Class.
	
	create self.aMySmtpConnect transient;
	smtpConnectObj	:=	self.aMySmtpConnect;
	smtpConnectObj.myCnKarmaCntrl	:=	app.myCnKarmaCntrl;

	on CnSmtpConnectionException do self.xHandlerMessageValidate(exception);

	// Set up message completion notification.

	self.beginNotification(smtpConnectObj, CnSmtpConnection.Completion_Event_Type, Response_Cancel, 0); // Trap completion in form.

	// Set up parameters for message send.
	
	addressFrom				:=	self.getSelectedAddress(cmbAddressFrom);
	addressTo				:=	self.getSelectedAddress(cmbAddressTo);
	
	smtpConnectObj.clientName	:=	app.computerName().toLower &amp; self.DOMAIN_SUFFIX;	// DNS name of mail client
	smtpConnectObj.name			:=	self.SERVER_MAIL; 			// Ditto mail server
	smtpConnectObj.sendFrom		:=	addressFrom;				// From
	smtpConnectObj.sendTo		:=	addressTo; 					// To
	smtpConnectObj.replyTo		:=	addressFrom; 				// Reply-To
	smtpConnectObj.subject		:=	self.getSubject(true);		// Subject
	smtpConnectObj.message		:=	self.getMessage();			// Message body
	smtpConnectObj.contentType	:=	"html";						// Content type (otherwise "null");
	
	if chkIsCopy.value then
		smtpConnectObj.cc	:=	addressFrom;
	else
		smtpConnectObj.cc	:=	null;
	endif;
	
	comments	:=	"This message was generated by " &amp;
					app.userName() &amp; "@" &amp; app.computerName() &amp;
					" - JADE " &amp; app.getSystemVersion() &amp;
					" (app=" &amp; app.name &amp; ")";
	
	smtpConnectObj.comments	:=	comments;					// Comments

	// Indicate that we're sending the message.

	self.doShowStatus("Sending...");
//	app.myCnCntrl.cnWriteLog(	CnCntrl.CnLogComment,
//								"Email message to " &amp; smtpConnect.sendTo &amp;
//								" from " &amp; smtpConnect.sendFrom &amp;
//								" (" &amp; app.userName() &amp; "@" &amp; app.computerName() &amp; ")" &amp; CrLf &amp;
//								"Subject: " &amp; smtpConnect.subject &amp; CrLf &amp;
//								"Message: " &amp; smtpConnect.message,
//								null);

	// Send it!
	smtpConnectObj.send();
epilog
	return self.doShowError();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetDefaults" id="dbd5a312-ef33-437a-adee-06ef65a88ecf">
        <updating/>
        <source>doSetDefaults() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Initializes the forms controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if app.computerName().toLower = "cnwdad1a" then
		cmbAddressFrom.listIndex	:=	cmbAddressFrom.findStringExact(1, self.ADDRESS_DARRELL);
		cmbAddressTo.listIndex		:=	cmbAddressTo.findStringExact(1, self.ADDRESS_LUCY);
	endif;
	
	chkIsCopy.value		:=	true;
	txtCaller.text		:=	null;
	txtOf.text			:=	null;
	txtPhone.text		:=	null;
	optCalled.value		:=	true;
	txtMessage.text		:=	null;

	txtCaller.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowError" id="3fec1532-5100-49d1-993f-e7f95ea76a57">
        <updating/>
        <source>doShowError():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Displays an error message if one has been set on the form.
//
// Parameters:	None
//
// Returns:		A flag to indicate whether an error message had been set.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	errorMessage	:=	self.aError;

	if errorMessage &lt;&gt; null then
		app.msgBox(errorMessage, $CNEC_ERROR, MsgBox_Stop_Icon + MsgBox_OK_Only);
	endif;
epilog
	self.aError	:=	null;
	return (errorMessage = null);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowStatus" id="2aea2a76-ae01-4ff4-b47e-81921658ed0a">
        <updating/>
        <source>doShowStatus(pStatus:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Displays a status message, and refreshes the status label control.
//
// Parameters:	pStatus (String) - The status message to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pStatus = null then
		staStatus.caption	:=	self.DEFAULT_STATUS;
	else
		staStatus.caption	:=	pStatus;
	endif;
	
	staStatus.refreshNow();
end;</source>
        <access>protected</access>
        <Parameter name="pStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCaller" id="a8a3bba3-b282-4513-88c7-fda44bd6c2b8">
        <source>getCaller():String protected;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Returns the name of the caller.
//
// Parameters:	None
//
// Returns:		The caller's details.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	callerDetails	: String;
	
begin
	callerDetails	:=	txtCaller.cnEcString();
	
	if txtOf.cnEcString() &lt;&gt; null then
		callerDetails	:=	callerDetails &amp; " of " &amp; txtOf.cnEcString();
	endif;
epilog
	return callerDetails;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessage" id="62801ff4-98e9-4f10-9d77-f5e909f10a7b">
        <source>getMessage():String protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Returns the Message body based upon the inputs.
//
// Parameters:	None
//
// Returns:		The formatted body of the message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlPageObj			: CnEcHtmlPage;
	pageHeadObj			: CnEcPageHead;
	pageBodyObj			: CnEcPageBody;
	tableObj			: CnEcHtmlTableTag;
	tableRowObj			: CnEcHtmlTableRowTag;
	tableCellObj		: CnEcHtmlTableDataTag;
	fontObj				: CnEcHtmlFontTag;
	message				: String;

begin
	create htmlPageObj transient;
	pageHeadObj				:=	htmlPageObj.myHead;
	pageHeadObj.headTitle	:=	"Phone Message";
	pageBodyObj				:=	htmlPageObj.myBody;
	
	tableObj					:=	pageBodyObj.createTable();
	tableObj.tableColumns		:=	2;
	tableObj.tableWidth			:=	"100%";
	tableObj.tableBorderWidth	:=	2;
	tableObj.tableCellPadding	:=	2;
	tableObj.tableCellSpacing	:=	2;
	
	// Build the message heading row.
	
	tableRowObj						:=	tableObj.createRow();
	tableRowObj.setTableAlign(CnEcHtmlTagObject.ALIGN_CENTER);
	tableRowObj.tableBackColor		:=	CNEC_HEX_BLUE;
	tableCellObj					:=	tableRowObj.createTableData();
	tableCellObj.tableColumnSpan	:=	2;
	fontObj							:=	tableCellObj.createFont();
	fontObj.setFontSize(1, true);
	fontObj.fontColor				:=	CNEC_HEX_WHITE;
	fontObj.fontValue				:=	"Phone Message for " &amp; cmbAddressTo.text &amp; "&lt;BR&gt;";
	fontObj							:=	tableCellObj.createFont();
	fontObj.fontColor				:=	CNEC_HEX_WHITE;
	fontObj.fontValue				:=	"taken on " &amp; app.actualTimeServer().cnEcShortFullFormat();
	
	// Build the caller row and cells.
	
	tableRowObj				:=	tableObj.createRow();
	tableRowObj.setTableVAlign(CnEcHtmlTagObject.ALIGN_TOP);
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.tableWidth	:=	"120";
	tableCellObj.cellValue	:=	"&lt;B&gt;Caller&lt;/B&gt;";
	tableCellObj			:=	tableRowObj.createTableData();
	
	if txtCaller.cnEcString() = null then
		tableCellObj.cellValue	:=	"-";
	else
		tableCellObj.cellValue	:=	self.getCaller();
	endif;
	
	// Build the phone number row and cells.
	
	tableRowObj				:=	tableObj.createRow();
	tableRowObj.setTableVAlign(CnEcHtmlTagObject.ALIGN_TOP);
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.tableWidth	:=	"120";
	tableCellObj.cellValue	:=	"&lt;B&gt;Phone number&lt;/B&gt;";
	tableCellObj			:=	tableRowObj.createTableData();
	
	if txtPhone.cnEcString() = null then
		tableCellObj.cellValue	:=	"-";
	else
		tableCellObj.cellValue	:=	txtPhone.cnEcString();
	endif;
	
	// Build the message row and cell.
	
	tableRowObj				:=	tableObj.createRow();
	tableRowObj.setTableVAlign(CnEcHtmlTagObject.ALIGN_TOP);
	tableCellObj			:=	tableRowObj.createTableData();
	tableCellObj.tableWidth	:=	"110";
	tableCellObj.cellValue	:=	"&lt;B&gt;Message&lt;/B&gt;";
	tableCellObj			:=	tableRowObj.createTableData();
	
	if txtMessage.cnEcString() = null then
		tableCellObj.cellValue	:=	self.getSubject(false);
	else
		tableCellObj.cellValue	:=	txtMessage.cnEcString();
	endif;
	
	message	:=	htmlPageObj.getHtml();
epilog
	delete htmlPageObj;
	
	return message;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedAddress" id="ff862b95-ea24-42e1-88a8-15ac6b48776c">
        <source>getSelectedAddress(pComboboxObj:CnEcComboBox):String protected;
// --------------------------------------------------------------------------------
// Created:		07 October 2001 by cnwdad1
//
// Purpose:		Returns the email address for the currently selected person.
//
// Parameters:	pComboboxObj
//
// Returns:		The selected person's email address.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj		: CnEcComboBox;
	addressIndex	: Integer;
	emailAddress	: String;

begin
	comboboxObj		:=	pComboboxObj;
	addressIndex	:=	comboboxObj.listIndex;
	
	if addressIndex = CNEC_NULL_INDEX then
		emailAddress	:=	null;
	else
		emailAddress	:=	'"' &amp; comboboxObj.itemText[addressIndex] &amp; '" ' &amp;
							comboboxObj.getItemValueString(addressIndex);
	endif;
epilog
	return emailAddress;
end;</source>
        <access>protected</access>
        <Parameter name="pComboboxObj" type="CnEcComboBox"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubject" id="c973ec07-87b3-4770-ae9e-4a1218d26403">
        <source>getSubject(pIsIncludeNumber:Boolean):String protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Returns the subject based upon the response option.
//
// Parameters:	pIsIncludeNumber - If true, the phone number, if present, will be
//				included in the subject.
//
// Returns:		The formatted Subject of the message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	callerDetails	: String;
	phoneNumber		: String;

begin
	callerDetails	:=	self.getCaller();
	phoneNumber		:=	txtPhone.cnEcString();
	
	if optCalled.value or optPleaseCall.value then
		if optCalled.value then
			callerDetails	:=	callerDetails &amp; " called";

			if phoneNumber &lt;&gt; null and pIsIncludeNumber then
				callerDetails	:=	callerDetails &amp; ": #" &amp; phoneNumber;
			endif;
		
		elseif optPleaseCall.value then
			callerDetails	:=	"Please call " &amp; callerDetails;

			if phoneNumber &lt;&gt; null and pIsIncludeNumber then
				callerDetails	:=	callerDetails &amp; " on " &amp; phoneNumber;
			endif;
		endif;
		
		if txtMessage.cnEcString() &lt;&gt; null then
			callerDetails	:=	callerDetails &amp; " (see message)";
		endif;
		
		return callerDetails;
		
	elseif optReturnedCall.value then
		return callerDetails &amp; " returned your call";
		
	elseif optWillCallBack.value then
		return callerDetails &amp; " called - will call back later";
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pIsIncludeNumber" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="9cd7a000-be25-4902-9815-7caca776e466">
        <controlMethod name="Form::load"/>
