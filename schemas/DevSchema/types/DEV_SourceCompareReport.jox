    <JadeMethod name="createGrouping" id="4734e129-b3de-4921-bf19-337210ed33da">
        <source>createGrouping(_user: String; grouping :JadeDynamicObject io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2025	navsaa30	Initial creation
21/5/2025 navsaa30 MTN-34812 MTN - Source Compare/Unit Test - Change Email to be a Summary Count by User - Phase1
*/

vars
   // grouping 				  : JadeDynamicObject;
	
begin
	
		//create grouping transient;		
		grouping.addProperty(GroupingUserName, String);
		grouping.setPropertyValue(GroupingUserName,_user);
		grouping.addProperty(GlobalCnstCatMissingCount, Integer);
		grouping.setPropertyValue(GlobalCnstCatMissingCount,0);
		grouping.addProperty(GlobalCnstCatDifferentCount, Integer);
		grouping.setPropertyValue(GlobalCnstCatDifferentCount,0);
		grouping.addProperty(GlobalCnstMissingCount, Integer);
		grouping.setPropertyValue(GlobalCnstMissingCount,0);
		grouping.addProperty(GlobalCnstDifferentCount, Integer);
		grouping.setPropertyValue(GlobalCnstDifferentCount,0);
		grouping.addProperty(ClassesMissingCount, Integer);
		grouping.setPropertyValue(ClassesMissingCount,0);
		grouping.addProperty(MethodsMissingCount,Integer);
		grouping.setPropertyValue(MethodsMissingCount,0);
		grouping.addProperty(MethodsDifferentCount, Integer);
		grouping.setPropertyValue(MethodsDifferentCount,0);
		grouping.addProperty(AttributesMissingCount, Integer);
		grouping.setPropertyValue(AttributesMissingCount,0);
		grouping.addProperty(AttributesDifferentCount, Integer);
		grouping.setPropertyValue(AttributesDifferentCount,0);
		grouping.addProperty(ConstantsMissingCount, Integer);
		grouping.setPropertyValue(ConstantsMissingCount,0);
		grouping.addProperty(ConstantsDifferentCount, Integer);
		grouping.setPropertyValue(ConstantsDifferentCount,0);
		grouping.addProperty(ReferencesMissingCount, Integer);
		grouping.setPropertyValue(ReferencesMissingCount,0);
		grouping.addProperty(ReferencesDifferentCount, Integer);
		grouping.setPropertyValue(ReferencesDifferentCount,0);
	
		
epilog

end;</source>
        <Parameter name="_user" type="String"/>
        <Parameter name="grouping" type="JadeDynamicObject" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayName" id="1d373ee0-227e-4294-b02e-6fab826a88a6">
        <source>getDisplayName() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 October 2022		navmd1	Initial creation

*/

vars

begin
	if self.reportType = DEV_SourceCompareReport.ReportType_Manual then
		// Manual / Full
		return self.timeStamp.String &amp; " - (Full)";
	endif;
	
	// Automatic / Short
	return self.timeStamp.String;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReport" id="ca07fadf-6f09-4a66-b3c6-03404e44451d">
        <source>getReport() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	concatenatedString 			: String;
	devSchema 					: DEV_Schema;
	devGlobalConstantCategory 	: DEV_GlobalConstantCategory;
	devGlobalConstant 			: DEV_GlobalConstant;
	devClass 					: DEV_Class;
	devAttribute 				: DEV_Attribute;
	devConstant 				: DEV_ClassConstant;
	devReference 				: DEV_Reference;
	devMethod 					: DEV_Method;
	wroteHeaderLine 			: Boolean;
	
	globalCnstCatMissingCount,
 	globalCnstCatDifferentCount,
	globalCnstMissingCount,
	globalCnstDifferentCount,
	classesMissingCount,
	methodsMissingCount,
	methodsDifferentCount,
	attributesMissingCount,
	attributesDifferentCount,
	constantsMissingCount,
	constantsDifferentCount,
	referencesMissingCount,
	referencesDifferentCount	: Integer;

begin
	
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Missing do
			if not wroteHeaderLine then
				concatenatedString &amp;= CrLf &amp; "Missing Global Constant Categories:";
				wroteHeaderLine := true;
			endif;
			
			concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp; " - " &amp; devGlobalConstantCategory.modifiedBy &amp;  " | " &amp; devGlobalConstantCategory.modifiedTimeStamp.String;
			globalCnstCatMissingCount += 1;
		endforeach;
	endforeach;
	
	if globalCnstCatMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Global Constant Categories Count: " &amp; globalCnstCatMissingCount.String;
	endif;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Different do
			if not wroteHeaderLine then
				concatenatedString &amp;= CrLf &amp; "DIffering Global Constant Categories:";
				wroteHeaderLine := true;
			endif;
			
			concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp; " - " &amp; devGlobalConstantCategory.modifiedBy &amp;  " | " &amp; devGlobalConstantCategory.modifiedTimeStamp.String;
			globalCnstCatDifferentCount += 1;
		endforeach;
	endforeach;
	
	if globalCnstCatDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing Global Constant Categories Count: " &amp; globalCnstCatDifferentCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do		
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devGlobalConstant in devGlobalConstantCategory.allConstants where devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if not wroteHeaderLine then
					concatenatedString &amp;= CrLf &amp; "Missing Global Constants:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp;  "::" &amp; devGlobalConstant.name &amp; " - " &amp; devGlobalConstant.modifiedBy &amp;  " | " &amp; devGlobalConstant.modifiedTimeStamp.String;
				globalCnstMissingCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if globalCnstMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Global Constants Count: " &amp; globalCnstMissingCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devGlobalConstant in devGlobalConstantCategory.allConstants where devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Different do
				if not wroteHeaderLine then
					concatenatedString &amp;= CrLf &amp; "Differing Global Constants:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp;  "::" &amp; devGlobalConstant.name &amp; " - " &amp; devGlobalConstant.modifiedBy &amp;  " | " &amp; devGlobalConstant.modifiedTimeStamp.String;
				globalCnstDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if globalCnstDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing Global Constants Count: " &amp; globalCnstDifferentCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	wroteHeaderLine := false;
