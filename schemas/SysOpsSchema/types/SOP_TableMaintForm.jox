    <JadeMethod name="cmbCamProtDesc_lostFocus" id="8ffba3b6-8ea7-4dd4-8176-90ac94e72c3b">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCamProtDesc_lostFocus(_combo: ComboBox input) updating;

// 01 Jul 2013	cnwcs5	par 31819 - moved code to setupJRWDesignComboAndSheets
// 11 Jun 2014	cnwrs1	Par 34159 - include CargoType in cam protocol
// 20 Jun 2014	cnwrs1	Par 3441 - 1090 when createing a new cam protcocol
//24 May 2016	cnwrs1	TFS 2008 - Vermas file changes
// 25 Aug 2025	navnk30	JIRA 35713: 5 - YARA | Create a external webservice history class(EWS) and agent for AgGateway
vars
	protocolDesc		: CM_CamProtocolDesc;
	item				: SOP_TableMaintItem;
	camItem				: SOPTM_CamProtocol;
	camProtocol : CM_CamProtocol;
	camProtocolProxy : CM_CamProtocol;
begin
	item := self.myCurrentTableItem;
	camProtocol := self.myCurrentObject.CM_CamProtocol;
	camProtocolProxy := self.myProxyObject.CM_CamProtocol;
	if item.isKindOf(SOPTM_CamProtocol) then
		camItem 		:= item.SOPTM_CamProtocol;
		protocolDesc 	:= app.myRoot.allCamProtocolDescs[_combo.text];
		camItem.setAvailableTransactions(protocolDesc);
		camItem.setAvailableEvents(protocolDesc);  //epr 35431 18/12/14
		camItem.setAvailableCargoTypes(camProtocol, protocolDesc);
		if camProtocolProxy &lt;&gt; null then
			camProtocolProxy.setProtocolDesc(protocolDesc);
		endif;
		if camProtocol &lt;&gt; null then
			camItem.setSelectedTransactions(camProtocol);
			camItem.setSelectedCargoTypes(camProtocol);	
		endif;
		self.setupJRWDesignComboAndSheets(protocolDesc, camItem);		
	endif;
	if camProtocolProxy &lt;&gt; null then
		self.showThumbnailData(camProtocolProxy);
	endif;
	
	if CM_CamAgGatewayDesc.hasInstance(_combo.listObject) then			//25AUG2025 navnk30 JIRA-35713
		self.myCurrentTableItem.SOPTM_CamProtocol.setViewForAgGatewayProtDesc();
	else
		self.tblInput1.setValueByName(ETRow_SendToWebService, null);
		self.cmbWebServiceType.listObject := null;
		self.tblInput1.enableRowByName(ETRow_SendToWebService);
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
