    <JadeMethod name="initModalDialog" id="bebdbda6-caa2-409b-ace2-acb337131aea">
        <source>initModalDialog();
// MES 1010 JMN moved up for use by doImport
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	
	theForm.frmModalDialog.centreWindow;
	theForm.frmProgressCtr.move(0,0,theForm.frmModalDialog.clientWidth,theForm.frmModalDialog.clientHeight);
	theForm.frmModalDialog.backColor := theForm.backColor;
	theForm.btnModalDefault.visible := false;
	theForm.pbProgressBar.top := 38;
	theForm.lblModalInfo.top := theForm.pbProgressBar.top + theForm.pbProgressBar.height + 2;
	theForm.pbProgressBar.zOrder(0);
end;</source>
    </JadeMethod>
    <JadeMethod name="initShtDataTable1" id="ab85d23e-bed4-42c2-b01e-d2e4ecdec2b4">
        <updating/>
        <source>initShtDataTable1() updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/02/2010	cnwrl1		PAR 22122 - correct the display on the user terminal access sheet
// ---------------------------------------------------------------------------
vars
	form	:SOP_TableMaintForm;
	table	:CM_DataTable;
	label	:Label;
begin
	form	:= self.myForm;
	table 	:= form.tblData1;
	label	:= form.lblTBDataTable1;
	
	table.clear;
	table.rows		:= 0;
	table.columns	:= 0;
	// all row/column formatting will be gone now
	table.rows		:= 1;
	table.columns	:= 1;
	table.fixedRows	:= 1;
	//table.accessRow(1).fontBold := false;
	
	table.wordWrap	:= false;
	table.autoSize	:= Table.AutoSize_Column;	//default
	table.selectMode := Table.SelectMode_Default;
	table.top		:= 0;
	table.left 		:= 0;
	table.width		:= table.parent.Control.clientWidth;
	
	form.frmTBDataTable1.visible	:= false;
	form.shtDataTable1.visible := false;
	
	label.autoSize	:= true;
	label.left		:= label.parent.Control.clientWidth - label.width - 10;
	label.top		:= (label.parent.Control.clientHeight/2) - (label.height/2);
	
	// cnwrl1 05/02/2010 PAR 22122 - start of coding
	// when the user has restricted access eg can only see the user code table
	// the Terminal Access sheet has the lblTBDataTable1 displayed incorrectly.
	// fix this by making sure the table is on top of the lblTBDataTable1 control.
	table.zOrder( 1 );
	// cnwrl1 05/02/2010 PAR 22122 - end of coding
	
end;
</source>
    </JadeMethod>
