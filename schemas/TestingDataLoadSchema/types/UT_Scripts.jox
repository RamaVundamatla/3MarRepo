    <JadeMethod name="uDeleteTerminal" id="46060886-87e8-4e35-9554-231d903bee04">
        <source>uDeleteTerminal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2012	cnwmc5	Initial creation

*/

vars
	terminalName 	: String;
	terminal 		: CM_Terminal;
	msg 			: String;
	terminalCode	: String;
	code			: String;
	
begin
	terminalName := "Enter Terminal Name";
	read terminalName;
	
	if terminalName = null then
		return;
	endif;

	terminal := app.myRoot.getTerminalByName(terminalName);	
	assertNotNull(terminal);
	code := terminal.code;
	msg := "Are you sure you want to delete this terminal?";
				
	if app.msgBox(msg, "WARNING!", MsgBox_Yes_No) = MsgBox_Return_Yes then
		beginTransaction;
			delete terminal;
			assertNull(app.myRoot.allTerminals[code]);
		abortTransaction;		
	endif;
epilog

end;</source>
    </JadeMethod>
