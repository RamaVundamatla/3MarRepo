    <JadeMethod name="resizeDrawingFrames" id="f09a9cad-f9e6-4e2b-97af-21fd29af5d65">
        <updating/>
        <source>resizeDrawingFrames() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwjk3	Initial creation

*/

vars

begin
	self.myDrawingFrame.left := -self.myViewportFrame.left - self.getScrollOffsetSize();
	self.myDrawingFrame.top := -self.myViewportFrame.top - self.getScrollOffsetSize();
	self.myDrawingFrame.width := self.myViewportFrame.width + self.getScrollOffsetSize()*2 + self.myViewportFrame.left;
	self.myDrawingFrame.height := self.myViewportFrame.height + self.getScrollOffsetSize()*2 + self.myViewportFrame.top;
	
	self.myTIFrame.left := -self.myViewportFrame.left - self.getScrollOffsetSize();
	self.myTIFrame.top := -self.myViewportFrame.top - self.getScrollOffsetSize();
	self.myTIFrame.width := self.myViewportFrame.width + self.getScrollOffsetSize() * 2 + self.myViewportFrame.left;
	self.myTIFrame.height := self.myViewportFrame.height + self.getScrollOffsetSize() * 2 + self.myViewportFrame.top;
	
	self.leftStartOffset := -self.myViewportFrame.left - self.getScrollOffsetSize();
	self.topStartOffset := -self.myViewportFrame.top - self.getScrollOffsetSize();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="scrollDown" id="e2b73eaa-e4a4-4def-8148-8f0c2b15a4f3">
        <updating/>
        <source>scrollDown() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars
	prevScrollOffset : Integer;
begin
	
	self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );
	
	// New
	if self.myDrawingFrame.top &lt; self.topStartOffset then
		// We need to adjust the top offset to maintain the buffer around the viewport
		self.myDrawingFrame.top := self.myDrawingFrame.top + self.vScrollAmount;
		self.myTIFrame.top := self.myTIFrame.top + self.vScrollAmount;
		if self.myDrawingFrame.top &gt; self.topStartOffset then
			self.myDrawingFrame.top := self.topStartOffset;
			self.myTIFrame.top := self.topStartOffset;
		endif;
	endif;
	//
	
	if self.flipV and self.vScrollOffset = 0 then
		if self.topGridRow &gt;=  self.maxGridRow then
			// New
			self.scrollDrawingFramesDown();
			//
			return;
		endif;	
	elseif self.vScrollOffset = 0 then
		if self.topGridRow = 1 then
			// New
			self.scrollDrawingFramesDown();
			//
			return;
		endif;	
	endif;
	
	if self.topOffset &gt; 0 then
		return;
	endif;
	
	
	if self.bottomOffset &gt; 0 then
		self.bottomOffset := (self.bottomOffset - self.vScrollAmount).Integer;
		if self.bottomOffset &lt; 0 then
			self.bottomOffset := 0;
		endif;
	else
		prevScrollOffset := self.vScrollOffset;		
		self.vScrollOffset := (self.vScrollOffset + self.vScrollAmount).Integer;		
		
		if self.vScrollOffset.abs() &gt; self.getGridHeight()-1 then
			self.vScrollOffset := 0;
			if self.flipV then
				if self.topGridRow = self.maxGridRow then			
					self.vScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesDown();
					//
				else
					self.topGridRow := self.topGridRow  + 1;
				
				
					// Only adjust bottom column if it doesn't fit on screen anymore
					if not self.canBottomRowFitOnScreen(self.bottomGridRow) then
						self.bottomGridRow := self.bottomGridRow + 1;
					endif;

				
				endif;
			else
				if self.topGridRow = 1 or self.bottomGridRow = 1 then 
					self.vScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesDown();
					//
				else
		
					self.topGridRow := self.topGridRow - 1;
			
					// Only adjust bottom row if it doesn't fit on screen anymore
					if not self.canBottomRowFitOnScreen(self.bottomGridRow) then
						self.bottomGridRow := self.bottomGridRow - 1;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	self.calcViewSizes();
	self.reCalcRowsCols();
	self.calcDrawRows();
	self.drawEverything();
	
	
	self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollDownOLD" id="f6735c1e-1981-4221-a43b-9a545632758b">
        <updating/>
        <source>scrollDownOLD() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars
	prevScrollOffset : Integer;
begin

	self.debugCols( "-------- " &amp; method.name &amp; " Before Cols ------- " );
	self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );	

	if self.flipV and self.vScrollOffset = 0 then
		if self.topGridRow &gt;=  self.maxGridRow then
			return;
		endif;
	elseif self.vScrollOffset = 0 then
			if self.topGridRow = 1 then
			return;
		endif;
	endif;
	
	//self.vScrollOffset := self.vScrollOffset + self.SCROLL_INCREMENT;		
	prevScrollOffset := self.vScrollOffset;
	self.vScrollOffset := (self.vScrollOffset + self.vScrollAmount).Integer;		

	if self.vScrollOffset.abs() &gt; self.getGridHeight()-1 then
		self.vScrollOffset := 0;		
		
		if self.flipV then	
			if  self.topGridRow = self.maxGridRow then
				self.vScrollOffset := prevScrollOffset;
			else
				self.topGridRow := self.topGridRow  + 1;
				self.bottomGridRow := self.bottomGridRow + 1;
			endif;
		else
			if self.topGridRow = 1 or self.bottomGridRow = 1 then 
				self.vScrollOffset := prevScrollOffset;
			else
				self.topGridRow := self.topGridRow - 1;
				
				// Only adjust the bottom row if it doesn't fit on screen anymore
				if not self.canBottomRowFitOnScreen(self.bottomGridRow) then
					self.bottomGridRow := self.bottomGridRow - 1;
				endif;
			endif;
		endif;
	endif;
	
	self.calcViewSizes();
	self.reCalcRowsCols();
	self.calcDrawRows();
	self.drawEverything();

	self.debugCols( "-------- " &amp; method.name &amp; " After Cols ------- " );
	self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );	

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollDrawingFramesDown" id="6d7ee4d9-d437-4b7e-b9a2-ec21bc44a44e">
        <source>scrollDrawingFramesDown() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.myDrawingFrame.top &lt; 0 then
		self.myDrawingFrame.top := 	self.myDrawingFrame.top + self.vScrollAmount;
		self.myTIFrame.top := 	self.myTIFrame.top + self.vScrollAmount;
		if self.myDrawingFrame.top &gt; 0 then
			self.myDrawingFrame.top := 0;
			self.myTIFrame.top := 0;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="scrollDrawingFramesLeft" id="4dfaceaa-8801-4303-85b0-7c721c36e608">
        <source>scrollDrawingFramesLeft() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwjk3	Initial creation

*/

vars

begin

	if self.myDrawingFrame.left &gt;  -self.getScrollOffsetSize() * 2 - self.myViewportFrame.left  then
		self.myDrawingFrame.left := self.myDrawingFrame.left - self.hScrollAmount;
		self.myTIFrame.left := 	self.myTIFrame.left - self.hScrollAmount;
		if self.myDrawingFrame.left &gt;  self.getScrollOffsetSize() * 2  - self.myViewportFrame.left then
			self.myDrawingFrame.left := self.getScrollOffsetSize() * 2;
			self.myTIFrame.left := self.getScrollOffsetSize() * 2 - self.myViewportFrame.left;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
