    <JadeMethod name="tSnapshotOutputFormat" id="6b4817a2-6e1b-47ba-b83c-078a83cd49bc">
        <source>tSnapshotOutputFormat();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	name : String;
	pxyFormat : CM_OutputFormat_SS;
	
	pxyField : CM_XTABField;
	pxyGrouping : CM_XTABGrouping;
	
	propertyName : String;
	function : Integer;
	functionString : String;
	
	realFormat : CM_OutputFormat_SS;
	field : CM_XTABField;
	grouping : CM_XTABGrouping;
	queryProperty : CM_QueryProperty;
	
	currentEdition : Integer;
	
	
begin

	// 23 Dec 2020 - string too long error probably caused by global constant 'AVERAGE' - integer = 83026

	name := "UT_MT_TEU";
	
	realFormat := app.myRoot.allOutputFormats_SS.getAtKey(name);
	if realFormat &lt;&gt; null then
		// clean up data before we start.
		app.myTrxDA.trxDeleteOutputFormat_SS(realFormat, app.myPassport);
	endif;

	//set up a basic Snap shot output definition.
	create pxyFormat transient;
	pxyFormat.setName(name);
	pxyFormat.setDescription("UT - Test suite - Empty TEU Snapshot Summary");
	pxyFormat.setModeAndType(1,0);
	
	
	//add a field
	function := CM_XTABField.Function_Sum;
	functionString := app.getErrorString( SUM );
	propertyName := CM_Container::getNumTEU.name;
	
	create pxyField transient;
	pxyField.setFunction( function );
	pxyField.setPropertyName( propertyName );

	pxyField.setHeading( functionString &amp; " (" &amp; propertyName &amp; ")" );

	pxyFormat.allFields.add( pxyField );
	
	
	//add a couple of groups
	create pxyGrouping transient;
	pxyGrouping.setPropertyName( CM_Container::contentsStatus.name );
	pxyFormat.allGroupings.add(pxyGrouping);
	
	create pxyGrouping transient;
	pxyGrouping.setPropertyName( CM_TrackedItem::operatorCode.name );
	pxyFormat.allGroupings.add(pxyGrouping);
	
	// Make the proxy persistent
	app.myTrxCA.trxCreateOutputFormatSS(pxyFormat, realFormat, app.myPassport);
	self.assertTrueMsg(realFormat &lt;&gt; null, "CM_OutputFormat_SS '" &amp; name &amp; "' not created.");
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//check to ensure we can derive the related queryPropertys of the persisted field and groupings
	foreach field in realFormat.allFields do
		queryProperty := field.getQueryProperty();
		self.assertTrueMsg(queryProperty &lt;&gt; null, "Query property not found for Field '" &amp; field.getName &amp; "'.");
	endforeach;
	
	foreach grouping in realFormat.allGroupings do
		queryProperty := grouping.getQueryProperty();
		self.assertTrueMsg(queryProperty &lt;&gt; null, "Query property not found for Grouping '" &amp; grouping.getName &amp; "'.");
	endforeach;
	
	//delete the proxy
	delete pxyFormat;
	
	//test the cloning of the persistent version
	beginLoad;
	pxyFormat := realFormat.cloneSelf( true );
	currentEdition	:= realFormat.edition;
	endLoad;
	
	self.assertTrueMsg(pxyFormat &lt;&gt; null, "Real format not cloned.");
	self.assertTrueMsg(pxyFormat.name = realFormat.name, "Real format 'name' not cloned.");
	self.assertTrueMsg(pxyFormat.description = realFormat.description, "Real format 'description' not cloned.");
	self.assertTrueMsg(pxyFormat.mode = realFormat.mode, "Real format 'mode' not cloned.");
	self.assertTrueMsg(pxyFormat.type = realFormat.type, "Real format 'type' not cloned.");
	self.assertTrueMsg(pxyFormat.allFields.size = realFormat.allFields.size, "Real format 'allFields collection' size differs after cloning.");
	self.assertTrueMsg(pxyFormat.allGroupings.size = realFormat.allGroupings.size, "Real format 'allGroupings collection' size differs after cloning.");
	field := realFormat.allFields.first;
	pxyField := pxyFormat.allFields.first;
	self.assertTrueMsg(pxyField.propertyName = field.propertyName, "Real format 'field.propertyName' not cloned properly.");
	self.assertTrueMsg(pxyField.function = field.function, "Real format 'field.function' not cloned properly.");
	grouping := realFormat.allGroupings.first;
	pxyGrouping := pxyFormat.allGroupings.first;
	self.assertTrueMsg(pxyGrouping.propertyName = grouping.propertyName, "Real format 'grouping.propertyName' not cloned properly.");
	
	//make changes to the proxy.
	pxyFormat.setDescription("UT - Test suite - Empty TEU Snapshot Summary : Updated");
	pxyFormat.setModeAndType(1,2);	// Booking reference Mode and Type
	
	function := CM_XTABField.Function_Average;
	functionString := app.getErrorString( AVERAGE );
	propertyName := "kg_" &amp; CM_BookingRef::totalWeightMap.name;
	
	pxyField.setPropertyName( propertyName );
	pxyField.setFunction( function );

	pxyField.setHeading( functionString &amp; " (" &amp; propertyName &amp; ")" );
	
	pxyFormat.allGroupings.purge;
	
	create pxyGrouping transient;
	pxyGrouping.setPropertyName( CM_BookingRef::getOperatorCode.name );
	pxyFormat.allGroupings.add(pxyGrouping);
	
	create pxyGrouping transient;
	pxyGrouping.setPropertyName( CM_BookingRef::getVoyageCode.name );
	pxyFormat.allGroupings.add(pxyGrouping);
	
	//call the update transaction.
	app.myTrxUA.trxUpdateOutputFormatSS(pxyFormat, realFormat, currentEdition, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	
	//check the changes have stuck.
	self.assertTrueMsg(pxyFormat.name = realFormat.name, "Real format 'name' not updated.");
	self.assertTrueMsg(pxyFormat.description = realFormat.description, "Real format 'description' not updated.");
	self.assertTrueMsg(pxyFormat.mode = realFormat.mode, "Real format 'mode' not updated.");
	self.assertTrueMsg(pxyFormat.type = realFormat.type, "Real format 'type' not updated.");
	self.assertTrueMsg(pxyFormat.allFields.size = realFormat.allFields.size, "Real format 'allFields collection' size differs after updating.");
	self.assertTrueMsg(pxyFormat.allGroupings.size = realFormat.allGroupings.size, "Real format 'allGroupings collection' size differs after updating.");
	field := realFormat.allFields.first;
	pxyField := pxyFormat.allFields.first;
	self.assertTrueMsg(pxyField.propertyName = field.propertyName, "Real format 'field.propertyName' not updated properly.");
	self.assertTrueMsg(pxyField.function = field.function, "Real format 'field.function' not updated properly.");
	grouping := realFormat.allGroupings.first;
	pxyGrouping := pxyFormat.allGroupings.first;
	self.assertTrueMsg(pxyGrouping.propertyName = grouping.propertyName, "Real format 'grouping.propertyName' not updated properly.");

	// test the delete transaction.
	if app.isValidObject(realFormat) then
		app.myTrxDA.trxDeleteOutputFormat_SS(realFormat, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
		
epilog

	endLoad;
	delete pxyFormat;

end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateMapping" id="84158d06-242b-479f-b759-7e5ee143d1a8">
        <source>uCreateMapping();
// ---------------------------------------------------------------------------
// Created:     26 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	NAME = 'UT_MAPPING';
vars
	proxy,
	mapping	:CM_XTABMapping;
	pxyLine	:CM_XTABMappingLine;
	def		:CM_QueryDefinition;
	prop	:CM_QueryProperty;
	op		:CM_QueryOperator;
begin
	self.deleteMapping (NAME);
	
	def 	:= app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container];
	prop	:= def.allQueryProperties[CM_Container::totalWeight.name];
	
	create proxy transient;
	
	proxy.setName (NAME);
	proxy.setDescription (NAME);
	proxy.setType (CM_QueryDefinition.TrackedItem_Query_Type);
	proxy.setMode (TI_CargoType_Container);
	proxy.setPropertyName (prop);
	proxy.setOrder (CM_XTABMapping.ORDER_MAPPING);
	proxy.setOtherValues (CM_XTABMapping.OTHER_GROUPED);
	proxy.setOtherHeading ('Other');
	
	create pxyLine transient;
	
	// &lt; 10000
	create pxyLine transient;
	
	create op as CM_QIntegerLessThanEquals transient;
	op.setSearchValue(10000);
	
	pxyLine.setMyQueryOperator (op);
	pxyLine.setMappedValue ('Under 10000');
	
	proxy.allMappingLines.add (pxyLine);

	// &lt; 20000
	create pxyLine transient;
	
	create op as CM_QIntegerLessThanEquals transient;
	op.setSearchValue(20000);
	
	pxyLine.setMyQueryOperator (op);
	pxyLine.setMappedValue ('Under 20000');
	
	proxy.allMappingLines.add (pxyLine);
	
	// &lt;30000
	create pxyLine transient;
	
	create op as CM_QIntegerLessThanEquals transient;
	op.setSearchValue(30000);
	
	pxyLine.setMyQueryOperator (op);
	pxyLine.setMappedValue ('under 30000');
	
	proxy.allMappingLines.add (pxyLine);
	
	app.myTrxCA.trxCreateXTABMapping (proxy, mapping, app.myPassport);
	

epilog

end;</source>
    </JadeMethod>
