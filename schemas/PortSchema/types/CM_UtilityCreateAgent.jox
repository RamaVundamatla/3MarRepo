    <JadeMethod name="utlCreateLogRow" id="fa7fe218-45bb-431d-bae7-4f70b676b8a9">
        <source>utlCreateLogRow(_cmifLogRow : CMIF_LogRowRestriction input; _realLogRow : CM_LogController output;
			_passport : CM_Passport input);

vars
	proxyRestriction, realRestriction 	: CM_LocationRestrictLog;
	proxyLogController						: CM_LogController;
	rowAreaRow							: CM_RowAreaRow;
	
begin
	
	self.initialiseActivity();
	create proxyLogController transient;
	create proxyRestriction transient;

	proxyLogController.setFromCMIF(_cmifLogRow);
	proxyRestriction.setFromCMIF(_cmifLogRow);
	app.myValCA.valLogRow(proxyRestriction, proxyLogController, _cmifLogRow, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	// Row &amp; restriction is correct now see if can fit in
	sharedLock(_cmifLogRow.myRowArea);

	if (not _cmifLogRow.isSplit) then
		create rowAreaRow persistent;
	else
		rowAreaRow := _cmifLogRow.myRowAreaRowTo;
	endif;

	// Now set width, work out position and update all other things.
	if rowAreaRow = null then//par 16805
		return;
	endif;
	
	rowAreaRow.setForCreateFromCMIFLogRow(_cmifLogRow);

	if _passport.noErrors then
		create realRestriction persistent;
		realRestriction.setForCreate(proxyRestriction);
	endif;
	
	if _passport.noErrors then
		create _realLogRow persistent;
		_realLogRow.setForCreate(proxyLogController, proxyLogController.myTerminalArea);
	endif;
	
	if _passport.noErrors then
		realRestriction.allLocationControllers.add(_realLogRow);
	endif;
	
	if _passport.noErrors then
		rowAreaRow.addController(_realLogRow);
	endif;
	
	if _passport.noErrors then
		global.causeEvent(_realLogRow.myTerminal.getTerminalEvent(EVENT_ROWCONTROLLER_CREATE), false, _realLogRow);
//		self.myCreateAuditAgent.audCreateGeneric(pNewRestriction);
		self.myCreateAuditAgent.audCreateGeneric(_realLogRow);	// 09/09/2009 cnwar2 CCMS-1107/#20627
	endif;

epilog
	delete proxyLogController;	//12 Jan 2011	NDL	- Leaking trans in unit test
	delete proxyRestriction;	//12 Jan 2011	NDL	- Leaking trans in unit test
end;</source>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction" usage="input"/>
        <Parameter name="_realLogRow" type="CM_LogController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
