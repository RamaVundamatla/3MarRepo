    <JadeMethod name="setComboValues" id="89ca60c4-f4a5-4160-8afb-a9349c9a304a">
        <source>setComboValues(comboBox 				: ComboBox input; 
			   queryCriteriaLineHolder 	: CM_QueryCriteriaLineHolder; 
			   queryOperator 			: CM_QueryOperator; 
			   passport 				: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 

/****Changes

Date			Name		TFS#		Description
21 Aug 2018		jlgka1		40200		Add Termninal description to the list Argument

 ----------   ----------  --------------------------------------------------*/
vars
	queryProperty			: CM_QueryProperty;
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	terminal				: CM_Terminal;
	bisUnit					: CM_Bank;
	object					: Object;
	objectSet				: ObjectSet;
	idx						: Integer;
	storeIdx				: Integer;
	selectStr				: String;
	str						: String;
	multiTerminal			: Boolean;
begin
	comboBox.clear();	
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	create objectSet transient;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		app.myRoot.allTerminals.copy(objectSet);
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		foreach bisUnit in terminal.companies do
			if multiTerminal then
				str := bisUnit.code &amp; Tab &amp; '- ' &amp; terminal.code &amp; Tab &amp; ' ('  &amp; bisUnit.mailingName &amp; ')';
			else
				str := bisUnit.code &amp; Tab &amp; ' ('  &amp; bisUnit.mailingName &amp; ')';
			endif;
			idx := comboBox.addItem(str);
			comboBox.itemObject[idx] := bisUnit;
			
			if bisUnit.code = selectStr then
				storeIdx := idx;
			endif;
		endforeach;
	endforeach;
	
	if storeIdx &gt; 0 and storeIdx &lt; comboBox.listCount then
		comboBox.listIndex := storeIdx;
	endif;
epilog
	delete objectSet;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="ce58b1ee-ff09-47c1-87c0-2ed7790e8cae">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 24 August 2018
TFS#		: 40200
Function	: Populate Selection List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	bisUnit					: CM_Bank;
	terminal				: CM_Terminal;
	object					: Object;
	objectSet				: ObjectSet;
	selectionValue			: Integer;
	idx						: Integer;
	array					: ObjectArray;
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	multiTerminal			: Boolean;
begin
	
	table.rows := table.fixedRows;
	
	array := table.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	create objectSet transient;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		app.myRoot.allTerminals.copy(objectSet);
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	
	foreach object in objectSet do
		terminal := object.CM_Terminal;		
		foreach bisUnit in terminal.companies do
		
			selectionValue := 0;
			if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(bisUnit.code) then
				selectionValue := 1;
				array.add(bisUnit);
			endif;		
			
			if multiTerminal then
				idx := table.addItem(selectionValue.String &amp; Tab  &amp; bisUnit.code  &amp; Tab &amp; '- ' &amp; terminal.code &amp; Tab &amp; ' (' &amp; bisUnit.mailingName &amp; ')');
			else
				idx := table.addItem(selectionValue.String &amp; Tab  &amp; bisUnit.code  &amp; Tab &amp; ' (' &amp; bisUnit.mailingName &amp; ')');
			endif;
			table.accessRow(idx).itemObject := bisUnit;
		endforeach;
	endforeach;
epilog
	delete objectSet;	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="8e63a2f3-9800-4741-aea3-1859ef151ff2">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	bisUnit		: CM_Bank;
	str			: String;
	numRows		: Integer;
	idx			: Integer;
	strArray	: StringArray;

begin

	create strArray transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			bisUnit := table.accessRow(idx).itemObject.CM_Bank;
			strArray.add(bisUnit.code);
		endif;
	endforeach;
	
	queryOperator.setSearchValue(strArray);

epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="7222e419-a9cc-4062-b905-c950ceea5f3b">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     16 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date			Who		TFS#			Reason
22 Oct 2008		cnwkpd1	PAR #18099		Handle null objects in selector queries
24/08/2018		jlgka1	40200			To fix dump error when it's coming from a Selection List.
*/

begin
	if _value.isKindOf(CM_Bank) then
		if _value &lt;&gt; null then
			return _value.CM_Bank.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	return null;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="3e02f185-0f24-45aa-b5ae-457a97d37dc3">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     16 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_Bank;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_Bank) then
			object := _value.CM_Bank;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="e43dfd40-0d8f-4584-a7de-146cebfed93e">
        <source>translateToSearchValueForWeb(_value : Any; _sending : Boolean) : Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	str, result, collStr : String;
	term : CM_Terminal;
	strArray : StringArray;
	bank : CM_Bank;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			result := result &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		result := result[1:result.length-2];
		return result;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			collStr.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		term := app.myPassport.myTerminal;
		if term &lt;&gt; null then
			bank := term.companies[_value.String];
			if bank &lt;&gt; null then
				return bank.code;
			endif;
		endif;
		
	endif;
	
	return inheritMethod(_value, _sending);
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
