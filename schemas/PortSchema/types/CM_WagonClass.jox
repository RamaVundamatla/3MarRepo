    <JadeMethod name="getWagonVisitClassToCreate" id="a4b23ebe-a6af-4669-b7bc-9b648e21f117">
        <source>getWagonVisitClassToCreate():Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2013	cnwndl1	Initial creation	par 31278

*/

vars

begin

	if self.isBoxcar then
		return CM_BoxcarVisit;
	elseif self.isFlatcar then
		return CM_FlatcarVisit;
	elseif self.isWellcar then	//Par 35346 / CCMS 1408
		return CM_WellcarVisit;
	elseif self.isSkeletonCar then	// TFS 2533
		return CM_SkeletonCarVisit;
	else
		return CM_FlatcarVisit;
	endif;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getWellAtPosition" id="18a50d92-de8e-46d3-976a-4601f14bb990">
        <source>getWellAtPosition( _lcPos : Integer; _posInWell : Integer output ):CM_WagonWellDefinition;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	posIndex : Integer;
	wellDef : CM_WagonWellDefinition;
	posInWell : Integer;

begin

	foreach wellDef in self.allWagonWellDefArray discreteLock do
		foreach _posInWell in 1 to wellDef.lenInUnits do
			posIndex := posIndex + 1;
			if posIndex = _lcPos then
				return wellDef;
			endif;
		endforeach;
	endforeach;
	
	_posInWell := 0;
	return null;

epilog

end;</source>
        <Parameter name="_lcPos" type="Integer"/>
        <Parameter name="_posInWell" type="Integer" usage="output"/>
        <ReturnType type="CM_WagonWellDefinition"/>
    </JadeMethod>
    <JadeMethod name="hasSelectableSealTypes" id="2ad819fa-fa23-457e-84b1-4aa8dadc8d3f">
        <source>hasSelectableSealTypes():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	sealType : CM_SealType;

begin

	foreach sealType in self.allSelectedSealTypes do
		if sealType.notAvailableForEntry then
			continue;
		endif;
		return true;
	endforeach;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
