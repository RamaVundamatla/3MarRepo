        <updating/>
        <source>btnCloneIn_click(btn: Button input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	N.B This will be a cloned button coming through in the signature with 'tag' attribute
			set so identify which one it is.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.showingForInwards := true;
	self.doShowFrmInfo(btn.tag.Integer);

end;


</source>
