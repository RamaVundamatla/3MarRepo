    <JadeMethod name="doNotableAdd" id="a3faa394-812d-43e1-af3b-a6f6c7be736f">
        <source>doNotableAdd(_anObject: Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2024	jlier1	Initial creation  JIRA#33496 

*/

vars

begin

	if not self.allNotableObjects.includes(_anObject) then
		if _anObject.isKindOf(CM_Train) then
			self.beginNotification(_anObject, self.myTerminal.getTerminalEvent(EVENT_TRAIN_REFRESH), Response_Continuous, null);
		endif;
	endif;
	inheritMethod(_anObject);
	
	

epilog

end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="8fee418b-ac8c-4d5e-93f1-ac25b1b971b1">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_Train) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_TRAIN_REFRESH)); //jlier1 JIRA#33496 5/12/24
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
