        <show3D>3</show3D>
        <tabIndex>608</tabIndex>
        <tabStop/>
        <backColor>-2147483633</backColor>
        <bubbleHelp>If checked the system will search for cargo that is 
currently overstowing cargo for a different voyage. 
 This is to highlight cargo that can potentially 
be moved to consolidate it.</bubbleHelp>
        <enabled/>
        <height>17</height>
        <left>20</left>
        <top>121</top>
        <visible/>
        <width>200</width>
    </CMUI_CheckBox>
