    <JadeMethod name="setupForm" id="2cdded6f-fad9-4c60-a905-8b970ae312d5">
        <updating/>
        <source>setupForm() updating;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.setNavigatorHeading(self.caption);
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	self.timerTS := null;
	self.widthDTColumn := 150;
	self.widthValueColumn := 100;
	self.colorRow1 := self.colorHeadingColumn;	
	self.colorRow2 := self.colorValueColumn;
	
	self.shtSearch.caption := app.getErrorString(Query_parameters) ;
	self.loadTaskTypes();
	self.cmbOrganisation.listCollection(app.myRoot.allOrganisations, true, 0);
	self.doResetSearch();

	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_WorkOrderSchedule_Update), Response_Continuous, 0);

epilog

end;</source>
