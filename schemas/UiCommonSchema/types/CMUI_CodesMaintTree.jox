    <JadeMethod name="doMnuFormContextMenu" id="71c57295-7171-4c33-9a9a-70599b5c5a73">
        <updating/>
        <source>doMnuFormContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 13 February 2004
//
//********************************************************************
vars
	tmpVMObject	: SOP_ViewModelObject;
	tmpObject	: CM_Object;
	
begin
	tmpVMObject := self.myCurrentVMObject;
	if tmpVMObject &lt;&gt; null then
		tmpObject := tmpVMObject.myObject;
		if tmpObject &lt;&gt; null and
		   (not tmpObject.isTransient) then
			self.myCurrentObject := tmpObject;
		endif;
	endif;
	
	return inheritMethod(conwin, mouse, x, y);

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPicClick" id="1cb19370-2ec4-405e-b05a-a70843af5759">
        <updating/>
        <source>doPicClick(_index: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		18 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	vmObj : SOP_ViewModelObject;
	needToExpand : Boolean;
	numRows : Integer;
	i : Integer;
begin
	vmObj := self.lstData.itemObject[_index].SOP_ViewModelObject;
	
	needToExpand := not self.lstData.itemExpanded[_index];
	
	//19 June 2013	NDL	Par 31770
	if needToExpand then
		self.replaceDummyLineInTree( vmObj, _index );
	endif;

	vmObj.setExpanded(needToExpand);

	self.lstData.itemExpanded[_index] := needToExpand;

	self.selectVMObject(vmObj, false);
end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="adbc2af0-7307-4c82-900b-acce68755fc1">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	10 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	inheritMethod();
	
	lblView.top 		:= self.frmToolbar.height + VerticalSpacing;
	cmbCodeGroup.top 	:= lblView.top;
	self.chkInclNotAvail.left := self.cmbCodeGroup.left + self.cmbCodeGroup.width + 25;
	self.chkInclNotAvail.top := self.cmbCodeGroup.top;
	self.chkInclNotAvail.width := 200;
	sptMain.top := cmbCodeGroup.top + cmbCodeGroup.height + VerticalSpacing;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="f0f12efc-bb68-4236-92d8-9e2dd55504c8">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	reset,
	result	: Boolean;	
	index	: Integer;

begin
	if self.myCurrentVMObject = null then //rs nov 2004 this should not be necassary
		return false;
	endif;
	if self.myCurrentVMObject.doSave() then

		reset := self.myCurrentVMObject.myObject.isKindOf(CM_CodeGroup);
		self.showTree(self.currentGroupType, reset);
		if not reset then
			if self.myCurrentVMObject.myParent.expanded then
				self.selectVMObject(self.myCurrentVMObject, true);
				else
				self.selectVMObject(self.myCurrentVMObject.myParent, false);
			endif;
		endif;
	endif;
	result := app.myPassport.noErrors();	
	if (not result) then
		app.showErrorWarningDialog('Errors', app.myPassport, ErrWarnMode_AddUpdate);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	else

		self.clearErrorWarnings();
		self.lstData.enabled := true; //epr par 16846 can get error 4s because this is enabled when it shouldn't be
	endif;
	
	return result;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowCodeGroup" id="945755dc-682d-4450-bd66-c42a1889de04">
        <updating/>
        <source>doShowCodeGroup() updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	vmObj			: SOP_ViewModelObject;
	myObject : CM_Object;

begin

	if self.currentGroupType &lt;&gt; self.allCodeGroupKeys[self.cmbCodeGroup.listIndex] then
		self.tblInput1.setValueByName(ETRow_Name, null);
//	currentGroupType	:= self.cmbCodeGroup.listIndex;
		currentGroupType	:= self.allCodeGroupKeys[self.cmbCodeGroup.listIndex];
		
		self.showTree(currentGroupType, true);
		vmObj := self.allVMObjects.first.SOP_ViewModelObject;
		self.selectVMObject(vmObj, false);
		self.setNavigatorHeading(cmbCodeGroup.text);
	endif;
	
	//21 June 2013	NDL	Par 31770
	if vmObj = null then
		self.chkInclNotAvail.visible := false;
	else
		myObject := vmObj.myObject;
		if myObject = null or myObject.CM_CodeGroup.groupType = CodeGroup_AvailabilityGrade then
			self.chkInclNotAvail.visible := false;
		else
			self.chkInclNotAvail.visible := true;	
		endif;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDeleteTV.enabled:= false;
		self.btnEditTV.enabled:= false;
		self.btnNewChildTV.enabled:= false;
		self.btnNewTV.enabled:= false;
		
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doTreeSelect" id="6af9db07-b50c-4c9e-8647-1405cfe15a57">
        <updating/>
        <source>doTreeSelect(_obj : SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		18 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	
begin
	if self.myLastVMObject &lt;&gt; self.myCurrentVMObject then
		self.myLastVMObject := self.myCurrentVMObject;
	endif;
	
	self.setMyCurrentVMObject(_obj); //epr par 16841 17/7/08

	if self.myCurrentVMObject &lt;&gt; null then
	//	if self.myCurrentVMObject.myParent.expanded then
			self.myCurrentVMObject.setControlsForView();	
			self.myCurrentVMObject.doSelected();	
		//	else			
		//	self.setMyCurrentVMObject(self.myCurrentVMObject.myParent);
		//	self.myCurrentVMObject.setControlsForView();	
		//	self.myCurrentVMObject.doSelected();
		//	endif;
	endif;
	
end;</source>
        <Parameter name="_obj" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="getCurrentVMObject" id="22df3d63-a53a-472d-9cac-04d2ec18fd07">
        <source>getCurrentVMObject() : SOP_ViewModelObject protected;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.lstData.listIndex &lt;&gt; -1 then
		return self.lstData.itemObject[self.lstData.listIndex].SOP_ViewModelObject;
