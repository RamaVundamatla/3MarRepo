// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.y2 - ((pIdx) * self.cellHeight);
	
end;</source>
        <Parameter name="pIdx" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
