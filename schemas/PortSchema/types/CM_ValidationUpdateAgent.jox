    <JadeMethod name="valUpdateVoyageKPIStats" id="3e587021-3648-4bfd-b990-6477c11fdab9">
        <source>valUpdateVoyageKPIStats(_voyage :CM_Voyage; _passport :CM_Passport);
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by concms1
// Purpose:     PAR 16982
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	terminal	:CM_Terminal;
begin
	if _voyage = null then
		return;	// should not happen
	endif;
	
	terminal := _voyage.myTerminal;		
	
	if terminal &lt;&gt; null then			
		// if the passport terminal is null then we are sure to get errors somewhere else so won't handle that case
		if terminal.allShiftsStandard.isEmpty then	
			app.raiseCMWarning1 (ERR_SHIFTS_NOT_DEFINED, terminal.code, null, null, null); 
		endif;							
	endif;								
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="valUser" id="a597aa0b-b803-42bc-ab8b-87e0651f1f18">
        <source>valUser(pProxyUser, pRealUser : CM_User; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNull(pProxyUser, 'Proxy User');
	pProxyUser.raiseExceptionIfNotProxy(method);
	pProxyUser.validateForUpdate(pRealUser, _passport);
end;</source>
        <Parameter name="pProxyUser" type="CM_User"/>
        <Parameter name="pRealUser" type="CM_User"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="valUserPassword" id="931e22db-fd1b-462b-a946-bb2716c7e5cb">
        <source>valUserPassword(pCheckOld : Boolean; pUserName, pOldPass, pNewPass, pNewPass2 : String; pUser : CM_User output; pUserEdition : Integer output);
// ---------------------------------------------------------------------------
// Created:     07 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 Feb 2025	navah1	Story 14660: MTN - New option to disable users from changing their own passwords
// ---------------------------------------------------------------------------
vars
	theUser	: CM_User;
	
begin

	theUser := app.myRoot.allUsers[pUserName.toUpper];
	
	if theUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'user code', null, null);
		app.raiseCMException(Input_required_field_userCode, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if not theUser.canChangePassword() then 	//04.02.2025 navah1 #14660
		app.raiseCMException1(PasswordChangeProhibited, theUser.code, null, null);
		return;
	endif;
	
	// do a beginLoad to ensure we have the latest edition of the user.
	beginLoad;
	
  	theUser.validatePasswordChange(pCheckOld, pOldPass, pNewPass, pNewPass2);

	pUser		 := theUser;
	pUserEdition := theUser.edition;

epilog
	endLoad;
	
end;</source>
        <Parameter name="pCheckOld" type="Boolean"/>
        <Parameter name="pUserName" type="String"/>
        <Parameter name="pOldPass" type="String"/>
        <Parameter name="pNewPass" type="String"/>
        <Parameter name="pNewPass2" type="String"/>
        <Parameter name="pUser" type="CM_User" usage="output"/>
        <Parameter name="pUserEdition" type="Integer" usage="output"/>
    </JadeMethod>
