<Class name="CMQF_CraneKPI">
    <JadeMethod name="setFromAgent" id="d9486d89-855a-4c27-93ad-ba7db0e1d939">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
// Dec 2010 CCMS 1134 Crane KPI reporting
vars
	time	:Time;
begin
	inheritMethod(_agent);

	if _agent.isRowIncluded(ETRow_Crane) then
		self.allCranes.clear;
		_agent.getSelectedCranes(self.allCranes);
	endif;
	if _agent.isRowIncluded (ETRow_StartTime) then
		self.startTime  := _agent.getValueByNameIfVisible(ETRow_StartTime).Time;
	endif;
	if _agent.isRowIncluded (ETRow_EndTime) then
		self.endTime  := _agent.getValueByNameIfVisible(ETRow_EndTime).Time; 
	else
		self.endTime := '23:59:59:999'.Time;
	endif;
epilog

end;
</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
