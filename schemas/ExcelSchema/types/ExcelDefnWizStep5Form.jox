    </ImplicitInverseRef>
    <JadeMethod name="loadForm" id="5bc9a018-9556-4fa2-b0f3-7be7569d13fb">
        <updating/>
        <source>loadForm() updating;

/*****************************************************
	Written by	:	cnwpra1		09 June 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	lblWarning.caption := 'To load the test data you must know where to get the appropriate data. The data returned will be loaded into the "Source data worksheet" you specified in Step 1.' &amp; CrLf &amp; CrLf &amp;
							'The application specific data will be placed row by row into the Source data worksheet. You will then be able to modify the workbook to process the loaded data and test the workbook display.' &amp; CrLf &amp; CrLf &amp;
							'Note that when the workbook is saved in Step 6, the contents of all cells in the Source data worksheet are cleared. Consequently, you should not include any permanent analysis in this worksheet.';
	
	inheritMethod;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProcessingParameters" id="e888e218-cc27-478b-b1d3-a4d3cc604162">
