    <JadeMethod name="isConsignor_Match" id="e2b78a78-48fe-4ef0-b3b0-64b07ae19ee1">
        <source>isConsignor_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------
vars

	yaData : CM_YAData;
	yaDataObjs : CM_YADataObjects;
	obj : Object;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_Consignor );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataObjects) then
		yaDataObjs := yaData.CM_YADataObjects;
		if not yaDataObjs.isEmpty then
			obj := yaDataObjs.getFirstObject;
		endif;
		if obj &lt;&gt; null then
			return _yaData.includes(obj);
		endif;
	endif;
		
	return true;
	
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isControlledAtmosphere_Match" id="1cdfb9b9-0b6f-4f39-bd37-e4a16cd594fc">
        <source>isControlledAtmosphere_Match( _yaData: CM_YADataBoolean ): Boolean;
// -------------------------------------------
// Created 18 September 2007 by cnwvu1
// -------------------------------------------

vars

	yaData : CM_YAData;
	yaDataBoolean : CM_YADataBoolean;
	booleanValue : Boolean;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_IsCA );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataBoolean) then
		yaDataBoolean := yaData.CM_YADataBoolean;
		if yaDataBoolean &lt;&gt; null then
			if yaDataBoolean.value =  CM_YADataBoolean.VALUE_EITHER then
				return true;
			endif;
			booleanValue := yaDataBoolean.getValueAsBoolean();
			return _yaData.doesValueMatch( booleanValue );
		endif;
	endif;

	if self.myTrackedItem = null then	//Par15224. It = null, when for example, releasing by entering pinNo of Release Request in Kiosk appplication
		return true;
	endif;
	
	if self.myTrackedItem.isContainer() then
		return _yaData.doesValueMatch( self.myTrackedItem.CM_Container.isControlledAtmosphere );
	else
		return false;
	endif;
	
end;
</source>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCountryOfDestRegion_Match" id="c79bc7e4-0150-4d35-ad43-e909c92df168">
        <source>isCountryOfDestRegion_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria

*/

vars
	yaData 		: CM_YAData;
	yaDataObjs 	: CM_YADataObjects;
	obj 		: Object;
begin

	yaData := self.getExtraCriteriaMatchData( YACriteriaType_CountryOfDestRg );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataObjects) then
		yaDataObjs := yaData.CM_YADataObjects;
		
		if not yaDataObjs.isEmpty then
			obj := yaDataObjs.getFirstObject;
		endif;
		
		if obj &lt;&gt; null then
			return _yaData.includes(obj);
		endif;
	endif;
	
	return true;

epilog

end;</source>
