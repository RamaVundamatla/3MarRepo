    <JadeMethod name="addToolbarControls" id="b2209a9c-7845-4ef2-a769-ef7927b1225d">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		05 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnShowSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="2cdd76e5-7121-4cd3-94ae-024e771dd17b">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		05 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.permissionView	 := PdAdmKPIFormView;
	self.permissionMaint := PmAdmKPIFormMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTree" id="d755fc9e-ed3d-423d-b4bf-7df6a9f9ed79">
        <updating/>
        <source>loadTree() updating;
// ---------------------------------------------------------------------------
// Created:		05 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx						: Integer;
	canKPI 			: Boolean;
	level					: Integer;
begin
//	canKPI := app.myPassport.myUser.canDo(self.myTerminal, PmKPIModule);
	canKPI := app.myPassport.myUser.canDo(self.myTerminal, Mod_BaseSystem);//07 Oct 2019	NDL	TFS 46169



	self.lstTree.clear();
	self.lstTree.visible := true;
	level := 1;

	idx := self.lstTree.addTreeObject("KPI Options", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIRoot.picture;
	
	// ### VOYAGE KPI OPTIONS
	level := 2;
	idx := self.lstTree.addTreeObject("Voyage", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIVoyage.picture;
	level := 3;
	idx := self.lstTree.addTreeObject("Voyage Timings", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	self.lstTree.itemEnabled[idx] := canKPI;
	level := 3;
	idx := self.lstTree.addTreeObject("Voyage Profile", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	level := 3;
	idx := self.lstTree.addTreeObject("Voyage Bay", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	self.lstTree.itemEnabled[idx] := canKPI;
	level := 3;
	idx := self.lstTree.addTreeObject("Voyage Moves", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	self.lstTree.itemEnabled[idx] := canKPI;
	level := 3;
	idx := self.lstTree.addTreeObject("Voyage Delays", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	self.lstTree.itemEnabled[idx] := canKPI;

	
	// ### YARD KPI OPTIONS
	level := 2;
	idx := self.lstTree.addTreeObject("Yard", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIYard.picture;
	level := 3;
	idx := self.lstTree.addTreeObject("Yard Utilisation", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	self.lstTree.itemEnabled[idx] := canKPI;
	level := 3;
	idx := self.lstTree.addTreeObject("Yard Utilisation Detail", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	self.lstTree.itemEnabled[idx] := canKPI;
	level := 3;
	idx := self.lstTree.addTreeObject("Yard Allocation Mismatch", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	self.lstTree.itemEnabled[idx] := canKPI;
	level := 3;
	idx := self.lstTree.addTreeObject("Yard Hazardous Mismatch", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	self.lstTree.itemEnabled[idx] := canKPI;
	level := 3;
	idx := self.lstTree.addTreeObject("Yard Truck Turnaround", null, level, true);
	self.lstTree.itemPicture[idx] := self.picKPIOption.picture;
	self.lstTree.itemEnabled[idx] := canKPI;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="34fa0071-5be3-4975-b30a-222f6697610f">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		05 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.isShowingForObject := false;
	self.mode := self.Mode_View;
	self.allowFrameTopLeft := true;
	self.allowFrameBottomLeft := false;
	self.allowFrameTopRight := false;
	self.allowFrameBottomRight := true;
	
	inheritMethod();
	self.btnDelete.visible := false;
	self.btnAddChild.visible := false;
	self.btnNext.visible := false;
	self.btnAddParent.visible := false;
	self.btnNew.visible := false;
	self.btnSaveBase.visible := false;
	self.btnEdit.visible := false;
	self.isShowingForObject := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3ed49021-73cd-4be7-9e9a-8aa8350cff12">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007779, locale);
end;</source>
    </JadeMethod>
</GUIClass>
