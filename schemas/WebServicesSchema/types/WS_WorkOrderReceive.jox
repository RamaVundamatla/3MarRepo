<Class name="WS_WorkOrderReceive" id="9a7193e2-0fb3-4506-b908-12b00e25f2af">
    <superclass name="WS_WorkOrderDetail"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="bookingNum" id="8b75b76f-565b-4ec7-8a05-ca853f5b6be8">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="bookingOid" id="1d17613c-87f3-45cf-82b3-a8c7ef2d010f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="customExportEntryNumber" id="813ef0c2-73a4-47db-a2f0-cc1ddd568e32">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="createProxyWorkOrder" id="64ecae81-1a8f-4e7d-aafb-e38811ca18c8">
        <source>createProxyWorkOrder(): CM_WorkOrderTIDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation

*/

vars

	pxyWorkOrder : CM_WodReceive;

begin
	create pxyWorkOrder transient;
	

	return pxyWorkOrder;

epilog

end;</source>
        <ReturnType type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="f878153d-85d9-44a8-8944-db407106bbdf">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodReceive) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 
16 May 2018	jlger1	Initial creation 38520
20/06/2018  cnwma1	ChangeRequest 38815: PEL1 - WP TI Work Order Changes
*/

vars
	invalidBooking : Boolean;

begin
	inheritMethod(_object);
	on Exception do app.handleDeletedObject(exception,_object.myBookingRef,invalidBooking);
	
	if _object.myBookingRef &lt;&gt; null then
		self.bookingOid := _object.myBookingRef.getOidAsString;
		if not invalidBooking then
			self.bookingNum:= _object.myBookingRef.bookingReference;
		endif;
	endif;
	self.customExportEntryNumber := _object.customExportEntryNumber;//20.6.2018 cnwma1 TFS #38815
	
	self.setProxyToDoTasks(_object);
	
	
epilog
	
end;</source>
        <Parameter name="_object" type="CM_WodReceive"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="6ef2884f-3c0d-40e1-bf63-fa035f3e5122">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodReceive input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation
20 Mar 2024 navlc30 Bug 62906: MTN - Unable to Action the task for the receive work orders created from webportal

*/

vars
	booking : CM_BookingRef;
	
begin
	inheritMethod(_pxyWorkOrder);
	
	/*
	//12.01.2023 navma1 #56141 Task#56147
	booking:= app.myPassport.getObjectOfTypeFromOid(self.bookingOid,CM_BookingRef).CM_BookingRef;
	if booking &lt;&gt; null then
		if _pxyWorkOrder.myParent &lt;&gt; null and _pxyWorkOrder.myParent.CM_WorkOrderTI.mySource &lt;&gt; null then
			if not _pxyWorkOrder.myParent.CM_WorkOrderTI.mySource.allBookings.includes(booking) then
				_pxyWorkOrder.myParent.CM_WorkOrderTI.mySource.proxyAddBooking(booking);
			endif;
		endif;
	endif;
	*/

	self.updateProxyToDoTasks(_pxyWorkOrder);

	//Defaulting the Transport mode to Road																		//20.03.2024 navlc30 #62906
	_pxyWorkOrder.CM_WodReceive.setTransportMode(TI_TRANSMODE_ROAD);											//20.03.2024 navlc30 #62906	
	
epilog


end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodReceive" usage="input"/>
    </JadeMethod>
</Class>
