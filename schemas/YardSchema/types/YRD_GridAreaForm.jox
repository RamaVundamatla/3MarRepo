    <JadeMethod name="doMnuLogPreviousClick" id="22bd0b9d-bac5-46f2-94ee-ac4c12575984">
        <updating/>
        <source>doMnuLogPreviousClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aLabela, aLabelb : String;
	lForm : CMUI_GetData;
	previousName	: String;
	prevDistance	: Real;
	anIndex : Integer;
begin

	if not  menuItem.userObject.isKindOf(CM_RowAreaRow) then
		return;
	endif;
	if  menuItem.userObject = null then
		return;
	endif;

	self.myRowAreaRow := menuItem.userObject.CM_RowAreaRow;
	create lForm;
	lForm.centreWindow;
	self.mousePointer := MousePointer_Default;
	
	aLabelb := self.mnuLogEnquire.userObject.CM_LogController.getID();

	// Call the rowArea method to return previous row controller.
	self.myRowAreaRow.myRowArea.getPreviousData(aLabelb, previousName, prevDistance, CM_RowArea.SEARCH_ACTUAL);

	aLabela := previousName;

	if aLabela &lt;&gt; null then
		lForm.lblTextCaption := "Enter the distance between rows " &amp; aLabela &amp; " &amp;&amp; " &amp; aLabelb;
	else
		lForm.lblTextCaption := "Enter the distance prior to  row "  &amp; aLabelb;
	endif;

	anIndex := self.myRowAreaRow.myRowArea.allRows.indexOf(self.myRowAreaRow);
	anIndex := anIndex - 1; // Get the gap index
	
	if anIndex &gt; 0 then
		 self.myRowAreaRow := self.myRowAreaRow.myRowArea.allRows[anIndex];
	endif;
	lForm.setLblTextFontSize( 10);
	lForm.txtData.text := self.myRowAreaRow.width.String;
	lForm.txtData.dataType := TextBox.DataType_Numeric;
	lForm.txtData.decimals := 2;
	lForm.myCaller := self;
	lForm.formCaption := "Set Gap Width";
	lForm.type := self.GetData_SetPrevWidth;
	lForm.doResize();
	lForm.show;
epilog
	mousePointer := MousePointer_Default;




end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuLogWidthClick" id="9da5b200-1a03-4ee5-860b-727c2a5eabc4">
