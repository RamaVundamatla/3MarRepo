    <JadeMethod name="translateForm" id="f927867c-286c-4017-a19d-55c3c2416327">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 January 2017 09:38:32.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021669, locale);
	btnCancel.translateBubbleHelp(Xlat_0021670, locale);
	btnCancel.translateCaption(Xlat_0021671, locale);
	btnClear.translateBubbleHelp(Xlat_0021672, locale);
	btnClear.translateCaption(Xlat_0021673, locale);
	btnGetWeight.translateCaption(Xlat_0021674, locale);
	btnRefresh.translateBubbleHelp(Xlat_0021723, locale);
	btnSave.translateBubbleHelp(Xlat_0021675, locale);
	btnSave.translateCaption(Xlat_0021676, locale);
	chkReceiptReq.translateCaption(Xlat_0021677, locale);
	lblCargoWeightCap.translateCaption(Xlat_0021678, locale);
	lblGate.translateCaption(Xlat_0021679, locale);
	lblGateLane.translateCaption(Xlat_0021680, locale);
	lblGatePrinter.translateCaption(Xlat_0021681, locale);
	lblRegno.translateCaption(Xlat_0021682, locale);
	lblSearchDays.translateCaption(Xlat_0021724, locale);
	lblWeibridge.translateCaption(Xlat_0021683, locale);
	lblWeighbridgeMessage.translateCaption(Xlat_0021684, locale);
	lblWgtOUT.translateCaption(Xlat_0021685, locale);
	mnuDeleteCurrentEntry.translateCaption(Xlat_0021686, locale);
	mnuInspectObj.translateCaption(Xlat_0021687, locale);
	mnuTableContext.translateCaption(Xlat_0021688, locale);
end;</source>
