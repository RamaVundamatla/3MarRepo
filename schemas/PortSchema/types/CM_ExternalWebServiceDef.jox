    <JadeMethod name="validateForCreate" id="36116b05-aadd-4f1e-b1f6-a9584e001f55">
        <source>validateForCreate();
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars
	existing : CM_ExternalWebServiceDef;
begin
	if self.name &lt;&gt; null then
		existing := app.myRoot.allExternalWebServices.getAtKey(self.name);
		if existing &lt;&gt; null then
			app.raiseCMException1(Exter_servi_with_name_apos1_al, self.name, app.getString(Id), null);
		endif;
	endif;
	
	self.validateMe();
epilog

end;</source>
    </JadeMethod>
