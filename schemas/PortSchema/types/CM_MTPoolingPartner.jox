<Class name="CM_MTPoolingPartner" id="11d5c69d-f0bc-41b6-9337-6f8afa52597f">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <ExplicitInverseRef name="myOperator" id="e48bded5-f19f-4493-804e-9aaf78a940eb">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Operator"/>
        <access>readonly</access>
        <Inverse name="CM_Operator::allPoolingPartners"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myPoolingParty" id="b260d461-770a-4fe9-af70-397324d37e15">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_MTPoolingParty"/>
        <access>readonly</access>
        <Inverse name="CM_MTPoolingParty::allPoolingPartners"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myTerminal" id="05e3e5c4-2c6f-4102-b803-6229da05eaf5">
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="percentageOfCharges" id="eb04889e-6c77-4575-827a-5709e0854aed">
        <precision>6</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="cd449693-7eb1-414a-9798-08988aea6657">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/12/2016	cnwdap1		Initial creation TFS 3039 Empty Container Pool Management
//
vars

begin
	if _attrName = ETRow_Percentage then
		return self.percentageOfCharges.asStringJMTWithPrecision(2, false);
	elseif _attrName = ETRow_MyOperator then
		return self.myOperator.code;
	elseif _attrName = ETRow_PoolParty then
		return self.myPoolingParty.code;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e0ea76be-c0b0-4ff7-aeb6-b3b3970b9f3a">
        <updating/>
        <source>setForCreate(_pxyPoolingPartner : CM_MTPoolingPartner) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/12/2016	cnwdap1		Initial creation TFS 3039 Empty Container Pool Management
// 10/05/2017	cnwdap1		TFS 4370 Allow pooling parties acroos multiple terminals
//
vars

begin
	self.percentageOfCharges := _pxyPoolingPartner.percentageOfCharges;
	self.myTerminal := _pxyPoolingPartner.myTerminal;							// TFS 4370
	self.myOperator := _pxyPoolingPartner.myOperator;
epilog

end;</source>
        <Parameter name="_pxyPoolingPartner" type="CM_MTPoolingPartner"/>
    </JadeMethod>
    <JadeMethod name="setMyPoolingParty" id="a616aa3e-bc3d-4a2d-84f2-aa26dd984653">
        <updating/>
        <source>setMyPoolingParty(_poolingParty : CM_MTPoolingParty) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/12/2016	cnwdap1		Initial creation TFS 3039 SNO Empty Container Pool Management
//
vars

begin
	self.myPoolingParty := _poolingParty;
epilog

end;</source>
        <Parameter name="_poolingParty" type="CM_MTPoolingParty"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="737f04e1-88e4-412b-8978-4b2ccdc57cdc">
        <updating/>
        <source>setProxy(_operator : CM_Operator; _terminal : CM_Terminal; _percentage : Decimal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/12/2016	cnwdap1		Initial creation TFS 3039 Empty Container Pool Management
// 10/05/2017	cnwdap1		TFS 4370 Allow pooling parties acroos multiple terminals
//
vars

begin
	self.percentageOfCharges := _percentage;
	self.myOperator := _operator;
	self.myTerminal := _terminal;						// TFS 4370
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_percentage" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="e61e82a5-7af0-4ac3-9737-422db915860e">
        <source>validateMe();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/12/2016	cnwdap1		Initial creation TFS 3039 SNO Empty Container Pool Management
//
vars

begin
	if self.myPoolingParty = null then
		app.raiseCMException1(REQUIRED_FIELD, ETRow_PoolParty, "myPoolingParty", null);
	endif;
	
	if self.myOperator = null then
		app.raiseCMException(Input_required_field_operator, "myOperator", null);
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
