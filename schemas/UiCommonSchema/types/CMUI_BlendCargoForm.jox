	self.optExistingTI.value := false;
	self.optCreateTI.value := true;
	self.optRecipe.value := false;
	self.optManual.value := false;
	self.doClickOutputCargoOptions();
	self.doClickBillOfMaterialOpts();

epilog

end;</source>
