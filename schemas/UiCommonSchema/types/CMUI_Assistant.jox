// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theTerminalArea : CM_TerminalArea;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin
	if _theTerminalArea = null then
		return;
	endif;
	
	theTerminalArea := _theTerminalArea;
	menuAction := app.myController.createMenuAction(PmAdmPadeditView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	aForm := menuAction.goToObject(null, null, false, null); 
	if aForm = null then
		return;
	endif;
	
	aForm.sendMsgWithParams("setInitializeWithObject",theTerminalArea,_areaMode,_initObject,_xmlFlipH,_xmlFlipV);
	aForm.show;	


end;</source>
