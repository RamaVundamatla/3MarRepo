    <JadeMethod name="doResize" id="082b0997-65cb-42aa-bf20-2ee5ff562d92">
        <source>doResize();
// ---------------------------------------------------------------------------
// Created:		01 August 2003  by Jason Chapman  (cnwjc2)
/* Changes

Date		Name	TFS#		Description
============================================================================
02 Nov 2009	cnwmh5	PAR21449 	remove line has we don't need to reinitialise
13 Dec 2016 cnwma1	TFS #2801*	Special Protocol Settings sheet display issues 
29 Aug 2017	jlgrs1	TFS 6772 	resize damage repair fields
20 Sep 2017	jlgrs1	TFS 7033 	Standard CODECO Corrections
19 Mar 2019	jlgka1  TFS 41641 	Change the bottom controller from self.chkIncludeExtraVGM 
								to form.chkRelaxedIdChecking. Adjust the picture scroll bar.
24 Apr 2019	jlgka1 	TFS 43785	Change bottom controller to form.chkUseCodecoNonStruc
29 Mar 2022 jlikaq	TFS 53181   Change bottom controller to from form.chkUseCodecoNonStruc to self.chkIsCustomsProtocol so it will adjust the scrool bar properly
18 Jul 2022	jlizm1	TFS 54142	Added chkIncludeNADMSForSMDG213
============================================================================*/
vars
	timeList		: CMUI_ListBox;
	frameObj		: CMUI_Frame;
	sheetWidth		: Real;
	sheetHeight		: Real;
	halfSheet		: Real;
	mulSelect		: CMUI_MultiSelectGroupBox;
	timeListResize 	: Real;
	form			: SOP_TableMaintForm;		// cnwcs5 July 2012
begin
	
	inheritMethod();
	
	form		:= self.myForm;					// cnwcs5 July 2012
	timeList 	:= form.timelistBox1;
	sheetWidth 	:= timeList.parent.width;
	sheetHeight := timeList.parent.height;
	
	if sheetWidth &gt; 480 then
		halfSheet 		:= sheetWidth/2;
		timeListResize 	:= 0;
	else
		halfSheet 		:= 240;
		timeListResize 	:= sheetWidth - halfSheet;
	endif;
	
	form.btnTimeAdd.left 	:= (halfSheet) - 80;
	form.btnTimeRemove.left 	:= (halfSheet) - 80;

	frameObj := form.frmInterval;
	
	frameObj.move(10, frameObj.top, (halfSheet)-10, frameObj.height);
	
	frameObj	:=	form.frmAdhoc;
	
	frameObj.move(10, frameObj.top, (halfSheet)-10, frameObj.height);

	form.btnRunAdhoc.left := (frameObj.width - 100);
	
	if timeListResize = 0 then
		timeList.move((halfSheet) + 10, timeList.top, halfSheet - 25, sheetHeight - timeList.top -10);
	else
		timeList.move((halfSheet) + 10, timeList.top, timeListResize - 25, sheetHeight - timeList.top -10);
	endif;
	
	mulSelect 				:= form.mulSelect41;
	mulSelect.height 		:= sheetHeight/2.5;
	form.mulSelect42.top 	:= mulSelect.top + mulSelect.height + 5;
	self.setPicSettingsScrollRange(self.chkIncludeNADMSForSMDG213, self.chkVERMASNAD);
end;</source>
    </JadeMethod>
    <JadeMethod name="doRunAdhoc" id="a1e653a3-1dae-4594-ae95-118e62f8eb6c">
        <source>doRunAdhoc(_camProtocol:  CM_CamProtocol; _startDate,_endDate:  TimeStamp; _logExcludedTransactions :Boolean);
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 16/07/2012	cnwcs5	par 29601 - log excluded transactions
// 13/02/2013	cnwcs5	CCMS SFW 1294 /par 30855 - translatable error messages
// 26/04/2023	navmd1	Make the warning of no BGP controller a little more obvious

vars
	heading		: String;
	code		: String;
	answer		: Integer;
	passport	: CM_Passport;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	heading	:= app.getErrorString (Adhoc_protocol_run);
	code 	:= _camProtocol.code;
	answer 	:= app.msgBox(app.getErrorString1 (Process_CAM_Protocol, code), heading, MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_No then
		return;
	endif;

	if app.isAppropriateBGPRunning(BGP_CamsRequest.name) then
		passport := app.myPassport;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateAdhocCamsRequest(_camProtocol, _startDate, _endDate, _logExcludedTransactions, passport);	// par 29601 July 2012
		
			if app.myPassport.trxCompletedOK then
				app.msgBox(app.getErrorString1 (Adhoc_CAMS_Initiated, code), heading, MsgBox_OK_Only + MsgBox_Information_Icon);
				break;
			else
				theResult := app.showErrorWarningDialog(heading, passport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
		return;
		
	endif;

	//didn't find a running controller
	app.msgBox(app.getErrorString1 (No_BGP_For_CAMS, code), heading, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
epilog
	
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_logExcludedTransactions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="9aff40fc-baf4-4177-ac01-372a960c103e">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
/* Changes

Date		Name	TFS#		Description
============================================================================
02/04/2009	cnwrl1	CCMS 1819 	EDI messaging needs the ability to send CAMS for operators that slot share
23/09/2010	cnwdad1	PAR #24065  Now using "specialField14" and "specialField15".
24/03/2011	cnwcs5	CCMS PNL 2057 
					/ PAR 27231 using specialField11 for "Single container per UNH~UNT"
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460 user defined special charac	ters
01/07/2013	cnwcs5	par 31819 	do not allow "send files with no message" for user defined JRW files
15 May 2014	cnwrs1	Par 34159 	include Chassis in Codeco
05 Jun 2014	cnwrs1	Par 34323 	cargo type in Cam Protocol
04 Mar 2015	cnwrs1	Par xxxx 	get ride of special references
30 Apr 2015	cnwrs1	Par35784 	increased exclusion reason logging to include non excluded
24 May 2016	cnwrs1	TFS 2008  	Vermas file changes
28 Jun 2016 cnwma1  TFS #2226 	POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 	CPL - Container Number in VERMAS DOC segment
12 Jul 2017	jlgrs1	TFS 4465 	SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 	SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 	Codeco/Coarri VGM extra details
18 Dec 2017 jlgrh7 	TFS 7781 	SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 	SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
12 Mar 2019	jlgka1	TFS 41641	SSL - Add Relaxed ID Checking.
19 Mar 2019	jlgsl4	TFS 41786 	SNO - output DAM segment for Standard Coarri/Codeco
24 Apr 2019 jlgka1	TFS 43785	STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
28 May 2019	jlgsl4	TFS 43706 	PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 	PNL Hapag CODECO on Weighing.
11 Mar 2020	jlgdap1	TFS 48785	SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726	GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 	AAT - Add NAD+MS to Standard COARRI SMDG213
05 Sep 2022 navcs2 	TFS 54528	MTN Cam Protocol 1035 when saving Translation Operator if Operator combo is shown by Name
06 Dec 2022	navdap1	TFS 55159 	MTN - Export CAMS to JSON API Endpoint
26 Jul 2023	jlika1	TFS 55938	EUP Load Confirmation Message
============================================================================*/
vars
	lCamISOPortDesc				: String;
	lCode,lDescription 			: String;
	lEmailMessage, 
	lEmailSubject				: String;
	lPackConsignor				: String;	 
	lPackConsignorCode, tString	: String;
	lFilePrefix ,lFileSuffix	: String;
	lOperatorXlationCode		: String;
	
	lStatus, 
	i, 
	lSendType, 
	token						: Integer;
	
	lUseVoOp,
	lEmailCopy, 
	lEmailFileImbedded			: Boolean;
	lSendMtFiles, pStatus		: Boolean;
	lClientRefAsBookingNo, 
	lSpare1 					: Boolean;
	lGateInForNullVoyageChange, 
	lGateInForNullOperatorChange : Boolean;
	lSpare2, lSpare3 			: Boolean;
	lSpecial_MSCForNZPOE, 
	lDaysToLookBack 			: Boolean;
	lTempLeadingZerosNoDecimal, 
	lSupressSealNumbers 		: Boolean;
	lSingleContainerPerBGM, 
	lSingleTransactionPerFile 	: Boolean;
	lReprocessOnIdChange, 
	lSendCancellationMsg 		: Boolean;
	lSendUpdateMsg, lDebug 		: Boolean;
	lUseContainerOperator_NAD_CF,
	lSendCarrier_RFF_CN 		: Boolean; //par 19423 cnwrs1 May 2009
	lUseCarrierForBooking 		: Boolean;
	lIncludeChassis 			: Boolean;
	lLogIncludedTransactions 	: Boolean;
	lLogExcludedTransactions 	: Boolean;
	lNoCrLf						: Boolean;
	specialFileName				: Boolean;
	lTerminalActivity			: Boolean;
	lDepotActivity              : Boolean;
	lUseSubTerminals			: Boolean;
	lPackGateInFull				: Boolean;
	lPackGateOutMT				: Boolean;
	lUnpackGateInMT             : Boolean;
	lUnpackGateOutFull          : Boolean;
	lPrcNullVoyageTransaction	: Boolean;
	lUseTiOperator 				: Boolean;
	
	lFirstRunDateTime		: TimeStamp;
	lFirstRunDate			: Date;
	lFirstRunTime			: Time;
	lLastRunDateTime		: TimeStamp;
	lLastRunDate			: Date;
	lLastRunTime			: Time;
	
	proxyCamProtocol 		: CM_CamProtocol;
	lAllCoarriExportPorts	: CM_PortByCodeDict;
	lCamGroup				: CM_CamGroup;
	lEmailAddress			: CM_EmailEntity;
	lEmailCopyAddresses		: CM_EmailEntityByTypeNameDict;
	lTerminal				: CM_Terminal;
	lPackOperators			: CM_OperatorByCodeDict;
	lPackExportConsignees	: CM_ConsignByCodeDict;
	lProtocolDesc			: CM_CamProtocolDesc; 
	theForm 				: SOP_TableMaintForm;
	table1, table2			: CM_EntryTable;		// cnwcs5 23/03/2011
	
	lRegisteredTransactions	: StringArray;
	lRegisteredCargoTypes 	: IntegerArray;
	lScheduleTimes			: TimeArray;
	transTypeDict			: CM_TransactionTypeByType;
	trxType					: CM_TransactionType;
	cargoTypeDict 			: CM_CargoTypesByIdDict;
	cargoType				: CM_CargoType;
	lAllPackAreas           : CM_TAByIdDict;
	lMyConsignee			: CM_ConsigneeConsignor;
	lIsEmailEnabled,				// ccms 1011	
	lIsSingleTransPerFile,	
	lIsFileTransferEnabled,
	lAnyEditTriggerField	: Boolean;		
	lOutputFileFormat,		
	lDestinationFilePath,
	lJRWReportName			: String;
	lQFCamTransaction		: CMQF_CamTransactionTemplate;
	lCamEditTriggerFields	: CM_CamEditTriggerFieldDict;
	lCamTrainEventTypes		: CM_EventTypeByNameDict;
	lOutputFileRollOver		: Integer;
	lOutputFileSeqLength	: Integer;
	lOutputFileStartSeq		: Integer;
	lLastSequenceNumberUsed	: Integer;
	lMyFTPEntity 			: CM_FTPEntity;	// CCMS 1143 cnwrs1 10 Aug 2010
	selectorQuery			: CM_MenuUserQuery;
	delayMinutes 			: Integer;
	
	lCOARRIBGM				: Boolean;			//cnwmc5 - 4 Feb 2016 - PAR 37503
	lCOARRIBGM4446			: Boolean;			//27Jan2023 navsp1 TFS 56282
	lVERMASNAD              : Boolean;           //28/06/2016 cnwma1 TFS #2226
	lVermasDOC				: Boolean;			// 05/10/2016 cnwma1 TFS #2712
	lPackUnpackStatusChange : Boolean;
	lIncludeRestowShifter 	: Boolean;
	lBGMDamCode 			: String;
	lBGMRepCode 			: String;
	lCoarriIncludeVGM 		: Boolean;
	lVERMASVer10			: Boolean;				//+TFS7781
	lSingleContainerPerUNB 	: Boolean;	//10 Apr 2018	NDL	TFS 7556
	lCOARRI95BLocPDS 		: Boolean;	// TFS 39345
	useRelaxedIDChecking	: Boolean; // jlgka1 TFS 41641
	produceDAMSegment		: Boolean; // TFS 41786
	useCodecoForNonStruc	: Boolean;	// jlgka1 TFS 43785
	dgsDetailsInGroup14		: Boolean;	//JIRA-20814
	enhancedGensetInfo		: Boolean; // TFS 43706
	codecoVGMBGMMsgCode		: String;  // jlgka1 TFS 44737
	coarriTShipImports		: Boolean;			// TFS 48785
	extWebService			: CM_ExternalWebServiceDef;			// TFS 55159
	messageGrouping			: Integer;
begin
    theForm := self.myForm; 
	table1	:= theForm.tblInput1;
	table2	:= theForm.tblInput2;
	
	lCode 				:= table1.getValueByName(ETRow_Code).String;
	lDescription 		:= table1.getValueByName(ETRow_Description).String;
	lCamGroup 			:= theForm.cmbCamGroup.myObject.CM_CamGroup;
	lCamISOPortDesc 	:= table1.getValueByName(ETRow_CamISOPortDesc).String;
	lMyFTPEntity 		:= theForm.cmbFTPEntity.myObject.CM_FTPEntity;	// CCMS 1143 cnwrs1 10 Aug 2010
	lEmailAddress 		:= theForm.cmbEmailAddress.myObject.CM_EmailEntity;
	lEmailCopy 			:= table1.getValueByName(ETRow_EmailCopy).Boolean;
	lEmailFileImbedded 	:= table1.getValueByName(ETRow_EmailFileImbedded).Boolean;
	lEmailMessage 		:= table1.getValueByName(ETRow_EmailMessage).String;
	lEmailSubject 		:= table1.getValueByName(ETRow_EmailSubject).String;
	lFirstRunDate 		:= table1.getValueAsDate(ETRow_FirstRunDate);
	lFirstRunTime 		:= table1.getValueByName(ETRow_FirstRunTime).Time;
	
	lFirstRunDateTime.setDate(lFirstRunDate);
	lFirstRunDateTime.setTime(lFirstRunTime);
	
	lLastRunDate 		:= table1.getValueAsDate(ETRow_LastRunDate);
	lLastRunTime 		:= table1.getValueByName(ETRow_LastRunTime).Time;
	
	lLastRunDateTime.setDate(lLastRunDate);
	lLastRunDateTime.setTime(lLastRunTime);
	
	specialFileName 		:= table1.getValueByName(ETRow_SpecialFileName).Boolean;
	lFilePrefix 			:= table1.getValueByName(ETRow_FilePrefix).String;
	lFileSuffix 			:= table1.getValueByName(ETRow_FileSuffix).String;
	//lOperatorXlationCode 	:= table1.getValueByName(ETRow_OperatorXlationCode).String; 		// 05 Sep 2022 navcs2 	TFS 54528
	if theForm.cmbOperator.getCurrentItemObject &lt;&gt; null then									// 05 Sep 2022 navcs2 	TFS 54528
		lOperatorXlationCode	:= theForm.cmbOperator.getCurrentItemObject.CM_Operator.code;	// 05 Sep 2022 navcs2 	TFS 54528
	endif;																						// 05 Sep 2022 navcs2 	TFS 54528
	lUseVoOp 				:= table1.getValueByName(ETRow_UseVoyageOperator).Boolean;
	lUseTiOperator			:= table1.getValueByName(ETRow_UseTiOperator).Boolean;				// cnwrl1 02/04/2009 CCMS 1819
	lPrcNullVoyageTransaction := table1.getValueByName(ETRow_PrcNullVoyageTrans).Boolean;		// cnwdad1 01/09/2009 - CCMS 1875.
	lTerminalActivity 		:= table2.getValueByName(ETRow_TerminalActivity).Boolean;
	lDepotActivity 			:= table2.getValueByName(ETRow_DepotActivity).Boolean;
	lUseSubTerminals 		:= table2.getValueByName(ETRow_UseSubTerminals).Boolean;			// cnwdad1 01/09/2009 - CCMS 1875.
	lPackGateInFull 		:= table2.getValueByName(ETRow_PackGateInFull).Boolean;
	lPackGateOutMT 			:= table2.getValueByName(ETRow_PackGateOutMT).Boolean;
	lUnpackGateInMT 		:= table2.getValueByName(ETRow_UnpackGateInMT).Boolean;
	lUnpackGateOutFull 		:= table2.getValueByName(ETRow_UnpackGateOutFull).Boolean;   
	lIsEmailEnabled			:= table1.getValueByName(ETRow_IsEmailEnabled).Boolean;				// ccms 1011	
	lIsSingleTransPerFile	:= table1.getValueByName(ETRow_IsSingleTransPerFile).Boolean;	
	lSingleContainerPerBGM := table1.getValueByName(ETRow_SpecialField11).Boolean;				// cnwcs5 24/03/2011 par 27231
	lSingleContainerPerUNB	:= table1.getValueByName(ETRow_SingleContainerPerUNB).Boolean;	//10 Apr 2018	NDL	TFS 7556
	lIsFileTransferEnabled 	:= table1.getValueByName(ETRow_IsFileTransferEnabled).Boolean;
	lAnyEditTriggerField	:= theForm.chkAnyTriggField.value;
	lOutputFileFormat 		:= table1.getValueByName(ETRow_OutputFileFormat).String;
	lOutputFileRollOver		:= table1.getValueByName(ETRow_OutputFileRollOver).Integer;			
	lOutputFileSeqLength 	:= table1.getValueByName(ETRow_OutputFileSeqLength).Integer;			
	lOutputFileStartSeq		:= table1.getValueByName(ETRow_OutputFileStartSeq).Integer;
	lLastSequenceNumberUsed	:= table1.getValueByName(ETRow_LastSequenceNumberUsed).Integer;
	lDestinationFilePath 	:= table1.getValueByName(ETRow_DestinationFilePath).String;
	lJRWReportName 			:= table1.getValueByName(ETRow_JrwReportName).String;
	lQFCamTransaction 		:= theForm.cmbQFCamTrans.listObject.CMQF_CamTransactionTemplate;
	useRelaxedIDChecking	:= theForm.chkRelaxedIdChecking.value; // jlgka1 TFS 41641
	useCodecoForNonStruc 	:= theForm.chkUseCodecoNonStruc.value; // jlgka1 TFS 43785
	dgsDetailsInGroup14		:= theForm.chkDGSDetailsInGroup14.value;	//JIRA-20814
	extWebService			:= theForm.cmbWebServiceType.listObject.CM_ExternalWebServiceDef;	// TFS 55159
	token := 1;
	if theForm.cmbMessageGrouping.text = app.getErrorString(Message_release_request_transp) then
		messageGrouping	:= CM_CamProtocol.MessagePerReleaseNumber;	
	elseif theForm.cmbMessageGrouping.text = app.getErrorString(Messa_relea_reque_line_number) then
		messageGrouping	:= CM_CamProtocol.MessagePerReleaseLineNumber;	
	elseif theForm.cmbMessageGrouping.text = app.getErrorString(Message_wagon_voyage_truck) then
		messageGrouping	:= CM_CamProtocol.MessagePerTransport;	
	endif;
	
	lPackConsignorCode := theForm.comboBox1.text;
	
	if lPackConsignorCode.trimBlanks &lt;&gt; null then
		lPackConsignor := lPackConsignorCode.getNextToken(token);
	else
		lPackConsignor := null;
	endif;
	
	lProtocolDesc 	:= theForm.cmbCamProtDesc.myObject.CM_CamProtocolDesc;
	
	if lProtocolDesc &lt;&gt; null and not lProtocolDesc.isUserDefinedEventReport and not lProtocolDesc.isUserDefinedReport then	// par 31819 cnwcs5
		lSendMtFiles 	:= table1.getValueByName(ETRow_SendMtFiles).Boolean;
	endif;
	if lProtocolDesc &lt;&gt; null and
	   not lProtocolDesc.isCodeco then
		lTerminalActivity 		:= false;
		lDepotActivity 			:= false;
		lUseSubTerminals 		:= false;
		lPackGateInFull 		:= false;
		lPackGateOutMT 			:= false;
		lUnpackGateInMT 		:= false;
		lUnpackGateOutFull 		:= false;
		lPackConsignorCode := null;
	endif;
	
	lSendType 		:= table1.getValueByName(ETRow_SendType).Integer;
	lSendCancellationMsg := table1.getValueByName(ETRow_SpecialField14).Boolean;		// cnwdad1 23/09/2010 - PAR #24065.
	lSendUpdateMsg := table1.getValueByName(ETRow_SpecialField15).Boolean;		// cnwdad1 23/09/2010 - PAR #24065.
	lMyConsignee 	:= theForm.cmbConsignee.myObject.CM_ConsigneeConsignor;
	lLogExcludedTransactions := table1.getValueByName(ETRow_LogExcludeTransactions).Boolean;
	lLogIncludedTransactions := table1.getValueByName(ETRow_LogIncludeTransactions).Boolean;
	
	create lAllCoarriExportPorts transient;
	create lEmailCopyAddresses transient;
	create lPackOperators transient; 
	create lPackExportConsignees transient; 
	create lRegisteredTransactions transient;
	create lRegisteredCargoTypes transient;
	create cargoTypeDict transient;
	create lScheduleTimes transient;
	create lAllPackAreas transient;
	create transTypeDict transient;
	create lCamEditTriggerFields transient;
	create lCamTrainEventTypes transient;

    theForm.mulSelect1.getSelected(lEmailCopyAddresses);   	
	theForm.mulSelect2.getSelected(transTypeDict);   
	
	foreach trxType in transTypeDict do 
		lRegisteredTransactions.add(trxType.trxType.asStringJMT());		//ccms 1070 - par 22306 
   	endforeach;  

    theForm.mulSelect3.getSelected(lAllCoarriExportPorts);   
	theForm.mulSelect41.getSelected(lPackOperators);
    theForm.mulSelect42.getSelected(lPackExportConsignees); 
	theForm.mulSelect6.getSelected(lCamEditTriggerFields);
	theForm.mulSelect7.getSelected(lCamTrainEventTypes);	// PAR 21905 CCMS MES 1008 - PHB
	theForm.mulSelect8.getSelected(cargoTypeDict);
	foreach cargoType in cargoTypeDict do 
		lRegisteredCargoTypes.add(cargoType.id);		//ccms 1070 - par 22306 
   	endforeach;  
	
   	i := 1;
   	while i &lt;=  theForm.timelistBox1.listCount do
   		tString := theForm.timelistBox1.itemText[i];
   		lScheduleTimes.add(tString.Time);
   		i := i+1;
   	endwhile;
	/*
	lSpecialField1 := 
	lSpecialField2 :=
	lSpecialField3 :=
	*/
	pStatus := table1.getValueByName(ETRow_Status).Boolean;
	if pStatus = true then
		lStatus := CAM_HOLDSTATUS;
	else
		lStatus := CAM_IDLESTATUS;
	endif;
	
	if ((lQFCamTransaction = null) and self.isUserDefinedReport(lProtocolDesc)) then		// PAR 20994 Oct 2009
		lQFCamTransaction := self.getDefaultQFCamTransTemplate();
	endif;
	
	if self.isUserDefinedEventReport(lProtocolDesc) then	// PAR 21905 CCMS MES 1008 - PHB - Always default a User-Defined Event Report selection to null
		lQFCamTransaction := null;
	endif;
	
	if lProtocolDesc &lt;&gt; null then	
	   	if lProtocolDesc.gateInForNullVoyageChange then
			if theForm.chkNullVoyage.value = true then
				lGateInForNullVoyageChange := true;
			else
				lGateInForNullVoyageChange := false;
			endif;
   		endif; 
		if lProtocolDesc.gateInForNullOperatorChange then
			if theForm.chkPonOperator.value = true then
				lGateInForNullOperatorChange := true;
			else
				lGateInForNullOperatorChange := false;
			endif;
		endif;
		if lProtocolDesc.special_MSCForNZPOE then
			if theForm.chkMSCForNZPOE.value = true then
				lSpecial_MSCForNZPOE := true;
			else
				lSpecial_MSCForNZPOE := false;
			endif;
		endif;
		if lProtocolDesc.daysToLookBack then
			if theForm.chkDaysLookBack.value = true then
				lDaysToLookBack := true;
			else
				lDaysToLookBack := false;
			endif;
		endif;
		if lProtocolDesc.temperatureFormat then //par16227 cnwrs1 Mar 2008
			if theForm.chkTempFormat.value = true then
				lTempLeadingZerosNoDecimal := true;
			else
				lTempLeadingZerosNoDecimal := false;
			endif;
		endif;
		if lProtocolDesc.supressSealNumbers then //CCMS1745 cnwrs1 aug 2008
			if self.chkHLCSel_Suppress.value = true then
				lSupressSealNumbers := true;
			else
				lSupressSealNumbers := false;
			endif;
		endif;
		if lProtocolDesc.reprocessChangeID then //CCMS1644 cnwrs1 aug 2008
			if self.chkReprocessChangeID.value = true then
				lReprocessOnIdChange := true;
			else
				lReprocessOnIdChange := false;
			endif;
		endif;
		if lProtocolDesc.includeChassis then //CCMS1644 cnwrs1 aug 2008
			if self.chkIncludeChassis.value = true then
				lIncludeChassis := true;
			else
				lIncludeChassis := false;
			endif;
		endif;		
		if lProtocolDesc.includeRestowShifter then 
			if self.chkIncludeRestowShifter.value = true then
				lIncludeRestowShifter := true;
			else
				lIncludeRestowShifter := false;
			endif;
		endif;		
		if lProtocolDesc.includePackUnpackChange then 
			if self.chkPackUnpackStatusChange.value = true then
				lPackUnpackStatusChange := true;
			else
				lPackUnpackStatusChange := false;
			endif;
		endif;		
		if lProtocolDesc.clientRefAsBookingNo then// cnwrd par 34369
			if theForm.chkCliRefBooking.value = true then
				lClientRefAsBookingNo := true;
			else
				lClientRefAsBookingNo := false;
			endif;
		endif;
		
		//cnwmc5 - 4 Feb 2016 - PAR 37503
		if lProtocolDesc.changeCOARRIBGM then
			if self.chkCOARRIBGM.value = true then
				lCOARRIBGM := true;
			else
				lCOARRIBGM := false;
			endif;
		endif;
		
		//27Jan2023 navsp1 TFS 56282
		if lProtocolDesc.changeCOARRIBGM4446 then
			if self.chkCOARRIBGM4446.value = true then
				lCOARRIBGM4446 := true;
			else
				lCOARRIBGM4446 := false;
			endif;
		endif;
		
		 //28/06/2016 cnwma1 TFS #2226 
		if lProtocolDesc.changeVERMASNAD then
			if self.chkVERMASNAD.value = true then
				lVERMASNAD := true;
			else
				lVERMASNAD := false;
			endif;
		endif;
		
		// 05/10/2016 cnwma1 TFS #2712
		if lProtocolDesc.changeVERMASDOC then
			if self.chkVERMASDOC.value = true then
				lVermasDOC := true;
			else
				lVermasDOC := false;
			endif;
		endif;
		if lProtocolDesc.isCoarri or
		   lProtocolDesc.isCodeco then
			if self.chkIncludeExtraVGM.value = true then
				lCoarriIncludeVGM := true;
			else
				lCoarriIncludeVGM := false;
			endif;
		endif;
		
		if lProtocolDesc.changeVERMASVer10() then					//+TFS7781
				if self.chkVERMASVer10.value = true then
					lVERMASVer10 := true;
				else
					lVERMASVer10 := false;
				endif;
		endif;

		if lProtocolDesc.changeCOARRI95BLocPDS() then	// TFS 39345 - enable LOC+PDS, LOC+7 for 95B
			if self.chkCoarri95BLocPDS.value = true then // TFS 39345
				lCOARRI95BLocPDS := true; // TFS 39345
			else // TFS 39345
				lCOARRI95BLocPDS := false; // TFS 39345
			endif; // TFS 39345
		endif; // TFS 39345

		if lProtocolDesc.changeProduceDAMSegment() then	// TFS 41786
			if self.chkProduceDAMSegment.value = true then // TFS 41786
				produceDAMSegment := true; // TFS 41786
			else // TFS 41786
				produceDAMSegment := false; // TFS 41786
			endif; // TFS 41786
		endif; // TFS 41786

		if lProtocolDesc.changeEnhancedGensetInfo() then	// --&gt; TFS 43706
			if self.chkEnhancedGensetInfo.value = true then
				enhancedGensetInfo := true;
			else
				enhancedGensetInfo := false;
			endif;
		endif; // &lt;-- TFS 43706

		if lProtocolDesc.isDamageRepairCodecoCodes then
			lBGMDamCode := self.txtBGMDamCode.text;
			lBGMRepCode := self.txtBGMRepCode.text;
		endif;
		
		//jlgka1 TFS 44737 --&gt;
		if lProtocolDesc.isCodeco then
			codecoVGMBGMMsgCode := self.txtVGMBGMMsgCode.text;
		endif;
		//jlgka1 TFS 44737 &lt;--
		
		if lProtocolDesc.isCoarri then							// TFS 48785
			coarriTShipImports := self.chkTShipImports.value;	// TFS 48785
		endif;													// TFS 48785
		
		lSpare1:= false; // PAR 33644 includeNonWorked is being removed in 832
		
		if lProtocolDesc.useContainerOperator_NAD_CF then
			lUseContainerOperator_NAD_CF	:= theForm.chkEDIXlatCtn.value;
		endif;
		if lProtocolDesc.sendCarrier_RFF_CN then			// par 27460 cnwcs5
			lSendCarrier_RFF_CN := theForm.chkSendCarrier.value;	// par 27460 cnwcs5
		endif;													// par 27460 cnwcs5
		if lProtocolDesc.useCarrierRef then			// par 27460 cnwcs5
			lUseCarrierForBooking := theForm.chkUseCarrierRef.value;	// par 27460 cnwcs5
		endif;													// par 27460 cnwcs5
		
		if lProtocolDesc.isKindOf(CM_CamUserDefRepDesc) then
			selectorQuery:=theForm.cmbCargoType2.listObject.CM_MenuUserQuery;
		endif;
		if lProtocolDesc.isKindOf(CM_CamUserDefRepEventDesc) then
			selectorQuery:=theForm.cmbMul7.listObject.CM_MenuUserQuery;
		endif;
		
		//08 Sep 2015	NDL	Par 36876
		if lProtocolDesc.useDelayMinutes then	
			delayMinutes := theForm.txtDelayMins.text.Integer;		
		endif;
		
	endif;

	lNoCrLf := table1.getValueByName(ETRow_NoCrLf).Boolean;

	lTerminal  := theForm.myTerminal;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_CamProtocol transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxyCamProtocol := theForm.myProxyObject.CM_CamProtocol;

	proxyCamProtocol.setProxy(	lCode,
								lDescription,
								lAllCoarriExportPorts,
								lCamGroup,
								lCamISOPortDesc,
								lEmailAddress,
								lEmailCopy,
								lEmailCopyAddresses,
								lEmailFileImbedded,
								lEmailMessage,
								lEmailSubject,
								lFirstRunDateTime,
								lLastRunDateTime,
								specialFileName,
								lFilePrefix,
								lFileSuffix,
								lOperatorXlationCode,
								lPackOperators,
								lPackExportConsignees,
								lPackConsignor,
								lProtocolDesc,
								lRegisteredTransactions,
								//lRegisteredTransactionClasses,
								lSendMtFiles,
								lSendType,
								lUseVoOp,
								lScheduleTimes,
								lClientRefAsBookingNo,
								lSpare1,
								lGateInForNullVoyageChange,
								lGateInForNullOperatorChange,
								lSpare2,
								lSpare3,
								lSpecial_MSCForNZPOE,
								lDaysToLookBack,
								lTempLeadingZerosNoDecimal,
								lSupressSealNumbers,
								lSingleContainerPerBGM,
								lSingleTransactionPerFile,
								lReprocessOnIdChange,
								lSendCancellationMsg,
								lSendUpdateMsg,
								lDebug,
								lUseContainerOperator_NAD_CF,
								lSendCarrier_RFF_CN,
								lUseCarrierForBooking,
								theForm.chkIncludeChild.value,
								lIsEmailEnabled,
								lIsSingleTransPerFile,
								lIsFileTransferEnabled,
								lAnyEditTriggerField,
								lOutputFileRollOver,
								lOutputFileSeqLength,
								lOutputFileStartSeq,
								lLastSequenceNumberUsed,	 // ccms 1011
								lOutputFileFormat,
								lDestinationFilePath,
								lJRWReportName,
								lCamEditTriggerFields,
								lCamTrainEventTypes,	// PAR 21905 CCMS MES 1008 - PHB
								lQFCamTransaction,
								lNoCrLf,
								lStatus,
								lTerminal,
								lTerminalActivity,
								lDepotActivity,
								lUseSubTerminals,
								lPackGateInFull,
								lPackGateOutMT,
								lUnpackGateInMT,	
								lUnpackGateOutFull,
								lPrcNullVoyageTransaction,
								lUseTiOperator,
								lAllPackAreas,
								lMyConsignee,
								lMyFTPEntity,
								table1.getValueByName(ETRow_DecimalCharacter).Character,		// par 27460 cnwcs5
								table1.getValueByName(ETRow_ElementSeperator).Character,		// par 27460 cnwcs5
								table1.getValueByName(ETRow_EscapeCharacter).Character,			// par 27460 cnwcs5
								table1.getValueByName(ETRow_SegmentTerminator).Character,		// par 27460 cnwcs5
								table1.getValueByName(ETRow_SubElementSeperator).Character,	// par 27460 cnwcs5 // CCMS 1143 cnwrs1 10 Aug 2010
								lRegisteredCargoTypes,
								selectorQuery,
								delayMinutes,	//_delayMinutes : Integer
								lCOARRIBGM,
								lCOARRIBGM4446,	//27Jan2023 navsp1 TFS 56282
								table1.getValueByName(ETRow_UseVGM).Boolean,
								useRelaxedIDChecking,		// jlgka1 TFS 41641
								useCodecoForNonStruc,		// jlgka1 TFS 43785								
								dgsDetailsInGroup14
								);
	proxyCamProtocol.setIncludeChassis(lIncludeChassis);
	proxyCamProtocol.setVermasNAD(lVERMASNAD);     //28/06/2016 cnwma1 TFS #2226 
	proxyCamProtocol.setVermasDOC(lVermasDOC);     // 05/10/2016 cnwma1 TFS #2712
	proxyCamProtocol.setVermasVer10(lVERMASVer10);			//+TFS7781
	proxyCamProtocol.setCoarri95BLocPDS(lCOARRI95BLocPDS);	// TFS 39345
	proxyCamProtocol.setProduceDAMSegment(produceDAMSegment); // TFS 41786
	proxyCamProtocol.setEnhancedGensetInfo(enhancedGensetInfo); // TFS 43706	
	proxyCamProtocol.setLogIncludedTransactions(lLogIncludedTransactions);
	proxyCamProtocol.setLogExcludedTransactions(lLogExcludedTransactions);					
	proxyCamProtocol.setPackUnpackStatusChange(lPackUnpackStatusChange);
	proxyCamProtocol.setIncludeRestowShifter(lIncludeRestowShifter);
	proxyCamProtocol.setDamageCodecoCode(lBGMDamCode);
	proxyCamProtocol.setRepairCodecoCode(lBGMRepCode);
	proxyCamProtocol.setIncludeExtraVGM(lCoarriIncludeVGM);
	proxyCamProtocol.setSingleContainerPerUNB(lSingleContainerPerUNB);	//10 Apr 2018	NDL	TFS 7556
	proxyCamProtocol.setCodecoVGMBGMMessageCode(codecoVGMBGMMsgCode);   // jlgka1 TFS 44737
	proxyCamProtocol.setTranshipImportsVoyageOp(coarriTShipImports);		// TFS 48785
	proxyCamProtocol.setIncludeRFFBM162(self.chkIncludeRFFBM162.value);	//26 Jan 2021	NDL	TFS 50708
	proxyCamProtocol.setIncludeLOC7InterTerm(self.chkIncludeLOC7InterTerm.value);	// TFS 50726
	proxyCamProtocol.setIsCustomsProtocol(self.chkIsCustomsProtocol.value);	// TFS 53181
	proxyCamProtocol.setIncludeNADMSCOARRISMDG213(self.chkIncludeNADMSForSMDG213.value);	// TFS 54142
	proxyCamProtocol.setMyWebServiceDef(extWebService.CM_APIEndpointServiceDef);		// TFS 55159
	proxyCamProtocol.setMessageGrouping(messageGrouping);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCamProtocol(proxyCamProtocol, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCamProtocol(proxyCamProtocol, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();

epilog
	delete lAllCoarriExportPorts;
	delete lEmailCopyAddresses;
	delete lPackOperators;
	delete lPackExportConsignees;
	delete lRegisteredTransactions;
	delete lRegisteredCargoTypes;
	delete lScheduleTimes;
	delete transTypeDict;
	delete cargoTypeDict;
	delete lAllPackAreas;
	delete lCamEditTriggerFields;
	delete lCamTrainEventTypes;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableView1Click" id="a21ffd7d-8d92-4191-b8f2-cb6060bd3bed">
        <source>doTableView1Click(table: CM_ViewTable input; button: Integer; shift: Integer; x: Real; y: Real);
// ---------------------------------------------------------------------------
// Created:		22 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin

end;</source>
        <Parameter name="table" type="CM_ViewTable" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataView1DblClick" id="7218f971-2d9b-48c6-be45-a333b8d6a0c9">
        <updating/>
        <source>doTblDataView1DblClick(table: Table input) updating;
//----------------------------------------------------------------
//	Created:	30 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.doMnuContext3Click(null);

