    <JadeMethod name="tblData_dblClick" id="952ee6c2-1480-4d5f-a26e-a41ba70a0db4">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;

vars

begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if currentMode = Mode_Exceptions then
		editException();
	elseif currentMode = Mode_Permissions or
	   currentMode = Mode_SpecialPermissions then
		editPermission();
	elseif self.currentMode = Mode_Subscriptions then	//16 June 2020	NDL	TFS 49569
		editPermission();
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_keyDown" id="b9be88a8-b4c4-4504-ba8f-5371f4318ef3">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if keyCode = J_key_C and shift.bitAnd(2) &lt;&gt; 0 then
		if table.row &lt;&gt; 0 and table.column &lt;&gt; 0 then
			app.copyStringToClipboard(table.accessCell(table.row, table.column).text);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
