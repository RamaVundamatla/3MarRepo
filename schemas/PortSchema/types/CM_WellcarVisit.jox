    <JadeMethod name="createWellFromDef" id="648ac17f-0fed-4c0d-adfc-de5a405a199c">
        <source>createWellFromDef( _wellDef : CM_WagonWellDefinition ):CM_WellcarWellVisit;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars
	
	prevWell : CM_WellcarWellVisit;
	lPreviousController : CM_WagonController;
	well : CM_WellcarWellVisit;
	locId : String;

begin

	if not self.allWagonWellsArray.isEmpty then
		prevWell := self.allWagonWellsArray.last;
		if prevWell &lt;&gt; null then
			if not prevWell.allLocationsControllersArray.isEmpty then
				lPreviousController := prevWell.allLocationsControllersArray.last;
			endif;
		endif;
	endif;
	
	create well;
	well.setFromDefinition( _wellDef, self, lPreviousController );
	
	return well;

epilog

end;</source>
        <Parameter name="_wellDef" type="CM_WagonWellDefinition"/>
        <ReturnType type="CM_WellcarWellVisit"/>
    </JadeMethod>
    <JadeMethod name="getLengthInUnitsForWagon" id="90bf5156-025e-48c0-a560-80054f4d2ea8">
        <source>getLengthInUnitsForWagon( _obj : CM_Object ):Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	ti : CM_TrackedItem;
	type : CM_ISOType;
	typeGroup : CM_ISOTypeGroup;
	wle : CM_WorkListEntry;
	req : CM_Request;
	str : String;
	
	obj : Object;
	unitLength : Integer;

begin

	obj := _obj;
	
	if obj.isKindOf( CM_WorkListEntry ) then
		wle := obj.CM_WorkListEntry;
		obj := null;
		if wle.myTrackedItem &lt;&gt; null then
			obj := wle.myTrackedItem;
		endif;
		if obj = null and wle.myRequest &lt;&gt; null then
			req := wle.myRequest;
			str := req.getISOType();
			if str &lt;&gt; null then
				obj := app.myRoot.allISOTypes.getAtKey( str );
			endif;
			if obj = null then
				str := req.getISOGroup;
				if str &lt;&gt; null then
					obj := app.myRoot.allISOTypeGroups.getAtKey( str );
				endif;
			endif;
		endif;
	endif;

	if obj.isKindOf(CM_TrackedItem) then
		unitLength := obj.CM_TrackedItem.getLengthInUnitsForWagon().Integer;
		if unitLength &gt; 2 then
			unitLength := 4;
		endif;
		return unitLength;
		
	elseif obj.isKindOf(CM_ISOType) then
		type := obj.CM_ISOType;
		if type.is20ftLong then
			return 2;
		else
			return 4;
		endif;
		
	elseif obj.isKindOf(CM_ISOTypeGroup) then
		typeGroup := obj.CM_ISOTypeGroup;
		if typeGroup.is20ftLong then
			return 2;
		else
			return 4;
		endif;
		
	else
		return 2;
		
	endif;

	

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Real"/>
    </JadeMethod>
