    <JadeMethod name="setFormHeading" id="2dcd856b-121e-4169-8fea-c019fe15110e">
        <updating/>
        <source>setFormHeading()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2016	cnwma1	PAR37816 JMT - Error on doing Customs Actions Search
*/

vars
	str : String;
begin
	
	str := "Custom Action";
	
	if self.ediFileType &lt;&gt; null then
		if self.ediFileType = EDIFileTypeX12_350_4010
		or self.ediFileType = EDIFileTypeCAMIR_CustomsStatus then	
		
			self.setCaption(str &amp; " - " &amp; "US Customs Status Message");
		elseif self.ediFileType = EDIFileType_CusRes then
		
			self.setCaption(str &amp; " - " &amp; "NZ Customs Response");
		else
			self.setCaption(str);		
		endif;
	else
		self.setCaption(str);		
	endif;
epilog

end;



</source>
    </JadeMethod>
    <JadeMethod name="setTableColors" id="b60410f3-8655-4d5f-bedc-f6dd9a945405">
        <source>setTableColors(_fromRow : Integer);
// ---------------------------------------------------------------------------
// Created:	11 September 2008 By Graeme Black cnwgb1
// Purpose:	Displays alternating colours in a table. Duplicate keys are 
//			coloured the same
//			CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
	startRow, endRow, idx : Integer;
	newVal, rowVal : String;
	rowIsColour1 : Boolean;
begin
	if _fromRow = 0 then
		startRow := self.tblActions.fixedRows + 1;
	else
		startRow := _fromRow;
	endif;
	endRow := self.tblActions.rows;
	rowIsColour1 := false;
	foreach idx in startRow to endRow do
		newVal := self.tblActions.accessCell(idx, 1).text;
		if newVal &lt;&gt; rowVal then
			rowIsColour1 := not rowIsColour1;
		endif;
		if rowIsColour1 then
			self.tblActions.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblActions.accessRow(idx).backColor := self.colorRow2;
		endif;
		rowVal := newVal;
	endforeach;
epilog
end;</source>
        <Parameter name="_fromRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b314b3c3-bef3-4e94-a902-883e65ceea2c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:	09 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// 28 July 2016	cnwma1	PAR37816 JMT - Error on doing Customs Actions Search
// ---------------------------------------------------------------------------
vars
	table : CM_DataTable;
begin
	table := self.tblActions;
	table.visible := false;
	table.readOnly := false;
	table.multiSelect := CM_BaseTable.MultiSelect_None; //PAR21437 - cnwsh3 Remove multi selection on table.
	table.selectMode := Table.SelectMode_WholeRows;
	table.selectionType := CM_BaseTable.SelectionType_Row; //PAR21437 - cnwsh3 Remove multi selection on table.
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	self.mnuCA.visible := false;
	
	self.initSearcher();
	if self.ediFileType &lt;= 0 then
		self.showSearcher();
	else
		self.showTable();
	endif;
	//self.setNavigatorHeading(self.caption);   // cnwma1 28/07/16 PAR #37816
	self.setFormHeading();                      // cnwma1 28/07/16 PAR #37816
	beginClassNotification(CM_EDIAction, false, Object_Update_Event, Response_Continuous, Object_Update_Event);
	beginClassNotification(CM_EDIAction, false, Object_Create_Event, Response_Continuous, Object_Create_Event);
	beginClassNotification(CM_EDIAction, false, Object_Delete_Event, Response_Continuous, Object_Delete_Event);
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnNew.enabled:= false;
		self.btnEdit.enabled:= false;
		self.btnCSVImport.enabled:= false;
	endif;

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="showSearcher" id="c0c258db-8a9d-4ae1-a38e-4daaa91ecfb6">
        <source>showSearcher();
// ---------------------------------------------------------------------------
// Created:	29 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
	searchFrame : CMUI_MoveableFrame;
begin
	self.btnSearch.enabled := false;
	searchFrame := self.frmSearchFType;
	searchFrame.zOrder(1);
	searchFrame.centreWindow();
	searchFrame.visible := true;
	self.frmToolbar.visible := true;
	//PAR21437 - 20/11/2009. cnwsh3 removed default to first item in filetype combo box.
	//self.cmbFileType.listIndex := 1;
	self.cmbFileType.setFocus();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="showTable" id="44ea0dfe-e321-482d-861f-26ec8e47a929">
        <updating/>
        <source>showTable() updating;
// ---------------------------------------------------------------------------
// Created:	30 September 2008 By Graeme Black cnwgb1
// Purpose:	
// 28 July 2016	cnwma1	PAR37816 JMT - Error on doing Customs Actions Search
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops

vars
	entTableDef : EntTableDef;
	table : CM_DataTable;
begin
	if  self.ediFileType = null then  // cnwma1 28/07/16 PAR #37816
		return;
	endif;

	table := self.tblActions;
	if self.ediFileType = EDIFileTypeX12_350_4010
	or self.ediFileType = EDIFileTypeCAMIR_CustomsStatus then			//cnwmc5 - 10 July 2014 - CCMS 2353 PEN
		entTableDef := app.myController.getEntTableDef(ETDef_CustomsActionMaint);
	//elseif self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_XMLOneStopCust or self.ediFileType = EDIFileType_JMTInternal then // TFS 39133	// ### TFS 58831 (58833) 11July2023 NAVPW1 - Commented Out
	// ### TFS 58831 (58833) 11July2023 NAVPW1
	elseif self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_XMLOneStopCust then // TFS 39133
		entTableDef := app.myController.getEntTableDef(ETDef_CustomsActionNZ);
	elseif self.ediFileType = EDIFileType_JMTInternal then
		entTableDef := app.myController.getEntTableDef(ETDef_CustomsActionNZTSW);
	// ### TFS 58831 (58833) 11July2023 NAVPW1
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled EDI File Type (' &amp; self.ediFileType.asStringJMT() &amp; ')');
		return;
	endif;
	self.setFormHeading();     // cnwma1 28/07/16 PAR #37816
	table.setMyDataClass(CM_EDIAction);
	table.setMyEntTableDef(entTableDef);	
	table.setTblDataEntRowsFromDef(entTableDef);	
	table.visible := true;
	
	self.loadTable();
	
	//PAR18285	Select the first row when showing the table. cnwsh3	16/3/2009
	table.selectRow(table.fixedRows +1, false);
	self.setTableColors(0);
	self.frmSearchFType.visible := false;
	self.btnSearch.enabled := true;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="32822ca8-4a5d-4650-a452-b766338a571d">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:	18 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(eventType, theObject, eventTag);
	
	self.handleSystemNotification(eventType, theObject, eventTag); //PAR21437 - cnwsh3 20/11/2009. Moved to it's own method.
epilog
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblActions_contextMenu" id="53faeb6f-bff1-439f-9206-7a75f8b47b25">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblActions_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:	05 October 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
	action : CM_EDIAction;
begin

	action := table.accessRow(table.row).itemObject.CM_EDIAction;
	self.mnuCAAudits.userObject:=action;
	self.mnuCAInspect.visible:=app.isAllowedToInspect();
	if self.mnuCAInspect.visible then
		self.mnuCAInspect.userObject:=action;
	endif;
	
	return self.showContextMenu(mnuCA, table, conwin, mouse, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblActions_dblClick" id="a48521da-d256-4160-988d-503e6aa2a944">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblActions_dblClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:	17 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin


	if table.row &gt; table.fixedRows then
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			return;
		endif;

		self.doEdit( false );
	elseif table.row &lt;= table.fixedRows then //PAR21437 - cnwsh3 - allow sorting by column heading.
	
		table.resortTableByColumn(table.column);
	endif;
epilog
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="33289c71-0441-4693-9bd9-0f923b421552">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014991, locale);
	btnCSVExp.translateBubbleHelp(Xlat_0009772, locale);
	btnCSVExp.translateCaption(Xlat_0009773, locale);
	btnCSVImport.translateBubbleHelp(Xlat_0009774, locale);
	btnCSVImport.translateCaption(Xlat_0009775, locale);
	btnDelete.translateCaption(Xlat_0009776, locale);
	btnEdit.translateBubbleHelp(Xlat_0009777, locale);
	btnEdit.translateCaption(Xlat_0009778, locale);
	btnNew.translateBubbleHelp(Xlat_0009779, locale);
	btnNew.translateCaption(Xlat_0009780, locale);
	btnSearch.translateCaption(Xlat_0009781, locale);
	btnSearchCancel.translateCaption(Xlat_0009782, locale);
	btnSearchSearch.translateCaption(Xlat_0009783, locale);
	lblFileType.translateCaption(Xlat_0009784, locale);
	mnuCA.translateCaption(Xlat_0009785, locale);
	mnuCAAudits.translateCaption(Xlat_0009786, locale);
	mnuCAInspect.translateCaption(Xlat_0009787, locale);
end;</source>
    </JadeMethod>
</GUIClass>
