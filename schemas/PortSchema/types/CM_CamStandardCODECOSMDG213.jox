    <JadeMethod name="availableTransactions" id="0d0f7404-1d47-428e-8a88-b9548f865a59">
        <source>availableTransactions(_classColl: ClassColl input);
		
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
31 Oct 2019		jlgdi1		46578		Added CM_ReceiveRoadCancelled transaction
****************************************************/

begin
	inheritMethod(_classColl);
	_classColl.add(CM_Repair);
	_classColl.add(CM_Damage);
