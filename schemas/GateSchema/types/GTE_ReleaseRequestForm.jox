    <JadeMethod name="doResize" id="b3ef519b-5763-4dc2-9ed2-047c2240d8ac">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/04/2017	cnwdap1		TFS 4038 Release Request Form Usability Issues
// ---------------------------------------------------------------------------
vars
	
begin

	inheritMethod();

	self.btnSearch2.visible := false;
	self.btnSearch2.width := 1;
/*
	if app.isSpecial() then
		self.btnSearch2.visible := true;	
		self.btnSearch2.top 	:= self.frmToolbar.height + VerticalSpacing;
		self.btnSearch2.left	:= WinLeftMargin;
		self.btnSearch2.width := 80;
	endif;
	*/
	//23 Sep 2016	NDL	TFS 2649
	self.tblResDetails.left := 0;
	self.tblResDetails.width := self.frmDetailsBottom.width;
	self.tblResDetails.accessColumn(1).width := self.tblResDetails.width.Integer;
	
	lblView.top 	:= self.frmToolbar.height + VerticalSpacing;
	cmbView.top 	:= self.frmToolbar.height + VerticalSpacing;
	
	lblView.left	:= WinLeftMargin + self.btnSearch2.width + HorizontalSpacing + HorizontalSpacing + HorizontalSpacing + HorizontalSpacing;
	
	cmbView.left	:= lblView.left + lblView.width + HorizontalSpacing;

	self.lblType.top := self.lblView.top;
	self.lblType.top := self.lblView.top;
	self.cmbType.top := self.cmbView.top;
	self.lblType.left := self.cmbView.left + self.cmbView.width + VerticalSpacing;
	self.cmbType.left := self.lblType.left + self.lblType.clientWidth + HorizontalSpacing;
	self.positionSptMain();
	self.zPositionBottomControls();
	
	//30 Oct 2015	NDL	Par 37094 - resizing issue when re-opened		// TFS 4028
	// after being minimised with the searcher hidden.					// TFS 4028
	//if not self.isSearcherVisible then								// TFS 4028
	//	self.zShowSearcher();											// TFS 4028
	//	self.zHideSearcher();											// TFS 4028
	//endif;															// TFS 4028
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doSummariseAll" id="ca15c3cc-5bc6-4f0c-9d05-ca346f1162b3">
        <source>doSummariseAll()protected;
// ---------------------------------------------------------------------------
// Created:     15 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	coll	: ObjectSet;
begin
	// Get a collection of ALL the rows displayed to pass to the Summary Definition form.
	app.mousePointer	:= Busy;
	
	create coll transient;
	
	if self.amInitialisingWithObject then
		coll.addNoDuplicates( self.myCurrentObject, false );
	else
		tblData.getAllRowObjects( coll );
	endif;
	
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false , false, false, true);
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
