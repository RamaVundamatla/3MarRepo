    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="4d627369-7284-4559-a127-5303fb73c8fe">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     21 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyQryReport	: CM_QryReport;
	defaultTemplate	: CMQF_FilterReports;
	filterClass		: Class;
	completedOK		: Boolean;
begin
	pxyQryReport := inheritMethod();
	self.allSecurityRoles.copy(pxyQryReport.allSecurityRoles);
	pxyQryReport.myFilterObject := pxyQryReport.createFilter;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyQryReport;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyQryReport;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="bf4692a8-175d-446c-af4c-018a0a33f9c0">
        <updating/>
        <source>setForCreate(_proxy : SelfType; 
			_parent : CM_MenuEntity input; 
			_pos : Integer;
			_menuRoot : CM_MenuRoot input) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user 			: CM_User;
	userTerminal	: CM_UserTerminal;
	termSecRole 	: CM_SecurityRole;

begin
	inheritMethod(_proxy, _parent, _pos, _menuRoot);
	
	// 22/01/2016 cnwar2 #37414 - now add to user's role and all roles above this
	//self.addToRootSecurityRoles();
	user := app.myPassport.myUser;
	foreach userTerminal in user.allUserTerminals do
	
		termSecRole := userTerminal.mySecurityRole;
		while termSecRole &lt;&gt; null do
			if (not self.allSecurityRoles.includes(termSecRole)) then
				self.allSecurityRoles.add(termSecRole);
			endif;
			
			termSecRole := termSecRole.myParentRole;
		endwhile;
		
	endforeach;
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b99c24f3-0f22-4ad1-8cf9-35b81987bda0">
        <updating/>
        <source>setForUpdate(_proxy : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     21 November 2002		cnwth2	
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 02/03/2017 	cnwrh7      TFS3484       #MSL - TEMPLATE FOR TASK "TRASPORTI" NOT RUN CORRECTLY
// 13/02/2018	jlgdap1		TFS 37030 SSL Demurrage Report
vars
	user					: CM_User;
	ut						: CM_UserTerminal;
	realQryParam,
	pxyQryParam				: CM_QueryReportParam;
	newDefaultTemplate		: CMQF_FilterReports;
begin
	inheritMethod(_proxy);
	
	if _proxy.myFilterObject &lt;&gt; null then
		//create new default template object
		delete self.myFilterObject;
		newDefaultTemplate := _proxy.myFilterObject.cloneSelf(false);
		self.myFilterObject := newDefaultTemplate;							// TFS 37030 moved up to here
		newDefaultTemplate.cloneReferences(_proxy.myFilterObject, false);
		if _proxy.myFilterObject.isKindOf(CMQF_ResourceUsage) then																																					//+TFS3484	
			_proxy.myFilterObject.CMQF_ResourceUsage.allToDoTaskDescs.copy(newDefaultTemplate.CMQF_ResourceUsage.allToDoTaskDescs);
		endif;
		newDefaultTemplate.isDefaultHolder := true;
		//self.myFilterObject := newDefaultTemplate;						// TFS 37030 moved up 
	endif;
	
	self.allQueryReportParams.purge();
	foreach pxyQryParam in _proxy.allQueryReportParams do
		create realQryParam persistent;
		self.allQueryReportParams.add(realQryParam);
		realQryParam.setForCreate(pxyQryParam);
	endforeach;
	
	self.menuId	:= self.getIdPrefix &amp; self.getInstanceIdForObject64(self).String;
	self.myRoot := app.myRoot;
	self.jrwViewName := _proxy.jrwViewName;

	if self.jrwViewName = null then
		self.jrwViewName := getViewNameOfFirstDesign();
	endif;
	
	self.isSelectorAvailable := _proxy.isSelectorAvailable;
	
	// only need to do this is allowed for web
//	if app.getMyUserCode = 'CNWRS2' then
//		process.debug;
// Enabled by DVB 18/11/04
		self.setReportWebPages();
//	endif;
	
	self.reportAvailability 	:= _proxy.reportAvailability;
	self.reportProcessType	:= _proxy.reportProcessType;
	self.reportFormats.clear();
	_proxy.reportFormats.copy(self.reportFormats);
	
	//add to all userterminal report menus
/*	foreach user in app.myRoot.allUsers do
		foreach ut in user.allUserTerminals do	
			ut.myReportMenuRoot.addQryReportToUserMenu(self);
		endforeach;
	endforeach;*/
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="c51bbf15-9394-4d11-9669-5ed1b711d00c">
        <updating/>
        <source>setFromXML(_str: String; _root: CM_MenuRoot; _constValue : Integer; _childValues : IntegerArray; _systemOnly : Boolean; _passedInMenuId : String) updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	xmlParser 			: CnEcXmlParser;
	xmlStruct, 
	xmlGroup 			: CnEcXmlStructureInstance;
	repCategory			: Integer;
	rowName				: String;
	filterObject		: CMQF_FilterReports;
	menuId				: String;	//24 Apr 2014	NDL	Error running Permissions App. (second time)
begin

	menuId := '_rpt' &amp; _constValue.String;
	
	inheritMethod(_str, _root, _constValue, _childValues, _systemOnly, menuId);
	
//	self.menuId := '_rpt' &amp; _constValue.String; //constant value as integer
	
	create xmlParser transient;
	create xmlStruct as CnEcXmlGroupInstance transient;

	xmlParser.parseToMsgStructure(_str, xmlStruct);
	
	if xmlStruct.findStructure('reportControllerClass') &lt;&gt; null then
		self.reportControllerClass	:= xmlStruct.findStructure('reportControllerClass').tagData;
	endif;
	//if we're creating from XML it is always a system type
	self.reportType := self.ReportType_SystemDefined;
	
	self.isInternal			:= (xmlStruct.findStructure('isInternal').tagData).Boolean;
	self.reportName 		:= xmlStruct.findStructure('reportName').tagData;
	self.heading 			:= self.reportName[1:60]; // TFS 3009 increased to 60
	self.qryMethodName 		:= xmlStruct.findStructure('qryMethodName').tagData;
	self.filterClassName 	:= xmlStruct.findStructure('filterClassName').tagData;
	self.tableDefName 		:= xmlStruct.findStructure('tableDefName').tagData;
	self.tableDefViewName 	:= xmlStruct.findStructure('tableDefViewName').tagData;
	xmlGroup				:= xmlStruct.findStructure('isFormBasedReport');
	
	if xmlGroup &lt;&gt; null then
		self.isFormBasedReport := xmlGroup.tagData.toUpper.convertToBoolean();
		xmlGroup				:= xmlStruct.findStructure('canCSV');
		if xmlGroup &lt;&gt; null then
			//self.canCSV := xmlGroup.tagData.toUpper.convertToBoolean();
		endif;
	endif;
	
	xmlGroup	:= xmlStruct.findStructure('schemaName');
	if xmlGroup &lt;&gt; null then
		self.schemaName := xmlGroup.tagData;
	endif;
	
	xmlGroup	:= xmlStruct.findStructure('formClassName');
	if xmlGroup &lt;&gt; null then
		self.formClassName := xmlGroup.tagData;
	endif;
	
	if xmlStruct.findStructure('pageLayout') &lt;&gt; null then
		self.pageLayout := xmlStruct.findStructure('pageLayout').tagData.Integer;
	endif;
	
	if xmlStruct.findStructure('reportDescription') &lt;&gt; null then
		self.reportDescription 	:= xmlStruct.findStructure('reportDescription').tagData;
	endif;

// users can edit this info so don't blat if it's already set	
	//jrwReportName.clear;
	//jrwReportProfileName.clear();
	
	if self.jrwReportName.isEmpty then	//new one
		self.jrwReportProfileName.clear;
		foreach xmlGroup in xmlStruct.findStructure('allJRWs').CnEcXmlGroupInstance.allFields do
			jrwReportName.add(xmlGroup.findStructure('jrwReportName').tagData);
			jrwReportProfileName.add(xmlGroup.findStructure('jrwReportProfileName').tagData);
		endforeach;
	endif;
	
		
	self.requiredFields.clear;
	if xmlStruct.findStructure('allReqdFields') &lt;&gt; null then
		foreach xmlGroup in xmlStruct.findStructure('allReqdFields').CnEcXmlGroupInstance.allFields do
			rowName := xmlGroup.findStructure('rowName').tagData;
			if rowName &lt;&gt; null then
				requiredFields.add(rowName);
			endif;
		endforeach;
	endif;
	
	self.addToRootSecurityRoles();
	//create filterObject to hold defaults if there isn't one already
	if (filterClassName &lt;&gt; null) then
		if (self.myFilterObject = null or self.myFilterObject.class.name.toUpper &lt;&gt; filterClassName.toUpper) then
			create filterObject as currentSchema.getClass(self.filterClassName) persistent;
			self.myFilterObject := filterObject;
		endif;
	endif;
	
	self.setJRWViewName();
epilog
	delete xmlParser;
	delete xmlStruct;

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_root" type="CM_MenuRoot"/>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_childValues" type="IntegerArray"/>
        <Parameter name="_systemOnly" type="Boolean"/>
        <Parameter name="_passedInMenuId" type="String"/>
    </JadeMethod>
