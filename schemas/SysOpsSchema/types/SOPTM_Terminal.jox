    <JadeMethod name="initShtFld1" id="28547780-a391-4dda-aa75-eabdaa021be8">
        <source>initShtFld1();
//25 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// cnwdap1	11/08/2011	PAR #27972 Bulk release type no longer translatable, replaced by string constants
// jlizm1	13/09/2023	TFS 59985 Truck Seals design changes
vars
	theForm : SOP_TableMaintForm;
	tbl : CM_EntryTable;
	terminal : CM_Terminal;
begin
	self.myForm.shtFolder1.visible := true;
	self.myForm.shtFldSheet2.visible := false;
	theForm := self.myForm;
	
	//+cnwml2 PAR26035
	if self.myForm.myCurrentObject.isKindOf(CM_Terminal) then
		terminal := self.myForm.myCurrentObject.CM_Terminal;
	endif;
	
	//+cnwml2 PAR25756
	if terminal = null then		//will be on create new
		return;
	endif;
	
	//set Form Sheet Captions
	theForm.shtFolder1.caption := app.getErrorString(Seal_Checks);
	theForm.shtFldSheet1.caption := app.getErrorString(Terminal_level);
	
	//setup tables
	tbl := theForm.tblFldSheet1;
	tbl.visible := true;
	tbl.clear();
	tbl.columns := 3;
	tbl.rows := 7;
	
	tbl.accessCell(1,1).text := app.getErrorString(Seal_check_type) &amp; Tab &amp; app.getErrorString(Receivals) &amp; Tab &amp;  app.getErrorString(Releases);
	tbl.accessColumn(2).inputType := Table.InputType_ComboBox;	
	tbl.comboList := app.getString(Strict) &amp; Tab &amp; app.getString(Full)&amp; Tab &amp; app.getString(View) &amp; Tab &amp; app.getString(None);	// 14 Sep 2010	NDL	Par 25608 - Not allowed default on terminal.
	tbl.accessColumn(3).inputType := Table.InputType_ComboBox;
	tbl.accessCell(2,1).text := BR_TYPE_SHIP_STR &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckShipReceival) &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckShipRelease);					// PAR #27972
	tbl.accessCell(3,1).text := BR_TYPE_RAIL_STR &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckRailReceival) &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckRailRelease);					// PAR #27972
	tbl.accessCell(4,1).text := BR_TYPE_ROAD_STR &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckRoadReceival) &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckRoadRelease);					// PAR #27972
	tbl.accessCell(5,1).text := BR_TYPE_PACKING_STR &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckUnpack) &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckPack);
	tbl.accessCell(6,1).text := app.getErrorString(Rail_wagon) &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckWagonDischarge) &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckWagonLoad);// PAR #27972
	tbl.accessCell(7,1).text := app.getErrorString(Truck) &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckTruckDischarge) &amp; Tab &amp; app.sealCheckTypeEnumToString(terminal.sealCheckTruckLoad);	// TFS 59985
	
	//epr tfs 2011 performance improvements
	tbl.selectMode := Table.SelectMode_Default;
	tbl.width		:= tbl.parent.Control.clientWidth;
	tbl.parentAspect := Table.ParentAspect_StretchRight;	
	tbl.autoSize:= Table.AutoSize_Column;
	tbl.accessColumn(1).widthPercent := 33.33;
	tbl.accessColumn(2).widthPercent := 33.33;
	tbl.accessColumn(3).widthPercent := 33.33;
	
	
	tbl.width := self.myForm.shtFolder1.width;
	tbl.height := tbl.rows * 19;
	tbl.top		:= 0;
	tbl.left 	:= 0;
	tbl.fixedRows := 1;
	tbl.fixedColumns := 0;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="84842ec6-b98d-4f72-8f2f-fb07c66d52ce">
        <source>initShtMultiSelect();
// ---------------------------------------------------------------------------
// Created:     22 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/06/2023	navdap1		TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
// 09 Aug 2023	jlika1		TFS 59720 EUP | Default Cargo Group Type on Terminal Config
// 01 Aug 2025 navsp1       JIRA-35530 Solution Implementation - COPRAR Trailer Support
// ---------------------------------------------------------------------------
vars
	theForm	: SOP_TableMaintForm;
	col     : CM_CargoBOLTypeArray;
begin

	theForm := self.myForm;
	inheritMethod;	
	theForm.cmbCargoBOLType.visible := true;
	theForm.cmbCargoType2.visible := true;
	theForm.cmbBOLType.visible := true;
	theForm.lblName2.visible := true;
	theForm.lblName3.visible := true;
	theForm.lblName4.visible := true;
	theForm.mulSelect2.visible	:= true;
	theForm.shtMultiSelect2.visible := true;
	//theForm.shtDrawing.visible := true;	// 31/05/2011 cnwar2 #26741 - suppress Graphic tab
	if app.isCargoGroupEnabled then
		theForm.cmbCargoGroup.visible := true;		// TFS 56747
		theForm.lblName5.visible := true;			// TFS 56747
		endif;
    theForm.cmbTrailerCargoType.visible    := true; //JIRA-35530
    theForm.lblName6.visible               := true; //JIRA-35530
    
	create col transient;
	app.myRoot.getCargoTypesForLicense(theForm.myTerminal, col);
	self.setupMultiSelect2("Cargo\BoL Type",col,SOP_TableMaintForm::displayEntryCargoBolType.name);
epilog   
	delete col;	

end;</source>
    </JadeMethod>
    <JadeMethod name="initShtTblInput2" id="b5170134-31b2-4e52-958d-16b3cf94526d">
        <updating/>
        <source>initShtTblInput2() updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef	: EntTableDef;
	mainSheet,
	tmpSheet	: CMUI_Sheet;
	idx			: Integer;
	defName		: String;
	theForm		: SOP_TableMaintForm;
	
begin
	inheritMethod();
	theForm 	:= self.myForm;
	mainSheet	:= theForm.shtTblInput2;

	foreach defName in self.allEntTableDefs do
		entTableDef := app.myController.getEntTableDef(defName);
		if entTableDef = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown def (' &amp; defName &amp; ')');
			continue;
		endif;

		idx := idx + 1;
		tmpSheet := mainSheet.getControl(idx).CMUI_Sheet;
		
		if tmpSheet = null then
			tmpSheet := mainSheet.loadControl(idx).CMUI_Sheet;
		endif;
		
		tmpSheet.visible := true;
		tmpSheet.caption := entTableDef.description;
		tmpSheet.backColor := mainSheet.backColor;
	endforeach;
	
	
end;</source>
    </JadeMethod>
