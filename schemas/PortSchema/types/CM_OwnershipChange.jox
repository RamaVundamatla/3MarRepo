    <JadeMethod name="pxyCreateUpdateProxy" id="988f180d-4b59-4f3d-b87f-bf83e2922670">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason1
06 June 2023 navtnr20	TFS CR 58507	Task 58209: Jade - TRX CM_OwnershipChange

*/

vars
	_proxy : SelfType;
begin
	_proxy := inheritMethod();
	_proxy.myOperatorOld	:= self.myOperatorOld;
	_proxy.myFreightForwarder	:= self.myFreightForwarder;
	_proxy.myIncoterm			:= self.myIncoterm;
	_proxy.myOperatorNew		:= self.myOperatorNew;
	_proxy.myOperatorOrig		:= self.myOperatorOrig;
	_proxy.myOperatorStorage	:= self.myOperatorStorage;
	_proxy.myOwnershipChangePrevious	:= self.myOwnershipChangePrevious;
	_proxy.myTerminal			:= self.myTerminal;
	_proxy.myInvoiceContract    := self.myInvoiceContract;							//navra1 - TFS 64874 - 14th Aug 2024
	
	return _proxy;
	
epilog

end;</source>
