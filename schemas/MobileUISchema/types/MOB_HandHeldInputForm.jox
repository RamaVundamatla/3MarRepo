    </ImplicitInverseRef>
    <JadeMethod name="doResize" id="8bea0c05-3cd5-447e-af98-66b44c300842">
        <updating/>
        <source>doResize() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 July 2010	cnwer1	Initial creation PAR 24807

*/


constants
	WIDTH = 240;
	Dummy = "Dummy";
vars

	screenWidth,
	screenHeight : Integer;
begin
	if app.myVMAgent &lt;&gt; null then
		self.getVehicleMountedScreenSize(screenWidth,screenHeight);
		
		if screenWidth &gt; 400 then
			self.width:=400;
		else
			self.width:=screenWidth;
		endif;
	else
		self.width:=WIDTH;	
	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getValues" id="b40b699b-4457-4320-9eb1-2a268032a8c3">
        <source>getValues( _fieldValues : StringArray input);
// ---------------------------------------------------------------------------
// Created:	18 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	index : Integer;
begin
	foreach index in 1 to self.tblInfo.rows do
		_fieldValues.add( self.tblInfo.accessCell( index, 2).text.trimBlanks());
	endforeach;
epilog
end;</source>
        <Parameter name="_fieldValues" type="StringArray" usage="input"/>
    </JadeMethod>
