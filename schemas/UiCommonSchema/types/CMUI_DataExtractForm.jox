    <JadeMethod name="translateForm" id="442818bc-c34d-4eba-8978-11649eea6574">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015992, locale);
	btnCancel.translateBubbleHelp(Xlat_0015993, locale);
	btnCancel.translateCaption(Xlat_0015994, locale);
	btnClear.translateBubbleHelp(Xlat_0015995, locale);
	btnClear.translateCaption(Xlat_0015996, locale);
	btnExtract.translateBubbleHelp(Xlat_0015997, locale);
	btnExtract.translateCaption(Xlat_0015998, locale);
	btnFind.translateBubbleHelp(Xlat_0015999, locale);
	lblDirectory.translateCaption(Xlat_0016000, locale);
	lblTblExtract.translateCaption(Xlat_0016001, locale);
	lblTerminal.translateCaption(Xlat_0016002, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="d68a07ba-57cd-40ec-b4b8-a6c1ef3768ae">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2011		cnwth2	27436
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
constants
	UpdateInterval			= 4000;
	
vars
	//pgMsg : String;
begin
	if (app.relativeMachineTime() - self.lastMessageDisplay) &lt; UpdateInterval then
		return;
	endif;
	
	self.lblModalInfo.caption := _cmifMonitor.partsDone.String &amp; " " &amp; _cmifMonitor.message &amp; " have been extracted";
	
	self.doWindowEvents(0);
	
	_cmifMonitor.monitorReturnValue := self.modalDialogReturnValue;	

	if self.modalDialogReturnValue = ModalDialogReturn_Option2 then
		_cmifMonitor.monitorReturnValue := CMIF_Monitor.MonitorReturnValue_Cancel;
	elseif self.modalDialogReturnValue = ModalDialogReturn_Option1 then
		_cmifMonitor.monitorReturnValue := CMIF_Monitor.MonitorReturnValue_Return;
	endif;
	
	self.lastMessageDisplay := app.relativeMachineTime();
	
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
</GUIClass>
