    <JadeMethod name="noteUser" id="19e2cf14-35d0-4f28-9bf6-40dc101a76da">
        <updating/>
        <source>noteUser(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     26 January 2010 by cnwab1
//
/*

Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance
					Changed form to use timer queued refreshes to handle large numbers of
					consecutive notifications from a single action


*/

vars
	actualEvent 	: Integer;
	theTI 			: CM_TrackedItem;
	voyAlloc 		: CM_VoyageAllocation;
	
begin
	actualEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	self.exportsHaveChanged := false;

	if actualEvent = EVENT_UPDATE_VOYAGE_AREA and 
	   (userInfo.isKindOf(CM_SlotController) or	// PAR 23435 listening for slot controllers not slot requests
	    userInfo.isKindOf(CM_ROROSlotController)) then	// 28663 Nov 2011 cnwjre1 add RORO controllers
		self.doQueueRefresh();				// PAR #27032
	elseif actualEvent = EVENT_VOY_ALLOC_UPDATE and userInfo.isKindOf(CM_VoyageAllocation) then
		self.doNoteUpdateAllocation(userInfo.CM_VoyageAllocation);
	elseif actualEvent = EVENT_VOY_ALLOC_DELETE and userInfo.isKindOf(CM_VoyageAllocation) then
		self.doNoteDeleteAllocation(userInfo.CM_VoyageAllocation);	
	elseif (actualEvent = TIEvent_Terminal_Receival) then
		self.doQueueRefresh();
	elseif (actualEvent = TIEvent_PreNote_Delete) then
		self.doQueueRefresh();	
	elseif actualEvent = ShowHide_VoyageAllocationsCC and userInfo.isKindOf(Boolean) then //cnwas3 23840a
		if userInfo.Boolean &lt;&gt; self.visible then
			self.visible := userInfo.Boolean;
			if self.visible then
				self.doQueueRefresh();
			endif;
		endif;		
	elseif (actualEvent = TIEvent_PreNote_Add or actualEvent = TIEvent_PreNote_Update)		// PAR #27032
		and userInfo.isKindOf(CM_TrackedItem) then
		theTI := userInfo.CM_TrackedItem;
		if theTI.myVoyage &lt;&gt; self.myVoyage then
			return;
		endif;
		
		voyAlloc := self.myVoyage.getVoyageAllocationForTI(theTI);
		self.displayCCTableExportAddOne(voyAlloc);
	endif;
	
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
