    <JadeMethod name="setTCP" id="1f080714-cd0e-43bc-a1a5-062a73de87e4">
        <source>setTCP(_cmif : CMIF_BGPManagerChildren input) : Boolean protected;

// cnwdvb1 11 December 2002 

vars
//	tcpIp,
	numberOfWorkers	: String;
//	loggingLevel,
	workerClass		: String;
//	interface		: String;

begin
	numberOfWorkers			:=	fieldNoWorkers.getString();
	workerClass				:=	fieldWorkerType.getString();//self.tblAddEdit.getValueByName(ETRow_TcpipWorkerType).String;
	
//	tcpIp 					:= self.tblAddEdit.getValueByName(ETRow_TcpIpPort).String;	
//	numberOfWorkers			:= self.tblAddEdit.getValueByName(ETRow_NumberOfWorkers).String;	
//	loggingLevel			:= self.tblAddEdit.getValueByName(ETRow_LoggingLevel).String;	
//	workerClass				:= self.tblAddEdit.getValueByName(ETRow_TcpipWorkerType).String;
//	interface				:= self.tblAddEdit.getValueByName(ETRow_BgpTcpIpInterface).String;
	
	if numberOfWorkers.Integer &gt;  SOP_BackgroundForm.MaxApps then
		app.msgBox('Maximum of ' &amp; SOP_BackgroundForm.MaxApps.String &amp; ' applications has been exceeded','Error',MsgBox_OK_Only);
		return false;
	endif;
	
	if not _cmif.setWorker(workerClass) then
		app.msgBox('Must select type of worker', 'Error', MsgBox_OK_Only);
		return false;
	endif;
	
//	_cmif.tcpIpPort 			:= tcpIp;
//	_cmif.numberOfWorkers		:= numberOfWorkers;
//	_cmif.loggingLevel			:= loggingLevel;
//	_cmif.tcpIpInterfaceAddress	:= interface;
	
	_cmif.tcpIpPort 			:=	fieldTcpPort.getString();
	_cmif.numberOfWorkers		:=	numberOfWorkers;
	_cmif.loggingLevel			:=	fieldLogLevel.getString();
	_cmif.tcpIpInterfaceAddress	:=	fieldTcpAddress.getString();
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableForManager" id="1d3708e9-14ca-4927-bb65-1383999a6b27">
        <source>setTableForManager(_manager : BGP_Manager) protected;

// cnwdvb1 25 October 2002 
//
//28 Apr 2016	cnwrs1	TFS Push Events Geneva
// 10 May 2017	cnwrs1	TFS 3518 remove Push Events
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
vars
	proxyObj	: CMIF_BGPManagerChildren;

begin
	create proxyObj transient;
	proxyObj.loadFromManager(self.aMyBGPObject.BGP_Manager);
	
	self.fieldIsServer.setValue(proxyObj.isServer);
	self.fieldManagerName.setValue(proxyObj.managerName);
	self.fieldNoRemotes.setValue(proxyObj.numberOfRemotes);
	self.fieldNoReports.setValue(proxyObj.numberOfReports);
	self.fieldNoDirect.setValue(proxyObj.numberOfDirectories);
	self.fieldNoTcpServer.setValue(proxyObj.numberOfTcpIpServers);
	self.fieldNoTcpClient.setValue(proxyObj.numberOfTcpIpClients);
	self.fieldNoExtWSrvs.setValue(proxyObj.numberOfExtWSServices);
	self.fieldIsAutoTimer.setValue(proxyObj.isAutoTimer);
	self.fieldIsFutureTim.setValue(proxyObj.isFutureTimer);	// ***
	self.fieldIsLockKeep.setValue(proxyObj.isLockKeeper);
	self.fieldIsLocStats.setValue(proxyObj.isLocationStatistics);
	self.fieldIsRFIDList.setValue(proxyObj.isRFIDListenController);
	self.fieldIsChgTrack.setValue(proxyObj.isChangeTracker);
	self.fieldIsBackupJnl.setValue(proxyObj.isBackupJournal);
	self.fieldIsAutoWarn.setValue(proxyObj.isAutoWarning);
	self.fieldMachineName.setValue(proxyObj.machineNameSpecific);
	self.fieldIsFatOnly.setValue(proxyObj.isFatClientOnly);
	self.fieldIsWOSched.setValue(proxyObj.isWorkOrderScheduler);
	self.fieldIsCalCheck.setValue(proxyObj.isCalendarCheck);		// 02 Nov 2010	NDL	Par 25530
	self.fieldIsVSBookGen.setValue(proxyObj.isVSBookGen);	//15 Apr 2013	NDL	Par 31393
	self.fieldIsDeferred.setValue(proxyObj.isDeferred);//06 Jul 2021	NDL	TFS 51443
	
epilog
	delete proxyObj;
end;</source>
        <access>protected</access>
        <Parameter name="_manager" type="BGP_Manager"/>
    </JadeMethod>
