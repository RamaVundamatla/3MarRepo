    <JadeMethod name="getVisibleStatus" id="c1ea289c-7fea-410d-9ce7-68cf848204fd">
        <source>getVisibleStatus(): Boolean;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myButtonForToolbar &lt;&gt; null then
		return self.myButtonForToolbar.visible;
	endif;
	
	if self.myMenuUserToolbar &lt;&gt; null then
		return true;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWidth" id="e6774eed-d261-4677-b797-397c72622a42">
        <source>getWidth(_showCaptions : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     28 July 2003		cnwth2	
//
// Purpose:      
// ----------   ----------  --------------------------------------------------
vars

begin

	if _showCaptions then
		if self.width &gt; self.WidthTotalWithCaption then // JMT METRO CNWAB1
			return self.width.Integer; // JMT METRO CNWAB1
		endif;
	
	
		return self.WidthTotalWithCaption;
	endif;
	
	return self.WidthTotalWithoutCaption;	

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromButton" id="318c093c-c91b-42e4-a068-1aa263a387d5">
        <updating/>
        <source>initFromButton(_button : CMUI_ButtonForToolbar; _showCaptions : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHeight,
	tmpWidth	: Real;
	tmpHelp		: String;
	theCaption	: String;

begin
	if _button = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Button passed in is null');
		return;
	endif;
	
	self.myButtonForToolbar := _button;
	self.referenceType 		:= self.ReferenceType_Button;
	self.style				:= _button.style;
	
	self.userObjectName := _button.name;

	if _button.fontCharacter &lt;&gt; null then
		self.drawCharacter(_button.fontName, _button.fontCharacter.Character, _button.fontColour);
	else
		self.myToolbarPicture.picture 			:= _button.picture;
		self.myToolbarPicture.pictureDisabled	:= _button.pictureDisabled;
		self.myToolbarPictureCaption.picture 			:= _button.picture;
		self.myToolbarPictureCaption.pictureDisabled	:= _button.pictureDisabled;
		
		
	endif;

	self.setShowCaptions(_showCaptions);

	tmpHelp := _button.bubbleHelp;

	if tmpHelp = null then
		self.myToolbarOverlay.bubbleHelp := _button.caption.replaceString('&amp;', '');
	else
		self.myToolbarOverlay.bubbleHelp := tmpHelp;
	endif;
	
	self.enabled := _button.enabled;
	self.visible := _button.visible;
	
	if _button.value then
		self.resetButtonState(_button.value);
	endif;
end;</source>
        <Parameter name="_button" type="CMUI_ButtonForToolbar"/>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserToolbar" id="272d453a-c0ec-4584-aa3d-b854a10e68e7">
        <updating/>
        <source>initFromUserToolbar(_menuUserToolbar : CM_MenuUserToolbar; _seperatorPic : Binary; _showCaption : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     Returns next offset		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _menuUserToolbar = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Menu user toolbar passed in is null');
		return;
	endif;

	self.myMenuUserToolbar := _menuUserToolbar;
	self.referenceType := self.ReferenceType_MenuUserToolbar;
	
	self.userObjectName := _menuUserToolbar.mySystemToolbar.constantValue.String;

	self.myToolbarPicture.picture 			:= _menuUserToolbar.pictureButton;
	self.myToolbarPicture.pictureDisabled	:= _menuUserToolbar.pictureButtonDown;
	self.myToolbarPictureCaption.picture 			:= _menuUserToolbar.pictureButton;
	self.myToolbarPictureCaption.pictureDisabled	:= _menuUserToolbar.pictureButtonDown;
	self.bubbleHelp 						:= _menuUserToolbar.toolTip;
	self.setShowCaptions(_showCaption);

	self.visible := true;

end;</source>
        <Parameter name="_menuUserToolbar" type="CM_MenuUserToolbar"/>
        <Parameter name="_seperatorPic" type="Binary"/>
        <Parameter name="_showCaption" type="Boolean"/>
    </JadeMethod>
