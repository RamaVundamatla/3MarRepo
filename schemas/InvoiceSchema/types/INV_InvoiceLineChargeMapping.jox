    <JadeMethod name="doCopy" id="d29738d8-116a-4d2f-a00b-e31ccd4bd402">
        <source>doCopy(pObjSet :ObjectSet; pMaps :CM_InvLineChargingMapsDict io);

vars
	obj	: Object;
begin
	on Exception do handleDeletedObject(exception);
	foreach obj in pObjSet do
		pMaps.add(obj.CM_InvoiceLineChargeMapping);
	endforeach;
end;
</source>
        <Parameter name="pObjSet" type="ObjectSet"/>
