    <JadeMethod name="mnuDockFrameSub_click" id="c1848323-7a23-4b77-bbfc-dd8b030f6ee2">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDockFrameSub_click(menuItem: MenuItem input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	dockControl		: JadeDockBase;
	dockParent			: Control;
begin
	dockControl := menuItem.userObject.JadeDockBase;
	if dockControl = null then
		return;
	endif;
	if (not dockControl.visible) then
		dockControl.visible := true;
	endif;
	
	dockParent := self.getOriginalDockingParent(dockControl);
	if dockParent = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Developer has not reimplemented and specified parent frame for "' &amp; dockControl.caption &amp; '"');
		return;
	endif;
	
	dockControl.parent := dockParent;
	
	if (not dockParent.visible) then
		dockParent.visible := true;
	endif;
	

end;



</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuEnquireCargo_click" id="0de958ef-8aa5-4e94-b648-0f60820348a1">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuEnquireCargo_click(menuItem: MenuItem input) updating;
/*

Date		Who		Reason
14 September 2015	cnwer1	Initial creation PAR

*/

vars
	reserveSelection : CM_ReserveSelection;
	objArray 	: CM_ObjectArray;
	minCargoIdLength : Integer;
begin
	if self.mySelectedObject = null then
		return;
	endif;
	if not self.mySelectedObject.isKindOf(CM_ReserveSelection) then
		return;
	endif;
	
	reserveSelection:= self.mySelectedObject.CM_ReserveSelection;
	create objArray transient;
	reserveSelection.getAllCargoMatchingRelease(objArray,minCargoIdLength);
	
	if objArray.isEmpty then
		return;
	endif;
	
	self.myAssistant.showCargoEnquiryForTIs(objArray.first.CM_TrackedItem,objArray,null,false);
epilog
	delete objArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
