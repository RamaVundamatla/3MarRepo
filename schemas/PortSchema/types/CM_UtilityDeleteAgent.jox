    <JadeMethod name="utlDeleteRowController" id="9724a4d1-e954-476e-8778-cf76401eb693">
        <source>utlDeleteRowController(_rowController : CM_RowController; _passport : CM_Passport input);

vars
	toDelete	: CM_RowController;
	terminal	: CM_Terminal;

begin

	toDelete := _rowController;

	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	app.myValDA.valRowController(_rowController);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
	endif;
	
	terminal := toDelete.myTerminal;
	if _passport.noErrors then
		toDelete.erase(NORMAL_ERASE);
	endif;
	
	if _passport.noErrors then
		global.causeEvent(terminal.getTerminalEvent(EVENT_ROWCONTROLLER_DELETE), false, null);
	endif;

end;</source>
        <Parameter name="_rowController" type="CM_RowController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
