    <JadeMethod name="checkTempDirFolderPath" id="8b2a211e-c898-4063-83bf-98a82a1df1cc">
        <source>checkTempDirFolderPath(_folderPath :String io; _callingMethod : String; _classAttributeName : String) ;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 29 July 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change Refer PAR 22336 behind reason.
// 29/07/2010	cnwsh3  	Purpose: To check the validity of the file path that has been passed in.  Used for when using a location for temporarily holding files we are generating/processing.
//							Eg. Emails, reports, packages need a temp location and this could be on the server.
//     						If a the folder path is invalid or does not exist on the machine running the process thhe default temp directory is used but we log
//							the fact we have passed in something but couldn't use it.
//							We don't prevent the processing from occurring.
//							
//							Parameters: _folderPath - the intended directory path.
//										
//										_callingMethod - the method that uses this method so we know where to look if we need to.
//										
//										_setLocation - where we (or the user) can set the location for this. 
//													   An example area of where we set a temp location is, BGP Reports and System Config. (as at 29/07/2010)
//----------------------------------------------------------------------
vars
	path : String;
begin
	path := _folderPath;
		
	if path = null then
		//We haven't got a temp directory so use the default temp dir
		path := app.getTempDir();
		app.writeLog(method.qualifiedName &amp; '&gt;&gt; called from ' &amp; _callingMethod 
					 &amp; ' &gt;&gt;&gt; No System Temp Directory specified - using app.getTempDir().  Managed Services should specify a default temp directory. Property &gt;&gt; ' 
					 &amp; _classAttributeName, LogINFO);
	elseif not path.isFoldername() then
		//The path doesn't exist on the machine so use the default
		app.writeLog(method.qualifiedName &amp; '&gt;&gt; called from ' &amp; _callingMethod 
		             &amp; ' &gt;&gt; Directory (' &amp; path &amp; ') was not valid - reverting to app.getTempDir().  Managed Services should specify a valid default temp dir in property &gt;&gt; ' 
					 &amp; _classAttributeName, LogINFO);
		path := app.getTempDir();
		
	else
		app.writeLog(method.qualifiedName &amp; '&gt;&gt; called from ' &amp; _callingMethod &amp; ' &gt;&gt; Temporary Directory is valid &gt;&gt; ' &amp; path, LogINFO);
	endif;
	
	//Check if we have a separator at the end of the folder path.  If not, add one.
	path := path.addLastSeparatorToFilePath();
	
	_folderPath := path;
	
epilog
end;</source>
        <Parameter name="_folderPath" type="String" usage="io"/>
        <Parameter name="_callingMethod" type="String"/>
        <Parameter name="_classAttributeName" type="String"/>
    </JadeMethod>
    <JadeMethod name="checkYardAllocationLicensing" id="4dac4495-6568-49c1-8503-d6e3098d665e">
        <updating/>
        <source>checkYardAllocationLicensing(_terminal : CM_Terminal) : Boolean updating;
// -------------------------------------------
// Created 23 September 2005 by cnwdvb1
// -------------------------------------------

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags

vars

	useOverStowNew	 : Boolean;
	
begin

	if _terminal = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, 'TI', 'terminal has not been specified', null, null);
		return false;
	endif;
	
	if self.myYAAgent = null then
		
		if not _terminal.isAutoPlanningEnabled() then
			//26 Jun 2015	NDL	Par 36522 - Don't raise an error
		//	app.raiseCMException2(AutoPlanningYAError, 'TI', 'Auto Planning not enabled', null, null);
			return false;
		endif;
		
		// Is system licensed for new autoplanning
		// If not raise exception.
		// ### JIRA 33505 30DEC2024 NAVAB1 Mod_YardPlanning is now part of base module
		/*
		if not app.getMyUser.canDo(_terminal, Mod_YardPlanning) then
			app.raiseCMException1(NotLicensedToPerformAction, app.getLicenseName(Mod_YardPlanning), null, null);
			return false;
		endif;
		*/
		
		if _terminal.isAutoPlanUseOverstowRules() then
			useOverStowNew := true;
		endif;

		create self.myYAAgent transient;
		self.myYAAgent.useOverstowRules := useOverStowNew;
	endif;
	
	return true;


end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="chkPointTypeEnumToString" id="0d9c7250-0a18-4083-a1f8-548d6f381071">
        <source>chkPointTypeEnumToString(_dataType : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     06/10/2006	cnwmo1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
begin
	if _dataType = HMS_ChkPointType_Current then
		return app.getErrorString(HMS_ChkPointDescr_Current);
	elseif _dataType = HMS_ChkPointType_Draft then
		return app.getErrorString(HMS_ChkPointDescr_Draft);
	elseif _dataType = HMS_ChkPointType_HiLo then
		return app.getErrorString(HMS_ChkPointDescr_HiLo);
	elseif _dataType = HMS_ChkPointType_TimeGap then
		return app.getErrorString(HMS_ChkPointDescr_TimeGap);	
	//jlgka1 TFS 45620 --&gt;	
	/*
	elseif _dataType = HMS_ChkPointType_TideRange then
		return app.getErrorString(HMS_ChkPointDescr_TideRange);
	elseif _dataType = HMS_ChkPointType_ShipsDepart then
		return app.getErrorString(HMS_ChkPointDescr_ShipsDepart);		
	elseif _dataType = HMS_ChkPointType_UserHookCode then
		return app.getErrorString(HMS_ChkPointDescr_UserHookCode);
	//epr par 16884 4/6/08 	
	elseif _dataType = HMS_ChkPointType_TideState then
		return app.getErrorString(HMS_ChkPointDescr_TideState);
	*/	
	//jlgka1 TFS 45620 &lt;--
	else
		return null;
	endif;

end;</source>
        <Parameter name="_dataType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
