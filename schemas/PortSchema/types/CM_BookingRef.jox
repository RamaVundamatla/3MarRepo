    <JadeMethod name="setSpecialLift" id="b0f142d7-3095-4d3a-bf73-aeb338fced12">
        <source>setSpecialLift(_allSpecialLifts : CM_SpecialLiftByCodeDict);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2009	cnwml2	Initial creation

*/

vars
	spLift : CM_SpecialLift;
begin
	self.allSpecialLifts.clear;	//just clear

	if _allSpecialLifts.isEmpty then
		return;
	endif;
	
	foreach spLift in _allSpecialLifts do
		self.allSpecialLifts.add(spLift);
	endforeach;
epilog

end;</source>
        <Parameter name="_allSpecialLifts" type="CM_SpecialLiftByCodeDict"/>
    </JadeMethod>
