    <JadeMethod name="setComboValues" id="2dffc314-42c9-49bd-8ad8-196b999e5cd9">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	ut			: CM_UserTerminal;
	qrl			: CM_QReferenceLookup;
	term		: CM_Terminal;
	foundTerm	: Boolean;
begin

	_combo.clear;

	//cnwjo3 21231
	if _queryOperator &lt;&gt; null then
		if _queryOperator.isKindOf(CM_QReferenceLookup) then
			term := _queryOperator.CM_QReferenceLookup.mySelectionValue.CM_Terminal;
		endif;
	endif;
	
	foreach ut in _passport.myUser.allUserTerminals do
		idx := _combo.addItem(ut.getMyTerminal.code);
		_combo.itemObject[idx] := ut.getMyTerminal;
		
		//cnwjo3 21231
		if ut.getMyTerminal = term then
			foundTerm := true;
		endif;
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) and foundTerm then   //cnwjo3 21231
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="9458eb0c-476d-4bda-a2bf-2b01bccadf2e">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QReferenceIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	selectionValue		: Integer;
	ut					: CM_UserTerminal;
	user				: CM_User;
	idx					: Integer;
begin
	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2; // TFS 7821

	user := app.getMyUser;
	foreach ut in user.allUserTerminals do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(ut.getMyTerminal) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; ut.getMyTerminal.code);
		_tbl.accessRow(idx).itemObject := ut.getMyTerminal;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="d9b48157-0ea2-4a38-b07c-4ebadc038276">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	str				: String;
	numRows,
	idx				: Integer;
	termSet			: CM_ObjectSet;
	term			: CM_Terminal;
begin

	create termSet transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			term := _tbl.accessRow(idx).itemObject.CM_Terminal;
			termSet.add(term);
		endif;
	endforeach;
	
	_op.setSearchValue(termSet);
	
epilog
	delete termSet;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="7a93e324-c70f-49d8-ae13-81b3cb59a557">
        <source>translateStringToSearchValue( _value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	ut		: CM_UserTerminal;
	conDict	: CM_UserTerminalByTerminalDict;
	tmpValue: String;
	
begin

	if _value.isKindOf( CM_Terminal ) then
		return _value;
	endif;
	
	tmpValue := _value.String.toUpper();
	conDict	:= app.myPassport.myUser.allUserTerminals;
	
	foreach ut in conDict do
		if ut.getMyTerminal.code.toUpper() = tmpValue then
			return ut.getMyTerminal;
		endif;
	endforeach;

	// Terminal not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="1d373ff7-be1a-449e-af94-1d9c7ff05d3e">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Oct 2008	cnwkpd1		PAR #18099 - Handle null objects in selector queries
// 10 Sep 2018	jlgka1		TFS #40200 - Removed unused variable.
// ---------------------------------------------------------------------------
begin
	if _value &lt;&gt; null then
		return _value.CM_Terminal.code;
	endif;
	
	return null;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="7162e1f6-2a83-4f4c-8d73-4fbfe42eca6d">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	returnVal		: CM_Terminal;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_Terminal) then
			returnVal := _value.CM_Terminal;
		endif;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="46c5de6a-4833-4a94-bd40-23cfc9ce4939">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(CM_Terminal) then
		return _value.CM_Terminal.code;
		
	elseif _value.isKindOf(String) then
		return app.myRoot.allTerminals[_value.String];
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
