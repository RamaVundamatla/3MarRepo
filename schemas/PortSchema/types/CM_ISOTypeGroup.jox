end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f3c58bc9-fa20-4702-b7f1-bc53cc8a7353">
        <updating/>
        <source>setProxy( 	_code, _description : String; 
			_colour, _repGrpOrder : Integer; 
			_extRef1, _extRef2 : String;
			_maxTareWeight,
			_maxTotalWeight : Integer;
			_isoTypeColl : CM_ISOTypeByCodeDict;
			_substituteISOGroupColl : CM_ISOTypeGroupByCodeDict 
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date					Who		Reason
29/07/2016 				cnwma1  TFS #2446 1310 error when trying to save YAM with ISO Group selected
10 September 2010		jlizm1	TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references

*/
vars
	isoType : CM_ISOType;
	
begin

	self.raiseExceptionIfNotTransient(method);

	self.code 				:= _code[1:4].toUpper(); //29/07/2016 cnwma1 TFS #2446
	self.description 		:= _description[1:30];
	self.colour				:= _colour;
	self.externalReference1	:= _extRef1;
	self.externalReference2	:= _extRef2;
	self.reportGroupOrder 	:= _repGrpOrder;
	self.maxTareWeight		:= _maxTareWeight;
	self.maxTotalWeight		:= _maxTotalWeight;
	self.myRoot 			:= app.myRoot;


	self.allISOTypes.clear;
	_isoTypeColl.copy(self.allISOTypes);
	
	//cnwrd1 par 30414 25.9.2012
	self.allSubstitutingISOGroups.clear;
	_substituteISOGroupColl.copy(self.allSubstitutingISOGroups);
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_repGrpOrder" type="Integer"/>
        <Parameter name="_extRef1" type="String"/>
        <Parameter name="_extRef2" type="String"/>
        <Parameter name="_maxTareWeight" type="Integer"/>
        <Parameter name="_maxTotalWeight" type="Integer"/>
        <Parameter name="_isoTypeColl" type="CM_ISOTypeByCodeDict"/>
        <Parameter name="_substituteISOGroupColl" type="CM_ISOTypeGroupByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="testIsUsedInAttributePlan" id="aff7a640-8522-4101-8873-303a35499a6a">
        <source>testIsUsedInAttributePlan();
//Test the attribute plans, make sure none are referencing us!
vars
	ap	:	CM_CargoTypeAttribPlan;
begin
	foreach ap in CM_CargoTypeAttribPlan.instances do
		if ap.isoTypeGroup = self then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_USED_IN_ATTRIB_PLAN, "ISO Type Group code "&amp; code.trimRight, "Tracked Item Type "&amp; ap.id.trimRight ,null, null);
			return;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b5b3aa83-08f0-4d1f-8182-6df1b4a2f872">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//29/07/2016 cnwma1  TFS #2446 1310 error when trying to save YAM with ISO Group selected
// ---------------------------------------------------------------------------
vars
	isoTypeGrp : CM_ISOTypeGroup;
begin
	/*if app.myRoot.allISOTypeGroups[code] &lt;&gt; null then                        //29/07/2016 cnwma1 TFS #2446           
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;*/
	foreach isoTypeGrp in app.myRoot.allISOTypeGroups do   //29/07/2016 cnwma1 TFS #2446
		if isoTypeGrp.code.toUpper = code.toUpper then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
		endif;
	endforeach;
	
	self.validateForUpdate;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="d869b6cb-52d0-4b48-9f37-b5d9d5554280">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	iter : Iterator;
	objArray : ObjectArray;
	obj : Object;
	threshold : CM_Threshold;
	release : CM_BulkRelease;
	reserve : CM_ReserveSelection;

begin
	if self.allISOTypes.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "ISO Type", null, null);
	endif;
	
	//23 Feb 2012	NDL	Par 28072
	create objArray transient;
	CM_Threshold.allInstances( objArray, 0, true);
	if not objArray.isEmpty then
		iter := objArray.createIterator;
		while iter.next( obj ) do
			threshold := obj.CM_Threshold;
			if threshold.myISOTypeGroup = self then
				app.raiseCMException3(Object_referenced_by, self.code, "Threshold", threshold.auditId, null, null);
				return;
			endif;
		endwhile;
		delete iter;
	endif;
	delete objArray;
	
	create objArray transient;
	CM_BulkRelease.allInstances( objArray, 0, true);
	if not objArray.isEmpty then
		iter := objArray.createIterator;
		while iter.next( obj ) do
			release := obj.CM_BulkRelease;
			if release.myISOGroup = self then
				app.raiseCMException3(Object_referenced_by, self.code, "Release", release.code, null, null);
				return;
			endif;
		endwhile;
		delete iter;
	endif;
	delete objArray;
	
	create objArray transient;
	CM_ReserveSelection.allInstances( objArray, 0, true);
	if not objArray.isEmpty then
		iter := objArray.createIterator;
		while iter.next( obj ) do
			reserve := obj.CM_ReserveSelection;
			if reserve.myISOGroup = self then
				app.raiseCMException3(Object_referenced_by, self.code, "Reserve Selection", reserve.getDescription, null, null);
				return;
			endif;
		endwhile;
		delete iter;
	endif;
	delete objArray; 
	// end of Par 28072

epilog

	delete iter;
	delete objArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="20083148-e4d6-42f6-bdc6-9cf7059e9c15">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/12/2014  cnwdb2	PAR 35364
// ---------------------------------------------------------------------------
vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ISOTypeGroup Code', null, null);
		app.raiseCMException(Input_required_field_isoGrpCod, null, null); // cnwdb2	PAR 35364


	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ISOTypeGroup Description', null, null);
		app.raiseCMException(Input_required_field_isoTypGD, null, null); // cnwdb2	PAR 35364
	endif;
	
	//cnwrd1 par 30414 25.9.2012
	if self.allSubstitutingISOGroups[code] &lt;&gt; null  then
		app.raiseCMException(Group_cannot_substit_itself, null, null);
	endif;
end;</source>
    </JadeMethod>
</Class>
