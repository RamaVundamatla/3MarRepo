    <JadeMethod name="disableCreditNoteContext" id="c9e3469c-8241-49a7-9f1a-c547bc48d62b">
        <source>disableCreditNoteContext();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/11/2023	navkc1 Bug 60895: FR | 54086 - Invoice Maintenance - Changing an Invoice to credit notes

*/

vars
	theTable		: CM_DataTable;
	invoice			: CM_Invoice;
	
begin
	theTable := self.tblData;
	
	foreach invoice in theTable.allSelectedObjects as CM_Invoice where invoice.isCreditNote() do
		self.mnuContextCrteCrdFrmInv.enabled := false;
		self.mnuContextLinkCredit.enabled := false;
		self.mnuContextUnlinkCredit.enabled := false;
		break;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayInvoice" id="f1e584cf-6451-43b1-b09b-39741f594ef4">
        <source>displayInvoice();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//21 Apr 2016		cnwns1	TFS 488 - Multi Timezone Support
//22 July 2019		cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
//18 August 2022	navpw1	TFS: 54564 (54381) - EUP - Inv Config - Debtor Currencies and Countries
//23 August 2022	navpw1	TFS: 54564 (54382) - EUP - Inv Config - Debtor Currencies and Countries
// 01/02/2023		navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
//14/08/2023		navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
//4/12/2023			navra1	TFS 54090 CR - 61386/Task - 61564 - 4th DecNov 2023
vars
	textHeight,
	narrHeight		: Integer;
	packageNames	: String;
	theTable 		: CM_EntryTable;
	theNarrRow 		: Integer;
	today			: Date;
	finIOClass 		: CM_ExtFinanceIO;
	isASPAInterface : Boolean;
begin
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass &lt;&gt; null and finIOClass.isKindOf( CM_ASPAInterface ) then
		isASPAInterface := true;
	endif;
	theTable := self.tblInvProperties;
	theTable.hideRowByName(ETRow_ArrivalTS,false);
	theTable.hideRowByName(ETRow_DepartureTS,false);
	theTable.hideRowByName(ETRow_VoyageDesc,false);
	theTable.hideRowByName(ETRow_Voyage,false);
	
	if isASPAInterface then
		theTable.hideRowByName(ETRow_IsZeroRated,false);
	endif;
	if self.myCurrentInvoice = null then
		return;
	endif;
	
	if self.currentView = null then
		return;
	endif;
	
	theNarrRow := theTable.getRowByName(ETRow_Narration);
	if theNarrRow &gt; 0 then
		theTable.accessCell(theNarrRow,CM_EntryTable.ColumnValue).wordWrap := true;
	endif;
	theTable.defaultRowHeight := 16;

	if self.currentView =  ETView_InvListInvPropUpdate  or 
		self.currentView = ETView_InvListInvPropPost    or 
		self.currentView = ETView_InvListInvPropPending or
		self.currentView = ETView_InvListInvPropPostASPA	then	//22.07.2019 cnwma1 TFS #45577
		theTable.setTableFromCM_Object(self.myCurrentInvoice,null);
		theTable.disableRowByName(ETRow_SequenceNum);
		theTable.setValueByName(ETRow_InvoiceDate, app.cnGetServerTime().Date);												//navra1 - TFS 54090 CR - 61386/Task - 61564 - 21st Dec 2023
		self.txtNarr.text := self.myCurrentInvoice.narration;
		//30 Oct 2019	NDL	TFS 47279 - Don't clobber the existing value.
		//	theTable.setValueByName(ETRow_PurchaseOrderNumber,self.myCurrentInvoice.debtor.purchaseOrderCode);	//22.07.2019 cnwma1 TFS #45577
		
		if self.myCurrentInvoice.debtor.myTermsOfTrade &lt;&gt; null then
			theTable.setValueByName(ETRow_Terms,self.myCurrentInvoice.debtor.myTermsOfTrade.description);	//22.07.2019 cnwma1 TFS #45577
		endif;
	endif;
	
	if self.currentView = ETView_InvListInvPropPending then //22.07.2019 cnwma1 TFS #45577
		self.doCmbDebtorAddressBuild(self.myCurrentInvoice.debtor);
		self.doCmbDebtorAltAddressBuild(self.myCurrentInvoice.debtor); // ### TFS 54564 (54381) 19Aug2022 NAVPW1
	endif;
	
	if self.currentView = ETView_InvListInvPropNew then //22.07.2019 cnwma1 TFS #45577
		theTable.showRowByName(ETRow_DebtorAddress,false);	
		self.doCmbDebtorAddressBuild(null);
		self.doCmbCategoryBuild(); // 01/02/2023	navkc1	TFS CR 55305 TASK 55537
	endif;
	
	if self.currentView = ETView_InvListInvPropUpdate and 
		self.myCurrentInvoice.isPosted		then	//22.07.2019 cnwma1 TFS #45577
		theTable.hideRowByName(ETRow_DebtorAddress,false);	
	endif;
	
	if self.currentView = ETView_InvListInvPropUpdate then
		if self.myCurrentInvoice.invoiceType.accrualType = CM_InvoiceDesc.Accrue_Until_Manually_Closed then
			if self.myCurrentInvoice.isPosted then // ## PAR 10628
				theTable.setValueByName(ETRow_EndDate, self.myCurrentInvoice.toDT.date()); // ## PAR 10628
				theTable.disableRowByName(ETRow_EndDate); // ## PAR 10628
			elseif self.myCurrentInvoice.status = CM_Invoice.INVOICE_PENDING then
				theTable.setValueByName(ETRow_EndDate, self.myCurrentInvoice.toDT.date());
				theTable.enableRowByName(ETRow_EndDate);
							
			else
				theTable.setValueByName(ETRow_EndDate, null); // ## PAR 10628
				theTable.hideRowByName(ETRow_EndDate,false); // ## PAR 10628
			endif;
		else		
			theTable.setValueByName(ETRow_EndDate, self.myCurrentInvoice.toDT.date());
			theTable.enableRowByName(ETRow_EndDate);
		endif;
		
		// ### PAR 34764
		theTable.hideRowByName(ETRow_RunPackage, false);
		theTable.hideRowByName(ETRow_Packages, false);

		if self.myCurrentInvoice.isPosted then
			packageNames:=self.myCurrentInvoice.getDisplayStringForAttribute(ETRow_Packages,false);
			if packageNames &lt;&gt; null then
				theTable.showRowByName(ETRow_RunPackage, false);				
				theTable.showRowByName(ETRow_Packages, false);
				theTable.setValueByName(ETRow_Packages, packageNames);
			endif;		
		endif;	
		
		//22.07.2019 cnwma1 TFS #45577
		if not self.myCurrentInvoice.isPostedOrReversal then
			theTable.showRowByName(ETRow_DebtorAddress,false);	
			self.doCmbDebtorAddressBuild(self.myCurrentInvoice.debtor);
		endif;
		
	elseif self.currentView = ETView_InvListInvPropPost or 
		self.currentView = ETView_InvListInvPropPostASPA	then	//22.07.2019 cnwma1 TFS #45577
		//theTable.setValueByName(ETRow_Terms,null);
		self.doCmbTermsTradeBuild();
		self.doCmbCurrencyType(self.myCurrentInvoice.debtor); // ### TFS 54564 (54382) 22Aug2022 NAVPW1
		if self.myCurrentInvoice.myInvoiceProcess.isInvoiceAPIProcess() then					//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
			if self.myCurrentInvoice.status = CM_Invoice.INVOICE_POSTED_PENDING then			//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
				theTable.setValueByName(ETRow_Export, false);									//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
			else																				//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
				theTable.setValueByName(ETRow_Export, true);									//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
			endif;																				//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
		else
			theTable.setValueByName(ETRow_Export, true);		// 37149 keep the Export option set by default
		endif;																													//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
		packageNames:=self.myCurrentInvoice.getDisplayStringForAttribute(ETRow_Packages,false);	
		if packageNames &lt;&gt; null then
			theTable.setValueByName(ETRow_Packages, packageNames);
		else
			theTable.hideRowByName(ETRow_RunPackage, false);
			theTable.hideRowByName(ETRow_Packages, false);
		endif;
		
		if not self.myCurrentInvoice.toDT.isValid then
			//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
			today := app.actualTimeServer().date();
		
			theTable.setValueByName(ETRow_EndDate, today);
		endif;
		theTable.enableRowByName(ETRow_EndDate);
	endif;	

	if  theNarrRow &gt; 0 then
		// from 35971 set the narrative height more dynamically within reasonable ranges
		textHeight := self.textSearch.getTextHeightForWidth(self.txtNarr.text, self.txtNarr.width.Integer) + 10;
		narrHeight := textHeight;
		if textHeight &lt; 50 then
			narrHeight := 50;			// was fixed at 50
		elseif textHeight &gt; 150 then
			narrHeight := 150;
		endif;
		theTable.accessRow(theNarrRow).height := narrHeight; // PAR 10548 modified 35971
		self.txtNarr.height := narrHeight;		// PAR 10548
	endif;
	
	//14/08/2023	navkc1	Bug 59803
	if not self.isMTNDefaultProcess then
		if not self.currentView = ETView_InvListInvPropPending then
			theTable.hideRowByName(ETRow_AlternativeAddress, false);
			theTable.hideRowByName(ETRow_DebtorAddress, false);
		endif;
		theTable.hideRowByName(ETRow_Locale, false);
		theTable.hideRowByName(ETRow_InvoiceTypeCode, false);
		theTable.hideRowByName(ETRow_CreditNoteStartDate, false);
		theTable.hideRowByName(ETRow_CreditNoteStartTime, false);
		theTable.hideRowByName(ETRow_CreditNoteEndDate, false);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayOverrideExtRef" id="afa4ff4e-91be-463d-8453-598e71eda084">
        <source>displayOverrideExtRef() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	inv 	: CM_Invoice;
	yesNo 	: Boolean;
begin
	if self.tblData.allSelectedObjects.size() = 1 then
		inv := self.myCurrentInvoice;
		
		if inv &lt;&gt; null then
			yesNo := inv.isManViewExtRefAllowedForUser() or inv.isManUpdeExtRefAllowedForUser(); //23/01/2026	navkc1 JIRA MTN 37058
		endif;
	endif;
	
	return yesNo;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayPostTable" id="2d3c5e8f-b1dd-4c27-80b0-1d939f8022e5">
        <source>displayPostTable();
// ---------------------------------------------------------------------------
// Created:		March 2010	cnwjre1
//
// Purpose:		
//	par 23341 multi-select posting, if multiple invoices are selected, set up the table but populate it with just defaults
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 01 Apr 2022	jlier1	TFS 53286
//	14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
vars
	showRunPackage	: Boolean;
	packageNames	: String;
	package			: CM_Package;
	theTable 		: CM_EntryTable;
	obj				: Object;
	invoice			: CM_Invoice;
	dit				: CM_DebtorInvType;
	theNarrRow 		: Integer;
	today			: Date;
	
begin
	theTable := self.tblInvProperties;
	theTable.hideRowByName(ETRow_SequenceNum, false);
	
	if self.currentView = null then
		return;
	endif;
	
	theNarrRow := theTable.getRowByName(ETRow_Narration);
	theTable.defaultRowHeight := 16;

	theTable.accessCell(theNarrRow,CM_EntryTable.ColumnValue).wordWrap := true;
		
	
	if theTable.isRowVisible(ETRow_Export) then
		theTable.setValueByName(ETRow_Export,true);
	endif;
	
	
//	theTable.setValueByName(ETRow_PurchaseOrderNumber,self.myCurrentInvoice.debtor.purchaseOrderCode);	//22.07.2019 cnwma1 TFS #45577	//12 Nov 2019	NDL	TFS 47379 remoed as per Bishs instructions.	
	theTable.setValueByName(ETRow_Terms,null);
	theTable.setValueByName(ETRow_EndDate, today);
	// 28218 CCMS 2120 Sep 2011 show debtor reference and run package
	theTable.setValueByName(ETRow_DebtorReference, self.myCurrentInvoice.debtorReference);
	theTable.enableRowByName(ETRow_EndDate);
	// show the 'run package' checkbox if at least one selected invoice is set up for it
	foreach obj in self.tblData.allSelectedObjects do
		if obj.isKindOf(CM_Invoice) then
			invoice := obj.CM_Invoice;
			dit := invoice.debtor.allDebtorInvTypes[invoice.invoiceType];
			if dit &lt;&gt; null then
				showRunPackage := true;
				foreach package in dit.allPackageInvoices do
					if packageNames = null then
						packageNames := package.code;
					else
						packageNames := packageNames &amp; ", " &amp; package.code;
					endif;
				endforeach;
				break;
			endif;
		endif;
	endforeach;
	if not showRunPackage then
		theTable.hideRowByName(ETRow_RunPackage, false);
		theTable.hideRowByName(ETRow_Packages, false);
	else		
		theTable.setValueByName(ETRow_Packages, packageNames);
	endif;
	theTable.accessRow(theNarrRow).height := 50; // PAR 10548
	self.txtNarr.height := 50;		// PAR 10548

	// disable default button as if press enter form refreshes and cause problems when saving
	self.btnQuery.enabled := false;
	
	//14/08/2023	navkc1	Bug 59803
	if self.isMTNDefaultProcess then
		theTable.showRowByName(ETRow_AlternativeAddress, false);
		theTable.showRowByName(ETRow_Locale, false);
		
		theTable.hideRowByName(ETRow_InvoiceTypeCode, false);
		theTable.hideRowByName(ETRow_CreditNoteStartDate, false);
		theTable.hideRowByName(ETRow_CreditNoteStartTime, false);
		theTable.hideRowByName(ETRow_CreditNoteEndDate, false);
	else
		theTable.hideRowByName(ETRow_AlternativeAddress, false);
		theTable.hideRowByName(ETRow_DebtorAddress, false);
		theTable.hideRowByName(ETRow_Locale, false);
		theTable.hideRowByName(ETRow_InvoiceTypeCode, false);
		theTable.hideRowByName(ETRow_CreditNoteStartDate, false);
		theTable.hideRowByName(ETRow_CreditNoteStartTime, false);
		theTable.hideRowByName(ETRow_CreditNoteEndDate, false);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayRates" id="3a1d83bf-c4d3-4844-a679-3adcaac9c194">
        <source>displayRates();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theInvLines : CM_InvoiceLineBySeqNumDict;
	pd:                     CMS_Progress;
	service:                CM_Service;
	invoiceLineDesc:        CM_InvoiceLineDesc;
	invoiceLine:            CM_InvoiceLine;
	charge:                 CM_Charge;
	keyService:             CM_Service;
	keyOverridden:          Boolean;
	keyRate:                Real;
	prevKeyService:         CM_Service;
	prevKeyOverridden:      Boolean;
	prevKeyRate:            Real;
	chargeCount:            Integer;
	i:                      Integer;
	chargeIterator : Iterator;
	theTable : Table;
begin
	theTable := self.tblRatesOR;
	create theInvLines transient;
	
	self.getInvoiceLines(theInvLines);
		
	create pd;
	pd.show;
	pd.raiseExceptionOnAbort := false;
	pd.setAction("Extracting charges from invoice lines...");
	pd.progress.partsInJob := theInvLines.size;

	self.allORCharges.clear;
	i := 0;
	foreach invoiceLine in theInvLines do
		if invoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED and
			//invoiceLine.invoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED then
			not invoiceLine.invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759
			invoiceLine.charges.copy(self.allORCharges);
		endif;
		i := i + 1;
		pd.progress.partsDone := i;
// ### TFS BUG 62926 13MAR2024 NAVAB1		pd.doWindowEvents(0);
		if pd.aborted then
			return;
		endif;
	endforeach;

	pd.setAction("Grouping service rates...");
	pd.progress.partsInJob := self.allORCharges.size;

	chargeIterator := self.allORCharges.createIterator;

	i := 0;
	while chargeIterator.next(charge) do
		self.allORCharges.getIteratorKeys(keyService, keyRate, keyOverridden, chargeIterator);
		if keyService = prevKeyService and
			keyRate = prevKeyRate and
			keyOverridden = prevKeyOverridden then
			chargeCount := chargeCount + 1;
		else
			if chargeCount &gt; 0 then
				self.addServiceRateToTable(prevKeyService, prevKeyRate, prevKeyOverridden, chargeCount);
			endif;
			prevKeyService := keyService;
			prevKeyRate := keyRate;
			prevKeyOverridden := keyOverridden;
			chargeCount := 1;
		endif;
		i := i + 1;
		pd.progress.partsDone := i;
// ### TFS BUG 62926 13MAR2024 NAVAB1		pd.doWindowEvents(0);
		if pd.aborted then
			return;
		endif;
	endwhile;

	if chargeCount &gt; 0 then
		addServiceRateToTable(prevKeyService, prevKeyRate, prevKeyOverridden, chargeCount);
	endif;

	theTable.sortColumn[1] := 3;
	theTable.sortColumn[2] := 1;
	theTable.resort;

	theTable.sortColumn[1] := 0;
	theTable.sortColumn[2] := 0;
	theTable.sortColumn[3] := 0;

	// ### PAR 10544 set a default selected line
	if theTable.rows &gt; theTable.fixedRows then
		theTable.row := 2;
		theTable.accessRow(2).selected := true;
	endif;

epilog
	delete pd;
	delete theInvLines;
	delete chargeIterator;
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="6966b9cd-a5db-4bc4-ab20-f57434f34f65">
        <updating/>
        <source>displaySelectorResults(_resultCollection : Collection; _mode : Integer) updating;
/*

Date				Who		Reason
13 December 2022   navmv20  TFS CR 55301 Task 55554: UI - Invoice List changes for Selector
06.10.25			Navcs2	MTN-36185	MTN | Invoice Form displaying empty rows when rows are added from Selector form

*/
vars
	tbl					: CM_DataTable;			// 06.10.25	Navcs2	MTN-36185
	selectedRow			: Integer;				// 06.10.25	Navcs2	MTN-36185
	itemsToShow			: Integer;				// 06.10.25	Navcs2	MTN-36185
begin
	/*
		This method was rewritten to allow the user to send data from the selector to the table. 
		// 06.10.25	Navcs2	MTN-36185  Start
	*/
	on CM_ProgressException do haltProgress(exception);
	self.mousePointer := Window.MousePointer_HourGlass;
	self.myCurrentInvoice := null;
	self.tblInfo.rows := 0;			
    self.allInvoices.clear();
	_resultCollection.copy(self.allInvoices);
	tbl := self.tblData;
	
	tbl.CM_DataTable.clearAllData();

	selectedRow := 0;
	
	itemsToShow := self.allInvoices.size;
	
	if not tbl.isPaginated and not self.doMaxTableSizeCheck(itemsToShow, null) then		
		return;
	endif;
	
	tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, self.allInvoices,true);
	self.frmQuery.visible := (tbl.rows = tbl.fixedRows);
 
	// set up the info table from the new entries
	if tbl.rows &gt; tbl.fixedRows then
		tbl.selectRow(2,false);
		tbl.row := 2;
		self.doTblDataRowColChange(tbl);
	endif;
	/*
		// 06.10.25	Navcs2	MTN-36185  End
	*/
 
	// Code was removed and replaced with the above for 06.10.25	Navcs2	MTN-36185
	// Use method history to see what was removed. 
epilog
	self.setMyCaption();
	self.showSelectedCount(self.tblData.allSelectedObjects.size, self.tblData.rows-self.tblData.fixedRows);
	//delete pd;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
