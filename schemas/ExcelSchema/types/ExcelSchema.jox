    <JadeMethod name="showForm" id="f2ff9040-6816-4a9e-bfd6-ce793bbea71c">
        <source>showForm (cls: Class): Form;

vars
	frm : Form;
begin
	frm := app.getForm(cls.getName);
	if frm = null then
	//	if app.viewsEnabled then
			//frm := app.parentForm.vLoadForm(cls,false,true,null,true);
	//		frm := app.myViewManager.vLoadForm(frm, cls, false, true, null, true);
	//	else
			create frm as cls;
			frm.show;
	//	endif;
	else
		if frm.windowState = Form.WindowState_Minimized	then
			frm.windowState := Form.WindowState_Normal;
		endif;
		frm.setFocus;
//		app.statusBusy(frm, false);
	endif;
	return frm;
end;</source>
        <Parameter name="cls" type="Class"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="statusBusy" id="ad3911ed-ca38-4595-a14e-f7c2b704a76b">
        <source>statusBusy(blnBusy:Boolean);

/*****************************************************
	Written by	:	cnwgrp1		26 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if blnBusy then
		app.mousePointer	:=	Form.MousePointer_HourGlass;
	else
		app.mousePointer	:=	Form.MousePointer_Default;
	endif;

epilog

end;</source>
        <Parameter name="blnBusy" type="Boolean"/>
    </JadeMethod>
</Class>
