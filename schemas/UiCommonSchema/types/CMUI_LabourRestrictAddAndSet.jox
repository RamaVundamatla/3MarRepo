<GUIClass name="CMUI_LabourRestrictAddAndSet" id="c763ea71-794a-49e0-9f8c-60634ae867dd">
    <superclass name="CMUI_LabourRestrictionsModal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myYardControllersArray" id="a6f8414d-332c-4f33-a6da-751a04541275">
        <memberTypeInverse/>
        <type name="CM_LCArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtSubAreaName" id="5e8cf4e2-df52-4f59-a6d8-5407aa1daa10">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="doBaseFormSave" id="f214d60f-d421-46a1-868b-584a2a62c99c">
        <updating/>
        <source>doBaseFormSave() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars
	realLabRestrict,
	pxyLabRestrict		: CM_LabourRestriction;
	intHours			: Time;
	intDays,
	colour 				: Integer;
	reason				: CM_LabourRestrictionReasonCode;
	comment,
	userCode,
	orgname				: String;
	termArea			: CM_TerminalArea;
//	email				: CM_EmailEntity;
	labRestID			: String;
	ignoreLights		: Boolean;
	organisation		: CM_Organisation;
	result				: Integer;
	newSubAreaName : String;
	msg : String;
	pxyTermSubArea : CM_TerminalSubArea;
	theLocations : CM_YardControllerSet ;
	emails : CM_EmailAddressByAddressDict;
	
begin

	termArea := self.myTerminalArea;

	newSubAreaName	:= self.txtSubAreaName.text.trimBlanks;
	if newSubAreaName = null then
		msg := "Must Enter a name for the new Terminal Sub Area";
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only );
		txtSubAreaName.setFocus();
		return;
	endif;
	
	if termArea.allSubAreas.getAtKey(newSubAreaName) &lt;&gt; null then
		msg := "Terminal Sub Area name already exists!";
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only );
		txtSubAreaName.setFocus();
		return;
	endif;
	
	intDays			:=	self.txtDays.text.Integer;
	intHours		:=	self.txtHrs.getTime();
	comment			:=	self.txtComment.text;
	reason			:=	self.cmbReason.myObject.CM_LabourRestrictionReasonCode;
	organisation	:=	self.cmbOrganisation.myObject.CM_Organisation;
//	email			:=	self.cmbNotify.myObject.CM_EmailEntity;
	userCode		:=	app.myPassport.myUser.code;
	ignoreLights	:=	false;
	
	create emails transient;
	self.mulNotifyEmails.getSelected(emails);
	
	if organisation &lt;&gt; null then 
		orgname	:= ' - ' &amp; organisation.name;
	endif;
	
	create pxyLabRestrict transient;
	create pxyTermSubArea transient;		
	create theLocations transient;
	
	self.myYardControllersArray.copy(theLocations);
	
	pxyTermSubArea.setProxy(newSubAreaName,	//_description : String;
							null,	//_colour : Integer;
							termArea,	//_terminalArea : CM_TerminalArea; 
							theLocations	//_yardControllers : CM_YardControllerSet
							);
		
	labRestID := pxyTermSubArea.id &amp; orgname;
	colour := pxyTermSubArea.colour;
	
	if self.isIgnoreLightsUsed then
		ignoreLights	:=	chkIgnoreLights.value;
	endif;

	pxyLabRestrict.setProxy(colour,
							userCode,
							comment,
							intHours,
							intDays,
							reason,
							self.myYardControllersArray,
							labRestID,
							ignoreLights,
							organisation,
							null,
							emails,
							termArea);
			
	while true do
		
		app.myTrxCA.trxCreateSubAreaAndRestLabour(pxyTermSubArea, pxyLabRestrict, realLabRestrict, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog("Labour Restrictions - "&amp; labRestID, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors() and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		
		break;
	endwhile;
	
	self.unloadForm();
	
epilog

	delete pxyLabRestrict;
	delete theLocations;
	delete pxyTermSubArea;
	delete emails;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFormForNewLocationSet" id="6593bb57-ef40-4000-98ce-cd76e727a3f6">
        <source>setFormForNewLocationSet( _locs : CM_LCSet );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	tmpSort : CM_GridControllersByRowColumn;

begin

	if not _locs.isEmpty and _locs.first.isKindOf( CM_RoRoController ) then	//22 Mar 2016	NDL	TFS 1698
		_locs.copy( self.myYardControllersArray );
			
	else
		create tmpSort transient;
		_locs.copy(tmpSort);
		tmpSort.copy( self.myYardControllersArray );
	
	endif;

epilog

	delete tmpSort;

end;</source>
        <Parameter name="_locs" type="CM_LCSet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="45100909-be95-4119-bacf-bf24194c366b">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

begin
	inheritMethod();
	
	self.lstBxSubArea.visible := false;
	self.txtSubAreaName.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a2d53065-7d73-40a9-8872-3095e253aa51">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018783, locale);
end;</source>
    </JadeMethod>
</GUIClass>
