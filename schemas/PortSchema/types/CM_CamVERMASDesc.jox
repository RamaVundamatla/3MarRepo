    <JadeMethod name="getSenderCode_UNB" id="bc712dae-fb66-4b08-ad90-2cefc9fe35f2">
        <source>getSenderCode_UNB(_protocol :CM_CamProtocol):String protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
vars
	code : String;
	fCode :String;
	terminal :CM_Terminal;
begin
	code := _protocol.camGroup.senderCode.trimBlanks;
	terminal := _protocol.terminal;
	
	// 09/03/2012 cnwar2 #29175
	if code = null then
		code := _protocol.camISOPortDesc.trimBlanks;
	endif;
	
	if code = null then
		code := terminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	
	fCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal).trimRight;
	
	return fCode;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includeTransaction" id="6f22ddf7-61b3-4679-a822-3f93a0f340d4">
        <source>includeTransaction(_transaction: CM_TITransaction; _camsTS: TimeStamp; _startTS: TimeStamp; _endTS: TimeStamp; _camProtocol: CM_CamProtocol; _camGroup: CM_CamGroup; _camAgent: CM_CamControllerAgent; _logExcluded: Boolean; _event : CM_EventTransaction): Boolean;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//09/05/2016    cnwma1	TFS 1964 CPL - Missing EDI CAMS Report transaction line on VERMAS messages
//12/03/2020	jlgdap1	TFS 48785 SNO COARRI Issue - new parameter for CM_CamProtocolDesc includeTransaction
//
vars
	
begin
		
	//epr TFS 2395 21/7/16
	if not _transaction.myTrackedItem.isWeightCertified then
		_camAgent.logReasonForExclusion(_transaction, 'Cargo Item weight has not been certified.');
		return false;
	endif;	
	
	//epr TFS 2395edit settings handled by inherited method
	if not inheritMethod(_transaction, _camsTS, _startTS, _endTS, _camProtocol, _camGroup, _camAgent, _logExcluded, _event) then	// TFS 48785
		return false;
	endif;
			
	return true;
	
	/*
	if theTi.isWeightCertified then
		if (_transaction.isKindOf(CM_Edit) and
			self.checkEditTransaction(_transaction)) or
			not _transaction.isKindOf(CM_Edit) then					//09/05/2016 cnwma1 TFS #1964
			return inheritMethod(_transaction, _camsTS, _startTS, _endTS, _camProtocol, _camGroup, _camAgent, _logExcluded);
		endif;
	endif;
	//endif;
	if _logExcluded then
		_camAgent.logReasonForExclusion(_transaction, 'Cargo Item weight has not been certified.');
	endif;
	return false;*/
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camsTS" type="TimeStamp"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_logExcluded" type="Boolean"/>
        <Parameter name="_event" type="CM_EventTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeVoyage" id="695b4524-44fd-4900-be66-f06aafcca375">
        <source>includeVoyage(_camProtocol: CM_CamProtocol; _voyage: CM_Voyage; _trx: CM_Transaction; _camAgent: CM_CamControllerAgent; _logExcluded: Boolean): Boolean protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
vars
	result	:Boolean;
begin
	result := _voyage.isCellularVoyage or (_camProtocol.prcNullVoyageTransaction and _voyage.isNullVoyage);
	
	if not result and 
	   _logExcluded then
		_camAgent.logReasonForExclusion(_trx, 'Voyage ' &amp; _voyage.code &amp; ' is not cellular or (if process null voyage option set) null voyage');
	endif;
	
	return result;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_logExcluded" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
