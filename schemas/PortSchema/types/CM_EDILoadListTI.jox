    <JadeMethod name="getCarbonDioxide" id="e92aa094-a4d7-4368-9f6d-7f6b60a5f33e">
        <source>getCarbonDioxide():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Carbon Dioxide display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.carbonDioxide &gt; 999.99 then
		return 999.99;
	endif;

	return self.carbonDioxide;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
