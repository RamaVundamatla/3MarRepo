        <Parameter name="_pict" type="HMS_GraphicalDragPicture"/>
    </JadeMethod>
    <JadeMethod name="drawWharfLegend" id="847601c3-063f-4d41-af6d-0e1495896271">
        <updating/>
        <source>drawWharfLegend()updating, protected;
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
vars
	thisColour,
	berthColour,
	wharfColour,
	txtExtent,
	overhangEnd,
	overhangStart	: Integer;
	mtrPerPix,
	startPos,
	endPos,
	y2,
	y1,
	tmpHeight,	
	tmpWidth		: Real;
	bstr			: String;
	firstTime,
	leftToRight		: Boolean;
	tmpBerth		: HMS_Berth;
	tmpWharf		: HMS_Wharf;
	tmpLabelFrm 	: CMUI_ScrollableLabelsFrame;
	tmpBerthDict 	: HMS_BerthByPosnAndCodeDict;
	tmpBerths		: HMS_BerthByLeftPosDict;
	tmpScrollingFrm : HMS_ScrollingWharfFrame;		
begin

	tmpBerths			:= self.allBerthByLeftPos;
	tmpLabelFrm			:= self.myScrollableLabelFrame;
	tmpWidth 			:= tmpLabelFrm.width;
	y2 					:= tmpLabelFrm.height;	
	y1 					:= y2-15;
	tmpScrollingFrm		:= self.myScrollingFrame;	
	tmpHeight			:= tmpScrollingFrm.height;
	mtrPerPix 			:= self.metersPerPixel;
	tmpWharf 			:= self.myWharf;
	tmpBerthDict 		:= tmpWharf.allBerthsByStartPosnAndName;	
	overhangStart 		:= tmpWharf.overhangZeroMetreEnd;
	overhangEnd 		:= tmpWharf.overhangMaxMetreEnd;
	wharfColour 		:= tmpWharf.colour;
	leftToRight			:= tmpWharf.displayLeftToRight;
	firstTime			:= (not leftToRight);
		
	//Draw rectangle along length of label, visible white area represents overhangs
	tmpLabelFrm.drawFillColor := White;
	tmpLabelFrm.drawFilledRectangle(0, y1, tmpWidth, y2, White);

	if wharfColour = 0 then
		wharfColour := Gray;
	endif;
	
	//Draw wharf area along scale
	tmpLabelFrm.drawFillColor := wharfColour;

	if leftToRight then
		startPos := overhangStart/mtrPerPix;
		endPos := tmpWharf.length/mtrPerPix;
	else
		startPos := overhangEnd/mtrPerPix;
		endPos := (tmpWharf.length-overhangStart)/mtrPerPix;
	endif;
	tmpLabelFrm.drawFilledRectangle(startPos, y1, endPos, y2, wharfColour);		
	tmpScrollingFrm.drawLine(startPos, 0, startPos, tmpHeight, Berth_Colour_Line);			
	
	//Clear external key dict
	tmpBerths.clear();
	
	foreach tmpBerth in tmpBerthDict do
		bstr 		:= tmpBerth.code;
		berthColour := tmpBerth.colour;			

		// Alternate the berth colour if no system defined colour
		if berthColour = 0 then
			if thisColour = self.Berth_Colour_1 then
				thisColour := self.Berth_Colour_2;
			else
				thisColour := self.Berth_Colour_1;
			endif;
			berthColour := thisColour;
		endif;

		// Draw berth area along wharf scale
		tmpLabelFrm.drawFillColor := berthColour;
		if leftToRight then
			startPos := (overhangStart + tmpBerth.startPosition)/mtrPerPix;
			endPos := startPos + ((tmpBerth.length)/mtrPerPix).rounded;
		else
			endPos := tmpWidth - (overhangStart + tmpBerth.startPosition)/mtrPerPix;
			startPos := endPos - (tmpBerth.length/mtrPerPix);
		endif;				
		tmpLabelFrm.drawFilledRectangle(startPos, y1, endPos, y2, berthColour);
		tmpBerths.putAtKey(startPos, tmpBerth);									

		// Label berth area
		txtExtent := tmpLabelFrm.getTextExtent(bstr);
		if txtExtent &gt; endPos-startPos then
			bstr := bstr[1:2];
		endif;
		tmpLabelFrm.drawTextAt(bstr, ((endPos-startPos)/2)+startPos, y1, berthColour.getInverseColour());		

		// Draw vertical lines up main blue area representing start and end limits for berths/overhangs
		tmpScrollingFrm.drawLine(startPos, 0, startPos, tmpHeight, Berth_Colour_Line);
		if firstTime then
			tmpScrollingFrm.drawLine(endPos, 0, endPos, tmpHeight, Berth_Colour_Line);
			firstTime := false;	
		endif;		
	endforeach;

	// Draw vertical lines up main blue area representing start and end limits for berths/overhangs	
	if leftToRight then
		tmpScrollingFrm.drawLine(endPos, 0, endPos, tmpHeight, Berth_Colour_Line);	
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawWharfLockouts" id="c04ee16e-f65f-43d3-9862-653547db33ec">
        <updating/>
        <source>drawWharfLockouts() updating, protected;
//--------------------------------------------------
// Created:	01 March 2005 By: cnwgd1
//--------------------------------------------------
vars
	minsPerPix,
	xWidth,
	xLeft,
	yTop,
	yHeight : Real;
	saveStyle,
	saveColour : Integer;	
	lockout : HMS_WharfLockout;
	tmpFrame : HMS_ScrollingWharfFrame;
	tmpWharf : HMS_Wharf;
	tmpVStartDT,
	tmpVEndDT,	
	tmpLStartDT,
	tmpLEndDT : TimeStamp;
	gViewX : HMS_GraphicalViewX;
begin
	tmpFrame := self.myScrollingFrame;
	tmpWharf := self.myWharf;
	gViewX := self.myGraphicalViewForm;
	minsPerPix := gViewX.minutesPerPixel;
	tmpVEndDT := gViewX.myViewController.viewFinishDT;
	tmpVStartDT := gViewX.myViewController.viewStartDT;

	saveColour := tmpFrame.drawFillColor;
	saveStyle := tmpFrame.drawFillStyle;
	tmpFrame.drawFillColor := Black;
	tmpFrame.drawFillStyle := tmpFrame.DrawFillStyle_DiagonalCross;									

	foreach lockout in tmpWharf.allWLockoutsByBothDT do
		
		tmpLStartDT := lockout.startOfLockoutDT;
		tmpLEndDT := lockout.endOfLockoutDT;
		
		if (not tmpLEndDT.isValid())
		or (not tmpLStartDT.isValid())
		or tmpLStartDT &gt; tmpVEndDT		
		or tmpLEndDT &lt; tmpVStartDT then
			continue;
		endif;
		
		if tmpLStartDT &lt; tmpVStartDT then
			tmpLStartDT := tmpVStartDT;
		endif;

		if tmpLEndDT &gt; tmpVEndDT then
			tmpLEndDT := tmpVEndDT;
		endif;		
		
		yHeight := (tmpLStartDT.minutesDiff(tmpLEndDT)) / minsPerPix;
		yTop := (tmpLStartDT.minutesDiff(tmpVEndDT) / minsPerPix);
		yHeight := yTop-yHeight;
		if yHeight &gt; tmpFrame.height then
			yHeight := tmpFrame.height;
		endif;				
		
		if tmpWharf.displayLeftToRight then
			xLeft := ((lockout.startMarkOnWharf + tmpWharf.overhangZeroMetreEnd)/self.metersPerPixel);
		else
			xLeft := ((tmpWharf.length + tmpWharf.overhangMaxMetreEnd - lockout.endMarkOnWharf)/self.metersPerPixel);
		endif;
		xWidth := xLeft + ((lockout.endMarkOnWharf-lockout.startMarkOnWharf)/self.metersPerPixel);

		tmpFrame.drawFilledRectangle(xLeft, yTop, xWidth, yHeight, Red);
	endforeach;

	tmpFrame.drawFillColor := saveColour;
	tmpFrame.drawFillStyle := saveStyle;								
			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawWharfResourceIcons" id="d03cdbaa-6c37-4f52-ba8c-41b073e1555f">
        <updating/>
        <source>drawWharfResourceIcons() updating, protected;
//--------------------------------------------------
// Created:	05 May 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------------
// 14/11/2012	cnwdap1		PAR #30741 CCMS QNS 2232 Include Resource Labels on Harbour View
// 15/09/2023	navdap1		TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
vars
	picStart,
	picStop		: CMUI_Picture;
	lastType,
	resType	   	: HMS_ResourceType;
	res 	 	: HMS_Resource;
	offset,
	iconTop,
	iconTop3,
	iconTop2,
	iconTop1,
	lblWidth,
	iconHeight,
	iconWidth	: Real;
	mPerPixel	: Real;
	first,
	startOK,
	stopOK		: Boolean;
	str			: String;
	startPos,endPos		: Real;
	dispLeftToRight	: Boolean;
	tmpCurrentIndex,
	wharfOverhang	: Integer;
	tmpDict : HMS_ResourceByTypeDict;
	label, lastLabel : CMUI_Label;				// PAR #30741
	textExtent, pos : Integer;					// PAR #30741
	obj : Object;								// PAR #30741
	lastLabelRight, labelRight : Real;			// PAR #30741
	pic : CMUI_Picture;							// PAR #30741
begin

	// this method builds the resource icons that appear at the bottom of the water area - giving a representation
	// of the physical location of various resources along the wharf
	self.allResourceIcons.purge;
	mPerPixel := self.metersPerPixel;
	iconHeight := self.myResourceIcon.height;
	iconWidth := self.myResourceIcon.width + 2;
	lblWidth := self.myScrollableLabelFrame.width;
	offset := (iconWidth/2);
	iconTop1 := 22;
	iconTop2 := iconTop1 + iconHeight;
	iconTop3 := iconTop2 + iconHeight;
	iconTop := iconTop1;
	first := true;
	dispLeftToRight := self.myWharf.displayLeftToRight;
	wharfOverhang := self.myWharf.overhangZeroMetreEnd;
	
	create tmpDict transient;
	self.myWharf.allResources.copy(tmpDict);

	foreach res in tmpDict discreteLock do
		resType := res.myResourceType;
		if (not resType.iconVisibleOnView) 
		or (res.isNotAvailableForEntry) then // CCMS 1350
			continue;
		endif;
		
		if first then
			lastType := resType;
			first := false;
		elseif lastType.code &lt;&gt; resType.code then
			if iconTop = iconTop1 then
				iconTop := iconTop2;
			elseif iconTop = iconTop2 then
				iconTop := iconTop3;
			else
				iconTop := iconTop1;
			endif;
		endif;
		
		startOK := false;
		stopOK	:= false;
		startPos := 0;
		endPos := 0; 

		if dispLeftToRight then
			startPos := ((wharfOverhang + res.startPosnAlongWharf)/mPerPixel)-offset;
			endPos := ((wharfOverhang + res.endPosnAlongWharf)/mPerPixel)-offset;
		else
			startPos := lblWidth - ((wharfOverhang + res.startPosnAlongWharf)/mPerPixel);//-offset;
			if res.endPosnAlongWharf &lt;&gt; res.startPosnAlongWharf
			and res.endPosnAlongWharf &lt;&gt; 0 then
				endPos := startPos-offset;
				startPos := endPos - ((res.endPosnAlongWharf - res.startPosnAlongWharf)/mPerPixel);//-offset;
			else
				startPos := startPos-offset;			
			endif;
		endif;					
		// the resource occurs within the selected view window, 
		// or part of its range is within the view window
		if startPos &lt;&gt; 0 then
			tmpCurrentIndex := tmpCurrentIndex + 1;
			picStart := self.myResourceIcon.loadControl(tmpCurrentIndex).CMUI_Picture;
			self.allResourceIcons.add(picStart);
			picStart.picture := resType.iconUpState;
			picStart.userObject := resType;
			picStart.move(startPos, iconTop, iconWidth, iconHeight);
			if res.startPosnAlongWharf &lt;&gt; res.endPosnAlongWharf then 
				str := resType.description &amp; ': ' &amp; res.description &amp; ' range ' &amp; res.startPosnAlongWharf.String &amp; ' - ' &amp; res.endPosnAlongWharf.String;
			else
				str := resType.description &amp; ': ' &amp; res.description &amp; ' position ' &amp; res.startPosnAlongWharf.String;
			endif;
			picStart.bubbleHelp := str;
			picStart.visible 	:= true;
			startOK := true;
			// PAR #30741 draw the resource code on top of the icon if we need to,
			// and if the start position = the end position
			if resType.displayCodeOnView and (endPos = 0 or endPos = startPos) then
				// draw a label with the resource code as the caption, and position the label over the icon
				tmpCurrentIndex := tmpCurrentIndex + 1;
				label := self.myTimeNowLine.loadControl(tmpCurrentIndex).CMUI_Label;
				self.allResourceIcons.add(label);
				label.parent := picStart.parent;
				if resType.iconDownState &lt;&gt; null then
					picStart.picture := resType.iconDownState;
					// we've changed the icon picture - remember the picture and resoruce type so
					// we can put the icon back again if we clear the label
					label.tag := picStart.getOidString &amp; "_" &amp; resType.getOidString;
				endif;
				label.transparent := true;
				label.caption := res.code;
				label.bubbleHelp := picStart.bubbleHelp;
				label.alignment := label.Alignment_Center_Middle;
				label.fontSize := 8;
				label.foreColor := Black;
				label.fontBold := true;			// TFS 59472
				label.stretchWidth := false;
				label.move(picStart.left-1, picStart.top, 20, 20);
			endif;
			// PAR #30741 end
		endif;
		if endPos &lt;&gt; 0 and endPos &lt;&gt; startPos then
			tmpCurrentIndex := tmpCurrentIndex + 1;
			picStop := self.myResourceIcon.loadControl(tmpCurrentIndex).CMUI_Picture;
			self.allResourceIcons.add(picStop);			
			picStop.picture := resType.iconUpState;//iconLocation;
			picStop.userObject := resType;
			picStop.move(endPos, iconTop, iconWidth, iconHeight);
			if res.startPosnAlongWharf &lt;&gt; res.endPosnAlongWharf then 
				str := resType.description &amp; ': ' &amp; res.description &amp; ' range ' &amp; res.startPosnAlongWharf.String &amp; ' - ' &amp; res.endPosnAlongWharf.String;
			else
				str := resType.description &amp; ': ' &amp; res.description &amp; ' position ' &amp; res.endPosnAlongWharf.String;
			endif;
			picStop.bubbleHelp := str;
			picStop.visible 	:= true;
			stopOK := true; 
		endif;

		// draw the seperating lines that indicate the range that a resource moves over (eg a crane may be on tracks
		// that allow it to move over a 100 meter range)
		if startPos &lt;&gt; 0 and endPos &lt;&gt; 0 then
			if startOK and stopOK then
				// PAR #30741 place a label on the midpoint of the separating line with the resource's code as its caption
				// if we need to, and if it fits
				if resType.displayCodeOnView then
					tmpCurrentIndex := tmpCurrentIndex + 1;
					label := self.myTimeNowLine.loadControl(tmpCurrentIndex).CMUI_Label;
					self.allResourceIcons.add(label);
					label.caption := res.code;
					label.fontBold := true;			// TFS 59472
					textExtent := self.getTextExtent(label.caption);
					if textExtent &lt; endPos - startPos - iconWidth then
						// we have enough space to show the code
						label.bubbleHelp := str;
						label.parent := self.myScrollableLabelFrame;
						label.transparent := true;
						label.alignment := label.Alignment_Center_Middle;
						label.fontSize := 8;
						label.foreColor := Black;
						label.stretchWidth := false;
						label.move(startPos + ((endPos-startPos-textExtent)/2) + (iconWidth/2), picStart.top+1, textExtent, 15);
						self.myScrollableLabelFrame.drawLine(picStart.left + iconWidth, picStart.top + iconHeight/2, label.left - 1, picStart.top + iconHeight/2, Black);
						self.myScrollableLabelFrame.drawLine(label.left + label.width + 1, picStart.top + iconHeight/2, picStop.left, picStart.top + iconHeight/2, Black);
					else
						self.myScrollableLabelFrame.drawLine(picStart.left + iconWidth, picStart.top + iconHeight/2, picStop.left, picStart.top + iconHeight/2, Black);
					endif;
					// PAR #30741 end
				else
					self.myScrollableLabelFrame.drawLine(picStart.left + iconWidth, picStart.top + iconHeight/2, picStop.left, picStart.top + iconHeight/2, Black);
				endif;
			endif;  
		endif;

		lastType := resType;		
	endforeach;
	
	// PAR #30741 Double-check: clear the caption on any label that overlaps another label
	foreach obj in self.allResourceIcons where obj.isKindOf(CMUI_Label) do
		label := obj.CMUI_Label;
		if lastLabel &lt;&gt; null then
			lastLabelRight := lastLabel.left + lastLabel.width - 3;
			labelRight := label.left + label.width - 3;
			if lastLabel.top = label.top and ((lastLabelRight &gt; label.left and lastLabelRight &lt; labelRight) or (labelRight &gt; lastLabel.left and labelRight &lt; lastLabelRight)) then
				label.caption := null;
				lastLabel.caption := null;
				if label.tag &lt;&gt; null then
					pos := 1;
					pic := label.tag.scanUntil("_", pos).asOid.CMUI_Picture;
					resType := label.tag[pos+1:end].asOid.HMS_ResourceType;
					pic.picture := resType.iconUpState;
				endif;
				if lastLabel.tag &lt;&gt; null then
					pos := 1;
					pic := lastLabel.tag.scanUntil("_", pos).asOid.CMUI_Picture;
					resType := lastLabel.tag[pos+1:end].asOid.HMS_ResourceType;
					pic.picture := resType.iconUpState;
				endif;
			endif;
		endif;
		lastLabel := label;
	endforeach;
	// PAR #30741 end

epilog
	delete tmpDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawWharfScaleLeftToRight" id="f063fbe7-974f-44f5-aba7-c3f250f529a5">
        <updating/>
        <source>drawWharfScaleLeftToRight()updating, protected;
//-----------------------------------------
// Created: August 2004 By: cnwgd1
//-----------------------------------------
vars
	mmTop,
	mtrPerPix 				: Real;
	wharfPos,
	scale,
	pos,
	int,
	tmpLblWidth,
	tmpWharfLength,
	overhangZeroMetreEnd 	: Integer;
	firstTime 				: Boolean;
	tmpWharf				: HMS_Wharf;
	tmpLabelFrm 			: CMUI_ScrollableLabelsFrame;
	
begin
	//	draw ruler marks along the wharf control
	tmpWharf	:= self.myWharf;
	tmpLabelFrm := self.myScrollableLabelFrame;
	tmpLblWidth := tmpLabelFrm.width.Integer;
	mmTop 		:= 12;
	mtrPerPix 	:= self.metersPerPixel;
	scale 		:= 1;
	firstTime 	:= true;
	overhangZeroMetreEnd := (tmpWharf.overhangZeroMetreEnd / mtrPerPix).rounded();
	tmpWharfLength := tmpWharf.length;
	pos			:= -overhangZeroMetreEnd;
	wharfPos 	:= (pos * mtrPerPix).rounded();

	while true do
		if int &gt; tmpLblWidth then
			break;
		endif;
		
		if (pos mod 50 = 0) or (pos = 0) then
			tmpLabelFrm.drawLine(int, 0, int, 12, Black);
			
			if firstTime then
				if wharfPos &lt; 0 then
					tmpLabelFrm.drawTextAt(wharfPos.String[2:end], int, mmTop, Red);
				else
					tmpLabelFrm.drawTextAt(wharfPos.String, int, mmTop, Red);
				endif;
				
			elseif wharfPos &gt; tmpWharfLength then
				tmpLabelFrm.drawTextAt(wharfPos.String, int, mmTop, Red);
			else
				tmpLabelFrm.drawTextAt(wharfPos.String, int, mmTop, Black);
			endif;
			
		elseif pos mod 25 = 0 then
			tmpLabelFrm.drawLine(int, 0, int, 9, Black);			
		elseif pos mod 10 = 0 then
			tmpLabelFrm.drawLine(int, 0, int, 6, Black);
		elseif pos mod 5 = 0 then
			tmpLabelFrm.drawLine(int, 0, int, 3, Black);
		endif;
		
		pos := pos + scale;
		int := int + scale;
		
		if firstTime then
			if int &gt;= overhangZeroMetreEnd then
				pos := 0;
				firstTime := false;
			endif;
		endif;
		
		wharfPos := (pos * mtrPerPix).rounded();
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawWharfScaleRightToLeft" id="49d3b1f5-822a-4479-bc75-b8c4a84edcc9">
        <updating/>
        <source>drawWharfScaleRightToLeft()updating, protected;
//-----------------------------------------
// Created: August 2004 By: cnwgd1
//-----------------------------------------
vars
	mmTop,
	mtrPerPix 		: Real;
	wharfPos,
	scale,
	pos,
	int,
	tmpLblWidth,
	tmpWharfLength,
	overhang		: Integer;
	firstTime 		: Boolean;
	tmpWharf		: HMS_Wharf;
	tmpLabelFrm 	: CMUI_ScrollableLabelsFrame;
	
begin
	//	draw ruler marks along the wharf control
	tmpWharf	:= self.myWharf;
	tmpLabelFrm := self.myScrollableLabelFrame;
	tmpLblWidth := tmpLabelFrm.width.Integer;
	mtrPerPix 	:= self.metersPerPixel;
	mmTop 		:= 12;
	scale 		:= 1;
	firstTime 	:= true;
	overhang	:= (tmpWharf.overhangZeroMetreEnd/mtrPerPix).rounded();
	tmpWharfLength := tmpWharf.length;
	wharfPos 	:= (pos * mtrPerPix).rounded();
	int 		:= tmpLblWidth;
	
	while true do
		if int &lt; 1 then
			break;
		endif;
		
		if (pos mod 50 = 0) or (pos = 0) then
			tmpLabelFrm.drawLine(int, 0, int, 12, Black);
			
			if firstTime then
				if wharfPos &lt; 0 then
					tmpLabelFrm.drawTextAt(wharfPos.String[2:end], int, mmTop, Red);
				else
					tmpLabelFrm.drawTextAt(wharfPos.String, int, mmTop, Red);
				endif;
				
			elseif wharfPos &gt; tmpWharfLength then
				tmpLabelFrm.drawTextAt(wharfPos.String, int, mmTop, Red);
			else
				tmpLabelFrm.drawTextAt(wharfPos.String, int, mmTop, Black);
			endif;
			
		elseif pos mod 25 = 0 then
			tmpLabelFrm.drawLine(int, 0, int, 9, Black);
		elseif pos mod 10 = 0 then
			tmpLabelFrm.drawLine(int, 0, int, 6, Black);
		elseif pos mod 5 = 0 then
			tmpLabelFrm.drawLine(int, 0, int, 3, Black);
		endif;
	
		int := int - scale;
		pos := pos + scale;
		
		if firstTime then
			if pos &gt;= overhang then
				pos := 0;
				firstTime := false;
			endif;
		endif;
		
		wharfPos := (pos * mtrPerPix).rounded();
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getBerthBowSternMarks" id="b0d97e7c-750d-4cab-ab28-b49f28b08c9b">
        <source>getBerthBowSternMarks(_leftPos, _loa : Decimal; _berth : HMS_Berth output; _bowMark, _sternMark : Decimal output);
//--------------------------------------------------
// Created:	21 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	wharf : HMS_Wharf;
	wharfPos : Real;
	newBerth : HMS_Berth;
begin

	_berth := self.getBerthByLeftPos(_leftPos);

	wharf := self.myWharf;
	if wharf.displayLeftToRight then
		_bowMark  := (_leftPos*self.metersPerPixel) - wharf.overhangZeroMetreEnd;
		_sternMark := _bowMark + _loa;				
	else
		wharfPos := (_leftPos*self.metersPerPixel) + wharf.overhangZeroMetreEnd;		
		_sternMark := self.wharfTotalLength - wharfPos;
		_bowMark := _sternMark - _loa;
	endif;
	
	//Check we have got the right berth for the marks
	newBerth := self.myWharf.getBerthForMarks(_bowMark, _sternMark);
	if newBerth &lt;&gt; null then
		_berth := newBerth;
	endif;
	
end;</source>
        <Parameter name="_leftPos" type="Decimal"/>
        <Parameter name="_loa" type="Decimal"/>
        <Parameter name="_berth" type="HMS_Berth" usage="output"/>
        <Parameter name="_bowMark" type="Decimal" usage="output"/>
        <Parameter name="_sternMark" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getBerthByLeftPos" id="ab137886-bb37-4847-b8cc-f318873bad47">
        <source>getBerthByLeftPos(_leftPos : Real) : HMS_Berth;
//--------------------------------------------------
// Created:	21 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpBerth : HMS_Berth;
begin

	if self.myWharf.displayLeftToRight then
		tmpBerth := self.allBerthByLeftPos.getAtKeyLeq(_leftPos);
		if tmpBerth = null then
			// assume that we are in the zero end overhang zone
			tmpBerth := self.allBerthByLeftPos.first;
		endif;
	else
		//tmpBerth := self.allBerthByLeftPos.getAtKeyGeq(_leftPos);
		tmpBerth := self.allBerthByLeftPos.getAtKeyLeq(_leftPos);		
		if tmpBerth = null then
			// assume that we are in the max end overhang zone
			tmpBerth := self.allBerthByLeftPos.last;
		endif;
	endif;

	return tmpBerth;

end;</source>
        <Parameter name="_leftPos" type="Real"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getFromToTimes" id="7cf521d9-b1b4-450e-be2d-a69334170f26">
        <source>getFromToTimes(_dragPict : HMS_GraphicalDragPicture; _yTop : Real; _fromTime, _toTime : TimeStamp output)protected;
//--------------------------------------------------
// Created:	20 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpFromTime : TimeStamp;
	minPerPix : Real;
begin

	// get the timestamp values for the changes...
	
	minPerPix := self.myGraphicalViewForm.minutesPerPixel;
	tmpFromTime := self.myGraphicalViewForm.myDrawTimeLabel.fromTimePeriod;

	if _yTop &gt; 0 then
		_toTime := tmpFromTime;
		_toTime := _toTime.changeByXXMinutes(((self.myGraphicalViewForm.myDrawTimeLabel.scaleHeight-_yTop)* minPerPix).Integer);	
		_fromTime := _toTime.changeByXXMinutes((_dragPict.height * minPerPix * -1).Integer);

	elseif (_yTop + _dragPict.height &lt;= _dragPict.parent.height) and _yTop + _dragPict.height &gt; 0 then
		_fromTime := tmpFromTime;
		_fromTime := _fromTime.changeByXXMinutes(((self.myGraphicalViewForm.myDrawTimeLabel.scaleHeight - _yTop + _dragPict.height)* minPerPix).Integer);			
		_toTime	:= _toTime.changeByXXMinutes((_dragPict.height * minPerPix).Integer);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_dragPict" type="HMS_GraphicalDragPicture"/>
        <Parameter name="_yTop" type="Real"/>
        <Parameter name="_fromTime" type="TimeStamp" usage="output"/>
        <Parameter name="_toTime" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getLeftPosForBerth" id="6b5893fb-f19c-4ea4-88dd-88b31c1632af">
        <source>getLeftPosForBerth(_berth : HMS_Berth) : Real;
//--------------------------------------------------
// Created:	03 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpKey : Real;
	iter : Iterator;
	tmpBerth : HMS_Berth;
begin
	if _berth = null then
		return null;
	endif;
	iter := self.allBerthByLeftPos.createIterator();
	
	while iter.next(tmpBerth) do
		if tmpBerth &lt;&gt; _berth then
			continue;
		endif;
		self.allBerthByLeftPos.getIteratorKeys(tmpKey, iter);
		break;
	endwhile;

	return tmpKey;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="initControl" id="9483743f-0abe-4620-a24b-b7d9a8d53e38">
        <updating/>
        <source>initControl(_wharf : HMS_Wharf; _wharfZoom : Real;_totLblWidth : Real io)updating;
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
vars
begin

	self.myWharf := _wharf;
	self.myHarbour := self.myWharf.getHarbour();
	self.wharfTotalLength := self.myWharf.length + self.myWharf.overhangMaxMetreEnd + self.myWharf.overhangZeroMetreEnd;	
	self.wharfZoom := _wharfZoom;
	self.myScrollingFrame.bubbleHelp := self.myWharf.code &amp; ' ' &amp; self.myWharf.description;
	if self.myHarbour &lt;&gt; null then
		self.timeNowLineColour := self.myHarbour.timeNowLineColour;
	else
		self.timeNowLineColour := Black;	
	endif;
	self.setMyLabelFrmWidth();	
	self.visible := true;
	self.isVisible := true;
	
	_totLblWidth := _totLblWidth + self.myScrollableLabelFrame.width;			
end;</source>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <Parameter name="_wharfZoom" type="Real"/>
        <Parameter name="_totLblWidth" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isControlHidden" id="26ae8b2d-3ac9-4ffc-9cb5-7762b3891a49">
        <condition/>
        <source>isControlHidden():Boolean condition;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//--------------------------------------------------
begin
	return (not self.isVisible);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isControlVisible" id="af769573-3ce2-4895-9040-7b72c705d825">
        <condition/>
        <source>isControlVisible():Boolean condition;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//--------------------------------------------------
begin
	return self.isVisible;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="movePointers" id="1e9d0450-5a94-49bc-b477-4ce3b21edf68">
        <source>movePointers(pShow : Boolean; pP1,pP2 : Real);

vars

begin
	
	if pShow then
		self.lblWharfPointerLeft.left	 := pP1;
		self.lblWharfPointerRight.left	 := pP2;
		self.lblPositionDetails.left 	:= pP1;				
		self.lblWharfPointerLeft.visible := true;
		self.lblWharfPointerRight.visible := true;
	else
		self.lblWharfPointerLeft.visible := false;
		self.lblWharfPointerRight.visible := false;
	endif;	

end;</source>
        <Parameter name="pShow" type="Boolean"/>
        <Parameter name="pP1" type="Real"/>
        <Parameter name="pP2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="positionCurrentTimeLine" id="acd56341-dc03-467b-8097-c7848d97eef9">
        <updating/>
        <source>positionCurrentTimeLine(_top : Integer) updating;
//-----------------------------------------
// Created: November 2004 By: cnwgd1
//-----------------------------------------
vars
begin

	//Set the position and colour of the current date/time line
	self.myTimeNowLine.top := _top;
 	self.myTimeNowLine.backColor := self.timeNowLineColour;
 	self.myTimeNowLine.zOrder(0);

end;</source>
        <Parameter name="_top" type="Integer"/>
    </JadeMethod>
