    <JadeMethod name="saveEDITIChanges" id="0634b4ce-f3db-4ede-9f27-4c219138c29c">
        <updating/>
        <source>saveEDITIChanges(_passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	26 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	ediTIs		: CM_EDITIById;
	realEDITI,
	pxyEDITI	: CM_EDICustomStopTI;
	loadState	: Boolean;
	obj			: Object;
	setVoyage	: CM_Voyage;
	setComment	: String;
	reset		: Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := MousePointer_HourGlass;
	create ediTIs transient;

	if self.cmbVoyage.listObject &lt;&gt; null then
		setVoyage := self.cmbVoyage.listObject.CM_Voyage;
	endif;
	setComment := self.txtComment.text;
	
	//if comment is blank we dont want to overwrite comments on bulk edit
	//only reset if single edit mode
	reset := (self.tblData.allSelectedObjects.size &lt; 2);
	
	foreach obj in self.tblData.allSelectedObjects do
		realEDITI := obj.CM_EDICustomStopTI;
	
		app.cmsBeginLoad(loadState);
		pxyEDITI := realEDITI.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		
		pxyEDITI.setVoyage(setVoyage);
		pxyEDITI.setUserNotes(setComment, reset);
		
		ediTIs.add(pxyEDITI);
	
	endforeach;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateEDITIs(ediTIs, _passport);
	
		if app.myPassport.trxCompletedOK then
			self.setControlsForQuery();
				self.frmQuery.visible := false;
			break;
		else
			theResult := app.showErrorWarningDialog('Save EDI Details', _passport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
				
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	app.mousePointer := MousePointer_Default;
	ediTIs.purge();//clear proxies
	delete ediTIs;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
