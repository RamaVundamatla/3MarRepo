    <JadeMethod name="trxUpdateVoyageWithOperator" id="1624c167-1d59-4b6f-9e24-637608cf3a7d">
        <updating/>
        <source>trxUpdateVoyageWithOperator(_voyage : CM_Voyage input; _operator : CM_Operator input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2025	naviv1	Initial creation - JIRA MTN-34341 NSW | 34310.020 Setting Operators on Voyage from IFCSUM files

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _voyage = null then	
		app.raiseCMException(Input_required_field_voyage,  null, null);
		return;
	endif;
	
	if _operator = null then
		app.raiseCMException(Input_required_field_operator,null, null);
		return;
	endif;
	
	
	beginTransaction;
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_voyage, true);
	
	if not _voyage.allOperators.includes(_operator) then
		_voyage.allOperators.add(_operator);
	endif;
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_voyage, false);
	endif;
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_operator" type="CM_Operator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateVoyageWithPort" id="d2c4a121-181f-444c-adc8-29c39fa370d6">
        <updating/>
        <source>trxUpdateVoyageWithPort(_voyage : CM_Voyage input; _port : CM_Port input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	jlier1	Initial creation 56234

*/

vars
	port : CM_Port;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _voyage = null then	
		app.raiseCMException(Input_required_field_voyage,  null, null);
		return;
	endif;
	
	if _port = null then
		app.raiseCMException(Input_required_field_prtCode,null, null);
		return;
	endif;
	
	beginTransaction;
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_voyage, true);
	
	_voyage.addPortToAllPorts(_port);
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_voyage, false);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_port" type="CM_Port" usage="input"/>
