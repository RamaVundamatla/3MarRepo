	errorMessage	:=	valReportDefinitionUpdate(	pReportDefinitionObj,
													pReportName,
													pReportCategoryObj,
													pReportDescription,
													pFormName,
													pPrinterName,
													pCopies,
													pIsLocalAllowed,
													pPaperSize,
													pOrientation,
													pMarginTop,
													pMarginBottom,
													pMarginLeft,
													pMarginRight,
													pParameterArray);

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pReportDefinitionObj, "The Report Definition being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
