    <JadeMethod name="doSave" id="68e1013d-85d6-465b-9a36-9189c3ff9d9a">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     26 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	errObj:CM_Error;
	idx:Integer;
	tmpListBox:ListBox;
	ignoreWarnings,rtnValue:Boolean;
	proxyLogRejectRCCode:CM_LogRejectRecoveryCode;
	lCode,lDescription:String;
	notAvailForEntry	: Boolean;
	theForm : SOP_TableMaintForm;
begin
  	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	notAvailForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_LogRejectRecoveryCode transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyLogRejectRCCode := theForm.myProxyObject.CM_LogRejectRecoveryCode;
	proxyLogRejectRCCode.setProxy(lCode, lDescription, notAvailForEntry);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateLogRejectRCCode(proxyLogRejectRCCode, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateLogRejectRCCode(proxyLogRejectRCCode, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	

	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
