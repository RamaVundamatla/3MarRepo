    <JadeMethod name="setForCreate" id="e0304671-4595-4aaa-9986-3b309c0591ef">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

