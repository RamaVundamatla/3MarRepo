<Class name="WS_RestWebServiceAgent" id="d8e353ba-c6ac-439a-90cc-283905cf20cb">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <JadeMethod name="findAllVoyagesForAPI" id="a78a146b-e7ca-4155-8ba9-c49c80af1f61">
        <options>4</options>
        <source>findAllVoyagesForAPI(_terminal : CM_Terminal; _voyageId : String; _arrivalDateTime : TimeStamp; _archived : Boolean; _voySet : CM_VoyageSet input) : CM_VoyageSet typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 September 2025	navlw1	JIRA-35882: Support External Voyage Code

*/

vars
	inwardsVoy,
	externalCodeVoy,
	voy,
	externalCodeAutoVoy,
	inwardsCodeAutoVoy	: CM_Voyage;
	inwardsAutoVoy,
	externalCodeAuto	: CM_VoyageSet;
	inwardsCodeDict		: CM_VoyageByInwardCodeAutoDict;
	externalCodeDict	: CM_VoyageByExtCodeAutoDict;
begin
	if _voySet = null then
		return null;
	endif;
	
	create inwardsAutoVoy transient;
	create inwardsCodeDict transient;
	create externalCodeAuto transient;
	create externalCodeDict transient;
	
	voy := _terminal.lookupVoyage(_voyageId, _arrivalDateTime, _archived);
	inwardsVoy := _terminal.allVoyagesByInwardCode[_voyageId];
	
	_terminal.allVoyagesByInwardCodeAuto.copyNoDuplicates(inwardsCodeDict, false); // copy the collection to a local varible so that we can pass it to a method on the collection
	inwardsCodeDict.getAllVoyages(_voyageId,inwardsAutoVoy); // this will populate the voyage set with the voyage using the inwardsCodeAuto
	
	externalCodeVoy := _terminal.allVoyagesByExternalCode[_voyageId];
	
	_terminal.allVoyagesByExtCodeAuto.copyNoDuplicates(externalCodeDict, false); // copy the collection to a local varible so that we can pass it to a method on the collection
	externalCodeDict.getAllVoyages(_voyageId,externalCodeAuto); // this will populate the voyage set with the voyage using the externalCodeAuto
	
	if voy &lt;&gt; null then
		_voySet.addNoDuplicates(voy, false);
	endif;
	if inwardsVoy &lt;&gt; null then
		_voySet.addNoDuplicates(inwardsVoy, false);
	endif;
	foreach inwardsCodeAutoVoy in inwardsAutoVoy do
		_voySet.addNoDuplicates(inwardsCodeAutoVoy, false);
	endforeach;
	if externalCodeVoy &lt;&gt; null then
		_voySet.addNoDuplicates(externalCodeVoy, false);
	endif;
	foreach externalCodeAutoVoy in externalCodeAuto do
		_voySet.addNoDuplicates(externalCodeAutoVoy, false);
	endforeach;
	return _voySet;
epilog
	delete inwardsAutoVoy;
	delete inwardsCodeDict;
	delete externalCodeDict;
	delete externalCodeAuto;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyageId" type="String"/>
        <Parameter name="_arrivalDateTime" type="TimeStamp"/>
        <Parameter name="_archived" type="Boolean"/>
        <Parameter name="_voySet" type="CM_VoyageSet" usage="input"/>
        <ReturnType type="CM_VoyageSet"/>
    </JadeMethod>
    <JadeMethod name="getWSJobClass" id="47944b8c-5f62-4a01-b239-6adf4f05c0c6">
        <options>4</options>
        <source>getWSJobClass(_job: CM_Job): Class typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2023	navma1 EUP | Mobile DD - [BackEnd] Mobile App list of Jobs - Road
25 Sep 2023 navhl20 ChangeRequest 60640:[60641] EUP | Mobile DD - Packing Jobs
26 Sep 2023 navlc30 ChangeRequest 60645:[60644] EUP | Mobile DD - [53891.050] - UnPacking Jobs
27 Sep 2023 navhl20 ChangeRequest 60668:[60667] EUP | Mobile DD - [53891.040] - Rail Jobs [Release]
27 Sep 2023 navhl20 ChangeRequest 60649:[60650] EUP | Mobile DD - [53891.070] - VAS Jobs
*/

vars
	wodTI : CM_WorkOrderTIDtl;
begin
	if _job &lt;&gt; null then
		wodTI := _job.myWODtl;
		
		if wodTI &lt;&gt; null then
			if _job.isKindOf(CM_WOPackJob) then				//25.9.2023 navhl20 #60640[60641]
				return WS_RestIntPackJob;
			elseif _job.isKindOf(CM_WOUnpackJob) then		//26.9.2023 navlc30 #60645[60644]
				return WS_RestIntUnPackJob;
			elseif _job.isKindOf(CM_WOToDoTaskJob) then		//27.9.2023 navhl20 #60649[60650]
				return WS_RestIntTodoJob;
			endif;

		elseif _job.myWorkOrderDtlToDo &lt;&gt; null then
			if _job.isKindOf(CM_WOToDoTaskJob) then			//27.9.2023 navhl20 #60649[60650]
				return WS_RestIntTodoJob;
			endif;
		elseif _job.isKindOf(CM_RoadJob) then
			return WS_RestIntRoadJob;
		elseif _job.isKindOf(CM_RailJob) then				//27.9.2023 navhl20 #60668[60667]
			return WS_RestIntRailJob;
		endif;
		
		return WS_RestIntJob;
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getWSJobRequest" id="03af4193-fe97-49e0-af44-423f79e4c0f1">
        <options>4</options>
        <source>getWSJobRequest(_job,_operationalJob : CM_Job; _requestArr : WS_RestIntJobRequestArray input) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2023 navhl20 ChangeRequest 60640:[60641] EUP | Mobile DD - Packing Jobs
15 Nov 2023 navhl20 ChangeRequest 58757:[60741] EUP | VAS Mobile App - [53813.020] VAS Job Details
22 May 2024	navpw1	TFS: 64096 (64098) - Added support for Work Order To Do Tasks.
30 Jul 2024 navhl20	ChangeRequest 65468: EUP -  VAS Mobile App - Enable Remarks for ToDo Tasks on Cargo Work Orders
01 Oct 2024 navhl20 Bug 32981 EUP - Todo Tasks Job complete for Partial Receive and Release Work orders
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	request 			: CM_Request;
	wle					: CM_WorkListEntry;
	wsRequest			: WS_RestIntJobRequest;
	reserveSelectionArr	: CM_ReserveDetailArray;
	reserve				: CM_ReserveDetail;
	ti					: CM_TrackedItem;
	woJob				: CM_WOToDoTaskJob;
	toDoTaskDesc		: CM_ToDoTaskDesc;
	transType			: CM_TransactionType;
	operJob				: CM_Job;
	tiSet				: CM_TISet;
begin
	
	create reserveSelectionArr  transient;
	
	if _job.isKindOf(CM_WOUnpackJob) then
		foreach wle in _job.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
			if wle.myTrackedItem.allChildren.isNotEmpty() then
				create wsRequest transient;
				wsRequest.setProxyFromObject(wle);	
				_requestArr.add(wsRequest);
			endif;
		endforeach;
	elseif _job.isKindOf(CM_WOToDoTaskJob) and (_job.getToDoTaskType() = TODO_TYPE_GROUP_TI_STR or _job.getToDoTaskType() = TODO_TYPE_GROUP_CARGOGROUP_STR) then					//15.11.2023 navhl20 #58757[60741]
		woJob := _job.CM_WOToDoTaskJob;
		
		toDoTaskDesc := woJob.getToDoTask();
		
		if toDoTaskDesc &lt;&gt; null then
			transType := toDoTaskDesc.myTransactionType;
		endif;
		
		if toDoTaskDesc &lt;&gt; null and 
			/*
			//08.10.2024 navhl20 #32981
			transType &lt;&gt; null and 													//30.07.2024 navhl20 #65468
			transType.isForWorkOrder and */
			woJob.allTrackedItems.isNotEmpty
		then
			create tiSet transient;													//01.10.2024 navhl20 #32981
			if _operationalJob &lt;&gt; null then											//01.10.2024 navhl20 #32981
				operJob := _operationalJob;
				if operJob.status = JOB_COMPLETE then
					if operJob.isRelease then
						if operJob.isRail then
							operJob.CM_RailJob.allReleaseTrackedItems.tryCopy(tiSet);
						else
							operJob.CM_RoadJob.allReleaseTrackedItems.tryCopy(tiSet);
						endif;
					else
						if operJob.isRail then
							operJob.CM_RailJob.allReceiveTrackedItems.tryCopy(tiSet);
						else
							operJob.CM_RoadJob.allReceiveTrackedItems.tryCopy(tiSet);
						endif;
					endif;
				endif;
				
				foreach ti in woJob.allTrackedItems discreteLock where tiSet.includes(ti) do		//29.10.2024 navhl20 #32981
					create wsRequest transient;
					wsRequest.setProxyFromObject(ti);	
					_requestArr.add(wsRequest);
				endforeach;
				return;
			endif;
			
			foreach ti in woJob.allTrackedItems discreteLock do		//06.03.2025 navma1 #MTN-34179
				create wsRequest transient;
				wsRequest.setProxyFromObject(ti);	
				_requestArr.add(wsRequest);
			endforeach;
			return;
		endif;
		
		foreach wle in woJob.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
			create wsRequest transient;
			wsRequest.setProxyFromObject(wle);	
			_requestArr.add(wsRequest);
		endforeach;
	else
		foreach request in _job.allRequests discreteLock do			//06.03.2025 navma1 #MTN-34179
			
			create wsRequest transient;
			
			if request.isDeliveryRequest then
				reserve := request.myReserveDetail;
				if reserveSelectionArr.includes(reserve) then
					continue;
				endif;
			endif;
			
			if request.isComplete then
				continue;
			endif;
			
			wsRequest.setProxyFromObject(request);	
			_requestArr.add(wsRequest);
			
			if request.isDeliveryRequest then
				if reserve &lt;&gt; null and reserve.isKindOf(CM_ReserveSelection) then
					reserveSelectionArr.tryAddIfNotNull(reserve);
				endif;
			endif;
			
		endforeach;
	endif;
epilog
	delete reserveSelectionArr;
	delete tiSet;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_operationalJob" type="CM_Job"/>
        <Parameter name="_requestArr" type="WS_RestIntJobRequestArray" usage="input"/>
    </JadeMethod>
</Class>
