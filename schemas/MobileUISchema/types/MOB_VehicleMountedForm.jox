	btnSaveWeight.translateCaption(Xlat_0021743, locale);
	btnSearchTwin.translateCaption(Xlat_0015244, locale);
	btnSwap.translateCaption(Xlat_0014886, locale);
	btnSwapCargo.translateCaption(Xlat_0019376, locale);
	btnTandem.translateCaption(Xlat_0015245, locale);
	btnTaskMode.translateCaption(Xlat_0014887, locale);
	btnVoyDischarge.translateCaption(Xlat_0014888, locale);
	frmBottomHLabels.translateCaption(Xlat_0015246, locale);
	frmButtons.translateCaption(Xlat_0015247, locale);
	frmGetTask.translateCaption(Xlat_0014889, locale);
	frmGraphic.translateCaption(Xlat_0014890, locale);
	frmLeftVLabels.translateCaption(Xlat_0015248, locale);
	frmRightVLabels.translateCaption(Xlat_0015249, locale);
	frmTopHLabels.translateCaption(Xlat_0015250, locale);
	lblMode.translateCaption(Xlat_0014891, locale);
end;</source>
