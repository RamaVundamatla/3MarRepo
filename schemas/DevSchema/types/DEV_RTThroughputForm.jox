    <JadeMethod name="doCargoClear" id="335a5dcb-2768-476c-937c-9b682aa357eb">
        <source>doCargoClear();
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.tblCargoEnq.clearValues();
	self.txtCargoId.text := null;
	self.txtCargoId.setFocus();
	self.lblNotFound.visible := false;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoEnquiry" id="82c9b79d-ac89-4a1e-bb69-9f9086b42540">
        <source>doCargoEnquiry();
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	tmpTI : CM_TrackedItem;
begin
	
	if self.txtCargoId.text = null then
		self.doMsgBoxCargoIdReq('Cargo Enquiry');
		self.txtCargoId.setFocus();	
		return;
	endif;
	
	tmpTI := self.myRoot.lookupTrackedItem(self.txtCargoId.text, null, TI_STATE_NORMAL, null, false, null, true);
	if tmpTI = null then
		self.tblCargoEnq.clearValues();
		self.lblNotFound.visible := true;
		self.txtCargoId.setFocus();
		return;
	endif;
	self.lblNotFound.visible := false;
	self.tblCargoEnq.setTableFromObject(tmpTI, null);
	self.txtCargoId.text := tmpTI.id;

epilog
	str := self.txtCargoId.text;
	if str = null then
		str := 'Cargo id was blank';
	endif;
	str := 'Enquiry: ' &amp; str;	
	if self.lblNotFound.visible then
		if self.txtCargoInquiry.text = null then
			self.txtCargoInquiry.text := str &amp; ' Not Found';			
		else
			self.txtCargoInquiry.text := self.txtCargoInquiry.text &amp; CrLf &amp; str &amp; ' Not Found';		
		endif;
	else
		if self.txtCargoInquiry.text = null then
			self.txtCargoInquiry.text := str;		
		else
			self.txtCargoInquiry.text := self.txtCargoInquiry.text &amp; CrLf &amp; str;	
		endif;
	endif;
	self.lblShowQtyCE.caption := (self.lblShowQtyCE.caption.Integer+1).String;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoEnquiryToDo" id="bacd24c8-2a26-438c-95a4-d47dc8d9e794">
        <updating/>
        <source>doCargoEnquiryToDo()updating;
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	tmpTI : CM_TrackedItem;
begin
	
		
	if self.txtCargoIdToDo.text = null then
		self.doToDoClear();
		self.doMsgBoxCargoIdReq('To Do Task Cargo Enquiry');
		return;
	endif;
	
	tmpTI := self.myRoot.lookupTrackedItem(self.txtCargoIdToDo.text, null, TI_STATE_NORMAL, null, false, null, true);
	
	self.myCurrentTrackedItem := tmpTI;
	
	if tmpTI = null then
		self.lblNotFoundToDo.visible := true;
		self.txtCargoIdToDo.setFocus();
		return;
	endif;
	
	self.lblNotFoundToDo.visible := false;
	self.txtCargoIdToDo.text := tmpTI.id;
	self.lblShowLocation.caption := tmpTI.locationId;			
	self.lblShowOperator.caption := tmpTI.operatorDescription &amp; ' (' &amp; tmpTI.operatorCode &amp; ')';
	
	app.myPassport.setMyTerminal(tmpTI.myTerminal);
	
	self.populateToDoTable();

epilog
	str := self.txtCargoIdToDo.text;
	if str = null then
		str := 'Cargo id was blank';
	endif;
	str := 'Enquiry: ' &amp; str;
	if self.lblNotFound.visible then
		if self.txtTDEnquiry.text = null then
			self.txtTDEnquiry.text := str &amp; ' Not Found';			
		else
			self.txtTDEnquiry.text := self.txtTDEnquiry.text &amp; CrLf &amp; str &amp; ' Not Found';		
		endif;
	else
		if self.txtTDEnquiry.text = null then
			self.txtTDEnquiry.text := str;		
		else
			self.txtTDEnquiry.text := self.txtTDEnquiry.text &amp; CrLf &amp; str;	
		endif;
	endif;
	self.lblShowQtyTD.caption := (self.lblShowQtyTD.caption.Integer+1).String;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMsgBoxCargoIdReq" id="511ec204-1867-4e89-9fee-5ec208bc8534">
        <source>doMsgBoxCargoIdReq(_caption : String);
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	app.msgBox('Please enter cargo Id and try again.', _caption, MsgBox_Information_Icon + MsgBox_OK_Only);
end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="doMsgBoxNotImplemented" id="5568d04b-4eb5-4b98-8283-f54884e3e081">
        <source>doMsgBoxNotImplemented(_caption : String);
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	app.msgBox('This function has not been implemented.' &amp; CrLf &amp;
				'We apologise for any inconvenience this may cause.' &amp; CrLf &amp; CrLf &amp;
				'Please try again later. Have a happy day.', _caption, MsgBox_Information_Icon + MsgBox_OK_Only);
end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="doToDoClear" id="21d9782a-5cc3-4c1b-829f-9ff7a095e4e8">
        <updating/>
        <source>doToDoClear()updating;
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.populateToDoTableForInit();
	self.myCurrentTrackedItem := null;
	self.lblShowLocation.caption := null;
	self.lblShowOperator.caption := null;
	self.cmbAvGrade.setObject(null);	
	self.txtCargoIdToDo.text := null;	
	self.txtCargoIdToDo.setFocus();
	self.lblNotFoundToDo.visible := false;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doToDoUpdate" id="24e44d8e-70ec-40c7-8ea4-541396f36790">
        <updating/>
        <source>doToDoUpdate()updating;
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
begin

	//self.doMsgBoxNotImplemented('Update');
	self.doUpdate();

	str := 'Updated';

	if self.txtTDEnquiry.text = null then
		self.txtTDEnquiry.text := str;		
	else
		self.txtTDEnquiry.text := self.txtTDEnquiry.text &amp; CrLf &amp; str;	
	endif;

	self.lblShowQtyTD.caption := (self.lblShowQtyTD.caption.Integer+1).String;			
			
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="27b7880b-6b8d-486c-b3fa-e34cedce2903">
        <updating/>
        <source>doUpdate()updating;
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	row,
	numRows,
	gradeKey : Integer;
	tmpDone,
	tmpSel,
	tmpDT : String;
	tmpTI : CM_TrackedItem;
	isNew,
	isSelected,
	isToBeCompleted : Boolean;
	toDoTask : CM_ToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	object : Object;
	newTrans : CM_TITransaction;	//30 Dec 2009	NDL		MES CCMS 1006 - return transaction...
begin
	
	tmpTI := self.myCurrentTrackedItem;
	
	if tmpTI = null then
		app.msgBox('Cargo item not found.', 'Update', MsgBox_Information_Icon + MsgBox_OK_Only);	
		return;
	endif;
	
	beginTransaction;
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
			
	if self.cmbAvGrade.listObject &lt;&gt; null then
		gradeKey := self.cmbAvGrade.listObject.CM_MTGrade.code;

		tmpTI.setAvailabilityGradeRT(gradeKey, app.myPassport);
	endif;
	
	numRows := self.tblDataToDo.rows;
	
	foreach row in 2 to numRows do
		tmpDone := self.tblDataToDo.accessCell(row, 3).text;
		tmpSel := self.tblDataToDo.accessCell(row, 2).text;
		
		object := self.tblDataToDo.accessRow(row).itemObject;

		toDoTask := null;
		toDoTaskDesc :=	null;

		if CM_ToDoTask.hasInstance(object) then
			toDoTask := object.CM_ToDoTask;
		elseif CM_ToDoTaskDesc.hasInstance(object) then
			toDoTaskDesc :=	object.CM_ToDoTaskDesc;
		endif;

		isSelected := tmpSel='1';

		isNew := (isSelected and toDoTask = null);

		isToBeCompleted := (isSelected and tmpDone = "1");

		if isSelected and toDoTask = null and toDoTaskDesc = null then
			//-------------
			//They have selected a null line!
			//-------------
			continue;
		endif;
		//---------------------
		//Determine what to do
		//---------------------
		if isSelected then
			if toDoTask = null then
				if isNew then
					toDoTask := tmpTI.addToDoTask(toDoTaskDesc.description, app.myPassport);
				endif;
			endif;
			if isToBeCompleted then
				toDoTask.setTaskComplete(app.myPassport, true, newTrans);
			endif;
		else
			//-------------
			//Not selected. Does it have a task oid?
			//-------------
			if toDoTask &lt;&gt; null then
				toDoTask.erase(NORMAL_ERASE);
			endif;
	        //----------------------
	        //(Ones without a toDoTaskOid are left alone)
	        //'----------------------
		endif;

	endforeach;

	commitTransaction;
	
	self.populateToDoTable();

end;</source>
    </JadeMethod>
    <JadeMethod name="initCargoEnqTable" id="c67d4472-b454-4c32-b32c-26564926731c">
        <source>initCargoEnqTable();
//--------------------------------------------------
