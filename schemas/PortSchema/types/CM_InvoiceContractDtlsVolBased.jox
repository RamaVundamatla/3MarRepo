    <JadeMethod name="getAccumulatedTypeText" id="c2cb59c4-5e4b-4988-8ce4-f4b673189ce7">
        <source>getAccumulatedTypeText() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars

begin
	if self.accumulationType = INV_VOL_BASED_PERIOD then
		return INV_VOL_BASED_PERIOD_STR;
	elseif self.accumulationType = INV_VOL_BASED_VOYAGE then
		return INV_VOL_BASED_VOYAGE_STR;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
