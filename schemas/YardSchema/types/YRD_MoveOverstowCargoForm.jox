    <JadeMethod name="setupForm" id="89ceca0b-e50d-4372-9378-4540f1446db3">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;

begin

	inheritMethod();
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top;
	self.getXMLSettingsForSetup(); // PAR 25527

	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.dkbGridAreas.width:=self.frmOptions.left - 15;
	self.dkbGridAreas.height:=self.btnSave.top - 15; // PAR 25364
	self.dkbGridAreas.parentAspect:=Control.ParentAspect_StretchBoth;
	self.cmbICArea.enabled := false;
	self.cmbTA.enabled:=false;
	self.loadCombos();
	self.txtOverstow.backColor:=self.backColor;
	self.txtOverstow.text:=app.getErrorString1(TI_Overstowed_by,self.myTrackedItem.id);
	foreach ti in self.allOverstowingTIs do
		self.txtOverstow.text:=self.txtOverstow.text &amp; CrLf &amp; " - "  &amp; ti.id;
	endforeach;
	self.doResize();

	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b35f2b3b-ccbc-4978-a38f-7d602d87c724">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 May 2018 08:34:18.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013590, locale);
	btnCancel.translateCaption(Xlat_0013591, locale);
	btnFlipH.translateBubbleHelp(Xlat_0016334, locale);
	btnFlipH.translateCaption(Xlat_0016335, locale);
	btnFlipV.translateBubbleHelp(Xlat_0016336, locale);
	btnFlipV.translateCaption(Xlat_0016337, locale);
	btnRefresh.translateBubbleHelp(Xlat_0013592, locale);
	btnRefresh.translateCaption(Xlat_0013593, locale);
	btnSave.translateCaption(Xlat_0013594, locale);
	lblAPinTA.translateCaption(Xlat_0014302, locale);
	lblAPinTerm.translateCaption(Xlat_0014303, locale);
	lblMachine.translateCaption(Xlat_0022435, locale);
	lblSelect.translateCaption(Xlat_0014654, locale);
	optBest.translateCaption(Xlat_0013596, locale);
	optCurrent.translateCaption(Xlat_0013597, locale);
	optICArea.translateCaption(Xlat_0013598, locale);
	optQtoLocation.translateCaption(Xlat_0014304, locale);
	optViewEnd.translateCaption(Xlat_0016338, locale);
	optViewFace.translateCaption(Xlat_0016339, locale);
end;</source>
    </JadeMethod>
</GUIClass>
