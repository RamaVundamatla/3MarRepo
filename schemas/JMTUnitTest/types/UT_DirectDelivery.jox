    <JadeMethod name="planLoadItemsPN" id="2b952fbe-da38-4a14-95f5-df04775e8138">
        <source>planLoadItemsPN( _voyage : CM_Voyage; _ti : CM_TrackedItem; _col : Integer; _tier : Integer ):CM_VoyageJob protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2013	cnwndl1	Initial creation

*/

vars

	jobSheet : CM_VoyageJobSheet;
	slots : CM_SlotControllerArray;
	theTIs: CM_TIArray;
	ti : CM_TrackedItem;
	lcs : CM_LCArray;
	moveController : CMIF_MoveController;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;

begin

	jobSheet := voyage.allJobSheets["CRN1"];
	
	create theTIs transient;
	theTIs.add(_ti);

	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs,true,app.myPassport);
	
	create slots transient;
	self.getJobSlotControllers(_voyage.code,"01",DeckOnDeck,_col,_tier,1,slots);
	
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];
	
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	
	voyageJob := self.addVoyageJob(_voyage,"CRN1",slots, false);
	
	create lcs transient;
	slots.copy(lcs);
	create moveController transient;

	moveController.isRehandleMove := false;
	moveController.mySlotRequest := slots.first.mySlotRequestLoad;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;
	
	app.myPassport.setWarningsIgnored(true);

	// ### BULK LOAD PLAN
	app.myTrxUA.trxMoveTIsAUTOAssignToJob(theTIs, lcs, moveController, app.myPassport);
	
	foreach ti in theTIs discreteLock do
		self.assertTrueMsg((ti.myPrimaryPlannedLocation &lt;&gt; null),ti.id &amp; " Prenote did not plan load.");
	endforeach;	
	
	return voyageJob;
	
epilog

	delete lcs;
	delete theTIs;
	delete slots;
	delete moveController;
	delete tmpLoadCC;
	
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_tier" type="Integer"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="tBasicDirectDeliveryRailToRoad" id="fbe6b4b4-a123-4604-a1da-c786ea66bc8c">
        <updating/>
        <source>tBasicDirectDeliveryRailToRoad()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2013	cnwndl1	Initial creation	Par 31102

*/

constants

	BookingId : String = "DDBOOKING";
	ContId9 : String = "JMTZ0022029";
	ContId10 : String = "JMTZ0022030";
	TRAIN_CODE : String = "UT-TRAINDD";
	WAGON_CODE : String = "UK0110";
	RAIL_AREA_ID : String = "UT_RADD";
	TruckId : String = "UTDDTRUCK";
	DriverId : String = "UTDDDRIVER";
	
vars

	booking : CM_BookingRef;
	oper : CM_Operator;
	ti9 : CM_TrackedItem;
	ti10 : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
	railJob : CM_RailJob;
	railWle : CM_WorkListEntry;
	roadWle : CM_WorkListEntry;
	sourceLoc : CM_LocationsController;
	targetLoc : CM_LocationsController;
	truck : CM_Vehicle;
	wagon : CM_Wagon;
	
	bookingOverSubscribe : Boolean;
	isDoClearanceCheck : Boolean;

begin

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

	self.setTerminalConfig(BookingOversubscribe, true);

	// Cleanup here
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	self.deleteVehicle(TruckId);
	self.deleteBooking(BookingId);
	
	//create DD prenote.
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.opts.addAssoc("DD",true);
	booking := self.addBookingForContainer(BookingId, oper, voyage, "NZAKL", "2200", "MT");
	ti9 := self.addPrenotedContainer(booking.allBookingRefItems.first, ContId9);
	ti10 := self.addPrenotedContainer(booking.allBookingRefItems.first, ContId10);
	
	//Gate in an empty truck that wants to take out the DD Container related to job 1
	vvr := gateOutContainer(TruckId, "", DriverId, ti9.CM_Container, false, dualGate, null);
	
	//Create Rail area and then arrive a Train with cargo.
	wagon := createRailTrainAndWagon(WAGON_CODE,TRAIN_CODE,RAIL_AREA_ID, ti9, ti10);
	
	//Check that:
	//Rail release job exists and is planned but not queued 
	//VoyageWle records the truck as its source location
	//Transfer area is the the crane transfer area of the crane related to the voyage job.
	roadJob := ti9.jobRoadRelease;
	self.assertTrueMsg(roadJob &lt;&gt; null, "1. DD Road Release Job not created");
	roadWle := roadJob.workListEntries.first;
	self.assertTrueMsg(roadWle &lt;&gt; null, "2. DD Road Release Job has no WLE");
	self.assertTrueMsg(not roadWle.isQueued, "3. WLE for DD Road Release Job should not be queued for a DD");
	railJob := ti9.jobRailReceive;
	self.assertTrueMsg(railJob &lt;&gt; null, "3. DD Rail Receive Job not created");
	railWle := railJob.getWLEForTI(ti9);
	self.assertTrueMsg(railWle &lt;&gt; null, "4. DD Rail Receive Job has no WLE");
	self.assertTrueMsg(not railWle.isQueued, "5. WLE for DD Rail Receive Job should not be queued for a DD");
	self.assertTrueMsg(roadWle &lt;&gt; null, "6. DD Road Job has no WLE");
	self.assertTrueMsg(railWle.getSourceLocation() = roadWle.getSourceLocation(), "7. DD Rail and Road WLE have different source locations");
	targetLoc := roadWle.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "8. DD Road WLE has not target location");
	truck := vvr.vehicle;
	self.assertTrueMsg(truck &lt;&gt; null, "9. Truck not created");
	
	//Move truck to yard and confirm that it goes to the crane transfer area.
	self.moveTruckToInterchangeArea(truck);
	self.assertTrueMsg(truck.myPrimaryActualLocation &lt;&gt; null, "10. Truck has no current location");
	self.assertTrueMsg(not truck.myPrimaryActualLocation.isKindOf(CM_CraneLaneController), "10. Truck is in a Crane transfer area");
	
	//Set up a move controller to do a real move using the rail wle and call the move trx
	self.handHeldDirectDischargeTrx( ti9, targetLoc, railWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"11. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "12. Rail Wle not complete");
	self.assertTrueMsg(roadWle.status = WLE_COMPLETED, "13. Road Wle not complete");
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"14. Truck failed to exit. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(ti9.getTransReceive &lt;&gt; null, "15. No receipt transaction");
	self.assertTrueMsg(ti9.getTransRelease &lt;&gt; null, "16. No release transaction");
	self.assertTrueMsg(ti9.isOffSite, "17. Cargo not off site");
	
	//Gate in an empty truck that wants to take out the second DD Container
	vvr := gateOutContainer(TruckId, "", DriverId, ti10.CM_Container, false, dualGate, null);
	
	railJob := ti10.jobRailReceive;
	self.assertTrueMsg(railJob &lt;&gt; null, "18. DD Rail Receive Job not created");
	railWle := railJob.getWLEForTI(ti10);
	self.assertTrueMsg(railWle &lt;&gt; null, "19. DD Rail Job has no WLE");
	roadJob := ti10.jobRoadRelease;
	self.assertTrueMsg(roadJob &lt;&gt; null, "20. DD Road Release Job not created");
	roadWle := roadJob.workListEntries.first;
	self.assertTrueMsg(roadWle &lt;&gt; null, "21. DD Road Release Job has no WLE");
	targetLoc := roadWle.getTargetLocation();
	
	//Set up a move controller to do a real move using the road wle and call the move trx
	self.handHeldDirectDischargeTrx( ti10, targetLoc, roadWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"22. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(roadWle.status = WLE_COMPLETED, "23. Road Wle not complete");
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "24. Rail Wle not complete");
	self.assertTrueMsg(ti10.getTransReceive &lt;&gt; null, "25. No receipt transaction");
	self.assertTrueMsg(ti10.getTransReceiveFirst = ti10.getTransReceive, "25A. There should only be one receipt transaction");
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"26. Truck failed to exit. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(ti10.getTransRelease &lt;&gt; null, "27. No release transaction");
	self.assertTrueMsg(ti10.isOffSite, "28. Cargo not off site");
	

epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	self.deleteVehicle(TruckId);
	self.deleteBooking(BookingId);

end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicDirectDeliveryRailToShip" id="5a6f00f7-8c93-4b18-a43e-e838f05639b2">
        <updating/>
        <source>tBasicDirectDeliveryRailToShip()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2013	cnwndl1	Initial creation	Par 31102

*/

constants

	BookingId : String = "DDBOOKING";
	ContId3 : String = "JMTZ0022027";
	ContId4 : String = "JMTZ0022028";
	TRAIN_CODE : String = "UT-TRAINDD";
	WAGON_CODE : String = "UK0110";
	RAIL_AREA_ID : String = "UT_RADD";
	
vars

	booking : CM_BookingRef;
	oper : CM_Operator;
	ti3 : CM_TrackedItem;
	ti4 : CM_TrackedItem;
	voyageJob : CM_VoyageJob;
	railJob : CM_RailJob;
	railWle : CM_WorkListEntry;
	voyageWle : CM_VoyageWLE;
	sourceLoc : CM_LocationsController;
	targetLoc : CM_LocationsController;
	cell : Integer;
	tier : Integer;
	wagon : CM_Wagon;
	isDoClearanceCheck : Boolean;

begin

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

	self.setTerminalConfig(BookingOversubscribe, true);

	// Cleanup here
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	self.deleteBooking(BookingId);
	
	//create DD prenote for voyage.
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.opts.addAssoc("DD",true);
	booking := self.addBookingForContainer(BookingId, oper, voyage, "NZAKL", "2200", "MT");
	ti3 := self.addPrenotedContainer(booking.allBookingRefItems.first, ContId3);
	ti4 := self.addPrenotedContainer(booking.allBookingRefItems.first, ContId4);
	self.deleteStops(ti3);
	self.deleteStops(ti4);
	
	//Create load jobs for the first container
	//And plan it to the slot
	tier := 1;
	cell := 5;
	voyageJob := self.planLoadItemsPN( self.voyage, ti3, cell, tier );
	voyageWle := voyageJob.workListEntries.first().CM_VoyageWLE;
	
	//Load first job to operations
	self.loadVoyJobToOps(voyageJob, true, false);
	
	//Create Rail area and then arrive a Train with cargo.
	wagon := createRailTrainAndWagon(WAGON_CODE,TRAIN_CODE,RAIL_AREA_ID, ti3, ti4);
	
	//Check that:
	//Rail release job exists and is planned but not queued 
	//VoyageWle records the truck as its source location
	//Transfer area is the the crane transfer area of the crane related to the voyage job.
	railJob := ti3.jobRailReceive;
	self.assertTrueMsg(railJob &lt;&gt; null, "1. DD Rail Receive Job not created");
	railWle := railJob.getWLEForTI(ti3);
	self.assertTrueMsg(railWle &lt;&gt; null, "2. DD Rail Receive Job has no WLE");
	self.assertTrueMsg(not railWle.isQueued, "3. WLE for DD Rail Receive Job should not be queued for a DD");
	self.assertTrueMsg(voyageWle &lt;&gt; null, "4. DD Voyage Job has no WLE");
	self.assertTrueMsg(railWle.getSourceLocation() = voyageWle.getSourceLocation(), "5. DD Rail and Voyage WLE have different source locations");
	targetLoc := voyageWle.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "6. DD Voyage WLE has not target location");
	
	//Set up a move controller to do a real move using the voyage wle and call the move trx
	self.handHeldDirectDischargeTrx( ti3, targetLoc, voyageWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"7. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "8. Rail Wle not complete");
	self.assertTrueMsg(voyageWle.status = WLE_COMPLETED, "9. Voyage Wle not complete");
	self.assertTrueMsg(ti3.getTransReceive &lt;&gt; null, "10. No receipt transaction");
	self.assertTrueMsg(ti3.getTransReceiveFirst = ti3.getTransReceive, "10A. There should only be one receipt transaction");
	self.assertTrueMsg(ti3.getTransRelease &lt;&gt; null, "11. No release transaction");
	self.assertTrueMsg(ti3.isOnShip, "12. Cargo not on ship");
	

	//Create second job and plan cargo to the slot
	tier := 2;
	cell := 5;
	voyageJob := self.planLoadItemsPN( self.voyage, ti4, cell, tier );
	voyageWle := voyageJob.workListEntries.first().CM_VoyageWLE;
	
	railJob := ti4.jobRailReceive;
	self.assertTrueMsg(railJob &lt;&gt; null, "13. DD Rail Receive Job not created");
	railWle := railJob.getWLEForTI(ti4);
	self.assertTrueMsg(voyageWle &lt;&gt; null, "14. DD Rail Job has no WLE");
	voyageWle := voyageJob.workListEntries.first.CM_VoyageWLE;
	self.assertTrueMsg(voyageWle &lt;&gt; null, "15. DD Voyage Job has no WLE");
	targetLoc := voyageWle.getTargetLocation();
	
	//Set up a move controller to do a real move using the voyage wle and call the move trx
	self.handHeldDirectDischargeTrx( ti4, targetLoc, railWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"16. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "17. Road Wle not complete");
	self.assertTrueMsg(voyageWle.status = WLE_COMPLETED, "18. Voyage Wle not complete");
	self.assertTrueMsg(ti4.getTransReceive &lt;&gt; null, "19. No receipt transaction");
	self.assertTrueMsg(ti4.getTransRelease &lt;&gt; null, "20. No release transaction");
	self.assertTrueMsg(ti4.isOnShip, "21. Cargo not on ship");
	

epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	self.deleteBooking(BookingId);

end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicDirectDeliveryRoadToRail" id="a81b5c23-5f69-455a-ad0c-b4a871d27134">
        <updating/>
        <source>tBasicDirectDeliveryRoadToRail()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2013	cnwndl1	Initial creation	Par 31102

*/

constants

	BookingId : String = "DDBOOKING";
	ContId7 : String = "JMTZ0022029";
	ContId8 : String = "JMTZ0022030";
	TruckId : String = "UTDDTRUCK";
	DriverId : String = "UTDDDRIVER";
	TRAIN_CODE : String = "UT-TRAINDD";
	WAGON_CODE : String = "UK0110";
	RAIL_AREA_ID : String = "UT_RADD";
	
vars

	booking : CM_BookingRef;
	oper : CM_Operator;
	ti7 : CM_TrackedItem;
	ti8 : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
	roadWle : CM_WorkListEntry;
	railJob : CM_RailJob;
	railWle : CM_WorkListEntry;
	sourceLoc : CM_LocationsController;
	targetLoc : CM_LocationsController;
	truck : CM_Vehicle;
	wagon : CM_Wagon;
	isDoClearanceCheck : Boolean;
	
begin

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

	self.setTerminalConfig(BookingOversubscribe, true);

	// Cleanup here
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	self.deleteVehicle(TruckId);
	self.deleteBooking(BookingId);
	
	//create DD prenote.
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.opts.addAssoc("DD",true);
	booking := self.addBookingForContainer(BookingId, oper, voyage, "NZAKL", "2200", "MT");
	ti7 := self.addPrenotedContainer(booking.allBookingRefItems.first, ContId7);
	ti8 := self.addPrenotedContainer(booking.allBookingRefItems.first, ContId8);
	
	//Create Rail area and then arrive a Train with no cargo.
	wagon := createRailTrainAndWagon(WAGON_CODE,TRAIN_CODE,RAIL_AREA_ID, null, null);

	// mark cargo as release by train and assign and plan to train.
	self.assignCargoToTrain(wagon,ti7,1);
	
	//Gate in a truck with the 1st prenote on board.
	vvr :=  self.gateInPrenote(TruckId, "", DriverId, ti7, dualGate);
	
	//Check that:
	//Road release job exists and is planned but not queued 
	//railWle records the truck as its source location
	//Transfer area is the the crane transfer area of the crane related to the voyage job.
	roadJob := ti7.jobRoadReceive;
	self.assertTrueMsg(roadJob &lt;&gt; null, "1. DD Road Receive Job not created");
	roadWle := roadJob.workListEntries.first;
	self.assertTrueMsg(roadWle &lt;&gt; null, "2. DD Road Receive Job has no WLE");
	self.assertTrueMsg(not roadWle.isQueued, "3. WLE for DD Road Receive Job should not be queued for a DD");
	
	railJob := ti7.jobRailRelease;
	self.assertTrueMsg(railJob &lt;&gt; null, "4. DD Rail Release Job not created");
	railWle := railJob.getWLEForTI(ti7);
	self.assertTrueMsg(railWle &lt;&gt; null, "5. DD Rail Release Job has no WLE");
	
	self.assertTrueMsg(roadWle.getSourceLocation() = railWle.getSourceLocation(), "6. DD Road and Rail WLE have different source locations");
	truck := vvr.vehicle;
	self.assertTrueMsg(truck &lt;&gt; null, "7. Truck not created");
	targetLoc := railWle.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "8. DD Rail WLE has not target location");
	
	
	//Move truck to yard and confirm that it goes to the crane transfer area.
	self.moveTruckToInterchangeArea(truck);
	self.assertTrueMsg(truck.myPrimaryActualLocation &lt;&gt; null, "9. Truck has no current location");
	self.assertTrueMsg(not truck.myPrimaryActualLocation.isKindOf(CM_CraneLaneController), "10. Truck is in Crane transfer area");
	
	//Set up a move controller to do a real move using the rail wle and call the move trx
	self.handHeldDirectDischargeTrx( ti7, targetLoc, railWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"11. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	//Check that:
	// No errors
	//Voyage job, Road Release job, and both WLEs are completed.
	//Check that the cargo has ship receive transaction
	self.assertTrueMsg(roadWle.status = WLE_COMPLETED, "11. Road Wle not complete");
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "12. Rail Wle not complete");
	self.assertTrueMsg(ti7.getTransReceive &lt;&gt; null, "13. No receipt transaction");
	
	
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"14. Truck failed to exit. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	// mark cargo as release by train and assign and plan to train.
	self.assignCargoToTrain(wagon,ti8,3);
	
	
	//Gate in a truck with the 2nd prenote on board.
	vvr :=  self.gateInPrenote(TruckId, "", DriverId, ti8, dualGate);
	
	roadJob := ti8.jobRoadReceive;
	self.assertTrueMsg(roadJob &lt;&gt; null, "15. DD Road Receive Job not created");
	roadWle := roadJob.workListEntries.first;
	self.assertTrueMsg(roadWle &lt;&gt; null, "16. DD Road Job has no WLE");
	
	railJob := ti8.jobRailRelease;
	self.assertTrueMsg(railJob &lt;&gt; null, "17. DD Rail Release Job not created");
	railWle := railJob.getWLEForTI(ti8);
	self.assertTrueMsg(railWle &lt;&gt; null, "18. DD Rail Release Job has no WLE");
	
	self.assertTrueMsg(roadWle.getSourceLocation() = railWle.getSourceLocation(), "19. DD Road and Rail WLE have different source locations");
	truck := vvr.vehicle;
	self.assertTrueMsg(truck &lt;&gt; null, "20. Truck not created");
	targetLoc := railWle.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "21. DD Rail WLE has not target location");
	
	self.moveTruckToInterchangeArea(truck);
	
	
	//Set up a move controller to do a real move using the road wle and call the move trx
	self.handHeldDirectDischargeTrx( ti8, targetLoc, roadWle );
	
	//Check that:
	// No errors
	//Rail job, Road Release job, and both WLEs are completed.
	//Check that the cargo has ship receive transaction
	//Vehicle Visit record includes the cargo 
	self.assertTrueMsg(roadWle.status = WLE_COMPLETED, "22. Road Wle not complete");
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "23. Rail Wle not complete");
	self.assertTrueMsg(ti8.getTransReceive &lt;&gt; null, "24. No receipt transaction");
	self.assertTrueMsg(ti8.getTransReceiveFirst = ti8.getTransReceive, "24A. There should only be one receipt transaction");
	
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	
	
	//Depart the Train.
	self.departTrainAndClearRake( wagon.myTrainInwards );
	
	//Check that:
	// No errors
	//Check that the cargo has release transaction
	self.assertTrueMsg(ti8.getTransRelease &lt;&gt; null, "25. No release transaction");
	self.assertTrueMsg(ti7.getTransRelease &lt;&gt; null, "26. No release transaction");
	

epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	self.deleteVehicle(TruckId);
	self.deleteBooking(BookingId);

end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicDirectDeliveryRoadToShip" id="93b02c91-9133-4d9f-b2ad-fa4e8b4cdb53">
        <updating/>
        <source>tBasicDirectDeliveryRoadToShip()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2013	cnwndl1	Initial creation	Par 31102

*/

constants
	BookingId : String = "DDBOOKING";
	ContId1 : String = "JMTZ0022025";
	ContId2 : String = "JMTZ0022026";
	TruckId : String = "UTDDTRUCK";
	DriverId : String = "UTDDDRIVER";
vars

	booking : CM_BookingRef;
	oper : CM_Operator;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	voyageJob : CM_VoyageJob;
	vvr : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
	roadWle : CM_WorkListEntry;
	voyageWle : CM_VoyageWLE;
	sourceLoc : CM_LocationsController;
	targetLoc : CM_LocationsController;
	truck : CM_Vehicle;
	cell : Integer;
	tier : Integer;
	isDoClearanceCheck : Boolean;

begin

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

	self.setTerminalConfig(BookingOversubscribe, true);

	// Cleanup here
	self.deleteVehicle(TruckId);
	self.deleteBooking(BookingId);
	
	//create DD prenote for voyage.
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.opts.addAssoc("DD",true);
	booking := self.addBookingForContainer(BookingId, oper, voyage, "NZAKL", "2200", "MT");
	ti1 := self.addPrenotedContainer(booking.allBookingRefItems.first, ContId1);
	ti2 := self.addPrenotedContainer(booking.allBookingRefItems.first, ContId2);
	self.deleteStops(ti1);
	self.deleteStops(ti2);
	
	//Create load jobs for the first container
	//And plan it to the slot
	tier := 3;
	cell := 4;
	voyageJob := self.planLoadItemsPN( self.voyage, ti1, cell, tier );
	voyageWle := voyageJob.workListEntries.first().CM_VoyageWLE;
	
	//Load first job to operations
	self.loadVoyJobToOps(voyageJob, true, false);
	
	//Gate in a truck with the 1st prenote on board.
	vvr :=  self.gateInPrenote(TruckId, "", DriverId, ti1, dualGate);
	
	//Check that:
	//Road release job exists and is planned but not queued 
	//VoyageWle records the truck as its source location
	//Transfer area is the the crane transfer area of the crane related to the voyage job.
	roadJob := ti1.jobRoadReceive;
	self.assertTrueMsg(roadJob &lt;&gt; null, "1. DD Road Receive Job not created");
	roadWle := roadJob.workListEntries.first;
	self.assertTrueMsg(roadWle &lt;&gt; null, "2. DD Road Receive Job has no WLE");
	self.assertTrueMsg(not roadWle.isQueued, "3. WLE for DD Road Receive Job should not be queued for a DD");
	self.assertTrueMsg(voyageWle &lt;&gt; null, "4. DD Voyage Job has no WLE");
	self.assertTrueMsg(roadWle.getSourceLocation() = voyageWle.getSourceLocation(), "5. DD Road and Voyage WLE have different source locations");
	truck := vvr.vehicle;
	self.assertTrueMsg(truck &lt;&gt; null, "6. Truck not created");
	targetLoc := voyageWle.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "7. DD Voyage WLE has not target location");
	
	//Move truck to yard and confirm that it goes to the crane transfer area.
	self.moveTruckToInterchangeArea(truck);
	self.assertTrueMsg(truck.myPrimaryActualLocation &lt;&gt; null, "8. Truck has no current location");
	self.assertTrueMsg(truck.myPrimaryActualLocation.isKindOf(CM_CraneLaneController), "9. Truck is NOT in Crane transfer area");
	
	//Set up a move controller to do a real move using the voyage wle and call the move trx
	self.handHeldDirectDischargeTrx( ti1, targetLoc, voyageWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"10. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	//Check that:
	// No errors
	//Voyage job, Road Release job, and both WLEs are completed.
	//Check that the cargo has ship receive transaction
	self.assertTrueMsg(roadWle.status = WLE_COMPLETED, "11. Road Wle not complete");
	self.assertTrueMsg(voyageWle.status = WLE_COMPLETED, "12. Voyage Wle not complete");
	self.assertTrueMsg(ti1.getTransReceive &lt;&gt; null, "13. No receipt transaction");
	self.assertTrueMsg(ti1.getTransRelease &lt;&gt; null, "14. No release transaction");
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	
	//Check that:
	// No errors
	//Check that the cargo has release transaction
	// Cargo is off site.
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"15. Truck failed to exit. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(ti1.isOnShip, "16. Cargo not on ship");
	
	//Create second job and plan cargo to the slot
	tier := 4;
	cell := 4;
	voyageJob := self.planLoadItemsPN( self.voyage, ti2, cell, tier );
	voyageWle := voyageJob.workListEntries.first().CM_VoyageWLE;
	
	//DO NOT Load the second job to operations
	//Gate in a truck with the 2nd prenote on board.
	vvr :=  self.gateInPrenote(TruckId, "", DriverId, ti2, dualGate);
	
	roadJob := ti2.jobRoadReceive;
	self.assertTrueMsg(roadJob &lt;&gt; null, "17. DD Road Receive Job not created");
	roadWle := roadJob.workListEntries.first;
	self.assertTrueMsg(voyageWle &lt;&gt; null, "18. DD Road Job has no WLE");
	voyageWle := voyageJob.workListEntries.first.CM_VoyageWLE;
	self.assertTrueMsg(voyageWle &lt;&gt; null, "19. DD Voyage Job has no WLE");
	
	self.moveTruckToInterchangeArea(truck);
	
	//Check that:
	//Transfer area is the Gate Trouble Area (because the voyage wle isn't loaded to ops yet.).
	
	self.assertTrueMsg(truck.myPrimaryActualLocation &lt;&gt; null, "20. Truck has no current location");
	self.assertTrueMsg(not truck.myPrimaryActualLocation.isKindOf(CM_CraneLaneController), "21. Truck should not be the in Crane transfer area");
	
	//Set up a move controller to do a real move using the voyage wle and call the move trx
	targetLoc := voyageWle.getTargetLocation();
	self.handHeldDirectDischargeTrx( ti2, targetLoc, voyageWle );
	
	//Check that:
	// No errors
	//Voyage job, Road Release job, and both WLEs are completed.
	//Check that the cargo has ship receive transaction
	//Vehicle Visit record includes the cargo 
	self.assertTrueMsg(roadWle.status = WLE_COMPLETED, "20. Road Wle not complete");
	self.assertTrueMsg(voyageWle.status = WLE_COMPLETED, "21. Voyage Wle not complete");
	self.assertTrueMsg(ti2.getTransReceive &lt;&gt; null, "22. No receipt transaction");
	self.assertTrueMsg(ti2.getTransRelease &lt;&gt; null, "23. No release transaction");
	self.assertTrueMsg(ti2.getTransReceiveFirst = ti2.getTransReceive, "23A. There should only be one receipt transaction");
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"24. Truck failed to exit");
	self.assertTrueMsg(ti2.isOnShip, "25. Cargo not on ship");
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.deleteVehicle(TruckId);
	self.deleteBooking(BookingId);

end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicDirectDeliveryShipToRail" id="ae780f88-468e-486a-84b4-a84b0000f38c">
        <source>tBasicDirectDeliveryShipToRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2013	cnwndl1	Initial creation	Par 31102

*/

constants

	TRAIN_CODE : String = "UT-TRAINDD";
	WAGON_CODE : String = "UK0110";
	RAIL_AREA_ID : String = "UT_RADD";
	
vars

	ti5 : CM_TrackedItem;
	ti6 : CM_TrackedItem;
	voyageJob : CM_VoyageJob;
	railJob : CM_RailJob;
	railWle : CM_WorkListEntry;
	voyageWle : CM_VoyageWLE;
	sourceLoc : CM_LocationsController;
	targetLoc : CM_LocationsController;
	wagon : CM_Wagon;
	isDoClearanceCheck : Boolean;
	
begin

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

	// Cleanup here
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	
	
	//Create container on a voyage and mark as direct delivery (DD).
	ti5 := self.createDDCargoOnShip(5);
	ti6 := self.createDDCargoOnShip(6);
	
	//Mark for discharge
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Create first job
	voyageJob := self.createDischargeJob(5);
	
	//Load the first job to operations
	self.loadVoyJobToOps(voyageJob, true, false);
	
	//Create Rail area and then arrive a Train with no cargo.
	wagon := createRailTrainAndWagon(WAGON_CODE,TRAIN_CODE,RAIL_AREA_ID, null, null);
	
	// mark cargo as release by train and assign and plan to train.
	self.assignCargoToTrain(wagon,ti5,1);	
	
	//Check that:
	//Rail release job exists and is planned but not queued 
	//RailWle records the slot as its source location
	railJob := ti5.jobRailRelease;
	self.assertTrueMsg(railJob &lt;&gt; null, "1. DD Rail Release Job not created");
	railWle := railJob.getWLEForTI(ti5);
	self.assertTrueMsg(railWle &lt;&gt; null, "2. DD Rail Release Job has no WLE");
	self.assertTrueMsg(not railWle.isQueued, "3. WLE for DD Rail Release Job should not be queued for a DD");
	voyageWle := voyageJob.workListEntries.first.CM_VoyageWLE;
	self.assertTrueMsg(voyageWle &lt;&gt; null, "4. DD Voyage Job has no WLE");
	self.assertTrueMsg(railWle.getSourceLocation() = voyageWle.getSourceLocation(), "5. DD Rail and Voyage WLE have different source locations");
	targetLoc := railWle.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "6. DD Rail WLE has not target location");
	
	
	//Set up a move controller to do a real move using the voyage wle and call the move trx
	self.handHeldDirectDischargeTrx( ti5, targetLoc, voyageWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"7. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	//Check that:
	// No errors
	//Voyage job, Road Release job, and both WLEs are completed.
	//Check that the cargo has ship receive transaction
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "8. Rail Wle not complete");
	self.assertTrueMsg(voyageWle.status = WLE_COMPLETED, "9. Voyage Wle not complete");
	self.assertTrueMsg(ti5.getTransReceive &lt;&gt; null, "10. No receipt transaction");
	
	//Second cargo will do the move from teh other WLE
	//Create second job
	voyageJob := self.createDischargeJob(6);
	
	//Load the second job to operations
	self.loadVoyJobToOps(voyageJob, true, false);
	
	// mark cargo as release by train and assign and plan to train.
	self.assignCargoToTrain(wagon,ti6,3);	
	
	
	railJob := ti6.jobRailRelease;
	self.assertTrueMsg(railJob &lt;&gt; null, "11. DD Rail Release Job not created");
	railWle := railJob.getWLEForTI(ti6);
	self.assertTrueMsg(voyageWle &lt;&gt; null, "12. DD Rail Job has no WLE");
	voyageWle := voyageJob.workListEntries.first.CM_VoyageWLE;
	self.assertTrueMsg(voyageWle &lt;&gt; null, "13. DD Voyage Job has no WLE");
	
	targetLoc := railWle.getTargetLocation();
	self.handHeldDirectDischargeTrx( ti6, targetLoc, voyageWle );
	
	//Check that:
	// No errors
	//Voyage job, Rail Release job, and both WLEs are completed.
	//Check that the cargo has ship receive transaction
	
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "14. Rail Wle not complete");
	self.assertTrueMsg(voyageWle.status = WLE_COMPLETED, "15. Voyage Wle not complete");
	self.assertTrueMsg(ti6.getTransReceive &lt;&gt; null, "16. No receipt transaction");
	self.assertTrueMsg(ti6.getTransReceiveFirst = ti6.getTransReceive, "16A. There should only be one receipt transaction");
	
	
	//Depart the Train.
	self.departTrainAndClearRake( wagon.myTrainInwards );
	
	self.assertTrueMsg(ti5.site = TI_SITE_OFFSITE, "17. " &amp; ti5.id &amp; " should be offsite after departure!");
	self.assertTrueMsg(ti6.site = TI_SITE_OFFSITE, "18. " &amp; ti6.id &amp; " should be offsite after departure!");
	self.assertTrueMsg(ti5.getTransRelease() &lt;&gt; null, "19. " &amp; ti5.id &amp; " no release trnsaction");
	self.assertTrueMsg(ti6.getTransRelease() &lt;&gt; null, "20. " &amp; ti6.id &amp; " no release trnsaction");
	self.checkTIForTxnOfType(ti5, TRANS_TYPE_REL_RAIL);
	self.checkTIForTxnOfType(ti6, TRANS_TYPE_REL_RAIL);
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	// Cleanup here too.
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicDirectDeliveryShipToRoad" id="9353da18-0b0b-4494-a804-3980a1e6f402">
        <source>tBasicDirectDeliveryShipToRoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwndl1	Initial creation	Par 31102

*/

constants

	TruckId : String = "UTDDTRUCK";
	DriverId : String = "UTDDDRIVER";
vars

	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	voyageJob : CM_VoyageJob;
	vvr : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
	roadWle : CM_WorkListEntry;
	voyageWle : CM_VoyageWLE;
	sourceLoc : CM_LocationsController;
	targetLoc : CM_LocationsController;
	truck : CM_Vehicle;
	isDoClearanceCheck : Boolean;

begin

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

	// Cleanup here
	deleteVehicle(TruckId);
	
	//Create container on a voyage and mark as direct delivery (DD).
	ti1 := self.createDDCargoOnShip(1);
	ti2 := self.createDDCargoOnShip(2);
	
	//Mark for discharge
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Create first job
	voyageJob := self.createDischargeJob(1);
	
	//Load the first job to operations
	self.loadVoyJobToOps(voyageJob, true, false);
	
	//Gate in an empty truck that wants to take out the DD Container related to job 1
	vvr := gateOutContainer(TruckId, "", DriverId, ti1.CM_Container, false, dualGate, null);
	
	//Check that:
	//Road release job exists and is planned but not queued 
	//RoadWle records the slot as its source location
	//Transfer area is the the crane transfer area of the crane related to the voyage job.
	roadJob := ti1.jobRoadRelease;
	self.assertTrueMsg(roadJob &lt;&gt; null, "1. DD Road Release Job not created");
	roadWle := roadJob.workListEntries.first;
	self.assertTrueMsg(roadWle &lt;&gt; null, "2. DD Road Release Job has no WLE");
	self.assertTrueMsg(not roadWle.isQueued, "3. WLE for DD Road Release Job should not be queued for a DD");
	voyageWle := voyageJob.workListEntries.first.CM_VoyageWLE;
	self.assertTrueMsg(voyageWle &lt;&gt; null, "4. DD Voyage Job has no WLE");
	self.assertTrueMsg(roadWle.getSourceLocation() = voyageWle.getSourceLocation(), "5. DD Road and Voyage WLE have different source locations");
	truck := vvr.vehicle;
	self.assertTrueMsg(truck &lt;&gt; null, "6. Truck not created");
	targetLoc := roadWle.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "7. DD Road WLE has not target location");
	
	
	//Move truck to yard and confirm that it goes to the crane transfer area.
	self.moveTruckToInterchangeArea(truck);
	self.assertTrueMsg(truck.myPrimaryActualLocation &lt;&gt; null, "8. Truck has no current location");
	self.assertTrueMsg(truck.myPrimaryActualLocation.isKindOf(CM_CraneLaneController), "9. Truck in Crane transfer area");
	
	//Set up a move controller to do a real move using the voyage wle and call the move trx
	self.handHeldDirectDischargeTrx( ti1, targetLoc, voyageWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"10. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	//Check that:
	// No errors
	//Voyage job, Road Release job, and both WLEs are completed.
	//Check that the cargo has ship receive transaction
	self.assertTrueMsg(roadWle.status = WLE_COMPLETED, "11. Road Wle not complete");
	self.assertTrueMsg(voyageWle.status = WLE_COMPLETED, "12. Voyage Wle not complete");
	self.assertTrueMsg(ti1.getTransReceive &lt;&gt; null, "13. No receipt transaction");
	
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	
	//Check that:
	// No errors
	//Check that the cargo has release transaction
	// Cargo is off site.
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"14. Truck failed to exit. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(ti1.isOffSite, "15. Cargo not off site");
	
	
	//Create cargo on ship, 
	//DO NOT Load the second job to operations
	//Gate in an empty truck that wants to take out the DD Container related to job 2
	voyageJob := self.createDischargeJob(2);
	vvr := gateOutContainer(TruckId, "", DriverId, ti2.CM_Container, false, dualGate, null);
	roadJob := ti2.jobRoadRelease;
	self.assertTrueMsg(roadJob &lt;&gt; null, "16. DD Road Release Job not created");
	roadWle := roadJob.workListEntries.first;
	self.assertTrueMsg(voyageWle &lt;&gt; null, "17. DD Road Job has no WLE");
	voyageWle := voyageJob.workListEntries.first.CM_VoyageWLE;
	self.assertTrueMsg(voyageWle &lt;&gt; null, "18. DD Voyage Job has no WLE");
	
	self.moveTruckToInterchangeArea(truck);
	
	//Check that:
	//Transfer area is the Gate Trouble Area (because the voyage wle isn't loaded to ops yet.).
	
	self.assertTrueMsg(truck.myPrimaryActualLocation &lt;&gt; null, "19. Truck has no current location");
	self.assertTrueMsg(not truck.myPrimaryActualLocation.isKindOf(CM_CraneLaneController), "20. Truck should not be the in Crane transfer area");
	
	//Load the second job to operations
	//Set up a move controller to do a real move using the voyage wle and call the move trx
	targetLoc := roadWle.getTargetLocation();
	self.handHeldDirectDischargeTrx( ti2, targetLoc, voyageWle );
	
	//Check that:
	// No errors
	//Voyage job, Road Release job, and both WLEs are completed.
	//Check that the cargo has ship receive transaction
	//Vehicle Visit record includes the cargo 
	self.assertTrueMsg(roadWle.status = WLE_COMPLETED, "21. Road Wle not complete");
	self.assertTrueMsg(voyageWle.status = WLE_COMPLETED, "22. Voyage Wle not complete");
	self.assertTrueMsg(ti2.getTransReceive &lt;&gt; null, "23. No receipt transaction");
	self.assertTrueMsg(ti2.getTransReceiveFirst = ti2.getTransReceive, "23A. There should only be one receipt transaction");
	
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"24. Truck failed to exit. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(ti1.getTransRelease &lt;&gt; null, "25. No release transaction");
	self.assertTrueMsg(ti2.getTransRelease &lt;&gt; null, "26. No release transaction");
	self.assertTrueMsg(ti1.isOffSite, "27. Cargo not off site");
	self.assertTrueMsg(ti2.isOffSite, "28. Cargo not off site");


epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	// Cleanup here too.
	deleteVehicle(TruckId);

end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicDirectDeliveryShipToShip" id="27c1f666-a9fc-47fd-9a22-b2c400d09a77">
        <source>tBasicDirectDeliveryShipToShip();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2013	cnwndl1	Initial creation	Par 31102
// 10 Sep 2019	cnwrs1	TFS 46030
*/

constants

	VoyageOutCode : String = "UTVOY1DD";
	
vars

	voyageOut : CM_Voyage;
	ti3 : CM_TrackedItem;
	ti4 : CM_TrackedItem;
	
	voyageJobIn : CM_VoyageJob;
	voyageJobOut : CM_VoyageJob;
	voyageWleIn : CM_WorkListEntry;
	voyageWleOut : CM_WorkListEntry;
	cell : Integer;
	tier : Integer;
	targetLoc : CM_LocationsController;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	//create out bound voyage.
	voyageOut := self.createOutwardVoyage( VoyageOutCode &amp; self.getProfileStr(UT_Profile.P_INITIAL) );
	
	//Create container on the inward voyage and mark as direct delivery (DD).
	ti3 := self.createDDCargoOnShip(3);
	ti4 := self.createDDCargoOnShip(4);
	
	//mark cargo as tranships going to the out bound voyage.
	self.setCargoAsTranshipTo( ti3, voyageOut );
	self.setCargoAsTranshipTo( ti4, voyageOut );
	
	self.deleteStops(ti3);
	self.deleteStops(ti4);
	
	//Mark for discharge
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//First job processed from the DISCHARGE end.....
	//Create first discharge job
	voyageJobIn := self.createDischargeJob(3);
	self.assertTrueMsg(voyageJobIn &lt;&gt; null, "1. DD Discharge Job not created");
	voyageWleIn := voyageJobIn.workListEntries.first;
	self.assertTrueMsg(voyageWleIn &lt;&gt; null, "2. DD Discharge Job has no WLE");
	
	//Load the first discharge job to operations
	self.loadVoyJobToOps(voyageJobIn, true, false);
	
	
	//Create load jobs for the first container
	//And plan it to the slot
	tier := 1;
	cell := 4;
	voyageJobOut := self.planLoadItemsPN( voyageOut, ti3, cell, tier );
	
	self.assertTrueMsg(voyageJobOut &lt;&gt; null, "3. DD Load Job not created");
	voyageWleOut := voyageJobOut.workListEntries.first().CM_VoyageWLE;
	self.assertTrueMsg(voyageWleOut &lt;&gt; null, "4. DD Load Job has no WLE");
	
	
	//Load first job to operations
	self.loadVoyJobToOps(voyageJobOut, true, true);
	
	//Check that:
	//Voyage jobs exist and are planned but not queued 
	self.assertTrueMsg(not voyageWleIn.isQueued, "5. WLE for DD Discharge Job should not be queued for a DD");
	self.assertTrueMsg(not voyageWleOut.isQueued, "6. WLE for DD Discharge Job should not be queued for a DD");
	self.assertTrueMsg(voyageWleIn.getSourceLocation() = voyageWleOut.getSourceLocation(), "7. DD Voyage WLEs have different source locations");
	targetLoc := voyageWleOut.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "8. DD Voyage WLE has no target location");
	
	//Set up a move controller to do a real move using the "voyage In wle" and call the move trx
	self.handHeldDirectDischargeTrx( ti3, targetLoc, voyageWleIn );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"9. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	
	//Check that:
	// No errors
	// Both  WLEs are completed.
	//Check that the cargo has ship receive transaction
	self.assertTrueMsg(voyageWleIn.status = WLE_COMPLETED, "10. Discharge Wle not complete");
	self.assertTrueMsg(voyageWleOut.status = WLE_COMPLETED, "11. Load Wle not complete");
	self.assertTrueMsg(ti3.getTransReceive &lt;&gt; null, "12. No receipt transaction");
	self.assertTrueMsg(ti3.getTransRelease &lt;&gt; null, "13. No release transaction");
	

	//Second job processed from the LOAD end.....
	//Create second discharge job
	voyageJobIn := self.createDischargeJob(4);
	self.assertTrueMsg(voyageJobIn &lt;&gt; null, "14. DD Discharge Job not created");
	voyageWleIn := voyageJobIn.workListEntries.first;
	self.assertTrueMsg(voyageWleIn &lt;&gt; null, "15. DD Discharge Job has no WLE");
	
	//Load the second discharge job to operations
	self.loadVoyJobToOps(voyageJobIn, true, false);
	
	
	//Create load jobs for the second container
	//And plan it to the slot
	tier := 2;
	cell := 4;
	voyageJobOut := self.planLoadItemsPN( voyageOut, ti4, cell, tier );
	
	self.assertTrueMsg(voyageJobOut &lt;&gt; null, "16. DD Load Job not created");
	voyageWleOut := voyageJobOut.workListEntries.first().CM_VoyageWLE;
	self.assertTrueMsg(voyageWleOut &lt;&gt; null, "17. DD Load Job has no WLE");
	
	
	//Load second job to operations
	self.loadVoyJobToOps(voyageJobOut, true, true);
	
	//Check that:
	//voyage jobs exist and are planned but not queued 
	
	self.assertTrueMsg(not voyageWleIn.isQueued, "18. WLE for DD Discharge Job should not be queued for a DD");
	self.assertTrueMsg(not voyageWleOut.isQueued, "19. WLE for DD Discharge Job should not be queued for a DD");
	self.assertTrueMsg(voyageWleIn.getSourceLocation() = voyageWleOut.getSourceLocation(), "20. DD Voyage WLE have different source locations");
	targetLoc := voyageWleOut.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "21. DD Voyage WLE has no target location");
	
	//Set up a move controller to do a real move using the voyage OUT wle and call the move trx
	self.handHeldDirectDischargeTrx( ti4, targetLoc, voyageWleOut );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"22. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	
	//Check that:
	// No errors
	// Both  WLEs are completed.
	//Check that the cargo has ship receive transaction
	self.assertTrueMsg(voyageWleIn.status = WLE_COMPLETED, "23. Discharge Wle not complete");
	self.assertTrueMsg(voyageWleOut.status = WLE_COMPLETED, "24. Load Wle not complete");
	self.assertTrueMsg(ti4.getTransReceive &lt;&gt; null, "25. No receipt transaction");
	self.assertTrueMsg(ti4.getTransRelease &lt;&gt; null, "26. No release transaction");
	self.assertTrueMsg(ti4.getTransReceiveFirst = ti4.getTransReceive, "26A. There should only be one receipt transaction");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	// Cleanup here
	self.deleteVoyage(VoyageOutCode);

end;</source>
    </JadeMethod>
    <JadeMethod name="tDDShipToRoadAndRejectOne" id="6c590332-1fdd-492b-a3d8-ed2916488f0c">
        <source>tDDShipToRoadAndRejectOne();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2013	cnwndl1	Initial creation	Par 31102

*/

constants

	TruckId : String = "UTDDTRUCK";
	DriverId : String = "UTDDDRIVER";
vars

	ti11 : CM_TrackedItem;
	voyageJob : CM_VoyageJob;
	vvr : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
	roadWle : CM_WorkListEntry;
	voyageWle : CM_VoyageWLE;
	sourceLoc : CM_LocationsController;
	targetLoc : CM_LocationsController;
	truck : CM_Vehicle;
	tier : Integer;
	cell : Integer;
	isDoClearanceCheck : Boolean;

begin

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

	// Cleanup here
	deleteVehicle(TruckId);
	
	//Create container on a voyage and mark as direct delivery (DD).
	ti11 := self.createDDCargoOnShip(11);
	
	//Mark for discharge
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Create first job
	voyageJob := self.createDischargeJob(11);
	
	//Load the first job to operations
	self.loadVoyJobToOps(voyageJob, true, false);
	
	//Gate in an empty truck that wants to take out the DD Container related to job 1
	vvr := gateOutContainer(TruckId, "", DriverId, ti11.CM_Container, false, dualGate, null);
	
	//Check that:
	//Road release job exists and is planned but not queued 
	//RoadWle records the slot as its source location
	//Transfer area is the the crane transfer area of the crane related to the voyage job.
	roadJob := ti11.jobRoadRelease;
	self.assertTrueMsg(roadJob &lt;&gt; null, "1. DD Road Release Job not created");
	roadWle := roadJob.workListEntries.first;
	self.assertTrueMsg(roadWle &lt;&gt; null, "2. DD Road Release Job has no WLE");
	self.assertTrueMsg(not roadWle.isQueued, "3. WLE for DD Road Release Job should not be queued for a DD");
	voyageWle := voyageJob.workListEntries.first.CM_VoyageWLE;
	self.assertTrueMsg(voyageWle &lt;&gt; null, "4. DD Voyage Job has no WLE");
	self.assertTrueMsg(roadWle.getSourceLocation() = voyageWle.getSourceLocation(), "5. DD Road and Voyage WLE have different source locations");
	truck := vvr.vehicle;
	self.assertTrueMsg(truck &lt;&gt; null, "6. Truck not created");
	targetLoc := roadWle.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "7. DD Road WLE has not target location");
	
	
	//Set up a move controller to do a real move using the voyage wle and call the move trx
	self.handHeldDirectDischargeTrx( ti11, targetLoc, voyageWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"8. Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	//Check that:
	// No errors
	//Voyage job, Road Release job, and both WLEs are completed.
	//Check that the cargo has ship receive transaction
	self.assertTrueMsg(roadWle.status = WLE_COMPLETED, "9. Road Wle not complete");
	self.assertTrueMsg(voyageWle.status = WLE_COMPLETED, "10. Voyage Wle not complete");
	self.assertTrueMsg(ti11.getTransReceive &lt;&gt; null, "11. No receipt transaction");
	self.assertTrueMsg(ti11.myPrimaryActualLocation = truck.locationsController, "12. Cargo not on Truck");
	
	//**************************************************
	//"We are going to reject and turn the cargo around"
	//**************************************************
	
	//Change the cargo to be an export, targetting another destination on the voyage.
	self.opts.purge();
	self.opts.addAssoc('IMEXStatus', TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc(UTTI_DischargePort, app.myRoot.allPorts["NZAKL"].code);
	self.updateTI(ti11);
	self.assertTrueMsg(ti11.isExport, "13. Not an Export");
	self.assertTrueMsg(ti11.dischargePort = app.myRoot.allPorts["NZAKL"].code, "14. Return Port not set");
	
	//Plan a Load job to the Voyage for the "rejected" cargo and Load the job to ops.
	tier := 1;
	cell := 2;
	voyageJob := self.planLoadItemsPN( self.voyage, ti11, cell, tier );
	voyageWle := voyageJob.workListEntries.first().CM_VoyageWLE;
	targetLoc := voyageWle.getTargetLocation();
	
	//Move the cargo
	self.handHeldDirectDischargeTrx( ti11, targetLoc, voyageWle );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"15. Move back to Ship failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	self.assertTrueMsg(ti11.getTransRelease &lt;&gt; null, "16. No release transaction back to the ship");
	self.assertTrueMsg(ti11.isOnShip, "17. Cargo is not 'on ship'");
	self.assertTrueMsg(ti11.myPrimaryActualLocation.isKindOf(CM_VoyageController), "18. Cargo not on a voyage controller");
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"19. Truck failed to exit. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	

epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	// Cleanup here too.
	deleteVehicle(TruckId);

end;</source>
    </JadeMethod>
    <JadeMethod name="tDirectReleaseHoldVoyRail" id="77e1dae5-f1cf-4458-ad2b-a8a670e64f52">
        <source>tDirectReleaseHoldVoyRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 August 2019		jlgzm1	TFS 42872 Direct Release Between HOLD Voyages and Rail
13 June 2019		jlgndl1	Initial creation
17 Mar 2025			jlizm1	Unit test failing overnight only
*/

constants
	
	VesselCode 		: String = 'SCONRO';
	Voyagecode 		: String = 'DRCONRO';
	
	TrainCodeIn 	: String = "DRTRAIN5";
	TrainCodeOut 	: String = "DRTRAIN6";

	WagonIdInFC 	: String = "UTFC51";// Flat-car - see class constants
	WagonIdInBC 	: String = "UTBC52";// Box-car
	WagonIdInBC2 	: String = "UTBC53";// Box-car
	WagonIdInBC3 	: String = "UTBC54";// Box-car
	WagonIdOutFC 	: String = "UTFC61";// Flat-car - see class constants
	WagonIdOutBC1 	: String = "UTBC62";// Box-car
	WagonIdOutBC2 	: String = "UTBC63";// Box-car
	WagonIdOutBC3 	: String = "UTBC64";// Box-car
	
	BBULKCargoType 	: String = "UTREBAR";  // Pre existing Break Bulk cargo type allows duplicates
	BULKCargoType 	: String = "UTDRBULK"; //new bulk cargo type for test
	
	//Hold To Rail
	ContIdHR 		: String = "DRHR0007001";
	ContIdHR2 		: String = "DRHR0007002";
	BBIdHR 			: String = "DRHR0006001";
	BulkIdHR 		: String = "DRHR0006002";
	
	//Rail To Hold
	ContIdRH 		: String = "DRRH0007003";
	ContIdRH2 		: String = "DRRH0007004";
	BBIdRH 			: String = "DRRH0006003";
	BBIdRH2 		: String = "DRRH0006004";
	BulkIdRH 		: String = "DRHR0006005";
	
	DRWorkPoint 	: String = "DRWP";
	
	// Machines
	IMV1 	= "UTIM";
	STRA1	= "USTL";
	
vars
	operator 		: CM_Operator;
	shipLineStr 	: String;
	voyage 			: CM_Voyage;
	
	railArea 		: CM_Rail;

	trainIn 		: CM_Train;
	trainOut 		: CM_Train;
	wagon 			: CM_Wagon;
	wagon2 			: CM_Wagon;
	wagon3 			: CM_Wagon;
	wagonBCOut1 	: CM_Wagon;
	wagonBCOut2 	: CM_Wagon;
	wagonBCOut3 	: CM_Wagon;
	wagonFCOut 		: CM_Wagon;
	
	//Hold -&gt; Rail
	bbHR 			: CM_BreakBulkGeneric;
	bulkHR 			: CM_Bulk;
	contHR 			: CM_Container;
	contHR2 		: CM_Container;
	
	//Rail -&gt; Hold
	bbRH 			: CM_BreakBulkGeneric;
	bbRH2 			: CM_BreakBulkGeneric;
	bulkRH 			: CM_Bulk;
	contRH 			: CM_Container;
	contRH2 		: CM_Container;
	
	bbCargoType 	: CM_CargoType;
	contCargoType 	: CM_CargoType;
	bulkCargoType 	: CM_CargoType;

	importHold 		: CM_LocationsController;
	exportHold 		: CM_LocationsController;
	railLC 			: CM_LocationsController;
	
	dischJob1		: CM_VoyageHoldJob;
	dischJob2		: CM_VoyageHoldJob;
	loadJob1		: CM_VoyageHoldJob;
	loadJob2		: CM_VoyageHoldJob;
	job				: CM_Job;
	railJobs 		: CM_JobArray;
	allocatedWLEs 	: CM_WLEArray;
	tmpVWle			: CM_VoyageWLE;
	wle				: CM_WorkListEntry;
	workPoint 		: CM_WorkPoint;
	tas				: StringArray;
	loadWleSet		: CM_WLESet;
	tiTrx 			: CM_TITransaction;
	linkedDRWle		: CM_WorkListEntry;
	ti				: CM_TrackedItem;
	allTis			: CM_TISet;
begin
	//get base data
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	
	self.opts.purge();
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	bulkCargoType := addCargoType(BULKCargoType, false);
	self.opts.purge();
	
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBULKCargoType &amp; "' not found during setup.");
	
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg(contCargoType &lt;&gt; null, "Container Cargo Type not found during setup.");
	
	///************************
	//clean-up old data - if it exists
	//*************************
	self.deleteVoyage(Voyagecode);
	
	self.deleteContainer( ContIdHR );
	self.deleteContainer( ContIdRH );
	self.deleteContainer( ContIdHR2 );
	self.deleteContainer( ContIdRH2 );
	self.deleteCargo( BBIdHR, bbCargoType );
	self.deleteCargo( BBIdRH, bbCargoType );
	self.deleteCargo( BBIdRH2, bbCargoType );
	self.deleteCargo( BulkIdHR, bulkCargoType );
	self.deleteCargo( BulkIdRH, bulkCargoType );
		
	usetupDRWagonClasses( false );  //delete and re setup wagon classes ( delete does wagons and wagon masters too )
	
	self.deleteTrain(TrainCodeIn,null);
	self.deleteTrain(TrainCodeOut,null);
	
	self.deleteRailArea(RailAreaId);
	
	app.myPassport.setWarningsIgnored(false);

	//create new base data
	//Voyage and its import cargo
	voyage := self.addVoyageWithConRORO(Voyagecode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	importHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	exportHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.last;
	assertNotNullMsg(importHold, "Voyage doesn't have any holds");
	assertNotEqualMsg(exportHold, importHold, "Voyage doesn't have enough holds");
	
	create allTis transient;
	//********************
	//CREATE CARGO ON SHIP
	//********************
	bbHR := self.addCargoBreakBulkAtLocation(BBIdHR, bbCargoType, 80, importHold, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bbHR &lt;&gt; null, "'" &amp; BBIdHR &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80000);
	self.updateTI( bbHR );
	allTis.add(bbHR);
	self.opts.purge();
	
	bulkHR := self.addCargoBreakBulkAtLocation(BulkIdHR, bulkCargoType, 1, importHold, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_Bulk;
	self.assertTrueMsg(bulkHR &lt;&gt; null, "'" &amp; BulkIdHR &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 40000);
	self.updateTI( bulkHR );
	allTis.add(bulkHR);
	self.opts.purge();
	
	contHR := self.addContainerAtLocation(ContIdHR, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, importHold);
	self.assertTrueMsg(contHR &lt;&gt; null, "'" &amp; ContIdHR &amp; "' on ship cargo not created during setup");
	allTis.add(contHR);
	
	//contHR.inspect;
	contHR2 := self.addContainerAtLocation(ContIdHR2, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, importHold);
	self.assertTrueMsg(contHR2 &lt;&gt; null, "'" &amp; ContIdHR2 &amp; "' on ship cargo not created during setup");
	allTis.add(contHR2);
	
	//***************
	//Initialise Rail
	//***************
	railArea := self.addRailArea(RailAreaId, 2, 5); // 2 rail lines, 5 spaces
	self.assertTrueMsg(railArea &lt;&gt; null, "Rail Area '" &amp; RailAreaId &amp; "' not created during setup.");
	
	//Inwards train with its wagons and the export cargo for the voyage.
	trainIn := self.addTrain(TrainCodeIn,null);
	self.assertTrueMsg(trainIn &lt;&gt; null, "'Train in' not created during setup");
	
	self.opts.addAssoc("RailLine", railArea.allRailLines.first); // inward train wagons first line of two
	wagon := self.addWagonInRailArea(WagonIdInFC, WagonClassFC, railArea, trainIn);
	self.assertTrueMsg(wagon &lt;&gt; null, "'" &amp; WagonIdInFC &amp; "' flat car not created on 'train in' during setup");
	
	
	//********************
	//CREATE CARGO ON RAIL
	//********************
	// FLATCAR 1
	contRH := self.addRailPreNote( wagon.id, wagon.myWagonClass.code, ContIdRH ).CM_Container;
	self.assertTrueMsg(contRH &lt;&gt; null, "'" &amp; ContIdRH &amp; "' not created during setup");
	allTis.add(contRH);

	contRH2 := self.addRailPreNote( wagon.id, wagon.myWagonClass.code, ContIdRH2 ).CM_Container;
	self.assertTrueMsg(contRH2 &lt;&gt; null, "'" &amp; ContIdRH2 &amp; "' not created during setup");
	allTis.add(contRH2);

	beginTransaction;
	contRH.setImExStatus(TI_IMEX_STATUS_EXPORT);
	contRH.setMyVoyage(voyage, app.myPassport);
	contRH2.setImExStatus(TI_IMEX_STATUS_EXPORT);
	contRH2.setMyVoyage(voyage, app.myPassport);
	commitTransaction;

	//BOXCAR 1
	wagon := self.addWagonInRailArea(WagonIdInBC, WagonClassBC, railArea, trainIn);
	self.assertTrueMsg(wagon &lt;&gt; null, "'" &amp; WagonIdInBC &amp; "' box car not created on 'train in' during setup");
	self.opts.purge();
	self.opts.addAssoc("CargoType", bbCargoType.id);
	self.opts.addAssoc("Wagon", wagon);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 40.Integer );
	bbRH := self.addPrenoted( BBIdRH ).CM_BreakBulkGeneric;
	self.opts.purge();
	self.assertTrueMsg(bbRH &lt;&gt; null, "'" &amp; BBIdRH &amp; "' not created during setup");
	allTis.add(bbRH);
	
	//BOXCAR 2
	self.opts.addAssoc("RailLine", railArea.allRailLines.first); // inward train wagons first line of two
	wagon2 := self.addWagonInRailArea(WagonIdInBC2, WagonClassBC, railArea, trainIn);
	self.assertTrueMsg(wagon2 &lt;&gt; null, "'" &amp; WagonIdInBC2 &amp; "' box car not created on 'train in' during setup");
	self.opts.purge();
	self.opts.addAssoc("CargoType", bbCargoType.id);
	self.opts.addAssoc("Wagon", wagon2);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 40.Integer );
	bbRH2 := self.addPrenoted( BBIdRH2 ).CM_BreakBulkGeneric;
	self.opts.purge();
	self.assertTrueMsg(bbRH2 &lt;&gt; null, "'" &amp; BBIdRH2 &amp; "' not created during setup");
	allTis.add(bbRH2);
	
	//BOXCAR 3
	self.opts.addAssoc("RailLine", railArea.allRailLines.first); // inward train wagons first line of two
	wagon3 := self.addWagonInRailArea(WagonIdInBC3, WagonClassBC, railArea, trainIn);
	self.assertTrueMsg(wagon3 &lt;&gt; null, "'" &amp; WagonIdInBC3 &amp; "' box car not created on 'train in' during setup");
	self.opts.purge();
	self.opts.addAssoc("CargoType", bulkCargoType.id);
	self.opts.addAssoc("Wagon", wagon3);
	self.opts.addAssoc("ExportVoyage", voyage);
	//self.opts.addAssoc("TotalQuantity", 40.Integer );
	self.opts.addAssoc("TotalWeight", 40000);
	bulkRH := self.addPrenoted( BulkIdRH ).CM_Bulk;
	self.opts.purge();
	self.assertTrueMsg(bulkRH &lt;&gt; null, "'" &amp; BulkIdRH &amp; "' not created during setup");
	allTis.add(bulkRH);
	
	//*******************************
	// Outwards train with its wagons ( for the imported voyage cargo )
	//*******************************
	self.opts.purge();
	
	trainOut := self.addTrain(TrainCodeOut,null);
	self.assertTrueMsg(trainIn &lt;&gt; null, "'Train out' not created during setup");
	self.opts.addAssoc("RailLine", railArea.allRailLines.last); // outward train wagons the second line of two
	wagonFCOut := self.addWagonInRailArea(WagonIdOutFC, WagonClassFC, railArea, trainOut);
	self.assertTrueMsg(wagonFCOut &lt;&gt; null, "'" &amp; WagonIdOutFC &amp; "' flat car not created on 'train out' during setup");	
	wagonBCOut1 := self.addWagonInRailArea(WagonIdOutBC1, WagonClassBC, railArea, trainOut);
	self.assertTrueMsg(wagonBCOut1 &lt;&gt; null, "'" &amp; WagonIdOutBC1 &amp; "' box car not created on 'train out' during setup");
	wagonBCOut2 := self.addWagonInRailArea(WagonIdOutBC2, WagonClassBC, railArea, trainOut);
	self.assertTrueMsg(wagonBCOut2 &lt;&gt; null, "'" &amp; WagonIdOutBC2 &amp; "' box car not created on 'train out' during setup");
	wagonBCOut3 := self.addWagonInRailArea(WagonIdOutBC3, WagonClassBC, railArea, trainOut);
	self.assertTrueMsg(wagonBCOut3 &lt;&gt; null, "'" &amp; WagonIdOutBC3 &amp; "' box car not created on 'train out' during setup");
	self.opts.purge();
	
	//**************************
	//now make both trains arrive
	//**************************
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, trainIn, false, app.myPassport);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, trainOut, false, app.myPassport);

	//clear any stops, and unplan any potential auto plans
	foreach ti in allTis do
		self.deleteStops(ti);
		self.unqueueTI(ti);
		self.unplanTI(ti);
	endforeach; 
	
	//**************
	//Setup Machines
	//**************
	workPoint := self.getWorkpoint(DRWorkPoint);
	railLC := railArea.getLocationsController;

	//***********************
	//Create Voyage Hold Jobs
	//***********************
	
	//Discharge Job 1
	//1 container, 11 of 80 Break-bulk
	create allocatedWLEs transient;
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(contHR);
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bbHR);
	tmpVWle.setQuantity(11);
	dischJob1 := self.addVoyageHoldJob(JOB_TYPE_DISCHARGE, voyage, allocatedWLEs, railLC, workPoint);
	self.assertNotNullMsg(dischJob1, "Discharge job 1 not creted");
	self.assertEqualMsg(dischJob1.workListEntries.size, 2, "Disc Job 1 wrong number of WLEs");
	
	//Discharge Job 2
	//1 container, 69 of 80 break-bulk, total Bulk
	allocatedWLEs.purge();
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(contHR2);
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bbHR);
	tmpVWle.setQuantity(bbHR.totalQuantity - 11);
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bulkHR);
	tmpVWle.setWeight(bulkHR.totalWeight);
	dischJob2 := self.addVoyageHoldJob(JOB_TYPE_DISCHARGE, voyage, allocatedWLEs, railLC, workPoint);
	self.assertNotNullMsg(dischJob2, "Discharge job 2 not creted");
	self.assertEqualMsg(dischJob2.workListEntries.size, 3, "Disc Job 2 wrong number of WLEs");
	
	//Load Job 1
	//1 container, 40 of 40 break-bulk, 12 of 40 break-bulk, 500Kg of 2000Kg Bulk
	allocatedWLEs.purge();
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(contRH);
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bbRH);
	tmpVWle.setQuantity(bbRH.totalQuantity);
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bbRH2);
	tmpVWle.setQuantity(12);
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bulkRH);
	tmpVWle.setWeight(500);
	loadJob1 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, exportHold, workPoint);
	self.assertNotNullMsg(loadJob1, "Load job 1 not creted");
	self.assertEqualMsg(loadJob1.workListEntries.size, 4, "Load Job 1 wrong number of WLEs");
	
	//Load Job 2
	//1 container, 28 of 40 break-bulk, 1500Kg of 2000Kg Bulk
	allocatedWLEs.purge();
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(contRH2);
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bbRH2);
	tmpVWle.setQuantity(bbRH2.totalQuantity - 12);
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bulkRH);
	tmpVWle.setWeight(bulkRH.totalWeight - 500);
	loadJob2 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, exportHold, workPoint);
	self.assertNotNullMsg(loadJob2, "Load job 2 not creted");
	self.assertEqualMsg(loadJob2.workListEntries.size, 3, "Load Job 2 wrong number of WLEs");
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
	
	//*****************************
	//Assign Jobs to Direct Release
	//*****************************
	create railJobs transient;
	create loadWleSet transient;
	loadJob1.workListEntries.copy(loadWleSet);
	loadJob2.workListEntries.copy(loadWleSet);
	
	app.myTrxUA.trxUpdateWLEsSetDirectRelease(loadWleSet, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to assign to direct release");
	
	foreach wle in loadWleSet do
		linkedDRWle := wle.getDRLinkedWLE();
		if linkedDRWle &lt;&gt; null then
			railJobs.add(linkedDRWle.job);
		endif;
	
	endforeach;
	
	foreach wle in dischJob1.workListEntries do
		app.myPassport.setWarningsIgnored(false);
		if wle.myTrackedItem = contHR then
			self.assignWLEToTrainDR(wle, 0, 0, wagonFCOut, 1);
		elseif wle.myTrackedItem = bbHR then
			self.assignWLEToTrainDR(wle, wle.quantity, wle.weight, wagonBCOut1, 1);
		endif;
		linkedDRWle := wle.getDRLinkedWLE();
		if linkedDRWle &lt;&gt; null then
			railJobs.add(linkedDRWle.job);
		endif;
	endforeach;
	
	foreach wle in dischJob2.workListEntries do
		if wle.myTrackedItem = contHR2 then
			self.assignWLEToTrainDR(wle, 0, 0, wagonFCOut, 3);
		elseif wle.myTrackedItem = bbHR then
			self.assignWLEToTrainDR(wle, wle.quantity, wle.weight, wagonBCOut2, 1);
		elseif wle.myTrackedItem = bulkHR then
			self.assignWLEToTrainDR(wle, wle.quantity, wle.weight, wagonBCOut3, 1);
		endif;
		
		linkedDRWle := wle.getDRLinkedWLE();
		if linkedDRWle &lt;&gt; null then
			railJobs.add(linkedDRWle.job);
		endif;
	endforeach;
	
	//**********
	//Move Cargo
	//**********
	foreach wle in loadWleSet do
		self.handHeldDirectDischargeTrx(wle.myTrackedItem, wle.getTargetLocation, wle);
		ti := wle.myTrackedItem;
		self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to move [" &amp; ti.id &amp; "]: " &amp; app.myPassport.getErrorsAsString());
		tiTrx := ti.getLastTransOfClass( CM_Move );	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " move transaction not found." );	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " move transaction not marked as Direct Release." &amp; CrLf &amp; self.listAllTransactions(ti));	//10 Sep 2019	NDL	TFS 42882
		tiTrx := ti.getTransRelease;	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " release transaction not found." );	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " release transaction not marked as Direct Release." &amp; CrLf &amp; self.listAllTransactions(ti));	//10 Sep 2019	NDL	TFS 42882
	endforeach;
	
	foreach wle in dischJob1.workListEntries do
		self.handHeldDirectDischargeTrx(wle.myTrackedItem, wle.getTargetLocation, wle);
		ti := wle.myTrackedItem;
		self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to move [" &amp; ti.id &amp; "]: " &amp; app.myPassport.getErrorsAsString());
		tiTrx := ti.getLastTransOfClass( CM_Move );	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " move transaction not found." );	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " move transaction not marked as Direct Release." &amp; CrLf &amp; self.listAllTransactions(ti));	//10 Sep 2019	NDL	TFS 42882
		tiTrx := ti.getTransReceive;	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " receive transaction not found." );	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " receive transaction not marked as Direct Release." &amp; CrLf &amp; self.listAllTransactions(ti));	//10 Sep 2019	NDL	TFS 42882
	endforeach;
	
	foreach wle in dischJob2.workListEntries do
		self.handHeldDirectDischargeTrx(wle.myTrackedItem, wle.getTargetLocation, wle);
		ti := wle.myTrackedItem;
		self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to move [" &amp; ti.id &amp; "]: " &amp; app.myPassport.getErrorsAsString());
		tiTrx := ti.getLastTransOfClass( CM_Move );	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " move transaction not found." );	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " move transaction not marked as Direct Release." &amp; CrLf &amp; self.listAllTransactions(ti));	//10 Sep 2019	NDL	TFS 42882
		tiTrx := ti.getTransReceive;	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " receive transaction not found." );	//10 Sep 2019	NDL	TFS 42882
		self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " receive transaction not marked as Direct Release." &amp; CrLf &amp; self.listAllTransactions(ti));	//10 Sep 2019	NDL	TFS 42882
	endforeach;
	
	//***************************
	//Check all Jobs are complete
	//***************************
	self.assertEqualMsg(dischJob1.status, JOB_COMPLETE, "Job not complete");
	self.assertEqualMsg(dischJob2.status, JOB_COMPLETE, "Job not complete");
	self.assertEqualMsg(loadJob1.status, JOB_COMPLETE, "Job not complete");
	self.assertEqualMsg(loadJob2.status, JOB_COMPLETE, "Job not complete");
	foreach job in railJobs do
		self.assertEqualMsg(job.status, JOB_COMPLETE, "Job not complete");
	endforeach;
	
	//******************************
	// all finished, now clean - up
	//******************************
	//return
	self.deleteVoyage(Voyagecode);
	
	self.deleteContainer( ContIdHR );
	self.deleteContainer( ContIdRH );
	self.deleteContainer( ContIdHR2 );
	self.deleteContainer( ContIdRH2 );
	self.deleteCargo( BBIdHR, bbCargoType );
	self.deleteCargo( BBIdRH, bbCargoType );
	self.deleteCargo( BBIdRH2, bbCargoType );
	self.deleteCargo( BulkIdHR, bulkCargoType );
	self.deleteCargo( BulkIdRH, bulkCargoType );
	
	usetupDRWagonClasses( true );  //delete only
	
	self.deleteTrain(TrainCodeIn,null);
	self.deleteTrain(TrainCodeOut,null);
	
	self.deleteRailArea(RailAreaId);
	self.deleteCargoType(BULKCargoType);
	
epilog
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
	if allocatedWLEs &lt;&gt; null then
		beginTransaction;
		allocatedWLEs.purge();
		commitTransaction;
	endif;
	delete loadWleSet;
	delete allocatedWLEs;
	delete tas;
	delete railJobs;
	delete allTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDirectReleaseRailToShip" id="51c92e7e-ce5a-4430-99a4-1aa31327d7df">
        <updating/>
        <source>tDirectReleaseRailToShip() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2019	jlgzm1	Initial creation

*/

constants
	BookingId : String = "DRBOOKING";
	VoyageName 		= 'UTDRVOY1';
	ShipName 		= 'UTDRVES1';
	TestOperator	= 'MSK';
	CraneTransferAreaId	= "UTDRCT";
	IMV1 	= "UTIM";
	STRA1	= "USTL";
	CONT1 	= "UTDR0000001";
	CONT2 	= "UTDR0000002";
	CONT3 	= "UTDR0000003";
	CONT4 	= "UTDR0000004";
	CONT5 	= "UTDR0000005";
	TRAIN_CODE 		: String = "UT-TRAINDR";
	WAGON_CODE 		: String = "UK0115";
	RAIL_AREA_ID 	: String = "ZPO8463";

vars
	cta				: CM_CraneTransferArea;
	rail			: CM_Rail;
	tas				: StringArray;
	vessel 			: CM_Vessel;
	voyage 			: CM_Voyage;
	queue			: CM_VoyageQueue;
	rampQueue		: CM_VoyageCraneQueue;
	queueEntry		: CM_RTQueueEntry;
	queuetask		: CM_RTQueueTask;
	cargo1, cargo2, cargo3,
	cargo4,cargo5	: CM_TrackedItem;
	crane			: CM_Machine;
	imv				: CM_Machine;
	straddle		: CM_Machine;
	wagon 			: CM_Wagon;
	vjob, vjob2		: CM_VoyageJob;
	railJob 		: CM_RailJob;
	railWle 		: CM_WorkListEntry;
	vwle1,vwle2, vwle3	: CM_VoyageWLE;
	targetLoc 		: CM_LocationsController;
	agent 			: CMIF_MobileGenericAgent;
	result			: Boolean;
	rule 			: CM_RTQueueMultiRuleTAMaster;
	tmpCTA, tmpRTA 	: CM_TerminalArea;
	ctaType, rtaType : CM_TerminalAreaType;
	booking 		: CM_BookingRef;
	oldConfig		: Boolean;
	oper 			: CM_Operator;
	cell, tier 		: Integer;
	wleArray,
	wlesWithWarnings : CM_WLEArray;	
	tiTrx 			: CM_TITransaction;

begin

	//remember old terminal config to put it back after the test
	oldConfig := self.getTerminalConfig(BookingOversubscribe).Boolean;
	self.setTerminalConfig(BookingOversubscribe, true);
	
	//**********
	// CLEANUP
	//**********
	tmpCTA := self.getTerminalArea(CraneTransferAreaId);
	tmpRTA := self.getTerminalArea(RAIL_AREA_ID);
	if tmpCTA &lt;&gt; null then
		ctaType := tmpCTA.myType;
	endif;
	if tmpRTA &lt;&gt; null then
		rtaType := tmpRTA.myType;
	endif;

	self.deleteMachineRule(ctaType, rtaType);
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	self.assertNullMsg(getTerminalArea(RAIL_AREA_ID), "Railway track");
	self.deleteMachine("UTMC");
	self.deleteBooking(BookingId);
	self.deleteContainer(CONT1);
	self.deleteContainer(CONT2);
	
	//***************************
	// Setup
	//***************************
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	ctaType := cta.myType;


	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("UTMC", null, tas, null);
	
	//initialize voyage/vessel
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, crane);
	
	//create prenote for voyage.
	oper := self.getOperator(TestOperator);
	booking := self.addBookingForContainer(BookingId, oper, voyage, "NZAKL", "2200", "MT");
	cargo1 := self.addPrenotedContainer(booking.allBookingRefItems.first, CONT1);
	cargo2 := self.addPrenotedContainer(booking.allBookingRefItems.first, CONT2);
	
	//Create Rail area and then arrive a Train with cargo.
	wagon := createRailTrainAndWagon(WAGON_CODE,TRAIN_CODE,RAIL_AREA_ID, cargo1, cargo2);
	//undo any auto planning
	beginTransaction;
	if cargo1.isQueued then 
		cargo1.doForcedUnqueue(app.myPassport);
	endif;
	cargo1.doForcedUnplan(app.myPassport);
	
	if cargo2.isQueued then 
		cargo2.doForcedUnqueue(app.myPassport);
	endif;
	cargo2.doForcedUnplan(app.myPassport);
	commitTransaction;
	
	self.deleteStops(cargo1);
	self.deleteStops(cargo2);

	//Create load jobs for the first container
	//And plan it to the slot
	tier := 1;
	cell := 5;
	vjob := self.planLoadItemDR(voyage, cargo1, cargo1.allWorklistEntries.first, cell, tier );
	vjob2 := self.planLoadItemDR(voyage, cargo2, cargo2.allWorklistEntries.first, cell+1, tier );
	vwle1 := vjob.getWLEForTI(cargo1).CM_VoyageWLE;
	vwle2 := vjob2.getWLEForTI(cargo2).CM_VoyageWLE;
	self.loadVoyJobToOps(vjob, true, false);
	self.loadVoyJobToOps(vjob2, true, false);
	
	//Check that:
	//Rail/voyage job/wle exists and is planned but not queued 
	railJob := cargo1.jobRailReceive;
	self.assertTrueMsg(railJob &lt;&gt; null, "Rail Receive Job not created");
	railWle := railJob.getWLEForTI(cargo1);
	self.assertTrueMsg(railWle &lt;&gt; null, "Rail Receive Job has no WLE");
	self.assertTrueMsg(not railWle.isQueued, "WLE for Rail Receive Job should not be queued");
	self.assertTrueMsg(vwle1 &lt;&gt; null, "Voyage Job has no WLE");
	self.assertTrueMsg(railWle.getSourceLocation() = vwle1.getSourceLocation(), "Rail and Voyage WLE have different source locations");
	targetLoc := vwle1.getTargetLocation();
	self.assertTrueMsg(targetLoc &lt;&gt; null, "Voyage WLE has not target location");
	
	
	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	self.machineAssignToQueue(imv, rampQueue);
	straddle := self.addMachine(MACHINETYPE_STRADDLE, STRA1, 94, tas, rampQueue.id);
	self.machineAssignToQueue(straddle, rampQueue);
	
	//*********************************
	// lander instant move
	//***********************************
	
	//Set up a move controller to do a real move using the voyage wle and call the move trx
	self.handHeldDirectDischargeTrx( cargo1, targetLoc, vwle1 );
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Move failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "Rail Wle not complete");
	self.assertTrueMsg(vwle1.status = WLE_COMPLETED, "Voyage Wle not complete");
	self.assertTrueMsg(cargo1.getTransReceive &lt;&gt; null, "No receipt transaction");
	self.assertTrueMsg(cargo1.getTransReceiveFirst = cargo1.getTransReceive, "There should only be one receipt transaction");
	self.assertTrueMsg(cargo1.getTransRelease &lt;&gt; null, "No release transaction");
	self.assertTrueMsg(cargo1.isOnShip, "Cargo not on ship");
	tiTrx := cargo1.getLastTransOfClass( CM_Move );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx &lt;&gt; null, cargo1.id &amp; " move transaction not found." );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, cargo1.id &amp; " move transaction not marked as Direct Release." );	//10 Sep 2019	NDL	TFS 42882
	tiTrx := cargo1.getTransRelease;	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, cargo1.id &amp; " release transaction not marked as Direct Release." );	//10 Sep 2019	NDL	TFS 42882
	
	
	//********************************
	// Straddle -&gt; IMV -&gt; lander load
	//********************************
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	
	rail := self.getTerminalArea(RAIL_AREA_ID).CM_Rail; 
	rtaType := rail.myType;
	self.addMachineRuleType(rtaType, ctaType, RTMoveMethod_17, FullMoveQueuing);
	
	create wleArray transient;
	wleArray.add(cargo2.allWorklistEntries.first);
	create wlesWithWarnings transient;
	self.assertNull(cargo2.myPrimaryQueuedLocation);
	app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, QUEUE_MODE, false,null, app.myPassport);
	self.assertNotNull(cargo2.myPrimaryQueuedLocation);
	
	railWle := vwle2.getDRLinkedWLE;
	queueEntry := railWle.allRTQueueEntries.first; // TFS 42872

	app.isRTApp:=true;  
	self.machineLogon(imv);
	self.machineLogon(straddle);
	self.machineAcceptSpecifiedTask(straddle, queueEntry);
	self.machinePickup(straddle);
	self.assertEqual(queueEntry.allTasks.last.ti, cargo2);
	self.machineSetdownTask(straddle, queueEntry.allTasks.last, imv.myMachineController.id);
	
	self.assertEqualMsg(cargo2.myPrimaryActualLocation, imv.myMachineController, "Cargo not found on IMV");
	
	result := agent.doLanderLoad(cargo2, vwle2.getTargetLocation, vwle2, null, null);
	assertTrueMsg(result, "voyage load failed");
	
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "Rail Wle 2 not complete");
	self.assertTrueMsg(vwle2.status = WLE_COMPLETED, "Voyage Wle 2 not complete");
	self.assertTrueMsg(cargo2.getTransRelease &lt;&gt; null, "No release transaction");
	self.assertTrueMsg(cargo2.getTransReleaseLast = cargo2.getTransRelease, "There should only be one release transaction");
	self.assertTrueMsg(cargo2.isOnShip, "Cargo not on ship");
	self.deleteMachineRule(rtaType, ctaType);
	
	//finished clean up 
	self.deleteMachineRule(ctaType, rtaType);
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	self.assertNullMsg(getTerminalArea(RAIL_AREA_ID), "Railway track");
	self.deleteMachine("UTMC");
	self.deleteBooking(BookingId);
	self.deleteContainer(CONT1);
	self.deleteContainer(CONT2);
	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	self.deleteBooking(BookingId);
	self.setTerminalConfig(BookingOversubscribe, oldConfig);
	app.isRTApp:=false;
	delete tas;
	delete agent;
	if voyage &lt;&gt; null then
		self.deleteVoyageJobs(voyage);
	endif;
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDirectReleaseRoadRail" id="4df10319-95e0-4e28-8f8b-124d24bc53d4">
        <source>tDirectReleaseRoadRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 June 2019	jlgndl1	Initial creation TFS 42876
17 March 2025	jlizm1	Unit Test failing due to terminal config change
14 April 2025	jlizm1	Unable to delete terminal area from other failed tests

*/

constants

	TrainCodeIn : String = "DRTRAIN1";
	TrainCodeOut : String = "DRTRAIN2";

	WagonIdInFC : String = "UTFC01";// Flat-car - see class constants
	WagonIdInBC : String = "UTBC01";// Box-car
	WagonIdInWC : String = "UTWC01";// Well-car
	WagonIdOutFC : String = "UTFC02";
	WagonIdOutBC : String = "UTBC02";
	WagonIdOutWC : String = "UTWC02";
	
	TruckIn : String = "UTTRUCK00";
	TruckOut1 : String = "UTTRUCK01";
	TruckOut2 : String = "UTTRUCK02";
	TruckOut3 : String = "UTTRUCK03";
	TruckOut4 : String = "UTTRUCK04";
	
	ContId1 : String = "DRRR0001001";
	ContId2 : String = "DRRR0001002";
	ContId3 : String = "DRRR0001003";
	ContId4 : String = "DRRR0001004";
	BBId1 : String = "DRRR0001005";
	BBId2 : String = "DRRR0001006";
	BulkId1 : String = "DRRR0001007";
	BulkId2 : String = "DRRR0001008";
	
	BBULKCargoType : String = "UTREBAR";  // Pre existing Break Bulk cargo type allows duplicates
	BulkCargoType : String = "UTCOAL";  // Pre existing Bulk cargo type allows duplicates
	
	MACHINE : String = "DRFL";
		
vars

	railArea : CM_Rail;
	railLine : CM_RailLine;
	operator : CM_Operator;
	trainIn : CM_Train;
	trainOut : CM_Train;
	wagon : CM_Wagon;
	wagonFCOut : CM_Wagon;
	wagonBCOut : CM_Wagon;
	wagonWCOut : CM_Wagon;
	contFC1 : CM_Container;
	bbBC1 : CM_BreakBulkGeneric;
	contWC1 : CM_Container;
	bulkBC1 : CM_Bulk;
	contFC2 : CM_Container;
	bbBC2 : CM_BreakBulkGeneric;
	contWC2 : CM_Container;
	bulkBC2 : CM_Bulk;
	bbCargoType : CM_CargoType;
	bCargoType : CM_CargoType;
	truckPreNotes : CM_TISet;
	wagonPreNotes : CM_TISet;
	gate : CM_Gate;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut1 : CM_VehicleVisitRecord;
	vvrOut2 : CM_VehicleVisitRecord;
	vvrOut3 : CM_VehicleVisitRecord;
	vvrOut4 : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	tas: StringArray;
	ta: Object;
	termArea : CM_TerminalArea;
	lc : CM_LocationsController;
	forkLift : CM_Machine;
	qEntry : CM_RTQueueEntry;
	wle1 : CM_WorkListEntry;
	wle2 : CM_WorkListEntry;
	cmifToDepartTrain : CMIF_RakeRegion;
	targetLocation : CM_LocationsController;
	splitTi : CM_TrackedItem;
	tiTrx : CM_TITransaction;
	origAllowAPSetting : Boolean;
	
begin
	origAllowAPSetting := self.getTerminalConfig(AutoPlanEnabled).Boolean;
	self.setTerminalConfig(AutoPlanEnabled, true);

	//get base data
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBULKCargoType &amp; "' not found during setup.");
	bCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BulkCargoType);
	self.assertTrueMsg(bCargoType &lt;&gt; null, "Cargo Type '" &amp; BulkCargoType &amp; "' not found during setup.");
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.assertTrueMsg(gate &lt;&gt; null, "No gate not found during setup.");

	//clean-up old data - if it exists
	
	self.deleteVehicle( TruckIn );
	self.deleteVehicle( TruckOut1 );
	self.deleteVehicle( TruckOut2 );
	self.deleteVehicle( TruckOut3 );
	self.deleteVehicle( TruckOut4 );
	
	self.deleteContainer( ContId1 );
	self.deleteContainer( ContId2 );
	self.deleteContainer( ContId3 );
	self.deleteContainer( ContId4 );
	self.deleteCargo( BBId1, bbCargoType );
	self.deleteCargo( BBId2, bbCargoType );
	self.deleteCargo( BulkId1, bCargoType );
	self.deleteCargo( BulkId2, bCargoType );
	
	self.deleteMachine(MACHINE);
		
	usetupDRWagonClasses( false );  //delete and re setup wagon classes ( delete does wagons and wagon masters too )
	
	self.deleteTrain(TrainCodeIn,null);
	self.deleteTrain(TrainCodeOut,null);

	// basically trying to force delete rail terminal area
	termArea := getTerminalArea(RailAreaId &amp; "TA");
	if termArea &lt;&gt; null then
		foreach lc in termArea.allLocationsControllers do
			if lc.hasTIs then
				beginTransaction;
				lc.allTrackedItems.purge;
				lc.unplanAllTrackedItems(QUEUE_MODE);
				lc.unplanAllTrackedItems(PLANNING_MODE);
				commitTransaction;
			endif;
		endforeach;
	endif;

	self.deleteRailArea(RailAreaId);
	
	
	//create new base data
	railArea := self.addRailArea(RailAreaId, 2, 5); // 2 rail lines, 5 spaces
	self.assertTrueMsg(railArea &lt;&gt; null, "Rail Area '" &amp; RailAreaId &amp; "' not created during setup.");
	
	//Inwards train with its wagons and cargo
	create wagonPreNotes transient;
	trainIn := self.addTrain(TrainCodeIn,null);
	self.assertTrueMsg(trainIn &lt;&gt; null, "'Train in' not created during setup");
	
	self.opts.addAssoc("RailLine", railArea.allRailLines.first); // inward train wagons first line of two
	wagon := self.addWagonInRailArea(WagonIdInFC, WagonClassFC, railArea, trainIn);
	self.assertTrueMsg(wagon &lt;&gt; null, "'" &amp; WagonIdInFC &amp; "' flat car not created on 'train in' during setup");	
	contFC1 := self.addRailPreNote( wagon.id, wagon.myWagonClass.code, ContId1 ).CM_Container;
	self.assertTrueMsg(contFC1 &lt;&gt; null, "'" &amp; ContId1 &amp; "' not created during setup");
	wagonPreNotes.add( contFC1 );
	
	wagon := self.addWagonInRailArea(WagonIdInBC, WagonClassBC, railArea, trainIn);
	self.assertTrueMsg(wagon &lt;&gt; null, "'" &amp; WagonIdInBC &amp; "' box car not created on 'train in' during setup");
	self.opts.purge();
	self.opts.addAssoc("CargoType", bbCargoType.id);
	self.opts.addAssoc("Wagon", wagon);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 80.Integer );
	bbBC1 := self.addPrenoted( BBId1 ).CM_BreakBulkGeneric;
	self.opts.purge();
	self.assertTrueMsg(bbBC1 &lt;&gt; null, "'" &amp; BBId1 &amp; "' not Break Bulk created during setup");
	wagonPreNotes.add( bbBC1 );
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", bCargoType.id);
	self.opts.addAssoc("Wagon", wagon);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 5000.Integer );
	bulkBC1 := self.addPrenoted( BulkId1 ).CM_Bulk;
	self.opts.purge();
	self.assertTrueMsg(bulkBC1 &lt;&gt; null, "'" &amp; BulkId1 &amp; "' Bulk not created during setup");
	wagonPreNotes.add( bulkBC1 );
	
	self.opts.addAssoc("RailLine", railArea.allRailLines.first);
	wagon := self.addWagonInRailArea(WagonIdInWC, WagonClassWC, railArea, trainIn);
	self.assertTrueMsg(wagon &lt;&gt; null, "'" &amp; WagonIdInWC &amp; "' well car not created on 'train in' during setup");	
	contWC1 := self.addRailPreNote( wagon.id, wagon.myWagonClass.code, ContId2 ).CM_Container;
	self.assertTrueMsg(contWC1 &lt;&gt; null, "'" &amp; ContId2 &amp; "' not created during setup");
	wagonPreNotes.add( contWC1 );
	
	// Outwards train with its wagons
	trainOut := self.addTrain(TrainCodeOut,null);
	self.assertTrueMsg(trainIn &lt;&gt; null, "'Train out' not created during setup");
	self.opts.addAssoc("RailLine", railArea.allRailLines.last); // outward train wagons the second line of two
	wagonFCOut := self.addWagonInRailArea(WagonIdOutFC, WagonClassFC, railArea, trainOut);
	self.assertTrueMsg(wagonFCOut &lt;&gt; null, "'" &amp; WagonIdOutFC &amp; "' flat car not created on 'train out' during setup");	
	wagonBCOut := self.addWagonInRailArea(WagonIdOutBC, WagonClassBC, railArea, trainOut);
	self.assertTrueMsg(wagonBCOut &lt;&gt; null, "'" &amp; WagonIdOutBC &amp; "' box car not created on 'train out' during setup");
	wagonWCOut := self.addWagonInRailArea(WagonIdOutWC, WagonClassWC, railArea, trainOut);
	self.assertTrueMsg(wagonWCOut &lt;&gt; null, "'" &amp; WagonIdOutWC &amp; "' well car not created on 'train out' during setup");
	self.opts.purge();
	
	//now make both trains arrive
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, trainIn, false, app.myPassport); // auto plan the cargo to the yard creates the wles to remove the cargo
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, trainOut, false, app.myPassport);
	
	//pre-notes for the inward truck
	create truckPreNotes transient;
	contFC2 := self.addPrenoted( ContId3 ).CM_Container;
	self.assertTrueMsg(contFC2 &lt;&gt; null, "'" &amp; ContId3 &amp; "' not created during setup");
	truckPreNotes.add( contFC2 );
	
	contWC2 := self.addPrenoted( ContId4 ).CM_Container;
	self.assertTrueMsg(contWC2 &lt;&gt; null, "'" &amp; ContId4 &amp; "' not created during setup");
	truckPreNotes.add( contWC2 );
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", bbCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 80.Integer );
	bbBC2 := self.addPrenoted( BBId2 ).CM_BreakBulkGeneric;
	self.assertTrueMsg(bbBC2 &lt;&gt; null, "'" &amp; BBId2 &amp; "' Break Bulknot created during setup");
	truckPreNotes.add( bbBC2 );
	self.opts.purge();
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", bCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 5000.Integer );
	bulkBC2 := self.addPrenoted( BulkId2 ).CM_Bulk;
	self.assertTrueMsg(bulkBC2 &lt;&gt; null, "'" &amp; BulkId2 &amp; "' not created during setup");
	truckPreNotes.add( bulkBC2 );
	self.opts.purge();
	
	// now gate in the truck with the cargo for the outward train	
	vvrIn := self.gateInPrenote( TruckIn, null, null, truckPreNotes, gate );
	self.assertTrueMsg(vvrIn &lt;&gt; null, "'" &amp; TruckIn &amp; "' failed to gate in during setup");
	
	//clear any stops
	foreach ti in wagonPreNotes do
		self.deleteStops( ti );
	endforeach;
	foreach ti in truckPreNotes do
		self.deleteStops( ti );
	endforeach;
	
//start the test
	
	//do the equivalent of manually unplanning the road jobs from the yard in Road Operations. (They may have been auto queued to the yard)
	foreach ti in truckPreNotes do
	//Unqueue and Unplan the items on the truck
		self.unqueueTI( ti );
		self.unplanTI( ti );
	endforeach; 
	
	//plan each of the inward truck cargo to their respective outbound rail positions, i.e. equaivalent of drag drop from Road Ops to Rail Ops in Plan mode.
	//will create a Rail Job, and WLE, and link them up as Direct Release.
	self.movePlanned( contFC2, wagonFCOut.allLocationsControllersArray.first );
	self.movePlanned( contWC2, wagonWCOut.allLocationsControllersArray.first );
	self.movePlanned( bbBC2, wagonBCOut.allLocationsControllersArray.first );
	self.movePlanned( bulkBC2, wagonBCOut.allLocationsControllersArray.first );
	
	//validate planned as Direct Release
	foreach ti in truckPreNotes do
		self.assertTrueMsg( ti.allWorklistEntries.size = 2, ti.id &amp; " has the wrong number of wles, should have 2");
		self.assertTrueMsg( ti.allWorklistEntries.first.isDRLinkedByFM, ti.id &amp; " not marked as Direct Release");
	endforeach;
	
	//now queue them.
	foreach ti in truckPreNotes do
		wle := ti.allWorklistEntries.first;
		self.queueWLE( wle );
		self.assertTrueMsg( ti.isQueued, ti.id &amp; " not queued" );
		self.assertTrueMsg( ti.myPrimaryActualLocation.isVehicle, ti.id &amp; " should still be on the truck" );
	endforeach;
	
	
	//Now gate in the trucks picking up the cargo from the inward train
	vvrOut1 := self.gateOutGC(TruckOut1, null, null, contFC1, gate, null);  
	vvrOut2 := self.gateOutGC(TruckOut2, null, null, contWC1, gate, null);
	self.opts.addAssoc('TotalRequested',80.Integer);
	vvrOut3 := self.gateOutGC(TruckOut3, null, null, bbBC1, gate, null);
	self.opts.purge();
	self.opts.addAssoc('TotalWeight',5000.Integer);
	vvrOut4 := self.gateOutGC(TruckOut4, null, null, bulkBC1, gate, null);
	self.opts.purge();
	
	//check that each of the wagon cargo item now has two wles, that are linked as Direct Releases, I.e. every thing is queued in and out and still on their incoming vehicle/wagon
	//validate planned as Direct Release
	foreach ti in wagonPreNotes do
		self.assertTrueMsg( ti.allWorklistEntries.size = 2, ti.id &amp; " has the wrong number of wles, should have 2");
		targetLocation := ti.allWorklistEntries.last.getTargetLocation; // establish teh target
		self.unqueueTI( ti ); // unqueue and unplan liKE in thE form
		self.unplanTI( ti );
		self.movePlannedWLE( ti, targetLocation, ti.allWorklistEntries.first ); // same as drag drop in teh form
		self.assertTrueMsg( ti.allWorklistEntries.first.isDRLinkedByFM, ti.id &amp; " not marked as Direct Release");
		self.queueWLE( ti.allWorklistEntries.first );
		self.assertTrueMsg( ti.isQueued, ti.id &amp; " not queued" );
		self.assertTrueMsg( ti.myPrimaryActualLocation.isWagon, ti.id &amp; " should still be on the wagon" );
	endforeach;
	
	//To just set up the data to do actual testing from the forms, do a return HERE............
	//return;
	
	//simulated Form testing
	//Form Road Operations and Rail Operation both use the same trx , so we are doing a "Move Selected" - should just move the cargo (total amount) and close both linked wles.
	ti := contFC1; // Cargo going from wagon to truck i.e. outward truck job using roadWle
	wle := ti.allWorklistEntries.first;
	self.moveWLE( wle ); // uses the same trx as the form
	self.assertTrueMsg( ti.myPrimaryActualLocation.isVehicle, ti.id &amp; " should have moved onto the truck" );
	self.assertTrueMsg( ti.allWorklistEntries.first.status = WLE_COMPLETED, ti.id &amp; " first wle should be complete" );
	self.assertTrueMsg( ti.allWorklistEntries.last.status = WLE_COMPLETED, ti.id &amp; " second wle should be complete" );
	tiTrx := ti.getLastTransOfClass( CM_Move );
	self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " move to truck transaction not found." );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " move to truck transaction not marked as Direct Release." );
	
	ti := contWC1; // Cargo going from wagon to truck i.e. outward truck job using rail Wle
	wle := ti.allWorklistEntries.last;
	self.moveWLE( wle ); // uses the same trx as the form
	self.assertTrueMsg( ti.myPrimaryActualLocation.isVehicle, ti.id &amp; " should have moved onto the truck" );
	self.assertTrueMsg( ti.allWorklistEntries.first.status = WLE_COMPLETED, ti.id &amp; " first wle should be complete" );
	self.assertTrueMsg( ti.allWorklistEntries.last.status = WLE_COMPLETED, ti.id &amp; " second wle should be complete" );
	tiTrx := ti.getLastTransOfClass( CM_Move );
	self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " move to truck transaction not found." );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " move to truck transaction not marked as Direct Release." );
	
	ti := contFC2; // Cargo going from truck to wagon i.e. outward rail job using rail wle
	wle := ti.allWorklistEntries.first;
	self.moveWLE( wle );
	self.assertTrueMsg( ti.myPrimaryActualLocation.isWagon, ti.id &amp; " should have moved onto the wagon" );
	self.assertTrueMsg( ti.allWorklistEntries.first.status = WLE_COMPLETED, ti.id &amp; " first wle should be complete" );
	self.assertTrueMsg( ti.allWorklistEntries.last.status = WLE_COMPLETED, ti.id &amp; " second wle should be complete" );
	tiTrx := ti.getLastTransOfClass( CM_Move );
	self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " move to wagon transaction not found." );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " move to wagon transaction not marked as Direct Release." );
	
	ti := contWC2; // Cargo going from truck to wagon i.e. outward rail job using road wle
	wle := ti.allWorklistEntries.last;
	self.moveWLE( wle );
	self.assertTrueMsg( ti.myPrimaryActualLocation.isWagon, ti.id &amp; " should have moved onto the wagon" );
	self.assertTrueMsg( ti.allWorklistEntries.first.status = WLE_COMPLETED, ti.id &amp; " first wle should be complete" );
	self.assertTrueMsg( ti.allWorklistEntries.last.status = WLE_COMPLETED, ti.id &amp; " second wle should be complete" );
	tiTrx := ti.getLastTransOfClass( CM_Move );
	self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " move to wagon transaction not found." );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " move to wagon transaction not marked as Direct Release." );
	
	ti := bbBC1; // Break Bulk Cargo going from wagon to truck i.e. outward road job using rail wle
	wle := ti.allWorklistEntries.last;
	self.moveWLE( wle ); // uses the same trx as the form
	self.assertTrueMsg( ti.myPrimaryActualLocation.isVehicle, ti.id &amp; " should have moved onto the truck" );
	self.assertTrueMsg( ti.allWorklistEntries.first.status = WLE_COMPLETED, ti.id &amp; " first wle should be complete" );
	self.assertTrueMsg( ti.allWorklistEntries.last.status = WLE_COMPLETED, ti.id &amp; " second wle should be complete" );
	tiTrx := ti.getLastTransOfClass( CM_Move );
	self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " move to truck transaction not found." );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " move to truck transaction not marked as Direct Release." );
	
	ti := bulkBC2; // Bulk Cargo going from truck to wagon i.e. outward wagon job using road wle
	wle := ti.allWorklistEntries.last;
	self.moveWLE( wle );
	self.assertTrueMsg( ti.myPrimaryActualLocation.isWagon, ti.id &amp; " should have moved onto the wagon" );
	self.assertTrueMsg( ti.allWorklistEntries.first.status = WLE_COMPLETED, ti.id &amp; " first wle should be complete" );
	self.assertTrueMsg( ti.allWorklistEntries.last.status = WLE_COMPLETED, ti.id &amp; " second wle should be complete" );
	tiTrx := ti.getLastTransOfClass( CM_Move );
	self.assertTrueMsg( tiTrx &lt;&gt; null, ti.id &amp; " move to wagon transaction not found." );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, ti.id &amp; " move to wagon transaction not marked as Direct Release." );

	
	//simulated VMT tetsing
	
	create tas transient;
	tas.add(railArea.id);
	tas.add(vvrIn.vehicle.myPrimaryActualLocation.myTerminalArea.id);
	
	ti := bbBC2; // Break Bulk Cargo going from truck to wagon i.e. outward rail job using rail wle
	wle := ti.allWorklistEntries.first; // need the wle to find the queue to use for the forlift.
	
	forkLift := self.addForkLift( MACHINE, 0, tas, wle.queueId);
	self.assertTrueMsg(forkLift &lt;&gt; null, MACHINE &amp; " forklift not created");
	
	qEntry := wle.allRTQueueEntries.first;
	app.isRTApp := true;  
	self.machineLogon(forkLift);
	
	//Accept, Pick up and Set down the first 40 of the 80 rebar in this job
	self.machineAcceptSpecifiedTask( forkLift, qEntry );
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMachinePickupTask( forkLift, 40, null, app.myPassport );
	splitTi := forkLift.myMachineController.allTrackedItems.first();
	tiTrx := splitTi.getLastTransOfClass( CM_Pickup );
	self.assertTrueMsg( tiTrx &lt;&gt; null, splitTi.id &amp; " pick up transaction not found." );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, splitTi.id &amp; " pick up transaction not marked as Direct Release." );

	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	self.machineSetdown( forkLift, wle.myTrackedItem, forkLift.currentQueueTask.targetLocationId );
	tiTrx := splitTi.getLastTransOfClass( CM_SetDown );
	self.assertTrueMsg( tiTrx &lt;&gt; null, splitTi.id &amp; " set down transaction not found." );	//10 Sep 2019	NDL	TFS 42882
	self.assertTrueMsg( tiTrx.isDirectReleaseMove, splitTi.id &amp; " set down transaction not marked as Direct Release." );

	
	self.assertTrueMsg( ti.allWorklistEntries.first.status = WLE_PART_COMPLETE, ti.id &amp; " first wle should be part complete" );
	self.assertTrueMsg( ti.allWorklistEntries.last.status = WLE_UNACTIONED, ti.id &amp; " second wle should be unactioned" );
	self.assertTrueMsg( ti.allWorklistEntries.first.quantity = 40, ti.id &amp; " should be 40 unactioned" );
	self.assertTrueMsg( ti.allWorklistEntries.last.quantity = 40, ti.id &amp; " should be 40 unactioned" );
	
	//Accept, Pick up and Set down the last 40 of the 80 rebar in this job
	wle1 := ti.allWorklistEntries.first;
	wle2 := ti.allWorklistEntries.last;
	qEntry := wle.allRTQueueEntries.first;
	
	self.machineAcceptSpecifiedTask( forkLift, qEntry );
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMachinePickupTask( forkLift, 40, null, app.myPassport );	

	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	self.machineSetdown( forkLift, wle.myTrackedItem, forkLift.currentQueueTask.targetLocationId );
	
	self.assertTrueMsg( ti.hasBeenMerged, ti.id &amp; " original should have been merged (zombied)" );
	self.assertTrueMsg( self.getTerminal.allOnsiteTIsByIdCargoType[ ti.id, ti.cargoType ].myPrimaryActualLocation.isWagon, ti.id &amp; " should have moved onto the wagon" );
	self.assertTrueMsg( wle1.status = WLE_COMPLETED, ti.id &amp; " first wle should be complete" );
	self.assertTrueMsg( wle2.status = WLE_COMPLETED, ti.id &amp; " second wle should be complete" );
	
	
	
	ti := bulkBC1; // Bulk Cargo going from wagon to truck i.e. outward truck job using road wle
	wle := ti.allWorklistEntries.last;
	qEntry := wle.allRTQueueEntries.first;
	
	//Accept, Pick up and Set down the first 2500 of the 5000 kg Coal in this job
	self.machineAcceptSpecifiedTask( forkLift, qEntry );
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMachinePickupTask( forkLift, 0, 2500, app.myPassport );	

	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	self.machineSetdown( forkLift, wle.myTrackedItem, forkLift.currentQueueTask.targetLocationId );
	
	self.assertTrueMsg( ti.allWorklistEntries.last.status = WLE_PART_COMPLETE, ti.id &amp; " last wle should be part complete" );
	self.assertTrueMsg( ti.allWorklistEntries.first.status = WLE_UNACTIONED, ti.id &amp; " first wle should be unactioned" );
	self.assertTrueMsg( ti.allWorklistEntries.first.weight = 2500, ti.id &amp; " should be 2500kg unactioned" );
	self.assertTrueMsg( ti.allWorklistEntries.last.weight = 2500, ti.id &amp; " should be 2500kg unactioned" );
	
	//Accept, Pick up and Set down the last 2500 of the 5000kg of Coal in this job
	wle1 := ti.allWorklistEntries.first;
	wle2 := ti.allWorklistEntries.last;
	qEntry := wle.allRTQueueEntries.first;
	
	self.machineAcceptSpecifiedTask( forkLift, qEntry );
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMachinePickupTask( forkLift, 0, 2500, app.myPassport );	

	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	self.machineSetdown( forkLift, wle.myTrackedItem, forkLift.currentQueueTask.targetLocationId );
	
	self.assertTrueMsg( ti.hasBeenMerged, ti.id &amp; " original should have been merged (zombied)" );
	self.assertTrueMsg( self.getTerminal.allOnsiteTIsByIdCargoType[ ti.id, ti.cargoType ].myPrimaryActualLocation.isVehicle, ti.id &amp; " should have moved onto the truck" );
	self.assertTrueMsg( wle1.status = WLE_COMPLETED, ti.id &amp; " first wle should be complete" );
	self.assertTrueMsg( wle2.status = WLE_COMPLETED, ti.id &amp; " second wle should be complete" );
	
	self.machineLogOff(forkLift);


	//depart the trains
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, trainIn, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	create cmifToDepartTrain transient;	
	cmifToDepartTrain.myTrain := trainIn;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateRailClearRake(cmifToDepartTrain, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete cmifToDepartTrain;
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, trainOut, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	create cmifToDepartTrain transient;	
	cmifToDepartTrain.myTrain := trainOut;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateRailClearRake(cmifToDepartTrain, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete cmifToDepartTrain;

	//gate out the trucks.
	app.myTrxDA.trxVehicleRoadExit( vvrIn.vehicle, app.myPassport );
	app.myTrxDA.trxVehicleRoadExit( vvrOut1.vehicle, app.myPassport );
	app.myTrxDA.trxVehicleRoadExit( vvrOut2.vehicle, app.myPassport );
	app.myTrxDA.trxVehicleRoadExit( vvrOut3.vehicle, app.myPassport );
	app.myTrxDA.trxVehicleRoadExit( vvrOut4.vehicle, app.myPassport );
	
	// all finished, now clean - up
	self.deleteVehicle( TruckIn );
	self.deleteVehicle( TruckOut1 );
	self.deleteVehicle( TruckOut2 );
	self.deleteVehicle( TruckOut3 );
	self.deleteVehicle( TruckOut4 );
	
	self.deleteContainer( ContId1 );
	self.deleteContainer( ContId2 );
	self.deleteContainer( ContId3 );
	self.deleteContainer( ContId4 );
	self.deleteCargo( BBId1, bbCargoType );
	self.deleteCargo( BBId2, bbCargoType );
	self.deleteCargo( BulkId1, bCargoType );
	self.deleteCargo( BulkId2, bCargoType );
	
	self.deleteMachine(MACHINE);
	
	usetupDRWagonClasses( true );  //delete only
	
	self.deleteTrain(TrainCodeIn,null);
	self.deleteTrain(TrainCodeOut,null);
	
	self.deleteRailArea(RailAreaId);
	
	
		
epilog
	self.setTerminalConfig(AutoPlanEnabled, origAllowAPSetting);

	app.isRTApp := false; 
	delete truckPreNotes;
	delete wagonPreNotes;
	delete tas;
	delete cmifToDepartTrain;

end;</source>
    </JadeMethod>
    <JadeMethod name="tDirectReleaseRoadShip" id="14448300-8d1e-4bcd-973d-5e9e2adbf142">
        <updating/>
        <source>tDirectReleaseRoadShip() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 August 2019		jlgzm1	TFS 42878 Direct Release Between Road and Voyage
13 June 2019		jlgndl1	Initial creation

*/

constants
	
	VesselCode : String = 'SCONRO';
	Voyagecode : String = 'DRCONRO';

	TruckIn : String = "UTTRUCK10";
	TruckOut1 : String = "UTTRUCK11";
	TruckOut2 : String = "UTTRUCK12";
	TruckOut3 : String = "UTTRUCK13";
	TruckOut4 : String = "UTTRUCK14";
	
	ContId1 : String = "DRSR0004001";
	ContId2 : String = "DRSR0004002";
	ContId3 : String = "DRRS0004003";
	ContId4 : String = "DRRS0004004";
	BBId1 : String = "DRSR0004005";
	BBId2 : String = "DRRS0004006";
	
	LoadLcId1 : String = "D1040";
	LoadLcId2 : String = "D1039";
	
	BBULKCargoType : String = "UTREBAR";  // Pre existing Break Bulk cargo type allows duplicates
	
	DRWorkPoint : String = "DRWP";
	IMV1 	= "UTIM";
	STRA1	= "USTL";
	
vars
	
	operator : CM_Operator;
	shipLineStr : String;
	voyage : CM_Voyage;

	contLc2 : CM_LocationsController;
	contLc3 : CM_LocationsController;
	contLcOut1 : CM_LocationsController;
	contLcOut2 : CM_LocationsController;
	voyInLocn : CM_ROROGCController;
	voyOutLocn : CM_ROROGCController;
	deck : CM_DeckVoyage;
	workPoint 		: CM_WorkPoint;
	lcSet 			: CM_LCSet;
	lcArray			: CM_LCArray;
	altRoroLCs		: CM_LCArray;
	dischJob		: CM_Job;
	loadJob			: CM_Job;
	loadJob2		: CM_Job;
	loadGC			: CM_ROROGCDefnVoyage;
	alloc			: CM_VoyageAllocation;
	roadJobs		: CM_JobArray;
	roadJob 		: CM_Job;

	contCargoType : CM_CargoType;
	bbCargoType : CM_CargoType;
	truckPreNotes : CM_TISet;
	gate : CM_Gate;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut1 : CM_VehicleVisitRecord;
	vvrOut2 : CM_VehicleVisitRecord;
	vvrOut3 : CM_VehicleVisitRecord;
	vvrOut4 : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
	gateOutCargo1 : CM_TrackedItem;
	gateOutCargo2 : CM_TrackedItem;
	gateOutCargo3 : CM_TrackedItem;
	
	wle : CM_WorkListEntry;
	drWLE : CM_WorkListEntry;
	tmpLC : CM_LocationsController;
	moveController : CMIF_MoveController;
	origAllowAPSetting : Boolean;
	
begin
	origAllowAPSetting := self.getTerminalConfig(AutoPlanEnabled).Boolean;
	self.setTerminalConfig(AutoPlanEnabled, true);

	//get base data
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBULKCargoType &amp; "' not found during setup.");
	contCargoType := app.myRoot.allCargoTypesById[ TI_CargoType_Container ];
	self.assertTrueMsg(contCargoType &lt;&gt; null, "Container Cargo Type not found during setup.");
	
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.assertTrueMsg(gate &lt;&gt; null, "No gate not found during setup.");

	//clean-up old data - if it exists
	
	self.deleteVoyage(Voyagecode);
	
	self.deleteVehicle( TruckIn );
	self.deleteVehicle( TruckOut1 );
	self.deleteVehicle( TruckOut2 );
	self.deleteVehicle( TruckOut3 );
	self.deleteVehicle( TruckOut4 );
	
	self.deleteContainer( ContId1 );
	self.deleteContainer( ContId2 );
	self.deleteContainer( ContId3 );
	self.deleteContainer( ContId4 );
	self.deleteCargo( BBId1, bbCargoType );
	self.deleteCargo( BBId2, bbCargoType );
	
		
	//create new base data
	self.opts.purge();
	voyage := self.addVoyageWithConRORO(Voyagecode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	//create the GC areas (only every declared per voyage, NOT at vessel level.)
	deck := voyage.myROROStructure.allDecks.first;
	voyage.myROROStructure.createQuickGCLocation(null,50.60,-10.10,deck,"GCIMPORT");
	voyInLocn := voyage.myROROStructure.allROROGCDefnByCode.getAtKey( "GCIMPORT").CM_ROROGCDefnVoyage.myGCController;
	self.assertTrueMsg(voyInLocn &lt;&gt; null, "'GCIMPORT' area not created during setup");
	voyage.myROROStructure.createQuickGCLocation(null,113.40,-6.40,deck,"GCEXPORT");
	voyOutLocn := voyage.myROROStructure.allROROGCDefnByCode.getAtKey( "GCEXPORT").CM_ROROGCDefnVoyage.myGCController;
	self.assertTrueMsg(voyOutLocn &lt;&gt; null, "'GCEXPORT' area not created during setup");
	
	gateOutCargo1 := self.addCargoBreakBulkAtLocation(BBId1, bbCargoType, 80, voyInLocn, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(gateOutCargo1 &lt;&gt; null, "'" &amp; BBId1 &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80000);
	self.updateTI(gateOutCargo1 );
	
	contLc2 := voyage.myROROStructure.allDecks.first.allROROSlotControllers.first;
	gateOutCargo2 := self.addContainerAtLocation(ContId1, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, contLc2);
	self.assertTrueMsg(gateOutCargo2 &lt;&gt; null, "'" &amp; ContId1 &amp; "' on ship container not created during setup");
	
	contLc3 := voyage.myROROStructure.allDecks.first.allROROSlotControllers.last;
	gateOutCargo3 := self.addContainerAtLocation(ContId2, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, contLc3);
	self.assertTrueMsg(gateOutCargo3 &lt;&gt; null, "'" &amp; ContId2 &amp; "' on ship container not created during setup");
	
	//*****************************
	//create discharge CC for cargo
	//*****************************
	create lcSet transient;
	lcSet.add(contLc2);
	lcSet.add(contLc3);
	lcSet.add(voyInLocn);
	app.myTrxCA.trxCreateRORODischargeCCs(lcSet, app.myPassport);
	
	create lcArray transient;
	lcArray.add(contLc2);
	lcArray.add(contLc3);
	lcArray.add(voyInLocn);
	dischJob := self.addVoyageROROJob(voyage, deck, DRWorkPoint, lcArray, true);
	self.assertNotNullMsg(dischJob, "voyage discharge job not created");
	workPoint := self.getWorkpoint(DRWorkPoint);
	
	self.loadAllJobsToOps(voyage, true);
	
	//*************************
	//create load CC for cargo
	//*************************
	create altRoroLCs transient;
	lcArray.clear();
	contLcOut1 := voyage.myROROStructure.findSlotController(LoadLcId1, 1);
	contLcOut2 := voyage.myROROStructure.findSlotController(LoadLcId2, 1);
	lcArray.add(contLcOut1);
	lcArray.add(contLcOut2);
	alloc := self.addVoyageAllocation(voyage, null, "", "", gateOutCargo2.myCargoType.id, false, false);
	self.addLCsToROROAllocation(true, alloc, lcArray, altRoroLCs, 1);
	loadJob := self.addVoyageROROJob(voyage, deck, DRWorkPoint, lcArray, false);
	self.assertNotNullMsg(dischJob, "voyage load job for containers not created");
	
	lcArray.clear();
	altRoroLCs.clear();
	alloc := self.addVoyageAllocation(voyage, null, "", "", bbCargoType.id, false, false); 
	loadGC := app.myTrxCA.trxCreateROROGCLoadCC(null, 4, 10, 10, deck, app.myPassport);
	lcArray.add(loadGC.getLC);
	self.addLCsToROROAllocation(true, alloc, lcArray, altRoroLCs, 20);
	loadJob2 := self.addVoyageROROJob(voyage, deck, workPoint.code, lcArray, false);
	self.assertNotNullMsg(dischJob, "voyage load job for GC not created");
	
	
	//pre-notes for the inward truck
	create truckPreNotes transient;
	self.opts.purge();
	self.opts.addAssoc("ExportVoyage", voyage);
	ti := self.addPrenoted( ContId3 ).CM_Container;
	self.assertTrueMsg(ti &lt;&gt; null, "'" &amp; ContId3 &amp; "' not created during setup");
	truckPreNotes.add( ti );
	
	ti := self.addPrenoted( ContId4 ).CM_Container;
	self.assertTrueMsg(ti &lt;&gt; null, "'" &amp; ContId4 &amp; "' not created during setup");
	truckPreNotes.add( ti );
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", bbCargoType.id);
	self.opts.addAssoc("TotalQuantity", 20);
	self.opts.addAssoc("ExportVoyage", voyage);
	ti := self.addPrenoted( BBId2 ).CM_BreakBulkGeneric;
	self.assertTrueMsg(ti &lt;&gt; null, "'" &amp; BBId2 &amp; "' not created during setup");
	truckPreNotes.add( ti );
	self.opts.purge();
	

	// now gate in the truck with the cargo for the outward train	
	vvrIn := self.gateInPrenote( TruckIn, null, null, truckPreNotes, gate );
	self.assertTrueMsg(vvrIn &lt;&gt; null, "'" &amp; TruckIn &amp; "' failed to gate in during setup");
	
	//clear any stops
	foreach ti in truckPreNotes do
		self.deleteStops( ti );
		//Unqueue and Unplan the items on the truck
		self.unqueueTI( ti );
		self.unplanTI( ti );
	endforeach;
	
	self.deleteStops( gateOutCargo1 );
	self.deleteStops( gateOutCargo2 );
	self.deleteStops( gateOutCargo3 );
	
	//Now gate in the trucks picking up the cargo from the inward train
	
	
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 20);
	vvrOut1 := self.gateOutGC(TruckOut1, null, null, gateOutCargo1, gate, null);
	self.opts.purge();
	vvrOut2 := self.gateOutGC(TruckOut2, null, null, gateOutCargo2, gate, null);
	vvrOut3 := self.gateOutGC(TruckOut3, null, null, gateOutCargo3, gate, null);
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 60);
	vvrOut4 := self.gateOutGC(TruckOut4, null, null, gateOutCargo1, gate, null);
	self.opts.purge();
	
	
	//*****************************
	//Assign jobs to direct release
	//*****************************
	create roadJobs transient;
	foreach wle in dischJob.workListEntries where wle.myTrackedItem.isContainer do 
		ti := wle.myTrackedItem;
		drWLE := ti.allWorklistEntries.last;
		roadJobs.add(drWLE.job);
		tmpLC := drWLE.getTargetLocation;
		self.unqueueTI(ti);
		self.unplanTI(ti);
		app.myPassport.setWarningsIgnored(true);
		self.assignWLEToRoadDR(drWLE, drWLE.quantity, drWLE.weight, tmpLC);
	endforeach;
	
	
	foreach ti in truckPreNotes do
		app.myPassport.clearErrorsWarnings();
		drWLE := ti.allWorklistEntries.first;
		if ti.id = ContId3 then
			wle := loadJob.workListEntries.first;
			tmpLC := contLcOut1;
		elseif ti.id = ContId4 then
			wle := loadJob.workListEntries.last;
			tmpLC := contLcOut2;
		elseif ti.id = BBId2 then
			wle := loadJob2.workListEntries.first;
			tmpLC := loadGC.getLC;
		endif;
		
		roadJobs.add(drWLE.job);
		create moveController transient;
	
		moveController.isRehandleMove := false;
		moveController.setMoveMode(PLANNING_MODE);
		moveController.isSystemMove := true;
		moveController.isForcedMove := true;
		moveController.doingAutoLoadPlanning := true;
		
		moveController.setMyWorkListEntry(drWLE);
		moveController.myDDWorkListEntry := wle;
		moveController.setMyTrackedItem(ti);
		if wle.myRequest.isKindOf(CM_SlotRequest) then
			moveController.mySlotRequest := wle.myRequest.CM_SlotRequest;
		elseif wle.myRequest.isKindOf(CM_VoyageRequest) then
			moveController.myVoyageRequest := wle.myRequest.CM_VoyageRequest;
		endif;
		
			
		app.myPassport.setWarningsIgnored(true);
		moveController.moveTrackedItemTarget(self.getTerminal(), tmpLC, null, null);
		app.myPassport.setWarningsIgnored(false);
		delete moveController;
	endforeach;
	self.loadAllJobsToOps(voyage, true);
	
	//**********
	//Move Cargo
	//**********
	foreach wle in loadJob.workListEntries do
		self.handHeldDirectDischargeTrx(wle.myTrackedItem, wle.getTargetLocation, wle);
	endforeach;
	
	foreach wle in loadJob2.workListEntries do
		self.handHeldDirectDischargeTrx(wle.myTrackedItem, wle.getTargetLocation, wle);
	endforeach;
	
	foreach wle in dischJob.workListEntries do
		self.handHeldDirectDischargeTrx(wle.myTrackedItem, wle.getTargetLocation, wle);
	endforeach;

	//***************************
	//Check all Jobs are complete
	//***************************
	self.assertEqualMsg(dischJob.status, JOB_COMPLETE, "Job not complete");
	self.assertEqualMsg(loadJob.status, JOB_COMPLETE, "Job not complete");
	self.assertEqualMsg(loadJob2.status, JOB_COMPLETE, "Job not complete");
	foreach roadJob in roadJobs do
		self.assertEqualMsg(roadJob.status, JOB_COMPLETE, "Job not complete");
	endforeach;
	
	
	// all finished, now clean - up
	
	self.deleteVoyage(Voyagecode);
	
	self.deleteVehicle( TruckIn );
	self.deleteVehicle( TruckOut1 );
	self.deleteVehicle( TruckOut2 );
	self.deleteVehicle( TruckOut3 );
	self.deleteVehicle( TruckOut4 );
	
	self.deleteContainer( ContId1 );
	self.deleteContainer( ContId2 );
	self.deleteContainer( ContId3 );
	self.deleteContainer( ContId4 );
	self.deleteCargo( BBId1, bbCargoType );
	self.deleteCargo( BBId2, bbCargoType );

epilog
	self.setTerminalConfig(AutoPlanEnabled, origAllowAPSetting);
	
	delete truckPreNotes;
	delete lcSet;
	delete lcArray;
	delete altRoroLCs;
	delete roadJobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDirectReleaseRoroVoyRailBB" id="3d11923c-29f9-40e8-a287-638965a92440">
        <updating/>
        <source>tDirectReleaseRoroVoyRailBB() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 July 2019		jlgzm1	TFS 42863
11 June 2019		jlgndl1	Initial creation
08 July 2019		jlgzm1	TFS 42863 MSL - Direct Delivery Between RORO Voyages and Rail - Break Bulk Bulk
21 February 2025	jlizm1	Fixing failing tests

*/

constants

	VesselCode : String = 'SCONRO';
	Voyagecode : String = 'DRCONRO';
	
	TrainCodeIn : String = "DRTRAIN3";
	TrainCodeOut : String = "DRTRAIN4";

	WagonIdInBaseId : String = "UTBC3";
	WagonIdOutBaseId : String = "UTBC4";
	
	BBULKCargoType : String = "UTREBAR";  // Pre existing Break Bulk cargo type allows duplicates
	
	BBIdInTrainBaseId : String = "DRRR000200";
	BBId5 : String = "DRRR0003001";
	DRWorkPoint : String = "DRWP";
	
	IMV1 	= "UTIM";
	STRA1	= "USTL";
	
	
vars

	operator 		: CM_Operator;
	shipLineStr 	: String;
	voyage 			: CM_Voyage;
	
	railArea 		: CM_Rail;
	railLine 		: CM_RailLine;
	trainIn 		: CM_Train;
	trainOut 		: CM_Train;
	wagon 			: CM_Wagon;
	wagonBCOut1 	: CM_Wagon;
	wagonBCOut2 	: CM_Wagon;
	wagonBCOut3 	: CM_Wagon;
	wagonBCOut4 	: CM_Wagon;
	wagonMaster		: CM_WagonMaster;
	bbBC5 			: CM_BreakBulkGeneric;
	bbCargoType 	: CM_CargoType;
	ti 				: CM_TrackedItem;
	tiId 			: String;
	wagonId 		: String;
	index 			: Integer;
	deck 			: CM_DeckVoyage;
	voyInLocn 		: CM_ROROGCController;
	voyOutLocn 		: CM_ROROGCController;
	theLCs 			: CM_LCSet;
	tmpLCs 			: CM_LCArray;
	voyDischJob 	: CM_VoyageJob;
	railReleaseJobs : CM_JobArray;
	railReleaseJob 	: CM_Job;
	loadTIs,
	dischargeTIs 	: CM_TIArray;
	vwles 			: CM_WLEArray;
	wle				: CM_WorkListEntry;
	vwle 			: CM_VoyageWLE;
	ywle 			: CM_YardWLE;
	sourceLoc		: CM_LocationsController;
	targetLoc 		: CM_LocationsController;
	workPoint 		: CM_WorkPoint;
	wpi 			: CM_TerminalArea;
	machine, imv 	: CM_Machine;
	queue			: CM_VoyageQueue;
	wpQueue			: CM_RadioTelemetryQueue;
	tas				: StringArray;
	tmpWLEs,
	tmpWLEWarn		: CM_WLEArray;
	queueEntry		: CM_RTQueueEntry;
	queuetask		: CM_RTQueueTask;
	vQtyBefore,
	yQtyBefore		: Integer;
	result 			: Boolean;
	agent 			: CMIF_MobileGenericAgent;
	loadJob			: CM_Job;
	loadGC			: CM_ROROGCDefnVoyage;
	alloc			: CM_VoyageAllocation;
	altRoroLCs,
	roroLCs 		: CM_LCArray;
	moveController	: CMIF_MoveController;
	
begin

	//get base data
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBULKCargoType &amp; "' not found during setup.");

	//clean-up old data - if it exists
		
	self.deleteVoyage(Voyagecode);
	foreach index in 1 to 4 do
		tiId := BBIdInTrainBaseId &amp; index.String;
		self.deleteCargo( tiId, bbCargoType );
		
		wagonMaster := self.getRoot.allWagonMasters[ WagonIdInBaseId &amp; index.String ];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons( wagonMaster );
		endif;

		wagonMaster := self.getRoot.allWagonMasters[ WagonIdOutBaseId &amp; index.String ];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons( wagonMaster );
		endif;
	endforeach;
	self.deleteCargo( BBId5, bbCargoType );
		
	usetupDRWagonClasses( false );  //delete and re setup wagon classes ( delete does wagons and wagon masters too )
	
	self.deleteTrain(TrainCodeIn,null);
	self.deleteTrain(TrainCodeOut,null);
	
	self.deleteRailArea(RailAreaId);

	//create new base data
	voyage := self.addVoyageWithConRORO(Voyagecode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	//create the GC areas (only every declared per voyage, NOT at vessel level.)
	deck := voyage.myROROStructure.allDecks.first;
	voyage.myROROStructure.createQuickGCLocation(null,50.60,-10.10,deck,"GCIMPORT");
	voyInLocn := voyage.myROROStructure.allROROGCDefnByCode.getAtKey( "GCIMPORT").CM_ROROGCDefnVoyage.myGCController;
	self.assertTrueMsg(voyInLocn &lt;&gt; null, "'GCIMPORT' area not created during setup");
	voyage.myROROStructure.createQuickGCLocation(null,113.40,-6.40,deck,"GCEXPORT");
	voyOutLocn := voyage.myROROStructure.allROROGCDefnByCode.getAtKey( "GCEXPORT").CM_ROROGCDefnVoyage.myGCController;
	self.assertTrueMsg(voyOutLocn &lt;&gt; null, "'GCEXPORT' area not created during setup");
	
	bbBC5 := self.addCargoBreakBulkAtLocation(BBId5, bbCargoType, 80, voyInLocn, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bbBC5 &lt;&gt; null, "'" &amp; BBId5 &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80000);
	self.updateTI( bbBC5 );
	
	//create discharge CC for cargo
	beginTransaction;
	voyInLocn.createDefaultDischargeCC(app.myPassport, false);
	commitTransaction;
	
	create loadTIs transient;
	create dischargeTIs transient;
	
	railArea := self.addRailArea(RailAreaId, 2, 5); // 2 rail lines, 5 spaces
	self.assertTrueMsg(railArea &lt;&gt; null, "Rail Area '" &amp; RailAreaId &amp; "' not created during setup.");
	
	//Inwards train with its wagons and cargo
	trainIn := self.addTrain(TrainCodeIn,null);
	self.assertTrueMsg(trainIn &lt;&gt; null, "'Train in' not created during setup");
	
	foreach index in 1 to 4 do
		tiId := BBIdInTrainBaseId &amp; index.String;
		wagonId := WagonIdInBaseId &amp; index.String;
		self.opts.purge();
		self.opts.addAssoc("RailLine", railArea.allRailLines.first); // inward train wagons first line of two
		wagon := self.addWagonInRailArea(wagonId, WagonClassBC, railArea, trainIn);
		self.assertTrueMsg(wagon &lt;&gt; null, "'" &amp; wagonId &amp; "' box car not created on 'train in' during setup");
		self.opts.purge();
		self.opts.addAssoc("CargoType", bbCargoType.id);
		self.opts.addAssoc("Wagon", wagon);
		self.opts.addAssoc("ExportVoyage", voyage);
		self.opts.addAssoc("TotalQuantity", 20.Integer );
		ti := self.addPrenoted( tiId ).CM_BreakBulkGeneric;
		self.opts.purge();
		self.assertTrueMsg(ti &lt;&gt; null, "'" &amp; tiId &amp; "' not created during setup");
		loadTIs.add(ti);
	endforeach;
	
	// Outwards train with its wagons
	self.opts.purge();
	trainOut := self.addTrain(TrainCodeOut,null);
	self.assertTrueMsg(trainIn &lt;&gt; null, "'Train out' not created during setup");
	self.opts.addAssoc("RailLine", railArea.allRailLines.last); // outward train wagons the second line of two
	foreach index in 1 to 4 do
		wagonId := WagonIdOutBaseId &amp; index.String;
		wagon := self.addWagonInRailArea(wagonId, WagonClassBC, railArea, trainOut);
		self.assertTrueMsg(wagon &lt;&gt; null, "'" &amp; wagonId &amp; "' box car not created on 'train out' during setup");
	endforeach;
	self.opts.purge();
	
	//now make both trains arrive
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, trainIn, false, app.myPassport);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, trainOut, false, app.myPassport);
	
	//clear any stops
	self.deleteStops( bbBC5 );
	
	create theLCs transient;
	theLCs.add(voyInLocn);
	app.myTrxCA.trxCreateRORODischargeCCs(theLCs, app.myPassport);
	create tmpLCs transient;
	tmpLCs.add(voyInLocn);
	voyDischJob := self.addVoyageROROJob(voyage, deck, DRWorkPoint, tmpLCs, true);
	self.assertNotNullMsg(voyDischJob, "voyage job not created");
	
	workPoint := self.getWorkpoint(DRWorkPoint);

	//plan the outward rail cargo
	self.opts.addAssoc("TotalQuantity", 20.Integer );
	foreach wagon in trainOut.allWagonsByIdOutward do
		self.createRailOutPlanned( wagon, bbBC5 );
	endforeach;
	self.opts.purge();

	
	
	create tas transient;
	tas.add(railArea.id);
	queue := self.addVoyageQueue(voyage);
	beginTransaction;
	queue.createWorkPointQueue(workPoint, wpQueue);
	commitTransaction;
	
	machine := self.addMachine(MACHINETYPE_FORK_LIFT, STRA1, 94, tas, queue.id);
	imv := self.addIMV(IMV1, 93, tas, queue.id);

	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
//Start the test	

	//===================
	//	Ship To Rail
	//===================
	
	//============
	//**Lander Instant Move**
	//============
	
	create vwles transient;
	voyDischJob.getWLEsForTI(bbBC5, vwles);
	railReleaseJob:=  bbBC5.jobRailRelease;
	
	vwle := vwles.at(1).CM_VoyageWLE;
	self.assertNotNullMsg(vwle, "voyage wle 1 not created");
	ywle := railReleaseJob.workListEntries.getFirstUnactionedWLE.CM_YardWLE;
	self.assertNotNullMsg(ywle, "rail wle 1 not found");
	targetLoc := ywle.getTargetLocation();
	self.handHeldDirectDischargeTrx( bbBC5, targetLoc, vwle );
	
	self.assertTrueMsg(ywle.status = WLE_COMPLETED, "Rail Wle 1 not complete");
	self.assertTrueMsg(vwle.status = WLE_COMPLETED, "Voyage Wle 1 not complete");
	self.assertTrueMsg(ywle.myTrackedItem.getTransReceive &lt;&gt; null, "No receipt transaction");
	self.assertTrueMsg(ywle.myTrackedItem.getTransReceiveFirst = ywle.myTrackedItem.getTransReceive, "There should only be one receipt transaction");
	
	
	//=============
	// FL Move
	//=============
	self.addMachineRuleType(app.myRoot.allTerminalAreaTypes.getAtKey(TA_TYPE_WORKPOINT_INTERCHANGE), railArea.myType, RTMoveMethod_24, LegMoveQueuing);
	vwle := vwles.at(2).CM_VoyageWLE;
	self.assertNotNullMsg(vwle, "voyage wle 2 not created");
	ywle := railReleaseJob.workListEntries.getFirstUnactionedWLE.CM_YardWLE;
	self.assertNotNullMsg(ywle, "rail wle 2 not found");
	targetLoc := ywle.getTargetLocation();
	create tmpWLEs transient;
	create tmpWLEWarn transient;
	tmpWLEs.add(vwle);
	app.myPassport.setWarningsAcknowledged(true);
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWLEsDoMove(tmpWLEs, tmpWLEWarn, QUEUE_MODE, false,app.actualTimeServer, app.myPassport);
	app.myPassport.setWarningsIgnored(false);
	
	self.machineAssignToQueue(machine, wpQueue);
	queueEntry := vwle.allRTQueueEntries.first;
	queuetask := queueEntry.allTasks.first;
	vQtyBefore := vwle.job.workListEntries.size();
	yQtyBefore := ywle.job.workListEntries.size();
	app.isRTApp:=true;  
	self.machineLogon(machine);
	//set to move 10 at a time
	self.opts.addAssoc("QUANTITY", 10.Integer );
	//move first half
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machinePickup(machine);
	self.machineSetdownTask(machine, machine.allCurrentQueueTasks.first, ywle.getTargetLocation().getFullId);
	self.assertEqualMsg(vQtyBefore + 1, vwle.job.workListEntries.size(), "new vwle not created during split move");
	self.assertEqualMsg(yQtyBefore + 1, ywle.job.workListEntries.size(), "new ywle not created during split move");
	//move second half
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machinePickup(machine);
	self.machineSetdownTask(machine, machine.allCurrentQueueTasks.first, ywle.getTargetLocation().getFullId);
	
	self.assertTrueMsg(ywle.status = WLE_COMPLETED, "Rail Wle 2 not complete");
	self.assertTrueMsg(vwle.status = WLE_COMPLETED, "Voyage Wle 2 not complete");
	self.assertTrueMsg(ywle.myTrackedItem.getTransReceive &lt;&gt; null, "No receipt transaction");
	self.assertTrueMsg(ywle.myTrackedItem.getTransReceiveFirst = ywle.myTrackedItem.getTransReceive, "There should only be one receipt transaction");
	
	//=============
	// Lander discharge to ground in transit
	//=============
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);

	wpi := self.addWorkPointTransferArea(DRWorkPoint &amp; "TA", workPoint);
	beginTransaction;
	machine.addTAMaster(wpi);
	commitTransaction;
	tmpLCs.clear;
	wpi.CM_WorkPointInterchangeArea.getLanes(tmpLCs);
	vwle := vwles.at(3).CM_VoyageWLE;
	self.assertNotNullMsg(vwle, "voyage wle 3 not created");
	ywle := railReleaseJob.workListEntries.getFirstUnactionedWLE.CM_YardWLE;
	self.assertNotNullMsg(ywle, "rail wle 3 not found");
	targetLoc := ywle.getTargetLocation();
	tmpWLEs.clear;
	tmpWLEs.add(vwle);
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWLEsDoMove(tmpWLEs, tmpWLEWarn, QUEUE_MODE, false,app.actualTimeServer, app.myPassport);
	result := agent.doLanderDischargeToGround(bbBC5, tmpLCs.first, GroundInTransit, null, null);
	app.myPassport.setWarningsIgnored(false);
	assertTrueMsg(result, "dishcarge failed");
	self.assertEqualMsg(vwle.myTrackedItem.myPrimaryActualLocation, tmpLCs.first, "Cargo not on ground");
	
	queueEntry := vwle.allRTQueueEntries.first;
	queuetask := queueEntry.allTasks.first;
	vQtyBefore := vwle.job.workListEntries.size();
	yQtyBefore := ywle.job.workListEntries.size();

	self.machineLogon(machine);
	//set to move 10 at a time
	self.opts.addAssoc("QUANTITY", 10.Integer );
	//move first half
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machinePickup(machine);
	self.machineSetdownTask(machine, machine.allCurrentQueueTasks.first, ywle.getTargetLocation().getFullId);
	self.assertEqualMsg(vQtyBefore + 1, vwle.job.workListEntries.size(), "vwle not created during split move");
	self.assertEqualMsg(yQtyBefore + 1, ywle.job.workListEntries.size(), "ywle not created during split move");
	//move second half
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machinePickup(machine);
	self.machineSetdownTask(machine, machine.allCurrentQueueTasks.first, ywle.getTargetLocation().getFullId);
	
	self.assertTrueMsg(ywle.status = WLE_COMPLETED, "Rail Wle 3 not complete");
	self.assertTrueMsg(vwle.status = WLE_COMPLETED, "Voyage Wle 3 not complete");
	
	
	//=============
	// move the rest to complete the job
	//=============
	vwle := vwles.at(4).CM_VoyageWLE;
	self.assertNotNullMsg(vwle, "voyage wle 4 not created");
	ywle := railReleaseJob.workListEntries.getFirstUnactionedWLE.CM_YardWLE;
	self.assertNotNullMsg(ywle, "rail wle 4 not found");
	targetLoc := ywle.getTargetLocation();
	self.handHeldDirectDischargeTrx( bbBC5, targetLoc, vwle );
	
	self.assertTrueMsg(ywle.status = WLE_COMPLETED, "Rail Wle 4 not complete");
	self.assertTrueMsg(vwle.status = WLE_COMPLETED, "Voyage Wle 4 not complete");
	self.assertTrueMsg(ywle.myTrackedItem.getTransReceive &lt;&gt; null, "No receipt transaction");
	self.assertTrueMsg(ywle.myTrackedItem.getTransReceiveFirst = ywle.myTrackedItem.getTransReceive, "There should only be one receipt transaction");
	
	
	
	self.assertTrueMsg(voyDischJob.status = JOB_COMPLETE, "voy job not complete");
	self.assertTrueMsg(railReleaseJob.status = JOB_COMPLETE, "rail job not complete");
	
	
	
	
	//===================
	// Rail To Ship
	//===================

	create roroLCs transient;
	create altRoroLCs transient;
	alloc := self.addVoyageAllocation(voyage, null, "", "", bbCargoType.id, false, false); 
	loadGC := app.myTrxCA.trxCreateROROGCLoadCC(null, 4, 10, 10, deck, app.myPassport);
	roroLCs.add(loadGC.getLC);
	self.addLCsToROROAllocation(true, alloc, roroLCs, altRoroLCs, 80);
	loadJob := self.addVoyageROROJob(voyage, deck, workPoint.code, roroLCs, false);
	
	// Plan each TI to the voyage
	foreach index in 1 to 4 do
		ti := loadTIs.at(index);
		ywle := ti.allWorklistEntries.first.CM_YardWLE;
		vwle := loadJob.workListEntries.last.CM_VoyageWLE;
		self.assertTrueMsg(vwle &lt;&gt; null, "voyage wle not created");
		self.assertTrueMsg(loadJob.workListEntries.size = index, "Too many wles created for load job");
		
		create moveController transient;
	
		moveController.isRehandleMove := false;
		moveController.setMoveMode(PLANNING_MODE);
		moveController.isSystemMove := true;
		moveController.isForcedMove := true;
		moveController.doingAutoLoadPlanning := true;
		
		moveController.setMyWorkListEntry(ywle);
		moveController.myDDWorkListEntry := vwle;
		moveController.setMyTrackedItem(ti);
		
		app.myPassport.setWarningsIgnored(true);
		moveController.moveTrackedItemTarget(self.getTerminal(), roroLCs.first, null, null);
		app.myPassport.setWarningsIgnored(false);
		
		delete moveController;
	endforeach;
	
	//===============
	//**Lander Instant Move**
	//================
	
	ti := loadTIs.at(1);
	wle := ti.allWorklistEntries.first;
	self.handHeldDirectDischargeTrx(ti, wle.getTargetLocation, wle);
	foreach wle in ti.allWorklistEntries do
		self.assertTrueMsg(wle.status = WLE_COMPLETED, "Not all WLEs for TI are complete");
		if wle.isKindOf(CM_YardWLE) then
			self.assertTrueMsg(wle.job.status = JOB_COMPLETE, "rail job not complete");
		endif;
	endforeach;
	self.assertTrueMsg(ti.isOnShip, "Cargo not on ship");
	
	//==============
	// FL Move
	//==============
	ti := loadTIs.at(2);
	vwle := ti.allWorklistEntries.getFirstWleOfClass(CM_VoyageWLE).CM_VoyageWLE;
	ywle := ti.allWorklistEntries.getFirstWleOfClass(CM_YardWLE).CM_YardWLE;
	
	self.addMachineRuleType(railArea.myType, app.myRoot.allTerminalAreaTypes.getAtKey(TA_TYPE_WORKPOINT_INTERCHANGE), RTMoveMethod_24, LegMoveQueuing);
	tmpWLEs.clear;
	tmpWLEWarn.clear;
	tmpWLEs.add(ywle);
	app.myPassport.setWarningsAcknowledged(true);
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWLEsDoMove(tmpWLEs, tmpWLEWarn, QUEUE_MODE, false,app.actualTimeServer, app.myPassport);
	app.myPassport.setWarningsIgnored(false);
	
	self.machineAssignToQueue(machine, wpQueue);
	queueEntry := ywle.allRTQueueEntries.first;
	queuetask := queueEntry.allTasks.first;
	vQtyBefore := vwle.job.workListEntries.size();
	yQtyBefore := ywle.job.workListEntries.size();

	self.machineLogon(machine);
	self.opts.addAssoc("QUANTITY", 10.Integer );
	//move first half
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machinePickup(machine);
	self.machineSetdownTask(machine, machine.allCurrentQueueTasks.first, vwle.getTargetLocation().getFullId);
	self.assertEqualMsg(vQtyBefore + 1, vwle.job.workListEntries.size(), "vwle not created during split move");
	self.assertEqualMsg(yQtyBefore + 1, ywle.job.workListEntries.size(), "ywle not created during split move");
	//move second half
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machinePickup(machine);
	self.machineSetdownTask(machine, machine.allCurrentQueueTasks.first, vwle.getTargetLocation().getFullId);
	
	foreach wle in ti.allWorklistEntries do
		self.assertTrueMsg(wle.status = WLE_COMPLETED, "Not all WLEs for TI are complete");
		if wle.isKindOf(CM_YardWLE) then
			self.assertTrueMsg(wle.job.status = JOB_COMPLETE, "rail job not complete");
		endif;
	endforeach;
	self.assertTrueMsg(vwle.myTrackedItem.isOnShip, "Cargo not on ship");
	
	//================
	//**FL-&gt;IMV-&gt;FL**
	//================
	ti := loadTIs.at(3);
	wle := ti.allWorklistEntries.first;
	vwle := ti.allWorklistEntries.getFirstWleOfClass(CM_VoyageWLE).CM_VoyageWLE;
	ywle := ti.allWorklistEntries.getFirstWleOfClass(CM_YardWLE).CM_YardWLE;
	
	self.addMachineRuleType(railArea.myType, app.myRoot.allTerminalAreaTypes.getAtKey(TA_TYPE_WORKPOINT_INTERCHANGE), RTMoveMethod_4, LegMoveQueuing);
	tmpWLEs.clear;
	tmpWLEWarn.clear;
	tmpWLEs.add(ywle);
	app.myPassport.setWarningsAcknowledged(true);
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWLEsDoMove(tmpWLEs, tmpWLEWarn, QUEUE_MODE, false,app.actualTimeServer, app.myPassport);
	app.myPassport.setWarningsIgnored(false);
	
	self.machineAssignToQueue(machine, wpQueue);
	queueEntry := ywle.allRTQueueEntries.first;
	queuetask := queueEntry.allTasks.first;
	vQtyBefore := vwle.job.workListEntries.size();
	yQtyBefore := ywle.job.workListEntries.size();

	self.machineLogon(machine);
	self.opts.addAssoc("QUANTITY", 20.Integer );
	//move onto IMV
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machinePickup(machine);
	self.machineSetdownTask(machine, machine.allCurrentQueueTasks.first, imv.myMachineController.id);
	self.assertEqualMsg(ti.myPrimaryActualLocation, imv.myMachineController, "Cargo not found on IMV");
	queueEntry := queueEntry.myNextRelatedEntry;
	queueEntry := queueEntry.myNextRelatedEntry;
	queuetask := queueEntry.allTasks.first;
	//Move onto vessel
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machinePickup(machine);
	self.machineSetdownTask(machine, machine.allCurrentQueueTasks.first, vwle.getTargetLocation().getFullId);
	
	foreach wle in ti.allWorklistEntries do
		self.assertTrueMsg(wle.status = WLE_COMPLETED, "Not all WLEs for TI are complete");
		if wle.isKindOf(CM_YardWLE) then
			self.assertTrueMsg(wle.job.status = JOB_COMPLETE, "rail job not complete");
		endif;
	endforeach;
	self.assertTrueMsg(vwle.myTrackedItem.isOnShip, "Cargo not on ship");
		
	
	//=============
	// move the rest to complete the job
	//=============
	
	ti := loadTIs.at(4);
	wle := ti.allWorklistEntries.first;
	self.handHeldDirectDischargeTrx(ti, wle.getTargetLocation, wle);
	foreach wle in ti.allWorklistEntries do
		self.assertTrueMsg(wle.status = WLE_COMPLETED, "Not all WLEs for TI are complete");
		if wle.isKindOf(CM_YardWLE) then
			self.assertTrueMsg(wle.job.status = JOB_COMPLETE, "rail job not complete");
		endif;
	endforeach;
	self.assertTrueMsg(ti.isOnShip, "Cargo not on ship");
	
	
	self.assertTrueMsg(loadJob.status = JOB_COMPLETE, "Voyage load job not complete");
	
	
	
	// all finished, now clean - up
	self.machineLogOff(machine);
	self.machineLogOff(imv);
	self.deleteVoyage(Voyagecode);
	foreach index in 1 to 4 do
		tiId := BBIdInTrainBaseId &amp; index.String;
		self.deleteCargo( tiId, bbCargoType );
	endforeach;
	self.deleteCargo( BBId5, bbCargoType );
	
	usetupDRWagonClasses( true );  //delete only
	
	self.deleteTrain(TrainCodeIn,null);
	self.deleteTrain(TrainCodeOut,null);
	
	self.deleteRailArea(RailAreaId);

epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	app.isRTApp:=false;
	delete agent;
	delete theLCs;
	delete tmpLCs;
	delete loadTIs;
	delete dischargeTIs;
	delete vwles;
	delete tas;
	delete tmpWLEs;
	delete tmpWLEWarn;
	delete roroLCs;
	delete altRoroLCs;
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDirectReleaseShipToRail" id="79265ef5-525b-4a64-87df-87e6002a3353">
        <source>tDirectReleaseShipToRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2019	jlgzm1	Initial creation

*/

constants

	VoyageName 		= 'UTDRVOY1';
	ShipName 		= 'UTDRVES1';
	TestOperator	= 'MSK';
	CraneTransferAreaId	= "UTDRCT";
	IMV1 	= "UTIM";
	STRA1	= "USTL";
	CONT1 	= "UTDR0000001";
	CONT2 	= "UTDR0000002";
	CONT3 	= "UTDR0000003";
	CONT4 	= "UTDR0000004";
	CONT5 	= "UTDR0000005";
	
	TRAIN_CODE 		: String = "UT-TRAINDR";
	WAGON_CODE 		: String = "UK0115";
	RAIL_AREA_ID 	: String = "ZPO8463";

vars
	strs 			: StringArray;
	cta				: CM_CraneTransferArea;
	rail			: CM_Rail;
	ta 				: CM_TerminalArea;
	tas				: StringArray;
	vessel 			: CM_Vessel;
	voyage 			: CM_Voyage;
	queue			: CM_VoyageQueue;
	rampQueue		: CM_VoyageCraneQueue;
	queueEntry		: CM_RTQueueEntry;
	queuetask		: CM_RTQueueTask;
	cargo1, cargo2, cargo3,
	cargo4,cargo5	: CM_TrackedItem;
	crane			: CM_Machine;
	imv				: CM_Machine;
	straddle		: CM_Machine;
	wagon 			: CM_Wagon;
	theSlot 		: CM_LocationsController;
	idx				: Integer;
	slotsFrom		: CM_SlotControllerArray;
	tmpLoadCC		: CMIF_LoadColorCode;
	job 			: CM_VoyageJob;
	railJob 		: CM_RailJob;
	railWle 		: CM_WorkListEntry;
	vwle1,vwle2, vwle3	: CM_VoyageWLE;
	wle 			: CM_WorkListEntry;
	sourceLoc		: CM_LocationsController;
	targetLoc 		: CM_LocationsController;
	agent 			: CMIF_MobileGenericAgent;
	result			: Boolean;
	rule 			: CM_RTQueueMultiRuleTAMaster;
	tmpCTA, tmpRTA 	: CM_TerminalArea;
	ctaType, rtaType : CM_TerminalAreaType;
begin
	//**********
	// CLEANUP
	//**********
	tmpCTA := self.getTerminalArea(CraneTransferAreaId);
	tmpRTA := self.getTerminalArea(RAIL_AREA_ID);
	if tmpCTA &lt;&gt; null then
		ctaType := tmpCTA.myType;
	endif;
	if tmpRTA &lt;&gt; null then
		rtaType := tmpRTA.myType;
	endif;

	self.deleteMachineRule(ctaType, rtaType);
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID); 
	self.assertNullMsg(getTerminalArea(RAIL_AREA_ID), "Railway track");
	self.deleteMachine("UTMC");
	
	//***************************
	// Setup
	//***************************
	//Create Rail area and then arrive a Train with no cargo.
	wagon := createRailTrainAndWagon(WAGON_CODE,TRAIN_CODE,RAIL_AREA_ID, null, null);
	
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	rail := self.getTerminalArea(RAIL_AREA_ID).CM_Rail; 
	ctaType := cta.myType;
	rtaType := rail.myType;

	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("UTMC", null, tas, null);
	
	//initialize voyage/vessel
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, crane);
	
	//Create Containers on Voyage
	create strs transient;
	deleteContainer(CONT1);
	strs.clear;
	strs.add("010682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo1 := self.addContainerAtLocnDisch(CONT1, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	deleteContainer(CONT2);
	strs.clear;
	strs.add("010684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo2 := self.addContainerAtLocnDisch(CONT2, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	deleteContainer(CONT3);
	strs.clear;
	strs.add("010686");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addContainerAtLocnDisch(CONT3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	deleteContainer(CONT4);
	strs.clear;
	strs.add("010482");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addContainerAtLocnDisch(CONT4, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);
	
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageName, "01", DeckOnDeck, 1, 1, 3, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	job := self.addVoyageJob(voyage, crane.code, slotsFrom, true);
	self.assertNotNullMsg(job, "voyage job not created");
	vwle1 := job.getWLEForTI(cargo1).CM_VoyageWLE;
	self.assertNotNullMsg(vwle1, "voyage wle 1 not created");
	vwle2 := job.getWLEForTI(cargo2).CM_VoyageWLE;
	self.assertNotNullMsg(vwle2, "voyage wle 2 not created");
	vwle3:= job.getWLEForTI(cargo3).CM_VoyageWLE;
	self.assertNotNullMsg(vwle3, "voyage wle 3 not created");
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
	// mark cargo as release by train and assign and plan to train.
	self.assignSlotToTrain(slotsFrom, wagon,cargo1,1);
	self.assignSlotToTrain(slotsFrom, wagon,cargo2,3);
	self.assignSlotToTrain(slotsFrom, wagon,cargo3,5);

	railJob := cargo1.jobRailRelease;
	self.assertTrueMsg(railJob &lt;&gt; null, "DR Rail Release Job not created");
	railWle := railJob.getWLEForTI(cargo1);
	self.assertTrueMsg(railWle &lt;&gt; null, "DR Rail Release Job has no WLE");
	self.assertNotNull(cargo1.myPrimaryPlannedLocation);
	assertTrueMsg(cargo1.myPrimaryPlannedLocation.isKindOf(CM_FlatcarWagonController), "cargo1 not planned to the rail");
	self.assertNotNull(cargo2.myPrimaryPlannedLocation);
	assertTrueMsg(cargo2.myPrimaryPlannedLocation.isKindOf(CM_FlatcarWagonController), "cargo2 not planned to the rail");
	self.assertNotNull(cargo3.myPrimaryPlannedLocation);
	assertTrueMsg(cargo3.myPrimaryPlannedLocation.isKindOf(CM_FlatcarWagonController), "cargo3 not planned to the rail");
	
	
	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	self.machineAssignToQueue(imv, rampQueue);
	straddle := self.addMachine(MACHINETYPE_STRADDLE, STRA1, 94, tas, rampQueue.id);
	self.machineAssignToQueue(straddle, rampQueue);
	
	targetLoc := railWle.getTargetLocation();
	
	//*********************************
	// lander instant move
	//***********************************
	self.handHeldDirectDischargeTrx( cargo1, targetLoc, vwle1 );
	
	// Check that:
	// No errors
	// Voyage job, Rail job, and both WLEs are completed.
	// Check that the cargo has ship receive transaction
	
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "Rail Wle 1 not complete");
	self.assertTrueMsg(vwle1.status = WLE_COMPLETED, "Voyage Wle 1 not complete");
	self.assertTrueMsg(cargo1.getTransReceive &lt;&gt; null, "No receipt transaction");
	self.assertTrueMsg(cargo1.getTransReceiveFirst = cargo1.getTransReceive, "There should only be one receipt transaction");
	
	
	//********************
	// lander discharge to machine
	//*********************
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	
	self.addMachineRuleType(ctaType, rtaType, RTMoveMethod_9, FullMoveQueuing);
	
	result := agent.doLanderDischarge(cargo2, imv.getMyVehicleMachineController, null, null);
	self.assertTrueMsg(result, "Failed to discharge to IMV");
	assertEqualMsg(cargo2.myPrimaryActualLocation, imv.myMachineController, "Cargo not found on IMV");
	self.assertNotNull(cargo2.myPrimaryQueuedLocation);
	
	railWle := vwle2.getDRLinkedWLE;
	queueEntry := vwle2.allRTQueueEntries.first;
	queueEntry:= queueEntry.getNextRelatedEntry;
	queuetask := queueEntry.allTasks.first;
	
	app.isRTApp:=true;  
	self.machineLogon(imv);
	self.machineLogon(straddle);
	self.machineAcceptSpecifiedTask(straddle, queueEntry);
	self.machinePickup(straddle);
	assertEqual(queueEntry.allTasks.size, 2);
	assertEqual(queueEntry.allTasks.last.ti, cargo2);
	self.machineSetdownTask(straddle, queueEntry.allTasks.last, railWle.getTargetLocation().getFullId);
	
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "Rail Wle 2 not complete");
	self.assertTrueMsg(vwle2.status = WLE_COMPLETED, "Voyage Wle 2 not complete");
	self.assertTrueMsg(cargo2.getTransReceive &lt;&gt; null, "No receipt transaction");
	self.assertTrueMsg(cargo2.getTransReceiveFirst = cargo2.getTransReceive, "There should only be one receipt transaction");
	
	
	//*********************************
	// Lander move to ground in transit
	//*********************************
	self.deleteMachineRule(ctaType, rtaType);
	self.addMachineRuleType(ctaType, rtaType, RTMoveMethod_23, FullMoveQueuing);
	
	result := agent.doLanderDischargeToGround(cargo3, cta.dischargeLanes.first, GroundInTransit, null, null);
	assertTrueMsg(result, "dishcarge failed");
	self.assertEqualMsg(cargo3.myPrimaryActualLocation, cta.dischargeLanes.first, "Cargo 3 not on ground");
	
	railWle := vwle3.getDRLinkedWLE;
	queueEntry := vwle3.allRTQueueEntries.first;
	queuetask := queueEntry.allTasks.first;

	self.machineLogon(straddle);
	self.machineAcceptSpecifiedTask(straddle, queueEntry);
	self.machinePickup(straddle);
	assertEqual(queueEntry.allTasks.size, 2);
	assertEqual(queueEntry.allTasks.last.ti, cargo3);
	self.machineSetdownTask(straddle, queueEntry.allTasks.last, railWle.getTargetLocation().getFullId);
	
	self.assertTrueMsg(railWle.status = WLE_COMPLETED, "Rail Wle 3 not complete");
	self.assertTrueMsg(vwle3.status = WLE_COMPLETED, "Voyage Wle 3 not complete");
	self.assertTrueMsg(cargo3.getTransReceive &lt;&gt; null, "No receipt transaction");
	self.assertTrueMsg(cargo3.getTransReceiveFirst = cargo3.getTransReceive, "There should only be one receipt transaction");
	
	
	//*******************
	// For sake of completion
	//*******************
	// Depart the Train.
	self.departTrainAndClearRake( wagon.myTrainInwards );
	
	self.assertTrueMsg(cargo1.site = TI_SITE_OFFSITE, cargo1.id &amp; " should be offsite after departure!");
	self.assertTrueMsg(cargo1.getTransRelease() &lt;&gt; null, cargo1.id &amp; " no release trnsaction");
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_REL_RAIL);
	
	self.assertTrueMsg(cargo2.site = TI_SITE_OFFSITE, cargo2.id &amp; " should be offsite after departure!");
	self.assertTrueMsg(cargo2.getTransRelease() &lt;&gt; null, cargo2.id &amp; " no release trnsaction");
	self.checkTIForTxnOfType(cargo2, TRANS_TYPE_REL_RAIL);
	
	self.assertTrueMsg(cargo3.site = TI_SITE_OFFSITE, cargo3.id &amp; " should be offsite after departure!");
	self.assertTrueMsg(cargo3.getTransRelease() &lt;&gt; null, cargo3.id &amp; " no release trnsaction");
	self.checkTIForTxnOfType(cargo3, TRANS_TYPE_REL_RAIL);
	
	self.machineLogOff(straddle);
	self.machineLogOff(imv);
	
	//finished clean up 
	self.deleteMachineRule(ctaType, rtaType);
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID); 
	self.assertNullMsg(getTerminalArea(RAIL_AREA_ID), "Railway track");
	self.deleteMachine("UTMC");
	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	app.isRTApp:=false;
	delete slotsFrom;
	delete strs;
	delete tas;
	delete agent;
	if voyage &lt;&gt; null then
		self.deleteVoyageJobs(voyage);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tDirectReleaseShipToShip" id="7b1cdace-2a88-4e40-935c-9db416609e98">
        <source>tDirectReleaseShipToShip();
/*

Purpose:			Unit test for testing Direct Release Moves from Ship to Ship
					Only Hold Voyages at the moment

Parameters:			

Return Value:		

Date				Who		Reason
31 October 2019		jlgzm1	Initial creation TFS 47085 Direct Release Ship to Ship

*/
constants
	// Voyages/Vessels
	VesselCodeA 	: String = 'UT_HOLD_DR1';
	VesselCodeB 	: String = 'UT_HOLD_DR2';
	VoyagecodeA 	: String = 'DRHOLDVOY1';
	VoyagecodeB 	: String = 'DRHOLDVOY2';
	
	// Cargo Types
	BBULKCargoType 	: String = "UTREBAR";  // Pre existing Break Bulk cargo type allows duplicates
	BULKCargoType 	: String = "UTDRBULK"; // New bulk cargo type for test
	
	// Work points
	DRWorkPoint 	: String = "DRWP";
	
	//Terminal Areas
	BlockStackID	: String = "UTBLS1";
	
	// Cargo IDs
	BBId 			: String = "DRSS0007001";
	BBId2 			: String = "DRSS0007002";
	BulkId 			: String = "DRSS0008001";
	ContId 			: String = "DRSS0009001";
	ContId2 		: String = "DRSS0009002";
vars
	operator 		: CM_Operator;
	shipLineStr 	: String;
	vesselA			: CM_Vessel;
	vesselB			: CM_Vessel;
	voyageA 		: CM_Voyage;
	voyageB 		: CM_Voyage;
	importHold 		: CM_LocationsController;
	exportHold 		: CM_LocationsController;
	tmpBS 			: CM_BlockStack;
	
	bbTI			: CM_BreakBulkGeneric;
	bbTI2			: CM_BreakBulkGeneric;
	bulkTI			: CM_Bulk;
	contTI			: CM_Container;
	contTI2			: CM_Container;
	
	bbCargoType 	: CM_CargoType;
	bulkCargoType 	: CM_CargoType;
	contCargoType 	: CM_CargoType;
	
	allTIs			: CM_TISet;
	ti				: CM_TrackedItem;
	
	job				: CM_Job;
	allJobs			: CM_JobSet;
	dischJob1		: CM_VoyageHoldJob;
	dischJob2		: CM_VoyageHoldJob;
	dischJob3		: CM_VoyageHoldJob;
	loadJob1		: CM_VoyageHoldJob;
	loadJob2		: CM_VoyageHoldJob;
	loadJob3		: CM_VoyageHoldJob;
	allocatedWLEs 	: CM_WLEArray;
	wlesWithWarn	: CM_WLEArray;
	loadWleSet		: CM_WLESet;
	tmpWLE			: CM_VoyageWLE;
	workPoint 		: CM_WorkPoint;
	wleA, wleB		: CM_WorkListEntry;
	index : Integer;
	drWle : CM_WorkListEntry;
	
begin
	//##########################
	//### Get Base Data
	//##########################
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBULKCargoType &amp; "' not found during setup.");
	
	self.opts.purge();
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	bulkCargoType := addCargoType(BULKCargoType, false);
	self.assertTrueMsg(bulkCargoType &lt;&gt; null, "Cargo Type '" &amp; BULKCargoType&amp; "' not created during setup.");
		

	//##########################
	//### Clean up old data
	//##########################
	self.deleteVoyage(VoyagecodeA);
	self.deleteVessel(VesselCodeA);
	self.deleteVoyage(VoyagecodeB);
	self.deleteVessel(VesselCodeB);
	
	self.deleteCargo( BBId, bbCargoType );
	self.deleteCargo( BBId2, bbCargoType );
	self.deleteCargo( BulkId, bulkCargoType );
	self.deleteContainer( ContId );
	self.deleteContainer( ContId2 );
	
	self.deleteTerminalArea(BlockStackID);
	
	//##########################
	//### Set up new data
	//##########################
	vesselA := self.addVesselWithHolds(VesselCodeA, 2, 1);
	self.assertNotNullMsg(vesselA, "Vessel A not created during setup");
	voyageA := self.addVoyageWithGeneralCargoStruc(VoyagecodeA, VesselCodeA, operator.code, shipLineStr, 0);
	self.assertNotNullMsg(vesselA, "Voyage A not created during setup");
	vesselB := self.addVesselWithHolds(VesselCodeB, 2, 1);
	self.assertNotNullMsg(vesselA, "Vessel B not created during setup");
	voyageB := self.addVoyageWithGeneralCargoStruc(VoyagecodeB, VesselCodeB, operator.code, shipLineStr, 0);
	self.assertNotNullMsg(vesselA, "Voyage A not created during setup");
	
	importHold := voyageA.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	assertNotNullMsg(importHold, "VoyageA doesn't have any holds");
	exportHold := voyageB.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	assertNotNullMsg(exportHold, "VoyageB doesn't have any holds");
	
	// need an onsite target to create discharge job, create block stack just for planning, nothing actually needs to be moved there
	tmpBS:=self.addBlockStack(BlockStackID, 100, null);
	self.assertNotNullMsg(tmpBS, tmpBS.id);
	
	
	//##########################
	//### Create Cargo on Ship
	//##########################
	create allTIs transient;
	
	bbTI := self.addCargoBreakBulkAtLocation(BBId, bbCargoType, 80, importHold, null, TI_IMEX_STATUS_IMPORT, voyageA, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bbTI &lt;&gt; null, "'" &amp; BBId &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80000);
	self.updateTI( bbTI );
	allTIs.add(bbTI);
	
	bbTI2 := self.addCargoBreakBulkAtLocation(BBId2, bbCargoType, 80, importHold, null, TI_IMEX_STATUS_IMPORT, voyageA, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bbTI2 &lt;&gt; null, "'" &amp; BBId &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80000);
	self.updateTI( bbTI2 );
	allTIs.add(bbTI2);
	
	bulkTI := self.addCargoBreakBulkAtLocation(BulkId, bulkCargoType, 1, importHold, null, TI_IMEX_STATUS_IMPORT, voyageA, operator).CM_Bulk;
	self.assertTrueMsg(bulkTI &lt;&gt; null, "'" &amp; BulkId &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80000);
	self.updateTI( bulkTI );
	allTIs.add(bulkTI);
	
	contTI := self.addContainerAtLocation(ContId, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, importHold);
	self.assertTrueMsg(contTI &lt;&gt; null, "'" &amp; ContId &amp; "' on ship cargo not created during setup");
	allTIs.add(contTI);
	
	contTI2 := self.addContainerAtLocation(ContId2, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, importHold);
	self.assertTrueMsg(contTI2 &lt;&gt; null, "'" &amp; ContId2 &amp; "' on ship cargo not created during setup");
	allTIs.add(contTI2);
	
	
	//##########################
	//### Set For Tranship
	//##########################
	
	foreach ti in allTIs do
		self.setCargoAsTranshipTo(ti, voyageB);
		self.assertTrueMsg(ti.isTranshipItem, "'" &amp; ti.id &amp; "' not set as tranship");
		self.assertTrueMsg(ti.isTranshipInbound, "'" &amp; ti.id &amp; "' not set as inbound tranship");
		self.deleteStops(ti);
	endforeach;
	
	//##########################
	//### Create Jobs
	//##########################
	
	workPoint := self.getWorkpoint(DRWorkPoint);
	
	create allocatedWLEs transient;
	foreach ti in allTIs do
		create tmpWLE transient;	
		allocatedWLEs.add(tmpWLE);
		tmpWLE.setMyTrackedItem(ti);
		if ti.isKindOf(CM_BreakBulkGeneric) then
			tmpWLE.setQuantity(ti.totalQuantity);
		elseif ti.isKindOf(CM_Bulk) then
			tmpWLE.setWeight(ti.totalWeight);
		endif;
	endforeach;
	
	dischJob1 := self.addVoyageHoldJob(JOB_TYPE_DISCHARGE, voyageA, allocatedWLEs, tmpBS.myLocationsController, workPoint);
	self.assertNotNullMsg(dischJob1, "Discharge job 1 not created");
	self.assertEqualMsg(dischJob1.workListEntries.size, allTIs.size, "Discharge Job 1 has wrong number of WLEs");
	
	allocatedWLEs.purge();
	foreach ti in allTIs do
		create tmpWLE transient;	
		allocatedWLEs.add(tmpWLE);
		tmpWLE.setMyTrackedItem(ti);
		if ti.isKindOf(CM_BreakBulkGeneric) then
			tmpWLE.setQuantity(ti.totalQuantity);
		elseif ti.isKindOf(CM_Bulk) then
			tmpWLE.setWeight(ti.totalWeight);
		endif;
	endforeach;
	
	loadJob1 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyageB, allocatedWLEs, exportHold, workPoint);
	self.assertNotNullMsg(loadJob1, "Load job 1 not created");
	self.assertEqualMsg(loadJob1.workListEntries.size, allTIs.size, "Load Job 1 has wrong number of WLEs");
	
	//##################################
	//### Assign Jobs To Direct Release
	//##################################
	
	create loadWleSet transient;
	loadJob1.workListEntries.copy(loadWleSet);
	
	app.myTrxUA.trxUpdateWLEsSetDirectRelease(loadWleSet, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to assign to direct release");
	
	//##########################
	//### Mess with stuff
	//##########################
	
	wleA := loadWleSet.first();
	self.assertTrueMsg(wleA.myFutureMove &lt;&gt; null, "future move should not be null");
	wleB := wleA.getDRLinkedWLE();
	self.assertTrueMsg(wleB.myFutureMove = null, "future move should be null");
	
	create wlesWithWarn transient;
	allocatedWLEs.purge();
	allocatedWLEs.add(wleA);
	app.myTrxUA.trxUpdateWLEsUnplan(allocatedWLEs, wlesWithWarn, NO_MODE, app.myPassport);
	
	self.assertTrueMsg(wleA.myFutureMove &lt;&gt; null, "future move should not be null");
	self.assertTrueMsg(wleB.myFutureMove &lt;&gt; null, "future move should not be null");

	loadWleSet.clear();
	loadWleSet.add(wleA);
	app.myTrxUA.trxUpdateWLEsSetDirectRelease(loadWleSet, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to assign to direct release");
	
	//##########################
	//### Move Cargo
	//##########################
	
	foreach wleA in loadJob1.workListEntries do
		index := index + 1;
		if index.isEven then
			drWle := wleA.getDRLinkedWLE();
			self.handHeldDirectDischargeTrx(wleA.myTrackedItem, wleA.getTargetLocation, drWle);
			continue;
		endif;
		self.handHeldDirectDischargeTrx(wleA.myTrackedItem, wleA.getTargetLocation, wleA);	
	endforeach;
	
	//################################
	//### Check all jobs are complete
	//################################
	self.assertEqualMsg(dischJob1.status, JOB_COMPLETE, "Discharge job not complete");
	self.assertEqualMsg(loadJob1.status, JOB_COMPLETE, "Load Job not complete");
	
	//11 Mar 2020	NDL	TFS 48774
	self.assertTrueMsg(voyageA.allTITransactionsByDTType.size = 5, "Incorrect number of transactions on the incoming voyage s/be 5, got " &amp; voyageA.allTITransactionsByDTType.size.String );
	self.assertTrueMsg(voyageB.allTITransactionsByDTType.size = 5, "Incorrect number of transactions on the outgoing voyage s/be 5, got " &amp; voyageB.allTITransactionsByDTType.size.String );	
	self.assertTrueMsg(voyageA.allJobSheets.first.allShipReceivals.size = 5, "Incorrect number of receival transactions on the incoming voyage JOB Sheet s/be 5, got " &amp; voyageA.allJobSheets.first.allShipReceivals.size.String);
	self.assertTrueMsg(voyageB.allJobSheets.first.allShipReleases.size = 5, "Incorrect number of release transactions on the outgoing voyage JOB Sheet s/be 5, got " &amp; voyageA.allJobSheets.first.allShipReleases.size.String);
	
	//#############################
	//### Clean up after yourself
	//#############################
	
	self.deleteVoyage(VoyagecodeA);
	self.deleteVessel(VesselCodeA);
	self.deleteVoyage(VoyagecodeB);
	self.deleteVessel(VesselCodeB);
	
	self.deleteCargo( BBId, bbCargoType );
	self.deleteCargo( BBId2, bbCargoType );
	self.deleteCargo( BulkId, bulkCargoType );
	self.deleteContainer( ContId );
	self.deleteContainer( ContId2 );
	
	
	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	delete allTIs;
	if allocatedWLEs &lt;&gt; null then
		beginTransaction;
		allocatedWLEs.purge();
		commitTransaction;
	endif;
	delete allocatedWLEs;
	delete loadWleSet;
	delete wlesWithWarn;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSalalahDirectToShipQty1" id="0d3b28a8-4d03-4bfc-8353-d6a60f15292d">
        <source>tSalalahDirectToShipQty1();
//
// Purpose:			Test Salalah's Prenote Direct load from truck to multiple voyage locations for break-bulk by quantity
//					Replicates using the Cargo Lander by using CMIF_MobileGenericAgent::moveCargo method
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/11/2021	navdap1		Initial creation TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
//
constants
	ThisVoyageCode : String = "DAVEH51935_1";
	ThisVesselCode : String = "DAVEHOLD";
	REBAR : String = "REBAR";
	RebarId : String = "REBARDD51935_1";
	ThisWorkPoint : String = "WP51935_1";
	TruckId	: String = "UT51935_1";
	MoveCheck : String = "Move Check ";
	
vars
	terminal, passportTerminal : CM_Terminal;
	directTruckMoves : Boolean;
	operator : CM_Operator;
	rebarCargoType : CM_CargoType;
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	rebarPrenote, rebarOnsite, 	rebarin0101, rebarin0102, rebarin0201, rebarin0202 : CM_TrackedItem;
	hold0101, hold0102, hold0201, hold0202 : CM_GeneralCargoController;
	hold0101Str, hold0102Str, hold0201Str, hold0202Str : String;
	voyageWle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	allocatedWLEs : CM_WLEArray;
	jobSheet : CM_VoyageHoldJobSheet;
	holdjob : CM_VoyageJob;
	count, count2, qty, completeQty, unactionedQty : Integer;
	loc : String;
	mobileAgent : CMIF_MobileGenericAgent;
	targetLocation : CM_LocationsController;
	yardWLE, unactionedYardWLE : CM_YardWLE;
	voyageWleFound, yardWleFound : Boolean;
	roadjob : CM_RoadJob;
	correctQty1, correctQty2 : Boolean;
	vvr : CM_VehicleVisitRecord;
	moveCheck : String;
	yardJob : CM_Job;
	job100, job101, job102, job103 : CM_VoyageHoldJob;

begin
	// Set the terminal config that drives all of this
	terminal := self.getTerminal;
	directTruckMoves := self.setTerminalConfig(DirectTruck2VesselMult, true).Boolean;
	//return;
	///////////////////////////////////////
	// Sanity Check and Pre-run Clean Up //
	///////////////////////////////////////
	rebarCargoType := app.myRoot.getCargoTypeFromAbbrev(REBAR);
	self.assertTrueMsg(rebarCargoType &lt;&gt; null, REBAR &amp; "does not exist as a Cargo Type");
	
	self.opts.purge;
	self.opts.addAssoc("includePrenote", true);
	self.deleteCargo(RebarId, rebarCargoType);
	self.deleteVehicle(TruckId);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteWorkPoint(ThisWorkPoint);
	self.assertTrueMsg(self.getVoyage(ThisVoyageCode) = null, "Voyage " &amp; ThisVoyageCode &amp; " not deleted");
	
	////////////
	// Set Up //
	////////////
	// Create a Voyage with Holds
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage := self.addVoyageWithGeneralCargoStruc(ThisVoyageCode, ThisVesselCode, operator.code, "DOUG", 2);
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage not created");
	self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null and voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.size = 10, "General Cargo voyage not set up correctly");
	// and a workpoint
	workPoint := self.addWorkPoint(ThisWorkPoint, false);
	self.assertTrueMsg(workPoint &lt;&gt; null, "Work Point not created");
	
	hold0101 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,1];
	hold0102 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,2];
	hold0201 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,1];
	hold0202 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,2];
	hold0101Str := hold0101.getFullId;
	hold0102Str := hold0102.getFullId;
	hold0201Str := hold0201.getFullId;
	hold0202Str := hold0202.getFullId;
	
	// Create a prenote for the voyage splittable by quantity
	self.opts.purge;
	self.opts.addAssoc("CargoType", rebarCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 250);
	self.opts.addAssoc("DD", true);
	rebarPrenote := self.addPrenoted(RebarId);
	self.assertTrueMsg(rebarPrenote &lt;&gt; null, "Rebar prenote not created");
	self.assertEqualMsg(rebarPrenote.totalQuantity, 250, "Rebar prenote quantity is incorrect");
	self.assertTrueMsg(rebarPrenote.directDelivery = true, "Rebar prenote is not Direct Delivery");
	
	////////////////////////////////////////
	// Plan the prenote to multiple holds //
	////////////////////////////////////////
	// Load job 100 to 0101: 30 rebar 
	create allocatedWLEs transient;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(30);
	allocatedWLEs.add(voyageWle);
	job100 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0101, workPoint);
	beginTransaction;
	job100.setOriginalJobAmount(30);
	commitTransaction;
	
	// Load job 101 to 0102: 50 rebar 
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(50);
	allocatedWLEs.add(voyageWle);
	job101 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0102, workPoint);
	beginTransaction;
	job101.setOriginalJobAmount(50);
	commitTransaction;
	
	// Load job 102 to 0201: 70 rebar 
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(70);
	allocatedWLEs.add(voyageWle);
	job102 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job102.setOriginalJobAmount(70);
	commitTransaction;
	
	// Load job 103 to 0202: 100 rebar
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(100);
	allocatedWLEs.add(voyageWle);
	job103 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0202, workPoint);
	beginTransaction;
	job103.setOriginalJobAmount(100);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 4 jobs in its jobsheet, each job should have 1 WLE, prenote should have 4 WLEs 
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 4, "Voyage Job sheet has the wrong number of jobs");
	foreach holdjob in jobSheet.allJobsByJobNum do
		self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	endforeach;
	self.assertEqualMsg(rebarPrenote.allWorklistEntries.size, 4, "Rebar prenote has the wrong number of WLEs");
	// Check quantity / weight on each prenoted WLE
	// Rebar: 30 to 0101, 50 to 0102, 70 to 0201 and 100 to 0202
	foreach wle in rebarPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 30;
			loc := ThisVoyageCode &amp; Space &amp; "0101 Under Deck";
		elseif count = 2 then
			qty := 50;
			loc := ThisVoyageCode &amp; Space &amp; "0102 On Deck";
		elseif count = 3 then
			qty := 70;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		elseif count = 4 then
			qty := 100;
			loc := ThisVoyageCode &amp; Space &amp; "0202 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.quantity, qty, "Rebar WLE " &amp; count.String &amp; " has the wrong quantity");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Rebar WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	////////////////////////
	// Gate some rebar in //
	////////////////////////
	self.opts.purge;
	self.opts.addAssoc("Quantity", 50);
	vvr := self.gateInPrenote(TruckId, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	rebarOnsite := terminal.allOnsiteTIsByIdCargoType[RebarId, rebarCargoType.id];
	self.assertNotNullMsg(rebarOnsite, "No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite.totalQuantity, 50, "Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite.allWorklistEntries.size, rebarPrenote.allWorklistEntries.size + 1, "Onsite and prenoted rebar has different WLE count");
	foreach wle in rebarOnsite.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, rebarPrenote.allWorklistEntries.size, "Yard WLE has an incorrect number of direct delivery WLEs");
	
	///////////////////////////////////
	// Move some of the onsite cargo //
	///////////////////////////////////
	// Move from the truck to various holds in chunks - some chunks to partially satisfy a hold job, 
	// some to completely fill a hold job and overlap into the next hold job
	// (replicating the use of the Cargo Lander Mobile app)
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 10 rebar to hold 0101
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(rebarOnsite, targetLocation, null, 10, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. Onsite TI reduced from 50 to 40
	// 2. New onship TI in hold 0101 - quantity 10, with 2 WLEs (voyage and yard, both complete, both for quantity 10)
	// 3. Onsite rebar has 1 Yard WLE for 40. The job for this WLE has two yard WLEs - 1 complete for 10, one unactioned for 40
	// 4. Prenote TI has planned WLE for hold 0101 quantity reduced from 30 to 20
	// 5. Job for 0101 has one completed WLE for quantity 10, linked to onship TI
	moveCheck := MoveCheck &amp; "1: ";
	// 1. Onsite TI reduced from 50 to 40
	self.assertEqualMsg(rebarOnsite.totalQuantity, 40, moveCheck &amp; "Rebar onsite quantity is wrong");
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, moveCheck &amp; "On ship cargo count is wrong");
	// 2. New onship TI in hold 0101 - quantity 10, with 2 WLEs (voyage and yard, both complete, both for quantity 10)
	rebarin0101 := voyage.allOnshipTIsByIdCargoType[rebarOnsite.id, rebarOnsite.cargoType];
	self.assertNotNullMsg(rebarin0101, moveCheck &amp; "No on ship rebar with id " &amp; rebarOnsite.id);
	self.assertEqualMsg(rebarin0101.myPrimaryActualLocation, hold0101, "Rebar on ship is in the wrong location " &amp; rebarin0101.locationId);
	self.assertEqualMsg(rebarin0101.totalQuantity, 10, moveCheck &amp; "Rebar in 0101 has the wrong quantity");
	self.assertEqualMsg(rebarin0101.allWorklistEntries.size, 2, moveCheck &amp; "Rebar in 0101 has the wrong number of WLEs");
	foreach wle in rebarin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.quantity, 10, moveCheck &amp; "Rebar in 0101 voyage WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0101 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.quantity, 10, moveCheck &amp; "Rebar in 0101 yard WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0101 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Rebar in 0101 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Rebar in 0101 has no yard WLE");
	// 3. Onsite rebar has 1 Yard WLE for 40. The job for this WLE has two yard WLEs - 1 complete for 10, one unactioned for 40
	count := null;
	foreach wle in rebarOnsite.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		self.assertEqualMsg(wle.quantity, 40, moveCheck &amp; "Unactioned Yard WLE has wrong quantity");
		roadjob := wle.job.CM_RoadJob;
		break;
	endforeach;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Onsite Road WLE not found");
	foreach wle in roadjob.workListEntries do
		count := count + 1;
		if wle.status = WLE_COMPLETED then
			self.assertEqualMsg(wle.quantity, 10, moveCheck &amp; "Completed Yard WLE has wrong quantity");
		elseif wle.status = WLE_UNACTIONED then
			self.assertEqualMsg(wle.quantity, 40, moveCheck &amp; "Unactioned Yard WLE has wrong quantity");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Road job for Rebar onsite has wrong number of Yard WLEs");
	// 4. Prenote TI has planned WLE for hold 0101 quantity reduced from 30 to 20
	foreach wle in rebarPrenote.allWorklistEntries where wle.locationTarget = hold0101Str do
		self.assertEqualMsg(wle.quantity, 20, moveCheck &amp; "Rebar Prenote has wrong quantity for hold 0101");
	endforeach;
	// 5. Job 100 for 0101 has one completed WLE for quantity 10, linked to onship TI
	count := null;
	foreach wle in job100.workListEntries where wle.isKindOf(CM_VoyageWLE) do
		// there will be a WLE connected to the prenoted Rebar
		// just count the ones related to the onsite and onship cargo
		if wle.myTrackedItem = rebarOnsite then
			count := count + 1;
			self.assertEqualMsg(wle.quantity, 40, moveCheck &amp; "WLE for onsite rebar in hold job " &amp; job100.id &amp; " has the wrong quantity");
		elseif wle.myTrackedItem = rebarin0101 then
			count := count + 1;
			self.assertEqualMsg(wle.quantity, 10, moveCheck &amp; "WLE for onship rebar in hold job " &amp; job100.id &amp; " has the wrong quantity");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Hold Job " &amp; job100.id &amp; " has wrong number of WLEs");
	
	// Move the remaining 40 from the truck to hold 0101 again - this will complete job 100 and part-complete job 101
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// second move - 40 rebar to hold 0101. Will be split into 20 for hold 0101 and 20 for hold 0102
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(rebarOnsite, targetLocation, null, 40, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors");
	// Things to check:
	// 1. Onsite TI is no longer there
	// 2. There are 2 onship TIs - 1 in 0101 for 30 with 2 voyage WLEs and 2 yard WLEs, new one in 0102 for 20 with 1 voyage WLE and 1 yard WLE
	// 3. Road job has 3 completed yard WLEs - 1 for 10, 2 for 20
	// 4. Prenote now only has 3 WLEs - 0101 WLE has been deleted, 0102 WLE has been reduced to 30
	// 5. Job 100 is complete and has 2 voyage WLEs for 10 and 20, both linked to onship TI in 0101
	// 6. Job 101 is part complete and has 1 completed voyage WLE for 20, linked to onship TI in 0102
	moveCheck := MoveCheck &amp; "2: ";
	// 1. Onsite TI is no longer there
	self.assertTrueMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, moveCheck &amp; "There are " &amp; voyage.allOnsiteTIsByIdCargoType.size.String &amp; " onsite cargo items for the voyage");
	// 2. There are 2 onship TIs - 1 in 0101 for 30 with 2 voyage WLEs and 2 yard WLEs, new one in 1020 for 20 with 1 voyage WLE and 1 yard WLE
	self.assertTrueMsg(voyage.allOnshipTIsByIdCargoType.size = 2, moveCheck &amp; "There are " &amp; voyage.allOnshipTIsByIdCargoType.size.String &amp; " onship TIs");
	rebarin0101 := hold0101.allTrackedItems.first;
	self.assertTrueMsg(rebarin0101 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0101");
	self.assertTrueMsg(rebarin0101.totalQuantity = 30, moveCheck &amp; "Rebar in 0101 quantity is " &amp; rebarin0101.quantity.String);
	self.assertTrueMsg(rebarin0101.allWorklistEntries.size = 4, moveCheck &amp; "Rebar in 0101 has " &amp; rebarin0101.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	foreach wle in rebarin0101.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		count := count + 1;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Rebar in 0101 has " &amp; count.String &amp; " Voyage WLEs");
	rebarin0102 := hold0102.allTrackedItems.first;
	self.assertTrueMsg(rebarin0102 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0102");
	self.assertTrueMsg(rebarin0102.totalQuantity = 20, moveCheck &amp; "Rebar in 0102 quantity is " &amp; rebarin0102.quantity.String);
	self.assertTrueMsg(rebarin0102.allWorklistEntries.size = 2, moveCheck &amp; "Rebar in 0102 has " &amp; rebarin0102.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	yardWLE := null;
	foreach wle in rebarin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
		elseif wle.isKindOf(CM_YardWLE) then
			yardWLE := wle.CM_YardWLE;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Rebar in 0102 has " &amp; count.String &amp; " Voyage WLEs");
	// 3. Road job has 3 completed yard WLEs - 1 for 10, 2 for 20
	self.assertTrueMsg(yardWLE &lt;&gt; null, moveCheck &amp; "No Yard WLE found for onship TI " &amp; rebarin0102.id);
	self.assertTrueMsg(yardWLE.job &lt;&gt; null and yardWLE.job.workListEntries.size = 3 and yardWLE.job.status = JOB_COMPLETE, "Yard WLE has no job, or job has wrong number of WLEs");
	// 4. Prenote now only has 3 WLEs - 0101 WLE has been deleted, 0102 WLE has been reduced to 30
	self.assertTrueMsg(rebarPrenote.allWorklistEntries.size = 3, moveCheck &amp; "Rebar prenote has wrong number of WLEs - " &amp; rebarPrenote.allWorklistEntries.size.String);
	foreach wle in rebarPrenote.allWorklistEntries do
		if wle.locationTarget = hold0101Str then
			self.assertTrueMsg(false, moveCheck &amp; "Rebar prenote still has a WLE for hold 0101");
		elseif wle.locationTarget = hold0102Str then
			self.assertTrueMsg(wle.quantity = 30, moveCheck &amp; "Rebar prenote WLE for hold 0102 has wrong quantity - " &amp; wle.quantity.String);
		endif;
	endforeach;
	// 5. Job 100 is complete and has 2 voyage WLEs for 10 and 20, both linked to onship TI in 0101
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	self.assertTrueMsg(job100.status = JOB_COMPLETE, moveCheck &amp; "Hold job for 0101 is not Complete but is " &amp; job100.status.String);
	foreach wle in job100.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.myTrackedItem = rebarin0101 then
			count := count + 1;
			if wle.quantity = 10 then
				correctQty1 := true;
			elseif wle.quantity = 20 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Hold job for 0101 has " &amp; count.String &amp; " voyage WLEs");
	self.assertTrueMsg(correctQty1 and correctQty2, moveCheck &amp; "Hold job for 0101 has incorrect WLE quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 6. Job 101 for 0102 is part complete and has 1 completed voyage WLE for 20, linked to onship TI in 0102
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	self.assertTrueMsg(job101.status = JOB_PART_COMPLETE, moveCheck &amp; "Hold job for 0102 is not Part Complete but is " &amp; job101.status.String);
	foreach wle in job101.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.myTrackedItem = rebarin0102 then
			count := count + 1;
			if wle.quantity = 20 then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Hold job for 0102 has " &amp; count.String &amp; " voyage WLEs");
	self.assertTrueMsg(correctQty1, moveCheck &amp; "Hold job for 0102 has incorrect WLE quantity");
	
	// Road exit the truck - all cargo gone
	self.roadExit(vvr);
	
	// Gate in the rest of the prenote
	self.opts.purge;
	self.opts.addAssoc("Quantity", 200);
	vvr := self.gateInPrenote(TruckId, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	rebarOnsite := terminal.allOnsiteTIsByIdCargoType[RebarId, rebarCargoType.id];
	self.assertEqualMsg(rebarPrenote, rebarOnsite, moveCheck &amp; "Rebar prenote did not become the rebar on site");
	self.assertNotNullMsg(rebarOnsite, moveCheck &amp; "No onsite Rebar cargo item :2");
	self.assertEqualMsg(rebarOnsite.totalQuantity, 200, moveCheck &amp; "Rebar onsite quantity is incorrect :2");
	self.assertEqualMsg(rebarOnsite.allWorklistEntries.size, 4, moveCheck &amp; "Onsite rebar has wrong WLE count - should be 3 voyage and 1 yard WLE :2");
	foreach wle in rebarOnsite.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, moveCheck &amp; "Rebar onsite has no yard WLE :2");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 3/*one for each incomplete voyage job*/, moveCheck &amp; "Yard WLE has an incorrect number of direct delivery WLEs :2");
	
	/////////////////////////////////
	// Move the onsite cargo again //
	/////////////////////////////////
	// First, move 90 to 0202
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	targetLocation := hold0202;
	moveCheck := MoveCheck &amp; "3: ";
	mobileAgent.doLanderLoad(rebarOnsite, targetLocation, null, 90, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, moveCheck &amp; "Errors: " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. Onsite TI reduced to 110
	// 2. There are 3 onship TIs
	//		- 0101 30 (2 WLEs 10/20)
	//		- 0102 20 (1 WLE)
	//		- 0202 90 (1 WLE)
	// 3. Road job has 1 completed WLE for 90 and 1 unactioned WLE for 110
	// 4. DD WLE for 0202 on the unactioned yard WLE has reduced to 10
	// 5. Job 103 is part complete and has 1 completed voyage WLE for 90, linked to onship TI in 0202
	// 1. Onsite TI reduced to 110
	self.assertEqualMsg(rebarOnsite.totalQuantity, 110, moveCheck &amp; "Rebar on site has the wrong quantity - " &amp; rebarOnsite.totalQuantity.String);
	// 2. There are 3 onship TIs
	//		- 0101 30 (2 WLEs 10/20)
	//		- 0102 20 (1 WLE)
	//		- 0202 90 (1 WLE)
	self.assertTrueMsg(voyage.allOnshipTIsByIdCargoType.size = 3, moveCheck &amp; "There are " &amp; voyage.allOnshipTIsByIdCargoType.size.String &amp; " onship TIs");
	rebarin0101 := hold0101.allTrackedItems.first;
	self.assertTrueMsg(rebarin0101 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0101");
	self.assertTrueMsg(rebarin0101.totalQuantity = 30, moveCheck &amp; "Rebar in 0101 quantity is " &amp; rebarin0101.quantity.String);
	self.assertTrueMsg(rebarin0101.allWorklistEntries.size = 2, moveCheck &amp; "Rebar in 0101 has " &amp; rebarin0101.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	foreach wle in rebarin0101.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		count := count + 1;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Rebar in 0101 has " &amp; count.String &amp; " Voyage WLEs");
	rebarin0102 := hold0102.allTrackedItems.first;
	self.assertTrueMsg(rebarin0102 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0102");
	self.assertTrueMsg(rebarin0102.totalQuantity = 20, moveCheck &amp; "Rebar in 0102 quantity is " &amp; rebarin0102.quantity.String);
	self.assertTrueMsg(rebarin0102.allWorklistEntries.size = 1, moveCheck &amp; "Rebar in 0102 has " &amp; rebarin0102.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	yardWLE := null;
	foreach wle in rebarin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Rebar in 0102 has " &amp; count.String &amp; " Voyage WLEs");
	rebarin0202 := hold0202.allTrackedItems.first;
	self.assertTrueMsg(rebarin0202 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0202");
	self.assertTrueMsg(rebarin0202.totalQuantity = 90, moveCheck &amp; "Rebar in 0202 quantity is " &amp; rebarin0202.quantity.String);
	self.assertTrueMsg(rebarin0202.allWorklistEntries.size = 2, moveCheck &amp; "Rebar in 0202 has " &amp; rebarin0202.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	foreach wle in rebarin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Rebar in 0202 has " &amp; count.String &amp; " Voyage WLEs");
	// 3. Road job has 1 completed WLE for 90 and 1 unactioned WLE for 110
	foreach wle in rebarOnsite.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, moveCheck &amp; "Yard WLE is null");
	yardJob := yardWLE.job;
	self.assertEqualMsg(yardJob.workListEntries.size, 2, moveCheck &amp; "Yard job has the wrong number of WLEs - " &amp; yardJob.workListEntries.size.String);
	count := null;
	count2 := null;
	unactionedYardWLE := null;
	foreach wle in yardJob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			self.assertEqualMsg(wle.quantity, 90, moveCheck &amp; "Conpleted Yard WLE quantity is " &amp; wle.quantity.String);
		elseif wle.status = WLE_UNACTIONED then
			unactionedYardWLE := wle.CM_YardWLE;
			count2 := count2 + 1;
			self.assertEqualMsg(wle.quantity, 110, moveCheck &amp; "Unactioned Yard WLE quantity is " &amp; wle.quantity.String);
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Yard job has wrong number of Complete WLEs - " &amp; count.String);
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Yard job has wrong number of Unactioned WLEs - " &amp; count2.String);
	// 4. DD WLE for 0202 on the unactioned yard WLE has reduced to 10
	self.assertNotNullMsg(unactionedYardWLE, moveCheck &amp; "Unactioned Yard WLE");
	foreach wle in unactionedYardWLE.allDirectDeliveryChildWLEs do
		if wle.locationTarget = hold0202Str then
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 10, moveCheck &amp; "Voyage WLE for 0202 on the unactioned yard WLE has wrong subSeqNum - " &amp; wle.CM_VoyageWLE.subSeqNum.String);
		endif;
	endforeach;
	// 5. Job 103 is part complete and has 1 completed voyage WLE for 90, linked to onship TI in 0202
	holdjob := jobSheet.allJobsByJobNum["103"];
	self.assertEqualMsg(holdjob.status, JOB_PART_COMPLETE, moveCheck &amp; "Hold job for 0202 status is " &amp; holdjob.statusString);
	count := null;
	correctQty1 := null;
	foreach wle in holdjob.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.status = WLE_COMPLETED and not wle.myTrackedItem.hasBeenMerged then
			count := count + 1;
			if wle.quantity = 90 then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "There are " &amp; count.String &amp; " Complete WLEs in hold job for 0202");
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Completed WLE for hold job 0202 is for the wrong quantity");
	
	// Try to really mess with things - move 60 rebar to 0202
	// This should 	- complete 0202 (100 rebar - 2 WLEs 90+10)
	//				- complete 0102 (50 rebar - 2 WLEs 20+30)
	//				- part complete 0201 (20 rebar - 50 still to go)
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(rebarOnsite, targetLocation, null, 60, null);
	moveCheck := MoveCheck &amp; "4: ";
	self.assertNullMsg(app.myPassport.getErrorsAsString, moveCheck &amp; "Start: " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. Onsite TI reduced to 50
	// 2. There are 4 onship TIs
	//		- 0101 30 (2 WLEs, 10/20)
	// 		- 0102 50 (2 WLEs, 20/30)
	//		- 0201 20 (1 WlE, 20)
	//		- 0202 100 (2 WLEs, 90/10)
	// 3. Road job has 4 completed WLEs (90 - original move, 10-30-20 from this move) and 1 unactioned WLE for 50)
	// 4. DD WLE for 0201 on the unactioned yard WLE has been reduced to 50
	// 5. Job 101 is complete and has 2 completed voyage WLEs for 20+30, linked to onship TI in 0102
	// 6. Job 102 is part complete, with 1 completed voyage WLE for 20, linked to onship TI in 0201
	// 7. Job 103 is complete, with 2 completed voyage WLEs for 90+10, linked to onship TI in 0202
	// 1. Onsite TI reduced to 50
	self.assertEqualMsg(rebarOnsite.totalQuantity, 50, moveCheck &amp; "Rebar on site has the wrong quantity - " &amp; rebarOnsite.totalQuantity.String);
	// 2. There are 4 onship TIs
	//		- 0101 30 (2 WLEs, 10/20)
	// 		- 0102 50 (2 WLEs, 20/30)
	//		- 0201 20 (1 WlE, 20)
	//		- 0202 100 (2 WLEs, 90/10)
	//self.assertTrueMsg(voyage.allOnshipTIsByIdCargoType.size = 4, moveCheck &amp; "Voyage has the wrong number of on-ship cargo items - " &amp; voyage.allOnshipTIsByIdCargoType.size.String);
	self.assertTrueMsg(hold0101.allTrackedItems.size = 1, moveCheck &amp; "Hold 0101 has the wrong number of cargo items - " &amp; hold0101.allTrackedItems.size.String);
	self.assertTrueMsg(hold0102.allTrackedItems.size = 1, moveCheck &amp; "Hold 0102 has the wrong number of cargo items - " &amp; hold0102.allTrackedItems.size.String);
	self.assertTrueMsg(hold0201.allTrackedItems.size = 1, moveCheck &amp; "Hold 0201 has the wrong number of cargo items - " &amp; hold0201.allTrackedItems.size.String);
	self.assertTrueMsg(hold0202.allTrackedItems.size = 1, moveCheck &amp; "Hold 0202 has the wrong number of cargo items - " &amp; hold0202.allTrackedItems.size.String);
	rebarin0101 := hold0101.allTrackedItems.first;
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	foreach wle in rebarin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.quantity = 10 then
				correctQty1 := true;
			elseif wle.quantity = 20 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Rebar in hold 0101 has the wrong number of WLEs - " &amp; count.String);
	self.assertTrueMsg(correctQty1 and correctQty2, moveCheck &amp; "Rebar in hold 0101 WLEs have wrong quantity - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	rebarin0102 := hold0102.allTrackedItems.first;
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	foreach wle in rebarin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.quantity = 20 then
				correctQty1 := true;
			elseif wle.quantity = 30 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Rebar in hold 0102 has the wrong number of WLEs - " &amp; count.String);
	self.assertTrueMsg(correctQty1 and correctQty2, moveCheck &amp; "Rebar in hold 0102 WLEs have wrong quantity - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	rebarin0201 := hold0201.allTrackedItems.first;
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	foreach wle in rebarin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.quantity = 20 then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Rebar in hold 0201 has the wrong number of WLEs - " &amp; count.String);
	self.assertTrueMsg(correctQty1, moveCheck &amp; "Rebar in hold 0201 WLE has wrong quantity - " &amp; correctQty1.asStringJMT);
	rebarin0202 := hold0202.allTrackedItems.first;
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	foreach wle in rebarin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.quantity = 90 then
				correctQty1 := true;
			elseif wle.quantity = 10 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Rebar in hold 0202 has the wrong number of WLEs - " &amp; count.String);
	self.assertTrueMsg(correctQty1 and correctQty2, moveCheck &amp; "Rebar in hold 0202 WLEs have wrong quantity - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 3. Road job has 4 completed WLEs (90 - original move, 10-30-20 from this move) and 1 unactioned WLE for 50
	count := null;
	count2 := null;
	unactionedYardWLE := null;
	completeQty := null;
	unactionedQty := null;
	roadjob := vvr.myRoadJob;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			completeQty := completeQty + wle.quantity;
		elseif wle.status = WLE_UNACTIONED then
			count2 := count2 + 1;
			unactionedQty := unactionedQty + wle.quantity;
			//unactionedYardWLE := wle.CM_YardWLE;
		endif;
		if wle.allDirectDeliveryChildWLEs.size &gt; 1 and wle.isKindOf(CM_YardWLE) then
			unactionedYardWLE := wle.CM_YardWLE;
		endif;
	endforeach;
	self.assertEqualMsg(count, 4, moveCheck &amp; "Yard job has wrong number of Complete WLEs - " &amp; count.String);
	self.assertEqualMsg(completeQty, 150, moveCheck &amp; "Completed Yard job WLEs have incorrect total quantity - " &amp; completeQty.String);
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Yard job has wrong number of Unactioned WLEs - " &amp; count2.String);
	self.assertEqualMsg(unactionedQty, 50, moveCheck &amp; "Unactioned Yard job WLE has incorrect quantity - " &amp; unactionedQty.String);
	// 4. DD WLE for 0201 on the unactioned yard WLE has been reduced to 50
	count := null;
	foreach wle in unactionedYardWLE.allDirectDeliveryChildWLEs do
		if wle.status = WLE_UNACTIONED and wle.CM_VoyageWLE.subSeqNum &lt;&gt; null then
			count := count + 1;
		endif;
		if wle.locationTarget = hold0201Str then
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 50, moveCheck &amp; "DD WLE for 0201 has wrong quantity left - " &amp; wle.CM_VoyageWLE.subSeqNum.String);
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Unactioned Yard WLE has wrong number of direct delivery children!");
	// 5. Job 101 is complete and has 2 completed voyage WLEs for 20+30, linked to onship TI in 0102
	self.assertEqualMsg(job101.status, JOB_COMPLETE, moveCheck &amp; "Hold job for 0102 is not complete - " &amp; job101.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	rebarin0102 := hold0102.allTrackedItems.first;
	foreach wle in job101.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and not wle.myTrackedItem.hasBeenMerged then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
				self.assertEqualMsg(wle.myTrackedItem, rebarin0102, moveCheck &amp; "TI on Hold Job 0102 WLE is NOT the TI in Hold 0102");
			endif;
			if wle.quantity = 20 then
				correctQty1 := true;
			elseif wle.quantity = 30 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Hold Job 0102 has the wrong number of completed voyage WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Hold Job 0102 voyage WLEs have the wrong quantities");
	// 6. Job 102 is part complete, with 1 completed voyage WLE for 20, linked to onship TI in 0201
	self.assertEqualMsg(job102.status, JOB_PART_COMPLETE, moveCheck &amp; "Hold job for 0201 is not complete - " &amp; job102.statusString);
	count := null;
	correctQty1 := false;
	rebarin0201 := hold0201.allTrackedItems.first;
	foreach wle in job102.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and not wle.myTrackedItem.hasBeenMerged then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
				self.assertEqualMsg(wle.myTrackedItem, rebarin0201, moveCheck &amp; "TI on Hold Job 0201 WLE is NOT the TI in Hold 0201");
			endif;
			if wle.quantity = 20 then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Hold Job 0201 has the wrong number of completed voyage WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Hold Job 0201 voyage WLE ha2 the wrong quantity");
	// 7. Job 103 is complete, with 2 completed voyage WLEs for 90+10, linked to onship TI in 0202
	self.assertEqualMsg(job103.status, JOB_COMPLETE, moveCheck &amp; "Hold job for 0202 is not complete - " &amp; job103.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	rebarin0202 := hold0202.allTrackedItems.first;
	foreach wle in job103.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and not wle.myTrackedItem.hasBeenMerged then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
				self.assertEqualMsg(wle.myTrackedItem, rebarin0202, moveCheck &amp; "TI on Hold Job 0202 WLE is NOT the TI in Hold 0202");
			endif;
			if wle.quantity = 90 then
				correctQty1 := true;
			elseif wle.quantity = 10 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Hold Job 0202 has the wrong number of completed voyage WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Hold Job 0202 voyage WLEs have the wrong quantities");
	
	// Move the final 50 to 0201. This should complete the yard job, and all hold jobs
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(rebarOnsite, targetLocation, null, 50, null);
	moveCheck := MoveCheck &amp; "5: ";
	self.assertNullMsg(app.myPassport.getErrorsAsString, moveCheck &amp; "Start: " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. No Onsite TI
	// 2. There are 4 onship TIs
	//		- 0101 30 (2 WLEs, 10/20)
	// 		- 0102 50 (2 WLEs, 20/30)
	//		- 0201 70 (2 WLEs, 20/50)
	//		- 0202 100 (2 WLEs, 90/10)
	// 3. Road job is complete and has 5 completed WLEs and no unactioned WLEs 
	// 4. Job 3 is complete 
	// 5. All voyage jobs are complete
	// 1. No Onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, true, moveCheck &amp; "There is still an on site caargo item!");
	// 2. There are 4 onship TIs
	//		- 0101 30 (2 WLEs, 10/20)
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 4, moveCheck &amp; "There are " &amp; voyage.allOnshipTIsByIdCargoType.size.String &amp; " on Ship cargo items!!");
	rebarin0101 := hold0101.allTrackedItems.first;
	self.assertNotEqualMsg(rebarin0101, null, moveCheck &amp; "There is no cargo item in Hold 0101");
	self.assertEqualMsg(rebarin0101.totalQuantity, 30, moveCheck &amp; "Cargo item in 0101 has the wrong quantity - " &amp; rebarin0101.totalQuantity.String);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in rebarin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Hold 0101 Cargo Item is not Completed");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, null, moveCheck &amp; "WLE for Hold 0101 Cargo Item has a non-null subSeqNum " &amp; wle.myTrackedItem.hasBeenMerged.asStringJMT);
			count := count + 1;
			if wle.quantity = 10 then
				correctQty1 := true;
			elseif wle.quantity = 20 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Cargo item in 0101 has the wrong number of Completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Cargo item in 0101 has incorrect WLE quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 		- 0102 50 (2 WLEs, 20/30)
	rebarin0102 := hold0102.allTrackedItems.first;
	self.assertNotEqualMsg(rebarin0102, null, moveCheck &amp; "There is no cargo item in Hold 0102");
	self.assertEqualMsg(rebarin0102.totalQuantity, 50, moveCheck &amp; "Cargo item in 0102 has the wrong quantity - " &amp; rebarin0102.totalQuantity.String);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in rebarin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Hold 0102 Cargo Item is not Completed");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, null, moveCheck &amp; "WLE for Hold 0102 Cargo Item has a non-null subSeqNum " &amp; wle.myTrackedItem.hasBeenMerged.asStringJMT);
			count := count + 1;
			if wle.quantity = 20 then
				correctQty1 := true;
			elseif wle.quantity = 30 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Cargo item in 0102 has the wrong number of Completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Cargo item in 0102 has incorrect WLE quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	//		- 0201 70 (2 WLEs, 20/50)
	rebarin0201 := hold0201.allTrackedItems.first;
	self.assertNotEqualMsg(rebarin0201, null, moveCheck &amp; "There is no cargo item in Hold 0201");
	self.assertEqualMsg(rebarin0201.totalQuantity, 70, moveCheck &amp; "Cargo item in 0201 has the wrong quantity - " &amp; rebarin0201.totalQuantity.String);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in rebarin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Hold 0201 Cargo Item is not Completed");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, null, moveCheck &amp; "WLE for Hold 0201 Cargo Item has a non-null subSeqNum " &amp; wle.myTrackedItem.hasBeenMerged.asStringJMT);
			count := count + 1;
			if wle.quantity = 20 then
				correctQty1 := true;
			elseif wle.quantity = 50 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Cargo item in 0201 has the wrong number of Completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Cargo item in 0201 has incorrect WLE quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	//		- 0202 100 (2 WLEs, 90/10)
	rebarin0202 := hold0202.allTrackedItems.first;
	self.assertNotEqualMsg(rebarin0202, null, moveCheck &amp; "There is no cargo item in Hold 0202");
	self.assertEqualMsg(rebarin0201.totalQuantity, 70, moveCheck &amp; "Cargo item in 0202 has the wrong quantity - " &amp; rebarin0201.totalQuantity.String);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in rebarin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Hold 0202 Cargo Item is not Completed");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, null, moveCheck &amp; "WLE for Hold 0202 Cargo Item has a non-null subSeqNum " &amp; wle.myTrackedItem.hasBeenMerged.asStringJMT);
			count := count + 1;
			if wle.quantity = 90 then
				correctQty1 := true;
			elseif wle.quantity = 10 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Cargo item in 0202 has the wrong number of Completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Cargo item in 0202 has incorrect WLE quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 3. Road job is complete and has 5 completed WLEs and no unactioned WLEs 
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Yard job status is " &amp; roadjob.statusString);
	count := null;
	count2 := null;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
		else
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 5, moveCheck &amp; "Road job has the wrong number of completed WLEs - " &amp; count.String);
	self.assertEqualMsg(count2, 0, moveCheck &amp; "Road job has some incomplete WLEs - " &amp; count.String);
	// 4. Job 102 is complete 
	self.assertNotNullMsg(job102, moveCheck &amp; "Can't find hold job for 0201");
	self.assertEqualMsg(job102.status, JOB_COMPLETE, "Hold Job for 0201 is is not Complete - " &amp; job102.statusString);
	// 5. All voyage jobs are complete
	foreach holdjob in jobSheet.allJobsByJobNum do
		self.assertEqualMsg(holdjob.status, JOB_COMPLETE, moveCheck &amp; "Hold Job " &amp; holdjob.id &amp; " is not Complete - " &amp; holdjob.statusString);
	endforeach;
	
	// Road exit the truck - all cargo gone
	self.roadExit(vvr);
	self.assertEqualMsg(app.myPassport.getErrorsAndWarningsAsString, null, app.myPassport.getErrorsAndWarningsAsString);
	
	////////////////////////
	// Finished - Tidy up //
	////////////////////////
	self.deleteWorkPoint(ThisWorkPoint);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteVehicle(TruckId);
	
epilog
	delete allocatedWLEs;
	delete mobileAgent;
	self.setTerminalConfig(DirectTruck2VesselMult, directTruckMoves);
	app.myPassport.setMyTerminal(passportTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="tSalalahDirectToShipQty2" id="88583e65-7e09-4db7-af03-9a0ad0f8d43f">
        <source>tSalalahDirectToShipQty2();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/11/2021	navdap1		Initial creation TFS 52360
//
constants
	ThisVoyageCode : String = "DAVEH51935_2";
	ThisVesselCode : String = "DAVEHOLD";
	REBAR : String = "REBAR";
	RebarId1 : String = "REBARDD51935_2_1";
	RebarId2 : String = "REBARDD51935_2_2";
	RebarId3 : String = "REBARDD51935_2_3";
	RebarId4 : String = "REBARDD51935_2_4";
	ThisWorkPoint : String = "WP51935_2";
	TruckId1 : String = "UT51935_2_1";
	TruckId2 : String = "UT51935_2_2";
	TruckId3 : String = "UT51935_2_3";
	MoveCheck : String = "Move Check ";

vars
	terminal, passportTerminal : CM_Terminal;
	directTruckMoves : Boolean;
	operator : CM_Operator;
	rebarCargoType : CM_CargoType;
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	rebarPrenote, rebarOnsite1, rebarOnsite2, rebarOnsite3, rebarin0101, rebarin0102, rebarin0201, rebarin0202, ti : CM_TrackedItem;
	hold0101, hold0102, hold0201, hold0202 : CM_GeneralCargoController;
	hold0101Str, hold0102Str, hold0201Str, hold0202Str : String;
	voyageWle : CM_VoyageWLE;
	wle, ddWle : CM_WorkListEntry;
	allocatedWLEs : CM_WLEArray;
	jobSheet : CM_VoyageHoldJobSheet;
	holdjob : CM_VoyageJob;
	count, count2, qty, completeQty, unactionedQty, vQty, yQty : Integer;
	loc : String;
	mobileAgent : CMIF_MobileGenericAgent;
	targetLocation : CM_LocationsController;
	yardWLE, unactionedYardWLE : CM_YardWLE;
	voyageWleFound, yardWleFound : Boolean;
	roadjob : CM_RoadJob;
	correctQty1, correctQty2 : Boolean;
	vvr1, vvr2, vvr3 : CM_VehicleVisitRecord;
	moveCheck : String;
	yardJob : CM_Job;
	job100, job101, job102, job103, job104, job105, job106, job107 : CM_VoyageHoldJob;
	truck1, truck2, truck3 : CM_Vehicle;

begin
	// Set the terminal config that drives all of this
	terminal := self.getTerminal;
	directTruckMoves := self.setTerminalConfig(DirectTruck2VesselMult, true).Boolean;
	//return;
	///////////////////////////////////////
	// Sanity Check and Pre-run Clean Up //
	///////////////////////////////////////
	rebarCargoType := app.myRoot.getCargoTypeFromAbbrev(REBAR);
	self.assertTrueMsg(rebarCargoType &lt;&gt; null, REBAR &amp; "does not exist as a Cargo Type");
	
	self.opts.purge;
	self.opts.addAssoc("includePrenote", true);
	self.deleteCargo(RebarId1, rebarCargoType);
	self.deleteVehicle(TruckId1);
	self.deleteVehicle(TruckId2);
	self.deleteVehicle(TruckId3);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteWorkPoint(ThisWorkPoint);
	self.assertTrueMsg(self.getVoyage(ThisVoyageCode) = null, "Voyage " &amp; ThisVoyageCode &amp; " not deleted");
	
	////////////
	// Set Up //
	////////////
	// Create a Voyage with Holds
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage := self.addVoyageWithGeneralCargoStruc(ThisVoyageCode, ThisVesselCode, operator.code, "DOUG", 2);
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage not created");
	self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null and voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.size = 10, "General Cargo voyage not set up correctly");
	// and a workpoint
	workPoint := self.addWorkPoint(ThisWorkPoint, false);
	self.assertTrueMsg(workPoint &lt;&gt; null, "Work Point not created");
	
	hold0101 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,1];
	hold0102 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,2];
	hold0201 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,1];
	hold0202 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,2];
	hold0101Str := hold0101.getFullId;
	hold0102Str := hold0102.getFullId;
	hold0201Str := hold0201.getFullId;
	hold0202Str := hold0202.getFullId;
	
	///////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// TEST 1: Total quantity planned to one hold, brought in on 2 trucks, trucks loaded individually to the job //
	///////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Create a prenote for the voyage splittable by quantity
	self.opts.purge;
	self.opts.addAssoc("CargoType", rebarCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 100);
	self.opts.addAssoc("DD", true);
	rebarPrenote := self.addPrenoted(RebarId1);
	self.assertTrueMsg(rebarPrenote &lt;&gt; null, "Rebar prenote not created");
	self.assertEqualMsg(rebarPrenote.totalQuantity, 100, "Rebar prenote quantity is incorrect");
	self.assertTrueMsg(rebarPrenote.directDelivery = true, "Rebar prenote is not Direct Delivery");
	
	// Plan the prenote to a hold
	// Load job 100 to 0101: all 100 rebar
	create allocatedWLEs transient;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(100);
	allocatedWLEs.add(voyageWle);
	job100 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0101, workPoint);
	beginTransaction;
	job100.setOriginalJobAmount(100);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 1 job in its jobsheet, the job should have 1 WLE, prenote should have 1 WLE
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 1, "Voyage Job sheet has the wrong number of jobs");
	foreach holdjob in jobSheet.allJobsByJobNum do
		self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	endforeach;
	self.assertEqualMsg(rebarPrenote.allWorklistEntries.size, 1, "Rebar prenote has the wrong number of WLEs");
	// Check quantity on the prenoted WLE
	// Rebar: 100 to 0101
	foreach wle in rebarPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 100;
			loc := ThisVoyageCode &amp; Space &amp; "0101 Under Deck";
		endif;
		self.assertEqualMsg(voyageWle.quantity, qty, "Rebar WLE " &amp; count.String &amp; " has the wrong quantity");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Rebar WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the rebar in on 2 trucks
	self.opts.purge;
	self.opts.addAssoc("Quantity", 50);
	vvr1 := self.gateInPrenote(TruckId1, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	rebarOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite1, "No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite1.totalQuantity, 50, "Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite1.allWorklistEntries.size, rebarPrenote.allWorklistEntries.size + 1, "Truck1 Onsite and prenoted rebar has different WLE count");
	foreach wle in rebarOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, rebarPrenote.allWorklistEntries.size, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Second truck
	self.opts.purge;
	self.opts.addAssoc("Quantity", 50);
	vvr2 := self.gateInPrenote(TruckId2, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	rebarOnsite2 := truck2.locationsController.allTrackedItems.first;
	// prenoted item is now the onsite item
	self.assertEqualMsg(rebarOnsite2, rebarPrenote, "Truck2 Rebar on site is not the prenote TI");
	self.assertNotNullMsg(rebarOnsite2, "Truck2 No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite2.totalQuantity, 50, "Truck2 Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite2.allWorklistEntries.size, rebarPrenote.allWorklistEntries.size, "Truck2 Onsite and prenoted rebar has different WLE count");
	foreach wle in rebarOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	
	// Move some of the onsite cargo
	// Move from the trucks to the hold (replicating the use of the Cargo Lander Mobile app)
	// Truck 1 first - all 50 rebar
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 50 rebar to hold 0101
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(rebarOnsite1, targetLocation, null, 50, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is one TI onsite 
	// 2. Onship TI in hold 0101 - qyantity 50, with 2 WLEs (voyage and yard, both complete, both for quantity 50)
	// 3. Road job has 1 WLE and is complete
	// 4. Job 100 is part complete, with 1 voyage WLE for quantity 50, linked to onship TI in hold 0101
	moveCheck := MoveCheck &amp; "1: ";
	// 1. There is one TI onsite 
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite TIs");
	// 2. Onship TI in hold 0101 - quantity 50, with 2 WLEs (voyage and yard, both complete, both for quantity 50)
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onship TIs");
	rebarin0101 := voyage.allOnshipTIsByIdCargoType[rebarOnsite1.id, rebarOnsite1.cargoType];
	self.assertNotNullMsg(rebarin0101, moveCheck &amp; "No on ship rebar with id " &amp; rebarOnsite1.id);
	self.assertEqualMsg(rebarin0101.totalQuantity, 50, moveCheck &amp; "Rebar in 0101 has the wrong quantity");
	self.assertEqualMsg(rebarin0101.allWorklistEntries.size, 2, moveCheck &amp; "Rebar in 0101 has the wrong number of WLEs");
	foreach wle in rebarin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.quantity, 50, moveCheck &amp; "Rebar in 0101 voyage WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0101 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.quantity, 50, moveCheck &amp; "Rebar in 0101 yard WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0101 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Rebar in 0101 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Rebar in 0101 has no yard WLE");
	// 3. Road job for truck 1 has 1 WLE and is complete
	roadjob := vvr1.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId1 &amp; " is null");
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for " &amp; TruckId1 &amp; "'s road job is not complete");
	// 4. Job 100 is part complete, with 1 voyage WLE for quantity 50, linked to onship TI in hold 0101
	self.assertEqualMsg(job100.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 100 for hold 0101 is " &amp; job100.statusString);
	count := null;
	voyageWle := null;
	foreach wle in job100.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.status = WLE_COMPLETED then
				count2 := count2 + 1;
				voyageWle := wle.CM_VoyageWLE;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 100 has wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Job 100 has wrong number of Completed voyage WLEs");
	self.assertNotNullMsg(voyageWle, moveCheck &amp; "No voyage WLE found for job 100");
	self.assertEqualMsg(voyageWle.status, WLE_COMPLETED, moveCheck &amp; "WLE for job 100 has wrong status");
	self.assertEqualMsg(voyageWle.quantity, 50, moveCheck &amp; "WLE for job 100 has wrong quantity");
	self.assertEqualMsg(voyageWle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 100 has wrong subSeqNum");
	self.assertEqualMsg(voyageWle.myTrackedItem, rebarin0101, moveCheck &amp; "WLE for job 100 has the wrong TI");
	
	// second move - remaining 50 rebar to hold 0101
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(rebarOnsite2, targetLocation, null, 50, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is no TI onsite 
	// 2. There is 1 Onship TI in hold 0101 - quantity 100, with 4 WLEs (2 voyage and 2 yard, all complete, all for quantity 100)
	// 3. Road job for truck 2 has 1 WLE and is complete
	// 4. Job 100 is complete, with 2 voyage WLEs each for quantity 50, both linked to onship TI in hold 0101
	moveCheck := MoveCheck &amp; "2: ";
	// 1. There is no TI onsite 
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 0, moveCheck &amp; "Wrong number of onsite TIs");
	// 2. There is 1 Onship TI in hold 0101 - quantity 100, with 4 WLEs (2 voyage and 2 yard, all complete, all for quantity 100)
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onship TIs");
	rebarin0101 := voyage.allOnshipTIsByIdCargoType[rebarOnsite1.id, rebarOnsite1.cargoType];
	self.assertNotNullMsg(rebarin0101, moveCheck &amp; "No on ship rebar with id " &amp; rebarOnsite1.id);
	self.assertEqualMsg(rebarin0101.totalQuantity, 100, moveCheck &amp; "Rebar in 0101 has the wrong quantity");
	self.assertEqualMsg(rebarin0101.allWorklistEntries.size, 4, moveCheck &amp; "Rebar in 0101 has the wrong number of WLEs");
	count := null;
	count2 := null;
	foreach wle in rebarin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.quantity, 50, moveCheck &amp; "Rebar in 0101 voyage WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0101 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.quantity, 50, moveCheck &amp; "Rebar in 0101 yard WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0101 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Rebar in 0101 has wrong voyage WLE count");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "Rebar in 0101 has wring yard WLE count");
	// 3. Road job for truck 2 has 1 WLE and is complete
	roadjob := vvr2.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId2 &amp; " is null");
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for " &amp; TruckId2 &amp; "'s road job is not complete");
	// 4. Job 100 is complete, with 2 voyage WLEs each for quantity 50, both linked to onship TI in hold 0101
	self.assertEqualMsg(job100.status, JOB_COMPLETE, moveCheck &amp; "Job 100 for hold 0101 is " &amp; job100.statusString);
	self.assertEqualMsg(job100.workListEntries.size, 2, moveCheck &amp; "Job 100 has wrong number of WLEs");
	count := null;
	foreach wle in job100.workListEntries do
		count := count + 1;
		self.assertEqualMsg(wle.status, WLE_COMPLETED, "WLE for job 100 has wrong status :" &amp; count.String);
		self.assertEqualMsg(wle.quantity, 50, "WLE for job 100 has wrong quantity :" &amp; count.String);
		self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, "WLE for job 100 has wrong subSeqNum :" &amp; count.String);
		self.assertEqualMsg(wle.myTrackedItem, rebarin0101, "WLE for job 100 has the wrong TI :" &amp; count.String);
	endforeach;
	
	// Road exit the trucks - all cargo gone
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	
	////////////////////////////////////////////////////////////////////////////////////////////////
	// TEST 2: Total quantity planned to two holds, different amounts brought in on 2 trucks,     //
	// first truck completes part of a job, second truck completes that job and the remaining one //
	////////////////////////////////////////////////////////////////////////////////////////////////
	// Create another prenote for the voyage 
	rebarPrenote := null;
	rebarOnsite1 := null;
	rebarOnsite2 := null;
	self.opts.purge;
	self.opts.addAssoc("CargoType", rebarCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 100);
	self.opts.addAssoc("DD", true);
	rebarPrenote := self.addPrenoted(RebarId2);
	self.assertTrueMsg(rebarPrenote &lt;&gt; null, "Rebar prenote not created");
	self.assertEqualMsg(rebarPrenote.totalQuantity, 100, "Rebar prenote quantity is incorrect");
	self.assertTrueMsg(rebarPrenote.directDelivery = true, "Rebar prenote is not Direct Delivery");
	
	// Plan the prenote to two holds
	// Load job 101 to 0201: 50 rebar
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(50);
	allocatedWLEs.add(voyageWle);
	job101 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job101.setOriginalJobAmount(50);
	commitTransaction;
	// Load job 102 to 0202: 50 rebar
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(50);
	allocatedWLEs.add(voyageWle);
	job102 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0202, workPoint);
	beginTransaction;
	job102.setOriginalJobAmount(50);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 3 jobs in its jobsheet, the 2 new jobs (101 and 102) should have 2 WLEs, prenote should have 2 WLEs
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 3, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["101"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 101");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	holdjob := jobSheet.allJobsByJobNum["102"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 102");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(rebarPrenote.allWorklistEntries.size, 2, "Rebar prenote has the wrong number of WLEs");
	// Check quantity on the prenoted WLE
	// Rebar: 50 to 0201, 20 to 0202
	count := null;
	foreach wle in rebarPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 50;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		elseif count = 2 then
			qty := 50;
			loc := ThisVoyageCode &amp; Space &amp; "0202 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.quantity, qty, "Rebar WLE " &amp; count.String &amp; " has the wrong quantity");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Rebar WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the rebar in on 2 trucks
	self.opts.purge;
	self.opts.addAssoc("Quantity", 25);
	vvr1 := self.gateInPrenote(TruckId1, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	rebarOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite1, "No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite1.totalQuantity, 25, "Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite1.allWorklistEntries.size, rebarPrenote.allWorklistEntries.size + 1, "Truck1 Onsite and prenoted rebar has different WLE count");
	foreach wle in rebarOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, rebarPrenote.allWorklistEntries.size, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Second truck
	self.opts.purge;
	self.opts.addAssoc("Quantity", 75);
	vvr2 := self.gateInPrenote(TruckId2, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	rebarOnsite2 := truck2.locationsController.allTrackedItems.first;
	// prenoted item is now the second onsite item
	self.assertNotEqualMsg(rebarOnsite1, rebarOnsite2, "The two onsite TIs are the same!");
	self.assertEqualMsg(rebarOnsite2, rebarPrenote, "Truck2 Rebar on site is not the prenote TI");
	self.assertNotNullMsg(rebarOnsite2, "Truck2 No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite2.totalQuantity, 75, "Truck2 Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite2.allWorklistEntries.size, rebarPrenote.allWorklistEntries.size, "Truck2 Onsite and prenoted rebar has different WLE count");
	foreach wle in rebarOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 2, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 2, "There is the wrong number of onsite TIs after gating in the two trucks");
	
	// Move some of the onsite cargo
	// Move from the trucks to the hold (replicating the use of the Cargo Lander Mobile app)
	// Truck 1 first - all 25 rebar
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 25 rebar to hold 0201
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(rebarOnsite1, targetLocation, null, 25, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is 1 TI onsite - for quantity 75
	// 2. Onship TI in hold 0201 - qyantity 25, with 2 WLEs (voyage and yard, both complete, both for quantity 25)
	// 3. Road job for truck 1 is complete and has 1 complete WLE for 25 
	// 4. Job 101 is part complete, with 1 voyage WLE for quantity 25, linked to onship TI in hold 0201
	moveCheck := MoveCheck &amp; "3: ";
	// 1. There is 1 TI onsite - for quantity 75
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite TIs");
	self.assertEqualMsg(rebarOnsite2.totalQuantity, 75, moveCheck &amp; "Rebar 2 onsite has the wrong quantity");
	// 2. Onship TI in hold 0201 - quantity 25, with 2 WLEs (voyage and yard, both complete, both for quantity 25)
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	rebarin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(rebarin0201, moveCheck &amp; "No on ship rebar in 0201");
	self.assertEqualMsg(rebarin0201.totalQuantity, 25, moveCheck &amp; "Rebar in 0201 has the wrong quantity");
	self.assertEqualMsg(rebarin0201.allWorklistEntries.size, 2, moveCheck &amp; "Rebar in 0201 has the wrong number of WLEs");
	foreach wle in rebarin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "Rebar in 0201 voyage WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0201 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "Rebar in 0201 yard WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0201 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Rebar in 0201 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Rebar in 0201 has no yard WLE");
	// 3. Road job for truck 1 is complete and has 1 complete WLE for 25 
	roadjob := vvr1.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId1 &amp; " is null");
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, "Road job for " &amp; TruckId1 &amp; " has wrong status - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Road job for " &amp; TruckId1 &amp; " is not complete");
	self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "WLE Road job for " &amp; TruckId1 &amp; " has wrong quantity");
	// 4. Job 101 is part complete, with 1 completed voyage WLE for quantity 25, linked to onship TI in hold 0201
	self.assertEqualMsg(job101.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 101 for hold 0201 is " &amp; job101.statusString);
	count := null;
	count2 := null;
	voyageWle := null;
	foreach wle in job101.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.status = WLE_COMPLETED then
				count2 := count2 + 1;
				voyageWle := wle.CM_VoyageWLE;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 101 has wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Job 101 has wrong number of Completed voyage WLEs");
	self.assertNotNullMsg(voyageWle, moveCheck &amp; "No voyage WLE found for job 101");
	self.assertEqualMsg(voyageWle.status, WLE_COMPLETED, moveCheck &amp; "WLE for job 101 has wrong status");
	self.assertEqualMsg(voyageWle.quantity, 25, moveCheck &amp; "WLE for job 101 has wrong quantity");
	self.assertEqualMsg(voyageWle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 101 has wrong subSeqNum");
	self.assertEqualMsg(voyageWle.myTrackedItem, rebarin0201, moveCheck &amp; "WLE for job 101 has the wrong TI");
	
	// second move - 25 rebar of onsite TI 2 to hold 0201
	// this will complete the outstanding 25 on job 101
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(rebarOnsite2, targetLocation, null, 25, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is still 1 TI onsite, with total quantity 50, with 1 WLE with a subSeqNum of 50
	// 2. There is 1 Onship TI in hold 0201 - quantity 50, with 4 WLEs (2 voyage and 2 yard, all complete, all for quantity 25)
	// 3. Road job for truck 2 is part complete and has 2 yard WLEs (1 complete for 25, one unactioned for 50)
	// 4. Job 101 is complete, with 2 voyage WLEs each for quantity 25, both linked to onship TI in hold 0201
	moveCheck := MoveCheck &amp; "4: ";
	// 1. There is still 1 TI onsite, with total quantity 50, with 1 unactioned WLE with a subSeqNum of 50
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite TIs");
	rebarOnsite2 := voyage.allOnsiteTIsByIdCargoType.first;
	self.assertEqualMsg(rebarOnsite2.totalQuantity, 50, moveCheck &amp; "Remaining TI on site has the wrong total quantity");
	correctQty1 := false;
	foreach wle in rebarOnsite2.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.status = WLE_UNACTIONED and wle.CM_VoyageWLE.subSeqNum = 50 then
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(correctQty1, true, "TI still on site does not have an unactione voyage WLE with subSeqNum = 50");
	// 2. There is 1 Onship TI in hold 0201 - quantity 50, with 4 WLEs (2 voyage and 2 yard, all complete, all for quantity 25)
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	rebarin0201 := hold0201.allTrackedItems.first;
	self.assertEqualMsg(rebarin0201.totalQuantity, 50, moveCheck &amp; "Rebar in 0201 has the wrong quantity");
	self.assertEqualMsg(rebarin0201.allWorklistEntries.size, 4, moveCheck &amp; "Rebar in 0201 has the wrong number of WLEs");
	count := null;
	count2 := null;
	foreach wle in rebarin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "Rebar in 0201 voyage WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0201 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "Rebar in 0201 yard WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0201 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Rebar in 0201 has wrong voyage WLE count");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "Rebar in 0201 has wrong yard WLE count");
	// 3. Road job for truck 2 is part complete and has 2 yard WLEs (1 complete for 25, one unactioned for 50)
	roadjob := vvr2.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId2 &amp; " is null");
	self.assertEqualMsg(roadjob.workListEntries.size, 2, moveCheck &amp; "Road job has wrong number of WLEs");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in roadjob.workListEntries do
		if wle.isKindOf(CM_YardWLE) then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
			elseif wle.status = WLE_UNACTIONED then
				count2 := count2 + 1;
			endif;
			if count = 1 and wle.quantity = 25 then
				correctQty1 := true;
			elseif count2 = 1 and wle.quantity = 50 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Road Job for " &amp; TruckId2 &amp; " has wrong number of completed WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Road Job for " &amp; TruckId2 &amp; " has wrong number of unactioned WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "Road Job for " &amp; TruckId1 &amp; " - WLEs have incorrect amounts " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 4. Job 101 is complete, with 2 voyage WLEs each for quantity 25, both linked to onship TI in hold 0201
	self.assertEqualMsg(job101.status, JOB_COMPLETE, moveCheck &amp; "Job 101 for hold 0201 is " &amp; job101.statusString);
	count := null;
	foreach wle in job101.workListEntries do
		if wle.myTrackedItem = null or wle.myTrackedItem.hasBeenMerged or wle.myDirectDeliveryParentWLE &lt;&gt; null then
			continue;
		endif;
		count := count + 1;
		self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for job 101 has wrong status :" &amp; count.String);
		self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "WLE for job 101 has wrong quantity :" &amp; count.String);
		self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 101 has wrong subSeqNum :" &amp; count.String);
		self.assertEqualMsg(wle.myTrackedItem, rebarin0201, moveCheck &amp; "WLE for job 101 has the wrong TI :" &amp; count.String);
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 101 has wrong number of WLEs");
	
	// third move - all 50 rebar of onsite TI 2 to hold 0202
	// this will complete job 102
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(rebarOnsite2, targetLocation, null, 50, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are no TIs onsite 
	// 2. There is still 1 Onship TI in hold 0201 
	// 3. There is 1 Onship TI in hold 0202 - quantity 50, with 2 WLEs (1 voyage and 1 yard, all complete, all for quantity 50)
	// 4. Road job for truck 2 is complete and has 2 yard WLEs (for 25 and 50), both complete
	// 5. Job 102 is complete, with 1 voyage WLE for quantity 50, linked to onship TI in hold 0202
	moveCheck := MoveCheck &amp; "5: ";
	// 1. There are no TIs onsite 
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 0, moveCheck &amp; "Wrong number of onsite TIs");
	// 2. There is still 1 Onship TI in hold 0201 
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	// 3. There is 1 Onship TI in hold 0202 - quantity 50, with 2 WLEs (1 voyage and 1 yard, all complete, all for quantity 50)
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0202");
	rebarin0202 := hold0202.allTrackedItems.first;
	self.assertEqualMsg(rebarin0202.totalQuantity, 50, moveCheck &amp; "TI in 0202 has the wrong total quantity");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in rebarin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0202 is not complete - " &amp; wle.statusString);
			count := count + 1;
			if wle.quantity = 50 then
				correctQty1 := true;
			endif;
		elseif wle.isKindOf(CM_YardWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0202 is not complete - " &amp; wle.statusString);
			count2 := count2 + 1;
			if wle.quantity = 50 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "TI in 0202 has the wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "TI in 0202 has the wrong numnber of yard WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "TI in 0202 WLEs have wrong quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 4. Road job for truck 2 is complete and has 2 yard WLEs (for 25 and 50), both complete
	roadjob := vvr2.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, "Road Job for truck " &amp; TruckId2 &amp; " is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 2, "Road job for truck " &amp; TruckId2 &amp; " has the wrong number of WLEs");
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in roadjob.workListEntries do
		count := count + 1;
		if wle.status = WLE_COMPLETED and wle.quantity = 25 then
			correctQty1 := true;
		elseif wle.status = WLE_COMPLETED and wle.quantity = 50 then
			correctQty2 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Road job for truck " &amp; TruckId2 &amp; " has the wrong number of WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "WLEs on Road job for truck " &amp; TruckId2 &amp; " have the wrong quantity / status - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	
	// Road exit the trucks - all cargo gone
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	
	///////////////////////////////////////////////////////////////////////////////////////////////
	// TEST 3: Total quantity planned to two holds, different amounts brought in on 2 trucks,    //
	// first truck completes first job and part of the second, second truck completes the second //
	///////////////////////////////////////////////////////////////////////////////////////////////
	// Create another prenote for the voyage 
	rebarPrenote := null;
	rebarOnsite1 := null;
	rebarOnsite2 := null;
	self.opts.purge;
	self.opts.addAssoc("CargoType", rebarCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 100);
	self.opts.addAssoc("DD", true);
	rebarPrenote := self.addPrenoted(RebarId3);
	self.assertTrueMsg(rebarPrenote &lt;&gt; null, "Rebar prenote not created");
	self.assertEqualMsg(rebarPrenote.totalQuantity, 100, "Rebar prenote quantity is incorrect");
	self.assertTrueMsg(rebarPrenote.directDelivery = true, "Rebar prenote is not Direct Delivery");
	
	// Plan the prenote to two holds
	// Load job 103 to 0101: 50 rebar
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(50);
	allocatedWLEs.add(voyageWle);
	job103 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0101, workPoint);
	beginTransaction;
	job103.setOriginalJobAmount(50);
	commitTransaction;
	// Load job 104 to 0201: 50 rebar
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(50);
	allocatedWLEs.add(voyageWle);
	job104 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job104.setOriginalJobAmount(50);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 5 jobs in its jobsheet, the 2 new jobs (103 and 104) should have 1 WLE each, prenote should have 2 WLEs
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 5, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["103"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 103");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	holdjob := jobSheet.allJobsByJobNum["104"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 104");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(rebarPrenote.allWorklistEntries.size, 2, "Rebar prenote has the wrong number of WLEs");
	// Check quantity on the prenoted WLE
	// Rebar: 50 to 0101, 50 to 0201
	count := null;
	foreach wle in rebarPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 50;
			loc := ThisVoyageCode &amp; Space &amp; "0101 Under Deck";
		elseif count = 2 then
			qty := 50;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		endif;
		self.assertEqualMsg(voyageWle.quantity, qty, "Rebar WLE " &amp; count.String &amp; " has the wrong quantity");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Rebar WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the rebar in on 2 trucks
	self.opts.purge;
	self.opts.addAssoc("Quantity", 75);
	vvr1 := self.gateInPrenote(TruckId1, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	rebarOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite1, "No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite1.totalQuantity, 75, "Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite1.allWorklistEntries.size, rebarPrenote.allWorklistEntries.size + 1, "Truck1 Onsite and prenoted rebar has different WLE count");
	foreach wle in rebarOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, rebarPrenote.allWorklistEntries.size, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Second truck
	self.opts.purge;
	self.opts.addAssoc("Quantity", 25);
	vvr2 := self.gateInPrenote(TruckId2, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	rebarOnsite2 := truck2.locationsController.allTrackedItems.first;
	// prenoted item is now the second onsite item
	self.assertNotEqualMsg(rebarOnsite1, rebarOnsite2, "The two onsite TIs are the same!");
	self.assertEqualMsg(rebarOnsite2, rebarPrenote, "Truck2 Rebar on site is not the prenote TI");
	self.assertNotNullMsg(rebarOnsite2, "Truck2 No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite2.totalQuantity, 25, "Truck2 Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite2.allWorklistEntries.size, rebarPrenote.allWorklistEntries.size, "Truck2 Onsite and prenoted rebar has different WLE count");
	foreach wle in rebarOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 2, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 2, "There is the wrong number of onsite TIs after gating in the two trucks");
	
	// Move some of the onsite cargo
	// Move from the trucks to the hold (replicating the use of the Cargo Lander Mobile app)
	// Truck 1 first - all 75 rebar
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 75 rebar to hold 0101 - this will complete job 103 and partially complete job 104
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(rebarOnsite1, targetLocation, null, 75, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is 1 TI onsite - for quantity 25
	// 2. Onship TI in hold 0101 - quantity 50, with 2 WLEs (voyage and yard, both complete, both for quantity 50)
	// 3. Onship TI in hold 0201 - quantity 25, with 2 WLEs (voyage and yard, both complete, both for quantity 25)
	// 4. Road job for truck 1 is complete and has 1 complete WLE for 75 
	// 5. Job 103 is complete, with 1 voyage WLE for quantity 50, linked to onship TI in hold 0101
	// 6. Job 104 is part complete, with 1 voyage WLE for quantity 25, linked to onship TI in hold 0201
	moveCheck := MoveCheck &amp; "6: ";
	// 1. There is 1 TI onsite - for quantity 25
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite cargo items");
	// 2. Onship TI in hold 0101 - quantity 50, with 2 WLEs (voyage and yard, both complete, both for quantity 50)
	foreach ti in hold0101.allTrackedItems where ti.id = rebarOnsite1.id do
		rebarin0101 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(rebarin0101, moveCheck &amp; "There is no TI on ship with the ID " &amp; rebarOnsite1.id);
	self.assertEqualMsg(hold0101.allTrackedItems.includes(rebarin0101), true, moveCheck &amp; "TI " &amp; rebarin0101.id &amp; " is not in Hold 0101");
	self.assertEqualMsg(rebarin0101.totalQuantity, 50, moveCheck &amp; "TI in hold 0101 has the wrong quantity");
	count := null;
	count2 := null;
	foreach wle in rebarin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWle := wle.CM_VoyageWLE;
			count := count + 1;
		elseif wle.isKindOf(CM_YardWLE) then
			yardWLE := wle.CM_YardWLE;
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "TI in 0101 has the wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "TI in 0101 has the wrong number of yard WLEs");
	self.assertEqualMsg(voyageWle.quantity, 50, moveCheck &amp; "Voyage WLE for TI in 0101 has the wrong quantity");
	self.assertEqualMsg(voyageWle.subSeqNum, 0, moveCheck &amp; "Voyage WLE for TI in 0101 has the wrong subSeqNum");
	self.assertEqualMsg(yardWLE.quantity, 50, moveCheck &amp; "Yard WLE for TI in 0101 has the wrong quantity");
	self.assertEqualMsg(voyageWle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0101 has the wrong status - " &amp; voyageWle.statusString);
	self.assertEqualMsg(yardWLE.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0101 has the wrong status - " &amp; yardWLE.statusString);
	// 3. Onship TI in hold 0201 - quantity 25, with 2 WLEs (voyage and yard, both complete, both for quantity 25)
	foreach ti in hold0201.allTrackedItems where ti.id = rebarOnsite1.id do
		rebarin0201 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(rebarin0201, moveCheck &amp; "There is no TI on ship with the ID " &amp; rebarOnsite1.id);
	self.assertEqualMsg(hold0201.allTrackedItems.includes(rebarin0201), true, moveCheck &amp; "TI " &amp; rebarin0201.id &amp; " is not in Hold 0101");
	self.assertEqualMsg(rebarin0201.totalQuantity, 25, moveCheck &amp; "TI in hold 0201 has the wrong quantity");
	count := null;
	count2 := null;
	foreach wle in rebarin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWle := wle.CM_VoyageWLE;
			count := count + 1;
		elseif wle.isKindOf(CM_YardWLE) then
			yardWLE := wle.CM_YardWLE;
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "TI in 0201 has the wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "TI in 0201 has the wrong number of yard WLEs");
	self.assertEqualMsg(voyageWle.quantity, 25, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong quantity");
	self.assertEqualMsg(voyageWle.subSeqNum, 0, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong subSeqNum");
	self.assertEqualMsg(yardWLE.quantity, 25, moveCheck &amp; "Yard WLE for TI in 0201 has the wrong quantity");
	self.assertEqualMsg(voyageWle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong status - " &amp; voyageWle.statusString);
	self.assertEqualMsg(yardWLE.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0201 has the wrong status - " &amp; yardWLE.statusString);
	// 4. Road job for truck 1 is complete and has 2 complete WLEs, for 50 and 25 
	roadjob := vvr1.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 2, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has wrong number of WLEs");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 50 then
				correctQty1 := true;
			elseif wle.quantity = 25 then
				correctQty2 := true;
			endif;
		else
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has the wrong number of completed WLEs");
	self.assertEqualMsg(count2, 0, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has some incomplete WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "WLEs for Road job for " &amp; TruckId1 &amp; " have the wrong quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 5. Job 103 is complete, with 1 voyage WLE for quantity 50, linked to onship TI in hold 0101
	job103 := jobSheet.allJobsByJobNum["103"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job103, moveCheck &amp; "Job 103 not found");
	self.assertEqualMsg(job103.status, JOB_COMPLETE, moveCheck &amp; "job 103 is not complete - " &amp; job103.statusString);
	count := null;
	foreach wle in job103.workListEntries where wle.myDirectDeliveryParentWLE = null do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for job 103 is not complete - " &amp; wle.statusString);
			self.assertEqualMsg(wle.quantity, 50, moveCheck &amp; "Voyage WLE for job 103 has the wrong quantity");
			self.assertEqualMsg(wle.myTrackedItem, rebarin0101, "Voyage WLE for job 103 has the wrong TI - " &amp; wle.myTrackedItem.id &amp; ":" &amp; rebarin0101.id);
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 103 has the wrong number of voyage WLEs");
	// 6. Job 104 is part complete, with 1 completed voyage WLE for 25 and 1 unactione wle for 25, linked to onship TI in hold 0201
	job104 := jobSheet.allJobsByJobNum["104"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job104, moveCheck &amp; "Job 104 not found");
	self.assertEqualMsg(job104.status, JOB_PART_COMPLETE, moveCheck &amp; "job 104 is not part complete - " &amp; job104.statusString);
	count := null;
	count2 := null;
	foreach wle in job104.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.status = WLE_COMPLETED then
				count2 := count2 + 1;
				self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "Completed Voyage WLE for job 104 has the wrong quantity");
				self.assertEqualMsg(wle.myTrackedItem, rebarin0201, "Completed Voyage WLE for job 103 has the wrong TI - " &amp; wle.myTrackedItem.id &amp; ":" &amp; rebarin0201.id);
			elseif wle.status = WLE_UNACTIONED then
				self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "Unactioned Voyage WLE for job 104 has the wrong quantity");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 104 has the wrong number of voyage WLEs");
	
	// second move - 25 rebar of onsite TI 2 to hold 0201
	// this will complete the outstanding 25 on job 104
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(rebarOnsite2, targetLocation, null, 25, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are no onsite TIs
	// 2. Road job for Truck 2 is complete, with 1 WLE for quantity 25
	// 3. There is still an on ship TI in 0101
	// 4. On ship TI in 0201 is now quantity 50, with 2 voyage WLEs and 2 yard WLEs, all for quantity 25
	// 5. Job 104 is complete, with 2 voyage WLEs, both for quantity 25
	moveCheck := MoveCheck &amp; "7: ";
	// 1. There are no onsite TIs
	self.assertTrueMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, moveCheck &amp; "There is still an onsite TI");
	// 2. Road job for Truck 2 is complete, with 1 WLE for quantity 25
	roadjob := vvr2.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "No road job for VVR 2!");
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for VVR 2 is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; " Road job has too many WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for road job 2 is not complete - " &amp; wle.statusString);
	self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "WLE for road job 2 has wrong quantity");
	// 3. There is still an on ship TI in 0101
	foreach ti in hold0101.allTrackedItems where ti.id = rebarOnsite1.id do
		rebarin0101 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(rebarin0101, moveCheck &amp; "There is no TI on the voyage with the ID of the old TI 1 on site");
	self.assertEqualMsg(rebarin0101.myPrimaryActualLocation, hold0101, moveCheck &amp; "TI " &amp; rebarin0101.id &amp; " is not in 0101 - " &amp; rebarin0101.locationId);
	// 4. On ship TI in 0201 is now quantity 50, with 2 voyage WLEs and 2 yard WLEs, all for quantity 25
	foreach ti in hold0201.allTrackedItems where ti.id = rebarOnsite2.id do
		rebarin0201 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(rebarin0201, moveCheck &amp; "There is no TI on the voyage with the ID of the old TI 2 on site");
	self.assertEqualMsg(rebarin0201.myPrimaryActualLocation, hold0201, moveCheck &amp; "TI " &amp; rebarin0201.id &amp; " is not in 0201 - " &amp; rebarin0201.locationId);
	self.assertEqualMsg(rebarin0201.totalQuantity, 50, moveCheck &amp; "TI in 0201 has the wrong quantity");
	count := null;
	count2 := null;
	foreach wle in rebarin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong status - " &amp; wle.statusString);
			self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong quantity");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong subSeqNum");
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0201 has the wrong status - " &amp; wle.statusString);
			self.assertEqualMsg(wle.quantity, 25, moveCheck &amp; "Yard WLE for TI in 0201 has the wrong quantity");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "TI in 0201 has the wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "TI in 0201 has the wrong number of yard WLEs");
	// 5. Job 104 is complete, with 2 voyage WLEs, both for quantity 25
	job104 := jobSheet.allJobsByJobNum["104"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job104, moveCheck &amp; "No job found for 104");
	self.assertEqualMsg(job104.status, JOB_COMPLETE, "Job 104 has the wrong status - " &amp; job104.statusString);
	count := null;
	correctQty1 := true;
	foreach wle in job104.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity &lt;&gt; 25 then
				correctQty1 := false;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Job 104 has the wrong number of Complete WLEs");
	self.assertEqualMsg(correctQty1, true, "Job 104 has a WLE with an incorrect quantity");
	
	// Road exit the trucks - all cargo gone
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	
	////////////////////////////////////////////////////////////////////////////////////////////
	// TEST 4: Total quantity planned to two holds, different amounts brought in on 3 trucks. //
	// First move part completes first job, second move completes the first and part of the   //
	// second, third move completes the second                                                //
	////////////////////////////////////////////////////////////////////////////////////////////
	// Create another prenote for the voyage 
	rebarPrenote := null;
	rebarOnsite1 := null;
	rebarOnsite2 := null;
	self.opts.purge;
	self.opts.addAssoc("CargoType", rebarCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 100);
	self.opts.addAssoc("DD", true);
	rebarPrenote := self.addPrenoted(RebarId4);
	self.assertTrueMsg(rebarPrenote &lt;&gt; null, "Rebar prenote not created");
	self.assertEqualMsg(rebarPrenote.totalQuantity, 100, "Rebar prenote quantity is incorrect");
	self.assertTrueMsg(rebarPrenote.directDelivery = true, "Rebar prenote is not Direct Delivery");
	
	// Plan the prenote to two holds
	// Load job 105 to 0101: 50 rebar
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(50);
	allocatedWLEs.add(voyageWle);
	job105 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0101, workPoint);
	beginTransaction;
	job105.setOriginalJobAmount(50);
	commitTransaction;
	// Load job 106 to 0102: 50 rebar
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(50);
	allocatedWLEs.add(voyageWle);
	job106 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0102, workPoint);
	beginTransaction;
	job106.setOriginalJobAmount(50);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 7 jobs in its jobsheet, the 2 new jobs (105 and 106) should have 1 WLE, prenote should have 2 WLEs
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 7, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["105"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 105");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	holdjob := jobSheet.allJobsByJobNum["106"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 106");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(rebarPrenote.allWorklistEntries.size, 2, "Rebar prenote has the wrong number of WLEs");
	// Check quantity on the prenoted WLE
	// Rebar: 50 to 0101, 50 to 0102
	count := null;
	foreach wle in rebarPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 50;
			loc := ThisVoyageCode &amp; Space &amp; "0101 Under Deck";
		elseif count = 2 then
			qty := 50;
			loc := ThisVoyageCode &amp; Space &amp; "0102 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.quantity, qty, "Rebar WLE " &amp; count.String &amp; " has the wrong quantity");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Rebar WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the rebar in on 3 trucks
	self.opts.purge;
	self.opts.addAssoc("Quantity", 20);
	vvr1 := null;
	vvr2 := null;
	vvr1 := self.gateInPrenote(TruckId1, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	rebarOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite1, "No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite1.totalQuantity, 20, "Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite1.allWorklistEntries.size, rebarPrenote.allWorklistEntries.size + 1, "Truck1 Onsite and prenoted rebar has different WLE count");
	foreach wle in rebarOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, rebarPrenote.allWorklistEntries.size, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Second truck
	self.opts.purge;
	self.opts.addAssoc("Quantity", 50);
	vvr2 := self.gateInPrenote(TruckId2, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	rebarOnsite2 := truck2.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite2, "No onsite Rebar cargo item for Truck 2");
	self.assertEqualMsg(rebarOnsite2.totalQuantity, 50, "Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite2.allWorklistEntries.size, rebarPrenote.allWorklistEntries.size + 1, "Truck2 Onsite and prenoted rebar has different WLE count");
	foreach wle in rebarOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, rebarPrenote.allWorklistEntries.size, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	// Third truck
	self.opts.purge;
	self.opts.addAssoc("Quantity", 30);
	vvr3 := self.gateInPrenote(TruckId3, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck3 := vvr3.myRoadJob.myVehicle;
	rebarOnsite3 := truck3.locationsController.allTrackedItems.first;
	// prenoted item is now the third onsite item
	self.assertEqualMsg(rebarOnsite3, rebarPrenote, "Truck3 Rebar on site is not the prenote TI");
	self.assertNotNullMsg(rebarOnsite3, "Truck3 No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite3.totalQuantity, 30, "Truck3 Rebar onsite quantity is incorrect");
	foreach wle in rebarOnsite3.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck3 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 2, "Truck3 Yard WLE has an incorrect number of direct delivery WLEs");
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 3, "There is the wrong number of onsite TIs after gating in the three trucks");
	
	// Move some of the onsite cargo
	// Truck 1 first - all 20 rebar
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 20 rebar to hold 0101 - this will part complete job 105
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(rebarOnsite1, targetLocation, null, 20, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are 2 TIs onsite - for quantity 50 and 30
	// 2. Onsite TI 1 has become Onship TI in hold 0101 - quantity 20, with 2 WLEs (voyage and yard, both complete, both for quantity 20)
	// 3. DD WLEs for 0101 on the 2 onsite WLES have subSeqNum reduced to 30
	// 4. Road job for truck 1 is complete and has 1 complete WLE for 20
	// 5. Job 105 is part complete, with 1 completed voyage WLE for 20, linked to onship TI in hold 0101, and 1 unactioned voyage WLE for 30 (one unactioned WLE for each still-onsite TI)
	moveCheck := MoveCheck &amp; "8: ";
	// 1. There are 2 TIs onsite - for quantity 50 and 30
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 2, moveCheck &amp; "Wrong number of onsite TIs after first move");
	correctQty1 := false;
	correctQty2 := false;
	foreach ti in voyage.allOnsiteTIsByIdCargoType do
		if ti.totalQuantity = 50 then
			correctQty1 := true;
		elseif ti.totalQuantity = 30 then
			correctQty2 := true;
		endif;
	endforeach;
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "The onsite TIs have the wrong quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 2. Onsite TI 1 has become Onship TI in hold 0101 - quantity 20, with 2 WLEs (voyage and yard, both complete, both for quantity 20)
	rebarin0101 := voyage.allOnshipTIsByIdCargoType[rebarOnsite1.id, rebarOnsite1.cargoType];
	self.assertNotNullMsg(rebarin0101, moveCheck &amp; "There is no TI in 0101 matching the former onsite TI's id");
	self.assertEqualMsg(rebarin0101, rebarOnsite1, moveCheck &amp; "TI in 0101 is NOT the former onsite TI");
	self.assertEqualMsg(rebarin0101.totalQuantity, 20, moveCheck &amp; "TI in 0101 has the wrong quantity");
	self.assertEqualMsg(rebarin0101.allWorklistEntries.size, 2, moveCheck &amp; "TI in 0101 has the wrong number of WLEs");
	count := null;
	count2 := null;
	foreach wle in rebarin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0101 is not complete - " &amp; wle.statusString);
			self.assertEqualMsg(wle.quantity, 20, moveCheck &amp; "Voyage WLE for TI in 0101 has wrong quantity");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Voyage WLE for TI in 0101 has wrong subSeqNum");
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0101 is not complete - " &amp; wle.statusString);
			self.assertEqualMsg(wle.quantity, 20, moveCheck &amp; "Yard WLE for TI in 0101 has wrong quantity");
		endif;
	endforeach;
	// 3. DD WLEs for 0101 on the 2 onsite WLES have subSeqNum reduced to 30
	correctQty1 := false;
	foreach wle in rebarOnsite2.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.myDirectDeliveryParentWLE &lt;&gt; null and wle.locationTarget = hold0101Str then
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 30, moveCheck &amp; "Onsite TI 2 has wrong subSeqNum on the WLE for 0101");
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Onsite TI 2 has no voyage WLE pointing to 0101");
	correctQty1 := false;
	foreach wle in rebarOnsite3.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.myDirectDeliveryParentWLE &lt;&gt; null and wle.locationTarget = hold0101Str then
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 30, moveCheck &amp; "Onsite TI 3 has wrong subSeqNum on the WLE for 0101");
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Onsite TI 3 has no voyage WLE pointing to 0101");
	// 4. Road job for truck 1 is complete and has 1 complete WLE for 20
	roadjob := vvr1.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for Truck 1 is not complete");
	count := null;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			self.assertEqualMsg(wle.quantity, 20, moveCheck &amp; "Completed WLE on road job for truck 1 has teh wrong quantity");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Road job for truck 1 has teh wrong number of completed WLEs");
	// 5. Job 105 is part complete, with 1 completed voyage WLE for 20, linked to onship TI in hold 0101, and 2 unactioned voyage WLEs for 30
	// (one unactioned WLE for each still-onsite TI)
	job105 := jobSheet.allJobsByJobNum["105"].CM_VoyageHoldJob;
	self.assertEqualMsg(job105.status, JOB_PART_COMPLETE, moveCheck &amp; "JOb 105 is not part complete - " &amp; job105.statusString);
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job105.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 20 then
				correctQty1 := true;
			endif;
			self.assertEqualMsg(wle.myTrackedItem, rebarin0101, "TI on completed WLE for job 105 is not the TI in 0101");
		elseif wle.status = WLE_UNACTIONED then
			count2 := count2 + 1;
			if wle.quantity = 30 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 105 has the wrong number of completed WLEs");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "Job 105 has the wrong number of unactioned WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "job 105 has incorrect quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	
	// Move the next piece of cargo - all the rebar on Truck 2 (50)
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// second move - 50 rebar to hold 0101 - this will complete job 105 and partially complete job 106
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(rebarOnsite2, targetLocation, null, 50, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is only 1 onsite TI
	// 2. TI in 0101 is now quantity 50, with 2 completed voyage WLEs for 20 and 30
	// 3. There is a new TI in 0102, quantity 20, with 1 completed voyage WLE and 1 completed yard WLE, both for 20
	// 4. Voyage job 105 is complete, with 2 completed voyage WLEs for 30 and 20
	// 5. Voyage job 106 is part complete, with 1 completed voyage WLE  for 20 and one unactioned voyage WLE for 30
	// 6. Road job for Truck 2 is complete, with 2 completed yard WLEs for 30 and 20
	// 7. DD WLE for road job for Truck 3 pointing to 0102 has its subSeqNum reduced to 30
	moveCheck := MoveCheck &amp; "9: ";
	// 1. There is only 1 onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite TIs");
	// 2. TI in 0101 is now quantity 50, with 2 completed voyage WLEs for 20 and 30
	rebarin0101 := null;
	foreach ti in hold0101.allTrackedItems do
		if ti.id = RebarId4 and ti.myCargoType = rebarCargoType then
			rebarin0101 := ti;
			break;
		endif;
	endforeach;
	self.assertNotNullMsg(rebarin0101, moveCheck &amp; "No TI found for " &amp; RebarId4 &amp; " in 0101");
	self.assertEqualMsg(rebarin0101.totalQuantity, 50, moveCheck &amp; "TI in 0101 has the wrong quantity");
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in rebarin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "TI in 0101 has a completed voyage WEL with non-zero subSeqNum");
				if wle.quantity = 20 then
					correctQty1 := true;
				elseif wle.quantity = 30 then
					correctQty2 := true;
				endif;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "TO in 0101 has wrong number of completed voyage WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "TI in 0101 has wrong quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 3. There is a new TI in 0102, quantity 20, with 1 completed voyage WLE ad 1 completed yard WLE, both for 20
	rebarin0102 := null;
	foreach ti in hold0102.allTrackedItems do
		if ti.id = RebarId4 and ti.myCargoType = rebarCargoType then
			rebarin0102 := ti;
			break;
		endif;
	endforeach;
	self.assertNotNullMsg(rebarin0102, moveCheck &amp; "No TI found for " &amp; RebarId4 &amp; " in 0101");
	self.assertEqualMsg(rebarin0102.totalQuantity, 20, moveCheck &amp; "TI in 0101 has the wrong quantity");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in rebarin0102.allWorklistEntries do
		if wle.status = WLE_COMPLETED then
			if wle.isKindOf(CM_VoyageWLE) then
				count := count + 1;
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "TI in 0102 has a voyage WLE with non-zero subSeqNum");
				if wle.quantity = 20 then
					correctQty1 := true;
				endif;
			elseif wle.isKindOf(CM_YardWLE) then
				count2 := count2 + 1;
				if wle.quantity = 20 then
					correctQty2 := true;
				endif;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "TI in 0102 has the wrong number of completed Voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "TI in 0102 has the wrong number of completed Yard WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "TI in 0102 has wrong quantities on WLEs - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 4. Voyage job 105 is complete, with 2 completed voyage WLEs for 30 and 20
	job105 := jobSheet.allJobsByJobNum["105"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job105, moveCheck &amp; "No job found for 105");
	self.assertEqualMsg(job105.status, JOB_COMPLETE, moveCheck &amp; "Job 105 is not complete");
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job105.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 20 then
				correctQty1 := true;
			elseif wle.quantity = 30 then
				correctQty2 := true;
			endif;
			if wle.isKindOf(CM_VoyageWLE) then
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Job 105 has a completed voyage WLE with non-zero subSeqNum");
			endif;
		elseif wle.status = WLE_UNACTIONED and wle.CM_VoyageWLE.subSeqNum &lt;&gt; null then
			self.assertTrueMsg(false, moveCheck &amp; "Job 105 has an incomplete WLE");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 102 has the wrong number of Completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Job 105 has wrong WLE quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 5. Voyage job 106 is part complete, with 1 completed voyage WLE for 20 and one unactioned voyage WLE for 30
	job106 := jobSheet.allJobsByJobNum["106"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job106, moveCheck &amp; "No job found for 106");
	self.assertEqualMsg(job106.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 105 is not part complete");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job106.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 20 then
				correctQty1 := true;
			endif;
			if wle.isKindOf(CM_VoyageWLE) then
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Job 105 has a completed voyage WLE with non-zero subSeqNum");
			endif;
		elseif wle.status = WLE_UNACTIONED and wle.CM_VoyageWLE.subSeqNum &lt;&gt; null then
			count2 := count2 + 1;
			if wle.quantity = 30 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 106 has the wrong number of Completed WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Job 106 has the wrong number of Unactioned WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Job 106 has incorrect WLE quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 6. Road job for Truck 2 is complete, with 2 completed yard WLEs for 30 and 20
	roadjob := vvr2.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for Truck 2 has wrong status - " &amp; roadjob.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in roadjob.workListEntries do
		self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Road job for Truck 2 has an incomplete WLE");
		count := count + 1;
		if wle.quantity = 20 then
			correctQty1 := true;
		elseif wle.quantity = 30 then
			correctQty2 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Road job for truck 2 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Road job for Truck 2 has incorrect WLE quantities - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 7. DD WLE for road job for Truck 3 pointing to 0102 has its subSeqNum reduced to 30
	roadjob := vvr3.myRoadJob;
	foreach wle in roadjob.workListEntries do
		foreach ddWle in wle.allDirectDeliveryChildWLEs do
			if ddWle.isKindOf(CM_VoyageWLE) and wle.locationTarget = hold0102Str then
				self.assertEqualMsg(ddWle.CM_VoyageWLE.subSeqNum, 30, "DD WLE in road job for truck 3 has wrong subSeqNum");
			endif;
		endforeach;
	endforeach;
	
	// Move the last piece of cargo - all the rebar on Truck 3 (30)
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// third move - 30 rebar to hold 0102 - this will complete job 106
	targetLocation := hold0102;
	mobileAgent.doLanderLoad(rebarOnsite3, targetLocation, null, 30, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are no more onsite TIs
	// 2. TI on ship in 0102 now has quantity 50, 2 voyage WLEs and 2 road WLEs (for 20 and 30), all complete
	// 3. Total quantity of all TIs with current id on ship adds up to 100
	// 4. Job 106 is complete, and has 2 complete voyage WLEs for 20 and 30 - both linked to TI in 0102
	// 5. Road job for truck 3 is complete, with 1 complete yard WLE for 30
	moveCheck := MoveCheck &amp; "10: ";
	// 1. There are no more onsite TIs
	self.assertTrueMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, moveCheck &amp; "There is still at least 1 on site TI");
	// 2. There is a new TI quantity 30 on ship in 0102 - 1 voyage WLE and 1 road WLE, both for 30 and both complete
	rebarin0102 := null;
	foreach ti in hold0102.allTrackedItems where ti.id = RebarId4 do
		rebarin0102 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(rebarin0102, moveCheck &amp; "There is no TI in 0102 matching id " &amp; RebarId4);
	self.assertEqualMsg(rebarin0102.totalQuantity, 50, moveCheck &amp; "TI in 0102 has the wrong quantity");
	count := null;
	count2 := null;
	foreach wle in rebarin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "TI in 0102 Voyage WEL is not complete - " &amp; wle.statusString);
			count := count + 1;
			vQty := vQty + wle.quantity;
		elseif wle.isKindOf(CM_YardWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "TI in 0102 Yard WLE is not complete - " &amp; wle.statusString);
			count2 := count2 + 1;
			yQty := yQty + wle.quantity;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "TI in 0102 has the wrong number of Voyage WLEs");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "TI in 0102 has the wrong number of Yard WLEs");
	self.assertEqualMsg(vQty = 50 and yQty = 50, true, moveCheck &amp; "TI in 0102 has incorrect WLE quantities - " &amp; vQty.asStringJMT &amp; ":" &amp; yQty.asStringJMT);
	// 3. Total quantity of all TIs with current id on ship adds up to 100
	count := null;
	foreach ti in voyage.allOnshipTIsByIdCargoType where ti.id = RebarId4 do
		count := count + ti.totalQuantity;
	endforeach;
	self.assertEqualMsg(count, 100, moveCheck &amp; "TIs with id " &amp; RebarId4 &amp; " on voyage do not add up to 100");
	// 4. Job 106 is complete, and has 2 complete voyage WLEs for 20 and 30 - both linked to TI in 0102
	job106 := jobSheet.allJobsByJobNum["106"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job106, moveCheck &amp; "No job found in job sheet for 106");
	self.assertEqualMsg(job106.status, JOB_COMPLETE, moveCheck &amp; "Job 106 is not complete - " &amp; job106.statusString);
	count := null;
	correctQty1 := false;
	correctQty1 := false;
	foreach wle in job106.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and not wle.myTrackedItem.hasBeenMerged then
			count := count + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE in job 106 is not complete - " &amp; wle.statusString);
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Voyage WLE in job 106 has non-zero subSeqNum");
			self.assertEqualMsg(wle.myTrackedItem, rebarin0102, moveCheck &amp; "Voyage WLE in job 106 has wrong TI - " &amp; wle.myTrackedItem.id &amp; ":" &amp; rebarin0102.id);
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 106 has wrong number of Voyage WLEs");
	// 5. Road job for truck 3 is complete, with 1 complete yard WLE for 30
	roadjob := vvr3.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for truck 3 is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job for truck 3 has the wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for road job for truck 3 is not complete - " &amp; wle.statusString);
	self.assertEqualMsg(wle.quantity, 30, moveCheck &amp; "WLE for road job for truck 3 has the wrong quantity");
	
	// Road exit the trucks - all cargo gone
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	self.roadExit(vvr3);
	
	////////////////////////
	// Finished - Tidy up //
	////////////////////////
	self.deleteWorkPoint(ThisWorkPoint);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteVehicle(TruckId1);
	self.deleteVehicle(TruckId2);
	
epilog
	delete allocatedWLEs;
	delete mobileAgent;
	self.setTerminalConfig(DirectTruck2VesselMult, directTruckMoves);
	app.myPassport.setMyTerminal(passportTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="tSalalahDirectToShipQty3" id="3d475c76-97b7-452a-8892-51788cc718b2">
        <source>tSalalahDirectToShipQty3();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/12/2021	navdap1		Initial creation TFS 52293
//
constants
	ThisVoyageCode : String = "DAVEH52293_6";
	ThisVesselCode : String = "DAVEHOLD";
	REBAR : String = "REBAR";
	RebarId1 : String = "REBARDD52293_6_1";
	ThisWorkPoint : String = "WP52293_6";
	TruckId1 : String = "UT52293_6_1";
	MoveCheck : String = "Move Check ";
	
vars
	terminal, passportTerminal : CM_Terminal;
	directTruckMoves : Boolean;
	operator : CM_Operator;
	rebarCargoType : CM_CargoType;
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	rebarPrenote, rebarOnsite1, rebarin0201, rebarin0202 : CM_TrackedItem;
	hold0101, hold0102, hold0201, hold0202 : CM_GeneralCargoController;
	hold0101Str, hold0102Str, hold0201Str, hold0202Str : String;
	voyageWle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	allocatedWLEs : CM_WLEArray;
	jobSheet : CM_VoyageHoldJobSheet;
	holdjob : CM_VoyageJob;
	count, count2 : Integer;
	qty, total : Integer;
	loc : String;
	mobileAgent : CMIF_MobileGenericAgent;
	targetLocation : CM_LocationsController;
	yardWLE : CM_YardWLE;
	voyageWleFound, yardWleFound : Boolean;
	roadjob : CM_RoadJob;
	correctQty1, correctQty2, correctQty3, correctQty4 : Boolean;
	vvr1 : CM_VehicleVisitRecord;
	moveCheck : String;
	job100, job101 : CM_VoyageHoldJob;
	truck1 : CM_Vehicle;


begin
	// Set the terminal config that drives all of this
	terminal := self.getTerminal;
	directTruckMoves := self.setTerminalConfig(DirectTruck2VesselMult, true).Boolean;
	//return;
	///////////////////////////////////////
	// Sanity Check and Pre-run Clean Up //
	///////////////////////////////////////
	rebarCargoType := app.myRoot.getCargoTypeFromAbbrev(REBAR);
	self.assertTrueMsg(rebarCargoType &lt;&gt; null, REBAR &amp; "does not exist as a Cargo Type");
	
	self.opts.purge;
	self.opts.addAssoc("includePrenote", true);
	self.deleteCargo(RebarId1, rebarCargoType);
	self.deleteVehicle(TruckId1);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteWorkPoint(ThisWorkPoint);
	self.assertTrueMsg(self.getVoyage(ThisVoyageCode) = null, "Voyage " &amp; ThisVoyageCode &amp; " not deleted");
	
	////////////
	// Set Up //
	////////////
	// Create a Voyage with Holds
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage := self.addVoyageWithGeneralCargoStruc(ThisVoyageCode, ThisVesselCode, operator.code, "DOUG", 2);
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage not created");
	self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null and voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.size = 10, "General Cargo voyage not set up correctly");
	// and a workpoint
	workPoint := self.addWorkPoint(ThisWorkPoint, false);
	self.assertTrueMsg(workPoint &lt;&gt; null, "Work Point not created");
	
	hold0101 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,1];
	hold0102 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,2];
	hold0201 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,1];
	hold0202 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,2];
	hold0101Str := hold0101.getFullId;
	hold0102Str := hold0102.getFullId;
	hold0201Str := hold0201.getFullId;
	hold0202Str := hold0202.getFullId;
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// TEST: Plan most but not all of the cargo to two holds, then bring the entire prenote in on one truck //
	// Move it in chunks to the planned holds.                                                              //
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Create a prenote for the voyage splittable by quantity
	self.opts.purge;
	self.opts.addAssoc("CargoType", rebarCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 100);
	self.opts.addAssoc("DD", true);
	rebarPrenote := self.addPrenoted(RebarId1);
	self.assertTrueMsg(rebarPrenote &lt;&gt; null, "Rebar prenote not created");
	self.assertEqualMsg(rebarPrenote.totalQuantity, 100, "Rebar prenote quantity is incorrect");
	self.assertTrueMsg(rebarPrenote.directDelivery = true, "Rebar prenote is not Direct Delivery");
	
	// Plan the prenote to two holds
	// Load job 100 to 0201: 30
	create allocatedWLEs transient;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(30);
	allocatedWLEs.add(voyageWle);
	job100 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job100.setOriginalJobAmount(30);
	commitTransaction;
	// Load job 102 to 0202: 50
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(50);
	allocatedWLEs.add(voyageWle);
	job101 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0202, workPoint);
	beginTransaction;
	job101.setOriginalJobAmount(50);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 2 jobs in its jobsheet, the 2 jobs (100 and 101) should have 1 WLE each, prenote should have 2 WLEs
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 2, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["100"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 100");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	holdjob := jobSheet.allJobsByJobNum["101"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 101");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(rebarPrenote.allWorklistEntries.size, 2, "Rebar prenote has the wrong number of WLEs");
	// Check quantity on the prenoted WLE
	// 30 to 0201, 50 to 0202
	count := null;
	foreach wle in rebarPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 30;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		elseif count = 2 then
			qty := 50;
			loc := ThisVoyageCode &amp; Space &amp; "0202 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.quantity, qty, "Rebar WLE " &amp; count.String &amp; " has the wrong quantity");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Rebar WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the rebar in on 1 truck
	self.opts.purge;
	self.opts.addAssoc("TotalQuantity", 100);
	vvr1 := self.gateInPrenote(TruckId1, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	rebarOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite1, "No onsite Rebar cargo item");
	self.assertEqualMsg(rebarOnsite1.totalQuantity, 100, "Rebar onsite quantity is incorrect");
	self.assertEqualMsg(rebarOnsite1, rebarPrenote, "Onsite Rebar is not prenoted Rebar");
	foreach wle in rebarOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 2, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	
	// Move some of the onsite cargo
	// Move from the truck to the holds (replicating the use of the Cargo Lander Mobile app)
	// First move - 40 to 0201
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 40 to hold 0201
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(rebarOnsite1, targetLocation, null, 40, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is still one TI onsite - quantity 60
	// 2. There is an onship TI in hold 0201 - quantity 30, with 2 WLEs (voyage and yard, both complete, both for 30)
	// 3. There is an onship TI in hold 0202 - quantity 10, with 2 WLEs (voyage and yard, both complete, both for 10)
	// 4. Road job for truck is Part Complete and has 2 complete yard WLEs (1 for 30, 1 for 10) and 1 unactioned WLE for 60
	// 5. Job 100 is complete, with 1 completed voyage WLE for 30, linked to the onship TI in 0201
	// 6. Job 101 is part complete, with 1 completed voyage WLE for 10, linked to the onship TI in 0202, and 2 unactioned WLEs (1 for 40, one for 20)
	//	  The 20 incomplete WLE has been created to cater for the 20 left on the truck once all the planned quantities are taken in to account
	moveCheck := MoveCheck &amp; "1: ";
	// 1. There is still one TI onsite - quantity 60
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong numbmer of onsite TIs");
	self.assertEqualMsg(rebarOnsite1.totalQuantity, 60, moveCheck &amp; "Rebar onsite has the wrong quantity");
	// 2. There is an onship TI in hold 0201 - quantity 30, with 2 WLEs (voyage and yard, both complete, both for 30)
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	rebarin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(rebarin0201, "There is no onship Rebar in hold 0201");
	self.assertEqualMsg(rebarin0201.totalQuantity, 30, moveCheck &amp; "Rebar in 0201 has the wrong quantity");
	self.assertEqualMsg(rebarin0201.allWorklistEntries.size, 2, moveCheck &amp; "Rebar in 0201 has the wrong number of WLEs");
	voyageWleFound := false;
	yardWleFound := false;
	foreach wle in rebarin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.quantity, 30, moveCheck &amp; "Rebar in 0201 voyage WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0201 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.quantity, 30, moveCheck &amp; "Rebar in 0201 yard WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0201 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Rebar in 0201 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Rebar in 0201 has no yard WLE");
	// 3. There is an onship TI in hold 0202 - quantity 10, with 2 WLEs (voyage and yard, both complete, both for 10)
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0202");
	rebarin0202 := hold0202.allTrackedItems.first;
	self.assertNotNullMsg(rebarin0202, "There is no onship Clinker in hold 0202");
	self.assertEqualMsg(rebarin0202.totalQuantity, 10, moveCheck &amp; "Rebar in 0202 has the wrong quantity");
	self.assertEqualMsg(rebarin0202.allWorklistEntries.size, 2, moveCheck &amp; "Rebar in 0202 has the wrong number of WLEs");
	voyageWleFound := false;
	yardWleFound := false;
	foreach wle in rebarin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.quantity, 10, moveCheck &amp; "Rebar in 0202 voyage WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0202 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.quantity, 10, moveCheck &amp; "Rebar in 0202 yard WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0202 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Rebar in 0202 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Rebar in 0202 has no yard WLE");
	// 4. Road job for truck is Part Complete and has 2 complete yard WLEs (1 for 30, 1 for 10) and 1 unactioned WLE for 60
	roadjob := vvr1.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId1 &amp; " is null");
	self.assertEqualMsg(roadjob.status, JOB_PART_COMPLETE, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has wrong status - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 3, moveCheck &amp; "Road job has wrong number of WLEs");
	count := null;
	count2 := null;
	total := null;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			total := total + wle.quantity;
		elseif wle.status = WLE_UNACTIONED then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.quantity, 60, moveCheck &amp; "Unactioned WLE on road job has the wrong quantity");
		endif;
	endforeach;
	self.assertEqualMsg(total, 40, moveCheck &amp; "Completed WLEs on the road job have the wrong total quantity");
	// 5. Job 100 is complete, with 1 completed voyage WLE for 30, linked to the onship TI in 0201
	self.assertEqualMsg(job100.status, JOB_COMPLETE, moveCheck &amp; "Job 100 for hold 0201 is not complete - " &amp; job100.statusString);
	self.assertEqualMsg(job100.workListEntries.size, 1, moveCheck &amp; "Job 100 for hold 0201 has the wrong number of WLEs");
	wle := job100.workListEntries.first;
	self.assertNotNullMsg(wle, moveCheck &amp; "There is no WLE for job 100 in hold 0201");
	self.assertEqualMsg(wle.quantity, 30, moveCheck &amp; "WLE for job 100 has the wrong quantity");
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Wle for job 100 in hold 0201 has the wrong status - " &amp; wle.statusString);
	self.assertEqualMsg(wle.myTrackedItem, rebarin0201, "WLE for job 100 in 0201 is linked to the wrong TI");
	self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 100 in 0201 has the wrong subSeqNum");
	// 6. Job 101 is part complete, with 1 completed voyage WLE for 10, linked to the onship TI in 0202, and 2 unactioned WLEs (1 for 40, one for 20)
	//	  The 20 incomplete WLE has been created to cater for the 20 left on the truck once all the planned quantities are taken in to account
	self.assertEqualMsg(job101.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 101 for hold 0202 has the wrong status - " &amp; job101.statusString);
	self.assertEqualMsg(job101.workListEntries.size, 3, moveCheck &amp; "Job 101 for hold 0202 has the wrong number of WLEs");
	count := null;
	count2 := null;
	total := null;
	foreach wle in job101.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			self.assertEqualMsg(wle.quantity, 10, moveCheck &amp; "Completed WLE for job 101 has the wrong quantity");
			self.assertEqualMsg(wle.myTrackedItem, rebarin0202, moveCheck &amp; "Completed WLE for job 101 is linked to the wrong TI");
		elseif wle.status = WLE_UNACTIONED then
			count2 := count2 + 1;
			total := total + wle.CM_VoyageWLE.subSeqNum;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 101 has the wrong number of complete WLEs");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "Job 101 has the wrong number of unactioned WLEs");
	self.assertEqualMsg(total, 60, moveCheck &amp; "Job 101 unactioned WLEs have the wrong total quantity");
	
	// second move - move the remaining 60 to hold 0202
	// this will complete the 2 outstanding WLEs on job 101
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(rebarOnsite1, targetLocation, null, 60, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is no onsite TI
	// 2. There is still 1 TI in hold 0201, still quantity 30
	// 3. There is still 1 TI in hold 0202, but now its quantity is 70
	// 4. Road job is complete, with 4 completed road WLEs (30, 10, 20, 40)
	// 5. Job 101 is complete, with 3 completed voyage WLEs for 10, 20 and 40
	// 6. TI in hold 0202 has 3 completed voyage WLEs for 10, 20 and 40
	moveCheck := MoveCheck &amp; "2: ";
	// 1. There is no onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 0, moveCheck &amp; "There is still an onsite TI");
	// 2. There is still 1 TI in hold 0201, still quantity 30
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0201");
	rebarin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(rebarin0201, moveCheck &amp; "There is no TI in hold 0201");
	self.assertEqualMsg(rebarin0201.totalQuantity, 30, moveCheck &amp; "Rebar in 0201 has the wrong quantity");
	// 3. There is still 1 TI in hold 0202, but now its quantity is 70
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0202");
	rebarin0202 := hold0202.allTrackedItems.first;
	self.assertNotNullMsg(rebarin0202, moveCheck &amp; "There is no TI in hold 0202");
	self.assertEqualMsg(rebarin0202.totalQuantity, 70, moveCheck &amp; "Rebar in 0202 has the wrong quantity");
	// 4. Road job is complete, with 4 completed road WLEs (30, 10, 20, 40)
	roadjob := vvr1.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 4, moveCheck &amp; "Road job has the wrong number of WLEs");
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	correctQty3 := false;
	correctQty4 := false;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 30 then
				correctQty1 := true;
			elseif wle.quantity = 10 then
				correctQty2 := true;
			elseif wle.quantity = 20 then
				correctQty3 := true;
			elseif wle.quantity = 40 then
				correctQty4 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 4, moveCheck &amp; "Road job has wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2 and correctQty3 and correctQty4, true, "Road job completed WLE quantities are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT &amp; ":" &amp; correctQty3.asStringJMT &amp; ":" &amp; correctQty4.asStringJMT);
	// 5. Job 101 is complete, with 3 completed voyage WLEs for 10, 20 and 40
	self.assertEqualMsg(job101.status, JOB_COMPLETE, moveCheck &amp; "Job 101 has the wrong status - " &amp; job101.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	correctQty3 := false;
	foreach wle in job101.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 10 then
				correctQty1 := true;
			elseif wle.quantity = 20 then
				correctQty2 := true;
			elseif wle.quantity = 40 then
				correctQty3 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, moveCheck &amp; "Job 101 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2 and correctQty3, true, "Job 101 completed WLEs quantities are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT &amp; ":" &amp; correctQty3.asStringJMT);
	// 6. TI in hold 0202 has 3 completed voyage WLEs for 10, 20 and 40
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	correctQty3 := false;
	foreach wle in rebarin0202.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 10 then
				correctQty1 := true;
			elseif wle.quantity = 20 then
				correctQty2 := true;
			elseif wle.quantity = 40 then
				correctQty3 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, moveCheck &amp; "Rebar in hold 0202 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2 and correctQty3, true, "Rebar in hold 0202 completed WLEs quantities are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT &amp; ":" &amp; correctQty3.asStringJMT);
	
	// Road exit the truck - all cargo gone
	self.roadExit(vvr1);
	
	////////////////////////
	// Finished - Tidy up //
	////////////////////////
	self.deleteWorkPoint(ThisWorkPoint);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteVehicle(TruckId1);
	
epilog
	delete allocatedWLEs;
	delete mobileAgent;
	self.setTerminalConfig(DirectTruck2VesselMult, directTruckMoves);
	app.myPassport.setMyTerminal(passportTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="tSalalahDirectToShipQty4" id="d687a41f-de18-4c9e-9d32-5cf19c7a6c12">
        <source>tSalalahDirectToShipQty4();
//
// Purpose:			Test new process for removing incomplete prenote from hold job and replanning 
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17 February 2022	navdap1		Initial creation TFS 52801 Direct Delivery - End of Shift Job Transfer
//
constants
	ThisVoyageCode : String = "DAVEH52293_7";
	ThisVesselCode : String = "DAVEHOLD";
	REBAR : String = "REBAR";
	RebarId1 : String = "REBARDD52293_7_1";
	ThisWorkPoint : String = "WP52293_7";
	TruckId1 : String = "UT52293_7_1";
	TruckId2 : String = "UT52293_7_2";
	TruckId3 : String = "UT52293_7_3";
	MoveCheck : String = "Move Check ";
	
vars
	terminal, passportTerminal : CM_Terminal;
	directTruckMoves : Boolean;
	operator : CM_Operator;
	rebarCargoType : CM_CargoType;
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	rebarPrenote, rebarOnsite1, rebarOnsite2, rebarOnsite3, rebarin0201, rebarin0202 : CM_TrackedItem;
	hold0201, hold0202 : CM_GeneralCargoController;
	hold0201Str, hold0202Str : String;
	voyageWle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	allocatedWLEs : CM_WLEArray;
	allocatedTIs : CM_TISet;
	jobSheet : CM_VoyageHoldJobSheet;
	holdjob : CM_VoyageJob;
	count, count2 : Integer;
	qty, total : Integer;
	loc : String;
	mobileAgent : CMIF_MobileGenericAgent;
	targetLocation : CM_LocationsController;
	yardWLE : CM_YardWLE;
	voyageWleFound, yardWleFound : Boolean;
	roadjob : CM_RoadJob;
	correctQty1, correctQty2 : Boolean;
	vvr1, vvr2, vvr3, vvr4 : CM_VehicleVisitRecord;
	moveCheck : String;
	job100, pxyJob100, job101 : CM_VoyageHoldJob;
	truck1, truck2, truck3 : CM_Vehicle;
	jobParams : CMIF_VoyageJobParams;
	realShift, pxyShift : CM_Shift;

begin
	// Set the terminal config that drives all of this
	terminal := self.getTerminal;
	directTruckMoves := self.setTerminalConfig(DirectTruck2VesselMult, true).Boolean;
	//return;
	///////////////////////////////////////
	// Sanity Check and Pre-run Clean Up //
	///////////////////////////////////////
	rebarCargoType := app.myRoot.getCargoTypeFromAbbrev(REBAR);
	self.assertTrueMsg(rebarCargoType &lt;&gt; null, REBAR &amp; "does not exist as a Cargo Type");
	
	self.opts.purge;
	self.opts.addAssoc("includePrenote", true);
	self.deleteCargo(RebarId1, rebarCargoType);
	self.deleteVehicle(TruckId1);
	self.deleteVehicle(TruckId2);
	self.deleteVehicle(TruckId3);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteWorkPoint(ThisWorkPoint);
	self.assertTrueMsg(self.getVoyage(ThisVoyageCode) = null, "Voyage " &amp; ThisVoyageCode &amp; " not deleted");
	
	////////////
	// Set Up //
	////////////
	// Create a Voyage with Holds
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage := self.addVoyageWithGeneralCargoStruc(ThisVoyageCode, ThisVesselCode, operator.code, "DOUG", 2);
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage not created");
	self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null and voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.size = 10, "General Cargo voyage not set up correctly");
	// and a workpoint
	workPoint := self.addWorkPoint(ThisWorkPoint, false);
	self.assertTrueMsg(workPoint &lt;&gt; null, "Work Point not created");
	
	hold0201 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,1];
	hold0202 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,2];
	hold0201Str := hold0201.getFullId;
	hold0202Str := hold0202.getFullId;
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////
	// TEST: Plan all the cargo to one hold, bring smoe of the prenote in on three trucks               //
	// Move two of the trucks to the hold job, then remove and replan the prenote to another hold job.  //
	// Move the last truck (which should be planned to the new job) and the rest of the prenote.        //
	//////////////////////////////////////////////////////////////////////////////////////////////////////
	// Create a prenote for the voyage splittable by quantity
	self.opts.purge;
	self.opts.addAssoc("CargoType", rebarCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalQuantity", 1000);
	self.opts.addAssoc("DD", true);
	rebarPrenote := self.addPrenoted(RebarId1);
	self.assertTrueMsg(rebarPrenote &lt;&gt; null, "Rebar prenote not created");
	self.assertEqualMsg(rebarPrenote.totalQuantity, 1000, "Rebar prenote quantity is incorrect");
	self.assertTrueMsg(rebarPrenote.directDelivery = true, "Rebar prenote is not Direct Delivery");
	
	// Plan the prenote to one hold
	// Load job 100 to 0201: 1000
	create allocatedWLEs transient;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(1000);
	allocatedWLEs.add(voyageWle);
	job100 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job100.setOriginalJobAmount(1000);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 1 job in its jobsheet, the job should have 1 WLE, prenote should have 1 WLE
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 1, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["100"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 100");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(rebarPrenote.allWorklistEntries.size, 1, "Rebar prenote has the wrong number of WLEs");
	// Check quantity on the prenoted WLE
	// 1000 to 0201
	count := null;
	foreach wle in rebarPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 1000;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		endif;
		self.assertEqualMsg(voyageWle.quantity, qty, "Rebar WLE " &amp; count.String &amp; " has the wrong quantity");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Rebar WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate some of the rebar in on 3 trucks
	// Truck 1 - 40 
	self.opts.purge;
	self.opts.addAssoc("Quantity", 40);
	vvr1 := self.gateInPrenote(TruckId1, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	rebarOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite1, "No onsite Rebar cargo item for quantity 40");
	self.assertEqualMsg(rebarOnsite1.totalQuantity, 40, "Rebar onsite quantity 1 is incorrect");
	foreach wle in rebarOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Truck 2 - 90
	self.opts.purge;
	self.opts.addAssoc("Quantity", 90);
	vvr2 := self.gateInPrenote(TruckId2, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	rebarOnsite2 := truck2.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite2, "No onsite Rebar cargo item for quantity 90");
	self.assertEqualMsg(rebarOnsite2.totalQuantity, 90, "Rebar onsite quantity 2 is incorrect");
	foreach wle in rebarOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	// Truck 3 - 70
	self.opts.purge;
	self.opts.addAssoc("Quantity", 70);
	vvr3 := self.gateInPrenote(TruckId3, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck3 := vvr3.myRoadJob.myVehicle;
	rebarOnsite3 := truck3.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite3, "No onsite Rebar cargo item for quantity 70");
	self.assertEqualMsg(rebarOnsite3.totalQuantity, 70, "Rebar onsite quantity 3 is incorrect");
	foreach wle in rebarOnsite3.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck3 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Truck3 Yard WLE has an incorrect number of direct delivery WLEs");
	
	// Move some of the onsite cargo
	// Move from the truck to the holds (replicating the use of the Cargo Lander Mobile app)
	// First move from truck1 - 40 to 0201
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 40 from truck 1 to hold 0201
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(rebarOnsite1, targetLocation, null, 40, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are still two TIs onsite - quantity 160
	// 2. There is an onship TI in hold 0201 - quantity 40, with 2 WLEs (voyage and yard, both complete, both for 40)
	// 3. Road job for truck1 is Complete and has 1 complete yard WLE for 40
	// 4. Job 100 is part complete, with 1 completed voyage WLE for 40, linked to the onship TI in 0201
	moveCheck := MoveCheck &amp; "1: ";
	// 1. There are still two TIs onsite - quantity 160
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 2, moveCheck &amp; "Wrong numbmer of onsite TIs");
	self.assertEqualMsg(rebarOnsite2.site, TI_SITE_ONSITE, moveCheck &amp; " Rebar onsite 2 has incorrect site - " &amp; app.siteEnumToString(rebarOnsite2.site));
	self.assertEqualMsg(rebarOnsite2.totalQuantity, 90, moveCheck &amp; "Rebar onsite 2 has the wrong quantity");
	self.assertEqualMsg(rebarOnsite3.site, TI_SITE_ONSITE, moveCheck &amp; " Rebar onsite 3 has incorrect site - " &amp; app.siteEnumToString(rebarOnsite3.site));
	self.assertEqualMsg(rebarOnsite3.totalQuantity, 70, moveCheck &amp; "Rebar onsite 3 has the wrong quantity");
	// 2. There is an onship TI in hold 0201 - quantity 40, with 2 WLEs (voyage and yard, both complete, both for 40)
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	rebarin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(rebarin0201, "There is no onship Rebar in hold 0201");
	self.assertEqualMsg(rebarin0201.totalQuantity, 40, moveCheck &amp; "Rebar in 0201 has the wrong quantity");
	self.assertEqualMsg(rebarin0201.allWorklistEntries.size, 2, moveCheck &amp; "Rebar in 0201 has the wrong number of WLEs");
	voyageWleFound := false;
	yardWleFound := false;
	foreach wle in rebarin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.quantity, 40, moveCheck &amp; "Rebar in 0201 voyage WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0201 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.quantity, 40, moveCheck &amp; "Rebar in 0201 yard WLE quantity is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Rebar in 0201 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Rebar in 0201 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Rebar in 0201 has no yard WLE");
	// 3. Road job for truck1 is Complete and has 1 complete yard WLE for 40
	roadjob := vvr1.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId1 &amp; " is null");
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has wrong status - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has wrong number of WLEs");
	count := null;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			total := total + wle.quantity;
		endif;
	endforeach;
	self.assertEqualMsg(total, 40, moveCheck &amp; "Completed WLE on the road job has the wrong total quantity");
	// 4. Job 100 is part complete, with 1 completed voyage WLE for 40, linked to the onship TI in 0201
	self.assertEqualMsg(job100.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 100 for hold 0201 is not part complete - " &amp; job100.statusString);
	count := null;
	correctQty1 := false;
	foreach wle in job100.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 40 then
				correctQty1 := true;
				self.assertEqualMsg(wle.myTrackedItem, rebarin0201, "WLE for job 100 in 0201 is linked to the wrong TI");
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 100 in 0201 has the wrong subSeqNum");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 100 for hold 0201 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Completed WLE for job 100 has the wrong quantity");
	
	// second move - move the 90 from truck 2 to hold 0201
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(rebarOnsite2, targetLocation, null, 90, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is still 1 onsite TI
	// 2. There is still 1 TI in hold 0201, now quantity 130
	// 3. Road job for truck 2 is complete, with 1 completed road WLE for 90
	// 4. Job 100 is part complete, with 2 completed voyage WLEs for 40 and 90
	// 5. TI in hold 0201 has 2 completed voyage WLEs for 40 and 90
	// 6. Prenote should have quantity 800
	// 7. Unactioned WLE on job 100 should have quantity 800
	moveCheck := MoveCheck &amp; "2: ";
	// 1. There is still 1 onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "There is the wrong number of onsite TIs");
	// 2. There is still 1 TI in hold 0201, now quantity 130
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0201");
	rebarin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(rebarin0201, moveCheck &amp; "There is no TI in hold 0201");
	self.assertEqualMsg(rebarin0201.totalQuantity, 130, moveCheck &amp; "Rebar in 0201 has the wrong quantity");
	// 3. Road job for truck 2 is complete, with 1 completed road WLE for 90
	roadjob := vvr2.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has the wrong number of WLEs");
	count := null;
	correctQty1 := false;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 90 then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Road job 2 has wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1, true, "Road job completed WLE quantity is wrong");
	// 4. Job 100 is part complete, with 2 completed voyage WLEs for 40 and 90
	self.assertEqualMsg(job100.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 100 has the wrong status - " &amp; job100.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job100.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 40 then
				correctQty1 := true;
			elseif wle.quantity = 90 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 100 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "Job 100 completed WLEs quantities are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 5. TI in hold 0201 has 2 completed voyage WLEs for 40 and 90
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in rebarin0201.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 40 then
				correctQty1 := true;
			elseif wle.quantity = 90 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Rebar in hold 0201 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "Rebar in hold 0201 completed WLEs quantities are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 6. Prenote should have quantity 800
	self.assertEqualMsg(rebarPrenote.totalQuantity, 800, moveCheck &amp; "Prenote rebar has incorrect quantity - " &amp; rebarPrenote.totalQuantity.String);
	// 7. Unactioned WLE on job 100 should have quantity 800
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job100.workListEntries where wle.status = WLE_UNACTIONED and not wle.myTrackedItem.hasBeenMerged do
		count := count + 1;
		if wle.quantity = 870 then
			correctQty1 := true;
		elseif wle.quantity = 70 then
			correctQty2 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 100 has the wrong number of unactioned WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Job 100 unactioned WLE has the wrong quantity - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	
	// Edit the 0201 hold job to remove the prenote WLE
	allocatedWLEs.purge;
	create allocatedTIs transient;
	foreach wle in job100.workListEntries where wle.status = WLE_COMPLETED do
		if wle.myTrackedItem &lt;&gt; null then
			allocatedTIs.addNoDuplicates(wle.myTrackedItem, false);
		endif;
	endforeach;
	pxyJob100 := app.createUpdateProxy(job100).CM_VoyageHoldJob;
	pxyJob100.setProxy(job100.jobNum, job100.jobType);
	pxyJob100.setProxyVoyage(job100.myVoyage);
	pxyJob100.setProxyVoyageHoldJob(null, job100.jobNum, job100.remarks, null, false, job100.jobType, null, null, job100.actualStartTs, job100.actualEndTs, false, job100.myShift, null, allocatedTIs, null, null);
	pxyJob100.setTransferType(job100.transferType);
	pxyJob100.setIsDirectDelivery(true);
	pxyJob100.setOriginalJobAmount(job100.originalJobAmount);
	realShift := job100.myShift;
	pxyShift := app.createUpdateProxy(realShift).CM_Shift;
	pxyShift.setProxy(realShift.startDateTime.date.day, realShift.startDateTime.time, realShift.endDateTime.time, realShift.code, realShift.description, realShift.myTerminal, realShift.ignore);
	pxyJob100.setMyShift(pxyShift);
	create jobParams transient;
	jobParams.myLocation := hold0201;
	jobParams.myVoyage := pxyJob100.myVoyage;
	jobParams.myProxyJob := pxyJob100;
	jobParams.autoSortIntoOOW := false;
	jobParams.craneID := null;
	jobParams.myJobType := null;
	jobParams.remarks := job100.remarks;
	jobParams.myWorkPoint := job100.getMyWorkPointObject().CM_WorkPoint;
	jobParams.craneID := job100.getMyWorkPointObject.CM_WorkPoint.code;
	jobParams.allowOutOfOrderLoading := false;
	jobParams.transitStatus := TI_TransitStatusNull;
	jobParams.isDischarge := false;
	jobParams.isDirectDelivery := true;
	jobParams.originalJobAmount := pxyJob100.originalJobAmount;
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxUpdateVoyageHoldJob(jobParams, pxyJob100, job100, app.myPassport, allocatedWLEs);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Check:
	// 1. Prenote should no longer be Direct Delivery
	// 2. Onsite TI should no longer be Direct Delivery
	// 3. Job 100 should be Completed, with 2 completed Voyage WLEs for 40 and 90
	// 1. Prenote should no longer be Direct Delivery
	self.assertEqualMsg(rebarPrenote.directDelivery, false, "After completing Job 100: Prenote is still Direct Delivery");
	// 2. Onsite TI should no longer be Direct Delivery
	self.assertEqualMsg(rebarOnsite3.directDelivery, false, "After completing Job 100: TI still on site is still Direct Delivery");
	// 3. Job 100 should be Completed, with 2 completed Voyage WLEs for 40 and 90
	self.assertEqualMsg(job100.status, JOB_COMPLETE, "After completing Job 100: Job 100 is not Complete - " &amp; job100.statusString);
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job100.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.quantity = 40 then
				correctQty1 := true;
			elseif wle.quantity = 90 then
				correctQty2 := true;
			endif;
		else
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "After completing Job 100: Job 100 has the wrong number of Complete WLEs");
	self.assertEqualMsg(count2, 0, "After completing Job 100: Job 100 has the wrong number of incomplete WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "After completing Job 100: Job 100 WLEs have the wrong quantity - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	
	// Take a break - to allow timestamps to be different between the receival date of the cargo on site and the newly created voyage WLE for the prenote
	process.sleep(1000);
	
	// Create a new hold job in 0202 and plan the entire remaining prenote to it
	// Load job 101 to 0202: 800
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(rebarPrenote);
	voyageWle.setQuantity(800);
	allocatedWLEs.add(voyageWle);
	job101 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0202, workPoint);
	beginTransaction;
	job101.setOriginalJobAmount(800);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 2 jobs in its jobsheet, job 101 should have 2 WLEs (1 for 800 and 1 for 70), prenote should have 1 WLE
	// Onsite TI rebarOnsite3 should be Direct Delivery, and have one voyage WLE planned to 0202
	// Road job for onsite TI rebarOnsite3 should have 1 yard WLE which should have 1 allDirectDeliveryChildWLEs entry
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 2, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["101"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 101");
	self.assertEqualMsg(holdjob.workListEntries.size, 2, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(rebarPrenote.allWorklistEntries.size, 1, "Rebar prenote has the wrong number of WLEs");
	self.assertEqualMsg(holdjob, job101, "Hold job found with key '101' is not the hold job created as job101");
	// Check quantity on the prenoted WLE
	// 800 to 0202
	count := null;
	foreach wle in rebarPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 800;
			loc := ThisVoyageCode &amp; Space &amp; "0202 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.quantity, qty, "Rebar WLE " &amp; count.String &amp; " has the wrong quantity");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Rebar WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	// check remaining TI on site is now direct delivery, has 1 voyage WLE for job 101 for 70
	self.assertEqualMsg(rebarOnsite3.directDelivery, true, "Rebar left on site is not Direct Delivery");
	count := null;
	correctQty1 := false;
	foreach wle in rebarOnsite3.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		count := count + 1;
		if wle.quantity = 70 then
			correctQty1 := true;
			self.assertEqualMsg(wle.locationTarget, hold0202Str, "Remaining Onsite TI is planned to the wrong location");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Remaining Onsite TI has the wrong number of voyage WLEs");
	self.assertEqualMsg(correctQty1, true, "Remaining Onsite TI has the wrong quantity");
	roadjob := vvr3.myRoadJob;
	self.assertEqualMsg(roadjob.workListEntries.size, 1, "Road job for truck 3 has the wrong number of WLEs");
	self.assertEqualMsg(roadjob.workListEntries.first.allDirectDeliveryChildWLEs.size, 1, "Yard WLE for the remaining onsite cargo has the wrong number of direct delivery child WLEs");
	
	// Move the cargo on truck 3 - should complete the road job, part complete the new job 101 and create a new onship cargo item
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(rebarOnsite3, targetLocation, null, 70, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is no onsite TI
	// 2. There is still 1 TI in hold 0201, quantity 130
	// 3. There is a new TI in hold 0202, quantity 70
	// 4. Road job for truck 3 is complete, with 1 completed road WLE for 70 and no direct delivery children
	// 5. Job 101 is part complete, with 1 completed voyage WLEs for 70
	// 6. TI in hold 0202 has 1 completed voyage WLE for 70 and 1 completed yard WLE for 70
	// 7. Prenote should still have quantity 800
	// 8. Unactioned WLE on job 101 should have quantity 800
	moveCheck := MoveCheck &amp; "3: ";
	// 1. There is no onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 0, moveCheck &amp; "There is still an onsite cargo item");
	// 2. There is still 1 TI in hold 0201, quantity 130
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0201");
	// 3. There is a new TI in hold 0202, quantity 70
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0202");
	// 4. Road job for truck 3 is complete, with 1 completed road WLE for 70 and no direct delivery children
	roadjob := vvr3.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for rebarOnsite3 has the wrong status - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job for rebarOnsite3 has the wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.quantity, 70, moveCheck &amp; "Yard WLE for road job 3 has the wrong quantity - " &amp; wle.quantity.String);
	self.assertEqualMsg(wle.allDirectDeliveryChildWLEs.size, null, moveCheck &amp; "Yard WLE for road job 3 still has direct delivery children");
	// 5. Job 101 is part complete, with 1 completed voyage WLEs for 70
	self.assertEqualMsg(job101.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 101 has the wrong status - " &amp; job101.statusString);
	count := null;
	correctQty1 := false;
	foreach wle in job101.workListEntries where wle.status = WLE_COMPLETED do
		count := count + 1;
		if wle.quantity = 70 then
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 101 has the wrong number of completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Completed WLE for job 101 has the wrong quantity");
	// 6. TI in hold 0202 has 1 completed voyage WLE for 70 and 1 completed yard WLE for 70
	rebarin0202 := hold0202.allTrackedItems.first;
	self.assertNotNullMsg(rebarin0202, moveCheck &amp; "There is no rebar in hold 0202");
	self.assertEqualMsg(rebarin0202.allWorklistEntries.size, 2, moveCheck &amp; "Rebar in 0202 has the wrong number of WLEs");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in rebarin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			correctQty1 := wle.quantity = 70;
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			correctQty2 := wle.quantity = 70;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Rebar in 0202 has the wrong number of Voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Rebar in 0202 has the wrong number of Yard WLEs");
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Voyage WLE for Rebar in 0202 has the wrong quantity");
	self.assertEqualMsg(correctQty2, true, moveCheck &amp; "Yard WLE for Rebar in 0202 has the wrong quantity");
	// 7. Prenote should still have quantity 800
	self.assertEqualMsg(rebarPrenote.totalQuantity, 800, moveCheck &amp; "Prenote has the wrong quantity");
	// 8. Unactioned WLE on job 101 should have quantity 800
	count := null;
	correctQty1 := false;
	foreach wle in job101.workListEntries where wle.status = WLE_UNACTIONED do
		count := count + 1;
		if wle.quantity = 800 then
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "There is the wrong number of unactioned WLEs on job 101");
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "The unactioned WLE on job 101 has the wrong quantity");
	
	// Road exit the current trucks 
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	self.roadExit(vvr3);
	
	// Gate in the remaining prenote quantity - 800
	self.opts.purge;
	self.opts.addAssoc("Quantity", 800);
	vvr4 := self.gateInPrenote(TruckId1, null, null, rebarPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr4.myRoadJob.myVehicle;
	rebarOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(rebarOnsite1, "Final Prenote brought onsite: No onsite Rebar cargo item for quantity 800");
	self.assertEqualMsg(rebarOnsite1.totalQuantity, 800, "Final Prenote brought onsite: Rebar onsite quantity is incorrect");
	foreach wle in rebarOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Final Prenote brought onsite: Truck1 Rebar onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Final Prenote brought onsite: Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	count := null;
	correctQty1 := false;
	foreach wle in rebarOnsite1.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		count := count + 1;
		if wle.quantity = 800 then
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Final Prenote brought onsite: Rebar Onsite has the wrong number of WLEs");
	self.assertEqualMsg(correctQty1, true, "Final Prenote brought onsite: Rebar onsite WLE has the wrong quantity");
	self.assertTrueMsg(voyage.allNotifiedTIsByIdCargoType.isEmpty, "Final Prenote brought onsite: There is still some prenoted cargo");
	
	// Move the entire onsite quantity to hold 0202
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(rebarOnsite1, targetLocation, null, 800, null);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are no onsite TIs
	// 2. There are 2 onship TIs - 1 for 130 in hold 0201, 1 for 870 in hold 0202
	// 3. Job 101 is Complete, with 2 completed voyage WLEs for 70 and 800
	// 4. Road job is complete, with 1 yard WLE for 800
	moveCheck := MoveCheck &amp; "4: ";
	// 1. There are no onsite TIs
	self.assertTrueMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, moveCheck &amp; "There is still at least 1 onsite TI");
	// 2. There are 2 onship TIs - 1 for 130 in hold 0201, 1 for 870 in hold 0202
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 2, moveCheck &amp; "There is the wrong number of onship TIs");
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in Hold 0201");
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in Hold 0202");
	rebarin0201 := hold0201.allTrackedItems.first;
	self.assertEqualMsg(rebarin0201.totalQuantity, 130, moveCheck &amp; "TI in hold 0201 has the wrong quantity");
	rebarin0202 := hold0202.allTrackedItems.first;
	self.assertEqualMsg(rebarin0202.totalQuantity, 870, moveCheck &amp; "TI in hold 0202 has the wrong quantity");
	// 3. Job 101 is Complete, with 2 completed voyage WLEs for 70 and 800
	
	////////////////////////
	// Finished - Tidy up //
	////////////////////////
	self.deleteWorkPoint(ThisWorkPoint);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteVehicle(TruckId1);
	self.deleteVehicle(TruckId2);
	self.deleteVehicle(TruckId3);
	
epilog
	delete allocatedWLEs;
	delete mobileAgent;
	delete jobParams;
	delete pxyJob100;
	delete pxyShift;
	delete allocatedTIs;
	self.setTerminalConfig(DirectTruck2VesselMult, directTruckMoves);
	app.myPassport.setMyTerminal(passportTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="tSalalahDirectToShipWgt1" id="41123ba5-3fd0-48fd-86b2-7ff78b61f4fe">
        <source>tSalalahDirectToShipWgt1();
//
// Purpose:			Test Salalah's Prenote Direct load from truck to multiple voyage locations for bulk by weight
//					Replicates using the Cargo Lander by using CMIF_MobileGenericAgent::moveCargo method
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/12/2021	navdap1		Initial creation TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
//
constants
	ThisVoyageCode : String = "DAVEH51935_3";
	ThisVesselCode : String = "DAVEHOLD";
	CLINKER : String = "CLINKER";
	ClinkerId : String = "CLINKDD51935_3_1";
	ThisWorkPoint : String = "WP51935_1";
	TruckId	: String = "UT51935_3_1";
	MoveCheck : String = "Move Check ";
	
vars
	terminal, passportTerminal : CM_Terminal;
	directTruckMoves : Boolean;
	operator : CM_Operator;
	clinkerCargoType : CM_CargoType;
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	clinkPrenote, clinkOnsite, 	clinkin0101, clinkin0102, clinkin0201, clinkin0202 : CM_TrackedItem;
	hold0101, hold0102, hold0201, hold0202 : CM_GeneralCargoController;
	hold0101Str, hold0102Str, hold0201Str, hold0202Str : String;
	voyageWle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	allocatedWLEs : CM_WLEArray;
	jobSheet : CM_VoyageHoldJobSheet;
	holdjob : CM_VoyageJob;
	count, count2 : Integer;
	qty, completeQty, unactionedQty : Decimal [14,4];
	loc : String;
	mobileAgent : CMIF_MobileGenericAgent;
	targetLocation : CM_LocationsController;
	yardWLE, unactionedYardWLE : CM_YardWLE;
	voyageWleFound, yardWleFound : Boolean;
	roadjob : CM_RoadJob;
	correctQty1, correctQty2 : Boolean;
	vvr : CM_VehicleVisitRecord;
	moveCheck : String;
	yardJob : CM_Job;
	job100, job101, job102, job103 : CM_VoyageHoldJob;

begin
	// Set the terminal config that drives all of this
	terminal := self.getTerminal;
	directTruckMoves := self.setTerminalConfig(DirectTruck2VesselMult, true).Boolean;
	//return;
	///////////////////////////////////////
	// Sanity Check and Pre-run Clean Up //
	///////////////////////////////////////
	clinkerCargoType := app.myRoot.getCargoTypeFromAbbrev(CLINKER);
	self.assertTrueMsg(clinkerCargoType &lt;&gt; null, CLINKER &amp; "does not exist as a Cargo Type");
	
	self.opts.purge;
	self.opts.addAssoc("includePrenote", true);
	self.deleteCargo(ClinkerId, clinkerCargoType);
	self.deleteVehicle(TruckId);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteWorkPoint(ThisWorkPoint);
	self.assertTrueMsg(self.getVoyage(ThisVoyageCode) = null, "Voyage " &amp; ThisVoyageCode &amp; " not deleted");
	
	////////////
	// Set Up //
	////////////
	// Create a Voyage with Holds
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage := self.addVoyageWithGeneralCargoStruc(ThisVoyageCode, ThisVesselCode, operator.code, "DOUG", 2);
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage not created");
	self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null and voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.size = 10, "General Cargo voyage not set up correctly");
	// and a workpoint
	workPoint := self.addWorkPoint(ThisWorkPoint, false);
	self.assertTrueMsg(workPoint &lt;&gt; null, "Work Point not created");
	
	hold0101 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,1];
	hold0102 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,2];
	hold0201 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,1];
	hold0202 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,2];
	hold0101Str := hold0101.getFullId;
	hold0102Str := hold0102.getFullId;
	hold0201Str := hold0201.getFullId;
	hold0202Str := hold0202.getFullId;
	
	// Create a prenote for the voyage splittable by quantity
	self.opts.purge;
	self.opts.addAssoc("CargoType", clinkerCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 25000);
	self.opts.addAssoc("DD", true);
	clinkPrenote := self.addPrenoted(ClinkerId);
	self.assertTrueMsg(clinkPrenote &lt;&gt; null, "Prenote not created");
	self.assertEqualMsg(clinkPrenote.weight, 25000.0000.Decimal, "Prenote quantity is incorrect");
	self.assertTrueMsg(clinkPrenote.directDelivery = true, "Prenote is not Direct Delivery");
	
	////////////////////////////////////////
	// Plan the prenote to multiple holds //
	////////////////////////////////////////
	// Load job 100 to 0101: 3MT
	create allocatedWLEs transient;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(3000.0000);
	allocatedWLEs.add(voyageWle);
	job100 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0101, workPoint);
	beginTransaction;
	job100.setOriginalJobAmount(3000);
	commitTransaction;
	
	// Load job 101 to 0102: 5MT
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(5000.0000);
	allocatedWLEs.add(voyageWle);
	job101 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0102, workPoint);
	beginTransaction;
	job101.setOriginalJobAmount(5000);
	commitTransaction;
	
	// Load job 102 to 0201: 7MT
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(7000.0000);
	allocatedWLEs.add(voyageWle);
	job102 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job102.setOriginalJobAmount(7000);
	commitTransaction;
	
	// Load job 103 to 0202: 10MT
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(10000.0000);
	allocatedWLEs.add(voyageWle);
	job103 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0202, workPoint);
	beginTransaction;
	job103.setOriginalJobAmount(10000);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 4 jobs in its jobsheet, each job should have 1 WLE, prenote should have 4 WLEs 
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 4, "Voyage Job sheet has the wrong number of jobs");
	foreach holdjob in jobSheet.allJobsByJobNum do
		self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	endforeach;
	self.assertEqualMsg(clinkPrenote.allWorklistEntries.size, 4, "Prenote has the wrong number of WLEs");
	// Check quantity / weight on each prenoted WLE
	// 3000 to 0101, 5000 to 0102, 7000 to 0201 and 10000 to 0202
	foreach wle in clinkPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 3000.0000;
			loc := ThisVoyageCode &amp; Space &amp; "0101 Under Deck";
		elseif count = 2 then
			qty := 5000.0000;
			loc := ThisVoyageCode &amp; Space &amp; "0102 On Deck";
		elseif count = 3 then
			qty := 7000.0000;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		elseif count = 4 then
			qty := 10000.0000;
			loc := ThisVoyageCode &amp; Space &amp; "0202 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.weight, qty, "Clinker WLE " &amp; count.String &amp; " has the wrong quantity");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Clinker WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	//////////////////////////
	// Gate some clinker in //
	//////////////////////////
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 5000.Decimal);
	vvr := self.gateInPrenote(TruckId, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	clinkOnsite := terminal.allOnsiteTIsByIdCargoType[ClinkerId, clinkerCargoType.id];
	self.assertNotNullMsg(clinkOnsite, "No onsite cargo item");
	self.assertEqualMsg(clinkOnsite.weight, 5000.0000.Decimal, "Onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite.allWorklistEntries.size, clinkPrenote.allWorklistEntries.size + 1, "Onsite and prenote have different WLE count");
	foreach wle in clinkOnsite.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, clinkPrenote.allWorklistEntries.size, "Yard WLE has an incorrect number of direct delivery WLEs");
	
	///////////////////////////////////
	// Move some of the onsite cargo //
	///////////////////////////////////
	// Move from the truck to various holds in chunks - some chunks to partially satisfy a hold job, 
	// some to completely fill a hold job and overlap into the next hold job
	// (replicating the use of the Cargo Lander Mobile app)
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 1000kg to hold 0101
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(clinkOnsite, targetLocation, null, null, 1000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. Onsite TI reduced from 5000 to 4000
	// 2. New onship TI in hold 0101 - weight 1000, with 2 WLEs (voyage and yard, both complete, both for weight 1000)
	// 3. Onsite rebar has 1 Yard WLE for 4000. The job for this WLE has two yard WLEs - 1 complete for 1000, one unactioned for 4000
	// 4. Prenote TI has planned WLE for hold 0101 weight reduced from 3000 to 2000
	// 5. Job for 0101 has one completed WLE for weight 1000, linked to onship TI
	moveCheck := MoveCheck &amp; "1: ";
	// 1. Onsite TI reduced from 5000 to 4000
	self.assertEqualMsg(clinkOnsite.weight, 4000.0000.Decimal, moveCheck &amp; "Clinker onsite quantity is wrong");
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, moveCheck &amp; "On ship cargo count is wrong");
	// 2. New onship TI in hold 0101 - weight 1000, with 2 WLEs (voyage and yard, both complete, both for weight 1000)
	clinkin0101 := voyage.allOnshipTIsByIdCargoType[clinkOnsite.id, clinkOnsite.cargoType];
	self.assertNotNullMsg(clinkin0101, moveCheck &amp; "No on ship clinker with id " &amp; clinkOnsite.id);
	self.assertEqualMsg(clinkin0101.weight, 1000.0000.Decimal, moveCheck &amp; "Clinker in 0101 has the wrong weight");
	self.assertEqualMsg(clinkin0101.allWorklistEntries.size, 2, moveCheck &amp; "Clinker in 0101 has the wrong number of WLEs");
	foreach wle in clinkin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.weight, 1000.0000.Decimal, moveCheck &amp; "Clinker in 0101 voyage WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0101 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.weight, 1000.0000.Decimal, moveCheck &amp; "Clinker in 0101 yard WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0101 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Clinker in 0101 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Clinker in 0101 has no yard WLE");
	// 3. Onsite clinker has 1 Yard WLE for 4000. The job for this WLE has two yard WLEs - 1 complete for 1000, one unactioned for 4000
	count := null;
	foreach wle in clinkOnsite.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		self.assertEqualMsg(wle.weight, 4000.0000.Decimal, moveCheck &amp; "Unactioned Yard WLE has wrong unactionedQty");
		roadjob := wle.job.CM_RoadJob;
		break;
	endforeach;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Onsite Road WLE not found");
	foreach wle in roadjob.workListEntries do
		count := count + 1;
		if wle.status = WLE_COMPLETED then
			self.assertEqualMsg(wle.weight, 1000.0000.Decimal, moveCheck &amp; "Completed Yard WLE has wrong unactionedQty");
		elseif wle.status = WLE_UNACTIONED then
			self.assertEqualMsg(wle.weight, 4000.0000.Decimal, moveCheck &amp; "Unactioned Yard WLE has wrong unactionedQty");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Road job for Clinker onsite has wrong number of Yard WLEs");
	// 4. Prenote TI has planned WLE for hold 0101 weight reduced from 3000 to 2000
	foreach wle in clinkPrenote.allWorklistEntries where wle.locationTarget = hold0101Str do
		self.assertEqualMsg(wle.weight, 2000.0000.Decimal, moveCheck &amp; "Clinker Prenote has wrong weight for hold 0101");
	endforeach;
	// 5. Job 100 for 0101 has one completed WLE for weight 1000, linked to onship TI
	count := null;
	foreach wle in job100.workListEntries where wle.isKindOf(CM_VoyageWLE) do
		// just count the ones related to the onsite and onship cargo
		if wle.myTrackedItem = clinkOnsite then
			count := count + 1;
			self.assertEqualMsg(wle.weight, 4000.0000.Decimal, moveCheck &amp; "WLE for onsite clinker in hold job " &amp; holdjob.id &amp; " has the wrong weight");
		elseif wle.myTrackedItem = clinkin0101 then
			count := count + 1;
			self.assertEqualMsg(wle.weight, 1000.0000.Decimal, moveCheck &amp; "WLE for onship clinker in hold job " &amp; holdjob.id &amp; " has the wrong weight");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Hold Job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	
	// Move the remaining 4000 from the truck to hold 0101 again - this will complete job 100 and part-complete job 101
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// second move - 4000 clinker to hold 0101. Will be split into 2000 for hold 0101 and 2000 for hold 0102
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(clinkOnsite, targetLocation, null, null, 4000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors");
	// Things to check:
	// 1. Onsite TI is no longer there
	// 2. There are 2 onship TIs - 1 in 0101 for 3000 with 2 voyage WLEs and 2 yard WLEs, new one in 0102 for 2000 with 1 voyage WLE and 1 yard WLE
	// 3. Road job has 3 completed yard WLEs - 1 for 1000, 2 for 2000
	// 4. Prenote now only has 3 WLEs - 0101 WLE has been deleted, 0102 WLE has been reduced to 3000
	// 5. Job 100 is complete and has 2 voyage WLEs for 1000 and 2000, both linked to onship TI in 0101
	// 6. Job 101 is part complete and has 1 completed voyage WLE for 2000, linked to onship TI in 0102
	moveCheck := MoveCheck &amp; "2: ";
	// 1. Onsite TI is no longer there
	self.assertTrueMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, moveCheck &amp; "There are " &amp; voyage.allOnsiteTIsByIdCargoType.size.String &amp; " onsite cargo items for the voyage");
	// 2. There are 2 onship TIs - 1 in 0101 for 3000 with 2 voyage WLEs and 2 yard WLEs, new one in 1020 for 2000 with 1 voyage WLE and 1 yard WLE
	self.assertTrueMsg(voyage.allOnshipTIsByIdCargoType.size = 2, moveCheck &amp; "There are " &amp; voyage.allOnshipTIsByIdCargoType.size.String &amp; " onship TIs");
	clinkin0101 := hold0101.allTrackedItems.first;
	self.assertTrueMsg(clinkin0101 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0101");
	self.assertTrueMsg(clinkin0101.weight = 3000.0000.Decimal, moveCheck &amp; "Clinker in 0101 quantity is " &amp; clinkin0101.quantity.String);
	self.assertTrueMsg(clinkin0101.allWorklistEntries.size = 4, moveCheck &amp; "Clinker in 0101 has " &amp; clinkin0101.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	foreach wle in clinkin0101.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		count := count + 1;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Clinker in 0101 has " &amp; count.String &amp; " Voyage WLEs");
	clinkin0102 := hold0102.allTrackedItems.first;
	self.assertTrueMsg(clinkin0102 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0102");
	self.assertTrueMsg(clinkin0102.weight = 2000.0000.Decimal, moveCheck &amp; "Clinker in 0102 quantity is " &amp; clinkin0102.quantity.String);
	self.assertTrueMsg(clinkin0102.allWorklistEntries.size = 2, moveCheck &amp; "Clinker in 0102 has " &amp; clinkin0102.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	yardWLE := null;
	foreach wle in clinkin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
		elseif wle.isKindOf(CM_YardWLE) then
			yardWLE := wle.CM_YardWLE;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Clinker in 0102 has " &amp; count.String &amp; " Voyage WLEs");
	// 3. Road job has 3 completed yard WLEs - 1 for 1000, 2 for 2000
	self.assertTrueMsg(yardWLE &lt;&gt; null, moveCheck &amp; "No Yard WLE found for onship TI " &amp; clinkin0102.id);
	self.assertTrueMsg(yardWLE.job &lt;&gt; null and yardWLE.job.workListEntries.size = 3 and yardWLE.job.status = JOB_COMPLETE, "Yard WLE has no job, or job has wrong number of WLEs");
	// 4. Prenote now only has 3 WLEs - 0101 WLE has been deleted, 0102 WLE has been reduced to 3000
	self.assertTrueMsg(clinkPrenote.allWorklistEntries.size = 3, moveCheck &amp; "Clinker prenote has wrong number of WLEs - " &amp; clinkPrenote.allWorklistEntries.size.String);
	foreach wle in clinkPrenote.allWorklistEntries do
		if wle.locationTarget = hold0101Str then
			self.assertTrueMsg(false, moveCheck &amp; "Clinker prenote still has a WLE for hold 0101");
		elseif wle.locationTarget = hold0102Str then
			self.assertTrueMsg(wle.weight = 3000.0000.Decimal, moveCheck &amp; "Clinker prenote WLE for hold 0102 has wrong weight - " &amp; wle.weight.String);
		endif;
	endforeach;
	// 5. Job 100 is complete and has 2 voyage WLEs for 1000 and 2000, both linked to onship TI in 0101
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	self.assertTrueMsg(job100.status = JOB_COMPLETE, moveCheck &amp; "Hold job for 0101 is not Complete but is " &amp; job100.status.String);
	foreach wle in job100.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.myTrackedItem = clinkin0101 then
			count := count + 1;
			if wle.weight = 1000.0000 then
				correctQty1 := true;
			elseif wle.weight = 2000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Hold job for 0101 has " &amp; count.String &amp; " voyage WLEs");
	self.assertTrueMsg(correctQty1 and correctQty2, moveCheck &amp; "Hold job for 0101 has incorrect WLE weights");
	// 6. Job 101 for 0102 is part complete and has 1 completed voyage WLE for 2000, linked to onship TI in 0102
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	self.assertTrueMsg(job101.status = JOB_PART_COMPLETE, moveCheck &amp; "Hold job for 0102 is not Part Complete but is " &amp; job101.status.String);
	foreach wle in job101.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.myTrackedItem = clinkin0102 then
			count := count + 1;
			if wle.weight = 2000.0000 then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Hold job for 0102 has " &amp; count.String &amp; " voyage WLEs");
	self.assertTrueMsg(correctQty1, moveCheck &amp; "Hold job for 0102 has incorrect WLE weight");
	
	// Road exit the truck - all cargo gone
	self.roadExit(vvr);
	
	// Gate in the rest of the prenote
	self.opts.purge;
	self.opts.addAssoc("Weight", 20000.Decimal);
	vvr := self.gateInPrenote(TruckId, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	clinkOnsite := terminal.allOnsiteTIsByIdCargoType[ClinkerId, clinkerCargoType.id];
	self.assertEqualMsg(clinkPrenote, clinkOnsite, moveCheck &amp; "Clinker prenote did not become the rebar on site");
	self.assertNotNullMsg(clinkOnsite, moveCheck &amp; "No onsite Rebar cargo item :2");
	self.assertEqualMsg(clinkOnsite.weight, 20000.0000.Decimal, moveCheck &amp; "Clinker onsite weight is incorrect :2");
	self.assertEqualMsg(clinkOnsite.allWorklistEntries.size, 4, moveCheck &amp; "Onsite rebar has wrong WLE count - should be 3 voyage and 1 yard WLE :2");
	foreach wle in clinkOnsite.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, moveCheck &amp; "Clinker onsite has no yard WLE :2");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 3/*one for each incomplete voyage job*/, moveCheck &amp; "Yard WLE has an incorrect number of direct delivery WLEs :2");
	
	/////////////////////////////////
	// Move the onsite cargo again //
	/////////////////////////////////
	// First, move 9000 to 0202
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	targetLocation := hold0202;
	moveCheck := MoveCheck &amp; "3: ";
	mobileAgent.doLanderLoad(clinkOnsite, targetLocation, null, null, 9000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, moveCheck &amp; "Errors: " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. Onsite TI reduced to 11000
	// 2. There are 3 onship TIs
	//		- 0101 3000 (2 WLEs 1000/2000)
	//		- 0102 2000 (1 WLE)
	//		- 0202 9000 (1 WLE)
	// 3. Road job has 1 completed WLE for 9000 and 1 unactioned WLE for 11000
	// 4. DD WLE for 0202 on the unactioned yard WLE has reduced to 1000
	// 5. Job 103 is part complete and has 1 completed voyage WLE for 9000, linked to onship TI in 0202
	// 1. Onsite TI reduced to 11000
	self.assertEqualMsg(clinkOnsite.weight, 11000.0000.Decimal, moveCheck &amp; "Clinker on site has the wrong weght - " &amp; clinkOnsite.weight.String);
	// 2. There are 3 onship TIs
	//		- 0101 3000 (2 WLEs 1000/2000)
	//		- 0102 2000 (1 WLE)
	//		- 0202 9000 (1 WLE)
	self.assertTrueMsg(voyage.allOnshipTIsByIdCargoType.size = 3, moveCheck &amp; "There are " &amp; voyage.allOnshipTIsByIdCargoType.size.String &amp; " onship TIs");
	clinkin0101 := hold0101.allTrackedItems.first;
	self.assertTrueMsg(clinkin0101 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0101");
	self.assertTrueMsg(clinkin0101.weight = 3000.0000.Decimal, moveCheck &amp; "Clinker in 0101 weight is " &amp; clinkin0101.weight.String);
	self.assertTrueMsg(clinkin0101.allWorklistEntries.size = 2, moveCheck &amp; "Clinker in 0101 has " &amp; clinkin0101.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	foreach wle in clinkin0101.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		count := count + 1;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Clinker in 0101 has " &amp; count.String &amp; " Voyage WLEs");
	clinkin0102 := hold0102.allTrackedItems.first;
	self.assertTrueMsg(clinkin0102 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0102");
	self.assertTrueMsg(clinkin0102.weight = 2000.0000.Decimal, moveCheck &amp; "Clinker in 0102 weight is " &amp; clinkin0102.weight.String);
	self.assertTrueMsg(clinkin0102.allWorklistEntries.size = 1, moveCheck &amp; "Clinker in 0102 has " &amp; clinkin0102.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	yardWLE := null;
	foreach wle in clinkin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Clinker in 0102 has " &amp; count.String &amp; " Voyage WLEs");
	clinkin0202 := hold0202.allTrackedItems.first;
	self.assertTrueMsg(clinkin0202 &lt;&gt; null, moveCheck &amp; "No cargo item in Hold 0202");
	self.assertTrueMsg(clinkin0202.weight = 9000.0000.Decimal, moveCheck &amp; "Clinker in 0202 weight is " &amp; clinkin0202.weight.String);
	self.assertTrueMsg(clinkin0202.allWorklistEntries.size = 2, moveCheck &amp; "Clinker in 0202 has " &amp; clinkin0202.allWorklistEntries.size.String &amp; " WLEs");
	count := null;
	foreach wle in clinkin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Clinker in 0202 has " &amp; count.String &amp; " Voyage WLEs");
	// 3. Road job has 1 completed WLE for 9000 and 1 unactioned WLE for 11000
	foreach wle in clinkOnsite.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, moveCheck &amp; "Yard WLE is null");
	yardJob := yardWLE.job;
	self.assertEqualMsg(yardJob.workListEntries.size, 2, moveCheck &amp; "Yard job has the wrong number of WLEs - " &amp; yardJob.workListEntries.size.String);
	count := null;
	count2 := null;
	unactionedYardWLE := null;
	foreach wle in yardJob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			self.assertEqualMsg(wle.weight, 9000.0000.Decimal, moveCheck &amp; "Conpleted Yard WLE weight is " &amp; wle.weight.String);
		elseif wle.status = WLE_UNACTIONED then
			unactionedYardWLE := wle.CM_YardWLE;
			count2 := count2 + 1;
			self.assertEqualMsg(wle.weight, 11000.0000.Decimal, moveCheck &amp; "Unactioned Yard WLE weight is " &amp; wle.weight.String);
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Yard job has wrong number of Complete WLEs - " &amp; count.String);
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Yard job has wrong number of Unactioned WLEs - " &amp; count2.String);
	// 4. DD WLE for 0202 on the unactioned yard WLE has reduced to 1000
	self.assertNotNullMsg(unactionedYardWLE, moveCheck &amp; "Unactioned Yard WLE");
	foreach wle in unactionedYardWLE.allDirectDeliveryChildWLEs do
		if wle.locationTarget = hold0202Str then
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 1000, moveCheck &amp; "Voyage WLE for 0202 on the unactioned yard WLE has wrong subSeqNum - " &amp; wle.CM_VoyageWLE.subSeqNum.String);
		endif;
	endforeach;
	// 5. Job 103 is part complete and has 1 completed voyage WLE for 9000, linked to onship TI in 0202
	holdjob := jobSheet.allJobsByJobNum["103"];
	self.assertEqualMsg(holdjob.status, JOB_PART_COMPLETE, moveCheck &amp; "Hold job for 0202 status is " &amp; holdjob.statusString);
	count := null;
	correctQty1 := null;
	foreach wle in holdjob.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.status = WLE_COMPLETED and not wle.myTrackedItem.hasBeenMerged then
			count := count + 1;
			if wle.weight = 9000.0000 then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "There are " &amp; count.String &amp; " Complete WLEs in hold job for 0202");
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Completed WLE for hold job 0202 is for the wrong weight");
	
	// Try to really mess with things - move 6000  to 0202
	// This should 	- complete 0202 (10000 - 2 WLEs 9000+1000)
	//				- complete 0102 (5000 - 2 WLEs 2000+3000)
	//				- part complete 0201 (2000 - 5000 still to go)
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(clinkOnsite, targetLocation, null, null, 6000);
	moveCheck := MoveCheck &amp; "4: ";
	self.assertNullMsg(app.myPassport.getErrorsAsString, moveCheck &amp; "Start: " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. Onsite TI reduced to 5000
	// 2. There are 4 onship TIs
	//		- 0101 3000 (2 WLEs, 1000/2000)
	// 		- 0102 5000 (2 WLEs, 2000/3000)
	//		- 0201 2000 (1 WlE, 2000)
	//		- 0202 10000 (2 WLEs, 9000/1000)
	// 3. Road job has 4 completed WLEs (9000 - original move, 1000-3000-2000 from this move) and 1 unactioned WLE for 5000)
	// 4. DD WLE for 0201 on the unactioned yard WLE has been reduced to 5000
	// 5. Job 101 is complete and has 2 completed voyage WLEs for 2000+3000, linked to onship TI in 0102
	// 6. Job 102 is part complete, with 1 completed voyage WLE for 2000, linked to onship TI in 0201
	// 7. Job 103 is complete, with 2 completed voyage WLEs for 9000+1000, linked to onship TI in 0202
	// 1. Onsite TI reduced to 5000
	self.assertEqualMsg(clinkOnsite.weight, 5000.0000.Decimal, moveCheck &amp; "Clinker on site has the wrong weight - " &amp; clinkOnsite.weight.String);
	// 2. There are 4 onship TIs
	//		- 0101 3000 (2 WLEs, 1000/2000)
	// 		- 0102 5000(2 WLEs, 2000/3000)
	//		- 0201 2000 (1 WlE, 2000)
	//		- 0202 10000 (2 WLEs, 9000/1000)
	//self.assertTrueMsg(voyage.allOnshipTIsByIdCargoType.size = 4, moveCheck &amp; "Voyage has the wrong number of on-ship cargo items - " &amp; voyage.allOnshipTIsByIdCargoType.size.String);
	self.assertTrueMsg(hold0101.allTrackedItems.size = 1, moveCheck &amp; "Hold 0101 has the wrong number of cargo items - " &amp; hold0101.allTrackedItems.size.String);
	self.assertTrueMsg(hold0102.allTrackedItems.size = 1, moveCheck &amp; "Hold 0102 has the wrong number of cargo items - " &amp; hold0102.allTrackedItems.size.String);
	self.assertTrueMsg(hold0201.allTrackedItems.size = 1, moveCheck &amp; "Hold 0201 has the wrong number of cargo items - " &amp; hold0201.allTrackedItems.size.String);
	self.assertTrueMsg(hold0202.allTrackedItems.size = 1, moveCheck &amp; "Hold 0202 has the wrong number of cargo items - " &amp; hold0202.allTrackedItems.size.String);
	clinkin0101 := hold0101.allTrackedItems.first;
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	foreach wle in clinkin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.weight = 1000.0000 then
				correctQty1 := true;
			elseif wle.weight = 2000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Clinker in hold 0101 has the wrong number of WLEs - " &amp; count.String);
	self.assertTrueMsg(correctQty1 and correctQty2, moveCheck &amp; "Clinker in hold 0101 WLEs have wrong weight - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	clinkin0102 := hold0102.allTrackedItems.first;
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	foreach wle in clinkin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.weight = 2000.0000 then
				correctQty1 := true;
			elseif wle.weight = 3000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Clinker in hold 0102 has the wrong number of WLEs - " &amp; count.String);
	self.assertTrueMsg(correctQty1 and correctQty2, moveCheck &amp; "Clinker in hold 0102 WLEs have wrong weight - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	clinkin0201 := hold0201.allTrackedItems.first;
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	foreach wle in clinkin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.weight = 2000.0000 then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 1, moveCheck &amp; "Clinker in hold 0201 has the wrong number of WLEs - " &amp; count.String);
	self.assertTrueMsg(correctQty1, moveCheck &amp; "Clinker in hold 0201 WLE has wrong weight - " &amp; correctQty1.asStringJMT);
	clinkin0202 := hold0202.allTrackedItems.first;
	correctQty1 := false;
	correctQty2 := false;
	count := null;
	foreach wle in clinkin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.weight = 9000.0000 then
				correctQty1 := true;
			elseif wle.weight = 1000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertTrueMsg(count = 2, moveCheck &amp; "Clinker in hold 0202 has the wrong number of WLEs - " &amp; count.String);
	self.assertTrueMsg(correctQty1 and correctQty2, moveCheck &amp; "Clinker in hold 0202 WLEs have wrong weight - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 3. Road job has 4 completed WLEs (9000 - original move, 1000-3000-2000 from this move) and 1 unactioned WLE for 5000
	count := null;
	count2 := null;
	unactionedYardWLE := null;
	completeQty := null;
	unactionedQty := null;
	roadjob := vvr.myRoadJob;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			completeQty := completeQty + wle.weight;
		elseif wle.status = WLE_UNACTIONED then
			count2 := count2 + 1;
			unactionedQty := unactionedQty + wle.weight;
			//unactionedYardWLE := wle.CM_YardWLE;
		endif;
		if wle.allDirectDeliveryChildWLEs.size &gt; 1 and wle.isKindOf(CM_YardWLE) then
			unactionedYardWLE := wle.CM_YardWLE;
		endif;
	endforeach;
	self.assertEqualMsg(count, 4, moveCheck &amp; "Yard job has wrong number of Complete WLEs - " &amp; count.String);
	self.assertEqualMsg(completeQty, 15000.0000.Decimal, moveCheck &amp; "Completed Yard job WLEs have incorrect total weight - " &amp; completeQty.String);
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Yard job has wrong number of Unactioned WLEs - " &amp; count2.String);
	self.assertEqualMsg(unactionedQty, 5000.0000.Decimal, moveCheck &amp; "Unactioned Yard job WLE has incorrect weight - " &amp; unactionedQty.String);
	// 4. DD WLE for 0201 on the unactioned yard WLE has been reduced to 5000
	count := null;
	foreach wle in unactionedYardWLE.allDirectDeliveryChildWLEs do
		if wle.status = WLE_UNACTIONED and wle.CM_VoyageWLE.subSeqNum &lt;&gt; null then
			count := count + 1;
		endif;
		if wle.locationTarget = hold0201Str then
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 5000, moveCheck &amp; "DD WLE for 0201 has wrong weight left - " &amp; wle.CM_VoyageWLE.subSeqNum.String);
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Unactioned Yard WLE has wrong number of direct delivery children!");
	// 5. Job 101 is complete and has 2 completed voyage WLEs for 2000+3000, linked to onship TI in 0102
	self.assertEqualMsg(job101.status, JOB_COMPLETE, moveCheck &amp; "Hold job for 0102 is not complete - " &amp; job101.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	clinkin0102 := hold0102.allTrackedItems.first;
	foreach wle in job101.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and not wle.myTrackedItem.hasBeenMerged then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
				self.assertEqualMsg(wle.myTrackedItem, clinkin0102, moveCheck &amp; "TI on Hold Job 0102 WLE is NOT the TI in Hold 0102");
			endif;
			if wle.weight = 2000.0000 then
				correctQty1 := true;
			elseif wle.weight = 3000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Hold Job 0102 has the wrong number of completed voyage WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Hold Job 0102 voyage WLEs have the wrong weights");
	// 6. Job 102 is part complete, with 1 completed voyage WLE for 2000, linked to onship TI in 0201
	self.assertEqualMsg(job102.status, JOB_PART_COMPLETE, moveCheck &amp; "Hold job for 0201 is not complete - " &amp; job102.statusString);
	count := null;
	correctQty1 := false;
	clinkin0201 := hold0201.allTrackedItems.first;
	foreach wle in job102.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and not wle.myTrackedItem.hasBeenMerged then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
				self.assertEqualMsg(wle.myTrackedItem, clinkin0201, moveCheck &amp; "TI on Hold Job 0201 WLE is NOT the TI in Hold 0201");
			endif;
			if wle.weight = 2000.0000 then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Hold Job 0201 has the wrong number of completed voyage WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Hold Job 0201 voyage WLE ha2 the wrong weight");
	// 7. Job 103 is complete, with 2 completed voyage WLEs for 9000+1000, linked to onship TI in 0202
	self.assertEqualMsg(job103.status, JOB_COMPLETE, moveCheck &amp; "Hold job for 0202 is not complete - " &amp; job103.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	clinkin0202 := hold0202.allTrackedItems.first;
	foreach wle in job103.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and not wle.myTrackedItem.hasBeenMerged then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
				self.assertEqualMsg(wle.myTrackedItem, clinkin0202, moveCheck &amp; "TI on Hold Job 0202 WLE is NOT the TI in Hold 0202");
			endif;
			if wle.weight = 9000.0000 then
				correctQty1 := true;
			elseif wle.weight = 1000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Hold Job 0202 has the wrong number of completed voyage WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Hold Job 0202 voyage WLEs have the wrong quantities");
	
	// Move the final 5000 to 0201. This should complete the yard job, and all hold jobs
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(clinkOnsite, targetLocation, null, null, 5000);
	moveCheck := MoveCheck &amp; "5: ";
	self.assertNullMsg(app.myPassport.getErrorsAsString, moveCheck &amp; "Start: " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. No Onsite TI
	// 2. There are 4 onship TIs
	//		- 0101 3000 (2 WLEs, 1000/2000)
	// 		- 0102 5000 (2 WLEs, 2000/3000)
	//		- 0201 7000 (2 WLEs, 2000/5000)
	//		- 0202 10000 (2 WLEs, 9000/1000)
	// 3. Road job is complete and has 5 completed WLEs and no unactioned WLEs 
	// 4. Job 3 is complete 
	// 5. All voyage jobs are complete
	// 1. No Onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, true, moveCheck &amp; "There is still an on site caargo item!");
	// 2. There are 4 onship TIs
	//		- 0101 3000 (2 WLEs, 10/20)
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 4, moveCheck &amp; "There are " &amp; voyage.allOnshipTIsByIdCargoType.size.String &amp; " on Ship cargo items!!");
	clinkin0101 := hold0101.allTrackedItems.first;
	self.assertNotEqualMsg(clinkin0101, null, moveCheck &amp; "There is no cargo item in Hold 0101");
	self.assertEqualMsg(clinkin0101.weight, 3000.0000.Decimal, moveCheck &amp; "Cargo item in 0101 has the wrong weight - " &amp; clinkin0101.weight.String);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in clinkin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Hold 0101 Cargo Item is not Completed");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, null, moveCheck &amp; "WLE for Hold 0101 Cargo Item has a non-null subSeqNum " &amp; wle.myTrackedItem.hasBeenMerged.asStringJMT);
			count := count + 1;
			if wle.weight = 1000.0000 then
				correctQty1 := true;
			elseif wle.weight = 2000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Cargo item in 0101 has the wrong number of Completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Cargo item in 0101 has incorrect WLE weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 		- 0102 5000 (2 WLEs, 2000/3000)
	clinkin0102 := hold0102.allTrackedItems.first;
	self.assertNotEqualMsg(clinkin0102, null, moveCheck &amp; "There is no cargo item in Hold 0102");
	self.assertEqualMsg(clinkin0102.weight, 5000.0000.Decimal, moveCheck &amp; "Cargo item in 0102 has the wrong weight - " &amp; clinkin0102.weight.String);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in clinkin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Hold 0102 Cargo Item is not Completed");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, null, moveCheck &amp; "WLE for Hold 0102 Cargo Item has a non-null subSeqNum " &amp; wle.myTrackedItem.hasBeenMerged.asStringJMT);
			count := count + 1;
			if wle.weight = 2000.0000 then
				correctQty1 := true;
			elseif wle.weight = 3000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Cargo item in 0102 has the wrong number of Completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Cargo item in 0102 has incorrect WLE weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	//		- 0201 7000 (2 WLEs, 2000/5000)
	clinkin0201 := hold0201.allTrackedItems.first;
	self.assertNotEqualMsg(clinkin0201, null, moveCheck &amp; "There is no cargo item in Hold 0201");
	self.assertEqualMsg(clinkin0201.weight, 7000.0000.Decimal, moveCheck &amp; "Cargo item in 0201 has the wrong weight - " &amp; clinkin0201.totalQuantity.String);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in clinkin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Hold 0201 Cargo Item is not Completed");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, null, moveCheck &amp; "WLE for Hold 0201 Cargo Item has a non-null subSeqNum " &amp; wle.myTrackedItem.hasBeenMerged.asStringJMT);
			count := count + 1;
			if wle.weight = 2000.0000 then
				correctQty1 := true;
			elseif wle.weight = 5000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Cargo item in 0201 has the wrong number of Completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Cargo item in 0201 has incorrect WLE weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	//		- 0202 10000 (2 WLEs, 9000/1000)
	clinkin0202 := hold0202.allTrackedItems.first;
	self.assertNotEqualMsg(clinkin0202, null, moveCheck &amp; "There is no cargo item in Hold 0202");
	self.assertEqualMsg(clinkin0202.weight, 10000.0000.Decimal, moveCheck &amp; "Cargo item in 0202 has the wrong weight - " &amp; clinkin0202.weight.String);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in clinkin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Hold 0202 Cargo Item is not Completed");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, null, moveCheck &amp; "WLE for Hold 0202 Cargo Item has a non-null subSeqNum " &amp; wle.myTrackedItem.hasBeenMerged.asStringJMT);
			count := count + 1;
			if wle.weight = 9000.0000 then
				correctQty1 := true;
			elseif wle.weight = 1000.0000 then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Cargo item in 0202 has the wrong number of Completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Cargo item in 0202 has incorrect WLE weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 3. Road job is complete and has 5 completed WLEs and no unactioned WLEs 
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Yard job status is " &amp; roadjob.statusString);
	count := null;
	count2 := null;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
		else
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 5, moveCheck &amp; "Road job has the wrong number of completed WLEs - " &amp; count.String);
	self.assertEqualMsg(count2, 0, moveCheck &amp; "Road job has some incomplete WLEs - " &amp; count.String);
	// 4. Job 102 is complete 
	self.assertNotNullMsg(job102, moveCheck &amp; "Can't find hold job for 0201");
	self.assertEqualMsg(job102.status, JOB_COMPLETE, "Hold Job for 0201 is is not Complete - " &amp; job102.statusString);
	// 5. All voyage jobs are complete
	foreach holdjob in jobSheet.allJobsByJobNum do
		self.assertEqualMsg(holdjob.status, JOB_COMPLETE, moveCheck &amp; "Hold Job " &amp; holdjob.id &amp; " is not Complete - " &amp; holdjob.statusString);
	endforeach;
	
	// Road exit the truck - all cargo gone
	self.roadExit(vvr);
	self.assertEqualMsg(app.myPassport.getErrorsAndWarningsAsString, null, app.myPassport.getErrorsAndWarningsAsString);
	
	////////////////////////
	// Finished - Tidy up //
	////////////////////////
	self.deleteWorkPoint(ThisWorkPoint);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteVehicle(TruckId);
	
epilog
	delete allocatedWLEs;
	delete mobileAgent;
	self.setTerminalConfig(DirectTruck2VesselMult, directTruckMoves);
	app.myPassport.setMyTerminal(passportTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="tSalalahDirectToShipWgt2" id="bd8d7fa5-c7b5-4652-ae96-74bf9dedd150">
        <source>tSalalahDirectToShipWgt2();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/12/2021	navdap1		Initial creation TFS 52360
//
constants
	ThisVoyageCode : String = "DAVEH51935_4";
	ThisVesselCode : String = "DAVEHOLD";
	CLINKER : String = "CLINKER";
	ClinkerId1 : String = "CLINKERDD51935_4_1";
	ClinkerId2 : String = "CLINKERDD51935_4_2";
	ClinkerId3 : String = "CLINKERDD51935_4_3";
	ClinkerId4 : String = "CLINKERDD51935_4_4";
	ThisWorkPoint : String = "WP51935_4";
	TruckId1 : String = "UT51935_4_1";
	TruckId2 : String = "UT51935_4_2";
	TruckId3 : String = "UT51935_4_3";
	MoveCheck : String = "Move Check ";

vars
	terminal, passportTerminal : CM_Terminal;
	directTruckMoves : Boolean;
	operator : CM_Operator;
	clinkCargoType : CM_CargoType;
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	clinkPrenote, clinkOnsite1, clinkOnsite2, clinkOnsite3, clinkin0101, clinkin0102, clinkin0201, clinkin0202, ti : CM_TrackedItem;
	hold0101, hold0102, hold0201, hold0202 : CM_GeneralCargoController;
	hold0101Str, hold0102Str, hold0201Str, hold0202Str : String;
	voyageWle : CM_VoyageWLE;
	wle, ddWle : CM_WorkListEntry;
	allocatedWLEs : CM_WLEArray;
	jobSheet : CM_VoyageHoldJobSheet;
	holdjob : CM_VoyageJob;
	count, count2 : Integer;
	qty, completeQty, unactionedQty, vQty, yQty, total : Decimal [14,4];
	loc : String;
	mobileAgent : CMIF_MobileGenericAgent;
	targetLocation : CM_LocationsController;
	yardWLE, unactionedYardWLE : CM_YardWLE;
	voyageWleFound, yardWleFound : Boolean;
	roadjob : CM_RoadJob;
	correctQty1, correctQty2 : Boolean;
	vvr1, vvr2, vvr3 : CM_VehicleVisitRecord;
	moveCheck : String;
	yardJob : CM_Job;
	job100, job101, job102, job103, job104, job105, job106, job107 : CM_VoyageHoldJob;
	truck1, truck2, truck3 : CM_Vehicle;

begin
	// Set the terminal config that drives all of this
	terminal := self.getTerminal;
	directTruckMoves := self.setTerminalConfig(DirectTruck2VesselMult, true).Boolean;
	//return;
	///////////////////////////////////////
	// Sanity Check and Pre-run Clean Up //
	///////////////////////////////////////
	clinkCargoType := app.myRoot.getCargoTypeFromAbbrev(CLINKER);
	self.assertTrueMsg(clinkCargoType &lt;&gt; null, CLINKER &amp; "does not exist as a Cargo Type");
	
	self.opts.purge;
	self.opts.addAssoc("includePrenote", true);
	self.deleteCargo(ClinkerId1, clinkCargoType);
	self.deleteVehicle(TruckId1);
	self.deleteVehicle(TruckId2);
	self.deleteVehicle(TruckId3);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteWorkPoint(ThisWorkPoint);
	self.assertTrueMsg(self.getVoyage(ThisVoyageCode) = null, "Voyage " &amp; ThisVoyageCode &amp; " not deleted");
	
	////////////
	// Set Up //
	////////////
	// Create a Voyage with Holds
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage := self.addVoyageWithGeneralCargoStruc(ThisVoyageCode, ThisVesselCode, operator.code, "DOUG", 2);
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage not created");
	self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null and voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.size = 10, "General Cargo voyage not set up correctly");
	// and a workpoint
	workPoint := self.addWorkPoint(ThisWorkPoint, false);
	self.assertTrueMsg(workPoint &lt;&gt; null, "Work Point not created");
	
	hold0101 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,1];
	hold0102 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,2];
	hold0201 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,1];
	hold0202 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,2];
	hold0101Str := hold0101.getFullId;
	hold0102Str := hold0102.getFullId;
	hold0201Str := hold0201.getFullId;
	hold0202Str := hold0202.getFullId;
	
	///////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// TEST 1: Total weight planned to one hold, brought in on 2 trucks, trucks loaded individually to the job //
	///////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Create a prenote for the voyage splittable by weight
	self.opts.purge;
	self.opts.addAssoc("CargoType", clinkCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 10000);
	self.opts.addAssoc("CargoWeight", 10000);
	self.opts.addAssoc("TareWeight", 0);
	self.opts.addAssoc("DD", true);
	clinkPrenote := self.addPrenoted(ClinkerId1);
	self.assertTrueMsg(clinkPrenote &lt;&gt; null, "Clinker prenote not created");
	self.assertEqualMsg(clinkPrenote.weight, 10000.0000.Decimal, "Clinker prenote weight is incorrect");
	self.assertTrueMsg(clinkPrenote.directDelivery = true, "Clinker prenote is not Direct Delivery");
	
	// Plan the prenote to a hold
	// Load job 100 to 0101: all 10000
	create allocatedWLEs transient;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(10000.0000);
	allocatedWLEs.add(voyageWle);
	job100 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0101, workPoint);
	beginTransaction;
	job100.setOriginalJobAmount(10000);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 1 job in its jobsheet, the job should have 1 WLE, prenote should have 1 WLE
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 1, "Voyage Job sheet has the wrong number of jobs");
	foreach holdjob in jobSheet.allJobsByJobNum do
		self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	endforeach;
	self.assertEqualMsg(clinkPrenote.allWorklistEntries.size, 1, "Clinker prenote has the wrong number of WLEs");
	// Check weight on the prenoted WLE
	// Clinker: 10000 to 0101
	foreach wle in clinkPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 10000.0000;
			loc := ThisVoyageCode &amp; Space &amp; "0101 Under Deck";
		endif;
		self.assertEqualMsg(voyageWle.weight, qty, "Clinker WLE " &amp; count.String &amp; " has the wrong weight");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Clinker WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the clinker in on 2 trucks
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 5000.Decimal);
	self.opts.addAssoc("CargoWeight", 5000.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr1 := self.gateInPrenote(TruckId1, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	clinkOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkOnsite1, "No onsite Clinker cargo item");
	self.assertEqualMsg(clinkOnsite1.weight, 5000.0000.Decimal, "Clinker onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite1.allWorklistEntries.size, clinkPrenote.allWorklistEntries.size + 1, "Truck1 Onsite and prenoted clinker has different WLE count");
	foreach wle in clinkOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, clinkPrenote.allWorklistEntries.size, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Second truck
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 5000.Decimal);
	vvr2 := self.gateInPrenote(TruckId2, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	clinkOnsite2 := truck2.locationsController.allTrackedItems.first;
	// prenoted item is now the onsite item
	self.assertEqualMsg(clinkOnsite2, clinkPrenote, "Truck2 Clinker on site is not the prenote TI");
	self.assertNotNullMsg(clinkOnsite2, "Truck2 No onsite Clinker cargo item");
	self.assertEqualMsg(clinkOnsite2.weight, 5000.0000.Decimal, "Truck2 Clinker onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite2.allWorklistEntries.size, clinkPrenote.allWorklistEntries.size, "Truck2 Onsite and prenoted clinker has different WLE count");
	foreach wle in clinkOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	
	// Move some of the onsite cargo
	// Move from the trucks to the hold (replicating the use of the Cargo Lander Mobile app)
	// Truck 1 first - all 5000
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 50 clinker to hold 0101
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(clinkOnsite1, targetLocation, null, null, 5000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is one TI onsite 
	// 2. Onship TI in hold 0101 - weight 5000, with 2 WLEs (voyage and yard, both complete, both for 5000)
	// 3. Road job has 1 WLE and is complete
	// 4. Job 100 is part complete, with 1 voyage WLE for 5000, linked to onship TI in hold 0101
	moveCheck := MoveCheck &amp; "1: ";
	// 1. There is one TI onsite 
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite TIs");
	// 2. Onship TI in hold 0101 - weight 5000, with 2 WLEs (voyage and yard, both complete, both for 5000)
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onship TIs");
	clinkin0101 := voyage.allOnshipTIsByIdCargoType[clinkOnsite1.id, clinkOnsite1.cargoType];
	self.assertNotNullMsg(clinkin0101, moveCheck &amp; "No on ship clinker with id " &amp; clinkOnsite1.id);
	self.assertEqualMsg(clinkin0101.weight, 5000.0000.Decimal, moveCheck &amp; "Clinker in 0101 has the wrong weight");
	self.assertEqualMsg(clinkin0101.allWorklistEntries.size, 2, moveCheck &amp; "Clinker in 0101 has the wrong number of WLEs");
	foreach wle in clinkin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.weight, 5000.0000.Decimal, moveCheck &amp; "Clinker in 0101 voyage WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0101 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.weight, 5000.0000.Decimal, moveCheck &amp; "Clinker in 0101 yard WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0101 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Clinker in 0101 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Clinker in 0101 has no yard WLE");
	// 3. Road job for truck 1 has 1 WLE and is complete
	roadjob := vvr1.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId1 &amp; " is null");
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for " &amp; TruckId1 &amp; "'s road job is not complete");
	// 4. Job 100 is part complete, with 1 voyage WLE for 5000, linked to onship TI in hold 0101
	self.assertEqualMsg(job100.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 100 for hold 0101 is " &amp; job100.statusString);
	count := null;
	voyageWle := null;
	foreach wle in job100.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.status = WLE_COMPLETED then
				count2 := count2 + 1;
				voyageWle := wle.CM_VoyageWLE;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 100 has wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Job 100 has wrong number of Completed voyage WLEs");
	self.assertNotNullMsg(voyageWle, moveCheck &amp; "No voyage WLE found for job 100");
	self.assertEqualMsg(voyageWle.status, WLE_COMPLETED, moveCheck &amp; "WLE for job 100 has wrong status");
	self.assertEqualMsg(voyageWle.weight, 5000.0000.Decimal, moveCheck &amp; "WLE for job 100 has wrong weight");
	self.assertEqualMsg(voyageWle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 100 has wrong subSeqNum");
	self.assertEqualMsg(voyageWle.myTrackedItem, clinkin0101, moveCheck &amp; "WLE for job 100 has the wrong TI");
	
	// second move - remaining 5000 to hold 0101
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(clinkOnsite2, targetLocation, null, null, 5000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is no TI onsite 
	// 2. There is 1 Onship TI in hold 0101 - weight 10000, with 4 WLEs (2 voyage and 2 yard, all complete, all for 5000)
	// 3. Road job for truck 2 has 1 WLE and is complete
	// 4. Job 100 is complete, with 2 voyage WLEs each for 5000, both linked to onship TI in hold 0101
	moveCheck := MoveCheck &amp; "2: ";
	// 1. There is no TI onsite 
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 0, moveCheck &amp; "Wrong number of onsite TIs");
	// 2. There is 1 Onship TI in hold 0101 - weight 10000, with 4 WLEs (2 voyage and 2 yard, all complete, all for weight 10000)
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onship TIs");
	clinkin0101 := voyage.allOnshipTIsByIdCargoType[clinkOnsite1.id, clinkOnsite1.cargoType];
	self.assertNotNullMsg(clinkin0101, moveCheck &amp; "No on ship clinker with id " &amp; clinkOnsite1.id);
	self.assertEqualMsg(clinkin0101.weight, 10000.0000.Decimal, moveCheck &amp; "Clinker in 0101 has the wrong weight");
	self.assertEqualMsg(clinkin0101.allWorklistEntries.size, 4, moveCheck &amp; "Clinker in 0101 has the wrong number of WLEs");
	count := null;
	count2 := null;
	foreach wle in clinkin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.weight, 5000.0000.Decimal, moveCheck &amp; "Clinker in 0101 voyage WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0101 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.weight, 5000.000.Decimal, moveCheck &amp; "Clinker in 0101 yard WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0101 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Clinker in 0101 has wrong voyage WLE count");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "Clinker in 0101 has wring yard WLE count");
	// 3. Road job for truck 2 has 1 WLE and is complete
	roadjob := vvr2.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId2 &amp; " is null");
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for " &amp; TruckId2 &amp; "'s road job is not complete");
	// 4. Job 100 is complete, with 2 voyage WLEs each for 5000, both linked to onship TI in hold 0101
	self.assertEqualMsg(job100.status, JOB_COMPLETE, moveCheck &amp; "Job 100 for hold 0101 is " &amp; job100.statusString);
	self.assertEqualMsg(job100.workListEntries.size, 2, moveCheck &amp; "Job 100 has wrong number of WLEs");
	count := null;
	foreach wle in job100.workListEntries do
		count := count + 1;
		self.assertEqualMsg(wle.status, WLE_COMPLETED, "WLE for job 100 has wrong status :" &amp; count.String);
		self.assertEqualMsg(wle.weight, 5000.0000.Decimal, "WLE for job 100 has wrong weight :" &amp; count.String);
		self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, "WLE for job 100 has wrong subSeqNum :" &amp; count.String);
		self.assertEqualMsg(wle.myTrackedItem, clinkin0101, "WLE for job 100 has the wrong TI :" &amp; count.String);
	endforeach;
	
	// Road exit the trucks - all cargo gone
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	
	////////////////////////////////////////////////////////////////////////////////////////////////
	// TEST 2: Total weight planned to two holds, different amounts brought in on 2 trucks,       //
	// first truck completes part of a job, second truck completes that job and the remaining one //
	////////////////////////////////////////////////////////////////////////////////////////////////
	// Create another prenote for the voyage 
	clinkPrenote := null;
	clinkOnsite1 := null;
	clinkOnsite2 := null;
	self.opts.purge;
	self.opts.addAssoc("CargoType", clinkCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 10000);
	self.opts.addAssoc("CargoWeight", 10000);
	self.opts.addAssoc("TareWeight", 0);
	self.opts.addAssoc("DD", true);
	clinkPrenote := self.addPrenoted(ClinkerId2);
	self.assertTrueMsg(clinkPrenote &lt;&gt; null, "Clinker prenote not created");
	self.assertEqualMsg(clinkPrenote.weight, 10000.0000.Decimal, "Clinker prenote weight is incorrect");
	self.assertTrueMsg(clinkPrenote.directDelivery = true, "Clinker prenote is not Direct Delivery");
	
	// Plan the prenote to two holds
	// Load job 101 to 0201: 5000
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(5000.0000);
	allocatedWLEs.add(voyageWle);
	job101 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job101.setOriginalJobAmount(5000);
	commitTransaction;
	// Load job 102 to 0202: 5000
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(5000.0000);
	allocatedWLEs.add(voyageWle);
	job102 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0202, workPoint);
	beginTransaction;
	job102.setOriginalJobAmount(5000);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 3 jobs in its jobsheet, the 2 new jobs (101 and 102) should have 2 WLEs, prenote should have 2 WLEs
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 3, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["101"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 101");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	holdjob := jobSheet.allJobsByJobNum["102"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 102");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(clinkPrenote.allWorklistEntries.size, 2, "Clinker prenote has the wrong number of WLEs");
	// Check weight on the prenoted WLE
	// 5000 to 0201, 5000 to 0202
	count := null;
	foreach wle in clinkPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 5000.0000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		elseif count = 2 then
			qty := 5000.0000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0202 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.weight, qty, "Clinker WLE " &amp; count.String &amp; " has the wrong weight");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Clinker WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the clinker in on 2 trucks
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 2500.Decimal);
	self.opts.addAssoc("CargoWeight", 2500.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr1 := self.gateInPrenote(TruckId1, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	clinkOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkOnsite1, "No onsite Clinker cargo item");
	self.assertEqualMsg(clinkOnsite1.weight, 2500.0000.Decimal, "Clinker onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite1.allWorklistEntries.size, clinkPrenote.allWorklistEntries.size + 1, "Truck1 Onsite and prenoted clinker has different WLE count");
	foreach wle in clinkOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, clinkPrenote.allWorklistEntries.size, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Second truck
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 7500.Decimal);
	self.opts.addAssoc("CargoWeight", 7500.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr2 := self.gateInPrenote(TruckId2, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	clinkOnsite2 := truck2.locationsController.allTrackedItems.first;
	// prenoted item is now the second onsite item
	self.assertNotEqualMsg(clinkOnsite1, clinkOnsite2, "The two onsite TIs are the same!");
	self.assertEqualMsg(clinkOnsite2, clinkPrenote, "Truck2 Clinker on site is not the prenote TI");
	self.assertNotNullMsg(clinkOnsite2, "Truck2 No onsite Clinker cargo item");
	self.assertEqualMsg(clinkOnsite2.weight, 7500.0000.Decimal, "Truck2 Clinker onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite2.allWorklistEntries.size, clinkPrenote.allWorklistEntries.size, "Truck2 Onsite and prenoted Clinker has different WLE count");
	foreach wle in clinkOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 2, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 2, "There is the wrong number of onsite TIs after gating in the two trucks");
	
	// Move some of the onsite cargo
	// Move from the trucks to the hold (replicating the use of the Cargo Lander Mobile app)
	// Truck 1 first - all 2500
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 2500 to hold 0201
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(clinkOnsite1, targetLocation, null, null, 2500);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is 1 TI onsite - for weight 7500
	// 2. Onship TI in hold 0201 - weight 2500, with 2 WLEs (voyage and yard, both complete, both for 2500)
	// 3. Road job for truck 1 is complete and has 1 complete WLE for 25 00
	// 4. Job 101 is part complete, with 1 voyage WLE for 2500, linked to onship TI in hold 0201
	moveCheck := MoveCheck &amp; "3: ";
	// 1. There is 1 TI onsite - for 7500
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite TIs");
	self.assertEqualMsg(clinkOnsite2.weight, 7500.0000.Decimal, moveCheck &amp; "Clinker 2 onsite has the wrong weight");
	// 2. Onship TI in hold 0201 - weight 2500, with 2 WLEs (voyage and yard, both complete, both for 2500)
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	clinkin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(clinkin0201, moveCheck &amp; "No on ship clinker in 0201");
	self.assertEqualMsg(clinkin0201.weight, 2500.0000.Decimal, moveCheck &amp; "Clinker in 0201 has the wrong weight");
	self.assertEqualMsg(clinkin0201.allWorklistEntries.size, 2, moveCheck &amp; "Clinker in 0201 has the wrong number of WLEs");
	foreach wle in clinkin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "Clinker in 0201 voyage WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0201 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "Clinker in 0201 yard WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0201 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Clinker in 0201 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Clinker in 0201 has no yard WLE");
	// 3. Road job for truck 1 is complete and has 1 complete WLE for 2500 
	roadjob := vvr1.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId1 &amp; " is null");
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, "Road job for " &amp; TruckId1 &amp; " has wrong status - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for Road job for " &amp; TruckId1 &amp; " is not complete");
	self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "WLE Road job for " &amp; TruckId1 &amp; " has wrong weight");
	// 4. Job 101 is part complete, with 1 completed voyage WLE for 2500, linked to onship TI in hold 0201
	self.assertEqualMsg(job101.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 101 for hold 0201 is " &amp; job101.statusString);
	count := null;
	count2 := null;
	voyageWle := null;
	foreach wle in job101.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.status = WLE_COMPLETED then
				count2 := count2 + 1;
				voyageWle := wle.CM_VoyageWLE;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 101 has wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Job 101 has wrong number of Completed voyage WLEs");
	self.assertNotNullMsg(voyageWle, moveCheck &amp; "No voyage WLE found for job 101");
	self.assertEqualMsg(voyageWle.status, WLE_COMPLETED, moveCheck &amp; "WLE for job 101 has wrong status");
	self.assertEqualMsg(voyageWle.weight, 2500.0000.Decimal, moveCheck &amp; "WLE for job 101 has wrong weight");
	self.assertEqualMsg(voyageWle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 101 has wrong subSeqNum");
	self.assertEqualMsg(voyageWle.myTrackedItem, clinkin0201, moveCheck &amp; "WLE for job 101 has the wrong TI");
	
	// second move - 2500 of onsite TI 2 to hold 0201
	// this will complete the outstanding 2500 on job 101
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(clinkOnsite2, targetLocation, null, null, 2500);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is still 1 TI onsite, with total weight 5000, with 1 WLE with a subSeqNum of 5000
	// 2. There is 1 Onship TI in hold 0201 - weight 5000, with 4 WLEs (2 voyage and 2 yard, all complete, all for 2500)
	// 3. Road job for truck 2 is part complete and has 2 yard WLEs (1 complete for 2500, one unactioned for 5000)
	// 4. Job 101 is complete, with 2 voyage WLEs each for 2500, both linked to onship TI in hold 0201
	moveCheck := MoveCheck &amp; "4: ";
	// 1. There is still 1 TI onsite, with total weight 5000, with 1 unactioned WLE with a subSeqNum of 5000
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite TIs");
	clinkOnsite2 := voyage.allOnsiteTIsByIdCargoType.first;
	self.assertEqualMsg(clinkOnsite2.weight, 5000.0000.Decimal, moveCheck &amp; "Remaining TI on site has the wrong total weight");
	correctQty1 := false;
	foreach wle in clinkOnsite2.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.status = WLE_UNACTIONED and wle.CM_VoyageWLE.subSeqNum = 5000 then
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(correctQty1, true, "TI still on site does not have an unactioned voyage WLE with subSeqNum = 5000");
	// 2. There is 1 Onship TI in hold 0201 - weight 5000, with 4 WLEs (2 voyage and 2 yard, all complete, all for 2500)
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	clinkin0201 := hold0201.allTrackedItems.first;
	self.assertEqualMsg(clinkin0201.weight, 5000.0000.Decimal, moveCheck &amp; "Clinker in 0201 has the wrong weight");
	self.assertEqualMsg(clinkin0201.allWorklistEntries.size, 4, moveCheck &amp; "Clinker in 0201 has the wrong number of WLEs");
	count := null;
	count2 := null;
	foreach wle in clinkin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "Clinker in 0201 voyage WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0201 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "Clinker in 0201 yard WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0201 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Clinker in 0201 has wrong voyage WLE count");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "Clinker in 0201 has wrong yard WLE count");
	// 3. Road job for truck 2 is part complete and has 2 yard WLEs (1 complete for 2500, one unactioned for 5000)
	roadjob := vvr2.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId2 &amp; " is null");
	self.assertEqualMsg(roadjob.workListEntries.size, 2, moveCheck &amp; "Road job has wrong number of WLEs");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in roadjob.workListEntries do
		if wle.isKindOf(CM_YardWLE) then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
			elseif wle.status = WLE_UNACTIONED then
				count2 := count2 + 1;
			endif;
			if count = 1 and wle.weight = 2500.0000.Decimal then
				correctQty1 := true;
			elseif count2 = 1 and wle.weight = 5000.0000.Decimal then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Road Job for " &amp; TruckId2 &amp; " has wrong number of completed WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Road Job for " &amp; TruckId2 &amp; " has wrong number of unactioned WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "Road Job for " &amp; TruckId1 &amp; " - WLEs have incorrect amounts " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 4. Job 101 is complete, with 2 voyage WLEs each for weight 2500, both linked to onship TI in hold 0201
	self.assertEqualMsg(job101.status, JOB_COMPLETE, moveCheck &amp; "Job 101 for hold 0201 is " &amp; job101.statusString);
	count := null;
	foreach wle in job101.workListEntries do
		if wle.myTrackedItem = null or wle.myTrackedItem.hasBeenMerged or wle.myDirectDeliveryParentWLE &lt;&gt; null then
			continue;
		endif;
		count := count + 1;
		self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for job 101 has wrong status :" &amp; count.String);
		self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "WLE for job 101 has wrong weight :" &amp; count.String);
		self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 101 has wrong subSeqNum :" &amp; count.String);
		self.assertEqualMsg(wle.myTrackedItem, clinkin0201, moveCheck &amp; "WLE for job 101 has the wrong TI :" &amp; count.String);
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 101 has wrong number of WLEs");
	
	// third move - all 5000 of onsite TI 2 to hold 0202
	// this will complete job 102
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(clinkOnsite2, targetLocation, null, null, 5000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are no TIs onsite 
	// 2. There is still 1 Onship TI in hold 0201 
	// 3. There is 1 Onship TI in hold 0202 - weight 5000, with 2 WLEs (1 voyage and 1 yard, all complete, all for weight 5000)
	// 4. Road job for truck 2 is complete and has 2 yard WLEs (for 2500 and 5000), both complete
	// 5. Job 102 is complete, with 1 voyage WLE for weight 5000, linked to onship TI in hold 0202
	moveCheck := MoveCheck &amp; "5: ";
	// 1. There are no TIs onsite 
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 0, moveCheck &amp; "Wrong number of onsite TIs");
	// 2. There is still 1 Onship TI in hold 0201 
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	// 3. There is 1 Onship TI in hold 0202 - weight 5000, with 2 WLEs (1 voyage and 1 yard, all complete, all for weight 5000)
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0202");
	clinkin0202 := hold0202.allTrackedItems.first;
	self.assertEqualMsg(clinkin0202.weight, 5000.0000.Decimal, moveCheck &amp; "TI in 0202 has the wrong total weight");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in clinkin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0202 is not complete - " &amp; wle.statusString);
			count := count + 1;
			if wle.weight = 5000.0000.Decimal then
				correctQty1 := true;
			endif;
		elseif wle.isKindOf(CM_YardWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0202 is not complete - " &amp; wle.statusString);
			count2 := count2 + 1;
			if wle.weight = 5000.0000.Decimal then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "TI in 0202 has the wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "TI in 0202 has the wrong number of yard WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "TI in 0202 WLEs have wrong weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 4. Road job for truck 2 is complete and has 2 yard WLEs (for 2500 and 5000), both complete
	roadjob := vvr2.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, "Road Job for truck " &amp; TruckId2 &amp; " is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 2, "Road job for truck " &amp; TruckId2 &amp; " has the wrong number of WLEs");
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in roadjob.workListEntries do
		count := count + 1;
		if wle.status = WLE_COMPLETED and wle.weight = 2500.0000.Decimal then
			correctQty1 := true;
		elseif wle.status = WLE_COMPLETED and wle.weight = 5000.0000.Decimal then
			correctQty2 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Road job for truck " &amp; TruckId2 &amp; " has the wrong number of WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "WLEs on Road job for truck " &amp; TruckId2 &amp; " have the wrong weight / status - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	
	// Road exit the trucks - all cargo gone
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	
	///////////////////////////////////////////////////////////////////////////////////////////////
	// TEST 3: Total weight planned to two holds, different amounts brought in on 2 trucks,      //
	// first truck completes first job and part of the second, second truck completes the second //
	///////////////////////////////////////////////////////////////////////////////////////////////
	// Create another prenote for the voyage 
	clinkPrenote := null;
	clinkOnsite1 := null;
	clinkOnsite2 := null;
	self.opts.purge;
	self.opts.addAssoc("CargoType", clinkCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 10000);
	self.opts.addAssoc("CargoWeight", 10000);
	self.opts.addAssoc("TareWeight", 0);
	self.opts.addAssoc("DD", true);
	clinkPrenote := self.addPrenoted(ClinkerId3);
	self.assertTrueMsg(clinkPrenote &lt;&gt; null, "Clinker prenote not created");
	self.assertEqualMsg(clinkPrenote.weight, 10000.0000.Decimal, "Clinker prenote weight is incorrect");
	self.assertTrueMsg(clinkPrenote.directDelivery = true, "Clinker prenote is not Direct Delivery");
	
	// Plan the prenote to two holds
	// Load job 103 to 0101: 5000
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(5000.0000);
	allocatedWLEs.add(voyageWle);
	job103 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0101, workPoint);
	beginTransaction;
	job103.setOriginalJobAmount(5000);
	commitTransaction;
	// Load job 104 to 0201: 5000
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(5000.0000);
	allocatedWLEs.add(voyageWle);
	job104 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job104.setOriginalJobAmount(5000);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 5 jobs in its jobsheet, the 2 new jobs (103 and 104) should have 1 WLE each, prenote should have 2 WLEs
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 5, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["103"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 103");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	holdjob := jobSheet.allJobsByJobNum["104"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 104");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(clinkPrenote.allWorklistEntries.size, 2, "Clinker prenote has the wrong number of WLEs");
	// Check weight on the prenoted WLE
	// 5000 to 0101, 5000 to 0201
	count := null;
	foreach wle in clinkPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 5000.0000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0101 Under Deck";
		elseif count = 2 then
			qty := 5000.0000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		endif;
		self.assertEqualMsg(voyageWle.weight, qty, "Clinker WLE " &amp; count.String &amp; " has the wrong weight");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Clinker WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the clinker in on 2 trucks
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 7500.Decimal);
	self.opts.addAssoc("CargoWeight", 7500.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr1 := self.gateInPrenote(TruckId1, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	clinkOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkOnsite1, "No onsite Clinker cargo item");
	self.assertEqualMsg(clinkOnsite1.weight, 7500.0000.Decimal, "Clinker onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite1.allWorklistEntries.size, clinkPrenote.allWorklistEntries.size + 1, "Truck1 Onsite and prenoted clinker has different WLE count");
	foreach wle in clinkOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, clinkPrenote.allWorklistEntries.size, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Second truck
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 2500.Decimal);
	self.opts.addAssoc("CargoWeight", 2500.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr2 := self.gateInPrenote(TruckId2, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	clinkOnsite2 := truck2.locationsController.allTrackedItems.first;
	// prenoted item is now the second onsite item
	self.assertNotEqualMsg(clinkOnsite1, clinkOnsite2, "The two onsite TIs are the same!");
	self.assertEqualMsg(clinkOnsite2, clinkPrenote, "Truck2 Clinker on site is not the prenote TI");
	self.assertNotNullMsg(clinkOnsite2, "Truck2 No onsite Clinker cargo item");
	self.assertEqualMsg(clinkOnsite2.weight, 2500.0000.Decimal, "Truck2 Clinker onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite2.allWorklistEntries.size, clinkPrenote.allWorklistEntries.size, "Truck2 Onsite and prenoted clinker has different WLE count");
	foreach wle in clinkOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 2, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 2, "There is the wrong number of onsite TIs after gating in the two trucks");
	
	// Move some of the onsite cargo
	// Move from the trucks to the hold (replicating the use of the Cargo Lander Mobile app)
	// Truck 1 first - all 7500
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 7500 to hold 0101 - this will complete job 103 and partially complete job 104
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(clinkOnsite1, targetLocation, null, null, 7500);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is 1 TI onsite - for weight 2500
	// 2. Onship TI in hold 0101 - weight 5000, with 2 WLEs (voyage and yard, both complete, both for 5000)
	// 3. Onship TI in hold 0201 - weight 2500, with 2 WLEs (voyage and yard, both complete, both for 2500)
	// 4. Road job for truck 1 is complete and has 1 complete WLE for 7500 
	// 5. Job 103 is complete, with 1 voyage WLE for weight 5000, linked to onship TI in hold 0101
	// 6. Job 104 is part complete, with 1 voyage WLE for weight 2500, linked to onship TI in hold 0201
	moveCheck := MoveCheck &amp; "6: ";
	// 1. There is 1 TI onsite - for weight 2500
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite cargo items");
	// 2. Onship TI in hold 0101 - weight 5000, with 2 WLEs (voyage and yard, both complete, both for 5000)
	foreach ti in hold0101.allTrackedItems where ti.id = clinkOnsite1.id do
		clinkin0101 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(clinkin0101, moveCheck &amp; "There is no TI on ship with the ID " &amp; clinkOnsite1.id);
	self.assertEqualMsg(hold0101.allTrackedItems.includes(clinkin0101), true, moveCheck &amp; "TI " &amp; clinkin0101.id &amp; " is not in Hold 0101");
	self.assertEqualMsg(clinkin0101.weight, 5000.0000.Decimal, moveCheck &amp; "TI in hold 0101 has the wrong weight");
	count := null;
	count2 := null;
	foreach wle in clinkin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWle := wle.CM_VoyageWLE;
			count := count + 1;
		elseif wle.isKindOf(CM_YardWLE) then
			yardWLE := wle.CM_YardWLE;
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "TI in 0101 has the wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "TI in 0101 has the wrong number of yard WLEs");
	self.assertEqualMsg(voyageWle.weight, 5000.0000.Decimal, moveCheck &amp; "Voyage WLE for TI in 0101 has the wrong weight");
	self.assertEqualMsg(voyageWle.subSeqNum, 0, moveCheck &amp; "Voyage WLE for TI in 0101 has the wrong subSeqNum");
	self.assertEqualMsg(yardWLE.weight, 5000.0000.Decimal, moveCheck &amp; "Yard WLE for TI in 0101 has the wrong weight");
	self.assertEqualMsg(voyageWle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0101 has the wrong status - " &amp; voyageWle.statusString);
	self.assertEqualMsg(yardWLE.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0101 has the wrong status - " &amp; yardWLE.statusString);
	// 3. Onship TI in hold 0201 - weight 2500, with 2 WLEs (voyage and yard, both complete, both for 2500)
	foreach ti in hold0201.allTrackedItems where ti.id = clinkOnsite1.id do
		clinkin0201 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(clinkin0201, moveCheck &amp; "There is no TI on ship with the ID " &amp; clinkOnsite1.id);
	self.assertEqualMsg(hold0201.allTrackedItems.includes(clinkin0201), true, moveCheck &amp; "TI " &amp; clinkin0201.id &amp; " is not in Hold 0101");
	self.assertEqualMsg(clinkin0201.weight, 2500.0000.Decimal, moveCheck &amp; "TI in hold 0201 has the wrong weight");
	count := null;
	count2 := null;
	foreach wle in clinkin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWle := wle.CM_VoyageWLE;
			count := count + 1;
		elseif wle.isKindOf(CM_YardWLE) then
			yardWLE := wle.CM_YardWLE;
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "TI in 0201 has the wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "TI in 0201 has the wrong number of yard WLEs");
	self.assertEqualMsg(voyageWle.weight, 2500.0000.Decimal, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong weight");
	self.assertEqualMsg(voyageWle.subSeqNum, 0, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong subSeqNum");
	self.assertEqualMsg(yardWLE.weight, 2500.0000.Decimal, moveCheck &amp; "Yard WLE for TI in 0201 has the wrong weight");
	self.assertEqualMsg(voyageWle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong status - " &amp; voyageWle.statusString);
	self.assertEqualMsg(yardWLE.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0201 has the wrong status - " &amp; yardWLE.statusString);
	// 4. Road job for truck 1 is complete and has 2 complete WLEs, for 5000 and 2500 
	roadjob := vvr1.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 2, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has wrong number of WLEs");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 5000.0000.Decimal then
				correctQty1 := true;
			elseif wle.weight = 2500.0000.Decimal then
				correctQty2 := true;
			endif;
		else
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has the wrong number of completed WLEs");
	self.assertEqualMsg(count2, 0, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has some incomplete WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "WLEs for Road job for " &amp; TruckId1 &amp; " have the wrong weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 5. Job 103 is complete, with 1 voyage WLE for weight 5000, linked to onship TI in hold 0101
	job103 := jobSheet.allJobsByJobNum["103"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job103, moveCheck &amp; "Job 103 not found");
	self.assertEqualMsg(job103.status, JOB_COMPLETE, moveCheck &amp; "job 103 is not complete - " &amp; job103.statusString);
	count := null;
	foreach wle in job103.workListEntries where wle.myDirectDeliveryParentWLE = null do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for job 103 is not complete - " &amp; wle.statusString);
			self.assertEqualMsg(wle.weight, 5000.0000.Decimal, moveCheck &amp; "Voyage WLE for job 103 has the wrong weight");
			self.assertEqualMsg(wle.myTrackedItem, clinkin0101, "Voyage WLE for job 103 has the wrong TI - " &amp; wle.myTrackedItem.id &amp; ":" &amp; clinkin0101.id);
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 103 has the wrong number of voyage WLEs");
	// 6. Job 104 is part complete, with 1 completed voyage WLE for 2500 and 1 unactione wle for 2500, linked to onship TI in hold 0201
	job104 := jobSheet.allJobsByJobNum["104"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job104, moveCheck &amp; "Job 104 not found");
	self.assertEqualMsg(job104.status, JOB_PART_COMPLETE, moveCheck &amp; "job 104 is not part complete - " &amp; job104.statusString);
	count := null;
	count2 := null;
	foreach wle in job104.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			if wle.status = WLE_COMPLETED then
				count2 := count2 + 1;
				self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "Completed Voyage WLE for job 104 has the wrong weight");
				self.assertEqualMsg(wle.myTrackedItem, clinkin0201, "Completed Voyage WLE for job 103 has the wrong TI - " &amp; wle.myTrackedItem.id &amp; ":" &amp; clinkin0201.id);
			elseif wle.status = WLE_UNACTIONED then
				self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "Unactioned Voyage WLE for job 104 has the wrong weight");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 104 has the wrong number of voyage WLEs");
	
	// second move - 2500 of onsite TI 2 to hold 0201
	// this will complete the outstanding 2500 on job 104
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(clinkOnsite2, targetLocation, null, null, 2500);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are no onsite TIs
	// 2. Road job for Truck 2 is complete, with 1 WLE for weight 2500
	// 3. There is still an on ship TI in 0101
	// 4. On ship TI in 0201 is now weight 5000, with 2 voyage WLEs and 2 yard WLEs, all for weight 2500
	// 5. Job 104 is complete, with 2 voyage WLEs, both for weight 2500
	moveCheck := MoveCheck &amp; "7: ";
	// 1. There are no onsite TIs
	self.assertTrueMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, moveCheck &amp; "There is still an onsite TI");
	// 2. Road job for Truck 2 is complete, with 1 WLE for weight 2500
	roadjob := vvr2.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "No road job for VVR 2!");
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for VVR 2 is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; " Road job has too many WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for road job 2 is not complete - " &amp; wle.statusString);
	self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "WLE for road job 2 has wrong weight");
	// 3. There is still an on ship TI in 0101
	foreach ti in hold0101.allTrackedItems where ti.id = clinkOnsite1.id do
		clinkin0101 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(clinkin0101, moveCheck &amp; "There is no TI on the voyage with the ID of the old TI 1 on site");
	self.assertEqualMsg(clinkin0101.myPrimaryActualLocation, hold0101, moveCheck &amp; "TI " &amp; clinkin0101.id &amp; " is not in 0101 - " &amp; clinkin0101.locationId);
	// 4. On ship TI in 0201 is now weight 5000, with 2 voyage WLEs and 2 yard WLEs, all for 2500
	foreach ti in hold0201.allTrackedItems where ti.id = clinkOnsite2.id do
		clinkin0201 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(clinkin0201, moveCheck &amp; "There is no TI on the voyage with the ID of the old TI 2 on site");
	self.assertEqualMsg(clinkin0201.myPrimaryActualLocation, hold0201, moveCheck &amp; "TI " &amp; clinkin0201.id &amp; " is not in 0201 - " &amp; clinkin0201.locationId);
	self.assertEqualMsg(clinkin0201.weight, 5000.0000.Decimal, moveCheck &amp; "TI in 0201 has the wrong weight");
	count := null;
	count2 := null;
	foreach wle in clinkin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong status - " &amp; wle.statusString);
			self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong weight");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Voyage WLE for TI in 0201 has the wrong subSeqNum");
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0201 has the wrong status - " &amp; wle.statusString);
			self.assertEqualMsg(wle.weight, 2500.0000.Decimal, moveCheck &amp; "Yard WLE for TI in 0201 has the wrong weight");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "TI in 0201 has the wrong number of voyage WLEs");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "TI in 0201 has the wrong number of yard WLEs");
	// 5. Job 104 is complete, with 2 voyage WLEs, both for 2500
	job104 := jobSheet.allJobsByJobNum["104"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job104, moveCheck &amp; "No job found for 104");
	self.assertEqualMsg(job104.status, JOB_COMPLETE, "Job 104 has the wrong status - " &amp; job104.statusString);
	count := null;
	correctQty1 := true;
	foreach wle in job104.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight &lt;&gt; 2500.0000.Decimal then
				correctQty1 := false;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Job 104 has the wrong number of Complete WLEs");
	self.assertEqualMsg(correctQty1, true, "Job 104 has a WLE with an incorrect weight");
	
	// Road exit the trucks - all cargo gone
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	
	////////////////////////////////////////////////////////////////////////////////////////////
	// TEST 4: Total weight planned to two holds, different amounts brought in on 3 trucks.   //
	// First move part completes first job, second move completes the first and part of the   //
	// second, third move completes the second                                                //
	////////////////////////////////////////////////////////////////////////////////////////////
	// Create another prenote for the voyage 
	clinkPrenote := null;
	clinkOnsite1 := null;
	clinkOnsite2 := null;
	self.opts.purge;
	self.opts.addAssoc("CargoType", clinkCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 10000);
	self.opts.addAssoc("CargoWeight", 10000);
	self.opts.addAssoc("TareWeight", 0);
	self.opts.addAssoc("DD", true);
	clinkPrenote := self.addPrenoted(ClinkerId4);
	self.assertTrueMsg(clinkPrenote &lt;&gt; null, "Clinker prenote not created");
	self.assertEqualMsg(clinkPrenote.weight, 10000.0000.Decimal, "Clinker prenote weight is incorrect");
	self.assertTrueMsg(clinkPrenote.directDelivery = true, "Clinker prenote is not Direct Delivery");
	
	// Plan the prenote to two holds
	// Load job 105 to 0101: 50000
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(5000.0000);
	allocatedWLEs.add(voyageWle);
	job105 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0101, workPoint);
	beginTransaction;
	job105.setOriginalJobAmount(5000);
	commitTransaction;
	// Load job 106 to 0102: 5000
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(5000.0000);
	allocatedWLEs.add(voyageWle);
	job106 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0102, workPoint);
	beginTransaction;
	job106.setOriginalJobAmount(5000);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 7 jobs in its jobsheet, the 2 new jobs (105 and 106) should have 1 WLE, prenote should have 2 WLEs
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 7, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["105"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 105");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	holdjob := jobSheet.allJobsByJobNum["106"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 106");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(clinkPrenote.allWorklistEntries.size, 2, "Clinker prenote has the wrong number of WLEs");
	// Check weight on the prenoted WLE
	// 5000 to 0101, 5000 to 0102
	count := null;
	foreach wle in clinkPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 5000.0000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0101 Under Deck";
		elseif count = 2 then
			qty := 5000.0000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0102 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.weight, qty, "Clinker WLE " &amp; count.String &amp; " has the wrong weight");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Clinker WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the clinker in on 3 trucks
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 2000.Decimal);
	self.opts.addAssoc("CargoWeight", 2000.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr1 := null;
	vvr2 := null;
	vvr1 := self.gateInPrenote(TruckId1, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	clinkOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkOnsite1, "No onsite Clinker cargo item");
	self.assertEqualMsg(clinkOnsite1.weight, 2000.0000.Decimal, "Clinker onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite1.allWorklistEntries.size, clinkPrenote.allWorklistEntries.size + 1, "Truck1 Onsite and prenoted clinker has different WLE count");
	foreach wle in clinkOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, clinkPrenote.allWorklistEntries.size, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Second truck
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 5000.Decimal);
	self.opts.addAssoc("CargoWeight", 5000.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr2 := self.gateInPrenote(TruckId2, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	clinkOnsite2 := truck2.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkOnsite2, "No onsite Clinker cargo item for Truck 2");
	self.assertEqualMsg(clinkOnsite2.weight, 5000.0000.Decimal, "Clinker onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite2.allWorklistEntries.size, clinkPrenote.allWorklistEntries.size + 1, "Truck2 Onsite and prenoted clinker has different WLE count");
	foreach wle in clinkOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, clinkPrenote.allWorklistEntries.size, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	// Third truck
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 3000.Decimal);
	self.opts.addAssoc("CargoWeight", 3000.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr3 := self.gateInPrenote(TruckId3, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck3 := vvr3.myRoadJob.myVehicle;
	clinkOnsite3 := truck3.locationsController.allTrackedItems.first;
	// prenoted item is now the third onsite item
	self.assertEqualMsg(clinkOnsite3, clinkPrenote, "Truck3 Clinker on site is not the prenote TI");
	self.assertNotNullMsg(clinkOnsite3, "Truck3 No onsite Clinker cargo item");
	self.assertEqualMsg(clinkOnsite3.weight, 3000.0000.Decimal, "Truck3 Clinker onsite weight is incorrect");
	foreach wle in clinkOnsite3.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck3 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 2, "Truck3 Yard WLE has an incorrect number of direct delivery WLEs");
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 3, "There is the wrong number of onsite TIs after gating in the three trucks");
	
	// Move some of the onsite cargo
	// Truck 1 first - all 2000
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 20000 to hold 0101 - this will part complete job 105
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(clinkOnsite1, targetLocation, null, null, 2000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are 2 TIs onsite - for weight 5000 and 3000
	// 2. Onsite TI 1 has become Onship TI in hold 0101 - weight 2000, with 2 WLEs (voyage and yard, both complete, both for weight 2000)
	// 3. DD WLEs for 0101 on the 2 onsite WLES have subSeqNum reduced to 3000
	// 4. Road job for truck 1 is complete and has 1 complete WLE for 2000
	// 5. Job 105 is part complete, with 1 completed voyage WLE for 2000, linked to onship TI in hold 0101, and 1 unactioned voyage WLE for 3000 (one unactioned WLE for each still-onsite TI)
	moveCheck := MoveCheck &amp; "8: ";
	// 1. There are 2 TIs onsite - for weight 5000 and 3000
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 2, moveCheck &amp; "Wrong number of onsite TIs after first move");
	correctQty1 := false;
	correctQty2 := false;
	foreach ti in voyage.allOnsiteTIsByIdCargoType do
		if ti.weight= 5000.0000.Decimal then
			correctQty1 := true;
		elseif ti.weight = 3000.0000.Decimal then
			correctQty2 := true;
		endif;
	endforeach;
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "The onsite TIs have the wrong weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 2. Onsite TI 1 has become Onship TI in hold 0101 - weight 2000, with 2 WLEs (voyage and yard, both complete, both for 2000)
	clinkin0101 := voyage.allOnshipTIsByIdCargoType[clinkOnsite1.id, clinkOnsite1.cargoType];
	self.assertNotNullMsg(clinkin0101, moveCheck &amp; "There is no TI in 0101 matching the former onsite TI's id");
	self.assertEqualMsg(clinkin0101, clinkOnsite1, moveCheck &amp; "TI in 0101 is NOT the former onsite TI");
	self.assertEqualMsg(clinkin0101.weight, 2000.0000.Decimal, moveCheck &amp; "TI in 0101 has the wrong weight");
	self.assertEqualMsg(clinkin0101.allWorklistEntries.size, 2, moveCheck &amp; "TI in 0101 has the wrong number of WLEs");
	count := null;
	count2 := null;
	foreach wle in clinkin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE for TI in 0101 is not complete - " &amp; wle.statusString);
			self.assertEqualMsg(wle.weight, 2000.0000.Decimal, moveCheck &amp; "Voyage WLE for TI in 0101 has wrong weight");
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Voyage WLE for TI in 0101 has wrong subSeqNum");
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Yard WLE for TI in 0101 is not complete - " &amp; wle.statusString);
			self.assertEqualMsg(wle.weight, 2000.0000.Decimal, moveCheck &amp; "Yard WLE for TI in 0101 has wrong weight");
		endif;
	endforeach;
	// 3. DD WLEs for 0101 on the 2 onsite WLES have subSeqNum reduced to 3000
	correctQty1 := false;
	foreach wle in clinkOnsite2.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.myDirectDeliveryParentWLE &lt;&gt; null and wle.locationTarget = hold0101Str then
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 3000, moveCheck &amp; "Onsite TI 2 has wrong subSeqNum on the WLE for 0101");
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Onsite TI 2 has no voyage WLE pointing to 0101");
	correctQty1 := false;
	foreach wle in clinkOnsite3.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) and wle.myDirectDeliveryParentWLE &lt;&gt; null and wle.locationTarget = hold0101Str then
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 3000, moveCheck &amp; "Onsite TI 3 has wrong subSeqNum on the WLE for 0101");
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Onsite TI 3 has no voyage WLE pointing to 0101");
	// 4. Road job for truck 1 is complete and has 1 complete WLE for 2000
	roadjob := vvr1.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for Truck 1 is not complete");
	count := null;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			self.assertEqualMsg(wle.weight, 2000.0000.Decimal, moveCheck &amp; "Completed WLE on road job for truck 1 has the wrong weight");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Road job for truck 1 has the wrong number of completed WLEs");
	// 5. Job 105 is part complete, with 1 completed voyage WLE for 2000, linked to onship TI in hold 0101, and 2 unactioned voyage WLEs for 3000
	// (one unactioned WLE for each still-onsite TI)
	job105 := jobSheet.allJobsByJobNum["105"].CM_VoyageHoldJob;
	self.assertEqualMsg(job105.status, JOB_PART_COMPLETE, moveCheck &amp; "JOb 105 is not part complete - " &amp; job105.statusString);
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job105.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 2000.0000.Decimal then
				correctQty1 := true;
			endif;
			self.assertEqualMsg(wle.myTrackedItem, clinkin0101, "TI on completed WLE for job 105 is not the TI in 0101");
		elseif wle.status = WLE_UNACTIONED then
			count2 := count2 + 1;
			if wle.weight = 3000.0000.Decimal then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 105 has the wrong number of completed WLEs");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "Job 105 has the wrong number of unactioned WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "job 105 has incorrect weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	
	// Move the next piece of cargo - all the clinker on Truck 2 (5000)
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// second move - 5000 to hold 0101 - this will complete job 105 and partially complete job 106
	targetLocation := hold0101;
	mobileAgent.doLanderLoad(clinkOnsite2, targetLocation, null, null, 5000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is only 1 onsite TI
	// 2. TI in 0101 is now weight 5000, with 2 completed voyage WLEs for 2000 and 3000
	// 3. There is a new TI in 0102, weight 2000, with 1 completed voyage WLE and 1 completed yard WLE, both for 2000
	// 4. Voyage job 105 is complete, with 2 completed voyage WLEs for 3000 and 2000
	// 5. Voyage job 106 is part complete, with 1 completed voyage WLE  for 2000 and one unactioned voyage WLE for 3000
	// 6. Road job for Truck 2 is complete, with 2 completed yard WLEs for 3000 and 2000
	// 7. DD WLE for road job for Truck 3 pointing to 0102 has its subSeqNum reduced to 3000
	moveCheck := MoveCheck &amp; "9: ";
	// 1. There is only 1 onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong number of onsite TIs");
	// 2. TI in 0101 is now weight 5000, with 2 completed voyage WLEs for 2000 and 3000
	clinkin0101 := null;
	foreach ti in hold0101.allTrackedItems do
		if ti.id = ClinkerId4 and ti.myCargoType = clinkCargoType then
			clinkin0101 := ti;
			break;
		endif;
	endforeach;
	self.assertNotNullMsg(clinkin0101, moveCheck &amp; "No TI found for " &amp; ClinkerId4 &amp; " in 0101");
	self.assertEqualMsg(clinkin0101.weight, 5000.0000.Decimal, moveCheck &amp; "TI in 0101 has the wrong weight");
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in clinkin0101.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			if wle.status = WLE_COMPLETED then
				count := count + 1;
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "TI in 0101 has a completed voyage WEL with non-zero subSeqNum");
				if wle.weight = 2000.0000.Decimal then
					correctQty1 := true;
				elseif wle.weight = 3000.0000.Decimal then
					correctQty2 := true;
				endif;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "TO in 0101 has wrong number of completed voyage WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "TI in 0101 has wrong weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 3. There is a new TI in 0102, weight 2000, with 1 completed voyage WLE ad 1 completed yard WLE, both for 2000
	clinkin0102 := null;
	foreach ti in hold0102.allTrackedItems do
		if ti.id = ClinkerId4 and ti.myCargoType = clinkCargoType then
			clinkin0102 := ti;
			break;
		endif;
	endforeach;
	self.assertNotNullMsg(clinkin0102, moveCheck &amp; "No TI found for " &amp; ClinkerId4 &amp; " in 0101");
	self.assertEqualMsg(clinkin0102.weight, 2000.0000.Decimal, moveCheck &amp; "TI in 0101 has the wrong weight");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in clinkin0102.allWorklistEntries do
		if wle.status = WLE_COMPLETED then
			if wle.isKindOf(CM_VoyageWLE) then
				count := count + 1;
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "TI in 0102 has a voyage WLE with non-zero subSeqNum");
				if wle.weight = 2000.0000.Decimal then
					correctQty1 := true;
				endif;
			elseif wle.isKindOf(CM_YardWLE) then
				count2 := count2 + 1;
				if wle.weight = 2000.0000.Decimal then
					correctQty2 := true;
				endif;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "TI in 0102 has the wrong number of completed Voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "TI in 0102 has the wrong number of completed Yard WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "TI in 0102 has wrong weights on WLEs - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 4. Voyage job 105 is complete, with 2 completed voyage WLEs for 3000 and 2000
	job105 := jobSheet.allJobsByJobNum["105"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job105, moveCheck &amp; "No job found for 105");
	self.assertEqualMsg(job105.status, JOB_COMPLETE, moveCheck &amp; "Job 105 is not complete");
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job105.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 2000.0000.Decimal then
				correctQty1 := true;
			elseif wle.weight = 3000.0000.Decimal then
				correctQty2 := true;
			endif;
			if wle.isKindOf(CM_VoyageWLE) then
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Job 105 has a completed voyage WLE with non-zero subSeqNum");
			endif;
		elseif wle.status = WLE_UNACTIONED and wle.CM_VoyageWLE.subSeqNum &lt;&gt; null then
			self.assertTrueMsg(false, moveCheck &amp; "Job 105 has an incomplete WLE");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 102 has the wrong number of Completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Job 105 has wrong WLE weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 5. Voyage job 106 is part complete, with 1 completed voyage WLE for 2000 and one unactioned voyage WLE for 3000
	job106 := jobSheet.allJobsByJobNum["106"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job106, moveCheck &amp; "No job found for 106");
	self.assertEqualMsg(job106.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 105 is not part complete");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job106.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 2000.0000.Decimal then
				correctQty1 := true;
			endif;
			if wle.isKindOf(CM_VoyageWLE) then
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Job 105 has a completed voyage WLE with non-zero subSeqNum");
			endif;
		elseif wle.status = WLE_UNACTIONED and wle.CM_VoyageWLE.subSeqNum &lt;&gt; null then
			count2 := count2 + 1;
			if wle.weight = 3000.0000.Decimal then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 106 has the wrong number of Completed WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Job 106 has the wrong number of Unactioned WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Job 106 has incorrect WLE weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 6. Road job for Truck 2 is complete, with 2 completed yard WLEs for 3000 and 2000
	roadjob := vvr2.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for Truck 2 has wrong status - " &amp; roadjob.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in roadjob.workListEntries do
		self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Road job for Truck 2 has an incomplete WLE");
		count := count + 1;
		if wle.weight = 2000.0000.Decimal then
			correctQty1 := true;
		elseif wle.weight = 3000.0000.Decimal then
			correctQty2 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Road job for truck 2 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Road job for Truck 2 has incorrect WLE weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 7. DD WLE for road job for Truck 3 pointing to 0102 has its subSeqNum reduced to 3000
	roadjob := vvr3.myRoadJob;
	foreach wle in roadjob.workListEntries do
		foreach ddWle in wle.allDirectDeliveryChildWLEs do
			if ddWle.isKindOf(CM_VoyageWLE) and wle.locationTarget = hold0102Str then
				self.assertEqualMsg(ddWle.CM_VoyageWLE.subSeqNum, 3000, "DD WLE in road job for truck 3 has wrong subSeqNum");
			endif;
		endforeach;
	endforeach;
	
	// Move the last piece of cargo - all the clinker on Truck 3 (3000)
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// third move - 3000 to hold 0102 - this will complete job 106
	targetLocation := hold0102;
	mobileAgent.doLanderLoad(clinkOnsite3, targetLocation, null, null, 3000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are no more onsite TIs
	// 2. TI on ship in 0102 now has weight 5000, 2 voyage WLEs and 2 road WLEs (for 2000 and 3000), all complete
	// 3. Total weight of all TIs with current id on ship adds up to 10000
	// 4. Job 106 is complete, and has 2 complete voyage WLEs for 2000 and 3000 - both linked to TI in 0102
	// 5. Road job for truck 3 is complete, with 1 complete yard WLE for 3000
	moveCheck := MoveCheck &amp; "10: ";
	// 1. There are no more onsite TIs
	self.assertTrueMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, moveCheck &amp; "There is still at least 1 on site TI");
	// 2. There is a new TI weight 5000 on ship in 0102 - 1 voyage WLE and 1 road WLE, both for 5000 and both complete
	clinkin0102 := null;
	foreach ti in hold0102.allTrackedItems where ti.id = ClinkerId4 do
		clinkin0102 := ti;
		break;
	endforeach;
	self.assertNotNullMsg(clinkin0102, moveCheck &amp; "There is no TI in 0102 matching id " &amp; ClinkerId4);
	self.assertEqualMsg(clinkin0102.weight, 5000.0000.Decimal, moveCheck &amp; "TI in 0102 has the wrong weight");
	count := null;
	count2 := null;
	foreach wle in clinkin0102.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "TI in 0102 Voyage WEL is not complete - " &amp; wle.statusString);
			count := count + 1;
			vQty := vQty + wle.weight;
		elseif wle.isKindOf(CM_YardWLE) then
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "TI in 0102 Yard WLE is not complete - " &amp; wle.statusString);
			count2 := count2 + 1;
			yQty := yQty + wle.weight;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "TI in 0102 has the wrong number of Voyage WLEs");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "TI in 0102 has the wrong number of Yard WLEs");
	self.assertEqualMsg(vQty = 5000.0000.Decimal and yQty = 5000.0000.Decimal, true, moveCheck &amp; "TI in 0102 has incorrect WLE weights - " &amp; vQty.asStringJMT &amp; ":" &amp; yQty.asStringJMT);
	// 3. Total weight of all TIs with current id on ship adds up to 10000
	total := null;
	foreach ti in voyage.allOnshipTIsByIdCargoType where ti.id = ClinkerId4 do
		total := total + ti.weight;
	endforeach;
	self.assertEqualMsg(total, 10000.0000.Decimal, moveCheck &amp; "TIs with id " &amp; ClinkerId4 &amp; " on voyage do not add up to 10000");
	// 4. Job 106 is complete, and has 2 complete voyage WLEs for 2000 and 3000 - both linked to TI in 0102
	job106 := jobSheet.allJobsByJobNum["106"].CM_VoyageHoldJob;
	self.assertNotNullMsg(job106, moveCheck &amp; "No job found in job sheet for 106");
	self.assertEqualMsg(job106.status, JOB_COMPLETE, moveCheck &amp; "Job 106 is not complete - " &amp; job106.statusString);
	count := null;
	correctQty1 := false;
	correctQty1 := false;
	foreach wle in job106.workListEntries do
		if wle.isKindOf(CM_VoyageWLE) and not wle.myTrackedItem.hasBeenMerged then
			count := count + 1;
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Voyage WLE in job 106 is not complete - " &amp; wle.statusString);
			self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "Voyage WLE in job 106 has non-zero subSeqNum");
			self.assertEqualMsg(wle.myTrackedItem, clinkin0102, moveCheck &amp; "Voyage WLE in job 106 has wrong TI - " &amp; wle.myTrackedItem.id &amp; ":" &amp; clinkin0102.id);
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 106 has wrong number of Voyage WLEs");
	// 5. Road job for truck 3 is complete, with 1 complete yard WLE for 3000
	roadjob := vvr3.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for truck 3 is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job for truck 3 has the wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "WLE for road job for truck 3 is not complete - " &amp; wle.statusString);
	self.assertEqualMsg(wle.weight, 3000.0000.Decimal, moveCheck &amp; "WLE for road job for truck 3 has the wrong weight");
	
	// Road exit the trucks - all cargo gone
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	self.roadExit(vvr3);
	
	////////////////////////
	// Finished - Tidy up //
	////////////////////////
	self.deleteWorkPoint(ThisWorkPoint);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteVehicle(TruckId1);
	self.deleteVehicle(TruckId2);
	
epilog
	delete allocatedWLEs;
	delete mobileAgent;
	self.setTerminalConfig(DirectTruck2VesselMult, directTruckMoves);
	app.myPassport.setMyTerminal(passportTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="tSalalahDirectToShipWgt3" id="a36949c2-3c7e-4014-bdc1-daf500e48849">
        <source>tSalalahDirectToShipWgt3();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/12/2021	navdap1		Initial creation TFS 52293
//
constants
	ThisVoyageCode : String = "DAVEH52293_5";
	ThisVesselCode : String = "DAVEHOLD";
	CLINKER : String = "CLINKER";
	ClinkerId1 : String = "CLINKERDD52293_5_1";
	ThisWorkPoint : String = "WP52293_5";
	TruckId1 : String = "UT52293_5_1";
	MoveCheck : String = "Move Check ";
	
vars
	terminal, passportTerminal : CM_Terminal;
	directTruckMoves : Boolean;
	operator : CM_Operator;
	clinkCargoType : CM_CargoType;
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	clinkPrenote, clinkOnsite1, clinkin0201, clinkin0202 : CM_TrackedItem;
	hold0101, hold0102, hold0201, hold0202 : CM_GeneralCargoController;
	hold0101Str, hold0102Str, hold0201Str, hold0202Str : String;
	voyageWle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	allocatedWLEs : CM_WLEArray;
	jobSheet : CM_VoyageHoldJobSheet;
	holdjob : CM_VoyageJob;
	count, count2 : Integer;
	qty, total : Decimal [14,4];
	loc : String;
	mobileAgent : CMIF_MobileGenericAgent;
	targetLocation : CM_LocationsController;
	yardWLE : CM_YardWLE;
	voyageWleFound, yardWleFound : Boolean;
	roadjob : CM_RoadJob;
	correctQty1, correctQty2, correctQty3, correctQty4 : Boolean;
	vvr1 : CM_VehicleVisitRecord;
	moveCheck : String;
	job100, job101 : CM_VoyageHoldJob;
	truck1 : CM_Vehicle;


begin
	// Set the terminal config that drives all of this
	terminal := self.getTerminal;
	directTruckMoves := self.setTerminalConfig(DirectTruck2VesselMult, true).Boolean;
	//return;
	///////////////////////////////////////
	// Sanity Check and Pre-run Clean Up //
	///////////////////////////////////////
	clinkCargoType := app.myRoot.getCargoTypeFromAbbrev(CLINKER);
	self.assertTrueMsg(clinkCargoType &lt;&gt; null, CLINKER &amp; "does not exist as a Cargo Type");
	
	self.opts.purge;
	self.opts.addAssoc("includePrenote", true);
	self.deleteCargo(ClinkerId1, clinkCargoType);
	self.deleteVehicle(TruckId1);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteWorkPoint(ThisWorkPoint);
	self.assertTrueMsg(self.getVoyage(ThisVoyageCode) = null, "Voyage " &amp; ThisVoyageCode &amp; " not deleted");
	
	////////////
	// Set Up //
	////////////
	// Create a Voyage with Holds
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage := self.addVoyageWithGeneralCargoStruc(ThisVoyageCode, ThisVesselCode, operator.code, "DOUG", 2);
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage not created");
	self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null and voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.size = 10, "General Cargo voyage not set up correctly");
	// and a workpoint
	workPoint := self.addWorkPoint(ThisWorkPoint, false);
	self.assertTrueMsg(workPoint &lt;&gt; null, "Work Point not created");
	
	hold0101 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,1];
	hold0102 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,2];
	hold0201 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,1];
	hold0202 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,2];
	hold0101Str := hold0101.getFullId;
	hold0102Str := hold0102.getFullId;
	hold0201Str := hold0201.getFullId;
	hold0202Str := hold0202.getFullId;
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// TEST: Plan most but not all of the cargo to two holds, then bring the entire prenote in on one truck //
	// Move it in chunks to the planned holds.                                                              //
	//////////////////////////////////////////////////////////////////////////////////////////////////////////
	// Create a prenote for the voyage splittable by weight
	self.opts.purge;
	self.opts.addAssoc("CargoType", clinkCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 100000);
	self.opts.addAssoc("CargoWeight", 100000);
	self.opts.addAssoc("TareWeight", 0);
	self.opts.addAssoc("DD", true);
	clinkPrenote := self.addPrenoted(ClinkerId1);
	self.assertTrueMsg(clinkPrenote &lt;&gt; null, "Clinker prenote not created");
	self.assertEqualMsg(clinkPrenote.weight, 100000.0000.Decimal, "Clinker prenote weight is incorrect");
	self.assertTrueMsg(clinkPrenote.directDelivery = true, "Clinker prenote is not Direct Delivery");
	
	// Plan the prenote to two holds
	// Load job 100 to 0201: 30000
	create allocatedWLEs transient;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(30000.0000);
	allocatedWLEs.add(voyageWle);
	job100 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job100.setOriginalJobAmount(30000);
	commitTransaction;
	// Load job 102 to 0202: 50000
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkPrenote);
	voyageWle.setWeight(50000.0000);
	allocatedWLEs.add(voyageWle);
	job101 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0202, workPoint);
	beginTransaction;
	job101.setOriginalJobAmount(50000);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 2 jobs in its jobsheet, the 2 jobs (100 and 101) should have 1 WLE each, prenote should have 2 WLEs
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 2, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["100"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 100");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	holdjob := jobSheet.allJobsByJobNum["101"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 101");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(clinkPrenote.allWorklistEntries.size, 2, "Clinker prenote has the wrong number of WLEs");
	// Check weight on the prenoted WLE
	// 30000 to 0201, 50000 to 0202
	count := null;
	foreach wle in clinkPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 30000.0000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		elseif count = 2 then
			qty := 50000.0000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0202 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.weight, qty, "Clinker WLE " &amp; count.String &amp; " has the wrong weight");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Clinker WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate the clinker in on 1 truck
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 100000.Decimal);
	self.opts.addAssoc("CargoWeight", 100000.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr1 := self.gateInPrenote(TruckId1, null, null, clinkPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	clinkOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkOnsite1, "No onsite Clinker cargo item");
	self.assertEqualMsg(clinkOnsite1.weight, 100000.0000.Decimal, "Clinker onsite weight is incorrect");
	self.assertEqualMsg(clinkOnsite1, clinkPrenote, "Onsite Clinker is not prenoted clinker");
	foreach wle in clinkOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 2, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	
	// Move some of the onsite cargo
	// Move from the truck to the holds (replicating the use of the Cargo Lander Mobile app)
	// First move - 40000 to 0201
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 40000 to hold 0201
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(clinkOnsite1, targetLocation, null, null, 40000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is still one TI onsite - weight 60000
	// 2. There is an onship TI in hold 0201 - weight 30000, with 2 WLEs (voyage and yard, both complete, both for 30000)
	// 3. There is an onship TI in hold 0202 - weight 10000, with 2 WLEs (voyage and yard, both complete, both for 10000)
	// 4. Road job for truck is Part Complete and has 2 complete yard WLEs (1 for 30000, 1 for 10000) and 1 unactioned WLE for 60000
	// 5. Job 100 is complete, with 1 completed voyage WLE for 30000, linked to the onship TI in 0201
	// 6. Job 101 is part complete, with 1 completed voyage WLE for 10000, linked to the onship TI in 0202, and 2 unactioned WLEs (1 for 40000, one for 20000)
	//	  The 20000 incomplete WLE has been created to cater for the 20000 left on the truck once all the planned weights are taken in to account
	moveCheck := MoveCheck &amp; "1: ";
	// 1. There is still one TI onsite - weight 60000
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "Wrong numbmer of onsite TIs");
	self.assertEqualMsg(clinkOnsite1.weight, 60000.0000.Decimal, moveCheck &amp; "Clinker onsite has the wrong weight");
	// 2. There is an onship TI in hold 0201 - weight 30000, with 2 WLEs (voyage and yard, both complete, both for 30000)
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	clinkin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(clinkin0201, "There is no onship Clinker in hold 0201");
	self.assertEqualMsg(clinkin0201.weight, 30000.0000.Decimal, moveCheck &amp; "Clinker in 0201 has the wrong weight");
	self.assertEqualMsg(clinkin0201.allWorklistEntries.size, 2, moveCheck &amp; "Clinker in 0201 has the wrong number of WLEs");
	voyageWleFound := false;
	yardWleFound := false;
	foreach wle in clinkin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.weight, 30000.0000.Decimal, moveCheck &amp; "Clinker in 0201 voyage WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0201 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.weight, 30000.0000.Decimal, moveCheck &amp; "Clinker in 0201 yard WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0201 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Clinker in 0201 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Clinker in 0201 has no yard WLE");
	// 3. There is an onship TI in hold 0202 - weight 10000, with 2 WLEs (voyage and yard, both complete, both for 10000)
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0202");
	clinkin0202 := hold0202.allTrackedItems.first;
	self.assertNotNullMsg(clinkin0202, "There is no onship Clinker in hold 0202");
	self.assertEqualMsg(clinkin0202.weight, 10000.0000.Decimal, moveCheck &amp; "Clinker in 0202 has the wrong weight");
	self.assertEqualMsg(clinkin0202.allWorklistEntries.size, 2, moveCheck &amp; "Clinker in 0202 has the wrong number of WLEs");
	voyageWleFound := false;
	yardWleFound := false;
	foreach wle in clinkin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.weight, 10000.0000.Decimal, moveCheck &amp; "Clinker in 0202 voyage WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0202 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.weight, 10000.0000.Decimal, moveCheck &amp; "Clinker in 0202 yard WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0202 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Clinker in 0202 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Clinker in 0202 has no yard WLE");
	// 4. Road job for truck is Part Complete and has 2 complete yard WLEs (1 for 30000, 1 for 10000) and 1 unactioned WLE for 60000
	roadjob := vvr1.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId1 &amp; " is null");
	self.assertEqualMsg(roadjob.status, JOB_PART_COMPLETE, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has wrong status - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 3, moveCheck &amp; "Road job has wrong number of WLEs");
	count := null;
	count2 := null;
	total := null;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			total := total + wle.weight;
		elseif wle.status = WLE_UNACTIONED then
			count2 := count2 + 1;
			self.assertEqualMsg(wle.weight, 60000.0000.Decimal, moveCheck &amp; "Unactioned WLE on road job has the wrong weight");
		endif;
	endforeach;
	self.assertEqualMsg(total, 40000.0000.Decimal, moveCheck &amp; "Completed WLEs on the road job have the wrong total weight");
	// 5. Job 100 is complete, with 1 completed voyage WLE for 30000, linked to the onship TI in 0201
	self.assertEqualMsg(job100.status, JOB_COMPLETE, moveCheck &amp; "Job 100 for hold 0201 is not complete - " &amp; job100.statusString);
	self.assertEqualMsg(job100.workListEntries.size, 1, moveCheck &amp; "Job 100 for hold 0201 has the wrong number of WLEs");
	wle := job100.workListEntries.first;
	self.assertNotNullMsg(wle, moveCheck &amp; "There is no WLE for job 100 in hold 0201");
	self.assertEqualMsg(wle.weight, 30000.0000.Decimal, moveCheck &amp; "WLE for job 100 has the wrong weight");
	self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Wle for job 100 in hold 0201 has the wrong status - " &amp; wle.statusString);
	self.assertEqualMsg(wle.myTrackedItem, clinkin0201, "WLE for job 100 in 0201 is linked to the wrong TI");
	self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 100 in 0201 has the wrong subSeqNum");
	// 6. Job 101 is part complete, with 1 completed voyage WLE for 10000, linked to the onship TI in 0202, and 2 unactioned WLEs (1 for 40000, one for 20000)
	//	  The 20000 incomplete WLE has been created to cater for the 20000 left on the truck once all the planned weights are taken in to account
	self.assertEqualMsg(job101.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 101 for hold 0202 has the wrong status - " &amp; job101.statusString);
	self.assertEqualMsg(job101.workListEntries.size, 3, moveCheck &amp; "Job 101 for hold 0202 has the wrong number of WLEs");
	count := null;
	count2 := null;
	total := null;
	foreach wle in job101.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			self.assertEqualMsg(wle.weight, 10000.0000.Decimal, moveCheck &amp; "Completed WLE for job 101 has the wrong weight");
			self.assertEqualMsg(wle.myTrackedItem, clinkin0202, moveCheck &amp; "Completed WLE for job 101 is linked to the wrong TI");
		elseif wle.status = WLE_UNACTIONED then
			count2 := count2 + 1;
			total := total + wle.CM_VoyageWLE.subSeqNum;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 101 has the wrong number of complete WLEs");
	self.assertEqualMsg(count2, 2, moveCheck &amp; "Job 101 has the wrong number of unactioned WLEs");
	self.assertEqualMsg(total, 60000.0000.Decimal, moveCheck &amp; "Job 101 unactioned WLEs have the wrong total weight");
	
	// second move - move the remaining 60000 to hold 0202
	// this will complete the 2 outstanding WLEs on job 101
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(clinkOnsite1, targetLocation, null, null, 60000);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is no onsite TI
	// 2. There is still 1 TI in hold 0201, still weight 30000
	// 3. There is still 1 TI in hold 0202, but now its weight is 70000
	// 4. Road job is complete, with 4 completed road WLEs (30000, 10000, 20000, 40000)
	// 5. Job 101 is complete, with 3 completed voyage WLEs for 10000, 20000 and 40000
	// 6. TI in hold 0202 has 3 completed voyage WLEs for 10000, 20000 and 40000
	moveCheck := MoveCheck &amp; "2: ";
	// 1. There is no onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 0, moveCheck &amp; "There is still an onsite TI");
	// 2. There is still 1 TI in hold 0201, still weight 30000
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0201");
	clinkin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(clinkin0201, moveCheck &amp; "There is no TI in hold 0201");
	self.assertEqualMsg(clinkin0201.weight, 30000.0000.Decimal, moveCheck &amp; "Clinker in 0201 has the wrong weight");
	// 3. There is still 1 TI in hold 0202, but now its weight is 70000
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0202");
	clinkin0202 := hold0202.allTrackedItems.first;
	self.assertNotNullMsg(clinkin0202, moveCheck &amp; "There is no TI in hold 0202");
	self.assertEqualMsg(clinkin0202.weight, 70000.0000.Decimal, moveCheck &amp; "Clinker in 0202 has the wrong weight");
	// 4. Road job is complete, with 4 completed road WLEs (30000, 10000, 20000, 40000)
	roadjob := vvr1.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 4, moveCheck &amp; "Road job has the wrong number of WLEs");
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	correctQty3 := false;
	correctQty4 := false;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 30000.0000.Decimal then
				correctQty1 := true;
			elseif wle.weight = 10000.0000.Decimal then
				correctQty2 := true;
			elseif wle.weight = 20000.0000.Decimal then
				correctQty3 := true;
			elseif wle.weight = 40000.0000.Decimal then
				correctQty4 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 4, moveCheck &amp; "Road job has wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2 and correctQty3 and correctQty4, true, "Road job completed WLE weights are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT &amp; ":" &amp; correctQty3.asStringJMT &amp; ":" &amp; correctQty4.asStringJMT);
	// 5. Job 101 is complete, with 3 completed voyage WLEs for 10000, 20000 and 40000
	self.assertEqualMsg(job101.status, JOB_COMPLETE, moveCheck &amp; "Job 101 has the wrong status - " &amp; job101.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	correctQty3 := false;
	foreach wle in job101.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 10000.0000.Decimal then
				correctQty1 := true;
			elseif wle.weight = 20000.0000.Decimal then
				correctQty2 := true;
			elseif wle.weight = 40000.0000.Decimal then
				correctQty3 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, moveCheck &amp; "Job 101 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2 and correctQty3, true, "Job 101 completed WLEs weights are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT &amp; ":" &amp; correctQty3.asStringJMT);
	// 6. TI in hold 0202 has 3 completed voyage WLEs for 10000, 20000 and 40000
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	correctQty3 := false;
	foreach wle in clinkin0202.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 10000.0000.Decimal then
				correctQty1 := true;
			elseif wle.weight = 20000.0000.Decimal then
				correctQty2 := true;
			elseif wle.weight = 40000.0000.Decimal then
				correctQty3 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, moveCheck &amp; "Clinker in hold 0202 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2 and correctQty3, true, "Clinker in hold 0202 completed WLEs weights are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT &amp; ":" &amp; correctQty3.asStringJMT);
	
	// Road exit the truck - all cargo gone
	self.roadExit(vvr1);
	
	////////////////////////
	// Finished - Tidy up //
	////////////////////////
	self.deleteWorkPoint(ThisWorkPoint);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteVehicle(TruckId1);
	
epilog
	delete allocatedWLEs;
	delete mobileAgent;
	self.setTerminalConfig(DirectTruck2VesselMult, directTruckMoves);
	app.myPassport.setMyTerminal(passportTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="tSalalahDirectToShipWgt4" id="865ebd05-8c49-4ae0-b270-49e4ed94da84">
        <source>tSalalahDirectToShipWgt4();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17 February 2022	navdap1		Initial creation TFS 52801 Direct Delivery - End of Shift Job Transfer
//
constants
	ThisVoyageCode : String = "DAVEH52293_8";
	ThisVesselCode : String = "DAVEHOLD";
	CLINKER : String = "CLINKER";
	ClinkerId1 : String = "CLINKERDD52293_8_1";
	ThisWorkPoint : String = "WP52293_8";
	TruckId1 : String = "UT52293_8_1";
	TruckId2 : String = "UT52293_8_2";
	TruckId3 : String = "UT52293_8_3";
	MoveCheck : String = "Move Check ";
	
vars
	terminal, passportTerminal : CM_Terminal;
	directTruckMoves : Boolean;
	operator : CM_Operator;
	rebarCargoType : CM_CargoType;
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	clinkerPrenote, clinkerOnsite1, clinkerOnsite2, clinkerOnsite3, clinkerin0201, clinkerin0202 : CM_TrackedItem;
	hold0201, hold0202 : CM_GeneralCargoController;
	hold0201Str, hold0202Str : String;
	voyageWle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	allocatedWLEs : CM_WLEArray;
	allocatedTIs : CM_TISet;
	jobSheet : CM_VoyageHoldJobSheet;
	holdjob : CM_VoyageJob;
	count, count2 : Integer;
	qty, total : Decimal [14,4];
	loc : String;
	mobileAgent : CMIF_MobileGenericAgent;
	targetLocation : CM_LocationsController;
	yardWLE : CM_YardWLE;
	voyageWleFound, yardWleFound : Boolean;
	roadjob : CM_RoadJob;
	correctQty1, correctQty2, correctQty3, correctQty4 : Boolean;
	vvr1, vvr2, vvr3, vvr4 : CM_VehicleVisitRecord;
	moveCheck : String;
	job100, pxyJob100, job101 : CM_VoyageHoldJob;
	truck1, truck2, truck3 : CM_Vehicle;
	jobParams : CMIF_VoyageJobParams;
	realShift, pxyShift : CM_Shift;

begin
	// Set the terminal config that drives all of this
	terminal := self.getTerminal;
	directTruckMoves := self.setTerminalConfig(DirectTruck2VesselMult, true).Boolean;
	//return;
	///////////////////////////////////////
	// Sanity Check and Pre-run Clean Up //
	///////////////////////////////////////
	rebarCargoType := app.myRoot.getCargoTypeFromAbbrev(CLINKER);
	self.assertTrueMsg(rebarCargoType &lt;&gt; null, CLINKER &amp; "does not exist as a Cargo Type");
	
	self.opts.purge;
	self.opts.addAssoc("includePrenote", true);
	self.deleteCargo(ClinkerId1, rebarCargoType);
	self.deleteVehicle(TruckId1);
	self.deleteVehicle(TruckId2);
	self.deleteVehicle(TruckId3);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteWorkPoint(ThisWorkPoint);
	self.assertTrueMsg(self.getVoyage(ThisVoyageCode) = null, "Voyage " &amp; ThisVoyageCode &amp; " not deleted");
	
	////////////
	// Set Up //
	////////////
	// Create a Voyage with Holds
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage := self.addVoyageWithGeneralCargoStruc(ThisVoyageCode, ThisVesselCode, operator.code, "DOUG", 2);
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage not created");
	self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null and voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.size = 10, "General Cargo voyage not set up correctly");
	// and a workpoint
	workPoint := self.addWorkPoint(ThisWorkPoint, false);
	self.assertTrueMsg(workPoint &lt;&gt; null, "Work Point not created");
	
	hold0201 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,1];
	hold0202 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[2,2];
	hold0201Str := hold0201.getFullId;
	hold0202Str := hold0202.getFullId;
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////
	// TEST: Plan all the cargo to one hold, bring some of the prenote in on three trucks               //
	// Move two of the trucks to the hold job, then remove and replan the prenote to another hold job.  //
	// Move the last truck (which should be planned to the new job) and the rest of the prenote.        //
	//////////////////////////////////////////////////////////////////////////////////////////////////////
	// Create a prenote for the voyage splittable by weight
	self.opts.purge;
	self.opts.addAssoc("CargoType", rebarCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 1000);
	self.opts.addAssoc("CargoWeight", 1000);
	self.opts.addAssoc("TareWeight", 0);
	self.opts.addAssoc("DD", true);
	clinkerPrenote := self.addPrenoted(ClinkerId1);
	self.assertTrueMsg(clinkerPrenote &lt;&gt; null, "Clinker prenote not created");
	self.assertEqualMsg(clinkerPrenote.weight, 1000.0000.Decimal, "Clinker prenote weight is incorrect");
	self.assertTrueMsg(clinkerPrenote.directDelivery = true, "Clinker prenote is not Direct Delivery");
	
	// Plan the prenote to one hold
	// Load job 100 to 0201: 1000
	create allocatedWLEs transient;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkerPrenote);
	voyageWle.setWeight(1000.0000);
	allocatedWLEs.add(voyageWle);
	job100 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0201, workPoint);
	beginTransaction;
	job100.setOriginalJobAmount(1000);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 1 job in its jobsheet, the job should have 1 WLE, prenote should have 1 WLE
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 1, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["100"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 100");
	self.assertEqualMsg(holdjob.workListEntries.size, 1, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(clinkerPrenote.allWorklistEntries.size, 1, "Rebar prenote has the wrong number of WLEs");
	// Check weight on the prenoted WLE
	// 1000 to 0201
	count := null;
	foreach wle in clinkerPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 1000.0000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0201 Under Deck";
		endif;
		self.assertEqualMsg(voyageWle.weight, qty, "Clinker WLE " &amp; count.String &amp; " has the wrong weight");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Clinker WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	count := null;
	
	// Gate some of the Clinker in on 3 trucks
	// Truck 1 - 40 
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 40.Decimal);
	self.opts.addAssoc("CargoWeight", 40.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr1 := self.gateInPrenote(TruckId1, null, null, clinkerPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr1.myRoadJob.myVehicle;
	clinkerOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkerOnsite1, "No onsite Clinker cargo item for weight 40");
	self.assertEqualMsg(clinkerOnsite1.weight, 40.0000.Decimal, "Clinker onsite weight 1 is incorrect");
	foreach wle in clinkerOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck1 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	// Truck 2 - 90
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 90.Decimal);
	self.opts.addAssoc("CargoWeight", 90.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr2 := self.gateInPrenote(TruckId2, null, null, clinkerPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck2 := vvr2.myRoadJob.myVehicle;
	clinkerOnsite2 := truck2.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkerOnsite2, "No onsite Clinker cargo item for weight 90");
	self.assertEqualMsg(clinkerOnsite2.weight, 90.0000.Decimal, "Clinker onsite weight 2 is incorrect");
	foreach wle in clinkerOnsite2.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck2 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Truck2 Yard WLE has an incorrect number of direct delivery WLEs");
	// Truck 3 - 70
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 70.Decimal);
	self.opts.addAssoc("CargoWeight", 70.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr3 := self.gateInPrenote(TruckId3, null, null, clinkerPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck3 := vvr3.myRoadJob.myVehicle;
	clinkerOnsite3 := truck3.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkerOnsite3, "No onsite Clinker cargo item for weight 70");
	self.assertEqualMsg(clinkerOnsite3.weight, 70.0000.Decimal, "Clinker onsite weight 3 is incorrect");
	foreach wle in clinkerOnsite3.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Truck3 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Truck3 Yard WLE has an incorrect number of direct delivery WLEs");
	
	// Move some of the onsite cargo
	// Move from the truck to the holds (replicating the use of the Cargo Lander Mobile app)
	// First move from truck1 - 40 to 0201
	delete mobileAgent;
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setDoNotShowMsgBox(true);
	// first move - 40 from truck 1 to hold 0201
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(clinkerOnsite1, targetLocation, null, null, 40);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are still two TIs onsite - weight 160
	// 2. There is an onship TI in hold 0201 - weight 40, with 2 WLEs (voyage and yard, both complete, both for 40)
	// 3. Road job for truck1 is Complete and has 1 complete yard WLE for 40
	// 4. Job 100 is part complete, with 1 completed voyage WLE for 40, linked to the onship TI in 0201
	moveCheck := MoveCheck &amp; "1: ";
	// 1. There are still two TIs onsite - weight 160
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 2, moveCheck &amp; "Wrong numbmer of onsite TIs");
	self.assertEqualMsg(clinkerOnsite2.site, TI_SITE_ONSITE, moveCheck &amp; "Clinker onsite 2 has incorrect site - " &amp; app.siteEnumToString(clinkerOnsite2.site));
	self.assertEqualMsg(clinkerOnsite2.weight, 90.0000.Decimal, moveCheck &amp; "Clinker onsite 2 has the wrong weight");
	self.assertEqualMsg(clinkerOnsite3.site, TI_SITE_ONSITE, moveCheck &amp; "Clinker onsite 3 has incorrect site - " &amp; app.siteEnumToString(clinkerOnsite3.site));
	self.assertEqualMsg(clinkerOnsite3.weight, 70.0000.Decimal, moveCheck &amp; "Clinker onsite 3 has the wrong weight");
	// 2. There is an onship TI in hold 0201 - weight 40, with 2 WLEs (voyage and yard, both complete, both for 40)
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "Wrong number of onship TIs in hold 0201");
	clinkerin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(clinkerin0201, "There is no onship Clinker in hold 0201");
	self.assertEqualMsg(clinkerin0201.weight, 40.0000.Decimal, moveCheck &amp; "Clinker in 0201 has the wrong weight");
	self.assertEqualMsg(clinkerin0201.allWorklistEntries.size, 2, moveCheck &amp; "Clinker in 0201 has the wrong number of WLEs");
	voyageWleFound := false;
	yardWleFound := false;
	foreach wle in clinkerin0201.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			voyageWleFound := true;
			self.assertEqualMsg(wle.weight, 40.0000.Decimal, moveCheck &amp; "Clinker in 0201 voyage WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinker in 0201 voyage WLE not completed");
		elseif wle.isKindOf(CM_YardWLE) then
			yardWleFound := true;
			self.assertEqualMsg(wle.weight, 40.0000.Decimal, moveCheck &amp; "Clinker in 0201 yard WLE weight is wrong");
			self.assertEqualMsg(wle.status, WLE_COMPLETED, moveCheck &amp; "Clinkerin 0201 yard WLE not completed");
		endif;
	endforeach;
	self.assertEqualMsg(voyageWleFound, true, moveCheck &amp; "Clinker in 0201 has no voyage WLE");
	self.assertEqualMsg(yardWleFound, true, moveCheck &amp; "Clinker in 0201 has no yard WLE");
	// 3. Road job for truck1 is Complete and has 1 complete yard WLE for 40
	roadjob := vvr1.myRoadJob;
	self.assertNotNullMsg(roadjob, moveCheck &amp; "Road Job for Truck " &amp; TruckId1 &amp; " is null");
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for " &amp; TruckId1 &amp; " has wrong status - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has wrong number of WLEs");
	count := null;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			total := total + wle.weight;
		endif;
	endforeach;
	self.assertEqualMsg(total, 40.0000.Decimal, moveCheck &amp; "Completed WLE on the road job has the wrong total weight");
	// 4. Job 100 is part complete, with 1 completed voyage WLE for 40, linked to the onship TI in 0201
	self.assertEqualMsg(job100.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 100 for hold 0201 is not part complete - " &amp; job100.statusString);
	count := null;
	correctQty1 := false;
	foreach wle in job100.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 40.0000.Decimal then
				correctQty1 := true;
				self.assertEqualMsg(wle.myTrackedItem, clinkerin0201, "WLE for job 100 in 0201 is linked to the wrong TI");
				self.assertEqualMsg(wle.CM_VoyageWLE.subSeqNum, 0, moveCheck &amp; "WLE for job 100 in 0201 has the wrong subSeqNum");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 100 for hold 0201 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Completed WLE for job 100 has the wrong weight");
	
	// second move - move the 90 from truck 2 to hold 0201
	targetLocation := hold0201;
	mobileAgent.doLanderLoad(clinkerOnsite2, targetLocation, null, null, 90);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is still 1 onsite TI
	// 2. There is still 1 TI in hold 0201, now weight 130
	// 3. Road job for truck 2 is complete, with 1 completed road WLE for 90
	// 4. Job 100 is part complete, with 2 completed voyage WLEs for 40 and 90
	// 5. TI in hold 0201 has 2 completed voyage WLEs for 40 and 90
	// 6. Prenote should have weight 800
	// 7. Unactioned WLE on job 100 should have weight 800
	moveCheck := MoveCheck &amp; "2: ";
	// 1. There is still 1 onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 1, moveCheck &amp; "There is the wrong number of onsite TIs");
	// 2. There is still 1 TI in hold 0201, now weight 130
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0201");
	clinkerin0201 := hold0201.allTrackedItems.first;
	self.assertNotNullMsg(clinkerin0201, moveCheck &amp; "There is no TI in hold 0201");
	self.assertEqualMsg(clinkerin0201.weight, 130.0000.Decimal, moveCheck &amp; "Clinker in 0201 has the wrong weight");
	// 3. Road job for truck 2 is complete, with 1 completed road WLE for 90
	roadjob := vvr2.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job is not complete - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job has the wrong number of WLEs");
	count := null;
	correctQty1 := false;
	foreach wle in roadjob.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 90.0000.Decimal then
				correctQty1 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Road job 2 has wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1, true, "Road job completed WLE weight is wrong");
	// 4. Job 100 is part complete, with 2 completed voyage WLEs for 40 and 90
	self.assertEqualMsg(job100.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 100 has the wrong status - " &amp; job100.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job100.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 40.0000.Decimal then
				correctQty1 := true;
			elseif wle.weight = 90.0000.Decimal then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 100 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "Job 100 completed WLEs weights are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 5. TI in hold 0201 has 2 completed voyage WLEs for 40 and 90
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in clinkerin0201.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 40.0000.Decimal then
				correctQty1 := true;
			elseif wle.weight = 90.0000.Decimal then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Clinker in hold 0201 has the wrong number of completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "Clinker in hold 0201 completed WLEs weights are wrong - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	// 6. Prenote should have weight 800
	self.assertEqualMsg(clinkerPrenote.weight, 800.0000.Decimal, moveCheck &amp; "Prenote clinker has incorrect weight - " &amp; clinkerPrenote.weight.String);
	// 7. Unactioned WLE on job 100 should have weight 800
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job100.workListEntries where wle.status = WLE_UNACTIONED and not wle.myTrackedItem.hasBeenMerged do
		count := count + 1;
		if wle.weight = 870.0000.Decimal then
			correctQty1 := true;
		elseif wle.weight = 70.0000.Decimal then
			correctQty2 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 100 has the wrong number of unactioned WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Job 100 unactioned WLE has the wrong weight - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	
	// Edit the 0201 hold job to remove the prenote WLE
	allocatedWLEs.purge;
	create allocatedTIs transient;
	foreach wle in job100.workListEntries where wle.status = WLE_COMPLETED do
		if wle.myTrackedItem &lt;&gt; null then
			allocatedTIs.addNoDuplicates(wle.myTrackedItem, false);
		endif;
	endforeach;
	pxyJob100 := app.createUpdateProxy(job100).CM_VoyageHoldJob;
	pxyJob100.setProxy(job100.jobNum, job100.jobType);
	pxyJob100.setProxyVoyage(job100.myVoyage);
	pxyJob100.setProxyVoyageHoldJob(null, job100.jobNum, job100.remarks, null, false, job100.jobType, null, null, job100.actualStartTs, job100.actualEndTs, false, job100.myShift, null, allocatedTIs, null, null);
	pxyJob100.setTransferType(job100.transferType);
	pxyJob100.setIsDirectDelivery(true);
	pxyJob100.setOriginalJobAmount(job100.originalJobAmount);
	realShift := job100.myShift;
	pxyShift := app.createUpdateProxy(realShift).CM_Shift;
	pxyShift.setProxy(realShift.startDateTime.date.day, realShift.startDateTime.time, realShift.endDateTime.time, realShift.code, realShift.description, realShift.myTerminal, realShift.ignore);
	pxyJob100.setMyShift(pxyShift);
	create jobParams transient;
	jobParams.myLocation := hold0201;
	jobParams.myVoyage := pxyJob100.myVoyage;
	jobParams.myProxyJob := pxyJob100;
	jobParams.autoSortIntoOOW := false;
	jobParams.craneID := null;
	jobParams.myJobType := null;
	jobParams.remarks := job100.remarks;
	jobParams.myWorkPoint := job100.getMyWorkPointObject().CM_WorkPoint;
	jobParams.craneID := job100.getMyWorkPointObject.CM_WorkPoint.code;
	jobParams.allowOutOfOrderLoading := false;
	jobParams.transitStatus := TI_TransitStatusNull;
	jobParams.isDischarge := false;
	jobParams.isDirectDelivery := true;
	jobParams.originalJobAmount := pxyJob100.originalJobAmount;
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxUpdateVoyageHoldJob(jobParams, pxyJob100, job100, app.myPassport, allocatedWLEs);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Check:
	// 1. Prenote should no longer be Direct Delivery
	// 2. Onsite TI should no longer be Direct Delivery
	// 3. Job 100 should be Completed, with 2 completed Voyage WLEs for 40 and 90
	// 1. Prenote should no longer be Direct Delivery
	self.assertEqualMsg(clinkerPrenote.directDelivery, false, "After completing Job 100: Prenote is still Direct Delivery");
	// 2. Onsite TI should no longer be Direct Delivery
	self.assertEqualMsg(clinkerOnsite3.directDelivery, false, "After completing Job 100: TI still on site is still Direct Delivery");
	// 3. Job 100 should be Completed, with 2 completed Voyage WLEs for 40 and 90
	self.assertEqualMsg(job100.status, JOB_COMPLETE, "After completing Job 100: Job 100 is not Complete - " &amp; job100.statusString);
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job100.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 40.0000.Decimal then
				correctQty1 := true;
			elseif wle.weight = 90.0000.Decimal then
				correctQty2 := true;
			endif;
		else
			count2 := count2 + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "After completing Job 100: Job 100 has the wrong number of Complete WLEs");
	self.assertEqualMsg(count2, 0, "After completing Job 100: Job 100 has the wrong number of incomplete WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, "After completing Job 100: Job 100 WLEs have the wrong weight - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	
	// Take a break - to allow timestamps to be different between the receival date of the cargo on site and the newly created voyage WLE for the prenote
	process.sleep(1000);
	
	// Create a new hold job in 0202 and plan the entire remaining prenote to it
	// Load job 101 to 0202: 800
	allocatedWLEs.purge;
	create voyageWle transient;
	voyageWle.setMyTrackedItem(clinkerPrenote);
	voyageWle.setWeight(800.0000.Decimal);
	allocatedWLEs.add(voyageWle);
	job101 := self.addVoyageHoldJob(JOB_TYPE_LOAD, voyage, allocatedWLEs, hold0202, workPoint);
	beginTransaction;
	job101.setOriginalJobAmount(800);
	commitTransaction;
	allocatedWLEs.purge;
	
	// Check - voyage should have 2 jobs in its jobsheet, job 101 should have 2 WLEs (1 for 800 and 1 for 70), prenote should have 1 WLE
	// Onsite TI clinkerOnsite3 should be Direct Delivery, and have one voyage WLE planned to 0202
	// Road job for onsite TI clinkerOnsite3 should have 1 yard WLE which should have 1 allDirectDeliveryChildWLEs entry
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 2, "Voyage Job sheet has the wrong number of jobs");
	holdjob := jobSheet.allJobsByJobNum["101"];
	self.assertNotNullMsg(holdjob, "No Hold Job found for 101");
	self.assertEqualMsg(holdjob.workListEntries.size, 2, "Hold job " &amp; holdjob.id &amp; " has wrong number of WLEs");
	self.assertEqualMsg(clinkerPrenote.allWorklistEntries.size, 1, "Clinker prenote has the wrong number of WLEs");
	self.assertEqualMsg(holdjob, job101, "Hold job found with key '101' is not the hold job created as job101");
	// Check quantity on the prenoted WLE
	// 800 to 0202
	count := null;
	foreach wle in clinkerPrenote.allWorklistEntries do
		voyageWle := wle.CM_VoyageWLE;
		count := count + 1;
		if count = 1 then
			qty := 800.000.Decimal;
			loc := ThisVoyageCode &amp; Space &amp; "0202 On Deck";
		endif;
		self.assertEqualMsg(voyageWle.weight, qty, "Clinker WLE " &amp; count.String &amp; " has the wrong weight");
		self.assertEqualMsg(voyageWle.locationTarget, loc, "Clinker WLE " &amp; count.String &amp; " has the wrong target location");
	endforeach;
	// check remaining TI on site is now direct delivery, has 1 voyage WLE for job 101 for 70
	self.assertEqualMsg(clinkerOnsite3.directDelivery, true, "Clinker left on site is not Direct Delivery");
	count := null;
	correctQty1 := false;
	foreach wle in clinkerOnsite3.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		count := count + 1;
		if wle.weight = 70.0000.Decimal then
			correctQty1 := true;
			self.assertEqualMsg(wle.locationTarget, hold0202Str, "Remaining Onsite TI is planned to the wrong location");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Remaining Onsite TI has the wrong number of voyage WLEs");
	self.assertEqualMsg(correctQty1, true, "Remaining Onsite TI has the wrong weight");
	roadjob := vvr3.myRoadJob;
	self.assertEqualMsg(roadjob.workListEntries.size, 1, "Road job for truck 3 has the wrong number of WLEs");
	self.assertEqualMsg(roadjob.workListEntries.first.allDirectDeliveryChildWLEs.size, 1, "Yard WLE for the remaining onsite cargo has the wrong number of direct delivery child WLEs");
	
	// Move the cargo on truck 3 - should complete the road job, part complete the new job 101 and create a new onship cargo item
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(clinkerOnsite3, targetLocation, null, null, 70);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There is no onsite TI
	// 2. There is still 1 TI in hold 0201, weight 130
	// 3. There is a new TI in hold 0202, weight 70
	// 4. Road job for truck 3 is complete, with 1 completed road WLE for 70 and no direct delivery children
	// 5. Job 101 is part complete, with 1 completed voyage WLEs for 70
	// 6. TI in hold 0202 has 1 completed voyage WLE for 70 and 1 completed yard WLE for 70
	// 7. Prenote should still have weight 800
	// 8. Unactioned WLE on job 101 should have weight 800
	moveCheck := MoveCheck &amp; "3: ";
	// 1. There is no onsite TI
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 0, moveCheck &amp; "There is still an onsite cargo item");
	// 2. There is still 1 TI in hold 0201, weight 130
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0201");
	self.assertEqualMsg(hold0201.allTrackedItems.first.weight, 130.0000.Decimal, moveCheck &amp; "The TI in hold 0201 has the wrong weight");
	// 3. There is a new TI in hold 0202, weight 70
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in hold 0202");
	self.assertEqualMsg(hold0202.allTrackedItems.first.weight, 70.0000.Decimal, moveCheck &amp; "The TI in hold 0202 has the wrong weight");
	// 4. Road job for truck 3 is complete, with 1 completed road WLE for 70 and no direct delivery children
	roadjob := vvr3.myRoadJob;
	self.assertEqualMsg(roadjob.status, JOB_COMPLETE, moveCheck &amp; "Road job for clinkerOnsite3 has the wrong status - " &amp; roadjob.statusString);
	self.assertEqualMsg(roadjob.workListEntries.size, 1, moveCheck &amp; "Road job for clinkerOnsite3 has the wrong number of WLEs");
	wle := roadjob.workListEntries.first;
	self.assertEqualMsg(wle.weight, 70.0000.Decimal, moveCheck &amp; "Yard WLE for road job 3 has the wrong weight - " &amp; wle.weight.String);
	self.assertEqualMsg(wle.allDirectDeliveryChildWLEs.size, null, moveCheck &amp; "Yard WLE for road job 3 still has direct delivery children");
	// 5. Job 101 is part complete, with 1 completed voyage WLEs for 70
	self.assertEqualMsg(job101.status, JOB_PART_COMPLETE, moveCheck &amp; "Job 101 has the wrong status - " &amp; job101.statusString);
	count := null;
	correctQty1 := false;
	foreach wle in job101.workListEntries where wle.status = WLE_COMPLETED do
		count := count + 1;
		if wle.weight = 70.0000.Decimal then
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Job 101 has the wrong number of completed WLEs - " &amp; count.String);
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Completed WLE for job 101 has the wrong weight");
	// 6. TI in hold 0202 has 1 completed voyage WLE for 70 and 1 completed yard WLE for 70
	clinkerin0202 := hold0202.allTrackedItems.first;
	self.assertNotNullMsg(clinkerin0202, moveCheck &amp; "There is no clinker in hold 0202");
	self.assertEqualMsg(clinkerin0202.allWorklistEntries.size, 2, moveCheck &amp; "Clinker in 0202 has the wrong number of WLEs");
	count := null;
	count2 := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in clinkerin0202.allWorklistEntries do
		if wle.isKindOf(CM_VoyageWLE) then
			count := count + 1;
			correctQty1 := wle.weight = 70.0000.Decimal;
		elseif wle.isKindOf(CM_YardWLE) then
			count2 := count2 + 1;
			correctQty2 := wle.weight = 70.0000.Decimal;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "Clinker in 0202 has the wrong number of Voyage WLEs");
	self.assertEqualMsg(count2, 1, moveCheck &amp; "Clinker in 0202 has the wrong number of Yard WLEs");
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "Voyage WLE for Clinker in 0202 has the wrong weight");
	self.assertEqualMsg(correctQty2, true, moveCheck &amp; "Yard WLE for Clinker in 0202 has the wrong weight");
	// 7. Prenote should still have weight 800
	self.assertEqualMsg(clinkerPrenote.weight, 800.0000.Decimal, moveCheck &amp; "Prenote has the wrong weight");
	// 8. Unactioned WLE on job 101 should have weight 800
	count := null;
	correctQty1 := false;
	foreach wle in job101.workListEntries where wle.status = WLE_UNACTIONED do
		count := count + 1;
		if wle.weight = 800.0000.Decimal then
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, moveCheck &amp; "There is the wrong number of unactioned WLEs on job 101");
	self.assertEqualMsg(correctQty1, true, moveCheck &amp; "The unactioned WLE on job 101 has the wrong weight");
	
	// Road exit the current trucks 
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	self.roadExit(vvr3);
	
	// Gate in the remaining prenote weight - 800
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 800.Decimal);
	self.opts.addAssoc("CargoWeight", 800.Decimal);
	self.opts.addAssoc("TareWeight", 0.Decimal);
	vvr4 := self.gateInPrenote(TruckId1, null, null, clinkerPrenote, self.getProfileSetting(UT_Profile.P_SGATE).asString);
	truck1 := vvr4.myRoadJob.myVehicle;
	clinkerOnsite1 := truck1.locationsController.allTrackedItems.first;
	self.assertNotNullMsg(clinkerOnsite1, "Final Prenote brought onsite: No onsite Clinker cargo item for weight 800");
	self.assertEqualMsg(clinkerOnsite1.weight, 800.0000.Decimal, "Final Prenote brought onsite: Clinker onsite weight is incorrect");
	foreach wle in clinkerOnsite1.allWorklistEntries where wle.isKindOf(CM_YardWLE) do
		yardWLE := wle.CM_YardWLE;
		break;
	endforeach;
	self.assertNotNullMsg(yardWLE, "Final Prenote brought onsite: Truck1 Clinker onsite has no yard WLE");
	self.assertEqualMsg(yardWLE.allDirectDeliveryChildWLEs.size, 1, "Final Prenote brought onsite: Truck1 Yard WLE has an incorrect number of direct delivery WLEs");
	count := null;
	correctQty1 := false;
	foreach wle in clinkerOnsite1.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
		count := count + 1;
		if wle.weight = 800.0000.Decimal then
			correctQty1 := true;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Final Prenote brought onsite: Rebar Onsite has the wrong number of WLEs");
	self.assertEqualMsg(correctQty1, true, "Final Prenote brought onsite: Rebar onsite WLE has the wrong weight");
	self.assertTrueMsg(voyage.allNotifiedTIsByIdCargoType.isEmpty, "Final Prenote brought onsite: There is still some prenoted cargo");
	
	// Move the entire onsite weight to hold 0202
	targetLocation := hold0202;
	mobileAgent.doLanderLoad(clinkerOnsite1, targetLocation, null, null, 800);
	self.assertNullMsg(app.myPassport.getErrorsAsString, "1: Errors - " &amp; app.myPassport.getErrorsAsString);
	// Things to check:
	// 1. There are no onsite TIs
	// 2. There are 2 onship TIs - 1 for 130 in hold 0201, 1 for 870 in hold 0202
	// 3. Job 101 is Complete, with 2 completed voyage WLEs for 70 and 800
	// 4. Road job is complete, with 1 yard WLE for 800
	moveCheck := MoveCheck &amp; "4: ";
	// 1. There are no onsite TIs
	self.assertTrueMsg(voyage.allOnsiteTIsByIdCargoType.isEmpty, moveCheck &amp; "There is still at least 1 onsite TI");
	// 2. There are 2 onship TIs - 1 for 130 in hold 0201, 1 for 870 in hold 0202
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 2, moveCheck &amp; "There is the wrong number of onship TIs");
	self.assertEqualMsg(hold0201.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in Hold 0201");
	self.assertEqualMsg(hold0202.allTrackedItems.size, 1, moveCheck &amp; "There is the wrong number of TIs in Hold 0202");
	clinkerin0201 := hold0201.allTrackedItems.first;
	self.assertEqualMsg(clinkerin0201.weight, 130.0000.Decimal, moveCheck &amp; "TI in hold 0201 has the wrong weight");
	clinkerin0202 := hold0202.allTrackedItems.first;
	self.assertEqualMsg(clinkerin0202.weight, 870.0000.Decimal, moveCheck &amp; "TI in hold 0202 has the wrong weight");
	// 3. Job 101 is Complete, with 2 completed voyage WLEs for 70 and 800
	self.assertEqualMsg(job101.status, JOB_COMPLETE, moveCheck &amp; "Job 101 has the wrong status - " &amp; job101.statusString);
	count := null;
	correctQty1 := false;
	correctQty2 := false;
	foreach wle in job101.workListEntries do
		if wle.status = WLE_COMPLETED then
			count := count + 1;
			if wle.weight = 70.000.Decimal then
				correctQty1 := true;
			elseif wle.weight = 800.0000.Decimal then
				correctQty2 := true;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, moveCheck &amp; "Job 101 has the incorrect number of Completed WLEs");
	self.assertEqualMsg(correctQty1 and correctQty2, true, moveCheck &amp; "Job 101 WLEs have incorrect weights - " &amp; correctQty1.asStringJMT &amp; ":" &amp; correctQty2.asStringJMT);
	
	////////////////////////
	// Finished - Tidy up //
	////////////////////////
	self.deleteWorkPoint(ThisWorkPoint);
	self.deleteVoyage(ThisVoyageCode);
	self.deleteVehicle(TruckId1);
	self.deleteVehicle(TruckId2);
	self.deleteVehicle(TruckId3);
	
epilog
	delete allocatedWLEs;
	delete mobileAgent;
	delete jobParams;
	delete pxyJob100;
	delete pxyShift;
	delete allocatedTIs;
	self.setTerminalConfig(DirectTruck2VesselMult, directTruckMoves);
	app.myPassport.setMyTerminal(passportTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateRequestDetails" id="8ee89090-0464-4f32-8451-c2a73e6f6096">
        <source>tUpdateRequestDetails();
/*

Purpose:	Create Release request and update DelivertyRequest Details 		

Date		Who		Reason
15/04/2014	cnwma1	Initial creation

*/
constants
	TRK 			= "TRK0999";
	RoadRelRequest	= "UTMAREL1";
	DriverId		= "MA";	
	BlockStack		= "UTBS777";
vars

   releaseRequest	: CM_BulkRelease;
   vvr	 			: CM_VehicleVisitRecord;
   gate  			: CM_Gate;
   pxyDeliveryRequest,
   deliveryRequest	: CM_DeliveryRequest;
   operator 		: CM_Operator;
   request		    : CM_Request;
   wleArray			: CM_WLEArray;
   termArray 		: CM_TerminalAreaArray;
   bs 				: CM_BlockStack;
   gridObj 			: CM_GridObjectArray;
   
begin
	
	self.deleteTerminalArea(BlockStack);
	self.deleteDriverDetails(DriverId);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	// create the road release request
	self.deleteReleaseRequest(RoadRelRequest);
	
	self.opts.purge();
	self.opts.addAssoc("Number", 1);
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	releaseRequest := self.addReleaseByTypeRequest(RoadRelRequest, BR_TYPE_ROAD, TI_CargoType_Container, "UT20");
	self.assertNotNull(releaseRequest);

	// gate out container1
	self.deleteVehicle(TRK);
	
	self.opts.purge();
	self.opts.addAssoc('release', releaseRequest);
	
	vvr := self.gateOutContainer(TRK, "", "MA", null, true, singleGate, null);
	self.assertNotNull(vvr);
	

	request :=vvr.myRoadJob.allRequests.first;
	deliveryRequest :=request.CM_DeliveryRequest;

	beginLoad;	
	pxyDeliveryRequest := deliveryRequest.pxyCreateUpdateProxy();
	endLoad;
	pxyDeliveryRequest.setRemarks("Unit Test Update Remarks");
	pxyDeliveryRequest.setIsoGroup("20BX");
	
	bs := self.addBlockStack(BlockStack, 10, null);
	self.assertNotNull(bs);
	create termArray transient;
	termArray.add(bs);
	
	create  wleArray transient;
	vvr.myRoadJob.getAllWLEs(wleArray);
		
	create gridObj transient;
	
	self.ignoreTrxWarnings(true);	
	app.myTrxUA.trxUpdateRequestDetails(pxyDeliveryRequest,wleArray,termArray,gridObj,false,true,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrue(deliveryRequest.isFIFO);
	self.assertFalse(deliveryRequest.isBestPick);
	self.assertEqual(deliveryRequest.remarks,"Unit Test Update Remarks");

epilog
	delete wleArray;
	delete termArray;
	delete gridObj;
	delete pxyDeliveryRequest;

end;</source>
    </JadeMethod>
    <JadeMethod name="usetupDRWagonClasses" id="b9a965b3-c940-47da-a1a2-159477cd3f78">
        <source>usetupDRWagonClasses( _deleteOnly : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2019	jlgndl1	Initial creation

*/

vars

	wagonClass : CM_WagonClass;

begin

	self.opts.addAssoc( "deleteWagonMasters", true );
	wagonClass := app.myRoot.allWagonClasses[WagonClassFC];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	wagonClass := app.myRoot.allWagonClasses[WagonClassBC];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	wagonClass := app.myRoot.allWagonClasses[WagonClassWC];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	wagonClass := app.myRoot.allWagonClasses[WagonClassSC];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	self.opts.purge();
	

	if _deleteOnly then
		return;
	endif;
	
	wagonClass := addWagonClass(WagonClassFC); //flat car
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; WagonClassFC &amp; "' (flat car) not created.");
	
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Boxcar);
	self.opts.addAssoc("InternalHeight", 200.Decimal);
	self.opts.addAssoc("InternalLength", 1500.Decimal);
	self.opts.addAssoc("InternalWidth", 200.Decimal);
	self.opts.addAssoc("ExternalHeight", 201.Decimal);
	self.opts.addAssoc("ExternalLength", 1501.Decimal);
	self.opts.addAssoc("ExternalWidth", 201.Decimal);
	self.opts.addAssoc("Tare", "5443".Decimal);
	self.opts.addAssoc("MaxLoadWeight", "100000".Decimal);
	wagonClass := addWagonClass(WagonClassBC);	// box car
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; WagonClassBC &amp; "' (box car) not created.");
	
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Wellcar);
	self.opts.addAssoc("LengthInUnits", 8.Integer);
	self.opts.addAssoc("MaxNumInStack", 2.Integer);
	self.opts.addAssoc("WellDeckHeight", "150".Decimal);
	self.opts.addAssoc("WellMaxCargoHeight", "540".Decimal);
	self.opts.addAssoc("WellCargoWeight", "80000".Decimal);
	self.opts.addAssoc("WellTare", "20000".Decimal);
	self.opts.addAssoc("WellLength", "2000".Decimal);
	self.opts.addAssoc("WellWidth", "300".Decimal);
	self.opts.addAssoc("TierIds", "BA".String);
	wagonClass := addWagonClass(WagonClassWC);	// Well car
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; WagonClassWC &amp; "' (well car) not created.");
	
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_SkeletonCar);
	wagonClass := addWagonClass(WagonClassSC);	// Well car
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; WagonClassSC &amp; "' (skeleton car) not created.");

epilog

end;</source>
        <Parameter name="_deleteOnly" type="Boolean"/>
    </JadeMethod>
