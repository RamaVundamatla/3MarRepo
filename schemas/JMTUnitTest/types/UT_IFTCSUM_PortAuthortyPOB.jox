			self.assertEqualMsg(ti.commodity, "", "For Cargo On Ship 3");
			self.assertEqualMsg(ti.consignee, "00172", "For Cargo On Ship 3");
			self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on ship 3");
		elseif ti.billOfLading = "00000004" then
			self.assertEqualMsg(ti.cargoTypeDescr, "Cannon", "For Cargo On Ship 4"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "", "For Cargo On Ship 4"); 
			self.assertEqualMsg(ti.billOfLading, "00000004", "For Cargo On Ship 4");
			self.assertEqualMsg(ti.dischargePort, "AUADL", "For Cargo On Ship 4"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship 4"); 
			self.assertEqualMsg(ti.destinationPort, "", "For Cargo On Ship 4"); 
			self.assertEqualMsg(ti.quantity, 2, "For Cargo On Ship 4"); 
			self.assertEqualMsg(ti.weight.String, "8200.0000", "For Cargo On Ship 4"); 
			self.assertEqualMsg(ti.totalVolume.String, "90.2500", "For Cargo On Ship 4"); 
			self.assertEqualMsg(ti.commodity, "", "For Cargo On Ship 4");
			self.assertEqualMsg(ti.consignee, "00172", "For Cargo On Ship 4");
			self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on ship 4");
		elseif ti.billOfLading = "00000005" then
			self.assertEqualMsg(ti.cargoTypeDescr, "Cannon", "For Cargo On Ship 5"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "", "For Cargo On Ship 5"); 
			self.assertEqualMsg(ti.billOfLading, "00000005", "For Cargo On Ship 5");
			self.assertEqualMsg(ti.dischargePort, "AUPKL", "For Cargo On Ship 5"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship 5"); 
			self.assertEqualMsg(ti.destinationPort, "", "For Cargo On Ship 5"); 
			self.assertEqualMsg(ti.quantity, 136, "For Cargo On Ship 5"); 
			self.assertEqualMsg(ti.weight.String, "221940.0000", "For Cargo On Ship 5"); 
			self.assertEqualMsg(ti.totalVolume.String, "2032.9610", "For Cargo On Ship 5"); 
			self.assertEqualMsg(ti.commodity, "", "For Cargo On Ship 5");
			self.assertEqualMsg(ti.consignee, "00172", "For Cargo On Ship 5");
			self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on ship 5");
		endif;
	endforeach;
return;
	//long version
//	ediData := self.xIFCSUMPOB94Bfile_3;	
//	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, "POB_IFCSUM94B", EDIFileType_Unknown, false, false, false, false, null);
//	self.assertTrueMsg(ediFile &lt;&gt; null, "EDI file not created. " &amp; app.myPassport.getErrorsAndWarningsAsString);
//	filesToDelete.add(ediFile);	
	
	//WLAs
	
	self.deleteEDIParty(EDIPartyName  &amp; "_WLA");
	ediParty := self.createEDIParty(EDIPartyName  &amp; "_WLA", method.qualifiedName &amp; " Unit Test", "WLA_COAST", wlaOper); 
//	self.createEDIPartyIFCSUM49B(ediParty, mclarenConsign, carCargoType, mclarenMake, true, false, false, null );
	self.createEDIPartyIFCSUM49B(ediParty, bmwConsign, carCargoType, bmwMake, true, false, false, null );
//	self.createEDIPartyIFCSUM49B(ediParty, lrConsign, carCargoType, lrMake, true, false, false, null );
	if app.isRunningInDMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10046);		//Cannon
	elseif app.isRunningInWMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10056);		//Cannon
	endif;
	rules := ediParty.getRulesForFileType (EDIFileType_IFCSUM94B);
	beginTransaction;
	rules.setPropertyValue(CM_EDIPartyIFCSUMRules::myDefaultCargoType.name, cargoType);
	commitTransaction;
	
	//short version
	ediData := self.xIFCSUMPOB94Bfile_2;	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, "POB_IFCSUM94B_WLA", "POB_IFCSUM94B_WLA"&amp;method.name, EDIFileType_Unknown, true, true, false, false, null);
	self.assertTrueMsg(ediFile &lt;&gt; null, "EDI file not created. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	filesToDelete.add(ediFile);
	
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 20, "Total number of ediTis");
    foreach ediTI in ediFile.ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
/*			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "Motor Vehicle", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "BEZEE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "BE12777058", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "NZPOE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "DEHAM", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "NZLYT", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 1, "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "4780.0000", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "50.490", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "00172", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 1");*/
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
/*			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "BE12777058", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "DEHAM", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "NZPOE", "For BOL 1"); */
		endif;
    endforeach;
	self.assertEqualMsg(voyage1.allOnshipTIsByIdCargoType.size, 38, "Total number of on ship Tis");
	foreach ti in voyage1.allOnshipTIsByIdCargoType do
/*		self.assertEqualMsg(ti.cargoTypeDescr, "Motor Vehicle", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getPortOfOrigin(), "BEZEE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.billOfLading, "BE12777058", "For Cargo On Ship");
		self.assertEqualMsg(ti.dischargePort, "NZPOE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.loadPort, "DEHAM", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.destinationPort, "NZLYT", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
		self.assertEqualMsg(ti.weight.String, "4780.0000", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.totalVolume.String, "50.4900", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.commodity, "", "For Cargo On Ship");
		self.assertEqualMsg(ti.consignee, "00172", "For Cargo On Ship");
		self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on ship");*/
	endforeach;

	//long version
//	ediData := self.xIFCSUMPOB94Bfile_4;	
//	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, "POB_IFCSUM94B", EDIFileType_Unknown, false, false, false, false, null);
//	self.assertTrueMsg(ediFile &lt;&gt; null, "EDI file not created. " &amp; app.myPassport.getErrorsAndWarningsAsString);
//	filesToDelete.add(ediFile);
	
	//cleanup if successfull
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	self.deleteEDIInwardXlation(ForeignOperatorCode1, XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation(ForeignOperatorCode2, XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation(ForeignOperatorCode3, XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation('MCLAREN AUTOMOTIVE ASIA PTE LT', XLATION_TYPE_CONSIGNEE_BYOP, wlaOper, null);
	self.deleteEDIInwardXlation('LAND ROVER EXPORTS LTD', XLATION_TYPE_CONSIGNEE_BYOP, wlaOper, null);
	self.deleteEDIInwardXlation('BMW AUSTRALIA LTD', XLATION_TYPE_CONSIGNEE_BYOP, wlaOper, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, wlaOper, null);
	
//	self.deleteEDIParty(EDIPartyName  &amp; "_WLA");
