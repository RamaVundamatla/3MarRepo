    <JadeMethod name="doSave" id="4552ffc8-8bcb-4a40-ba83-dc363da16a89">
        <updating/>
        <source>doSave(): Boolean updating;
//	03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint
vars
	errObj						: CM_Error;
	idx							: Integer;
	tmpListBox					: ListBox;
	ignoreWarnings,rtnValue,
	isNotAvailableForEntry		: Boolean;
	proxyCountry				: CM_Country;
	lCode,lDescription			: String;
	thePorts 					: CM_PortSet;
	intCountry 					: CMIF_Country;
	theForm 					: SOP_TableMaintForm;
	iso3Char			: String;
	unNum			: String; 
	countryRegion	: CM_CountryRegion;
begin
  	theForm := self.myForm; 
  	
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	iso3Char := theForm.tblInput1.getValueByName(ETRow_IsoCode3).String;	//08 Aug 2013	NDL	Par //08 Aug 2013	NDL	Par 32033
	unNum := theForm.tblInput1.getValueByName(ETRow_UnNum).String;	//08 Aug 2013	NDL	Par //08 Aug 2013	NDL	Par 32033
	isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	countryRegion := theForm.cmbCountryRegion.listObject.CM_CountryRegion; //03/08/2023	navkc1	CR 59552   Task 59555
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Country transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyCountry := theForm.myProxyObject.CM_Country;
	create thePorts transient;
	theForm.mulSelect1.getSelected(thePorts);
	
	
	proxyCountry.setProxy(lCode, lDescription, iso3Char, unNum, isNotAvailableForEntry, countryRegion); //03/08/2023	navkc1	CR 59552   Task 59555

	create intCountry;
	intCountry.myProxyCountry := proxyCountry;
	thePorts.copy(intCountry.allRealPorts);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCountry(intCountry, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCountry(intCountry, app.myPassport);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK();
epilog
	delete thePorts;
	delete intCountry;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
