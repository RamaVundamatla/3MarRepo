    </JadeMethod>
    <JadeMethod name="doBuildComboTableBay" id="1f8166af-7d2f-4e70-a87c-f6b13c9137e7">
        <updating/>
        <source>doBuildComboTableBay() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aVessel : CM_Vessel;
	aBay : CM_Bay; //Defn;
	idx : Integer;
	theBays : ObjectArray;
	structure : CM_CellularVoyageStructure;	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		structure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;

	if structure &lt;&gt; null then
		
		self.tblComboHatchBay.rows := 1;
		self.tblComboHatchBay.accessCell(1,2).text := " Bays For Hatch Lids...";
		self.tblComboHatchBay.accessRow(1).itemObject := null;
		self.tblComboHatchBay.allSelectedObjects.clear;
		foreach aBay in structure.allBayVoyagesById do
			self.tblComboHatchBay.addItemObject(aBay.id.trimBlanks , aBay);
//			self.cmbBayLayout.addItemObject(aBay.id.trimBlanks , aBay);
		endforeach;
	else
		return;	
	endif;


/*
	if self.myDataClass = CM_CellularVessel then
		if self.myCurrentVessel = null then
			return;
		endif;
		
		aCellVessel := self.myCurrentVessel;
		
		self.tblComboBays.rows := 1;
		self.tblComboBays.tabIndex := 20;
		self.tblComboBays.accessCell(1,2).text := " Bays For Hatch Lids...";
		self.tblComboBays.allSelectedObjects.clear;
		foreach aBay in aCellVessel.allBaysByLabel do
			idx := self.tblComboBays.addRow( false, aBay.id.trimBlanks , aBay);
			if self.myCurrentBay = aBay then
				self.tblComboBays.tickRow(idx,true);
			endif;
		endforeach;
	else
		if self.myCurrentVoyage = null then
			return;
		endif;
		
		self.tblComboBays.rows := 1;
		self.tblComboBays.accessCell(1,2).text := " Bays For Hatch Lids...";
		self.tblComboBays.allSelectedObjects.clear;
		foreach aBay in myCurrentVoyage.allBayVoyagesById do
			idx := self.tblComboBays.addRow( false, aBay.id.trimBlanks , aBay);
			if self.myCurrentBay = aBay then
				self.tblComboBays.tickRow(idx,true);
			endif;
		endforeach;
	
	endif;
*/
	create theBays transient;
	self.tblComboHatchBay.setSelected(theBays);
epilog
	delete theBays;

	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboTableBays" id="927a11c3-07c5-40b0-92cd-5b62835b2a4c">
        <updating/>
        <source>doBuildComboTableBays(_theBays : CM_BaySet) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		THIS IS A CALL BACK from the draw on SHP_LidPoint
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aVessel : CM_Vessel;
	aBay : CM_Bay; //Defn;
	idx : Integer;
	theBays : ObjectArray;
	structure : CM_CellularVoyageStructure;	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		structure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
	self.tblComboHatchBay.allSelectedObjects.clear;
	self.cmbBayLayout.clear;

	if structure = null then
		return;
	endif;
	
	self.tblComboHatchBay.rows := 1;
	self.tblComboHatchBay.accessCell(1,2).text := " Bays For Hatch Lids...";
	self.tblComboHatchBay.accessRow(1).itemObject := null;
	self.tblComboHatchBay.allSelectedObjects.clear;
	foreach aBay in structure.allBayVoyagesById do
		self.tblComboHatchBay.addItemObject(aBay.id.trimBlanks , aBay);
		if _theBays.includes(aBay) then
			self.cmbBayLayout.addItemObject(aBay.id.trimBlanks &amp; " " &amp; 215.Character , aBay);
		else
			self.cmbBayLayout.addItemObject(aBay.id.trimBlanks , aBay);
		endif;			
	endforeach;
	
	create theBays transient;
	_theBays.copy(theBays);
	self.tblComboHatchBay.setSelected(theBays);
	if not theBays.isEmpty then
		self.tblComboHatchBay.findObject(theBays.first,idx);
		if idx &gt; 1 then
			self.tblComboHatchBay.topRow := idx;
		endif;
	endif;
epilog
	delete theBays;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_theBays" type="CM_BaySet"/>
    </JadeMethod>
    <JadeMethod name="doBuildProxyBayList" id="3d18005d-efb7-4a07-a45c-91f0c37e5a46">
        <updating/>
        <source>doBuildProxyBayList(_theBays : String) updating;
// ---------------------------------------------------------------------------
// Created:		December  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	aVessel : CM_Vessel;
	aProxyBay,previousBayDefn, realBay : CM_Bay; //Defn;
	idx,theOrdinal,currentColour,lastRowColour : Integer;
	theLabels : StringArray;
	aLabel : String;
	theHold : CM_Hold;
	theBays : CM_BayArray;
	structure : CM_CellularVoyageStructure;	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		structure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	if structure = null then
		return;
	endif;
		
	aLabel := _theBays;
	aLabel.replaceString(" ","|");
	
	theLabels := aLabel.getTokens;
	create theBays transient;
	
	structure.allBayVoyagesByOrdinal.copy(theBays);
	// dettach
	foreach aProxyBay in theBays  do
		//theOrdinal := aProxyBay.ordinalBay + 500;
		theOrdinal := aProxyBay.ordinalBay + CM_Bay.BayOrdinalOffset;//03 Feb 2012 NDL Par 28640
		aProxyBay.setOrdinalBay(theOrdinal);
		aProxyBay.setMyAftBay(null);
	endforeach;
	theOrdinal := 0;
	
	// attach and insert, if necessary
	foreach aLabel in theLabels do
		if aLabel.trimBlanks &lt;&gt; null then
			theOrdinal := theOrdinal + 1;
			aProxyBay := structure.allBayVoyagesById[aLabel.trimBlanks];
			if aProxyBay = null then
				create aProxyBay as CM_BayVoyage transient;
//					theOrdinal := self.myCurrentVoyage.allBayVoyagesById.size + 1;
				aProxyBay.CM_BayVoyage.setProxyBay(aLabel.trimBlanks,null,null,null,null,null,theOrdinal,
				null,null,null,null,null,null,null,null,null,null,null,null,null,null,null, null,true,true,self.myCurrentVoyage.myCellularVoyageStructure,null,0,false,false);
			else
				aProxyBay.setOrdinalBay(theOrdinal);
			endif;
		endif;
	endforeach;
	// re link
	foreach aProxyBay in structure.allBayVoyagesByOrdinal do
		if aProxyBay.id.trimBlanks = null then
			continue;
		endif;
		
		if previousBayDefn &lt;&gt; null then
			previousBayDefn.CM_BayVoyage.setMyAftBay(aProxyBay);
		endif;
		previousBayDefn := aProxyBay;
	endforeach;

	self.doBuildComboBay(self.cmbBayList);

epilog
	delete theLabels;
	delete theBays;
end;</source>
        <Parameter name="_theBays" type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildProxyHoldList" id="4c9e0ac8-f7e6-4270-b899-ad09672593a0">
        <source>doBuildProxyHoldList(_numberOfHolds : Integer);
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, numHolds : Integer;
	aHold : CM_Hold;
	structure : CM_CellularVoyageStructure;	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		structure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;

	if structure = null then
		return;
	endif;
	
	if self.mode &lt;&gt; self.Mode_Update then
		return;
	endif;
	
	numHolds := structure.allHolds.size;
	
	if numHolds &gt; _numberOfHolds then
		foreach idx in _numberOfHolds + 1 to numHolds do
			aHold := structure.allHolds[idx];
			
			if aHold &lt;&gt; null then
				if aHold.allBays.isEmpty then
					delete aHold;
				endif;
			endif;
		endforeach;
	else
		foreach idx in 1 to _numberOfHolds do
			if structure.allHolds[idx] = null then
				create aHold as CM_VoyageHold transient;
				aHold.CM_VoyageHold.setProxy(structure,idx);
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="_numberOfHolds" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="fcb8c211-5903-4476-a759-19d22cd647b1">
        <updating/>
        <source>doCancel() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aSBC : CM_ShipBlockController;
begin

	if self.myCurrentVoyage &lt;&gt; null then
		if self.myCurrentVoyage.pxyIsProxy then
			if self.myCurrentVoyage.myShipBlockStack &lt;&gt; null then
				aSBC :=  self.myCurrentVoyage.myShipBlockStack.CM_ShipBlockController;
				if aSBC.pxyIsProxy then
					delete aSBC;
				endif;
			endif;
		endif;
	endif;
	
	delete self.myProxyVoyage;

	self.setMyCurrentVoyage(self.cmbVoyage.myObject.CM_Voyage);
				
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCopyTemplateAttributes" id="433a1ccb-8eab-4935-9c25-e0eff535ddcb">
        <updating/>
        <source>doCopyTemplateAttributes(_templateBay : CM_Bay) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aColumn : CMUI_GridColumn;
	bayFrame,bayFrameUD : CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	bayPoint : SHP_BayPoint;
	theString : CM_String;
	bayArea : SHP_BayArea;
	theTierOrd, theTierSize : Integer;
	aTCell, aUCell : CM_CellDefn;
	aTSlot, aUSlot : CM_SlotDefn;
	theBay : CM_Bay;
begin
	if _templateBay = null then
		return;
	endif;
	
	self.anythingChanged := true;
	
	// #################################
	// Ondeck Cell Alignment
	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null 
	and not _templateBay.allCellsOnDeckByOrdinal.isEmpty then
		theBay := bayFrame.myGridArea.SHP_BayArea.myBay;
		theTierSize := theBay.allTiersOnDeck.size;
		
		foreach aColumn in bayFrame.myGridArea.allGridColumns do
			aTCell := _templateBay.allCellsOnDeckByOrdinal[aColumn.column];
			aColumn.SHP_BayColumn.allignment := aTCell.alignment;
		endforeach;
		foreach aPoint in bayFrame.myGridArea.SHP_BayAreaAboveDeck.allGridPoints do
			if aPoint.isKindOf(SHP_BayPoint) then
				bayPoint := aPoint.SHP_BayPoint;
				theTierOrd :=  theTierSize - (bayPoint.row - 1);

				aTSlot := _templateBay.allSlotsByOrdinal[DeckOnDeck, bayPoint.column,theTierOrd];
				if aTSlot &lt;&gt; null then
					bayPoint.bayDefnFortyFoot := aTSlot.fortyFront;
					bayPoint.bayDefnThirtyFoot := aTSlot.is30; // PAR 16415 CCMS 1029
					bayPoint.bayDefnFiftyThreeFoot := aTSlot.is53; // PAR 16415 CCMS 1029
					bayPoint.bayDefnPowered := aTSlot.power;
					bayPoint.bayDefnFortyFive := aTSlot.is45; // PAR 18682 CCMS 1055
					bayPoint.bayDefnReefer := aTSlot.reefer;
					bayPoint.bayDefnWaterCooled := aTSlot.watercooled;
					bayPoint.bayDefnUnavailable := aTSlot.unavailable;
					bayPoint.bayDefnDoorDirection20 := aTSlot.doors20Aft;
//					bayPoint.bayDefnDoorDirection40 := aTSlot.doors40Aft;
					bayPoint.bayDefnMotorDirection20 := false;
					bayPoint.bayDefnMotorDirection40 := false;
					bayPoint.bayDefnMtOnly := aTSlot.mtOnly;
					bayPoint.bayDefnHeavy := aTSlot.heavy;
					bayPoint.bayDefnVoltage := aTSlot.voltageType;
				endif;
			endif;
		endforeach;
	endif;
	// #################################
	// Underdeck Cell Alignment
	bayFrameUD := self.frmGridArea.getControl(UNDERDECK);
	if bayFrameUD &lt;&gt; null 
	and not _templateBay.allCellsUnderDeckByOrdinal.isEmpty then
		theBay := bayFrameUD.myGridArea.SHP_BayArea.myBay;
		theTierSize := theBay.allTiersUnderDeck.size;

		foreach aColumn in bayFrameUD.myGridArea.allGridColumns do
			aTCell := _templateBay.allCellsUnderDeckByOrdinal[aColumn.column];
			aColumn.SHP_BayColumn.allignment := aTCell.alignment;
		endforeach;
		foreach aPoint in bayFrameUD.myGridArea.SHP_BayAreaBelowDeck.allGridPoints do
			if aPoint.isKindOf(SHP_BayPoint) then
				bayPoint := aPoint.SHP_BayPoint;
				theTierOrd :=  theTierSize - (bayPoint.row - 1);

				aTSlot := _templateBay.allSlotsByOrdinal[DeckUnderDeck, bayPoint.column,theTierOrd];
				if aTSlot &lt;&gt; null then
					bayPoint.bayDefnFortyFoot := aTSlot.fortyFront;
					bayPoint.bayDefnThirtyFoot := aTSlot.is30; // PAR 16415 CCMS 1029
					bayPoint.bayDefnFiftyThreeFoot := aTSlot.is53; // PAR 16415 CCMS 1029
					bayPoint.bayDefnFortyFive := aTSlot.is45; // PAR 18682 CCMS 1055
					bayPoint.bayDefnPowered := aTSlot.power;
					bayPoint.bayDefnReefer := aTSlot.reefer;
					bayPoint.bayDefnWaterCooled := aTSlot.watercooled;
					bayPoint.bayDefnUnavailable := aTSlot.unavailable;
					bayPoint.bayDefnDoorDirection20 := aTSlot.doors20Aft;
//					bayPoint.bayDefnDoorDirection40 := aTSlot.doors40Aft;
					bayPoint.bayDefnMotorDirection20 := false;
					bayPoint.bayDefnMotorDirection40 := false;
					bayPoint.bayDefnMtOnly := aTSlot.mtOnly;
					bayPoint.bayDefnHeavy := aTSlot.heavy;
					bayPoint.bayDefnVoltage := aTSlot.voltageType;
				endif;
			endif;
		endforeach;
	endif;
	bayFrame.myGridArea.drawSelf();
	bayFrameUD.myGridArea.drawSelf();
	// ########################
	// DRAW THE LEGEND
	// merge the attributes used on the 2 frames into the top frames and print the legend
	if bayFrame &lt;&gt; null then
		if bayFrameUD &lt;&gt; null then
			
			foreach theString in bayFrameUD.myGridArea.SHP_BayArea.allAttributesUsed do
				if not global.isValidObject(theString) then
					continue;
				endif;
				if bayFrame.myGridArea.SHP_BayArea.allAttributesUsed[theString.string] = null then
					bayFrame.myGridArea.SHP_BayArea.allAttributesUsed.add(theString);
				endif;
			endforeach;
		endif;	
		bayFrame.myGridArea.SHP_BayArea.displayAttributeLegend(self.frmLegend);
	endif;
	self.doSetProxyAttributesFromGUI();
end;</source>
        <Parameter name="_templateBay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="doDrawBay" id="832947df-c4f8-4eac-84ab-0d30c48281a6">
        <updating/>
        <source>doDrawBay() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	bayAreaAboveDeck : SHP_BayAreaAboveDeck;
	bayAreaBelowDeck : SHP_BayAreaBelowDeck;
	anObject : Object;
	aCMObject : CM_Object;
	rowFrame	: CMUI_GridAreaFrame;
	maxRowFrames, pointX, pointY, aColour : Integer;
	aLabel : String;
	theString : CM_String;
	bayFrame,bayFrameUD	: CMUI_GridAreaFrame;
begin
	// clear these out cos we are only looking at one area at a time and they all have column =  and row = 1
	app.mousePointer := Window.MousePointer_HourGlass;

	if self.myCurrentBay = null then
		self.mySDF.visible := false;
		return;
	else
		self.mySDF.visible := true;
	endif;

	self.mySDF.clearAllSelectedPoints();
	self.mySDF.myDrawingFrame.bubbleHelp := "Hatch Lids";
	self.mySDF.allGridAreasByColumnRow.clear;
	self.mySDF.allGridAreasByRowColumn.clear;
	if self.myCurrentBay.allSlotsByOrdinal.size = 0 then
		self.mySDF.drawSelf();
		self.doEnablePens(false);
		return;
	endif;
	
	self.doEnablePens(true);

	bayAreaAboveDeck := self.frmGridArea.myGridArea.SHP_BayAreaAboveDeck;
	delete bayAreaAboveDeck;

	self.setCaption(self.cmbVoyage.text &amp; ', Bay ' &amp; self.myCurrentBay.id &amp; ', ' &amp; self.Caption);

	delete	self.frmGridArea.getControl(ONDECK);
	delete	self.frmGridArea.getControl(UNDERDECK);

	// ######################
	// ABOVE DECK
	bayFrame := self.frmGridArea.loadControl(ONDECK).CMUI_GridAreaFrame;
	bayFrame.caption := null;

	create bayAreaAboveDeck as SHP_BayAreaAboveDeck transient;
	// there is only one at a time here so the col and row are one
	bayAreaAboveDeck.setForCreate(self.myCurrentBay,1,ONDECK, ShpDisplayMode_Defn);
	self.mySDF.addGridAreaAndFrame(bayAreaAboveDeck, bayFrame);
	bayAreaAboveDeck.myGridAreaFrame := bayFrame;
	bayAreaAboveDeck.myForm := self;
	bayAreaAboveDeck.setZoomFactorTo(4);
	
	// ######################
	// BELOW DECK
	bayFrameUD := self.frmGridArea.loadControl(UNDERDECK).CMUI_GridAreaFrame;
	bayFrameUD.caption := null;

	create bayAreaBelowDeck as SHP_BayAreaBelowDeck transient;
	// there is only one at a time here so the col and row are one
	bayAreaBelowDeck.setForCreate(self.myCurrentBay,1,UNDERDECK, ShpDisplayMode_Defn);
	self.mySDF.addGridAreaAndFrame(bayAreaBelowDeck, bayFrameUD);
//	bayAreaAboveDeck.myGridAreaFrame := bayFrameUD;
	bayAreaBelowDeck.myForm := self;
	bayAreaBelowDeck.setZoomFactorTo(4);

	self.mySDF.drawSelf();
/*
	// Adjust the height
	if bayFrame.myGridArea.allGridRows.isEmpty = false then
		bayFrame.height := bayFrame.myGridArea.allGridRows.last.y2 + 20;
	else
		bayFrame.height := 200;
	endif;
*/
	// ########################
	// DRAW THE LEGEND
	// merge the attributes used on the 2 frames into the top frames and print the legend
	if bayFrame &lt;&gt; null then
		if bayFrameUD &lt;&gt; null then
			foreach theString in bayFrameUD.myGridArea.SHP_BayArea.allAttributesUsed do
				if not global.isValidObject(theString) then
					continue;
				endif;
				if bayFrame.myGridArea.SHP_BayArea.allAttributesUsed[theString.string] = null then
					bayFrame.myGridArea.SHP_BayArea.allAttributesUsed.add(theString);
				endif;
			endforeach;
		endif;	
		bayFrame.myGridArea.SHP_BayArea.displayAttributeLegend(self.frmLegend);
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default;



end;</source>
    </JadeMethod>
    <JadeMethod name="doEnablePens" id="c9d785d9-9244-43f5-9689-d84f960e765e">
        <updating/>
        <source>doEnablePens(_enable : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.btnPen40.enabled := _enable;
	self.btnPen30.enabled := _enable; // PAR 16415 CCMS 1029
	self.btnPen53.enabled := _enable; // PAR 16415 CCMS 1029
	self.btnPen45.enabled := _enable; // PAR 18682 CCMS SFW 1055
	self.btnPenAftDoors20.enabled := _enable;
	self.btnPenAftDoors40.enabled := _enable;
	self.btnPenAftMotor20.enabled := _enable;
	self.btnPenAftMotor40.enabled := _enable;
	self.btnPenCellShiftL.enabled := _enable;
	self.btnPenCellShiftR.enabled := _enable;
	self.btnPenClearSel.enabled := _enable;
	self.btnPenEmpty.enabled := _enable;
	self.btnPenHeavy.enabled := _enable;
	self.btnPenVoltage.enabled := _enable;
	self.btnPenLidCreate.enabled := _enable;
	self.btnPenLidDelete.enabled := _enable;
	self.btnPenLidDelete.enabled := _enable;
	self.btnPenLidMidEnd.enabled := _enable;
	self.btnPenLidMidSt.enabled := _enable;
	self.btnPenPower.enabled := _enable;
	self.btnPenReefer.enabled := _enable;
	self.btnPenRefresh.enabled := _enable;
	self.btnPenTemplate.enabled := _enable;
	self.btnPenUnavail.enabled := _enable;
	self.btnPenWaterCool.enabled := _enable;
	self.cmbBayLayout.enabled := _enable;
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadTblCellLimits" id="73107a6c-6eaa-410e-9895-60d55603a9d5">
        <source>doLoadTblCellLimits():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2010	cnwndl1	Initial creation		Par 25127	/ CCMS 1140

*/

vars

	theBay : CM_Bay;
	aCellDef : CM_CellDefn;
	aTierDef : CM_TierDefn;
	numCols : Integer;
	tableHeight : Integer;
	editMode : Boolean;
	
	index : Integer;
	rowData : String;
	
begin

	theBay := self.myCurrentBay;
	if theBay = null then
		numCols := 0;
		editMode := false;
		self.shtBayCellLimit.caption := app.getErrorString1(BayDimensions, null);
	else
		numCols := theBay.allCellsOnDeckByOrdinal.size;
		editMode := theBay.isTransient;
		self.shtBayCellLimit.caption := app.getErrorString1(BayDimensions, theBay.id);
	endif;

	// set up the 'On Deck' table
	self.tblOnCellDims.clear();
	self.tblOnCellDims.clearAllSelected();
	self.tblOnCellDims.fixedRows := 1;
	self.tblOnCellDims.fixedColumns := 1;
	self.tblOnCellDims.columns := numCols + 1;
	self.tblOnCellDims.rows := 4;
	tableHeight := (self.tblOnCellDims.accessRow(1).height * 5) + 4;	// 4 real rows plus room for a scroll bar if required
	
	self.tblOnCellDims.move( 	2,
								20,
								self.shtBayCellLimit.width - 10,
								tableHeight );
								
	self.tblOnCellDims.setCellText(1,1,app.getErrorString(On_deck_cells) );
	self.tblOnCellDims.setCellText(2,1,app.getErrorString(OnDeck20CellMaxPileTons) );
	self.tblOnCellDims.setCellText(3,1,app.getErrorString(OnDeck40CellPileTons) );
	self.tblOnCellDims.setCellText(4,1,app.getErrorString(OnDeckCellMaxHeightMetres) );
	
	if theBay &lt;&gt; null then
		// add the 'On deck' data.
		index := 1;
		foreach aCellDef in theBay.allCellsOnDeckByOrdinal do
			index := index + 1;
			// headings
			self.tblOnCellDims.setCellText(1,index,aCellDef.id.trimBlanks);
			self.tblOnCellDims.accessColumn(index).itemObject := aCellDef;
			self.tblOnCellDims.accessCell(1,index).alignment := Table.Alignment_Center_Middle;
			//real data
			self.tblOnCellDims.accessColumn(index).alignment := Table.Alignment_Right_Middle;
			self.tblOnCellDims.setCellText(2,index,aCellDef.maxPileWeight20.asStringJMT);
			self.tblOnCellDims.setCellText(3,index,aCellDef.maxPileWeight40.asStringJMT);
			self.tblOnCellDims.setCellText(4,index,aCellDef.maxHeight.asStringJMTWithPrecision(2,false));
			if editMode then	// in edit mode, allow input.
				// allow Integers only
				self.tblOnCellDims.decimals := 0;
				self.tblOnCellDims.accessCell(2,index).inputType := Table.InputType_TextNumeric;
				self.tblOnCellDims.accessCell(3,index).inputType := Table.InputType_TextNumeric;
				// must be decimal in this one
				self.tblOnCellDims.decimals := 2;
				self.tblOnCellDims.accessCell(4,index).inputType := Table.InputType_TextNumeric;
			endif;
		endforeach;

	endif;

	// set up the 'Under Deck' table
	self.tblUnderCellDim.clear();
	self.tblUnderCellDim.clearAllSelected();
	self.tblUnderCellDim.fixedRows := 1;
	self.tblUnderCellDim.fixedColumns := 1;
	if theBay &lt;&gt; null then
		numCols := theBay.allCellsUnderDeckByOrdinal.size;
	endif;
	self.tblUnderCellDim.columns := numCols + 1;
	self.tblUnderCellDim.rows := 4;
	tableHeight := (self.tblUnderCellDim.accessRow(1).height * 5) + 4;
	
	self.tblUnderCellDim.move( self.tblOnCellDims.left,
								self.tblOnCellDims.top + self.tblOnCellDims.height + 50,
								self.tblOnCellDims.width,
								tableHeight );
								
	self.tblUnderCellDim.setCellText(1,1,app.getErrorString(Under_deck_cells) );
	self.tblUnderCellDim.setCellText(2,1,app.getErrorString(UnderDeck20CellMaxPileTons) );
	self.tblUnderCellDim.setCellText(3,1,app.getErrorString(UnderDeck40CellPileTons) );
	self.tblUnderCellDim.setCellText(4,1,app.getErrorString(UnderDeckCellMaxHeightMetres) );
	
	if theBay &lt;&gt; null then
		// add the 'Under deck' data.
		index := 1;
		foreach aCellDef in theBay.allCellsUnderDeckByOrdinal do
			index := index + 1;
			self.tblUnderCellDim.setCellText(1,index,aCellDef.id.trimBlanks);
			self.tblUnderCellDim.accessColumn(index).itemObject := aCellDef;
			self.tblUnderCellDim.accessCell(1,index).alignment := Table.Alignment_Center_Middle;
			
			self.tblUnderCellDim.accessColumn(index).alignment := Table.Alignment_Right_Middle;
			self.tblUnderCellDim.setCellText(2,index,aCellDef.maxPileWeight20.asStringJMT);
			self.tblUnderCellDim.setCellText(3,index,aCellDef.maxPileWeight40.asStringJMT);
			self.tblUnderCellDim.setCellText(4,index,aCellDef.maxHeight.asStringJMTWithPrecision(2,false));
			if editMode then
				self.tblUnderCellDim.decimals := 0;
				self.tblUnderCellDim.accessCell(2,index).inputType := Table.InputType_TextNumeric;
				self.tblUnderCellDim.accessCell(3,index).inputType := Table.InputType_TextNumeric;
				self.tblUnderCellDim.decimals := 2;
				self.tblUnderCellDim.accessCell(4,index).inputType := Table.InputType_TextNumeric;
			endif;
		endforeach;
		
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLstPortContext" id="5158e575-2694-40d9-8dbc-f27207d32793">
        <updating/>
        <source>doLstPortContext(listBox : ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, 
	y1					: Real;
	idx					: Integer;
	obj					: Object;
	shipPortGroup		: CM_ShipPortGroup;
	
begin

	idx := listBox.getListIndex(x,y);
	if (idx &lt; 1) or (idx &gt; listBox.listCount) then
		return false; 
	endif;
	
	obj := listBox.itemObject[idx];
	
	if CM_ShipPortGroup.hasInstance(obj) then
		shipPortGroup := obj.CM_ShipPortGroup;
	elseif CM_ShipPort.hasInstance(obj) then
		shipPortGroup := obj.CM_ShipPort.shipPortGroup;
	endif;
	
	if shipPortGroup = null then
		return false;
	endif;
	
	listBox.listObject := obj;
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if listBox.listIndex &lt; 0 then
	        y1 := 5;
	    else
	        y1 := listBox.positionTop(listBox.listIndex);
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   
	
	self.mnuEditPortGroup.caption := 'Edit port group ' &amp; shipPortGroup.code &amp; '...';	
	self.popupMenu(self.mnuLstPortContext, x1.Integer, y1.Integer);

end;</source>
        <access>protected</access>
        <Parameter name="listBox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintBay" id="e0fbe68e-b65f-4646-bf8c-e09cae16d8cd">
        <updating/>
        <source>doPrintBay() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bayFrame,bayFrameUD : CMUI_GridAreaFrame;
	pxyJadeReport	: JadeReport;
	header, theType, theCode :String;
	theLeft : Real;
	bckClr : Integer;
begin
	if self.myCurrentBay = null then
		app.msgBox("Please select a bay from the list.", "No Bay Selected", MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	if self.myCurrentVoyage &lt;&gt; null then
		theType := "Voyage";
		theCode := self.myCurrentVoyage.vesselName.trimBlanks;
	endif;	
	header := theType &amp; " : " &amp; theCode &amp;  ". Bay Definition, Bay " &amp; self.myCurrentBay.id;
	

// ####################################

		create pxyJadeReport transient;
		app.printer.setReport(pxyJadeReport);
		app.printer.newPage();
		app.printer.setFooter(null);
		app.printer.setPrintPosition(50);

		
		self.frmReport.left := app.printer.rightMargin;
		self.frmReport.width :=	app.printer.pageWidth - app.printer.leftMargin - app.printer.rightMargin;
		self.lblReport.width := self.frmReport.width;
			
		self.lblReport.caption := header;
//		self.lblReport.caption := self.txtBayID.text;
		app.printer.print(self.frmReport);
		
		
		
		self.grpBayDetails.ignoreSkin := true;
		self.grpBayDetails.transparent := true;
		self.grpBayDetails.backColor := White;
		self.picBayDetails.picture := self.grpBayDetails.createPictureIndirect(false,true);
		self.framePrint.move(0,0,self.grpBayDetails.width,self.grpBayDetails.height);
		self.grpBayDetails.ignoreSkin := false;
		app.printer.print(self.framePrint);
		
		
		theLeft := self.mySDF.myHLabels.left;
		self.mySDF.myHLabels.left := 0;
		app.printer.print(self.mySDF.myHLabels);
		self.mySDF.myHLabels.left := theLeft;
		
		bayFrame := self.frmGridArea.getControl(ONDECK);
		if bayFrame &lt;&gt; null then
			bckClr := bayFrame.backColor;
			bayFrame.backColor := White;
			app.printer.print(bayFrame);
			bayFrame.backColor := bckClr;
		endif;
	
		bayFrameUD := self.frmGridArea.getControl(UNDERDECK);
		if bayFrameUD &lt;&gt; null then
			bckClr := bayFrameUD.backColor;
			bayFrameUD.backColor := White;
			bayFrameUD.height := bayFrameUD.myGridArea.allGridRows.last.y2 + 100;
			app.printer.print(bayFrameUD);
			bayFrameUD.backColor := bckClr;
		endif;	
	
		// print the legend
		theLeft := self.frmLegend.left;
		self.frmLegend.left := 10;
		self.frmLegend.width := 400;
		self.frmLegend.borderStyle := Frame.BorderStyle_None;
		app.printer.print(self.frmLegend);
		self.frmLegend.left := theLeft;

		app.printer.close();
		app.printPreview(pxyJadeReport, true);
	

epilog
	self.lblReport_1.caption := null;
	self.lblReport.caption := null;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="bab51f2a-6741-4778-9f04-2001da57a7ca">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aW, aH : Real;
begin
	inheritMethod();
	self.grpVoyageBay.top := self.frmToolbar.height;
	self.fldVessel.top := self.grpVoyageBay.top + self.grpVoyageBay.height + VerticalSpacing;

	self.fldVessel.height := self.clientHeight - self.fldVessel.top;
	
	self.frmToolBarBay.top := 0;
	self.frmToolBarBay.left := 1;
	self.frmToolBarLayout.top := 0;
	self.frmToolBarLayout.left := 1;
		
	// BAY LAYOUT TOOLBAR
	self.splLayout.move(1,self.frmToolBarLayout.clientHeight+2 ,self.shtBayLayout.width, self.shtBayLayout.height - (self.frmToolBarLayout.clientHeight).Integer);
	self.splLayout.cnEcResizeContents();	

	self.mySDF.myHScroll.move(0, self.mySDF.height - self.mySDF.ScrollBarWidth - 2, self.mySDF.width - self.mySDF.ScrollBarWidth, self.mySDF.ScrollBarWidth);
	self.mySDF.myVScroll.move(self.mySDF.width - self.mySDF.ScrollBarWidth , 0, self.mySDF.ScrollBarWidth, self.mySDF.height);
	self.mySDF.resizeDrawingFrame(self.mySDF.width,self.mySDF.height);
	self.mySDF.myDrawingFrame.backColor := self.frmGridArea.backColor;


	if self.mySDF.allGridAreasByRowColumn.isEmpty then
		aW :=self.mySDF.width;
		aH := self.mySDF.height;
	else
		aW := self.mySDF.getWidthOfAllFrames();
		aH := self.mySDF.getHeightOfAllFrames() + 70;
	endif;
	self.mySDF.resizeDrawingFrame(aW,aH);
	self.mySDF.repositionScrollBars();

	
 // ### TFS 50421 04NOV2021 NAVAB1	self.grpBayDetails.centreVerticallyInParent();
 // ### TFS 50421 04NOV2021 NAVAB1	self.grpBayDetails.centreHorizontallyInParent();
  // ### TFS 50421 04NOV2021 NAVAB1 replaced these 2 statements with setting the parent aspect and setting the minimum height of the form, so that the  toolbar is not clipping the fields.

	self.grpVesselDetails.centreVerticallyInParent();
	self.grpVesselDetails.centreHorizontallyInParent();	
	
	self.tblOnCellDims.width := self.shtBayCellLimit.width - 10;	//29 July 2010	NDL	Par 25127	/ CCMS 1140
	self.tblUnderCellDim.width := self.shtBayCellLimit.width - 10;	//29 July 2010	NDL	Par 25127	/ CCMS 1140
	
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="6e6b956d-1bb6-452a-8b09-b0e96871b11c">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aSBC			: CM_ShipBlockController;
	rtnValue		: Boolean;
	result			: Integer;
begin

	app.mousePointer := Window.MousePointer_HourGlass;
   		
	if self.mode &lt;&gt; self.Mode_Update
	or self.viewModeOnly then
		return false;
	endif;
	
	if self.myProxyVoyage = null then
		return false;
	endif;
	
	self.doSetProxyVoyageCellular(self.myProxyVoyage.myCellularVoyageStructure);
	
	while true do
		app.myTrxUA.trxUpdateCellularVoyStructure(self.myProxyVoyage.myCellularVoyageStructure, app.myPassport);
		if app.myPassport.trxCompletedOK then
			
			self.myCurrentVoyage := self.myProxyVoyage.pxyGetRealObject();
			self.cmbVoyage.setObject(self.myCurrentVoyage);
			delete self.myProxyVoyage;
			break;
		else
			result := app.showErrorWarningDialog('Voyage Definition', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		return false;
	endwhile;

	self.anythingChanged := false;	
	self.anythingChangedBay := false;
	
	global.beep;
	rtnValue := true;
	return rtnValue;

epilog
	self.frmModalDialog.visible := false;
	self.btnBaySeqBay.caption := self.CAPTION_BTN_SEQNUM;
	self.btnBaySeqBay.bubbleHelp := self.BUBBLE_SEQNUM;
	self.btnBaySeqBay.visible := true;
	self.btnBaySeqBay40.visible := true;
	self.frmToolBarBay.positionToolbarControls();
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetAllSlots40" id="78fa498a-65b3-4492-b2ad-6b7b9ef16438">
        <source>doSetAllSlots40();
//----------------------------------------------------------------
//	Created:	29 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	pxyStructure : CM_CellularVoyageStructure;
	bay			: CM_Bay;	
begin
	if self.myProxyVoyage = null then
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	pxyStructure := self.myProxyVoyage.myCellularVoyageStructure;
	
	foreach bay in pxyStructure.allBayVoyagesById40 do
		bay.setProxyBaySlots40();
	endforeach;
	global.beep;
epilog
	app.mousePointer := Window.MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetProxyAttributesFromGUI" id="b9e6c92f-6fe3-4f83-9071-5e384ed6b184">
        <updating/>
        <source>doSetProxyAttributesFromGUI() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		Sets the Proxy copy of the Bay and Cell and Slots with the onscreen attributes
//
// Parameters:	None
//
// Returns:		Nothing
//
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    21MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------

vars
	aColumn : CMUI_GridColumn;
	bayFrame,bayFrameUD : CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	bayPoint : SHP_BayPoint;
	theString : CM_String;
	bayArea : SHP_BayArea;
begin
	if self.myCurrentBay = null then
		return;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
	
	// #################################
	// Ondeck Cell Alignment
	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		foreach aColumn in bayFrame.myGridArea.allGridColumns do
			aColumn.SHP_BayColumn.myCell.setAlignment(aColumn.SHP_BayColumn.allignment);
		endforeach;
		foreach aPoint in bayFrame.myGridArea.SHP_BayAreaAboveDeck.allGridPoints do
			if aPoint.isKindOf(SHP_BayPoint) then
				bayPoint := aPoint.SHP_BayPoint;
				bayPoint.mySlotDefn.setAttributes(bayPoint.bayDefnThirtyFoot, bayPoint.bayDefnFiftyThreeFoot,bayPoint.bayDefnFortyFive,bayPoint.bayDefnFortyFoot, bayPoint.bayDefnPowered,bayPoint.bayDefnReefer,
									bayPoint.bayDefnWaterCooled,bayPoint.bayDefnUnavailable,bayPoint.bayDefnDoorDirection20,
									bayPoint.bayDefnDoorDirection20,bayPoint.bayDefnMotorDirection20,bayPoint.bayDefnMotorDirection40,bayPoint.bayDefnMtOnly, bayPoint.bayDefnHeavy, bayPoint.bayDefnVoltage);
			endif;
			//_fortyFront,_power,_reefer,_watercooled,_unavailable,_doors20Aft,_doors40Aft,_mtOnly,_motor20Aft,_motor40Aft
		endforeach;
	endif;
	// #################################
	// Underdeck Cell Alignment
	bayFrame := self.frmGridArea.getControl(UNDERDECK);
	if bayFrame &lt;&gt; null then
		foreach aColumn in bayFrame.myGridArea.allGridColumns do
			aColumn.SHP_BayColumn.myCell.setAlignment(aColumn.SHP_BayColumn.allignment);
		endforeach;
		foreach aPoint in bayFrame.myGridArea.SHP_BayAreaBelowDeck.allGridPoints do
			bayPoint := aPoint.SHP_BayPoint;

			bayPoint.mySlotDefn.setAttributes(bayPoint.bayDefnThirtyFoot, bayPoint.bayDefnFiftyThreeFoot,bayPoint.bayDefnFortyFive,bayPoint.bayDefnFortyFoot, bayPoint.bayDefnPowered,bayPoint.bayDefnReefer,
									bayPoint.bayDefnWaterCooled,bayPoint.bayDefnUnavailable,bayPoint.bayDefnDoorDirection20,
									bayPoint.bayDefnDoorDirection20,bayPoint.bayDefnMotorDirection20,bayPoint.bayDefnMotorDirection40,bayPoint.bayDefnMtOnly, bayPoint.bayDefnHeavy, bayPoint.bayDefnVoltage);

			//_fortyFront,_power,_reefer,_watercooled,_unavailable,_doors20Aft,_doors40Aft,_mtOnly,_motor20Aft,_motor40Aft
		endforeach;
	endif;

	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		bayFrame.myGridArea.drawSelf();
	endif;
	self.currentBayEdition := self.myCurrentBay.edition;


	// ########################
	// DRAW THE LEGEND
	// merge the attributes used on the 2 frames into the top frames and print the legend
	bayFrameUD := self.frmGridArea.getControl(UNDERDECK);
	if bayFrame &lt;&gt; null then
		if bayFrameUD &lt;&gt; null then
			
			foreach theString in bayFrameUD.myGridArea.SHP_BayArea.allAttributesUsed do
				if not global.isValidObject(theString) then
					continue;
				endif;
				if bayFrame.myGridArea.SHP_BayArea.allAttributesUsed[theString.string] = null then
					bayFrame.myGridArea.SHP_BayArea.allAttributesUsed.add(theString);
				endif;
			endforeach;
		endif;	
		bayFrame.myGridArea.SHP_BayArea.displayAttributeLegend(self.frmLegend);
	endif;
	if self.anythingChanged then
		self.anythingChangedBay := true;
	endif;
	self.anythingChanged := false;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetProxyBay" id="b82693c3-5e4f-49f0-ab59-d95aa4529098">
        <updating/>
        <source>doSetProxyBay(theProxyBay : CM_Bay input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theIdBay40,theClonedFromBay,theLashFromTier,theUnlashFromTier,theRemarks, theMaxNumHighCubesIfFull:String;
	theOrdinalBay,theBayType,theMaxPileWeight20IB,theMaxPileWeight20OB,
	theMaxPileWeight40IB,theMaxPileWeight40OB,theMaxPileWeightUD,theNumOfPlugs,theOrdinalHold :Integer;
	theAthwartships,theFortyFootBay,theFortyFootOnly,theFortyFiveFootBay,theFortyFiveFootOnly,theUseCellTierODSequencing,theUseCellTierUDSequencing:Boolean;
	theUseCellTierODSequencing40,theUseCellTierUDSequencing40,theTLOD, theTLUD : Boolean;
	osCrane : Integer;
	aProxyHold : CM_Hold;
	theNextBay ,theRealBay: CM_Bay; //Defn;
	allOtherBays : CM_BayArray;
	result : Boolean;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	result:=true;
	// #############################################
	// set the proxy BAY DEFINITION

	theRealBay := theProxyBay.pxyGetRealObject();
	
	theIdBay40 := self.txt40FootBayID.text;
	theLashFromTier := self.cmbLashFrom.text;
	theUnlashFromTier := self.cmbUnlashFrom.text;
	theRemarks := self.txtRemarks.text;
	theOrdinalBay := theProxyBay.ordinalBay;
	theBayType := self.cmbBayType.listIndex - 1;
	theMaxPileWeight20IB := self.txtMaxPileWt20IB.text.Integer * 1000;
	theMaxPileWeight20OB := self.txtMaxPileWt20OB.text.Integer * 1000;
	theMaxPileWeight40IB := self.txtMaxPileWt40IB.text.Integer * 1000;
	theMaxPileWeight40OB := self.txtMaxPileWt40OB.text.Integer * 1000;
	theMaxPileWeightUD := self.txtMaxPileWtUD.text.Integer * 1000;
	theNumOfPlugs := self.txtNumOfPlugs.text.Integer;

	theAthwartships := self.ckbAftwartships.value;
	theTLOD := self.ckbTwinLiftOD.value;
	theTLUD := self.ckbTwinLiftUD.value;
	theFortyFootBay := self.ckbFortyFootBay.value;
	theFortyFootOnly := self.ckbFortyFootOnly.value;
	theFortyFiveFootBay := self.ckbForty5FootBay.value;
	theFortyFiveFootOnly := self.ckbForty5FtOnly.value;
	theMaxNumHighCubesIfFull := self.txtUDCellsHiCub.text;

	theUseCellTierODSequencing := (self.cmbDirOn.listIndex = 1); // PAR 8824 AKB2004AUGUST
	theUseCellTierUDSequencing := (self.cmbDirUnder.listIndex = 1); // PAR 8824 AKB2004AUGUST
	
	theUseCellTierODSequencing40 := (self.cmbDirOn40.listIndex = 1); // PAR 8824 AKB2004AUGUST
	theUseCellTierUDSequencing40 := (self.cmbDirUnder40.listIndex = 1); // PAR 8824 AKB2004AUGUST
	if self.cmbOnShipCrane.listIndex = -1 then
		osCrane := 0;
	else
		osCrane := self.cmbOnShipCrane.itemData[self.cmbOnShipCrane.listIndex];
	endif;

	aProxyHold := null;
	if self.cmbHolds.listIndex &gt; 0 then
		aProxyHold := self.cmbHolds.itemObject[self.cmbHolds.listIndex].CM_Hold;
	elseif self.cmbHolds.listCount &gt; 0 then
		aProxyHold := self.cmbHolds.itemObject[1].CM_Hold;
	endif;

	if self.myCurrentVoyage &lt;&gt; null then
		theProxyBay.CM_BayVoyage.setProxyBay(theProxyBay.id,theIdBay40,theClonedFromBay,theLashFromTier,theUnlashFromTier,theRemarks,
							theOrdinalBay,null,theBayType,theMaxPileWeight20IB,theMaxPileWeight20OB,
							theMaxPileWeight40IB,theMaxPileWeight40OB,theMaxPileWeightUD,theNumOfPlugs,theOrdinalHold,
							theAthwartships,theFortyFootBay,theFortyFootOnly,theUseCellTierODSequencing,theUseCellTierUDSequencing, theUseCellTierODSequencing40,theUseCellTierUDSequencing40,
							theTLOD, theTLUD,
							self.myCurrentVoyage.myCellularVoyageStructure,aProxyHold,osCrane,theFortyFiveFootBay,theFortyFiveFootOnly);
	endif;
	
	
	//epr par 34518 25/11/14
	if theProxyBay &lt;&gt; null then
		
		create allOtherBays transient;
		foreach theNextBay in theProxyBay.myHold.allBays do
			if theNextBay &lt;&gt; theProxyBay then
				allOtherBays.add(theNextBay);
				theNextBay.setBayType(theBayType);
			endif;
		endforeach;
		
		if not theProxyBay.setProxyCellsODFromLabels(self.txtOnDeckCells.text,true) then
			result:= false;
		endif;
		if not theProxyBay.setProxyCellsUDFromLabels(self.txtUnderDeckCell.text,self.txtUDCellsHiCub.text,true) then
			result:= false;
		endif;
		if not theProxyBay.setProxyTiersODFromLabels(self.txtOnDeckTier.text,true) then
			result:= false;
		endif;
		if not theProxyBay.setProxyTiersUDFromLabels(self.txtUnderDeckTier.text,true) then
			result:= false;
		endif;
		
		if self.mode = Mode_Update then
			foreach theNextBay in allOtherBays  discreteLock do
				if theNextBay.getAllCellsOnDeck().trimBlanks &lt;&gt; self.txtOnDeckCells.text.trimBlanks then
					theNextBay.setProxyCellsODFromLabels(self.txtOnDeckCells.text,false);		
				endif;
				if theNextBay.getAllCellsUnderDeck().trimBlanks &lt;&gt; self.txtUnderDeckCell.text.trimBlanks then
					theNextBay.setProxyCellsUDFromLabels(self.txtUnderDeckCell.text,null,false);
				endif;
				if theNextBay.getAllTiersOnDeck().trimBlanks &lt;&gt;  self.txtOnDeckTier.text.trimBlanks then
					theNextBay.setProxyTiersODFromLabels(self.txtOnDeckTier.text,false);
				endif;
				if theNextBay.getAllTiersUnderDeck().trimBlanks &lt;&gt; self.txtUnderDeckTier.text.trimBlanks then
					theNextBay.setProxyTiersUDFromLabels(self.txtUnderDeckTier.text,false);
				endif;
			endforeach;
		endif;
	endif;
	
	return result;
epilog
	delete allOtherBays;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="theProxyBay" type="CM_Bay" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetProxyVoyageCellular" id="7f77536b-6133-45dd-b945-b6a94d472587">
        <source>doSetProxyVoyageCellular(_pxyStructure : CM_CellularVoyageStructure input);
//--------------------------------------------------------------
//Created: June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpBridgeAfterBay 			: String; 		
	tmpUse40Id,
	tmpUseBayCellTierNumbering,
	tmpISOHalfHeights				: Boolean;
	changes : Boolean;
begin
	
	if _pxyStructure = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy Cellular Voyage Structure is null.');
		return;
	endif;

	self.doUpdateDeckCellProxies( self.tblOnCellDims, self.tblUnderCellDim, changes );	//19 Oct 2010	NDL	Par 26058
	
	self.doBuildProxyHoldList(self.txtNumHolds.text.Integer);
	
	tmpBridgeAfterBay := self.cmbBridgeAftBay.text;
	tmpISOHalfHeights := self.ckbISOHalfHeight.value;
	tmpUse40Id := self.ckb40BayIds.value;
	tmpUseBayCellTierNumbering := self.cmbStowageNumber.text = Vessel_Stowage_Type_BCT_Text;
	
	_pxyStructure.setProxyCellularVoyage(tmpBridgeAfterBay, tmpISOHalfHeights, tmpUse40Id, tmpUseBayCellTierNumbering);


end;</source>
        <Parameter name="_pxyStructure" type="CM_CellularVoyageStructure" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doZoom" id="476b35d2-d90f-4531-a724-59b77bdbc7a5">
        <updating/>
        <source>doZoom(pFactor : Real; _theSDF : CMUI_ScrollableDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	posH, posV : Real;
	theHValue, theVValue : Integer;	
	endTime,startTime : TimeStamp;
	thePoints : CMUI_GridPointSet;
	aPoint : CMUI_GridPoint;
	theSDF : CMUI_ScrollableDrawingFrame;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	theSDF := _theSDF;
	
	create thePoints transient;
	theSDF.getAllSelectedPoints(thePoints);
	posH := (theSDF.myHScroll.value / theSDF.myHScroll.max).Real;
	posV := (theSDF.myVScroll.value / theSDF.myVScroll.max).Real;
	
	theSDF.doZoom(pFactor);

	aPoint := thePoints.first;
	if aPoint &lt;&gt; null then
		aPoint.getXYOnSDF(theHValue,theVValue);
	else
		theHValue := (theSDF.myHScroll.max * posH).Integer;
		theVValue := (theSDF.myVScroll.max * posV).Integer;
	endif;
	theSDF.myHScroll.value := theHValue;
	theSDF.myVScroll.value := theVValue;
	theSDF.repositionScrollBars();
	
epilog 
	delete thePoints;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="pFactor" type="Real"/>
        <Parameter name="_theSDF" type="CMUI_ScrollableDrawingFrame"/>
    </JadeMethod>
