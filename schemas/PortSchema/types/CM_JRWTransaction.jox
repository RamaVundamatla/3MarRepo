    <JadeMethod name="getEndDateLocalTZ" id="e7f46d43-12be-4290-9396-00433cfc38ce">
        <source>getEndDateLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2016	cnwns1	Initial creation
// 03 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.endDate,TimeEndOfDay);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
