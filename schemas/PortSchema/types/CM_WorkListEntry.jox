    <JadeMethod name="getCarryComplete" id="166c8f47-b729-4c87-8aeb-046f849e1474">
        <source>getCarryComplete() : Time;
/*
Purpose:	OPSVIEW		

Date		Who		Reason
13 December 2021	navab1	TFS 51853
*/

vars
	qentry : CM_RTQueueEntry;
	qtask : CM_RTQueueTask;
	start, finish : TimeStamp;
	posneg, totdays : Integer;
	length : Time;
begin
	qentry := self.allRTQueueEntries.first;
	
	if qentry = null then
		return self.completedDate.time;  // ### TFS 51855 24JAN2022 NAVAB1
	endif;
	
	if qentry.areAllTasksEqualStatus(TASK_COMPLETE) then
		qtask := qentry.allTasks.first;
		if qtask &lt;&gt; null then
			start := qtask.machineAssignedDT;
			
			qentry := self.allRTQueueEntries.last;
			
			if qentry = null then
				return self.completedDate.time;  // ### TFS 51855 24JAN2022 NAVAB1
			endif;
			
			if qentry.areAllTasksEqualStatus(TASK_COMPLETE) then
				qtask := qentry.allTasks.first;
				if qtask &lt;&gt; null then
					finish := qtask.machineAssignedDT;
					
					length := start.differenceAsTime(finish,posneg, totdays);
					return length;
				endif;
			endif;
		endif;
	endif;

		return self.completedDate.time;  // ### TFS 51855 24JAN2022 NAVAB1
epilog

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="getCurrentRTQueueName" id="64004f19-279b-4bee-bc8d-b739f802495e">
        <source>getCurrentRTQueueName():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2017	jlgndl1	Initial creation	TFS 5312

*/

vars

	iter : Iterator;
	rtQueueEntry : CM_RTQueueEntry;
	queue : CM_RadioTelemetryQueue;
	allQueues : CM_RTQueueSet;
	retString : String;
	invalid : Boolean;
	wle : CM_WorkListEntry;

begin

	on Exception do app.handleDeletedObject(exception,rtQueueEntry,invalid);
	
	create allQueues transient;
	
	if self.isTransient then
		wle := self.pxyGetRealObject().CM_WorkListEntry;
	else
		wle := self;
	endif;
	
	if wle = null then
		return null;
	endif;
	
	iter := wle.allRTQueueEntries.createIterator;
	while iter.next( rtQueueEntry ) do
		queue := rtQueueEntry.myQueue;
		if queue &lt;&gt; null then
			allQueues.addNoDuplicates( queue, false );
		endif;
	endwhile;

	if not allQueues.isEmpty then
		foreach queue in allQueues do
			if retString &lt;&gt; null then
				retString := retString &amp; ", ";
			endif;
			retString := retString &amp; queue.id;
		endforeach;
	endif;
	
	return retString;

epilog

	delete iter;
	delete allQueues;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCustomStatus" id="6b922d51-4e70-4e7e-b511-45f44fa4986f">
