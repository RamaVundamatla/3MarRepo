    <JadeMethod name="cmbJob_click" id="c65f87fc-1765-4d4e-8756-f4b1e5c2ff57">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbJob_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	voyageJob : CM_VoyageJob;
begin
	self.tblEntry.setValueByControlName(combobox.name,combobox.text);
	
	voyageJob:=combobox.listObject.CM_VoyageJob;
	
	if voyageJob &lt;&gt; null then
		if voyageJob.isDischarge then
			self.tblEntry.setValueByName(ETRow_StowageType,app.getErrorString(CM_Discharge));
		else
			self.tblEntry.setValueByName(ETRow_StowageType,app.getErrorString(CM_Load));
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
