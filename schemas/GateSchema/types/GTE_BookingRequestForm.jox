    <JadeMethod name="getTransTypeFromCmb" id="6c04fa0d-3c71-4e19-b15e-49726ef25677">
        <source>getTransTypeFromCmb(): Integer;
//29 September 2009	cnwml2


vars

begin
	if self.cmbTransType.text = app.transModeToString(BR_TYPE_ROAD) then
		return app.transModeToCode(self.cmbTransType.text);
	elseif self.cmbTransType.text = app.transModeToString(BR_TYPE_RAIL) then
		return app.transModeToCode(self.cmbTransType.text);
	elseif self.cmbTransType.text = app.transModeToString(TI_TRANSMODE_PACKING) then // cnwrd1 POL packing stuff CCMS 2103 par 27856
		return BR_TYPE_PACKING;// app.transModeToCode(self.cmbTransType.text);		//hack
	else
		return BR_TYPE_ROAD;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
