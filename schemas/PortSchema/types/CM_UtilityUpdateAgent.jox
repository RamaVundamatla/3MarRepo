    <JadeMethod name="utlUpdQshipsWSLastSuccessTS" id="aa801538-ff5a-4eb8-949f-3560900f8788">
        <source>utlUpdQshipsWSLastSuccessTS(_webService: CM_ExternalWebServiceDef input; _timeStamp: TimeStamp; _passport : CM_Passport input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 March 2023
TFS#		: 57276
Function	: Update Qships Web Service Last Successful Date/Time

*** Changes ***
Date			Name		TFS#		Description
24.Jul.24 		navsp1 		TFS ChangeRequest 63842: NSW | OnePort Integration Dev
09 Dec 2025 	navah1		MTN-36364: NSW | OnePort API Last Run Date - Use the terminal-specific Last Successful Date/Time for external web service task runs
****************************************************/

begin
	self.initialiseActivity();
	if _webService.isKindOf(CM_QshipsWebServiceDef) then						//63842
		_webService.CM_QshipsWebServiceDef.setLastSuccessfulTS(_timeStamp);		//63842
	elseif _webService.isKindOf(CM_APIEndpointServiceDef) then					//63842
		//_webService.CM_APIEndpointServiceDef.setLastSuccessfulTS(_timeStamp);	//63842 //09.12.2025 navah1 #MTN-36364
		_webService.CM_APIEndpointServiceDef.setLastSuccessfulTSByTerminal(_timeStamp, _passport.myTerminal); //09.12.2025 navah1 #MTN-36364
	endif;
end;</source>
        <Parameter name="_webService" type="CM_ExternalWebServiceDef" usage="input"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
