<Class name="HMS_WharfSection" id="f3db906c-7dcf-456b-82a9-83ac5ce7644d">
    <superclass name="HMS_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <PrimAttribute name="endMeterage" id="76d6b7de-06bb-4ac9-a282-d7140516352f">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myWharf" id="0101bbe7-3da1-4c8b-bdc8-29196073cfde">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="HMS_Wharf"/>
        <access>readonly</access>
        <Inverse name="HMS_Wharf::allWharfSections"/>
    </ExplicitInverseRef>
    <PrimAttribute name="startMeterage" id="cee73fca-a37c-49ae-8e7b-5513d804c446">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="pxyCreateUpdateProxy" id="4382a4b4-2032-4dc4-b5fc-6717dc343063">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_WharfSection;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myWharf := self.myWharf;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setEndMeterage" id="49b76d9d-a145-44dc-be79-bc944d0762d0">
        <updating/>
        <source>setEndMeterage(_endMeterage : Integer)updating;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	self.endMeterage := _endMeterage;
end;</source>
        <Parameter name="_endMeterage" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a5344f98-5103-4374-95bd-966290439383">
        <updating/>
        <source>setForUpdate(_pxyWharfSection: HMS_WharfSection; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyWharfSection, _passport);
	
	self.endMeterage := _pxyWharfSection.endMeterage;
	self.startMeterage := _pxyWharfSection.startMeterage;
	self.myWharf := _pxyWharfSection.myWharf;

end;</source>
        <Parameter name="_pxyWharfSection" type="HMS_WharfSection"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a88dc39f-f938-4d1f-9ee7-eac2f9293680">
        <updating/>
        <source>setProxy(_endMeterage, _startMeterage : Integer; _wharf : HMS_Wharf)updating;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.endMeterage := _endMeterage;
	self.startMeterage := _startMeterage;
	self.myWharf := _wharf;
end;</source>
        <Parameter name="_endMeterage" type="Integer"/>
        <Parameter name="_startMeterage" type="Integer"/>
        <Parameter name="_wharf" type="HMS_Wharf"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="e987beb3-c613-4be7-9b33-4629fa64608a">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	tmpWharfSection : HMS_WharfSection;
begin
	inheritMethod(_passport);

	if self.endMeterage &lt; 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'End Meterage', ETRow_EndMeterage, null);
		app.raiseCMException(Input_required_field_endMetre, ETRow_EndMeterage, null); // cnwdb2	PAR 35364


	endif;
	if self.startMeterage &lt; 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Start Meterage', ETRow_StartMeterage,  null);
		app.raiseCMException(Input_required_field_strtMeter, ETRow_StartMeterage,  null); // cnwdb2	PAR 35364
	endif;

	if self.myWharf = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Wharf', ETRow_MyWharf,  null);
		app.raiseCMException(Input_required_field_wharf, ETRow_MyWharf,  null); // cnwdb2	PAR 35364
	endif;

	if _passport.hasErrors then
		return;
	endif;

	tmpWharfSection := self.myWharf.allWharfSections.getAtKey(self.startMeterage, self.endMeterage);
	if tmpWharfSection &lt;&gt; null then
		if self.isTransient and tmpWharfSection &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'WharfSection', self.startMeterage.String, ETRow_StartMeterage, null); //14.06.2022 navds20 53760
			// WharfSection already exists for %1 : Wharfsecti_already_exists
			app.raiseCMException1(Wharfsecti_already_exists, self.startMeterage.String, ETRow_StartMeterage, null); //14.06.2022 navds20 53760
		endif;
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
