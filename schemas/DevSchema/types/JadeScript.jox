    <JadeMethod name="eprTestCreateVoyRequest" id="a3a4fcfe-b031-4377-b16f-ba7ea3d639bc">
        <source>eprTestCreateVoyRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2018	jlger1	Initial creation

*/

vars


	terminal : CM_Terminal;
	vessel: CM_Vessel;
	now : TimeStamp;
	operator : CM_Operator;
	pxyVoyage : CM_Voyage;
	departureTS,
	arrivalTS : TimeStamp;
	pxyWorkOrder : CM_WorkOrderVoyage;
	pxyWorkOrderExtension : CM_WodExtension;
	//departureTS : TimeStamp;
	realWorkOrder : CM_WorkOrder;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("CNWER1");
	
	terminal:=CM_Root.firstInstance.allTerminals["JBL"];
	app.myPassport.setMyTerminal(terminal);
	
	vessel:="4477.518226".asOid.CM_Vessel;
	vessel:="4477.35995".asOid.CM_Vessel;
	operator:="2312.5358".asOid.CM_Operator;
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	
	departureTS.setDate("24/08/2018".Date);
	departureTS.setTime("12:00".Time);
	/*
	pxyVoyage:= vessel.createProxyVoyageRequest(terminal,"A3",operator,arrivalTS,departureTS,false,null, null, 
	null,null,null,null,null,null,null,null,null,app.myPassport);
	
	app.myPassport.setWarningsIgnored(true);
	
	app.myTrxCA.trxCreateVoyageRequest(pxyVoyage,
										vessel,
										null,null,
										app.myPassport);
	
	//app.myTrxCA.trxCreateVoyageRequest(vessel,terminal,"DEX212",operator,now,7,true,null,app.myPassport);
	*/
	
	

	
	
	create pxyWorkOrder  transient;
	pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,app.myPassport.myTerminal,null,null,null, WO_STATUS_PENDING);
	pxyWorkOrder.setMyVoyage("4480.1246686".asOid.CM_Voyage);	
	
	//departureTS:=self.tanggalSelesai.asTimeStampFromInaportnet;
	
	create pxyWorkOrderExtension transient;
	pxyWorkOrderExtension.setProxyWodExtension(departureTS, false);
	pxyWorkOrder.allWoDtls.add(pxyWorkOrderExtension);
	
	app.myPassport.setWarningsIgnored( true);
	app.myPassport.setWarningsAcknowledged( true);
	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,app.myPassport);
	
	 app.myPassport.dumpErrorWarnings;
epilog
	delete pxyVoyage;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestDecimalDays" id="336aba17-587f-4a1a-ba93-cdf41923f2b8">
        <source>eprTestDecimalDays();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlger1	Initial creation

*/

vars
	now,
	newNow : TimeStamp;
begin
	write now.addHours(12);
