    <JadeMethod name="drawMe" id="94569dac-be43-43d6-a454-49a9c901f874">
        <updating/>
        <source>drawMe()updating;

vars
  	chkptTime, moveTime, moveTimeStandardTime, now:	TimeStamp;
  	clocksChangeToday, junk : Boolean;
  	timeStr :String;
begin

	if (not global.isValidObject(self.myWorkingMovement)) then
		self.myWorkingMovement := null;
	endif;
	
	if self.myWorkingMovement &lt;&gt; null then
		self.setCaption(self.myWorkingMovement.getDisplayStringForAttribute(ETRow_HmsMovementShip, false) &amp; ' ' &amp; self.Caption);
		moveTime := self.myWorkingMovement.occursOnDT;

		now := app.actualTimeServer();
		//aa 23/8/01 Check the daylight saving time status of both the move time and the system time
		//moveTimeIsDST := moveTime.checkIfDaylightSaving(clocksChangeToday);
		//systemTimeIsDST := now.checkIfDaylightSaving(junk);
		moveTimeIsDST := self.myTerminal.checkIfDaylightSaving(moveTime, clocksChangeToday);
		systemTimeIsDST := self.myTerminal.checkIfDaylightSaving(now, junk);	
	
		if moveTimeIsDST then
			timeStr := "Daylight Time";
			moveTimeStandardTime := moveTime.changeByXXMinutes(-60);		//Convert move time from NZDT to NZST
		else
			timeStr := "Standard Time";
			moveTimeStandardTime := moveTime;	
		endif;
	
		if clocksChangeToday then
			timeStr := timeStr &amp; " (Changes Today)";
		endif;
		
		// get the values for the window of opportunity graph
		self.getEntranceWindowValues(moveTimeStandardTime);
	
		chkptTime := moveTime.changeByXXMinutes(minuteOffset);
		timestampCenter := chkptTime.changeByXXMinutes(offsetForReportedTimes);
	
		timestampStart := timestampCenter.changeByXXMinutes(-720);
		
	else
		self.setCaption(self.Caption);
		self.windowArray.clear;
	endif;

	// draw the time line
	self.drawTime(timeStr);

	self.plotEntranceWindow();

end;</source>
    </JadeMethod>
    <JadeMethod name="drawTime" id="ff125cbc-fd04-444b-82ad-bf59825f3237">
        <source>drawTime(zoneStr : String);

vars
	t1,t2,t3 : Time;
	s1,s2,s3,s4 : String;
begin
	lblTime.clearGraphics;

	t2 := timestampCenter.time;
	t1 := t2 - (12 * 60 * 60000);
	t3 := t2 + (12 * 60 * 60000);
	s1 := t1.format('HH:mm');
	s2 := t2.format('HH:mm');
	s3 := t3.format('HH:mm');
	s4 := timestampCenter.date.shortFormatJMT() &amp; " " &amp; zoneStr;

	lblTime.drawTextAlign := DrawTextAlign_Left;
	lblTime.drawTextAt(s1,0,10,Black);
	lblTime.drawTextAlign := DrawTextAlign_Center;
	lblTime.drawTextAt(s4,lblTime.width/2,0,Black);
	lblTime.drawTextAt(s2,lblTime.width/2,10,Black);
	lblTime.drawTextAlign := DrawTextAlign_Right;
	lblTime.drawTextAt(s3,lblTime.width,10,Black);
	

end;</source>
        <Parameter name="zoneStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="getEntranceWindowValues" id="724f432b-3d17-49f8-ba43-ba3cca24a338">
        <updating/>
        <source>getEntranceWindowValues(moveTime : TimeStamp)updating;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------------------
// 09/10/2013	cnwdap1		PAR #32656 Correct daylight savings adjustments - since PAR 28250, self.windowArray
//							can have null entries in teh first and last positions, so don't do adjustments to these
vars
 	
	selectedRegion:			HMS_HarbourRegion;
	tideClass:				HMS_TidalClass;
	voyageData:				HMS_VoyageData;
	harbour:				HMS_Harbour;
 	currentLimitPosve:		Real;
 	currentLimitNegve:		Real;
 	draftLimit:				Real;
 	enterLeaveStatus:		String;
    i: 						Integer;
    daylightAdjust: 		Time;
    tmpBerth:				HMS_Berth;
begin

	harbour := self.myWorkingMovement.myHarbour;

    // Get first region with checkpoints
    selectedRegion:=myWorkingMovement.getFirstRegionWithChkPts(self.minuteOffset,enterLeaveStatus,myWorkingMovement.getMovementPrevious);
	

	if selectedRegion &lt;&gt; null then 
	    //myTargetTimeStamp:=myMovement.occursOnDT;
	    if myWorkingMovement.myMoveTidalClass=null then
			// tideClass := myMovement.ofWorkingVoyage.ofVessel.tidalClass;
			// Modified by Russell 29/03/99
			// ---------------------------------------------------
			if myWorkingMovement.moveType=HMSMovementTypeDeparture then
				tideClass:=myWorkingMovement.myWorkingVoyage.myHMSVoyageData.myTidalClassDept;
				if tideClass=null then
					tideClass:=myWorkingMovement.myWorkingVoyage.myHMSVoyageData.myTidalClass;
				endif;	
			else
				tideClass:=myWorkingMovement.myWorkingVoyage.myHMSVoyageData.myTidalClass;
			endif;	

			// ---------------------------------------------------
		else
			tideClass:=myWorkingMovement.myMoveTidalClass;
		endif;

		if tideClass &lt;&gt; null then
			if enterLeaveStatus = HMSMovementTypeEntering then
				currentLimitPosve:= tideClass.allMaximumCurrents[1];	// flood tide
				currentLimitNegve:= (tideClass.allMaximumCurrents[2])*-1;	// ebb tide
			else
				currentLimitPosve:= tideClass.allMaximumCurrents[3];	// flood tide
				currentLimitNegve:= (tideClass.allMaximumCurrents[4])*-1;	// ebb tide
			endif;
			lblTidalClass.caption := "Tidal Class: " &amp; tideClass.description;
		else			
			currentLimitPosve:=100;
		 	currentLimitNegve:=-100;
		 	lblTidalClass.caption := "Tidal Class: None";
		endif;

		voyageData := myWorkingMovement.myWorkingVoyage.myHMSVoyageData;

		if myWorkingMovement.draftMax &gt;= 0.1 then
			draftLimit := myWorkingMovement.draftMax;	//4.1.1: Use movement drafts by default
			lblDraft.caption := "Draft: " &amp; draftLimit.String &amp; " m";
		elseif voyageData &lt;&gt; null then
			if voyageData.dim_DraftAft &gt; voyageData.dim_DraftFore then
			 	draftLimit := voyageData.dim_DraftAft;
			else
			 	draftLimit := voyageData.dim_DraftFore;
			endif;		
			lblDraft.caption := "Draft: " &amp; draftLimit.String &amp; " m";
		else
			draftLimit := 50;
			lblDraft.caption := "Draft: 0.0 m";
		endif; 

		windowArray.clear;
		//AJA 19/6/00: Use rewritten function to get tidal windows
		// PAR 14079 This was using getTidalWindows not getTidalWindows2 
			// Modified by Russell 02/08/99
		// -------------------------------------------------------------------------------------------------
		// Adjust tidal restriction windows times to report relative to pilot on board time or time at wharf
		// depending on the preference setting.

		self.setOffsetTimeAndLocation();

		// -------------------------------------------------------------------------------------------------
		app.myHMSRvTide.getTidalWindows2(selectedRegion,moveTime,currentLimitPosve,currentLimitNegve,draftLimit,windowArray,self.minuteOffset);
		
		if moveTimeIsDST and not systemTimeIsDST then
			daylightAdjust.setTime(1,0,0,0);
			foreach i in 1 to windowArray.size do
				if windowArray[i] &lt;&gt; null then								// PAR #32656
					windowArray[i] := windowArray[i] + daylightAdjust;
				endif;														// PAR #32656
			endforeach;
		endif;

		if systemTimeIsDST and not moveTimeIsDST then
			daylightAdjust.setTime(1,0,0,0);
			foreach i in 1 to windowArray.size do
				if windowArray[i] &lt;&gt; null then								// PAR #32656
					windowArray[i] := windowArray[i] - daylightAdjust;
				endif;														// PAR #32656
			endforeach;
		endif;



		// change the offset time to be based from the berth view
		//minuteOffset := minuteOffset * -1;
		//offsetForReportedTimes:=offsetForReportedTimes * -1;

		/*lblNotAvailable.visible := false;
		legendRegion.visible:= true;
		legendBerth.visible	:= true;*/
		if selectedRegion &lt;&gt; null then
			lblLegendRegion.caption := 'Region : ' &amp; selectedRegion.description;
		else
			lblLegendRegion.caption := 'Region : ';		
		endif;

		// Modified by Russell 30/07/99
		// -------------------------------------------------------------------------
		if reportTimeCaption&lt;&gt;"" then
			lblLegendBerth.caption:=reportTimeCaption;
		else
			tmpBerth := myWorkingMovement.getBaseTimeBerth();
			if tmpBerth &lt;&gt; null then
				lblLegendBerth.caption	:= 'Berth    : ' &amp; tmpBerth.description;
			else
				lblLegendBerth.caption	:= 'Berth    : ';			
			endif;
		endif;
		// -------------------------------------------------------------------------

	else
		windowArray.clear;
	endif;


end;</source>
        <Parameter name="moveTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationRefreshView" id="6819f252-ce45-4c8f-ac4c-d0fa6116e4ae">
        <updating/>
        <source>handleNotificationRefreshView(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

begin
	app.msgBox(app.getErrorString(HMS_RefreshView), app.getErrorString(Refreshing_View) &amp; ': ' &amp; self.caption, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);		
	self.unloadForm();
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="feb8e26d-a9e5-4eb4-98cf-d213a1ee6f1b">
        <updating/>
        <source>initForm()updating;
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
vars
begin

	self.setNavigatorHeading(self.caption);
	// setup the shading, rows and columns on the tables
	self.initTables();

	// setup the graphic properties for anything that will be drawn on
	lblTime.autoRedraw := true;
	tblEntranceWindow.autoRedraw := true;
	lblTime.drawFontName		:= 'Arial';
	lblTime.drawFontSize		:= 8;

	// set the minutes per pixel item
	minutesPerPixel := 1440 / tblEntranceWindow.width;

	legendRegion.backColor 	:= Black;
	legendBerth.backColor	:= TidalWindowBlue;
	lblTidalClass.backColor := TidalWindowBlue;
	self.lblNotAvailable.backColor := self.backColor;
	
	self.width := tblDetails.width + 25;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="initTables" id="24229643-8071-4675-bc17-5cc5df464570">
        <source>initTables();

constants
	Stripe : Integer = 15724527; // very light gray

vars
	int : Integer;
	colW: Integer;
	rowH: Integer;
begin

	// setup the table that will be drawn on...
	tblEntranceWindow.columns:= 24;
	tblEntranceWindow.rows	:= 6;
	colW := (tblEntranceWindow.width / 24).Integer; 
	tblEntranceWindow.backColor := White;
	tblEntranceWindow.gridColor := DarkGray;
	tblEntranceWindow.accessMode := Table.AccessMode_Column;

	int := 1;
	while int &lt;= 24 do
		tblEntranceWindow.columnWidth[int] := colW;		
		if int mod 2 = 0 then
			tblEntranceWindow.column := int;
			tblEntranceWindow.backColor := Stripe;
		endif;				
		int := int + 1;
	endwhile;

	tblEntranceWindow.accessMode := Table.AccessMode_Row;

	int := 1;
	while int &lt;= 6 do
		tblEntranceWindow.rowHeight[int] := 10;
		int := int + 1;
	endwhile;		

	tblEntranceWindow.accessMode 	:= Table.AccessMode_Sheet;
	tblEntranceWindow.readOnly   	:= true;
	tblEntranceWindow.autoRedraw 	:= true;
	tblEntranceWindow.drawStyle  	:= DrawStyle_Solid;
	tblEntranceWindow.drawWidth	:= 3;		
	tblEntranceWindow.drawTextAlign := DrawTextAlign_Center;
	
	/*tblDetails.rows := 0;
	tblDetails.rows := 6;
	tblDetails.clear;
	tblDetails.accessMode 	:= Table.AccessMode_Sheet;
	tblDetails.backColor  	:= White;
	tblDetails.accessMode 	:= Table.AccessMode_Row;
	tblDetails.row			:= 1;
	tblDetails.column		:= 1;
	tblDetails.backColor	:= Stripe;
	tblDetails.text			:= '#' &amp; Tab &amp; 'Window Start' &amp; Tab &amp; 'Window Finish';	
	tblDetails.column 		:= 1;*/
	
	// setup the table that will display the text details ...
	tblDetails.columns := 3;
	tblDetails.rows	   := 6;
	tblDetails.height  := tblDetails.rowHeight[1] * 6;	
	tblDetails.accessMode := Table.AccessMode_Row;
	tblDetails.row 		:= 1;
	tblDetails.backColor:= Stripe;
	tblDetails.accessMode 	:= Table.AccessMode_Column; 
	tblDetails.row		:= 1;
	tblDetails.column	:= 1;
	tblDetails.text		:= '#' &amp; Tab &amp; 'Window Start' &amp; Tab &amp; 'Window Finish';
	self.frmDetail.backColor := self.backColor;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="52a7b8de-4295-45b4-9787-dc6f2e5bdc9d">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	05 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	
	//GD shifted to here because it was causing the form height to be reset incorrectly
	self.handleMenusForModalDisplay();			// cnwdad1 02/03/2005.	
	if self.myWorkingMovement &lt;&gt; null then
		self.drawMe();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="plotEntranceWindow" id="961a832f-2cff-4dbc-b949-0070bb92e3b9">
        <updating/>
        <source>plotEntranceWindow() updating;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------------
// 21/05/2012	cnwdap1		PAR #28250 Suppress display of the first entry or the last entry
//							in the window array if they're blank
constants
	Stripe : Integer = 15724527; // very light gray

vars
	int,size	: Integer;
	ts1,ts2		: TimeStamp;
	t			: Time;
	start,stop,
	tWidth,tHeight,
	offset,pos 	: Real;
	str			: String;
	c			: Control;
	mo,h,m,s,ms	: Integer;
	ts1Offset,
	ts2Offset	: TimeStamp;
	roundTo		: Integer;
	tsDate		: Date;
	startD		: String;		// PAR #28250
	startT		: String;		// PAR #28250
	finishD		: String;		// PAR #28250
	finishT		: String;		// PAR #28250
begin

	roundTo := 15;	// Round reported times to the nearest 15 mins

	self.tblEntranceWindow.clearGraphics;
	self.tblDetails.rows := 1;
	self.tblDetails.rows := 6;
	self.tblDetails.row := 1;
	self.tblDetails.column := 1;	

	int := 1;
	size:= windowArray.size;
	while int &lt;= size do
		if int mod 2 &lt;&gt; 0 then
			ts1 := self.windowArray[int];
		else
			ts2 := self.windowArray[int];
			// draw the window of opportunity

			// Modified by Russell 19/10/99 - Round reported times to nearest 15 mins
			// ------------------------------------------------------------------
			if ts1 &lt;&gt; null then												// PAR #28250
				ts1Offset:=ts1.changeByXXMinutes(offsetForReportedTimes);
			endif;															// PAR #28250
			if ts2 &lt;&gt; null then												// PAR #28250
				ts2Offset:=ts2.changeByXXMinutes(offsetForReportedTimes);
			endif;															// PAR #28250

            // Round offset times
            ts1Offset:=ts1Offset.roundToXXMinutes(roundTo);
            ts2Offset:=ts2Offset.roundToXXMinutes(roundTo);


			if ts1 &lt;&gt; null then												// PAR #28250
				ts1:=ts1Offset.changeByXXMinutes(-1*offsetForReportedTimes);
			endif;															// PAR #28250
			if ts2 &lt;&gt; null then												// PAR #28250
				ts2:=ts2Offset.changeByXXMinutes(-1*offsetForReportedTimes);
			endif;															// PAR #28250
			// ------------------------------------------------------------------
	
			if ts1 &lt;&gt; null then															// PAR #28250
				start := (timestampStart.minutesDiff(ts1) / minutesPerPixel).Integer;
			endif;																		// PAR #28250
			if ts2 &lt;&gt; null then															// PAR #28250
				stop  := (timestampStart.minutesDiff(ts2) / minutesPerPixel).Integer;
			else																		// PAR #28250
				stop  := (self.tblEntranceWindow.width + self.tblEntranceWindow.left);	// PAR #28250
			endif;																		// PAR #28250
		
			// draw the actual time blocks
			tblEntranceWindow.drawFillColor := Black;
			tblEntranceWindow.drawFilledRectangle(start,0,stop,tblEntranceWindow.height/2,Black);
			str := (int/2).String;
			tHeight := tblEntranceWindow.drawTextHeight(str)/2;
			offset  := tblEntranceWindow.height / 4;
			tblEntranceWindow.drawTextAt(str,((stop - start)/2)+ start,offset-tHeight,White);

			// draw the offset time as seen from the wharf
			//start := start + (minuteOffset / minutesPerPixel).Integer;
			//stop  := stop  + (minuteOffset / minutesPerPixel).Integer;
			
			start := start + (self.offsetForReportedTimes / minutesPerPixel).Integer;
			stop  := stop  + (self.offsetForReportedTimes / minutesPerPixel).Integer;
		
			tblEntranceWindow.drawFillColor := TidalWindowBlue;
			tblEntranceWindow.drawFilledRectangle(start,tblEntranceWindow.height/2,stop,tblEntranceWindow.height,TidalWindowBlue);
			tblEntranceWindow.drawTextAt(str,((stop - start)/2)+ start,(offset*3)-tHeight,White);

			// display the text details for each window
			// adjust the timestamp to get the time at the wharf...
			mo := offsetForReportedTimes.abs;
			h := (mo/60).Integer;
			m  := (mo - (h * 60)).Integer;
			s  := 0;
			ms	 := 0;
			t.setTime(h,m,s,ms);
			if offsetForReportedTimes &lt; 0 then
				if ts1 &lt;&gt; null then											// PAR #28250
					ts1 := ts1 - t;
				endif;														// PAR #28250
				if ts2 &lt;&gt; null then											// PAR #28250
					ts2 := ts2 - t;
				endif;														// PAR #28250
			else
				if ts1 &lt;&gt; null then											// PAR #28250
					ts1 := ts1 + t;
				endif;														// PAR #28250
				if ts2 &lt;&gt; null then											// PAR #28250
					ts2 := ts2 + t;
				endif;														// PAR #28250
			endif;			
			
			// show text details
			tblDetails.row := ((int/2) + 1).Integer;
			if ts1 &lt;&gt; null then												// PAR #28250
				startD := ts1.date.shortFormatJMT();						// PAR #28250
				startT := ts1.time.format('HH:mm');							// PAR #28250
			endif;															// PAR #28250
			if ts2 &lt;&gt; null then												// PAR #28250
				finishD := ts2.date.shortFormatJMT();						// PAR #28250
				finishT := ts2.time.format('HH:mm');						// PAR #28250
			else															// PAR #28250
				finishD := null;											// PAR #28250
				finishT := null;											// PAR #28250
			endif;															// PAR #28250
			//tblDetails.text:= (int/2).String &amp; Tab &amp; ts1.date.shortFormatJMT() &amp; ' ' &amp;	// PAR #28250
			//				ts1.time.format('HH:mm') &amp; Tab &amp; 								// PAR #28250
			//				ts2.date.shortFormatJMT() &amp; ' ' &amp; ts2.time.format('HH:mm');		// PAR #28250
			tblDetails.text:= (int/2).String &amp; Tab &amp; startD &amp; ' ' &amp;							// PAR #28250
							startT &amp; Tab &amp; 													// PAR #28250
							finishD &amp; ' ' &amp; finishT;										// PAR #28250
			//if ts1 &lt;= myTargetTimeStamp and ts2 &gt;= myTargetTimeStamp then
			//if ts1 &lt;= timestampCenter and ts2 &gt;= timestampCenter then						// PAR #28250
			if ts1 &lt;= timestampCenter and (ts2 = null or ts2 &gt;= timestampCenter) then		// PAR #28250
				// changed to actual access the row - PAR-10637
				tblDetails.accessRow(tblDetails.row).backColor := MovementIsSelected;
				//tblDetails.backColor := MovementIsSelected;
			endif;	
		endif;		
		int := int + 1;
	endwhile;

	// draw a center line on the graph
	tblEntranceWindow.drawWidth := 2;
	pos := (tblEntranceWindow.width/2) + ((offsetForReportedTimes * -1)/minutesPerPixel);
	tblEntranceWindow.drawLine(pos,0,pos,tblEntranceWindow.height/2,Red);
	tblEntranceWindow.drawLine(tblEntranceWindow.width/2,tblEntranceWindow.height/2,tblEntranceWindow.width/2,tblEntranceWindow.height,Red);
	
	if self.myWorkingMovement &lt;&gt; null then
		lblDesc.caption := self.myWorkingMovement.myWorkingVoyage.myHMSVoyageData.vesselName.trimBlanks &amp; ' : ' &amp; myWorkingMovement.moveType.String;	
	else
		lblDesc.caption := null;
	endif;

	// nothing to display
	if size &lt; 1 then
		lblNotAvailable.visible := true;
		lblNotAvailable.zOrder(1);
		btnDetail.enabled := false;
	else
		btnDetail.enabled := true;	
		lblNotAvailable.visible := false;
	endif;		
end;</source>
    </JadeMethod>
    <JadeMethod name="setOffsetTimeAndLocation" id="ef1c4ded-f687-4c8d-a16e-a454619dabba">
        <updating/>
        <source>setOffsetTimeAndLocation() updating;

vars
	harbour:					HMS_Harbour;
	steamTimeRegToWharf:		Integer;
	genRegionForEnquiry:		HMS_HarbourRegion;
  	offsetChkPtRelToBaseTime:	Integer;
  	arrv_PilotOBRelToBaseTime:	Integer;
  	arrv_LinesRelToBaseTime:	Integer;
  	dept_PilotOffRelToBaseTime:	Integer;
  	dept_LinesRelToBaseTime:	Integer;
  	berthFrom, berthTo : HMS_Berth;
	movePrevious:	CMIF_HMS_WorkingMovement;  	
begin
	// This method sets the offset time and caption to reflect the tidal restriction times reported
	// For example - are times relative to time at wharf or time of pilot on board

	offsetChkPtRelToBaseTime:=self.minuteOffset;
	reportTimeCaption:="";
	harbour := self.myTerminal.myHarbour;
	if harbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		return;
	endif;	
	// NOTE: 'offsetForReportedTimes' is the 'offset time' between the tidal windows
	//       for the checkpoint (eg Tanea) and the tidal windows for either 
	//       (a) the pilot on board time or (b) the time at the wharf.

    // Test to see if this is a general enquiry or an enquiry for a specific movement
    if myWorkingMovement=null then
   		// General enquiry - Not applicable to summary window
   	else
   		// Enquiry for a Specific Movement
   		movePrevious := myWorkingMovement.getMovementPrevious;	//AJA 27/11/00 : Added this section of code
   		if movePrevious &lt;&gt; null then
   			berthFrom := movePrevious.myBerth;
   		endif;
   		berthTo := myWorkingMovement.myBerth;
   		// Determine movement type
		// ---------------------------------------------------------------------------------------
		// ARRIVAL
		//AJA 27/11/00: Or a shift from a non piloted berth (eg outside the harbour)
		// ---------------------------------------------------------------------------------------
		if myWorkingMovement.moveType=HMSMovementTypeArrival or
			(myWorkingMovement.moveType=HMSMovementTypeShift and berthFrom.noMarineServices = true)then
			arrv_PilotOBRelToBaseTime:=harbour.defaultOrderTimesArrive[4];
			arrv_LinesRelToBaseTime:=harbour.defaultOrderTimesArrive[1];
			if harbour.tidalTimeTypeArrival=TidalTimeType_AtWharf then
				// Report times relative to TIME AT WHARF
				if harbour.baseTimeArrive=AtSea then
					// Movement time is pilot on board time
					// Set offset time from movement time (pilot on board time ..to.. at berth - lines- time)
					offsetForReportedTimes:=arrv_LinesRelToBaseTime-offsetChkPtRelToBaseTime;
					// eg. +45mins  -  +35mins = +10mins
				elseif harbour.baseTimeArrive=AtWharf then
				    // Movement time is time at berth
				    offsetForReportedTimes:=(-1*offsetChkPtRelToBaseTime);
				    // eg. +10mins
				endif;
			elseif harbour.tidalTimeTypeArrival=TidalTimeType_AtSea then
				// Report times relative to TIME OF PILOT ON BOARD (ie At sea for an arrival)
				reportTimeCaption:=app.getErrorString(PilotOnBoard);
				if harbour.baseTimeArrive=AtSea then
					// Movement time is pilot on board time
					// Set offset time from movement time 
					offsetForReportedTimes:=(-1*offsetChkPtRelToBaseTime);
					// eg. -  +35mins = -35mins
				elseif harbour.baseTimeArrive=AtWharf then
				    // Movement time is time at berth 
				    // Set offset time from movement time (ie pilot on board time ..to.. at berth)
				    offsetForReportedTimes:=arrv_PilotOBRelToBaseTime-offsetChkPtRelToBaseTime;
					  self.minuteOffset := (offsetChkPtRelToBaseTime);
				    // eg. -45mins - (-10mins) = -35mins
				endif;
			endif;
			
		elseif myWorkingMovement.moveType=HMSMovementTypeDeparture 
		or (myWorkingMovement.moveType=HMSMovementTypeShift 
		and berthTo.noMarineServices = true)then
		// ---------------------------------------------------------------------------------------
		// DEPARTURE
		//AJA 27/11/00: Or a shift to a non piloted berth (eg outside the harbour)
		// ---------------------------------------------------------------------------------------	
			dept_PilotOffRelToBaseTime:=harbour.defaultOrderTimesDepart[5];
			dept_LinesRelToBaseTime:=harbour.defaultOrderTimesDepart[1];
			if harbour.tidalTimeTypeDeparture=TidalTimeType_AtWharf then
			
				// Report times relative to TIME AT WHARF
				if harbour.baseTimeDepart=AtSea then
					// Movement time is pilot off vessel time (ie at sea)
					// Set offset time from movement time (pilot off vessel time ..to.. time at wharf departure)
					self.offsetForReportedTimes:=dept_LinesRelToBaseTime-offsetChkPtRelToBaseTime;
					// eg. -45mins - (-35mins) = -10mins
				elseif harbour.baseTimeDepart=AtWharf then
				    // Movement time is time at berth
				    self.offsetForReportedTimes:=(-1*offsetChkPtRelToBaseTime);
				    // eg. - (+10mins) = -10mins
				endif;
			elseif harbour.tidalTimeTypeDeparture=TidalTimeType_AtSea then
				reportTimeCaption:=app.getErrorString(PilotOffVessel);
				
				// Report times relative to TIME OF PILOT OFF VESSEL (ie At sea for a departing movement)
				if harbour.baseTimeDepart=AtSea then
					// Movement time is pilot off vessel time
					// Set offset time from movement time 
					self.offsetForReportedTimes:=offsetChkPtRelToBaseTime;
					// eg -35mins
				elseif harbour.baseTimeDepart=AtWharf then
				    // Movement time is time at berth 
				    // Set offset time from movement time (ie at berth time ..to.. pilot off vessel)
				    self.offsetForReportedTimes:=dept_PilotOffRelToBaseTime-offsetChkPtRelToBaseTime;
				    // eg +45mins - +10mins = +35mins  
				endif;
			endif;
		elseif myWorkingMovement.moveType=HMSMovementTypeShift then
		// ---------------------------------------------------------------------------------------
		// SHIFT
		// ---------------------------------------------------------------------------------------
			// Always report times relative to pilot on board time - which is the movement time, which is 
			// also the 'berth departing from' time.
			offsetForReportedTimes:=(-1*offsetChkPtRelToBaseTime);
			// eg. -10mins
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b2ba8c0c-48fb-48aa-9062-f335ef535730">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	05 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.initForm();	

end;</source>
    </JadeMethod>
    <JadeMethod name="showTidalModel" id="0833f5f5-e248-4222-95b5-fca9583643f9">
        <updating/>
        <source>showTidalModel() updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 10/02/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
vars
	form	: HMS_TidalModelForm;				// PAR #33337

begin
	if self.myGraphicalView &lt;&gt; null and self.myGraphicalView.myTidalModelForm &lt;&gt; null then			// PAR #33337
		self.myGraphicalView.myTidalModelForm.handleNotificationRefreshView(null, self.myWorkingMovement, null, null);	// PAR #33337
		return;																						// PAR #33337
	endif;																							// PAR #33337
	
	//self.myAssistant.showHMSTidalModel(self.myWorkingMovement, self.myMasterMenuAction);			// PAR #33337
	form := self.myAssistant.showHMSTidalModel(self.myWorkingMovement, self.myMasterMenuAction).HMS_TidalModelForm;		// PAR #33337
	if self.myGraphicalView &lt;&gt; null then															// PAR #33337
		self.myGraphicalView.myTidalModelForm := form;												// PAR #33337
	endif;																							// PAR #33337
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="81fe8873-17fd-4fb2-9d07-9e6e233d1962">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005967, locale);
	btnDetail.translateBubbleHelp(Xlat_0001631, locale);
	btnDetail.translateCaption(Xlat_0001632, locale);
	lblDesc.translateCaption(Xlat_0001633, locale);
	lblDraft.translateCaption(Xlat_0005968, locale);
	lblLegendBerth.translateCaption(Xlat_0001635, locale);
	lblLegendRegion.translateCaption(Xlat_0001629, locale);
	lblNotAvailable.translateCaption(Xlat_0001630, locale);
	lblTidalClass.translateCaption(Xlat_0014388, locale);
end;</source>
    </JadeMethod>
</GUIClass>
