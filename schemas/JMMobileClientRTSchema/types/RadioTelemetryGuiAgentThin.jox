    <JadeMethod name="setQueryDtoDefinitionFromRT" id="bdd80740-9fe0-4a32-b585-6b17865383cd">
        <source>setQueryDtoDefinitionFromRT(  _form: RadioTelemetryMainForm; _dtoQueryDef : MobileServerRTThin::DTO_QueryDefinitionRT input );
// -------------------------------------------
// Created 05 may 2008 by cnwvu1
// -------------------------------------------

vars
	rtCriteriaLine		: RT_QueryCriteriaLine;
	dtoCriteriaHolder	: MobileServerRTThin::DTO_QueryCriteriaLineHolderRT;
	dtoCriteriaLine		: MobileServerRTThin::DTO_SelectorCriteriaLineRT;
	dtoCriteriaLineBoolean		: MobileServerRTThin::DTO_CriteriaLineBoolean;
	dtoCriteriaLineString		: MobileServerRTThin::DTO_CriteriaLineString;
	dtoCriteriaLineStringFromTo : MobileServerRTThin::DTO_CriteriaLineStringFromTo;
	queryOperatorOid, propClassName, propName : String;
	searchValueA, searchValueB : String;
	_searchValueBoolean : Boolean;
	
begin

	_dtoQueryDef.setName( _form.lblQueryName.caption );
	
	create dtoCriteriaHolder transient;
	dtoCriteriaHolder.setForCreateFromRT( _dtoQueryDef );
	
	foreach rtCriteriaLine in _form.aAllQueryCriteriaLines do 
	
		if rtCriteriaLine.isKindOf( RT_CriteriaLineSplittingSheets ) then	// creating a new dtoCriteriaHolder for the next sheet
			
			create dtoCriteriaHolder transient;
			dtoCriteriaHolder.setForCreateFromRT( _dtoQueryDef );
			
		else
			
			rtCriteriaLine.getDtoDefinitionFromRT(	queryOperatorOid, propClassName, propName,
													searchValueA, searchValueB, _searchValueBoolean );
			
			if rtCriteriaLine.isKindOf( RT_CriteriaLineBoolean ) then
				create dtoCriteriaLineBoolean transient;
				dtoCriteriaLine	:= dtoCriteriaLineBoolean;
			elseif rtCriteriaLine.isKindOf( RT_CriteriaLineStringFromTo ) then
				create dtoCriteriaLineStringFromTo transient;
				dtoCriteriaLine	:= dtoCriteriaLineStringFromTo;
			elseif rtCriteriaLine.isKindOf( RT_CriteriaLineString ) then
				create dtoCriteriaLineString transient;
				dtoCriteriaLine	:= dtoCriteriaLineString;
			endif;
			
			dtoCriteriaLine.setForCreateFromRT(		dtoCriteriaHolder,
													queryOperatorOid, propClassName, propName,
													searchValueA, searchValueB, _searchValueBoolean );
			
		endif;
	
	endforeach;

end;
</source>
        <Parameter name="_form" type="RadioTelemetryMainForm"/>
        <Parameter name="_dtoQueryDef" type="MobileServerRTThin::DTO_QueryDefinitionRT" usage="input"/>
    </JadeMethod>
