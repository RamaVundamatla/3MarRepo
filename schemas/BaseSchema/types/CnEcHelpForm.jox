    <JadeMethod name="txtStartDate_lostFocus" id="ceccce5c-2f05-44fa-8b2a-94d6ea70d417">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtStartDate_lostFocus(textbox: TextBox input) updating;

vars
	date	: Date;

begin
	if txtStartDate.text.Date.isValid then
		date := txtStartDate.text.Date;
