    <JadeMethod name="makeCTASegment" id="91f1ece6-fb2d-4d02-8371-f6a74ab0b59a">
        <source>makeCTASegment(_protocol :CM_CamProtocol; _group :HugeStringArray input;_contactName :String):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2018	jlgma1	Initial creation

*/

constants
	MESSAGE	= "CTA";
	CONTACT_FUNCTION = "IC";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;

begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			CONTACT_FUNCTION &amp; plus 
			&amp; colon &amp;
			_contactName.String;

	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_contactName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageHazardsData" id="cf65c85a-29aa-49f9-8884-0672fb4818d1">
        <source>makeMessageHazardsData(_ti: CM_TrackedItem; _protocol: CM_CamProtocol; _group: HugeStringArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI
11 Jun 2020	NDL	TFS 49558	Giuseppe now says every FTX segments should be per DGS not per Hazard  

*/

constants
	MESSAGE = "DGS";
	REGULATIONS_CODE = "IMD";
vars
	haz						:CM_Hazard;
	code					:String;
	plus,colon, singleQuote	: Character;
	msg 					: String;
	packingLevel,
	flashTemp 	 			: String;
	uNDGCode                : String;
	baseMsg : String;
	extraMsg : String;
begin
	if _ti.allTIHazards.isEmpty then									
		return;
	endif;
	
	plus 		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	colon		:= _protocol.subElementSeparator;
	
	//07 May 2020 NDL	TFS 49211
	foreach haz in _ti.allTIHazards do
	
		baseMsg := MESSAGE &amp; plus &amp; REGULATIONS_CODE &amp; plus &amp; haz.code.trimRight;
	
		if haz.CM_TIHazard.flashpointTemperature &lt;&gt; NULL_TEMPERATURE then
			flashTemp := haz.CM_TIHazard.flashpointTemperature.asStringJMT;
		else
			flashTemp := null;
		endif;
		
		if haz.CM_TIHazard.packingGroup &lt;&gt; null then
			if haz.CM_TIHazard.packingGroup = 'I' then
				packingLevel := '1';
			elseif  haz.CM_TIHazard.packingGroup = 'II' then
				packingLevel := '2';
			elseif haz.CM_TIHazard.packingGroup = 'III' then
				packingLevel := '3';
			endif;
		else
			packingLevel := null;
		endif;
		
		extraMsg := null;
		if flashTemp &lt;&gt; null or packingLevel &lt;&gt; null then
			if flashTemp &lt;&gt; null then
				extraMsg := extraMsg &amp; plus &amp; flashTemp &amp; colon &amp; 'CEL';
			endif;
			if packingLevel &lt;&gt; null then
				if flashTemp&lt;&gt; null then
					extraMsg := extraMsg &amp; plus &amp; packingLevel;
				else
					extraMsg := extraMsg &amp; plus  &amp; colon &amp; 'CEL'  &amp;plus &amp; packingLevel;
				endif;
			endif;
		endif;
		
		if haz.CM_TIHazard.allUNDGCodes.isEmpty then
			msg := baseMsg &amp; extraMsg;
			_group.add(msg &amp; singleQuote);
			
			//11 Jun 2020	NDL	TFS 49558
			_group.add('FTX' &amp; plus &amp; 'AAD' &amp; plus &amp; plus &amp; plus &amp; haz.description.toUpper  &amp; singleQuote);	
			if haz.CM_TIHazard.isMarinePollutant = 2   then
				_group.add('FTX' &amp; plus &amp; 'AAC' &amp; plus &amp; plus &amp; 'P'  &amp; singleQuote);
			endif;			
			if haz.CM_TIHazard.limitedQuantity then 
				_group.add('FTX' &amp; plus &amp; 'AAC' &amp; plus &amp; plus &amp; 'TLQ'  &amp; singleQuote);
			endif;
		
		else
			foreach uNDGCode in haz.CM_TIHazard.allUNDGCodes do
				msg := baseMsg &amp; plus &amp; uNDGCode &amp; extraMsg;
				_group.add(msg &amp; singleQuote);
				
				//11 Jun 2020	NDL	TFS 49558
				_group.add('FTX' &amp; plus &amp; 'AAD' &amp; plus &amp; plus &amp; plus &amp; haz.description.toUpper  &amp; singleQuote);	
				if haz.CM_TIHazard.isMarinePollutant = 2   then
					_group.add('FTX' &amp; plus &amp; 'AAC' &amp; plus &amp; plus &amp; 'P'  &amp; singleQuote);
				endif;			
				if haz.CM_TIHazard.limitedQuantity then 
					_group.add('FTX' &amp; plus &amp; 'AAC' &amp; plus &amp; plus &amp; 'TLQ'  &amp; singleQuote);
				endif;
			
			endforeach;
		endif;

		/*	11 Jun 2020 moved up into the UNDG code
		// FTX for Hazards
		_group.add('FTX' &amp; plus &amp; 'AAD' &amp; plus &amp; plus &amp; plus &amp; haz.description.toUpper  &amp; singleQuote);
		
		if haz.CM_TIHazard.isMarinePollutant = 2   then
			_group.add('FTX' &amp; plus &amp; 'AAC' &amp; plus &amp; plus &amp; 'P'  &amp; singleQuote);
		endif;
		
		if haz.CM_TIHazard.limitedQuantity then 
			_group.add('FTX' &amp; plus &amp; 'AAC' &amp; plus &amp; plus &amp; 'TLQ'  &amp; singleQuote);
		endif; */
	
	endforeach;
	
	/*  Pre 07 May 2020
	haz := _ti.allTIHazards.first.CM_TIHazard;
	
	if haz.CM_TIHazard.flashpointTemperature &lt;&gt; NULL_TEMPERATURE then
		flashTemp := haz.CM_TIHazard.flashpointTemperature.asStringJMT;
	endif;
	
	if haz.CM_TIHazard.getUndgCodesAsString(false) &lt;&gt; null  then	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
		uNDGCode := haz.CM_TIHazard.getUndgCodesAsString(false).trimRight; //25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
	endif;
	
	if haz.CM_TIHazard.packingGroup &lt;&gt; null then
					if haz.CM_TIHazard.packingGroup = 'I' then
						packingLevel := '1';
					elseif  haz.CM_TIHazard.packingGroup = 'II' then
						packingLevel := '2';
					elseif haz.CM_TIHazard.packingGroup = 'III' then
						packingLevel := '3';
					endif;
	endif;
	
	msg := MESSAGE &amp; plus &amp; REGULATIONS_CODE &amp; plus &amp; haz.code.trimRight ;
	
	if uNDGCode &lt;&gt; null then
		msg := msg &amp; plus &amp; uNDGCode;
	endif;
	
	if flashTemp &lt;&gt; null or  packingLevel &lt;&gt; null then
		if flashTemp &lt;&gt; null then
			msg := msg &amp; plus &amp; flashTemp &amp; colon &amp; 'CEL';
		endif;
		
		if packingLevel &lt;&gt; null then
			if flashTemp&lt;&gt; null then
				msg := msg &amp; plus &amp; packingLevel;
			else
				msg  :=msg &amp; plus  &amp; colon &amp; 'CEL'  &amp;plus &amp; packingLevel;
			endif;
		endif;
	endif;
	_group.add(msg &amp; singleQuote);
	
	// FTX for Hazards
	_group.add('FTX' &amp; plus &amp; 'AAD' &amp; plus &amp; plus &amp; plus &amp; haz.description.toUpper  &amp; singleQuote);
	
	if haz.CM_TIHazard.isMarinePollutant = 2   then
		_group.add('FTX' &amp; plus &amp; 'AAC' &amp; plus &amp; plus &amp; 'P'  &amp; singleQuote);
	endif;
	
	if haz.CM_TIHazard.limitedQuantity then 
		_group.add('FTX' &amp; plus &amp; 'AAC' &amp; plus &amp; plus &amp; 'TLQ'  &amp; singleQuote);
	endif;
	
	*/
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC" id="11fbb70e-5d72-4696-8f51-9f3af86a8141">
        <source>makeMessageLOC(_protocol: CM_CamProtocol; _group: HugeStringArray input; _activity: Integer; _ti: CM_TrackedItem) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI
12 Dec 2018 jlgsl4  TFS 42528 - SNO - Tranship Discharge needs incoming voyage Load port info
*/

vars
	terminal : CM_Terminal;
	code : String;
	fCode : String; 
	pCode : String;
	location : CM_LocationsController;
	ourCode : String;
	foundHeight : Integer;
begin
	terminal := _protocol.terminal;
	ourCode := terminal.getConfig(PortDestCode).String;
	
	// LOC+9 - load port
	code := _ti.loadPort.trimRight;

	if _activity = COARRI_SHIPDISCHARGE then // TFS 42528
		if _ti.isTranshipItem then // TFS 42528
			if _ti.myTranshipDetail &lt;&gt; null then // TFS 42528
				if  _ti.myTranshipDetail.importOriginalLoadPort &lt;&gt; null then // TFS 42528
					code := _ti.myTranshipDetail.importOriginalLoadPort; // TFS 42528
				endif; // TFS 42528
			endif; // TFS 42528
		endif; // TFS 42528
	endif; // TFS 42528
	
	fCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
	
	if fCode = null then
		fCode := code.trimRight;
	endif;
	if code = ourCode or fCode = ourCode then
		self.makeLOCSegment(_protocol, _group, '9', fCode, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ");
	else
		self.makeLOCSegment(_protocol, _group, '9', fCode, '139', '6', null, null, null);
	endif;
	
	if _activity = COARRI_SHIPLOAD then
		// LOC+11 - get the discharge port code
		code := _ti.dischargePort;
		pCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if pCode = null then
			pCode := code;
		endif;
		
		pCode := pCode.trimRight;
		
		if code = ourCode or pCode = ourCode then
			self.makeLOCSegment(_protocol, _group, '11', pCode, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ");
		else
			self.makeLOCSegment(_protocol, _group, '11', pCode, '139', '6', null, null, null);
		endif;
		// LOC+8 - get the destination port code PAR2836 99/115
		code := _ti.destinationPort;
		pCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if pCode = null then
			pCode := code;
		endif;
		
		pCode := pCode.trimRight;
		
		if pCode &lt;&gt; null then
			if code = ourCode or pCode = ourCode then
				self.makeLOCSegment (_protocol, _group, '7', pCode, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ");
			else
				self.makeLOCSegment (_protocol, _group, '7', pCode, '139', '6', null, null, null);
			endif;
		endif;
		
		// LOC+147 - setup bay position
		location := _ti.getPrimaryLocation(REAL_MODE);

		if location &lt;&gt; null and location.isKindOf(CM_SlotController) and not location.isKindOf(CM_ShipBlockController) then
			self.makeLOCSegment (_protocol, _group, '147', location.CM_SlotController.getStowageId(_ti).trimRight, null, '5', null, null, null);
		endif;
	else
				// LOC+9 - get the discharge port code
		code := _ti.loadPort;
		pCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if pCode = null then
			pCode := code;
		endif;
		
		pCode := pCode.trimRight;
		terminal.findLocationFromString(_ti.priorStowage, true, location, foundHeight);
		if location &lt;&gt; null and location.isKindOf(CM_SlotController) and not location.isKindOf(CM_ShipBlockController) then
			self.makeLOCSegment (_protocol, _group, '147', location.CM_SlotController.getStowageId(_ti).trimRight, null, '5', null, '72', null);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsData" id="6a5c8e96-09bc-4098-8d4b-ea777ab0269f">
        <source>makeMessageSealsData(_ti: CM_TrackedItem; _camMessage: CM_CamMessage input; _group: HugeStringArray input; _camProtocol: CM_CamProtocol; _contentsStatus : String );
/* Changes

Date		Name	TFS#		Description
============================================================================
18 Nov 2019 jlgsl4	47450		SNO - Missing seal in CoarriSMDG213
============================================================================*/

vars
	strSeal		: String;
	plus 		: Character;
	singleQuote	: Character;	
	seals 		: HugeStringArray;
	sealParty 	: String;
	ventSeal 	: String;
	seal 		: String;
	sealTI 		: CM_SealTI;
begin
	if _contentsStatus = '4' then // slightly tidied copy of CM_CamStandardCODECODesc::makeMessageSealsData
		//Empty Containers should never include seals data...
		return;
	endif;	
	create seals transient;
	plus := _camProtocol.elementSeparator;	
	singleQuote	:= _camProtocol.segmentTerminator;	
	_ti.getSealNumStringArray(seals, SealType_Operator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CA" &amp; singleQuote);	
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumCustomsStringArray(seals);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CU" &amp; singleQuote);	
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_Shipper);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "SH" &amp; singleQuote);
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_TerminalOperator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "TO" &amp; singleQuote);
		endif;
	endforeach;	
	if _ti.isKindOf (CM_Container) then
		seals.clear();
		_ti.getSealNumStringArray(seals, SealType_Vent);
		foreach strSeal in seals do
			if strSeal.trimRight &lt;&gt; "" then
				_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "AB" &amp; singleQuote);
			endif;
		endforeach;
	endif;

	foreach sealTI in _ti.allSeals do
		if sealTI.sealType = SealType_Customs or
		   sealTI.sealType = SealType_Operator or
		   sealTI.sealType = SealType_Shipper or
		   sealTI.sealType = SealType_TerminalOperator or
		   sealTI.sealType = SealType_Vent then
			continue;
		endif;
		foreach seal in sealTI.allSealNums do // unknown seal type
			//27 Aug 2020	NDL	TFS 49974 - Don't report 'unknown' type seals with no 'current' value.
			if _camProtocol.formatSeal(seal).trimBlanks = null then
				continue;
			endif;
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(seal) &amp; plus &amp; "AB" &amp; singleQuote);
		endforeach;
	endforeach;
epilog
	delete seals;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsReceivedData" id="9dbef484-43ab-41a0-84fd-fc452e1404db">
        <source>makeMessageSealsReceivedData(_transaction : CM_Receive; _camProtocol: CM_CamProtocol; _group : HugeStringArray input);
/*
Purpose:		Copy of CM_CamStandardCODECOSMDG213::makeMessageSealsReceivedData
				Output seal details at time of Receive transaction

Parameters:			

Return Value:		

Date		Who		Reason
18 Nov 2018	jlgsl4	TFS 47450 - SNO - Missing unknown seal in CoarriSMDG213
*/

vars
	theSealNumbers : StringArray;
	knownSealTypes : StringArray;
	knownSealSegmentSuffixes : StringArray;
	sealNumber : String;
	sealType : String;
	plus : String;
	singleQuote : String;
	allKnownSealTypes : String;
	sealIndex : Integer;
begin
	create theSealNumbers transient;
	create knownSealTypes transient;
	create knownSealSegmentSuffixes transient;
	knownSealTypes.add(SealType_Customs);
	knownSealSegmentSuffixes.add("CU");
	knownSealTypes.add(SealType_Operator);
	knownSealSegmentSuffixes.add("CA");
	knownSealTypes.add(SealType_Shipper);
	knownSealSegmentSuffixes.add("SH");
	knownSealTypes.add(SealType_TerminalOperator);
	knownSealSegmentSuffixes.add("TO");
	knownSealTypes.add(SealType_Vent);
	knownSealSegmentSuffixes.add("AB"); // last seal-segment suffix also used for 'unknown' seal types...!
	plus := _camProtocol.elementSeparator;
	singleQuote	:= _camProtocol.segmentTerminator;	
	foreach sealType in knownSealTypes do
		_transaction.getSealsAtReceiveArray(sealType, theSealNumbers);
		foreach sealNumber in theSealNumbers do
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealNumber) &amp; plus &amp;
				knownSealSegmentSuffixes[knownSealTypes.indexOf(sealType)] &amp; singleQuote);
		endforeach;
		theSealNumbers.clear;
	endforeach;
	allKnownSealTypes := knownSealTypes.asCSV(false);
	_transaction.getUnknownSealsAtReceiveArray(allKnownSealTypes, theSealNumbers);// get seal numbers for unknown seal-types
	foreach sealNumber in theSealNumbers do // note use of last seal-segment suffix here...
		_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealNumber) &amp; plus &amp; knownSealSegmentSuffixes.last &amp; singleQuote);
	endforeach;
epilog
	delete theSealNumbers;
	delete knownSealTypes;
	delete knownSealSegmentSuffixes;
end;</source>
        <Parameter name="_transaction" type="CM_Receive"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="790c92fe-b1d7-4887-9acd-c4b4e14bd69d">
        <source>makeMessages(_trackedItem: CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx: CM_TITransaction);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI
28 Jun 2018	jlgkpd1	TFS 39157 - Protect again null CM_Voyage::myVessel
28 Aug 2018	jlggb1	TFS 40080 No Translation of Tranship Voyage Code
25 Aug 2018 jlggb1	TFS 40957 Correction to TFS 36713
09 Nov 2018	jlgsl4	TFS 39345 SNO - add LOC+7 to TDT+30
20 Mar 2019	jlgsl4	TFS 41786 SNO - output DAM segment for Standard Coarri/Codeco
17 Jul 2019	jlgdap1	TFS 45582 SNO - correct DAM segment formatting
25 Sep 2019	jlgsl4	TFS 46608 SNO - tranship details -&gt; segment group 12, with NAD
13 Oct 2020 cnwma1  Bug 50021: GPHA -- Extract of segment RFF+BM into a COARRI message
21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
7th Mar 2024 navra1 //navra1 - MTN-34174 - 7th Mar 2024
*/

vars
	fCode 			 : String; 
	code 			 : String; 
	pCode 			 : String;
	temp 			 : String; 
	carrierCode 	 : String;
	ti 				 : CM_TrackedItem;
	exportVoyage 	 : String; 
	callSign 		 : String; 
	lloydsNumber 	 : String; 
	vesselName 		 : String;
	contentsStatus 	 : String;
	isoCode,fIsoCode : String;
	includeVGM 		 : Boolean;
	xlationOperator  : CM_Operator;
	foundMatch 		 : Boolean;
	ourCode 		 : String;
begin
	
	ourCode := _terminal.getConfig(PortDestCode).String;
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then	
		includeVGM := true;
	endif;
	
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus,_camMessage.activity, _transaction.type);
	
	// EQD segment Group 6
	
	fIsoCode := getfIsoCode(_camProtocol,ti.CM_Container.isoType,_terminal);
	
	self.makeEQDSegment(_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, self.imExStatusToString(ti),  contentsStatus); 
	
	_camMessage.eqdCount := _camMessage.eqdCount + 1;
	
	// RFF+BN
	self.makeMessageRFF_BN(_camProtocol, _camMessage.group5,  ti);
	
	//navra1 - MTN-34174 - 7th Mar 2024
	// RFF+RE
	self.makeMessageRFF_RE(_camProtocol, _camMessage.group5,  ti);
	
	// RFF+BM
	self.makeMessageRFF_BM (_camProtocol, _camMessage.group5,  ti);   //13.10.2020 cnwma1 #50021
	
	// RFF+CN
	self.makeMessageRFF_CN(_camProtocol, _camMessage.group5, ti);

	// RFF+ABT
	self.makeMessageRFF_ABT(_camProtocol, _camMessage.group5,  _camMessage.activity, ti);

   //  TMD
   
   // DTM
	if _camMessage.activity = COARRI_SHIPLOAD then
		self.makeDTMSegment(_camProtocol, _camMessage.group5, '404', _transaction.dateTime, "203"); // TFS 53754
	else
		self.makeDTMSegment(_camProtocol, _camMessage.group5, '403', _transaction.dateTime, "203"); // TFS 53754
	endif;	
	
	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					
	endif;
	
	// LOC segments
	self.makeMessageLOC(_camProtocol, _camMessage.group5, _camMessage.activity, ti);
	
	// MEA - weight
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5, ti, null);
	// MEA Tare Weight
	if ti.weightTare &lt;&gt; 0 then
		self.makeMEASegment(_camProtocol, _camMessage.group5, 'AAE', 'T', 'KGM', ti.weightTare);	
	endif;

	// DIM+ segment
	self.makeMessageDimensionsData(_camProtocol, _camMessage.group5, ti);
	
	// TMP Segment
	self.makeTMPSegment(_camProtocol, _camMessage.group5, 2, ti.getTemperature, "CEL"); 	
	
	// SEL Segment
	if _transaction.isA(CM_ReceiveShip) and contentsStatus &lt;&gt; '4' then // --&gt; TFS 47450 - output non-MT as-at received seals details
		self.makeMessageSealsReceivedData(_transaction.CM_Receive, _camProtocol, _camMessage.group5);
	else // &lt;-- TFS 47450
		self.makeMessageSealsData(ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);
	endif; // TFS 47450
	
	// FTX Segment 
	temp := ti.getCommodityDesc;
	if temp &lt;&gt; null then
		self.makeFTXSegment(_camProtocol, _camMessage.group5, "AAA", null, null, temp);
	endif;
	
	if ti.damaged then
		//self.makeFTXSegment(_camProtocol, _camMessage.group5, "DAR", null, null, "DAMAGED "&amp; ti.getDamageDetailsDescr[1:70]); // TFS 41786
		self.makeMessageFTX_Damage(_camProtocol, _camMessage.group5, ti, null); // TFS 41786
	endif;
	
	// DGS Segment + FTX HAZ
	self.makeMessageHazardsData(ti, _camProtocol, _camMessage.group5);	
	
	// EQA Segment 
	self.makeEQASegment (_camProtocol, _camMessage.group5, 'RG', ti);
	
	// DAM+ segment
	if ti.damaged then
		if _camProtocol.getProduceDAMSegment() then // TFS 41786
			//self.makeDAMSegment(_camProtocol, _camMessage.group5, '1', '33', null, null, "DAMAGED "&amp; ti.getDamageDetailsDescr[1:70]); // TFS 41786	// TFS 45582
			self.makeMessageDAM(_camProtocol, _camMessage.group5, ti);																					// TFS 45582
		else // TFS 41786
			self.makeDAMSegment(_camProtocol, _camMessage.group5, '1', null, null, null, null);
		endif; // TFS 41786
	endif;

	// TDT Segment for Transhipment
	
	if ti.isTranshipItem and 
	   ti.myExportVoyage &lt;&gt; null and 
	   _transaction.getMyVoyage &lt;&gt; ti.myExportVoyage then
		// only has values if tranship
		exportVoyage := ti.myExportVoyage.code;						
		callSign := ti.myExportVoyage.callSign.trimRight;
		if callSign = null and ti.myExportVoyage.myVessel &lt;&gt; null then
			callSign := ti.myExportVoyage.myVessel.callSign;
		endif;
		lloydsNumber := ti.myExportVoyage.lloydsNumber;
		if lloydsNumber = null and ti.myExportVoyage.myVessel &lt;&gt; null then
			lloydsNumber := ti.myExportVoyage.myVessel.lloydsNumber;
		endif;
		vesselName := ti.myExportVoyage.vesselName.trimRight.toUpper;
	
		if ti.myExportVoyage.myOperator &lt;&gt; null then	
			code := ti.myExportVoyage.myOperator.code;
			xlationOperator := app.myRoot.allOperators[_camProtocol.operatorXlationCode.trimBlanks];
			fCode := app.myRoot.getXlationForeignOperatorCode(xlationOperator, code, foundMatch).trimRight;
					
			if fCode = null then
				fCode := code;
			endif;
			carrierCode := fCode;
			if xlationOperator &lt;&gt; null then // TFS 46608 - will be null if not set on CamProtocol
				fCode := xlationOperator.getXlationForeignCode(exportVoyage, XLATION_TYPE_VOYAGETERMINAL, foundMatch);  //TFS 40080 jlggb1	28/08/2018
				if foundMatch and fCode&lt;&gt; null then
					exportVoyage := fCode;
				endif;
			endif; // TFS 46608
		endif;

		if _camProtocol.camGroup.useCallSign then
			if _camMessage.activity = COARRI_SHIPLOAD then
				self.makeTDT10Segment(_camProtocol, _camMessage.group5/*3*/, exportVoyage, '1', null, null, carrierCode, '172', '20', null, callSign, '103', null, vesselName); // 25/9/2018 jlggb1 40947 // TFS 46608
			else
				self.makeTDT30Segment(_camProtocol, _camMessage.group5/*3*/, exportVoyage, '1', null, null, carrierCode, '172', '20', null, callSign, '103', null, vesselName); // 25/9/2018 jlggb1 40947 // TFS 46608
				fCode := ti.destinationPort; // TFS 39345
				if fCode &lt;&gt; null then // TFS 39345
					self.makeLOCSegment(_camProtocol, _camMessage.group5/*3*/, '7', fCode, '139', '6', null, null, null); // TFS 39345 // TFS 46608
				endif;  // TFS 39345
			endif;
		else
			if _camMessage.activity = COARRI_SHIPLOAD then
				self.makeTDT10Segment(_camProtocol, _camMessage.group5/*3*/, exportVoyage, '1', null, null, carrierCode, '172', '20', null, lloydsNumber, '146', null, vesselName); // 25/9/2018 jlggb1 40947 // TFS 46608
			else
				self.makeTDT30Segment(_camProtocol, _camMessage.group5/*3*/, exportVoyage, '1', null, null, carrierCode, '172', '20', null, lloydsNumber, '146', null, vesselName); // 25/9/2018 jlggb1 40947 // TFS 46608
				fCode := ti.destinationPort; // TFS 39345
				if fCode &lt;&gt; null then // TFS 39345
					self.makeLOCSegment(_camProtocol, _camMessage.group5/*3*/, '7', fCode, '139', '6', null, null, null); // TFS 39345 // TFS 46608
				endif;  // TFS 39345
			endif;
		endif;
		
		
		code := ti.myTranshipDetail.dischargePort.trimRight;
		fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);
		if fCode = null then
			fCode := code.trimRight;
		endif;
		
		//LOC Segment
		if code = ourCode or fCode = ourCode then
			self.makeLOCSegment(_camProtocol, _camMessage.group5/*3*/, '11', fCode, '139', '6', _camProtocol.camGroup.facilityCode, "TER", "ZZZ"); // TFS 46608
		else
			self.makeLOCSegment(_camProtocol, _camMessage.group5/*3*/, '11', fCode, '139', '6', null, null, null); // TFS 46608
		endif;

	endif;
	
	
	// NAD Segment
	self.makeMessageNAD_CF(_camProtocol, _camMessage.group5, ti);	
	
	if includeVGM then
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);
	endif;
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeTDT20Segment" id="b8efef88-b1c1-4108-98e2-1f02efca9f51">
        <source>makeTDT20Segment(_protocol: CM_CamProtocol; _ref: String; _mode: String; _means: String; _carrier: String; _carrierQual: String; _carrierAgency: String;
				_vslOperatorName: String; _excess: String; _transportMeansID: String; _transportQual: String; _transportAgency: String; _transportID: String): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI
*/

constants
	MESSAGE	= "TDT";
	STAGE = "20";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			STAGE &amp; plus &amp; 
			_ref &amp; plus &amp;
			_mode &amp; plus &amp; 
			_means &amp; plus &amp;
			_carrier;
			
	if _carrierQual &lt;&gt; null then
		msg := msg &amp; colon &amp; _carrierQual;
	endif;

	if _carrierAgency &lt;&gt; null then
		msg := msg &amp; colon &amp; _carrierAgency;
	endif;
	
	msg := msg &amp; colon &amp; 
			_vslOperatorName &amp; plus &amp; plus &amp;
			_excess &amp; plus &amp;
			_transportMeansID;
			
	if _transportQual &lt;&gt; null then
		msg := msg &amp; colon &amp; _transportQual &amp; colon &amp; _transportAgency &amp; colon &amp; _transportID;
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_means" type="String"/>
        <Parameter name="_carrier" type="String"/>
        <Parameter name="_carrierQual" type="String"/>
        <Parameter name="_carrierAgency" type="String"/>
        <Parameter name="_vslOperatorName" type="String"/>
        <Parameter name="_excess" type="String"/>
        <Parameter name="_transportMeansID" type="String"/>
        <Parameter name="_transportQual" type="String"/>
        <Parameter name="_transportAgency" type="String"/>
        <Parameter name="_transportID" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeUNHSegment" id="a6fa322f-2e5b-4058-8503-d12550c55c2b">
        <source>makeUNHSegment(_protocol: CM_CamProtocol; _number: Integer; _fileType: String; _msgVersion: String; _msgReleaseNo: String; _agency: String; _association: String; _030: String; _runDateTime: TimeStamp): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI

*/

vars

begin
	/* Sample UNH+SN241445110001+COARRI:D:00B:UN:SMDG21'*/
	return inheritMethod(_protocol, _number, 'COARRI', 'D', '00B','UN','SMDG21', null, _runDateTime);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_msgVersion" type="String"/>
        <Parameter name="_msgReleaseNo" type="String"/>
        <Parameter name="_agency" type="String"/>
        <Parameter name="_association" type="String"/>
        <Parameter name="_030" type="String"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="0e47a153-94fa-4a4b-a68e-a35378f672a6">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
31 Jan 2018	jlgma1				Initial creation
10 Apr 2019	jlgka1	44294		SNO - Missing UNA, UNB segments in COARRI SMDG213
09 Jan 2020	jlgdap1	TFS 48016 	SNO Deletion CODECO - new _transactions parameter
============================================================================*/

vars
	camVoyage 	: CM_CamVoyage;
	camMessage 	: CM_CamMessage;
	headerColl, 
	trailerColl	: HugeStringArray;	
	strLine 	: String;
	una,
	unb 		: String;
begin
	app.writeLog("===================================", LogWARN);
	//jlgka1 TFS 44294 --&gt;  
	// UNA Segment	
	una := self.outputHeader_UNA (_protocol, _camTaskHistory);	
	strLine := strLine &amp; una;
	
	//UNB header	
	unb := self.outputHeader_UNB (_protocol, _camTaskHistory, _seqNumber, null);
	strLine := strLine &amp; unb;
	//jlgka1 TFS 44294 &lt;--	
	
	if _camFile.camVoyages.size &gt; 0 then
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				headerColl 	:= camMessage.header;
				trailerColl	:= camMessage.trailer;
				
				if una &lt;&gt; null then
					headerColl.add (una);
				endif;
				
				if unb &lt;&gt; null then
					headerColl.add (unb);
				endif;	
				
				
				//BGM header
				strLine := strLine &amp; self.outputHeader_UNH_BGM (_camFile, _camTaskHistory, camMessage.activity, _unhSeqNumber, camMessage.segmentCount, headerColl);
				
				// DTM
				
				// RFF Group1 
				
				//TDT header Group2
				strLine := strLine &amp; self.outputHeader_TDT (_camTaskHistory, _protocol, camVoyage, camMessage.segmentCount, headerColl);
				
				//RFF header  Group2
				strLine := strLine &amp; self.outputHeader_RFF (_protocol, _camTaskHistory, camMessage, headerColl);
				
				// LOC Group3
				strLine := strLine &amp; self.outputHeader_LOC (_camTaskHistory, _protocol, camMessage.activity, camMessage.segmentCount, headerColl);
				
				//DTM header for arrival and departue date/times  Group 3
				strLine := strLine &amp; self.outputHeader_DTM_ArriveDepart (_camTaskHistory, _protocol, camVoyage, camMessage.segmentCount, headerColl);

			    //NAD header Group 4
				strLine := strLine &amp; self.outputHeader_NAD (_protocol, _camTaskHistory, camMessage, headerColl);
				
				// CTA Header Group 5
				strLine := strLine &amp; self.outputHeader_CTA (_protocol, _camTaskHistory, camMessage, headerColl);
				
				//now give them all of the messages
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group3, camMessage.segmentCount);
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group5, camMessage.segmentCount);
				
				//CNT segment for message
				strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeCNTSegment (_protocol, 16, camMessage.eqdCount), trailerColl);
				
				camMessage.segmentCount := camMessage.segmentCount + 2;
				
				// UNT segment
				strLine := strLine &amp; self.outputTrailer_UNT (_protocol, _camTaskHistory, camMessage.segmentCount, _unhSeqNumber, trailerColl);
				
				camMessage.segmentCount := 0;
			endforeach;
		endforeach;
		
		//set unhSeq here
		_protocol.setUNHSeqNum(_unhSeqNumber);
	endif;
	
	//UNZ segement for file
	strLine := strLine &amp; self.outputTrailer_UNZ (_protocol, _camTaskHistory, _camFile.messageCount, _seqNumber, null);

	app.writeLog(_protocol.code &amp; " File contains " &amp; _camFile.messageCount.String &amp; " messages.", LogWARN);
	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine.toUpper);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_CTA" id="0b922735-31b8-483d-9854-648f067c0aeb">
        <updating/>
        <source>outputHeader_CTA(_protocol: CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input; _camMessage: CM_CamMessage input; _coll: HugeStringArray input): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI

*/

vars
	strLine : String;
begin
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeCTASegment (_protocol,null,'ZZZ'), _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 1;

	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_DTM_ArriveDepart" id="13c2220c-45e8-4000-9319-5c3e162e850d">
        <updating/>
        <source>outputHeader_DTM_ArriveDepart(_camTaskHistory: CM_CamTaskHistory input; _protocol: CM_CamProtocol; _camVoyage: CM_CamVoyage; _count: Integer io; _coll: HugeStringArray input): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI
04 Jul 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs

/*132 Arrival date/time, estimated
  133 Departure date/time, estimated
  178 Arrival date/time, actual
  186 Departure date/time, actual
*/


vars
	voyage : CM_Voyage;
	strLine : String;
begin
	voyage := _camVoyage.voyageOid;
	
	if voyage = null then
		return null;	
	endif;
	

	if voyage.estimatedDepartureDT.date.isValid then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeDTMSegment (_protocol, null, '133', voyage.estimatedDepartureDT, '203'), _coll);
		_count := _count + 1;
	endif;
	
	if voyage.estimatedArrivalDT.date.isValid then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeDTMSegment (_protocol, null, '132', voyage.estimatedArrivalDT, '203'), _coll);
		_count := _count + 1;
	endif;
	
	if voyage.departedDT.date.isValid then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeDTMSegment (_protocol, null, '186', voyage.departedDT, '203'), _coll);
		_count := _count + 1;
	endif;
	
	if voyage.arrivedDT.date.isValid then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeDTMSegment (_protocol, null, '178', voyage.arrivedDT, '203'), _coll);
		_count := _count + 1;
	endif;
	
	
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="8a6e4695-6bd3-48de-91db-498b669ebd67">
        <updating/>
        <source>outputHeader_NAD(_protocol: CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input; _camMessage: CM_CamMessage input; _coll: HugeStringArray input): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI
18 Jul 2022	jlzim1	TFS 54142 AAT - Add NAD+MS to Standard COARRI SMDG213

*/

vars
	code : String;
	fCode : String;
	strLine : String;
	operatorOid : CM_Operator;
	xlationOperator : CM_Operator;
	nullOperator : Boolean;
	foundMatch : Boolean;
begin
	
	code := _camMessage.camVoyage.getVoyageOperatorCode;
	operatorOid := app.myRoot.allOperators[code];
	if operatorOid &lt;&gt; null and
	   CM_NullOperator.hasInstance(operatorOid) then
	   nullOperator := true;
	endif;

	xlationOperator := app.myRoot.allOperators[_protocol.operatorXlationCode.trimBlanks];
	fCode := app.myRoot.getXlationForeignOperatorCode(xlationOperator, code, foundMatch).trimRight;
	
	if fCode = null then
		fCode := code;
	endif;
	
	if fCode &lt;&gt; null and
	   not nullOperator then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "CA", fCode, '172', '20'), _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 1;
	endif;
	
	if _protocol.getIncludeNADMSCOARRISMDG213() = true then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment(_protocol, null, "MS",  self.getCamISOPortDesc(_protocol), '160', '87'), _coll);
	endif;

	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_RFF" id="3653a5ee-8d4b-482b-bef6-e4d2802e0d0e">
        <updating/>
        <source>outputHeader_RFF(_protocol: CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input; _camMessage: CM_CamMessage input; _coll: HugeStringArray input): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI

*/


vars
	strLine : String;
	voyageCode : String;
	voyage : CM_Voyage;
	callSign : String;
begin
	voyageCode := _camMessage.camVoyage.getSanitisedVoyageCode();
	if voyageCode &lt;&gt; null then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeRFFSegment(_protocol, null, "VON",  voyageCode), _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 1;
	endif;
	
	voyage := _camMessage.camVoyage.voyageOid;
	callSign := voyage.callSign.trimRight;
	if callSign = null and
	   voyage.myVessel &lt;&gt; null then
		callSign := voyage.myVessel.callSign;
	endif;
	
	if callSign &lt;&gt; null then
	
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeRFFSegment(_protocol, null, "VM",  callSign), _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 1;
	endif;

	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_TDT" id="07f3e77e-c6d8-49c0-8c40-036751367e79">
        <updating/>
        <source>outputHeader_TDT(_camTaskHistory: CM_CamTaskHistory input; _protocol: CM_CamProtocol; _camVoyage: CM_CamVoyage; _count: Integer io; _coll: HugeStringArray input): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI

*/

vars
	voyage : CM_Voyage;
	callSign : String;
	lloydsNumber : String;
	code : String;
	fCode : String; 
	msg : String;
	strLine : String;
	xlationOperator : CM_Operator;
	foundMatch : Boolean;
	voyOperator : CM_Operator;
begin
	voyage := _camVoyage.voyageOid;
		
	if voyage &lt;&gt; null then
		lloydsNumber := voyage.lloydsNumber;
		if lloydsNumber = null and
		   voyage.myVessel &lt;&gt; null then
			lloydsNumber := voyage.myVessel.lloydsNumber;
		endif;
	endif;
	// work out carrier code - 
	code := _camVoyage.getVoyageOperatorCode;
	xlationOperator := app.myRoot.allOperators[_protocol.operatorXlationCode.trimBlanks];
	fCode := app.myRoot.getXlationForeignOperatorCode(xlationOperator, code, foundMatch).trimRight;
	
	voyOperator	 := app.myRoot.allOperators[code];
	
	if fCode = null then
		fCode := code;
	endif;
	
	msg := self.makeTDT20Segment(_protocol, _camVoyage.getVoyageVoyageCode(), "1", 
									null, fCode , "172", "20", voyOperator.description, null, lloydsNumber, '146', '11', voyage.vesselName.trimRight.toUpper);
			
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, msg, _coll);	
	
	_count := _count + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNA" id="a87302c0-a8af-46a9-b9dd-cf9abe15708b">
        <updating/>
        <source>outputHeader_UNA(_protocol: CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input): String updating, protected;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 April 2019
TFS#		: 44294
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	return self.outputFileMessage(_camTaskHistory, self.makeUNASegment (_protocol), null);
end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
