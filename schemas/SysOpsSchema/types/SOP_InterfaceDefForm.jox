    <JadeMethod name="setupForm" id="ece1269c-d4a9-4d04-8159-b865e779e746">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method called when a form is loaded.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.myTerminal	:=	app.getMyTerminalDO_NOT_USE();
	
	if self.myTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "No current Terminal is selected.");
	endif;
	
	self.fldDefinition.useSheetBackColors	:=	true;
	self.fldDefinition.setDefaultSheetBackColors();
	self.fldDefinition.initSheetBackColors();
	
	// cnwrl1 10/11/2009 PAR 21033 - start of coding
	self.minimumHeight	:= 427;
	self.minimumWidth	:= 713;
	// cnwrl1 10/11/2009 PAR 21033 - end of coding
	
	self.comboboxPopulateDefinitions();
	self.comboboxPopulateLocales();
	self.comboboxPopulateTypes();//29 December 2009	#cnwdz2	 par21593
	self.tableInitializeTranslations();
	cmbTermArea.listCollection(self.myTerminal.allTerminalAreaMastersById, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	self.doPopulateWithDefinition(null, true);
	frmToolbar.visible	:=	false;
	self.doEnableControls();
end;</source>
    </JadeMethod>
    <JadeMethod name="tableDeleteTranslations" id="07aac08c-26aa-4b62-bb84-c07925881c2f">
        <source>tableDeleteTranslations() protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Clears the table of Interface Translations, and deletes each row's
//				proxy object.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: CM_BaseTable;
	rowObj			: JadeTableRow;
	startRow		: Integer;
	maxRow			: Integer;
	rowPointer		: Integer;
	translationObj	: CM_InterfaceTranslationTA;
	isObjInvalid	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, translationObj, isObjInvalid);
	
	tableObj	:=	tblTranslations;
	startRow	:=	tableObj.fixedRows + 1;
	maxRow		:=	tableObj.rows;
	
	foreach rowPointer in startRow to maxRow do
		rowObj			:=	tableObj.accessRow(rowPointer);
		translationObj	:=	rowObj.itemObject.CM_InterfaceTranslationTA;
		
		if translationObj &lt;&gt; null then
			delete translationObj;
			
			if isObjInvalid then
				isObjInvalid	:=	false;
				continue;
			endif;
		endif;
	endforeach;
	
	tableObj.rows	:=	1;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableInitializeTranslations" id="cced0e58-9036-46ba-b529-a115de59e701">
        <source>tableInitializeTranslations() protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Initializes the table of Interface Translations.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: CM_BaseTable;
	columnObj	: JadeTableColumn;
	
begin
	self.tableDeleteTranslations();
	tableObj			:=	tblTranslations;
	tableObj.columns	:=	3;
	tableObj.tabKey		:=	J_key_Tab;
	tableObj.partialTextIndication	:=	true;
	tableObj.accessRow(1).backColor := self.colorHeadingColumn;	
	
	if not self.isReadOnly then
		columnObj				:=	tableObj.accessColumn(1);
		columnObj.cellControl	:=	cmbTermArea;
		cmbTermArea.automaticCellControl	:=	true;
		
		columnObj				:=	tableObj.accessColumn(2);
		columnObj.inputType		:=	Table.InputType_TextBox;
		columnObj.cellControl	:=	txtCellText;
		
		columnObj				:=	tableObj.accessColumn(3);
		columnObj.inputType		:=	Table.InputType_TextBox;
		columnObj.cellControl	:=	txtCellText;
		txtCellText.automaticCellControl	:=	true;
	endif;
	
	tableObj.setCellText(1, 1, app.getErrorString(TerminalArea) &amp; Tab &amp; app.getErrorString(SourceTranslation) &amp; Tab &amp; app.getErrorString(DestinationTranslation));
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tablePopulateTranslations" id="d922f7f2-d943-4b93-8ba9-a8abd03cd67e">
        <source>tablePopulateTranslations(_definitionObj:CM_TCPInterfaceDefinition) protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Populates the Interface Translations table.
//
// Parameters:	_definitionObj - A reference to the Interface Definition to populate
//					from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: CM_BaseTable;
	translationObj	: CM_InterfaceTranslationTA;
	cellObj			: JadeTableCell;
	rowPointer		: Integer;
	
begin
	self.tableInitializeTranslations();
	
	if _definitionObj = null then
		return;
	endif;
	
	tableObj	:=	tblTranslations;
	
	foreach translationObj in _definitionObj.allInterfaceTranslationTAs do
		rowPointer	:=	tableObj.addItem(translationObj.getTableDisplay());
		tableObj.accessRow(rowPointer).itemObject	:=	translationObj;
		cellObj		:=	tableObj.accessCell(rowPointer, 1);
		cellObj.itemObject	:=	translationObj.myTerminalAreaMaster;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_definitionObj" type="CM_TCPInterfaceDefinition"/>
    </JadeMethod>
    <JadeMethod name="tableSetRowTerminalArea" id="ed2ffe3f-6a33-4ec4-8f18-6eae7ccceefc">
        <updating/>
        <source>tableSetRowTerminalArea(_terminalAreaObj:CM_TerminalAreaMaster) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Sets the Terminal Area of the currently selected Interface Translation.
//
// Parameters:	_terminalAreaObj - A reference to the Terminal Area object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: CM_BaseTable;
	rowPointer		: Integer;
	cellObj			: JadeTableCell;
	
begin
	tableObj	:=	tblTranslations;
	rowPointer	:=	tableObj.row;
	
	if tableObj.cnEcIsValidRow(rowPointer) then
		cellObj	:=	tableObj.accessCell(rowPointer, 1);
		cellObj.itemObject	:=	_terminalAreaObj;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_terminalAreaObj" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
