					&lt;messageMode&gt;U&lt;/messageMode&gt;
					&lt;remarks&gt;Details remarks 03&lt;/remarks&gt;
				&lt;/BOLDetails&gt;
				&lt;BOLDetails&gt;
					&lt;height&gt;4.0000&lt;/height&gt;
					&lt;length&gt;13.0000&lt;/length&gt;
					&lt;weight&gt;6.0000&lt;/weight&gt;
					&lt;width&gt;3.0000&lt;/width&gt;
					&lt;quantity&gt;5&lt;/quantity&gt;
					&lt;colour&gt;1224&lt;/colour&gt;
					&lt;commodity&gt;GENL&lt;/commodity&gt;
					&lt;id&gt;BOL122&lt;/id&gt;
					&lt;messageMode&gt;D&lt;/messageMode&gt;
					&lt;remarks&gt;Details remarks 04&lt;/remarks&gt;
				&lt;/BOLDetails&gt;
			&lt;/AllBOLDetails&gt;
		&lt;/BOLHeader&gt;
		&lt;BOLHeader&gt;
			&lt;bolType&gt;5003&lt;/bolType&gt;
			&lt;destinationPort&gt;NZAKL&lt;/destinationPort&gt;
			&lt;dischargePort&gt;AUSYD&lt;/dischargePort&gt;
			&lt;id&gt;BOL123&lt;/id&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;messageMode&gt;U&lt;/messageMode&gt;
			&lt;notifyParty&gt;CCS&lt;/notifyParty&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;remarks&gt;This is a remarks&lt;/remarks&gt;
			&lt;transportMode&gt;SHIP&lt;/transportMode&gt;
			&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;clientRef1&gt;Service Order Number 2&lt;/clientRef1&gt;
			&lt;clientRef2&gt;Purchase Order Number 2&lt;/clientRef2&gt;
			&lt;vehicle&gt;&lt;/vehicle&gt;
			&lt;AllBOLDetails&gt;
				&lt;BOLDetails&gt;
					&lt;height&gt;12.0000&lt;/height&gt;
					&lt;length&gt;13.0000&lt;/length&gt;
					&lt;weight&gt;49.0000&lt;/weight&gt;
					&lt;width&gt;3.0000&lt;/width&gt;
					&lt;quantity&gt;5&lt;/quantity&gt;
					&lt;colour&gt;1231&lt;/colour&gt;
					&lt;commodity&gt;GENL&lt;/commodity&gt;
					&lt;id&gt;BOL123&lt;/id&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;remarks&gt;Details remarks&lt;/remarks&gt;
				&lt;/BOLDetails&gt;
			&lt;/AllBOLDetails&gt;
		&lt;/BOLHeader&gt;
		&lt;BOLHeader&gt;
			&lt;bolType&gt;5003&lt;/bolType&gt;
			&lt;destinationPort&gt;NZAKL&lt;/destinationPort&gt;
			&lt;dischargePort&gt;AUSYD&lt;/dischargePort&gt;
			&lt;id&gt;BOL124&lt;/id&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;messageMode&gt;U&lt;/messageMode&gt;
			&lt;notifyParty&gt;CCS&lt;/notifyParty&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;remarks&gt;This is a remarks second&lt;/remarks&gt;
			&lt;transportMode&gt;SHIP&lt;/transportMode&gt;
			&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;clientRef1&gt;Service Order Number 3&lt;/clientRef1&gt;
			&lt;clientRef2&gt;Purchase Order Number 3&lt;/clientRef2&gt;
			&lt;vehicle&gt;&lt;/vehicle&gt;
			&lt;AllBOLDetails&gt;
				&lt;BOLDetails&gt;
					&lt;height&gt;12.0000&lt;/height&gt;
					&lt;length&gt;13.0000&lt;/length&gt;
					&lt;weight&gt;49.0000&lt;/weight&gt;
					&lt;width&gt;3.0000&lt;/width&gt;
					&lt;quantity&gt;5&lt;/quantity&gt;
					&lt;colour&gt;1241&lt;/colour&gt;
					&lt;commodity&gt;GENL&lt;/commodity&gt;
					&lt;id&gt;BOL124&lt;/id&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;remarks&gt;Details remarks&lt;/remarks&gt;
				&lt;/BOLDetails&gt;
			&lt;/AllBOLDetails&gt;
		&lt;/BOLHeader&gt;
		&lt;BOLHeader&gt;
			&lt;bolType&gt;5003&lt;/bolType&gt;
			&lt;destinationPort&gt;NZAKL&lt;/destinationPort&gt;
			&lt;dischargePort&gt;AUSYD&lt;/dischargePort&gt;
			&lt;id&gt;BOL125&lt;/id&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;messageMode&gt;U&lt;/messageMode&gt;
			&lt;notifyParty&gt;CCS&lt;/notifyParty&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;remarks&gt;This is a remarks second&lt;/remarks&gt;
			&lt;transportMode&gt;SHIP&lt;/transportMode&gt;
			&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;clientRef1&gt;Service Order Number 4&lt;/clientRef1&gt;
			&lt;clientRef2&gt;Purchase Order Number 4&lt;/clientRef2&gt;
			&lt;vehicle&gt;&lt;/vehicle&gt;
			&lt;AllBOLDetails&gt;
				&lt;BOLDetails&gt;
					&lt;height&gt;12.0000&lt;/height&gt;
					&lt;length&gt;13.0000&lt;/length&gt;
					&lt;weight&gt;49.0000&lt;/weight&gt;
					&lt;width&gt;3.0000&lt;/width&gt;
					&lt;quantity&gt;5&lt;/quantity&gt;
					&lt;colour&gt;1251&lt;/colour&gt;
					&lt;commodity&gt;GENL&lt;/commodity&gt;
					&lt;id&gt;BOL125&lt;/id&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;remarks&gt;Details remarks&lt;/remarks&gt;
