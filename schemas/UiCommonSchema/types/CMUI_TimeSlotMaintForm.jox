    <JadeMethod name="doBtnNextPrevClick" id="648a4ba1-c4b5-488f-a71d-6452b5d2b574">
        <source>doBtnNextPrevClick(_isNext : Boolean);
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	date : Date;
	monthIndex : Integer;
begin
	monthIndex := cmbMonth.listIndex;
	//if monthIndex &lt; 12 and monthIndex &gt; 1 then
		if _isNext and (monthIndex - 1) &gt;= 1 then
			self.tblCalendar.selectedDate.setDate(self.tblCalendar.selectedDate.day, cmbMonth.itemData[cmbMonth.listIndex - 1], txtYear.text.Integer);
			self.tblCalendar.setDate(self.tblCalendar.selectedDate);	
			self.cmbMonth.listIndex	:=	self.cmbMonth.listIndex - 1;
		elseif not _isNext and (monthIndex + 1) &lt;= 12 then
			self.tblCalendar.selectedDate.setDate(self.tblCalendar.selectedDate.day, cmbMonth.itemData[cmbMonth.listIndex + 1], txtYear.text.Integer);
			self.tblCalendar.setDate(self.tblCalendar.selectedDate);	
			self.cmbMonth.listIndex	:=	self.cmbMonth.listIndex + 1;
		endif;
	//endif;
epilog

end;</source>
        <Parameter name="_isNext" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnSaveClick" id="75e17f77-451e-4091-b092-8167ec848ca5">
