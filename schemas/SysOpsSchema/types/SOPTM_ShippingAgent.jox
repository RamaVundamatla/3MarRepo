    <JadeMethod name="includeObject" id="4797ab7c-8d46-47bd-86af-25bc8a52a2ee">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_ShippingAgent.notAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="d6176664-bb98-4d64-b79f-0fff3c0e698e">
        <source>initShtMultiSelect();
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpCol	: ObjectSet;
begin

	inheritMethod;	

	create tmpCol transient;
	app.myRoot.getEmailAddresses(tmpCol,false);
	self.setupMultiSelect1("Contacts",tmpCol,SOP_TableMaintForm::displayEntryEmailAddress.name);	
	
epilog
	delete tmpCol;

end;</source>
    </JadeMethod>
