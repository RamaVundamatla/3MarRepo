    <JadeMethod name="displayForXlation" id="03476bfd-a1c6-4392-9d7e-95331e2324cd">
        <source>displayForXlation(_codeFirst: Boolean): String;
/*

Purpose:			Displays the code and description field for the Xlation

Parameters:			_codeFirst	Boolean	Whether or not the code should appear first

Return Value:		String	Representing the fields that should be displayed

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	if _codeFirst then
		return self.code.trimBlanks &amp; ' [' &amp; self.description.trimBlanks &amp; ']';
	else
		return self.description.trimBlanks &amp; ' [' &amp; self.code.trimBlanks &amp; ']';
	endif;
	
end;</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
