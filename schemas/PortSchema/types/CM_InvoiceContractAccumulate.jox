    <JadeMethod name="setForUpdate" id="bf3c36e4-6641-4994-a874-92cebcf24f63">
        <updating/>
        <source>setForUpdate(_pxyInvContractAccumulate : CM_InvoiceContractAccumulate) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars

begin
	_pxyInvContractAccumulate.raiseExceptionIfNotTransient(method);
	
	self.raiseExceptionIfTransient(method);
	
	self.accumulatedQuantity 	:= _pxyInvContractAccumulate.accumulatedQuantity;
	self.accumulatedTEU 		:= _pxyInvContractAccumulate.accumulatedTEU;
	self.accumulatedVolume 		:= _pxyInvContractAccumulate.accumulatedVolume;
	self.accumulatedWeight 		:= _pxyInvContractAccumulate.accumulatedWeight;
	self.accumulationType		:= _pxyInvContractAccumulate.accumulationType;
	self.myBusinessUnit 		:= _pxyInvContractAccumulate.myBusinessUnit;
	self.myVoyage 				:= _pxyInvContractAccumulate.myVoyage;
	self.myContractByVolume 	:= _pxyInvContractAccumulate.myContractByVolume;
	self.myVessel 				:= _pxyInvContractAccumulate.myVessel;
	
epilog

end;</source>
        <Parameter name="_pxyInvContractAccumulate" type="CM_InvoiceContractAccumulate"/>
    </JadeMethod>
    <JadeMethod name="setFromInvoiceLine" id="090a91b2-f2ab-4a99-874b-334246d0d314">
        <updating/>
        <source>setFromInvoiceLine(_invLine : CM_InvoiceLine; _accumType : Integer; _detail : CM_InvoiceContractDtlsVolBased) updating;
/*
Purpose:			

Date		Who		Reason
24 January 2023	navab1	TFS CR 55624 TASK 55700 
*/

vars
	titrans : CM_TITransaction;
	voyage : CM_Voyage;

begin
	if _invLine = null then
		return;
	endif;
	
	titrans := _invLine.myTransactionTI;
	if titrans &lt;&gt; null then
		voyage := titrans.getVoyage();
	endif;
	
	self.accumulationType := _accumType;
	
	if _accumType = INV_VOL_BASED_VOYAGE 
	and voyage &lt;&gt; null then
		self.myVoyage := voyage;
		self.myVessel := voyage.vessel;
	endif;
	
	self.myBusinessUnit := _invLine.bank;
	self.myContractByVolume := _detail;
	
	self.createdDateTime := app.actualTimeAppServer;
	

epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <Parameter name="_accumType" type="Integer"/>
        <Parameter name="_detail" type="CM_InvoiceContractDtlsVolBased"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="47cbbb85-3ed6-47b8-9bc9-5e2314d6598b">
        <updating/>
        <source>setProxy(	_accumulatedQty : Integer;
			_accumulatedTEU : Decimal; 
			_accumulatedVol : Decimal; 
			_accumulatedWeight : Decimal;
			_accumulationType : Integer; 
			_createdDateTime : TimeStamp;
			_myBusinessUnit : CM_Bank;
			_myContractByVolume : CM_InvoiceContractDtlsVolBased;
			_myVessel : CM_Vessel;
			_myVoyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars

begin
	self.accumulatedQuantity 	:= _accumulatedQty;
	self.accumulatedTEU 		:= _accumulatedTEU;
	self.accumulatedVolume 		:= _accumulatedVol;
	self.accumulatedWeight 		:= _accumulatedWeight;
	self.accumulationType 		:= _accumulationType;
	self.createdDateTime 		:= _createdDateTime;
	self.myBusinessUnit 		:= _myBusinessUnit;
	self.myContractByVolume 	:= _myContractByVolume;
	self.myVessel 				:= _myVessel;
	self.myVoyage 				:= _myVoyage;
epilog

end;</source>
        <Parameter name="_accumulatedQty" type="Integer"/>
        <Parameter name="_accumulatedTEU" type="Decimal"/>
        <Parameter name="_accumulatedVol" type="Decimal"/>
        <Parameter name="_accumulatedWeight" type="Decimal"/>
        <Parameter name="_accumulationType" type="Integer"/>
        <Parameter name="_createdDateTime" type="TimeStamp"/>
        <Parameter name="_myBusinessUnit" type="CM_Bank"/>
        <Parameter name="_myContractByVolume" type="CM_InvoiceContractDtlsVolBased"/>
        <Parameter name="_myVessel" type="CM_Vessel"/>
        <Parameter name="_myVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="cd35f7b5-cf1c-4b22-ace9-012ac596ed99">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	realInvContAccumulate 	: CM_InvoiceContractAccumulate;
	invContDtlsVolBased		: CM_InvoiceContractDtlsVolBased;
begin
	
	invContDtlsVolBased := self.myContractByVolume;
	
	// Accumulate by Period, can only have 1 accumulation
	if invContDtlsVolBased.isAccumulateByPeriod() then
		if invContDtlsVolBased.allAccumulationsByType.getAtKey(self.accumulationType, null) &lt;&gt; null then
			app.raiseCMException(ContDtlOnlyOneAccum, null, null);
		endif;
	// Accumulate by Period, can only have 1 accumulation for the same voyage
	elseif invContDtlsVolBased.isAccumulateByVoyage() then
		
		if self.myVoyage = null then
			app.raiseCMException(SHP_Please_Select_A_Voyage, null, null);
		endif;
		
		if invContDtlsVolBased.allAccumulationsByType.getAtKey(self.accumulationType, self.myVoyage) &lt;&gt; null then
			if self.myVoyage &lt;&gt; null then
				app.raiseCMException1(ContDtlAlreadyHaveAccum, self.myVoyage.code, null, null);
			else
				app.raiseCMException1(ContDtlAlreadyHaveAccum, "null", null, null);
			endif;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
