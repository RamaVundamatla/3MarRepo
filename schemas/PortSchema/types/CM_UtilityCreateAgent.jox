        <source>utlCreateUnpackInternalJob(	_unpackJobParam	: CMIF_WorkOrderJobParams;
							_realUnpackJob	: CM_WOUnpackJob output;
							_terminal 				: CM_Terminal;
							_passport				: CM_Passport input) updating;
/*

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwrd1	Initial creation
12/06/2022	navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema Changed input parameters to use new types
*/


vars
	cancelSave : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	// app.myValCA.valYardInternalJob(_yardInternalJobParam);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;


	app.setContinueCMExceptions(false);

	create _realUnpackJob persistent;
