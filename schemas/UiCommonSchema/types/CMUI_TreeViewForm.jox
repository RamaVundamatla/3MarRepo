    <JadeMethod name="getOriginalDockingParent" id="c6926fe4-d429-444c-9338-8b3bae7cb6ee">
        <source>getOriginalDockingParent(_dockControl : JadeDockBase) : Control;
/*
----------   ----------  --------------------------------------------------
Created:	26 April 2007 By cnwth2

Purpose:	re-implement and inherit as necessary if you have further dock controls on sub-classes

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _dockControl = self.dkcLeftMain or _dockControl = self.dkcRightMain then
		return self.frmMain;
	elseif _dockControl = self.dkbTopLeft or _dockControl = self.dkbBottomLeft then
		return self.dkcLeftMain;
	elseif _dockControl = self.dkbTopRight or _dockControl = self.dkbBottomRight then
		return self.dkcRightMain;
	endif;
	
	return null;
end;


</source>
        <Parameter name="_dockControl" type="JadeDockBase"/>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="getXMLDockControlSettings" id="9319a216-b3ea-4263-ac7a-f8e430dd8cb5">
        <source>getXMLDockControlSettings(_dkb : JadeDockBase) : String protected;
/*
----------   ----------  --------------------------------------------------
Created:	03 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str		: String;
begin
	
	str := global.formatAsXMLPrefix(_dkb.name) &amp;
			global.formatAsXML(self.XMLTag_DockBarWidth, _dkb.width.String) &amp;
			global.formatAsXML(self.XMLTag_DockBarHeight, _dkb.height.String) &amp;
			global.formatAsXML(self.XMLTag_DockBarLeft, _dkb.left.String) &amp;
			global.formatAsXML(self.XMLTag_DockBarTop, _dkb.top.String) &amp;
			global.formatAsXML(self.XMLTag_DockBarFloating, _dkb.isFloating.String) &amp;
			global.formatAsXML(self.XMLTag_DockBarVisible, _dkb.visible.String) &amp;
		global.formatAsXMLSuffix(_dkb.name);
	
	
	return str;

end;


</source>
        <access>protected</access>
        <Parameter name="_dkb" type="JadeDockBase"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="76c06205-5777-4543-a88c-c3ff2379c893">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
----------   ----------  --------------------------------------------------
Created:	03 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str			: String;
begin
	str := inheritMethod() &amp; CrLf;
	str := str &amp; self.getXMLDockControlSettings(self.dkcLeftMain) &amp;
				self.getXMLDockControlSettings(self.dkcRightMain) &amp;
				self.getXMLDockControlSettings(self.dkbTopLeft) &amp;
				self.getXMLDockControlSettings(self.dkbBottomLeft) &amp;
				self.getXMLDockControlSettings(self.dkbTopRight) &amp;
				self.getXMLDockControlSettings(self.dkbBottomRight);
				
	str := str &amp; CrLf &amp; global.formatAsXML(self.XMLTag_CloseOnSave, self.mnuCloseOnSave.checked.String);
	
	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initDockControlFromXML" id="707e66ae-d250-43ea-9224-2dc046f58f31">
        <source>initDockControlFromXML(_str : String; _dkb : JadeDockBase input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	03 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-' &amp; _str);
	
	if _str.cnEcGetTagValueOfName(self.XMLTag_DockBarFloating).Boolean then
		_dkb.float(_str.cnEcGetTagValueOfName(self.XMLTag_DockBarLeft).Integer,
					_str.cnEcGetTagValueOfName(self.XMLTag_DockBarTop).Integer,
					_str.cnEcGetTagValueOfName(self.XMLTag_DockBarWidth).Integer,
					_str.cnEcGetTagValueOfName(self.XMLTag_DockBarHeight).Integer);
	else//if JadeDockContainer.hasInstance(_dkb) then
		_dkb.width := _str.cnEcGetTagValueOfName(self.XMLTag_DockBarWidth).Integer - 50;//for the grab bar
		_dkb.height := _str.cnEcGetTagValueOfName(self.XMLTag_DockBarHeight).Integer;	
	endif;
	
	_dkb.visible := _str.cnEcGetTagValueOfName(self.XMLTag_DockBarVisible).Boolean;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <Parameter name="_dkb" type="JadeDockBase" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initEntryTable" id="d1bd41da-d033-4561-8158-7d6060dd3026">
        <updating/>
        <source>initEntryTable(_entTabelDefName: String; _tbl: CM_EntryTable input) updating,protected;
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	entTableDef		: EntTableDef;
	table 			: CM_EntryTable;
begin
	if self.mode = self.Mode_View then
		self.tblEntry.userInputEnabled := false;
	else
		self.tblEntry.userInputEnabled := true;
	endif;	
	
	_tbl.warningMethod 			:= CMUI_TreeViewForm::zEntTableWarning.name;
	_tbl.setObjectWarningMethod := CMUI_TreeViewForm::zSetTblFromObjWarning.name;
	
	self.setColorsForEntryTable(_tbl);
	
	_tbl.changeMode := _tbl.ChangeMode_FirstOnly;	
	entTableDef 	:= app.myController.getEntTableDef(_entTabelDefName);
	
	_tbl.setEntTableDef(entTableDef, null, CMUI_TreeViewForm::zSetEntTableDefWarning.name);
	table:=_tbl;
	//epr par 34623 25/7/14
	self.resetMeasurementRows(table);																	// PAR #34058
	self.loadMeasurementTypes(table, _tbl.myEntTableDef.name, _tbl.myEntTableDef.allEntTableRows, true);	// PAR #34058
end;


</source>
        <access>protected</access>
        <Parameter name="_entTabelDefName" type="String"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="aa66ab90-0378-42a7-b57f-bc1b5bfdfa1f">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*
----------   ----------  --------------------------------------------------
Created:	03 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str		: String;

begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	/*
	self.initDockControlFromXML(_userWindow.xmlInfo.cnEcGetTagValueOfName(self.dkcLeftMain.name), self.dkcLeftMain);
	self.initDockControlFromXML(_userWindow.xmlInfo.cnEcGetTagValueOfName(self.dkcRightMain.name), self.dkcRightMain);
	self.initDockControlFromXML(_userWindow.xmlInfo.cnEcGetTagValueOfName(self.dkbTopLeft.name), self.dkbTopLeft);
	self.initDockControlFromXML(_userWindow.xmlInfo.cnEcGetTagValueOfName(self.dkbBottomLeft.name), self.dkbBottomLeft);
	self.initDockControlFromXML(_userWindow.xmlInfo.cnEcGetTagValueOfName(self.dkbTopRight.name), self.dkbTopRight);
	self.initDockControlFromXML(_userWindow.xmlInfo.cnEcGetTagValueOfName(self.dkbBottomRight.name), self.dkbBottomRight);
	*/
	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_CloseOnSave).String;
	if str = null then
		str := true.String;
	endif;
	self.mnuCloseOnSave.checked := str.Boolean;
	self.closeOnSave := str.Boolean;
		
	
end;


</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="2972ad08-e9d4-45e2-9fde-e18f86345ad8">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if keyCode = J_key_LeftArrow then
		self.doKeyLeftArrow(shift);
		return;
	elseif keyCode = J_key_RightArrow then
		self.doKeyRightArrow(shift);
		return;
		
	elseif keyCode = J_key_F3 then
		if self.mode &lt;&gt; self.Mode_View then
			return;
		endif;
		self.showHideSearcher();
		return;
	elseif keyCode =J_key_Escape then
		self.doEscapeKeyPress();
	endif;
	
	inheritMethod (keyCode, shift);

end;


</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
