    <JadeMethod name="cmbTrailIMEX_click" id="5997139e-d60c-4423-9bd0-10a2a3c2492f">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTrailIMEX_click(combobox: ComboBox input) updating;
/*

Date		Who		Reason
10 July 2014	cnwer1	Initial creation PAR

*/

vars
	imex : CM_IMEXStatus;
begin
	imex:=combobox.listObject.CM_IMEXStatus;
	if imex &lt;&gt;  null and imex.code = TI_IMEX_STATUS_REMAINONBOARD then
		self.grpTrailerOut.enabled:=false;
		self.optChassisRelID.value:=true;
		self.txtChassisIDOut.text:=self.txtChassisIDIn.text;
	else
		self.grpTrailerOut.enabled:=true;
		if self.txtChassisIDOut.text = self.txtChassisIDIn.text then
			self.txtChassisIDOut.text:=null;
		endif;
	endif;
epilog

end;</source>
