        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isAnExcludedTypeForMatching" id="3e82094b-cb4d-4271-9333-61d3c6172fde">
        <source>isAnExcludedTypeForMatching(_type: Integer): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2015	cnwndl1	Initial creation	STW Par 37402 TFS 1192  EDI Multi line Release
11 December 2024    navsp1  MTN-33485 EUP | Commodity and IMEX Status are not accepted as Extra Criteria in the RequestMultiLine EDI
*/

vars

begin

	if _type = YACriteriaType_AvGrade
	or _type = YACriteriaType_BOL
	or _type = YACriteriaType_BookingRef //12 Aug 2016	NDL	TFS 2527
	or _type = YACriteriaType_CargoType
	or _type = YACriteriaType_Clean
	//or _type = YACriteriaType_Commodity //12 Aug 2016	NDL	TFS 2527 			//MTN-33485
	or _type = YACriteriaType_CommodityGroup //12 Aug 2016	NDL	TFS  
	or _type = YACriteriaType_Consignee
	or _type = YACriteriaType_FreightForward
	or _type = YACriteriaType_ISO
	or _type = YACriteriaType_ISOGroup
	//or _type = YACriteriaType_ImexStatus										//MTN-33485
	or _type = YACriteriaType_OperatorItem
	or _type = YACriteriaType_Product
	or _type = YACriteriaType_RailReleaseReq //12 Aug 2016	NDL	TFS 2527
	or _type = YACriteriaType_RequiresPower //12 Aug 2016	NDL	TFS 2527
	or _type = YACriteriaType_TrailerType  //12 Aug 2016	NDL	TFS 2527
	or _type = YACriteriaType_TransactionType  //12 Aug 2016	NDL	TFS 2527
	or _type = YACriteriaType_SrcTermArea
	or _type = YACriteriaType_SrcTermAreaType //12 Aug 2016 2016	NDL TFS 2527
	or _type = YACriteriaType_Stops	//21 Mar 2016	NDL	TFS 1691
	or _type = YACriteriaType_SubTerminal
	or _type = YACriteriaType_ToDoTasks	//21 Mar 2016	NDL	TFS 1691
	or _type = YACriteriaType_Voyage
	or _type = YACriteriaType_Weight //12 Aug 2016	NDL	TFS
	then
		return true;
	endif;
	
	return inheritMethod(_type);

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
