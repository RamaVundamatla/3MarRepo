//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	str : String;
	
begin
	if _colour &lt;&gt; null then
		str := _colour.colour;
		if _selected then
			return TableCheckBox_Selected &amp; Tab &amp; str;
