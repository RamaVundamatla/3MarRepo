    <JadeMethod name="convertAutoCargoIdCont" id="d16aa6b1-ebb8-4a8b-9393-d894b4515760">
        <source>convertAutoCargoIdCont();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation	Par 34660
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars

	term : CM_Terminal;
	autoCargo : CM_AutoCargoIdController;
	proxy : CM_AutoCargoIdGen;
	real : CM_AutoIdGenerator;

begin

	app.writeLog( method.qualifiedName &amp; ' Converting Auto Id Generator 8.3.2', LogINFO);

	foreach term in app.myRoot.allTerminals do
	
		autoCargo := term.myAutoCargoIdCont;	// the old way of doing it...
		if autoCargo &lt;&gt; null and autoCargo.nextSequenceNum &gt; 0 then
			real := term.getMyAutoIdGenerator( CM_AutoCargoIdGen );
			if real = null then
			
				create proxy transient;
				proxy.setProxy(	autoCargo.cargoIdPrefix,	//_cargoIdPrefix : String ;
								autoCargo.cargoIdSeqNumLength,	//_cargoIdSeqNumLength : Integer;
								autoCargo.cargoIdStyle,	//_cargoIdStyle : Integer; 
								autoCargo.myTerminal,	//_myTerminal : CM_Terminal; 
								autoCargo.nextSequenceNum,	//_nextSequenceNum : Real
								CM_AutoCargoIdGen.Reset_On_Overflow_Int
								);					
				//proxy.setPxyOtherAttributes( autoCargo.cargoLabelFormat );   // 1 Sept 2022 navmv20 TFS 54610
				proxy.setPxyOtherAttributes( autoCargo.cargoLabelFormat,null); //1 Sept 2022 navmv20 TFS 54610
				app.myTrxCA.trxCreateAutoIdGenerator( proxy, real, app.myPassport);				
				delete proxy;
				
				if not app.myPassport.trxCompletedOK then
					app.myPassport.clearErrorsWarnings();
					app.writeLog( method.qualifiedName &amp; ' Converting Auto Id Generator Failed for ' &amp; term.code , LogINFO);
					continue;
				else
					beginTransaction;
					real.setPropertyValue( CM_AutoCargoIdGen::lastIdGenerated.name, autoCargo.lastIdGenerated );
					commitTransaction;
					app.writeLog( method.qualifiedName &amp; ' Converted Auto Id Generator for ' &amp; term.code , LogINFO);
				endif;
				
			endif;
		endif;
		
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; ' Converting Auto Id Generator Completed', LogINFO);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertHookTypeDescriptions" id="7b99d44d-8d9b-42a7-b753-b2fa4b44702d">
        <source>convertHookTypeDescriptions();
/*
Purpose:			
Date		Who		Reason
22 August 2014	cnwab1	Initial creation
*/

vars


	root : CM_Root;
	hookType : CM_HookType;
begin

	app.writeLog( method.qualifiedName &amp; ' Renaming Invoice Hook Code Types 8.3.2', LogINFO);

	root := CM_Root.firstInstance;
	
	hookType := root.allHookTypes[12];
	beginTransaction;
	hookType.setPropertyValue("description", "Invoice Rate Cargo");
	commitTransaction;
	
	hookType := root.allHookTypes[24];
	beginTransaction;
	hookType.setPropertyValue("description", "Invoice Rate Voyage");
	commitTransaction;
	
	hookType := root.allHookTypes[13];
	beginTransaction;
	hookType.setPropertyValue("description", "Invoice Quantity Cargo");
	commitTransaction;
	
	hookType := root.allHookTypes[23];
	beginTransaction;
	hookType.setPropertyValue("description", "Invoice Quantity Voyage");
	commitTransaction;
end;

</source>
    </JadeMethod>
    <JadeMethod name="convertSavedUserWindows" id="a83d917e-b4f4-4118-b3aa-58d53d66dbcf">
        <source>convertSavedUserWindows();
/*

Purpose:		Rename saved user window table rows	

Parameters:			

Return Value:		

Date		Who		Reason
8/10/2014	cnwjre1	Initial creation	renamed ent table rows (Booleans from checkboxes to Yes/No)

*/

vars

	user	: CM_User;
	userWindow	: CM_UserWindowForOpen;
	transUserWindow	: CM_UserWindowForOpen;
	formName	: String;
	xmlStr	: String;

begin

	app.writeLog( method.qualifiedName &amp; ' Converting Saved User Windows 8.3.2', LogINFO);

	formName := "GTE_ReleaseRequestForm";
	foreach user in app.myRoot.allUsers do
		userWindow := user.allUserWindowsForOpen[formName];
		if userWindow &lt;&gt; null then
			transUserWindow := userWindow.cloneSelf(true);
			xmlStr := userWindow.xmlInfo;
			xmlStr.replaceString("&lt;column&gt;doISOGroupCheck&lt;/column&gt;","&lt;column&gt;doISOGroupCheckStr&lt;/column");
			xmlStr.replaceString("&lt;column&gt;hiLowCube&lt;/column&gt;","&lt;column&gt;hiLowCubeStr&lt;/column");
			xmlStr.replaceString("&lt;column&gt;allowCargoOnMultiRel&lt;/column&gt;","&lt;column&gt;allowCargoOnMultiRelStr&lt;/column");
			xmlStr.replaceString("&lt;column&gt;removeStops&lt;/column&gt;","&lt;column&gt;removeStopsStr&lt;/column");
			xmlStr.replaceString("&lt;column&gt;interTerminalRelease&lt;/column&gt;","&lt;column&gt;interTerminalReleaseStr&lt;/column");
			xmlStr.replaceString("&lt;column&gt;customsAssistance&lt;/column&gt;","&lt;column&gt;customsAssistanceStr&lt;/column");
			xmlStr.replaceString("&lt;column&gt;mtRelease&lt;/column&gt;","&lt;column&gt;mtReleaseStr&lt;/column");
			transUserWindow.setProxy(userWindow.myUser,
									 userWindow.windowClassName,
									 xmlStr,
									 userWindow.top,
									 userWindow.left,
									 userWindow.width,
									 userWindow.height,
									 userWindow.windowState);
			app.myTrxUA.trxUpdateUserWindow(user, transUserWindow, app.myPassport);
			delete transUserWindow;
		endif;
		
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; ' Converting Saved User Windows Completed', LogINFO);
	
epilog
	delete transUserWindow;
end;</source>
    </JadeMethod>
    <JadeMethod name="measurementsOnSummaries" id="fb67e9ec-4c5c-473f-942a-ed93c330bd48">
        <source>measurementsOnSummaries();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/08/2014	cnwdap1		Initial creation PAR #33235 Put measurement type on all CM_XTABGrouping and CMXTAB_Field objects
//
vars
	root : CM_Root;
	grouping : CM_XTABGrouping;
	field : CM_XTABField;
	weight, volume, linear, displacement, density : CM_MeasurementType;
	wc, vc, lc, disc, denc : Integer;
	
begin
	app.writeLog("Adding measurement types to exsting saved Summaries", LogINFO);
	
	weight := app.getDefaultMeasurementForType(Type_Weight);
	volume := app.getDefaultMeasurementForType(Type_Volume);
	linear := app.getDefaultMeasurementForType(Type_Linear);
	displacement := app.getDefaultMeasurementForType(Type_Displacement);
	density := app.getDefaultMeasurementForType(Type_Density);
	
	beginTransaction;
	foreach grouping in CM_XTABGrouping.instances do
		if grouping.propertyName.toUpper.cnContains("WEIGHT") then
			wc := wc + 1;
			grouping.setPropertyValue(CM_XTABGrouping::propertyName.name, weight.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
		if grouping.propertyName.toUpper.cnContains("VOLUME") then
			vc := vc + 1;
			grouping.setPropertyValue(CM_XTABGrouping::propertyName.name, volume.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
		if grouping.propertyName.toUpper.cnContains("VENTILATION") then
			disc := disc + 1;
			grouping.setPropertyValue(CM_XTABGrouping::propertyName.name, displacement.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
		if grouping.propertyName.toUpper.cnContains("LENGTH")			
		or grouping.propertyName.toUpper.cnContains("HEIGHT") 
		or grouping.propertyName.toUpper.cnContains("WIDTH") then
			lc := lc + 1;
			grouping.setPropertyValue(CM_XTABGrouping::propertyName.name, linear.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
		if grouping.propertyName.toUpper.cnContains("DENSITY") then
			denc := denc + 1;
			grouping.setPropertyValue(CM_XTABGrouping::propertyName.name, density.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
	endforeach;
	
	foreach field in CM_XTABField.instances do
		if field.propertyName.toUpper.cnContains("WEIGHT") then
			wc := wc + 1;
			field.setPropertyValue(CM_XTABField::propertyName.name, weight.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
		if field.propertyName.toUpper.cnContains("VOLUME") then
			vc := vc + 1;
			field.setPropertyValue(CM_XTABField::propertyName.name, volume.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
		if field.propertyName.toUpper.cnContains("VENTILATION") then
			disc := disc + 1;
			field.setPropertyValue(CM_XTABField::propertyName.name, displacement.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
		if field.propertyName.toUpper.cnContains("LENGTH")			
		or field.propertyName.toUpper.cnContains("HEIGHT") 
		or field.propertyName.toUpper.cnContains("WIDTH") then
			lc := lc + 1;
			field.setPropertyValue(CM_XTABField::propertyName.name, linear.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
		if field.propertyName.toUpper.cnContains("DENSITY") then
			denc := denc + 1;
			field.setPropertyValue(CM_XTABField::propertyName.name, density.shortName &amp; CN_UNDERSCORE &amp; grouping.propertyName);
		endif;
	endforeach;
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rel822_par34666" id="b12bab0b-0e45-4647-af2f-5735c87ebef7">
        <source>rel822_par34666();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2014	cnwrd1	Initial creation
foer par 34666 tidy up temporary data fix for changetracker.
*/

vars
	theClass : Class;
	aSchema : Schema;
	theJS	: Object;
begin

	aSchema := rootSchema.getSchema('JSSChangeTrackingSchema');
	theClass := aSchema.getClass('JSSCTNibblerManager');
	
	create theJS as theClass transient;

	
	theJS.sendMsg('removeJSSCTDict');
	
	
epilog
	delete theJS;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAllowPackMoreCargoConfig" id="76cef324-63bc-4c4b-b0ff-0dcea62c1792">
        <source>setAllowPackMoreCargoConfig();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2014	cnwdw1	Initial creation
*/
vars

begin
	app.writeLog('Set System Config - Allow Pack More Cargo',0);
	beginTransaction;
	app.myRoot.setConfig(AllowPackMoreCargo, true, true);  // default is on
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="4ee62f46-a02a-4244-823f-3848f70e170f">
        <updating/>
        <source>specificPostStandard(_controller : CnEcReleaseController) updating;
/*

Purpose:	Specific Release upgrade for JMT 8.3.2		

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2014	cnwdw1	Initial creation

*/
vars
	file	: File;
	str		: String;
begin
	create file transient;
	
	file.usePresentationFileSystem	:= false;
	//file.kind						:= File.Kind_ANSI;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	file.mode						:= File.Mode_Output;
	file.fileName					:= app.myCnCntrl.logPath &amp; '\app_upgrade.log';
	
	if file.isAvailable then
		file.purge();
	endif;
	
	str	:= 'Performing Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage( str, _controller, file );
	
	inheritMethod(_controller);

	self.setAllowPackMoreCargoConfig();
	
	self.convertAutoCargoIdCont();	//29 Jul 2014 NDL	Par 34660
	
	self.convertHookTypeDescriptions(); // AKB2014AUG PAR 34804
	
	self.rel822_par34666(); //cnwrd1 par 34666
	
	self.measurementsOnSummaries();		// cnwdap1 PAR #33235
	
	self.convertSavedUserWindows();
	
	//*************** this is the last thing that should happen
	str	:= 'Finished Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage(str, _controller, file);
	
epilog
	delete file;
end;
</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="specificPreStandard" id="2fe2f72b-26e4-4f61-abca-a4f5b66ab056">
        <updating/>
        <source>specificPreStandard(pControllerObj: CnEcReleaseController) updating;

vars

begin
	inheritMethod(pControllerObj);
end;
</source>
        <Parameter name="pControllerObj" type="CnEcReleaseController"/>
    </JadeMethod>
</Class>
