Parameters:			

Return Value:		

Date		Who		TFS		Reason
29 Aug 2019	jlgdi1	45802	Initial creation
*/

constants
	NEW_ENCRYPTION : Boolean = true;
	
vars
	user : CM_User;
	passwordBin : Binary;

begin
	user := app.myRoot.allUsers[JMTSUPPORT_Str];
	passwordBin := app.encryptPassword(JMTSUPPORT_Str, 'ManillaR0cks!', NEW_ENCRYPTION); 
	user.setPropertyValue(CM_User::currentPassword.name, passwordBin);
