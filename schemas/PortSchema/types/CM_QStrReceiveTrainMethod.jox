    <JadeMethod name="create" id="db6e77f2-bd01-43bd-bd55-cf70c8a7d9a7">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="850968b0-489c-462d-9b1e-7b61921d5dd4">
