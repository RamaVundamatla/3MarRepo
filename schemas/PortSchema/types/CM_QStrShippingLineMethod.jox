    <JadeMethod name="create" id="437b0e0e-eece-49d3-849f-f7080e0dd9aa">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2022	navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema

*/

vars
	operator : CM_QueryOperator;

begin
	if self.isTransient then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
epilog

end;</source>
    </JadeMethod>
