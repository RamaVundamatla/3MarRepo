    <JadeMethod name="getAuditTextForProperty" id="19ff67bc-c02a-4750-97e7-5c5d86f74697">
        <source>getAuditTextForProperty(_property: Property): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2016	cnwma1	Initial creation

*/

vars

	propName : String;
	
begin

	propName := _property.name;
	if propName = CM_BRefItemContainer::carbonDioxide.name then
		if self.CM_BRefItemContainer.getCarbonDioxide = NULL_CARBON_DIOXIDE then
			return self.formatAuditText(propName, null);			
		else
			return self.formatAuditText(propName, self.getCarbonDioxide.String);		
		endif;
	endif;
	
	if propName = CM_BookingRefItem::cubicMetres.name then
		if self.cubicMetres = NULL_INTEGER then
			return self.formatAuditText(propName, null);		
		else
			return self.formatAuditText(propName, self.cubicMetres.String);		
		endif;
	endif;
		
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
