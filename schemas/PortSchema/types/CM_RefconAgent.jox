        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="rfcIdent" id="9d48a2b4-ae87-4ab6-8473-4de6d8c25e1b">
        <source>rfcIdent(_containerID : String) : String protected;
//rfcIdent(_container : CM_Container) : String protected;
// cnwdvb1 29 April 2003 

vars

	message,	
	tiId		:String;
	
begin

	tiId := _containerID;
	tiId := tiId.padBlanks(11);
	message := tiId[1:4]&amp;" "&amp;tiId[5:7]&amp;"  ";
	return message[1:14];
end;</source>
