    <JadeMethod name="doDelete" id="a0fdd202-6f70-43f0-a3d2-bff57cd5bc79">
        <updating/>
        <source>doDelete():Boolean updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	: Integer;
begin
	if self.myCurrentObject = null then
		return true;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteGate(self.myCurrentObject.CM_Gate, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;

	return true;	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doInterchangeAreas" id="55769d6d-8ee7-4fa6-a761-1026cdd3e5a1">
        <source>doInterchangeAreas()protected;
// ---------------------------------------------------------------------------
// Created:     23 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	:SOP_TerminalAreaDefForm;
begin	

	form := app.loadForm (SOP_TerminalAreaDefForm, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).SOP_TerminalAreaDefForm;
	
	if form = null then
		return;	// should not happen :)
	endif;
	
	form.myFilterTAType_Default := app.myRoot.allTerminalAreaTypes[TA_TYPE_YARD_INTERCHANGE];
	
	form.show;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doKiosk" id="5785dfd4-eb7e-4b90-9587-18d6fc98cda7">
        <source>doKiosk(_mode : Integer; _kiosk : CM_Kiosk; _gateLane : CM_GateAreaLaneController) protected;

/*
Date			Who		Reason
07 July 2009	cnwar2	Initial creation

*/
vars
	form 	: SOP_LDKioskForm;
	kiosk	: CM_Kiosk;
	
begin
	// belts and braces - should not be here if no kiosk license
/*	if not app.myRoot.canDo(PmRoadGateKiosk) then 	
		return;
	endif;	*///07 Oct 2019	NDL	TFS 46169
		
	if _mode = Mode_Update and _kiosk = null then
		return;
	endif;

	form := app.loadForm (SOP_LDKioskForm, null, false, false, true, self.myTerminal, null).SOP_LDKioskForm;
	if form = null then
		return;	// should not happen :)
	endif;
	
	form.mode 			:= _mode;
	form.updateObject 	:= _kiosk;
	form.myGateLane 	:= _gateLane.pxyGetRealObject;
	
	form.showModal;
	
	if form.modalResult = IDOK then
		// add to hierarchy
		kiosk := form.updateObject.CM_Kiosk;
		self.myAssistant.comboBoxKiosks(self.cmbKiosk, app.myCurrentUserCan (self.myTerminal, PmAdmKioskMaint), kiosk.description);
		self.tblGateLanes.text := kiosk.description;
	else
		if _mode = Mode_Add then
			self.tblGateLanes.text := "";
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_kiosk" type="CM_Kiosk"/>
        <Parameter name="_gateLane" type="CM_GateAreaLaneController"/>
    </JadeMethod>
    <JadeMethod name="doMove" id="ce9dfb80-94a0-47dd-9af9-54a874f1ddf1">
        <updating/>
        <source>doMove(_isFirst :Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//				Move the trouble gate area B4 or after the p-check gates
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gate				:CM_Gate;
	usage				:CM_GateAreaUsage;
	coll				:Array;
	oldIndex, newIndex	:Integer;
begin
	gate	:= self.myProxyObject.CM_Gate;
	usage	:= gate.getTroubleInUsage;
	coll	:= usage.myGate.allGateAreas_IN;
	
	oldIndex := coll.indexOf (usage);
	
	// remove from current position
	coll.removeAt (oldIndex);
	// add at new position
	if _isFirst then
		coll.insert (2, usage);	// after a-gate
	else
		// moving down
		coll.add (usage);// after all p-checks
	endif;
	
	self.loadGateAreas (gate);
	self.loadGateLanes;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_isFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNewGateArea" id="9b3a101a-959e-4bc8-87cf-f62481383d1c">
        <updating/>
        <source>doNewGateArea() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	:SOP_NewGateAreaForm;
begin
	form := app.loadForm (SOP_NewGateAreaForm, null, false, false, true, self.myTerminal, null).SOP_NewGateAreaForm;
	
	if form = null then
		return;	// should not happen :)
	endif;
	
	form.setGateProxy (self.myProxyObject.CM_Gate);
	
	form.showModal;
	
	if form.modalResult = IDOK then
		// redisplay gate areas - does lanes as well
		self.loadGateAreas (self.myProxyObject.CM_Gate);
		// if we have added gate areas we may need to allow for or display input of the id column in the area table
		self.setControlsForAddEdit;
		// if we have added areas we may need to enabled the trouble combo
		self.setTroubleInCombo (self.myProxyObject.CM_Gate);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrinter" id="5a889ff9-9899-4d6b-a2b8-5d5908a29357">
        <source>doPrinter(_mode : Integer; _printer : CM_PrinterDef; _gateLane : CM_GateAreaLaneController) protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form 	: SOP_LDPrinterForm;
	printer	: CM_PrinterDef;
	
begin
	if _mode = Mode_Update and _printer = null then
		return;
	endif;

	form := app.loadForm (SOP_LDPrinterForm, null, false, false, true, self.myTerminal, null).SOP_LDPrinterForm;
	if form = null then
		return;	// should not happen :)
	endif;
	
	form.mode 			:= _mode;
	form.updateObject 	:= _printer;
	form.myGateLane 	:= _gateLane.pxyGetRealObject;
	
	form.showModal;
	
	if form.modalResult = IDOK then
		// add to hierarchy
		printer := form.updateObject.CM_PrinterDef;
		self.myAssistant.comboBoxPrinterDefs(self.cmbPrinter, app.myCurrentUserCan (self.myTerminal, PmCmpPortTableMaint), printer.description);
		self.tblGateLanes.text := printer.description;
	else
		if _mode = Mode_Add then
			self.tblGateLanes.text := "";
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_printer" type="CM_PrinterDef"/>
        <Parameter name="_gateLane" type="CM_GateAreaLaneController"/>
    </JadeMethod>
    <JadeMethod name="doRFIDTagReader" id="abdb0a0c-6b9f-46c7-b00c-2e6db1b413ec">
        <source>doRFIDTagReader(_mode : Integer; _reader : CM_RFIDTagReader; _gateLane : CM_GateAreaLaneController) protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	 : SOP_LDRFIDReaderForm;
	reader	 : CM_RFIDTagReader;
	typeRead : Boolean;
	canAdd	 : Boolean;
begin
	if _mode = Mode_Update and _reader = null then
		return;
	endif;

	form := app.loadForm(SOP_LDRFIDReaderForm, null, false, false, true, self.myTerminal, null).SOP_LDRFIDReaderForm;
	if form = null then
		return;	// should not happen :)
	endif;
	
	typeRead := (self.tblGateLanes.column = tblGateLanes.getColumnByRowName (ETRow_Lane_rfid_tag_read));
	
	form.mode 			:= _mode;
	form.updateObject 	:= _reader;
	/*if typeRead then
		form.myGateLane := _gateLane.pxyGetRealObject;	// only associate the read tag reader (not the assign) to the gate lane
	endif;*/
	
	form.showModal;
	
	if form.modalResult = IDOK then
		// add to hierarchy
		reader	:= form.updateObject.CM_RFIDTagReader;
		canAdd	:= app.myCurrentUserCan (self.myTerminal, PmAdmRFIDTagReadMaint);
		
		if typeRead then
			self.myAssistant.comboBoxRFIDTagReaders (self.cmbRFIDReader, canAdd, reader.description);
		else
			self.myAssistant.comboBoxRFIDTagReaders (self.cmbRFIDReaderA, canAdd, reader.description);
		endif;
		self.tblGateLanes.text := reader.description;
	else
		if _mode = Mode_Add then
			self.tblGateLanes.text := "";
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
