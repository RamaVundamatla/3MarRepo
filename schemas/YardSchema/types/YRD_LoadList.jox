    <JadeMethod name="doMyCaption" id="d50fe84b-d0d3-4fe6-8bd4-b7923676e1bd">
        <updating/>
        <source>doMyCaption() updating;

vars
	aPort : CM_Port;
	anOperator : CM_Operator;
	aCargoType : CM_CargoType;
	anObject : Object;
begin
	self.caption := app.getErrorString(Rail_load_list) &amp; " - ";

	if self.cmbTrainNote.listObject &lt;&gt; null then
		self.caption := self.caption &amp; self.cmbTrainNote.listObject.CM_Train.code.trimBlanks &amp; ". ";
	endif;
	self.caption := self.caption &amp; app.getErrorString(CargoTypes) &amp; ": " &amp; self.lstCargoTypes.getSelectedString(CM_CargoType::abbreviation.name) &amp; ". ";
	self.caption := self.caption &amp; app.getErrorString(Operators) &amp; ": " &amp; self.lstOperators.getSelectedString(CM_Operator::code.name) &amp; ". ";
	self.caption := self.caption &amp; app.getErrorString(Destinations) &amp; ": " &amp; self.lstPorts.getSelectedString(CM_Port::code.name) &amp; ". ";
	self.caption := self.caption &amp; app.getErrorString(INV_On_Ship) &amp; ": " &amp; self.lstVoyages.getSelectedString(CM_Voyage::code.name) &amp; ". ";	//03 Nov 2009	NDL	Par 21519
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="3ba25849-7ba8-4818-8c2b-cbe2270d3255">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_Train) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			removedNotification := removedNotification + 1;
		elseif anObject.isKindOf(CM_TerminalArea) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED));
			removedNotification := removedNotification + 1;
		elseif anObject.isKindOf(CM_TrackedItem) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableNotification" id="d661e490-3e2a-4194-b961-f93fdf1da436">
        <updating/>
        <source>doNotableNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
08 Nov 2010	cnwdap1	PAR #23794 CCMS MES 1102 theObject here could be a WLE as well as a TI
					Cater for WLE_Update_Event
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
08 Dec 2011	NDL	Par 28797

*/

vars
	lController		: CM_LocationsController;
	event,theRow,
	numZeros, idx	: Integer;
	theCode			: String;
	theArea			: CM_BlockStack;
	anObject		: Object;
	theTI,
	theObjectTI		: CM_TrackedItem;
	breakOut		: Boolean;
	invalidTrain : Boolean;
	invalid 		: Boolean;
	id				: String;
	theWLE			: CM_WorkListEntry;		// PAR #23794 CCMS MES 1102
	bulkRelease		: CM_BulkRelease;		// PAR #23794 CCMS MES 1102
	train			: CM_Train;				// PAR #23794 CCMS MES 1102
	
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = TIEvent_Transit_Status_Update then
		if userInfo.isKindOf(CM_TrackedItem) then
			theTI := userInfo.CM_TrackedItem;
		endif;
		if theTI = null then
			invalid := true;
		else
			invalid := false;
			on Exception do app.handleDeletedObject(exception, theTI, invalid);
			id := theTI.id;		// Dereference to ensure TI is valid
		endif;
		
		if invalid and theTI &lt;&gt; null then
			self.tblData.removeItemObject(theTI);
			self.tblPlanned.removeItemObject(theTI);
			self.tblAll.removeItemObject(theTI);
		endif;
		
		self.doNotesStorageStartTimer(theTI);
		return;
		
	endif;
	
	if event = EDI_ColourCode_Update then
		self.updateSummaryFromEDI();
		// Force redraw
		self.doNotesStorageStartTimer(null);
		return;

	endif;
		
	if event = EVENT_TI_TRAIN_INTENDED then
		theTI := theObject.CM_TrackedItem;
		self.doNotesStorageStartTimer(theTI);
	elseif userInfo.isKindOf(CM_TrackedItem) then
		theTI := userInfo.CM_TrackedItem;
		self.doNotesStorageStartTimer(theTI);
	elseif theObject.isKindOf(CM_TrackedItem) then
		theTI := theObject.CM_TrackedItem;
		self.doNotesStorageStartTimer(theTI);
	endif;
	
	// PAR #23794 CCMS MES 1102 Allow for WLE updates
	if event = WLE_Update_Event then
		invalid := false;
		on Exception do app.handleDeletedObject(exception, theObject, invalid);		// 12/03/2013 cnwar2 #29273
		theWLE := theObject.CM_WorkListEntry;
			
		if not CM_DeliveryRequest.hasInstance(theWLE.myRequest) or not CM_RailJob.hasInstance(theWLE.job) or invalid then
			return;
		endif;
		self.doNotesStorageStartTimer(theWLE);
	endif;
	
	// PAR #23794 and Bulk Release updates
	if event = BulkRelease_Update_Event then
		bulkRelease := theObject.CM_BulkRelease;
		self.doNotesStorageStartTimer(bulkRelease);
	endif;
	
	// PAR #23794 and train job sheet transfer to rail are
	if event = Train_OutwardJobMove_Event then
		train := theObject.CM_Train;
		self.doNotesStorageStartTimer(train);
	endif;
	
epilog

	if not self.startedTimer then
		self.updateShtCaptions();
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doNotesStorageStartTimer" id="11621634-cab1-49e6-b5db-924cf98becb5">
        <updating/>
        <source>doNotesStorageStartTimer(theObject : CM_Object) protected, updating;
//doNotesStorageStartTimer(theTI : CM_TrackedItem) protected, updating;		// PAR #23794 what it was

// Created by cnwdvb1 on 13 March 2007
// Have decided to allow null in here to forced start of timer.
// Changed On	By			Reason
// ----------	--------	-----------------------------------------
// 08/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 accept WLEs as well as TIs in this method
//							Signature changed from 'theTI : CM_TrackedItem' to 'theObject : CM_Object'
//08 Dec 2011	NDL	Par 28797
constants
	MinimumTimerDelay	= 1000;
	
vars

	randomNumber : Integer;
	wle			 : CM_WorkListEntry;	// PAR #23794

begin

	if not self.startedTimer then
		randomNumber := 0;
		randomNumber := app.random(10)  * 100;
		
		randomNumber := MinimumTimerDelay + randomNumber;	//08 Dec 2011	NDL	Par 28797
		
		self.beginTimer(randomNumber, Timer_OneShot, 1);
		self.startedTimer := true;
	endif;
	
	//if theTI &lt;&gt; null then																	// PAR #23794
	//	self.allTIsSummaryUpdate.addNoDuplicates(theTI, false);// ### PAR 13388 15FEB2007	// PAR #23794
	
	if self.myTerminal.getConfig(ShowRelReqOnRailLoadList).Boolean then	//08 Dec 2011	NDL	Par 28797
	
		if CM_TrackedItem.hasInstance(theObject) then											// PAR #23794
			self.allTIsSummaryUpdate.addNoDuplicates(theObject.CM_TrackedItem, false);			// PAR #23794
			// add each yard wle for the TI to the WLE array so we udate the release request	// PAR #23794
			// details on the summary too 														// PAR #23794
			foreach wle in theObject.CM_TrackedItem.allWorklistEntries discreteLock do			// PAR #23794
				if CM_YardWLE.hasInstance(wle) then												// PAR #23794
					self.allWLEsSummaryUpdate.addNoDuplicates(wle, false);						// PAR #23794
				endif;																			// PAR #23794
			endforeach;																			// PAR #23794
		elseif CM_WorkListEntry.hasInstance(theObject) then										// PAR #23794
			self.allWLEsSummaryUpdate.addNoDuplicates(theObject.CM_WorkListEntry, false);		// PAR #23794
		elseif CM_BulkRelease.hasInstance(theObject) then										// PAR #23794
			self.allBulkReleasesSummaryUpdate.addNoDuplicates(theObject.CM_BulkRelease, false);	// PAR #23794
		endif;																					// PAR #23794
	
	else
		//08 Dec 2011	NDL	Par 28797
		if CM_TrackedItem.hasInstance(theObject) then											
			self.allTIsSummaryUpdate.addNoDuplicates(theObject.CM_TrackedItem, false);
		endif;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="theObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doPreferenceOKClick" id="81a72e25-2a2e-4312-ab13-d0b1f0b7fdfe">
        <updating/>
        <source>doPreferenceOKClick() updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	function		: Integer;
	allSummariesObj	: CMIF_LoadListSummaryObjectSet;
	
begin
	if self.optEnquire.value then
		function := self.Function_Enquiry;
	elseif self.optLoadList.value then
		function := self.Function_ShowInLoadList;
	elseif self.optLocateCargo.value then
		function := self.Function_LocateGridRows;
	elseif self.optAskMe.value then
		self.defaultDblClickFunction := null;
		self.chkRemember.value := false;
	endif;

	if self.chkRemember.value = true then
		self.defaultDblClickFunction := function;
	endif;

	self.frmPreferences.visible := false;

	if function = null 
	or self.myFunctionObject = null then
		return;
	endif;
	
	create allSummariesObj transient;
	allSummariesObj.add(self.myFunctionObject.CMIF_LoadListSummaryObject);
	
//	self.handleFunctionForObject(function, self.myFunctionObject.CMIF_LoadListSummaryObject, self.tblSummary.column);
	self.handleFunctionForObject(function, allSummariesObj, self.tblSummary.column);
epilog
	delete allSummariesObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="159153c0-3722-4957-b9ed-26ffd5e876d3">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	08 Dec 2011	NDL	Par 28797
// ---------------------------------------------------------------------------

vars
begin
	if self.fldMain.topSheet = self.shtNonplanned then
		self.myAssistant.showReportOptions(self.tblData, caption , self.caption, true);
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.myAssistant.showReportOptions(self.tblPlanned, caption , self.caption, true);
	elseif self.fldMain.topSheet = self.shtSummary then
		self.myAssistant.showReportOptions(self.tblSummary, caption , self.caption, true);
	elseif self.fldMain.topSheet = self.shtAll then
		self.myAssistant.showReportOptions(self.tblAll, caption , self.caption, true);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="d1d38759-ded8-43ff-8885-a2eac2dfb6bc">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 added WLE code
//	08 Dec 2011	NDL	Par 28797
// ---------------------------------------------------------------------------
vars
	aTI 					: CM_TrackedItem;
	theFilter				: CMQF_TrainLoadListTIs;
	loadState, newQuery 	: Boolean;
	invalidTrain : Boolean;
	allOnShipTrainReleaseTIs : CM_TIArray;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentTrain, invalidTrain); //10/10/08 cnwdz2 Par 17732
	
	//self.startedTimer := false;	//11 June 2013	NDL	Par 31692
	if self.startedTimer then
		self.endTimer(1);
		self.startedTimer := false;
	endif;
	
	
	self.allTIsSummaryUpdate.clear();
	self.allWLEsSummaryUpdate.clear();			// PAR #23794
	self.allBulkReleasesSummaryUpdate.clear();	// PAR #23794
	self.trainJobsRefresh := false;				// PAR #23794
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow(null, app.getErrorString(ReturnData), app.getErrorString(Cancel), null, app.getErrorString(SearchingForData), null);
	
	// Par 15247
	endLoad;
	self.newQuery := true;
	self.mousePointer := Window.MousePointer_HourGlass;
	self.tblData.rows := self.tblData.fixedRows;
	self.tblInfo.rows := 0;
	self.tblData.clearAllSelected();
	self.tblPlanned.clearAllSelected();
	// CCMS 1578 Adding a new folder to the LoadList
	self.tblAll.clearAllSelected();
	self.tblAll.allTableObjects.clear();
	// Table for colecting all the information form the other tables (tblData, tblPlanded, tblTranship, tblDLR)
	self.tblAll.rows := self.tblAll.fixedRows;
	self.tbAllInfo.rows := 0;
	
	self.quitSummaryMode();
	
	self.doFldMainClick();

	// ### SET FILTER INITIALISE
	self.doQueryInitFilter();
	theFilter := self.myQuery;
	self.doNotableClear();
	// setup note for this train
	self.doNotableAdd(self.myCurrentTrain);
	
	// 22206 04/2011 option to show unassigned cargo (Centreport want to only see the assigned cargo)
	theFilter.includeUnassignedCargo := self.chkUnassigned.value;
	app.myQAFilter.qryTerminalTIs(theFilter, app.myPassport);
	self.displayTable(self.tblData);
	//CCMS 1578 adding the tblData information to the tblAll 	
	foreach aTI in theFilter.allQryTrackedItems do
		self.tblAll.allTableObjects.addObject(aTI);
	endforeach;
		
	// ### SET FILTER PLANNED
	self.tblPlanned.rows := self.tblPlanned.fixedRows;
	self.tblPlannedInfo.rows := 0;
	theFilter.reset;	
	self.doQueryInitFilter();
	theFilter := self.myQuery;
	theFilter.isGroundPos := false;
	theFilter.isOverstowed := false;
	theFilter.plannedToTrain := true;
	theFilter.topPosition := null;
	theFilter.useTopPosition := false;
	app.myQAFilter.qryTerminalTIs(theFilter, app.myPassport);

	self.displayTable(self.tblPlanned);
	//CCMS 1578 adding the tblPlanned information to the tblAll 	
	foreach aTI in theFilter.allQryTrackedItems do
		self.tblAll.allTableObjects.addObject(aTI);
	endforeach;
		
	
	self.doSummaryQuery();
	
	self.updateShtCaptions();
	inheritMethod();
	 
	self.frmQuery.visible := ((self.tblData.rows = self.tblData.fixedRows) 
						and (self.tblPlanned.rows = self.tblPlanned.fixedRows)
						and (self.tblAll.rows = self.tblAll.fixedRows)
						and (self.tblSummary.rows = self.tblSummary.fixedRows));	// PAR #23794
	
epilog
	self.mousePointer := Window.MousePointer_Default;
	endLoad;
	self.progressFinish();
	delete allOnShipTrainReleaseTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="93513b3e-f4fc-460d-aaef-ed69efa19eac">
        <updating/>
        <source>doQueryAddItem(_table : CM_DataTable input; _theRow : Integer; _theTI : CM_TrackedItem;_numZeros : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theDataLine : String;
	idx : Integer;
begin
	theDataLine := _theTI.getAttributeStringForDefArray(_table.allTblDataEntRows);

	if _theRow = 0 then
		idx := _table.addItem(theDataLine.trimBlanks);
	else
		idx := _theRow;
//	WAS	_table.addItemAt(theDataLine.trimBlanks, idx);
// NOW

		if idx &gt; _table.rows then
			idx := _table.addItem(theDataLine.trimBlanks);
		else
			_table.addItemAt(theDataLine.trimBlanks, idx);
		endif;

	endif;
	_table.accessRow(idx).itemObject := _theTI;
	
	// setup note for this item
	self.doNotableAdd(_theTI.myTerminalArea);
	self.doNotableAdd(_theTI);	

	// general renumber is called later
	//_table.setCellValueByName(ETRow_RowNumber, idx, _theRow.String.padLeadingZeros(_numZeros));
	self.doQueryColourUp(_table, _theTI, idx);
	
	return idx;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_numZeros" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueryColourUp" id="586563eb-8ab9-4ec3-8a39-78d0d30ac63e">
        <source>doQueryColourUp(_table : CM_DataTable input;_theTI : CM_TrackedItem;_theRow : Integer);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePort : CM_Port;
	theColour, theColumn : Integer;
	theCommodity : CM_Commodity;
	theISOType : CM_ISOType;
	theCell : JadeTableCell;
	drwAtt : CM_DrawingAttribute;
	train : CM_Train;
	carrier: CM_Carrier;
begin
		// COLOUR UP THE ISO Type
		theColumn := _table.getColumnByRowName(ETRow_IsoTypeDesc);
		if theColumn &gt; 0 then
			if _theTI.isKindOf(CM_Container) then 
				theISOType := _theTI.CM_Container.getISOTypeObject();
				if theISOType &lt;&gt; null then
					theColour := theISOType.colour;
				endif;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Ready To Ship
		theColumn := _table.getColumnByRowName(ETRow_ReadyToShip);
		if theColumn &gt; 0 then
			if _theTI.readyToShip then
				theColour := Green;
			else
				theColour := Red;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Operator
		theColumn := _table.getColumnByRowName(ETRow_OperatorCode);
		if theColumn &gt; 0 then
			if _theTI.myOperator &lt;&gt; null then
				theColour := _theTI.myOperator.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Discharge Port
		theColumn := _table.getColumnByRowName(ETRow_DischargePort);
		if theColumn &gt; 0 then
			//thePort := app.myRoot.allPorts[_theTI.dischargePort];
			thePort := app.myRoot.allPorts[_theTI.dischargePort];
			if thePort &lt;&gt; null then
				theColour := thePort.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		
		// COLOUR UP THE Destination Port
		theColumn := _table.getColumnByRowName(ETRow_DestinationPort);
		if theColumn &gt; 0 then
			thePort := app.myRoot.allPorts[_theTI.destinationPort];
			if thePort &lt;&gt; null then
				theColour := thePort.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Commodity
		theColumn := _table.getColumnByRowName(ETRow_Commodity);
		if theColumn &gt; 0 then
			theCommodity := app.myRoot.allCommodities[_theTI.commodity];
			if theCommodity &lt;&gt; null then
				theColour := theCommodity.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Voyage
		theColumn := _table.getColumnByRowName(ETRow_VoyageCode);
		if theColumn &gt; 0 then
			if _theTI.myVoyage &lt;&gt; null then
				theColour := _theTI.myVoyage.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;

		// COLOUR UP THE ASSIGNED Train
		theColumn := _table.getColumnByRowName(ETRow_MyTrainAssigned);
		if theColumn &gt; 0 then
			if _theTI.myTrainAssigned &lt;&gt; null then
				theColour := _theTI.myTrainAssigned.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		
		//+ cnwmd1, Par 21428 - Actual Train
		theColumn := _table.getColumnByRowName(ETRow_Train);
		train := _theTI.getTrainActual();
		if theColumn &gt; 0 then
			if train &lt;&gt; null then
				theColour := train.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;

		// COLOUR UP THE Custom Export Delivery Number
		theColumn := _table.getColumnByRowName(ETRow_CustomExportEntryNumber);
		if theColumn &gt; 0 then
			if _theTI.customExportEntryNumber = null then
				theColour := Red;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;

		// COLOUR UP THE Custom Export Hold
		theColumn := _table.getColumnByRowName(ETRow_CustomExportStop);
		if theColumn &gt; 0 then
			theCell := _table.accessCell(_theRow, theColumn);
			if theCell.text &lt;&gt; null then
				drwAtt := app.myRoot.allDrawingAttributes[PicTICustomHold];
				if drwAtt &lt;&gt; null then
					theCell.foreColor := drwAtt.colour;
					theCell.text := drwAtt.fontCharacter.Character;	
					theCell.fontName := drwAtt.fontName;
				endif;								
			endif;			
		endif;	
		// COLOUR UP THE 'Plnning State'
		theColumn := _table.getColumnByRowName(ETRow_PlanningStateLoadList);
		if theColumn &gt; 0 then
	
				if _theTI.myPrimaryPlannedLocation &lt;&gt; null then 
					theColour := xmlColourPlanned;
				elseif _theTI.myPrimaryPlannedLocation = null then
					theColour := xmlColourNonPlanned;
				elseif _theTI.myPrimaryActualLocation.isWagon() then
					theColour := xmlColourOnTrain;
				else
					theColour := White;
				endif;	
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;

		// COLOUR UP THE carrier	TFS4209 MAP 8/6/17
		theColumn := _table.getColumnByRowName(ETRow_Carrier);
		if theColumn &gt; 0 then
			carrier := app.myRoot.allCarriers[_theTI.carrier];
			if carrier &lt;&gt; null then
				theColour := carrier.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow, theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		theColumn := _table.getColumnByRowName(ETRow_ReleaseCarrier);
		if theColumn &gt; 0 then
			carrier := app.myRoot.allCarriers[_theTI.releaseCarrier];
			if carrier &lt;&gt; null then
				theColour := carrier.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueryInitFilter" id="8cc7e1cc-f160-4d77-9009-450f207a92ef">
        <updating/>
        <source>doQueryInitFilter() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theFilter				: CMQF_TrainLoadListTIs;
begin

	// ### SET FILTER INITIALISE
	if self.myQuery = null then
		create theFilter transient;
		self.myQuery := theFilter;
	endif;
	theFilter := self.myQuery;
	theFilter.reset;	
	theFilter.allTerminals.add(self.myTerminal);
	if self.cmbTrainNote.listObject &lt;&gt; null then
		theFilter.allTrains.add(self.cmbTrainNote.itemObject[self.cmbTrainNote.listIndex].CM_Train);
	endif;
	self.lstCargoTypes.allSelectedObjects.copy(theFilter.allCargoTypes);
	self.lstOperators.allSelectedObjects.copy(theFilter.allOperators);
	self.lstPorts.allSelectedObjects.copy(theFilter.allPortsDischarge);
	
	//03 Nov 2009	NDL	Par 21519
	theFilter.CMQF_TrainLoadListTIs.allOnShipVoyages.clear();
	self.lstVoyages.allSelectedObjects.copy(theFilter.CMQF_TrainLoadListTIs.allOnShipVoyages);

	theFilter.isGroundPos := self.chkGroundPos.value;
	theFilter.isOverstowed := self.chkIsOverstowed.value;
	theFilter.topPosition := self.txtHeight.text.Integer;
	theFilter.useTopPosition := self.chkTopPos.value;
	theFilter.plannedToTrain := false;
	theFilter.includeUnassignedCargo := self.chkUnassigned.value;	// 28768 Dec 2011 cnwjre1 don't lose planned/non-planned items with no assigned train

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="bbe6ba9e-d576-4a9a-ac09-1735681c59c2">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	05 November 2003 By: cnwgd1
//--------------------------------------------------
//	08 Dec 2011	NDL	Par 28797
vars

begin
	inheritMethod();
	
	self.tblAll.rows := self.tblAll.fixedRows;
	
	if self.fldMain.topSheet = self.shtAll then
		self.displayAllTable();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="98f40749-858b-4f8c-91d5-a07f7e5e057f">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.lstOperators.setSelected(null);
	self.lstCargoTypes.setSelected(null);
	self.lstPorts.setSelected(null);
	self.lstVoyages.setSelected(null);	//03 Nov 2009	NDL	Par 21519
	self.chkGroundPos.value := false;
	self.chkIsOverstowed.value := false;
	self.txtHeight.text := null;
	self.chkTopPos.value := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="dbd178bc-9c42-4c9e-8bca-971062670ac6">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		26 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpH : Integer;
begin
	tmpH := self.clientHeight - self.frmStatLine.clientHeight - self.frmToolbar.clientHeight-10;
	self.fldMain.width := self.clientWidth;
	self.fldMain.height := tmpH;
	self.topMargin := 0;
	
	inheritMethod();

	self.fldMain.top := self.frmToolbar.clientHeight+2;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="ce1d4051-b987-43e1-b201-7446e59ae8d7">
        <source>doSelectAll();
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     THIS METHOD IS NOT REFERENCED ANYMORE! AER - 10/10/2008 Par 18060
//			
// Changed:		
// Date			Who			Reason
// 13 Mar 2014	cnwmc5		PAR 33599 - changed so that the select all works again on the searcher..
// ----------   ----------  --------------------------------------------------
vars
	sht					: CMUI_Sheet;
begin
	sht := self.fldQuery.topSheet.CMUI_Sheet;
	
	if sht = self.shtQuery2 then
		self.lstCargoTypes.setAllToTrue;
	elseif sht = self.shtQuery3 then
		self.lstOperators.setAllToTrue;
	elseif sht = self.shtQuery4 then
		self.lstPorts.setAllToTrue;
	elseif sht = self.shtQuery6 then
		self.lstVoyages.setAllToTrue;
	endif;
	
end;
//par 17821---in order to have consistency of selectall/unselectall
/*vars

begin

	self.tblData.selectAll();

end;*/

</source>
    </JadeMethod>
    <JadeMethod name="doSetFunctionPref" id="c52884ee-3d15-4847-a32b-25cda9d39eed">
        <updating/>
        <source>doSetFunctionPref(_summaryObject: CMIF_LoadListSummaryObject) updating;
//----------------------------------------------------------------
//	Created:	16 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _summaryObject = null then
		self.myFunctionObject := null;
		return;
	endif;	
	
	self.chkRemember.enabled := true;
	self.chkRemember.value := false;
	self.optAskMe.visible := false;
	self.myFunctionObject := _summaryObject;
	
	self.lblPreference.caption := app.getErrorString(What_want_WOT_U_WANT_WHAT_U);
	self.frmPreferences.visible := true;
	self.frmPreferences.centreWindow();
	self.frmPreferences.zOrder(1);
end;</source>
        <Parameter name="_summaryObject" type="CMIF_LoadListSummaryObject"/>
    </JadeMethod>
    <JadeMethod name="doSetSelectorCriteria" id="9906f2f8-9f30-4244-ab84-f113d5875c23">
        <source>doSetSelectorCriteria(_queryParams: CM_QueryCriteriaLineHolder input;_queryDef	: CM_QueryDefinition;_property : String; _operator : String; _value : Any);


// NOT USED, MOVED TO ASSISTANT DELETE in 761



// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	criteria: CM_SelectorCriteriaLine;
	queryProperty,clonedProp			: CM_QueryProperty;
	queryOperator,clonedOp			: CM_QueryOperator;
	queryValue				: Any;
begin
	create criteria transient;
	queryProperty := _queryDef.allQueryProperties[_property];
	queryOperator := queryProperty.allAllowedOperators[_operator];
	queryValue := queryProperty.translateToSearchValue(_value); 
	clonedProp := queryProperty.cloneSelf(true);
	clonedOp := queryOperator.cloneSelf(true);

	clonedOp.setSearchValue(queryValue);	
	criteria.set(clonedProp, clonedOp, false);
	criteria.setMyCriteriaLineHolder(_queryParams);

end;</source>
        <Parameter name="_queryParams" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <Parameter name="_queryDef" type="CM_QueryDefinition"/>
        <Parameter name="_property" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doShowPopupInfo" id="182ced76-8f83-433f-a33c-f25c712f515d">
        <updating/>
        <source>doShowPopupInfo(table: CM_DataTable input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		21 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theObject : Object;
	dataContainer : CM_DataContainer;
	theAttribs :	CMUI_GridAttributesArray;
	theAttrib : CMUI_GridAttributes;
	thePIC : CMIF_PopupInfoController;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	if self.mnuContextHide.caption = self.MNU_MACRO_HIDE then // this means that the macro info is hidden
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if useTableInfo then

		theObject := table.accessRow(table.row).itemObject;
		if theObject = null then
			self.tblInfo.rows := 0;
			return;
		endif;
		if theObject.isKindOf(CM_WorkListEntry) then
			theObject := theObject.CM_WorkListEntry.myTrackedItem;
		endif;
		if not app.isDragging 
		and table.longLeftClick then
			create thePIC transient;
			thePIC.setForCreate(theObject.CM_Object, 0, self.frmPopupInfo,self.tblPopupInfo,self.frmToolBarPopup,
								self.frmPopupInfoPic1,self.picExtraInfoTI1,self.btnPopupEnq);
			self.showPopupInfoFrame(thePIC);
		endif;
	endif;
epilog
	app.isDragging := false;
	delete dataContainer;
	delete theAttrib;
	delete thePIC;
	delete theAttribs;
	self.mousePointer := Window.MousePointer_Default;


end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
