        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="pxyCreateUpdateProxy" id="83458010-435b-4577-858c-c3e79d608f51">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2023	jlier1	Initial creation

*/

vars
	proxy			: SelfType;
	completedOK		: Boolean;
begin
	proxy :=  inheritMethod();
	proxy.myLocale := self.myLocale;
	
	completedOK := true;			
	return proxy;
epilog
	if not completedOK then			
		delete proxy;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d5109ccb-82c6-483a-b8b2-c1b36f28cce7">
        <updating/>
        <source>setForCreate(_pxyTranslation : CM_KioskTranslation) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2023	jlier1	Initial creation 58511

*/

vars

begin
	self.setForUpdate(_pxyTranslation);
epilog

end;</source>
        <Parameter name="_pxyTranslation" type="CM_KioskTranslation"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="05a93e34-1fdf-450f-bda2-31462cd420ab">
        <updating/>
        <source>setForUpdate(_pxyTranslation : CM_KioskTranslation) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2023	jlier1	Initial creation 58511

*/

vars

begin
	self.text:=_pxyTranslation.text;
	self.myLocale:=_pxyTranslation.myLocale;
	
epilog

end;</source>
        <Parameter name="_pxyTranslation" type="CM_KioskTranslation"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2307cef4-e40d-4ce5-947c-3f948cb551b1">
        <updating/>
        <source>setProxy(_localeId : String; _text : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2023	jlier1	Initial creation 58511

*/

vars

	locale : CM_Locale;
begin
	
	locale:=app.myRoot.allLocales[_localeId];
	
	if locale &lt;&gt; null then
		self.myLocale:=locale;
	endif;
	
	self.text:=_text;

epilog

end;</source>
        <Parameter name="_localeId" type="String"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
</Class>
