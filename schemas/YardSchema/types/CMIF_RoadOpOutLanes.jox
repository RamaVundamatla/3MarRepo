    <JadeMethod name="getTableObjects" id="0bcae8c3-a1e3-4ca3-ac12-9259348b223a">
        <source>getTableObjects(_obj : CM_Object;_objectArray : ObjectArray input);
/*
Date		Who		Reason
21 Aug 2006	cnwer1	Initial creation - PAR#xxxx
23 Oct 2010	cnwcs5	par 29653 - use includeObject method
*/
vars
	vehicle 		: CM_Vehicle;
	controller		: CMIF_RoadOpController;
	job 			: CM_Job;
	wle 			: CM_WorkListEntry;
	wleWasFiltered 	: Boolean;
	edition			: Integer;
	invalid			: Boolean;
	
begin
	if _obj = null then
		return;
	endif;
	
	_objectArray.clear;
	//epr par 35702 2/3/15 CCMS 2457
	if not _obj.isKindOf(CM_Vehicle) then
		return;
	endif;
	//its a vehicle or nothing
	vehicle		:= _obj.CM_Vehicle;
	controller	:= self.myRoadOpController;
	
	on Exception do app.handleDeletedObject (exception, job, invalid);		// 14/03/2013 cnwar2 #30431
	
	foreach job in vehicle.allRoadJobs discreteLock do
	
		// 12/03/2013 cnwar2 #29273
		invalid := false;
		edition := job.edition;
		if invalid then
			continue;
		endif;
		
		foreach wle in job.CM_RoadJob.workListEntries discreteLock do
			if wle.isReceipt then
				continue;
			endif;
			
			if not self.includeObject (wle, controller) then
				wleWasFiltered := true;
				continue;
			endif;
				
			_objectArray.add(wle);
		endforeach;			
	endforeach;
	
	if _objectArray.size = null and not wleWasFiltered then
		_objectArray.add(vehicle);
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objectArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="78d76a94-8bd7-4234-9451-17243ae273b4">
        <source>includeObject(_wle: CM_WorkListEntry; _controller: CMIF_RoadOpController): Boolean protected;

/*
Date			Who		Reason
25 September 2014	cnwar2	Initial creation

*/
vars
	job	:CM_RoadJob;
begin
	// 25/09/2014 cnwar2 #34333
	if _controller.hideCompletedJobs then
		job := _wle.job.CM_RoadJob;
		
		if job &lt;&gt; null and job.isJobComplete then
			return false;
		endif;
	endif;
	
	return inheritMethod(_wle, _controller);

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_controller" type="CMIF_RoadOpController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
