    <JadeMethod name="load" id="f4dbbf42-280d-47c3-88e2-cd88939310fe">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	mainForm		: Form;
begin
	inheritMethod();
	
	mainForm := app.mainForm;
	if mainForm &lt;&gt; null then
		self.left := (mainForm.width /2) - (self.width /2);
		self.top := 300;
	endif;
		
	

end;


</source>
    </JadeMethod>
    <JadeMethod name="populateIMEX" id="92222428-3e8c-4ee4-8b93-29940c5e5d3e">
        <updating/>
        <source>populateIMEX() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 April 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	imexDict			: CM_IMEXStatusByCodeDict;
	imexStatus			: CM_IMEXStatus;
	
begin
	self.cmbIMEX.clear;
	imexDict := app.myRoot.allImexStatuses;
	foreach imexStatus in imexDict do
		if imexStatus.code = TI_IMEX_STATUS_TRANSHIP or // skip Tranship and ROB
		   imexStatus.code = TI_IMEX_STATUS_REMAINONBOARD  then
				continue;
		endif;
		self.cmbIMEX.itemObject[cmbIMEX.addItem(imexStatus.description)] := imexStatus;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveCriteria" id="6f3d3f81-9c63-4e0e-8e01-3005c70e6900">
        <updating/>
        <source>saveCriteria() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	result : Integer;
begin
	self.applyFormChanges();
	while true do
	
		if self.isUpdate then
			app.myTrxUA.trxUpdateObjMatchCrit(self.myProxyObject.CM_IMEXTransitionCriteria, app.myPassport);
		else
			app.myTrxCA.trxCreateObjMatchCrit(self.myProxyObject.CM_IMEXTransitionCriteria, self.myNewTransition, app.myPassport );
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Rail_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

		endif;
		
		return false;
		
	endwhile;
	
	self.myNewTransition := null;
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
