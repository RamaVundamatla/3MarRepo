    <JadeMethod name="getVesselName" id="303853b4-09f2-42eb-8a8f-af5e00f3448d">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.vesselName;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="1a0acc53-3a20-4d16-bf72-55ddd9307a24">
        <source>getVoyageCode(): String;
/*

Date		Who		Reason
21 October 2015	cnwer1	Initial creation PAR 37090

*/

vars
	ediTI : CM_EDITrackedItem;
begin

	foreach ediTI in self.allEDITrackedItems  do
		return ediTI.getVoyageCode();
	endforeach;

	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageETA" id="a115d53c-5e13-4e02-83a0-5142da878228">
        <source>getVoyageETA(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
