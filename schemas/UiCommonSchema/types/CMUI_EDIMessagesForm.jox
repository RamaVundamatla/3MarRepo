    </JadeMethod>
    <JadeMethod name="doShowEDIFile" id="e34aedd2-17b2-4319-a0be-84868d246d57">
        <updating/>
        <source>doShowEDIFile() updating, protected;
/*
Date		Who		Reason
29 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
constants
	FileSizeLimit = 40000;
vars
	ediFile	:CM_EDIFile;
	theLines : HugeStringArray;
begin
	ediFile := self.cmbFile.listObject.CM_EDIFile;
	
	if ediFile = null then
		self.loadSmallMessage (null, null, null);
	else
		create theLines transient;
		ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
		if ediFile.getRawDataLength() &lt;= FileSizeLimit then
			self.loadSmallMessage (null, theLines, self.textToHightlight);
		else
			self.loadBigMessage (null, theLines, self.textToHightlight);
		endif;
	endif;
epilog
	delete theLines;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b8868953-e9ff-4f2f-8bf8-9a218d155cb6">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
28 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	coll			:CM_EDIFileArray;
	combo			:CMUI_ComboBox;
	ediFile			:CM_EDIFile;
	gotException	:Boolean;
	test, index		:Integer;
begin
	self.jdbTop.visible	:= true;
	self.jdbTop.height	:= 60;
	
	inheritMethod();
	
	// load EDI files combo
	coll 	:= self.allEDIFiles;
	combo	:= self.cmbFile;
	
	if not coll.isEmpty then
		on Exception do app.handleDeletedObject (exception, ediFile, gotException);
		
		combo.sorted := false;
		
		foreach ediFile in coll do 
			test := ediFile.edition;
			
			if gotException then
				// it has been deleted - ignore it
				gotException := false;
				continue;
			endif;
			
			index 					:= combo.addItem (ediFile.fileName &amp; ' (' &amp; ediFile.fileCreatedTs.asStringJMT &amp; ')');
			combo.itemObject[index]	:= ediFile;
		endforeach;
		
		// now select first entry
		if combo.listCount &gt; 0 then
			combo.listIndex := 1;
			
			self.doShowEDIFile;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="278c7d95-5bc1-45ae-808d-4aac53659df3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018730, locale);
	lblFile.translateCaption(Xlat_0018731, locale);
end;</source>
    </JadeMethod>
</GUIClass>
