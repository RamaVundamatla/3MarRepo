<Class name="WS_VehicleVisitDetail" id="505c1070-f221-43e9-9aab-4327b68d3b3a">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents Vehicle visit Stages detail</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="date" id="654b6829-a538-49f0-83d3-30f52033a479">
        <type name="String"/>
        <access>readonly</access>
        <text>Date of this Stage, Format [DD/MM/YYYY]</text>
    </PrimAttribute>
    <PrimAttribute name="detail" id="58571a6b-c21b-42d7-aca7-82f9aedf5349">
        <type name="String"/>
        <access>readonly</access>
        <text>Vehicle Visit Stage details . Ex.[Pre-Check (AGATE 1)]</text>
    </PrimAttribute>
    <PrimAttribute name="time" id="a1c358d8-b499-4308-9ea5-9329d3db7fe1">
        <type name="String"/>
        <access>readonly</access>
        <text>Time of this stage, Format HH:MI:SS</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="a59a7737-b6ef-49ff-8e46-1e3bd5ffed19">
        <updating/>
        <source>setProxyFromObject(_detail : CM_VehicleVisitRecordDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2015	cnwmc5	Initial creation

*/

vars

begin
	inheritMethod(_detail);
	
	self.detail := _detail.getRecordDetailDescription();
	
	self.date := _detail.timeStart.date.asStringForWebInterface;
	self.time := _detail.timeStart.time.asStringForWebInterface;

epilog

end;</source>
        <Parameter name="_detail" type="CM_VehicleVisitRecordDetail"/>
    </JadeMethod>
</Class>
