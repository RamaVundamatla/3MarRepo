<GUIClass name="CMUI_ListTableSelectForm" id="a17e74a1-7d50-47dc-804d-535d8313240e">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="captionForLblMessage" id="e339dfd8-87ce-47d6-a19f-133f03719b5e">
        <length>201</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="lblMessage" id="00f7d9bf-b1a8-406d-ad51-7a70fdb095fc">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lstSelect" id="fe1e2995-d6e3-4728-a32d-ba6d9f6281e4">
        <embedded/>
        <type name="CMUI_ListTable"/>
    </ImplicitInverseRef>
    <JadeMethod name="initForm" id="06ca6a0e-34e9-401f-b5c9-ba4fbaf2945c">
        <updating/>
        <source>initForm(	_message 			: String;
			_availObjects 		: Collection;
			_displayMethod 		: String;
			_defaultToSelected	: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwer1	Initial creation
16/03/2010	cnwmh5	PAR22996 - Store locally the message passed in rather than 
						setting lblMessage.caption as the translateFrom metho
						overwrites what is in it.
19/02/2024	jlika1	TFS 62137 CUX | Shortlanded cargo
*/

vars
	messageHeight : Real;
	obj 	: Object;
	str 	: String;
	iter : Iterator;
begin

	//self.lblMessage.caption:=_message;		// - 16/03/2010 cnmwh5 #22996
	self.captionForLblMessage := _message;		// + 16/03/2010 cnwmh5 #22996
	self.lblMessage.wordWrap:=true;
	messageHeight:=self.lblMessage.getTextHeightForWidth(_message,self.lblMessage.width.Integer);
	self.lblMessage.height:=messageHeight;
	self.lstSelect.top:=self.lblMessage.top + self.lblMessage.height + 5;
	
	iter:=_availObjects.createIterator;
	while iter.next(obj) do
		str:=obj.sendMsg(_displayMethod).String;
		self.lstSelect.addItemObject(str,obj);
		
		if _defaultToSelected then
			self.lstSelect.addSelectedObject(obj);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_availObjects" type="Collection"/>
        <Parameter name="_displayMethod" type="String"/>
        <Parameter name="_defaultToSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9027d79d-5f0b-4c32-bc07-5aded8361bb5">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwer1	Initial creation
16/03/2010	cnwmh5	PAR22996 - Set lblMessage.caption from previously
						stored captionForLblMessage.  This is to get 
						round the issue of translateFrom overwriting it						
*/

vars

begin
	inheritMethod();

	self.lblMessage.caption := self.captionForLblMessage;		// + 16/03/2010 cnwmh5 #22996
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="833b0034-ea54-40f5-a328-44c36f6c26b2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 February 2024 09:16:57.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017422, locale);
	lblMessage.translateCaption(Xlat_0013457, locale);
end;</source>
    </JadeMethod>
</GUIClass>
