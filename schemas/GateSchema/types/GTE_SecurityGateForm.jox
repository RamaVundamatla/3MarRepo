    <JadeMethod name="tblDataDblClick" id="0b298d58-d2db-420a-8cf0-adab78ca8a62">
        <updating/>
        <source>tblDataDblClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/05/2014	cnwdap1		Initial creation PAR #34117 Security Gate
//
vars
	sortColNo	: Integer;
	sortColName	: String;

begin
	sortColNo := self.tblData.column;
	
	if sortColNo &lt;= 0
	or sortColNo &gt; self.tblData.columns then
		return;
	endif;
	
	if self.tblData.allTblDataColPropertyNames.size &gt;= sortColNo then	
		// look in the data table collection
		sortColName := self.tblData.allTblDataColPropertyNames[sortColNo];
	endif;

	if sortColName = null then
		return;
	endif;
	
	self.tblData.resortTableByColumn(sortColNo);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblData_click" id="7c9bc84c-d6ff-46a1-9212-939d9516c1fb">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	vvr 		: CM_VehicleVisitRecord;
	invalidVvr 	: Boolean; // ### TFS 51994 01Oct2021 NAVPW1
begin
	on Exception do app.handleDeletedObject(exception, vvr, invalidVvr); // ### TFS 51994 01Oct2021 NAVPW1

	// enable / disable the Delete button as appropriate - can't cancel vehicle visit record if it's not updateable
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	vvr := table.accessRow(table.row).itemObject.CM_VehicleVisitRecord;
	vvr.edition; // ### TFS 51994 01Oct2021 NAVPW1
	
	if vvr.isUpdatable and not invalidVvr then // ### TFS 51994 06Oct2021 NAVPW1
		self.btnDelete.enabled := true;
	else
		self.btnDelete.enabled := false;
	endif;
	// can't exit a visit unless it's ready to leave or has been road exited
	// but it's also OK to road exit something that has no Gate In (this may have been a banacol or drop lot visit)
	if not invalidVvr and 
		(vvr.getReadyToLeaveTime &lt;&gt; null or vvr.getRoadExitTime &lt;&gt; null or 
		(vvr.getArrivalAtGateInTime = null and vvr.getArrivalAtYardIC = null))// ### TFS 51994 01Oct2021 NAVPW1
	then
		self.btnDeparture.enabled := true;
	else
		self.btnDeparture.enabled := false;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="cbf06f17-0628-41c1-8f21-1e44f1f6bf98">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(_table: CM_DataTable input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer):Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	x 			: Real;
	y			: Real;
	obj	 		: CM_Object;
	invalidObj	: Boolean;
	edition		: Integer;
	vvr			: CM_VehicleVisitRecord;

begin
	x 	:= _x;
	y 	:= _y;

	_conwin.windowToScreen(x, y);
	self.screenToWindow(x, y);   // convert x, y relative to form
	
	// find out what we have selected in the table
	obj := _table.allSelectedObjects.first.CM_Object;
	
	if obj &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, obj, invalidObj);
		edition := obj.edition;
		if invalidObj then
			obj := null;
		endif;
		on Exception do null;
	endif;
	self.mnuCancelVisit.enabled := false;
	self.mnuDeparture.enabled := false;
	vvr := obj.CM_VehicleVisitRecord;
	if vvr &lt;&gt; null then 
		self.enableMenuToolbarItems(vvr);
	endif;
	if app.isAllowedToInspect then
		self.mnuSeparator2.visible := true;
		self.mnuInspect.visible := true;
		if vvr &lt;&gt; null then
			self.mnuInspect.userObject := obj;
		else
			self.mnuInspect.userObject := obj;
		endif;
	else
		self.mnuSeparator2.visible := false;
		self.mnuInspect.visible := false;
		self.mnuInspect.userObject := null;
	endif;
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuCancelVisit.visible := false;
		self.mnuDeparture.visible := false;
		self.mnuNewVisit.visible := false;

	endif;
	
	self.popupMenu(self.mnuContext, x.Integer, y.Integer);
	return false;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
