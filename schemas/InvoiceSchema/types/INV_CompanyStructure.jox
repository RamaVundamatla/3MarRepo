    <JadeMethod name="displayPropData" id="c6277c21-a7cb-4e94-a773-964fc817d6b7">
        <updating/>
        <source>displayPropData() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theBank : CM_Bank;
begin
	if self.modePropertyNew = self.MODEPROPERTY_COMPANY 
	or self.modePropertyUpdate = self.MODEPROPERTY_COMPANY then
		self.tblProperties.hideRowByName(ETRow_Debtor,false);
		self.tblProperties.hideRowByName(ETRow_Address,false);
		self.tblProperties.hideRowByName(ETRow_RemAddress,false); // CCMS 1587
		self.tblProperties.hideRowByName(ETRow_BankDetails,false);
		self.tblProperties.hideRowByName(ETRow_Email,false);
		self.tblProperties.hideRowByName(ETRow_Fax,false);
		self.tblProperties.hideRowByName(ETRow_Phone,false);
		self.tblProperties.hideRowByName(ETRow_Parent,false);
		self.tblProperties.hideRowByName(ETRow_IsSuspended,false);
		self.tblProperties.hideRowByName(ETRow_CutOffTime,false);

		self.tblProperties.showRowByName(ETRow_TaxCode,false);
		self.tblProperties.showRowByName(ETRow_TaxNarration,false);
		self.tblProperties.showRowByName(ETRow_TaxPC,false);
		self.tblProperties.showRowByName(ETRow_RateLookup,false);
	else
		self.tblProperties.showRowByName(ETRow_Debtor,false);
		self.tblProperties.showRowByName(ETRow_Address,false);
		self.tblProperties.showRowByName(ETRow_RemAddress,false);// CCMS 1587
		self.tblProperties.showRowByName(ETRow_BankDetails,false);
		self.tblProperties.showRowByName(ETRow_Email,false);
		self.tblProperties.showRowByName(ETRow_Fax,false);
		self.tblProperties.showRowByName(ETRow_Phone,false);
		self.tblProperties.showRowByName(ETRow_Parent,false);
		self.tblProperties.showRowByName(ETRow_IsSuspended,false);
		self.tblProperties.showRowByName(ETRow_CutOffTime,false);

		self.tblProperties.hideRowByName(ETRow_TaxCode,false);
		self.tblProperties.hideRowByName(ETRow_TaxNarration,false);
		self.tblProperties.hideRowByName(ETRow_TaxPC,false);
		self.tblProperties.hideRowByName(ETRow_RateLookup,false);
	endif;

	if self.updateMode = self.UpdateMode_New then
		self.tblProperties.clearValues();
		self.tblProperties.setValueByName(ETRow_CutOffTime, null);	
		self.fldProperties.topSheet := self.shtPropOne;
	else
		inheritMethod();
		if self.modePropertyUpdate = self.MODEPROPERTY_BU then
			if self.myCurrentBU &lt;&gt; null then
				theBank := self.myCurrentBU;
				self.tblProperties.setValueByName(ETRow_Name,theBank.mailingName);
				self.tblProperties.setValueByName(ETRow_Code,theBank.code);
				self.tblProperties.setValueByName(ETRow_Address,theBank.getMailingAddressString());
				self.tblProperties.setValueByName(ETRow_RemAddress,theBank.getRemittanceAddressString());// CCMS 1587
				self.tblProperties.setValueByName(ETRow_BankDetails,theBank.getBankDetailsString());
				self.tblProperties.setValueByName(ETRow_Email,theBank.emailAddress);
				self.tblProperties.setValueByName(ETRow_Fax,theBank.faxNumber);
				self.tblProperties.setValueByName(ETRow_Phone,theBank.phoneNumber);
				self.tblProperties.setValueByName(ETRow_Parent,theBank.parentCompany.code);
				self.tblProperties.setValueByName(ETRow_IsSuspended,theBank.isSuspended);
				self.cmbDebtorInvProp.listObject := theBank.businessUnitDebtor;
				self.cmbDebtorInvProp.lostFocus(self.cmbDebtorInvProp);
				self.tblProperties.setValueByName(ETRow_CutOffTime, theBank.onsiteStorageChargeTime);	
			endif;	
		else		
			theBank := self.myCurrentCompany;
			self.tblProperties.setValueByName(ETRow_Name,theBank.mailingName);
			self.tblProperties.setValueByName(ETRow_Code,theBank.code);
			self.tblProperties.setValueByName(ETRow_TaxCode,theBank.taxNumber);
			self.tblProperties.setValueByName(ETRow_TaxNarration,theBank.taxNarration);
			self.tblProperties.setValueByName(ETRow_TaxPC,theBank.taxPercentageRate);
			self.tblProperties.setValueByName(ETRow_RateLookup,theBank.retrospectiveRates);
		endif;
		self.fldProperties.topSheet := self.shtPropOne;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPropSaveClick" id="afff659a-db64-4ff5-9acf-47928c7145d2">
        <updating/>
        <source>doBtnPropSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	aComp, pxyComp : CM_Bank;
	ls : Boolean;
	theReturn : Integer;
	theController : CMIF_BankDetails;
begin
	create theController transient;
	self.populateController(theController);
	
	// ### NEW STUFF
	if self.updateMode = self.UpdateMode_New then
		create pxyComp transient;
	else
		// ## UPDATE BU
		if self.modePropertyUpdate = self.MODEPROPERTY_BU then
			app.cmsBeginLoad(ls);
			pxyComp := app.createUpdateProxy(self.myCurrentBU).CM_Bank;
			app.cmsEndLoad(ls);
		// ## UPDATE COMP
		else
			app.cmsBeginLoad(ls);
			pxyComp := app.createUpdateProxy(self.myCurrentCompany).CM_Bank;
			app.cmsEndLoad(ls);
		
		endif;
	endif;
	theController.myProxyBank := pxyComp;
	pxyComp.setProxy(theController);

	while true do
		if self.updateMode = self.UpdateMode_New then
			app.myTrxCA.trxCreateBank(theController,aComp,app.myPassport);
		else
			app.myTrxUA.trxUpdateBank(theController,app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Company_Structure), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.frmProperties.visible := false;
	self.lstData.enabled := true;
	self.frmToolbar.enabled := true;

epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyComp;
	delete theController;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSuspendClick" id="db216bdd-820f-4a56-baa1-19d41af058fe">
        <updating/>
        <source>doBtnSuspendClick() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars

	pxyBank : CM_Bank;
	ls : Boolean;
	theReturn : Integer;
	theBank: CM_Bank;
begin
	if self.myCurrentBU = null then
		theBank := self.myCurrentCompany;
	else
		theBank := self.myCurrentBU;
	endif;

	app.cmsBeginLoad(ls);
	pxyBank := app.createUpdateProxy(theBank).CM_Bank;
	app.cmsEndLoad(ls);
	pxyBank.setProxySuspend(not pxyBank.isSuspended);
	while true do
		app.myTrxUA.trxUpdateBankSuspenders(pxyBank,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Bank_Suspend), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.frmProperties.visible := false;
	self.lstData.enabled := true;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyBank;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="f738381b-4984-4a7e-99ed-38709c68054e">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aComp : CM_Bank;
	theReturn : Integer;
	label : String;
	
begin
	if self.modePropertyUpdate = self.MODEPROPERTY_BU then
		aComp := self.myCurrentBU;
		label := app.getErrorString(INV_Business_Unit);
	else
		aComp := self.myCurrentCompany;
		label := app.getErrorString(INV_Company);
	endif;

	if aComp = null then
		app.msgBox(app.getErrorString(INV_Please_Select_A) &amp; label &amp; ".", app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete,  aComp.mailingName),app.getErrorString(Confirm_Delete),
					MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	while true do
	 	app.myTrxDA.trxDeleteBank(aComp, app.myPassport);
		 
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return ;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Company_Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return ;
		endif;
		break;
	endwhile;


end;</source>
    </JadeMethod>
    <JadeMethod name="doLstDataClick" id="38944519-f2e5-427a-bca3-3363a554430f">
        <updating/>
        <source>doLstDataClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 30/12/2022	navkc1	TFS CR 55300 TASK 55525 - Business Unit Maint changes  for auto id
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	aMess : String;
	theBank : CM_Bank;
begin
	inheritMethod(listbox);
	
	if listbox.listIndex &lt; 0 then
		return;
	endif;
	anObject := listbox.itemObject[listbox.listIndex];
	self.modePropertyNew := null;
	self.btnDelete.enabled := true;
	if anObject = null then
		self.myCurrentBU:= null;
		self.myCurrentCompany := null;
		self.modePropertyUpdate := null;
	elseif anObject.isKindOf(CM_Bank) then
		theBank := anObject.CM_Bank;
		self.btnDelete.enabled := not theBank.isInUse(aMess);
		self.mnuCSDelete.enabled := self.btnDelete.enabled;
		if theBank.isSuspended then
			self.btnSusp.myToolbarButton.changePicture(self.picReinstate);
			self.btnSusp.bubbleHelp := app.getErrorString(INV_Reinstate);
			self.mnuCSSuspend.caption := "&amp;" &amp; app.getErrorString(INV_Reinstate);
		else
			self.btnSusp.myToolbarButton.changePicture(self.picSuspend);
			self.btnSusp.bubbleHelp := app.getErrorString(INV_Suspend);
			self.mnuCSSuspend.caption := "&amp;" &amp; app.getErrorString(INV_Suspend);
		endif;
		
		if theBank.isBusinessUnit then
			self.modePropertyUpdate := self.MODEPROPERTY_BU;
			self.myCurrentBU:= theBank;
			self.myCurrentCompany := self.myCurrentBU.parentCompany;
		else
			self.myCurrentBU:= null;
			self.myCurrentCompany := theBank;
			self.modePropertyUpdate := self.MODEPROPERTY_COMPANY;
		endif;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.btnNew.enabled := false;
		self.btnNewCompany.enabled := false;
		self.btnUpdate.enabled := false;
		self.btnSusp.enabled := false;
		self.btnAutoId.enabled := false; // 30/12/2022	navkc1	TFS CR 55300 TASK 55525
		
		self.mnuCSBU.enabled := false;
		self.mnuCSDelete.enabled := false;
		self.mnuCSComp.enabled := false;
		self.mnuCSUpdate.enabled := false;
		self.mnuCSSuspend.enabled := false;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
