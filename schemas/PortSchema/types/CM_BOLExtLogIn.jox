/* ---------------------------------------------------------------------------
Created:	21 May 2010	by cnwvu1

Purpose:	#23894
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.actualPieceCountError := _pieceCountError;
	
	//15 Jan 2014	NDL	Par 33264
	if self.myBOL &lt;&gt; null and not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		self.updateObjectEdition(self.myBOL);
	endif;

end;</source>
        <Parameter name="_pieceCountError" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="bd60ab28-d042-4ffc-9301-712c2b045ebf">
        <updating/>
        <source>setForCreate(_pxyBOLExt: CM_BOLExtLogIn) updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_pxyBOLExt);
	
	// On create we are always unmatched
	self.myTerminalIfUnmatched	:= self.myBOL.myTerminal;	//_pxyBOLExt.myTerminalIfUnmatched;

	self.setTicketSequences(_pxyBOLExt);

	self.isFSC	:= _pxyBOLExt.isFSC;	//CCMS JML 1105, PAR 21535 Nov 2009
	self.setLoggingOrganisation(_pxyBOLExt.getLoggingOrganisation()); //08/03/2010 cnwdz2 par22177

	self.setActualPieceCountError( _pxyBOLExt.getActualPieceCountError() );	//#23894 21/10/2010
	
end;</source>
        <Parameter name="_pxyBOLExt" type="CM_BOLExtLogIn"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9ac357f4-a546-4d68-ad77-480e4f95839d">
        <updating/>
        <source>setForUpdate(_pxyBOLExt: CM_BOLExtLogIn) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	inheritMethod(_pxyBOLExt);

	self.myTerminalIfUnmatched	:= _pxyBOLExt.myTerminalIfUnmatched;

	self.setTicketSequences(_pxyBOLExt);

	//15 Jan 2014	NDL	Par 33264
	if self.isFSC &lt;&gt; _pxyBOLExt.isFSC and self.myBOL &lt;&gt; null and not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		foreach ti in self.myBOL.allTrackedItems do
			self.updateObjectEdition( ti );
		endforeach;
	endif;
	self.isFSC	:= _pxyBOLExt.isFSC;	//CCMS JML 1105, PAR 21535 Nov 2009
	self.setLoggingOrganisation(_pxyBOLExt.getLoggingOrganisation()); //08/03/2010 cnwdz2 par22177
	
	self.setActualPieceCountError( _pxyBOLExt.getActualPieceCountError() );	//#23894 21/10/2010
	
end;</source>
        <Parameter name="_pxyBOLExt" type="CM_BOLExtLogIn"/>
    </JadeMethod>
    <JadeMethod name="setLoggingOrganisation" id="099a9428-dcfa-4f43-882f-4c51486516ea">
