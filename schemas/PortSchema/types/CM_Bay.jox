    <JadeMethod name="setProxy40Attributes" id="1cda9bff-90dc-4f95-83d3-1ce66a0dd803">
        <updating/>
        <source>setProxy40Attributes(_fortyFootBay, _fortyFootOnly, _fortyFiveBay, _fortyFiveOnly : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 March 2021		navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.fortyFootBay		:= _fortyFootBay;
	self.fortyFootOnly		:= _fortyFootOnly;
	self.fortyFiveFootBay	:= _fortyFiveBay;
	self.fortyFiveFootOnly	:= _fortyFiveOnly;
	
epilog

end;</source>
        <Parameter name="_fortyFootBay" type="Boolean"/>
        <Parameter name="_fortyFootOnly" type="Boolean"/>
        <Parameter name="_fortyFiveBay" type="Boolean"/>
        <Parameter name="_fortyFiveOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyBayFromXML" id="55512b33-b601-478d-b361-2e7f246b2809">
        <updating/>
        <source>setProxyBayFromXML(_theXML : String; _theVessel : CM_CellularVesselStructure input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXML : String;
begin

	self.raiseExceptionIfNotTransient(method);

	if _theXML = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "XML", "The XML is Empty", null, null);
	endif;
	if self.allCellsOnDeckByOrdinal.isEmpty = false then
		app.raiseCMException2(ERR_INVALID_VALUE, "Cells", "Bay " &amp; self.ordinalBay.String &amp; " Already has Cells. XML Import must have an 'empty' Bay", null, null);
	endif;

	// SET ME
	self.ordinalBay := _theXML.cnEcGetTagValueOfName("bo").Integer;
	self.id := _theXML.cnEcGetTagValueOfName("id");
	self.idBay40 := _theXML.cnEcGetTagValueOfName("id4");
	self.fortyFootBay := _theXML.cnEcGetTagValueOfName("fb").Integer.Boolean;
	self.fortyFootOnly := _theXML.cnEcGetTagValueOfName("fo").Integer.Boolean;
	self.fortyFiveFootBay := _theXML.cnEcGetTagValueOfName("f5b").Integer.Boolean;
	self.fortyFiveFootOnly := _theXML.cnEcGetTagValueOfName("f5o").Integer.Boolean;
	self.athwartships := _theXML.cnEcGetTagValueOfName("as").Integer.Boolean;
	self.lashFromTier := _theXML.cnEcGetTagValueOfName("lf");
	self.isTwinLiftOD := _theXML.cnEcGetTagValueOfName("tlod").Integer.Boolean;
	self.isTwinLiftUD := _theXML.cnEcGetTagValueOfName("tlud").Integer.Boolean;
	self.unlashFromTier := _theXML.cnEcGetTagValueOfName("uf");
	self.maxPileWeight20IB := _theXML.cnEcGetTagValueOfName("2mi").Integer;
	self.maxPileWeight20OB := _theXML.cnEcGetTagValueOfName("2mo").Integer;
	self.maxPileWeight40IB := _theXML.cnEcGetTagValueOfName("4mi").Integer;
	self.maxPileWeight40OB := _theXML.cnEcGetTagValueOfName("4mo").Integer;
	self.maxPileWeightUD := _theXML.cnEcGetTagValueOfName("mu").Integer;
	self.numOfPlugs := _theXML.cnEcGetTagValueOfName("np").Integer;
	self.bayType := _theXML.cnEcGetTagValueOfName("bt").Integer;
	self.remarks := _theXML.cnEcGetTagValueOfName("br");

// removed - not needed JC
//	theXML := _theXML.cnEcGetTagValueOfName("hi");
//	theXML := theXML.replaceString(" ", "|");
//	theHiCubes := theXML.getTokens();
	
	self.myHold := _theVessel.allHolds[_theXML.cnEcGetTagValueOfName("bh").Integer];
	
	// CREATE THE CELLS AND TIERS
	theXML := _theXML.cnEcGetTagValueOfName("OCELLS");
	self.doCreateProxyCellsFromXML(theXML, true);
	theXML := _theXML.cnEcGetTagValueOfName("UCELLS");
	self.doCreateProxyCellsFromXML(theXML, false);
	theXML := _theXML.cnEcGetTagValueOfName("OTIERS");
	self.doCreateProxyTiersFromXML(theXML, true);
	theXML := _theXML.cnEcGetTagValueOfName("UTIERS");
	self.doCreateProxyTiersFromXML(theXML, false);
	theXML := _theXML.cnEcGetTagValueOfName("OSLOTS");
	self.doCreateProxySlotsFromXML(theXML, true);
	theXML := _theXML.cnEcGetTagValueOfName("USLOTS");
	self.doCreateProxySlotsFromXML(theXML, false);


end;</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_theVessel" type="CM_CellularVesselStructure" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyBaySlots40" id="45bea450-cfd8-494f-b524-2373a64a69ab">
        <source>setProxyBaySlots40();
//----------------------------------------------------------------
//	Created:	29 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	slotDefn	: CM_SlotDefn;
begin
	if not self.canHandle4045() 
	or (not self.isForwardBay) then
		//don't call for non-40 bay fronts
		return;
	endif;

	foreach slotDefn in self.allSlotsByOrdinal do

		if (not slotDefn.unavailable) then
			if (slotDefn.myAftSlot &lt;&gt; null)
			and  (not slotDefn.myAftSlot.unavailable) then
				slotDefn.setAsFortyFoot(true);
				continue;
			endif;
			slotDefn.setAsFortyFoot(false);
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyCellsODFromLabels" id="451f130a-5d9e-4a61-9c32-4966b584ec4c">
        <source>setProxyCellsODFromLabels(_theLabels : String;_validate : Boolean) : Boolean;
/*

Date		Who		Reason
24 November 2014	cnwer1	Initial creation PAR 34518 - refactored moved from vessel &amp; voygage bay definitions

*/

vars

	realCell,
	aProxyCellDefn : CM_CellDefn;
	oldLabels,
	aLabel: String;
	theLabels : StringArray;
	theAlignment : Real;
	idx : Integer;
	cellsToDelete : CM_CellDefnByIdDict;
	realBay : CM_Bay;
begin

	aLabel := _theLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;
	
	oldLabels:=self.getAllCellsOnDeck();
	if _validate and not self.doValidateCellTierLabels(_theLabels, "On Deck Cell", oldLabels) then
		return false;
	endif;
	
	
	create cellsToDelete transient;
	self.allCellsOnDeck.copy(cellsToDelete);
	realBay := self.pxyGetRealObject(); // PAR 19872

	if theLabels.isEmpty then
		return true;
	endif;
	idx := 0;
	aProxyCellDefn:=  self.allCellsOnDeck[theLabels.first.trimBlanks];
	if aProxyCellDefn &lt;&gt; null then
		theAlignment:=aProxyCellDefn.alignment;
	else
		theAlignment:=1;
	endif;

	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		idx := idx + 1;
		aProxyCellDefn := self.allCellsOnDeck[aLabel.trimBlanks];
		
		if aProxyCellDefn = null then
			if realBay &lt;&gt; null then
				realCell:= realBay.allCellsOnDeck[aLabel.trimBlanks];
				if realCell &lt;&gt; null then
					beginLoad;
					aProxyCellDefn:=realCell.pxyCreateUpdateProxy;
					endLoad;
					aProxyCellDefn.setMyBay(self,true);
				endif;
			endif;	
			if aProxyCellDefn = null then
				create aProxyCellDefn transient;
			endif;
		endif;
		
		cellsToDelete.removeIfPresent(aProxyCellDefn);
		aProxyCellDefn.setProxy(aLabel.trimBlanks,theAlignment,idx,self,null,null);
		
		theAlignment:=theAlignment+1;
	endforeach;

	return true;
epilog
	delete theLabels;
	if cellsToDelete &lt;&gt; null then
		// we have a delete!!!!
		cellsToDelete.purge;
	endif;
	delete cellsToDelete;
end;</source>
        <Parameter name="_theLabels" type="String"/>
        <Parameter name="_validate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyCellsUDFromLabels" id="52483af2-4473-4d30-87da-c7c097190eb8">
        <source>setProxyCellsUDFromLabels(_cellLabels : String; _hiCubeLabels : String;_validate : Boolean) : Boolean;
/*

Date		Who		Reason
24 November 2014	cnwer1	Initial creation PAR 34518 - refactored moved from vessel &amp; voygage bay definitions
 
*/

vars
	realCell,
	aProxyCellDefn 			: CM_CellDefn;
	oldLabels,
	aLabel					: String;
	cellsToDelete			: CM_CellDefnByIdDict;
	theLabels,	theHiCubes	: StringArray; // Par 13608 AER 11/08/08
	idx, theCount,
	theHiCubeHeight  				: Integer;
	theAlignment 			: Real;
	realBay : CM_Bay;
begin
	aLabel := _hiCubeLabels;
	aLabel.replaceString(" ","|");
	theHiCubes := aLabel.getTokens;
	
	aLabel := _cellLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens();
	
	
	oldLabels:=self.getAllCellsUnderDeck();
	if _validate then
		if not self.doValidateCellTierLabels(_cellLabels,"Under Deck Cell", oldLabels) then
			return false;
		endif;
		
		if not self.doValidateTotalHiCubesUDCells(_hiCubeLabels, "Total HiCubes Cells") then
			return false;
		endif;
	endif;
	
	create cellsToDelete transient;
	self.allCellsUnderDeck.copy(cellsToDelete);
	realBay := self.pxyGetRealObject(); // PAR 19872
	idx := 0;
	
	aProxyCellDefn:=  self.allCellsUnderDeck[theLabels.first.trimBlanks];
	if aProxyCellDefn &lt;&gt; null then
		theAlignment:=aProxyCellDefn.alignment;
	else
		theAlignment:=1;
	endif;
	
	
	foreach aLabel in theLabels  do
		theCount := theCount + 1;
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		idx := idx + 1;
		if theCount &lt;= theHiCubes.size then
			if theHiCubes[theCount].isInteger() then 	// Par 13608 AER 11/08/08
				theHiCubeHeight := theHiCubes[theCount].Integer;
			endif;
		else
			// carry on using the last number
			theHiCubeHeight := theHiCubeHeight;
		endif;
		
		aProxyCellDefn := self.allCellsUnderDeck[aLabel.trimBlanks];
		if aProxyCellDefn = null then
			if realBay &lt;&gt; null then
				realCell:= realBay.allCellsUnderDeck[aLabel.trimBlanks];
				if realCell &lt;&gt; null then
					beginLoad;
					aProxyCellDefn:=realCell.pxyCreateUpdateProxy;
					endLoad;
					aProxyCellDefn.setMyBay(self,false);
				endif;
			endif;	
			if aProxyCellDefn = null then
				create aProxyCellDefn transient;
			endif;
		endif;
		
		cellsToDelete.removeIfPresent(aProxyCellDefn);
		aProxyCellDefn.setProxy(aLabel.trimBlanks,theAlignment,idx,null,self,theHiCubeHeight);
		theAlignment:=theAlignment + 1;
	endforeach;
	
	return true;
epilog
	
	delete theLabels;
	delete theHiCubes;	
	
	if cellsToDelete &lt;&gt; null then
		// we have a delete!!!!
		cellsToDelete.purge;
	endif;
	delete cellsToDelete;

end;</source>
        <Parameter name="_cellLabels" type="String"/>
        <Parameter name="_hiCubeLabels" type="String"/>
        <Parameter name="_validate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyTiersODFromLabels" id="a5df757b-275b-4cbc-978c-704c78268e98">
        <source>setProxyTiersODFromLabels(_theLabels : String; _validate : Boolean) : Boolean;
/*

Date		Who		Reason
24 November 2014	cnwer1	Initial creation PAR 34518 - refactored moved from vessel &amp; voygage bay definitions

*/

vars

realTier,
	aProxyTierDefn : CM_TierDefn;
	tiersToDelete : CM_TierDefnByIdDict;
	typeMessage,
	aLabel,tierLabels : String;
	theLabels : StringArray;
	idx : Integer;
	realBay : CM_Bay;
begin
	aLabel := _theLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;

	if _validate and not self.doValidateCellTierLabels(_theLabels, "On Deck Tier", self.getAllTiersOnDeck) then
		return false;
	endif;
	
	create tiersToDelete transient;
	self.allTiersOnDeck.copy(tiersToDelete);
	realBay := self.pxyGetRealObject(); // PAR 19872
	
	idx := 0;
	//create someTiers transient;
	foreach aLabel in theLabels  do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		idx := idx + 1;
		aProxyTierDefn := self.allTiersOnDeckByLabel[aLabel.trimBlanks];
		if aProxyTierDefn = null then
			if realBay &lt;&gt; null then
				realTier:= realBay.allTiersOnDeckByLabel[aLabel.trimBlanks];
				if realTier &lt;&gt; null then
					beginLoad;
					aProxyTierDefn:=realTier.pxyCreateUpdateProxy;
					endLoad;
					aProxyTierDefn.setMyBay(self,true);
				endif;
			endif;		
			// only create new cells if we have added a label to the list
			if aProxyTierDefn = null then	
				create aProxyTierDefn transient;
			endif;

		endif;
		
		tiersToDelete.removeIfPresent(aProxyTierDefn);	
		aProxyTierDefn.setProxy(aLabel.trimBlanks,idx,idx,self,null);
		
	endforeach;
	
	return true;
epilog
	delete theLabels;
	if tiersToDelete &lt;&gt; null then
		// we have a delete!!!!
		tiersToDelete.purge;
	endif;
	delete tiersToDelete;

end;</source>
        <Parameter name="_theLabels" type="String"/>
        <Parameter name="_validate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyTiersUDFromLabels" id="c05e28bd-d7e9-41ac-bc99-ebaef92ca2ea">
        <source>setProxyTiersUDFromLabels(	_theLabels : String;
							_validate : Boolean) : Boolean;
/*

Date		Who		Reason
24 November 2014	cnwer1	Initial creation PAR 34518 - refactored moved from vessel &amp; voygage bay definitions

*/

vars
	realTier,
	aProxyTierDefn : CM_TierDefn;
	aLabel : String;
	theLabels : StringArray;
	tiersToDelete : CM_TierDefnByIdDict;
	idx : Integer;
	realBay : CM_Bay;
begin
	aLabel := _theLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;

	
	if _validate and not self.doValidateCellTierLabels(_theLabels, "Under Deck Tier", self.getAllTiersUnderDeck()) then
		return false;
	endif;
	
	create tiersToDelete transient;
	self.allTiersUnderDeck.copy(tiersToDelete);
	realBay := self.pxyGetRealObject(); // PAR 19872
	
	idx := 0;
	foreach aLabel in theLabels   do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		idx := idx + 1;
		aProxyTierDefn := self.allTiersUnderDeckByLabel[aLabel.trimBlanks];
		if aProxyTierDefn = null then
			if realBay &lt;&gt; null then
				realTier:= realBay.allTiersUnderDeckByLabel[aLabel.trimBlanks];
				if realTier &lt;&gt; null then
					beginLoad;
					aProxyTierDefn:=realTier.pxyCreateUpdateProxy;
					endLoad;
					aProxyTierDefn.setMyBay(self,false);
				endif;
			endif;		
			// only create new cells if we have added a label to the list
			if aProxyTierDefn = null then	
				create aProxyTierDefn transient;
			endif;
	
		endif;
		
		tiersToDelete.removeIfPresent(aProxyTierDefn);
		aProxyTierDefn.setProxy(aLabel.trimBlanks,0,idx,null,self);
	endforeach;
	
	return true;
epilog
	delete theLabels;
	
	if tiersToDelete &lt;&gt; null then
		// we have a delete!!!!
		tiersToDelete.purge;
	endif;
	delete tiersToDelete;
end;</source>
        <Parameter name="_theLabels" type="String"/>
        <Parameter name="_validate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="e874beb4-549d-478e-9284-7732b34bfbfa">
        <updating/>
        <source>setRemarks(_remarks: String;_additional: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		18 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if _additional then
		self.remarks := _remarks &amp; ' ' &amp; self.remarks.trimBlanks;
	else
		self.remarks := _remarks.trimBlanks;
	endif;
	
end;</source>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_additional" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSequenceNums" id="f54433f0-4491-4d9c-915f-1ce35a0bde19">
        <updating/>
        <source>setSequenceNums() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sequenceUDSeaToWharf : Boolean;
begin
	exclusiveLock(self);

	sequenceUDSeaToWharf := app.getMyTerminalConfigDO_NOT_USE(SequenceUnderDeckSeaToWharf).Boolean;

	
//	self.generateSequenceNums(true, Start_Top_Left, "sequenceNumPortDis", false);
//	self.generateSequenceNums(false, Start_Top_Left, "sequenceNumPortDis", false);
	self.generateSequenceNums(true, Start_Top_Left,CM_SlotDefn::sequenceNumPortDis.name, false);
	self.generateSequenceNums(false, Start_Top_Left, CM_SlotDefn::sequenceNumPortDis.name, false);
	
	// Generate 40 stuff.
//	self.generateSequenceNums(true, Start_Top_Left, "sequenceNumPortDis40", true);
//	self.generateSequenceNums(false, Start_Top_Left, "sequenceNumPortDis40", true);
	self.generateSequenceNums(true, Start_Top_Left, CM_SlotDefn::sequenceNumPortDis40.name, true);
	self.generateSequenceNums(false, Start_Top_Left, CM_SlotDefn::sequenceNumPortDis40.name, true);
	

//	self.generateSequenceNums(true, Start_Top_Right, "sequenceNumStarDis", false);
//	self.generateSequenceNums(false, Start_Top_Right, "sequenceNumStarDis",false);
	self.generateSequenceNums(true, Start_Top_Right, CM_SlotDefn::sequenceNumStarDis.name, false);
	self.generateSequenceNums(false, Start_Top_Right, CM_SlotDefn::sequenceNumStarDis.name,false);
	
	// Generate 40 stuff.
//	self.generateSequenceNums(true, Start_Top_Right, "sequenceNumStarDis40", true);
//	self.generateSequenceNums(false, Start_Top_Right, "sequenceNumStarDis40", true);
	self.generateSequenceNums(true, Start_Top_Right, CM_SlotDefn::sequenceNumStarDis40.name, true);
	self.generateSequenceNums(false, Start_Top_Right, CM_SlotDefn::sequenceNumStarDis40.name, true);
	
	
//	self.generateSequenceNums(true, Start_Bottom_Right, "sequenceNumPortLoad", false);
//	self.generateSequenceNums(true, Start_Bottom_Left, "sequenceNumStarLoad", false);
	self.generateSequenceNums(true, Start_Bottom_Right, CM_SlotDefn::sequenceNumPortLoad.name, false);
	self.generateSequenceNums(true, Start_Bottom_Left, CM_SlotDefn::sequenceNumStarLoad.name, false);
	
	// Generate 40 stuff.
//	self.generateSequenceNums(true, Start_Bottom_Right, "sequenceNumPortLoad40", true);
//	self.generateSequenceNums(true, Start_Bottom_Left, "sequenceNumStarLoad40", true);
	self.generateSequenceNums(true, Start_Bottom_Right, CM_SlotDefn::sequenceNumPortLoad40.name, true);
	self.generateSequenceNums(true, Start_Bottom_Left, CM_SlotDefn::sequenceNumStarLoad40.name, true);

	if sequenceUDSeaToWharf then
//		self.generateSequenceNums(false, Start_Bottom_Left, "sequenceNumPortLoad", false);
//		self.generateSequenceNums(false, Start_Bottom_Right, "sequenceNumStarLoad",false);
		self.generateSequenceNums(false, Start_Bottom_Left, CM_SlotDefn::sequenceNumPortLoad.name, false);
		self.generateSequenceNums(false, Start_Bottom_Right, CM_SlotDefn::sequenceNumStarLoad.name,false);
		
		// Generate 40 stuff.
//		self.generateSequenceNums(false, Start_Bottom_Left, "sequenceNumPortLoad40", true);
//		self.generateSequenceNums(false, Start_Bottom_Right, "sequenceNumStarLoad40", true);
		self.generateSequenceNums(false, Start_Bottom_Left, CM_SlotDefn::sequenceNumPortLoad40.name, true);
		self.generateSequenceNums(false, Start_Bottom_Right, CM_SlotDefn::sequenceNumStarLoad40.name, true);
	else
//		self.generateSequenceNums(false, Start_Bottom_Right, "sequenceNumPortLoad", false);
//		self.generateSequenceNums(false, Start_Bottom_Left, "sequenceNumStarLoad",false);
		self.generateSequenceNums(false, Start_Bottom_Right, CM_SlotDefn::sequenceNumPortLoad.name, false);
		self.generateSequenceNums(false, Start_Bottom_Left, CM_SlotDefn::sequenceNumStarLoad.name,false);
		
		// Generate 40 stuff.
//		self.generateSequenceNums(false, Start_Bottom_Right, "sequenceNumPortLoad40", true);
//		self.generateSequenceNums(false, Start_Bottom_Left, "sequenceNumStarLoad40", true);
		self.generateSequenceNums(false, Start_Bottom_Right, CM_SlotDefn::sequenceNumPortLoad40.name, true);
		self.generateSequenceNums(false, Start_Bottom_Left, CM_SlotDefn::sequenceNumStarLoad40.name, true);

	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="b6ffc253-6a9c-4373-b141-e48e8d261559">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if _property.name = CM_Bay::myForwardBay.name 
	or _property.name = CM_Bay::myAftBay.name
	or _property.name = CM_Bay::myHold.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSlotLinks" id="bbed4ecf-e095-4426-957f-a5d57875327c">
        <updating/>
        <source>updateSlotLinks() updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2002 by cnwdwq1 
//
// Purpose:     rebuild the links between all the slots
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBayDefn: CM_BayDefn;
	nextBayDefn: CM_BayDefn;
	slotDefnVesse:CM_SlotDefnVessel;
	slotDefn,aftSlotDefn: CM_SlotDefn;
	nextSlotDefn,portSlotDefn,underfootSlotDefn: CM_SlotDefn;
begin
	exclusiveLock(self);
	foreach slotDefn in self.allSlotsByOrdinal do
		exclusiveLock(slotDefn);
		slotDefn.setAdjacentSlots(null, null, null);
	endforeach;
	foreach slotDefn in self.allSlotsByOrdinal do
		portSlotDefn := self.allSlotsByOrdinal[slotDefn.ordinalDeck, slotDefn.ordinalCell+1, slotDefn.ordinalTier];
		underfootSlotDefn := self.allSlotsByOrdinal[slotDefn.ordinalDeck, slotDefn.ordinalCell, slotDefn.ordinalTier+1 ];
		if self.myAftBay &lt;&gt; null then
			if slotDefn.ordinalDeck = DeckUnderDeck then 
				aftSlotDefn := self.myAftBay.allSlotsUnderDeck[slotDefn.cellId, slotDefn.tierId];
			else
				aftSlotDefn := self.myAftBay.allSlotsOnDeck[slotDefn.cellId, slotDefn.tierId];
			endif;
			slotDefn.setAdjacentSlots(portSlotDefn, underfootSlotDefn, aftSlotDefn);
		else // PAR 37111
			slotDefn.setAdjacentSlots(portSlotDefn, underfootSlotDefn, null); // PAR 37111 slots in the aft bay of every hold did not have the port and under foot link set within their own bay. 
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="useCellTierNumbering" id="6d0fd4ac-6ee3-4c32-b69c-e5395d9aa9c7">
        <source>useCellTierNumbering() : Boolean abstract;</source>
        <abstract/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCellIDs" id="b02b5f1e-b38d-4166-806f-62197a051050">
        <source>validateCellIDs();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theCellIds : StringArray;
	aCell : CM_CellDefn;
	errorCellID : String;

begin
	
	create theCellIds transient;
	
	// CHECK that the Cell ids are unique
	errorCellID := "";
	foreach aCell in self.allCellsOnDeck do
		if aCell.id &lt;&gt; null then
			if not theCellIds.includes(aCell.id) then
				theCellIds.add(aCell.id);
			else
				errorCellID := aCell.id;
				break;
			endif;
		endif;
	endforeach;
	if errorCellID &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Bay " &amp; self.id &amp; " On Deck Cell IDs.", " Cell ID '" &amp; errorCellID &amp; "' is already is use, it must be unique", null, null);
	
	endif;
	errorCellID := "";
	theCellIds.clear;
	foreach aCell in self.allCellsUnderDeck do
		if aCell.id &lt;&gt; null then
			if not theCellIds.includes(aCell.id) then
				theCellIds.add(aCell.id);
			else
				errorCellID := aCell.id;
				break;
			endif;
		endif;
	endforeach;
	if errorCellID &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Bay " &amp; self.id &amp; " Under Deck Cell IDs.", " Cell ID '" &amp; errorCellID &amp; "' is already is use, it must be unique", null, null);
	
	endif;
	errorCellID := "";
epilog
	delete theCellIds;


end;</source>
    </JadeMethod>
