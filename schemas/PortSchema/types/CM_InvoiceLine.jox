    <JadeMethod name="doAuditCOOVoidInvoiceLine" id="8f57eb23-0cb1-46b4-8a13-d7465746471a">
        <source>doAuditCOOVoidInvoiceLine(_cooHeader : CM_OwnershipChange; _cooDetail : CM_OwnershipChangeDetail; _hasVoided : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email

*/

vars
	audit: CM_AuditLineCOOVoid;
begin

	create audit persistent;
	
	audit.hasVoided := _hasVoided;
	audit.myOwnershipChange := _cooHeader;
	audit.myOwnershipChangeDetail := _cooDetail;
	audit.invLineNumber := self.sequenceNum;
	audit.sequenceNum := self.invoice.sequenceNum;
	audit.setRemarks();
	
	audit.auditedFOs.clear();
	audit.unauditedFOs.clear();
	
	audit.auditedFOs.add(self);
	
epilog

end;</source>
        <Parameter name="_cooHeader" type="CM_OwnershipChange"/>
        <Parameter name="_cooDetail" type="CM_OwnershipChangeDetail"/>
        <Parameter name="_hasVoided" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCreateAuditStatusChanged" id="66dcfc54-cd43-4c70-ac54-8945608588a0">
        <source>doCreateAuditStatusChanged(_invoiceStatus : CMIF_InvoiceStatus) protected;
/*

Date		Who		Reason
29 September 2015	cnwer1	Initial creation PAR 36958
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	auditStatusChg:   CM_AuditLineStatusChanged;
begin
	if _invoiceStatus.newStatus = self.status then
		return;
	endif;
	
	create auditStatusChg;
	auditStatusChg.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT);
	auditStatusChg.previousStatus := self.status;

	auditStatusChg.newStatus :=_invoiceStatus.newStatus ;

	auditStatusChg.invoiceLine := self;
	auditStatusChg.userId := app.getMyUserCode;
	auditStatusChg.datetime := app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	//epr par 36958 29/9/15
	auditStatusChg.clearingRemarks:=_invoiceStatus.voidReason;
	auditStatusChg.statusChangeReasonCode:=_invoiceStatus.voidReasonCode;
	
	auditStatusChg.auditedFOs.clear;
	auditStatusChg.unauditedFOs.clear;

	auditStatusChg.unauditedFOs.add(invoice);
	// put the line in audited Financial Objects since the auditing is handled at the
	// invoice level.
	auditStatusChg.auditedFOs.add(self);

	auditStatusChg.setRemarks;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invoiceStatus" type="CMIF_InvoiceStatus"/>
    </JadeMethod>
    <JadeMethod name="doHookCodeForRemarks" id="74b05618-44de-4665-9035-ec5e509b4f72">
        <updating/>
        <source>doHookCodeForRemarks() updating;
/*

Purpose:			

Parameters:			Migrated from 'CM_InvoiceLineDesc::createManualInvoiceLine'
								and 'CM_InvoiceLineDesc::createInvoiceLine'
								originally part of 37124.

Return Value:		

Date				Who		Reason
27 December 2018	jlgndl1	Initial creation	TFS 42119
23 Oct 2024			navlw1 	JIRA-33107: Invoice Logging Use Levels

*/

vars

	calcType : CM_CalculationType;
	cmifHook : CMIF_CalcTypeRemarksHook;
	valueOut : String;

begin

	calcType := self.getCalcType();	
	
	if calcType &lt;&gt; null and calcType.myHookCodeRemarks &lt;&gt; null then
	
		create cmifHook transient;
		if self.myTransactionTI &lt;&gt; null then
			cmifHook.myTransaction := self.myTransactionTI;
		elseif self.myTransactionEvent &lt;&gt; null then
			cmifHook.myTransaction := self.myTransactionEvent;
		elseif self.myTransactionHMS &lt;&gt; null then
			cmifHook.myTransaction := self.myTransactionHMS;
		elseif self.myTransactionWO &lt;&gt; null then
			cmifHook.myTransaction := self.myTransactionWO;
		elseif self.myTransactionBOL &lt;&gt; null then	//31 Oct 2019	NDL	TFS 47100
			cmifHook.myTransaction := self.myTransactionBOL;
		endif;
		cmifHook.origRemarks := self.remarks;
		cmifHook.myInvoiceLine := self;

		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceRemarks, calcType, calcType, cmifHook).String;
		if self.remarks &lt;&gt; valueOut then
			app.invLog("Remarks change from " &amp; self.remarks &amp; " to " &amp; valueOut, LogINFO.String);
			self.setRemarks(valueOut);
		endif;
		
	endif;

epilog

	delete cmifHook;

end;</source>
    </JadeMethod>
    <JadeMethod name="getActualQuantityNoMinMax" id="19017d8c-e4ec-41f1-9f12-3498640e7b8c">
        <updating/>
        <source>getActualQuantityNoMinMax() : Real updating;
// ---------------------------------------------------------------------------
// Created:     30 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	theCalcType : CM_CalculationType;
begin
	if self.invoice = null then 	// or (not global.isValidObject(invoice)) then	//AKB July 2001 PAR 1104
		return 0;
	endif;

	if not manual 
	//and invoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED then
	and not invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759	
		// #### VOYAGE TRANSACTION
		if self.myTransactionHMS &lt;&gt; null then
			theCalcType := self.invoiceLineDesc.getCalcType(); // ### TFS BUG 61892 29DEC2023 NAVAB1
			return self.quantityVOYAGECalcType(theCalcType);
		// #### CARGO TRANSACTION
		elseif self.myTransactionTI &lt;&gt; null then
			return self.quantityCARGO();
		endif;
	endif;

	return self.quantity;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAmountForCurrencyCode" id="dc2fc45d-90e6-4eb0-a5ad-41f9eea85b01">
        <source>getAmountForCurrencyCode( _typeCode : String ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlgndl1	Initial creation	TFS 37550
29 Nov   2018   cnwma1  Bug 42218: PEL1 - International Tariff - Currency Conversion.
*/

vars

	effectiveDT : TimeStamp;
	currencyType : CM_CurrencyType;
	rate : CM_CurrencyRate;

begin
	if not self.isCurrencyConversionRequired() then // TFS 41484
		return self.lineTotal;
	endif;

	if _typeCode.trimBlanks = null then
		return 0.0;
	endif;
	
	currencyType := app.myRoot.allCurrencyTypes.getAtKey(_typeCode).CM_CurrencyType;
	
	if currencyType = null then
		return 0.0;
	endif;
	
	//13 Jun 2018	NDL	TFS 39197
	effectiveDT := null;
	if self.invoice &lt;&gt; null then
		effectiveDT := self.invoice.getRateDateFromStatus();
	endif;
	
	if not effectiveDT.isValid() then
		effectiveDT := self.chargeTime;
	endif;
	
	rate := currencyType.getRate( effectiveDT );
	if rate = null then
		return 0.0;
	endif;
	
	//return rate.rate * self.lineTotal;      //29.11.2018 cnwma1 Bug #42218
	return self.getLineTotalConverted(rate);  //29.11.2018 cnwma1 Bug #42218

epilog

end;</source>
        <Parameter name="_typeCode" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAmountForInvCurrencyCode" id="b9b724b4-5034-47f0-a8d2-0985fc636bc3">
        <source>getAmountForInvCurrencyCode() : Decimal;
/*

Purpose:			Gets the amount for the invoice line based on currency code

Parameters:			NONE

Return Value:		Decimal	Representing the converted amount based on the currency code

Date		Who		Reason
30 August 2022	navpw1	Initial creation TFS: 54564 (54377)

*/

begin
	if self.invoice = null then
		return null;
		
	endif;
	
	if self.invoice.myCurrencyType = null then
		return null;
		
	endif;
	
	return self.getAmountForCurrencyCode(self.invoice.myCurrencyType.code);
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAuditOfClass" id="7a047a9a-4c91-4bff-80fc-ab7736aef50b">
        <source>getAuditOfClass(cls: Class): CM_Audit protected;

vars
	audit:   CM_Audit;
begin
	foreach audit in qualifiedAudits do
		if audit.isKindOf(cls) then
			break;
		endif;
		audit := null;
	endforeach;

	if audit = null then
		foreach audit in unqualifiedAudits do
			if audit.isKindOf(cls) then
				break;
			endif;
			audit := null;
		endforeach;
	endif;

	return audit;
end;</source>
        <access>protected</access>
        <Parameter name="cls" type="Class"/>
        <ReturnType type="CM_Audit"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="d3a0cb89-f14b-4715-b743-4465ed41a6c9">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2018	jlgmp6	Initial creation	TFS37718
05 May 2023 navmv20 CR 57229 Task 57697: Jade - Include Charge Changes on Invoice Line Audit
*/

vars
	txt,
	tmpStr: String;
	charge : CM_Charge; //05/05/2023 navmv20 CR 57229 Task 57697
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
/*
	tmpStr := null;
	if self.bank &lt;&gt; null then
		tmpStr := self.bank.code;
	endif;
	txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	tmpStr := self.chargeTime.String;
	txt := txt &amp; app.getErrorString(Charge) &amp; Space &amp; app.getErrorString(TimeStr) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	if self.debtor &lt;&gt; null then
		tmpStr := self.debtor.name;
	endif;
	txt := txt &amp; app.getErrorString(INV_Debtor) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	if self.invoice &lt;&gt; null then
		tmpStr := self.invoice.sequenceNum.String;
	endif;
	txt := txt &amp; app.getErrorString(CM_Invoice_Number) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	if self.invoiceLineDesc &lt;&gt; null then
		tmpStr := self.invoiceLineDesc.narration;
	endif;
	txt := txt &amp; app.getErrorString(Invoice_line_type) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	tmpStr := self.lineTotal.String;
	txt := txt &amp; app.getErrorString(Line_total) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	tmpStr := self.manual.String;
	txt := txt &amp; app.getErrorString(CM_Manual_Invoice) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	if self.myInvoiceLineAdditional &lt;&gt; null then
		tmpStr := self.myInvoiceLineAdditional.sequenceNum.String;
	endif;
	txt := txt &amp; app.getErrorString(Invoice_line_type) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
*/
	//05/05/2023 navmv20 CR 57229 Task 57697 - START
	foreach charge in self.charges do
		if charge.myOverrideTaxCode &lt;&gt; null then
			tmpStr := charge.myOverrideTaxCode.code;
			txt := txt &amp; app.getErrorString(Overridden_code) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		tmpStr := charge.overriddenTax.getYesNo();
		txt := txt &amp; app.getErrorString(OverriddenTax) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endforeach;
	//05/05/2023 navmv20 CR 57229 Task 57697 - END
	return txt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
