    <JadeMethod name="valWagonRailAlloc" id="29783bb3-9928-4cb5-9680-b598dfd2ed57">
        <source>valWagonRailAlloc(_allWagons : CM_WagonByIdDict; _railAllocTemplate : CM_RailAllocation; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon			: CM_Wagon;
begin
	foreach wagon in _allWagons do
		if (not wagon.confirmed) then
//			app.raiseCMWarning1(Full_Replacement_Message, 'Warning: Wagon ' &amp; wagon.id &amp; ' is not confirmed and will be skipped over.', null, null, wagon);
		endif;
	endforeach;
	_railAllocTemplate.validate();

end;


</source>
        <Parameter name="_allWagons" type="CM_WagonByIdDict"/>
        <Parameter name="_railAllocTemplate" type="CM_RailAllocation"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
