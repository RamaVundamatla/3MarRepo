    <JadeMethod name="executePostMoveForOrigLocation" id="3116f697-7b4b-4b2d-a454-22f0072b43e2">
        <updating/>
        <source>executePostMoveForOrigLocation(control: CMIF_MoveController; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		PAR 9055. If a container is instant mode moved from the bottom of a stack. Re do the locations of 
//							all the containers on the source location to reset the stack height on the location ID
//
// ---------------------------------------------------------------------------
vars
	aTI : CM_TrackedItem;
	lcStr : String;
begin
	inheritMethod(control, _passport);
	
	if control.moveMode = REAL_MODE then
		foreach  aTI in self.allTrackedItems do
			aTI.refreshLocationId(REAL_MODE);
		endforeach;
	endif;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForToLocation" id="e658de7a-1a36-4cf3-bb3c-4a464c2c6ec7">
        <updating/>
        <source>executePostMoveForToLocation(control: CMIF_MoveController; _passport: CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:	14 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	ti : CM_TrackedItem;

begin
	inheritMethod(control, _passport);

	//some screens need notifications, when cargo becomes owerstowed in a grid area. Par 19481 May 2009 cnwvu1
	if control.moveMode = REAL_MODE then 
	
		if self.myTerminalArea &lt;&gt; null and self.myTerminalArea.type = TA_TYPE_YARD_INTERCHANGE then	//27 Feb 2019	NDL	TFS 43356
			// don't refresh these, we don't need to for these, and don't want a flood of the notifications it causes.
		else
			foreach  ti in self.allTrackedItems do
				ti.refreshLocationId(REAL_MODE);
			endforeach;
		endif;
	endif;

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="get40ftColumnLabel" id="43d9fa03-0e94-44bf-b82b-090a8a97b6d8">
        <source>get40ftColumnLabel() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2009	cnwer1	Initial creation

*/

vars
	rowLength : Integer;
	rowString : String;
begin
	if self.id40ft = null then
		return null;
	endif;
	//ident is always stored row then col
	//likewise I've always stored id40ft row then column
	rowString:=self.myGridRow.label.trimBlanks;
	rowLength:=self.myGridRow.label.trimBlanks.length;
	
	return self.id40ft[rowLength+1:end];
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="get53NoOverhangOffset" id="576e29f0-e755-4a0c-9085-607e1111edc9">
        <source>get53NoOverhangOffset() : Real;
// ---------------------------------------------------------------------------
// Created:		08 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	prevGC : CM_GridController;
begin
	if not self.is53ft then
		return -1;
	endif;
	
	
	if self.offset53 &lt;&gt; self.Offset53_6 then
		return -1;
	endif;
	prevGC := self.getPreviousControllerOfType(CM_GridController);
	if prevGC &lt;&gt; null then
		if prevGC.allTrackedItemOSBackEnds.isEmpty then
			return -1;
		endif;
	endif;
	return 3;
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getActualHeight" id="54ab9887-278f-46ea-882e-01a8a95edfff">
        <source>getActualHeight(): Real;
// ---------------------------------------------------------------------------
// Created:		October 2001 By Andrew Bishop cnwab1
//
// Purpose:		Returns the height in feet of the TI's in this stack
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpHeight	: Real;
	lTI 		: CM_TrackedItem;
begin

	tmpHeight := 0;
	// add up the height of all the containers at this location to see whether our machine can lift that high
	foreach lTI in self.allTrackedItems do
		tmpHeight := tmpHeight + lTI.getActualHeight();
	endforeach;

	return tmpHeight;
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getActualRowColumnOrdinal" id="039a3c48-2f3a-4777-9700-510a3fe54284">
        <source>getActualRowColumnOrdinal(_row,_col : Integer output);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	_row := self.myGridColumn.allControllersByRow.indexOf(self);
	_col := self.myGridRow.allControllersByColumn.indexOf(self);
	
end;</source>
        <Parameter name="_row" type="Integer" usage="output"/>
        <Parameter name="_col" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getActualStackHeightOfTI" id="5651c457-c61d-48fb-9852-63ff5908cf39">
        <source>getActualStackHeightOfTI(_ti : CM_TrackedItem) :Real;
/*

Purpose:		I want to get the height that the ti container is stacked on	

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2009	cnwer1	Initial creation

*/

vars
	tmpHeight	: Real;
	lTI 		: CM_TrackedItem;
begin

	if self.allTrackedItems.indexOf(_ti) = 0 then
		return 0;
	endif;
	
	tmpHeight := 0;
	// add up the height of all the containers at this location to see whether our machine can lift that high
	foreach lTI in self.allTrackedItems do
		if lTI = _ti then
			break;
		endif;
		tmpHeight := tmpHeight + lTI.getActualHeight();
	endforeach;

	return tmpHeight;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getActualStackPositionOfTI" id="d4f7db1a-31ca-4f2a-ad41-e2b5f23a893c">
        <source>getActualStackPositionOfTI(_ti : CM_TrackedItem) : Integer;
/*

Purpose:		I want to get the height that the ti container is stacked on	

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	pos 		: Integer;
	lTI 		: CM_TrackedItem;
begin

	if self.allTrackedItems.indexOf(_ti) = 0 then
		return 0;
	endif;
	
	pos := 1;
	// add up the height of all the containers at this location to see whether our machine can lift that high
	foreach lTI in self.allTrackedItems do
		if lTI = _ti then
			break;
		endif;
		pos := pos + 1;
	endforeach;

	return pos;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
