    <JadeMethod name="docketCorrection" id="ae91f023-698a-4318-a64a-2e9b0341beb1">
        <updating/>
        <source>docketCorrection( _itIsTheFirstMoveTransaction : Boolean; _locationNew : CM_LocationsController ) updating;
// --------------------------------------------------------------------------------------------------------
// Created:     30 Jan 2008 by cnwvu1
//
// Purpose:     ccms1089. Docket Correction.
// 				a) clones the transaction and puts the clone into the array self.previousVersions
// 				b) corrects Location field for the transaction
//
// Parameters:	_itIsTheFirstMoveTransaction = true - edits the Move transaction From Road =&gt; Location1
//				_itIsTheFirstMoveTransaction = false - edits the Move transaction From Location1 =&gt; Location2
//
// ----------------------------------------------------------------------------------------------------------

vars
	
begin

	if _locationNew = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Docket Corrections. The Location is null for the MOVE transaction correction. Contact developer.', null, self);
		return;
	endif;

	self.savePreviousVersion();
	// details are shown in Docket Correction transaction
	//self.generateEditAudit( app.myPassport ); //don't need? 
	
	if _itIsTheFirstMoveTransaction then	//the Move transaction From Road =&gt; Location1
	
		self.targetLocn := _locationNew.getFullIdAndLevel(self.myTrackedItem, REAL_MODE, false);
		
	else	//the Move transaction From Location1 =&gt; Location2
	
		self.sourceLocn := _locationNew.getFullIdAndLevel(self.myTrackedItem, REAL_MODE, false);
		
	endif;

end;
</source>
        <Parameter name="_itIsTheFirstMoveTransaction" type="Boolean"/>
        <Parameter name="_locationNew" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionLocn_stockMove" id="4c40e838-8c19-4a07-88c9-30b0c3767248">
        <updating/>
        <source>docketCorrectionLocn_stockMove( _trnRoadToLocation : CM_Move; _trnFromLocation1ToLocation2 : CM_TITransaction; 
							_oldLocation, _newLocation : CM_LocationsController ) updating;
// --------------------------------------------------------------------------------------------------------
// Created:     25 March 2008 by cnwvu1
//
// Purpose:		Corrects stock move for the Move transaction.
//
// Parameters:	_oldLocation, _newLocation - locations affected by Docket Correction. Relate only to
//					the transactions _trnRoadToLocation and _trnFromLocation1ToLocation2.
// 				_trnRoadToLocation - the first Move transaction corrected by Docket Correction.
//				_trnFromLocation1ToLocation2 - the second Move transaction corrected by Docket Correction.
//						_trnFromLocation1ToLocation2 &lt;&gt; null when the log has been regraded 
//					and moved to another location.
//				Note. We have to correct stock move for the movementIn on the _trnRoadToLocation
//					and for the movementOut on the _trnFromLocation1ToLocation2
// --------------------------------------------------------------------------------------------------------
vars
	tmpMovement		: CM_StockMovement;
	tmpSOHLocation,
	tmpSOHLocation2	: CM_SOHLocation;
	tmpProduct		: CM_Product;
	tmpDateTime		: TimeStamp;
	tmpBucket		: CM_StockMoveBucket;
	tmpOldSedMean,
	tmpNewSedMean,
	sedMean			: Decimal[6,2];
	
begin

	// ----------------------------------------------------------------------
	//			the first Move transaction: From Road To Location
	// ----------------------------------------------------------------------
	if self = _trnRoadToLocation then	
	
		// MOVEMENT OUT = null - should be null
		if self.myStockMovementOut &lt;&gt; null then
			app.raiseUnexpectedProgramError( class.name, method.name, 'Docket Correction. myStockMovementOut &lt;&gt; null for the Move transaction: From Road To Location' );
			return;
		endif;
		
		// MOVEMENT IN - we have to reduce stock for the _oldLocation and increase for the _newLocation
		
		// ------------------------ _oldLocation --------------------------
		// stock decrease for the movemetin IN
		if not _oldLocation.isStockControlled then
			return;
		endif;
		tmpMovement		:= self.myStockMovementIn;
		tmpBucket		:= tmpMovement.myStockMoveBucket;
		tmpDateTime		:= self.completedDateTime;
		tmpSOHLocation	:= tmpMovement.myStockMoveBucket.CM_StockMoveLocation.mySOHLocation;
		tmpProduct		:= tmpSOHLocation.myProduct;
		tmpSOHLocation2 := _oldLocation.getSOHLocationForProduct( tmpProduct );
		if tmpSOHLocation &lt;&gt; tmpSOHLocation2 then
			app.raiseUnexpectedProgramError( class.name, method.name, 'Changed location. Incorrect SOHLocation' );
		endif;
		// getting sedMean
		if tmpSOHLocation.myExtension &lt;&gt; null then
			self.myTrackedItem.CM_Log.docketCorrection_getCurrentSED( self, tmpOldSedMean, tmpNewSedMean );
			sedMean	:= tmpOldSedMean;
		endif;
		tmpSOHLocation.adjustStockOnHand_docketCorect( tmpDateTime, tmpMovement.type, true, 
										self.totalQuantity, self.totalWeight, self.totalVolume, sedMean, self.myTrackedItem, self, tmpBucket,
										true);

		// ------------------------ _newLocation --------------------------
		// _newLocation - stock increase
		tmpSOHLocation := _newLocation.getSOHLocationForProduct( tmpProduct );
		tmpSOHLocation.adjustStockOnHand_docketCorect( tmpDateTime, tmpMovement.type, false, 
										(self.totalQuantity), (self.totalWeight), (self.totalVolume), sedMean, self.myTrackedItem, self, tmpBucket,
										true);
	
	// ----------------------------------------------------------------------
	//			the second Move transaction: From Location1 To Location2
	// ----------------------------------------------------------------------
	elseif self = _trnFromLocation1ToLocation2 and 
	   _trnFromLocation1ToLocation2.isKindOf(CM_Move) then	//#24462 07/07/2010. The second move from locn1 to locn2 can be CM_ReinstateReject transaction. It has myStockMovementIn- new another location, beyond docket correctio.
	
		// MOVEMENT OUT - we have to increase (do reverse) stock for the _oldLocation and reduce for the _newLocation
		// ------------------------ _oldLocation --------------------------
		if not _oldLocation.isStockControlled then
			return;
		endif;
		// _oldLocation - stock decrease
		tmpMovement		:= self.myStockMovementOut;
		tmpDateTime		:= self.completedDateTime;
		tmpSOHLocation	:= tmpMovement.myStockMoveBucket.CM_StockMoveLocation.mySOHLocation;
		tmpProduct		:= tmpSOHLocation.myProduct;
		tmpSOHLocation2 := _oldLocation.getSOHLocationForProduct( tmpProduct );
		if tmpSOHLocation &lt;&gt; tmpSOHLocation2 then
			app.raiseUnexpectedProgramError( class.name, method.name, 'Docket Correction. Incorrect SOHLocation' );
		endif;
		// getting sedMean
		if tmpSOHLocation.myExtension &lt;&gt; null then
			self.myTrackedItem.CM_Log.docketCorrection_getCurrentSED( self, tmpOldSedMean, tmpNewSedMean );
			sedMean	:= tmpOldSedMean;
		endif;
		tmpSOHLocation.adjustStockOnHand_docketCorect( tmpDateTime, tmpMovement.type, true, 
										-(self.totalQuantity), -(self.totalWeight), -(self.totalVolume), sedMean, self.myTrackedItem, self, tmpBucket, 
										true);
		
		// ------------------------ _newLocation --------------------------
		// _newLocation - stock decrease for the movementOut
		tmpSOHLocation := _newLocation.getSOHLocationForProduct( tmpProduct );
		tmpSOHLocation.adjustStockOnHand_docketCorect( tmpDateTime, tmpMovement.type, false,
										-(self.totalQuantity), -(self.totalWeight), -(self.totalVolume), sedMean, self.myTrackedItem, self, tmpBucket,
										true);

		// MOVEMENT IN - no stock move correction, because correction is for the past
	
	
	
	else
		app.raiseUnexpectedProgramError( class.name, method.name, 'Not valid move transaction for stock move correction ' &amp; self.String );
		return;
	endif;
	
end;
</source>
        <Parameter name="_trnRoadToLocation" type="CM_Move"/>
        <Parameter name="_trnFromLocation1ToLocation2" type="CM_TITransaction"/>
        <Parameter name="_oldLocation" type="CM_LocationsController"/>
        <Parameter name="_newLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionProd_stockMove" id="b6c1ed83-82a9-4a98-9bae-d7cf95b5fd9a">
        <updating/>
        <source>docketCorrectionProd_stockMove( _oldProduct, _newProduct : CM_Product; 	_newQuantity: Integer; _newWeightKgs: Decimal; _newVolume: Decimal ) updating;
// --------------------------------------------------------------------------------------------------------
// Created:     17 March 2008 by cnwvu1
//
// Purpose:		Corrects stock move for the Move transaction when product has been changed by Docket Correction.
// --------------------------------------------------------------------------------------------------------

vars
	tmpLocation		: CM_LocationsController;
	tmpMovement		: CM_StockMovement;
	sedMean,
	tmpOldSedMean,
	tmpNewSedMean: Decimal[6,2];
	tmpSOHLocation,
	tmpSOHLocation2	: CM_SOHLocation;
	tmpProduct		: CM_Product;
	tmpDateTime		: TimeStamp;
	tmpBucket		: CM_StockMoveBucket;
	tmpType			: Integer;
	tmpNewWeight	: Decimal[14,4];
	tmpNewVolume	: Decimal[16,4];

begin

	// if there are following transactions with changed Weight (Volume) we have to use current Weight (Volume)
	tmpNewWeight := self.myTrackedItem.CM_Log.docketCorrection_getNewWeigth( _newWeightKgs,	self );
	tmpNewVolume := self.myTrackedItem.CM_Log.docketCorrection_getNewVolume( _newVolume, _oldProduct, _newProduct, self );

	// ----------------------------------------------------------------------
	//						M O V E M E N T   O U T
	// ----------------------------------------------------------------------
	// myStockMovementOut = null, when there is the first Move trn: From Road To Location
	if self.myStockMovementOut &lt;&gt; null then
		// -------------------------- oldProduct ---------------------------
		// we have to correct-neutralize old bucket.myStockmovementOut (increase value to null)
		tmpMovement		:= self.myStockMovementOut;
		tmpBucket		:= tmpMovement.myStockMoveBucket;	// this is the old bucket. corrected by previous transaction
		tmpLocation		:= tmpBucket.CM_StockMoveLocation.myLocationsController;
		if not tmpLocation.isStockControlled then
			return;
		endif;
		tmpDateTime		:= self.completedDateTime;
		tmpSOHLocation	:= tmpBucket.CM_StockMoveLocation.mySOHLocation;
		tmpProduct		:= tmpSOHLocation.myProduct;
		tmpSOHLocation2 := tmpLocation.getSOHLocationForProduct( _oldProduct );
		if tmpSOHLocation &lt;&gt; tmpSOHLocation2 then
			app.raiseUnexpectedProgramError( class.name, method.name, 'Incorrect SOHLocation' );
		endif;
		//getting sedMean
		if tmpSOHLocation.myExtension &lt;&gt; null then
			self.myTrackedItem.CM_Log.docketCorrection_getCurrentSED( self, tmpOldSedMean, tmpNewSedMean );
			sedMean	:= tmpOldSedMean;
		endif;

		// correcting the movement OUT in the previous old bucket - increase stock (do reverse)
		tmpSOHLocation.adjustStockOnHand_docketCorect( tmpDateTime, tmpMovement.type, true, 
										-self.totalQuantity, -self.totalWeight, -self.totalVolume, sedMean, self.myTrackedItem, self, tmpBucket,
										false);
		
		
		// -------------------------- newProduct ---------------------------
		// we have to decrease value for stock move for the new product
		tmpSOHLocation	:= tmpLocation.getSOHLocationForProduct( _newProduct );
		tmpSOHLocation.adjustStockOnHand_docketCorect( tmpDateTime, tmpMovement.type, false, 
										-(_newQuantity), -(tmpNewWeight), -(tmpNewVolume), sedMean, self.myTrackedItem, self, tmpBucket,
										false);
		
	endif;

	// ----------------------------------------------------------------------
	//						M O V E M E N T   I N
	// ----------------------------------------------------------------------
	// MOVEMENT IN - we have to reduce stock for the _oldProduct and increase for the _newLProduct
	
	// ------------------------ _oldProduct --------------------------
	// stock decrease for the movemetin IN
	tmpMovement		:= self.myStockMovementIn;
	tmpBucket		:= tmpMovement.myStockMoveBucket;
	tmpLocation		:= tmpBucket.CM_StockMoveLocation.myLocationsController;
	if not tmpLocation.isStockControlled then
		return;
	endif;
	tmpDateTime		:= self.completedDateTime;
	tmpSOHLocation	:= tmpBucket.CM_StockMoveLocation.mySOHLocation;
	tmpProduct		:= tmpSOHLocation.myProduct;
	tmpSOHLocation2 := tmpLocation.getSOHLocationForProduct( _oldProduct );
	if tmpSOHLocation &lt;&gt; tmpSOHLocation2 then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Incorrect SOHLocation' );
	endif;
	// geting sedMean
	if tmpSOHLocation.myExtension &lt;&gt; null then
		self.myTrackedItem.CM_Log.docketCorrection_getCurrentSED( self, tmpOldSedMean, tmpNewSedMean );
		sedMean	:= tmpOldSedMean;	// tmpOldSedMean is actual sedMean for the Mmove transaction. Of course, it can be changed in the follwowing transacactions
	endif;
	tmpSOHLocation.adjustStockOnHand_docketCorect( tmpDateTime, tmpMovement.type, true, 
									self.totalQuantity, self.totalWeight, self.totalVolume, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
									
	// ------------------------ _newProduct --------------------------
	// stock increase and creating new (possibly) bucket
	tmpSOHLocation := tmpLocation.getSOHLocationForProduct( _newProduct );
	// geting sedMean - it is the same as counted above. sedMean cannot been changed in a Move transaction
	tmpSOHLocation.adjustStockOnHand_docketCorect( tmpDateTime, tmpMovement.type, false, 
									_newQuantity, tmpNewWeight, tmpNewVolume, sedMean, self.myTrackedItem, self, tmpBucket,
									false);
									
	// correcting the transaction by the new product values									
	self.totalQuantity	:= _newQuantity;
	self.totalWeight	:= tmpNewWeight;
	self.totalVolume	:= tmpNewVolume;
	
end;
</source>
        <Parameter name="_oldProduct" type="CM_Product"/>
        <Parameter name="_newProduct" type="CM_Product"/>
        <Parameter name="_newQuantity" type="Integer"/>
        <Parameter name="_newWeightKgs" type="Decimal"/>
        <Parameter name="_newVolume" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doesRequireSnapShot" id="3c7597c7-d53d-4dac-9ee4-7347ebdce777">
        <methodInvocation>mapping</methodInvocation>
        <source>doesRequireSnapShot(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     22 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.transitStatus = TI_TransitStatusSOB then
			_value := true;
		else
			_value := false;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="forced" id="5a6090cd-4831-45fb-9e1b-83f20460c6be">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>forced(set: Boolean; _value: Boolean io) updating, mapping;
begin
	if set then
		if _value then
			flags := flags.bitOr(ForcedFlag);
		else
			flags := flags.getValueWithBitUnset(ForcedFlag);
		endif;
	else
		_value := (flags.bitAnd(ForcedFlag) &lt;&gt; 0);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCompletedDateTimeLocalTZ" id="3b91dcf8-9e01-4339-b42c-a08dfe91db5b">
        <source>getCompletedDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.completedDateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCraneForMove" id="f5ca1281-15f2-48a8-9f5a-0393c3ad8e31">
        <source>getCraneForMove() : CM_Machine;
/*
Purpose:			

Date		Who		Reason
28JAN2022	NAVAB1	TFS 51855
*/

vars
	machine: CM_Machine;
	lc: CM_LocationsController;
	tmpFoundHeight: Integer;
	cta: String;
	pos: Integer;
begin
	if self.machineId &lt;&gt; null then
		machine := self.myTerminal.machines[self.machineId];
		return machine;
	endif;
	
	if self.isCM_Move then
		// Old txns do not have the crane set
		pos := 1;
		if self.targetTATypeDesc = "Crane Transfer Area" then
			cta := self.targetLocn.getNextToken(pos);
		endif;
		if self.sourceTATypeDesc = "Crane Transfer Area" then
			cta := self.sourceLocn.getNextToken(pos);
		endif;
		
		if cta &lt;&gt; null then
			foreach machine in self.myTerminal.machines do
				if not machine.isCrane then
					continue;
				endif;
				if machine.CM_Crane.transferArea.id = cta then
					return machine;
				endif;
			endforeach;
		endif;		


	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="getCraneTxnFor" id="d2706c80-ae22-4bb9-ac28-4c9febf2b9bb">
        <source>getCraneTxnFor(_machineMove: CM_Move): CM_Move;
/*
Purpose:			Return the crane transaction that matches the pickup or setdown

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2012	cnwdw1	Initial creation
*/
vars
	iter: Iterator;
	moveTxn, craneMoveTxn: CM_Move;
	releaseShipTxn: CM_ReleaseShip;
	txn: CM_TITransaction;
	lc: CM_LocationsController;
	tmpFoundHeight: Integer;
	history: CM_MachineMoveHistory;
begin
	if _machineMove.class = CM_Pickup then
		// if this is a voyage discharge then need to find the crane move from voyage to CTA. 
		// This will have happened within the previous minute as it is system generated on the first actual move
		self.myTerminal.findLocationFromString(_machineMove.sourceLocn, true, lc, tmpFoundHeight);
		if lc &lt;&gt; null and lc.isCraneLaneController then
			if _machineMove.myTrackedItem &lt;&gt; null then
				iter := _machineMove.myTrackedItem.allTransactions.createIterator();
				iter.startAtObject(_machineMove);
				// Look for the Discharge Crane move
				while iter.back(txn) do
					if txn.class = CM_Move  and txn.CM_Move.id = _machineMove.id then
						return txn.CM_Move;
					endif;
				endwhile;
			endif;
		endif;
	else
		// if this is a voyage load then need to create a transient move for the crane leg
		// as JMT does not automatically create the crane move 
		history := _machineMove.allMachineMoveHistories.first.CM_MachineMoveHistory;
		if history &lt;&gt; null then
			self.myTerminal.findLocationFromString(history.targetLocation, true, lc, tmpFoundHeight);
			if lc &lt;&gt; null and lc.isCraneLaneController then
				create craneMoveTxn transient;
				craneMoveTxn.setCraneMoveDetailsFrom(_machineMove, lc.CM_CraneLaneController);
				return craneMoveTxn;
			endif;
		endif;
	endif;
	
	return null;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_machineMove" type="CM_Move"/>
        <ReturnType type="CM_Move"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="a59d4b21-357a-40ed-83d2-ecebdeeb66d1">
        <source>getDisplayString(): String;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
	amountString : String;
begin

	if self.mode = REAL_MODE then
		if self.sourceLocn = null and
		   self.targetLocn = null then
		   	//str := 'From and to locations unknown';
			str := app.getErrorString(MOVE_FROMTO_UNKNOWN);
		elseif self.sourceLocn &lt;&gt; null and
		   self.targetLocn &lt;&gt; null then
		   if self.isShiftMove then
				//str := "Shift ";
				str := app.getErrorString(MOVE_SHIFT) &amp; " " ;
				if self.shiftDirection = CMIF_MoveController.ShiftLeft then
					//str := str &amp; "Left ";
					str := str &amp; app.getErrorString(Left) &amp; " " ;
				elseif self.shiftDirection = CMIF_MoveController.ShiftRight then
					//str := str &amp; "Right ";
					str := str &amp; app.getErrorString(Right) &amp; " " ;
				endif;
		   // cnwjk3 ccms 1018 15/01/10
		   elseif self.isShufflingInCurrentLocation then
				str := app.getErrorString(MOVE_SHUFFLED) &amp; " " ;		   
		   endif;
		   
		   // cnwjk3 ccms 1018 15/01/10
		   if self.isShufflingInCurrentLocation then		   
				str := str &amp; app.getErrorString1(MOVE_SHUFFLED_LOCATION, self.sourceLocn) &amp; " " ;
		   else
				str := str &amp; app.getErrorString2(MOVE_FROMTO, self.sourceLocn, self.targetLocn) &amp; " " ;
		   endif;
			//str := str &amp; 'From ' &amp; self.sourceLocn &amp; ' to ' &amp; self.targetLocn;
		elseif self.sourceLocn = null then
			//str := 'From unknown to ' &amp; self.targetLocn;
			str := app.getErrorString1(MOVE_FROM_UNKNOWN, self.targetLocn);
			
		else
			//str := 'From ' &amp; self.sourceLocn &amp; ' to unknown';
			str := str &amp; app.getErrorString1(MOVE_TO_UNKNOWN, self.sourceLocn) &amp; " " ;
			
		endif;
	elseif self.mode = PLANNING_MODE then
		if self.unplan then // undo
			//str := 'From ' &amp; self.sourceLocn;
			str := app.getErrorString1(MOVE_FROM, self.sourceLocn);
		elseif self.isReplan then
			//str := 'Was planned to ' &amp; self.sourceLocn &amp; ', now to ' &amp; self.targetLocn;
			str := app.getErrorString2(MOVE_WAS_PLANNED, self.sourceLocn, self.targetLocn);// PAR 19600
		else
			//str := 'From ' &amp; self.sourceLocn &amp; ' to ' &amp; self.targetLocn;
			str := str &amp; app.getErrorString2(MOVE_FROMTO, self.sourceLocn, self.targetLocn) &amp; " " ;
		endif;
	elseif self.mode = QUEUE_MODE then
		if self.unplan then // undo
//			str := 'From ' &amp; self.sourceLocn;
			str := app.getErrorString1(MOVE_FROM, self.sourceLocn);
		elseif self.isReQueue then // PAR 19600
			str := app.getErrorString2(MOVE_WAS_QUEUED, self.sourceLocn, self.targetLocn);// PAR 19600
		else
//			str := 'From ' &amp; self.sourceLocn &amp; ' to ' &amp; self.targetLocn;
			str := str &amp; app.getErrorString2(MOVE_FROMTO, self.sourceLocn, self.targetLocn) &amp; " " ;
		endif;
	endif;
	
//	str :='(' &amp;  self.getAmountDisplay() &amp; ') ' &amp; str;
	
	//20 Dec 2017 TFS 8231
	amountString := self.getAmountDisplay();
	if amountString &lt;&gt; null then
		str :='(' &amp;  amountString &amp; ') ' &amp; str;
	endif;
	
	// TFS 42882
	if self.isDirectReleaseMove then
		str :='DR ' &amp; str;
	endif;


	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6a36c4e5-b3fe-4bc7-bb6b-9af79c92235e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := self.getDisplayString();
			if self.machineId &lt;&gt; null 
			and not self.isKindOf(CM_CraneMove) then // ### TFS 51855 03FEB2022 NAVAB1
				lDetail := lDetail &amp; " by MACH " &amp; self.machineId;
			endif;
		
			if lDetail &lt;&gt; "" then
				lDetail := lDetail &amp; " " &amp; self.urNumber.String;
			else
				lDetail := self.urNumber.String;
			endif;			
			
			return lDetail;
			
		endif;
	elseif _attrName = ETRow_MovedDetail then
		lDetail := self.getDisplayString();
		if self.machineId &lt;&gt; null 
		and not self.isKindOf(CM_CraneMove) then // ### TFS 51855 03FEB2022 NAVAB1
			lDetail := lDetail &amp; " by MACH " &amp; self.machineId;
		endif;
		return lDetail;
	elseif _attrName = 	ETRow_SourceLocation or
		   _attrName = ETRow_MovedSourceLocn then
		return self.sourceLocn;
	elseif _attrName = 	ETRow_TargetLocation or
		   _attrName = ETRow_MoveTargetLocn then
		return self.targetLocn;
	elseif _attrName = ETRow_Machine or
		   _attrName = ETRow_MoveMachine then
		return self.machineId;
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="0c650bad-784e-42c1-9d41-a170076bd3aa">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();

	//lDetail := lDetail &amp; self.sourceLocn &amp; " to " &amp; self.targetLocn;
	lDetail := lDetail &amp; self.getDisplayString();
	
	if self.machineId &lt;&gt; null 
	and not self.isKindOf(CM_CraneMove) then // ### TFS 51855 03FEB2022 NAVAB1
		lDetail := lDetail &amp; " by MACH " &amp; self.machineId;
	endif;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstPickup" id="45bb8f72-fac7-4313-8335-2c74d5b9fa14">
        <source>getFirstPickup() : CM_Move;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2012	cnwdw1	Initial creation
*/
vars
	machineMove: CM_MachineMoveHistory;
	pickUpSourceController: CM_LocationsController;
	tmpFoundHeight: Integer;
	txns: CM_TITransactionByDateTypeDict;
	txn: CM_TITransaction;
	craneTxn, pickupTxn: CM_Move;

begin
	if not self.isMachineMove then
		return self;
	endif;
	
	machineMove := self.allMachineMoveHistories.first.CM_MachineMoveHistory;
	if machineMove = null then
		return self;
	endif;
	
	machineMove := machineMove.getFirstPickup;
	if machineMove = null then
		return self;
	endif;

	pickupTxn := machineMove.myMoveTransaction;

	self.myTerminal.findLocationFromString(machineMove.sourceLocation, true, pickUpSourceController, tmpFoundHeight);
	if pickUpSourceController.isCraneLaneController then
		// Need to find the crane move from voyage to CTA. This will have happened within the previous minute
		create txns transient;
		self.myTerminal.getTITxns(TRANS_TYPE_MOVE, pickupTxn.dateTime.addMinutes(-1), pickupTxn.dateTime, true, null, null, txns);
		foreach txn in txns do
			craneTxn := txn.CM_Move;
			if craneTxn.id = pickupTxn.id and craneTxn.targetLocn = pickupTxn.sourceLocn then
				pickupTxn := craneTxn;
				break;
			endif;
		endforeach;
	endif;
	
	return pickupTxn;
	
epilog
	delete txns;
end;</source>
        <ReturnType type="CM_Move"/>
    </JadeMethod>
    <JadeMethod name="getFromToTransportCodes" id="9f2a2e95-eb9e-4b62-a059-8231584bac22">
        <source>getFromToTransportCodes(_wle : CM_WorkListEntry; _move : CM_Move; _fromCode, _toCode : String io);
/*
Purpose:	return the voyage, train  or truck codes for a move. The 'yard' is always the terminal code.		

Date		Who		Reason
11 February 2022	navab1	TFS 51855
*/

vars
	term : CM_Terminal;
	sourceLC, targetLC : CM_LocationsController;
	foundHeight : Integer;
	slotreq :	CM_SlotRequest;
begin
	term := self.myTerminal;
	
	if _wle &lt;&gt; null then // ### TFS 53105 03JUN2022 NAVAB1
		if _wle.myRequest.isReleaseType() then // LOAD
			_fromCode := term.code; 
			
			term.findLocationFromString(_wle.locationTarget,true,targetLC,foundHeight);
			if targetLC = null then
				term.findLocationFromString(_move.targetLocn,true,targetLC,foundHeight);
			
			endif;
			if targetLC &lt;&gt; null then
				_toCode := targetLC.getTransportCode(true);
			endif;
		else // DISCHARGE
				
			_toCode := term.code;
			_fromCode := "";
			
			term.findLocationFromString(_wle.locationSource,true,sourceLC,foundHeight);
			if sourceLC = null then
				term.findLocationFromString(_move.sourceLocn,true,sourceLC,foundHeight);		
			endif;
			if sourceLC &lt;&gt; null then
				/* We should be doing this, however it doubles up discharges in waterside report */
				if _wle.myRequest.isSlotRequest() then // ### TFS 51855 24JAN2022 NAVAB1
					slotreq := _wle.myRequest.CM_SlotRequest;
					if not slotreq.isDischarge then
						_fromCode := sourceLC.getTransportCode(false);
					endif;			
				else
					_fromCode := sourceLC.getTransportCode(not _wle.isReceipt); // ### TFS 51855 25MAY2022 NAVAB1
				endif;			
			endif;
		endif;		
	else
		if self.isSourceOfType(CM_LocationsController.Location_Type_YARD) then // LOAD
			_fromCode := term.code; 
			term.findLocationFromString(_move.targetLocn,true,targetLC,foundHeight);
			
			if targetLC &lt;&gt; null then
				_toCode := targetLC.getTransportCode(true);
			endif;
		
		else // DISCHARGE
			_toCode := term.code;
			
			if not self.isSourceOfType(CM_LocationsController.Location_Type_SHIP) then // DO not do discharge from ship  it doubles up discharges in waterside report
			
				term.findLocationFromString(_move.sourceLocn,true,sourceLC,foundHeight);	
				
				if sourceLC &lt;&gt; null then
					_fromCode := sourceLC.getTransportCode(true); 
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_move" type="CM_Move"/>
        <Parameter name="_fromCode" type="String" usage="io"/>
        <Parameter name="_toCode" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getInvMoveSourceString" id="0cca74dc-b067-4972-8697-67089eb426d5">
        <source>getInvMoveSourceString() : String;
// ---------------------------------------------------------------------------
// Created:     May 2012 ANDREW BISHOP PAR 29570
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
	locationType	: Integer;
	ta : CM_TerminalArea;
begin
	self.myTerminal.findLocationFromString(self.sourceLocn, true, tmpFoundLC, tmpFoundHeight);
	// 36460 handle offsite rail
	if tmpFoundLC = null and
	   self.myTrackedItem &lt;&gt; null and
	   self.myTrackedItem.isOffSite then
		locationType := self.myTerminal.findLocationWhenOffsite(self.sourceLocn);
		if locationType = 1 then
			return GROSSAREA_RAIL;
		endif;
	endif;
	
	if tmpFoundLC &lt;&gt; null then
		if tmpFoundLC.isVoyageController() then
			return GROSSAREA_SHIP;
		elseif tmpFoundLC.isVehicle() then		// 36446 handle Road source
			return GROSSAREA_ROAD;
		elseif tmpFoundLC.isWagon then			// 36460
			return GROSSAREA_RAIL;
		else
			ta := tmpFoundLC.getMyTerminalArea();
			if ta &lt;&gt; null then
				return ta.id;
			else
				return null;
			endif;
		endif;
	else
		// 36460 handle "Nowhere"
		if self.sourceLocn = GROSSAREA_NOWHERE then
			return GROSSAREA_NOWHERE;
		endif;
		return null;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvMoveTargetString" id="9ac27721-bd86-469c-821c-0f2617183fbe">
        <source>getInvMoveTargetString() : String;
// ---------------------------------------------------------------------------
// Created:     May 2012 ANDREW BISHOP PAR 29570
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
	locationType	: Integer;
	ta : CM_TerminalArea;
begin
	self.myTerminal.findLocationFromString(self.targetLocn, true, tmpFoundLC, tmpFoundHeight);
	// 36460 handle offsite rail
	if tmpFoundLC = null and
	   self.myTrackedItem &lt;&gt; null and
	   self.myTrackedItem.isOffSite then
		locationType := self.myTerminal.findLocationWhenOffsite(self.targetLocn);
		if locationType = 1 then
			return GROSSAREA_RAIL;
		endif;
	endif;
	
	if tmpFoundLC &lt;&gt; null then
		if tmpFoundLC.isVoyageController() then
			return GROSSAREA_SHIP;
		elseif tmpFoundLC.isVehicle() then		// 36348 handle Road target
			return GROSSAREA_ROAD;
		elseif tmpFoundLC.isWagon then			// 36460
			return GROSSAREA_RAIL;
		else
			ta := tmpFoundLC.getMyTerminalArea();
			if ta &lt;&gt; null then
				return ta.id;
			else
				return null;
			endif;
		endif;
	else
		// 36460 handle "Nowhere"
		if self.targetLocn = GROSSAREA_NOWHERE then
			return GROSSAREA_NOWHERE;
		endif;
		return null;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKEASourceLocation" id="d7b39373-f117-4978-8a9f-8e01ca6074ce">
        <source>getKEASourceLocation(_sourceType: String) : String;
// Get the location of source as required by KEA
vars
	txn:  CM_TITransaction;
	pos: Integer;
	tokens: StringArray;
begin
	if _sourceType = CM_LocationsController.Location_Type_RAIL then
		if self.myTrackedItem &lt;&gt; null then
			if self.myTrackedItem.myNotifiedWagon &lt;&gt; null then
				return self.myTrackedItem.myNotifiedWagon.myTrainInwards.code &amp; " " &amp; self.myTrackedItem.myNotifiedWagon.id;
			endif;
			
			// No notified wagon so try the RailReceive Txns
			txn := self.myTrackedItem.getLastTransOfType(TRANS_TYPE_REC_RAIL);
			if txn &lt;&gt; null then
				pos := 1;
				tokens := txn.CM_ReceiveRail.getReceiveTrainCode.getTokens();
				return tokens.first &amp; " " &amp; self.myTrackedItem.wagon;
			endif;
		endif;		
	endif;
	
	return self.sourceLocn;
	
epilog
	delete tokens;
end;
</source>
        <Parameter name="_sourceType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKEATargetLocation" id="4da5eb61-66ca-4d3c-883a-c474e2522261">
        <source>getKEATargetLocation(_targetType: String) : String;
// Get the location of source as required by KEA
// 11/03/2015	cnwmh5	Transient Leaks
vars
	txn:  CM_TITransaction;
	pos: Integer;
	tokens: StringArray;
begin
	if _targetType = CM_LocationsController.Location_Type_RAIL then
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myNotifiedWagon &lt;&gt; null then
			return self.myTrackedItem.myNotifiedWagon.myTrainOutwards.code &amp; " " &amp; self.myTrackedItem.myNotifiedWagon.id;
		endif;
		
		// No notified wagon so try the RailRelease Txns
		txn := self.myTrackedItem.getLastTransOfType(TRANS_TYPE_REL_RAIL);
		if txn &lt;&gt; null then
			pos := 1;
			tokens := txn.CM_ReleaseRail.getReleaseTrainCode.getTokens();
			return tokens.first &amp; " " &amp; self.myTrackedItem.wagon;
		endif;
	endif;
	
	return self.targetLocn;	
	
epilog
	delete tokens;
end;
</source>
        <Parameter name="_targetType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastSetDown" id="fc15ec62-6329-41f5-b811-8bc5c45afa3f">
        <source>getLastSetDown() : CM_Move;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2012	cnwdw1	Initial creation
*/
vars
	machineMove: CM_MachineMoveHistory;
begin
	if not self.isMachineMove then
		return self;
	endif;
	
	machineMove := self.allMachineMoveHistories.first.CM_MachineMoveHistory;
	if machineMove = null then
		return null;
	endif;
	
	machineMove := machineMove.getLastSetDown;
	if machineMove = null then
		return null;
	endif;

	return machineMove.myMoveTransaction;

epilog

end;</source>
        <ReturnType type="CM_Move"/>
    </JadeMethod>
    <JadeMethod name="getLoadMoveKindFromWLE" id="b8a37114-dcfb-440c-ba59-3bb7dc8ee441">
        <source>getLoadMoveKindFromWLE(_opsViewTable : CMIF_OpsViewTables) : String;
/*
Purpose:	OPSVIEW		

Date		Who		Reason
20 May 2022	navab1	TFS 51855
*/

vars
	wle			: CM_WorkListEntry;
	voyageWle   : CM_VoyageWLE;
	yardWLE : CM_YardWLE;

begin
	wle := self.getWLEForMove(); // ### TFS 51855 24MAY2022 NAVAB1
	
	if wle = null then
		return "";
	endif;
	
	if wle.isRoad() then
		return _opsViewTable.Move_Kind_Delivered;
	elseif wle.isRail() then
		return _opsViewTable.Move_Kind_LoadRail;
	elseif wle.isKindOf(CM_VoyageWLE) then
		return _opsViewTable.Move_Kind_Load;
	endif;

	return "";

epilog

end;</source>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
        <ReturnType type="String"/>
    </JadeMethod>
