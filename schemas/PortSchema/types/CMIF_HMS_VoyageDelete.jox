<Class name="CMIF_HMS_VoyageDelete" id="b3d7acfe-c2b4-43dd-93a9-1815b9bf73b0">
    <superclass name="CMIF_HMS_StackChange"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ImplicitInverseRef name="appliesToVoyage" id="b13ecd87-70aa-42c3-b95b-8158fd8a0b4a">
        <embedded/>
        <type name="CMIF_HMS_WorkingVoyage"/>
    </ImplicitInverseRef>
    <JadeMethod name="applyChange" id="2c80400f-78ec-4af8-b796-f7acaaf92a9d">
        <updating/>
        <source>applyChange() updating;

vars
 	workingMovement:	CMIF_HMS_WorkingMovement;
begin
    // Remove voyage and all its current working movements from current view, 
 	// and add it to the list of voyages to be deleted
	self.appliesToVoyage.ofCurrentView := null;

 	foreach workingMovement in self.appliesToVoyage.allWorkingMovements do
 		workingMovement.myViewControllerCurrent := null;	
 	endforeach;

	if self.appliesToVoyage.ofPermanentVoyage &lt;&gt; null then
 		self.ofViewController.allDeletedVoyages.add(self.appliesToVoyage.ofPermanentVoyage);
  	endif;

  	// Update views
	// Russell Changed 15/03/99
	if self.ofViewController.allVoyagesViewedByCode.size &gt; 0 then
		self.ofViewController.view_NewSelectedMovement(self.ofViewController.allVoyagesViewedByCode.first.allWorkingMovements.first, false);
    endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getMyWorkingVoyage" id="e848a96b-d4db-4cd1-bc00-2c8187421d5b">
        <source>getMyWorkingVoyage(): CMIF_HMS_WorkingVoyage;
//--------------------------------------------------
// Created:	20 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.appliesToVoyage;

end;</source>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="undoChange" id="b33186a5-003e-44aa-903a-cb06b1869e2e">
        <updating/>
        <source>undoChange() updating;

vars
 	workingMovement:	CMIF_HMS_WorkingMovement;
begin
    // Add voyage and all its current working movements to current view, 
 	// and remove it from the list of voyages to be deleted
	appliesToVoyage.ofCurrentView:=ofViewController;

 	foreach workingMovement in appliesToVoyage.allWorkingMovements do
 		workingMovement.myViewControllerCurrent:=ofViewController;
 	endforeach;

	if appliesToVoyage.ofPermanentVoyage&lt;&gt;null then
 		ofViewController.allDeletedVoyages.remove(appliesToVoyage.ofPermanentVoyage);
  	endif;


 	// Update views
 	// ofViewController.view_NewSelectedMovement(appliesToVoyage.allWorkingMovements.first);

 	// Russell Changed 15/03/99
 	if appliesToVoyage.allWorkingMovements.size&gt;0 then
 		ofViewController.view_NewSelectedMovement(appliesToVoyage.allWorkingMovements.first, false);
    endif;
    // --------------

end;</source>
    </JadeMethod>
</Class>
