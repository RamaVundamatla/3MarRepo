    <JadeMethod name="toDoTaskDescSetType" id="f080306f-9ffb-4bef-a66b-1835fa167377">
        <source>toDoTaskDescSetType(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Oct 2022 navds20 ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance

*/

vars
	toDoTask: CM_ToDoTaskDesc;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " TO DO TASK DESC type value update ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" TO DO TASK DESC type value update ") ;	
	endif;
	
	beginTransaction;
		foreach toDoTask in CM_ToDoTaskDesc.instances do
			toDoTask.setType(TODO_TYPE_GROUP_TI);
		endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " TO DO TASK DESC type value update ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" TO DO TASK DESC type value update ") ;	
	endif;	
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
