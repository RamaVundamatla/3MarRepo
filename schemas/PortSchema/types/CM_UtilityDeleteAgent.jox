    <JadeMethod name="utlDeleteJob" id="ce67833f-3fed-4b67-9de7-ef9e642940d7">
        <source>utlDeleteJob(_job : CM_Job io; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	wle	: CM_WorkListEntry;
	wleSet : CM_WLESet;
	aRequest : CM_Request;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valJob(_job);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_job);
	else
		return;
	endif;

	// ### CCMS 1282 AKB2004NOV
	aRequest := _job.allRequests.first;
	if aRequest &lt;&gt; null then
		if aRequest.bulkRelease &lt;&gt; null then
			if aRequest.bulkRelease.type = BR_TYPE_RAIL then
				aRequest.bulkRelease.causeUpdateEvent();
			endif;
		endif;
	endif;

	_job.erase(NORMAL_ERASE);
		

epilog
	delete wleSet;
end;</source>
        <Parameter name="_job" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteJobEntry" id="64e14a27-accb-4fdc-85cd-e2bb32597e7d">
        <source>utlDeleteJobEntry(pWle : CM_WorkListEntry io; _reason : String; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
// 23/02/2010	cnwcs5	par 22360 - perform a rebuild job when we delete a WLE
// cnwrd1 par 22624 3.5.2010 added reason param
// 18 Sep 2023 navma1	 Bug 60531: MTN - Deleting Road Work list entry delete work order wles
// 27 Sep 2023 navnk30	 Bug 60531: MTN - Deleting Road Work list entry delete work order wles
// 24 Apr 2025 navma1  	 MTN-34621 MTN - 1081 dead lock on CM_EIRNumberDict
// 16 May 2025 navma1	 MTN-34915 | Cargo on a Cancelled Road Job no longer changed to Remain On Board
vars
	bulkRelease 	: CM_BulkRelease;
	job				: CM_YardJob;	
	jobDeleted,
	gteDeleted		: Boolean;		
	gteEntity 		: CMGTE_Entity;
	gteID 			: String;
	ti 				: CM_TrackedItem;	
	tiDeleted 		: Boolean; 
	wle 			: CM_WorkListEntry;
	fm 				: CM_FutureMove; 
	vvrAuditAgent 	: CM_UpdateTransactionAuditAgent;
	vvr 			: CM_VehicleVisitRecord;
	vvrAudit 		: CM_AuditObject;	
	vvrCarrier 		: CM_Carrier;
	totRequested    : Integer;
	request			: CM_Request;
	lc				: CM_LocationsController;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valJobEntry(pWle);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	//02 Feb 2021	NDL	TFS 50152
	if _passport.noErrors then
		if pWle.isRoad then
			job := pWle.job.CM_YardJob;
			if job &lt;&gt; null and job.isRoadJob then
				vvr := job.CM_RoadJob.myVehicleVisit;
				if vvr &lt;&gt; null and vvr.isBulkGateVVR then
					create vvrAuditAgent transient;
					vvrAuditAgent.audUpdateGeneric(vvr, true);
				endif;
			endif;	
		endif;
	endif;
	
	
	//27 Jul 2020	NDL	TFS 49775 - Clean up any split moves on the same TiRequest - that used a YA Autoplan using Split Range
	ti := pWle.myTrackedItem;	
	on Exception do app.handleDeletedObject (exception, ti, tiDeleted);
	if ti &lt;&gt; null then
		lc := ti.myPrimaryActualLocation;												//16.05.2024 navma1 #34915
		
		if lc &lt;&gt; null and lc.isVehicle and not ti.allWorklistEntries.isEmpty then
			foreach wle in ti.allWorklistEntries do
				if wle = pWle then
					continue;
				endif;
				
				if wle.isWorkOrderWle then					//18.09.2023 navma1 #60531
					continue;
				endif;
				
				fm := wle.myFutureMove;
				
				if fm &lt;&gt; null then
					delete fm;
				endif;
				delete wle;
			endforeach;
		endif;
	endif;
	
	pWle.setMyWorkOrderWLE(null);							//27.09.2023 navnk30 #60531

	//Par 8380 - May need to delete the bulk release as well	
	
	request := pWle.myRequest;									//22.04.2025 navma1 #MTN-34621
	
	if request &lt;&gt; null then
		bulkRelease := request.myOriginatingBulkRelease;
		if bulkRelease &lt;&gt; null then
			exclusiveLock(bulkRelease);
		endif;
		//epr par 30353 9/10/12
		if request.isKindOf(CM_YardRequest) then
			gteEntity := request.CM_YardRequest.myGateEntity;
			//epr CCMS 2274 break bulk can have 1 gte 1 request and multiple wles only get gte to delete if 1 to 1 relationship
			if request.allWorkListEntries.size &gt; 1 then //22.04.2025 navma1 #MTN-34621 //16.05.2024 navma1 #34915
				gteEntity := null;
			endif;
			
		endif;
	endif;
	
	job := pWle.job.CM_YardJob;							// 23/02/2010 cnwcs5
	
	job.CM_YardJob.removeWLE(pWle, _reason);			// 23/02/2010 cnwcs5 par 22360 // cnwrd1 par 22624 3.5.2010
	
	if _passport.hasErrors then
		return;
	endif;	

	//Par 8380 - May need to delete the bulk release as well	
	if bulkRelease &lt;&gt; null then
		if bulkRelease.isSystemGenerated then
			totRequested := bulkRelease.getTotalRequested();													//22.04.2025 navma1 #MTN-34621
			if totRequested &lt; 1 or (bulkRelease.getFirstTIRequest(false) &lt;&gt; null and totRequested = 1) then		//22.04.2025 navma1 #MTN-34621
				bulkRelease.auditLogs.purge;
				delete bulkRelease;
			endif;
		endif;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	on Exception do app.handleDeletedObject (exception, gteEntity, gteDeleted);	
	//epr par 30353 9/10/12
	if gteEntity &lt;&gt; null then
		gteID:=gteEntity.id; //dereferenced to check invalid obj
		app.myUtilityDA.utlDeleteVehicleVisitGTE(gteEntity, _passport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	// now rebuild the job status - it is possible at this point that the job has been deleted
	// so arm exception handler to trap that situation
	on Exception do app.handleDeletedObject (exception, job, jobDeleted);	// 23/02/2010 cnwcs5 par 22360
	
	if job &lt;&gt; null then			// 23/02/2010 cnwcs5 par 22360
		job.rebuildStatus;		// 23/02/2010 cnwcs5 par 22360
	endif;						// 23/02/2010 cnwcs5 par 22360
	
	if _passport.hasErrors then	// 23/02/2010 cnwcs5 par 22360
		return;					// 23/02/2010 cnwcs5 par 22360
	endif;						// 23/02/2010 cnwcs5 par 22360
	
	//02 Feb 2021	NDL	TFS 50152
	if vvr &lt;&gt; null and vvrAuditAgent &lt;&gt; null then
		vvrAudit := vvrAuditAgent.audUpdateGeneric(vvr, false);
		if vvrAudit &lt;&gt; null then
			//03 Feb 2022	jlizm1 TFS 52364
			//The following values will be unchanged, so will not show on audit, but want to show anyway
			vvrAudit.addToBothText(app.getErrorString(Terminal), vvr.getMyTerminal.code);
			vvrCarrier := vvr.getMyCarrier;
			if vvrCarrier &lt;&gt; null then
				vvrAudit.addToBothText(app.getErrorString(Carrier), vvrCarrier.description);
				vvrAudit.addToBothText(app.getErrorString(Carrier_code), vvrCarrier.code);
			endif;
		endif;
	endif;
	
	if vvr &lt;&gt; null then
		// ### TFS 51853 27AUG2021 NAVAB1
		if _passport.isOpsViewEnabled(vvr.myTerminal) then
			vvr.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_VVR, vvr);	
			
			if job &lt;&gt; null then // Last WLE deleted, deletes job as well
				job.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB, job);	
			endif;
		endif;
	endif;
epilog

	delete vvrAuditAgent;	//02 Feb 2021	NDL	TFS 50152

end;</source>
        <Parameter name="pWle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
