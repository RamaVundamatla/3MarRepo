    <JadeMethod name="trxUpdateWagonReturn" id="1c93d93a-adb4-4318-bf04-5e0c98314539">
        <updating/>
        <source>trxUpdateWagonReturn(control : CMIF_WagonMoveController input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	wagon : CM_Wagon;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	if control.allWagons.isEmpty() then
		return;
	endif;
	
	beginTransaction;

	// ### MOVE TO RAIL
	if control.myTargetRailLine &lt;&gt; null then
		reserveLock(control.myTargetRailLine);
	endif;
	if control.myTargetTrain &lt;&gt; null then
		reserveLock(control.myTargetTrain);
	endif;
	
	app.myUtilityUA.utlReturnWagon(control, _passport);
	if _passport.hasErrorsOrWarnings() then
		return;
	endif;
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="control" type="CMIF_WagonMoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
