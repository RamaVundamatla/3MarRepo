    <JadeMethod name="isStorageDetailMatch" id="3b4a9327-e017-468f-96fd-35f440fb325b">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*
Purpose:			 // TFS 4271
Date		Who		Reason
30 June 2017	cnwab1	Initial creation
*/

vars
	val : String;
begin

	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		self.getCriteriaValueForTi( _tiTrx.myTrackedItem, val); // height not kept on the generic transaction
	else
		self.getCriteriaValueForTi( _ti, val);
	endif;
	
	if _criteria.myYAData.CM_YADataString.doesValueMatch(val) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
