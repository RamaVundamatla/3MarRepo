    <JadeMethod name="testIsDiffDischPort" id="9fbfffb6-f9f5-47c3-8080-5f11fede84a8">
        <source>testIsDiffDischPort(obj: CMIF_AutoMovePlan input);
//Here, we DEFAULT to OK for differing discharge ports for
//a controller. Where necessary, we over-ride (Stack Controller, SlotController)
