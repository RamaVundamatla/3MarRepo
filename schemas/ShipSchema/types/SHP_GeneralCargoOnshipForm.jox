    <JadeMethod name="unload" id="0ca7f9e5-0596-436a-8fc5-e63f89e55a11">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars

begin
	delete self.myBOLAgent;
	self.endClassNotification(CM_BOL, false, self.myTerminal.getTerminalEvent(Event_BOLAdd));
	self.endClassNotification(CM_BOL, false, self.myTerminal.getTerminalEvent(Event_BOLUpdate));
	inheritMethod();
end;
</source>
