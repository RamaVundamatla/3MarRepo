    <JadeMethod name="showMatchedFieldsCSV" id="b573f236-e64c-423f-8a6b-065bdf321660">
        <source>showMatchedFieldsCSV(_fieldElemArray: JadeXMLElementArray);
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	addsElem,
	addElem,
	xmlElem			: JadeXMLElement;
	ediItemField	: CM_EDIItemField;
	addItemField	: CM_EDIItemFieldCSV;
	sysName,
	tName,
	formatMeth,
	typeString		: String;
	colIndex		: Integer;
	additionals		: JadeXMLElementArray;
begin

	foreach xmlElem in _fieldElemArray do
		ediItemField := null;
		typeString	:= xmlElem.getElementByTagName('systemTypeName').textData;
		sysName := xmlElem.getElementByTagName('systemName').textData;
		tName := xmlElem.getElementByTagName('name').textData;
		formatMeth := xmlElem.getElementByTagName('stringFormatMethodName').textData;
		colIndex := xmlElem.getElementByTagName('columnIndex').textData.Integer;
		
		ediItemField := self.allFieldsOfType[typeString, sysName].CM_EDIItemField;
		
		if ediItemField = null then
			ediItemField := self.allFieldsOfFile[typeString, sysName].CM_EDIItemField;
			if ediItemField = null then
				//process.debug; commented out PAR 19975
				//old field in definition was not found in relevant field collections
				return;
			endif;
		endif;

		ediItemField.setNonSystemAttributes(tName, formatMeth, colIndex);
		self.allMatchedFileFields.add(ediItemField);
		
		addsElem := xmlElem.getElementByTagName('AdditionalFields');
		if addsElem &lt;&gt; null then
			create additionals transient;
			addsElem.getElementsByTagName('AdditionalField', additionals);
			
			foreach addElem in additionals do
				tName := addElem.getElementByTagName('name').textData;
				formatMeth := addElem.getElementByTagName('stringFormatMethodName').textData;
				colIndex := addElem.getElementByTagName('columnIndex').textData.Integer;
		
				create addItemField transient;
				addItemField.setNonSystemAttributes(tName, formatMeth, colIndex);
				ediItemField.addFieldAdditional(addItemField);
			endforeach;
		endif;
		
	endforeach;		
epilog
	delete additionals;
end;</source>
        <Parameter name="_fieldElemArray" type="JadeXMLElementArray"/>
    </JadeMethod>
    <JadeMethod name="showMatchedFieldsXML" id="b3cf96a7-ceb0-4125-9ae1-b6365f2500dc">
        <source>showMatchedFieldsXML(_fieldElemArray: JadeXMLElementArray);
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	foundDocElem,
	ptElem,
	xmlElem,
	addElem,
	addsElem		: JadeXMLElement;
	addItemField,
	subField		: CM_EDIItemFieldXML;
	ediItemField	: CM_EDIItemField;
	sysName,
	tName,
	subFieldName,
	formatMeth,
	typeString,
	parentTagName	: String;
	additionals,
	xmlPTElemArray	: JadeXMLElementArray;
	xmlAttrib		: JadeXMLAttribute;
begin

	create xmlPTElemArray transient;

	foreach xmlElem in _fieldElemArray do
		ediItemField := null;
		typeString	:= xmlElem.getElementByTagName('systemTypeName').textData;
		sysName := xmlElem.getElementByTagName('systemName').textData;
		tName := xmlElem.getElementByTagName('name').textData;
		formatMeth := xmlElem.getElementByTagName('stringFormatMethodName').textData;
		subFieldName := xmlElem.getElementByTagName('SubFieldName').textData;
		
		ediItemField := self.allFieldsOfType[typeString, sysName].CM_EDIItemField;
		
		if ediItemField = null then
			ediItemField := self.allFieldsOfFile[typeString, sysName].CM_EDIItemField;
			if ediItemField = null then
				//old field in definition was not found in relevant field collections
			endif;
		endif;

		ptElem := xmlElem.getElementByTagName('XMLDetail');
		ptElem := ptElem.getElementByTagName('PathTags');
		ptElem.getElementsByTagName('PathTag', xmlPTElemArray);
				
		if ediItemField &lt;&gt; null then
			//we've found the edi item field that relates to this
			//find the element in the list - need to go down the tag path to make sure we've got the right thing here
			//foundDocElem := self.myXMLDoc.getElementByTagName(tName);
			foundDocElem := self.getElementUsingPath(xmlPTElemArray);

			if foundDocElem = null then
				//? - unlikely - could happen if someone edits the constant text
			endif;
			
			app.writeStatement( tName &amp; " OK'd");
				
			if subFieldName &lt;&gt; null then
				//has subfield
				create subField transient;
				subField.setNonSystemAttributes(subFieldName, null, foundDocElem.getElementByTagName(subFieldName));
				ediItemField.setMySubField(subField);
			endif;
			
			ediItemField.setNonSystemAttributes(tName, formatMeth, foundDocElem);
			self.allMatchedFileFields.add(ediItemField);
		
			//additional fields
			addsElem := xmlElem.getElementByTagName('AdditionalFields');
			if addsElem &lt;&gt; null then
				create additionals transient;
				addsElem.getElementsByTagName('AdditionalField', additionals);
			
				foreach addElem in additionals do
					tName := addElem.getElementByTagName('name').textData;
					//formatMeth := addElem.getElementByTagName('stringFormatMethodName').textData;
					//colIndex := addElem.getElementByTagName('columnIndex').textData.Integer;
					
					ptElem := addElem.getElementByTagName('XMLDetail');
					ptElem := ptElem.getElementByTagName('PathTags');
					ptElem.getElementsByTagName('PathTag', xmlPTElemArray);
					
					foundDocElem := self.getElementUsingPath(xmlPTElemArray);
					
					create addItemField transient;
					addItemField.setNonSystemAttributes(tName, null, foundDocElem);
					ediItemField.addFieldAdditional(addItemField);
				endforeach;
			endif;
		
		endif;
	endforeach;		


epilog
	delete xmlPTElemArray;
end;</source>
        <Parameter name="_fieldElemArray" type="JadeXMLElementArray"/>
    </JadeMethod>
    <JadeMethod name="tblCSVDisplay_change" id="e1e208e6-d72f-445f-8c2d-afc01169e112">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCSVDisplay_change(table: Table input) updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	newRow,
	newCol,
	intCol		: Integer;
begin

	newRow := table.row;
	newCol := table.column;

	if newRow = 1 then
		//has clicked the field name row
		//reset all
		foreach intCol in table.fixedColumns+1 to table.columns do
			self.tblCSVDisplay.accessCell(1, intCol).text := "";
			self.tblCSVDisplay.accessColumn(intCol).backColor := White;
		endforeach;
		
		//set new
		self.csvHeadingsColumn := newCol;
		self.tblCSVDisplay.accessCell(newRow, newCol).text := "1";
		self.tblCSVDisplay.accessColumn(newCol).backColor := CM_BaseForm.ColourYellowDark;
		self.tblCSVDisplay.leftColumn := newCol;
	endif;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCSVDisplay_mouseUp" id="56852764-e7d1-4d47-bdb6-a39b6cd1190d">
        <controlMethod name="CM_Table::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCSVDisplay_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	09 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	int		: Integer;
begin

	if shift = 1 or shift = 3 then
		if self.allSelectedFieldRows.last &gt; table.row then
			foreach int in self.allSelectedFieldRows.last-1 to table.row step -1 do
				if not self.allSelectedFieldRows.includes(int) then
					self.allSelectedFieldRows.add(int);
				endif;
			endforeach;
		elseif self.allSelectedFieldRows.last &lt; table.row then
			foreach int in self.allSelectedFieldRows.last+1 to table.row do
				if not self.allSelectedFieldRows.includes(int) then
					self.allSelectedFieldRows.add(int);
				endif;
			endforeach;
		else
			//no nothing
		endif;
	elseif shift = 2 then
		int := table.row;
		if self.allSelectedFieldRows.includes(int) then
			self.allSelectedFieldRows.remove(int);
		else
			self.allSelectedFieldRows.add(int);
		endif;
	else
		self.allSelectedFieldRows.clear;
		self.allSelectedFieldRows.add(table.row);
	endif;  
	
	self.lblAllSelected.caption := self.allSelectedFieldRows.asCSV(false);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="unmatchField" id="64efd2c6-df54-4528-b6a3-df7ac6ac9a59">
        <source>unmatchField();
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	objSet	: CM_ObjectSet;
	ffield	: CM_EDIItemField;
begin
	create objSet transient;

	foreach ffield in self.allMatchedFileFields do
		//self.allMatchedFileFields.copy(objSet);
		if not objSet.includes(ffield) then
			objSet.add(ffield);
		endif;
	endforeach;
			
	if objSet.includes(self.currentFieldObject) then
		objSet.remove(self.currentFieldObject);
	else
		app.writeStatement( 'CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " This system field not matched!");
	endif;
	self.currentFieldObject.setNonSystemAttributes(null, null, null);
	self.currentFieldObject.resetFieldsAdditional();

	self.allMatchedFileFields.clear();
	objSet.copy(self.allMatchedFileFields);

epilog
	self.updateMatchedDisplay();
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMatchedDisplay" id="7e17723f-b2d2-4984-a1c7-e31cbdd95a8c">
        <source>updateMatchedDisplay();
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.cmbFormatMethod.text := "";
	self.lstMatchedFields.clear();
	self.lstMatchedFields.listCollection(self.allMatchedFileFields, false, 0);

end;</source>
    </JadeMethod>
</GUIClass>
