    <JadeMethod name="action" id="6af24904-7d5e-4347-985f-ce213879cb44">
        <updating/>
        <source>action(): Boolean updating;
// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//08 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP - make BGP_StorageProcessorRequest::effectiveRunDate work in unit test

vars
	anAgent : CM_AutoStorageTransactionAgent;
	errCode	: Integer;
	errTxt	: String;
	taskDescription	: String;
	msg : String;
	invalidSelector : Boolean;
begin
	on Exception do app.alertExceptionHandler(exception, null,  self.getErrorDesc(),errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	msg := 'Processing';
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogERROR);	//25 Nov 2019	NDL	TFS 47053
	
	self.setUser();
	
	create anAgent transient;
	// new parameters for 24016
	if self.myUpdateCallbackObject &lt;&gt; null and
	   self.myUpdateCallbackObject.isKindOf(CM_AutoTask) then
		taskDescription := self.myUpdateCallbackObject.CM_AutoTask.description;
	endif;
	
	on Exception do app.handleDeletedObject(exception,self.mySelectorQuery,invalidSelector);
	
	anAgent.initialise(self.myTerminal, self.myUser, self.myFinancialPeriod, self.mySelectorQuery, taskDescription, self.effectiveRunDate, app.myPassport);
	anAgent.runProcess();
	
	//epr par 36579 9/10/15
	if invalidSelector then
		errCode :=ERR_RTQueryDeleted;
		errTxt := app.getErrorString(errCode);
	endif;
epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, app.getErrorString1(Successfull_Storage_Processing, self.myTerminal.code), false, false);
	endif;
	inheritMethod();
	
	delete anAgent;
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="0de85d7c-4c39-451d-b829-c6f5bc4d7c3e">
        <source>getDisplay(): String;

// cnwdvb1 28 March 2003 

vars

	str, detail : String;

begin

	str := inheritMethod();
	detail := 'Storage Processor';
	return str &amp; Tab &amp; detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="80b1d7b3-b00c-42fc-a574-f43cc9734f2a">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskStorageProcessor) updating;
// added for 24016 add item selector and financial period
vars

begin
	self.myFinancialPeriod	:= _task.myFinancialPeriod;
	self.mySelectorQuery	:= _task.mySelectorQuery;
	inheritMethod(_task);
end;
</source>
        <Parameter name="_task" type="CM_AutoTaskStorageProcessor"/>
    </JadeMethod>
</Class>
