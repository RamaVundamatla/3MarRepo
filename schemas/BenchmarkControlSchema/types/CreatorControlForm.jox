    <JadeMethod name="startUserApp" id="a06c2354-909d-4d53-9c52-24a6776e5b1d">
        <updating/>
        <source>startUserApp() updating;

vars
	userSchema,userApp:String;
begin
	if myBmkControl.product.toUpper[1:3] = "JCC" then
		userSchema:="JccCoreReportSchema";
		userApp:="JccUserApp";

	elseif myBmkControl.product = "Derive" then
		userSchema:="DASystem";
		userApp:="DASystem";
	
	elseif myBmkControl.product.toUpper[1:4] = "CMIS" then
		userSchema:="CMI_View";
		userApp:="CMI_View";

	elseif myBmkControl.product.toUpper = "PORT" then
		userSchema:="ShipSchema";
		userApp:="ShipSchema";

	elseif myBmkControl.product.toLower = "jm" or myBmkControl.product = "mtl" then
		userSchema:="UiCommonSchema";
		userApp:="JMTerminal";

	elseif myBmkControl.product.toLower = "tui" then
		userSchema:="TWHTUI";
		userApp:="TWHTUI2";

	elseif myBmkControl.product.toLower = "jetx" then
		userSchema:="JCFViewSchema";
		userApp:="JCMController";

	elseif myBmkControl.product.toUpper[1:8] = "JADESTAR" then
		userSchema:="JadeStarSchemaView1";
		userApp:="JadeStarSchemaView1";

	elseif myBmkControl.product.toUpper[1:6] = "JASPER" or myBmkControl.product.toUpper[1:3] = "POL" or myBmkControl.product = "sms" then
		userSchema:="JASSchema";
		userApp:="JASMain";

	elseif myBmkControl.product[1:2] = "sk" or myBmkControl.product[1:2] = "sl" then
		userSchema:="SKIPTON";
		userApp:="SKIPTON_MainForm";
	endif;

	addResults(startApp(myBmkControl.envid, myBmkControl.appServerHost, myBmkControl.controlPort, userSchema, userApp));
end;</source>
    </JadeMethod>
    <JadeMethod name="stdRunManual" id="8a8aa039-bb8c-406a-a413-5670e5d4874b">
        <updating/>
        <source>stdRunManual() updating;

vars
	i,j:Integer;
begin
	if myBmkControl.envid = "copr6215" then
		startRap;						app.doWindowEvents(7000);
		startJadeDev;					app.doWindowEvents(1000);
		startJadeMon("V2");				app.doWindowEvents(000);

	elseif myBmkControl.envid = "jski6300b" then
		startRap;						app.doWindowEvents(6000);
		startJadeDev;					app.doWindowEvents(0);
		startAppServers;				app.doWindowEvents(3000);
		foreach i in 1 to 1 do startDriverApps; app.doWindowEvents(20); endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="stdRunMumbai" id="66b19f62-2b7b-48ad-a945-8a31998a570d">
        <updating/>
        <source>stdRunMumbai() updating;

begin
//	startCreators;					app.doWindowEvents(60000);
	startRap;						app.doWindowEvents(30000);
//	syncMasterThinbin;				app.doWindowEvents(10000);
//	syncThinbin;					app.doWindowEvents(10000);
	startAppServers;				app.doWindowEvents(1000);
	startODT;						app.doWindowEvents(1000);
	startControllerApp;				app.doWindowEvents(80000);  // 50000 for 4 queues
//	doPerfMonLogStart;				app.doWindowEvents(10000);
	startDriverApps;					app.doWindowEvents(70000);
	startDoCommand("start");		app.doWindowEvents(6*60*1000);
	startDoCommand("stop");		app.doWindowEvents(20000);
	startDoCommand("terminate");	app.doWindowEvents(30000);
	startKillerAll;
end;</source>
    </JadeMethod>
