<Class name="CM_WarehouseRowController" id="820c21f3-611c-4ce0-8419-35ff4ff54bcb">
    <superclass name="CM_RowController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <JadeMethod name="doesAllowType" id="672c7ff6-1025-4542-a5bb-55cc7ca305d3">
        <source>doesAllowType(_search : CMIF_SearchTypes; _giveError : Boolean) : Boolean;

// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwth2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - remove references to location restrictions
// ---------------------------------------------------------------------------
vars

begin
	if self.status &lt;&gt; LC_Status_Open then
		if _giveError then
			app.raiseCMException1(LocationIsClosed, self.getID, null, null);
		endif;
		return false;
	endif;
end;</source>
        <Parameter name="_search" type="CMIF_SearchTypes"/>
        <Parameter name="_giveError" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="71c5ffdc-23d2-45aa-ad7d-43507e87cdc3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// ----------   ----------  --------------------------------------------------
// 
vars
	
begin
	if _attrName = ETRow_TerminalAreaId then
		if self.myTerminalArea &lt;&gt; null then
			return self.myTerminalArea.id.String;
		else
			return '';
		endif;
	endif;

	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="a67ac1c1-3dce-4913-8a81-b35249f429e1">
        <source>getExtraInfo(_dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:     15 August 2002 by cnwth2
//
// Purpose:     Adds extra block details to the Data Container parameter object.
//
// Parameters:  _dataContainer - A reference to the block area data container.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// 07/11/2012	cnwcs5		par 30475 - remove references to location restrictions
// ---------------------------------------------------------------------------
vars
	blockObj			: CM_DataContainerBlock;
	passportObj			: CM_Passport;
	allBlocksArray		: CM_DataContainerBlockArray;
	sohLocationObj		: CM_SOHLocation;
	displayMode			: Integer;
	isAccessRestricted	: Boolean;
	itemDisplay			: String;
	itemCount			: Integer;
	itemTotal			: Integer;
	quantity			: Integer;
	quantityTotal		: Integer;
	sohVolume			: Decimal[16,4];
	totVolume			: Decimal[16,4];
	sohWeight			: Decimal[14,4];
	totWeight			: Decimal[14,4];
	failedDAC  :CM_DataAccessController;
	
begin
	displayMode		:=	_dataContainer.displayMode;
	
	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(CM_Row_ID), DC_Label, 1, null);
	blockObj.addNewItem(self.id.String, DC_Data, 1, null);

	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(CM_Width), DC_Label, 1, null);
	blockObj.addNewItem(self.myRow.width.numberFormat(), DC_Data, 1, null);

	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(CM_Total_Quantity), DC_Label, 1, null);
	blockObj.addNewItem(self.totalQuantity.cnEcNumberFormat(), DC_Data, 1, null);

	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(CM_Total_Volume), DC_Label, 1, null);
	blockObj.addNewItem(self.totalVolume.numberFormat(), DC_Data, 1, null);
	
	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(CM_TotalItems), DC_Label, 1, null);
	blockObj.addNewItem(self.allProductLocations.getTotalTIs().cnEcNumberFormat(), DC_Data, 1, null);
	
	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem(app.getErrorString(CM_Total_Weight), DC_Label, 1, null);
	blockObj.addNewItem(self.totalWeightTonnes.String, DC_Data, 1, null);
	
// ************************ Copied from the Log Area form *********************************
	
	create allBlocksArray transient;
	
	passportObj	:=	app.myPassport;
	
	if (not self.canUserAccessSelf(null, failedDAC, passportObj)) then
		blockObj	:=	_dataContainer.addNewBlock;
		blockObj.addNewItem(app.getErrorString(CM_You_Do_Not_Have_Access), DC_Header, 1, null);
		return;
	endif;
	
	isAccessRestricted	:=	(passportObj.allDataAccessControllers[CM_Operator.name] &lt;&gt; null);
	
	// sgp 11 June 2003 : Get spec details.  Must be retrieved before the summary to calculate the
	// summary totals as only shows totals for those specs the user has access to see.
	foreach sohLocationObj in self.allProductLocations do
		if sohLocationObj.allTrackedItems.isEmpty and
		   sohLocationObj.allStockOrderAllocations.isEmpty then
			continue;
		endif;
		
		if not sohLocationObj.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		itemCount		:=	sohLocationObj.numTIs;
		itemTotal		:=	itemTotal + itemCount;
		quantity		:=	sohLocationObj.currentQuantity;
		quantityTotal	:=	quantityTotal + quantity;
		sohVolume		:=	sohLocationObj.currentVolume;
		totVolume		:=	totVolume + sohVolume;
		sohWeight		:=	sohLocationObj.currentWeightKgs;
		totWeight		:=	totWeight + sohWeight;
		
		// Add the spec details to a local block array so they can be added
		// to the CM_DataContainer after the summary details.
		create blockObj transient;
		allBlocksArray.add(blockObj);
		blockObj.addNewItem(sohLocationObj.getDisplayStringForAttribute(ETRow_OperatorCode, false) &amp; ':' &amp; sohLocationObj.myProduct.code, DC_Data, 1, null);
		blockObj.addNewItem(itemCount.String, DC_Data, 1, null);
		blockObj.addNewItem(quantity.String, DC_Data, 1, null);
		blockObj.addNewItem(sohVolume.jasVolumeString, DC_Data, 1, null);
		blockObj.addNewItem(sohWeight.asStringWeightJMT(), DC_Data, 1, null);		
	endforeach;

	// pieces / volume / weight
	blockObj	:=	_dataContainer.addNewBlock;
	blockObj.addNewItem("", DC_LabelHeader, 1, null);
	blockObj.addNewItem(app.getErrorString(CM_Number_Of_Items), DC_LabelHeader, 1, null);
	blockObj.addNewItem(app.getErrorString(CM_Quantity), DC_LabelHeader, 1, null);
	blockObj.addNewItem(app.getErrorString(CM_VolumeM3), DC_LabelHeader, 1, null);
	blockObj.addNewItem(app.getErrorString(CM_Weight_Kgs), DC_LabelHeader, 1, null);
//	blockObj.addNewItem("", DC_LabelHeader, 1, null);
//	blockObj.addNewItem("", DC_LabelHeader, 1, null);
	
	if displayMode = DISPLAY_MODE_PLAN then
		if isAccessRestricted then
			itemDisplay	:=	"0";
		else
			itemDisplay	:=	self.numPlannedTIs.String;
		endif;
		
		itemDisplay	:=	itemDisplay &amp; " (Planned View)";
		
	elseif displayMode = DISPLAY_MODE_QUEUE then
		if isAccessRestricted then
			itemDisplay	:=	"0";
		else
			itemDisplay	:=	self.numQueuedTIs.String;
		endif;
		
		itemDisplay	:=	itemDisplay &amp; " (Queued View)";
		
	else
		itemDisplay	:=	itemTotal.String;
	endif;
	
	blockObj	:=	_dataContainer.addNewBlock();
	blockObj.addNewItem("TOTAL  ", DC_Data, 1, null);
	blockObj.addNewItem(itemDisplay, DC_Data, 1, null);
	blockObj.addNewItem(quantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	blockObj.addNewItem(totVolume.jasVolumeString(), DC_Data, 1, null);
	blockObj.addNewItem(totWeight.String, DC_Data, 1, null);
	
	// Add the spec details after the summary details.
	_dataContainer.addMultipleBlocks(allBlocksArray);
epilog
	delete allBlocksArray;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
</Class>
