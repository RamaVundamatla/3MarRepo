/*

Purpose:		

Date			Who		Reason
17 February 2017	cnwmh5	Initial creation

*/

vars

	schema						: Schema;
	klass						: Class;
	classObj					: Object;

begin

	schema := rootSchema.getSchema("DevSchema");
	if schema = null then
		app.msgBox("Schema DevSchema not found", "TestLink Test Case Run Details Error", MsgBox_OK_Only);
		return;
	endif;
		
	klass := schema.getClass("DevSchema");
	if klass = null then
		app.msgBox("Class DevSchema not found", "TestLink Test Case Run Details Error", MsgBox_OK_Only);
		return;
	endif;
	
	create classObj as klass transient;
	classObj.sendMsgWithIOParams("getTestLinkRunDetails");
	
epilog

end;</source>
