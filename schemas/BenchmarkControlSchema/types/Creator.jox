	else
		copies:=20;
		copies:=10;
		//profile:="All5";  // in startApp method
		//port:=myBmkControl.bmkBasePort.Integer + appSequenceId mod 60; // was this 01/03/2008
		port:=myBmkControl.bmkBasePort.Integer + appSequenceId mod 20;
//		port:=myBmkControl.bmkBasePort.Integer;
	endif;
end;</source>
