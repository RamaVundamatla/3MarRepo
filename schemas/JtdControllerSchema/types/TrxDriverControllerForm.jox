    <JadeMethod name="mnuDrvPopSaveAsText_click" id="60b9a024-856b-42e7-8d67-126639745c1e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDrvPopSaveAsText_click(menuItem: MenuItem input) updating;

vars
	errTxt, fileName : String;
	errNo : Integer;
	
begin
	fileName := self.getSaveTableAsTextFileName(self.lastSaveDrvTblFileName);
	
	if fileName = null then
		return;
	endif;

	app.mousePointer := Busy;
		
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	self.doSaveTableAsText(self.tblDrivers, self.tblDrivers.fixedRows, fileName);
	
	if errNo &lt;&gt; 0 or errTxt &lt;&gt; null then
		app.msgBox("Error saving file: " &amp; fileName &amp; CrLf &amp; CrLf &amp;
			'[' &amp; errNo.String &amp; "] " &amp; errTxt, "Error Saving File",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		self.lastSaveDrvTblFileName := fileName;
	endif;
	
epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
