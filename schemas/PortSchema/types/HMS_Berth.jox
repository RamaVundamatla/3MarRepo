    <JadeMethod name="setForUpdate" id="0d1a272d-d6f5-4d2d-82e5-66d199c1cd96">
        <updating/>
        <source>setForUpdate(_pxyBerth : HMS_Berth; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
// Cbanged On	By			Reason
// ----------	--------	------------------------------------
// 22/06/2018	jlgdap1		TFS 39373 PEL1 Berth Tug Default
// 02 Oct  2018 nwma1  		ChangeRequest 41234: SAP Integration - Mapping fields
vars

begin
	inheritMethod(_pxyBerth, _passport);
	
	self.code 			:= _pxyBerth.code.toUpper.trimBlanks;
	self.colour 		:= _pxyBerth.colour;
	self.defaultCargoOperation	:= _pxyBerth.defaultCargoOperation;
	self.description 	:= _pxyBerth.description;
	self.minimumDepth 	:= _pxyBerth.minimumDepth;
	self.noMarineServices := _pxyBerth.noMarineServices;
	self.myHarbour 		:= _pxyBerth.myHarbour;
	self.myWharf 		:= _pxyBerth.myWharf;
	self.autoAllocateBerth := _pxyBerth.autoAllocateBerth;
	
	self.externalReference1 := _pxyBerth.externalReference1;	//15 May 2018	NDL	TFS 38587
	self.externalReference2 := _pxyBerth.externalReference2;	//15 May 2018	NDL	TFS 38587
	self.externalReference3 := _pxyBerth.externalReference3;	//15 May 2018	NDL	TFS 38587
	self.externalReference4 := _pxyBerth.externalReference4;    //02.10.2018 cnwma1 TFS #41234
	
	self.requiresLengthOfTime := _pxyBerth.requiresLengthOfTime;	//27 Jul 2018	NDL	TFS 39932
	
	self.baseToBaseTugDuration := _pxyBerth.baseToBaseTugDuration;	//13 Nov 2018	NDL	TFS 41964 
	
	self.defaultTugUsageHours := _pxyBerth.defaultTugUsageHours;		// TFS 39373
	
	self.myRoot := _pxyBerth.myRoot;	// 10 May 2012	NDL	Par 29537

	self.setStartPositionLength(_pxyBerth.startPosition, _pxyBerth.length);
	
	if app.isConverting then
		self.myHarbourArrvBerth := _pxyBerth.myHarbourArrvBerth;
		self.myHarbourDepartBerth := _pxyBerth.myHarbourDepartBerth;
		self.myHarbourRegion := _pxyBerth.myHarbourRegion;
	endif;
	
	if self.myWharf &lt;&gt; null then
		self.myWharf.updateWharfSections();
	endif;
	
	self.paymentType := _pxyBerth.paymentType;		// 22/6/18 MAP TFS39250

end;</source>
        <Parameter name="_pxyBerth" type="HMS_Berth"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
