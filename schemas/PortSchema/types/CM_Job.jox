    <JadeMethod name="erase" id="6f1a3a05-5d77-446d-a40d-fbde0372dfca">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 Sep 2006	cnwer1	Initial creation - PAR#xxxx
29 May 2025	navhl20 Bug MTN-34847: MTN - 1081 (Dead loock) on CM_JobsByRequiredDTPriority
*/
vars
	jobsheet	: CM_WorkOrderJobSheet;
begin

	self.eraseAlerts();
	
	jobsheet := self.myJobSheetForWorkOrder;																//29.05.2025 navhl20 #34847
	//jlier1 MTN-34200 11/3/24
	if jobsheet &lt;&gt; null and not self.isTransient then														//29.05.2025 navhl20 #34847
		self.exclusiveLock(jobsheet.allJobsByRequiredDTPriority);											//29.05.2025 navhl20 #34847
		self.causeEvent(jobsheet.myTerminal.getTerminalEvent(WorkOrderJob_Delete_Event), false, self);		//29.05.2025 navhl20 #34847
	endif;
	
	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseAlerts" id="7ab4adb9-b697-4b79-a11a-1fc68f5d945d">
