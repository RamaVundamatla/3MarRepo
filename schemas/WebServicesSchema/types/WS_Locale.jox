    <JadeMethod name="setProxyFromObject" id="bc833b95-00aa-422d-9373-c587259e97cc">
        <updating/>
        <source>setProxyFromObject(_object: CM_Locale) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 June 2017	cnwam15	Initial creation TFS#5193 Return a list of locales for the user

*/

vars

begin
	inheritMethod(_object);
	self.localeId 		:= _object.localeId;
	self.description 	:= _object.localeDescription;
	self.displayLocale	:= _object.vLocaleIdAndDescription;
	

epilog

end;</source>
        <Parameter name="_object" type="CM_Locale"/>
    </JadeMethod>
