    <JadeMethod name="lstAttributes_displayRow" id="5dae7b4c-43b6-49ec-9c38-c1dbeff4e835">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAttributes_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	selected	: Boolean;

begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	if selected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.CMIF_YAOverstowAttributeType.description;
	else
		return  TableCheckBox_NotSelected &amp; Tab &amp; obj.CMIF_YAOverstowAttributeType.description;
	endif;	

	


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
