    <JadeMethod name="txtTrackedItemID_keyDown" id="e0906f8d-3676-4076-b292-9cfc203ac08c">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTrackedItemID_keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
//----------------------------------------------------------------
//	Created:	05 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//first change is not always picking up changes (i.e. when text is overtyped)
	if not self.hasFieldChanged and keyCode &gt; 47 then
		self.hasFieldChanged := true;
	endif;

end;</source>
