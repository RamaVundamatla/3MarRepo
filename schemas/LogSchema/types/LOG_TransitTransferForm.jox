        <updating/>
        <source>tblSelectData_dblClick(table: Table input) updating;
//--------------------------------------------------
// Created:	20 January 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	if table.row &gt; table.fixedRows
	and table.row &lt;= table.rows
	and self.optLogID.value then
		self.myAssistant.showCargoEnquiry(table.accessRow(table.row).itemObject.CM_TrackedItem);
	endif;
end;</source>
