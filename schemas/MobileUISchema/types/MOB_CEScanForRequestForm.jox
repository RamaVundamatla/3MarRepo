    <JadeMethod name="setAllReleases" id="c15012f6-ac8d-44d1-ad4b-841235abffcb">
        <updating/>
        <source>setAllReleases(_releases : CM_BulkReleaseSet) updating;
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	releaseObj	: CM_BulkRelease;
	
begin
	self.allBulkReleases.clear();
	_releases.copy(self.allBulkReleases);
	self.loadPackingReqTbl(self.tbl_PackingRqst);
	
	if self.allBulkReleases.isEmpty() then
		txt_Remarks.text :='';
	else
		releaseObj	:=	self.allBulkReleases.first();
		txt_Remarks.text := releaseObj.getRemarks();
	endif;
end;</source>
        <Parameter name="_releases" type="CM_BulkReleaseSet"/>
    </JadeMethod>
