    <JadeMethod name="doTerminate" id="9a10e6a3-bd70-4788-9e47-a18f4a14b609">
        <updating/>
        <source>doTerminate() protected, updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
begin
	if app.computerName().toUpper() = "CNWDAD1A" then//or app.computerName().toUpper() = "CNWDVB1A" then
		self.unloadForm();
		return;
	endif;
	
	if app.msgBox('Terminate', 'Terminate', MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		self.unloadForm();
	endif;
end;</source>
