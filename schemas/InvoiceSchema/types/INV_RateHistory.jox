    <JadeMethod name="checkSignedPercentage" id="39e5cbb0-296b-4be0-8cd0-73cda022f687">
        <source>checkSignedPercentage(_value : String input; _isPercentage : Boolean output):Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2012	cnwrns1	Initial creation

*/

vars
	intPosPercentage 	: Integer;
	strValue			: String;
	decValue			: Decimal [13,6];
	precisionError		: Boolean;
begin
	on Exception do app.handlePrecisionError(exception, precisionError);
	
	intPosPercentage :=  _value.pos("%",1);
	if intPosPercentage &lt;&gt; null then
		 strValue :=  _value.truncatedAt(intPosPercentage.Integer - 1);
		 _isPercentage := true;
	else
		_isPercentage := false;
		strValue := _value;
	endif;
	
	decValue :=  strValue.getRealFromText;
	if precisionError then
		app.msgBox("Too many digits in the Increment value", app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
	endif;
	return decValue;
epilog

end;</source>
        <Parameter name="_value" type="String" usage="input"/>
        <Parameter name="_isPercentage" type="Boolean" usage="output"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="chkIgnoreEntry_lostFocus" id="8f2cb8e3-d3e7-4edd-a86a-5d8f5fe95816">
        <controlMethod name="CheckBox::lostFocus"/>
