    <JadeMethod name="isInYACriteriaForm" id="dde5e360-ea9b-48ce-ace2-0883cc0429e8">
        <source>isInYACriteriaForm() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues

*/

vars
	form : Form;
begin
	form := self.form;
	
	if form &lt;&gt; null then
		return form.isKindOf(CMUI_YAMaintForm);
	endif;
	
	return false;
epilog

end;</source>
