    <JadeMethod name="getSelectedRTQueueEntries" id="c3d16df0-cae8-49a0-bd50-5c1dbf15afd3">
        <source>getSelectedRTQueueEntries(_allSelectedEntries : CM_RTQueueEntrySet input)  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation
24 Jan  2020    cnwma1	Bug 48273: PEN - 1309 when refreshing (old) VMT
*/

vars
	itemObject : Object;
	allSelectedRows : StringArray;
	row 			: String;
	invalidObj 		: Boolean;
	qEntry 			: CM_RTQueueEntry;
begin
	on Exception do app.handleDeletedObject(exception,itemObject,	invalidObj);
	//epr par 25048 11/7/11 never handled multi select table items
	allSelectedRows:=self.tblTasks.tag.getTokens();
	foreach row in allSelectedRows do
		if row.Integer &gt; self.tblTasks.rows then
			continue;
		endif;
		if row.Integer &lt;= self.tblTasks.fixedRows then
			continue;
		endif;
		invalidObj:=false;
		itemObject:=self.tblTasks.accessRow(row.Integer).itemObject;
		if itemObject.isKindOf(DTO_RTQueueEntry) then
			qEntry:=itemObject.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
			if invalidObj then
				continue;
			endif;
			_allSelectedEntries.addNoDuplicates(qEntry,false);  // 2401.2020 cnwma1 #48273
		endif;
	endforeach;
	
	
epilog
	delete allSelectedRows;
end;</source>
        <access>protected</access>
        <Parameter name="_allSelectedEntries" type="CM_RTQueueEntrySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTIs" id="73fd712f-c6a6-4520-b35c-b7d4bdea8e65">
        <source>getSelectedTIs(_allSelectedTIs : CM_TISet input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation
14 Oct 2011		cnwer1	PAR 28458
*/

vars
	theRow,
	theAcceptedRow : Integer;
	acceptedTI		: CM_TrackedItem;
	theItemObject 	: Object;
begin
	if self.tblTasks.rows =  self.tblTasks.fixedRows then 
		return;
	endif;
	
	theRow:= self.tblTasks.fixedRows +1;
	
	while theRow &lt;= self.tblTasks.rows do
		if self.tblTasks.accessRow(theRow).fontBold then
			theAcceptedRow:=theRow;
			//14 Oct 2011		cnwer1	PAR 28458
			theItemObject:=self.tblTasks.accessRow(theAcceptedRow).itemObject;
			if self.tblTasks.accessRow(theAcceptedRow).itemObject.isKindOf(CM_TrackedItem) then
				acceptedTI := theItemObject.CM_TrackedItem;
			endif;
			if acceptedTI &lt;&gt; null then
				_allSelectedTIs.add(acceptedTI);
			endif;
		endif;
		theRow:=theRow + 1;
	endwhile;


	

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allSelectedTIs" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTasks" id="6204e0eb-a030-4599-9e77-32fd53db8e63">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::getSelectedTasks"/>
        </interfaceImplements>
        <source>getSelectedTasks(_selectedTasks :  CM_RTQueueTaskArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwer1	Initial creation

*/

vars
	theAcceptedRow : Integer;
	obj : Object;
	selectedRow		: Integer;
	allSelectedRows  : StringArray;
	isTwin: Boolean;
	queueTask: CM_RTQueueTask;
begin
	
	if self.frmGetTask.visible then
		self.myMachine.allCurrentQueueTasks.copy(_selectedTasks);
		return;
	endif;
	
	theAcceptedRow:=0;
	
	//nothing to check
	if self.tblTasks.rows =  self.tblTasks.fixedRows then 
		return;
	endif;
	
	isTwin := true;
	if  self.btnTandem.visible and self.btnTandem.value then
		allSelectedRows:=self.tblTasks.tag.getTokens();
		// CCMS 1210
		if allSelectedRows.size = 1 then
			selectedRow := allSelectedRows.first.Integer;
			if selectedRow &lt;= self.tblTasks.rows then
				obj := self.tblTasks.accessRow(selectedRow).itemObject;
				app.myVMAgent.findTwinTask(obj.DTO_RTQueueEntry,_selectedTasks, isTwin);
			endif;
		elseif allSelectedRows.size = 2 then
			selectedRow := allSelectedRows.first.Integer;
			if selectedRow &lt;= self.tblTasks.rows then
				obj := self.tblTasks.accessRow(selectedRow).itemObject;
				queueTask := app.myVMAgent.getQueueTask(obj.DTO_RTQueueEntry);
				if queueTask &lt;&gt; null then
					_selectedTasks.add(queueTask);
				endif;
			endif;
			selectedRow := allSelectedRows.last.Integer;
			if selectedRow &lt;= self.tblTasks.rows then
				obj := self.tblTasks.accessRow(selectedRow).itemObject;
				queueTask := app.myVMAgent.getQueueTask(obj.DTO_RTQueueEntry);
				if queueTask &lt;&gt; null then
					_selectedTasks.add(queueTask);
				endif;
			endif;
			
			
		endif;
		/*	
		foreach selectedRow in allSelectedRows do
			//epr par 24666 25/6/10
			if selectedRow.Integer &lt;= self.tblTasks.rows then
				obj := self.tblTasks.accessRow(selectedRow.Integer).itemObject;
				app.myVMAgent.findTwinTask(obj.DTO_RTQueueEntry,_selectedTasks, isTwin);
			endif;
		endforeach;
		*/
	else
		theAcceptedRow:=self.tblTasks.row;
		obj := self.tblTasks.accessRow(theAcceptedRow).itemObject;
		////epr par 24942 9/7/10
		if obj = null then
			return;
		endif;
		//epr par 25518 20/8/10
		if not obj.isKindOf(DTO_RTQueueEntry) then
			return;
		endif;
        // CCMS SFW 1210
		isTwin := not self.btnTandem.visible or self.btnTandem.value;
		app.myVMAgent.findTwinTask(obj.DTO_RTQueueEntry,_selectedTasks, isTwin);
	endif;
	
epilog
	delete allSelectedRows;
end;</source>
        <Parameter name="_selectedTasks" type="CM_RTQueueTaskArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSetdownLocID" id="f18819fd-ddc4-4ee6-98f4-dd966e1ee116">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::getSetdownLocID"/>
        </interfaceImplements>
        <source>getSetdownLocID() : String;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
	accessCell : JadeTableCell;
	col : Integer;
begin
	
	if self.myMoveTableDetails.isEntRowNameVisible(ETRow_IcArea)  then
		return self.myMoveTableDetails.getDataForEntRowName(ETRow_IcArea);
	else
		if app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen  then
			self.myMoveTableDetails.setDataColumn(3); 
		endif;
		 //epr par 34682 4/8/14 getDataForEntRowName returns false if row not visible we need value regardless because now this row might be hidden
		row:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID);
		
		//15 Jan 2016	NDL	Par 37374
		col := self.myMoveTableDetails.dataColumn;	
		if col &lt; 1 then
			return null;
		endif;
		
		//if row &gt;  0 then
		if row &gt; 0 and col &lt;= self.myMoveTableDetails.myTable.rows then	//15 Jan 2016	NDL	Par 37374
			accessCell:=self.myMoveTableDetails.myTable.accessCell(row,self.myMoveTableDetails.dataColumn);
			if accessCell &lt;&gt; null then
				return accessCell.text;
			endif;
		endif;
		
		return self.myMoveTableDetails.getDataForEntRowName(ETRow_TargetID);
	
		
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSetdownTwinLocID" id="a4302e44-d658-4b3d-b914-17adf2bcd045">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::getSetdownTwinLocID"/>
        </interfaceImplements>
        <source>getSetdownTwinLocID() : String;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwer1	Initial creation

*/

vars
	row : Integer;	
	accessCell : JadeTableCell;
begin
	if self.myMoveTableDetails.isEntRowNameVisible(ETRow_IcArea)  then
		return self.myMoveTableDetails.getDataForEntRowName(ETRow_IcArea);
	else
	
		if app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen  then
			self.myMoveTableDetails.setDataColumn(5);
			 //epr par 34682 4/8/14 getDataForEntRowName returns false if row not visible we need value regardless because now this row might be hidden
			row:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID);
			if row &gt;  0 then
				accessCell:=self.myMoveTableDetails.myTable.accessCell(row,self.myMoveTableDetails.dataColumn);
				if accessCell &lt;&gt; null then
					return accessCell.text;
				endif;
			else
				return self.myMoveTableDetails.getDataForEntRowName(ETRow_TargetID);
			endif;
		endif;
		
		if self.myMachine.isTandemLift then
			return self.myMoveTableDetails.getDataForEntRowName(ETRow_TandemTargetID);
		else
			return self.myMoveTableDetails.getDataForEntRowName(ETRow_TwinTargetID);
		endif;
	endif;

epilog
	self.myMoveTableDetails.setDataColumn(DataColumn);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
