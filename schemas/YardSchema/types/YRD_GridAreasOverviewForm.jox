    <JadeMethod name="doMnuAttachGenSet" id="9f27755b-b97a-412a-85ee-2d9921f0efbf">
        <updating/>
        <source>doMnuAttachGenSet( menuItem: MenuItem ) updating, protected;
/* ---------------------------------------------------------------------------
Created:	01 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	form	: CMUI_AttachGenSet;
	anObject: Object;
	theTI	: CM_TrackedItem;

begin

	anObject := menuItem.userObject;
	if anObject = null then 
		return;
	endif;
	
	if not anObject.isKindOf(CM_Container) and not anObject.isKindOf(CM_TILC) then
		return;
	endif;
	self.mousePointer := Window.MousePointer_HourGlass;
	
	theTI := anObject.CM_TrackedItem;
	create form;
	form.centreWindow;
	form.myTrackedItem := theTI;
	form.setMyTerminal(self.myTerminal);
	form.setFormParent( self );
	//form.myTerminalArea := theTI.myTerminalArea;
	form.showModal;
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
