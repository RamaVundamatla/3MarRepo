<Class name="CM_TrxControlPostDeleteAgent" id="5410ef3a-1431-4adc-9824-17eadca9d22a">
    <superclass name="CM_TrxControlDeleteAgent"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="handleCargoGroupDetlGeneration" id="4b7e23c8-26c3-4027-b787-09fe85fffc72">
        <updating/>
        <source>handleCargoGroupDetlGeneration(_includeNotes : Boolean) updating;
/*
Purpose:			Copied from CM_TrxControlPostUpdateAgent

Date		Who		Reason
07/09/2023	navkc1	CR 60376 Task 60377: Jade - Cargo Group Regions
*/

vars
	trxPA : CMIF_TrxPostAction;
	cargoGroup : CM_CargoGroup;
	voyages : CM_VoyageSet;
	voyage : CM_Voyage;

begin

	if app.myPassport.trxCompletedOK()  then
	
		if _includeNotes then
			create voyages transient;
			foreach trxPA in app.myPassport.allTrxPostActions where trxPA.isCargoGroup() do
			
				cargoGroup := trxPA.CMIF_TrxActionCargoGroup.myCargoGroup;
				if cargoGroup &lt;&gt; null then
					cargoGroup.getCargoGroupMyVoyage(voyages);
				endif;
			endforeach;
		endif;
	
		app.myPassport.doTrxPostActions();		
		
		if _includeNotes then
			foreach voyage in voyages discreteLock do
				voyage.causeEvent( app.myPassport.myTerminal.getTerminalEvent(EVENT_CARGOGROUP_UPDATE), true, cargoGroup );	
			endforeach;
		endif;
	endif;	
epilog
	delete voyages;
end;</source>
        <Parameter name="_includeNotes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteBGPRequest" id="9c3f270d-76e6-4fd9-8c5b-7a1a2bc004e1">
        <updating/>
        <source>trxDeleteBGPRequest(_manager: BGP_Manager; _request: BGP_Request io; _sendCompletedNote: Boolean; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_manager, _request, _sendCompletedNote, _passport);
	if _passport.trxCompletedOK()  then
		_passport.doTrxPostActions();		
	endif;
epilog

end;</source>
        <Parameter name="_manager" type="BGP_Manager"/>
        <Parameter name="_request" type="BGP_Request" usage="io"/>
        <Parameter name="_sendCompletedNote" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteCustDocHeader" id="40d99812-5c6d-441d-a806-df9ee80772cb">
        <updating/>
        <source>trxDeleteCustDocHeader(_obj: CM_CustomDocument io; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/09/2023	navkc1	CR 60376 Task 60377: Jade - Cargo Group Regions

*/

vars

begin
	inheritMethod(_obj, _passport);
	
	self.handleCargoGroupDetlGeneration(true);
epilog

end;</source>
        <Parameter name="_obj" type="CM_CustomDocument" usage="io"/>
