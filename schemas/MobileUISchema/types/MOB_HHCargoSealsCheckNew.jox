    <JadeMethod name="clickBtnOK" id="46f75dd8-bdd8-41cf-88d1-b224940a5d19">
        <updating/>
        <source>clickBtnOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	mess : String;
	startPos : Integer;
	endPos : Integer;
 
begin

	startPos := tblSeals.fixedRows + 1;
	endPos := tblSeals.rows;
	if startPos &gt; tblSeals.rows then
		//no data to process
		return;
	endif;

	if sealCheckType = SEAL_CHECK_NONE then // 1
		// should never get here, OK button is disabled in this mode.
		mess := app.getErrorString1(Seal_check_mode, app.sealCheckTypeEnumToString(SEAL_CHECK_NONE) );
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		self.clickBtnBack();
		return;

	elseif self.sealCheckType = SEAL_CHECK_VIEW then	// 2
		if self.processViewChecks(startPos, endPos) then
			self.clickBtnBack();
			return;
		endif;		
	
	elseif self.sealCheckType = SEAL_CHECK_FULL then	// 3
		if self.processFullChecks(startPos, endPos) then
			self.clickBtnBack();
			return;
		endif;			
	
	elseif self.sealCheckType = SEAL_CHECK_STRICT then	//4
		if self.processStrictChecks(startPos, endPos) then
			self.clickBtnBack();
			return;
		endif;
	
	else
		mess := app.getErrorString(Invalid_seal_check_type) &amp; " [" &amp; self.sealCheckType.String &amp; "]" &amp; CrLf &amp; app.getErrorString(Contact_developer);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		
	endif;

epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="createPxyTiSealCheckDetail" id="589e2b51-f0b9-48af-b016-d6fbc9acd2a9">
        <source>createPxyTiSealCheckDetail(	_sealCheck : CM_SealCheck;
							_sealAfter : String;
							_sealBefore : String;
							_sealCheckType : Integer;
							_sealType : String;
							_viewed : Integer
							) : CM_SealCheckDetail;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	sealCheckDetail : CM_SealCheckDetail;

begin

	create sealCheckDetail transient;
	
	sealCheckDetail.setProxy(	_sealCheck,	//_sealCheck : CM_SealCheck;
								_sealAfter,	//_sealAfter : String;
								_sealBefore,	//_sealBefore : String;
								_sealCheckType,	//_sealCheckType : Integer;
								_sealType,	//_sealType : String;
								_viewed	//_viewed : Integer;
								);
								
	return sealCheckDetail;

epilog

end;</source>
        <Parameter name="_sealCheck" type="CM_SealCheck"/>
        <Parameter name="_sealAfter" type="String"/>
        <Parameter name="_sealBefore" type="String"/>
        <Parameter name="_sealCheckType" type="Integer"/>
        <Parameter name="_sealType" type="String"/>
        <Parameter name="_viewed" type="Integer"/>
        <ReturnType type="CM_SealCheckDetail"/>
    </JadeMethod>
    <JadeMethod name="createPxyWagonSealCheckDetail" id="b0ed7b63-24b2-447d-9fc1-d802aaf7e0d6">
        <source>createPxyWagonSealCheckDetail(	_objArray : ObjectArray input;
								_sealAfter : String;
								_sealBefore : String;
								_sealCheckType : Integer;
								_sealType : String;
								_viewed : Integer
								) : CM_SealCheckDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2015	cnwndl1	Initial creation

*/

vars

	sealCheckDetail : CM_WagonSealCheckDetail;

begin

	create sealCheckDetail transient;
	
	sealCheckDetail.setProxy(	null,	//_sealCheck : CM_SealCheck;
								_sealAfter,	//_sealAfter : String;
								_sealBefore,	//_sealBefore : String;
								_sealCheckType,	//_sealCheckType : Integer;
								_sealType,	//_sealType : String;
								_viewed	//_viewed : Integer;
								);
	
	_objArray.add( sealCheckDetail );
	return sealCheckDetail;

epilog

end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <Parameter name="_sealAfter" type="String"/>
        <Parameter name="_sealBefore" type="String"/>
        <Parameter name="_sealCheckType" type="Integer"/>
        <Parameter name="_sealType" type="String"/>
        <Parameter name="_viewed" type="Integer"/>
        <ReturnType type="CM_SealCheckDetail"/>
    </JadeMethod>
    <JadeMethod name="createTiSealCheckTransaction" id="338c383d-dc67-47f8-9a0c-f73d9376f3ad">
        <source>createTiSealCheckTransaction(	_proxySealCheckTrx 	: CM_SealCheck io;
								_updateSealsArray 	: CM_ObjectArray;
								_passport 			: CM_Passport input
								) : CM_SealCheck;

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
08 Sep 2010	cnwndl1	Par 25608	Initial creation part of SFW CCMS 1131			
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	trackedItem			: CM_TrackedItem;
	theTIProxy 			: CM_TrackedItem;
	mess 				: String;
	txnController 		: CMIF_TITransactionController;
	newTITxn 			: CM_TITransaction;
	toDoTaskDescToAdd 	: CM_ToDoTaskDesc;
	tiUpdateRequired 	: Boolean;
	obj 				: Object;
	updateSealType 		: CM_SealType;
	pxySealCheckDetail 	: CM_SealCheckDetail;
	sealAfter 			: String;
	sealBefore 			: String;
	pxySealTi 			: CM_SealTI;
	sealedDT 			: TimeStamp;
	loadState 			: Boolean;
	sealNumArray 		: HugeStringArray; //jlgka1 TFS 44020
	editFieldsValues 	: HugeStringArray; //jlgka1 TFS 44020
	result 				: Integer;
begin

	app.mousePointer :=	Busy;

	trackedItem := self.myMobileGenericAgent.myNextTiToAction;
	if trackedItem = null then
		mess := app.getErrorString(NO_Cargo_found);
		app.mousePointer :=	Idle;
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return null;
	endif;
	
	_proxySealCheckTrx.setMyTrackedItem(trackedItem,null);
	theTIProxy := trackedItem.pxyGetProxyObject;

	create txnController transient;
	txnController.type := TRANS_TYPE_SEAL_CHECK;
	txnController.noCharge := false; //TFS 3844 changed to false
	txnController.myTrackedItem := trackedItem;
	txnController.myTITransaction := _proxySealCheckTrx;

	
	//Add the to do task to the TI proxy if required.
	toDoTaskDescToAdd := self.getToDoTaskDescToAdd( trackedItem );
	if toDoTaskDescToAdd &lt;&gt; null then
		tiUpdateRequired := true;
		theTIProxy.addToDoTask( toDoTaskDescToAdd.description, _passport );
	endif;
	
	//Update the seal values on the proxy TI, for the ones that the user said they wanted updated. (Can only happen in 'Full' mode) 
	if _updateSealsArray &lt;&gt; null and not _updateSealsArray.isEmpty then
	
		app.cmsBeginLoad(loadState);
		tiUpdateRequired := true;
		create editFieldsValues transient;

		foreach obj in _updateSealsArray do

			updateSealType := obj.CM_SealType;
			pxySealCheckDetail := _proxySealCheckTrx.getSealCheckDetailForSealType( updateSealType.sealType );
			if pxySealCheckDetail = null then
				// we had an object that we were supposed to make changes from and now its gone ???
				mess := app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"pxySealCheckDetail = null");
				app.mousePointer :=	Idle;
				self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
				return null;
			endif;
			sealAfter := pxySealCheckDetail.sealAfter;
			sealBefore := pxySealCheckDetail.sealBefore;
			// find the existing seal data on the proxy ti. If its there, update it, otherwise create it.
			pxySealTi := theTIProxy.getSealTI(updateSealType);
			if pxySealTi = null then
				//create it.
				create pxySealTi transient;
				sealedDT := app.actualTimeServer();
			else
				sealedDT := pxySealTi.sealedDT;
			endif;
			
			if updateSealType.allowMultipleSealNums then
				if sealAfter.pos(",",1) &gt; 0 then
					create sealNumArray transient;
					sealAfter.getTokensForDelimiterHuge(",",sealNumArray); //jlgka1 TFS 44020
				endif;
			endif;
		
			pxySealTi.setProxy(	sealAfter,	//_sealNum : String;
								sealNumArray,	//_sealNumArray : StringArray;
								sealBefore,	//_prevSeal : String;
								updateSealType.sealType,	//_sealType : String;
								sealedDT,	//_sealedDT : TimeStamp;
								theTIProxy	//_myTrackedItem : CM_TrackedItem
								);
								
			if sealNumArray &lt;&gt; null then
				delete sealNumArray;
			endif;
			
			//gather up the edit details for the CM_Edit transaction
			self.getSealUpdateEditTransDetails( pxySealTi, editFieldsValues );
			
		endforeach;
		app.cmsEndLoad(loadState);
		
	endif;

	//epr TFS 8129 12/12/17 need to handle warnings
	while true do	
		app.myTrxCA.trxCreateSealsCheckTransaction( txnController, theTIProxy, tiUpdateRequired, null, newTITxn, editFieldsValues, app.myPassport);

		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return newTITxn.CM_SealCheck;
			
		else
	
			result := app.showErrorWarningDialog("", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			return null;
		endif;
		return null;
	endwhile;
epilog

	delete txnController;
	delete sealNumArray;
	delete editFieldsValues;
	app.cmsEndLoad(loadState);
	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="_proxySealCheckTrx" type="CM_SealCheck" usage="io"/>
        <Parameter name="_updateSealsArray" type="CM_ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_SealCheck"/>
    </JadeMethod>
    <JadeMethod name="createWagonSealCheckTrans" id="9df0d67c-d353-45e3-beda-8e01000c1ac3">
        <source>createWagonSealCheckTrans(	_wagon : CM_Wagon;
							_pxyWagonCheckDetailArray : ObjectArray;
							_updateSealsArray : CM_ObjectArray;
							_context : Integer
							):CMEVT_WagonTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2015	cnwndl1	Initial creation	Par 36658

*/
vars

	mess : String;
	wagonTrx : CMEVT_WagonTransaction;
	pxyUpdateSealsArray : CM_ObjectArray;
	loadState : Boolean;
	obj : Object;
	obj2 : Object;
	pxySealCheckDetail : CM_WagonSealCheckDetail;
	updateSealType : CM_SealType;
	sealAfter : String;
	sealBefore : String;
	realWagonSeal : CM_WagonSeal;
	pxyWagonSeal : CM_WagonSeal;
	sealedDT : TimeStamp;
	result 		: Integer;

begin

	app.mousePointer :=	Busy;
	
	app.myPassport.clearErrorsWarnings();
	
	//Create proxy  seals for the updated seal values on the Wagon, for the ones that the user said they wanted updated. (Can only happen in 'Full' mode) 
	if _updateSealsArray &lt;&gt; null and not _updateSealsArray.isEmpty then
	
		create pxyUpdateSealsArray transient;
	
		app.cmsBeginLoad(loadState);
		//tiUpdateRequired := true;
		//create editFieldsValues transient;

		foreach obj in _updateSealsArray do

			pxySealCheckDetail := null; // clear the pxy check detail before we start
			updateSealType := obj.CM_SealType;
			
			//find the pxy check detail that matches the update 'sealType' we need to change
			foreach obj2 in _pxyWagonCheckDetailArray do
				pxySealCheckDetail := obj2.CM_WagonSealCheckDetail;
				if pxySealCheckDetail.sealType = updateSealType.sealType then
					//found it.
					break;
				endif;
				pxySealCheckDetail := null;
			endforeach;
			
			if pxySealCheckDetail = null then
				// we had an object that we were supposed to make changes from and now its gone ???
				mess := app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"pxySealCheckDetail = null");
				app.mousePointer :=	Idle;
				self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
				return null;
			endif;
			
			sealAfter := pxySealCheckDetail.sealAfter;
			sealBefore := pxySealCheckDetail.sealBefore;
			// find the existing seal data on the proxy ti. If its there, update it, otherwise create it.
			realWagonSeal := _wagon.getWagonSeal(updateSealType);
			if realWagonSeal = null then	
				sealedDT := app.actualTimeServer();
			else
				sealedDT := realWagonSeal.sealedDT;
			endif;
		
			create pxyWagonSeal transient;
			pxyWagonSeal.setProxy(	sealAfter,	//_sealNum : String;
									sealBefore,	//_prevSeal : String;
									updateSealType.sealType,	//_sealType : String;
									sealedDT,	//_sealedDT : TimeStamp;
									_wagon	//_myWagonVisit : CM_Wagon
									);
								
			pxyUpdateSealsArray.add( pxyWagonSeal );
			
		endforeach;
		app.cmsEndLoad(loadState);
		
	endif;
	
	//epr TFS 8129 12/12/17 need to handle warnings
	while true do
		app.myTrxCA.trxCreateWagonSealsCheckTrans( null, _wagon, wagonTrx, _pxyWagonCheckDetailArray, pxyUpdateSealsArray, _context, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return wagonTrx;
			
		else
			result := app.showErrorWarningDialog("", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			return null;
		endif;
		return null;
	endwhile;
epilog

	if pxyUpdateSealsArray &lt;&gt; null then
		pxyUpdateSealsArray.purge();
		delete pxyUpdateSealsArray;
	endif;

	app.cmsEndLoad(loadState);
	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_pxyWagonCheckDetailArray" type="ObjectArray"/>
        <Parameter name="_updateSealsArray" type="CM_ObjectArray"/>
        <Parameter name="_context" type="Integer"/>
        <ReturnType type="CMEVT_WagonTransaction"/>
    </JadeMethod>
    <JadeMethod name="doClickTableSeals" id="e436006a-b612-4a0e-b252-953d40bce5f1">
        <updating/>
        <source>doClickTableSeals() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	checkItem 	: CM_CargoCheckItem;
	jadeCell 	: JadeTableCell;
	selected	: Boolean;

begin

	if self.sealCheckType = SEAL_CHECK_NONE then
		return;
		
	elseif self.sealCheckType = SEAL_CHECK_VIEW then
		if tblSeals.row &lt;= tblSeals.fixedRows then
			return;
		elseif tblSeals.column &lt;= tblSeals.fixedColumns then
			return;
		endif;

		jadeCell := tblSeals.accessCell(tblSeals.row, tblSeals.column).cloneSelf(true);
		if not jadeCell.selected then
	
			jadeCell.selected 	:= true;
			selected 			:= true;
			
			if tblSeals.column = tblSeals.ColumnValue then
				jadeCell.picture := self.btnTickDown.createPicture(false, false, 32);
				tblSeals.accessCell(tblSeals.row, tblSeals.ColumnValueExtra).picture := self.btnCross.createPicture(false, false, 32);
				tblSeals.accessCell(tblSeals.row, tblSeals.ColumnValueExtra).selected := false;
				tblSeals.accessCell(tblSeals.row, tblSeals.ColumnValue).selected := true;
			elseif tblSeals.column = tblSeals.ColumnValueExtra then
				jadeCell.picture := self.btnCrossDown.createPicture(false, false, 32);
				tblSeals.accessCell(tblSeals.row, tblSeals.ColumnValue).picture := self.btnTick.createPicture(false, false, 32);
				tblSeals.accessCell(tblSeals.row, tblSeals.ColumnValue).selected := false;
				tblSeals.accessCell(tblSeals.row, tblSeals.ColumnValueExtra).selected := true;
			endif;
			
		endif;
		
	elseif self.sealCheckType = SEAL_CHECK_FULL then
		if tblSeals.row &lt;= tblSeals.fixedRows then
			return;
		elseif tblSeals.column &lt;= tblSeals.fixedColumns then
			return;
		endif;
		
	elseif self.sealCheckType = SEAL_CHECK_STRICT then
		if tblSeals.row &lt;= tblSeals.fixedRows then
			return;
		elseif tblSeals.column &lt;= tblSeals.fixedColumns then
			return;
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="d0b6b9b3-4a82-44f2-a499-5cfafd8624c8">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	tblHeight : Real;
	tabIndex : Integer;
	
	ti : CM_TrackedItem;
	hasToDoTask : Boolean;
	context : Integer;
	wagon : CM_Wagon;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.caption := app.getErrorString(Seals);
	endif;	
	
	self.myCargoCheckItem := app.myMobileAgent.myCargoCheckItem;
	if self.myCargoCheckItem &lt;&gt; null then
		if self.myCargoCheckItem.myToDoTaskDesc &lt;&gt; null then
			self.chkToDoTask.caption := self.myCargoCheckItem.myToDoTaskDesc.description;
			hasToDoTask := true;
		endif;
	endif;
	
	if _initialSetup then
		self.lblCargoId.setAndIncrementTabIndex( tabIndex );
		self.lblCargoId.visible := true;
	endif;
	self.lblCargoId.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	if _initialSetup then
		context := self.myMobileGenericAgent.checksState;
		if context.isOneOf( WAGON_CHECK_CONTEXT_PLACE_IN, WAGON_CHECK_CONTEXT_PLACE_OUT ) then
			wagon := self.myMobileGenericAgent.myCurrentWagon;
			if wagon = null then
				lblCargoId.caption := app.getErrorString(Unknown);
			else
				lblCargoId.caption := wagon.id;
			endif;
		else
			ti := self.myMobileGenericAgent.myNextTiToAction;
			if ti = null then
				lblCargoId.caption := app.getErrorString(Unknown);
			else
				lblCargoId.caption := ti.id;
			endif;
		endif;
		
	endif;
	
	
	top := self.lblCargoId.top + self.lblCargoId.height + self.resizedMargin;
	// total form height - height of button area at bottom - room for to opt buttons below - some spare room + offset.
	tblHeight := self.clientHeight - self.getCMDHeight() - top;
	
	if hasToDoTask then
		tblHeight := tblHeight - stdHeight - self.resizedMargin;
	endif;
	
	if _initialSetup then
		self.tblSeals.setAndIncrementTabIndex( tabIndex );
		self.tblSeals.visible := true;
	endif;
	self.tblSeals.move(	stdLeft,
						top,
						stdWidth - self.resizedMargin,
						tblHeight );
						
	
	if _initialSetup then
		self.lblNoChecks.setAndIncrementTabIndex( tabIndex );
		self.lblNoChecks.visible := false;
	endif;
	self.lblNoChecks.move(	stdLeft,
							top,
							stdWidth,
							tblHeight );
						
	if hasToDoTask then
		top := self.tblSeals.top + self.tblSeals.height + self.resizedMargin;
		if _initialSetup then
			self.chkToDoTask.setAndIncrementTabIndex( tabIndex );
			self.chkToDoTask.visible := true;
		endif;
		self.chkToDoTask.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	else
		if _initialSetup then
			self.chkToDoTask.visible := false;
		endif;
	endif;
	
	self.populateTblSeals();

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="745e0c22-cc89-40f6-9d0d-4b57ba9b8b1f">
        <source>getHelpDescr(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation

*/

vars

begin

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSealUpdateEditTransDetails" id="ed45bc05-a9d0-4c67-8ac9-b924547c3e38">
        <source>getSealUpdateEditTransDetails( pxySealTi : CM_SealTI; fieldsValues : HugeStringArray io ) protected;

/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
Date		Who		Reason
21 Sep 2010	cnwndl1	Par 25608	Initial creation	
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	realTi 			: CM_TrackedItem;
	oldSealTi 		: CM_SealTI;
	sealType 		: CM_SealType;
	newSealValue 	: String;
	prevSealValue 	: String;
	oldSealDt 		: TimeStamp;
	newSealDt 		: TimeStamp;
	tiTrxDetails 	: String;
begin
	realTi := self.myMobileGenericAgent.myNextTiToAction;
	
	sealType := app.myRoot.getSealType( pxySealTi.sealType );
	if sealType = null then
		return;
	endif;
	
	oldSealDt := null;
	newSealDt := null;
	if realTi &lt;&gt; null then
		prevSealValue := realTi.getSealValue(sealType);
		if sealType.sealType = SealType_Operator then
			oldSealTi := realTi.getSealTI(sealType);
			if oldSealTi &lt;&gt; null then
				oldSealDt := oldSealTi.sealedDT;
			endif;
		endif;
	endif;
	newSealValue := pxySealTi.getSealValueAsString;
	
	if prevSealValue &lt;&gt; newSealValue then
		if sealType.isSystemSealType then
		
			if sealType.sealType = SealType_Operator then
				tiTrxDetails := app.formatForEditTransaction( SealNum, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				newSealDt := pxySealTi.sealedDT;
				if newSealDt &lt;&gt; oldSealDt then
					tiTrxDetails := app.formatForEditTransaction( SealDT, oldSealDt.asStringJMT, newSealDt.asStringJMT );
					fieldsValues.add(tiTrxDetails);
				endif;
				
			elseif sealType.sealType = SealType_Shipper then
				tiTrxDetails := app.formatForEditTransaction( SealNumShippers, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				
			elseif sealType.sealType = SealType_Customs then
				tiTrxDetails := app.formatForEditTransaction( SealNumCustoms, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				
			elseif sealType.sealType = SealType_Vent then
				tiTrxDetails := app.formatForEditTransaction( SealNumVent, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
			endif;		
		else
			tiTrxDetails := app.formatForEditTransaction( sealType.description, prevSealValue, newSealValue );
			fieldsValues.add(tiTrxDetails);
			
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pxySealTi" type="CM_SealTI"/>
        <Parameter name="fieldsValues" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getToDoTaskDescToAdd" id="46f585c5-640e-4112-82b7-d7a7feb5dbc8">
        <source>getToDoTaskDescToAdd( _ti : CM_TrackedItem ) : CM_ToDoTaskDesc;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	toDoTaskDesc : CM_ToDoTaskDesc;
	
begin

	toDoTaskDesc := self.myCargoCheckItem.myToDoTaskDesc;
	if toDoTaskDesc &lt;&gt; null then
		// there is a task associated with te seal check.
		if self.chkToDoTask.value then
			//The user has requested this task to be set.
			if _ti.allToDoTasksToDo.includesToDoDesc( toDoTaskDesc.code ) then
				// its already been set on the ti, so don't worry about it.
				return null;
			else
				// it hasn't been set yet, pass it back.
				return toDoTaskDesc;
			endif;
		endif;	
	endif;
	
	//nothing to do.
	return null;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
