    </JadeMethod>
    <JadeMethod name="trxCreateOwnershipChangeDtls" id="7901a606-fb74-40ae-b344-a31235ff5619">
        <updating/>
        <source>trxCreateOwnershipChangeDtls(_cmifOwnershipDetails : CMIF_OwnershipChangeDetail io;
					  _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2023 navtnr20    TFS CR 58507    Task 58210: Jade - TRX CM_OwnershipChangeDetail

*/

vars
	theTerminal : CM_Terminal;
	pxyOwnershipDetail,
	realOwnnershipDetail : CM_OwnershipChangeDetail;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	foreach pxyOwnershipDetail in _cmifOwnershipDetails.allPxyOwnershipChangeDetails do
		app.myUtilityCA.utlCreateOwnershipChangeDetail(pxyOwnershipDetail,  realOwnnershipDetail,  _passport);
		
		if _passport.hasErrorsOrWarnings() then
			return;
		endif;
		
		_cmifOwnershipDetails.allRealOwnershipChangeDtls.add(realOwnnershipDetail);
	endforeach;
	
	//_cmifOwnershipDetails.postValidateAvailability(); //21/05/2024	navkc1 Bug 64182
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
