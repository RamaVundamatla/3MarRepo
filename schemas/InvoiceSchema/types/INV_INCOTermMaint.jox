    <JadeMethod name="btnSave_click" id="b30d92c7-7d39-4a38-ac76-bc7d822501a3">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	pxy : CM_InvoiceINCOTerm;
begin
	if not self.mode then
		self.createINCOTerm();
	else
		self.updatINCOTerm();
	endif;
	if self.myINCOTerm &lt;&gt; null  then
		self.btnAdd.enabled := true;
		self.btnRemove.enabled := true;
		self.btnUpdate.enabled := true;
		self.btnAudits.enabled := true;
	endif;
	
	//self.unloadForm();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdate_click" id="3186c01a-2f78-488c-9937-3e7502d61850">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	form : INV_INCOTermMapping;
	//pxyShipMapping : CM_InvoiceShipTermMapping;
	incoMapping:CM_InvoiceINCOMapping;
begin
	incoMapping := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceINCOMapping;
	if incoMapping = null then
		app.msgBox("No record selected", "Warning",MsgBox_OK_Only);
		return;
	endif;
	if incoMapping &lt;&gt; null then
		form := app.loadForm(INV_INCOTermMapping, INV_Assistant, false, false,false, self.myTerminal,null).INV_INCOTermMapping;
		if form &lt;&gt; null then
			form.mode := true;
			form.setINCOTerm(myINCOTerm);
			form.setINCOTermMapping(incoMapping);
			form.setMyCurrentBank(myCurrentBank);
			form.centreWindow();
			form.show;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="039b334e-6559-41a4-8c50-d4db5cc45e0a">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars

begin
	self.permissionView	:= PmInvINCOTermMaintView;
	self.permissionMaint := PmInvINCOTermMaintMaint;
	self.helpFileName := HelpFile_Invoicing;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createINCOTerm" id="e014f26e-a5de-41ae-8295-e0c797c16ff1">
        <updating/>
        <source>createINCOTerm()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	code, desc : String;
	bank : CM_Bank;
	pxyINCOTerm,
	realINCOTerm:CM_InvoiceINCOTerm;
	theReturn : Integer;
begin
	if self.txtCode &lt;&gt; null then
		code := self.txtCode.text.String;
	endif;
	if self.txtDescription &lt;&gt; null then
		desc := self.txtDescription.text.String;
	endif;
	create pxyINCOTerm transient;
	pxyINCOTerm.setProxy(code,desc,self.myCurrentBank);
	while true do
		app.myTrxCA.trxCreateInvINCOTerms(pxyINCOTerm, self.myINCOTerm, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			//self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Inco_term_created), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	delete pxyINCOTerm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="d78533c0-b339-485a-898c-b152524c20f3">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	dataLine	: String;
	shipTerm : CM_InvoiceINCOMapping;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_InvoiceINCOMapping) then
		shipTerm := userInfo.CM_InvoiceINCOMapping;
	elseif theObject.isKindOf(CM_InvoiceINCOMapping) then
		shipTerm := theObject.CM_InvoiceINCOMapping;
	endif;
	
	if event = Event_InvINCOMappingCreate then
		if shipTerm &lt;&gt; null then			
			self.tblDisplayRow();
		endif;
	elseif event = Event_InvINCOMappingUpdate then
		if shipTerm &lt;&gt; null then
			self.tblData.findObjectInRow(shipTerm,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := shipTerm.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_InvINCOMappingDelete then
		self.tblData.removeItemObject(shipTerm);
		self.doNotableClear();
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="df874675-fefb-49d6-ab7d-97f45a774e05">
        <source>doNotableAdd(_shipTerm: CM_InvoiceShipTermMapping);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	invalid : Boolean;
	ed : Integer;
begin
	
	self.allNotableObjects.add(_shipTerm);
	beginNotification(_shipTerm, self.myTerminal.getTerminalEvent(Event_InvINCOMappingUpdate), Response_Continuous, null);
	beginNotification(_shipTerm, EventFileAdd, Response_Continuous, null);
	beginNotification(_shipTerm, EventFileDelete, Response_Continuous, null);
epilog

end;</source>
        <Parameter name="_shipTerm" type="CM_InvoiceShipTermMapping"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="24163995-ab81-4725-8ee9-80a734868b05">
        <source>doNotableClear();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars

	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvINCOMappingUpdate));
		endNotification(anObject, EventFileAdd);
		endNotification(anObject, EventFileDelete);
	endforeach;
	
	self.allNotableObjects.clear;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissions" id="70bbcac4-bb64-49ab-ba56-7e93bc16ed3c">
        <source>doPermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnRemove.enabled := false;
		self.btnAdd.enabled := false;
		self.btnUpdate.enabled := false;
		self.tblData.enabled := false;
		self.txtCode.enabled := false;
		self.txtDescription.enabled := false;
		self.btnClose.enabled := true;
		self.btnSave.enabled := false;
		self.btnAudits.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="02b44970-28e4-4cd6-9d2d-f0afb7410c37">
        <updating/>
        <source>doRemove(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	theReturn : Integer;
	iNCOMapping	: CM_InvoiceINCOMapping;
	msgString : String;
begin
	iNCOMapping := _obj.CM_InvoiceINCOMapping;
	if iNCOMapping = null then
		app.msgBox("No record selected", "Warning",MsgBox_OK_Only);
		return;
	endif;
	if app.msgBox(app.getErrorString2(Sure_want_remov_invoi_inco_map, iNCOMapping.myDebtorType.description,null), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
 	app.myTrxDA.trxDeleteInvoiceINCOMapping(iNCOMapping, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
		else
			theReturn := app.showErrorWarningDialog("Invoice INCO Term", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doViewAudits" id="61c9ab27-6d6d-4364-bd86-46c9206d0fe9">
        <updating/>
        <source>doViewAudits(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars

begin
	if _obj = null then
		return;
	endif;

	if self.myAssistant = null then
		create self.myAssistant as CMUI_Assistant transient;
		self.myAssistant.setMyTerminal(self.myTerminal);		
	endif;
	
	app.viewAuditForm(_obj.CM_InvoiceINCOMapping, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="initTblINCOMapping" id="e18b246b-5967-41d3-94de-ca7616a70a19">
        <source>initTblINCOMapping(_theEntDef :String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblData;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_InvoiceINCOMapping);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblData);	
		//self.setFieldAlignmentOnTable(theTable);
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateINCOterms" id="01dd3dab-d6bd-4c4e-9bc7-4d99d2c6a418">
