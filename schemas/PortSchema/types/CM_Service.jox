    <JadeMethod name="setProxy" id="6698a3b8-9fbe-4980-9a89-4f0f3e21dc89">
        <updating/>
        <source>setProxy(_name: String; _bank: CM_Bank; _remarks: String; _gl: CM_GLCode; _group: CM_ServiceGroup; _rateType: Integer; _ct : CM_CalculationType;  _tax : CM_TaxCode;
		 _notAvailableForEntry : Boolean;
		 _externalRef1 : String;
		 _externalRef2 : String;
		 _serviceTypes : CM_ServiceTypeSet // 23/08/22	navkc1	#54569
		 ) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/3/22  jlier1	TFS 53286
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
vars

begin
	//inheritMethod(_name, _bank, _remarks, _gl, _group, _rateType, _ct, _tax, _notAvailableForEntry,_externalRef1,_externalRef2);
	inheritMethod(_name, _bank, _remarks, _gl, _group, _rateType, _ct, _tax, _notAvailableForEntry,_externalRef1,_externalRef2, _serviceTypes); // 23/08/22	navkc1	#54569
	self.defaultRateTable := _rateType;
	
	self.myCalculationType := _ct;
	self.externalReference1:=_externalRef1;
	self.externalReference2:=_externalRef2;
	
	// 23/08/22	navkc1	#54569 --&gt;
	self.allServiceTypes.clear();
	
	if _serviceTypes &lt;&gt; null and _serviceTypes.isNotEmpty() then
		_serviceTypes.copy(self.allServiceTypes);
	endif;
	// 23/08/22	navkc1	#54569 &lt;--
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_gl" type="CM_GLCode"/>
        <Parameter name="_group" type="CM_ServiceGroup"/>
        <Parameter name="_rateType" type="Integer"/>
        <Parameter name="_ct" type="CM_CalculationType"/>
        <Parameter name="_tax" type="CM_TaxCode"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_externalRef1" type="String"/>
        <Parameter name="_externalRef2" type="String"/>
        <Parameter name="_serviceTypes" type="CM_ServiceTypeSet"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="fc7c69df-fd8d-437c-9734-5ce6ffb11903">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_Service::defaultRateTable.name or
		propName = CM_Service ::myChildQuantityMap.name or
		propName = CM_Service ::myCalculationType.name or
		propName = CM_Service ::chargeByOpCon.name or
		propName = CM_Service ::chargeByUnits.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
	


end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
