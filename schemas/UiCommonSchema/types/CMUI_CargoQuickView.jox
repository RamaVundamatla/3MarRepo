    <JadeMethod name="setupForm" id="81489065-4212-48f7-8f4a-b9b92fa7216f">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date			Who		Reason
13 Feb 2009		cnwkpd1	PAR #18899 - Reverse setting of checkAccess to correctly reflect intent of
							PmCargoQuickViewNoDAC permission
//18 Jan 2017	cnwrs1	TFS 3137 - resize the find/replace form when show captions is on
21/05/2025		navlw1	JIRA-34824 MTN | Quick Cargo Review UI Refactor
*/

vars

begin
	inheritMethod();

	self.myQuickViewController.setTerminal(self.myTerminal);
	self.myQuickViewController.canDoPartialMatch	:= app.myPassport.myUser.canDo(self.myTerminal, PmCargoQuickViewPartial);
	self.myQuickViewController.checkAccess			:= not app.myPassport.myUser.canDo(self.myTerminal, PmCargoQuickViewNoDAC); // PAR #18899

	self.btnView.visible	:= app.myPassport.myUser.canDo(self.myTerminal, PmAdmCargoEnquiryView);
	self.btnEdit.visible	:= (self.btnView.visible and app.myPassport.myUser.canDo(self.myTerminal, PmAdmCargoEnquiryMaint));
	
	self.mnuEdit.visible 	:= self.btnEdit.visible;
	self.mnuView.visible	:= self.btnView.visible;
	if not (self.mnuEdit.visible and self.mnuView.visible) then
		self.mnuTaskSep.visible := false;
	endif;
	
	// Until get tasks on security roles
	self.mnuTaskComplete.visible := false;
	
	self.toolbarStyle		:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar		:= true;
	
	self.initTblData();
	
	self.tblThumb.autoSize 		:= Table.AutoSize_Column;
	self.tblThumb.scrollBars	:= Table.ScrollBars_Both;
	
	self.myThumbDef := app.myController.getEntTableDef(ETDef_CargoQuickViewThumb);
	if self.myThumbDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (ETDef_CargoQuickViewThumb) not found');
		return;
	endif;

	// set search defaults
	self.cmbCargoType.setObject(app.myPassport.getDefaultCargoType());
	
	if app.isSpecial() then
		self.chkCheckAccess.value := self.myQuickViewController.checkAccess;
		self.chkPartialMatch.value := self.myQuickViewController.canDoPartialMatch;
		self.frmDeveloper.visible := true;
	endif;
	
	self.frmSearch.width := self.cmbCargoType.left + self.cmbCargoType.width + 30;

	self.txtCargoID.setFocus();
	
	if not app.myPassport.myUser.canDo(self.myTerminal, PmCargoQuickViewNoDAC) then
		self.mnuCargoTaskAdd.visible := false;
		self.mnuCargoTaskComplete.visible := false;
		self.mnuCargoTaskRemarks.visible := false;
		self.mnuCargoTaskRemove.visible := false;
	endif;
	self.minimumHeight := 400;
	self.minimumWidth := 400;
end;</source>
    </JadeMethod>
    <JadeMethod name="showContextMenu" id="f4b5fbbb-d56a-4a70-9e32-e2fc4a4c3180">
        <updating/>
        <source>showContextMenu(pMenuItem: MenuItem; cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 09/09/2008	concms1	par 17884/ccms 1742 To do tasks interim solution
// 15/06/2010	cnwcs5	par 24342 - use new stops maint form so don't build stops menu
// 26/05/2025	navlw1	JIRA-34824: MTN | Quick Cargo Review UI Refactor
vars

	useTaskForm : Boolean;
	
begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
		
	if self.myCurrentTI &lt;&gt; null then
		if (not self.canAccessCurrentTI)  //epr TFS 7725 made not sense if user has permission to hide menu items
		and  app.myPassport.myUser.canDo(self.myTerminal, PmCargoQuickViewNoDAC) then
			//app.raiseCMException1(Full_Replacement_Message, 'You do not have permission to access this TI', null, null);
			self.mnuEdit.visible := false;
			self.mnuView.visible := false;
			self.mnuTaskSep.visible := false;
			self.mnuTaskAdd.visible := false;
			self.mnuTaskComplete.visible := false;
			self.mnuTaskRemove.visible := false;
			self.mnuStopsSep.visible := false;
			self.mnuStopsSet.visible := false;
			self.mnuColOrgSep.visible := false;
			self.mnuRequestTask.visible	:= false;	// par 17884
			self.mnuCargoTaskAdd.visible := false;	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskComplete.visible := false;	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskRemove.visible := false;	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskRemarks.visible := false;	//07 Oct 2015	NDL	Par 37011
		else
		
			if not useTaskForm then	//07 Oct 2015	NDL	Par 37011
				self.mnuCargoTaskAdd.visible := false;	//07 Oct 2015	NDL	Par 37011
				self.mnuCargoTaskComplete.visible := false;	//07 Oct 2015	NDL	Par 37011
				self.mnuCargoTaskRemove.visible := false;	//07 Oct 2015	NDL	Par 37011
				self.mnuCargoTaskRemarks.visible := false;	//07 Oct 2015	NDL	Par 37011
			
				self.myAssistant.buildMnuTasksAdd(self.mnuTaskAdd, self.mnuTaskAddSub, self.myCurrentTI);
				self.myAssistant.buildMnuTasksComplete(self.mnuTaskComplete, self.mnuTaskCompleteSub, self.myCurrentTI);
				self.myAssistant.buildMnuTasksRemove(self.mnuTaskRemove, self.mnuTaskRemoveSub, self.myCurrentTI);
			else
				//07 Oct 2015	NDL	Par 37011
				self.mnuCargoTaskAdd.visible := true;
				self.mnuCargoTaskComplete.visible := true;	
				self.mnuCargoTaskRemove.visible := true;
				self.mnuCargoTaskRemarks.visible := true;
				
				self.mnuTaskAdd.visible := false;
				self.mnuTaskComplete.visible := false;
				self.mnuTaskRemove.visible := false;
			endif;
			
			// if the system config (use interim job request form) is set and
			// the user has view job request form permission then
			// show then interim job request menu item		
			if app.myRoot.getConfig (UseInterimJobRequestForm).Boolean and						// par 17884
				app.getMyUser.canDo (self.myTerminal, PmJobRequestView) then					// par 17884
				self.mnuRequestTask.visible := true;											// par 17884
			endif;
			
			// we don't show the old todo menus if we are using the inertim solution, 
			// unless the user has the 'PmShowToDoMenuInViewMode' permission set
			if app.myRoot.getConfig (UseInterimJobRequestForm).Boolean and						// par 17884
				not app.getMyUser.canDo (self.myTerminal, PmShowToDoMenuInViewMode) then		// par 17884
				self.mnuTaskAdd.visible			:= false;										// par 17884
				self.mnuTaskComplete.visible	:= false;										// par 17884
				self.mnuTaskRemove.visible		:= false;										// par 17884
				self.mnuCargoTaskAdd.visible := false;	//07 Oct 2015	NDL	Par 37011
				self.mnuCargoTaskComplete.visible := false;	//07 Oct 2015	NDL	Par 37011
				self.mnuCargoTaskRemove.visible := false;	//07 Oct 2015	NDL	Par 37011
				self.mnuCargoTaskRemarks.visible := false;	//07 Oct 2015	NDL	Par 37011
			endif;																				// par 17884
			
			if (not self.mnuTaskAdd.visible)
			and (not self.mnuTaskComplete.visible)
			and (not self.mnuTaskRemove.visible)
			and (not self.mnuRequestTask.visible)
			and (not self.mnuCargoTaskAdd.visible)	//07 Oct 2015	NDL	Par 37011
			and (not self.mnuCargoTaskRemove.visible)	//07 Oct 2015	NDL	Par 37011
			and (not self.mnuCargoTaskComplete.visible)	//07 Oct 2015	NDL	Par 37011
			and (not self.mnuCargoTaskRemarks.visible)	//07 Oct 2015	NDL	Par 37011
			then											// par 17884
				self.mnuTaskSep.visible := false;
			endif;

			// par 24342 - self.buildMnuStops(self.mnuStopsSet, self.myCurrentTI);
		endif;
		return inheritMethod(pMenuItem, cntrl, conwin, mouse, x, y);
	else
		//#JIRA-34824 navlw1 26/05/2025 
		self.mnuTaskAdd.visible 	:= false;
		self.mnuView.visible 		:= false;
		self.mnuEdit.visible 		:= false;
		self.mnuStopsSet.visible 	:= false;
		self.mnuTaskRemove.visible 	:= false;
//		app.raiseCMException1(Full_Replacement_Message, 'You must select a TI', null, null);
//		return false;
	endif;
	
	if app.myPassport.myUser.canDo(self.myTerminal, PmCargoQuickViewNoDAC) then
		self.mnuCargoTaskAdd.visible := false;
		self.mnuCargoTaskComplete.visible := false;
		self.mnuCargoTaskRemarks.visible := false;
		self.mnuCargoTaskRemove.visible := false;
	endif;
	
	return false;

end;</source>
        <Parameter name="pMenuItem" type="MenuItem"/>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showDetailsForTI" id="a770f570-0d02-4840-b558-c58f1f8b2953">
        <updating/>
        <source>showDetailsForTI(_ti : CM_TrackedItem) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
14 May 2008	cnwkpd1	PAR #16748 - Add in exception handling to deal with deleted TIs

*/

vars
	entTableRow	: EntTableRow;
	str,
	dataStr		: String;
	count,
	i, rowIdx,
	dataSize,
	rowHeight	: Integer;
	invalidTI	: Boolean;
	
begin

	self.tblThumb.rows := 0;

	self.allHeadings.clear;
	self.allDetails.clear;

	self.setCurrentTI(_ti);

	if _ti = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _ti, invalidTI);		// PAR #16748
	
	_ti.getDataForDef(self.myThumbDef, self.allHeadings, self.allDetails, self.myTerminal);

	if invalidTI then			// PAR #16748
		return;
	endif;
	
	dataSize := self.allDetails.size;
	foreach str in self.allHeadings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		dataStr := self.allDetails[i];
		rowIdx := self.tblThumb.addItem(str &amp; Tab &amp; dataStr);
		
		//expand row if text has carrage returns
		count := dataStr.countOccurrences(Cr);
		if count &gt; 0 then
			rowHeight := self.tblThumb.accessRow(rowIdx).height;
			self.tblThumb.accessedRow.height := rowHeight * (count+1);
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="showHideTblData" id="a2fb73d3-3915-431f-9371-3eb220315cc5">
        <updating/>
        <source>showHideTblData(_show : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
// 23 Apr 2025 navlc30 JIRA-34546-Cargo Quick View Form - UI issue
// Purpose:     
// ---------------------------------------------------------------------------
// 
vars

begin
	if self.frmBottom.visible = _show then
		// no change
		return;
	endif;
	
	self.btnPrintList.visible := _show;
	
	if (not _show) then
		self.height := self.minimumHeight;
	else
		if self.height &lt; self.minimumHeight + 200 then
			self.height := self.minimumHeight + 200;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showResults" id="c6d9a8a1-1f17-4060-b022-5b53e14327a3">
        <updating/>
        <source>showResults() updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
vars
	numFound	: Integer;
	theTI		: CM_TrackedItem;
begin
	numFound := self.myQuickViewController.allTIs.size;
	
	self.endNotificationForSubscriber(self);
	
	if numFound = 0 then
		self.showHideTblData(false);
		// clear
		return;
	elseif numFound = 1 then
		theTI := self.myQuickViewController.allTIs.first;
		self.beginNotification(theTI, Any_System_Event, Response_Continuous, 0);
		self.showHideTblData(false);
		self.showDetailsForTI(theTI);
		self.txtCargoID.setFocus();
	else
		self.showHideTblData(true);
		self.showResultsInTable();
	endif;
	self.doResize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showResultsInTable" id="bf8b9536-7754-444a-b4db-874b633fdee9">
        <updating/>
        <source>showResultsInTable() updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
14 May 2008	cnwkpd1	PAR #16748 - Add in exception handling to deal with deleted TIs
29 May 2025	navnk30	JIRA 34842: MTN | Cargo Quick View form - not able to close "Table Row Limit Reached" popup

*/

vars
	ti			: CM_TrackedItem;
	invalidTI	: Boolean;
	addedRowId	: Integer;
begin

	self.tblData.clearAllSelected();
	self.tblData.rows := self.tblData.fixedRows;
	
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);		// PAR #16748
	
	foreach ti in self.myQuickViewController.allTIs do
		self.beginNotification(ti, Any_System_Event, Response_Continuous, 0);
		addedRowId := self.tblData.addItemObject(ti, ti.getAttributeStringForDefArray(tblData.allTblDataEntRows));
		if addedRowId &lt; 1 then		//29.05.2025 navnk30 JIRA 34842
			break;
		endif;
	endforeach;
	
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	
	if self.tblData.rows &gt; self.tblData.fixedRows + 1 then
		self.tblData.selectRow(self.tblData.fixedRows + 1, true);
		ti := self.tblData.accessRow(self.tblData.fixedRows + 1).itemObject.CM_TrackedItem;
		self.showDetailsForTI(ti);
		
		self.tblData.setFocus();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="4428a0f5-6c69-478b-a39a-d69346f69cdd">
