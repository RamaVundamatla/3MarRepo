    <JadeMethod name="doCmdProfileMethod" id="fd647f12-526a-4ea9-9534-0c5cf24d0434">
        <updating/>
        <source>doCmdProfileMethod(target : Object; mthName, outputFileName : String) updating;

vars
	trimmedMthName, trimmedFileName, errTxt : String;
	errNo : Integer;
	
begin
	if target = null or (not Process.hasInstance(target)) then
		// this command can be sent only to an individual process
		return;
	endif;
	
	trimmedMthName := mthName.trimBlanks;
	trimmedFileName := outputFileName.trimBlanks;
	
	if trimmedMthName = null or trimmedFileName = null then
		return;
	endif;

	self.lastProfiledMethodName := trimmedMthName;
	self.lastProfiledOutputFileName := trimmedFileName;
	
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	target.causeEvent(CmdEventNumber, true, CmdProfileMethod &amp; ':' &amp;
		trimmedMthName &amp; ';' &amp; trimmedFileName);
end;</source>
        <Parameter name="target" type="Object"/>
        <Parameter name="mthName" type="String"/>
        <Parameter name="outputFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doCmdReloadProfile" id="c3fd7d9c-cfd3-443a-92fc-945b67c4cf49">
