    <JadeMethod name="validateForDelete" id="b2d4612e-03da-4027-9610-c6d219d38028">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	
begin

	lc := self.myLocationsController;
	if lc &lt;&gt; null then
		if lc.numTIs &gt; 0 or lc.numPlannedTIs &gt; 0 or lc.numQueuedTIs &gt; 0 then
			app.raiseCMException(ERR_SWAP_LC_HAS_TIS, null, null);
			return;
	 	endif;
	endif;
 	
 	// deliberately not done at this point as existance of TI's give
 	// a different error in superclasses
 	//inheritMethod();

end;</source>
    </JadeMethod>
