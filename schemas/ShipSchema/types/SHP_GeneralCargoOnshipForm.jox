    <JadeMethod name="addItemObjectToTable" id="27bb8d1d-22b3-4c4e-b750-973c0978c3b7">
        <source>addItemObjectToTable(_obj : CM_Object io;  _table : CM_DataTable input) protected;

vars
	rowIdx,
	backColour : Integer;
	str : String;
begin
	
	if _obj = null 
	or _table = null then
		return;
	endif;	
	
	on Exception do self.handleExceptionObject(exception, _obj);
	_obj.fetchLatest();
	if _obj = null then
		return;
	endif;	

	str := _obj.getAttributeStringForDefArray(_table.allTblDataEntRows);
	rowIdx := _table.addItemObject(_obj, str);

	if rowIdx mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;
	_table.accessedRow.backColor := backColour;	
	
	self.addNotableObject(_obj);
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object" usage="io"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addNotableObject" id="39241faf-8b5e-41c3-bbd8-9296915cb03b">
        <source>addNotableObject(_obj : CM_Object) protected;

vars
	bol	: CM_BOL;
begin
	if _obj = null then
		return;
	endif;
	
	if (not global.isValidObject(_obj)) then
		return;
	endif;
	
	if self.allNotableObjects.includes(_obj) then
		return;
	endif;
	
	self.allNotableObjects.add(_obj);
	beginNotification(_obj, Object_Update_Event, Response_Continuous, null);
	beginNotification(_obj, Object_Delete_Event, Response_Continuous, null);

	if _obj.isKindOf(CM_BOLDtl) then
		bol := _obj.CM_BOLDtl.myBOL;
		if not  self.allNotableObjects.includes(bol) then
			self.allNotableObjects.add(bol);
			self.beginNotification(bol, self.myTerminal.getTerminalEvent(Event_BOLUpdate), Response_Continuous, 0);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addSearchToolbarControls" id="4de0f22e-c055-4f8a-9be6-142e7e8f9e6c">
        <source>addSearchToolbarControls();
// F3 search for voyage
vars
	toolbar : CMUI_Toolbar;
begin
	
	toolbar := self.frmQueryToolbar;
	toolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	toolbar.alignContainer := Frame.AlignContainer_Top; 

end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="6193aa4e-c307-4059-95bc-0fb84736b1ec">
        <updating/>
        <source>addToolbarControls() updating, protected;
//-----------------------------------------
// Created: 12 Jan 2010 By: cnwjre1
//
// 22 Nov 2012	PJS		PAR #30787 
// 28 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
//-----------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnShowSelector, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnRefresh,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	// par 23144 add button to show BOL items
	toolbar.addButton(self.btnShowBOL, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnBOLReconcile, CMUI_Toolbar.Control_Alignment_Left);	// 30787
	toolbar.addButton(self.btnTransfer, CMUI_Toolbar.Control_Alignment_Left);	//27 April 2016	NDL	TFS 1903
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnExtract, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnInstruction, CMUI_Toolbar.Control_Alignment_Left);	//28.10.2022 navtnr20 TFS 54967
	/* //- cnwmd1, Par 22846
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCargoType, CMUI_Toolbar.Control_Alignment_Left);	
	*/
	//toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);				
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	// general select frame - NOT USED here
	toolbar := self.frmSelectToolbar;
	toolbar.addButton(self.btnSelect, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnResetSelector, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCloseSelector, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	// search frame
	toolbar := self.frmSearchToolbar;
	toolbar.addButton(self.btnSearchSelect, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnSearchReset, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnSearchClose, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	self.setToolbarSearch();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="7e3fa3bf-e576-4268-8a67-deda385a406e">
        <source>allowsTableFilters(_table: Table): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2014	cnwmc5	Initial creation		PAR 34074

*/

vars

begin
	return _table = self.tblCargo or _table = self.tblBOLItems;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="d6f7a593-0694-4240-b8e6-64da4daa0fa7">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2014	cnwmc5	Initial creation		PAR 34074

*/

vars

	visibleCount : Integer;

begin
	
	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="arrangeSplitters" id="931a0687-0321-400c-b8e8-337d91f94df4">
        <source>arrangeSplitters();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2016	cnwns1	Initial creation

*/

vars

begin
    if splMain.getMyLeftControl.width &lt; 300 then	
		splMain.setLeftToRightSizeAndResize(300);
	elseif splMain.getMyRightControl.width&lt; 365 then
		splMain.setLeftToRightSizeAndResize(splMain.width.Integer - 6 - 365);
	endif;
	
	if splBOL.getMyLeftControl.height &lt; 75 then	
		splBOL.setLeftToRightSizeAndResize(75);
	elseif splBOL.getMyRightControl.height&lt; 75 then
		splBOL.setLeftToRightSizeAndResize(splBOL.height.Integer - 6 - 75);
	endif;
end;
</source>
    </JadeMethod>
