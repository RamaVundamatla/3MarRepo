    </JadeMethod>
    <JadeMethod name="writeLog" id="bc600d02-172b-4923-80a6-946a17f6e0b3">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>writeLog(message: String; messageLevel: Integer) updating, clientExecution;
/*

Purpose:			Write app.writeLog messages to the Unit Test runner/results window

Parameters:			

Return Value:		

Date				Who		Reason
31 July 2024		navmd1	Initial creation

*/

vars

begin
	if self.isJMTUnitTest then
		if self.logLevel = LogTRACE then
			self.log(message);
		endif;
	endif;

	inheritMethod(message, messageLevel);

epilog

end;</source>
        <Parameter name="message" type="String"/>
        <Parameter name="messageLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xCheckForUncompiledMethods" id="9020cae7-304f-4f62-9f18-c33dc8344eb6">
        <source>xCheckForUncompiledMethods(_type : Integer; _uncompiledDetails : StringArray512 io);

/*

Purpose:		Check for Uncompiled Methods	

				_type:
				0 = All
				1 = Production Only
				2 = Non Production Only


Date			Who		Reason
15/11/2016		cnwmh5	Initial creation

*/

vars

	devSchemaReleaseAgent			: Object;
	schema							: Schema;
	type							: Type;
	meth							: Method;
	
	allClasses						: ClassColl;
	allTypes						: PrimTypeNDict;
	allMethods						: MethodNDict;
	
	prodSchemaNames					: StringArray512;
	
begin

	create devSchemaReleaseAgent as rootSchema.getSchema('DevSchema').getClass('DEV_ReleaseExtractAgent') transient;
	create prodSchemaNames transient;
	devSchemaReleaseAgent.sendMsgWithIOParams('getReleaseSchemas', prodSchemaNames);

	create allClasses transient;
	create allTypes transient;
	create allMethods transient;
	
	foreach schema in Schema.instances do : schema_loop
	
		// work out which type we are running
		if _type = 1 then
			if not prodSchemaNames.includes(schema.name) then
				continue;
			endif;
		elseif _type = 2 then
			if  prodSchemaNames.includes(schema.name) then
				continue;
			endif;
		endif;
		
		delete allClasses;
		allClasses	:= schema.getAllClasses( true );
		
		foreach type in allClasses do : class_loop
			allMethods.clear;
			type.getMethods(allMethods) ;
			foreach meth in allMethods do : method_loop
				if meth.getSchema &lt;&gt; schema then
					continue method_loop;
				endif;
				// display if in error and this method is actually in this schema not a super schema
				if meth.inError or meth.notCompiled then
					_uncompiledDetails.add(schema.name &amp; "^^" &amp; type.name &amp; "^^" &amp; meth.name &amp; "^^" &amp; 
						meth.cnGetModifiedTimeStamp().date.format("dd/MM/yyyy") &amp; "^^" &amp; 
						meth.cnGetModifiedTimeStamp().time.String &amp; "^^" &amp; meth.getModifiedBy());
				endif;
			endforeach method_loop;
		endforeach class_loop;
	
	endforeach schema_loop;

epilog

	delete devSchemaReleaseAgent;
	delete prodSchemaNames;
	delete allTypes;
	delete allClasses;
	delete allMethods;
	
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_uncompiledDetails" type="StringArray512" usage="io"/>
    </JadeMethod>
</Class>
