    <JadeMethod name="applyColour" id="6df3bf16-9c99-4bc2-88ed-2e08c673842c">
        <source>applyColour() protected;

vars
	listPointer	: Integer;
	classObj	: Class;
	
begin
	listPointer := 1;
	fraUnavail.caption := "Classes Unavailable for XML : " &amp; lstUnavailClasses.listCount.String;  
	fraAvail.caption := "Classes Available for XML : " &amp; lstAvailClasses.listCount.String;
	
	while listPointer &lt;= lstUnavailClasses.listCount do
		classObj := app.myCnEcXmlSchema.superschema.getClass(lstUnavailClasses.itemText[listPointer]);
		
		if classObj = null then
			classObj := app.myCnEcXmlSchema.getClass(lstUnavailClasses.itemText[listPointer]);
			if classObj &lt;&gt; null then
				if classObj.transient = true
				or classObj.getName = "JadeScript"
				or classObj.getName = "Application"
				or classObj.isKindOf(Window)
				or classObj.getName = app.myCnEcXmlSchema.name
				or classObj.getName = "G" &amp; app.myCnEcXmlSchema.name  
				or classObj.isKindOf(CollClass)
				then
					lstUnavailClasses.itemForeColor[listPointer] := Black;
				else
					lstUnavailClasses.itemForeColor[listPointer] := Red;
				endif;
			else
				lstUnavailClasses.itemForeColor[listPointer] := Black;	
			endif;	
		else
			if classObj.getName = "Object"  or classObj.getName = "Class" then
				lstUnavailClasses.itemForeColor[listPointer] := Red;
			else 
				lstUnavailClasses.itemForeColor[listPointer] := Black;
			endif;		
		endif;
		
   		listPointer := listPointer + 1;
	endwhile;
	
	listPointer := 1;
	
	while listPointer &lt;= lstAvailClasses.listCount do
		classObj := app.myCnEcXmlSchema.superschema.getClass(lstAvailClasses.itemText[listPointer]);
		
		if classObj &lt;&gt; null then
			if classObj.getName = "Object" or classObj.getName = "Class" then
				lstAvailClasses.itemForeColor[listPointer] := Black;
			else
				lstAvailClasses.itemForeColor[listPointer] := Red;
			endif;
		else
			classObj := app.myCnEcXmlSchema.getClass(lstAvailClasses.itemText[listPointer]);
			
			if classObj.transient = true
			or classObj.getName = "JadeScript"
			or classObj.getName = "Application"
			or classObj.isKindOf(Window)
			or classObj.getName = app.myCnEcXmlSchema.name
			or classObj.getName = "G" &amp; app.myCnEcXmlSchema.name   
			or classObj.isKindOf(CollClass) then
				lstAvailClasses.itemForeColor[listPointer] := Red;
			else
				lstAvailClasses.itemForeColor[listPointer] := Black;
			endif;		
		endif;
		
   		listPointer := listPointer + 1;
	endwhile; 
end;</source>
        <access>protected</access>
    </JadeMethod>
