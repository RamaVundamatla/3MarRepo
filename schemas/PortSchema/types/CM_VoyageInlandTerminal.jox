    <JadeMethod name="setFromVoyage" id="136e3147-f98c-4dde-a82e-ee1b9a800f32">
        <updating/>
        <source>setFromVoyage(_voyage : CM_Voyage) updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2007 by cnwrs2
//
// Purpose:     Set minimum fields on voyage
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
vars

begin

	self.archived	:= _voyage.archived;
	self.archivedDT	:= _voyage.archivedDT;
	self.setArrivalDT(_voyage.arrivedDT);
	self.callSign	:= _voyage.callSign;
	self.colour		:= _voyage.colour;
	self.cutOffDT	:= _voyage.cutOffDT;
	self.dateFirstAvailable	:= _voyage.dateFirstAvailable;
	self.departTargetDT	:= _voyage.departTargetDT;
	self.departedDT		:= _voyage.departedDT;
	self.vesselCode	:= _voyage.vesselCode;
	self.vesselName	:= _voyage.vesselName;

	//self.status := _voyage.status;//par15713		// TFS 37445 Can't do this here as we don't have a terminal yet
													// Moved to setFromVoyageForCreate/Update after the terminal is set
	
	//epr par 30407 26/9/12
	self.myTrade :=_voyage.myTrade;
	self.setForUpdatePortsOfCall(_voyage.allPortRotations);
	self.allOperators.clear;
	_voyage.allOperators.copy(self.allOperators);
	// need to think about references
	// self.myDebtor deliberately not copied as other terminal
	// may not have access to that debtor (maybe determine if can
	// access and set if can be accessed)
	self.myShippingLine	:= _voyage.myShippingLine;
	self.myOperator	:= _voyage.myOperator;

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setFromVoyageForCreate" id="2e615690-37e4-4176-9e83-bdb5c8ed1b88">
        <updating/>
        <source>setFromVoyageForCreate(_voyage : CM_Voyage; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2007 by cnwrs2
//
// Purpose:     Set minimum fields on voyage
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 16/07/2024	navlw1		ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code 
// 26/11/2024	navdap1		MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
vars

begin

	if _terminal = _voyage.myTerminal then
		app.raiseUnexpectedProgramError(class.name, method.name, 
				'Attempt to create inland terminal voyage for same terminal (' &amp; _voyage.myTerminal.String &amp; ')');
		return;
	endif;
	
	self.setFromVoyage(_voyage);

	self.code		:= _voyage.code;
	
	// navlw1 #63839
	//if self.isAutomaticProcess() then								// MTN-33516
	if _terminal.getConfig(AllowDupVoyageInOutCodes).Boolean then	// MTN-33516
		self.inwardCodeAuto := _voyage.inwardCodeAuto;
	else
		self.inwardCode	:= _voyage.inwardCode;
	endif;
	
// PAR 33644	self.isNonPlannedVoyage	:= true;
// PAR 33644	self.isNonWorkedVoyage	:= true;
	
	self.setMyTerminal(_terminal);
	self.status := _voyage.status;					// TFS 37445
	
	self.myVoyage 	:= _voyage;
	
	_terminal.addVoyageToDict(null, null, self);


end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setFromVoyageForUpdate" id="84ddaf64-867d-422f-b73b-86600d9ec73b">
        <updating/>
        <source>setFromVoyageForUpdate(_voyage : CM_Voyage; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2007 by cnwrs2
//
// Purpose:     Set minimum fields on voyage
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 16/07/2024	navlw1		ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code
// 26/11/2024	navdap1		MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
vars
	origCode,
	origInwardCode				: String;
	orginalArchiveValueIsTrue	: Boolean;

begin

	origCode					:=	self.code;
	origInwardCode				:=	self.inwardCode;
	orginalArchiveValueIsTrue	:=	self.archived;

	self.setFromVoyage(_voyage);
	self.status := _voyage.status;					// TFS 37445

	if self.code &lt;&gt; _voyage.code then
		self.updateCode(_voyage.code, _passport);
	endif;
	// navlw1 #63839
	//if self.isAutomaticProcess() then										// MTN-33516
	if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then		// MTN-33516
		if self.inwardCodeAuto &lt;&gt; _voyage.inwardCodeAuto then
			self.updateInwardCodeAuto(_voyage.inwardCodeAuto, _passport);
		endif;
	else
		if self.inwardCode &lt;&gt; _voyage.inwardCode then
			self.updateInwardCode(_voyage.inwardCode, _passport);
		endif;
	endif;
	
	/*
		   Date		 Who		Reason
		5 Aug 2008	cnwdz2	    Par15231 - The following is duplicate of updateCode and updateInwardCode.
	*/
	//if (not self.archived) and (origCode &lt;&gt; self.code or origInwardCode &lt;&gt; self.inwardCode or orginalArchiveValueIsTrue) then
	//	self.myTerminal.addVoyageToDict(origCode, origInwardCode, self);
	//endif;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
