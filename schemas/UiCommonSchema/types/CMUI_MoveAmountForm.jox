    <JadeMethod name="adjustAmountIfRequired" id="b20e63a3-28e0-4753-80fe-d4e7e3c3f3ec">
        <updating/>
        <source>adjustAmountIfRequired(_cargoType : CM_CargoType; _moveAmtIsFromWLE : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/03/2017	cnwdap1		Initial creation TFS 3516 LNX Hold Planning Quantity
// 19 Apr 2017	NDL			TFS 4125 - prevent converted amount becoming negative.
// 23 Oct 2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
// 10/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
//
vars
	wle : CM_WorkListEntry;
	committedQty : Integer;
	committedAmt, dischargeAmt, loadAmt : Decimal [18,8];
	committedVol : Decimal [18,8];
	convertedAmount : String;
	measureType : CM_MeasurementType;
	bestGuessDec : Decimal [18,8];
	bestGuessInt : Integer;

begin
	if _cargoType.isBulkByVolume then
		measureType := _cargoType.myVolumeMeasurementType;
	elseif _cargoType.isBulkByWeight then
		measureType := _cargoType.myWeightMeasurementType;
	endif;
	if self.excludeWLEs then
		foreach wle in self.myTrackedItem.allWorklistEntries where wle.status &lt;&gt; WLE_COMPLETED do
			if _cargoType.isBreakBulkMulti then
				if wle.isReceipt then 
					dischargeAmt := dischargeAmt + wle.quantity;
				else
					loadAmt := loadAmt + wle.quantity;
				endif;
			elseif _cargoType.isBulkMulti then
				if wle.isReceipt then
					dischargeAmt := dischargeAmt + wle.weight;
				else
					loadAmt := loadAmt + wle.weight;
				endif;
			endif;
		endforeach;
		if self.isHoldPlanningDischarge then
			if _cargoType.isBreakBulkMulti then
				committedAmt := dischargeAmt;
			elseif _cargoType.isBulkMulti then
				committedAmt := dischargeAmt;
			endif;
		else
			if self.isHoldPlanningTranship then			// TFS 47085
				committedAmt := dischargeAmt - loadAmt;	// TFS 47085
			else
				committedAmt :=  loadAmt; //epr TFS 4300 2/5/17  was dischargeAmt - loadAmt can't see how this would work because the discharge wle would be a different object so dischargeAmt is zero and would give a negative committedAmt 
										//results in the  amount available to load going up after each planned load
			endif;
		endif;
		if self.isHoldPlanningDLRSOB then
			if self.isHoldPlanningDischarge then
				if _cargoType.isTrackByVolume then
					committedVol := committedAmt / self.myTrackedItem.getDensity;
					//convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, (self.myTrackedItem.totalVolume - committedVol));
					//19 Apr 2017	NDL	TFS 4125
					bestGuessDec := self.myTrackedItem.totalVolume - committedVol;
					if bestGuessDec &lt; 0 then
						bestGuessDec := 0;
					endif;
					convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, bestGuessDec );
				elseif _cargoType.isTrackByWeight then
					//convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, (self.myTrackedItem.totalWeight - committedAmt));
					//19 Apr 2017	NDL	TFS 4125
					bestGuessDec := self.myTrackedItem.totalWeight - committedAmt;
					if bestGuessDec &lt; 0 then
						bestGuessDec := 0;
					endif;
					convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, bestGuessDec );
				elseif _cargoType.isBreakBulkMulti then
					//convertedAmount := (self.myTrackedItem.totalQuantity - committedAmt).String;
					//19 Apr 2017	NDL	TFS 4125
					bestGuessInt := self.myTrackedItem.totalQuantity - committedAmt.Integer;
					if bestGuessInt &lt; 0 then
						bestGuessInt := 0;
					endif;
					convertedAmount := bestGuessInt.String;
				endif;
			else
				if _cargoType.isTrackByVolume then
					committedVol := committedAmt / self.myTrackedItem.getDensity;
					//19 Apr 2017	NDL	TFS 4125
					if committedVol &lt; 0 then
						committedVol := 0;
					endif;
					convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, committedVol);
				elseif _cargoType.isTrackByWeight then
					//19 Apr 2017	NDL	TFS 4125
					if committedAmt &lt; 0 then
						committedAmt := 0;
					endif;
					convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, committedAmt);
				elseif _cargoType.isBreakBulkMulti then	
					//19 Apr 2017	NDL	TFS 4125
					if committedAmt &lt; 0 then
						committedAmt := 0;
					endif;
					convertedAmount := committedAmt.String;
				endif;
			endif;
		else
			if _cargoType.isTrackByVolume then
				committedVol := committedAmt / self.myTrackedItem.getDensity;
				//convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, (self.myTrackedItem.totalVolume - committedVol));
				if self.isHoldPlanningTranship then	// TFS 47085
					bestGuessDec := committedVol;	// TFS 47085
				else
					//19 Apr 2017	NDL	TFS 4125
					bestGuessDec := self.myTrackedItem.totalVolume - committedVol;
				endif;
				if bestGuessDec &lt; 0 then
					bestGuessDec := 0;
				endif;
				convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, bestGuessDec);
			elseif _cargoType.isTrackByWeight then
				//convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, (self.myTrackedItem.totalWeight - committedAmt));
				if self.isHoldPlanningTranship then	// TFS 47085
					bestGuessDec := committedAmt;	// TFS 47085
				else
					//19 Apr 2017	NDL	TFS 4125
					bestGuessDec := self.myTrackedItem.totalWeight - committedAmt;
				endif;
				if bestGuessDec &lt; 0 then
					bestGuessDec := 0;
				endif;
				convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, bestGuessDec);
			elseif _cargoType.isBreakBulkMulti then
				//convertedAmount := (self.myTrackedItem.totalQuantity - committedAmt).String;
				if self.isHoldPlanningTranship then			// TFS 47085
					bestGuessInt := committedAmt.Integer;	// TFS 47085
				else
					//19 Apr 2017	NDL	TFS 4125
					bestGuessInt := self.myTrackedItem.totalQuantity - committedAmt.Integer;
				endif;
				if bestGuessInt &lt; 0 then
					bestGuessInt := 0;
				endif;
				convertedAmount := bestGuessInt.String;
			endif;
		endif;
		if _cargoType.isBreakBulkMulti then
			self.txtQuantity.text := convertedAmount.Integer.asStringJMT;
		elseif _cargoType.isBulkMulti then
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; measureType.shortName);
		endif;
	endif;
	
	//if self.myWorkListEntry &lt;&gt; null then								// TFS 52360
	if self.myWorkListEntry &lt;&gt; null and not _moveAmtIsFromWLE then		// TFS 52360
		if _cargoType.isBreakBulkMulti then
			self.txtQuantity.text := (self.myWorkListEntry.quantity.asStringJMT);
		elseif _cargoType.isBulkByWeight then
			convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, self.myWorkListEntry.weight);
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; measureType.shortName);
		elseif _cargoType.isBulkByVolume then
			committedVol := self.myWorkListEntry.weight / self.myTrackedItem.getDensity;
			convertedAmount := app.convertMeasurementForDisplay(measureType.shortName, committedVol);
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; measureType.shortName);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_moveAmtIsFromWLE" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="77390002-d221-4958-81ef-6c0044d1cd9a">
        <updating/>
        <source>doOK() updating;
/*

Date		Who		Reason
26 March 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.byQuantity  then
		if self.getQuantity &gt; self.myTrackedItem.totalQuantity then
			app.msgBox( app.getErrorString1( Not_decla_quant_great_than_tot, self.myTrackedItem.totalQuantity.String ), app.getErrorString(Error), MsgBox_OK_Only);
			return;
		endif;
	else
		
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getQuantity" id="36065fdf-1e9c-472a-ba67-4e1c40df6556">
        <source>getQuantity() : Integer;
/*

Date		Who		Reason
20 March 2014	cnwer1	Initial creation PAR

*/

vars
	quantity : Integer;
begin
	quantity:=self.txtQuantity.text.Integer;
	
	if quantity = 0 then
		
		quantity:= self.myTrackedItem.totalQuantity;
	endif;
	
	return quantity;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWeightMovedKgs" id="5d789381-dd7a-43bc-95d7-3837bfc9b67a">
        <source>getWeightMovedKgs() : Decimal;
/*

Date		Who		Reason
19 March 2014	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	kgValue, volume  : Decimal[14,4];

begin
	if self.myTrackedItem = null then
		return null;
	endif;
	
	ct:=self.myTrackedItem.myCargoType;
	if ct.isTrackByWeight then
		kgValue:=self.tblAmount.getConvertedValue();
		
	else
		volume:=self.tblAmount.getConvertedValue();
		kgValue:= volume * self.myTrackedItem.getDensity;

	endif;
	
	if kgValue = null then
		return self.myTrackedItem.totalWeight;
	endif;
	return kgValue;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="933e44d2-71d8-4019-b7ef-d17be5131f19">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
25/03/2014	cnwer1	Initial creation PAR
01/03/2017	cnwdap1	TFS 3516 LNX Hold Planning Quantity
09 Dec 2019	NDL		Adjust to allow the use of 'myRequest' and/or 'myWorkListEntry'
10/1102021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
07/12/2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
28/07/2023	navkc1	Bug 59421: MTN - Move Amount Dialog
*/

vars
	ct : CM_CargoType;
	convertedAmount : String;
	reqMaxQty : Integer;
	reqMaxWt : Decimal[14,4];
	reqMaxVol : Decimal[14,4];
	moveAmtIsFromWle : Boolean;			// TFS 52360
	voyageWLE : CM_VoyageWLE;			// TFS 52360
begin
	inheritMethod();

	self.byQuantity:=false;
	
	self.lblInfo.caption:=app.getErrorString4( Move_from_to,app.myMoveController.getMoveModeString(), self.myTrackedItem.id,self.myTrackedItem.locationId,targetLocation);
	
	//28/07/2023	navkc1	Bug 59421 - Set label color and picture based on the move mode;
	if app.myMoveController.moveMode = REAL_MODE then
		self.lblInfo.foreColor := Blue;
		self.picMoveMode.picture := self.picMvInstantCur.picture;
	elseif app.myMoveController.moveMode = QUEUE_MODE then
		self.lblInfo.foreColor := Red;
		self.picMoveMode.picture := self.picMvQueueCur.picture;
	elseif app.myMoveController.moveMode = PLANNING_MODE then
		self.lblInfo.foreColor := Green;
		self.picMoveMode.picture := self.picMvPlanCur.picture;
	endif;
	
	self.tblAmount.top:=self.txtQuantity.top;
	self.tblAmount.left:=self.txtQuantity.left;
	self.frmMain.transparent:=true;
	
	self.setMyTerminal(self.myTrackedItem.myTerminal);
	ct:=self.myTrackedItem.myCargoType;
	
	if self.myAspaVVR &lt;&gt; null then
		if self.myAsapRelease &lt;&gt; null then
			reqMaxQty := self.myAsapRelease.getAspaMaxQty();
			reqMaxWt := self.myAsapRelease.getAspaMaxWeight();
		endif;	
	elseif self.myRequest &lt;&gt; null then
		if self.myRequest.getQuantityOnRequest.Integer &gt; 0 then
			reqMaxQty := ( self.myRequest.getQuantityOnRequest.Integer - self.myRequest.getWLEQuantityTIAssigned( null ) ).max(0);
		endif;
		if self.myRequest.weightRequested &gt; 0 then
			reqMaxWt := ( self.myRequest.weightRequested - self.myRequest.getWLEWeightTIAssigned( null ) ).max(0);
		endif;
	//elseif self.myWorkListEntry &lt;&gt; null and ct.isBreakBulkMulti then	//10 Dec 2019	NDL	TFS 46875	// TFS 52360
	elseif self.myWorkListEntry &lt;&gt; null and (ct.isBreakBulkMulti or ct.isBulkMulti) then				// TFS 52360
		reqMaxQty := self.myWorkListEntry.quantity;
		reqMaxWt := self.myWorkListEntry.weight;
		// TFS 52360 If we have a stored planned value on the voyage WLE, check if we need to us it instead of the actual WLE value
		//if self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean and self.myWorkListEntry.isKindOf(CM_VoyageWLE) then							// TFS 52293
		if self.myWorkListEntry.job &lt;&gt; null and self.myWorkListEntry.job.isDirectDeliveryJob and self.myWorkListEntry.isKindOf(CM_VoyageWLE) then	// TFS 52293
			voyageWLE := self.myWorkListEntry.CM_VoyageWLE;
			if voyageWLE.subSeqNum &lt;&gt; null then	
				if ct.isBulkMulti and voyageWLE.subSeqNum &lt; voyageWLE.weight then
					reqMaxWt := self.myWorkListEntry.CM_VoyageWLE.subSeqNum;
					moveAmtIsFromWle := true;
				elseif ct.isBreakBulkMulti and voyageWLE.subSeqNum &lt; voyageWLE.quantity then
					reqMaxQty := self.myWorkListEntry.CM_VoyageWLE.subSeqNum;
					moveAmtIsFromWle := true;
				endif;
			endif;
		endif;
		// TFS 52360 end of this bit
	endif;
	
	
	if ct.isBreakBulkMulti then
		self.byQuantity:=true;
		lblAmount.caption:= app.getErrorString(CM_Quantity);
		self.txtQuantity.visible:=true;
		self.txtQuantity.zOrder(1);
		self.txtQuantity.dataType := TextBox.DataType_Numeric;
		self.txtQuantity.decimals := 0;	
		if self.txtQuantity.text = "" then		// 3/8/17 MAP TFS4719
			if reqMaxQty &gt; 0 and reqMaxQty &lt; self.myTrackedItem.totalQuantity 		//06 Dec 2019	NDL	TFS 46875
			or moveAmtIsFromWle then																	// TFS 52360
				self.txtQuantity.text := reqMaxQty.asStringJMT;
			else
				self.txtQuantity.text:=self.myTrackedItem.totalQuantity.asStringJMT;
			endif;
		endif;
		self.txtQuantity.selectAll();
		self.txtQuantity.setFocus();
		self.tblAmount.visible:=false;
		self.caption:=app.getErrorString(Confirm_quantity_move);
		
	elseif ct.isBulkMulti then
		self.txtQuantity.visible:=false;
		self.tblAmount.visible:=true;
		self.tblAmount.zOrder(1);
		if ct.isTrackByWeight then
			self.lblAmount.caption:= app.getErrorString(CM_Weight);
			self.caption:=app.getErrorString(Confirm_weight_move);
			self.tblAmount.setup(Type_Weight, self.backColor);
			if self.txtQuantity.text = "" then		// 21/9/17 MAP TFS4719
				if reqMaxWt &gt; 0 and reqMaxWt &lt; self.myTrackedItem.totalWeight 		//06 Dec 2019	NDL	TFS 46875
				or moveAmtIsFromWle then																// TFS 52360
			//		convertedAmount := app.convertMeasurementForStorage(ct.myWeightMeasurementType.shortName, reqMaxWt).asStringJMT;	
					convertedAmount := app.convertMeasurementForDisplay(ct.myWeightMeasurementType.shortName, reqMaxWt);	//05 Nov 2020	NDL	TFS 50271
				else
					convertedAmount:=self.myTrackedItem.getConvertedTotalWeightIn(ct.myWeightMeasurementType.shortName);
				endif;
			else
				convertedAmount := app.convertMeasurementForDisplay(ct.myWeightMeasurementType.shortName, self.txtQuantity.text.Decimal);
			endif;
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; ct.myWeightMeasurementType.shortName);
			
		else
			self.caption:=app.getErrorString(Confirm_volume_move);
			self.lblAmount.caption:= app.getErrorString(CM_Volume);
			if self.txtQuantity.text = "" then		// 21/9/17 MAP TFS4719
				if reqMaxWt &gt; 0 and self.myTrackedItem.getDensity &lt;&gt; 0 and ( reqMaxWt / self.myTrackedItem.getDensity ) &lt; self.myTrackedItem.totalVolume 		//06 Dec 2019	NDL	TFS 46875
				or moveAmtIsFromWle then																	// TFS 52360
				//	convertedAmount := app.convertMeasurementForStorage(ct.myWeightMeasurementType.shortName, reqMaxWt / self.myTrackedItem.getDensity ).asStringJMT;
					convertedAmount := app.convertMeasurementForDisplay(ct.myVolumeMeasurementType.shortName, reqMaxWt / self.myTrackedItem.getDensity );	//05 Nov 2020	NDL	TFS 50271
				else
					convertedAmount:=self.myTrackedItem.getConvertedTotalVolumeIn(ct.myVolumeMeasurementType.shortName);
				endif;
			else
				convertedAmount := app.convertMeasurementForDisplay(ct.myVolumeMeasurementType.shortName, self.txtQuantity.text.Decimal);
			endif;
			self.tblAmount.setup(Type_Volume, self.backColor);		
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; ct.myVolumeMeasurementType.shortName);
		endif;
		
		self.tblAmount.tabKey:=J_key_Tab;
		
	endif;
		
	// do we need to adjsut the amount for partiallly-planned hold job TIs?			// TFS 3516
	//self.adjustAmountIfRequired(ct);												// TFS 3516				// TFS 52360
	self.adjustAmountIfRequired(ct, moveAmtIsFromWle);								// TFS 3516				// TFS 52360
	
epilog
	app.mousePointer	:=	MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6f878310-db3b-41bf-a2ef-4ed5b7d7f27a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:41:46.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023281, locale);
	lblAmount.translateCaption(Xlat_0023282, locale);
end;</source>
    </JadeMethod>
</GUIClass>
