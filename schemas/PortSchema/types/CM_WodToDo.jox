    <JadeMethod name="copyResourcesToWOTrans" id="cd2ade67-c60a-46bc-821f-b30ecffc3552">
        <source>copyResourcesToWOTrans(_resourceUsageProxys : CM_ResourceTypeUsageSet input; _task : CM_ToDoTask);
/*

Purpose:			
	This method will be used to popualte CM_WOTransaction::allResourceUsages
Parameters:			
 //24/05/2023  navmv20 CR 57925 Task 57921
Return Value:		

Date		Who		Reason

*/

vars
	woTrans	   : CM_WOTransaction;
	wod		   : CM_WodToDo;
begin
	
	wod := self;
	
	if wod.myWorkOrderDetail &lt;&gt; null then  //Cargo ToDo
		woTrans := wod.myWorkOrderDetail.getLastTransOfType(TRANS_TYPE_WO_TITODO_COMPLET);
	else
		woTrans := wod.getLastTransOfType(TRANS_TYPE_WO_TITODO_COMPLET);
	endif;
	
	if woTrans = null then
		woTrans := wod.createWOTransaction(wod.TRANS_COMPLETED, null, null);	
	endif;

	if woTrans &lt;&gt; null then
		woTrans.addResourcesFromProxys(_resourceUsageProxys);
	endif;
	
epilog

end;</source>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="createWOTransForToDoTask" id="280dbedc-505d-47a4-a593-c6ce9e52a735">
        <source>createWOTransForToDoTask(_transType : Integer): CM_WOTransaction;
/*
Purpose:	If the WLE is for a TI ToDO Task work order detail, and the to do task type has a work order transaction type configured for the completion 
				then there are no TIs on the to do task just the WOD.	We must use the transaction type on the to do task not the system ones for work order details	

Date		Who		Reason
14JUN2023	NAVAB1	 CR 54345 TASK 58281 
*/

vars
	woTrans			: CM_WOTransaction;
	transType,
	woTranstype		: Integer;
	class 			: Class;
	parent			: CM_WorkOrder;
	job : CM_Job;
begin
	
	if self.isWorkOrderVoyageDtl then	
		return null;
	endif;
	
	transType := _transType; 
	class 	  := global.getTiTxnClassForType(transType, true);// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
	parent    := self.myParent;
	
	create woTrans as class persistent;
	woTrans.setBaseAttributes( app.serverTimestampAtTrxStart, parent, transType, parent.getMyTerminal()); 
	woTrans.setMyWodtl(self);	

	// ### TFS CR 62818 TASK 62821 18MAR2024 NAVAB1
	job := self.allJobs.first;

	if job &lt;&gt; null then
		if job.isRetrospective() then
			woTrans.setDateTime(job.retrospectiveDT.addSeconds(1)); // the retro date has already been used for the COMPLETE
		endif;
	endif;
	
	return woTrans;

epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <ReturnType type="CM_WOTransaction"/>
    </JadeMethod>
    <JadeMethod name="createWOTransaction" id="7025060f-66ea-4813-a40a-a038047d3d64">
        <source>createWOTransaction(_transType: Integer; _resourceUsageProxys : CM_ResourceTypeUsageSet; _task : CM_ToDoTask): CM_WOTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 Jan 2023 	navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
04 Nov 2024		navhl20 Bug MTN-33380: TI To Do Task Completed transaction on the WO transactions form is NOT updating with the effective date/time
*/

vars
	trans : CM_WOTransaction;
	job : CM_Job;
begin
	trans :=  inheritMethod(_transType, _resourceUsageProxys, _task);
	
	if self.myWorkOrderDetail &lt;&gt; null then
		trans.setMyWodtl(self.myWorkOrderDetail);
	endif;

	// ### TFS CR 62818 TASK 62821 18MAR2024 NAVAB1
	job := self.allJobs.first;

	if job &lt;&gt; null then
		/*
		//04.11.2024 navhl20 #33380
		if job.isRetrospective() then
			trans.setDateTime(job.retrospectiveDT);
		endif;*/
		if app.myPassport.retrospectiveDT.isValid then					//04.11.2024 navhl20 #33380
			trans.setDateTime(app.myPassport.retrospectiveDT);
		endif;
	endif;
	
	return trans;
epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <ReturnType type="CM_WOTransaction"/>
    </JadeMethod>
    <JadeMethod name="doActionTaskKnown" id="8fefaf76-0533-4914-9e51-cf9be6c5194c">
        <updating/>
        <source>doActionTaskKnown(_woActionIF: CMIF_WorkOrderAction; _realJob: CM_Job io; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2023		navma1	Initial creation
19 Apr 2023 		navhl20	Defect 57571: MTN - WO - Error when creating a ToDo Cargo work order on the web portal
*/

vars
	
begin
	inheritMethod(_woActionIF, _realJob, _passport);
	
	if not _woActionIF.useYardJobs then								//19.4.2023 navhl20 #57571
		app.myUtilityCA.utlCreateToDosForWO( self, _passport );
	endif;
epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAdvWOTransactionType" id="a10dce59-5041-426a-ae3d-706d533d9715">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TITODO_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TITODO_UPDATED;
	else
		return TRANS_TYPE_WO_TITODO_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="eabe6648-d166-4f45-9090-91d83cb52e67">
        <source>getDisplayString(_useShortDesc : Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Aug 2009	cnwmd1	Initial creation
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
26 May 2022	navma1	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
06 Apr 2023 navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	displayStr : String;
	typeDesc   : String;
begin
	typeDesc := self.getTypeDescription();													 	//29.09.2021 navma1 #51925
	
	if _useShortDesc then
		//17.03.2022 navma1 #53038
			displayStr := typeDesc;							 									//06.4.2023 navhl20	#57301[57303]
	else
		//displayStr :=  self.getLongDescription(typeDesc,toDoDesc);			    			//29.09.2021 navma1 #51925
		displayStr :=  self.getLongDescription(typeDesc,null);			     					//06.4.2023 navhl20	#57301[57303]
	endif;
epilog
	return displayStr;
end;
</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
