/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design

*/

vars
	woForm 			 : YRD_WorkOrderOperation;
begin
	woForm 			 := app.getForm(YRD_WorkOrderOperation.name).YRD_WorkOrderOperation;
	
	if woForm = null then
		woForm := app.loadForm(YRD_WorkOrderOperation, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderOperation;
	endif;
	
	if woForm = null then
		return;
	endif;
	
	woForm.centreWindow;
	woForm.setMyTerminal(self.myTerminal);
	woForm.show;
epilog

end;</source>
