    <JadeMethod name="canUserSet" id="7d696189-b773-47cb-9328-48785e6f708e">
        <source>canUserSet(_propName: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/
vars

begin
	if _propName = CM_EDIDataTransManifest::myCargoOnSite.name or
	   _propName = CM_EDIDataTransManifest::myGateDocument.name or
	   _propName = CM_EDIDataTransManifest::myShipManifest.name or
	   _propName = CM_EDIDataTransManifest::myTrainConsist.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTransientChildrenClasses" id="8b5dcbaf-7e66-489a-823a-03ed52d68387">
        <updating/>
        <source>createTransientChildrenClasses() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2023	jlirs1	TFS 59171 Transport Manifest User Defined Format
*/

vars

begin
	if self.isTransient then
		create self.myCargoOnSite transient;
		create self.myGateDocument transient;
		create self.myShipManifest transient;
		create self.myTrainConsist transient;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="02e123f3-7218-47ad-ba26-ac5d4b37a5ea">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 September 2023		navmd1	Initial creation TFS 53853

*/

vars

begin
	// There is one CM_EDIFile shared between 5 data objects (including this one)
	// There are parent-child which means the File gets automatically deleted when the data does
	// To prevent things being done out of order, we need to unlink these references
	// Leaving just the one on us intact
	// NB. CM_EDIData::erase does something similar, just, from the other side
	// NB. A couple of unit tests that sanity check TI types / ent table defs don't assign a myEDIFile
	
	if self.myEDIFile &lt;&gt; null then
		if self.myCargoOnSite &lt;&gt; null then
			self.myEDIFile.allEDIData.remove(self.myCargoOnSite);
		endif;
		if self.myGateDocument &lt;&gt; null then
			self.myEDIFile.allEDIData.remove(self.myGateDocument);
		endif;
		if self.myShipManifest &lt;&gt; null then
			self.myEDIFile.allEDIData.remove(self.myShipManifest);
		endif;
		if self.myTrainConsist &lt;&gt; null then
			self.myEDIFile.allEDIData.remove(self.myTrainConsist);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteManifestData" id="027074c8-bc4e-4fe0-b080-3b10cfa4bdaf">
        <source>deleteManifestData(_existEdiData : CM_EDIData output; _passport : CM_Passport input; _isWOApproved : Boolean output) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2023	navsp1	Initial creation TFS 58055
9  Oct 2023 navra1  TFS 60777 EUP | FR 53824 - VBS Slot 'cleanup'
12 Oct 2023 navra1  TFS 60845 EUP | FR 53824 Transport Manifest - Updating Road Manifest fails "External Reference is already used"
24/11/2023	navcs2	ChangeRequest 60874: MTN | Jade Upgrade - Unit Test Review (Fixing transient leaks for postManifest unit tests)
//28 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
23/02/2024	navcs2	ChangeRequest 62250: EUP | FR 53824 - Transport Manifest - Multiple Manifests For a Single Wagon Need to be Possible. 
05/03/2024	navcs2	ChangeRequest 58059[58497]: EUP | Manifest - Change of Transport Mode
22 Nov 2024 navsp1  JIRA 33407 EUP | FR 53824 - Unable to update Manifest/VBS Appointment after WO Approved
04 Jun 2025	navdap1	MTN-12349 EUP - Transport Manifest load after locking does not add all cargo to work order
*/

vars
	existWorkOrder	: CM_WorkOrder;
	deleteTISet ,
	tisWithWarnSet,
	delTiSetVBS 	: CM_TISet;
	ti				: CM_TrackedItem;
	clientReference : String;
	existEdiFile	: CM_EDIFile;
	existEdiData,	
	ediData	,
	existManEdiData : CM_EDIData;
	ediDataOnsite	: CM_EDIDataCargoOnSite;
	bol 			: CM_BOLIn;
	ediTI 			: CM_EDITrackedItem;
	voyage 			: CM_Voyage;
	voyageCode 		: String;
	allBOLs 		: ObjectArray;
	vbsTerminal 	: CM_VehicleBookingTerminal;		//navra1 - TFS 60777 - 9th Sep 2023
	vbTS,pxyVBTS	: CM_VehicleBookingTimeSlot;		//navra1 - TFS 60777 - 9th Sep 2023
	prevVBReference : String;							//navra1 - TFS 60777 - 9th Sep 2023
	existingCG		: CM_CargoGroup;
	terminal		: CM_Terminal;
	existEdiDataMan : CM_EDIDataTransManifest;
	canDeleteVBS	: Boolean;
	vbsItem			: CM_VehicleBookingTimeSlotItem;
	manifestLength	: Integer;									// 05/03/2024 navcs2 ChangeRequest 58059[58497]
	isSingleWO		: Boolean;
	invalidTI		: Boolean;			// MTN-12349
	vbsTI			: CM_TrackedItem;	// MTN-12349
begin
	on Exception do app.handleDeletedObject(exception, vbsTI, invalidTI);	// MTN-12349
	
	terminal := self.getMyTerminal();
	
	if self.myGateDocument &lt;&gt; null then
		ediData    		:= self.myGateDocument;
	elseif self.myTrainConsist &lt;&gt; null then
		ediData    		:= self.myTrainConsist;
	elseif self.myShipManifest &lt;&gt; null then
		ediData    		:= self.myShipManifest;
	elseif self.myCargoOnSite &lt;&gt; null then
		ediData    		:= self.myCargoOnSite;
	endif;

	if ediData.myEDIFile = null and
	   self.myEDIFile &lt;&gt; null then
		clientReference := self.myEDIFile.ediClientRef;
	else
		clientReference := ediData.myEDIFile.ediClientRef;
	endif;
	
	create allBOLs transient;
	create deleteTISet transient;
	create delTiSetVBS transient;
	if ediData.myEDIFile = null and
	   self.myEDIFile &lt;&gt; null then
		self.myEDIFile.myEDIFileType.findExistingEDIFile(clientReference, self.myEDIFile, existEdiFile);
	else
		self.myEDIFile.myEDIFileType.findExistingEDIFile(clientReference, ediData.myEDIFile, existEdiFile);
	endif;
	
	if existEdiFile &lt;&gt; null then
		existEdiData	:= existEdiFile.ediData;
		_existEdiData 	:= existEdiData;
		manifestLength  := self.manifestNumber.length;
	endif;
	
	if existEdiData &lt;&gt; null then
		if self.myCargoOnSite &lt;&gt; null then						//09.Oct.2023 navsp1 TFS 58058 - Delete Cargo group and all the assigned TI's for Internal(Zimmer)
			ediDataOnsite := existEdiData.CM_EDIDataTransManifest.myCargoOnSite;
			foreach ediTI in ediDataOnsite.allEDITrackedItems do
				if ediTI.isEDICargo then		//28 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 	// MTN-12349
					ti := ediDataOnsite.getRealCargoItem(ediTI.CM_EDICargoTI);
					if ti &lt;&gt; null then
						if ti.isCargoGroupItem then
							existingCG := ti.CM_CargoGroup;
							break;
						else
							//existingCG := terminal.getCargoGroupItemForOperator( ti.getMyCargoGroupId, ti.operatorCode, ti.cargoType);//14.Nov.2023 navsp1 TFS 61127
							existingCG := terminal.getCargoGroupItem( ti.getMyCargoGroupId ); 											//14.Nov.2023 navsp1 TFS 61127
							break;
						endif;
					endif;
				endif;
			endforeach;
			
			if existingCG &lt;&gt; null then
				existingCG.allAssignedTrackedItems.copy(deleteTISet);
				
				create tisWithWarnSet transient;
				//Delete all the TIs assigned to the cargo group
				app.myTrxDA.trxDeleteTrackedItems(deleteTISet, tisWithWarnSet, false, _passport);
				
				if not _passport.hasErrors then
					//Finally delete the cargo group
					app.myTrxDA.trxDeleteTI(existingCG, false, _passport);
				endif;	
			endif;
		else
			isSingleWO := false;
			//20.11.2023 navsp1 TFS 61039
			existEdiDataMan := existEdiData.CM_EDIDataTransManifest;
			if existEdiDataMan.myGateDocument &lt;&gt; null then
				existManEdiData    		:= existEdiDataMan.myGateDocument;
				isSingleWO := true;															// 18/03/2024 navcs2 ChangeRequest 58059[58497]								
			elseif existEdiDataMan.myTrainConsist &lt;&gt; null then
				existManEdiData    		:= existEdiDataMan.myTrainConsist;
				isSingleWO := true;															// 23/02/2024	navcs2	ChangeRequest 62250
			elseif existEdiDataMan.myShipManifest &lt;&gt; null then
				existManEdiData    		:= existEdiDataMan.myShipManifest;
				isSingleWO := true;
			endif;	
			/* 																				 //14.Nov.2023 navsp1 TFS 61127
			//25.Oct.2023 navsp1 TFS 60913
			//Avoid deleting the TI'd, WO, and CG if the manifest for different operator
			
			//01.Nov.2023 navsp1 TFS 61067
			if existManEdiData.allEDITrackedItems &lt;&gt; null then
				existOpCode := existManEdiData.allEDITrackedItems.first.getOperatorCode;
			endif;			
			if ediData.allEDITrackedItems &lt;&gt; null then 
				newOpCode := ediData.allEDITrackedItems.first.getOperatorCode;
			endif;*/
			
			//if existOpCode = newOpCode then												//14.Nov.2023 navsp1 TFS 61127
				//if existEdiData.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
				if ediData &lt;&gt; null then	
					foreach ediTI in ediData.allEDITrackedItems do	//jlirs1 17 Jul 2023 TFS 58884 (57807) 
						if ediTI.isKindOf(CM_EDIBOLHdrTI) then
							if voyageCode = null then
								voyageCode := ediTI.CM_EDIBOLHdrTI.getVoyageCode();
								voyage := self.getMyTerminal.allVoyagesByCode.getAtKeyGeq(voyageCode, null);
							endif;
							foreach bol in voyage.allBOLInByTypeStatusNumDT do
								if bol.number = ediTI.id and
								   voyage.allBOLInByTypeStatusNumDT.includes(bol) then
									allBOLs.add(bol);
								endif;
							endforeach;
						endif;
					endforeach;
				endif;
				
				existEdiDataMan.getWorkOrderForManifest(existWorkOrder);					//JIRA-33407 - moved to a common method
				if existWorkOrder &lt;&gt; null then
					_isWOApproved := existWorkOrder.taskStatus = WO_STATUS_APPROVED;		//JIRA-33407
					app.myTrxDA.trxDeleteWorkOrderAndTI(existWorkOrder, allBOLs, self.manifestNumber, isSingleWO, _passport);	//04.Jan.2023 navsp1 TFS 61915 / 60866
				endif;
				
				//navra1 - TFS 60777 - 9th Oct 2023 - start		
				if _passport.allErrors.size() &lt;&gt; 0 then
					app.writeLog("Errors while deleting manifest data, not proceeding further", LogERROR);
					return;
				endif;
				
				if existEdiData &lt;&gt; null and existEdiData.isTransportManifest and existEdiData.CM_EDIDataTransManifest.transportReferenceCustomer &lt;&gt; null then
					//prevVBReference := existEdiData.CM_EDIDataTransManifest.transportReferenceCustomer;
					prevVBReference := existEdiData.CM_EDIDataTransManifest.transportReferenceCustomer.toUpper().replace(Space,'');			//navra1 - TFS 60845 - 12th Oct 2023
				endif;
				
				if prevVBReference &lt;&gt; null then
					//delete the VBS created for this manifest as well
					vbsTerminal := self.getMyTerminal().myVehicleBookingTerminal;
					vbTS := vbsTerminal.allVBTimeslotsByExtRef[prevVBReference];
					if vbTS &lt;&gt; null then
						
						//20.Nov.2023 navsp1 TFS 61039
						//Skip the VBS delete if it contains another manifest items.
						pxyVBTS := app.createUpdateProxy(vbTS).CM_VehicleBookingTimeSlot;					
						canDeleteVBS 	:= true;
						if vbTS.allVehicleBookingItems &lt;&gt; null then
							foreach vbsItem in pxyVBTS.allVehicleBookingItems do
								invalidTI := false;								// MTN-12349
								vbsTI := vbsItem.myTrackedItem;					// MTN-12349
								if vbsTI &lt;&gt; null then							// MTN-12349
									vbsTI.edition;								// MTN-12349
								endif;											// MTN-12349
								if vbsTI &lt;&gt; null and not invalidTI then			// MTN-12349
									if vbsTI.manifestNumber[1:manifestLength] &lt;&gt; existEdiData.CM_EDIDataTransManifest.manifestNumber then
										canDeleteVBS := false;
									else
										pxyVBTS.allVehicleBookingItems.remove(vbsItem);		
										delete vbsItem;										//06.Mar.24 navsp1 TFS 61039
									endif;
								else
									pxyVBTS.allVehicleBookingItems.remove(vbsItem);	
									delete vbsItem;											//06.Mar.24 navsp1 TFS 61039
								endif;
								//delete vbsItem;		// 24/11/2023	navcs2	ChangeRequest 60874 //05.Mar.24 navsp1 TFS 61039 - This was deleting the VBS items
							endforeach;
						endif;
						if canDeleteVBS then
							app.myTrxDA.trxDeleteVehicleBooking(vbTS, _passport);
						else
							app.myTrxUA.trxUpdateVehicleBookingAdv(pxyVBTS, _passport);
						endif;
						
					endif;
				endif;
			//endif;			//14.Nov.2023 navsp1 TFS 61127
			
		endif;
		
		if _passport.allErrors.size() &lt;&gt; 0 then
			app.writeLog("Errors while deleting manifest data, not proceeding further", LogERROR);
			return;
		endif;
		//navra1 - TFS 60777 - 9th Oct 2023 - end
		
		//Update the existing EDI file
		app.myTrxUA.trxSetEDIDataStatus(existEdiFile.ediData, CM_EDIFile.EDI_STATUS_CANCELLED);		
		app.writeLog(method.qualifiedName &amp; Tab &amp;"EDI file ("&amp;existEdiFile.ediClientRef&amp;") status has been updated to cancel", LogINFO);
		
		if self.statusString = CMIF_JsonHeaderEUP.Status_Cancel then
			//Set the status to DB loaded for the new EDI file
			app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED);			
			app.writeLog(method.qualifiedName &amp; Tab &amp;"EDI file ("&amp;self.manifestNumber&amp;") status has been updated to db loaded", LogINFO);	
			
		endif;
	
	else
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No EDI files exist with the reference"&amp; self.manifestNumber,LogERROR);
		return;
	endif;
epilog
	delete tisWithWarnSet;
	delete deleteTISet;
	delete allBOLs;
	delete delTiSetVBS;
	delete pxyVBTS;
end;</source>
        <access>protected</access>
        <Parameter name="_existEdiData" type="CM_EDIData" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_isWOApproved" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="deleteTransientChildrenClasses" id="c343c46a-bf47-4295-8001-488267abbef7">
        <updating/>
        <source>deleteTransientChildrenClasses() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2023	jlirs1	TFS 59171 Transport Manifest User Defined Format
*/

vars

begin
	if self.isTransient then
		delete self.myCargoOnSite;
		delete self.myGateDocument;
		delete self.myShipManifest;
		delete self.myTrainConsist;
	endif;
epilog

end;</source>
