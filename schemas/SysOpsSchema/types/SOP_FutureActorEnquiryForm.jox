    <JadeMethod name="mskDateFrom_lostFocus" id="85c6540f-3981-43c7-a69f-48f673549b1f">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mskDateFrom_lostFocus(editMask: JadeEditMask input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/

vars

begin
	if self.searchFromDT = null then
		create self.searchFromDT transient;
	endif;
	self.searchFromDT.dateTime.setDate(self.mskDateFrom.getDate());
	
	if process.isRam() then
		write self.searchFromDT.dateTime.date;
	endif;
epilog

end;</source>
