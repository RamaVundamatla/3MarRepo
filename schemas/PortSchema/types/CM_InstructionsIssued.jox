    <JadeMethod name="setProxy" id="331831c0-d19a-4caf-9989-b110049931c7">
        <updating/>
        <source>setProxy( _internal, 
		  _external : String;
		  _myInstruction: CM_InstructionType;
		  _parent : CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.internalInstructions 			:= _internal;
	self.externalInstruction 	:= _external;
	self.myInstructionType 		:= _myInstruction;
	self.myParent 				:= _parent;
epilog

end;</source>
        <Parameter name="_internal" type="String"/>
        <Parameter name="_external" type="String"/>
        <Parameter name="_myInstruction" type="CM_InstructionType"/>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="878b8428-cf01-4f3b-a48f-4a3d4695dc29">
