    <JadeMethod name="setProxy" id="93794927-8604-4320-9b26-1699ff516a9d">
        <updating/>
        <source>setProxy(_bOneLinePerFinancialPeriod : Boolean; _bPrintTrackedItems : Boolean;  _chargeByOpCon : Integer; _chargeDebtorType : CM_DebtorType;
			_calculationType : CM_CalculationType; _invoiceType : CM_InvoiceDesc; _narration : String; _printingOrder : Integer; _remarks : String;
			_unitNarration : String; _services : CM_ServiceByNameDict; _notAvailableForEntry : Boolean;
			_minimumCharge : Real; _minimumChargeGroupBy : String; _minimumChargeType : String; _currNot : Boolean;
			_taxAlwaysCharged : Boolean;	//07 May 2019	NDL	TFS 44651
			_externalRef1 : String;
			_uom		  : CM_InvoiceUnitOfMeasure	// 31 Jan 2023 navvt20 TFS 56134
			) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//Aug 2010		cnwjre1	replace _chargeByUnits with _calculationType (fifth parameter)
//Sep 2015		cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charge Changes
//07 Jun 2016	cnwrs1	TFS 2103 can crash if no self.bank
//28 Oct 2021 	navma1 ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
//30 Mar 2022	jlier1	 TFS 53286
//31 Jan 2023 	navvt20  TFS 56132 Task 56134: UI - Invoice Line Type - UOM
// ---------------------------------------------------------------------------

vars
	lineType : CM_InvoiceLineDesc;												// PAR #36909
	theBank : CM_Bank;
begin
	self.bOneLinePerFinancialPeriod    := _bOneLinePerFinancialPeriod;
	self.bPrintTrackedItems			   := _bPrintTrackedItems;
	self.myDebtorType 				   := _chargeDebtorType; 	// PAR 16666 CCMS 1047 April 2008 cnwgb1
	self.myCalculationType			   := _calculationType;  	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	self.invoiceType 				   := _invoiceType;
	self.narration 					   := _narration;//[1:60]; 	//28.10.2021 navma1 #52163
	self.printingOrder 				   := _printingOrder;
	self.remarks 					   := _remarks[1:601];
	self.unitNarration 				   := _unitNarration[1:10];
	self.isNotAvailableForEntry 	   := _notAvailableForEntry;
	self.currencyConversionNotRequired := _currNot; 			 // TFS 41484
	self.taxAlwaysCharged 			   := _taxAlwaysCharged;	 //07 May 2019	NDL	TFS 44651
	self.minimumChargeAmount           := _minimumCharge;												// PAR #36909
	self.minimumChargeGroupBy		   := self.getMinimumChargeGroupByFromStr(_minimumChargeGroupBy);	// PAR #36909
	self.externalReference1 		   :=_externalRef1;
	self.myUOM				  		   := _uom;	//31 Jan 2023 navvt20 TFS 56134
	theBank := self.getBank();
	if theBank &lt;&gt; null then
		lineType := theBank.invoiceLineDescriptors[_minimumChargeType];			// PAR #36909
		// ### JIRA 33421 18NOV2024 NAVAB1 - remove 'Cargo - '
		if lineType = null then
			lineType := theBank.invoiceLineDescriptors[_minimumChargeType[9:end]];
		endif;
	endif;
	
	if lineType &lt;&gt; null then													// PAR #36909
		self.minimumChargeInvoiceLineType := lineType;							// PAR #36909
	elseif _minimumChargeType = null then										// PAR #36909
		self.minimumChargeInvoiceLineType := null;								// PAR #36909
	endif;																		// PAR #36909

	self.services.clear;
	if _services &lt;&gt; null then
		_services.copy(self.services);
	endif;
	
end;</source>
        <Parameter name="_bOneLinePerFinancialPeriod" type="Boolean"/>
        <Parameter name="_bPrintTrackedItems" type="Boolean"/>
        <Parameter name="_chargeByOpCon" type="Integer"/>
        <Parameter name="_chargeDebtorType" type="CM_DebtorType"/>
        <Parameter name="_calculationType" type="CM_CalculationType"/>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_printingOrder" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_unitNarration" type="String"/>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_minimumCharge" type="Real"/>
        <Parameter name="_minimumChargeGroupBy" type="String"/>
        <Parameter name="_minimumChargeType" type="String"/>
        <Parameter name="_currNot" type="Boolean"/>
        <Parameter name="_taxAlwaysCharged" type="Boolean"/>
        <Parameter name="_externalRef1" type="String"/>
        <Parameter name="_uom" type="CM_InvoiceUnitOfMeasure"/>
    </JadeMethod>
    <JadeMethod name="setServices" id="cc55f9ce-324a-42e4-a4c8-37750f719b86">
        <updating/>
        <source>setServices(_services : CM_ServiceByNameDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 June 2022		jlizm1	Initial creation TFS 52495 void invoice line should only be able to edit narration

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.services.clear;
	if _services &lt;&gt; null then
		_services.copy(self.services);
	endif;

epilog

end;</source>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="bf0b5164-9994-4ba0-b9eb-69c668dd68d2">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_InvoiceLineDesc::isVoid.name or
		propName = CM_InvoiceLineDesc::minimumChargeGroupBy.name or
		propName = CM_InvoiceLineDesc::myCalculationType.name  or
		propName = CM_InvoiceLineDesc::myDebtorType.name or
		propName = CM_InvoiceLineDesc::myChildQuantityMap.name or
		propName = CM_InvoiceLineDesc::chargeByOpCon.name or
		propName = CM_InvoiceLineDesc::chargeByUnits.name or
		propName = CM_InvoiceLineDesc::bShipService.name 
		
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceLineQuantity" id="b0ea81bd-45bf-493f-a1d5-9dabcbba5d81">
        <source>updateInvoiceLineQuantity();
// CCMS 1264 Apr 2012 non-virtual CM_InvoiceLine quantity, update it from calculation type change
vars
	invoiceLine	: CM_InvoiceLine;
begin
	foreach invoiceLine in self.invoiceLines do
		if invoiceLine.invoice &lt;&gt; null then
			//if invoiceLine.invoice.status = CM_Invoice.INVOICE_POSTED then
			if invoiceLine.invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759	
				continue;
			endif;
			invoiceLine.calculateQuantity();
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="03a2dc5a-ada2-4e40-abb3-cfc68d104a6f">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 29/04/2016  cnwma1 PAR #37262 TFS #1772  JMT - Can't "Confirm Selected Train Inward" on Beta Sever
// ---------------------------------------------------------------------------

vars

begin
	if self.bank.invoiceLineDescriptors[self.narration] &lt;&gt; null then
		app.raiseCMException1(Invoi_line_type_with_narra_alr, self.narration,null,null);
	endif;
	if self.narration.trimBlanks =  null then
		app.raiseCMException(Invoi_line_type_must_have_narr,null,null);
	endif;
	if self.invoiceType =  null then
		app.raiseCMException(Invoi_line_type_must_have_invo,null,null);
	endif;
	// 36965 warning if no services
	if self.services.isEmpty then
		app.raiseCMWarning(No_service_selected, null, null, null);
	endif;
	
	if self.minimumChargeAmount &lt;&gt; null then							//29/04/2016 cnwma1 PAR #37262 TFS #1772 
		if self.minimumChargeGroupBy = null then 
			app.raiseCMException(Invoi_line_type_group_min,null,null);
		endif;
		if self.minimumChargeInvoiceLineType = null then
			app.raiseCMException(Invoi_line_type_min_invtype,null,null);
		endif;
	elseif self.minimumChargeGroupBy &lt;&gt; null then							//29/04/2016 cnwma1 PAR #37262 TFS #1772 
		if self.minimumChargeInvoiceLineType = null then
			app.raiseCMException(Invoi_line_type_min_invtype,null,null);
		endif;
		if self.minimumChargeAmount = null then
			app.raiseCMException(Invoi_line_type_min_amount,null,null);
		endif;
	elseif self.minimumChargeInvoiceLineType &lt;&gt; null then				//29/04/2016 cnwma1 PAR #37262 TFS #1772 
		if self.minimumChargeAmount = null then
			app.raiseCMException(Invoi_line_type_min_amount,null,null);
		endif;
		if self.minimumChargeGroupBy = null then 
			app.raiseCMException(Invoi_line_type_group_min,null,null);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="8210c28c-6e7f-4f3e-a327-d57c963b8c5c">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/09/2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charge changes
vars
	invDesc : CM_InvoiceLineDesc;
	whereUsed : String;
	
begin

	if not self.invoiceLines.isEmpty then
		app.raiseCMException2(Invoic_line_type_cannot_delete,self.narration, "invoice lines",null,null);
	endif;

	if self.isVoid and
	   not self.isTransient then
		app.raiseCMException(Cannot_Delete_VOID_LineType, null, null);
		
	endif;

	// PAR 21142 modified for CM_DebtorInvoiceLineDesc which don't have a bank
	if self.bank &lt;&gt; null and
	   self.bank.validateInvLineDescUsedTranMap(self) then
		app.raiseCMException2(Invoic_line_type_cannot_delete,self.narration, "transaction map",null,null);
	endif;

	if not self.allInvoiceTypeMappingsByDebtor.isEmpty() then
		app.raiseCMException2(Invoic_line_type_cannot_delete,self.narration, "invoice line mappings",null,null);
	endif;

	if not self.allConsolidatedDebtorInvLineD.isEmpty() then
		app.raiseCMException2(Invoic_line_type_cannot_delete,self.narration, "invoice line consolidations",null,null);
	endif;
	
	if self.bank &lt;&gt; null and self.bank.validateInvLineDescUsedChMaps(self) then
		app.raiseCMException2(Invoic_line_type_cannot_delete,self.narration, "invoice line charge mapping",null,null);
	endif;
	
	// check I'm not used as a minimum charge invoice line type on any other invoice line types					// PAR #36909
	foreach invDesc in CM_InvoiceLineDesc.instances discreteLock do												// PAR #36909
		if invDesc.minimumChargeInvoiceLineType = self then														// PAR #36909
			app.raiseCMException2(Invoice_line_type_used_min, self.narration, invDesc.narration, null, null);	// PAR #36909
		endif;																									// PAR #36909
	endforeach;																									// PAR #36909
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.narration, whereUsed, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c2223444-de0c-4bf1-a740-d7eab64ad67e">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------	
// 29/04/2016  	cnwma1 	PAR #37262 TFS #1772  JMT - Can't "Confirm Selected Train Inward" on Beta Sever
// 16/06/2022	jlizm1	TFS 52495 Disable editing of void service and invoice lines
// ---------------------------------------------------------------------------

vars
	realMe, anILD : SelfType;
	realBank : CM_Bank;
	whereUsed : String;
begin
	
	realMe := self.pxyGetRealObject();
	if realMe &lt;&gt; null then
		realBank := realMe.bank;
	endif;
	if realBank &lt;&gt; null then
		anILD := realBank.invoiceLineDescriptors[self.narration];
		if anILD &lt;&gt; null and anILD &lt;&gt; self.pxyGetRealObject() then
			app.raiseCMException1(Invoi_line_type_with_narra_alr,self.narration,null,null);
		endif;
	endif;
	
	// PAR 21142
	if self.narration.trimBlanks =  null then
		app.raiseCMException(Invoi_line_type_must_have_narV,null,null);
	endif;
//	if self.invoiceType =  null then
	if self.invoiceType =  null and not self.isVoid then	//02 Feb 2018	NDL	TFS 36900
		app.raiseCMException(Invoi_line_type_must_have_invD,null,null);
	endif;
	// 36965 warning if no services
	if self.services.isEmpty then
		app.raiseCMWarning(No_service_selected, null, null, null);
	endif;
	
	
	if self.minimumChargeAmount &lt;&gt; null then							//29/04/2016 cnwma1 PAR #37262 TFS #1772 
		if self.minimumChargeGroupBy = null then 
			app.raiseCMException(Invoi_line_type_group_min,null,null);
		endif;
		if self.minimumChargeInvoiceLineType = null then
			app.raiseCMException(Invoi_line_type_min_invtype,null,null);
		endif;
	elseif self.minimumChargeGroupBy &lt;&gt; null then							//29/04/2016 cnwma1 PAR #37262 TFS #1772 
		if self.minimumChargeInvoiceLineType = null then
			app.raiseCMException(Invoi_line_type_min_invtype,null,null);
		endif;
		if self.minimumChargeAmount = null then
			app.raiseCMException(Invoi_line_type_min_amount,null,null);
		endif;
	elseif self.minimumChargeInvoiceLineType &lt;&gt; null then				//29/04/2016 cnwma1 PAR #37262 TFS #1772 
		if self.minimumChargeAmount = null then
			app.raiseCMException(Invoi_line_type_min_amount,null,null);
		endif;
		if self.minimumChargeGroupBy = null then 
			app.raiseCMException(Invoi_line_type_group_min,null,null);
		endif;
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="zDeleteInvoiceLines" id="5c8d27fa-6d16-4686-9c26-5b13d583e8d9">
