    <JadeMethod name="updateTableElapsedTimes" id="bf68a247-2359-4622-a4ae-7f3d2660eb5d">
        <updating/>
        <source>updateTableElapsedTimes(_updateTime : Boolean) protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	row : Integer;
	time : String;
	timeCell : JadeTableCell;
begin
	foreach row in self.tblJobs.fixedRows + 1  to self.tblJobs.rows do
		timeCell:=self.tblJobs.accessCell(row,ColNoTime);
		if timeCell &lt;&gt; null then
			time:=timeCell.text;
			if _updateTime then
				timeCell.text:=(time.Integer + 1).String;
			endif;
			if time.Integer &gt; self.configElapsedTime then
				timeCell.fontBold:=true;
				timeCell.foreColor:=Red;
			else
				timeCell.fontBold:=false;
				timeCell.foreColor:=Black;	
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_updateTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="420b0a39-0c4a-44bf-8b65-9a274eb0dadd">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	indx : Integer;
	rtQueueEntry : CM_RTQueueEntry;
	row, foundRow : Integer;
	tblRow : JadeTableRow;
begin
	app.mousePointer	:=	Busy;
	if eventType = Event_Delete_Queue_Entry  or  eventType = Event_Add_Queue_Entry    then
		if userInfo.isKindOf(CM_RTQueueEntry) then
			self.refreshTableEntry(userInfo.CM_RTQueueEntry);
		else
			self.loadTaskTable();
		endif;
		
	elseif eventType = EVENT_MACH_BROADCAST_MSG  then
		app.msgBox(userInfo.String,"Message from RT Control",MsgBox_OK_Only);
	elseif eventType = EVENT_RFIDINFO then
		if txtWrongData.text = null then
			txtWrongData.text:=userInfo.String;
		else
			txtWrongData.text:=txtWrongData.text &amp; CrLf &amp;  userInfo.String;
		endif;
	elseif eventType = EVENT_MACHQUEUE_ALTERED then
		self.doControlChangedQueue(userInfo.String);
	elseif eventType = EVENT_RESET_MEDIATOR then
		self.doControlResetSession(userInfo.String);
	elseif eventType = EVENT_TWISTLOCK_CLOSED then
		foundRow:=0;
		if  userInfo &lt;&gt; null and userInfo.isKindOf(MobileHandHeldThin::CM_RTQueueEntry)  then
			rtQueueEntry:=userInfo.CM_RTQueueEntry;
			row:=1;

			while row &lt;&gt; self.tblJobs.rows do
				row:=row+1;
				tblRow:=self.tblJobs.accessRow(row);
				if tblRow.itemObject &lt;&gt; null and (tblRow.itemObject.DTO_RTQueueEntry.myRealQueueEntry = rtQueueEntry) then
					foundRow:=row;
					app.myHandHeldGuiAgent.writeLog(" FOUND  "  &amp; tblRow.String &amp; Tab &amp; tblRow.itemObject.getOidString &amp; Tab &amp;  rtQueueEntry.getOidString);
					break;	
				endif;
			endwhile;		
		endif;
		if foundRow = 0 then
			self.tblJobs.accessedRow:=null;
		else
			self.acceptedRow:=foundRow;
		endif;
	//	app.myHandHeldGuiAgent.writeLog(tblRow.row.String);
		//don't worry if they've already accepted one
		if not self.frmAccept.visible then
			self.doAcceptTask();
		endif;
	elseif eventType = EVENT_TWISTLOCK_OPENED then
		// only do it if the frame is visble i.e. have already accepted
		if self.frmAccept.visible then
			self.txtRow.text:=userInfo.String;
			self.doMove();
		endif;
	else
		return;
	endif;
	
epilog
	app.mousePointer	:=	Idle;



end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
