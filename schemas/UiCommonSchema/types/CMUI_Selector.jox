    <JadeMethod name="addCriteriaLine" id="a672c895-35ab-46b7-9446-c9b72bc50280">
        <updating/>
        <source>addCriteriaLine() : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	idx 						: Integer;
	criteriaLine				: CM_SelectorCriteriaLine;
	tblSheet					: JadeTableSheet;
begin

	self.queryLineChanged := false;
	criteriaLine := self.setPropertyValueAndOperator(null, false);
	
	if criteriaLine = null then//creation was not sucessful
		return false;
	endif;
	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);
	criteriaLine.setMyCriteriaLineHolder(tblSheet.itemObject.CM_QueryCriteriaLineHolder);
	
	idx := tblSheet.addItem(criteriaLine.getDescriptionString);
	tblSheet.accessRow(idx).itemObject := criteriaLine;
	
//	if criteriaLine.isUnavailableAtRunTime then
//		tblSheet.accessRow(idx).backColor := self.ROW_COLOUR_UNAVAILABLE;
//	else
	//	tblSheet.accessRow(idx).backColor := self.ROW_COLOUR_AVAILABLE;
		tblSheet.accessRow(idx).backColor := criteriaLine.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891
//	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addDefaultPropertyLine" id="1d8da395-4241-4b0e-bed7-015a535ea17b">
        <updating/>
        <source>addDefaultPropertyLine(_propName : String; _qOperatorStr : String; _value : Object) updating;
// May 2011 cnwjre1 27097 CCMS 2043 allow set up of generic selector queries
vars

begin
	self.properties.add(_propName);
	self.operators.add(_qOperatorStr);
	self.values.add(_value);
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addResultsRow" id="7762fe31-e51d-4cb8-9ead-084f2f405a37">
        <source>addResultsRow(_obj : Object) protected;
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 08/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 18/02/2014	cnwdap1		PAR #33329 Remove double-conversion of measurements which was resulting in rounding errors
//16 Mar 2016	cnwrs1	TFS 1455 Add Freight Tons
//TFS2303 cnwns1 15/7/16	Multi-timezone issue - Selector displaying dates wrong
// 24 Jul 2023	jlirs1		TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
// 10 Sep 2024 	navlc30 	Bug 65895: TPT | Selector Query - Change of Ownership
vars
	propDict		: CM_QueryPropertyDict;
	queryProp		: CM_QueryProperty;
	attrName,
	propValStr,
	rowStr			: String;
	propArray		: StringArray;
	propVal			: Any;
	idx				: Integer;
	oper 			: CM_QueryOperator;
	propName		: String;							// PAR #31155
	pos, revPos		: Integer;							// PAR #31155
	measureStr		: String;							// PAR #31155
	measure,											// PAR #31155
	default			: CM_MeasurementType;				// PAR #31155
	
begin
	if self.myQDef = null then
		return;
	endif;
	
	propDict := self.myQDef.allQueryProperties;
	propArray := self.allVisibleColumns;
	if propArray.size = 0 then	//Par 16731. When choosing a Query Definition (cmbSelectorMode), a set of columns can be null fro some definitions (Log Docket etc.)
		app.raiseCMException( ERR_NoColumnsInColumnOrganizer, null, self );
		return;
	endif;
	
	//foreach attrName in propArray do
	foreach attrName in propArray discreteLock do
		measureStr := null;										// PAR #31155
		measure := null;										// PAR #31155
		if attrName.isMeasurementType then						// PAR #31155
			pos := attrName.pos("_", 1);						// PAR #31155
			revPos := attrName.reversePos("_");					// PAR #31155
			measureStr := attrName[revPos+1:end];				// PAR #31155
			measure := app.myRoot.allMeasurementTypesByShortName[measureStr];	// PAR #31155
			propName := attrName[pos+1:revPos-pos-1];			// PAR #31155
		else													// PAR #31155
			propName := attrName;								// PAR #31155
		endif;													// PAR #31155
		//queryProp := propDict[attrName];						// PAR #31155
		queryProp := propDict[propName];						// PAR #31155
		if queryProp = null then
			continue;   //PAR23233 - 26/03/2010 cnwsh3 This needs to be the same as the code in self.displayResultColumn otherwise the results get out of sync with the labels.
			//propValStr := 'Could not retreive ' &amp; attrName;
		elseif (CM_QStringLookupProperty.hasInstance(queryProp)) then//no need to translate
			propValStr := _obj.getPropertyValue(queryProp.propertyName).String;
		elseif queryProp.propertyName = CM_TrackedItem::getContainerNumberText.name then	// 24 Jul 2023	jlirs1		TFS 59187 (59019)
			propValStr := _obj.CM_TrackedItem.getContainerNumberText();
		elseif queryProp.propertyName = CM_TrackedItem::getCOODate.name then				//10.09.2024 navlc30 #65895
			propValStr := _obj.CM_TrackedItem.getCOODate();
        elseif queryProp.propertyName = CM_TILC::getOnboardQuantity.name then               //JIRA-34864
            propValStr := _obj.CM_TILC.getOnboardQuantity().String;                         //JIRA-34864
		else 
		
			propVal := queryProp.getValueForObject(_obj,null);
			if propVal = null 
			and (not queryProp.displayNull) then
				propValStr := null;
			else
				if queryProp.propertyName = CM_TrackedItem::getFreightTons.name then
					propValStr := propVal.Decimal.asStringJMTWithPrecision(4, false);
				elseif queryProp.propertyName = CM_Invoice::getInvoiceNote.name then 		// ### TFS 52752 04Feb2022 NAVPW1
					propValStr := propVal.String.formatWithEllipsis(1, 100, true);			// ### TFS 52752 04Feb2022 NAVPW1
				else
					if propVal.isKindOf(TimeStamp) then										//TFS2303 cnwns1 15/7/16
						propVal := propVal.TimeStamp.systemToLocalTimeUsingObject(_obj);	//TFS2303 cnwns1 15/7/16
					endif;																	//TFS2303 cnwns1 15/7/16
					propValStr := queryProp.translateToDisplayValue(propVal);
				endif;
				// For measurement types, propValStr is now in whatever unit the system default is.	// PAR #31155
				// We now need to convert that to whatever unit we're displaying here				// PAR #31155
				if measure &lt;&gt; null then																// PAR #31155
					if CM_Object.hasInstance(_obj) then														// PAR #33329
						propValStr := _obj.CM_Object.getRawMeasurementValue(propName).String;				// PAR #33329
						propValStr := app.convertMeasurementForDisplay(measureStr, propValStr.Decimal);		// PAR #33329
					else																					// PAR #33329
						propValStr := propVal.String;	//cnwmc5 - PAR 32516
						default := app.getDefaultMeasurementForType(measure.measurementType);		// PAR #31155
						propValStr := app.convertMeasurementFromTo(default.shortName, measureStr, propValStr.Decimal).String;	// PAR #31155
						propValStr := measure.removeDecimalZeros(propValStr);						// PAR #31155
					endif;																					// PAR #33329							
				endif;																				// PAR #31155
			endif;
		endif;
		
		rowStr := rowStr &amp; propValStr &amp; Tab;
	endforeach;
	
	self.tblResults.accessRow(self.tblResults.addItem(rowStr)).itemObject := _obj;
	self.beginNotification(_obj, Object_Delete_Event, Response_Continuous, null);
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="8f8fe34e-53c9-44c1-b66f-e50b88537427">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     22 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// 31/01/2011	cnwdap1		PAR #26830 CCMS 2013 Queue from Itrem Selector
vars
	frm			: CMUI_Toolbar;
begin
	frm := self.frmToolbar;
	frm.addButton(self.btnClose, CMUI_Toolbar.Control_Alignment_Right);

	frm.addButton(self.btnShowHideSave, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnSendScreen, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSendReport, CMUI_Toolbar.Control_Alignment_Left);
	
	// cnwrl1 23/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	if self.bAllowSummaryDefn then
		frm.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	// cnwrl1 23/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	frm.addButton(self.btnExtract, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	frm.addButton(self.btnShowHideBR, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnLocateYardEnq, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	if app.myCurrentUserCan( null, PmAdmSelectorQueryForRT ) then
		frm.addButton(self.btnRTQueries, CMUI_Toolbar.Control_Alignment_Left);
		frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	// PAR #26830 CCMS 2013 allow move button on form
	if app.myCurrentUserCan(self.myTerminal, PmYardMoveView) then
		frm.addButton(self.btnMoveIt, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	// PAR #26830 end

	frm := self.frmBRToolbar;
	frm.showCaptions := false;
	frm.addButton(self.btnCreateForBR, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnHideBR, CMUI_Toolbar.Control_Alignment_Right);
	
	frm.positionToolbarControls();
	frm.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addYACriteriaToSelector" id="f707b343-f2ee-47e8-a722-dc3dfca53c3c">
        <updating/>
        <source>addYACriteriaToSelector( _yaCriteriaArray : CM_YACriteriaArray; _className : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2015	cnwndl1	Initial creation	Par 36525
12 Oct 2023	navdap1	TFS 58298 EUP | Calloff Zimmer DB Load
*/

vars

	iter : Iterator;
	criteria : CM_YACriteria;
	queryProp : CM_QueryProperty;
	operClass : Class;
	dataValue : Any;
	warningMess : String;
	assoc : CM_Association;

begin

	if _yaCriteriaArray = null or _yaCriteriaArray.isEmpty then
		return;
	endif;
	
	iter := _yaCriteriaArray.createIterator;
	while iter.next( criteria) do
		
		//warningMess := criteria.getSelectorEquivalentValues( _className, queryProp, operClass, dataValue );		// TFS 58928
		warningMess := criteria.getSelectorEquivalentValues( _className, true, queryProp, operClass, dataValue );	// TFS 58928
		if warningMess &lt;&gt; null then
			continue;
		endif;
		
		create assoc transient;
		assoc.setValue(dataValue);
		self.addDefaultPropertyLine(queryProp.propertyName, operClass.firstInstance.CM_QueryOperator.description, assoc);
	
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_yaCriteriaArray" type="CM_YACriteriaArray"/>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
    <JadeMethod name="btnAddSheet_click" id="3149623f-f8c7-4306-8f3a-5542a29374c4">
