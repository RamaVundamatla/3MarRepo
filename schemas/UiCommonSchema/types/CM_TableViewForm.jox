    <JadeMethod name="setTableDataFromOrganiser" id="51e8f5e1-9c54-4973-b510-3556c1c81527">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	13 November 2003 By: cnwgd1
//--------------------------------------------------
// 04/03/2013	cnwcs5	par 31087 - new parameter for zSetXMLStrFoTblColumns
// 13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
vars

begin
	// Save the entTableDef order to XLMStr
	self.zSetXMLStrForTblColumns(_theTable, false, self.xmlStrTblData);		// par 31087 March 2013
	
	// Re display the data. This is expensive, need take a look at it.
	//self.zTblDataSortAndShow(true);				//13.03.2025 navnk30 JIRA 34245
	if not self.tblData.isPaginated() then		//13.03.2025 navnk30 JIRA 34245
		self.zTblDataSortAndShow(true);
	endif;

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblDataEntRows" id="79282f86-d6b9-416a-a0d0-fe0702d387ba">
        <updating/>
        <source>setTblDataEntRows(_defName : String) updating;
// ---------------------------------------------------------------------------
// Created:     25 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  reason
//	15/04/02		cnwth2			now changes Tabe.InputType depending on entRow.inputType
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef	: EntTableDef;
	entRow		: EntTableRow;
	headingStr,
	tmpStr		: String;
	tmpFactor,
	widthFactorTotal,
	idx,
	numRows,inputType,	index : Integer;
	col	: JadeTableColumn;		
	rowFound	: Boolean;
		
begin

	entTableDef := app.myController.getEntTableDef(_defName);
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; _defName &amp; ') not found');
		return;
	endif;

	self.tblData.setTblDataEntRowsArray(entTableDef, self.allTblDataTransientRows, self.xmlStrTblData);

end;</source>
        <Parameter name="_defName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTblDataXML" id="66c36255-a25d-4118-a45b-d462de4aebb7">
