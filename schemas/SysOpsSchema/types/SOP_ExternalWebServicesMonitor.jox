    <JadeMethod name="doCmbInterfaceNameBuild" id="0581ccfe-f386-4aeb-8f0b-453297993bda">
        <updating/>
        <source>doCmbInterfaceNameBuild() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/02/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
// 01/04/2022	navgm20		Initial creation TFS 52777  EUP - INT - Generic API: record-scan
// 04/10/2022	jlika1		TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
// 08/12/2022	navdap1		TFS 55159 MTN Export CAMS to JSON API Endpoint
// 30/11/2023	navra1		TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
// 02/12/2024	navrv30	    JIRA 33578 EUP | Incoming API Logging
vars

	wsDef			: CM_ExternalWebServiceDef;
begin
	//self.cmbInterfaceName := true;
	self.cmbInterfaceName.clear;
	self.cmbInterfaceName.sorted := false;
	self.cmbInterfaceName.addItemObject(self.Interface_OpsView, app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef )); // ### TFS 52925 22FEB2022 NAVAB
	self.cmbInterfaceName.addItemObject(self.Interface_1StopVBS,app.myRoot.getFirstActiveExtWebService( CM_1StopVBSWebServiceDef ));
	self.cmbInterfaceName.addItem(self.Interface_GenericAPIScan);	//TFS 52777 01APR2022 navgm20
	self.cmbInterfaceName.addItemObject(self.Interface_Qships, app.myRoot.getFirstActiveExtWebService(CM_QshipsWebServiceDef));	
	self.cmbInterfaceName.addItemObject(self.Interface_EDBIC,app.myRoot.getFirstActiveExtWebService( CM_CuxportServiceDef));	// ### TFS 55215 29Nov2022 NAVPW1
	self.cmbInterfaceName.addItem(self.Interface_Cams);			// TFS 55159
	self.cmbInterfaceName.addItem(self.Interface_APILog);			//02 December 2024	navrv30	JIRA 33578
	//jlier1 TFS 56856 31/3/23
	wsDef:= app.myRoot.getFirstActiveExtWebService(CM_FinanceOneSeviceDef);
	if wsDef &lt;&gt; null then
		self.cmbInterfaceName.addItemObject(ExternalWebServiceFinanceOne,wsDef );
	endif;
	self.cmbInterfaceName.addItem(self.Interface_APIENDPOINT);	//06.April.2023 navsp1 TFS 57491
	
	self.cmbInterfaceName.addItem(self.Interface_InvoiceAPI);	//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023 - start
	
	self.cmbInterfaceName.addItem(self.Interface_AgGateway);	//navra1 - MTN-34782 - 15th July 2025
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbTypeBuild" id="dda08c29-ec50-499a-b939-3ec6a878d314">
        <source>doCmbTypeBuild();
/*
Purpose:			

Date		Who		Reason
23/07/2021	navab1	TFS 50669
04/02/2022	navdap1	TFS 52268 AAT 1-Stop VBS Integration
01/04/2022	navgm20	TFS 52777  EUP - INT - Generic API: record-scan
*/

vars
	cmb : CMUI_ComboBox;
	
begin
	cmb := self.cmbType;
	cmb.clear();
	
	if self.isOpsView then
		cmb.sorted := true;
		cmb.addItem("All Types");
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_BERTH);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_DELAY);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_DELAYTYPE);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_HMSMOVE);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_ISOTYPE);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_JOB);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_MACHINE);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_OPERATOR);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_TERMINAL);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_TRADE);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_VESSEL);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_VOYAGE);
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_WLE);

		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_CARRIER); // ### TFS 51855 06JAN2022 NAVAB1
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_MOVE); // ### TFS 51855 06JAN2022 NAVAB1
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_TRAIN); // ### TFS 51855 06JAN2022 NAVAB1
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_VVR); // ### TFS 51855 06JAN2022 NAVAB1
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_WAGON); // ### TFS 51855 06JAN2022 NAVAB1
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA); // ### TFS 51854 08FEB2022 NAVAB1
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM); // ### TFS 52925 21FEB2022 NAVAB1
		
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_DOCUMENT); // ### TFS 53105 30MAY2022 NAVAB1
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_DOCDETAIL); // ### TFS 53105 30MAY2022 NAVAB1
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_CONSIGNEENOR); // ### TFS 53105 31MAY2022 NAVAB1
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_CARGOTYPE);  			//navsp1 02Jun2022 TFS#53104
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_MEASUREMENTTYPE);  	//navsp1 02Jun2022 TFS#53104
		cmb.addItem(BGP_OpsViewWSRequest.OPS_TYPE_CARGOSUBTYPE);  		//navsp1 02Jun2022 TFS#53104 
		cmb.listIndex := 1;
	elseif self.is1StopVBS then
		cmb.sorted := false;
		cmb.addItem("All Types");
		cmb.addItem(CM_1StopVBSWebServiceDef.Type_GateEvent);
		cmb.addItem(CM_1StopVBSWebServiceDef.Type_SlotRequest);
		cmb.listIndex := 1;
	elseif self.isGenericAPIScan then
		cmb.sorted := false;
		cmb.addItem("All Types");
		cmb.addItem(CM_EWSActivityGenericScan.DataType); // ### TFS 52773 8APR2022 NAVPW1
		cmb.listIndex := 1;
	elseif self.isEDBIC then
		cmb.sorted := false;
		cmb.addItem("All Types");
		cmb.addItem(CM_EWSActivityEdBic.DataType_Truck);
		cmb.addItem(CM_EWSActivityEdBic.DataType_Train);
		cmb.addItem(CM_EWSActivityEdBic.DataType_Voyage);
		cmb.listIndex := 1;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="ea344129-64b1-4bbc-997f-3104d9af89a0">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging
14 January	2024	navrv30	JIRA 33784 MTN | Clear Button on the search form does not work as expected.
*/

vars
	filterTxt		    : String;
	rowIdx,
	start,
	colIndex 			: Integer;
	cellText,
	requestText,
	responseText    : String;
	obj 			    : Object;
	filteredRowCount    : Integer;
	firstFilteredRow	: Integer;
	exclude		: Boolean;
	
begin
	filteredRowCount := 0;
	filterTxt := self.frmTableFilter.txtFilterBox.text.toUpper();
	
	if filterTxt = "" then
		//self.clearFilter();
		self.lblQueryLinesValue.caption := self.frmTableFilter.numOfRowVisible.String; //15/01/2025	navkc1 JIRA Defect Sub-task MTN-33784
		return;
	else
		if filterTxt.length() &gt; 1 and filterTxt[1] = ExclaimationMark then
			exclude := true;
			filterTxt := filterTxt[2:end];
		endif;
		self.frmTableFilter.btnClearFilter.enabled := true;
	endif;
	
	start := self.tblData.fixedRows + 1;
	colIndex := 1;	
	
	foreach rowIdx in start to self.tblData.rows do	: rowLoop
			obj 	 := self.tblData.accessRow(rowIdx).itemObject;
			//Start TFS 53292
			requestText := obj.CM_ExternalWebServiceActivity.request.toUpper;
			responseText := obj.CM_ExternalWebServiceActivity.response.toUpper;
			
			if requestText.length &gt; 0 and requestText.pos(filterTxt, 1) &gt; 0 then
				if firstFilteredRow = null then
					firstFilteredRow := rowIdx;
				endif;
				self.tblData.accessedRow.visible := true;
				filteredRowCount				 := filteredRowCount + 1;
				continue rowLoop;	
			elseif responseText.length &gt; 0 and responseText.pos(filterTxt, 1) &gt; 0 then
				if firstFilteredRow = null then
					firstFilteredRow := rowIdx;
				endif;
				self.tblData.accessedRow.visible := true;
				filteredRowCount				 := filteredRowCount + 1;
				continue rowLoop;
			else
				foreach colIndex in start to self.tblData.columns do	: cellLoop
					cellText := self.tblData.accessCell(rowIdx, colIndex).text.toUpper;
					if cellText.length &gt; 0 and cellText.pos(filterTxt, 1) &gt; 0 then
						if firstFilteredRow = null then
							firstFilteredRow := rowIdx;
						endif;
						self.tblData.accessedRow.visible := true;
						filteredRowCount				 := filteredRowCount + 1;
						continue rowLoop;
					else
						self.tblData.accessedRow.visible := false;
					endif;
				endforeach;
			endif;
	endforeach;	
	
	if self.frmTableFilter.numOfRowVisible &gt; 0 then
		foreach rowIdx in start to self.tblData.rows do
			if self.tblData.accessRow(rowIdx).visible then
				firstFilteredRow := rowIdx;
				break;
			endif;
		endforeach;
	endif;
	if  firstFilteredRow &gt; self.tblData.fixedRows then
		self.tblData.clearAllSelected();
		//self.myCurrentObject := self.tblData.accessRow(firstFilteredRow).itemObject.CM_Object;
		self.tblData.accessedRow.selected := true;
		//self.showThumbnailData(self.myCurrentObject.CM_Object);
	endif;	
	
	self.lblQueryLinesValue.caption := filteredRowCount.String;

	
	if filteredRowCount = 0 then                        // TFS 53182 
	   //self.tblThumb.rows := 0;                         // TFS 53182
	endif;                                              // TFS 53182
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doInitTable" id="0185179d-ccb8-49c1-87ba-b729f86dd22c">
        <source>doInitTable();
/*
Purpose:			

Date		Who		Reason
23 July 2021	navab1	TFS 50669
30 November 2022	navpw1	TFS: 55215 - Moved EntTableDef code to a new method
*/

vars
	table : CM_DataTable;
	
begin
	table := self.tblData;

	self.setEntTableDef(); // ### TFS 55215 30Nov2022 NAVPW1
	
	table.userInputEnabled := false;
	table.selectMode := Table.SelectMode_CurrentRow;
	table.selectionType := CM_DataTable.SelectionType_Row;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doReprocessCAMS" id="17387f73-e9a5-4574-92bf-9a89fb87c46a">
        <source>doReprocessCAMS(activity : CM_EWSActivityCams input; status : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023	jlier1	Initial creation 58637

*/

vars
	camTaskHistory : CM_CamTaskHistory;
	theReturn,
	reprocessIndex : Integer;
begin
	
	camTaskHistory:=activity.myCamTaskHistory;
	if camTaskHistory = null then
		return;
	endif;
	
	//jlier1 TFS 59815 29/8/23
	if activity.myCamProtocol &lt;&gt; null and activity.myCamProtocol.onHold then
		app.raiseCMException1(Not_resen_messa_becau_proto_ho,activity.myCamProtocol.code,null,null);
		return;
	endif;
	
	if status = CAM_RESENDSTATUS then
		reprocessIndex:=activity.msgIndex;
	endif;
	
	while true do
		app.myTrxCA.trxCreateRestartCamsRequest(camTaskHistory,status,reprocessIndex, app.myPassport);
		if app.myPassport.trxCompletedOK then
				app.msgBox(app.getErrorString1 (Adhoc_CAMS_Initiated, camTaskHistory.seqNumber.String), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
				break;
		else		
			theReturn := app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
		break;
	endwhile;
epilog

end;</source>
        <Parameter name="activity" type="CM_EWSActivityCams" usage="input"/>
        <Parameter name="status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="f10004f2-e146-42fa-88de-d6bfe9d59526">
        <updating/>
        <source>doSearch() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2023	jlier1	Initial creation TFS 56856
30 Nov	 2023	navra1 	TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
27/09/2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback
02 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging
*/

vars
	prof : JadeProfiler;
	starTM   : Decimal[19,0];
begin
	if process.isCallum then
		app.myRoot.startJadeProfiler(prof,method.getNiceName,20,false,'CallumS',starTM);
	endif;
		
	if self.isOpsView() then
		self.populateTableOpsView();
	elseif self.isGenericAPIScan() then           //TFS 52777
	    self.populateTableGenericAPIScan();       //TFS 52777
	elseif self.is1StopVBS() then
		self.populateTable1Stop();
	elseif self.isAPILog() then
		self.populateTableAPILog();   // 02 December 2024	navrv30	JIRA 33578
	elseif self.isQships() then
		self.populateTableQships();
	// ### TFS 55215 30Nov2022 NAVPW1
	elseif self.isEDBIC() then
		self.populateTableEDBIC();
	// ### TFS 55215 30Nov2022 NAVPW1
	elseif self.isCams() then			// TFS 55159
		self.populateTableCams();		// TFS 55159
	elseif self.isFinanceOne then
		self.populateTableFinanceOne();
	elseif self.isAPIENDPOINT() then	//06.April.2023 navsp1 TFS 57491
		self.populateTableAPIENDPOINT();
	elseif self.isInvoiceAPI() then			//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
		self.populateTableInvoiceAPI();		//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
	elseif self.isAgGateway() then			//navra1 - MTN-34782 - 15th July 2025
		self.populateTableAgGateway();		//navra1 - MTN-34782 - 15th July 2025
	endif;
	
	self.frmQuery.visible	:= false;		// 27/09/2024	navcs2	ChangeRequest 66181
epilog
	if process.isCallum then
		app.myRoot.stopJadeProfiler(prof, starTM);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectUnselectAll" id="e60602a2-f6c0-4f82-af29-53f46b7b32d4">
