<GUIClass name="CMUI_ComboBoxCargoType" id="d10f700f-b29a-4e6e-94d1-0cd4237ed57f">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="displayEntry" id="4d120588-698e-493e-b7dd-83f6fad3eaae">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _cargoType: CM_CargoType; lstIndex: Integer): String updating, clientExecution;
// -------------------------------------------
// Created 07 September 2004 by cnwdvb1
// -------------------------------------------
// 23/11/2009	cnwmh5		PAR21660 - Change so it now also takes
//							into account the cargo types not available
//							for entry and terminal
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
// -------------------------------------------
vars

begin

	if _cargoType = null then
		return null;
	endif;
	
	if _cargoType.isSubCargoTypeRequired and _cargoType.allProducts.size = 0 then
		return null;
	endif;
	
	// 23/11/2009 cnwmh5 PAR21660 - Start
	// check not avaialble for entry
	if _cargoType.isNotAvailableForEntry then
		return null;
	endif;
	
	// check that is in this terminal
	if app.myPassport.myTerminal &lt;&gt; null and not _cargoType.allTerminals.includes(app.myPassport.myTerminal) then
		return null;
	endif;
	// 23/11/2009 cnwmh5 PAR21660 - End
	
	if _cargoType.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort then	// TFS 49252
		return null;																		// TFS 49252
	endif;																					// TFS 49252
	
	return _cargoType.description;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="96b1c6ab-2c14-4c87-9ad7-b3fd3cd2fb62">
        <source>getCollectionJMT(): Collection protected;
// -------------------------------------------
// Created 08 October 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return app.myRoot.allCargoTypesById;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
