    <JadeMethod name="getMaxPerms" id="07995cfa-56dd-4cb1-aeb4-9ffe47060f5d">
        <source>getMaxPerms() : Integer protected;
// -----------------------------------------------------------------------------
// Created:		22 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	maxPerms : Integer;
	category : ConstantCategory;
	constant : Constant;
begin
	maxPerms := 0;
	
	category := currentSchema.getCategory(XLAT_Permissions);		
	
	foreach constant in category.getConstants do
		if constant.valueAsInteger &gt; maxPerms then
			maxPerms := constant.valueAsInteger;
		endif;
	endforeach;
	
epilog
	return maxPerms;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
