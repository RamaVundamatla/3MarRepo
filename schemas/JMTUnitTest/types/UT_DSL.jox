    <JadeMethod name="countTransactionsOfType" id="976b556a-f66b-481e-857e-91e4b3347fa8">
        <source>countTransactionsOfType(_cargo : CM_TrackedItem; _tranType : Integer) : Integer;

vars
	count	: Integer;
	tran	: CM_TITransaction;
begin
	foreach tran in _cargo.allTransactions do
		if tran.type = _tranType then
			count := count + 1;
		endif;
	endforeach;
	
	return count;
end;
</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_tranType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createAvailabilityGrade" id="37450bb1-1aa3-4614-bc84-fe721045cf0b">
        <source>createAvailabilityGrade( _code : String ):CM_MTGrade;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2010	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	proxyAvailGrade : CM_MTGrade;
	availGrade : CM_MTGrade;
	index : Integer;
	
begin

	term := self.getTerminal;
	
	index := 100;
	while true do
		if app.myRoot.allAvailabilityGrades.getAtKey(index) = null then
			break;
		endif;
		index := index + 1;
	endwhile;
	
	create proxyAvailGrade transient;
	proxyAvailGrade.setProxy(	index,
								_code,
								false,
								false,
								0,
								null,	//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
								term.allSubTerminals	//CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
								);
								
	app.myTrxCA.trxCreateAvailabilityGrade(proxyAvailGrade, availGrade,app.myPassport);

	return availGrade;
	
epilog

	delete proxyAvailGrade;

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="createAvailabilityGradeAndDesc" id="66e234db-0874-46ce-bb26-e7d21f850fa2">
        <source>createAvailabilityGradeAndDesc(_code :Integer; _desc :String):CM_MTGrade;
/*
Date		Who		Reason
02 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

	terminal 	: CM_Terminal;
	proxy 		: CM_MTGrade;
	mtGrade 	: CM_MTGrade;	
begin
	terminal := self.getTerminal;
	
	create proxy transient;
	
	proxy.setProxy(_code, _desc,
								false,
								false,
								0,
								null,	//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
								terminal.allSubTerminals	//CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
								);
								
	app.myTrxCA.trxCreateAvailabilityGrade(proxy, mtGrade,app.myPassport);

	return mtGrade;
	
epilog

	delete proxy;

end;</source>
        <Parameter name="_code" type="Integer"/>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="createBGPManagerRunTask" id="47ca069f-8ccd-4717-ad75-3c9c83a711fe">
        <source>createBGPManagerRunTask(_autoSchedule : CM_AutoSchedule);

/*

Purpose:		Create the BPGManager and autoschedule and run the required task

Date			Who		Reason
11/02/2016		cnwmh5	Initial creation

*/

vars

	bgpManager					: BGP_Manager;
	bgpGeneric 					: BGP_GenericController;

begin

	// create the BGPManager
	self.opts.purge();
	self.opts.addAssoc("IsServer", true);
	bgpManager := self.addBGPManager(_autoSchedule.description);
	self.assertNotNull(bgpManager);

	// create Process Wash
	bgpGeneric := bgpManager.allBGPControllers.first.BGP_GenericController;
	self.updateBGPGenericControllerProc(bgpGeneric);
	
	// run the task
	_autoSchedule.runTasks(null, null);
	
	// start the bgp process
	//bgpManager.startBackGroundApp(bgpGeneric, false);
	
	// need to sleep for a minute to make sure that the process gets run
	//process.sleep(60000);

epilog

	if bgpManager &lt;&gt; null then	
		bgpManager.terminateProcessing(app.myPassport.userCode);
	endif;

end;</source>
        <Parameter name="_autoSchedule" type="CM_AutoSchedule"/>
    </JadeMethod>
    <JadeMethod name="createBOLCashReceipt" id="165dd56b-1463-49d7-8375-da28ef58eb63">
        <source>createBOLCashReceipt(	_payMeth : CM_PaymentMethod;
					_amount : Decimal;
					_chequeBank : String;
					_chequeBranch : String;
					_chequeNumber : String;
					_chequeDate : Date;
					_cashId1,
					_cashId2,
					_cashId3,
					_cashId4 : String;
					_payment1 : Decimal;
					_payment2 : Decimal;
					_effectiveDate : Date;
					_externalInvoiceNumber,
					_externalReferenceNumber : String;
					_totalCargoCharges : Decimal;
					_cashAlreadyPaid : Decimal;
					_voyage : CM_Voyage;
					_drTerm : CM_DebtorTerminal;
					_taxValue1 : Real;
					_taxValue2 : Real;
					_taxValue3 : Decimal;
					_shipReleaseDate : Date;
					_agents : ObjectArray;
					_taxCode1,
					_taxCode2,
					_taxCode3: String
					) : CM_CashReceipt;

// from doSave, INV_CashReceiptBOL
// This should be the main method used to create cash receipts
vars
	totalToAllocate	: Decimal[23, 6];
	pxyCashRec,
	newCashReceipt   : CM_CashReceipt;
	now 		  	 : TimeStamp;
	user          	 : CM_User;	
	allRealCashPays, 
	allProxyCashPays : ObjectArray;
	obj				 : Object;
	proformaAgent    : CM_CashInvoiceProformaAgent;
	newSeq	         : Integer;
	allAgentsSet     : CM_CashProformaAgentSet; // TFS 45953
	tmpController    : CMIF_ProformaInvLinesForDebtor; // TFS 45953
	cp               : CM_CashPayment;
begin

	now := app.actualTimeServer;
	user := app.getMyUser;

	create pxyCashRec transient;
	pxyCashRec.setProxy(	_amount,
								now,
								user,
								_drTerm.getNextRecSeqNum,
								_chequeBank,
								_chequeBranch,
								_chequeNumber,
								_chequeDate,
								_payMeth,
								_drTerm,
								0	//_paymentType : Integer
								);
	
	pxyCashRec.setProxy2(_cashId1,
							 _cashId2,
							 _cashId3,
							 null,
							 _payment1,
							 _payment2,
							 _effectiveDate,
							 _externalInvoiceNumber,
							 _externalReferenceNumber,
							 _totalCargoCharges,
							 _cashAlreadyPaid,
							 0,
							 0,
							 null,
							 null, null, null
							 );
	pxyCashRec.setTaxValues(_taxValue1, _taxValue2, _taxValue3, _taxCode1, _taxCode2, _taxCode3);
	pxyCashRec.setShipReleaseDate(_shipReleaseDate);

	// copy the cargo and invoice lines to the proxy old
	newSeq := 1;
	foreach obj in _agents do
		proformaAgent := obj.CM_CashInvoiceProformaAgent;
		if proformaAgent = null then
			continue;
		endif;
		
		if proformaAgent.myTrackedItem &lt;&gt; null then
			pxyCashRec.allTrackedItems.add(proformaAgent.myTrackedItem);
		endif;
	endforeach;

	create allRealCashPays transient;

	totalToAllocate := _amount;


	create allAgentsSet transient;
	create allProxyCashPays transient;
	
	 _agents.copy(allAgentsSet);
	create tmpController transient; 
	tmpController.proformaProxyCashPayments(pxyCashRec,allAgentsSet, false); // TFS 45953 added false
	
	// GATHER ALL THE PROXIES FOR DELETION IN THE EPILOG
	pxyCashRec.allCashPayments.copy(allProxyCashPays);
	tmpController.populateAllTransients(pxyCashRec.allCashPayments); // TFS 45953


	foreach obj in allProxyCashPays	discreteLock do
		cp := obj.CM_CashPayment;
		
		// TFS 45953 If the proxy cash payment is linked to a real invoice line, add that invoice line to the cash receipt. NOTE there is no inverse		
		if cp.myInvoiceLine &lt;&gt; null
		and not cp.myInvoiceLine.isTransient then
			pxyCashRec.allInvoiceLines.addNoDuplicates(cp.myInvoiceLine, false);
		endif;

	endforeach;
	
	
	// TFS 45953 Refactoring so UI, WorkOrders and Units Tests all call the same create cash receipt code
	app.myTrxCA.trxCreateCashReceipt(pxyCashRec,newCashReceipt, allProxyCashPays, allRealCashPays, "", app.myPassport);
	
	self.assertTrueMsg(app.myPassport.noErrors, "Create BOL Cash Receipt failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	return newCashReceipt;

epilog
	tmpController.allTransientsToDelete.purge; // TFS 45953
	delete tmpController; // TFS 45953
	delete allAgentsSet; // TFS 45953
	delete allProxyCashPays; // TFS 45953
	delete pxyCashRec;
	delete allRealCashPays;
end;
</source>
        <Parameter name="_payMeth" type="CM_PaymentMethod"/>
        <Parameter name="_amount" type="Decimal"/>
        <Parameter name="_chequeBank" type="String"/>
        <Parameter name="_chequeBranch" type="String"/>
        <Parameter name="_chequeNumber" type="String"/>
        <Parameter name="_chequeDate" type="Date"/>
        <Parameter name="_cashId1" type="String"/>
        <Parameter name="_cashId2" type="String"/>
        <Parameter name="_cashId3" type="String"/>
        <Parameter name="_cashId4" type="String"/>
        <Parameter name="_payment1" type="Decimal"/>
        <Parameter name="_payment2" type="Decimal"/>
        <Parameter name="_effectiveDate" type="Date"/>
        <Parameter name="_externalInvoiceNumber" type="String"/>
        <Parameter name="_externalReferenceNumber" type="String"/>
        <Parameter name="_totalCargoCharges" type="Decimal"/>
        <Parameter name="_cashAlreadyPaid" type="Decimal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_drTerm" type="CM_DebtorTerminal"/>
        <Parameter name="_taxValue1" type="Real"/>
        <Parameter name="_taxValue2" type="Real"/>
        <Parameter name="_taxValue3" type="Decimal"/>
        <Parameter name="_shipReleaseDate" type="Date"/>
        <Parameter name="_agents" type="ObjectArray"/>
        <Parameter name="_taxCode1" type="String"/>
        <Parameter name="_taxCode2" type="String"/>
        <Parameter name="_taxCode3" type="String"/>
        <ReturnType type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="createCalendar" id="790955ab-b1e0-467b-ac15-fd926289b861">
        <source>createCalendar(	_code : String; _description : String; _hasEndTime : Boolean; _hasTime : Boolean; _dayCode : String) : CM_Calendar;
// CCMS 1295 free storage days
vars
	proxy		: CM_Calendar;
	realCalendar	: CM_Calendar;
	proxyDayType	: CM_DayType;
	dayType		: CM_DayType;
	terminal	: CM_Terminal;
	allTerminals : CM_TerminalByCodeDict;
begin
	terminal := self.getTerminal();
	create allTerminals transient;
	allTerminals.add(terminal);
	create proxyDayType transient;
	proxyDayType.setProxy(_dayCode, _dayCode);
	app.myTrxCA.trxCreateDayType(proxyDayType, dayType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	create proxy transient;
	proxy.setProxy(	_code, _description, _hasEndTime, _hasTime, dayType, null, null, allTerminals);

	app.myTrxCA.trxCreateCalendar(proxy, realCalendar, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();
 	
	return realCalendar;
epilog
	delete proxy;
	delete proxyDayType;
	delete allTerminals;
end;


</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_hasEndTime" type="Boolean"/>
        <Parameter name="_hasTime" type="Boolean"/>
        <Parameter name="_dayCode" type="String"/>
        <ReturnType type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="createCargo" id="9ada24e7-99a2-4b98-af7b-dc25a36de432">
        <source>createCargo(_id: String; _isoType: String; _commodity: String; _operator: CM_Operator; _asTransient : Boolean; _ct : Integer) : CM_TrackedItem;
//29 August 2008	cnwdw1	
//
vars
	cargoTypeInt	: Integer;
	pxyTI			: CM_TrackedItem;
	realTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	root			: CM_Root;
	remarks 		: String;
	
begin
	root := CM_Root.firstInstance;
	
//	cargoType := root.allCargoTypesById[TI_CargoType_Container];	// cnwrl1 28/04/2010 PAR 23854 - what it was
	// cnwrl1 28/04/2010 PAR 23854 - start of coding
	cargoTypeInt	:= self.opts.intDef( ETRow_CargoType, _ct );
	cargoType		:= root.allCargoTypesById[ cargoTypeInt ];
	// cnwrl1 28/04/2010 PAR 23854 - end of coding
	
	if _asTransient then
		pxyTI := self.getTerminal.createTI(cargoType, _asTransient);
		
		//14 May 2015	NDL	- Needed to allow subTerminal default to make the correct decision.
		if self.opts.includesKey(UTTI_IMEX) then						
			pxyTI.zSetPxyImexStatus(self.opts.int(UTTI_IMEX));
		endif;
		
//		pxyTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		pxyTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, _commodity, _operator);
		pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
		pxyTI.setISOType(_isoType);
		//pxyTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
		pxyTI.setTotalWeight(4000, null, null);					//+cnwml2 MSL CCMS 1017
		if _commodity = "REEF" then
			pxyTI.setTemperature(4);
		endif;
		global.setExtraData(pxyTI.allExtraData, pxyTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		return pxyTI;
	else
		beginTransaction;
		realTI := self.getTerminal.createTI(cargoType, _asTransient);
//		realTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		realTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, _commodity, _operator);
		realTI.changeState(TI_STATE_NORMAL, app.myPassport);
		realTI.setISOType(_isoType);
		//realTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
		realTI.setPropertyValue( "totalWeight", "4000".Decimal );					//+cnwml2 MSL CCMS 1017
		if _commodity = "REEF" then
			realTI.setTemperature(4);
		endif;
		global.setExtraData(realTI.allExtraData, realTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		// 13/07/015 cnwmh5
		remarks := realTI.remarks;
		if remarks &lt;&gt; null then
			remarks := remarks &amp; CrLf;
		endif;
		realTI.setRemarks(remarks &amp; self.createdByUnitTest(remarks), false);
		commitTransaction;
		return realTI;
	endif;

epilog

	if not _asTransient then
		delete pxyTI;
	endif;
	
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_asTransient" type="Boolean"/>
        <Parameter name="_ct" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createCashCredit" id="ef772c2b-f431-46cf-af10-418ae3e598a3">
        <source>createCashCredit(_cashReceipt  : CM_CashReceipt; 
				 _creditAmount : Decimal;
				 _comments 	   : String;
				 _firstPaymentInv,
				 _firstPaymentProfrma  : Decimal) : CM_CashCredit;

/*

Purpose:			Create a cash credit from an existing cash receipt, based on INV_CashCredit::doSave, keep in sync with this

Parameters:			

Return Value:		


Date		Who		Reason
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars
	index				: Integer;
	cashOnPayment,
	cashOnPaymentTax	: Decimal[23, 6];	
	terminal			: CM_Terminal;
	pxyCashCredit	    : CM_CashCredit;
	pxyCreditDetail,
	pxyTaxCreditDetail  : CM_CashCreditDetail;
	cashCredit			: CM_CashCredit;
	drTerm 				: CM_DebtorTerminal;
	now 				: TimeStamp;
	user 				: CM_User;
	invoiceLine			: CM_InvoiceLine;
	bank				: CM_Bank;
	allPxyCashDetails 	: ObjectArray;
	obj			    	: Object;
	ti				    : CM_TrackedItem;
	cashPayment,
	cashPaymentTax 		: CM_CashPayment;
	invUpdated,
	profrmaUpdated   : Boolean;
begin

	now 		:= app.actualTimeServer;
	user 		:= app.getMyUser;
	terminal 	:= self.getTerminal();
	drTerm 		:= _cashReceipt.myDebtorTerminal;
	bank 		:= _cashReceipt.myBank;
	
	// don't create a credit if no value
	if _creditAmount = 0 then
		return null;
	endif;

	create pxyCashCredit transient;
	pxyCashCredit.setProxy(	_creditAmount,
							now,
							_comments,
							bank,
							drTerm,
							_cashReceipt,
							user
							);

	create allPxyCashDetails transient;

	
	foreach obj in _cashReceipt.allCashPayments do
		
		
		cashPayment   :=  obj.CM_CashPayment;
		ti			  := cashPayment.myTrackedItem;
		index 		  := 0;
		cashOnPayment := cashPayment.getUncreditedAmount;
		
		if invUpdated and profrmaUpdated then
			continue;
		endif;
		
		if not invUpdated then
			if cashPayment.myInvoice &lt;&gt; null then
				cashOnPayment := _firstPaymentInv ;
				invUpdated    := true;
			endif;
		endif;
		
		if not profrmaUpdated then
			if cashPayment.myProformaDetail &lt;&gt; null  then
				cashOnPayment := _firstPaymentProfrma ;
				profrmaUpdated    := true;
			endif;
		endif;
		
	
		if cashOnPayment &gt; 0 then
			
			create pxyCreditDetail transient;
			pxyCreditDetail.setDerivedProxy(null, 
											cashPayment,
											ti,
											cashOnPayment,
											now);
			allPxyCashDetails.add(pxyCreditDetail);
			
			if cashPayment.hasTax &lt;&gt; null then			
				cashPaymentTax   := cashPayment.myCashPaymentForTax;
				cashOnPaymentTax := cashPaymentTax.getUncreditedAmount;
				
				if cashOnPaymentTax &gt; 0 then
					create pxyTaxCreditDetail transient;
					pxyTaxCreditDetail.setDerivedProxy(null,
														cashPaymentTax,
														ti,
														cashOnPaymentTax,
														now);
														
					allPxyCashDetails.add(pxyTaxCreditDetail);
				endif;
			endif;
		endif;
	endforeach;
	
	
	app.myTrxCA.trxCreateCashCredit (pxyCashCredit, cashCredit, allPxyCashDetails, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Create Cash Credit failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	return cashCredit;	

epilog

	if allPxyCashDetails &lt;&gt; null and not allPxyCashDetails.isEmpty then
		allPxyCashDetails.purge();
	endif;
	delete pxyCashCredit;
	delete allPxyCashDetails;
	
end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_creditAmount" type="Decimal"/>
        <Parameter name="_comments" type="String"/>
        <Parameter name="_firstPaymentInv" type="Decimal"/>
        <Parameter name="_firstPaymentProfrma" type="Decimal"/>
        <ReturnType type="CM_CashCredit"/>
    </JadeMethod>
    <JadeMethod name="createContainer" id="792cd80d-d84c-4d0d-8960-62b1f8676a13">
        <source>createContainer(_id: String; _isoType: String; _commodity: String; _operator: CM_Operator; _asTransient : Boolean) : CM_TrackedItem;
//29 August 2008	cnwdw1	
//
vars
	cargoTypeInt	: Integer;
	pxyTI			: CM_TrackedItem;
	realTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	root			: CM_Root;
	imexInt 		: Integer;
	remarks			: String;
	
begin
	root := CM_Root.firstInstance;
	
//	cargoType := root.allCargoTypesById[TI_CargoType_Container];	// cnwrl1 28/04/2010 PAR 23854 - what it was
	// cnwrl1 28/04/2010 PAR 23854 - start of coding
	cargoTypeInt	:= self.opts.intDef( ETRow_CargoType, TI_CargoType_Container );
	cargoType		:= root.allCargoTypesById[ cargoTypeInt ];
	// cnwrl1 28/04/2010 PAR 23854 - end of coding

	
	
	if _asTransient then
		pxyTI := self.getTerminal.createTI(cargoType, _asTransient);
		
		//14 May 2015	NDL	- Needed to allow subTerminal default to make the correct decision.
		if self.opts.includesKey(UTTI_IMEX) then						
			pxyTI.zSetPxyImexStatus(self.opts.int(UTTI_IMEX));
		endif;
		
//		pxyTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		pxyTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, _commodity, _operator);
		pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
		pxyTI.setISOType(_isoType);
		//pxyTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
		pxyTI.setTotalWeight(4000, null, null);					//+cnwml2 MSL CCMS 1017
		if _commodity = "REEF" then
			pxyTI.setTemperature(4);
		endif;
		global.setExtraData(pxyTI.allExtraData, pxyTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));					// 10/09/2015 cnwmh5
		return pxyTI;
	else
		beginTransaction;
		realTI := self.getTerminal.createTI(cargoType, _asTransient);
//		realTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
		realTI.setPxyFromDefaultTI(self.getTerminal, cargoTypeInt, _id, _commodity, _operator);
		realTI.changeState(TI_STATE_NORMAL, app.myPassport);
		realTI.setISOType(_isoType);
		//realTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
		realTI.setPropertyValue( "totalWeight", "4000".Decimal );					//+cnwml2 MSL CCMS 1017
		if _commodity = "REEF" then
			realTI.setTemperature(4);
		endif;
		global.setExtraData(realTI.allExtraData, realTI, "createdByUnitTest" , self.getClassMethodCreatedBy());					// 29/08/2012 cnwmh5
		// 13/07/015 cnwmh5
		remarks := realTI.remarks;
		if remarks &lt;&gt; null then
			remarks := remarks &amp; CrLf;
		endif;
		realTI.setRemarks(remarks &amp; self.createdByUnitTest(null), false);
		commitTransaction;
		return realTI;
	endif;

epilog

	abortTransaction;  // in case if falls over during the begin commit above...
	if not _asTransient then
		delete pxyTI;
	endif;
	
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_asTransient" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createContainerFromVoyage" id="b91bdfab-740d-4968-a203-7104c7dc3065">
        <source>createContainerFromVoyage(_voyage : CM_Voyage; _id : String; _toLocation : Any; _isoType : String; _operator : CM_Operator; _commodity : String; 
							_destPort : String; _dischargePort : String; _tareWeight : Decimal; _cargoWeight : Decimal) : CM_TrackedItem;
// Create an onship container for the given attributes and then move it onsite to the given location
// This creates an onsite container with the required ship receive etc transactions for invoicing
vars
	intFaceArray		: CMIF_TIObjectArray;
	newTI				: CM_TrackedItem;
	intFaceObj			: CMIF_PreNote;
	preNote				: CMIF_PreNote;

begin
	
	create intFaceArray transient;
	create intFaceObj as CMIF_OnshipCargo transient;	
	
	intFaceObj.myTerminal		:= self.getTerminal;
	//intFaceObj.setUserDetails(self);
	intFaceObj.setMyInOutCommon(null);

	// Main Details
	intFaceObj.cargoType		:= TI_CargoType_Container;
	intFaceObj.commodity 		:= _commodity;
	intFaceObj.id				:= _id;
	intFaceObj.isoType			:= _isoType;
	
	intFaceObj.weightTotal			:= _cargoWeight + _tareWeight;
	intFaceObj.weightCargo			:= _cargoWeight;
	intFaceObj.weightTare			:= _tareWeight;
	
	intFaceObj.weightDeclared 	:= intFaceObj.weightTotal;

	intFaceObj.numberOfItems := 1;
	
	// Voyage Details
	intFaceObj.imExStatus := self.getRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
	intFaceObj.voyageCode		:= _voyage.code;
	intFaceObj.operatorCode		:= _operator.code;
	intFaceObj.destinationPort	:= _destPort;
	intFaceObj.dischargePort	:= _dischargePort;

	intFaceObj.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	intFaceObj.setOxygen( NULL_OXYGEN );
	intFaceObj.setHumidity( NULL_HUMIDITY );
	intFaceObj.ventilation 		:= NULL_VENTILATION;
	intFaceObj.transportMode 	:= BR_TYPE_SHIP_STR;
	intFaceObj.receiptTransportMode := app.transModeToCode(intFaceObj.transportMode);
	if _commodity = "REEF" then
		intFaceObj.carriageTempC := 4;
	endif;
	
	intFaceArray.add(intFaceObj);
	preNote := intFaceObj;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreatePreNotes(intFaceArray, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	newTI := intFaceObj.myPersistentTrackedItem;

	// now optionally move it
	if _toLocation &lt;&gt; null then
		if not self.opts.includesKey("isForcedMove") then
			self.opts.addAssoc("isForcedMove", true);
		endif;
		self.move(newTI, _toLocation);
		self.opts.removeAssoc("isForcedMove");
	endif;

	return newTI;
epilog
	delete intFaceObj;
	if intFaceArray &lt;&gt; null then
		delete intFaceArray;
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_toLocation" type="Any"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_destPort" type="String"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_cargoWeight" type="Decimal"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createContainerRange" id="4af7f19c-f4d5-4b4a-a4b0-469b573a6e22">
        <source>createContainerRange(_start, _end :String):CM_ContRange;
// ---------------------------------------------------------------------------
// Created:     24 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	range	:CM_ContRange;
	proxy	:CM_ContRange;
begin
	create proxy transient;
	
	proxy.setProxy (_start, _end, '2200', null, null, null, null, null, null, null, 45000, 2354, null, null, null);
	
	app.myTrxCA.trxCreateContRange (proxy, range, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings ();

	return range;
epilog
	delete proxy;
end;</source>
        <Parameter name="_start" type="String"/>
        <Parameter name="_end" type="String"/>
        <ReturnType type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="createCreditNoteApiType" id="730e65eb-b0fe-4b01-8aa2-d11baa57d27f">
        <source>createCreditNoteApiType(_invoiceDesc : String; _invoiceType : Integer) : CM_InvoiceDesc;

/*

Purpose:

Parameters:		

Return Value:

	
Date			Who		Reason
13 June 2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/
vars
	pxyInvoice				: CM_InvoiceDesc;
	invGenerationDateFrom	: Date;
	invGenerationDateTo		: Date;
	hgSA					: HugeStringArray;
	newInvoiceType			: CM_InvoiceDesc;
	bank					: CM_Bank;
	invoiceKey : Integer;	
	isAllowManEditExtRef, //08/12/2025	navkc1 JIRA 36262
	print1LineDay : Boolean;	
	triggerOnRelease : Integer;
	
begin
	bank := self.getTerminal().getDefaultCompanyBank();

	create pxyInvoice transient;
	create hgSA transient; 
	if self.opts.includesKey(UTINV_InvoiceTypeNarration) then
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
		hgSA.add("");
	else
		hgSA.add("None, cool!");
		hgSA.add("___field = 0");
		hgSA.add("The Debtors Name");
		hgSA.add("___field = 1");
		hgSA.add("The Voyage Code");
		hgSA.add("___field = 2");
		hgSA.add("The Vessel Name");
		hgSA.add("___field = 3");
		hgSA.add("12/12/2009");
		hgSA.add("___field = 5");
	endif;
	
	triggerOnRelease := InvTypeTrigger_Release;
	
	if self.opts.includesKey(UTINV_TriggerOnRelease) then
		triggerOnRelease := self.opts.int(UTINV_TriggerOnRelease);
	endif;
	
	print1LineDay := true;
	
	//08/12/2025	navkc1 JIRA 36262
	if self.opts.includesKey("AllowManEditExtRef") then
		isAllowManEditExtRef := self.opts.bool("AllowManEditExtRef").Boolean;
	endif;
	
	if self.opts.includesKey(UTINV_Print1LineDay) then
		print1LineDay := self.opts.bool(UTINV_Print1LineDay);
	endif; 
	
	invoiceKey := CM_InvoiceDesc.Key_None;
	if self.opts.includesKey( CM_InvoiceDesc::invoiceKey.name ) then
		invoiceKey := self.opts.int( CM_InvoiceDesc::invoiceKey.name );
	endif;
	
	pxyInvoice.setProxy(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
						hgSA,
						_invoiceDesc,
						invoiceKey,
						_invoiceType,
						app.myRoot.myRootCompany.allFinancialPeriods.first(),  
						app.myRoot.myRootCompany.allInvoiceTermsOfTrade.first(), 
						print1LineDay,  
						triggerOnRelease,
						invGenerationDateFrom,
						invGenerationDateTo,
						0,
						null,
						false,
						false,		
						true,
						isAllowManEditExtRef //08/12/2025	navkc1 JIRA 36262
						);		
	pxyInvoice.setCompany(bank);	

	app.myTrxCA.trxCreateInvoiceDesc(pxyInvoice,  newInvoiceType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return newInvoiceType;
epilog
	delete pxyInvoice;
	delete hgSA;
end;</source>
        <Parameter name="_invoiceDesc" type="String"/>
        <Parameter name="_invoiceType" type="Integer"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="createDamageInstance" id="f6662509-229e-41a8-8c89-ec8f77a2b8f0">
        <source>createDamageInstance(_ti : CM_TrackedItem input):CM_DamageInstance;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022	navds20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/
constants
			Code : String = "BENT";
			Pos : String = "All";
			Quan : Integer = 1;
			Remark : String = "XXX";
vars
			damageInstancePxy : CM_DamageInstance;
			_pxyTi 			: CM_TrackedItem;
			_pxyTIMaster 	: CM_TIMaster;
			_damageDefCode 	: CM_DamageDefinitionCode;
			_damagePosition : CM_DamagePosition;
			_isNewDamage	: Boolean;
			_severity		: CM_DamageSeverity;	
			_locationStr 	: String;	
			_damagePlace	: CM_DamagePlace;	
			_damageParty	: CM_DamageParty;	
			_damageReason	: CM_DamageReason;	
			_repairReason	: CM_RepairReason;	
			_damageSize		: Integer;			
			_damageDateTime	: TimeStamp;		
			_status			: Integer;		
			_repairRemarks	: String;		
			_repairedDateTime : TimeStamp;
			_pxyRealTIMaster : CM_TIMaster;
			_pxyNew : Boolean; 
			_pxyRepaired,loadState : Boolean;
			_newDamageInstance : CM_DamageInstance;
			terminal 	: CM_Terminal;
begin
	if _ti &lt;&gt; null then
		app.cmsBeginLoad(loadState);
			_pxyTi := _ti.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
	endif;
	
	_damageDefCode 	:= app.myRoot.allDamageDefinitionCodes[Code];
	self.assertNotNullMsg (_damageDefCode, ' invalid damage code');
	
	_damagePosition		:= app.myRoot.allDamagePositionsByCode [Pos];
	self.assertNotNullMsg (_damagePosition, ' invalid damage position');
	
	_damageSize := 25;
	
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		_damageParty := terminal.allDamageParties.first;
		_damageReason := terminal.allDamageReasons.first;
		_damagePlace := terminal.allDamagePlaces.first;
		_repairReason := terminal.allRepairReasons.first;
		_severity := terminal.allDamageSeverities.first;
	endif;

	create damageInstancePxy transient;
	damageInstancePxy.setProxy(_pxyTi,null,_damageDefCode,_damagePosition,
								Remark,true,Quan,_severity,_locationStr,_damagePlace,_damageParty,
								_damageReason,_repairReason,_damageSize.Decimal,app.actualTimeServer,1,Remark,app.actualTimeServer);
		
	_pxyNew := true; 
	_pxyRepaired := true;
								
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateDamageInstance(damageInstancePxy,_ti,null,_pxyNew,_pxyRepaired,_newDamageInstance,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return _newDamageInstance;
epilog
	delete damageInstancePxy;
	app.cmsEndLoad(loadState);
	delete _pxyTi;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="CM_DamageInstance"/>
    </JadeMethod>
    <JadeMethod name="createDamageParty" id="4219e5c2-9f0a-411d-953b-36f972071d5e">
        <source>createDamageParty(code,desc : String; isnot: Boolean) : CM_DamageParty;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	pxyDP	: CM_DamageParty;
	dp,dpOld	: CM_DamageParty;
begin
	dpOld := self.getTerminal().allDamageParties[code];
	self.deleteDamageParty(dpOld);
	
	create pxyDP transient;
	pxyDP.setProxy(code, desc, isnot, self.getTerminal());
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateDamageParty(pxyDP, dp, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return dp;
epilog
	delete pxyDP;
end;</source>
        <Parameter name="code" type="String"/>
        <Parameter name="desc" type="String"/>
        <Parameter name="isnot" type="Boolean"/>
        <ReturnType type="CM_DamageParty"/>
    </JadeMethod>
