    <JadeMethod name="cmbInterfaceName_click" id="24d7bf2d-6410-409d-8348-ddce7b467fd6">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbInterfaceName_click(combobox: ComboBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/02/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
// 01/04/2022	navgm20		Initial creation TFS 52777  EUP - INT - Generic API: record-scan
// 10/10/2022	jlika1		TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
// 12/01/2023	navdap1		TFS 55159 MTN Export CAMS to JSON API Endpoint
// 30/03/2023	jlier1 		TFS 56856 - refactoring
// 06/04/2023   navsp1		TFS Bug 57491: FR | 53667 - EUP - Inspection App Activity not visible in External Web Service Monitor
// 30/11/2023	navra1		TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
// 20/05/2024	navcs2		ChangeRequest 59188: EUP | API Search - External Webservice Monitor
// Bug 65096: 59188 - Interface Type Qships not updating UI correctly
vars
	wsDef : CM_ExternalWebServiceDef;
begin
	self.filterInterfaceName:=null;
	/*
	self.sheetQships.visible := combobox.text = self.Interface_Qships;
	self.sheetOpsView.visible := combobox.text = self.Interface_OpsView;
	self.sht1StopVBS.visible := combobox.text = self.Interface_1StopVBS;
	self.shtEdbic.visible := combobox.text = self.Interface_EDBIC;			
	self.shtCams.visible := combobox.text = self.Interface_Cams;	
	self.shtGenericAPIScan.visible := combobox.text = self.Interface_GenericAPIScan ;
	self.shtFinanceOne.visible:=combobox.text = ExternalWebServiceFinanceOne;
	self.mnuDelete.visible:=combobox.text = self.Interface_OpsView;
	self.lblBGPStatus.visible := combobox.text = self.Interface_OpsView;
	self.picBGPStatus.visible := combobox.text = self.Interface_OpsView;
	self.lblProducerStatus.visible := combobox.text = self.Interface_OpsView;
	self.picProducerStatus.visible := combobox.text = self.Interface_OpsView;
	self.shtAPIENDPOINT.visible	:= combobox.text = self.Interface_APIENDPOINT;
	self.shtInvoiceAPI.visible	:= combobox.text = self.Interface_InvoiceAPI;		//navra1 - TFS 54090(CR 61380/Task 61385) - 29th Nov 2023
	*/
	self.buildTblStatus();
	self.doCmbTypeBuild();
	if combobox.listObject &lt;&gt; null and combobox.listObject.isKindOf(CM_ExternalWebServiceDef) then
		wsDef:= combobox.listObject.CM_ExternalWebServiceDef;
	endif;
	if wsDef &lt;&gt; null then
		self.filterInterfaceName:=wsDef.name;
	endif;
	
	self.btnDetails.visible:=combobox.listObject &lt;&gt; null and combobox.listObject.isKindOf(CM_ExternalWebServiceDef);
	
	self.setEntTableDef();
	
	// Start 20/05/2024	navcs2		ChangeRequest 59188
	if self.isAPIENDPOINT then
		self.setupAPIENDPOINT();
	elseif self.is1StopVBS then
		self.setupVBS();
	elseif self.isCams then
		self.setupCamsWebservice();
	elseif self.isEDBIC then
		self.setupEDBIC();
	elseif self.isFinanceOne then
		self.setupFinanceOne();
	elseif self.isGenericAPIScan then
		self.setupGenericAPIScan();
	elseif self.isInvoiceAPI then
		self.setupInvoiceAPI();
	elseif self.isOpsView then
		self.setupOpsView();
	elseif self.isQships() then			// Bug 65096
		self.setupQShips();				// Bug 65096
	elseif self.isAgGateway() then		//navra1 - MTN-34782 - 15th July 2025
		self.setupAgGateway();			//navra1 - MTN-34782 - 15th July 2025
	endif;								//navra1 - MTN-34782 - 15th July 2025
	// End 20/05/2024	navcs2		ChangeRequest 59188
	
	self.shtMessageType.visible := self.isAgGateway();		//navra1 - MTN-34782 - 15th July 2025
	
	self.lblBGPStatus.visible := self.isOpsView;			// 04/06/2024	navcs2		ChangeRequest 59188
	self.picBGPStatus.visible := self.isOpsView;			// 04/06/2024	navcs2		ChangeRequest 59188
	self.lblProducerStatus.visible := self.isOpsView;		// 04/06/2024	navcs2		ChangeRequest 59188
	self.picProducerStatus.visible := self.isOpsView;		// 04/06/2024	navcs2		ChangeRequest 59188
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
