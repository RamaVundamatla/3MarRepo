    <JadeMethod name="canBeDBLoaded" id="e64178d8-c9a6-4315-bb9a-0feda5ad5e9a">
        <source>canBeDBLoaded(): Boolean;
//
//15 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
vars
	result 	:Boolean;
begin
	result := inheritMethod();
	
	if not result then
		result := self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
	endif;

	return result;
epilog
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
