        <updating/>
        <source>lstColour_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/08/2013	cnwdap1		Initial creation PAR #32331
//
vars

begin
	self.txtColourList.move(self.widestCaptionExtent + _fieldGeneric.HORIZONTAL_SPACING, 0, self.defaultControlWidth, self.lstColour.height);
	self.txtColourList.tabIndex := _fieldGeneric.tabIndex + 1;
	
	// list box invisible for now
