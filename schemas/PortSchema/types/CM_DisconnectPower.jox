    <JadeMethod name="listFlags" id="1ce04fde-d9a9-4f2b-aa27-ba79a6148a5f">
        <source>listFlags(): String;
// ---------------------------------------------------------------------------
// Created:     Oct 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str: String;
begin
	str := str&amp;inheritMethod();
	if self.secondary then
		str := str&amp;"/Secondary ";
	endif; 
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveVersionCopyRefs" id="cb68d94f-2990-4b87-a99f-0c1199a184d1">
        <source>saveVersionCopyRefs(toClone: CM_DisconnectPower input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(toClone);
	toClone.otherTrackedItem := self.otherTrackedItem;
end;</source>
        <access>protected</access>
        <Parameter name="toClone" type="CM_DisconnectPower" usage="input"/>
    </JadeMethod>
    <JadeMethod name="secondary" id="699347e2-b7f7-4083-b5a9-c0c944e9be49">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>secondary(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(SecondaryFlag);
		else
			flags := flags.getValueWithBitUnset(SecondaryFlag);
		endif;
	else
		_value := (flags.bitAnd(SecondaryFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="e4d2e97c-4067-44a1-905f-7be492d9e248">
        <updating/>
        <source>setForDelete(_reason: String) updating;
//----------------------------------------------------------------
//	Created:	02 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_reason);

	if self.myTrackedItem = null then
		return;
	endif;
	
	self.myTrackedItem.setForDisconnectDelete(self);	


end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
