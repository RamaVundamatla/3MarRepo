    <JadeMethod name="addTIAvailable" id="992b4400-74df-4000-9a9c-ea58b58c6a32">
        <updating/>
        <source>addTIAvailable(_theTI: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2018	jlgndl1	Initial creation	TFS 40157
27 Aug 2018	NDL	- Use the Hold voyage Not the local reference for this one.

*/

vars

	term : CM_Terminal;
	holdCode: String;
	holdVoyage : CM_Voyage;
	control : CMIF_MoveController;
	qdWleArray : CM_WLEArray;
	pdWleArray : CM_WLEArray;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	tmpVoyage : CM_Voyage;

begin

	inheritMethod( _theTI );
	
	
	if _theTI = null then
		return;
	endif;
	
	ti := _theTI;
	if not self.allAvailableTIs.includes( ti ) then
		return;
	endif;
	
	term := ti.myTerminal;
	if term = null then
		return;
	endif;
	
	holdCode := term.getConfig(HoldVoyageCode).String;
	if holdCode &lt;&gt; null then
		holdVoyage := term.allVoyagesByCode.getAtKeyGeq(holdCode, null);
		if holdVoyage &lt;&gt; null and holdVoyage.code = holdCode then
			tmpVoyage := holdVoyage;
		endif;
	endif;
	if tmpVoyage = null then
		tmpVoyage := term.getNullVoyage;
	endif;
	
	if tmpVoyage = null then
		return;
	endif;
	
	if ti.myVoyage &lt;&gt; tmpVoyage then
	
		if app.myPassport.hasErrors then
			return;
		endif;
		
		create qdWleArray transient;
		create pdWleArray transient;
	
		create control transient;
		
		control.setMyTrackedItem( ti);
		control.setMyToPrimaryLocation(null);
		control.isForcedMove := true;
		control.isSystemMove := true;
		
		foreach wle in _theTI.allWorklistEntries do
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			if wle.isQueued then
				qdWleArray.add( wle );
			endif;
		endforeach;
		
		if not qdWleArray.isEmpty then
			foreach wle in qdWleArray do
				control.setMyWorkListEntry(wle);
				control.setMoveMode(QUEUE_MODE);
				app.myUtilityUA.utlUpdateMoveTIUndo(control, app.myPassport);
				
				if app.myPassport.hasErrors then
					return;
				endif;
			endforeach;
		endif;
		
		foreach wle in ti.allWorklistEntries do
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			pdWleArray.add( wle );
		endforeach;
		
		if not pdWleArray.isEmpty then
			foreach wle in pdWleArray do
				control.setMyWorkListEntry(wle);
				control.setMoveMode(PLANNING_MODE);	
				app.myUtilityUA.utlUpdateMoveTIUndo(control, app.myPassport);
				
				if app.myPassport.hasErrors then
					return;
				endif;
			endforeach;
		endif;
		
		ti.changeVoyage( tmpVoyage, app.myPassport );
		
		if app.myPassport.hasErrors then
			return;
		endif;
	
	endif;

epilog

	delete control;
	delete qdWleArray;
	delete pdWleArray;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="allowAddNonOnsite" id="68fd7cfc-fea4-4efd-a4d5-f1b658d2fd4a">
