    <JadeMethod name="getToDoTask" id="40d38e33-5229-48f2-8313-5c511431fb76">
        <source>getToDoTask(_listObject : Object; _listIndex : Integer; _usesWorkOrderTIId : Boolean io; _constantId : Integer io) : CM_ToDoTaskDesc;
//_combo : CMUI_ComboBox; _usesWorkOrderTIId : Boolean io; _constantId : Integer io) : CM_ToDoTaskDesc;

/*

Purpose:			Get ToDoTask ID.  Corresponds to self.comboBoxToDoTasksAddRemForTerm.

Parameters:			

Return Value:		


Date		Who		Reason
29/07/2009	cnwmd1	Initial creation
07/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
*/

vars
	todo : CM_ToDoTaskDesc;
	alternateID : Integer;
begin
	todo := _listObject.CM_ToDoTaskDesc;
	if todo = null then
		alternateID := _listIndex;
		if alternateID = WO_TASK_MOVE or 
		alternateID = WO_TASK_PACK or 
		alternateID = WO_TASK_UNPACK or
		alternateID = WO_TASK_CHANGEVOYAGE or			// TFS 38501
		alternateID = WO_TASK_RECEIVE or				// TFS 38501
		alternateID = WO_TASK_RELEASE or				// TFS 38501
		alternateID = WO_TASK_RELEASEEXTENSION or		//12 Mar 2019	NDL	TFS 43405
		alternateID = WO_TASK_EXPORTRETURN then			// TFS 38501
			_usesWorkOrderTIId := false;
			_constantId := alternateID;
		endif;
	else
		_usesWorkOrderTIId := true;
		alternateID := WO_TASK_TODO;
		return todo;
	endif;
epilog

end;</source>
        <Parameter name="_listObject" type="Object"/>
        <Parameter name="_listIndex" type="Integer"/>
        <Parameter name="_usesWorkOrderTIId" type="Boolean" usage="io"/>
        <Parameter name="_constantId" type="Integer" usage="io"/>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
