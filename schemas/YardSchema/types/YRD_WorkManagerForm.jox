    <JadeMethod name="doScheduleTableContextMenu" id="e1a39d0e-bd8d-4ede-9897-2150f5c93678">
        <updating/>
        <source>doScheduleTableContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwrd1	Initial creation

*/

vars

	theRow,
	theColumn 	: Integer;
	allValue,
	theseValue : Integer;
	number : Integer;
	workOrder : CM_WorkOrder;
	woSet : CM_WorkOrderSet;
begin


	if cntrl.CM_BaseTable.getCellFromPosition(x,y,theRow,theColumn) then
		if cntrl.cnEcIsValidRow(theRow) and cntrl.cnEcIsValidColumn(theColumn) then
		
			woSet := cntrl.CM_BaseTable.accessCell(theRow,theColumn).JadeTableCell.itemObject.CM_WorkOrderSet;
			
			if woSet = null then
				self.mnuWorkOrderMain.visible := false;
				return false;
			endif;
			
			//self.mnuWorkOrderMain.visible := true;
			self.buildWorkOrderMenu(woSet);
			
			return self.showContextMenu(self.mnuWorkOrderMain,cntrl,conwin,mouse,x,y);
			/*
			self.mnuActionAll.userObject := schedule;
			self.mnuActionThese.userObject := schedule;
			self.mnuActionSome.userObject := schedule;
		
			if schedule &lt;&gt; null then // we can proceed
			
			
				// build action menu
				parent := schedule.myParent;
				
				if parent.totalUnactioned = 0 then
					return false;
				endif;
				
				allValue := parent.totalUnactioned;
				
				theseValue := schedule.numberScheduled - schedule.getNumberActioned();
				
				if theseValue &lt; 0 then 
					theseValue := 0;
				endif;
				
				if theseValue &gt; allValue then							
					theseValue := allValue;
				endif;
				
				
				
				self.mnuActionAll.caption := app.getErrorString1(Wo_Action_All, allValue.asStringJMT() );
				self.mnuActionThese.caption := app.getErrorString1(Wo_Action_These, theseValue.asStringJMT() );
				
			
				self.mnuActionThese.visible := not theseValue = 0 ;
			
	
			
			return self.showContextMenu(self.mnuAction,cntrl,conwin,mouse,x,y);
			

			endif;
			
		
		else
		// no schedule so show the other context menu
		return self.showContextMenu(self.mnuDateColumn,cntrl,conwin,mouse,x,y);		
		endif;
		
		*/
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterSchedule" id="dcefd5fd-58de-4a0b-a083-fdfe28985211">
        <source>filterSchedule(_schedule : CM_WorkOrderSchedule) : Boolean;
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	scheduledDateLocal : Date;
begin

	scheduledDateLocal := self.systemToLocalTime( _schedule.scheduledDT).date;

	if self.filterDateFrom &lt;&gt; null and scheduledDateLocal &lt; self.filterDateFrom then
		return false;
	endif;
	
	if self.filterDateTo &lt;&gt; null and scheduledDateLocal &gt; self.filterDateTo then
		return false;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_schedule" type="CM_WorkOrderSchedule"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterWorkOrder" id="d429c282-bb50-4bf5-acd9-6e4e40418d97">
        <source>filterWorkOrder(_workOrder : CM_WorkOrder) : Boolean;
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.filterWorkOrderId &lt;&gt; null and _workOrder.id &lt;&gt; self.filterWorkOrderId then
		return false;
	endif;

	return _workOrder.taskStatus = WO_STATUS_APPROVED or _workOrder.taskStatus = WO_STATUS_PARTCOMPLETE;
	
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterWorkOrderDetail" id="ed0e264c-01df-44b7-9254-cc9df5efa18c">
        <source>filterWorkOrderDetail(_woDetail : CM_WorkOrderDtl) : Boolean;
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	taskType : Object;
	
begin
	taskType := self.getTaskTypeForWoDtl(_woDetail);
	
	if taskType = null then
		return false;
	endif;
	
	return self.allTaskTypesFiltered.includes(taskType);
	
epilog

end;</source>
        <Parameter name="_woDetail" type="CM_WorkOrderDtl"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFilteredSchedules" id="8939b870-be34-4c40-92eb-30ed467762d6">
        <source>getFilteredSchedules();
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// -----------------------------------------------------------------------------

vars
	schedule  : CM_WorkOrderSchedule;
	workOrder : CM_WorkOrder;
	woDetail  : CM_WorkOrderDtl;
	
begin
	self.allSchedules.clear;
	
	if not self.filterSet then
		return;
	endif;
	
	foreach workOrder in self.myTerminal.allWorkOrders discreteLock where self.filterWorkOrder(workOrder) do
		if workOrder.isVoyageWorkOrder then  //29.09.2021 navma1 #51925
			continue;
		endif;
		foreach woDetail in workOrder.allWoDtls where self.filterWorkOrderDetail(woDetail) do
			foreach schedule in woDetail.CM_WorkOrderTIDtl.allSchedules where self.filterSchedule(schedule) do	
				if not ( schedule.numberScheduled = 0 and schedule.getNumberActioned() = 0 and schedule.getNumberComplete() = 0 )then
						self.allSchedules.add(schedule);
				endif;
			endforeach;
		endforeach;
	endforeach;
				
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getScheduledDT" id="5f988620-7f41-454a-8119-359c52f7aee9">
        <source>getScheduledDT(_row : Integer) : TimeStamp;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	return self.tblSchedule.accessCell(_row,1).text.asTimeStampJMT();
epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getTaskTypeForColumn" id="8df931e9-7512-4b77-8a4b-03974ad5041a">
        <source>getTaskTypeForColumn(col : Integer) : Object;
// -----------------------------------------------------------------------------
// Created:		18 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	return self.tblSchedule.accessColumn(col).itemObject;
epilog

end;</source>
        <Parameter name="col" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getTaskTypeForWoDtl" id="5745fc82-3fde-4b54-ac48-fc2ccd3821c5">
        <source>getTaskTypeForWoDtl(_woDetail : CM_WorkOrderDtl) : Object;
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		Get a reference for the form's Task Type filtering.
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 29 Sep 2021 navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// -----------------------------------------------------------------------------

vars
	dtlType : Integer;
	
begin
	
	//dtlType := _woDetail.getDtlType();           			//29.09.2021 navma1 #51925
	dtlType   := _woDetail.getWorkOrderTaskIdByClass();		//29.09.2021 navma1 #51925
	
	if dtlType = WO_TASK_TODO then
		return _woDetail.CM_WodToDo.myToDoTaskDesc;
	elseif dtlType = WO_TASK_MOVE then
		return CM_WodMove;
	elseif dtlType = WO_TASK_PACK then
		return CM_WodPack;
	elseif dtlType = WO_TASK_UNPACK then
		return CM_WodUnpack;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_woDetail" type="CM_WorkOrderDtl"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initSummary" id="b9086eb7-f02a-4e88-899e-ce28c0f4c16f">
        <updating/>
        <source>initSummary() updating;
// -----------------------------------------------------------------------------
// Created:		18 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	tbl : CM_BaseTable;
	
begin
	tbl := self.tblSummary;
	
	tbl.rows := 0;
	tbl.fixedColumns := self.tblSchedule.fixedColumns;

	tbl.gridLines := true;

	tbl.addItem( app.getErrorString(Total) );
	
	tbl.accessColumn(1).width := self.widthDTColumn;
	
	tbl.columns := tblSchedule.columns-1 ;
	
	col := tbl.fixedColumns;
	
	
	tbl.accessColumn(1).width := (self.widthDTColumn/3).Integer;
	tbl.accessColumn(2).width := (self.widthDTColumn/3).Integer;
	tbl.accessColumn(3).width := (self.widthDTColumn/3).Integer;
	if tbl.columns &gt; 3 then
		tbl.accessCell(1, 4).mergeCells := Table.MergeCells_NotAvailable;
	endif;
	
	tbl.accessCell(1, 1).mergeCells := Table.MergeCells_Merge;

	
	while col &lt; tbl.columns do
		col := col + 1;
		tbl.accessColumn(col).width := self.widthValueColumn;
		tbl.accessedColumn.alignment := Table.Alignment_Center_Middle;
		col := col + 1;
		tbl.accessColumn(col).width := self.widthValueColumn;
		tbl.accessedColumn.alignment := Table.Alignment_Center_Middle;
		col := col + 1;
		tbl.accessColumn(col).width := self.widthValueColumn;
		tbl.accessedColumn.alignment := Table.Alignment_Center_Middle;
		col := col + 1;
		tbl.accessColumn(col).width := self.widthValueColumn;
		tbl.accessedColumn.alignment := Table.Alignment_Center_Middle;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="08cc00f1-538f-43d9-9b69-64857e015729">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown() then
			inheritMethod(keyCode, shift);
		else
			self.showSearcher(self.frmSearcher.visible);
		endif;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="45138b81-c02f-4731-97ab-045792c161f5">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.tblSchedule.rows := self.tblSchedule.fixedRows;
	self.tblSchedule.columns := self.tblSchedule.fixedColumns;
	self.tblSchedule.backColor := self.colorControlBack;

	self.tblSummary.backColor := self.colorControlBack;
	
	self.allTaskTypes.copy(self.allTaskTypesFiltered);
	self.loadSchedule();
	
	self.showSearcher(false);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSchedule" id="83f2ff33-eb20-4e01-850a-856cc67b1909">
        <updating/>
        <source>loadSchedule() updating;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	colTask : Integer;
	dateTime : TimeStamp;
	invalidSchedule : Boolean;
	lastDT : TimeStamp;
	numberActioned : Integer;
	schedule : CM_WorkOrderSchedule;
	taskType : Object;
	tbl : CM_BaseTable;
	woDetail : CM_WorkOrderDtl;
	lastMonth,
	lastDay : String;
	monthText,
	dayText,
	tmpDayText	: String;	
	localScheduledDT : TimeStamp;
begin
	tbl := self.tblSchedule;

	//  End existing notifications for table
	
//	self.timerClear();
	
	col := tbl.fixedColumns + 1;
	while col &lt; tbl.columns do
//		woDetail := self.getTaskType(col);
//		self.endNotification(woDetail, self.myTerminal.getTerminalEvent(Event_WorkOrderSchedule_Update));
//		self.endNotification(woDetail, Object_Delete_Event);
		col := col + self.TaskColumns;
	endwhile;
	
	//  Initialise and set up headings
	//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.currentTS := self.systemToLocalTime(app.actualTimeServer());
	
	tbl.clearAllSelected();
	tbl.rows := tbl.fixedRows;
	tbl.columns := tbl.fixedColumns;

	tbl.gridLines := true;
	tbl.accessMode := Table.AccessMode_Cell;
	tbl.selectMode := Table.SelectMode_Single;

	tbl.accessColumn(2).width := ((self.widthDTColumn/3)*2).Integer;
	tbl.accessColumn(3).width := (self.widthDTColumn/3).Integer;
	
	tbl.accessCell(1, 1).mergeCells := Table.MergeCells_Merge;
	tbl.accessCell(2, 1).mergeCells := Table.MergeCells_Merge;	
	
	tbl.accessCell(1,1).gridBottom := false;

	tbl.columns := tbl.columns + 1;
	tbl.accessColumn(tbl.columns).visible := true;
	
	foreach taskType in self.allTaskTypesFiltered do
		colTask := tbl.columns;
		tbl.columns := tbl.columns + self.TaskColumns;

		tbl.accessColumn(colTask).alignment := Table.Alignment_Center_Middle;
		tbl.accessColumn(colTask + 1).alignment := Table.Alignment_Center_Middle;
		tbl.accessColumn(colTask + 2).alignment := Table.Alignment_Center_Middle;
		tbl.accessColumn(colTask + 3).alignment := Table.Alignment_Center_Middle;
				
		tbl.accessCell(1, colTask).mergeCells := Table.MergeCells_Merge;
		tbl.accessedCell.text := self.displayTask(taskType);
//		tbl.accessedCell.backColor := self.colorValueColumn;
		tbl.accessCell(1, colTask + 4).mergeCells := Table.MergeCells_NotAvailable;
		
		tbl.accessCell(2, colTask).text := "# Work Orders";
		tbl.accessedCell.backColor := self.colorHeadingColumn;
		tbl.accessCell(2, colTask+1).text := app.getErrorString(Planned);
		tbl.accessedCell.backColor := self.colorHeadingColumn;
		tbl.accessCell(2, colTask+2).text := app.getErrorString(Actioned);
		tbl.accessedCell.backColor := self.colorHeadingColumn;
		tbl.accessCell(2, colTask+3).text := app.getErrorString(Complete);
		tbl.accessedCell.backColor := self.colorHeadingColumn;
		
		tbl.accessColumn(colTask).itemObject := taskType;
		tbl.accessedColumn.width := self.widthValueColumn;
		tbl.accessColumn(colTask + 1).width := self.widthValueColumn;
		tbl.accessColumn(colTask + 2).width := self.widthValueColumn;
		tbl.accessColumn(colTask + 3).width := self.widthValueColumn;
	endforeach;
	
	tbl.accessColumn(tbl.columns).visible := false;

	self.initSummary();
	
	//  Get details

	self.getFilteredSchedules();
	
	//  Load schedule details
	
	on Exception do app.handleDeletedObject(exception, schedule, invalidSchedule);
	
	lastDT := null;

	foreach schedule in self.allSchedules do
		invalidSchedule := false;
		woDetail := schedule.myParent;
		if not invalidSchedule then
			localScheduledDT := self.systemToLocalTime(schedule.scheduledDT);
			if localScheduledDT  &lt;&gt; lastDT then
				//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
				lastDT := localScheduledDT;
				if lastMonth &lt;&gt;  lastDT.date.monthName() then
					lastMonth := lastDT.date.monthName();
					monthText := lastMonth;
				else
					monthText := '';			
				endif;
				
				tmpDayText :=  lastDT.date.dayName()[1:3] &amp; ' ' &amp; lastDT.date.day.asStringJMT();
				
				if lastDay &lt;&gt;  tmpDayText then
					lastDay := tmpDayText;
					dayText := lastDay;
				else
					dayText := '';			
				endif;		
				
				self.addRowToSchedule(lastDT,monthText  , dayText , lastDT.time.asStringJMT()  , 0);
			endif;
			self.addScheduleDetails(schedule, tbl.rows);
		endif;
	endforeach;

	//  Set up notifications for table
	
	col := tbl.fixedColumns + 1;
	while col &lt; tbl.columns do
//		woDetail := self.getTaskType(col);
//		self.beginNotification(woDetail, Object_Delete_Event, Response_Continuous, 0);
//		self.beginNotification(woDetail, self.myTerminal.getTerminalEvent(Event_WorkOrderSchedule_Update), Response_Continuous, 0);
		col := col + self.TaskColumns;
	endwhile;
	
//	self.timerSetup();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTaskTypes" id="83f52b5e-e192-48f2-9217-24934635974e">
        <source>loadTaskTypes();
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	taskDict : CM_ToDoTaskDescByCode;
begin
	self.mltTasks.userInputEnabled 				:= true;
	self.mltTasks.formDisplayEntryMethodName 	:= YRD_WorkManagerForm::displayTask.name;
	self.mltTasks.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltTasks.myAvailableListBox.sorted 	:= false;		
	self.mltTasks.mySelectedListBox.sorted 		:= false;
	self.mltTasks.setTabIndex();
	self.mltTasks.myBaseForm 					:= self;
		
	//  Set up all Task Types in standard sequence
	self.allTaskTypes.clear;
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForWOTerm(app.getMyTerminalDO_NOT_USE(), null, taskDict );
	taskDict.copy( self.allTaskTypes );
	
	self.allTaskTypes.atPut(WO_TASK_MOVE, CM_WodMove);
	self.allTaskTypes.atPut(WO_TASK_PACK, CM_WodPack);
	self.allTaskTypes.atPut(WO_TASK_UNPACK, CM_WodUnpack);
	
	self.mltTasks.setAvailable(self.allTaskTypes, true); 
	self.mltTasks.setSelected(self.allTaskTypes); 
	
epilog
	delete taskDict;
end;</source>
    </JadeMethod>
