    <JadeMethod name="myCargoType" id="519c1201-cd16-448f-99fa-1400d4ccc917">
        <methodInvocation>mapping</methodInvocation>
        <source>myCargoType(set: Boolean; _value: CM_CargoType io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

begin
	
	if _value = null then
		if self.myReserveSelection &lt;&gt; null then
			_value := self.myReserveSelection.getCargoType;
		endif;
	endif;
	if _value = null then
		if self.myBookingItem &lt;&gt; null then
			_value := self.myBookingItem.myCargoType;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_CargoType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateMe" id="c59ff636-6505-4c25-b40f-d1101d7d63f7">
        <updating/>
        <source>populateMe( _parent : CM_JRWVehicleBookingDetailsObj; _reserve : CM_ReserveSelection ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2014	cnwndl1	Initial creation

*/

vars

begin

	self.myBookingItem := _reserve.myBookingRefItem;
	self.myReserveSelection := _reserve;
	
	inheritMethod( _parent, null );

epilog

end;</source>
        <Parameter name="_parent" type="CM_JRWVehicleBookingDetailsObj"/>
        <Parameter name="_reserve" type="CM_ReserveSelection"/>
    </JadeMethod>
