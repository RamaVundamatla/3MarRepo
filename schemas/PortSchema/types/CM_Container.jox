    <JadeMethod name="detachCOU" id="5405c926-f456-4ec0-a7a4-82fee1d4b609">
        <updating/>
        <source>detachCOU(_passport : CM_Passport input) updating;
//Detaches the COU. Does NOT move the COU anywhere after detach. Note that an attached COU is not
//known to the location controller of the parent TI, so if a COU is detached on site, the calling
//function must move it to make it appear somewhere in the terminal.

// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
vars
	theCOU	:	CM_ClipOnUnit;
begin

	exclusiveLock(self);	

	theCOU := self.getCou;
	// Check that we have a COU...
	if theCOU = null then
		return;
	endif;

	theCOU.setImExStatus(TI_IMEX_STATUS_STORAGE);							// 15/06/2015 cnwmh5
	
	// Set the COU's parent to null...
	theCOU.myParent := null;	//Not required but just to be safe.

	//Null reference to the COU, cou.myReefer will also be set null
	self.setCou(null);

	//Null the location strings: See comments at top of method
	theCOU.locationId := null;
	theCOU.plannedLocnId := null;
	theCOU.rehandleLocnId := null;
	
	//Reset voyage and status properties
	if app.isUnitTestGarbageCollect then
		theCOU.myVoyage 	:= null;
	elseif (not self.isTransient) then
		theCOU.changeVoyage(null, _passport);
	else
		theCOU.myVoyage 	:= null;
	endif;
	
	//theCOU.setImExStatus(TI_IMEX_STATUS_STORAGE);

	self.updateObjectEdition(self);	// par 30292

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="detachGenerator" id="acb2dbf5-b4e4-44c2-b0c8-21edac5ad933">
        <updating/>
        <source>detachGenerator(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:      18 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// Detaches the generator. Does NOT move the generator anywhere after detach.
// Note that an attached generator is not known to the location controller of
// the parent TI, so if a generator is detached on site, the calling
// function must move it to make it appear somewhere in the terminal.

// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
vars
	theGererator : CM_Generator;
	desc		: String;
	task		: CM_ToDoTask;
	
begin
	exclusiveLock(self);	

	theGererator := self.getGenerator;
	// Check that we have a generator...
	if theGererator = null then
		return;
	endif;

	// Set the generator's parent to null...
	theGererator.myParent := null;	//Not required but just to be safe.

	//Null reference to the generator, generator.relatedTo will also be set null
	self.setGenerator(null);

	//Null the location strings: See comments at top of method
	theGererator.locationId := null;
	theGererator.plannedLocnId := null;
	theGererator.rehandleLocnId := null;
	
	// when detaching a generator type of nose-mounted, we should remove the To Do Task "Detach Generator Set" automatically
	// Par17775. ccms1405. APM Yard Ops, new generator types
	if theGererator.isNoseMounted() then
		if (not self.isTransient) then	
			desc := null;
			foreach task in self.allToDoTasksToDo do
				if task.toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_DetachGenerator then
					desc	:= task.toDoTaskDesc.description.trimBlanks;
					break;
				endif;
			endforeach;
			if desc &lt;&gt; null then
				self.completeToDoTaskForBulk( task.toDoTaskDesc, null, _passport);	
			endif;
		endif;
	endif;
	
	//Reset voyage and status properties
	if app.isUnitTestGarbageCollect then
		theGererator.myVoyage 	:= null;
	elseif (not self.isTransient) then
		theGererator.changeVoyage(null, _passport);
	else
		theGererator.myVoyage 	:= null;
	endif;
	theGererator.setImExStatus(TI_IMEX_STATUS_STORAGE);

	self.updateObjectEdition(self);	// par 30292
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="erase" id="fe318518-f036-4d5b-8458-8ff64e5c3fdf">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     28 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/11/2009	cnwdap1		CCMS 1017 All reefer properties now on CM_ReeferProperties class
// ---------------------------------------------------------------------------
vars
	child	: CM_TrackedItem;
	iter	: Iterator;
	log 	: CM_DailyReeferTemp;
	
begin

/*	//------------------------------------------------------------------
	//             Remove any cou it has 
	//------------------------------------------------------------------
	if self.cou &lt;&gt; null then
		child := self.cou;
		if child.site &lt;&gt; TI_SITE_ONSHIP then //rs oct 2004 stopping garbage collection
			self.detachCOU(null);
		endif;
		child.erase(_eraseLevel);
	endif;
	
	//------------------------------------------------------------------
	//             Remove any generator it has 
	//------------------------------------------------------------------
	if self.generator &lt;&gt; null then
		child := self.generator;
		if child.site &lt;&gt; TI_SITE_ONSHIP then //rs oct 2004 stopping garbage collection
			self.detachGenerator(null);
		endif;
		child.erase(_eraseLevel);
	endif;
	
	//And remove the packed temp details
	if packTempDetails &lt;&gt; null then
		delete packTempDetails;
	endif;
*/
	inheritMethod(_eraseLevel);

epilog
	if iter &lt;&gt; null then
		delete iter;
	endif;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseDefrostReeferSystemAlert" id="0837efd2-2805-49dd-9a10-7105fefb7912">
        <source>eraseDefrostReeferSystemAlert();
//
// CCMS1551 July 2007 cnwrs1
// 16/09/2010	cnwdap1		PAR #25754 This should have been moved up to CM_TrackedItem level as part
//							of reefer changes for CCMS 1116
//
vars
  sa1: CM_SystemAlert; // AKB 08Mar2001 PAR 3803
