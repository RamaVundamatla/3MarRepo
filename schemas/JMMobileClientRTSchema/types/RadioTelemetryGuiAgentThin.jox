    <JadeMethod name="doLogon" id="b9faabe3-e61a-4190-ab7f-0a405e36a863">
        <updating/>
        <source>doLogon(	_userName					:String;
			_password					:String;
			_clientConnectionDetails	: String;
			_sysColorBackGeneral,
			_sysColorForeGeneral,
			_sysColorBackTable,
			_sysColorForeTable,
			_userColorBackGeneral,
			_userColorForeGeneral,
			_userColorBackTable,
			_userColorForeTable			: Integer output;
			_machineCode				: String output;
			_machineLiftType			: Integer output;
			_primaryQueueId				: String output;	// PAR #16010
			_numberOfQueueEntries		: Integer output;	// PAR #16010
			_canChangeQueue				: Boolean output;	// PAR #16010
			_canRunSelectorQueries		: Boolean output;
			_showNumberofQueueEntries	: Boolean output;	// PAR #16010
			_portLogo					: Binary output;
			_state						: Integer output;
			_lastState					: Integer output;
			_errorString				: String output;
			_lastUpdateTs				: TimeStamp output) : Boolean updating;

/*

Date		Who		Reason
11 Jan 2006	cnwdvb1	Created 
07 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	rtnValue	: Boolean;
	dtoColor	: MobileServerRTThin::DTO_Colours;

begin
	self.clearStateObject();
	
	create dtoColor transient;
	
	rtnValue	 := self.myRTThinClientAgent.doLogon(_userName, _password, _clientConnectionDetails, dtoColor, self.myStateObj);

	_sysColorBackGeneral	:= dtoColor.sysColorBackGeneral;
	_sysColorForeGeneral	:= dtoColor.sysColorForeGeneral;
	_sysColorBackTable		:= dtoColor.sysColorBackTable;
	_sysColorForeTable		:= dtoColor.sysColorForeTable;
	_userColorBackGeneral	:= dtoColor.userColorBackGeneral;
	_userColorForeGeneral	:= dtoColor.userColorForeGeneral;
	_userColorBackTable		:= dtoColor.userColorBackTable;
	_userColorForeTable		:= dtoColor.userColorForeTable;
	_machineCode			:= dtoColor.machineCode;
	_machineLiftType		:= dtoColor.machineLiftType;				// CCMS 1595 20/11/2007
	_primaryQueueId			:= dtoColor.primaryQueueId;					// PAR #16010
	_numberOfQueueEntries	:= dtoColor.numberOfAvailableQueueEntries;	// PAR #16010
	_canChangeQueue			:= dtoColor.canChangeQueue;					// PAR #16010
	_canRunSelectorQueries	:= dtoColor.canRunSelectorQueries;
	_showNumberofQueueEntries	:= dtoColor.showNumberOfQueueEntries;	// PAR #16010
	
	_portLogo				:= dtoColor.portLogo;
	
	_errorString 		:= self.myStateObj.errorString;
	_state 				:= self.myStateObj.guiState;
	_lastUpdateTs		:= self.myStateObj.lastUpdateTs;
	_lastState			:= self.myStateObj.extraInfo;
	
	return rtnValue;
	
	
epilog	
	delete dtoColor;
	
end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_clientConnectionDetails" type="String"/>
        <Parameter name="_sysColorBackGeneral" type="Integer" usage="output"/>
        <Parameter name="_sysColorForeGeneral" type="Integer" usage="output"/>
        <Parameter name="_sysColorBackTable" type="Integer" usage="output"/>
        <Parameter name="_sysColorForeTable" type="Integer" usage="output"/>
        <Parameter name="_userColorBackGeneral" type="Integer" usage="output"/>
        <Parameter name="_userColorForeGeneral" type="Integer" usage="output"/>
        <Parameter name="_userColorBackTable" type="Integer" usage="output"/>
        <Parameter name="_userColorForeTable" type="Integer" usage="output"/>
        <Parameter name="_machineCode" type="String" usage="output"/>
        <Parameter name="_machineLiftType" type="Integer" usage="output"/>
        <Parameter name="_primaryQueueId" type="String" usage="output"/>
        <Parameter name="_numberOfQueueEntries" type="Integer" usage="output"/>
        <Parameter name="_canChangeQueue" type="Boolean" usage="output"/>
        <Parameter name="_canRunSelectorQueries" type="Boolean" usage="output"/>
        <Parameter name="_showNumberofQueueEntries" type="Boolean" usage="output"/>
        <Parameter name="_portLogo" type="Binary" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_lastState" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_lastUpdateTs" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enqTrackedItem" id="710f148b-7303-4a1f-a1ad-4e1cf5ddfa34">
        <source>enqTrackedItem(_form: JMMobileClient_BaseForm input; _tiId : String; _errorString: String output; _state: Integer output): Boolean;
// -------------------------------------------
// Created 16 January 2006 by cnwdvb1
// -------------------------------------------
vars

	
	packageDTO 		: MobileServerRTThin::DTO_EnquiryGradingTasks;
	rtnValue		: Boolean;

begin
	
	create packageDTO transient;

	self.clearStateObject();
	
	rtnValue := self.myRTThinClientAgent.enqTrackedItem(_tiId, packageDTO, self.myStateObj);

	_errorString := self.myStateObj.errorString;
	_state		:= self.myStateObj.guiState;
	
	if rtnValue then
		_form.loadFormFromThinClientObj(packageDTO);
//		self.loadFormFromPackageDTO(_form, packageDTO);
	endif;

	return rtnValue;

epilog
	delete packageDTO;
end;</source>
