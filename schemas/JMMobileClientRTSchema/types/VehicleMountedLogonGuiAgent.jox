    <JadeMethod name="setClientConnectionDetails" id="8e99c9a8-edef-4e90-918e-1f42dd2934e8">
        <source>setClientConnectionDetails(_deviceName: String; _terminalCode: String; _username: String);
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	iniFileName : String;
begin
	iniFileName 			:= app.getIniFileName();
	
	if _terminalCode &lt;&gt; null then
		app.setProfileString(iniFileName, VehicleMountedIniSection, Key_VehicleMountedTerminal, _terminalCode);
	endif;
	
	if _deviceName &lt;&gt; null then
		app.setProfileString(iniFileName, VehicleMountedIniSection, Key_VehicleMountedDevice, _deviceName);
	endif;
	
	if _username &lt;&gt; null then
		app.setProfileString(iniFileName, VehicleMountedIniSection, Key_VehicleMountedUser, _username);
	endif;


epilog

end;</source>
        <Parameter name="_deviceName" type="String"/>
        <Parameter name="_terminalCode" type="String"/>
        <Parameter name="_username" type="String"/>
    </JadeMethod>
</Class>
