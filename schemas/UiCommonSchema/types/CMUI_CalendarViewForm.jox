    <JadeMethod name="btnShowFilter_click" id="8c7efa80-bd4d-4428-b065-50a22fa7f354">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnShowFilter_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars
	
begin

	self.allSelectedDayTypes.clear();
	self.mulDayType.getSelected(self.allSelectedDayTypes);
	
	
	self.allSelectedCalendars.clear();
	self.mulCalendar.getSelected(self.allSelectedCalendars);
	
	self.doRefreshCalendar( true );
	
	self.showFilter();

epilog

end;</source>
