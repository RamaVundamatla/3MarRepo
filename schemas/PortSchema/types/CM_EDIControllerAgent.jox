    <JadeMethod name="getEDIDisplayStrForType" id="714ac861-d4da-43e4-8de0-c144f31f4f3c">
        <source>getEDIDisplayStrForType(_type :Integer):String;
// ---------------------------------------------------------------------------
// Created:     22 April 2010 by cnwcs5
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 220/04/2010	cnwcs5		ccms 1118 - enhanced edi form
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
