    <JadeMethod name="createBNZBuyLineVoid" id="903cc409-79b1-4f3f-893f-110d2195eec0">
        <source>createBNZBuyLineVoid(	pBuyLineMessage : CnEcBNZBuyLineMsg;
						pBNZBuyLineVoidNew :CnEcBNZBuyLineVoid output);

vars
	void : CnEcBNZBuyLineVoid;
	
begin
	create void;
	void.updateMe(	pBuyLineMessage.getAmount(),
					pBuyLineMessage.getCardNum(),
					pBuyLineMessage
					);

	pBNZBuyLineVoidNew := void;
end;</source>
        <Parameter name="pBuyLineMessage" type="CnEcBNZBuyLineMsg"/>
        <Parameter name="pBNZBuyLineVoidNew" type="CnEcBNZBuyLineVoid" usage="output"/>
