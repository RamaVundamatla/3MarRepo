    <JadeMethod name="deleteVoyage" id="bc809b7e-189a-48e1-81f4-795e4890169d">
        <source>deleteVoyage(_code: String);
//29 August 2008	cnwdw1
//16 Jul 2019	jlgsl4	TFS 44957 - PEL1 - include movement pilot details in voyage-movement UT
//
vars
	voyage: CM_Voyage;
	voyage1 : CM_Voyage;
	stockOrder: CM_StockOrderHeader;
	bol: CM_BOL;
	garbageCollValue : Boolean;
	manifest : CM_Manifest;
	allocation			: CM_YardAllocation;
	criteria			: CM_YACriteria;
	movementPilotDetail : HMS_MovementPilotDetails; // TFS 44957
begin
	voyage := self.getVoyage(_code);
	
	garbageCollValue := app.isGarbageCollectionProcess;
	
	if voyage &lt;&gt; null then
	
		self.deleteVoyageChildren(voyage);
		
		foreach stockOrder in voyage.allOrdersByOperatorOrderNo do
			self.deleteStockOrder(stockOrder);
		endforeach;
		
		foreach bol in voyage.allBOLOutByTypeStatusNumDT do
			self.deleteBOL(null, bol);
		endforeach;
		
		if voyage.myGeneralCargoVoyage &lt;&gt; null then
			foreach manifest in voyage.myGeneralCargoVoyage.allManifestsById do
				beginTransaction;
				delete manifest;
				commitTransaction;
			endforeach;
		endif;
		
		// 11/08/2015 cnwmh5 allocationd delete
		beginTransaction;
		foreach allocation in voyage.allVoyageAllocations do
			foreach criteria in allocation.allCriteriaByType do
				criteria.setYardAllocation(null);
				delete criteria;
			endforeach;
			//allocation.erase(NORMAL_ERASE);
			delete allocation;
		endforeach;
		commitTransaction;
		
		//31 May 2019	NDL	TFS 44773
		beginTransaction;
		voyage.allWorkOrders.purge();
		commitTransaction;

		if voyage.getMovementShift(1) &lt;&gt; null then // --&gt; TFS 44957
			beginTransaction;
			foreach movementPilotDetail in voyage.getMovementShift(1).allMovementPilotDetails do
				if movementPilotDetail.myPilot = null or movementPilotDetail.myPilot.code = "UTPILOT" then // only delete the UTPILOT
					delete movementPilotDetail.myPilot; // delete UTPILOT
				endif;
			endforeach;
			voyage.getMovementShift(1).allMovementPilotDetails.purge;
			commitTransaction;
		endif; // &lt;-- TFS 44957
		
		// 19/08/2019 jlgmd1 clean up RT queue
		if voyage.myQueue &lt;&gt; null then
			beginTransaction;
			voyage.myQueue.erase(NORMAL_ERASE);
			commitTransaction;
		endif;
		
		//06 May 2021	NDL	TFS 50906
		if not voyage.allLocationActivity.isEmpty then
			beginTransaction;
			voyage.allLocationActivity.purge();
			commitTransaction;
		endif;
		
		foreach voyage1 in voyage.allVoyageInlandTerminals do			// 17/08/2015 cnwmh5
			self.opts.removeAssoc("Terminal");
			self.opts.addAssoc("Terminal", voyage1.myTerminal.code);
			self.deleteVoyage(voyage1.code);
			self.opts.removeAssoc("Terminal");
			self.opts.addAssoc("Terminal", voyage.myTerminal.code);
		endforeach;
		
		self.ignoreTrxWarnings(true);
		
		app.isGarbageCollectionProcess := true;
		if self.myMergeIter &lt;&gt; null then								// 05/01/2015 cnwmh5
			self.removeMergeIterCollection(voyage.allOnshipTIsByIdCargoType);
		endif;
		app.myTrxDA.trxDeleteVoyage(voyage, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		app.isGarbageCollectionProcess := false;
			
	endif;
	
epilog
		app.isGarbageCollectionProcess := garbageCollValue;
end;
</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyageAllocation" id="fc71c0ce-b546-4fb2-9c24-f30afd0b5afc">
        <source>deleteVoyageAllocation(_voyageAllocation : CM_VoyageAllocation io);

/*

Purpose:		Delete a voyage's allocations	

Date			Who		Reason
11/08/2015		cnwmh5	Initial creation

*/

vars

	criteria			: CM_YACriteria;
	
begin

	if _voyageAllocation = null then
		return;
	endif;
	
	beginTransaction;
	foreach criteria in _voyageAllocation.allCriteriaByType do
		criteria.setYardAllocation(null);
		delete criteria;
	endforeach;
	delete _voyageAllocation;
	commitTransaction;

	//app.myTrxDA.trxDeleteVoyageAllocation(_voyageAllocation, app.myPassport);
	//self.assertNoTrxErrorsOrWarnings();
	
epilog

end;</source>
        <Parameter name="_voyageAllocation" type="CM_VoyageAllocation" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyageChildren" id="972b43ec-defc-4ba1-8342-63a783474358">
        <source>deleteVoyageChildren(voyage: CM_Voyage);
//29 August 2008	cnwdw1	
//
// 21/06/2011 cnwmh5 Move where it deletes the voyage jobs as was deleting wle's which are needed for deleteTrackedItem
vars
	ti: CM_TrackedItem;
	booking: CM_BookingRef;
	tiSet				: CM_TISet;
	tisWithWarnings		: CM_TISet;
	lc : CM_LocationsController;
	lcs : CM_LCSet;
		fm : CM_FutureMove;
begin
	if voyage &lt;&gt; null then
		beginTransaction;
			voyage.allBookingRefs.rebuild;
			voyage.allDeletedTIsByCargoTypeId.rebuild;
			voyage.allOnshipTIsByCargoTypeId.rebuild;
			voyage.allOnsiteTIsByCargoTypeId.rebuild;
			voyage.allNotifiedTIsByCargoTypeId.rebuild;
			voyage.allOffsiteTIsByCargoTypeId.rebuild;
			voyage.allTranshipTIsExport.rebuild;
			voyage.allTranshipTIsImport.rebuild;
			voyage.allTbaTIsByIdCargoType.rebuild;					// 20/03/2015 cnwmh5
			voyage.allRRPTIsByIdCargoType.rebuild;	//16 Mar 2020	NDL	TFS 47004
			voyage.allOffloadedTIsByCargoTypeId.rebuild;			// 20/03/2015 cnwmh5
			voyage.allTisByHouseBol.rebuild;
			
			voyage.allVoyageKPIEntities.purge;
		commitTransaction;
		
		
		// 05/01/2015 cnwmh5
		create tiSet transient;	
		create tisWithWarnings transient;
		
		tiSet.clear();
		voyage.allOnsiteTIsByCargoTypeId.tryCopy(tiSet);
		//deleteTrackedItem(tiSet, true); // AKB added true
		
		//tiSet.clear();
		voyage.allDeletedTIsByCargoTypeId.tryCopy(tiSet);
		//deleteTrackedItem(tiSet, true); // AKB added true

		//tiSet.clear();
		voyage.allOnshipTIsByCargoTypeId.tryCopy(tiSet);
		//deleteTrackedItem(tiSet, true); // AKB added true
		
		//tiSet.clear();
		voyage.allNotifiedTIsByCargoTypeId.tryCopy(tiSet);
		//deleteTrackedItem(tiSet, true); // AKB added true
		
		//tiSet.clear();
		voyage.allOffsiteTIsByCargoTypeId.tryCopy(tiSet);
		//deleteTrackedItem(tiSet, true); // AKB added true
		
		//tiSet.clear();
		voyage.allTranshipTIsImport.tryCopy(tiSet);
		//deleteTrackedItem(tiSet, true); // AKB added true
		
		//tiSet.clear();
		voyage.allTranshipTIsExport.tryCopy(tiSet);
		//deleteTrackedItem(tiSet, true); // AKB added true
		
		//tiSet.clear();
		voyage.allTbaTIsByIdCargoType.tryCopy(tiSet);
		//deleteTrackedItem(tiSet, true); // AKB added true
		
		voyage.allRRPTIsByIdCargoType.tryCopy(tiSet);	//16 Mar 2020	NDL	TFS 47004
		
		voyage.allOffloadedTIsByCargoTypeId.tryCopy(tiSet);		// 20/03/2015 cnwmh5
		
		// NAVAB1 - incase TIs are on LCs but same TIs are not in a voyage TI collection
		lcs := voyage.getAllLcs();
		foreach lc in lcs do
		
			//11 Sep 2019	NDL
			beginTransaction;
			lc.allTrackedItems.rebuild;
			lc.allTrackedItemsById.rebuild;
			commitTransaction;
			
			lc.allTrackedItems.tryCopy(tiSet);
			
			// cargo from other voyages can be planned to our voyage
			foreach fm in lc.allPlannedFutureMoves do
				ti := fm.getTrackedItem();
				if ti &lt;&gt; null then
					tiSet.addNoDuplicates(ti, false);
				endif;
			endforeach;
		endforeach;
		
		foreach ti in tiSet discreteLock do
			beginTransaction;
			ti.cleanupQueuedAndPlanned();
			commitTransaction;
		endforeach;
		
		
		//tiSet.clear();
		voyage.allTisByHouseBol.tryCopy(tiSet);
		deleteTrackedItem(tiSet, true); // AKB added true
		
		
		/*
		// 05/01/2015 cnwmh5 replaced by above
		foreach ti in voyage.allOnsiteTIsByCargoTypeId do
			deleteTrackedItem(ti, true); // AKB added true
		endforeach;
		
		foreach ti in voyage.allDeletedTIsByCargoTypeId do
			deleteTrackedItem(ti, true); // AKB added true
		endforeach;

		foreach ti in voyage.allOnshipTIsByCargoTypeId do
			deleteTrackedItem(ti, true); // AKB added true
		endforeach;
		foreach ti in voyage.allNotifiedTIsByCargoTypeId do
			if not ti.isDeleted then
				deleteTrackedItem(ti, true); // AKB added true
			endif;
		endforeach;
		foreach ti in voyage.allOffsiteTIsByCargoTypeId do
			deleteTrackedItem(ti, true); // AKB added true
		endforeach;
		foreach ti in voyage.allTranshipTIsImport do
			deleteTrackedItem(ti, true); // AKB added true
		endforeach;
		foreach ti in voyage.allTranshipTIsExport do
			deleteTrackedItem(ti, true); // AKB added true
		endforeach;
		foreach ti in voyage.allTbaTIsByIdCargoType do
			deleteTrackedItem(ti, true); // AKB added true
		endforeach;
		foreach ti in voyage.allTisByHouseBol do
			deleteTrackedItem(ti, true); // AKB added true
		endforeach;
		*/
		
		
		foreach booking in voyage.allBookingRefs do
			self.deleteBookingObj(booking);
		endforeach;
		if voyage.allInvoices.size &gt; 0 then
			beginTransaction;
				voyage.allInvoices.purge;
			commitTransaction;
		endif;
				
		self.deleteVoyageJobs(voyage);
		self.deleteQueue(voyage.code);
		
	endif;
	
epilog	
	delete lcs;
	delete tiSet;
	delete tisWithWarnings;
	
end;
</source>
        <Parameter name="voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyageCutoff" id="6d7f734e-4c5c-44b0-a702-c2a2972c0084">
