<Class name="CM_YATypeStops" id="2307dea0-4efd-4ad7-98dc-f3a137d30557">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="81e8756b-23cf-4cfc-b5b2-50da7afb36f2">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
begin
	app.myRoot.allAvailableStopsTables.copy(_allCriteriaValues); //cnwrs1 May 2007 Par 13378
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="bf30470e-e41e-4856-b8a8-7602c7ef844e">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2014	cnwndl1	Initial creation	Par 34217

*/

vars
	objs : ObjectSet;
	stop : CM_Stops;
	stopsTable : CM_StopsTable;
begin
	create objs transient;
	foreach stop in _ti.getAllStops discreteLock do
		stopsTable := stop.myStopsTable;
		objs.add(stopsTable);
	endforeach;

	_criteriaValue:= objs;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="ce44a547-6e4f-4cbc-80dd-541f5dbd2b98">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="8b06f950-7a68-432a-b139-87aee4fc1a35">
        <source>getDisplay(dataObj : Object) : String;
// 01 Aug 2008	cnwdw1
// 15 Sep 2025	navdap1	MTN-35615 ENS | Bulk Creation of Yard Allocations
vars
	ti : CM_TrackedItem;
	mess : String;
	stop : CM_Stops;
begin
	if dataObj.isKindOf(CM_StopsTable) then
		return dataObj.CM_StopsTable.shortHeading;
	//28 May 2014	NDL	Par 34217
	elseif dataObj.isKindOf(CM_TrackedItem) then
		ti := dataObj.CM_TrackedItem;
		
		foreach stop in ti.getAllStops discreteLock do
			if mess = "" then
				mess := stop.myStopsTable.shortHeading;					// MTN-35615
			else
				mess := mess &amp; ", " &amp; stop.myStopsTable.shortHeading;	// MTN-35615
			endif;
		endforeach;
		// MTN-35615 Original implementation of this didn't actually return anything,
		// so the CM_TrackedItem implementation was just wrong. Changed to return the 
		// same thing as the CM_StopsTable implementation
		return mess;
	endif;
	
	return "";
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="6a625010-51d6-4da8-a155-185ba77bf42a">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	stops: CM_StopsTable;
begin
	foreach stops in app.myRoot.allAvailableStopsTables do
		objects[stops.getYAIdentifier] := stops;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="c3a14676-c3ff-4255-a183-e61efc363cd6">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "Stops";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="a2713b13-d55c-4880-a92d-f9998a940aee">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return _cmifAutoPlan.isStops_Match(_yaData);

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="d39eeae6-36c6-4449-a611-854d4e52ca0a">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	if _criteria.myYAData.isKindOf(CM_YADataBoolean) then
		//epr TFS 37176 21/2/18
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _propertyValue.Boolean);
	endif;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="c44ae36e-8c45-477a-9de0-ad473558eeef">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/10/2018	jlgdap1		TFS 39133 - Initial creation TSW - to make IMEX transition work with stops
// 30/10/2018	jlgsl4		TFS 39133 - if no stops on item, shouldn't match any stops criteria
//
vars
	stops : CM_StopsByIdDict;
	stop : CM_Stops;

begin
	create stops transient;
	//_ti.getAllActiveStops(stops);
	
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		_tiTrx.myTrackedItem.getAllActiveStops(stops);// current stops not kept on the generic transaction
	else
		_ti.getAllActiveStops(stops);
	endif;

	if stops.size = 0 then // TFS 39133 30/10/18
		return false; // TFS 39133 30/10/18
	endif; // TFS 39133 30/10/18

	foreach stop in stops do
		if not _criteria.myYAData.CM_YADataObjects.matchesStorage(stop.myStopsTable) then
			return false;
		endif;
	endforeach;
	
	// default value
//	if _criteria.myYAData.isKindOf(CM_YADataPattern) and // TFS 39133 30/10/18 - redundant
//	   _criteria.myYAData.CM_YADataPattern.pattern = null then // TFS 39133 30/10/18
//		return true; // TFS 39133 30/10/18
//	endif; // TFS 39133 30/10/18
	
	return true;
epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYATypeStops" id="7d16668e-c546-47c3-b36d-9a087538a767">
