    <JadeMethod name="comboExtractFormatBuild" id="2e38448c-fa2f-4016-9be1-54a613a14db9">
        <source>comboExtractFormatBuild() protected;
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	iter : Iterator;
	str : String;
	row : Integer;

begin
	self.cmbExtractFormat.clear;
	self.cmbExtractFormat.sorted := true;
	row := self.cmbExtractFormat.addItem(global.getExtractFormatDescr(CM_DataDumpExtractDef.FmtXML_Generic));
	self.cmbExtractFormat.itemData[row] := CM_DataDumpExtractDef.FmtXML_Generic;
	row := self.cmbExtractFormat.addItem(global.getExtractFormatDescr(CM_DataDumpExtractDef.FmtExternalDatabase));
	self.cmbExtractFormat.itemData[row] := CM_DataDumpExtractDef.FmtExternalDatabase;
	row := self.cmbExtractFormat.addItem(global.getExtractFormatDescr(CM_DataDumpExtractDef.FmtSQLNative)); //20/04/2010 cnwdz2 24641
	self.cmbExtractFormat.itemData[row] := CM_DataDumpExtractDef.FmtSQLNative;
	self.cmbExtractFormat.listIndex := 1;

	if self.myCurrentObject.CM_DataDumpExtractDef &lt;&gt; null then
		self.cmbExtractFormat.listIndex := self.cmbExtractFormat.findStringExact(1,
				self.myCurrentObject.CM_DataDumpExtractDef.getExtractFormatDescr);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="comboExtractFormatBuildForEdit" id="8a0dad6d-fc7e-464b-b05e-854286d47f58">
        <source>comboExtractFormatBuildForEdit(_extractFormat:Integer) protected;
// ---------------------------------------------------------------------------
// Created:		25/06/2010 cnwdz2 24526
// ---------------------------------------------------------------------------
vars
	iter : Iterator;
	str : String;
	row : Integer;

begin
	self.cmbExtractFormat.clear;
	self.cmbExtractFormat.sorted := true;
	row := self.cmbExtractFormat.addItem(global.getExtractFormatDescr(_extractFormat));
	self.cmbExtractFormat.itemData[row] := _extractFormat;
	self.cmbExtractFormat.listIndex := 1;
end;</source>
        <access>protected</access>
        <Parameter name="_extractFormat" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboExtractFormatSelect" id="5e24343b-d1d4-40d2-942f-174effe0b260">
        <updating/>
        <source>comboExtractFormatSelect() updating, protected;
// ---------------------------------------------------------------------------
// Created:		06 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	viewName : String;

begin
	self.tblExtractDef.setValueByControlName(
			self.cmbExtractFormat.name, self.cmbExtractFormat.itemText);

	if cmbExtractFormat.text = global.getExtractFormatDescr(
			CM_DataDumpExtractDef.FmtExternalDatabase) then
		viewName := self.ViewEDB;
	elseif cmbExtractFormat.text = global.getExtractFormatDescr( //20/04/2010 cnwdz2 24641
			CM_DataDumpExtractDef.FmtSQLNative) then
		viewName := self.ViewSQLNative;
	else
		viewName := self.ViewXML;
	endif;
	
	self.tblExtractDef.showHideRowsByViewName(viewName,
			CM_EntryTable.ShowHideRows, false); //ShowRowsOnly or ShowHideRows or HideRowsOnly
	
	if viewName = self.ViewSQLNative then
		self.shtExtractClass.enabled := false;
		self.shtExtFeature.enabled := false;
		self.tblExtractDef.setValueByName(ETRow_AlertLimit, CM_DataDumpExtractDef.AlertLimit_DefaultValue);
	endif;
	
	self.tblExtractDef.resetSize;
	self.populateExtractClass(); //22/04/2010 cnwdz2 24641
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="comboOIDFormatBuild" id="b9579d08-6c5b-4158-9653-8d84b5fca823">
        <source>comboOIDFormatBuild() protected;
// ---------------------------------------------------------------------------
// Created:		27/04/2010 cnwdz2 24641
// ---------------------------------------------------------------------------
vars
