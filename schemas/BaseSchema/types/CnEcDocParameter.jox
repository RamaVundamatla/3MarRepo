    <JadeMethod name="create" id="9a8bd91e-52cf-4cef-8098-eaf371cb48d4">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/02/2003	cnwdad1		Added the allClasses property which is used to determine
//							whether a class is included in the documentation, and if
//							not, then a hyperlink will NOT be generated to the class
//							where it is shown as being inherited from, or is defined
//							as a property reference.
// --------------------------------------------------------------------------------
begin
	// Set up default parameters.
	
	self.isDoAllWhenNoList	:=	true;
	
	// Set up the dynamic dictionary for the features list.
	
	self.allClasses.setMembership(Class);
// cnwdad1 14/04/2004 - Temporary until PAR #33464 is fixed.
	self.allClasses.addMemberKey(Class::name.name, false, false);//Class::name.name, false, false);
	self.allClasses.endKeys(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="populateClassAndFeatureLists" id="f660009b-4c1c-44cd-9747-0fffc93f7d5e">
        <source>populateClassAndFeatureLists(pDocModelListObj:CnEcDocModelList);
// --------------------------------------------------------------------------------
// Created:		19 February 2003 by cnwdad1
//
// Purpose:		Populates the lists (collections) of classes and features being
//				documented.
//
// Parameters:	pDocModelListObj - A reference to the container of all Documentation
//					Model objects which represet schema entities to document.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	docModelSchemaObj	: CnEcDocModelSchema;
	docModelClassObj	: CnEcDocModelClass;
	
begin
	foreach docModelSchemaObj in pDocModelListObj.allDocSchemas do
		foreach docModelClassObj in docModelSchemaObj.allDocClasses do
			self.allClasses.add(docModelClassObj.myClass);
		endforeach;
	endforeach;
end;</source>
        <Parameter name="pDocModelListObj" type="CnEcDocModelList"/>
    </JadeMethod>
</Class>
