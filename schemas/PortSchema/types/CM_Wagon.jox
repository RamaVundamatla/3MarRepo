    <JadeMethod name="listWagonSeals" id="70f5c6a4-d74e-45ad-bdc9-44ad77992f29">
        <source>listWagonSeals():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	seal : CM_WagonSeal;
	str : String;

begin

	foreach seal in self.allWagonSeals do
	
		if seal.getSealValueAsString().trimBlanks = null then
			continue;
		endif;
	
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; seal.getSimpleDescription;
		
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="maxCargoHeight" id="0cf0f885-56c3-42b1-9832-75067b47bb11">
        <methodInvocation>mapping</methodInvocation>
        <source>maxCargoHeight(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2019	jlgndl1	Initial creation	TFS 4113

*/

vars

	edition : Integer;
	invalidObject : Boolean;

begin

	if not set then
		if self.myWagonClass &lt;&gt; null then
			on Exception do app.handleDeletedObject( exception, self.myWagonClass, invalidObject);
			edition := self.myWagonClass.edition;
			if not invalidObject then
				_value := self.myWagonClass.maxCargoHeight;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="maxCargoWeight" id="73d0972a-6219-4442-8a26-ff5387a0de9c">
        <methodInvocation>mapping</methodInvocation>
        <source>maxCargoWeight(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2019	jlgndl1	Initial creation	TFS 4113
22 July	 2022	jlika1	TFS 54050 - EUP- Max Wagon Payload
*/

vars

	edition 			: Integer;
	invalidObject 		: Boolean;
	allowWagonWeights 	: Boolean;	
begin

	if not set then
		
		if self.getMyTerminal &lt;&gt; null then
			allowWagonWeights := self.getMyTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;
		endif;
		
		if (allowWagonWeights) then						
			if self.maxCargoWeight &lt;&gt; null then
				_value := self.maxCargoWeight;				
				return;
			endif;
		endif;
		
		if self.myWagonClass &lt;&gt; null then
			_value := self.myWagonClass.maxLoadWeight;
		endif;		
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myDestinationPort" id="e4f59785-5450-4a43-8c9d-976182a98f91">
        <methodInvocation>mapping</methodInvocation>
        <source>myDestinationPort(set : Boolean; _value : CM_Port io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2010	#cnwdz2	 25317
CM_Wagon::myDestinationPort has never been used since creation. This mapping method
is to return an appropriate value if the wagon has been color coded.
*/

vars
	iter : Iterator;
	locController : CM_WagonController;
	railAlloc     : CM_RailAllocation;
	port : CM_Port;
begin
	if not set then
		//iter := self.allLocationsControllers.createIterator();
		iter := self.allLocationsControllersArray.createIterator();	//04 Dec 2014	NDL	Par 35345
		while iter.next(locController) do
			railAlloc := locController.myRailAllocation;
			if railAlloc &lt;&gt; null then
				port := railAlloc.getDestinationPort();
			endif;
		endwhile;
		
		if port = null then
			if self.myTrainOutwards &lt;&gt; null then
				port := self.myTrainOutwards.myDestinationPort;
			endif;
		endif;
		
		_value := port;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Port" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myOriginPort" id="b4cbf98b-e1b3-411f-9639-28b2a48c4c33">
        <methodInvocation>mapping</methodInvocation>
        <source>myOriginPort(set : Boolean; _value : CM_Port io) mapping;
/*
Purpose:			

Date		Who		Reason
06 January 2022	navab1	TFS 51855
*/

vars
	iter : Iterator;
	locController : CM_WagonController;
	railAlloc     : CM_RailAllocation;
	port : CM_Port;
begin
	if not set then

		iter := self.allLocationsControllersArray.createIterator();
		while iter.next(locController) do
			railAlloc := locController.myRailAllocation;
			if railAlloc &lt;&gt; null then
				port := railAlloc.getOriginPort();
			endif;
		endwhile;
		
		if port = null then
			if self.myTrainInwards &lt;&gt; null then
				port := self.myTrainInwards.myOriginPort;
			endif;
		endif;
		
		_value := port;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Port" usage="io"/>
    </JadeMethod>
