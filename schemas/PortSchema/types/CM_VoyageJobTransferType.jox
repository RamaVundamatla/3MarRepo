    <JadeMethod name="validateDelete" id="f298d5c6-419c-4db6-a4f3-a620f913dfe4">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	term : CM_Terminal;
	wp : CM_WorkPoint;
	wpCargoRate : CM_WorkPointCargoRates;

begin
	
	if self.isSystem then
		app.raiseCMException(System_defined_type, null, null);
		return;
	endif;
	
	foreach term in app.myRoot.allTerminals discreteLock do
		foreach wp in term.allWorkPointsByCode discreteLock do
			foreach wpCargoRate in wp.allWorkPointRates discreteLock do
				if wpCargoRate.transferType = self.id then
					app.raiseCMException3( InUseInTerminal, self.description, wp.code, term.code, null, null );
					return;
				endif;
			endforeach;
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="d1a50e24-1200-4af0-bcf3-82828be7199e">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37444
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable

*/

vars

	realForDupCheck : CM_VoyageJobTransferType;
	realSameKeys : CM_VoyageJobTransferType;
	
begin

	if not self.isSystem and self.id &lt; 10000 then
		app.raiseCMException2( Invali_value_must_greate_than, ETRow_Id, "10000", null, null );
		return;
	endif;
	
	if self.description.pos(Comma, 1) &lt;&gt; 0 then
		app.raiseCMException1(Must_not_contain_comma, "Voyage Job Transfer Type", null, null);		// 29/3/18 MAP TFS37555
	endif;
	
	//03 Oct 2018	NDL	TFS 41187 - description is used for teh YA Identifier, can't be blank.
	if self.description.trimBlanks = null then
		app.raiseCMException(Input_required_field_Desc, null, null);
		return;
	endif;
	
	if self.isTransient then
		realForDupCheck := self.pxyGetRealObject;
	else
		realForDupCheck := self;
	endif;
	
	realSameKeys := app.myRoot.allVoyageJobTransferTypes.getAtKey( self.id );
	if realSameKeys &lt;&gt; null and realSameKeys &lt;&gt; realForDupCheck then
		//app.raiseCMException2(DuplicateItem, self.id.String, "Voyage Job Transfer Type", null, null ); //14.06.2022 navds20 53760
		//%1 already exists for Voyage Job Transfer Type : Alread_exists_voyage_transf_ty
		app.raiseCMException1(Alread_exists_voyage_transf_ty, self.id.String, null, null ); //14.06.2022 navds20 53760
		return;
	endif;
	
	//03 Oct 2018	NDL	TFS 41187 - description is used for teh YA Identifier, must be unique.
	realSameKeys := null;
	foreach realSameKeys in app.myRoot.allVoyageJobTransferTypes do
		if realSameKeys = realForDupCheck then
			continue;
		endif;
		if self.getYAIdentifier = realSameKeys.getYAIdentifier then
			app.raiseCMException1(Value_Already_been_used, self.description, null, null);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
