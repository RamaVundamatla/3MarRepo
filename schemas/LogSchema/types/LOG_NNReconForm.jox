    <JadeMethod name="doCmbVoyageClick" id="22a17676-7e73-47a3-b906-ace49651d7c6">
        <updating/>
        <source>doCmbVoyageClick() updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	saveOrigVoy	: CM_Voyage;
begin
	
	saveOrigVoy := self.myFiltLogVoyage;
	self.myFiltLogVoyage := cmbVoyage.listObject.CM_Voyage;
	if self.myFiltLogVoyage &lt;&gt; null then
		self.setNavigatorHeading(self.myFiltLogVoyage.code);
	endif;
	self.myFiltOperator := null;
	self.myFiltLogLot := null;
	self.loadCmbLots();
	self.loadCmbOperators();
	self.doSearch();
	
	if saveOrigVoy &lt;&gt; self.myFiltLogVoyage then
		self.isShowError := true;
	endif;
end;</source>
    </JadeMethod>
