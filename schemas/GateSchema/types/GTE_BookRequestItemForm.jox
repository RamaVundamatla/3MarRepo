    <JadeMethod name="displaySoftAttributeOnSysProd" id="9be28e79-86a4-4f1a-ba8d-364efac54a6f">
        <updating/>
        <source>displaySoftAttributeOnSysProd(_cargoType : CM_CargoType; _product : CM_Product; _numbControls : Integer): Integer updating;
//15 September 2009	cnwml2
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 15/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 13/11/13 	cnwer1		PAR 32951 
// 24/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - don't show weight / volume / density cargo subtype attributes
constants
	MoveControl = 25;
vars
	tmpAttr : CM_ProductAttr;
	numbControls : Integer;
	newItem : Boolean;
	code : CM_ProductAttributeCode;
	measure : CM_MeasurementType;					// PAR #31155
begin
	self.hideCDGeneralGroupBox();
	self.lblCDTitle.visible := true;
	self.grpCDGeneral.visible := true;
	numbControls := _numbControls;
	newItem := self.isNewItem;
	
	if _product = null or _cargoType = null then
		self.grpCDGeneral.visible := false;  //no product is available, hide Sub-Cargo details groupbox
		return numbControls;
	endif;
	
	// PAR #33606 weight here is meaningless - it's just documentation of the cargo subtype, 
	// not a weight that should be able to be set separately from the total weight for a booking
	if _product.isAttributeValidForCargoType(ETRow_MyWeight) then
		measure := _product.getMyWeight.myMeasurementType;								// PAR #31155
		self.lblCDWeight.caption := _product.getMyWeight.displayName &amp; ":";
		self.lblCDWeight.visible := true;
		self.tblCDWeight.visible := true;												// PAR #31155
		
		numbControls := numbControls + 1;
		lblCDWeight.top := MoveControl;
		tblCDWeight.top := MoveControl;													// PAR #31155
		if newItem then
			if measure &lt;&gt; null then														// PAR #31155
				self.tblCDWeight.setValues(app.convertMeasurementForDisplay(measure.shortName, _product.getMyWeight.getRawValue) &amp; Space &amp; measure.shortName);	// PAR #31155
			endif;																		// PAR #31155
		endif;
	endif;
	
	if _product.isAttributeValidForCargoType(ETRow_MyLength) then
		measure := _product.getMyLength.myMeasurementType;								// PAR #31155
		self.lblCDLength.caption := _product.getMyLength.displayName &amp; ":";
		self.lblCDLength.visible := true;
		self.tblCDLength.visible := true;												// PAR #31155
		
		numbControls := numbControls + 1;
		lblCDLength.top := MoveControl * numbControls;
		tblCDLength.top := MoveControl * numbControls;									// PAR #31155
		
		if newItem then
			if measure &lt;&gt; null then														// PAR #31155
				self.tblCDLength.setValues(app.convertMeasurementForDisplay(measure.shortName, _product.getMyLength.getRawValue) &amp; Space &amp; measure.shortName);	// PAR #31155
			endif;																		// PAR #31155
		endif;
	endif;
	
	if _product.isAttributeValidForCargoType(ETRow_MyWidth) then
		measure := _product.getMyWidth.myMeasurementType;								// PAR #31155
		self.lblCDWidth.caption := _product.getMyWidth.displayName &amp; ":";
		self.lblCDWidth.visible := true;
		self.tblCDWidth.visible := true;												// PAR #31155
		
		numbControls := numbControls + 1;
		lblCDWidth.top := MoveControl * numbControls;
		tblCDWidth.top := MoveControl * numbControls;									// PAR #31155

		if newItem then
			if measure &lt;&gt; null then														// PAR #31155
				self.tblCDWidth.setValues(app.convertMeasurementForDisplay(measure.shortName, _product.getMyWidth.getRawValue) &amp; Space &amp; measure.shortName);	// PAR #31155
			endif;																		// PAR #31155
		endif;
	endif;
	
	if _product.isAttributeValidForCargoType(ETRow_MyHeight)  then
		measure := _product.getMyHeight.myMeasurementType;								// PAR #31155
		self.lblCDHeight.caption := _product.getMyHeight.displayName &amp; ":";
		self.lblCDHeight.visible := true;
		self.tblCDHeight.visible := true;												// PAR #31155
		
		numbControls := numbControls + 1;
		lblCDHeight.top := MoveControl * numbControls;
		tblCDHeight.top := MoveControl * numbControls;									// PAR #31155

		if newItem then
			if measure &lt;&gt; null then														// PAR #31155
				self.tblCDHeight.setValues(app.convertMeasurementForDisplay(measure.shortName, _product.getMyHeight.getRawValue) &amp; Space &amp; measure.shortName);	// PAR #31155
			endif;																		// PAR #31155
		endif;
	endif;
	
	if _product.isAttributeValidForCargoType(ETRow_MyWidthString) then
		
		self.lblCDWidthText.caption := _product.myWidthString.displayName &amp; ":";
		self.lblCDWidthText.visible := true;
		self.txtCDWidthText.visible := true;
		
		numbControls := numbControls + 1;
		lblCDWidthText.top := MoveControl * numbControls;
		txtCDWidthText.top := MoveControl * numbControls;

		if newItem then
			txtCDWidthText.text := _product.myWidthString.value;
		endif;
	endif;
	
	if _product.isAttributeValidForCargoType(ETRow_MyHeightString)  then
		self.lblCDHeightText.caption := _product.myHeightString.displayName &amp; ":";
		self.lblCDHeightText.visible := true;
		self.txtCDHeightText.visible := true;
		
		numbControls := numbControls + 1;
		lblCDHeightText.top := MoveControl * numbControls;
		txtCDHeightText.top := MoveControl * numbControls;

		if newItem then
			txtCDHeightText.text := _product.myHeightString.value;
		endif;
	endif;
	
	if _product.isAttributeValidForCargoType(ETRow_MyLengthString)   then
		self.lblCDLengthText.caption := _product.myLengthString.displayName &amp; ":";
		self.lblCDLengthText.visible := true;
		self.txtCDLengthText.visible := true;
		
		numbControls := numbControls + 1;
		lblCDLengthText.top := MoveControl * numbControls;
		txtCDLengthText.top := MoveControl * numbControls;
		
		if newItem then
			txtCDLengthText.text := _product.myLengthString.value;
		endif;
	endif;

	if _product.isAttributeValidForCargoType(ETRow_MyQuantity) then
		self.lblCDQuantity.caption := _product.myQuantity.displayName &amp; ":";
		self.lblCDQuantity.visible := true;
		self.txtCDQuantity.visible := true;
		
		numbControls := numbControls + 1;
		lblCDQuantity.top := MoveControl * numbControls;
		txtCDQuantity.top := MoveControl * numbControls;

		if newItem then
			txtCDQuantity.text := _product.myQuantity.getDefaultValueString(null);
		endif;
	endif;
	
	// PAR #33606 volume here is meaningless - it's just documentation of the cargo subtype, 
	// not a volume that should be able to be set separately from the total volume for a booking
	if _product.isAttributeValidForCargoType(ETRow_MyVolume) then
		measure := _product.myVolume.myMeasurementType;									// PAR #31155
		self.lblCDVolume.caption := _product.myVolume.displayName &amp; ":";
		self.lblCDVolume.visible := true;
		self.tblCDVolume.visible := true;												// PAR #31155
		
		numbControls := numbControls + 1;
		lblCDVolume.top := MoveControl * numbControls;
		tblCDVolume.top := MoveControl * numbControls;									// PAR #31155

		if newItem then
			if measure &lt;&gt; null then														// PAR #31155
				self.tblCDVolume.setValues(app.convertMeasurementForDisplay(measure.shortName, _product.myVolume.getRawValue) &amp; Space &amp; measure.shortName);	// PAR #31155
			endif;																		// PAR #31155
		endif;
	endif;
	
	// PAR #33606 density here is meaningless - it's just documentation of the cargo subtype, 
	// not a density that should be able to be set separately 
	if _product.isAttributeValidForCargoType(ETRow_MyDensity) then
		measure := _product.myDensityDec.myMeasurementType;								// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
		self.lblCDDensity.caption := _product.myDensityDec.displayName &amp; ":";			// ### TFS 52193 22Nov2021 NAVPW1
		self.lblCDDensity.visible := true;
		self.tblCDDensity.visible := true;												// PAR #31155
		
		numbControls := numbControls + 1;
		lblCDDensity.top := MoveControl * numbControls;
		tblCDDensity.top := MoveControl * numbControls;									// PAR #31155
	
		if newItem then
			//txtCDDensity.text := _product.myDensity.getDefaultValueString(null);		// PAR #31155
			if measure &lt;&gt; null then														// PAR #31155
				self.tblCDDensity.setValues(app.convertMeasurementForDisplay(measure.shortName, _product.myDensityDec.getRawValue) &amp; Space &amp; measure.shortName); // ### TFS 52193 22Nov2021 NAVPW1	// PAR #31155
			endif;																		// PAR #31155
		endif;
	endif;
	
	if  _product.isAttributeValidForCargoType(ETRow_MyType) then
		self.lblCDType.caption := _product.myType.displayName &amp; ":";
		self.lblCDType.visible := true;
	
		tmpAttr := _product.getProdAttrFromName(ETRow_MyType);
		if tmpAttr.validationType = CM_ProductAttr.ValidationType_Codes then	// 12/03/2010 cnwcs5 par 22775 - use constant instead of literal
			self.cmbCDType.visible := true;
			cmbCDType.clear;
			foreach code in _product.myType.allCodes do
				cmbCDType.addItem(code.code &amp; Tab &amp; code.description);
			endforeach;
	
			if newItem then
				self.cmbCDType.text := _product.myType.value.asStringJMT();
			endif;
		else
			self.txtCDType.visible := true;
			if newItem then
				self.txtCDType.text := _product.myType.value.asStringJMT();
			endif;
		endif;
		
		numbControls := numbControls + 1;
		if numbControls = 1 then
			lblCDType.top := MoveControl;
			cmbCDType.top := MoveControl;
			txtCDType.top := MoveControl;
		else
			lblCDType.top := MoveControl * numbControls;
			cmbCDType.top := MoveControl * numbControls;
			txtCDType.top := MoveControl * numbControls;				
		endif;
	endif;
	
	// PAR #33606 if numbControls hasn't changed, we haven't added any cargo subtype attributes			// PAR #33606
	// - make the whole group invisible																	// PAR #33606
	if numbControls = _numbControls then																// PAR #33606
		self.grpCDGeneral.visible := false;  //no product is available, hide Sub-Cargo details groupbox	// PAR #33606
		return numbControls;																			// PAR #33606
	endif;																								// PAR #33606
	
	numbControls := numbControls + 1;
	
	return numbControls;
	
epilog
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_numbControls" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLstColourGotFocus" id="85ed8bc1-d9fd-484a-97e8-bcc282ea54a6">
        <source>doLstColourGotFocus();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars

begin
	self.lstColour.top 		:= self.txtColour.top + 1 + grpDetail.top;
	self.lstColour.left 	:= self.txtColour.left - 10 + grpDetail.left;
	
	self.lstColour.height 	:= 80;
	self.lstColour.width 	:= self.txtColour.width;
	
	//list setup
	self.lstColour.visible 	:= true;
	self.lstColour.zOrder(1);
	self.lstColour.setFocus();
	self.txtColour.visible 	:= false;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="c3fb3869-6f22-4cd6-aaca-fc502de70342">
        <updating/>
        <source>doSave(_modalResult : Integer) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12/11/2008	cnwer1	Initial creation
08/06/2009	cnwjo3  now take an 'modalResult' to handle IDOK, IDCANCEL and IDNEXT (par 19840)
16/09/2014	cnwdap1	PAR #33944 Correct validation / handling of proxy objects here
22/05/2024	navra1	//navra1 - CR 63764/Task 64227 - 22nd May 2024
*/
vars
	result : Integer;
	bookingItem 		: CM_BRefItemContainer;
	bookingRef		: CM_BookingRef;
begin
	if self.hasErrors(true) then
		return false;  //error so don't continue
	endif;
	
	bookingRef:=self.myProxyBookingRefItem.myBookingReference;
	create bookingItem transient;
	self.saveProxyBookingRefItem(bookingItem);	
	bookingItem.setMyBookingRef(bookingRef);
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();	
	
	bookingItem.validateForCreate(app.myPassport,self.myTerminal);		// PAR #33944	
	
	self.myProxyBookingRefItem.setMyBookingRef(bookingRef);
	
	//navra1 - CR 63764/Task 64227 - 22nd May 2024 - start
	if bookingItem.matchMode = CM_BookingRefItem.STRICT_MATCH and not self.warnedForUser then				
		if app.msgBox(app.getErrorString(Strict_match_warn), "Confirmation", MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_OK then
			return false;
		endif;
	endif;
	//navra1 - CR 63764/Task 64227 - 22nd May 2024 - end
	
	// PAR #33944
	if app.myPassport.hasErrorsOrWarnings then
//		result:=app.showErrorWarningDialog('Equipment Item', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);	// cnwrl1 08/06/2009 PAR 19826 - what it was
		result	:= app.showErrorWarningDialog(	app.getErrorString( Booking_Item ),
												app.myPassport,
												ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
		if  app.myPassport.hasErrors  or result &lt;&gt; IDOK  then
			return false;
		endif;
	endif;
	
	// PAR #33944 now put the data (which is correct) back on the proxy 				// PAR #33944
	
	self.saveProxyBookingRefItem(self.myProxyBookingRefItem);							// PAR #33944
	
	if self.isBaseFormModal then
		self.modalResult:=_modalResult;
	endif;

	self.unloadForm;
epilog
	delete bookingItem;
end;</source>
        <Parameter name="_modalResult" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowHSCodeSearchForm" id="771a7d77-5151-495e-aa62-de78ead64443">
        <source>doShowHSCodeSearchForm() : CM_HarmonizedSystem;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 December 2022
TFS#		: 55890
