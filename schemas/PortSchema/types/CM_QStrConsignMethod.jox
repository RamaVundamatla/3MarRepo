    <JadeMethod name="create" id="b91db2e3-61d5-4bde-832b-9e2b46e95ca9">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/07/2023	navkc1	Change Request 58219 Task 58220: Jade - COO attributes on TI

*/

vars
	consign 		: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create consign as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(consign);

	
end;
</source>
    </JadeMethod>
