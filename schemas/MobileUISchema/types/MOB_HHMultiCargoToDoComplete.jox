    <JadeMethod name="resetColumnHeadings" id="8d7bf082-6ddd-40b8-b79d-e27df16eab72">
        <source>resetColumnHeadings() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2015	cnwndl1	Initial creation	Par 36993

*/

vars

	count : Integer;

begin

	count := self.tblAvailable.rows - 1;
	if count &lt; 1 then
		self.tblAvailable.setCellText(1,1, app.getErrorString(Available) );
	else
		self.tblAvailable.setCellText(1,1, count.String &amp; " " &amp; app.getErrorString(Available) );
	endif;
	
	count := self.tblSelected.rows - 1;
	if count &lt; 1 then
		self.tblSelected.setCellText(1,1, app.getErrorString(Selected) );
	else
		self.tblSelected.setCellText(1,1, count.String &amp; " " &amp; app.getErrorString(Selected) );
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetPopulateTables" id="52d549a4-ba3b-411c-9fa4-3ced83b37005">
        <source>resetPopulateTables();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2015	cnwndl1	Initial creation	Par 36993

*/

vars

	taskDesc : CM_ToDoTaskDesc;
	iter : Iterator;
	tiToDoTask : CM_TiToDoTask;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;

begin

	taskDesc := self.cmbTasks.listObject.CM_ToDoTaskDesc;
	
	self.tblAvailable.rows := 1;
	self.tblSelected.rows := 1;
		
	if taskDesc = null then
		self.btnAdd.enabled := false;
		return;
	else
		self.btnAdd.enabled := true;
		terminal := self.myTerminal;
		iter := taskDesc.allTiToDoTasksToComplete.createIterator;
		while iter.next( tiToDoTask ) do
			if tiToDoTask.myTerminal &lt;&gt; terminal then
				continue;
			endif;
			ti := tiToDoTask.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if not ti.isOnSite then
				continue;
			endif;
			self.unSelectTiToDoTask( tiToDoTask, false );
		endwhile;
	endif;

epilog

	self.resetColumnHeadings();
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="selectTiToDoTask" id="3f7f8816-942b-4c4e-a1d3-408ade06abdb">
        <source>selectTiToDoTask( _tiToDoTask : CM_TiToDoTask ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2015	cnwndl1	Initial creation	Par 36993

*/

vars

	rowIndex : Integer;
	invalid : Boolean;
	str : String;

begin


	self.tblAvailable.findObjectInRow( _tiToDoTask, rowIndex );
	if rowIndex &gt; self.tblAvailable.fixedRows then
		self.tblAvailable.removeItem( rowIndex );
	endif;
	rowIndex := 0;
	
	if _tiToDoTask = null or _tiToDoTask.myTrackedItem = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _tiToDoTask.myTrackedItem, invalid );
	str := _tiToDoTask.myTrackedItem.id;
	if invalid then
		return false;
	endif;

	self.tblSelected.findObjectInRow( _tiToDoTask, rowIndex );
	if rowIndex &lt; self.tblSelected.fixedRows then
		rowIndex := self.tblSelected.addItem( str );
		self.tblSelected.accessRow( rowIndex ).itemObject := _tiToDoTask;
		return true;
	endif;
	
	return false;

epilog

	self.resetColumnHeadings();

end;</source>
        <Parameter name="_tiToDoTask" type="CM_TiToDoTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
