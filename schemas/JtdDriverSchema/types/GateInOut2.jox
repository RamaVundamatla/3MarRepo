    <JadeMethod name="startup2" id="8efa5d5a-c52d-4bf6-8df5-aeb2b63ebf2e">
        <updating/>
        <source>startup2() updating;

vars
	i:Integer;
begin
	myGH.bookingRefListFile.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	startupSkipFile(myGH.bookingRefListFile);
	myGH.rfidTagListFile.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	startupSkipFile(myGH.rfidTagListFile);
	startupSkipIter(myGH.carrierIterator);
	myRFIDTag:=myGH.selectRandomRFIDTag;
	foreach i in 1 to app.profileSequenceId do  // first user does none, last user does most
		zClearRoadJob(CM_RoadJob.firstInstance);
	endforeach;
	zAllocateRTGCrane;
	zAllocateRFIDTagAndReaders;
	
	myGateInOutForm:=loadForm(PmGteInOutEntry, false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="stop" id="be657e26-5a7a-43d0-9ae7-ea6c47928994">
        <updating/>
        <source>stop() updating;

begin
	inheritMethod;
end;
</source>
    </JadeMethod>
    <JadeMethod name="stop2" id="9e503e99-0d0d-492f-8120-130b63ddbd19">
        <updating/>
        <source>stop2() updating;

vars
	o:Object;
begin
	app.logMessage(method.qualifiedName);
	if myGateInOutForm &lt;&gt; null then
		myGateInOutForm.unloadForm;
		myGateInOutForm := null;
	endif;
	
	foreach o in allTrackedItems do
		app.logMessage(method.qualifiedName&amp;" checking tracked item "&amp;o.getName);
		zClearRoadJob(o.CM_Container.jobRoadReceive);
		zClearRoadJob(o.CM_Container.jobRoadRelease);
	endforeach;
	zClearRoadJob(myRFIDTag.myRoadJob);
	app.logMessage(method.qualifiedName&amp;" "&amp;CM_RoadJob.instances.display.replace(CrLf,", "));
end;
</source>
    </JadeMethod>
