    <JadeMethod name="btnOpenFile_click" id="2a246e3d-e1c9-46a1-8bb3-aff20fddc49f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOpenFile_click(btn: Button input) updating;

vars
	file		: File;
	fileOpen	: CMDFileOpen;
	fileName	: String;

begin
	fraOutput.visible		:= false;
	btnClose.enabled		:= true;
	folder.enabled			:= true;
	btnExtractForm.visible	:= true;
	btnUpdateForm.visible	:= true;
	btnGetForms.visible		:= true;
	btnUpdateForm.setFocus();

	if optListOnly.value then
		fileName := "forms.txt";
	elseif optStatsOnly.value then
		fileName := "stats.txt";
	elseif optAllDetails.value then
		fileName := "helpsrce.txt";
	else
		fileName := "*.txt";
	endif;

	create fileOpen;
	fileOpen.fileName	:= fileName;
	fileOpen.initDir	:= "c:\temp";
	fileOpen.defaultExt	:= "*.txt";

	if fileOpen.open = 0 then
		create file;		
		file.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
		file.fileName := fileOpen.fileName;
		file.open;

		self.outputForms(file);

		file.close();
		delete file;
	endif;

	delete fileOpen;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnPassword_click" id="c2d3f651-b3e5-40a1-89c4-1b9903455479">
