    <JadeMethod name="createCharge" id="0e79ba73-5933-4b03-aa40-e5e32036f486">
        <updating/>
        <source>createCharge(_invoiceLine : CM_InvoiceLine) : CM_Charge updating;

vars
	charge : CM_Charge;
	seqNum : Integer;
begin

	// PAR 30751 seqNum := self.bank.getSeqNumCharge();// PAR 18104
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_CHARGE); // PAR 30751

	//assume that the noCharge flag for the transaction is false
	create charge persistent;
	charge.setForCreate(self.bank,
				_invoiceLine, 
				seqNum,
				self);
	
	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(charge);		// 9/5/18 MAP TFS37718
	
	return charge; // ### TFS CR 55624 TASK 55700 07FEB2023 NAVAB1
end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <ReturnType type="CM_Charge"/>
    </JadeMethod>
    <JadeMethod name="createTransientCharge" id="4f95a043-3b77-498e-bab4-d35570cc3129">
        <updating/>
        <source>createTransientCharge(_invoiceLine : CM_InvoiceLine; _seq : Integer) updating;

vars
	charge : CM_Charge;
	seqNum : Integer;
begin

	seqNum := _seq;
	//assume that the noCharge flag for the transaction is false
	create charge transient;
	charge.setForCreate(null,
				_invoiceLine, 
				seqNum,
				self);
				
	
end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_seq" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="erase" id="6ccbb4d1-dd72-4350-98d0-2be6ed16944e">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Purpose:			
Date		Who		Reason
28 May 2013	cnwab1	Initial creation
*/

vars
	iter : Iterator;
	cmqfIC : CMQF_InvoiceContract;

begin
	iter := CMQF_InvoiceContract.instances.createIterator;
	while iter.next(cmqfIC) do
		if cmqfIC.allRateServices.includes(self) then
			cmqfIC.allRateServices.remove(self);
		endif;
	endwhile;
	
	if _eraseLevel = FORCED_ERASE then
		inheritMethod(_eraseLevel);
	endif;


epilog
	delete iter;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="e06b965f-325b-4b89-b7f8-d567df717778">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;

vars

begin
	if _property = CM_Service::brokers then
		return true;
	elseif _property = CM_Service::charges then
		return true;
	elseif _property = CM_Service::debtorNodeRates then
		return true;
	elseif _property = CM_Service::invoiceLineDescriptions then
		return true;
	elseif _property = CM_Service::lineGroupDebtorRates then
		return true;
	endif;
	
	return inheritMethod(_property);
end;
</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="05b2a84d-7558-4dfb-952f-ecee0a5a55a7">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;

vars

begin
	if _property = CM_Service::myCalculationType then
		return ExportAsParent;
	elseif _property = CM_Service::myTaxCode then
		return ExportAsParent;
	endif;
	
	return inheritMethod(_property);
end;
</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllServiceTypesCSV" id="ee811221-6fc9-48af-be3f-11215b63347c">
        <source>getAllServiceTypesCSV() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2022	navkc1	Initial creation - ChangeRequest 54568: EUP - Inv Config - Reports and Extracts

*/

vars
	obj		: CM_ServiceType;
	value	: String;
	
begin
	
	foreach obj in self.allServiceTypes discreteLock do
		if value = "" then
			value := obj.code;
		else
			value := value &amp; "," &amp; obj.code;
		endif;
	endforeach;
	
	return value;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="5a3eb942-cdf8-48c4-8c11-0f075b37c7e5">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
26/03/2018	jlgdap1	TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
*/

vars
	txt,
	tmpStr	: String;
	serviceType	: CM_ServiceType;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	if self.defaultRateTable = CM_Service.DEFAULT_RATE_TABLE then
		tmpStr := app.getErrorString(Default_rate);
	elseif self.defaultRateTable = CM_Service.TRADE_RATE_TABLE then			// TFS 37794
		tmpStr :=app.getErrorString(Shipping_line_rate);
	elseif self.defaultRateTable = CM_Service.VESSEL_RATE_TABLE then		// TFS 37794
		tmpStr := app.getErrorString(Vessel_rate);							// TFS 37794
	elseif self.defaultRateTable = CM_Service.BERTH_RATE_TABLE then   //07.06.2018 cnwma1 ChangeRequest #38953
		tmpStr := app.getErrorString(Berth_rate);	
	elseif self.defaultRateTable = CM_Service.VESSELTYPE_RATE_TABLE then   //07.06.2018 cnwma1 ChangeRequest #38953
		tmpStr := app.getErrorString(VesselType_rate);	
	elseif self.defaultRateTable = CM_Service.VISITTYPE_RATE_TABLE then   //07.06.2018 cnwma1 ChangeRequest #38953
		tmpStr := app.getErrorString(VisitType_rate);	
	endif;

	txt := txt &amp; 'Rate Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.myCalculationType &lt;&gt; null then
		tmpStr := self.myCalculationType.description;
		txt := txt &amp;'Calculation Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	tmpStr := null;
	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	// 23/08/22	navkc1	#54569 --&gt;
	tmpStr := null;
	if self.allServiceTypes.isNotEmpty() then
		foreach serviceType in self.allServiceTypes do 
			tmpStr := serviceType.code &amp; Cr &amp; tmpStr;
		endforeach;
		txt := txt &amp; "Service Type" &amp; AuditStringSeparator &amp; tmpStr.length().String &amp; AuditStringSeparator &amp; tmpStr;
	endif;
	// 23/08/22	navkc1	#54569 &lt;--
	
	
	return txt;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getChargesForDebtor" id="7e74071f-14a7-4660-b01b-aebba3cf0f7c">
        <executionLocation>server</executionLocation>
        <source>getChargesForDebtor( _debtor : CM_DebtorNode; _chargesForDebtors : CM_ChargeByInvStatusSeqNumDict input )serverExecution;
/*

Purpose:			Used for Rate Entry changes to only update the charges were actually interested in

Parameters:			

Return Value:		

Date			Who		Reason
05 July 2018	jlgmd1	Initial creation TFS 38937 - STWO Performance changes
10 Dec 2025 	navhl20 Bug MTN-35943: POL - Importing Rates from CSV takes too long
*/

vars
	chargeByDebtors : CM_ChargeByDebtInvStsSeqNumDic;
	charge			: CM_Charge;
	debtors			: CM_DebtorNodeByNameDict;
	debtorNode,
	debtor			: CM_DebtorNode;
	iter 			: Iterator;
	status			: Integer;
begin		
	// If this is the '&lt;default&gt;' debtor listed in the Rate Table, then check everything
	if _debtor = null or _debtor.isRootDebtorGroup then
		self.charges.copy(_chargesForDebtors);
		return;
	endif;
	
	create chargeByDebtors transient;
	create debtors transient;
	self.charges.copy(chargeByDebtors);	// Order by debtors
	_debtor.getDebtors(debtors);	// grab all debtors at or below are given debtor node

	foreach debtorNode in debtors do										//10.12.2025 navhl20 #35943
		iter := chargeByDebtors.createIterator;
		
		// open invoices
		chargeByDebtors.startKeyGeq(debtorNode.CM_Debtor, CM_Invoice.INVOICE_OPEN,0,iter);
		while iter.next(charge) do
			status := iter.getCurrentKey(2).Integer;
			debtor := iter.getCurrentKey(1).CM_Debtor;
			if status &gt; CM_Invoice.INVOICE_OPEN or status &gt; CM_Invoice.INVOICE_OPEN or debtor &lt;&gt; debtorNode then
				break;
			endif;
			_chargesForDebtors.add(charge);
		endwhile;
		
		// pending invoices
		chargeByDebtors.startKeyGeq(debtorNode.CM_Debtor, CM_Invoice.INVOICE_PENDING,0,iter);
		while iter.next(charge) do
			status := iter.getCurrentKey(2).Integer;
			debtor := iter.getCurrentKey(1).CM_Debtor;
			if status &gt; CM_Invoice.INVOICE_PENDING or status &gt; CM_Invoice.INVOICE_PENDING or debtor &lt;&gt; debtorNode then
				break;
			endif;
			_chargesForDebtors.add(charge);
		endwhile;
		
		// suspense invoices
		chargeByDebtors.startKeyGeq(debtorNode.CM_Debtor, CM_Invoice.INVOICE_SUSPENSE,0,iter);
		while iter.next(charge) do
			status := iter.getCurrentKey(2).Integer;
			debtor := iter.getCurrentKey(1).CM_Debtor;
			if status &gt; CM_Invoice.INVOICE_SUSPENSE or status &gt; CM_Invoice.INVOICE_SUSPENSE or debtor &lt;&gt; debtorNode then
				break;
			endif;
			_chargesForDebtors.add(charge);
		endwhile;
		
		// pre-prending invoices
		chargeByDebtors.startKeyGeq(debtorNode.CM_Debtor, CM_Invoice.INVOICE_PREPEND,0,iter);
		while iter.next(charge) do
			status := iter.getCurrentKey(2).Integer;
			debtor := iter.getCurrentKey(1).CM_Debtor;
			if status &gt; CM_Invoice.INVOICE_PREPEND or status &gt; CM_Invoice.INVOICE_PREPEND or debtor &lt;&gt; debtorNode then
				break;
			endif;
			_chargesForDebtors.add(charge);
		endwhile;
		
		// disputed invoices
		chargeByDebtors.startKeyGeq(debtorNode.CM_Debtor, CM_Invoice.INVOICE_DISPUTED,0,iter);
		while iter.next(charge) do
			status := iter.getCurrentKey(2).Integer;
			debtor := iter.getCurrentKey(1).CM_Debtor;
			if status &gt; CM_Invoice.INVOICE_DISPUTED or status &gt; CM_Invoice.INVOICE_DISPUTED or debtor &lt;&gt; debtorNode then
				break;
			endif;
			_chargesForDebtors.add(charge);
		endwhile;
		
		delete iter;
	endforeach;
	
epilog
	delete chargeByDebtors;
	delete debtors;
	delete iter;
end;</source>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_chargesForDebtors" type="CM_ChargeByInvStatusSeqNumDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="b61787ea-a290-4ff0-ab08-db30933c7db8">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		27 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 26/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types//07.06.2018 cnwma1 ChangeRequest #38953

vars
	text  : String;
	block : CM_DataContainerBlock;
begin
	inheritMethod(_dataContainer);

	if self.myCalculationType &lt;&gt; null then
		block := _dataContainer.addNewBlock;
 
		block.addNewItem("Calculation Type", DC_Label, 1, self.myCalculationType);
		block.addNewItem(app.getInvoiceCalcTypeLabel(self.myCalculationType.calculationType,true), DC_Data, 1, self.myCalculationType);
		
		block := _dataContainer.addNewBlock; // TFS 4709
		block.addNewItem("Calculation Type Description", DC_Label, 1, self.myCalculationType);
		block.addNewItem(self.myCalculationType.description, DC_Data, 1, self.myCalculationType); // TFS 4709
	endif;
	if self.myTaxCode &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Tax Code", DC_Label, 1, self.myTaxCode);
		block.addNewItem(self.myTaxCode.getDisplayDetails(false), DC_Data, 1, self.myTaxCode);
	else
		block := _dataContainer.addNewBlock;
		block.addNewItem("Tax Code", DC_Label, 1, null);
		block.addNewItem("None", DC_Data, 1, null);
	
	endif;
	if self.genLCode &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("GL Code", DC_Label, 1, self.genLCode);
		block.addNewItem(genLCode.code &amp; " - " &amp; genLCode.remarks, DC_Data, 1, self.genLCode);
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem("Rate Type", DC_Label, 1, self);
	if self.defaultRateTable = CM_Service.DEFAULT_RATE_TABLE then
		block.addNewItem("Default", DC_Data, 1, self);
	elseif self.defaultRateTable = CM_Service.TRADE_RATE_TABLE then		// TFS 37794
		block.addNewItem("Trade", DC_Data, 1, self);
	elseif self.defaultRateTable = CM_Service.VESSEL_RATE_TABLE then	// TFS 37794
		block.addNewItem("Vessel", DC_Data, 1, self);					// TFS 37794
	elseif self.defaultRateTable = CM_Service.VESSELTYPE_RATE_TABLE then	//07.06.2018 cnwma1 ChangeRequest #38953
		block.addNewItem(app.getErrorString(VesselType), DC_Data, 1, self);	
	elseif self.defaultRateTable = CM_Service.BERTH_RATE_TABLE then			//07.06.2018 cnwma1 ChangeRequest #38953
		block.addNewItem(app.getErrorString(Berth), DC_Data, 1, self);	
	elseif self.defaultRateTable = CM_Service.VISITTYPE_RATE_TABLE then		//07.06.2018 cnwma1 ChangeRequest #38953
		block.addNewItem(app.getErrorString(VisitType), DC_Data, 1, self);	
	endif;
	
	if self.remarks &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Remarks", DC_Label, 1, self);
		block.addNewItem(self.remarks, DC_Data, 1, self);
	endif;
	// 31248 Mar 2103
	if self.isNotAvailableForEntry then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Not Available for Entry", DC_Label, 1, self);
		block.addNewItem(self.isNotAvailableForEntry.String, DC_Data, 1, self);
	endif;
	// 24024 CCMS 1151 Aug 2010 cnwjre1 display if user hook code for invoice rate is present
	if self.myCalculationType &lt;&gt; null then
		if self.myCalculationType.myHookCodeRate &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Hook Code", DC_Label, 1, self.myCalculationType.myHookCodeRate);
			text := "Rate";
			block.addNewItem(text, DC_Data, 1, self.myCalculationType.myHookCodeRate);
		endif;
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFullName" id="4a3a5233-d419-4610-a45b-fd9d67008dc0">
        <source>getFullName() : String;
// 24019 Rate Table services by group or name
vars
	work,
	result	: String;
	pos		: Integer;
	parent	: CM_ServiceGroup;
begin
	result := self.name;
	parent := self.group;
	while parent &lt;&gt; null do
		// output Root Service Group just as "Root"
		if parent.group = null then
			pos := 1;
			work := parent.name.scanUntil(" ", pos);
		else
			work := parent.name;
		endif;
		result := work &amp; "\" &amp; result;
		parent := parent.group;
	endwhile;
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
