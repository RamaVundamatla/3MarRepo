    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="daaf6e75-1c8b-44f3-899c-934dba9cb0b1">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwml2	Initial creation

*/

vars
	tmpMenu : MenuItem;
	table : CM_DataTable;
	wle : CM_WorkListEntry;

begin
	inheritMethod(conwin);
	self.mnuTblVShowHideData.visible := false;
	self.mnuTblVShowHideSearch.visible := false;
	self.mnuTblVShowHideThumb.visible := false;
	self.mnuTblVDockSearch.visible := false;
	
	if conwin = self.tblReceivals or conwin = self.tblReleases then
		table := conwin.CM_DataTable;
		self.mnuColumnOrganiser.visible := true;
	endif;
	
	if self.tblExtraInfo.visible then
		self.mnuMacro.caption := "Hide Macro Information";
	else
		self.mnuMacro.caption := "Show Macro Information";
	endif;
	
	//15 Nov 2011	NDL	Par 28366
	self.mnuDeleteCurrent.visible := false;	
	if table &lt;&gt; null then
		if table.row &gt; table.fixedRows and table.row &lt;= table.rows then
			wle := table.accessRow( table.row ).itemObject.CM_WorkListEntry;
			if wle &lt;&gt; null then
				self.mnuDeleteCurrent.visible := true;
				self.mnuDeleteCurrent.userObject := wle;
				tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDeleteCurrent, false);
			endif;
		endif;
	endif;
	

	
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuMacro, false);
	if self.myCurrentWLE &lt;&gt; null and self.myCurrentWLE.status &lt;&gt; WLE_COMPLETED and self.myCurrentWLE.myRequest.isKindOf(CM_ReceivalRequest) then
		tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuComplete, false);
		self.mnuComplete.visible := true;
	else
		self.hideMenuItem(app.getErrorString(Set_ToComplete));
	endif;

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a7b9adef-f67b-4887-a160-67f3ebdf5bec">
