    <JadeMethod name="sendRequest" id="e316853d-1ca0-40a7-bb9e-b3e7ad73dec5">
        <updating/>
        <source>sendRequest() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
08 Apr 2008	cnwkpd1	PAR #16487 - Remove transaction state check
					Also change to use exception handler on Process

*/

vars
	request	: NR_ShowScreenRequest;
	tmpProcess	: Process;
//	localChk : Boolean;
	invalidProcess : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, tmpProcess, invalidProcess);
	
	tmpProcess := self.myProcessToSendRequestTo;
//	if (not global.isValidObject(tmpProcess)) then
	if tmpProcess.persistentApp = null then				// PAR #16487 - just try to access the Process to see if it's still valid
	endif;
	if invalidProcess then
		// need message here to user
		return;
	endif;

//	if not process.isInTransactionState() then // ### AKB2007JUN DCTG Exception 
	beginTransaction;
//	localChk := true;
//	endif;

	request := self.myShowScreenRequest;
	if request = null then
		create request persistent;
		self.myShowScreenRequest := request;
	else
		// need to change this as if already being actioned do not want
		// to action again
		request.setIsBeingActioned(false);
	endif;
	request.sendRequest();
	
//	if localChk then
	commitTransaction;
//	endif;
	
	self.beginNotification(request, NR_ShowScreenRequest.NR_NodeRequestCompleteEvent, Response_Cancel, 0);

	// PAR #16487 - Let exception handler deal with this by resuming
//	if global.isValidObject(tmpProcess) then
		tmpProcess.causeEvent(NR_ShowScreenRequest.NR_NodeRequestActionEvent, true, request);
//	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
