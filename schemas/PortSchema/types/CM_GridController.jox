    <JadeMethod name="getFortyBackendsByMode" id="ee18d1bd-e079-4714-97d9-bb231c71408e">
        <source>getFortyBackendsByMode(_mode : Integer; _tmpTIs : CM_TIArray input);
// ---------------------------------------------------------------------------
// Created:		19 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	fms : CM_FutureMoveArray;
	tmpGC, prevGC : CM_GridController;
	fmTI : CM_TrackedItem;
	primLC : CM_LocationsController;
	aFM : CM_FutureMove;
begin
			
	if _mode = QUEUE_MODE 
	or _mode = PLANNING_MODE  then
		if _mode = QUEUE_MODE then
			fms := self.allQueuedFutureMoves;
		else
			fms := self.allPlannedFutureMoves;
		endif;
		foreach aFM in fms  discreteLock do
			fmTI := aFM.getTrackedItem();
			if fmTI &lt;&gt; null 
			and fmTI.isAttributeTrue(TI_Attrib_IsForty) then
				if _mode = QUEUE_MODE then
					primLC := fmTI.myPrimaryQueuedLocation;
				else
					primLC := fmTI.myPrimaryPlannedLocation;
				endif;
				
				// 40 back end only
				if self &lt;&gt; primLC then
					_tmpTIs.add(fmTI);
				endif;
			endif;
		endforeach;
	else
		foreach fmTI in self.allTrackedItems discreteLock do
			if fmTI.isForty() then
				_tmpTIs.add(fmTI);
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tmpTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFreeSpaceCheckNextCont" id="cb0df8f7-c50a-4e3b-bb10-dd569042afbf">
        <updating/>
        <source>getFreeSpaceCheckNextCont(set : CM_GridControllersByRowColumn) : Boolean updating;
/*

Purpose:			Checks that the Next Controller is OK

Parameters:			Set of Controllers for this Area

Return Value:		True if OK


Date		Who		Reason
28 August 2008	conkc1	Initial creation

*/

vars
	nextGC : CM_GridController;
begin
	nextGC := self.myNextController;
	if nextGC = null then
		return false;
	endif;
	if nextGC.amIAvailable = false then
		return false;
	endif;

	if set.includes(nextGC) = false then
		return false;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="set" type="CM_GridControllersByRowColumn"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFreeSpaceFor20" id="fd1b2357-66f5-45f3-9d6b-836776156c9c">
        <updating/>
        <source>getFreeSpaceFor20() : Integer updating;

/*

Purpose:			Return the free space for a 20 foot container.
					Does not take notice of Queued or Planned containers.

Parameters:			

Return Value:		Number of normal containers


Date		Who		Reason
26 August 2008	conkc1	Initial creation

*/
vars

	minStackingHeight       : Integer;
	container               : CM_Container;
	trackedItem             : CM_TrackedItem;
	spaceAvailable          : Integer;

begin

	if self.amIAvailable = false then
		return 0;
	endif;
	if self.allTrackedItems.isEmpty = true and self.allTrackedItemOSBackEnds.size = 0 and self.checkFor4Controller53Footer(20) = true then

		minStackingHeight := self.getMaxStackingHeight;
		return minStackingHeight;

	endif;
	//
	// Not empty
	//
	if self.getMaxStackingHeight = 0 then
		return 0;
	endif;
	
	trackedItem := self.allTrackedItems.first;
	if trackedItem.isKindOf(CM_Container) then
		container := trackedItem.CM_Container;
		if container = null then
			// we have a problem 
			// Or we have a Queued or Planned move
			// process.debug;
			return 0;
		endif;
		if container.is20 = true then

			spaceAvailable := self.getMaxStackingHeight - self.allTrackedItems.size;
			return spaceAvailable;
	
		endif;
	else
	//
	// Code to handle non CM_Containers
	//
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFreeSpaceFor30" id="56a9ed48-8c59-458a-b063-4690615e8d94">
        <updating/>
        <source>getFreeSpaceFor30(set : CM_GridControllersByRowColumn) : Integer updating;
/*
Purpose:			For this Controller check if a 30 foot container is possible

Parameters:			Set of Controllers for this area

Return Value:		Number of 30 foot containers possible

Date		Who		Reason
21 August 2008	conkc1	Initial creation

*/
vars
	nextGC                  : CM_GridController;
	minStackingHeight       : Integer;
	container               : CM_Container;
	trackedItem             : CM_TrackedItem;
	spaceAvailable          : Integer;

begin

	if self.amIAvailable = false then
		return 0;
	endif;
	
	///##### DOUG ADD IN 40s????
	
	
	
	
	
	//if self.is30ft = false then
	//	return 0;
	//endif;
	if self.offset30 = -1 then
		return 0;
	endif;
	if self.allTrackedItems.isEmpty = true and self.checkBackEndsOK(30) = true and self.checkFor4Controller53Footer(30) = true then

		if getFreeSpaceCheckNextCont(set) = false then
			return 0;
		endif;

		nextGC := self.myNextController;
		if nextGC.amIAvailable = false then
			return 0;
		endif;
		//
		// Next controller must be able to take a 30 foot container
		//
		if nextGC.is30ft = false then
			return 0;
		endif;

		if nextGC.allTrackedItems.isEmpty = true then
			minStackingHeight := self.getMaxStackingHeight;
			return minStackingHeight;
		else
			trackedItem := nextGC.allTrackedItems.first;
			if trackedItem.isKindOf(CM_Container) then
				container := trackedItem.CM_Container;
				if container.is20 = true then
					return 0;
				elseif container.is40 = true and container.is45 = false then
					return 0;
				elseif nextGC.checkMyEndsOK(30, container) = false then
					return 0;
				endif;
				minStackingHeight := nextGC.getMaxStackingHeight;
				return minStackingHeight;
			endif;
		endif;
		
		return 0;

	endif;
	//
	// Not empty
	//
	if self.getMaxStackingHeight = 0 then
		return 0;
	endif;

	trackedItem := self.allTrackedItems.first;
	if trackedItem.isKindOf(CM_Container) then
		container := trackedItem.CM_Container;
		if container = null then
			//  
			// Must have a backend that stops us
			// 
			return 0;
		endif;
		if container.is30 = true then
			spaceAvailable := self.getMaxStackingHeight - self.allTrackedItems.size;
			return spaceAvailable;
		else
			return 0;
		endif;
	else
	//
	// Code to handle non CM_Containers
	//
		return 0;
	endif;
epilog

end;</source>
        <Parameter name="set" type="CM_GridControllersByRowColumn"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFreeSpaceFor40" id="b5cb7ac8-1deb-4a6c-9f46-32dec3e9d2bb">
        <updating/>
        <source>getFreeSpaceFor40(set : CM_GridControllersByRowColumn; oa : ObjectArray io) : Integer updating;
/*
Purpose:			For this Controller check if a 40 foot container is possible

Parameters:			Set of Controllers for this area

Return Value:		Number of 40 foot containers possible
Date		Who		Reason
21 August 2008	conkc1	Initial creation

*/

vars
	nextGC                  : CM_GridController;
	minStackingHeight       : Integer;
	container               : CM_Container;
	trackedItem             : CM_TrackedItem;
	spaceAvailable          : Integer;

begin

	if self.amIAvailable = false then
		return 0;
	endif;
	if self.allTrackedItems.isEmpty = true  and self.allTrackedItemOSBackEnds.size = 0 and self.checkFor4Controller53Footer(40) = true then

		nextGC := self.myNextController;
		if nextGC = null then
			return 0;
		endif;
		if nextGC.amIAvailable = false then
			return 0;
		endif;
		if set.includes(nextGC) = false then
			return 0;
		endif;
		if nextGC.allTrackedItems.isEmpty then
			minStackingHeight := self.getMaxStackingHeight;
			if oa.includes(nextGC) = true then
				return 0;
			endif;
			if oa.includes(self) = true then
				return 0;
			endif;
			//
			// Add self and nextGC to array so we dont use them again
			//
			oa.add(self);
			oa.add(nextGC);
			return minStackingHeight;
		endif;
		
		return 0;

	endif;
	//
	// Not empty
	//
	if self.getMaxStackingHeight = 0 then
		return 0;
	endif;
	trackedItem := self.allTrackedItems.first;
	if trackedItem.isKindOf(CM_Container) then
		container := trackedItem.CM_Container;
		if container = null then
			// we have a problem 
			// Or we have a Queued or Planned move
			return 0;
		endif;
		if container.is40 = true and container.is45 = false then
			if container.isFrontEndOfTi(self) = true then
				spaceAvailable := self.getMaxStackingHeight - self.allTrackedItems.size;
				nextGC := self.myNextController;

				if oa.includes(self) = true then
					return 0;
				endif;
				//
				// Add self and nextGC to array so we dont use them again
				//
				oa.add(self);
				oa.add(nextGC);
				return spaceAvailable;
			else
				return 0;
			endif;
		elseif container.is20 = true then
			return 0;
		else
	
		endif;
	else
	//
	// Code to handle non CM_Containers
	//
		return 0;
	endif;
epilog

end;</source>
        <Parameter name="set" type="CM_GridControllersByRowColumn"/>
        <Parameter name="oa" type="ObjectArray" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFreeSpaceFor45" id="1d6746d0-435b-404a-bb6b-83e9090814d7">
        <updating/>
        <source>getFreeSpaceFor45(set : CM_GridControllersByRowColumn) : Integer updating;
/*
Purpose:			For this Controller check if a 45 foot container is possible

Parameters:			Set of Controllers for this area

Return Value:		Number of 45 foot containers possible	


Date		Who		Reason
21 August 2008	conkc1	Initial creation

*/
vars
	nextGC                  : CM_GridController;
	minStackingHeight       : Integer;
	container               : CM_Container;
	trackedItem             : CM_TrackedItem;
	spaceAvailable          : Integer;

begin

	if self.amIAvailable = false then
		return 0;
	endif;
	if self.is45ft = false then
		return 0;
	endif;
	if self.offset45 = -1 or self.offset45 = 20 then  // the check for 20 is because every 9th LC has 20 not -1 is being fixed
		return 0;
	endif;
	if self.allTrackedItems.isEmpty = true and self.checkBackEndsOK(45) = true and self.checkFor4Controller53Footer(45) = true then

		if getFreeSpaceCheckNextCont(set) = false then
			return 0;
		endif;	
		//
		// Second Controller
		//
		nextGC := self.myNextController;
		if nextGC.getFreeSpaceCheckNextCont(set) = false then
			return 0;
		endif;
		if nextGC.allTrackedItems.size &lt;&gt; 0 then
			return 0;
		endif;
		//
		// Next controller must be able to take a 45 foot container
		//
		if nextGC.is45ft = false then
			return 0;
		endif;
		//
		// Third controller
		//
		nextGC := nextGC.myNextController;
		if nextGC.amIAvailable = false then
			return 0;
		endif;
		//
		// Third controller must also be able to take a 45 foot container
		//
		if nextGC.is45ft = false then
			return 0;
		endif;
		if nextGC.allTrackedItems.isEmpty() then
			minStackingHeight := self.getMaxStackingHeight;
			return minStackingHeight;
		else
			trackedItem := nextGC.allTrackedItems.first;
			if trackedItem.isKindOf(CM_Container) then
				container := trackedItem.CM_Container;
				if container.is20 = true then
					return 0;
				elseif container.is40= true and container.is45 = false then
					return 0;
				elseif nextGC.checkMyEndsOK(45, container) = false then
					return 0;
				endif;
				minStackingHeight := nextGC.getMaxStackingHeight;
				return minStackingHeight;
			endif;

		endif;
		
		return 0;

	endif;
	//
	// Not empty
	//
	if self.getMaxStackingHeight = 0 then
		return 0;
	endif;

	trackedItem := self.allTrackedItems.first;
	if trackedItem.isKindOf(CM_Container) then
		container := trackedItem.CM_Container;
		if container = null then
			//  
			// Must have a backend that stops us
			// 
			return 0;
		endif;
		if container.myPrimaryActualLocation &lt;&gt; self then
			return 0;
		endif;
		if container.is45 = true then
			spaceAvailable := self.getMaxStackingHeight - self.allTrackedItems.size;
			return spaceAvailable;
		else
			return 0;
		endif;
	else
	//
	// Code to handle non CM_Containers
	//
		return 0;
	endif;
epilog

end;</source>
        <Parameter name="set" type="CM_GridControllersByRowColumn"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFreeSpaceFor53" id="f470ee23-059b-4852-945f-6883db38c9c2">
        <updating/>
        <source>getFreeSpaceFor53(set : CM_GridControllersByRowColumn) : Integer updating;
/*
Purpose:			For this Controller check if a 53 foot container is possible

Parameters:			Set of Controllers for this area

Return Value:		Number of 53 foot containers possible

Date		Who		Reason
21 August 2008	conkc1	Initial creation

*/
vars
	nextGC                  : CM_GridController;
	minStackingHeight       : Integer;
	container               : CM_Container;
	trackedItem             : CM_TrackedItem;
	spaceAvailable          : Integer;

begin

	if self.amIAvailable = false then
		return 0;
	endif;
	if self.is53ft = false then
		return 0;
	endif;
	if self.offset53 = -1 then
		return 0;
	endif;
	if self.allTrackedItems.isEmpty and self.checkBackEndsOK(53) = true then

		if validateControllersFor53(set) = false then
			return 0;
		endif;

		minStackingHeight := self.getMaxStackingHeight;
		return minStackingHeight;

	endif;
	//
	// Not empty - checkForBackENds and how high
	//
	if self.checkBackEndsOK(53) = false then
		return 0;
	endif;
	if self.getMaxStackingHeight = 0 then
		return 0;
	endif;

	trackedItem := self.allTrackedItems.first;
	if trackedItem.isKindOf(CM_Container) then
		container := trackedItem.CM_Container;
		if container = null then
			//  
			// Must have a backend that stops us
			// 
			return 0;
		endif;
		if container.is53 = true then
			spaceAvailable := self.getMaxStackingHeight - self.allTrackedItems.size;
			return spaceAvailable;
		else
			return 0;
		endif;
	else
	//
	// Code to handle non CM_Containers
	//
		return 0;
	endif;
epilog

end;</source>
        <Parameter name="set" type="CM_GridControllersByRowColumn"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFullId40" id="233e8df3-6536-4074-8b4d-21f5e76ac048">
        <source>getFullId40(): String;
/*

Purpose:			

