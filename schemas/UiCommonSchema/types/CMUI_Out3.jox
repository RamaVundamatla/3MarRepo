    <JadeMethod name="getFrameForPosition" id="5fff1d69-1314-459f-a602-d2db67095f43">
        <source>getFrameForPosition(_pos : Integer ) : Frame;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _pos = 1 then	
		return self.frmPosTL;
	elseif _pos = 2 then	
		return self.frmPosTM;
	elseif _pos = 3 then	
		return self.frmPosTR;
	elseif _pos = 4 then	
		return self.frmPosML;
	elseif _pos = 5 then	
		return self.frmPosMM;
	elseif _pos = 6 then	
		return self.frmPosMR;
	elseif _pos = 7 then	
		return self.frmPosBL;
	elseif _pos = 8 then	
		return self.frmPosBM;
	elseif _pos = 9 then	
		return self.frmPosBR;
	endif;
epilog

end;</source>
        <Parameter name="_pos" type="Integer"/>
        <ReturnType type="Frame"/>
    </JadeMethod>
    <JadeMethod name="getNextAIPos" id="12285b7f-e0f2-466a-b750-de3a39b77724">
        <source>getNextAIPos() : Integer;

// #### THE BRAIN ###

// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	nextAIPos : Integer;

begin
	nextAIPos := self.getPosFor1Gap(Cross); // Win for AI?
	if nextAIPos = 0 then
		nextAIPos := self.getPosFor1Gap(Nought); // Block for AI
		if nextAIPos = 0 then

			nextAIPos := self.getPosFor2Gap(Cross); // Win for AI?
			if nextAIPos = 0 then
				nextAIPos := self.getPosFor2Gap(Nought); // Block for AI
				if nextAIPos = 0 then
					nextAIPos := self.getPosFor1Gap(Anything); // Block opposite for AI
				endif;
			endif;
		endif;
	endif;

	return nextAIPos;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPosFor1Gap" id="7a8ee732-b5e3-4192-ba0d-508869fc8fd1">
        <source>getPosFor1Gap( _character : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	nextAIPos : Integer;
begin
	nextAIPos := self.has1Gap(1,2,3, _character);
	if nextAIPos = 0 then
		nextAIPos := self.has1Gap(4,5,6, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has1Gap(7,8,9, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has1Gap(1,4,7, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has1Gap(2,5,8, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has1Gap(3,6,9, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has1Gap(1,5,9, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has1Gap(3,5,7, _character);
	endif;
	
	return nextAIPos;

epilog

end;</source>
        <Parameter name="_character" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPosFor1GapNEW" id="c317d77c-c131-47fc-9f8a-b194df554604">
        <source>getPosFor1GapNEW( _character : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx, a, b, c, nextAIPos : Integer;
begin

	self.incrementGapsOrder2();

	foreach idx in 1 to 8 do
		self.getPositionsForIndex(self.gapsOrder2[idx],a,b,c);

		nextAIPos := self.has1Gap(a,b,c, _character);
		if nextAIPos &lt;&gt; 0 then
			return nextAIPos;
		endif;
	endforeach;
	
	return nextAIPos;


epilog

end;</source>
        <Parameter name="_character" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPosFor2Gap" id="38091a98-058a-4e76-9ff2-1b9d3174360c">
        <source>getPosFor2Gap( _character : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx, a, b, c, nextAIPos : Integer;
begin

	self.incrementGapsOrder2();

	foreach idx in 1 to 8 do
		self.getPositionsForIndex(self.gapsOrder2[idx],a,b,c);
//write class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; self.gapsOrder2[idx].String &amp; " &gt;&gt; " &amp; a.String &amp; " " &amp; b.String &amp; " " &amp; c.String;
		nextAIPos := self.has2Gaps(a,b,c, _character);
		if nextAIPos &lt;&gt; 0 then
			return nextAIPos;
		endif;
	endforeach;
	
	return nextAIPos;

epilog

end;</source>
        <Parameter name="_character" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPosFor2GapOLD" id="a7c75f10-b2b3-4746-9730-8fd819d9c745">
        <source>getPosFor2GapOLD( _character : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	nextAIPos : Integer;
begin
	nextAIPos := self.has2Gaps(1,5,9, _character);
	if nextAIPos = 0 then
		nextAIPos := self.has2Gaps(4,5,6, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has2Gaps(7,8,9, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has2Gaps(1,4,7, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has2Gaps(2,5,8, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has2Gaps(3,6,9, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has2Gaps(1,2,3, _character);
	endif;
	if nextAIPos = 0 then
		nextAIPos := self.has2Gaps(3,5,7, _character);
	endif;
	
	return nextAIPos;

epilog

end;</source>
        <Parameter name="_character" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPositionForFrame" id="87a01c0e-4206-43af-ab36-4cca40a9c063">
        <source>getPositionForFrame(_frame : Frame) : Integer;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _frame = self.frmPosTL then
		return 1;
	elseif _frame = self.frmPosTM then
		return 2;
	elseif _frame = self.frmPosTR then
		return 3;
	elseif _frame = self.frmPosML then
		return 4;
	elseif _frame = self.frmPosMM then
		return 5;
	elseif _frame = self.frmPosMR then
		return 6;
	elseif _frame = self.frmPosBL then
		return 7;
	elseif _frame = self.frmPosBM then
		return 8;
	elseif _frame = self.frmPosBR then
		return 9;
	endif;
epilog

end;</source>
        <Parameter name="_frame" type="Frame"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPositionsForIndex" id="8fb3b83a-7548-491f-ae4b-5667f5f73b0b">
        <source>getPositionsForIndex( _index : Integer; _a, _b, _c : Integer output);
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _index = 1 then
		_a := 1;
		_b := 5;
		_c := 9;
	elseif _index = 2  then
		_a := 1;
		_b := 4;
		_c := 7;
	elseif _index =  3 then
		_a := 1;
		_b := 2;
		_c := 3;
	elseif _index = 4 then
		_a := 4;
		_b := 5;
		_c := 6;
	elseif _index = 5 then
		_a := 2;
		_b := 5;
		_c := 8;
	elseif _index = 6 then
		_a := 3;
		_b := 6;
		_c := 9;
	elseif _index =  7 then
		_a := 7;
		_b := 8;
		_c := 9;
	elseif _index = 8 then
		_a := 3;
		_b := 5;
		_c := 7;
	endif;
	
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_a" type="Integer" usage="output"/>
        <Parameter name="_b" type="Integer" usage="output"/>
        <Parameter name="_c" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="has0Gaps" id="c4ed8785-0752-41bc-a3b9-0e334b68aeef">
        <source>has0Gaps(a,b,c : Integer; _character : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.positions[a] = _character and self.positions[b] = _character and self.positions[c] = _character then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="a" type="Integer"/>
        <Parameter name="b" type="Integer"/>
        <Parameter name="c" type="Integer"/>
        <Parameter name="_character" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="has1Gap" id="e8dc6b13-e8e5-4efb-9247-1cae65b7a573">
        <source>has1Gap(a,b,c : Integer; _character : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _character = Anything then
		if self.positions[a] &lt;&gt; null and self.positions[b] &lt;&gt; null and self.positions[c] = null then
			return c;
		elseif self.positions[a] &lt;&gt; null and self.positions[c] &lt;&gt; null and self.positions[b] = null then
			return b;
		elseif self.positions[b] &lt;&gt; null and self.positions[c] &lt;&gt; null and self.positions[a] = null then
			return a;
		endif;
	else
		if self.positions[a] = _character and self.positions[b] = _character and self.positions[c] = null then
			return c;
		elseif self.positions[a] = _character and self.positions[c] = _character and self.positions[b] = null then
			return b;
		elseif self.positions[b] = _character and self.positions[c] = _character and self.positions[a] = null then
			return a;
		elseif self.positions[a] = null and self.positions[b] = _character and self.positions[c] = _character then
			return a;
		elseif self.positions[a] = _character and self.positions[c] = null and self.positions[b] = _character then
			return c;
		elseif self.positions[b] = null and self.positions[c] = _character and self.positions[a] = _character then
			return b;
		endif;
	endif;
	
	return 0;
epilog

end;</source>
        <Parameter name="a" type="Integer"/>
        <Parameter name="b" type="Integer"/>
        <Parameter name="c" type="Integer"/>
        <Parameter name="_character" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="has2Gaps" id="0647b90b-5dac-4969-a9e4-427adcda8917">
        <source>has2Gaps(a,b,c : Integer; _character : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.positions[a] = _character and self.positions[b] = null and self.positions[c] = null then
		return c;
	elseif self.positions[a] = null and self.positions[b] = null and self.positions[c] = _character then
		return a;
	elseif self.positions[a] = null and self.positions[b] = _character and self.positions[c] = null then
		return a;
	endif;
	
	return 0;
epilog

end;</source>
        <Parameter name="a" type="Integer"/>
        <Parameter name="b" type="Integer"/>
        <Parameter name="c" type="Integer"/>
        <Parameter name="_character" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasWinningLine" id="bf26c315-30a5-4118-adbc-945b8709f4ca">
        <updating/>
        <source>hasWinningLine( _character : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	if self.has0Gaps(1,2,3, _character) then
		self.setWinningLineCoords(123);
		return true;
	elseif self.has0Gaps(4,5,6, _character) then
		self.setWinningLineCoords(456);
		return true;
	elseif self.has0Gaps(7,8,9, _character) then
		self.setWinningLineCoords(789);
		return true;
	elseif self.has0Gaps(1,4,7, _character) then
		self.setWinningLineCoords(147);
		return true;
	elseif self.has0Gaps(2,5,8, _character) then
		self.setWinningLineCoords(258);
		return true;
	elseif self.has0Gaps(3,6,9, _character) then
		self.setWinningLineCoords(369);
		return true;
	elseif self.has0Gaps(1,5,9, _character) then
		self.setWinningLineCoords(159);
		return true;
	elseif self.has0Gaps(3,5,7, _character) then
		self.setWinningLineCoords(357);
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_character" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="incrementGapsOrder2" id="2ea3b9ec-8639-4b5c-868b-b70d485e15cf">
        <source>incrementGapsOrder2();
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	tot, loop, idx : Integer;
begin
		
	idx := self.gapsOrder2[1];
	foreach loop in 1 to 8 do
		if loop &lt; 8 then
			self.gapsOrder2[loop] := self.gapsOrder2[loop + 1];
		else
			self.gapsOrder2[8] := idx;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="76fc3365-7836-4773-8874-dd2d80142b98">
        <updating/>
        <source>init() updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	self.doDebug := true;
	
	self.drawCross := false;
	
	foreach idx in 1 to 9 do
		self.positions[idx] := null;
	endforeach;
	self.initGapsOrder2();
//	self.testCoords();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initGapsOrder2" id="1b8e2122-72f2-4950-9c2e-0e364b15e9e0">
        <source>initGapsOrder2();
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	foreach idx in 1 to 8 do
		gapsOrder2.add(idx);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyPress" id="11a5b65f-b912-4916-968b-13847a23c00f">
        <controlMethod name="Form::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
