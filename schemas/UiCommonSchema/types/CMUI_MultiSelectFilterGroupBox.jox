    <JadeMethod name="moveItemTo" id="cbe3cf62-aa2f-4d8c-8e80-18639a3f24bc">
        <updating/>
        <source>moveItemTo(pIdx: Integer; pObj: Object; _moveTo: Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2025	navlw1	JIRA-34582: Improved how we move items to the top of the list box

*/

vars
	nexIndex				: Integer;
	parentCol				: ObjectArray;
begin

	inheritMethod(pIdx, pObj, _moveTo);
	
	if pIdx &gt; 0 and pObj &lt;&gt; null then
		nexIndex := _moveTo;
		if nexIndex &lt; 1 or nexIndex &gt; self.mySelectedListBox.listCount then
            return;
        endif;
		parentCol := self.parentCollectionRight;
		parentCol.removeAt(pIdx);
		parentCol.insert(nexIndex, pObj);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="pIdx" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
        <Parameter name="_moveTo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resetSelectedStatus" id="be42284e-d58d-43fa-bbf6-6270bb60dbbd">
        <source>resetSelectedStatus(_isFromTop : Boolean; _totalSelected: Integer);
/*

Purpose:			
	To retain the selected status of items that have been moved to top or bottom
Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.

*/

vars
	beginPos,
	endPos			: Integer;
	listBoxRight	: ListBox;
begin
	listBoxRight := self.mySelectedListBox;
	if _isFromTop then
		beginPos := 1;
		endPos := _totalSelected + 1;
	else
		endPos := listBoxRight.listCount() + 1;
		beginPos := endPos - _totalSelected;
	endif;
	
	listBoxRight.topIndex := beginPos;
	while beginPos &lt; endPos do
		listBoxRight.itemSelected[beginPos] := true;
		beginPos += 1;
	endwhile;
epilog

end;</source>
        <Parameter name="_isFromTop" type="Boolean"/>
        <Parameter name="_totalSelected" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resizeMultiSelectLists" id="7fef3e1e-551d-4053-b57b-f6b20aced0e1">
        <source>resizeMultiSelectLists(_availList: ListBox; _selectList: ListBox; _availLabel: Label; _selectLabel: Label; _allButtons: ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
*/

constants
	TopMargin		: Integer = 20;
	OffsetBottom	: Integer = 20;
	OffsetDiff		: Integer = 30;
	VertSpacing		: Integer = 5;
	BaseTopMargin	: Integer = 5;
	SideMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	HoroSpacing		: Integer = 10;
vars
	button 			: Object;
	availList,
	selectList		: ListBox;
	availLabel,
	selectLabel		: Label;
	filterBoxLeft,
	filterBoxRight	: CMUI_TextBox;
	firstButTop		: Integer;
	firstButton		: Button;
	listBoxHeight,
	vertSpacing		: Real;
	topMargin,
	btnLeftPos,
	lstBoxWidth,
	btnWidth,
	btnHeight,
	topPos,
	totWidth,
	totHeight		: Real;
	buttonCount 	: Integer;
	obj 			: Object;
	clearBtnLeft,
	clearBtnRight	: CMUI_Button;
begin
	vertSpacing		:= 5;
	topMargin := BaseTopMargin;
	if not self.isKindOf(Sheet) then
		if self.caption &lt;&gt; null then
			topMargin := topMargin + 10;
		endif;
	endif;
	
	totWidth :=self.clientWidth;
	totHeight := self.clientHeight;
	
	firstButton :=_allButtons.first.Button;
	btnHeight	:= firstButton.height;
	btnWidth	:= firstButton.width;	
	
	btnLeftPos	:= (totWidth / 2) - (btnWidth / 2);				 
	
	lstBoxWidth	:= btnLeftPos - HoroSpacing - SideMargin;
	
	_availList.move(SideMargin, topPos, lstBoxWidth, 
								(totHeight - topPos - BottomMargin).max(0));
	_selectList.move(btnLeftPos + btnWidth + HoroSpacing, topPos, lstBoxWidth,
								(totHeight - topPos - BottomMargin).max(0));
	
	listBoxHeight :=_availList.clientHeight;
	if _availLabel &lt;&gt; null and _selectLabel &lt;&gt; null and _availLabel.visible then
		_availLabel.move(SideMargin, topMargin, lstBoxWidth, _availList.height);
		_selectLabel.move(_selectList.left, topMargin, lstBoxWidth, _availList.height);	
	endif;
	
	foreach obj in _allButtons discreteLock do
		if obj.Button.visible then
			buttonCount :=buttonCount + 1;
		endif;
	endforeach;
	
	if (buttonCount * btnHeight) + ((buttonCount - 1) * vertSpacing) &gt; listBoxHeight then	
		vertSpacing := (listBoxHeight - (buttonCount * btnHeight))/(buttonCount - 1).max(0);
	endif;	
	
	availList 	:= _availList;
	selectList	:= _selectList;
	availLabel	:= _availLabel;
	selectLabel	:= _selectLabel;
	filterBoxLeft	:= self.txtFilterBoxLeft;
	clearBtnLeft 	:= self.myMultiSelectClearBtnLeft;
	
	filterBoxLeft.top := availLabel.top + TopMargin;
	filterBoxLeft.left := availList.left;
	availList.top += (filterBoxLeft.height + OffsetBottom); 
	selectList.top += (filterBoxLeft.height + OffsetBottom); 
	filterBoxLeft.width := availList.width - clearBtnLeft.width - 5;
	
	availList.height := filterBoxLeft.parentBottomOffset - OffsetDiff;
	selectList.height := filterBoxLeft.parentBottomOffset - OffsetDiff;
	availList.parentBottomOffset := OffsetBottom;
	selectList.parentBottomOffset := OffsetBottom;
	
	filterBoxLeft.top := availList.top - 25;
	clearBtnLeft.top := filterBoxLeft.top;
	clearBtnLeft.parentRightOffset := availList.parentRightOffset;
	
	topPos := availList.top;
	
	foreach obj in _allButtons discreteLock do
		if obj.Button.visible then
			obj.Button.move(btnLeftPos, topPos, btnWidth, btnHeight);
			topPos := topPos + btnHeight + vertSpacing;
		endif;
	endforeach;
	
	//09.07.2024 navnk30 #64536 Task 64537	START
	filterBoxRight		:= self.txtFilterBoxRight;
	filterBoxRight.top	:= self.txtFilterBoxLeft.top;
	filterBoxRight.left	:= _selectList.left;
	filterBoxRight.width := self.txtFilterBoxLeft.width;
	
	clearBtnRight		:= self.myMultiSelectClearBtnRight;
	clearBtnRight.top	:= self.myMultiSelectClearBtnLeft.top;
	clearBtnRight.parentRightOffset := selectList.parentRightOffset;
	//09.07.2024 navnk30 #64536 Task 64537	END
epilog

end;</source>
        <Parameter name="_availList" type="ListBox"/>
        <Parameter name="_selectList" type="ListBox"/>
        <Parameter name="_availLabel" type="Label"/>
        <Parameter name="_selectLabel" type="Label"/>
        <Parameter name="_allButtons" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setAvailable" id="78ac56ef-1754-45a3-aeb5-670b4749ba3c">
        <updating/>
        <source>setAvailable(pAvailable: Collection; pClearSelectedFirst: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
09 Sep 2024	navnk30	Bug 66009: MTN - Column Organiser Column Sorting Upon reordering sorted columns all columns appear in list
08 Apr 2025	navlw1	JIRA-34581: When switching tables we were not clearing the Parent collection Left

*/

vars
	iter	: Iterator;
	obj 	: Object;
begin
	inheritMethod(pAvailable, pClearSelectedFirst);
	
	self.parentCollectionLeft.clear(); // navlw1 #JIRA-34581 8/04/2025
	
	if pClearSelectedFirst then
		self.parentCollectionRight.clear();
	endif;
	
	if pAvailable = null or pAvailable.isEmpty() then
		return;
	endif;
	
	iter := pAvailable.createIterator();
	while iter.next(obj) do
		//if not self.parentCollectionRight.includes(obj) then		//09.09.2024 navnk30 #66009 START
			//self.parentCollectionRight.add(obj);
		if not self.parentCollectionLeft.includes(obj) then			//09.09.2024 navnk30 #66009 END
			self.parentCollectionLeft.add(obj);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="pAvailable" type="Collection"/>
        <Parameter name="pClearSelectedFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColSortStatus" id="bca7e570-b660-463a-9e8a-1569b4d37944">
        <source>setColSortStatus(_allDescCols	: EntTableRowSet);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Sep 2024	navnk30	Bug 66009: MTN - Column Organiser Column Sorting Upon reordering sorted columns all columns appear in list

*/

constants
	Ascending_Text	: String = CMUI_ColumnOrganiserForm.Ascending;
	Descending_Text	: String = CMUI_ColumnOrganiserForm.Descending;
vars
	idx,
	totalCount		: Integer;
	listItemTxt		: String;
	canAppendStr	: Boolean; 
begin
	if self.name &lt;&gt; CMUI_ColumnOrganiserForm::mulColumnSorter.name then
		return;
	endif;
	
	idx := 1;
	totalCount := self.mySelectedListBox.listCount();
	while idx &lt;= totalCount do
		listItemTxt := self.mySelectedListBox.itemText[idx];
		canAppendStr := not listItemTxt.endsWith__(Ascending_Text) and not listItemTxt.endsWith__(Descending_Text);
		if canAppendStr then
			if _allDescCols.includes(self.mySelectedListBox.itemObject[idx].EntTableRow) then
				self.mySelectedListBox.itemText[idx] &amp;= ' - ' &amp; Descending_Text;
			else
				self.mySelectedListBox.itemText[idx] &amp;= ' - ' &amp; Ascending_Text;
			endif;
		endif;
		idx += 1;
	endwhile;
epilog

end;</source>
        <Parameter name="_allDescCols" type="EntTableRowSet"/>
    </JadeMethod>
    <JadeMethod name="setParentCollection" id="2d1e5ee4-c762-4133-ba50-a66bd0bed199">
        <updating/>
        <source>setParentCollection(_collection: ObjectSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 April 2023	navcs2	Defect 57574: MTN - WO - The filter text is not getting cleared when selecting a new work order task

*/

vars

begin
	self.parentCollectionLeft.clear();
	_collection.copyNoDuplicates(self.parentCollectionLeft, false);
epilog

end;</source>
        <Parameter name="_collection" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="setSelected" id="fba418f1-7c7d-43c9-83ea-2e25122aafe7">
        <updating/>
        <source>setSelected(pSelected: Collection) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
18 Sep 2024	navnk30	Bug 66009: MTN - Column Organiser Column Sorting Upon reordering sorted columns all columns appear in list
31 Mar 2025	navpw1	JIRA: MTN-34413 - Columns not in parentCollectionLeft should not be added to parentCollectionRight.
										This is because views sometimes contain hidden rows and a row must appear in parentCollectionLeft or available before it can be selected.

*/

vars
	rightColl,
	leftColl	: Collection;
	iter		: Iterator;
	obj			: Object;
	isColSorter	: Boolean;
begin
	inheritMethod(pSelected);
	
	isColSorter := self.name = CMUI_ColumnOrganiserForm::mulColumnSorter.name;	//18.09.2024 navnk30 #66009
	leftColl	:= self.parentCollectionLeft;
	rightColl	:= self.parentCollectionRight;
	rightColl.copyNoDups(leftColl);
	rightColl.clear();
	
	if pSelected = null or pSelected.isEmpty() then
		return;
	endif;
	
	iter := pSelected.createIterator();
	
	while iter.next(obj) do
		if leftColl.tryRemoveIfNotNull(obj) then		// ### JIRA: MTN-34413 31Mar2025 NAVPW1  // ### JIRA 35154 17JUL2025 NAVAB1 tryRemoveIfNotNull
			rightColl.add(obj);
		endif;
		
		if isColSorter and rightColl.size() &gt; 2 then	//18.09.2024 navnk30 #66009
			break;
		endif;
	endwhile;
	
epilog
	if iter &lt;&gt; null then
		delete iter;
	endif;
end;</source>
        <Parameter name="pSelected" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setupControl" id="51cb05c0-a381-4ca9-90c0-e53ad071d6d4">
        <updating/>
        <source>setupControl(_headingName: String; _collection: Collection; _displayMethodName: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control
13/04/2023	navcs2	Defect 57574: MTN - WO - The filter text is not getting cleared when selecting a new work order task
14 May 2024 navbs1  Bug 64102: Cannot add todo task if there are multiple todo work order tasks
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
22 May 2025	navbs1	ChangeRequest 34819: MTN - Filtered Group Box Changes
*/

vars
	collection : ObjectSet;
begin
	inheritMethod(_headingName, _collection, _displayMethodName);
	
	self.parentCollectionLeft.clear();
	
	create collection transient;
	self.getAvailable(collection);
	collection.copyNoDuplicates(self.parentCollectionLeft, false);
	
	self.txtFilterBoxLeft.text := self.EmptyText;						// 13/04/2023	navcs2	Defect 57574
	self.txtFilterBoxLeft.hintText := self.FilterText;					// 13/04/2023	navcs2	Defect 57574
	self.txtFilterBoxLeft.hintForeColor := Grey;						// 13/04/2023	navcs2	Defect 57574
	
	self.txtFilterBoxRight.text := self.EmptyText;				//09.07.2024 navnk30 #64536 Task 64537
	self.txtFilterBoxRight.hintText := self.FilterText;			//09.07.2024 navnk30 #64536 Task 64537
	self.txtFilterBoxRight.hintForeColor := Grey;				//09.07.2024 navnk30 #64536 Task 64537
	
	self.myAvailableListBox.enabled := true;					//22.05.2025 navbs1 #34819
	
epilog
	delete collection;
end;</source>
        <Parameter name="_headingName" type="String"/>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_displayMethodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="showAvailable" id="32adcfae-1198-40b4-b619-93335385e893">
        <updating/>
        <source>showAvailable(pAvailable: Collection) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
08 Apr 2025	navlw1	JIRA-34583: Added a null check to itemStr and implement the exception handler
*/

vars
	obj			: Object;
	iter		: Iterator;
	itemStr		: String;
	exOccurred	: Boolean;
begin
	if pAvailable = null then
		return;
	endif;
	
	on Exception do self.form.listBoxLimitException( exception, self.mySelectedListBox, exOccurred);
	
	self.myAvailableListBox.clear;
	iter := pAvailable.createIterator();
	while (iter.next(obj)) do
		itemStr := self.displayEntry(obj);
		if itemStr = null then
			continue;
		endif;
		index := self.myAvailableListBox.addItem(itemStr);
		if exOccurred then
			break;
		endif;
		self.myAvailableListBox.itemObject[index] := obj;
	endwhile;

epilog

end;</source>
        <Parameter name="pAvailable" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="showSelected" id="fafe0e0e-7e48-4a3e-9b81-86ae1f2d1a52">
        <updating/>
        <source>showSelected(pSelected: Collection) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
15 Apr 2025	navlw1	JIRA-34580: Added a null check to itemStr and implement the exception handler

*/

vars
	obj			: Object;
	iter		: Iterator;
	exOccurred 	: Boolean;
	itemStr 	: String;
	index 		: Integer;
begin
	if pSelected = null then
		return;
	endif;
	
	on Exception do self.form.listBoxLimitException( exception, self.mySelectedListBox, exOccurred);
	
	self.mySelectedListBox.clear();
	iter := pSelected.createIterator();
	while (iter.next(obj)) do
		itemStr := self.displayEntry(obj);
		if itemStr = null then
			continue;
		endif;
		index := self.mySelectedListBox.addItem(itemStr);
		if exOccurred then
			break;
		endif;
		self.mySelectedListBox.itemObject[index] := obj;
		// self.mySelectedListBox.itemObject[self.mySelectedListBox.addItem(self.displayEntry(obj))] := obj;
	endwhile;
epilog

end;</source>
        <Parameter name="pSelected" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="86df722b-8794-4578-ac95-b3f371ec91f5">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
*/

vars

begin

	if eventTag = self.TimerConstant then	//09.07.2024 navnk30 #64536 Task 64537
		//self.filterAvailable();
		self.filterLeftListBox();		
		self.filterRightListBox();
	endif;

end;
</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
