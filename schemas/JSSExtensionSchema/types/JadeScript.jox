vars
	theColor	: CMDColor;
	
begin
	create theColor transient;
	
	if theColor.open() = 0 then
		write theColor.color;
	endif;
epilog
	delete theColor;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_CurrencyFormat" id="4f45ff03-f7b4-491b-9e95-db488d50aeeb">
        <source>cnwdad1_Test_CurrencyFormat();
// -----------------------------------------------------------------------------
// Created:		24 October 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	value		: Decimal[12,2];
	theFormat	: CurrencyFormat;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	value		:=	12345678.91 * -1;
	
	create theFormat transient;
	
	theFormat.defineCurrencyFormat(	2,			// Decimal places (zero will cause decimal rounding)
									".",		// Decimal separator
									"***",		// Thousands separator
									CurrencyFormat.PosCurrLeadingSymbol,
									CurrencyFormat.NegCurrLeadingSignSymbol,
									true,
									"$");
	
	write value;
	write value.userCurrencyFormat(theFormat);
epilog
	delete theFormat;
	
	write "Currency Format completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_DecimalWholeFrac" id="cef43922-c1b6-4763-8a2d-d4489b93a4ce">
        <source>cnwdad1_Test_DecimalWholeFrac();
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	value1		: Decimal[12,4];
	value2		: Decimal[12];
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	value1		:=	1234.5678;
	value2		:=	1234;
	
	write "1. Value: " &amp; value1.String;
	write "1. Whole value: " &amp; value1.jssWholeValue().String;
	write "1. Fraction Value: " &amp; value1.jssFractionValue().String;
	write "2. Value: " &amp; value2.String;
	write "2. Whole value: " &amp; value2.jssWholeValue().String;
	write "2. Fraction Value: " &amp; value2.jssFractionValue().String;
epilog
	write "Decimal fractions completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
