    <JadeMethod name="allMovementDirectionInts" id="5b114e9b-7115-4ce9-8faf-e5227edc9b6e">
        <options>4</options>
        <source>allMovementDirectionInts( _intArray : IntegerArray input ) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2021	navndl1	Initial creation	TFS 51528 - The conclusive list of all possible move directions for Location Activities.

*/

vars

begin

	_intArray.clear();
	
	_intArray.add( LocnActMoveDir_BargeToBarge );
	_intArray.add( LocnActMoveDir_BargeToRail );
	_intArray.add( LocnActMoveDir_BargeToRoad );
	_intArray.add( LocnActMoveDir_BargeToVessel );
	_intArray.add( LocnActMoveDir_BargeToYard );
	_intArray.add( LocnActMoveDir_RailToBarge );
	_intArray.add( LocnActMoveDir_RailToRail );
	_intArray.add( LocnActMoveDir_RailToRoad );
	_intArray.add( LocnActMoveDir_RailToVessel );
	_intArray.add( LocnActMoveDir_RailToYard );
	_intArray.add( LocnActMoveDir_RoadToBarge );
	_intArray.add( LocnActMoveDir_RoadToRail );
	_intArray.add( LocnActMoveDir_RoadToRoad );
	_intArray.add( LocnActMoveDir_RoadToVessel );
	_intArray.add( LocnActMoveDir_RoadToYard );
	_intArray.add( LocnActMoveDir_VesselToBarge );
	_intArray.add( LocnActMoveDir_VesselToRail );
	_intArray.add( LocnActMoveDir_VesselToRoad );
	_intArray.add( LocnActMoveDir_VesselToVessel );
	_intArray.add( LocnActMoveDir_VesselToYard );
	_intArray.add( LocnActMoveDir_YardToBarge );
	_intArray.add( LocnActMoveDir_YardToRail );
	_intArray.add( LocnActMoveDir_YardToRoad );
	_intArray.add( LocnActMoveDir_YardToVessel );
	_intArray.add( LocnActMoveDir_YardToYard );
	
epilog

end;</source>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="allMovementDirectionStrs" id="522aca7d-a207-4e50-87aa-295a456e07f0">
        <options>4</options>
        <source>allMovementDirectionStrs( _strArray : StringArray input ) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2021	navndl1	Initial creation	TFS 51528 - The conclusive list of all possible move directions for Location Activities.

*/

vars

begin

	
	_strArray.clear();
	
	_strArray.add( app.getErrorString(LocnActMoveStr_BargeToBarge) );
	_strArray.add( app.getErrorString(LocnActMoveStr_BargeToRail) );
	_strArray.add( app.getErrorString(LocnActMoveStr_BargeToRoad) );
	_strArray.add( app.getErrorString(LocnActMoveStr_BargeToVessel) );
	_strArray.add( app.getErrorString(LocnActMoveStr_BargeToYard) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RailToBarge) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RailToRail) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RailToRoad) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RailToVessel) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RailToYard) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RoadToBarge) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RoadToRail) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RoadToRoad) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RoadToVessel) );
	_strArray.add( app.getErrorString(LocnActMoveStr_RoadToYard) );
	_strArray.add( app.getErrorString(LocnActMoveStr_VesselToBarge) );
	_strArray.add( app.getErrorString(LocnActMoveStr_VesselToRail) );
	_strArray.add( app.getErrorString(LocnActMoveStr_VesselToRoad) );
	_strArray.add( app.getErrorString(LocnActMoveStr_VesselToVessel) );
	_strArray.add( app.getErrorString(LocnActMoveStr_VesselToYard) );
	_strArray.add( app.getErrorString(LocnActMoveStr_YardToBarge) );
	_strArray.add( app.getErrorString(LocnActMoveStr_YardToRail) );
	_strArray.add( app.getErrorString(LocnActMoveStr_YardToRoad) );
	_strArray.add( app.getErrorString(LocnActMoveStr_YardToVessel) );
	_strArray.add( app.getErrorString(LocnActMoveStr_YardToYard) );

	
epilog

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="allMovementDirectionsForYA" id="e7f545b9-b354-438e-87a2-4cbcfa113305">
        <options>4</options>
        <source>allMovementDirectionsForYA() : String typeMethod;
/*
Purpose:			

Date		Who		Reason
13JUL2021	NAVAB1	TFS 51515
*/


vars
	allstr : String;
begin
	
	allstr := app.getErrorString(LocnActMoveStr_BargeToBarge);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_BargeToRail);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_BargeToRoad);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_BargeToVessel);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_BargeToYard);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RailToBarge);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RailToRail);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RailToRoad);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RailToVessel);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RailToYard);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RoadToBarge);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RoadToRail);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RoadToRoad);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RoadToVessel);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_RoadToYard);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_VesselToBarge);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_VesselToRail);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_VesselToRoad);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_VesselToVessel);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_VesselToYard);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_YardToBarge);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_YardToRail);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_YardToRoad);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_YardToVessel);
	allstr := allstr &amp; ", " &amp; app.getErrorString(LocnActMoveStr_YardToYard);


	return allstr;
	
	
		
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
