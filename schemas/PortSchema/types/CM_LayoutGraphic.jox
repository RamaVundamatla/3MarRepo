    <JadeMethod name="validateForUpdate" id="e49a7b61-0a6c-42fd-b310-66dcd7fafc2b">
        <source>validateForUpdate(realLayoutGraphic: CM_LayoutGraphic);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
