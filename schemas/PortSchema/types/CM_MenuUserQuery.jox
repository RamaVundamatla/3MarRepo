    <JadeMethod name="setForCreateUserQuery" id="02aad27f-fa68-4372-aea7-244b22f38430">
        <updating/>
        <source>setForCreateUserQuery(_pxyQuery : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     17 April 2003		cnwth2	
//
// Purpose:     Has a two separate set for creates - method signature could not inherit
//				whilst being inclusive of all neccessary data.
//				Should call normal setFor create/update as well     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.setForUpdateUserQuery(_pxyQuery);

end;</source>
        <Parameter name="_pxyQuery" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateUserQuery" id="796201e1-956a-4921-bdcc-2517389b88f7">
        <updating/>
        <source>setForUpdateUserQuery(_pxyQuery : SelfType) updating;
/*

Purpose:		Has a two separate set for updates - method signature could not inherit
				whilst being inclusive of all neccessary data.
				Should call normal setFor create/update as well 

Parameters:			

Return Value:		

Date				Who		Reason
17 April 2003		cnwth2	Initial creation
21 March 2019		jlgzm1	TFS43705 selector query column organiser out of date

*/
vars
	pxyQueryLine,
	realQueryLine			: CM_SelectorCriteriaLine;
	realCriteriaHolder,
	pxyCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
begin
	self.heading 			:= _pxyQuery.heading;
	self.description 		:= _pxyQuery.description;
	self.queryMode			:= _pxyQuery.queryMode;
	self.userCodeCreated	:= _pxyQuery.userCodeCreated;

	self.allVisibleColumns.clear();
	_pxyQuery.allVisibleColumns.copy(self.allVisibleColumns);
	
	self.allCriteriaLineHolders.purge();
	foreach pxyCriteriaLineHolder in _pxyQuery.allCriteriaLineHolders do
		realCriteriaHolder := pxyCriteriaLineHolder.cloneSelf(false);
		self.allCriteriaLineHolders.add(realCriteriaHolder);
		realCriteriaHolder.setForUpdate(pxyCriteriaLineHolder);	
		
		foreach pxyQueryLine in pxyCriteriaLineHolder.allCriteriaLines do
			create realQueryLine persistent; 
			realQueryLine.setMyCriteriaLineHolder(realCriteriaHolder);
			realQueryLine.setForUpdate(pxyQueryLine);	
		endforeach;	
	endforeach;
		
end;</source>
        <Parameter name="_pxyQuery" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2aab57d4-6bb7-4549-90a9-4cdc6bc80d08">
        <updating/>
        <source>setProxy(_heading, 
		_description, 
		_userCode : String; 
		_cargoBOLType : Integer;
		_menuRoot : CM_MenuRootQuery;
		_terminal : CM_Terminal;
		_allVisibleColumns : StringArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 April 2003		cnwth2	Initial creation
21 March 2019		jlgzm1	TFS43705 selector query column organiser out of date

*/
vars

begin
	self.myTerminal				:= _terminal; //this may be null
	self.myMenuRoot				:= _menuRoot;
	self.heading 				:= _heading;
	self.description 			:= _description;
	self.userCodeCreated		:= _userCode;
	self.queryMode				:= _cargoBOLType;
	self.pictureStringIcon 		:= P16UserQuery;
	self.allVisibleColumns.clear();
	_allVisibleColumns.copy(self.allVisibleColumns);
	
end;
</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_cargoBOLType" type="Integer"/>
        <Parameter name="_menuRoot" type="CM_MenuRootQuery"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allVisibleColumns" type="StringArray"/>
    </JadeMethod>
