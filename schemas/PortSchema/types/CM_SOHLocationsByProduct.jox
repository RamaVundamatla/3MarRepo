<CollClass name="CM_SOHLocationsByProduct" id="149a5823-61e8-4d5a-b8a6-3e567a580d51">
    <memberType name="CM_SOHLocation"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="soh"/>
    <MemberKey>
        <property name="CM_SOHLocation::myProduct"/>
    </MemberKey>
    <JadeMethod name="getTotalTIs" id="2e43beda-19a5-470f-b76a-2d8624dab53b">
        <source>getTotalTIs():Integer;
// --------------------------------------------------------------------------------
// Created:		30 November 2005 by cnwdad1
//
// Purpose:		Returns the total count of TIs within all of the receiver's locations.
//
// Parameters:	None
//
// Returns:		The total number of TIs.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	locationObj		: CM_SOHLocation;
	tiCount			: Integer;
	
begin
	tiCount	:=	0;
	
	foreach locationObj in self do
		tiCount	:=	tiCount + locationObj.numTIs;
	endforeach;
	
	return tiCount;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
