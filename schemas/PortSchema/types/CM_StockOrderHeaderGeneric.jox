    <JadeMethod name="myConsignee" id="e7c1cd13-c01e-48ca-a715-4dc3cf1d1fe5">
        <methodInvocation>mapping</methodInvocation>
        <source>myConsignee(set: Boolean; _value: CM_ConsigneeConsignor io) mapping;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := app.myRoot.allConsigneeConsignors[self.consigneeCode];
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ConsigneeConsignor" usage="io"/>
    </JadeMethod>
