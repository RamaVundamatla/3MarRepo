    <JadeMethod name="getKeyStringForProperty" id="8e4afe29-5b65-4568-aa97-1dd413e87d47">
        <source>getKeyStringForProperty(_propName: String): String protected;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 31/07/2017	jlgdap1		TFS 5520 SSL Allow certain cash config options to be set in non-cash systems
vars

begin
	if _propName = CMIF_ConfigTerminal::mySelectorQueriesForRT.name then	// ccms 1593 16 April 2008	cnwvu1
		return SelectorQueriesForRT;
	elseif _propName = CMIF_ConfigTerminal::toDoTaskNoInfo.name then	//29 Jul 2011	NDL	Par 27003
		return DefNoInfoToDo;
	elseif _propName = CMIF_ConfigTerminal::myLocActVesselToRail.name then	//02 Jun 2021	NDl	TFS 51245
		return LocActVesselToRail;
	elseif _propName = CMIF_ConfigTerminal::myLocActRailToVessel.name then	//18 Jun 2021	NDL	TFS 51245
		return LocActRailToVessel;
	elseif _propName = CMIF_ConfigTerminal::myLocActYardToRail.name then	//18 Jun 2021	NDL	TFS 51245
		return LocActYardToRail;
	elseif _propName = CMIF_ConfigTerminal::myLocActRailToYard.name then	//18 Jun 2021	NDL	TFS 51245
		return LocActRailToYard;
	elseif _propName = CMIF_ConfigTerminal::cashReceiptReport.name then		// TFS 5520
		return GateCashReceiptReport;										// TFS 5520
	endif;
	return inheritMethod(_propName);
end;
</source>
        <access>protected</access>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
