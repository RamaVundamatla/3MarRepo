    <JadeMethod name="mouseLeave" id="ee09e773-e4e0-4c53-ab60-4a1210e70d05">
        <updating/>
        <source>mouseLeave(pict : Picture input) updating;

vars

begin
	inheritMethod(pict);
	if not isInPainter then //and canShowHotspot then
		self.pictureIndex := 0;
//		if myChild &lt;&gt; null then 
//			myChild.visible := true;
//		endif;	
	endif;
//	inheritMethod(pict);
end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="e28c65f1-3b26-4d28-8aad-529c93e6db1d">
        <updating/>
        <source>mouseMove(pict : Picture input; button : Integer; shift : Integer; x : Real; y : Real) updating;

vars

begin
	inheritMethod(pict,button,shift,x,y);
	if not isInPainter and self.pictureCount &gt; 0 then
		self.pictureIndex := 1;
//		if (isChild or pict.PictureLayout.myParent &lt;&gt; null) then 
//		pict.visible := false;
//		endif;	
	endif;
//	inheritMethod(pict,button,shift,x,y);
end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
