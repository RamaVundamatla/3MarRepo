    <JadeMethod name="doBaseFormCancel" id="495eaf19-0fd9-49f0-97f2-3dfede8f219a">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 November 2009 by cnwjo3
//
// Purpose:		Cancel any changes made and reload the table + listboxes.
//
vars

begin
	self.mode := self.ModeView;
	self.loadEntTable();	
	
	self.setupVoyageColorCodeSheet();
	
	self.setEditViewMode();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="fb1ccc4a-c8cb-45d7-8acb-2f055fa5f51e">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 November 2009 by cnwjo3
//
// Purpose:		This is where the saving occurs
//
vars

begin
	if self.currentSheet = self.shtConfigTerm then
		self.doSaveConfigTerm();
	elseif self.currentSheet = self.shtColorCoding then
		self.doSaveColourCoding();
	else
		//some how the self.currentSheet is null or a sheet we are not aware of.... adding new functionality?
		app.msgBox(app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.name,method.name,"self.currentSheet unknown"),"",0);
	endif;

	if self.selectedConfigRow &gt; 0 then
		tblConfigTerm.cnEcSetCellBackColor(self.selectedConfigRow, 1, self.backColor); // TFS 52235 2NOV2021 NAVLW1
	endif;
	
	self.mode := self.ModeView;
	self.setEditViewMode();		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doControlEvent" id="5e579088-9105-40f3-aec5-73ebdd5949e0">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 May 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	inheritMethod(_control);

	if _control = self.mulYACriteria.myAddAllBtn or
		_control = self.mulYACriteria.myAddSelectedBtn or
		_control = self.mulYACriteria.myRemoveAllBtn or
		_control = self.mulYACriteria.myRemoveSelectedBtn then
		self.setupCmbDefaultColour();
	endif;
epilog
	
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
