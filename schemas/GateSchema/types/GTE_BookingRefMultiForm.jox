    <JadeMethod name="setControlsForAddEdit" id="58a33bb0-b21a-469f-ba4f-f1ddac765bd0">
        <updating/>
        <source>setControlsForAddEdit() updating;
//-----------------------------------------------------------------------
//	Created:	13 June 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
/*

Date		Who		Reason
10 Jul 2008	cnwkpd1	PAR #17486 - Rework of tidy up of transients and interface

*/

vars
	assistant	: GTE_Assistant;
	tblLower 	: CM_BaseTable;
	blnMulti	: Boolean;
	multiRow : Integer;
	terminal : CM_Terminal;	
	entTableDef	: EntTableDef;
	entRow		: EntTableRow;
	defName		: String;
begin
	assistant := self.myAssistant.GTE_Assistant;
	terminal := self.myTerminal; //par17529 sept 2008

	self.clearEditControls; // dh 8/2/2008 moved below code to this method for reuse
	cmbConsignee.clear;
	
	self.doDeleteInterfaceBookingRef();		// PAR #17486 - ensure other transients are tidied up
//	if myInterfaceBookingRef = null then
	create myInterfaceBookingRef transient;
//	endif;
	myInterfaceBookingRef.setMyProxyBookingRef(myProxyObject.CM_BookingRef);
	
	self.setDefaultsFromObject(self.myProxyObject);

	tblMain.visible := true;
	blnMulti := myCurrentObject &lt;&gt; null and myCurrentObject.CM_BookingRef.isMultiItemBookingRef;
/*
	//05 Nov 2012	NDL	Par 29859
	if not (terminal.getConfig(AllowMultiBookingRef).Boolean 
	or blnMulti) then
		tblMain.hideRowByName(ETRow_MultiItem, false);
	else
		tblMain.showRowByName(ETRow_MultiItem, false);
	endif;
*/
	setControlsForMultiEdit(blnMulti);
	if blnMulti then
		tblLower := tblBRItems;
	else
		tblLower := tblExtra;
	endif;
	sptThumbEdit.showRightControl(30, true);
	assistant.mainExtraSplitterRatio(tblMain, tblLower, sptThumbEdit);
	assistant.mainExtraSyncColWidths(tblMain, tblExtra);
	tblMain.moveFirst();
	tblMain.setFocus();
	saveRowHeight := 0;
	
	defName := ETDef_BookRefThumb;
	entTableDef := app.myController.getEntTableDef(defName);
			
	if not app.myPassport.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
		// TFS 2155 37941 (see also 34920 which fixes this in showThumbnailData) this row is not always present
		entRow := entTableDef.getEntTableRow(ETRow_CutoffEarliestTS);
		if entRow &lt;&gt; null then
			self.tblThumb.hideRowFromHeading(entRow.getHeading(null, null, app.myCurrentLocale));
		endif;
		///self.tblThumb.hideRowFromHeading(entTableDef.getEntTableRow(ETRow_CutoffEarliestTS).getHeading(null, null, app.myCurrentLocale));	// original code
		self.tblMain.hideRowByName(ETRow_MyTranshipToPort, false);		
		self.tblData.hideColumnByColName(ETRow_MyTranshipToPort);
		self.tblExtra.showRowByName(ETRow_MyTranshipToPort, false);
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForMultiEdit" id="60f80034-cea9-41fa-bf85-bc90bb419b85">
        <updating/>
        <source>setControlsForMultiEdit(_isMulti : Boolean)updating;
/*
	Created on 08 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	interfaceBRItem : CMIF_BookingRefItem;
begin
	if _isMulti then
		self.frmToolbarItem.visible := true;
		tblBRItems.visible := true;
		tblBRItems.setMargins;
		tblExtra.visible := false;
		frmBRItems.top := frmToolbarItem.top + frmToolbarItem.height + 3;
		frmBRItems.height := frmDetailsBottom.height - 5 - frmToolbarItem.height ;
		frmBRItems.refresh;
	else
		tblExtra.visible := true;
		tblBRItems.visible := false;
		tblBRItems.clearAllSelected;
		self.frmToolbarItem.visible := false;
	endif;
//	setMultiChkEnablement;	//05 Nov 2012	NDL	Par 29859
end;</source>
        <Parameter name="_isMulti" type="Boolean"/>
    </JadeMethod>
