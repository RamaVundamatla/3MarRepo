<Class name="CMIF_InterfaceResponse" id="23db4120-94d9-4bc1-ba7f-751b39b73cfe">
    <superclass name="CMIF_InterfaceObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used by the CM_TCPInterfaceAgent.  One of these objects will be created for each line in the opuput message.
</text>
    <DbClassMap file="mobileServer"/>
    <CompAttribute name="allResponseFields" id="619cc71f-81c9-4337-be1c-14684537db5f">
        <type name="StringArray512"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="buildOutputResponseString" id="647e726c-1f5d-41a6-b42d-a367682aa69c">
        <source>buildOutputResponseString() : String;

/*

Purpose:			Generate an output response for the receiver, to be included in the output
					response string for its parent CMIF_InterfaceMsgController

Parameters:			None

Return Value:		String value representing the receiver response fields in CSV format (can be null 
					if there are no response fields


Date		Who		Reason
15 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
08 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Add in default response build (need to handle null first field)

*/

vars
	responseField,
	returnVal		: String;
	first			: Boolean;
	
begin
	first := true;
	foreach responseField in self.allResponseFields do
		if not first then					// PAR #18526
			returnVal := returnVal &amp; CNEC_COMMA;
		else
			first := false;
		endif;
		returnVal := returnVal &amp; responseField.csvFormat;
	endforeach;
	
	return returnVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
