    <JadeMethod name="getCapacityUsedDetails" id="761b8744-478a-46ff-b4e8-1f7f1845350a">
        <source>getCapacityUsedDetails(pCapacityPC, aCapacityPC : Integer io; pAmount, aAmount : Decimal io; capacityMax : Integer io) : String;
/*

Purpose:			TFS 49959

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2021	jlgab1	Initial creation

*/

vars

	actualArray, plannedArray: CM_TIArray; 

	ti : CM_TrackedItem;
	amountType : String;
begin

	capacityMax := self.getCurrentCapacity();

	if capacityMax = 0 then
		return "";
	endif;
	
	create actualArray transient;
	create plannedArray transient;
	
	self.getTIs(plannedArray, PLANNING_MODE, true);
	self.getTIs(actualArray, REAL_MODE, true);
	
	if self.isBulkLocation() then // TFS 51393 BISH 21JUN2021
		amountType := "BULKW"; // default to weight  // TFS 51393 BISH 21JUN2021
	else
		amountType := "NOTBULK";
	endif;
	
	// ### ACTUAL
	foreach ti in actualArray discreteLock do
		if self.isBulkLocation() then
			if ti.isBulkByWeight() then
				aAmount := aAmount + ti.totalWeight;
				amountType := "BULKW";

			elseif ti.isBulkByVolume() then
				aAmount := aAmount + ti.totalVolume;
				amountType := "BULKV";

			endif;
		else
			aAmount := aAmount + ti.totalQuantity;
		endif;
		
		
	endforeach;
	
	aCapacityPC := ((aAmount / capacityMax) * 100).Integer;
	
	// ### PLANNED
	foreach ti in plannedArray discreteLock do
		if self.isBulkLocation() then
			if ti.isBulkByWeight() then
				pAmount := pAmount + ti.totalWeight;
				amountType := "BULKW"; // TFS 51393 BISH 21JUN2021
			elseif ti.isBulkByVolume() then
				pAmount := pAmount + ti.totalVolume;
			endif;
		else
			pAmount := pAmount + ti.totalQuantity;
			amountType := "BULKV"; // TFS 51393 BISH 21JUN2021
		endif;
	endforeach;
	
	pCapacityPC := ((pAmount / capacityMax) * 100).Integer;
	
	return amountType;
epilog
	delete actualArray;
	delete plannedArray;

end;</source>
        <Parameter name="pCapacityPC" type="Integer" usage="io"/>
        <Parameter name="aCapacityPC" type="Integer" usage="io"/>
        <Parameter name="pAmount" type="Decimal" usage="io"/>
        <Parameter name="aAmount" type="Decimal" usage="io"/>
        <Parameter name="capacityMax" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCarCountForVoyage" id="68be9f3e-bcec-4456-bced-afe689682ba5">
        <source>getCarCountForVoyage(_voyageCode : String) :Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2017	jlger1	Initial creation 7931

*/

vars
	ti : CM_TrackedItem;
	count : Integer;
	iter   : Iterator;
begin
	iter := self.allTrackedItems.createIterator();
	while iter.next(ti) do
		if not ti.isCar then
			continue;
		endif;
		
		if (ti.voyageCode = _voyageCode or (ti.isTranshipExport and ti.importVoyageCode = _voyageCode )) then
			count := count + 1;
		endif;
	endwhile;
				
	return count;
epilog
	delete iter;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCargoDetail" id="efb8ef1b-bda9-467e-baae-f5c55a073d85">
        <source>getCargoDetail(_mode: Integer): String;
/*
Purpose:			
Date		Who		Reason
14 December 2011	cnwab1	Initial creation
*/

vars
	ti : CM_TrackedItem;
	itemDescs : StringArray;
	itemCount : IntegerArray;
	idx, idxSt, idxEnd : Integer;
	temp : String;
	coll : CM_TIArray;
begin

	create itemDescs transient;
	create itemCount transient;
	create coll transient;

	if _mode = ShpDisplayMode_Proposed then
		self.getProposedTIs(coll);
	else
		self.getTIs(coll,_mode,true);
	endif;
	foreach ti in coll discreteLock do
		temp := ti.getCargoDetails();
		
		idx := itemDescs.indexOf(temp);
		
		if idx = 0 then
			itemDescs.add(temp);
			idx := itemDescs.size;
			itemCount[idx] := 1;
		else
			itemCount[idx] := itemCount[idx] + 1;
		endif;
		
	endforeach;
	
	idxSt := 1;
	idxEnd := itemDescs.size;
	temp := null;
	
	foreach idx in idxSt to idxEnd do
		if temp = null then
			temp := itemCount[idx].String &amp; " x " &amp; itemDescs[idx];
		else
			temp := temp &amp; ", " &amp; itemCount[idx].String &amp; " x " &amp; itemDescs[idx];
		
		endif;
	endforeach;
	
	return temp;
epilog
	delete itemDescs;
	delete itemCount;
	delete coll;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
