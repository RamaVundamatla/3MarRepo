    <JadeMethod name="rel811_par30042" id="f8da9fe5-c159-4a39-afaa-d7b67a8d0592">
        <source>rel811_par30042();
/*
Date		Who		Reason
08 Aug 2012	cnwcs5	Initial creation - par 30042
*/
vars
	etAgent		: EntTableAgent;
	array 		: StringArray;
	terminal	: CM_Terminal;
begin
	app.initialize;
	
	create etAgent transient;
	create array transient;
	
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	array.add ("ETRow_EdiBookingEmailNoDelete");
	array.add ("ETDef_EDIConfig");
	
	etAgent.trxUpdateFromConstant(array);	
	
	// preserve existing behavior
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		terminal.setConfig (EdiBookingEmailNoDelete, true);
	endforeach;
	commitTransaction;
epilog
	delete etAgent;
	
	return;
	
	write EdiBookingEmailNoDelete;		// config constant
	write ETDef_EDIConfig;
	write ETRow_EdiBookingEmailNoDelete;
end;</source>
    </JadeMethod>
