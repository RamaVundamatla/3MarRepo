    <JadeMethod name="extractReports" id="cbc1b09d-21b6-4397-8d24-ae45cda41b26">
        <source>extractReports(_extractFolder,
			   _rwaName : String) : Boolean;

/*

Purpose:			Create the JRW report extract for all the required reports for a release.
					New reports or views need to be added to the releaseExtactsGetJRWDetails method

Parameters:			Server-relative target file directory, and the name of the rwa file to create

Return Value:		None


Date		Who		Reason
23 Feb 2010	cnwkpd1	Automate the release process

*/

vars
	views,
	templates,
	reports			: StringArray;
	unlFile			: File;
	name			: String;
	
begin
	self.log("Creating JRW Report Extract");
	
	create views transient;
	create templates transient;
	create reports transient;
	
	// 21/07/2023	navkc1	changed to typeMethod
	DEV_ReleaseExtractAgent@getJRWDetails(views, templates, reports);
	
	self.log("Selected " &amp; views.size.String &amp; " Views, " &amp;
			templates.size.String &amp; " Templates and " &amp;
			reports.size.String &amp; " Reports");
				
	create unlFile transient;
	unlFile.usePresentationFileSystem := false;
	unlFile.openOutput(_extractFolder &amp; _rwaName &amp; ".unl");
	
	foreach name in views do
		unlFile.writeLine("View " &amp; name);
	endforeach;
	
	foreach name in templates do
		unlFile.writeLine("Template " &amp; name);
	endforeach;
	
	foreach name in reports do
		unlFile.writeLine("Report " &amp; name);
	endforeach;
	
	unlFile.close();
	
	self.runJRWExtractCommand(_extractFolder &amp; _rwaName &amp; ".unl " &amp; _extractFolder &amp; _rwaName &amp; ".rwa");

	self.log("JRW Report Extract complete - check jadereportwriter.log for errors");								 
								 
	return true;
	
	
epilog
	delete views;
	delete templates;
	delete reports;
	delete unlFile;

end;</source>
        <Parameter name="_extractFolder" type="String"/>
        <Parameter name="_rwaName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="extractXSDs" id="ec4b23a1-5468-4766-9c2f-7f975ae35490">
        <source>extractXSDs(_extractDirectory : String) : Boolean;

/*

Purpose:			Extract the EDI XSD files monthly
					(This is a copy of the JadeScript:ediJMTInternalXSDCreate)

Parameters:			

Return Value:		


Date			Who		Reason
15 March 2018	jlgmd1	Initial creation

*/

vars
	ediData 				: CM_EDIData;
	ediFileTypeJMTXML 		: CM_EDIFileTypeXMLJMTInternal;
	cls 					: Class;
	coll 					: IntegerArray;
	xsdString 				: String;
	xml 					: JadeXMLDocument;
	ediControllerAgent 		: CM_EDIControllerAgent;
	ediConfig 				: CM_EDIConfig;
	xsdFileString,
	xsdFileAllString 		: String;
	idx 					: Integer;
	dir, dirSep				: String;
	folder					: FileFolder;
begin
	
	dir := _extractDirectory;
	dirSep := dir[dir.length-1:1];
	if dirSep &lt;&gt; "\" and dirSep &lt;&gt; "/" then
		dir := dir &amp; "\";
	endif;
	
	create folder transient;
	folder.fileName := dir;
	folder.usePresentationFileSystem := true;
	if not folder.isAvailable then
		self.log("**** Error, folder " &amp; dir &amp; " does not exist (or is inaccessible) ****");
		return false;
	endif;
	
	self.log("Extracting EDI XSD files to " &amp; dir);

	// Get any edi config
	ediConfig := app.myRoot.allTerminals["UT"].myEdiConfig;
	
	xsdFileAllString := '&lt;?xml version="1.0"?&gt;';
	xsdFileAllString := xsdFileAllString &amp; '&lt;xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified"&gt;';
	
	xsdFileAllString := xsdFileAllString &amp; '&lt;xs:element name="JMTInternalAll"&gt;';
    xsdFileAllString := xsdFileAllString &amp; '&lt;xs:complexType&gt;';
    xsdFileAllString := xsdFileAllString &amp; '&lt;xs:sequence&gt;';
	
	create coll transient;
	create ediControllerAgent transient;
 
	ediControllerAgent.getAllEDIDataTypeValues(coll, false);	

	foreach idx in coll do
		cls := ediConfig.getEDIDataClassForType(idx);
		if cls = CM_EDIDataGeneric or
		   cls = CM_EDIDataGenCSV or
		   cls = CM_EDIDataGenXML or
		   cls = null then 
			continue;
		endif;
		if cls.abstract	then
			continue;
		endif;

		self.log(Tab &amp; cls.name);
		
		delete ediData;
		create ediData as cls transient;
		ediFileTypeJMTXML := CM_EDIFileTypeXMLJMTInternal.firstInstance;
		
		xsdString := ediFileTypeJMTXML.getXSDDefinition(ediData);
		
		xsdFileString := '&lt;?xml version="1.0"?&gt;';
		xsdFileString := xsdFileString &amp; '&lt;xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified"&gt;';
	
		xsdFileString := xsdFileString &amp; xsdString;
		xsdFileString := xsdFileString &amp; '&lt;/xs:schema&gt;';
		
		delete xml;
		create xml transient;
		xml.parseString(xsdFileString);
		
		xml.outputDeclaration := true;
		xml.indentString := '  ';
		
		xml.writeToFile(dir &amp; ediData.getJMTInternalName()[12:end] &amp; '.xsd');
		
		xsdFileAllString := xsdFileAllString &amp; xsdString;
				
	endforeach;

    xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:sequence&gt;';
    xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:complexType&gt;';
	xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:element&gt;';

	xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:schema&gt;';

	self.log("Generating JMTInternalAll.xsd");
	
	delete xml;
	create xml transient;
	xml.parseString(xsdFileAllString);
	
	xml.outputDeclaration := true;
	xml.indentString := '  ';
	
	xml.writeToFile(dir &amp; 'JMTInternalAll.xsd');
	
	return true;
epilog
	delete ediData;
	delete coll;
	delete xml;
	delete ediControllerAgent;
end;
</source>
        <Parameter name="_extractDirectory" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
