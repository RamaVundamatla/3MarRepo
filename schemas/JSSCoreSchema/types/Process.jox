<Class name="Process">
    <JadeMethod name="jssEvaluate" id="e68ac3b8-9f46-45a3-b428-67d2308fe93b">
        <source>jssEvaluate(pExpression:String; pReturnType:Type; pTheReceiver:Object; pReturnValue:Any io):String;
// --------------------------------------------------------------------------------
// Created:		27 August 2001 by cnwdad1
//
// Purpose:		Evaluates an expression based upon JADE syntax.  The string to be
//				evaluated need only be expressed in simplistic terms, for example:
//
//					"(22/7) * 20 ^ 2"
//
//				...note that there is no need to append the expression with a
//				semi-colan (;).
//
//				Refer to the Process::cnEcExecute method for handling the execution
//				of full method source.
//
// Parameters:	None
//
// Returns:		The result of the evaluation is returned by the pReturnValue io
//				parameter.  The method itself will return a null value if the
//				expression is successfully evaluated, otherwise an error message
//				will be returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	methodObj		: JadeMethod;
	sourceCode		: String;
	errorCode		: Integer;
	errorPosition	: Integer;
	errorLength		: Integer;
	errorMessage	: String;

begin
	sourceCode	:=	"return " &amp; pExpression &amp; ";";
	methodObj	:=	process.createTransientMethod(	"evaluate",
													pTheReceiver.class(),
													currentSchema,
													sourceCode,
													true,
													pReturnType,
													errorCode,
													errorPosition,
													errorLength);
	
	if methodObj = null then
		errorMessage	:=	errorCode.String &amp;
							" - " &amp; process.getErrorText(errorCode) &amp;
							" (Position=" &amp; errorPosition.String &amp;
							":" &amp; errorLength.String &amp; ")";
		
		return errorMessage;
	else
		pReturnValue	:=	process.executeTransientMethod(methodObj, pTheReceiver);
		return null;
	endif;
epilog
	process.deleteTransientMethod(methodObj);
end;</source>
        <Parameter name="pExpression" type="String"/>
        <Parameter name="pReturnType" type="Type"/>
        <Parameter name="pTheReceiver" type="Object"/>
        <Parameter name="pReturnValue" type="Any" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
