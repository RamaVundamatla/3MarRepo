    <JadeMethod name="setRotateCloneLink" id="f9dd8a9b-3a9c-4b22-aaa1-390451627a39">
        <updating/>
        <source>setRotateCloneLink(_rotateDefn : CM_ROROLocnDefn input)  updating;
/*
Purpose:			
Date		Who		Reason
23 February 2012	cnwab1	Initial creation
*/

vars
	locn : CM_ROROLocnDefn;
begin
	if self.isRotatedLoadLayer() then
//	if self.myLayout.myDeckLayer.type = ROROLayerType_CCLoad then // I AM THE CLONE
		if _rotateDefn &lt;&gt; null then
			self.myRotateDischarge := _rotateDefn;
			self.hasBeenRotatedForLoad := true;
			_rotateDefn.hasBeenRotatedForLoad := true;

		else
			if self.myRotateDischarge &lt;&gt; null then
				self.myRotateDischarge.hasBeenRotatedForLoad := false;
				//self.hasBeenRotatedForLoad := false;		//cnwmc5 - 14 Oct 2014 - PAR 33972
				self.myRotateDischarge := null;
			endif;
		endif;
		
	else
		if _rotateDefn &lt;&gt; null then
			self.myRotateLoad := _rotateDefn;
			self.hasBeenRotatedForLoad := true;
			_rotateDefn.hasBeenRotatedForLoad := true;
		else
			if self.myRotateLoad &lt;&gt; null then
				//self.hasBeenRotatedForLoad := false;		//cnwmc5 - 14 Oct 2014 - PAR 33972
				self.myRotateLoad.hasBeenRotatedForLoad := false;
				self.myRotateLoad := null;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_rotateDefn" type="CM_ROROLocnDefn" usage="input"/>
    </JadeMethod>
