    <JadeMethod name="isRequestForMTs" id="90d09daa-5cb1-4112-b4bd-72a2a5ca82a8">
        <source>isRequestForMTs() : Boolean;

/*

Purpose:		Return whether request is for MTs	

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2010	cnwmh5	Initial creation #25169

*/

vars

	bulkRelease			: CM_BulkRelease;
	tmpCommodity		: CM_Commodity;
	gteEntity : CMGTE_Entity;	//19 Feb 2014	NDL	Par 33524

	emptyReleaseRequest	: Boolean;
	
begin
	
	if self.isDeliveryRequest then
		gteEntity := self.myDeliveryRequest.myGateEntity;	//19 Feb 2014	NDL	Par 33524
		bulkRelease := self.myDeliveryRequest.myOriginatingBulkRelease;
		if gteEntity &lt;&gt; null and gteEntity.isKindOf(CMGTE_Release) then	//19 Feb 2014	NDL	Par 33524
			emptyReleaseRequest := gteEntity.CMGTE_Release.mtOnly;
		elseif bulkRelease &lt;&gt; null then
			emptyReleaseRequest := not bulkRelease.fullRelease;
		else	
			bulkRelease := self.myDeliveryRequest.bulkRelease;
			if bulkRelease &lt;&gt; null then
				emptyReleaseRequest := not bulkRelease.fullRelease;
			endif;	
		endif;
		
	elseif self.myCommodity &lt;&gt; null then
		tmpCommodity := app.myRoot.allCommodities[self.myCommodity.code];
		if tmpCommodity.isEmpty then
			emptyReleaseRequest := true;
		endif;
	endif;

	return emptyReleaseRequest;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRequiresPower_Match" id="c6499e50-fb0b-4130-a60f-6fb9ee13e9d2">
