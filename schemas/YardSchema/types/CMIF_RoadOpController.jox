    <JadeMethod name="doTiled" id="55862bf1-081e-40f6-adf8-cb0188c5f22f">
        <source>doTiled()protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 July 2006	cnwer1	Initial creation - PAR#xxxx

*/


vars
	num,
	h,v , i, j, k,
	dbWidth,  dbLeft,row : Integer;
	x,y , rem 	: Real;
	obj		: Object; 
	dockBar 	: JadeDockBar;
	parentContainer : JadeDockContainer;
	offset		: Integer;
	areaHeight   : Integer;
begin
	parentContainer:=self.myBaseDockContainer;
	areaHeight:= ((parentContainer.parent.height * self.dockAreaHeightPCent)/100).Integer;
	k:=1;
	row:=1;
	foreach i in self.dockTilePlan do
		j:=0;
		while j &lt; i do	
			if row &gt; allDockContainers.size then
				parentContainer:=self.myBaseDockContainer.loadControl(row).JadeDockContainer;		
				self.allDockContainers.add(parentContainer);
			else
				parentContainer:=allDockContainers[row].JadeDockContainer;
			endif;
			dockBar:=allDockBars[k].JadeDockBar;
			dockBar.parent:=parentContainer;
			if tiled then
				dockBar.alignContainer:=JadeDockBase.AlignContainer_AllVertical;
			else
				dockBar.alignContainer:=JadeDockBase.AlignContainer_AllHorizontal;
			endif;
			k:=k+1;
			j:=j+1;
		endwhile;
		row:=row + 1;
	endforeach;
	

	
	
		

epilog


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findCMIF_RoadOpObjWithTable" id="5bd69374-b973-481e-9e8b-a21bba8a05c3">
        <source>findCMIF_RoadOpObjWithTable(_table : CM_DataTable) : CMIF_RoadOpObject;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	cmif_RoadOpObj : CMIF_RoadOpObject;
begin
	foreach cmif_RoadOpObj in self.allCMIFRoadOpObjects discreteLock do
		if cmif_RoadOpObj.myDataTable = _table then
			return cmif_RoadOpObj;
		endif;		
	endforeach;

	return null;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <ReturnType type="CMIF_RoadOpObject"/>
    </JadeMethod>
    <JadeMethod name="findCMIF_RoadOpObjWithVehicle" id="19398602-d9d1-4191-9b5a-46bd7924e492">
        <source>findCMIF_RoadOpObjWithVehicle(_vehicle: CM_Vehicle input) : CMIF_RoadOpObject;
/*
Date		Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	cmif_RoadOpObj : CMIF_RoadOpObject;

begin
	foreach cmif_RoadOpObj in self.allCMIFRoadOpObjects do
		if cmif_RoadOpObj.allVehicles.indexOf(_vehicle) &lt;&gt; 0 then
			return cmif_RoadOpObj;
		endif;
	endforeach;

	return null;
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <ReturnType type="CMIF_RoadOpObject"/>
    </JadeMethod>
    <JadeMethod name="findCMIF_RoadOpObjWithWLE" id="0c5e14a4-f2b7-41de-8c8d-ec78335d1fac">
        <source>findCMIF_RoadOpObjWithWLE(_wle : CM_WorkListEntry input) : CMIF_RoadOpObject;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	cmif_RoadOpObj : CMIF_RoadOpObject;
begin

	foreach cmif_RoadOpObj in self.allCMIFRoadOpObjects do
		if cmif_RoadOpObj.allWLEs.indexOf(_wle) &gt; 0 then
			return cmif_RoadOpObj;
		endif;
