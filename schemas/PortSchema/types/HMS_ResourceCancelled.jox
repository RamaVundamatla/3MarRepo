<Class name="HMS_ResourceCancelled" id="2171a8ef-ba7b-44cf-a040-2c1f900f4294">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <ImplicitInverseRef name="myResource" id="d8ab3ece-b580-42de-beb9-6b13db8b4be2">
        <embedded/>
        <type name="HMS_Resource"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myResourceUsedArchived" id="b95683e0-d01a-4a0a-bc8c-7e314fcec1d8">
        <embedded/>
        <type name="HMS_ResourceUsed"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createPropertyChanges" id="4225925c-94a6-4f3b-bf7b-8cd969ecad2f">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	propertyChange:	HMS_PropertyChange;
begin
	inheritMethod(_cmifTrans);

	create propertyChange;
	if self.myResource &lt;&gt; null then
	   	propertyChange.set(self, self.myResource.myResourceType.description &amp; ": " &amp; self.myResource.description, "Booked", "Cancelled");
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setGeneralProperties" id="389d7bad-7ae4-4b6d-b808-473fb4a4ca7c">
        <updating/>
        <source>setGeneralProperties(_transController: CMIF_HMS_TransactionController; _passport: CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_transController, _passport);
	self.myResource := _transController.myResource;
end;</source>
        <access>protected</access>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="b005717d-da8a-4395-b256-04630f64c4d6">
        <updating/>
        <source>setTypeDetails() updating, protected;

vars

begin
  	// Set type and typeString
	type:=TRANS_TYPE_ResourceCancelled;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="ba0c04e5-5cc8-4556-bb79-bca32018b7f6">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myVoyageMovement = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Movement', 'Null', null, null);
		return false;
	endif;	

	if _transController.myResource = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Resource', 'Null', null, null);
		return false;
	endif;
	return rtnValue;			
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
