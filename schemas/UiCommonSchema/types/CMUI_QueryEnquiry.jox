    <JadeMethod name="keyDown" id="2bde5f78-5e43-4188-9cb4-9e7c1f2a39f7">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2003	cnwth2
// ----------   ----------  --------------------------------------------------
// 16/10/2012	cnwcs5	par 30483 - check if using query frame
vars

begin 
	if keyCode = CMUI_Key_F3 then
		if not self.usesQueryFrame then
			return;
		endif;
		
		if not self.frmQuery.visible then 
			self.doShowSearcherClick();
		else 
			self.doHideSearcherClick();
		endif;
	else
		inheritMethod(keyCode, shift);
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
