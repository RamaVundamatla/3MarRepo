    <JadeMethod name="addCustomersTopics" id="caac9de9-9573-4fd8-95a4-adef319af5cb">
        <source>addCustomersTopics();

// TFS 38497 jlgmd1 12/10/2018 - Update list of customers/topics
// TFS 52293 navdap1	09/12/2021 - Added APMT Salalah
// navmd1 29/03/2024 Added Cuxport
// navdap1 14/06/2024 Added Euroports
vars

begin
	self.cmb_Customer.clear();
	self.cmb_Customer.addItem('Abu Dhabi Ports Company');
	self.cmb_Customer.addItem('Alabama State Port Authority');			// TFS 38497
	self.cmb_Customer.addItem('Alabama Steel');
	//self.cmb_Customer.addItem('APM Terminals Poti');					// TFS 38497
	self.cmb_Customer.addItem('APMT Salalah');						// TFS 52293
	self.cmb_Customer.addItem('Australian Amalgamated Terminals');		// TFS 38497
	self.cmb_Customer.addItem("Borouge");								// TFS 38497
	self.cmb_Customer.addItem('C3 Limited');
	self.cmb_Customer.addItem('CentrePort Wellington');
	self.cmb_Customer.addItem('CICE Group - Veracruz');
	self.cmb_Customer.addItem('Cuxport GmbH');
