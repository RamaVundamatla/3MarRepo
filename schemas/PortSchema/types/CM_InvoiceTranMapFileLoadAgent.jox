    <JadeMethod name="findMethodKey" id="6f87fa31-fd76-4ca6-a6ef-12ea48b46db5">
        <updating/>
        <source>findMethodKey(_proxyQuantityRangeMap : CM_QuantityRangeMap) : Integer updating, protected;
// 34477 return the integer key for the methods used, to search on
vars
	i	: Integer;
	key	: Integer;
	methodIdx	: Integer;
	size	: Integer;
	methodFlag,
	methodName	: String;
begin
	size := self.currentMethods.size;
	i := 0;
	foreach methodFlag in self.currentMethods do
		i := i + 1;
		if methodFlag &lt;&gt; null then
			methodName := self.fullMethodNames[i];
			methodIdx := self.getMethodIndex(methodName, _proxyQuantityRangeMap);
			if methodIdx &lt;&gt; 0 then	// safety check
				key := key.bitOr(2^(methodIdx-1));
			endif;
		endif;
	endforeach;

	return key;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyQuantityRangeMap" type="CM_QuantityRangeMap"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
