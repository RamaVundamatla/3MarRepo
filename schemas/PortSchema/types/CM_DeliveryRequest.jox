    <JadeMethod name="addWLE" id="f3050fbb-1b1d-47f7-9cdf-7e7c3196cea0">
        <updating/>
        <source>addWLE(_qty : Integer) updating;
//--------------------------------------------------
// Created:	24 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.totalRequested := self.totalRequested + _qty;
	self.createWLEs();
end;</source>
        <Parameter name="_qty" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildQueryToMatchDetails" id="3b237cf8-730e-40be-a559-881749219958">
        <source>buildQueryToMatchDetails(	_userQuery : CM_MenuUserQuery io; _criteriaLineHolder : CM_QueryCriteriaLineHolder io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2012	cnwndl1	Initial creation	Par 28953

*/

vars

	transQueryLine : CM_SelectorCriteriaLine;
	transProperty : CM_QueryProperty;
	transOperator : CM_QueryOperator;
	objSet : ObjectSet;
	className : String;
	
	term : CM_Terminal;
	subTerminal : CM_SubTerminal;
	imexs : IntegerArray;

begin

	create objSet transient;

	_userQuery.setPropertyValue( "queryMode", 1);

	if self.myCargoType &lt;&gt; null then
		if self.myCargoType.id = 1 then
			className := "CM_Container";
		endif;
	endif;
	if className = null then
		className := "CM_TrackedItem";
		_userQuery.setPropertyValue( "queryMode", 0);	//07 Aug 2015	NDL	 found and fixed during testing
	endif;

	//	Add Site criteria line
	create transQueryLine transient; 
	transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
	
	create transProperty as CM_QTiSiteLookupProperty transient;
	transProperty.set(	"Site",	//_niceName : String
						CM_TrackedItem::site.name,	//_propName : String
						className	//_className : String
						);
	transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create transOperator as CM_QIntegerLookupEqual transient;
	transOperator.setSearchValue( TI_SITE_ONSITE );
	
	transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										transProperty,	//_myQueryProperty : CM_QueryProperty;
										transOperator,	//_myQueryOperator : CM_QueryOperator;
										transProperty.propertyName,	//_propName : String;
										transProperty.propertyClassName	//_propClassName : String
										);
											
	
	//	Add Terminal criteria line
	if self.myTerminal &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QRefTerminalProperty transient;
		transProperty.set(	"Terminal",	//_niceName : String
							"myTerminal",	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QReferenceLookup transient;
		transOperator.setSearchValue( self.myTerminal );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.mySubTerminalSource &lt;&gt; null then
	
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QRefSubTerminalProperty transient;
		transProperty.set(	"Sub-Terminal",	//_niceName : String
							CM_TrackedItem::mySubTerminal.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QReferenceLookup transient;
		transOperator.setSearchValue( self.mySubTerminalSource );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	
	create transQueryLine transient; 
	transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
	
	create transProperty as CM_QImExStatusProperty transient;
	transProperty.set(	"Import/Export Status",	//_niceName : String
						CM_TrackedItem::imexStatus.name,	//_propName : String
						className	//_className : String
						);
	transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create imexs transient;
	imexs.add( imexStatus );
	
	create transOperator as CM_QIntegerIsOneOf transient;
	transOperator.setSearchValue( imexs );
	
	transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										transProperty,	//_myQueryProperty : CM_QueryProperty;
										transOperator,	//_myQueryOperator : CM_QueryOperator;
										transProperty.propertyName,	//_propName : String;
										transProperty.propertyClassName	//_propClassName : String
										);
	
	
										
	if not self.allTerminalAreas.isEmpty then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QRefTerminalAreaProperty transient;
		transProperty.set(	"Terminal Area",	//_niceName : String
							CM_TrackedItem::myTerminalArea.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		objSet.clear();
		self.allTerminalAreas.copyNoDupsNoTransaction( objSet );
		create transOperator as CM_QReferenceIsOneOf transient;
		transOperator.setSearchValue( objSet );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.myCargoType &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QCargoTypeLookupProperty transient;
		transProperty.set(	"Cargo Type",	//_niceName : String
							CM_TrackedItem::cargoType.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QIntegerLookupEqual transient;
		transOperator.setSearchValue( self.myCargoType.id );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.isoGroup.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrISOGroupProperty transient;
		transProperty.set(	"ISO Type Group",	//_niceName : String
							CM_Container::isoGroup.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.isoGroup );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.isoType.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrISOTypeProperty transient;
		transProperty.set(	"ISO Type",	//_niceName : String
							CM_Container::isoType.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.isoType );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.mySubCargoType &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QRefProductProperty transient;
		transProperty.set(	"Cargo Subtype",	//_niceName : String
							CM_TrackedItem::myProduct.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QReferenceIsOneOf transient;
		transOperator.setSearchValue( self.mySubCargoType );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	
	if not self.allAvailabilityGrades.isEmpty then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QAvailabilityGradeProperty transient;
		transProperty.set(	"Availability Grade",	//_niceName : String
							CM_Container::availabilityGrade.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QIntegerIsOneOf transient;
		transOperator.setSearchValue( self.allAvailabilityGrades );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.clean then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QBooleanProperty transient;
		transProperty.set(	"Is Clean",	//_niceName : String
							CM_Container::isClean.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QueryBooleanOperator transient;
		transOperator.setSearchValue( true );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.heavyRated then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QBooleanProperty transient;
		transProperty.set(	"Is Heavy Duty",	//_niceName : String
							CM_Container::isHeavyDuty.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QueryBooleanOperator transient;
		transOperator.setSearchValue( true );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.billOfLading.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStringProperty transient;
		transProperty.set(	"Bill Of Lading",	//_niceName : String
							CM_TrackedItem::billOfLading.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringEquals transient;
		transOperator.setSearchValue( self.billOfLading );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.voyageCode.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrVoyageProperty transient;
		transProperty.set(	"Voyage",	//_niceName : String
							CM_TrackedItem::voyageCode.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.voyageCode );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.operatorCode.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrOperatorProperty transient;
		transProperty.set(	"Operator",	//_niceName : String
							CM_TrackedItem::operatorCode.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.operatorCode );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif; 
	
	if self.consignee.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrConsignProperty transient;
		transProperty.CM_QStrConsignProperty.type := CONSIGNEE;
		transProperty.set(	"Consignee",	//_niceName : String
							CM_TrackedItem::consignee.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.consignee );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.freightForwarderCode.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrConsignProperty transient;
		transProperty.CM_QStrConsignProperty.type := FREIGHT_FORWARDER;
		transProperty.set(	"Freight Forwarder",	//_niceName : String
							CM_TrackedItem::freightForwarderCode.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.freightForwarderCode );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;

	
	

epilog

	delete imexs;
	delete objSet;
	
end;</source>
        <Parameter name="_userQuery" type="CM_MenuUserQuery" usage="io"/>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
    </JadeMethod>
