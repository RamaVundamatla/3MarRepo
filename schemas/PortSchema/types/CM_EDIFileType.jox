    <JadeMethod name="addFileErrors" id="4c789fc7-ef29-4d4b-856b-dfbd2a3ba3d4">
        <source>addFileErrors(_error: String; _msgNum: Integer; _errObject: Object);

vars
	ediError:CM_Error;
begin
	create ediError transient;
	ediError.set(0, _error, false, _msgNum.String, _errObject, null);
	ediError.setMyErrorPassport(app.myPassport);
	//ediError.setMyWarningPassport(app.myPassport);
	
end;</source>
