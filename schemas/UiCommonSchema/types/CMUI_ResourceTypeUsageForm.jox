    <JadeMethod name="setLblUnitsCaption" id="bcfad5c7-4246-46ce-8f41-9dcd410290ab">
        <source>setLblUnitsCaption( _decPlaces : Integer );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29/12/2009	cnwndl1	Initial creation	CCMS MES 1006
06/04/2020	jlgdap1	TFS 48977 STWO Unable to add enough digits for to do task resource
*/

vars

	type : CM_ResourceType;

begin

	if self.cmbResourceType.listIndex &gt; 0 then
		type := self.cmbResourceType.itemObject[cmbResourceType.listIndex].CM_ResourceType;
	endif;
	
	// clear before setting length, so it can never be too long
	self.txtUnits.decimals := 0;
	//self.txtUnits.maxLength := _decPlaces + 5;		// TFS 48977
	self.txtUnits.maxLength := _decPlaces + 9;			// TFS 48977 - quantity field on CM_ResourceTypeUsage is 12.4, so allow for that here
	if _decPlaces = null then							// TFS 48977
		self.txtUnits.maxLength := _decPlaces + 8;		// TFS 48977
	endif;												// TFS 48977
	self.txtUnits.decimals := _decPlaces;
	
	if type &lt;&gt; null then
		self.lblUnits.caption := type.unitDescription &amp; ":";
	else
		self.lblUnits.caption := app.getErrorString(Units) &amp; ":";
	endif;
	
epilog

end;</source>
        <Parameter name="_decPlaces" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyToDoTransaction" id="e6ffba18-50e7-4fb1-aa63-b7eceb0f90ec">
        <updating/>
        <source>setMyToDoTransaction( _transaction : CM_Transaction; _toDoTaskDesc : CM_ToDoTaskDesc ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 December 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks

*/


vars
	usage : CM_ResourceTypeUsage;
	proxy : CM_ResourceTypeUsage;
begin

	if _transaction &lt;&gt; null then
		self.myToDoTransaction := _transaction;
		//foreach usage in self.myTransaction.allResourceUsages do //24/05/2023  navmv20 CR 57925 Task 57921
		foreach usage in self.myToDoTransaction.allResourceUsages do //24/05/2023  navmv20 CR 57925 Task 57921
			beginLoad;
			proxy := usage.pxyCreateUpdateProxy();
			endLoad;
			self.allProxyResourceTypeUsages.add(proxy);
		endforeach;
	else
		self.myToDoTaskDesc := _toDoTaskDesc;
	endif;
	
epilog
	endLoad;				
end;</source>
        <Parameter name="_transaction" type="CM_Transaction"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="setMyTransaction" id="bc5076b6-6c07-42e1-832e-52d0032b1668">
        <updating/>
        <source>setMyTransaction( _transaction : CM_TITransaction; _toDoTaskDesc : CM_ToDoTaskDesc; _ti : CM_TrackedItem ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars

	usage : CM_ResourceTypeUsage;
	proxy : CM_ResourceTypeUsage;
	
begin

	if _transaction &lt;&gt; null then
		self.myTransaction := _transaction;
		// ### TFS DEFECT 65483 01AUG2024 NAVAB1
		self.myTrackedItem := _ti;
		if _ti = null then
			self.myTrackedItem := _transaction.myTrackedItem;
		endif;
		foreach usage in self.myTransaction.allResourceUsages do
			beginLoad;
			proxy := usage.pxyCreateUpdateProxy();
			endLoad;
			allProxyResourceTypeUsages.add(proxy);
		endforeach;
	else
		self.myToDoTaskDesc := _toDoTaskDesc;
		self.myTrackedItem := _ti;
	endif;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
