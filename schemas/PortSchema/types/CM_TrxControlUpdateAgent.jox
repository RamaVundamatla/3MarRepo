    <JadeMethod name="trxUpdateConfigFromString" id="64dfb8f4-0b1f-4706-bac4-7cafb80d3cff">
        <updating/>
        <source>trxUpdateConfigFromString(	_term : CM_Terminal;
							_cmif : CMIF_ConfigOptionsDisplay input;
							_newValue : String;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	if _cmif = null then
		return;
	endif;
	if _cmif.appliesToTerm then
		app.myUtilityUA.utlUpdateTermConfigFromString( _cmif, _term, _newValue, _passport);
	else
		app.myUtilityUA.utlUpdateRootConfigFromString( _cmif, _newValue, _passport);
	endif;
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
