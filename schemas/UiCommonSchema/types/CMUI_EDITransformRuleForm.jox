        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="8340e816-9340-4c62-a74a-b367b5d02fb6">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation

*/

vars
	pxy : CM_EDITransformRule;
	result : Integer;
	allIgnoreKeyords : StringArray;
	i : Integer;
	keyword : String;
begin

	create allIgnoreKeyords transient;
	i:=1;
	while i &lt;= self.lstKeywords.listCount do
		keyword:= self.lstKeywords.itemText[i];
		if keyword &lt;&gt; null then
			allIgnoreKeyords.add(keyword);
		endif;
		i:=i+1;
	endwhile;

	beginLoad;
	pxy:=self.myEDITransformRule.pxyCreateUpdateProxy;
	endLoad;
	pxy.setProxy(self.chkSpacesRemoved.value,self.chkNonAlphaRemoved.value,self.txtRemoveCharExpression.text,allIgnoreKeyords);

	while true do 

		app.myTrxUA.trxUpdateEDITransformRule( pxy, app.myPassport );
		if app.myPassport.trxCompletedOK then
			break;
		else
			 result:= app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
	endwhile; 
	
	if app.myPassport.trxCompletedOK then
		inheritMethod;
	endif;
epilog
	endLoad;
	delete pxy;
	delete allIgnoreKeyords;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstKeywords_click" id="e02b17cb-cb18-4e69-8108-f9f25b600319">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstKeywords_click(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation

*/

vars

begin
	self.txtKeyword.text:=lstKeywords.itemText[lstKeywords.listIndex];
	if lstKeywords.itemText[lstKeywords.listIndex] = null then
		self.btnAddKW.visible:=true;
		self.btnRemoveKW.visible:=false;
		self.btnUpdateKW.visible:=false;
	else
		self.btnRemoveKW.visible:=true;
		self.btnUpdateKW.visible:=true;
		self.btnAddKW.visible:=false;
	endif;
	
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyEDITransformRule" id="a968fe03-c0e7-4761-907a-d1e26deb1649">
        <updating/>
        <source>setMyEDITransformRule(_transformRule : CM_EDITransformRule input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation

*/

vars

begin
	self.myEDITransformRule:=_transformRule;
epilog

end;</source>
        <Parameter name="_transformRule" type="CM_EDITransformRule" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="da1cf8a1-2d52-438f-b05d-8e7b75a02719">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation

*/

vars
	keyword : String;
begin
	inheritMethod();
	
	self.chkNonAlphaRemoved.value:=self.myEDITransformRule.nonAlphaNumericCharsRemoved;
	self.chkSpacesRemoved.value:=self.myEDITransformRule.multipleSpacesTrimmed;
	self.lstKeywords.sorted:=true;
	self.btnUpdateKW.visible:=false;
	self.btnRemoveKW.visible:=false;
	self.lstKeywords.addItem(null);
	foreach keyword in self.myEDITransformRule.allIgnoredKeywords do
		self.lstKeywords.addItem(keyword);
	endforeach;
	
	self.txtRemoveCharExpression.text:=self.myEDITransformRule.removedCharsExpression;
	if self.txtRemoveCharExpression.text = null then
		self.txtRemoveCharExpression.text:=CM_EDITransformRule.DefaultRemoveCharsExpression;
	endif;
	

	self.lblRemoveCharPattern.visible:=self.chkNonAlphaRemoved.value;
	self.txtRemoveCharExpression.visible:=self.chkNonAlphaRemoved.value;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4388dc1e-9663-4ef9-b148-19cad761ef10">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 September 2023 10:08:03.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025382, locale);
	btnAddKW.translateCaption(Xlat_0025383, locale);
	btnRemoveKW.translateCaption(Xlat_0025384, locale);
	btnUpdateKW.translateCaption(Xlat_0025385, locale);
	chkNonAlphaRemoved.translateCaption(Xlat_0025386, locale);
	chkSpacesRemoved.translateCaption(Xlat_0025387, locale);
	grpKeywords.translateCaption(Xlat_0025388, locale);
	lblRemoveCharPattern.translateCaption(Xlat_0025389, locale);
end;</source>
    </JadeMethod>
</GUIClass>
