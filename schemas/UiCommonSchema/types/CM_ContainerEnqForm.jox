    <JadeMethod name="doMnuSetGradeClick" id="93369c4a-190b-45ff-af6b-01f6b4700fc6">
        <updating/>
        <source>doMnuSetGradeClick(_grade: CM_MTGrade; _menuItem: MenuItem input) updating;
//-----------------------------------------
// Created: 8 October 2003 By: cnwgd1
//19 Aug 2013	cnwer1	PAR 32261 - add AV grade to CM_TILCs
//-----------------------------------------
vars
	cargo 	: CM_TrackedItem;
	tmpObj 		: Object;
	tmpGrade	: Integer;
	allTis  	: ObjectArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if _grade = null then
		return;
	endif;
	
	create allTis transient;
	if self.tblData.visible then
		self.tblData.allSelectedObjects.copy(allTis);
	else
		if self.myCurrentObject = null then
			return;
		endif;
		allTis.add(self.myCurrentObject);
	endif;
	

	foreach tmpObj in allTis do
		cargo := tmpObj.CM_TrackedItem;
		
		if cargo = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'current object is null');
			return;
		endif;
		
		tmpGrade := cargo.getAvailabilityGrade;
		
		if _grade.code = tmpGrade then
			// already set.
			return;
		endif;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateTIAvailabilityGrade(cargo, _grade.code, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Set Grade', app.myPassport, ErrWarnMode_Add);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endforeach;
	
	_menuItem.checked := not _menuItem.checked;	
	
epilog
	delete allTis;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_grade" type="CM_MTGrade"/>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
