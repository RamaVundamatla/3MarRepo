    <JadeMethod name="updateBayOrdinalValue" id="8174bc5f-5664-4c04-9dbf-251213c9b51b">
        <source>updateBayOrdinalValue();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Nov 2025 navhl20 Bug MTN-36270: MSL - The system not shows all the active cranes on the VOy Side Profile window

*/

vars
	voyage			: CM_Voyage;
	vessel			: CM_Vessel;
	voyStructure	: CM_CellularVoyageStructure;
	vesStructure	: CM_CellularVesselStructure;
	bayVoyage		: CM_BayVoyage;
	bayOrdinal		: Integer;
	bayDefn			: CM_BayDefn;
	//lFile      		: File;
begin
	vessel := "4477.806".asOid.CM_Vessel;
	
	/*create lFile transient;
	lFile.fileName := "C:\TEMP\vsessel and voyage details.csv";
    lFile.open;
	
	lFile.writeLine( 	  'VesselOID'			 			&amp; Comma &amp;
						  'VesselID'			 			&amp; Comma &amp;
						  'VesselStructureOID'				&amp; Comma &amp;
						  'BayDefOid'						&amp; Comma &amp;
						  'OldBayOrdinal'					&amp; Comma &amp;
						  'NewOrdinalBay'					&amp; Comma &amp;
						  'VoyageOid'						&amp; Comma &amp;
						  'Voyageid'						&amp; Comma &amp;
						  'voyStructureOid'					&amp; Comma &amp;
						  'bayVoyageOid'					&amp; Comma &amp;
						  'OldBayOdinal'                    &amp; Comma &amp;
						  'NewBayOrdinal');*/
	
	vesStructure := vessel.myCellularVesselStructure;
	
	bayOrdinal := 0;
	foreach bayDefn in vesStructure.allBaysByOrdinal do
		bayOrdinal := bayOrdinal + 1;
		if bayOrdinal &lt;&gt; bayDefn.ordinalBay then
			beginTransaction;
			bayDefn.setOrdinalBay(bayOrdinal);
			commitTransaction;
			/*lFile.writeLine( vessel.getOidString			&amp; Comma &amp;
						  vessel.code						&amp; Comma &amp;
						  vesStructure.getOidAsString 		&amp; Comma &amp;
						  bayDefn.getOidAsString			&amp; Comma &amp;
						  bayDefn.ordinalBay.String			&amp; Comma &amp;
						  bayOrdinal.String					&amp; Comma &amp;
						  ""								&amp; Comma &amp;
						  ""								&amp; Comma &amp;
						  ""								&amp; Comma &amp;
						  ""								&amp; Comma &amp;
						  ""								&amp; Comma &amp;
						  ""
						  );*/
		endif;
	endforeach;
	
	foreach voyage in vessel.allVoyagesByTermCodeArrival do
		voyStructure := voyage.myCellularVoyageStructure;
		bayOrdinal := 0;
		foreach bayVoyage in voyStructure.allBayVoyagesByOrdinal do
			bayOrdinal := bayOrdinal + 1;
			if bayOrdinal &lt;&gt; bayVoyage.ordinalBay then
				beginTransaction;
				bayVoyage.setOrdinalBay(bayOrdinal);
				commitTransaction;
				/*lFile.writeLine( vessel.getOidString			&amp; Comma &amp;
						  vessel.code 							&amp; Comma &amp;
						  vesStructure.getOidAsString 			&amp; Comma &amp;
						  ""									&amp; Comma &amp;
						  ""									&amp; Comma &amp;
						  ""									&amp; Comma &amp;
						  voyage.getOidAsString					&amp; Comma &amp;
						  voyage.code							&amp; Comma &amp;
						  voyStructure.getOidAsString			&amp; Comma &amp;
						  bayVoyage.getOidAsString				&amp; Comma &amp;
						  bayVoyage.ordinalBay.String			&amp; Comma &amp;
						  bayOrdinal.String
						  );*/
			endif;
		endforeach;
	endforeach;
epilog
	//delete lFile;
end;</source>
    </JadeMethod>
