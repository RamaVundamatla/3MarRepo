<GUIClass name="CMUI_YACriteriaInvSelectForm" id="4d244904-f02c-479a-b468-f6d57416de6b">
    <superclass name="CMUI_YACriteriaSelectForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="create" id="e92f73e8-dd5a-4df3-a079-cbac11ba13fa">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin
	self.permissionView	 := PmAdmYACriteriaInvView;
	self.permissionMaint := PmAdmYACriteriaInvMaint;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNoMaintPermDisableControls" id="66583cd2-f400-4593-a9bd-581996342f9c">
        <source>doNoMaintPermDisableControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin
	
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.btnOK.enabled := false;
	self.txtFind.enabled := false;
	self.chkByDescription.enabled := false;
	self.btnClear.enabled := false;
	self.chkSelect.enabled := false;
	self.chkByDescription.enabled := false;
	self.cmbVoyage.enabled := false;
	self.cmbWeight.enabled := false;
	self.optAll.enabled := false;
	self.optSelected.enabled := false;
	self.optVoyage.enabled := false;
	self.tblAvailable.userInputEnabled := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f607ab3a-bac6-44ed-aba3-e6586b0e8fb6">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin
	inheritMethod();
	
	// 04/05/2023	navkc1	Bug 57484
	self.doNoMaintPermDisableControls();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="48f20d4f-c883-45cf-b256-9859d21c9695">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 May 2023 08:32:56.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026014, locale);
end;</source>
    </JadeMethod>
</GUIClass>
