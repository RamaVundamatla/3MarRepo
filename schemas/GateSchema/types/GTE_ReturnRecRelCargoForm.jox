    <JadeMethod name="setupForm" id="4e179c8b-d244-4978-88d1-fac8569f0025">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwml2	Initial creation

*/

vars
	str : String;
begin
	inheritMethod();
	frmMain.zOrder(1);
	
	self.width := 364;
	if myCurrentWLE.myTrackedItem &lt;&gt; null then
		self.lblCargoIdDetail.caption := self.myCurrentWLE.myTrackedItem.id;
		self.lblCargoTypeDeta.caption := self.myCurrentWLE.myTrackedItem.cargoTypeDescr;
	else
		if self.isReceival then
			self.lblCargoIdDetail.caption := self.myCurrentWLE.myRequest.CM_TIRequest.trackedItem.id;
			self.lblCargoTypeDeta.caption := self.myCurrentWLE.myRequest.CM_TIRequest.trackedItem.cargoTypeDescr;
		else
			str := self.myCurrentWLE.myRequest.getDisplayStringForAttribute(ETRow_OperatorCode, true);
			self.lblCargoIdDetail.caption :=  str &amp; ' ' &amp; self.myCurrentWLE.myRequest.getDisplayStringForAttribute(ETRow_IsoType, true);
			self.lblCargoTypeDeta.caption :=  self.myCurrentWLE.myRequest.getDisplayStringForAttribute(ETRow_CargoTypeDescr, true);
		endif;		
	endif;
	
	if self.isReceival then
		self.lblLocation.visible := false;
		self.txtLocation.visible := false;
		self.btnSave.top := 75;
		self.btnCancel.top := 75;
		self.height := 150;
	else
		// Can only unassign if the release has not been mopved to truck at this stage 7.7.3
		// In future may allow unaissgin from truck to a specified location
		self.lblLocation.visible := false;
		self.txtLocation.visible := false;
		self.btnSave.top := 75;
		self.btnCancel.top := 75;
		self.height := 150;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b945a20d-db3d-4cb3-96da-9e35d2f51371">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 16:46:00.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022933, locale);
	btnCancel.translateCaption(Xlat_0011450, locale);
	btnSave.translateCaption(Xlat_0011451, locale);
	lblCargoId.translateCaption(Xlat_0011452, locale);
	lblCargoType.translateCaption(Xlat_0011453, locale);
	lblLocation.translateCaption(Xlat_0011454, locale);
	lblReason.translateCaption(Xlat_0011455, locale);
end;</source>
    </JadeMethod>
</GUIClass>
