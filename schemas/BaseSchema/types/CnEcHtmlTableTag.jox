<Class name="CnEcHtmlTableTag" id="5af863be-3e69-4085-b5cb-192cfc44f330">
    <superclass name="CnEcHtmlTableObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
