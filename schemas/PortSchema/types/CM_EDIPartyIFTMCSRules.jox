<Class name="CM_EDIPartyIFTMCSRules" id="153ecf33-075e-4f7d-aec8-790ef11da9d1">
    <superclass name="CM_EDIPartyRules"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="e035bda8-201f-4a77-b4ba-75394ab835fc">
        <updating/>
        <source>create() updating;
/*
Date		Who		Reason
04 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
*/
vars
	type	:CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_IFTMCS03A, null);
	
	if type = null or 
	   type.type &lt;&gt; EDIFileType_IFTMCS03A then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'IFTMCS file type missing');
	endif;
	
	self.myEDIFileType	:= type;
epilog

end;</source>
    </JadeMethod>
</Class>
