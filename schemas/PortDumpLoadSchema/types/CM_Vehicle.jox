<Class name="CM_Vehicle">
    <JadeMethod name="importPLXMLReference" id="d79457c0-5739-466e-8ced-e5d0a465a9fe">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars
begin
	if _name = CM_Vehicle::myTerminal.name then
		return app.myRoot.allTerminals[_theCode];
	elseif _name = CM_Vehicle::carrier.name then
		return app.myRoot.allCarriers[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
