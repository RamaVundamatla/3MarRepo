	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	bol := self.getBOL("BOL124", 5003, "MSK");
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	self.assertNotNull(bol);
	bol := self.getBOL("BOL125", 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	self.assertTrueMsg( bol.clientRef1 = "Service Order Number 4".toUpper, "clientRef1 not set correctly");	//09 Jun 2017	NDL	TFS 4331
	self.assertTrueMsg( bol.clientRef2 = "Purchase Order Number 4".toUpper, "clientRef1 not set correctly");	//09 Jun 2017	NDL	TFS 4331
	
