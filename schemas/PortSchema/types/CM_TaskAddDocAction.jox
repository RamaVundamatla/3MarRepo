    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="252aba11-a853-499a-a5d6-5f35b4efe6e7">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_DocumentActionTrxCont; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation

*/

vars

	creationType : Integer;
	otherTransClass : Class;
	tempTrx : CM_TITransaction;


begin

	inheritMethod(_tiTransCntrl, _passport);
	
	self.amount := _tiTransCntrl.amount;
	
	self.todoTaskCode := _tiTransCntrl.myToDoTaskDesc.code;
	self.todoTaskDesc := _tiTransCntrl.myToDoTaskDesc.description;
	creationType := _tiTransCntrl.myToDoTaskDesc.trxTypeOnCreation;
	if creationType &gt; 0 then 
		self.type := creationType;
		otherTransClass := global.getTiTxnClassForType(self.type, true);
		if otherTransClass &lt;&gt; null then
			create tempTrx as otherTransClass transient;
			tempTrx.setMyTrackedItem(_tiTransCntrl.myTrackedItem, _tiTransCntrl );
			tempTrx.updateTI( app.myPassport );
		endif;
	endif;
	
	self.isBookingRefItemDoc := _tiTransCntrl.myDocumentActions.isBookingItemAction;
	self.isReserveDetailDoc := _tiTransCntrl.myDocumentActions.isReserveDetailAction;
	self.documentId := _tiTransCntrl.myDocumentActions.getDocumentId();
	self.parentDocId := _tiTransCntrl.myDocumentActions.getParentDocId();

epilog

	delete tempTrx;

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_DocumentActionTrxCont"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
