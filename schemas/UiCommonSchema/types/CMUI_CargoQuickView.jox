    <JadeMethod name="setCurrentTI" id="706c1f51-9fc3-4613-99e3-363829019a82">
        <updating/>
        <source>setCurrentTI(_ti : CM_TrackedItem) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	failedDAC	: CM_DataAccessController;

begin

	self.myCurrentTI	:= _ti;
	
	if _ti = null then
		self.canAccessCurrentTI := false;
		self.btnEdit.enabled := false;
		self.btnView.enabled := false;
		return;
	endif;
	
	self.canAccessCurrentTI  := _ti.canUserAccessSelf(null, failedDAC, app.myPassport);

	if self.canAccessCurrentTI then
		self.btnEdit.enabled := true;
		self.btnView.enabled := true;
	else
		self.btnEdit.enabled := false;
		self.btnView.enabled := false;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
