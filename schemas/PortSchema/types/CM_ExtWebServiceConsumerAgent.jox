    <JadeMethod name="createAlert" id="a1b73995-3aeb-4ded-b655-05dc1c13353c">
        <source>createAlert(_details : String; _errors: StringArray) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2024	navsp1	Initial creation TFS 62068

*/

vars
	alert : CM_SystemAlert;
	error : String;
begin
	create alert transient;
	alert.setSeverity(SEVERE_ERROR);
	alert.details := _details;
	
	foreach error in _errors do
		alert.addLogEntry(error);
	endforeach;
	
	alert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_AT_ExternalInterface]);
	alert.myTerminal := self.getMyTerminal;
	
	alert.add();
	
	app.commitAlert();
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_details" type="String"/>
        <Parameter name="_errors" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="doCreateActivityHistory" id="3af29a62-5152-43de-b5be-078063eed1a0">
        <updating/>
        <source>doCreateActivityHistory(_consumer : JadeWebServiceConsumer;
						_methodName,
						_soapRequest,
						_soapResponse : String;
						_responseCode : Integer) updating;
/*

Purpose:			Create an External Interface type of Activity History for the message data as passed in

Parameters:			Web Service Consumer that was called
					Web Service method that was called
					soapRequest that was sent (with sensitive data removed)
					soapResponse that was received

Return Value:		None

Date		Who		Reason
13 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
12 Nov 2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
19 Jun 2019 jgler1	TFS  45207 - added the definiton name 
11 Nov 2019 cnwma1  ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)
8  Feb 2023 navra1	Allow method to be called when under transaction state - Changed for TFS - 55859
18 Mar 2023 navmd1	TFS 57092 Revert changes for 55859 (there is NO way we should be in trx state when sending a http request that may take 60+ seconds to timeout!!!)
					Add _responseCode to handle recording ExternalWebService histories instead of default CM_ActivityHistory
27 Aug 2024	navdap1	TFS 63842 NSW | OnePort Integration Dev - don't call trx for activity history if we're already in trx state
*/

vars
	proxyActHistory : CM_ActivityHistoryExtInterface;
	activityHistory : CM_ActivityHistory;
begin	
	create proxyActHistory transient;
	proxyActHistory.setProxy(ActivityHistoryExtInterface, app.myPassport.myTerminal, false);
	proxyActHistory.setDescription( self.definitionName &amp; " " &amp; _methodName &amp; " was sent");	
	proxyActHistory.setMessageData(_soapRequest, _soapResponse);
	proxyActHistory.setRequestName(_methodName[1:100]);                  //12.11.2018 cnwma1 TFS #41945
	
	//03 Oct 2019	NDL	TFS 46758

	proxyActHistory.setInterfaceName( self.definitionName );
	
	if process.isInTransactionState then
		activityHistory:=app.myUtilityCA.utlCreateActivityHistory(proxyActHistory, app.myPassport);
	endif;

	// TFS 63842 If we're in transaction state already, don't create an activity history - assume that whoever called this is handling that externally
	if not process.isInTransactionState then		
		activityHistory:=app.myTrxCA.trxCreateActivityHistory(proxyActHistory, app.myPassport);		
		if not app.myPassport.trxCompletedOK then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Failed to create activity history - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr, LogDEBUG);
			app.remoteErrorWarningToAlert(app.getErrorString(FailedToCreateActivityHist), null , app.myPassport.allErrors, null, false, false);
		endif;
	endif;
	
	if activityHistory &lt;&gt; null then	
		self.myLastActivityHistory := activityHistory.CM_ActivityHistoryExtInterface;
	endif;	
epilog
	delete proxyActHistory;

end;</source>
        <Parameter name="_consumer" type="JadeWebServiceConsumer"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_soapRequest" type="String"/>
        <Parameter name="_soapResponse" type="String"/>
        <Parameter name="_responseCode" type="Integer"/>
    </JadeMethod>
