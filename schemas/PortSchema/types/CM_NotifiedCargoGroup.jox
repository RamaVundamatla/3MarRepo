    <JadeMethod name="addProcessedTi" id="7cb1f1c0-e4eb-4b61-a726-4b235371c3ae">
        <source>addProcessedTi( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2015	cnwndl1	Initial creation		Par 36338

*/

vars

begin

	if self.myCargoGroupAssignment.cargoIdsInclude( _ti.id ) then
		self.myCargoGroupAssignment.addProcessedTi( _ti );
		return;
	else
		if self.preAssignedCargoIdsInclude( _ti.id ) then
			self.myCargoGroupAssignment.addProcessedTi( _ti );
			return;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createCargoGroup" id="e1ea8721-e329-438b-9d08-48b1d8db536b">
        <source>createCargoGroup( _cargoGroupId : String; _passport : CM_Passport input ):CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cargoType : CM_CargoType;
	oper : CM_Operator;
	pxyTI : CM_TrackedItem;
	realTI : CM_TrackedItem;
	subT : CM_SubTerminal;
	invalidObj : Boolean;
	terminal : CM_Terminal;
	existingTI : CM_TrackedItem;

begin

	terminal := self.myCargoGroupAssignment.myTerminal;
	if terminal = null then
		app.raiseCMException( Select_Terminal, null, null );
		return null;
	endif;

	cargoType := self.myCargoType;
	if cargoType = null then
		cargoType := terminal.getDefaultCargoGroupCargoType();
	endif;
	if cargoType = null then
		app.raiseCMException( Unspecified_Cargo_Type, null, null );
		return null;
	elseif not cargoType.isCargoGroup then
		app.raiseCMException1( Cargo_type_selec_not_defin_car, cargoType.description, null, null );
		return null;
	endif;
	
	if _cargoGroupId = null then
		app.raiseCMException( ERR_INVALID_TI_ID, null, null );
		return null;
	endif;
	
	existingTI := terminal.allCargoGroupsByCargoTypeId.getAtKey( cargoType.id, _cargoGroupId );
	if existingTI &lt;&gt; null then
		app.raiseCMException1( Cargo_group_already_used, _cargoGroupId, null, null );
		return null;
	endif;
	
	oper := self.myOperator;
	if oper = null then
		app.raiseCMException( Please_select_operator, null, null );
		return null;
	endif;
	
	pxyTI := terminal.createTI(cargoType, true);
	pxyTI.zSetPxyTerminal( terminal );
	pxyTI.setCargoType(cargoType.id);

	pxyTI.setMyOperator(oper);
			
	pxyTI.setImExStatus(TI_IMEX_STATUS_STORAGE);

	pxyTI.zSetPxyCompany(terminal.getDefaultCompanyBank);
		
	if app.isSubTerminalsOn(terminal) then
		subT := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem, 0, TI_IMEX_STATUS_STORAGE, null, false); 
		pxyTI.setSubTerminal(subT,null);
	endif;
	pxyTI.zSetPxyId( _cargoGroupId );
	pxyTI.CM_CargoGroup.setPxyMinMaxWeights( self.minWeight, self.maxWeight );
	pxyTI.setRemarks( self.remarks, false );	//21 Sep 2015	NDL	Par 36338
	
	self.exclusiveLock(terminal.allCargoGroupsByCargoTypeId);
	self.exclusiveLock(terminal.allCargoGroupsByIdCargoType);
	
	app.myUtilityCA.utlCreateTrackedItem( pxyTI, realTI, _passport );
	
	on Exception do app.handleDeletedObject( exception, pxyTI, invalidObj );
	
	return realTI.CM_CargoGroup;
	
epilog

	if pxyTI &lt;&gt; null then
		delete pxyTI;
	endif;

end;</source>
        <Parameter name="_cargoGroupId" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="54e1f940-d2d6-48cc-a09e-8de48745f896">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jul 2018	jlgndl1	Initial creation
20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
*/

vars

	str, type	: String;
	cg : CM_CargoGroup;

begin

	if _attrName = ETRow_AssignmentId then
		return self.myCargoGroupAssignment.id;
		
	elseif _attrName = ETRow_CargoGroupId then
		return self.id;
		
	elseif _attrName = ETRow_DefaultLocation then
		return self.defaultLocation;
	
	elseif _attrName = ETRow_MinWeight then
		return self.minWeight.String;
	
	elseif _attrName = ETRow_MaxWeight then
		return self.maxWeight.String;
	
	elseif _attrName = ETRow_CargoType then
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.abbreviation;
		endif;
	
	elseif _attrName = ETRow_CargoCargoType then
		cg := self.getMatchingCargoGroup();
		if cg &lt;&gt; null then
			return cg.getDisplayStringForAttribute( ETRow_GroupCargoType, _short );
		endif;
		return null;
		
	elseif _attrName = ETRow_CargoCargoSubType then
		cg := self.getMatchingCargoGroup();
		if cg &lt;&gt; null then
			return cg.getDisplayStringForAttribute( ETRow_GroupCargoSubType, _short );
		endif;
		return null;
	
	elseif _attrName = ETRow_Operator then
		if self.myOperator &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
				return self.myOperator.description;						// TFS 53362
			else														// TFS 53362
				return self.myOperator.code;
			endif;														// TFS 53362
		endif;
	
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
		
	elseif _attrName = ETRow_IsCompleted then
		return self.isCompleted.asStringJMT;
		
	elseif _attrName = ETRow_ScannedCount then
		return self.getScannedCount( self.getMatchingCargoGroup ).asStringJMT;
	
	elseif _attrName.isMeasurementType then	
		_attrName.getRowNameMeasureType(str, type);	
		return self.getMeasurementStringForAttrib(str, type, _short);
	
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMatchingCargoGroup" id="4021df6e-37e3-441b-8cd3-338d127fc0e3">
        <source>getMatchingCargoGroup():CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

	terminal : CM_Terminal;
	cargoType : CM_CargoType;
	cg : CM_CargoGroup;

begin

	terminal := self.getMyTerminal();

	cargoType := self.myCargoType;
	if cargoType = null then
		if terminal&lt;&gt; null then
			cargoType := terminal.getDefaultCargoGroupCargoType();
		endif;
	endif;

	if cargoType &lt;&gt; null then
		if terminal &lt;&gt; null then
			cg := terminal.allCargoGroupsByIdCargoType.getAtKey( self.id, cargoType.id ).CM_CargoGroup;
		endif;
	endif;
	
	return cg;

epilog

end;</source>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="2a792985-d590-42bc-8619-e428e1422e9c">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation

*/

vars

	terminal : CM_Terminal;

begin

	if self.myTerminal &lt;&gt; null then
		return  self.myTerminal;
	endif;
	
	if self.myCargoGroupAssignment &lt;&gt; null then
		terminal := self.myCargoGroupAssignment.getMyTerminal();
		if terminal &lt;&gt; null then
			return terminal;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getName" id="c69a95fa-2d09-426c-af33-e1cc457cdea6">
        <source>getName(): String;
/*

Purpose:			TFS 8039

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2017	jlgab1	Initial creation
11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
*/

vars
	obj : Object;
	str, mess : String;
	iter : Iterator;
begin
	if self.allPreAssignedCargoIdsDict = null then
		return self.String &amp; " " &amp; self.id;
	endif;
	
	if self.allPreAssignedCargoIdsDict.isEmpty then
		return self.String &amp; " " &amp; self.id;
	endif;

	iter := self.allPreAssignedCargoIdsDict.createIterator();
	
	while iter.next(obj) do
		iter.getCurrentKeys(str);  //MTN-35226
		if mess = "" then
			mess := str;
		endif;
	endwhile;

	if self.allPreAssignedCargoIdsDict.size = 1 then
		return self.String &amp; " " &amp; self.id &amp; " - " &amp; mess;
	endif;

	
	mess := mess &amp; " to " &amp; str;
	
	return self.String &amp; " " &amp; self.id &amp; " - " &amp;  mess;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPreAssignedToScan" id="ef7c7e15-8a69-42a5-967e-e0c2bba0ac5e">
        <source>getPreAssignedToScan( _strArray : StringArray input ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	iter : Iterator;
	strArray : StringArray;
	obj : Object;
	cargoId : String;
	count : Integer;
	ti : CM_TrackedItem;

begin

	if self.allPreAssignedCargoIdsDict.isEmpty then
		return 0;
	endif;
	
	create strArray transient;
	
	iter := self.allPreAssignedCargoIdsDict.createIterator;
	while iter.next( obj ) do
		cargoId := iter.getCurrentKey( 1 ).String;
		if cargoId &lt;&gt; null then
			strArray.add( cargoId );
		endif;
	endwhile;
	
	count := strArray.size;
	if count= 0 then
		return 0;
	endif;
	
	foreach ti in self.myCargoGroupAssignment.allProcessedTis do
		cargoId := ti.id;
		if strArray.includes( cargoId ) then
			strArray.remove( cargoId );
			//this one has been done
			count := strArray.size;
		endif;
		if count= 0 then
			return 0;
		endif;
	endforeach;
	
	if _strArray &lt;&gt; null then
		foreach cargoId in strArray do
			_strArray.add( cargoId );
		endforeach;
	endif;
	
	return count;
epilog

	delete iter;
	delete strArray;

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getScannedCount" id="d153e954-f2e7-4076-b558-3c1ea81b75b0">
        <source>getScannedCount( _cg : CM_CargoGroup ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	ti : CM_TrackedItem;
	count : Integer;
	
begin

	if _cg = null then
		return 0;
	endif;
	
	foreach ti in _cg.allAssignedTrackedItems do
		if self.myCargoGroupAssignment.allProcessedTis.includes( ti ) then
			count := count + 1;
		endif;
	endforeach;
	
	return count;

epilog

end;</source>
        <Parameter name="_cg" type="CM_CargoGroup"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isCompleted" id="d2caa649-9f54-4040-bd49-39d7554807e6">
        <source>isCompleted():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

	cg : CM_CargoGroup;

begin

	cg := self.getMatchingCargoGroup;

	if cg &lt;&gt; null then
		return cg.isComplete;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
