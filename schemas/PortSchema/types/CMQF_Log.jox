    <JadeMethod name="canUserRunReport" id="ab8e9f52-d16a-4cc1-b552-612e6511867d">
        <source>canUserRunReport(_user: CM_User): Class;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	class : Class;

begin
	
	class := inheritMethod(_user);
	if class &lt;&gt; null then
		return class;
	endif;
	
	if not _user.canUserAccessObj(app.myRoot.allCarriers[self.carrierCode], CM_Carrier) then
		return CM_Carrier;
	endif;
	
	return null;


end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="184ad8d5-9d47-474f-882b-dea83c053fb4">
        <updating/>
        <source>cloneReferences(_obj: CMQF_Log; _transient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _transient);
	
	self.setMyLogGrade( _obj.getMyLogGrade );
	self.setMyLogLength( _obj.getMyLogLength );
	self.setMyLogLot( _obj.getMyLogLot );
	self.setMyLogSpecies( _obj.getMyLogSpecies );
	self.setMyLogTreatment( _obj.getMyLogTreatment );
	self.setMyLogType( _obj.getMyLogType );
	self.setMyVoyageGlobalActual( _obj.getMyVoyageGlobalActual );
	self.setMyVoyageGlobalAllocated( _obj.getMyVoyageGlobalAllocated );
	
	self.setMyQrySourceLocation( _obj.getMyQrySourceLocation );
	self.setMyQrySourceSubLocation(	_obj.getMyQrySourceSubLocation );
	self.setMyQrySourceSubSubLocation( _obj.getMyQrySourceSubSubLocation );

end;</source>
        <Parameter name="_obj" type="CMQF_Log"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="7c7c3d39-0e9c-4d5d-b15c-46f540a58adb">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.terminalAreaTypes.add(TA_TYPE_LOGAREA);
end;</source>
    </JadeMethod>
    <JadeMethod name="filterLocationControllers" id="7e3cf260-bfed-497a-b282-70c78eed1af6">
        <updating/>
        <source>filterLocationControllers(_locIter : Iterator input; 
						_collection : Collection input; 
						_passport : CM_Passport;
						_breakOut : Boolean output) protected, updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	lc				: CM_LocationsController;
	startPos		: Integer;
begin
	
	while _locIter.next(lc) do
		startPos := 1;
		if (CM_YardController.hasInstance(lc)) then
			if (self.locationComment &lt;&gt; null and lc.CM_YardController.remarks.toUpper.pos(self.locationComment.toUpper, startPos) = 0) then
				continue;
			endif;
		endif;
		
		// 28/09/2009 cnwar2 CCMS1107/#20638
		if (CM_LogController.hasInstance(lc)) then
			if (self.isLocationInspected = LOG_ROW_INSPECTED and not lc.CM_LogController.isInspected)
			or (self.isLocationInspected = LOG_ROW_NOTINSPECTED and lc.CM_LogController.isInspected)
			or (self.isLocationFumigated = LOG_ROW_FUMIGATED and not lc.CM_LogController.isFumigated)
			or (self.isLocationFumigated = LOG_ROW_NOTFUMIGATED and lc.CM_LogController.isFumigated) then
				continue;
			endif;
		endif;
		
		self.handleLocationsController(lc, _collection, _passport, _breakOut);
		if _breakOut then
			break;
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_locIter" type="Iterator" usage="input"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="19cfb7fe-ac50-4d4e-a402-46b2d47798be">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
//14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
vars
	locIter				: Iterator;
	stkOrderSum			: CM_StockOrderSummary;
	stkOrderAllocation	: CM_StockOrderAllocation;
	ta					: CM_TerminalArea;
	loadStateSet 		: Boolean;
	cargoTypeKey		: Integer;
	idKey				: String;
	iter				: Iterator;
	ti					: CM_TrackedItem;
	tiDict				: CM_TIByCargoTypeIdDict;
	terminal			: CM_Terminal;
	operatorTerm		: CM_OperatorTerminal;
	globalVoyage		: CM_VoyageGlobal;
	voyage				: CM_Voyage;
	breakOut			: Boolean;
	lcSet				: CM_LCSet;
begin
	
	app.cmsBeginLoad(loadStateSet);
	if self.getMyLocationsController &lt;&gt; null then
		self.handleLocationsController(self.getMyLocationsController, _collection, _passport, breakOut);
		return;
	endif;
	
	if self.getMyLogLot &lt;&gt; null then
		self.handleLogLot(self.getMyLogLot, _collection, _passport, breakOut);
		return;
	endif;
	
	if self.getMyVoyageGlobalAllocated &lt;&gt; null then
		create lcSet transient;
		globalVoyage := self.getMyVoyageGlobalAllocated;
		foreach voyage in globalVoyage.allVoyages discreteLock where self.allTerminals.includes(voyage.myTerminal) do :voyageLoop
			foreach stkOrderSum in voyage.allStockOrderSummaries discreteLock do
				foreach stkOrderAllocation in stkOrderSum.allStockAllocations discreteLock do
					if (not lcSet.includes(stkOrderAllocation.myLocationsController)) then
						lcSet.add(stkOrderAllocation.myLocationsController);
						self.handleLocationsController(stkOrderAllocation.myLocationsController, _collection, _passport, breakOut);
						if breakOut then
							break voyageLoop;
						endif;
					endif;
				endforeach;
			endforeach;
		endforeach;	
	
	elseif self.getMyVoyageGlobalActual &lt;&gt; null then
		globalVoyage := self.getMyVoyageGlobalActual;
		foreach voyage in globalVoyage.allVoyages discreteLock where self.allTerminals.includes(voyage.myTerminal) do
			delete locIter;			// PAR #26678
			locIter := voyage.allVoyageLocations.createIterator;
			self.filterLocationControllers(locIter, _collection, _passport, breakOut);
			if breakOut then
				break;
			endif;
		endforeach;
		
	elseif (self.myOperator &lt;&gt; null) and (self.getMyTerminalArea = null) then
		foreach terminal in self.allTerminals do : terminalLoop
			operatorTerm := self.myOperator.allOperatorTerminals[terminal];
			if operatorTerm = null then
				continue;
			endif;
			tiDict := operatorTerm.allOnsiteTIsByCargoTypeId;
			delete iter;		// PAR #26678
			iter := tiDict.createIterator;
			tiDict.startKeyGeq(TI_CargoType_Log, null, iter);
			
			while iter.next(ti) do
				iter.getCurrentKeys(cargoTypeKey, idKey); //MTN-35226
				if cargoTypeKey &lt;&gt; TI_CargoType_Log then
					break;
				endif;
				
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti.CM_Log, _passport, breakOut) then
					//_collection.add(ti);
					self.addToCollection(ti, _collection); //#cnwdz2	 CCMS 1108 par22177 
				endif;
				
//				if breakOut then
//					break terminalLoop;
//				endif;
			endwhile;
		endforeach;
		
	else
		self.populateQryTerminalAreas();	
		foreach ta in self.allQryTerminalAreas do
			delete locIter;			// PAR #26678
			locIter := ta.allLocationsControllers.createIterator;
			self.filterLocationControllers(locIter, _collection, _passport, breakOut);
			
			if breakOut then
				break;
			endif;
		endforeach;
	endif;
	
epilog
	endLoad;
	delete locIter;
	delete lcSet;
	delete iter;			// PAR #26678
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="71c41017-a12e-46c6-a0cb-5c36168cd787">
        <source>getDisplayStringForAttribute(_attrName : String; _getCalculatedDate : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	runDate			: Date;
	oid 	: String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_Carrier or
	   _attrName = ETRow_CarrierCode then
		return self.carrierCode;
	
	elseif _attrName = ETRow_GangNumber then
		return self.gangNumber;
		
	elseif _attrName = ETRow_Hatch then
		if self.logHatch &lt;&gt; null then
			return self.logHatch.String;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LoggingOrganisation then
		return self.loggingOrganisation;
	
	elseif _attrName = ETRow_LogLot then
		if self.myLogLot &lt;&gt; null then
			return self.myLogLot.String;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_MyLogSpecies or
		_attrName = ETRow_LogSpecies then
		if self.myLogSpecies &lt;&gt; null then
			return self.myLogSpecies.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_MyLogGrade or
		_attrName = ETRow_LogGrade then
		if self.myLogGrade &lt;&gt; null then
			return self.myLogGrade.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_MyLogType or
		_attrName = ETRow_LogType then
		if self.myLogType &lt;&gt; null then
			return self.myLogType.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MyLogTreatment or
		_attrName = ETRow_LogTreatment then
		if self.myLogTreatment &lt;&gt; null then
			return self.myLogTreatment.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MyLogLength or
		_attrName = ETRow_LogLength then
		if self.myLogLength &lt;&gt; null then
			return self.myLogLength.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MatchDateStart then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.matchStartDateTplType, self.matchStartDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.matchStartDateTplType, self.matchStartDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_MatchDateEnd then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.matchEndDateTplType, self.matchEndDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.matchEndDateTplType, self.matchEndDateTplFactor);
		endif;
		
	
	elseif _attrName = ETRow_MatchTimeStart then
		//return self.matchStartDate.time.String;
		return self.matchStartDate.time.asStringJMT();  //par 18944 cnwjo3

	elseif _attrName = ETRow_MatchTimeEnd then
		//return self.matchEndDate.time.String;
		return self.matchEndDate.time.asStringJMT();  //par 18944 cnwjo3
	
	elseif _attrName = ETRow_Place then
		return app.vesselPlaceEnumToStr(self.logPlace);		
	
	elseif _attrName = ETRow_SrcLocation then
		if self.sourceLocation &lt;&gt; null then
			return self.sourceLocation;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_SrcSubLocation then
		if sourceSubLocation &lt;&gt; null then
			return self.sourceSubLocation;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_SrcSubSubLocation then
		if sourceSubSubLocation &lt;&gt; null then
			return self.sourceSubSubLocation;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_VoyageAllocated then  //18/05/2009 cnwdz2 par19257 changed ETRow_Voyage to ETRow_VoyageAllocated
		if self.myVoyageGlobalAllocated &lt;&gt; null then
			return self.myVoyageGlobalAllocated.code;
		else
			return Any_String;
		endif;

	elseif _attrName = ETRow_VoyageActual then
		if self.myVoyageGlobalActual &lt;&gt; null then
			return self.myVoyageGlobalActual.code;
		else
			return Any_String;
		endif;
	endif;

	return inheritMethod(_attrName, _getCalculatedDate);
*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyLogGrade" id="90e666f1-ac4a-4f44-9571-6df16278e59b">
        <source>getMyLogGrade():CM_LogGrade;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_LogGrade;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myLogGrade;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_LogGrade"/>
    </JadeMethod>
