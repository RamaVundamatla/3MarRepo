        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*
Date		Who		Reason
26 May 2010	cnwar2	#23886

*/
vars

begin
	if _attrName = ETRow_DischargePort then
		if self.trackedItem &lt;&gt; null then
			return self.trackedItem.dischargePort;
		else
			return null;
		endif;
	else
