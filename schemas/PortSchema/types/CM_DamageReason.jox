    <JadeMethod name="validateForDelete" id="37f32785-fbf2-43b1-8317-3e2521a6e2f9">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if self.allDamageInstances.isNotEmpty then
		app.raiseCMException1(Cannot_Delete_DamageReason, self.code, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b9ad5a9a-aaa4-460f-8885-4a7f30c051f8">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	realDamageReason,
	existingDamageReason		: CM_DamageReason;
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_Code, self);
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description, self); 
	endif;
	
	
	existingDamageReason	:= self.myTerminal.allDamageReasons[self.code];
	realDamageReason		:= self.pxyGetRealObject();
	
	if existingDamageReason &lt;&gt; null and
	   (realDamageReason = null or //in which case we are trying add a new one that is duplicate
	   realDamageReason &lt;&gt; existingDamageReason) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException1(DamageReason_code_alreadyexist, self.code.String, null, null); 
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
