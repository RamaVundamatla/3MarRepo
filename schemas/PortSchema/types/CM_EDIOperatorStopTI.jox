    <JadeMethod name="canUserSet" id="79ffed09-0a25-4e82-8328-ca047fb80e36">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
vars

begin
	if _propName = CM_EDIOperatorStopTI::allTrackedItems.name or
	   _propName = CM_EDIOperatorStopTI::myTrackedItem.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
