    <JadeMethod name="loadDB" id="240897d6-4cc9-406d-aea4-00363ec9c0b6">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Jun 2023	jlirs1	Initial creation
27 Jun 2023	navdap1	TFS 58813 EUP Manifest Instructions and corrections
08 Aug 2023	navdap1	TFS 59747 EUP DB Load Failed with no errors for a Road Transport Manifest
03 Sep 2023	navdap1	TFS 60186 EUP | FR 53824 - Road Manifest VBS Booking
27 Sep 2023 navra1  TFS 60521 EUP | FR 53824 Manifest - Error 4 occurs on VBS slot after EDI Transport Manifest Cancel Call
9  Oct 2023 navra1  TFS 60777 EUP | FR 53824 - VBS Slot 'cleanup'
12 Oct 2023 navra1  TFS 60845 EUP | FR 53824 Transport Manifest - Updating Road Manifest fails "External Reference is already used"
22 Nov 2024 navsp1  JIRA 33407 EUP | FR 53824 - Unable to update Manifest/VBS Appointment after WO Approved
*/

vars
	ediData, manifestData : CM_EDIData;
	ediErrors : CM_EDIErrorSet;
	newStatus : Integer;
	existEdiData : CM_EDIData;
	prevVBReference : String;		// TFS 60186
	isWOApproved : Boolean;
	existWorkOrder : CM_WorkOrder;
	ediError	: CM_EDIError;
begin
	
	app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADING);	//11.Mar.24 navsp1 TFS 60793
	isWOApproved := false;
	if self.statusString &lt;&gt; CMIF_JsonHeaderEUP.Status_Create then	//10.Jul.2023 navsp1 TFS 58055
		self.deleteManifestData(existEdiData, _passport, isWOApproved);		//JIRA-33407 - new parameter "isWOApproved" added to identify the existing WO already approved.
		// TFS 60186 get the previous VBS external reference
		if existEdiData &lt;&gt; null and existEdiData.isTransportManifest and existEdiData.CM_EDIDataTransManifest.transportReferenceCustomer &lt;&gt; null then
			//prevVBReference := existEdiData.CM_EDIDataTransManifest.transportReferenceCustomer;
			prevVBReference := existEdiData.CM_EDIDataTransManifest.transportReferenceCustomer.toUpper().replace(Space,'');			//navra1 - TFS 60845 - 12th Oct 2023
		endif;

		//navra1 - TFS 60777 - 9th Oct 2023 - start
		//deletion of VBS data done as part of TFS 60521 is moved inside self.deleteManifestData as part of TFS 60777
		//navra1 - TFS 60777 - 9th Oct 2023 - end
	endif;
	
	if self.statusString &lt;&gt; CMIF_JsonHeaderEUP.Status_Cancel then	
		
		if self.myCargoOnSite &lt;&gt; null then
			ediData := self.myCargoOnSite;
			
		elseif self.myGateDocument &lt;&gt; null then
			self.loadDBGateDoc(_mergeCargo, prevVBReference, _passport);	// TFS 60186
			newStatus := self.myGateDocument.status;
			//ediErrors := self.myGateDocument.allErrorWarnings;	// TFS 59747
			
		elseif self.myShipManifest &lt;&gt; null then
			ediData := self.myShipManifest;
			
		elseif self.myTrainConsist &lt;&gt; null then
			self.loadDBTrainConsist(_mergeCargo, _passport);
			newStatus := self.myTrainConsist.status;
			//ediErrors := self.myTrainConsist.allErrorWarnings;	// TFS 59747
			
		endif;
		
		if ediData &lt;&gt; null then
			ediData.loadDB(_mergeCargo, _passport);
			newStatus := ediData.status;
			//ediErrors := ediData.allErrorWarnings;				// TFS 59747
		endif;		
		
		if _passport.hasErrorsOrWarnings then						//11.Jul.2023 navsp1 TFS 57805	//12.Jan.2024 navsp1 TFS 61660
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, null);
		else
			//Update WO back to 'Approved' if it has been approved before								//JIRA 33407
			if isWOApproved then																		//JIRA 33407
				self.getWorkOrderForManifest(existWorkOrder);											//JIRA 33407
				if existWorkOrder &lt;&gt; null and existWorkOrder.taskStatus &lt;&gt; WO_STATUS_APPROVED then		//JIRA 33407
					app.myTrxUA.trxUpdateWOApproved(existWorkOrder, false, null, null, app.myPassport);	//JIRA 33407
				endif;																					//JIRA 33407
			endif;																						//JIRA 33407
		endif;
		
		create ediErrors transient;														//MTN-33568
		if self.myGateDocument &lt;&gt; null then												//MTN-33568
			foreach ediError in self.myGateDocument.allErrorWarnings do 				//MTN-33568
				if not self.allErrorWarnings.includesErrorOrWarning(ediError.text) then //MTN-33568
					ediErrors.add(ediError);											//MTN-33568
				endif;																	//MTN-33568
			endforeach;																	//MTN-33568
		else																			//MTN-33568
			self.allErrorWarnings.copyNoDuplicates(ediErrors, false);					//MTN-33568
		endif;																			//MTN-33568
		
		if newStatus &lt;&gt; self.status then
			manifestData := self;
			app.myTrxUA.trxUpdateEDIDataErrorsStatus(manifestData, ediErrors, newStatus, app.myPassport);
		endif;
		
	endif;
	
epilog
	delete ediErrors;		// TFS 59747
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDBGateDoc" id="1f18d413-8b5f-4561-92ee-d6ad48d69bde">
        <updating/>
        <source>loadDBGateDoc(_mergeCargo: Boolean; _previousVBRef : String; _passport: CM_Passport input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Jun 2023	navsp1	Initial creation TFS ChangeRequest 57805: EUP - Manifest Processing - Truck - Create
03 Sep 2023	navdap1	TFS 60186 EUP | FR 53824 - Road Manifest VBS Booking
10 Sep 2023	navdap1	TFS 60387 EUP | FR 53824 - Transport Manifest - Multiple Pre-notes, same Cargo ID
12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
*/

vars
	ediData			: CM_EDIData;
	ediTi			: CM_EDITrackedItem;
	strArray		: StringArray;
	vbsTypeObj 		: CM_VehicleBookingTimeSlotType;
	terminal		: CM_Terminal;
	vbsType 		: String;
	cargoType		: CM_CargoType;
	operator		: CM_Operator;
	carrier			: CM_Carrier;
	ediPrenoteTI	: CM_EDIPrenoteTI;
	product			: CM_Product;
	commodity		: CM_Commodity;
	doneWO			: Boolean;			// TFS 60186
	errors			: CM_ErrorSet;		// TFS 60186
	newStatus		: Integer;			// TFS 60186
	ediTISet		: CM_EDITISet;		// TFS 60186
begin
	ediData    		:= self.myGateDocument;
	terminal		:= self.getMyTerminal;
	
	// TFS 60186 Find the VB slot type
	vbsTypeObj := app.findVBSlotType(self.vehicleBookingSlotType, ediData.allEDITrackedItems.first);
	
	// TFS 60387 LoadDB also does validation again, so we need to repeat some specific validation here that doesn't happen in loadDB
	if self.statusString = CMIF_JsonHeaderEUP.Status_Create or self.statusString = CMIF_JsonHeaderEUP.Status_Replace then
		self.verifyAssignedCargoGroup();
	endif;
	// TFS 60387 end
	
	//Load DB
	ediData.loadDB(_mergeCargo, _passport);
	
	// TFS 60186 We always create / update a vehicle booking slot for Road Transport
	//if (ediData.status	= CM_EDIFile.EDI_STATUS_DBLOADED) and (self.transportReferenceCustomer &lt;&gt; null or self.transportReferenceInternal &lt;&gt; null) then
	if ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
		
		doneWO := true;
		create strArray transient;
		foreach ediTi in ediData.allEDITrackedItems do
			strArray.add(ediTi.id);
		endforeach;
		
		create errors transient;
		_passport.moveErrorsToSet(errors);
		app.myTrxUA.trxUpdateVBSForRoadManifest(self, strArray, vbsTypeObj, _previousVBRef, _passport);
		_passport.addErrorsFromSet(errors);
		//app.myTrxUA.trxUpdateVBSAndPrenote(self.transportReferenceCustomer, 
		//									self.transportReferenceInternal, 
		//									self.vehicleBookingSlotRemarks,
		//									strArray, terminal,
		//									vbsTypeObj,
		//									app.myPassport);
		
	endif;	
	
epilog
	if self.myGateDocument &lt;&gt; null then
		if doneWO and app.myPassport.trxCompletedOK then
			newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
		elseif doneWO and _passport.allErrors.isEmpty and _passport.hasWarnings then
			newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
		elseif doneWO and _passport.hasErrors then
			newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
		elseif not doneWO then
			newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
		endif;
		
		create ediTISet transient;
		self.myGateDocument.allEDITrackedItems.copy(ediTISet);
		app.myTrxUA.trxUpdateEDITIStatusBulk(ediTISet, newStatus, _passport);
		app.myTrxUA.trxSetEDIDataStatus(self.myGateDocument, newStatus);
	endif;
	delete strArray;
	delete ediTISet;
	if errors &lt;&gt; null then
		delete errors;		//12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_previousVBRef" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDBTrainConsist" id="bf19a484-851c-46c0-a8ce-c378a2f5ec39">
        <updating/>
        <source>loadDBTrainConsist(_mergeCargo: Boolean; _passport: CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2023	navra1	Initial creation for TFS 57808 - EUP - Manifest Processing - Train - Create
15 Aug 2023	navdap1	TFS 59844 EUP FR | 53824 - Manifest EDI - Work order must have at least one tracked item error
23 February 2024	navcs2	ChangeRequest 62250: EUP | FR 53824 - Transport Manifest - Multiple Manifests For a Single Wagon Need to be Possible. 

*/

vars
	arrivalTrains : CM_TrainByArrivalDTDict;
	train : CM_Train;
	trainCode : String;	
	localTrainConsist : CM_EDIDataTrainConsist;
	ediTi : CM_EDITrackedItem;
	cargoGroup : CM_CargoGroup;
	cargoGroupArray : CM_ObjectArray;
	localTerminal : CM_Terminal;
	ediFileTM : CM_EDIFileTypeJSONTransManifst;
	oldEdiFile : CM_EDIFile;
	ediTisColl					: CM_EDITIById;
	realcargoItem : CM_TrackedItem;
	workOrder 	: CM_WorkOrder;
	tiSet	: CM_TIByCargoTypeIdDict;
begin	
	//loadDB the current file
	if self.myTrainConsist &lt;&gt; null then
		self.myTrainConsist.loadDB(_mergeCargo, _passport);
	endif;
	
	if _passport.allErrors.size() &lt;&gt; 0 then
		return;
	endif;
	
	create cargoGroupArray transient;
	create tiSet transient;
	localTrainConsist := self.myTrainConsist;
	//create work order	if we DBLoaded successfully
	if localTrainConsist &lt;&gt; null then		
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, localTrainConsist.status);	//navra1 - TFS 57808 - 23th June 2023

		//CREATTION OF WORK ORDER DONE HERE
		
		//create WO if the edi was loaded successfully to the DB
		if localTrainConsist.status= CM_EDIFile.EDI_STATUS_DBLOADED and _passport.isVASEnabled() then		
			//get all the cargo groups			
			foreach ediTi in localTrainConsist.allEDITrackedItems do
				if ediTi.isKindOf(CM_EDITrackedItem) then
					realcargoItem := localTrainConsist.getRealTrackedItem(ediTi);
					if realcargoItem &lt;&gt; null then
						tiSet.add(realcargoItem);
					endif;
					cargoGroup := self.getMyTerminal.getCargoGroupItem(ediTi.getCargoGroupId());
					if cargoGroup &lt;&gt; null and not cargoGroupArray.includes(cargoGroup) then
						cargoGroupArray.add(cargoGroup);
					endif;	
				endif;
			endforeach;			
			
			//call the work order creation trx
			localTerminal := self.getMyTerminal();
			if localTerminal &lt;&gt; null then
				if localTrainConsist.currentTrainCode = NULL_TRAIN_CODE then
					train := localTerminal.getNullTrain();
				else					
					foreach train in localTerminal.allTrainsArrival where train.scheduledArrivalDT = localTrainConsist.myTransportManifest.estimatedDateTimeOfArrival do
						if train.code = localTrainConsist.currentTrainCode then
							break;
						else 
							train := null;
						endif;
					endforeach;				
				endif;			
				
				if train &lt;&gt; null and cargoGroupArray &lt;&gt; null then			
					//create the WO
					//app.myTrxCA.trxCreateWOForManifest(self.manifestNumber, WO_TASK_RECEIVE, cargoGroupArray, train);			// TFS 59844
					app.myTrxCA.trxCreateWOForManifestTrans(self, WO_TASK_RECEIVE, cargoGroupArray, train, tiSet);		// TFS 59844			// 23/02/2024	navcs2	ChangeRequest 62250 		// 18/03/2024 navcs2 ChangeRequest 58059[58497]
				endif;
			endif;		
		endif;	
	endif;

epilog	
	delete ediFileTM;
	delete cargoGroupArray;
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processAttributeDependencies" id="d6230fb4-96fc-4c96-bb4d-a0adfb420bfa">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist: CMIF_EDIUserDefinedAssist input; _strIdentifier: String; _reset: Boolean; _xlationOperator: CM_Operator) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
06 Mar 2024	navdap1	TFS 62649 EUP | FR 53824 - UDF Transport Manifest Commodity Code Not Loaded From File
*/

vars
	ediTITrain : CM_EDITrainTI;
	now : TimeStamp;
	ediTI : CM_EDITrackedItem;
	ediTIs : CM_EDITIById;
begin
	if self.myTrainConsist &lt;&gt; null then
		create ediTITrain persistent;
		ediTITrain.setForCreateNew(self.myTrainConsist);
		ediTITrain.assignValueSpecial(CM_EDITrainTI::trainCode.name, NULL_TRAIN_CODE, null);
		ediTITrain.assignValueSpecial(CM_EDITrainTI::scheduledArrivalDT.name, now.String, null);
	endif;
	
	// TFS 62649 Do commodity translations for user-defined files
	if self.myShipManifest &lt;&gt; null then
		ediTIs := self.myShipManifest.allEDITrackedItems;
	elseif self.myGateDocument &lt;&gt; null then
		ediTIs := self.myGateDocument.allEDITrackedItems;
	elseif self.myCargoOnSite &lt;&gt; null then
		ediTIs := self.myCargoOnSite.allEDITrackedItems;
	elseif self.myTrainConsist &lt;&gt; null then
		ediTIs := self.myTrainConsist.allEDITrackedItems;
	endif;
	if ediTIs &lt;&gt; null then
		foreach ediTI in ediTIs do
			ediTI.doTranslations(self.myOperator);
		endforeach;
	endif;
	// TFS 62649 end
	
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);

epilog

end;</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setEDITIProperty" id="b412aa60-9403-4367-9c73-1f046f3cc761">
        <updating/>
        <source>setEDITIProperty(_name: String; _fullValue: Any; _ediFile: CM_EDIFile) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Nov 2023	jlirs1	Initial creation
11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
06 Mar 2024	navdap1	TFS 62649 EUP | FR 53824 - UDF Transport Manifest Commodity Code Not Loaded From File
27 Mar 2024 navhn30	Bug 63125: EUP | Transport Manifest UDF - Transport Reference customer error when try to Verify Road manifest
01 Apr 2024	navhn30	Bug 63123: EUP - User defined Transport Manifest - manifest with same message number can be loaded and DB loaded as Create more than once
09 May 2024	navcs2	Bug 63932: EUP | FR - 53824 Transport Manifest UHE 1035 Message On User Defined File Type Load
*/

vars
	ediFile : CM_EDIFile;
	ts : TimeStamp;
	debtorCode : String;
	debtor : CM_Debtor;
	senderOperator : CM_Operator;
	opCode : String;
	existingEdiFile : CM_EDIFile;
begin
	ediFile := _ediFile;
	if _name = ETRow_TransportStatus then
		ediFile.mode := _fullValue.String;
		self.statusString := _fullValue.String;
	elseif _name = ETRow_Guid then
		self.guid := _fullValue.String;
		ediFile.setGuid(_fullValue.String);
	elseif _name = ETRow_Sender then
		self.sender := _fullValue.String;
		
		// TFS 62649 fill in missing details - sender is debtor, receiver, operator code, etc
		self.receiver := self.getMyTerminal().code;
		debtorCode := self.sender.toUpper;
		opCode := self.sender.toUpper;
		debtor := app.myRoot.myRootCompany.allDebtorsByCode[debtorCode];
		if debtor &lt;&gt; null then
			senderOperator := debtor.operators.first;
			if senderOperator &lt;&gt; null then
				opCode := senderOperator.code;
			endif;
		endif;
		if senderOperator = null then
			senderOperator	:= app.myRoot.allOperators[opCode];
		endif;
		
		// 09 May 2024	navcs2	Bug 63932 Start
		if opCode.length &gt; 4 then
			opCode := opCode[1:4];
		endif;
		// 09 May 2024	navcs2	Bug 63932 End
		
		self.operatorCode := opCode;
		self.myOperator := senderOperator;
		self.xlationOperatorCode := opCode;
		// TFS 62649 end
		
		ediFile.setFileSenderCode(_fullValue.String);
	elseif _name = ETRow_Receiver then
		self.receiver := _fullValue.String;
		ediFile.setFileRecipientCode(_fullValue.String);
	elseif _name = ETRow_ManifestType then
		self.type := _fullValue.String;
		self.getMyActiveEDIData();							// TFS 62649
		ediFile.setEdiMessageType(_fullValue.String);
	elseif _name = ETRow_ManifestNumber then
		self.manifestNumber := _fullValue.String;
		ediFile.setEdiClientRef(_fullValue.String);
		ediFile.myEDIFileType.findExistingEDIFile(self.manifestNumber, ediFile, existingEdiFile);		//01.04.24		navhn30		TFS #63123
		if existingEdiFile &lt;&gt; null and self.statusString =  CMIF_JsonHeaderEUP.Status_Create  then
			self.statusString := CMIF_JsonHeaderEUP.Status_Replace;
		endif;
	elseif _name = ETRow_TransRefCust then					// 27.03.24		navhn30		TFS #63125
		self.transportReferenceCustomer := _fullValue.String;
	elseif _name = ETRow_TransRefInternal then
		self.transportReferenceInternal := _fullValue.String;
	elseif _name = ETRow_EstArrivalDate then
		ts := _fullValue.String.ediTimeStampFormat(ediFile.myEDIFileType, null, null);
		self.estimatedDateTimeOfArrival := ts;
	elseif _name = ETRow_EstDepartureDate then
		ts := _fullValue.String.ediTimeStampFormat(ediFile.myEDIFileType, null, null);
		self.estimatedDateTimeOfDeparture := ts;
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_fullValue" type="Any"/>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
