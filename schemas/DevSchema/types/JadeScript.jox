    <JadeMethod name="sh3RepVoyageRepTest" id="2db37b24-f877-438a-9290-ea91bc23ea94">
        <source>sh3RepVoyageRepTest(_designName 			: String;
					_fileFormatOption 		: Integer; 
					_filePath, _fileName 	: String; 
					_purgeFileWhenDone 		: Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     30 July 2004	cnwsh3	
//
// Purpose:     _fileFormatOptions : 
//				JadeReportWriterReport.CSV
//				JadeReportWriterReport.HTML
//				JadeReportWriterReport.XML
//				JadeReportWriterReport.TEXT
//				JadeReportWriterReport.RTF
//	
//			 
// ----------   ----------  --------------------------------------------------
vars
	qryReport			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jadeReport			: JadeReport;
	outputFileName,
	jrwFileName,
	returnStr			: String;
	jrwTransient		: CM_JRWVoyages;
	filterObject		: CMQF_HMSVoyages;
	terminal			: CM_Terminal;
	fileFolder			: FileFolder;
	workFile			: File;
	st		: Integer;
begin
	
	create jrwManager transient;
	create jadeReport transient;
	create filterObject transient;
	create fileFolder transient;
	create workFile transient;
	
	//Query database/////////////////////////////////////////////
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' -' &amp; 'querying database...');
	
	st := app.clock;
	
	terminal := app.myRoot.allTerminals['T01'];
	filterObject.allTerminals.add(terminal);
	//filterObject.myVoyage := 
	//filterObject.allQrySites.add(TI_SITE_ONSITE);
	//filterObject.myCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	//filterObject.myOperator := app.myRoot.allOperators['MSK'];

	app.myQAFilter.qryHMSVoyages(filterObject, app.myPassport);
	jrwTransient := app.myQAFilter.allJRWTransients.first.CM_JRWVoyages;

	app.writeStatement( 'database query took ' &amp; ((app.clock - st)/1000).String);
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' -retreived ' &amp; jrwTransient.allVoyages.size.String &amp; ' objects on which to report');

	st := app.clock;
	///////////////////////////////////////////////////////////////////////
	//get JRW report and run it///////////////////////////////////
	app.printer.printPreview := true;
	
	jrwReport := jrwManager.getReport(_designName);
	
	if jrwReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Design not found:' &amp; jrwFileName);
		return null;
	endif;
	
/*	fileFolder.fileName := _filePath.stripTrailingSlashes &amp; '\';
	
	if (not fileFolder.isAvailable) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Path: ' &amp; _filePath &amp; ' is not available');
		return null;
	endif;
	
	outputFileName := fileFolder.fileName &amp; _fileName;
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' - Report found. Output destination: ' &amp; outputFileName);
	jrwReport.setOutputDestination(_fileFormatOption);
	jrwReport.setOutputFileTitle(outputFileName);
	
	if _fileFormatOption = JadeReportWriterReport.HTML then
		//jrwReport.setHtmlOptions(true, true);
	endif;
*/	
	jadeReport.description := jrwReport.name;
	app.printer.setReport(jadeReport);
	jrwReport.run();
	/////////////////////////////////////////////////////////////
	//read file back in
	app.writeStatement( 'report run took ' &amp; ((app.clock - st)/1000).String);
	st := app.clock;

	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' -Report processing complete. Reading file back in');
//	workFile.fileName := outputFileName;
//	workFile.usePresentationFileSystem := false;
//	if (not workFile.isAvailable) then
//		app.raiseUnexpectedProgramError(class.name, method.name, outputFileName &amp; ' was not available');/
//		return null;
//	endif;
	//grab a chunk of space
	//returnStr[10000] := null;
//	workFile.kind := workFile.Kind_Binary;
//	workFile.open;
//	returnStr := workFile.readBinary(workFile.fileLength).String;
	
//	while (not workFile.endOfFile) do
//		returnStr := returnStr &amp; workFile.readLine() &amp; CrLf;
//	endwhile;

	app.writeStatement( 'reading file in ' &amp; ((app.clock - st)/1000).String);
	
//	return returnStr;
	////////////////////////////////////////////////////////////
epilog
	/*if workFile.fileName &lt;&gt; null then
		workFile.close;
		if _purgeFileWhenDone then
			workFile.purge;
		endif;
	endif;
	
	delete workFile;*/
	delete filterObject;
	delete jrwManager;
	delete jadeReport;
	abortTransaction;
end;</source>
        <Parameter name="_designName" type="String"/>
        <Parameter name="_fileFormatOption" type="Integer"/>
        <Parameter name="_filePath" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_purgeFileWhenDone" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sh3RepVoyageRepTestCSV" id="93925da5-987c-4efb-b048-56c9ea6826b3">
        <source>sh3RepVoyageRepTestCSV(_designName 			: String;
					_fileFormatOption 		: Integer; 
					_filePath, _fileName 	: String; 
					_purgeFileWhenDone 		: Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     30 July 2004	cnwsh3	
//
// Purpose:     _fileFormatOptions : 
//				JadeReportWriterReport.CSV
//				JadeReportWriterReport.HTML
//				JadeReportWriterReport.XML
//				JadeReportWriterReport.TEXT
//				JadeReportWriterReport.RTF
//	
//			 
// ----------   ----------  --------------------------------------------------
vars
	qryReport			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jadeReport			: JadeReport;
	outputFileName,
	jrwFileName,
	returnStr			: String;
	jrwTransient		: CM_JRWVoyageSummary;
	filterObject		: CMQF_VoyageRORODeckItemSummary;
	terminal			: CM_Terminal;
	fileFolder			: FileFolder;
	workFile			: File;
	st					: Integer;
	voyage 				: CM_Voyage;
//	outputFileName		: String;
begin
	
	create jrwManager transient;
	create jadeReport transient;
	create filterObject transient;
	create fileFolder transient;
	create workFile transient;
	outputFileName := 'c:\temp\PLANS.csv';
		
	//Query database/////////////////////////////////////////////
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' -' &amp; 'querying database...');
	//filterObject.myVoyage := '4480.36119'.asOid.CM_Voyage;
	//filterObject.myVoyage := '4480.38933'.asOid.CM_Voyage;
	filterObject.setMyVoyage( '4480.38952'.asOid.CM_Voyage );
	filterObject.modeDescr := 'Actual';
	st := app.clock;
	//app.msgBox(filterObject.myVoyage.code, null, 0);
	terminal := app.myRoot.allTerminals['BISH'];
	filterObject.allTerminals.add(terminal);

	app.myQAFilter.qryVoyageRORODeckItems(filterObject, app.myPassport);
	jrwTransient := app.myQAFilter.allJRWTransients.first.CM_JRWVoyageSummary;

	app.writeStatement( 'database query took ' &amp; ((app.clock - st)/1000).String);
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' -retreived ' &amp; jrwTransient.allDeckItemReporters.size.String &amp; ' objects on which to report');

	st := app.clock;
	///////////////////////////////////////////////////////////////////////
	//get JRW report and run it///////////////////////////////////
	//app.printer.printPreview := true;
	
	jrwReport := jrwManager.getReport(_designName);
	jrwReport.setOutputDestination(JadeReportWriterReport.CSV);
	jrwReport.setOutputFileTitle(outputFileName);
	
	if jrwReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Design not found:' &amp; jrwFileName);
		return null;
	endif;
	
/*	fileFolder.fileName := _filePath.stripTrailingSlashes &amp; '\';
	
	if (not fileFolder.isAvailable) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Path: ' &amp; _filePath &amp; ' is not available');
		return null;
	endif;
	
	outputFileName := fileFolder.fileName &amp; _fileName;
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' - Report found. Output destination: ' &amp; outputFileName);
	jrwReport.setOutputDestination(_fileFormatOption);
	jrwReport.setOutputFileTitle(outputFileName);
	
	if _fileFormatOption = JadeReportWriterReport.HTML then
		//jrwReport.setHtmlOptions(true, true);
	endif;
*/	
	jadeReport.description := jrwReport.name;
	app.printer.setReport(jadeReport);
	jrwReport.run();
	/////////////////////////////////////////////////////////////
	//read file back in
	app.writeStatement( 'report run took ' &amp; ((app.clock - st)/1000).String);
	st := app.clock;

	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' -Report processing complete. Reading file back in');
//	workFile.fileName := outputFileName;
//	workFile.usePresentationFileSystem := false;
//	if (not workFile.isAvailable) then
//		app.raiseUnexpectedProgramError(class.name, method.name, outputFileName &amp; ' was not available');/
//		return null;
//	endif;
	//grab a chunk of space
	//returnStr[10000] := null;
//	workFile.kind := workFile.Kind_Binary;
//	workFile.open;
//	returnStr := workFile.readBinary(workFile.fileLength).String;
	
//	while (not workFile.endOfFile) do
//		returnStr := returnStr &amp; workFile.readLine() &amp; CrLf;
//	endwhile;

	app.writeStatement( 'reading file in ' &amp; ((app.clock - st)/1000).String);
	
//	return returnStr;
	////////////////////////////////////////////////////////////
epilog
	/*if workFile.fileName &lt;&gt; null then
		workFile.close;
		if _purgeFileWhenDone then
			workFile.purge;
		endif;
	endif;
	
	delete workFile;*/
	delete filterObject;
	delete jrwManager;
	delete jadeReport;
	abortTransaction;
end;</source>
        <Parameter name="_designName" type="String"/>
        <Parameter name="_fileFormatOption" type="Integer"/>
        <Parameter name="_filePath" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_purgeFileWhenDone" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
