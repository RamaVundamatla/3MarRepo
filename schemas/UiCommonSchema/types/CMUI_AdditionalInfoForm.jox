    <JadeMethod name="create" id="ddd94c47-53a1-4912-952b-5670061d4474">
        <updating/>
        <source>create() updating;
//--------------------------------------------------
// Created:	16 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	userWindow : CM_UserWindowForOpen;
	cols : Integer;
begin
	
	self.setFormParent(app.mainForm);			
	create self.myDataContainer transient;
	userWindow := app.getUserWindow(self.class.name, false);
	//PAR15468 We're not calling the load form so need to set the xml again from the app.allUserWindow object if there is one.
	//Otherwise just use a hardcoded default.
	if userWindow = null then
		self.maxColumns := 4;
	else
		self.maxColumns := userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_MaxColumns).Integer;
		self.width := userWindow.width;
		self.height:= userWindow.height;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayExtraInfo" id="b574a953-4ae4-4307-9517-018cfbed6beb">
        <updating/>
        <source>displayExtraInfo() updating, protected;
//--------------------------------------------------
// Created:	16 December 2005 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	extent,
	biggest1,
	tRow :Integer;
	table : CM_DataTable;
	invalid 		: Boolean;
	ed				: Integer;
	
begin
	if self.myCurrentObject &lt;&gt; null then 
//	if (not global.isValidObject(self.myCurrentObject)) then
		on Exception do app.handleDeletedObject(exception, self.myCurrentObject, invalid);
		ed := self.myCurrentObject.edition();		// Dereference to check if it is valid
		if invalid then
			self.myCurrentObject := null;
		endif;
	endif;
	
	table := self.tblExtraInfo;
	
	table.rows := 0;
	
	self.myDataContainer.allBlocks.purge();
	
	if self.myCurrentObject = null then
		self.lblNoDetails.visible := true;
		self.lblNoDetails.centreWindow();
		self.lblNoDetails.zOrder(1);
		return;
	else
		self.lblNoDetails.visible := false;
	endif;

	self.myCurrentObject.getExtraInfo(self.myDataContainer);
	self.showExtraInformation(self.myDataContainer, table, true, false, self.maxColumns, 1, 1, 1, 1);
	
	if table.columns &gt; 1 then
	    tRow := 1;
   	    table.column := 1;	    
	    while tRow &lt;= table.rows do
	    	table.row := tRow;	    
	    	extent := table.getTextExtent(table.text);
	    	if extent &gt; biggest1 then
	    		 biggest1 := extent;
	    	endif;
	    	tRow := tRow + 1;
	    endwhile;

   	    table.column := 1;	
	    table.columnWidth[1] := biggest1 + 3;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNumberOfColumns" id="fa0fdb35-e9ac-45b4-a95f-e1a61ed015b0">
        <updating/>
        <source>doNumberOfColumns(_menuItem : MenuItem input; _maxColumns : Integer) updating, protected;
//--------------------------------------------------
// Created:	04 January 2006 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.mnuColTwo.checked := false;
	self.mnuColFour.checked := false;
	self.mnuColSix.checked := false;
	self.mnuColEight.checked := false;				
	self.mnuColTen.checked := false;
	
	if _maxColumns = 2
	or _maxColumns = 4
	or _maxColumns = 6
	or _maxColumns = 8		
	or _maxColumns = 10 then
		self.maxColumns := _maxColumns;
		_menuItem.checked := true;
	else
		self.maxColumns := 4;
		self.mnuColFour.checked := true;		
	endif;
	
	
	self.displayExtraInfo();
	
end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
        <Parameter name="_maxColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="2b64b5c6-12d6-4112-84f9-11c27010170d">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	04 January 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.displayExtraInfo();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="0b8ec7db-a4b3-4f34-b748-e89f6ecfedb1">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	04 January 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	return inheritMethod() &amp; global.formatAsXML(self.XMLTag_MaxColumns, self.maxColumns.Integer.String);	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="c00dbc3d-8d39-4b9c-8a0f-27521871121d">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//--------------------------------------------------
// Created:	04 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpMaxCol : Integer;
begin
	inheritMethod(_userWindow);
		
	if _userWindow = null then
		return;
	endif;
	
	tmpMaxCol := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_MaxColumns).Integer;

	if tmpMaxCol = 2 then
		self.mnuColTwo.checked := true;
		self.maxColumns := tmpMaxCol;
	elseif tmpMaxCol = 4 then
		self.mnuColFour.checked := true;
		self.maxColumns := tmpMaxCol;
	elseif tmpMaxCol = 6 then
		self.mnuColSix.checked := true;
		self.maxColumns := tmpMaxCol;
	elseif tmpMaxCol = 8 then
		self.mnuColEight.checked := true;
		self.maxColumns := tmpMaxCol;
	elseif tmpMaxCol = 10 then
		self.mnuColTen.checked := true;
		self.maxColumns := tmpMaxCol;
	else
		self.mnuColFour.checked := true;	
		self.maxColumns := 4;
	endif;
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="083c2149-db70-43d1-8c69-438230684987">
