    <JadeMethod name="addToolbarControls" id="76be1542-ab11-49a6-8df1-d28802ed4d31">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;

	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addFrame(self.frmTBViewMode, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnFlipH, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnFlipV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnFlipH_click" id="4378215a-6e7a-4761-978d-55cf1732666d">
        <controlMethod name="Button::click"/>
