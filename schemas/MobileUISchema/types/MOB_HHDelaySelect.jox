    <JadeMethod name="doAddDelay" id="5af8b80c-14b2-4329-87f9-77f3bea46d39">
        <updating/>
        <source>doAddDelay() updating, protected;
// 'Add' button click
vars

begin
	if self.myVoyage = null and
	   self.myMachine = null then
		return;
	endif;

	self.myMobileGenericAgent.setMyVoyage(self.myVoyage);
	if self.myMachine = null then
		self.myMobileGenericAgent.setStringField1(null);
	else
		self.myMobileGenericAgent.setStringField1(self.myMachine.getOidString());
	endif;
	self.gotoForm( MOB_HHDelayAdd, false );
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEditDelay" id="6f3f513b-1158-4523-8a6b-897cd42365ff">
        <updating/>
        <source>doEditDelay() updating, protected;
// 'Edit' button click
vars

begin
	if self.myVoyage = null and
	   self.myMachine = null then
		return;
	endif;

	self.myMobileGenericAgent.setMyVoyage(self.myVoyage);
	if self.myMachine = null then
		self.myMobileGenericAgent.setDriver(null);
	else
		self.myMobileGenericAgent.setDriver(self.myMachine.getOidString());
	endif;
	self.gotoForm( MOB_HHDelayList, false );
end;
</source>
        <access>protected</access>
    </JadeMethod>
