    <JadeMethod name="toolbarShowCaptions" id="2338230d-348f-4b63-aaf7-b03a034d4a14">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//20 Jan 2017	cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.frmFindReplace.top := self.frmFindReplace.top + heightDiff;
	self.frmSearch.top := self.frmSearch.top + heightDiff;
	self.tblData.top := self.tblData.top + heightDiff;
	self.doResize();
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
