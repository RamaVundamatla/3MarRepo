    <JadeMethod name="setProxyFlexiGate" id="a2d8ff7a-ab42-4779-bfe6-7435361cc10a">
        <updating/>
        <source>setProxyFlexiGate(_driverCode : String; _driverName : String; _carrier : String; _subCarrier : String; _regNumber : String; _state : String; _yic : String; _term : CM_Terminal; _gate: CM_Gate; _gateLane : CM_YardController; _ownerTrailerID : String) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 06/12/2016 cnwrh7	TFS	3032
// 13/05/2022 navhl20 	TFS 53430  EUP - Sub Carrier registration in MTN
// ---------------------------------------------------------------------------

vars

begin
	self.myTerminal := _term;
	self.transferAreaId := _yic;
	self.driversName := _driverName;
	self.driverCode := _driverCode;
	self.carrierCode := _carrier;
	self.subCarrierCode := _subCarrier;       // 13/05/2022 navhl20 TFS 53430 
	//self.regNumber := _regNumber;											//-TFS3032
	self.regNumber := _regNumber.removeTabCrLfs();		//+TFS3032
	self.state := _state;
	self.myGateLaneController := _gateLane;
	self.ownerTrailerID := _ownerTrailerID;
	self.myGateIn := _gate;
epilog

end;</source>
