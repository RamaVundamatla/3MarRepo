    <JadeMethod name="getAuditTextForProperty" id="4ef26fd3-0a44-4ffd-8df0-fd5e306a269c">
        <source>getAuditTextForProperty(_property: Property): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	propName : String;
	
begin

	propName := _property.name;

	if propName = CM_ResourceTypeUsage::myResourceType.name then
		return self.formatAuditText(propName, self.myResourceType.description);
	
	elseif propName = CM_ResourceTypeUsage::quantity.name then
		return self.formatAuditText(propName, self.quantity.String &amp; " " &amp; self.myResourceType.unitDescription );
	
	else	
		return inheritMethod(_property);
		
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBookingRef" id="e029ca54-cd92-47cc-b9ba-8f71e0696fad">
        <source>getBookingRef():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 October 2010	cnwndl1	Initial creation	Par 23800

*/

vars

	ti : CM_TrackedItem;
	
begin

	if myTransaction &lt;&gt; null 
	and self.myTransaction.isKindOf(CM_TITransaction) then
		ti := self.myTransaction.CM_TITransaction.myTrackedItem;
		if ti &lt;&gt; null then
			return ti.bookingReference;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
