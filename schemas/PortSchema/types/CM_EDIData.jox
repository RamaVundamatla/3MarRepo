    <JadeMethod name="getRealBOL" id="3c1f5abc-89c5-4c17-898b-a529fdbd9fc6">
        <source>getRealBOL(_ediBOL :CM_EDIBOLHdrTI):CM_BOL;
/*
Date		Who		Reason
20/06/2012	cnwcs5	Initial creation - par 29747
17/12/2018	jlgdap1	TFS 40930 AAT Avoid picking up a BOL for another voyage with the same BOL number
*/
vars
	operator	: CM_Operator;
	bolTerminal	: CM_BOLTerminal;
	bol			: CM_BOL;
begin
	operator	:=	app.myRoot.allOperators[_ediBOL.operatorCode];	
	bolTerminal	:=	self.getMyTerminal.allBOLTermsByTypeOpNum.getAtKey(_ediBOL.bolType, operator, _ediBOL.id);
	
	if bolTerminal &lt;&gt; null then
		bol :=	bolTerminal.myBOL;
		// TFS 40930 If we just rely on the BOL number and Operator, this isn't unique enough.		// TFS 40930
		// AAT had the situation where a supplier was re-using BOL numbers with different cargo		// TFS 40930
		// and voyage, and the old BOL was found here. This caused the old BOL's cargo items		// TFS 40930
		// (which were off site) to be planned to nowhere from nowhere								// TFS 40930
		// Try to prevent this happening by making sure the BOL we find here is for the 			// TFS 40930
		// same voyage as the EDI BOL header														// TFS 40930
		if bol.getMyVoyage &lt;&gt; null and bol.getMyVoyage.code &lt;&gt; _ediBOL.getVoyageCode then			// TFS 40930
			bol := null;																			// TFS 40930
		endif;																						// TFS 40930
	endif;
	
	return bol;
epilog

end;</source>
        <Parameter name="_ediBOL" type="CM_EDIBOLHdrTI"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="getRealBreakBulkItem" id="327a8293-59a3-481d-a153-33ecb1d1f034">
        <source>getRealBreakBulkItem(_ediTI : CM_EDICargoTI; _cargoType: CM_CargoType; _dict: CM_TIByCargoTypeIdDict): CM_TrackedItem;
/*
	PAR 32476 Find a break bulk item that matches both id and location
	06/10/2023	navcs2		Bug 60776: EUP | FR 53824 - Transport Manifest - Duplicate Item IDs for different Cargo Group IDs

*/
vars
	startObject, ti: CM_TrackedItem;
	iter: Iterator;
begin
	startObject := _dict.getAtKeyGeq(_ediTI.cargoType,_ediTI.id);
	if startObject &lt;&gt; null then
		iter := _dict.createIterator;
		iter.startAtObject(startObject);
		while iter.next(ti) do
			if ti.cargoType &lt;&gt; _ediTI.cargoType then
				break;
			endif;
			if ti.getMyCargoGroupId &lt;&gt; _ediTI.cargoGroupId then				// 06/10/2023	navcs2		Bug 60776
				break;														// 06/10/2023	navcs2		Bug 60776
			endif;															// 06/10/2023	navcs2		Bug 60776
			/* //14.Nov.2023 navsp1 TFS 61127
			if self.isTransportManifestRelated and ti.operatorCode &lt;&gt; _ediTI.operatorCode then	   //09.Nov.2023 navsp1 TFS 61067
				break;
			endif;*/
			
			if ti.id &lt;&gt; _ediTI.id then
				break;
			endif;
			if _ediTI.locationId = null then	//cnwmc5 - 30 Oct 2014 - PAR 35151
				return ti;						//cnwmc5 - 30 Oct 2014 - PAR 35151
			endif;								//cnwmc5 - 30 Oct 2014 - PAR 35151
			if ti.myPrimaryActualLocation = null then
				continue;
			endif;
			if ti.myPrimaryActualLocation.sameAs(_ediTI.locationId) then
				return ti;
			endif;
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_dict" type="CM_TIByCargoTypeIdDict"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
