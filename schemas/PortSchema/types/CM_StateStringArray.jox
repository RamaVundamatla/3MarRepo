<Class name="CM_StateStringArray" id="1a3ac12e-09e1-4e36-bfd5-15d850bc3f90">
    <superclass name="CM_StateData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmstate"/>
    <ExplicitInverseRef name="myValueArray" id="4c1226bb-078f-4923-8fd2-07123b3f1c90">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="StringArrayStateData"/>
        <access>readonly</access>
        <Inverse name="StringArrayStateData::myCMStateStringArray"/>
    </ExplicitInverseRef>
    <JadeMethod name="getValue" id="aafdf640-2d4a-478f-b14d-11c34528afda">
        <source>getValue(): Any;

vars

begin
	return self.myValueArray;
end;
</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="4559a782-ef3a-4b99-83e5-b13ab675f89a">
        <updating/>
        <source>setValue(pValue: Any) updating;

vars
	arr : StringArrayStateData;
	str : String;
begin
	if myValueArray = null then
		if self.isTransient then
			create myValueArray transient;
		else
			create myValueArray;
		endif;
	endif;
	myValueArray.clear;
	arr := pValue.StringArrayStateData;
	foreach str in arr do
		myValueArray.add(str);
	endforeach;		
end;
</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
</Class>
