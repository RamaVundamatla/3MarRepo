    <JadeMethod name="getKeyLengthForXTABDictionary" id="91d56f6d-58ec-4d2e-be4f-02eefadbf07d">
        <source>getKeyLengthForXTABDictionary(): Integer;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars

begin
	return CM_ConsigneeConsignor::code.length;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWebDataRowName" id="57092e29-ed04-4db0-8f0e-c1fcaf0575a6">
        <source>getWebDataRowName(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if self.type = CONSIGNEE then
		return ETRow_Consignee;
	elseif self.type = CONSIGNOR then
		return ETRow_Consignor;
	elseif self.type = FREIGHT_FORWARDER then
		return ETRow_FreightForwarder;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="b8c21051-3f27-4c2a-a737-4d95cdcd635f">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------
// 23/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
vars
	con			: CM_ConsigneeConsignor;
	conDict		: CM_ConsignByCodeDict;
	qrl			: CM_QReferenceLookup;
	byName 		: Boolean;					// TFS 53362
begin
	_combo.clear();
	conDict := app.myRoot.allConsigneeConsignors;
	byName := app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean;		// TFS 53362
	
	foreach con in conDict do
		if self.type = 0 then
			// Add all entries
		elseif self.type = FREIGHT_FORWARDER and not con.isFreightFwdr then
			continue;
		elseif self.type = CONSIGNEE and not con.isConsignee then
			continue;
		elseif self.type = CONSIGNOR and not con.isConsignor then
			continue; 
		endif;
		
		if byName then																		// TFS 53362
			_combo.itemObject[_combo.addItem(con.description &amp; Tab &amp; con.code)] := con;		// TFS 53362
		else																				// TFS 53362
			_combo.itemObject[_combo.addItem(con.code &amp; Tab &amp; con.description)] := con;
		endif;																				// TFS 53362
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="57fb5187-6234-4214-8ec7-80c773470693">
        <source>translateToDisplayValue(_value: Any): String;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars

begin
	if _value.isKindOf (CM_ConsigneeConsignor) then	
		if _value &lt;&gt; null then
			return _value.CM_ConsigneeConsignor.code;
		else
			return null;
		endif;
	endif;
	
	return _value.String;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="7ab125dd-55c3-484a-8c87-3024537464eb">
        <source>translateToSearchValue(_value: Any): Any;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;

		if _value.isKindOf(CM_ConsigneeConsignor) then
			return _value.CM_ConsigneeConsignor;
		endif;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="2047acc6-8cd8-4655-b671-67c25dc86890">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(String) then
		return app.myRoot.allConsigneeConsignors[_value.String];
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
