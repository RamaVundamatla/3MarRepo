<Class name="CM_ExportReturned" id="f3f326b1-97c4-4304-bab9-dd86ae67e0e5">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <JadeMethod name="updateTI" id="a8b52bf4-e7dc-4dd8-ba7a-5f5693b9bd21">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
//------------------------------------------------
// Created: 09 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	inheritMethod(_passport);
	if self.myTrackedItem &lt;&gt; null then
		self.myTrackedItem.setExportReturned(true);
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
