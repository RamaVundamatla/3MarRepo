    <JadeMethod name="setCMIFBOLOutForNew" id="b06a6021-7cba-4713-b953-5d052a852d79">
        <source>setCMIFBOLOutForNew(_cmifBOLOut : CMIF_BOLOut input) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_EntryTable;
	obj			: Object;
	ti			: CM_TrackedItem;
	bolOutLine	: CMIF_BOLOutLine;
	date: Date;
	idColumn,
	numRows,
	row			: Integer;
begin
	if _cmifBOLOut = null then	
		return false;
	endif;
	
	if self.mode &lt;&gt; self.Mode_New then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Incorrect method called for mode');
		return false;
	endif;
	
	tbl := self.tblMasterEnt;
	_cmifBOLOut.bolType := BOLType_GeneralDocket;
	_cmifBOLOut.myTerminal := self.myTerminal;
	_cmifBOLOut.bolNumber := tbl.getValueByName(ETRow_Number).String;
	_cmifBOLOut.myStockOrder := self.cmbStockOrder.listObject.CM_StockOrderHeaderGeneric;
	_cmifBOLOut.myOperator := self.cmbOperator.myObject.CM_Operator;
	_cmifBOLOut.myConsignee := self.cmbConsignee.myObject.CM_ConsigneeConsignor;
	_cmifBOLOut.myConsignor := self.cmbConsignor.myObject.CM_ConsigneeConsignor;
//	date := tbl.getValueByName(ETRow_ReferenceDate).Date;
	date := tbl.getValueAsDate(ETRow_ReferenceDate);
	
	if date.isValid then
		_cmifBOLOut.referenceDate := date;
	endif;
	if self.cmbProcessOpt.listIndex &lt;&gt; -1 then   // if no cmbProcessOpt selected will cause exception 
		_cmifBOLOut.processOption := self.cmbProcessOpt.itemData[self.cmbProcessOpt.listIndex];
	endif;
	_cmifBOLOut.noCharge := (not tbl.getValueByName(ETRow_Charged).Boolean);
	//th2 PAR 12493 - Duplicate Item Error when packing containers in General Cargo Loadout for BML
	//ensure an ID is entered for every detail row, otherwise the placeholder object behind the row maybe a 
	//duplpicate of one already entered, even though no ID has been selected.
	numRows := self.tblDataDetail.rows;
	idColumn := self.tblDataDetail.getColumnByRowName(ETRow_Id);
	foreach row in self.tblDataDetail.fixedRows + 1 to numRows do
		if self.tblDataDetail.accessCell(row, idColumn).text = null then
			app.msgBox('Line number ' &amp; (row - self.tblDataDetail.fixedRows).String &amp; ') has no item ID assigned. You must select one, or remove that line.',
					'No ID selected', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endforeach;

	_cmifBOLOut.allTrackedItems.clear();
	foreach obj in self.allDetailObjects do
		ti := obj.CMIF_BOLOutLine.myTrackedItem;
		if ti = null then
			continue;
		endif;
		if _cmifBOLOut.allTrackedItems.includes(ti) then
			app.msgBox('Item (' &amp; ti.id &amp; ') has been assigned to more then 1 row.  Please correct',
					'Duplicate Item', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		else
			_cmifBOLOut.allTrackedItems.add(ti);
		endif;
	endforeach;

	if _cmifBOLOut.processOption = Process_Pack then
		_cmifBOLOut.myMasterTI := self.cmbPackInto.listObject.CM_TrackedItem;
		
		if _cmifBOLOut.myMasterTI &lt;&gt; null then
			_cmifBOLOut.editionMasterTI := _cmifBOLOut.myMasterTI.edition;
			_cmifBOLOut.doUpdateParentContainer := true;
			_cmifBOLOut.myOperatorCont:= self.cmbContOp.myObject.CM_Operator;
			//th2 for PAR13885 14/04/07 - string too long error
			//_cmifBOLOut.containerDisPort := self.tblMasterEnt.getValueByName(ETRow_DischargePort).String;
			if self.cmbDisPort.listObject &lt;&gt; null then
				_cmifBOLOut.containerDisPort := self.cmbDisPort.listObject.CM_Port.code;
			endif;
			_cmifBOLOut.containerVolume := self.tblMasterEnt.getValueByName(ETRow_ContainerVolume).Decimal;
			_cmifBOLOut.volume := self.tblMasterEnt.getValueByName(ETRow_TotalVolume).Decimal;
			_cmifBOLOut.containerWeight := self.tblMasterEnt.getValueByName(ETRow_ContainerWeight).Integer;
			_cmifBOLOut.weightTotal := self.tblMasterEnt.getValueByName(ETRow_WeightTotal).Integer;
			_cmifBOLOut.containerBookingRef := self.tblMasterEnt.getValueByName(ETRow_BookingRef).String;
			_cmifBOLOut.myIMEXStatus := self.cmbIMEX.listObject.CM_IMEXStatus;
			_cmifBOLOut.myCommodity := self.cmbCommodity.listObject.CM_Commodity;
			_cmifBOLOut.myBulkRelease := self.cmbBR.listObject.CM_BulkRelease;
			_cmifBOLOut.myContentsStatus := self.cmbContents.listObject.CM_ContentsStatus;
			_cmifBOLOut.containerSealNum := self.tblMasterEnt.getValueByName(ETRow_Seal).String;
			_cmifBOLOut.containerSealNumCustoms := self.tblMasterEnt.getValueByName(ETRow_SealNumCustoms).String;// HJG added 11/01/05
			_cmifBOLOut.containerSealNumShippers := self.tblMasterEnt.getValueByName(ETRow_SealNumShippers).String;// HJG added 11/01/05
			_cmifBOLOut.containerPrevSealNum := self.tblMasterEnt.getValueByName(ETRow_PrevSealNum).String;// HJG added 11/01/05
			_cmifBOLOut.containerCEDONum := self.tblMasterEnt.getValueByName(ETRow_CedoNum).String;
			//the packing utl should move everything to the masterTIs location
			_cmifBOLOut.doNotMoveAsPartOfCreate := true;
		endif;
		
	elseif _cmifBOLOut.processOption = Process_Direct_Loadout then
		_cmifBOLOut.doNotMoveAsPartOfCreate := false;//DO move it
		if self.cmbTransportMode.listIndex &lt;&gt; -1 then // if no cmb item selected will cause exception 
			_cmifBOLOut.transportMode := self.cmbTransportMode.itemData[self.cmbTransportMode.listIndex];
		endif;	
		if _cmifBOLOut.transportMode = TI_TRANSMODE_ROAD then
			_cmifBOLOut.carrierCode := tbl.getValueByName(ETRow_CarrierCode).String;
			_cmifBOLOut.regNumber := tbl.getValueByName(ETRow_VehicleId).String;
		
		elseif _cmifBOLOut.transportMode = TI_TRANSMODE_RAIL then
			//cnwth yet to do
		elseif _cmifBOLOut.transportMode = TI_TRANSMODE_SHIP then
			_cmifBOLOut.bolType := BOLType_GeneralBillOfLading;
			_cmifBOLOut.myVoyage := self.cmbVoyage.listObject.CM_Voyage;
		
		endif;
	endif;
	
	_cmifBOLOut.numItems := _cmifBOLOut.allTrackedItems.size;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmifBOLOut" type="CMIF_BOLOut" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCMIFBOLOutForUpdate" id="c0ef34c8-5f7e-4617-bcc9-d5d2ad2bbef5">
        <source>setCMIFBOLOutForUpdate(_cmifBOLOut : CMIF_BOLOut input) protected;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_EntryTable;
	obj			: Object;
	ti			: CM_TrackedItem;
	bolOutLine	: CMIF_BOLOutLine;
	realBOLOut		: CM_BOLOut;
	date: Date;
begin

	if _cmifBOLOut = null then	
		return;
	endif;
	
	if self.mode &lt;&gt; self.Mode_Edit then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Incorrect method called for mode');
		return;
	endif;
	
	realBOLOut := self.myCurrentMasterPxy.pxyGetRealObject().CM_BOLOut;
	if realBOLOut = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy cannot locate real');
		return;
	endif;
	
	_cmifBOLOut.setMyPersistentBOL(realBOLOut);
	_cmifBOLOut.setMyProxyBOL(self.myCurrentMasterPxy.CM_BOLOut);
	
	tbl := self.tblMasterEnt;
	_cmifBOLOut.bolType := realBOLOut.bolType;
	_cmifBOLOut.myTerminal := realBOLOut.myTerminal;
	_cmifBOLOut.bolNumber := tbl.getValueByName(ETRow_Number).String;
	_cmifBOLOut.myStockOrder := realBOLOut.myStockOrderHeader;
	_cmifBOLOut.myOperator := self.cmbOperator.myObject.CM_Operator;
	_cmifBOLOut.myConsignee := self.cmbConsignee.myObject.CM_ConsigneeConsignor; 
	_cmifBOLOut.myConsignor := self.cmbConsignor.myObject.CM_ConsigneeConsignor; 

//	date := tbl.getValueByName(ETRow_ReferenceDate).Date;
	date := tbl.getValueAsDate(ETRow_ReferenceDate);
	
	if date.isValid then
		_cmifBOLOut.referenceDate := date;
	endif;
	_cmifBOLOut.processOption := realBOLOut.processOption;
	_cmifBOLOut.noCharge := (not tbl.getValueByName(ETRow_Charged).Boolean);
	
	if _cmifBOLOut.processOption = Process_Pack then
		_cmifBOLOut.myMasterTI := realBOLOut.myMasterTI;
		
		if _cmifBOLOut.myMasterTI &lt;&gt; null then
			_cmifBOLOut.editionMasterTI := _cmifBOLOut.myMasterTI.edition;
			_cmifBOLOut.doUpdateParentContainer := true;
			_cmifBOLOut.myOperatorCont:= self.cmbContOp.myObject.CM_Operator;
			//th2 for PAR13885 14/04/07 - string too long error
			//_cmifBOLOut.containerDisPort := self.tblMasterEnt.getValueByName(ETRow_DischargePort).String;
			if self.cmbDisPort.listObject &lt;&gt; null then
				_cmifBOLOut.containerDisPort := self.cmbDisPort.listObject.CM_Port.code;
			endif;
			_cmifBOLOut.containerVolume := self.tblMasterEnt.getValueByName(ETRow_ContainerVolume).Decimal;
			_cmifBOLOut.volume := self.tblMasterEnt.getValueByName(ETRow_TotalVolume).Decimal;
			_cmifBOLOut.containerWeight := self.tblMasterEnt.getValueByName(ETRow_ContainerWeight).Integer;
			_cmifBOLOut.weightTotal := self.tblMasterEnt.getValueByName(ETRow_WeightTotal).Integer;
			_cmifBOLOut.containerBookingRef := self.tblMasterEnt.getValueByName(ETRow_BookingRef).String;
			_cmifBOLOut.myIMEXStatus := self.cmbIMEX.listObject.CM_IMEXStatus;
			_cmifBOLOut.myCommodity := self.cmbCommodity.listObject.CM_Commodity;
			_cmifBOLOut.myBulkRelease := self.cmbBR.listObject.CM_BulkRelease;
			_cmifBOLOut.myContentsStatus := self.cmbContents.listObject.CM_ContentsStatus;
			_cmifBOLOut.containerSealNum := self.tblMasterEnt.getValueByName(ETRow_Seal).String;
			_cmifBOLOut.containerSealNumCustoms := self.tblMasterEnt.getValueByName(ETRow_SealNumCustoms).String;// HJG added 11/01/05
			_cmifBOLOut.containerSealNumShippers := self.tblMasterEnt.getValueByName(ETRow_SealNumShippers).String;// HJG added 11/01/05
			_cmifBOLOut.containerPrevSealNum := self.tblMasterEnt.getValueByName(ETRow_PrevSealNum).String;// HJG added 11/01/05
			_cmifBOLOut.containerCEDONum := self.tblMasterEnt.getValueByName(ETRow_CedoNum).String;
		endif;
	endif;
	
	_cmifBOLOut.numItems := realBOLOut.allTrackedItems.size;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifBOLOut" type="CMIF_BOLOut" usage="input"/>
    </JadeMethod>
