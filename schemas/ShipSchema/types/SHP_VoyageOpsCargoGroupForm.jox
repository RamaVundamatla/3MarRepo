end;</source>
        <Parameter name="_childrenOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedTIs" id="6be62df7-c36c-489f-a926-5e467bdb1f29">
        <source>getAllSelectedTIs(_context : String; _tiSet: CM_TISet input; _all: Boolean; _table: CM_DataTable input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
10 May 2022	navsrk20	Initial creation TFS 53388
08 Nov 2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
15 May 2024 navma1		Bug 64148: MTN - Error 1309 When selecting Cargo items on Voyage ops Screen
*/

vars
	rowIdx,
	rows,
	startRow	: Integer;
	trackedItem : CM_TrackedItem;
begin
	if _tiSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiSet passed to method');
		return;
	endif;

	if _table = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _table passed to method');
		return;
	endif;	

	if _all then
		rows := _table.rows;
		startRow := _table.fixedRows + 1;
		foreach rowIdx in startRow to rows do
			trackedItem := _table.accessRow(rowIdx).itemObject.CM_TrackedItem;
			if trackedItem = null then
				continue;
			endif;

			if trackedItem.isCargoGroupItem() then
				self.getTIsForCargoGroup(_context, _tiSet, trackedItem.CM_CargoGroup);
			else
				// ### TFS 58922 04JUL2023 NAVAB1
				if _context =Select_Context_Plan then
					if trackedItem.allPlannedFutureMoves.size &gt; 0 then
						continue;
					endif;
				elseif _context = Select_Context_Unplan then
					if trackedItem.allPlannedFutureMoves.size = 0 then
						continue;
					endif;
				elseif _context = Select_Context_Unqueue then
					if trackedItem.allQueuedFutureMoves.size = 0 then
						continue;
					endif;
				endif;
				_tiSet.tryAdd(trackedItem);		//15.05.2024 navma1 #64148
			endif;		
		endforeach;		
	else
		foreach trackedItem in _table.allSelectedObjects as CM_TrackedItem do

			if trackedItem.isCargoGroupItem() then
				self.getTIsForCargoGroup(_context, _tiSet, trackedItem.CM_CargoGroup);
			else
				// ### TFS 58922 04JUL2023 NAVAB1
				if _context = Select_Context_Plan then
					if trackedItem.allPlannedFutureMoves.size &gt; 0 then
						continue;
					endif;
				elseif _context = Select_Context_Unplan then
					if trackedItem.allPlannedFutureMoves.size = 0 then
						continue;
					endif;
				elseif _context = Select_Context_Unqueue then
					if trackedItem.allQueuedFutureMoves.size = 0 then
						continue;
					endif;
				endif;
				_tiSet.tryAdd(trackedItem);						//15.05.2024 navma1 #64148
			endif;		
		endforeach;	
	endif;
	
end;</source>
        <Parameter name="_context" type="String"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTIsInCurrentTable" id="0facde93-05b1-4f97-96f4-aff47457c38a">
        <updating/>
        <source>getAllTIsInCurrentTable(_table: CM_DataTable; _tiSet: CM_TISet input) updating;
/*
Purpose:			

Date		Who		Reason
10 July 2023	navab1	 BUG 58922
*/

vars
	idx,
	rows	: Integer;
	ti		: CM_TrackedItem;
	isLoad	: Boolean;
	table	: CM_DataTable;
	cg : CM_CargoGroup;
begin
	if _table = null then
		return;
	endif;
	
	rows := _table.rows;
	table := _table;
	_tiSet.clear;
	isLoad := _table = self.tblOnsite;
	
	foreach idx in _table.fixedRows + 1 to rows do
		ti := table.accessRow(idx).itemObject.CM_TrackedItem;
		if ti = null then
			continue;
		endif;
		if ti.isCargoGroupItem() then
			cg := ti.CM_CargoGroup;
			foreach ti in cg.allAssignedTrackedItems discreteLock do
				if not _tiSet.includes(ti) then
					_tiSet.add(ti);
				endif;
				
			endforeach;
		else
			if not _tiSet.includes(ti) then
				_tiSet.add(ti);
			endif;
		endif;
	endforeach;
	

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCurrentTableLineForObject" id="ef991e36-afb9-4d8e-81a6-a8041eef2d85">
        <source>getCurrentTableLineForObject(_table: CM_BaseTable; _obj: Object; _rowIdx: Integer): String;
/*

Purpose:			
		Reimplement to get the Cargo Group details base on the sites we are interested in
Parameters:			

Return Value:		

Date				Who		Reason
17 November 2022	navkc1	Initial creation	Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
10 May 2023			navmd1	TFS 56062 Fix incorrect header values
04 April	2024    navsp1  TFS Bug 61223: EUP | Cancel Transport Manifest not deleting all Cargo and doesn't db load.
*/

vars
	cargoGroup		: CM_CargoGroup;
	site			: Integer;
	detail,
	combinedDtl		: CM_CargoGroupDetail;
	indicator		: String;
	table			: CM_DataTable;
	currentVoyage	: CM_Voyage;
	invalid			: Boolean;//TFS 61223
begin
	on SystemException do app.cnHandleNullOrInvObjectRef(exception, null, invalid); //TFS 61223
	
	table := _table.CM_DataTable;
	
	if table = null or _obj = null then
		return null;
	endif;
	
	_obj.edition();					//TFS 61223
	if invalid then					//TFS 61223
		return null;				//TFS 61223
	endif;							//TFS 61223
	
	if not _obj.CM_TrackedItem.isCargoGroupItem then
		return inheritMethod(table, _obj, _rowIdx);
	endif;
	
	cargoGroup := _obj.CM_CargoGroup;
	indicator := table.accessCell(_rowIdx, 1).text[1];
	
	site := self.getSiteForTable(table);
	detail := self.myCurrentVoyage.allCargoGroupDtlBySiteCargoGrp[site, cargoGroup.id]; // ### TFS BUG 58853 10JUL2023 NAVAB1
	/* // ### TFS BUG 58853 10JUL2023 NAVAB1
	create combinedDtl transient;
	combinedDtl.initialise(null, site, cargoGroup, null, null);
	
	// The current voyage here is not checked for validity, so don't dereference it!
	currentVoyage := self.myCurrentVoyage;
	
	// There should only be 1 detail for the "site"/table we're interested in
	foreach detail in cargoGroup.allCargoGroupDetails discreteLock where detail.site = site do
		if detail.myVoyage &lt;&gt; null and detail.myVoyage &lt;&gt; currentVoyage then
			continue;	// Not our voyage, skip
		endif;
		combinedDtl.combine(detail);
	endforeach;
	*/
	if detail &lt;&gt; null
	and detail.allAssignedTrackedItems.size &gt; 0 then
		return indicator &amp; detail.getAttributeStringForDefArray(table.allTblDataEntRows);
	endif;
	
	// uh oh ... errr... just return nothing
	return null;
epilog
	//delete combinedDtl;
end;</source>
        <Parameter name="_table" type="CM_BaseTable"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentlySelectedTIs" id="32b90af1-2fc6-49ea-8fcb-dda329837673">
        <source>getCurrentlySelectedTIs(_tiSet: CM_TISet input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2022	navsrk20	Bug 53905: EUP - Planning issues for Cargo Groups in Voyage Operations screen

*/

vars

begin
	self.getAllSelectedTIs("", _tiSet, false, self.myCurrentContextTbl);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDragDropTIsForController" id="ee2654c9-5c3e-42c7-8bd8-aa3ba833eed3">
        <updating/>
        <source>getDragDropTIsForController(_controller: CMIF_MoveController input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/05/2022	navdap1		Initial creation TFS 53388
// 08/11/2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
// 06/09/2024   navma1		Bug 65985: EUP - Error 1311 when using voyage ops screen
vars
	ti,
	firstTi		: CM_TrackedItem;
begin
	ti := _controller.myTrackedItem;
	
	if not ti.isCargoGroupItem then
		return;
	endif;
	
	firstTi := self.getTIsForCargoGroup("", _controller.allOtherTrackedItems, ti.CM_CargoGroup);
	
	if firstTi &lt;&gt; null then			//06.09.2024 navma1 #65985
		//09Jan2023 navsp1 TFS 56063 - The previous behaviour of removing the first TI from the collection has been reintroduced.
		_controller.allOtherTrackedItems.remove(firstTi);
		_controller.setMyTrackedItem(firstTi);
	endif;
	
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIsForCargoGroup" id="28b35531-148e-4536-ba6d-859e9dc0a6f7">
        <source>getTIsForCargoGroup(_context : String; _tiColl : Collection input; _cargoGroup : CM_CargoGroup) : CM_TrackedItem protected;
/*

Purpose:			Get all 'child' TIs associated to the Cargo Group (for this voyage)

Parameters:			

Return Value:		

Date				Who		Reason
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
28 November 2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default

*/

vars
	ti, firstTi		: CM_TrackedItem;
	table 			: CM_DataTable;
	tis				: CM_TIByCargoGroupIdDict;
	iter			: Iterator;
	
begin
	if _tiColl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "input collection not set, nothing to populate");
		return null;
	endif;
	
	table := self.myCurrentContextTbl;
	
	if table = self.tblOnship then
		tis := self.myCurrentVoyage.allOnshipTIsByCargoGroupId;
	elseif table = self.tblOnsite then
		tis := self.myCurrentVoyage.allOnsiteTIsByCargoGroupId;
	elseif table = self.tblOffsite then
		tis := self.myCurrentVoyage.allOffsiteTIsByCargoGroupId;
	elseif table = self.tblPreNote then
		tis := self.myCurrentVoyage.allNotifiedTIsByCargoGroupId;
	endif;
	
	iter := tis.createIterator();
	tis.startKeyGeq(_cargoGroup, null, iter);
	
	while iter.next(ti) do
		if ti.myCargoGroup &lt;&gt; _cargoGroup then
			break;
		endif;
		// ### TFS 58922 04JUL2023 NAVAB1
		if _context = Select_Context_Plan then
			if ti.allPlannedFutureMoves.size &gt; 0 then
				continue;
			endif;
		elseif _context = Select_Context_Queue then
			if ti.allQueuedFutureMoves.size &gt; 0 then
				continue;
			endif;
		elseif _context = Select_Context_Unplan then
			if ti.allPlannedFutureMoves.size = 0 then
				continue;
			endif;
		elseif _context = Select_Context_Unqueue then
			if ti.allQueuedFutureMoves.size = 0 then
				continue;
			endif;
		endif;
		
		if firstTi = null then
			firstTi := ti;
		endif;
		
		//_tiColl.add(ti);
		_tiColl.tryAdd(ti); //30/07/2025	navkc1 JIRA MTN 35478
	endwhile;
	
	return firstTi;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_context" type="String"/>
        <Parameter name="_tiColl" type="Collection" usage="input"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="f9367f80-e91f-4841-bddb-ee306d6583e1">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 April 2022		navds20	Initial creation  TFS 53388
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
28 November 2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
*/

vars
	xmlStr	: String;
begin
	
	xmlStr := inheritMethod();
	
	// Group by cargo group and collapse all settings
	xmlStr := xmlStr &amp; global.formatAsXML(self.btnCargoGrouping.name, self.btnCargoGrouping.value.String);
	// 28/11/2022	navkc1	#55408 - Changed to expand only
	//xmlStr := xmlStr &amp; global.formatAsXML(self.btnExpandAll.name, self.btnExpandAll.value.String);
	
	return xmlStr;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handle1066" id="fa0d4fe7-012d-40d8-90ef-fa311ff2be37">
        <source>handle1066(_exc : Exception; _attr : String; _obj : Object) : Integer;
/*
Purpose:			

Date		Who		Reason
03 July 2023	navab1	 CR 55653 TASK 55669 
*/
constants
	InvalPropertyValue	= 1066;
	
vars
	returnVal		: Integer;
	aForm : Form;
begin
	returnVal := Ex_Resume_Next;
epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_attr" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="c5d45f8c-77a0-4777-b36e-f0b9b9393ba8">
        <updating/>
        <source>handleNotifications(eventType: Integer; _cargoGroup: CM_CargoGroup; eventTag: Integer; userInfo: Any) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	navsj20	Initial creation TFS 53388
18 Nov 2022	navkc1	Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
01 Dec 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
24 Jan 2023	navmp20	Bug 56062: EUP - #3, #4 Incorrect Cargo grouping/heading values
*/

vars
	table			: CM_FilterTable;
	rowIdx			: Integer;
	invalid			: Boolean;
	cargoGroupTi	: CM_TrackedItem;
	cgDetail		: CM_CargoGroupDetail;
	onshipDtl,
	onsiteDtl,
	offsiteDtl,
	prenoteDtl		: CM_CargoGroupDetail;
	
begin
	
	// Only handle CargoGroup Updates at this point
	if eventTag &lt;&gt; Object_Update_Event then
		return;
	endif;

	if self.myCurrentVoyage = null or _cargoGroup = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _cargoGroup, invalid);
	
	_cargoGroup.edition;
	if invalid then
		return;
	endif;
	
	on Exception do null;
	
	if _cargoGroup.myTerminal &lt;&gt; self.myTerminal	// should never be the case
		or not self.allDisplayedTIs.includes(_cargoGroup) then
		return;
	endif;
	
	// Check for and remove any 'yellow lines' that represent a cargo group detail that no longer exist
	foreach cgDetail in _cargoGroup.allCargoGroupDetails do
		if cgDetail.site = TI_SITE_ONSHIP then
			onshipDtl := cgDetail;
		elseif cgDetail.site = TI_SITE_ONSITE then
			onsiteDtl := cgDetail;
		elseif cgDetail.site = TI_SITE_OFFSITE then
			offsiteDtl := cgDetail;
		elseif cgDetail.site = TI_SITE_UNDEFINED then
			prenoteDtl := cgDetail;
		endif;
	endforeach;
	
	// On-Ship
	table := self.tblOnship;
	rowIdx := 0;
	if onshipDtl = null and table.findObjectInRow(_cargoGroup, rowIdx) then
		table.removeItem(rowIdx);
	endif;
	if onshipDtl &lt;&gt; null then
		self.myCargoGroup := null;
		cargoGroupTi := onshipDtl.getFirstTIForVoyage(self.myCurrentVoyage);
		self.loadCargoForTable(cargoGroupTi, rowIdx, table, false, true);
	endif;
	
	// On-Site
	table := self.tblOnsite;
	rowIdx := 0;
	if onsiteDtl = null and table.findObjectInRow(_cargoGroup, rowIdx) then
		table.removeItem(rowIdx);
	endif;
	if onsiteDtl &lt;&gt; null then
		self.myCargoGroup := null;
		cargoGroupTi := onsiteDtl.getFirstTIForVoyage(self.myCurrentVoyage);
		self.loadCargoForTable(cargoGroupTi, rowIdx, table, false, true);
	endif;

	// Off-Site
	table := self.tblOffsite;
	if table.visible then
		rowIdx := 0;
		if offsiteDtl = null and table.findObjectInRow(_cargoGroup, rowIdx) then
			table.removeItem(rowIdx);
		endif;
		if offsiteDtl &lt;&gt; null then
			self.myCargoGroup := null;
		    cargoGroupTi := offsiteDtl.getFirstTIForVoyage(self.myCurrentVoyage);
			self.loadCargoForTable(cargoGroupTi, rowIdx, table, false, true);
		endif;
	endif;
	
	// Pre-Note
	table := self.tblPreNote;
	if table.visible then
		rowIdx := 0;
		if prenoteDtl = null and table.findObjectInRow(_cargoGroup, rowIdx) then
			table.removeItem(rowIdx);
		endif;
		if prenoteDtl &lt;&gt; null then
			self.myCargoGroup := null;
			cargoGroupTi := prenoteDtl.getFirstTIForVoyage(self.myCurrentVoyage);
			self.loadCargoForTable(cargoGroupTi, rowIdx, table, false, true);
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="78b41fcf-f512-4330-a5e7-c477280612fc">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 April 2022		navds20	Initial creation TFS 53388
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
28 November 2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
08 December 2022	navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
*/

begin

	if _userWindow = null then
		return;
	endif;
	
	self.btnCargoGrouping.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.btnCargoGrouping.name).asBooleanJMT;
	self.isInCargoGrouping 		:= self.btnCargoGrouping.value; // 08/12/2022	navkc1	#55409
	
	inheritMethod(_userWindow);
	
	// // 28/11/2022	navkc1	#55408 - Changed to expand only;
	//self.btnExpandAll.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.btnExpandAll.name).asBooleanJMT;
	
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="isCargoGroupForm" id="9a0cf0d5-7a23-4914-a6e3-83569cb40dec">
        <source>isCargoGroupForm(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2022	navdap1		Initial creation TFS 53889 EUP Collapsed view not kept when moving or updating cargo
//
vars

begin
	return self.isInCargoGrouping;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCargoForTableCG" id="0c10df57-fa11-4b25-aeb4-52f9e6e61283">
        <updating/>
        <source>loadCargoForTableCG(_ti : CM_TrackedItem io; _table : CM_DataTable input; _rowIdx : Integer io; _str : String input; _fromNote : Boolean) protected, updating;
/*

Purpose:	
	This method is created to load TI into Voyage Ops screen tables if it's in Cargo Group form.
	It does similar thing as loadCargoForTable but instead of adding the TI to the last row, it first gets the TI's cargo group, 
	then locate the cargo group in the table, then add the TI as part of the cargo group.
	If the Cargo group is not found in the table, it'll create a new line for it and add the TI.
	If TI has no Cargo group, then it'll be categorized as "Unknown Cargo Group"

Parameters:			

Return Value:		

Date				Who		Reason
25 October 2022		navkc1	Initial creation Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
25 November 2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
20 April 2023		navmd1	TFS 56062 Fix Cargo Group Detail headers not updating correctly. Make sure we only add TIs to the table when we're the last row and not just updating the group via a note
*/
//--------------------------------------------------
vars
	cargoGroup			: CM_CargoGroup;
	colIdx,
	startIdx,
	startRow,
	endRow				: Integer;
	done				: Boolean;
	obj					: Object;
	row					: JadeTableRow;
	nextTi				: CM_TrackedItem;
	lastRow				: Boolean;
	tiName				: String;
	tableRow			: JadeTableRow;
begin

	// Now that we are loading cargo group by default, and user can choose what cargo group the expand, we'll know the cargo group row index // 28/11/2022	navkc1	#55408
	if _rowIdx &gt; 1 then
		_rowIdx += 1;
		_table.addItemAt(_str, _rowIdx);
		_table.accessRow(_rowIdx).itemObject := _ti;
		return;
	endif;
	
	// If we don't know the cargo group row index (most likely the TI came through notifications), find the cargo group. // 28/11/2022	navkc1	#55408
	
	// EUP Cargo Group.
	// Find where the cargo group is and add the ti below it.
	cargoGroup := _ti.myCargoGroup;
	if cargoGroup &lt;&gt; null then
		
		if cargoGroup = self.myCargoGroup then
			// Same cargo group as last time, so just add to the current position in the table
			_rowIdx := _table.addItem(_str);
			row := _table.accessRow(_rowIdx);
			row.itemObject := _ti;
		else
			self.myCargoGroup := cargoGroup;
			
			// We have a new cargo group, and we're not at the end of the table, so lets find it.
			// NB. This is a SLOW lookup, so lets avoid this as much as possible!
			if _rowIdx &lt;&gt; _table.rows then
				_rowIdx := _table.fixedRows;
				if not _table.findObjectInRow(cargoGroup, _rowIdx) then
					_rowIdx := 0;	// instructs populateCargoGroupDetails to add to the BOTTOM of the table
				endif;
			else
				_rowIdx := 0;	// instructs populateCargoGroupDetails to add to the BOTTOM of the table
			endif;			
			
			// By default, we only want to show new groups, the actual TIs can be populated later if the group is actually expanded
			if self.isInCargoGrouping and _fromNote and _rowIdx = 0 then
				// Add/Update the cargo group row
				self.populateCargoGroupDetails(-1, cargoGroup, _table.allTblDataEntRows, _table, _rowIdx);
				
				_rowIdx := -1;	// Set the rowIdx to something invalid to indicate that we didn't actually add the row, and so we shouldn't try and colour it!
				return;
			else
				// Add/Update the cargo group row
				self.populateCargoGroupDetails(-1, cargoGroup, _table.allTblDataEntRows, _table, _rowIdx);
			endif;
			
			// If successful, add the TI row
			if _rowIdx &gt; 0 then
				if _rowIdx = _table.rows then
					lastRow := true;
				else
					nextTi := _table.accessRow(_rowIdx+1).itemObject.CM_TrackedItem;
				endif;
				
				// ### TFS BUG 58853 05JUL2023 NAVAB1 - strange logic passes in first TI on the CG detail, and was adding it in again and again. Not sure why it needs the first ti every time
				if _table.findObjectInRow(_ti,startIdx) then
					nextTi := _ti;
				endif;
				
				// In case of user partially expanded some cargo groups, only load the items which user has expanded. // 28/11/2022	navkc1	#55408
				// Using nextTI to determine whether a cargo group is expanded
				if (lastRow and not _fromNote) or (nextTi &lt;&gt; null and not nextTi.isCargoGroupItem() and _ti &lt;&gt; nextTi) then
					// Add a new row, in the correct order
					
					startRow := _rowIdx + 1;
					endRow := _table.rows;
					tiName := _ti.id;
					
					foreach _rowIdx in startRow to endRow do
						tableRow := _table.accessRow(_rowIdx);
						nextTi := tableRow.itemObject.CM_TrackedItem;
						if nextTi = null or nextTi.isCargoGroupItem then
							break;	// Reached the next group, so add to the end
						endif;
						
						if nextTi = _ti then
							break;
						endif;
						
						if nextTi.id &gt; tiName then
							break;
						endif;
					endforeach;
					
					if nextTi &lt;&gt; _ti then
						_table.addItemObjectAt(_ti, _str, _rowIdx);
					else
						_table.accessCell(_rowIdx, 1).text := _str;
					endif;
						
				else
					_rowIdx := -1;	// Set the rowIdx to something invalid to indicate that we didn't actually add the row, and so we shouldn't try and colour it!
				endif;
			else
				// In the event of crap data - hopefully only in eupBjmt ??! - just pretend we don't have a cargo group :(
				// 0 means we didn't find a matching CM_CargoGroupDetail record for our Site/Table
				cargoGroup := null;
			endif;
		endif;
	endif;
	
	if cargoGroup = null then
		// Dont have cargo group. Group it in " Unknown"
		// Unknown cargo group will be at the bottom, and we're ordered, so just check the last rows TIs Cargo Group
		obj := _table.accessRow(_table.rows).itemObject;
		if obj = null or obj &lt;&gt; null and obj.CM_TrackedItem.myCargoGroup = null then
			_rowIdx := _table.rows+1;
			_table.addItemAt(_str, _rowIdx);
			row := _table.accessRow(_rowIdx);
			row.itemObject := _ti;
			done := true;
		endif;
		
		// If not done, means " Unknown" is not in the table yet, add it, then add the track item;
		if not done then
			_rowIdx := _table.addItem("");
			if _table.getColumnByRowName(ETRow_Id) &lt;&gt; null then
				colIdx := _table.getColumnByRowName(ETRow_Id);
				_table.accessCell(_rowIdx, colIdx).text := app.getErrorString(Unknown);
			endif;
			if _table.getColumnByRowName(ETRow_CargoType) &lt;&gt; null then
				colIdx := _table.getColumnByRowName(ETRow_CargoType);
				_table.accessCell(_rowIdx, colIdx).text := app.getErrorString(Unknown_cargo_group);
			endif;
			
			_table.accessCell(_rowIdx, 1).text := J_key_Hyphen.Character &amp; " " &amp; _table.accessCell(_rowIdx, 1).text;
			_table.accessRow(_rowIdx).itemObject := cargoGroup;
			_table.accessedRow.backColor := LightYellow;
			
			_rowIdx := _table.addItem(_str);
			row := _table.accessRow(_rowIdx);
			row.itemObject := _ti;
			
		endif;
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <Parameter name="_str" type="String" usage="input"/>
        <Parameter name="_fromNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCurrentVoyage" id="bc4f4990-4da4-420e-989a-c73baf67bb31">
        <updating/>
        <source>loadCurrentVoyage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
05 December 2022	navmd1	TFS 55379 - Fix cargo group line not being removed when cargo group detail is deleted

*/

vars
	ti			: CM_TrackedItem;
begin
	self.expandedRows := 0; //19Jan2023 navsp1 TFS 56209
	
	inheritMethod();

	foreach ti in self.allDisplayedTIs where ti.isCargoGroupItem do
		self.beginNotification(ti, Object_Update_Event, Response_Continuous, Object_Update_Event);
	endforeach;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadOffsiteTable" id="09fdf0dc-dde0-4cde-aff7-fbd0419eed7c">
        <updating/>
        <source>loadOffsiteTable(_startingTI : CM_TrackedItem; 	// 08/12/2022	navkc1	#55409
				 _next : Boolean				// 08/12/2022	navkc1	#55409
				 ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who				Reason
22 Apr 2022		navnk20			Initial creation TFS 53388
22 Jun 2022		navsrk20		Bug 53887: EUP - Items Cargo Type to be shown instead of Cargo Group Type
12 Jul 2022		navdap1			TFS 53889 EUP Collapsed view not kept when moving or updating cargo
25 Oct 2022		navkc1			Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
08 Nov 2022		navmd1			TFS 55379 Refactor VoyageOpsCG Form
28 Nov 2022 	navkc1			ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
08 Dec 2022		navkc1			ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
16 Jan 2023		navmp20			Bug 56062: EUP - #3, #4 Incorrect Cargo grouping/heading values
20 Apr 2023		navmd1			TFS 56062 Fix Cargo Group Detail headers not updating correctly
20/02/2024 		navcs2 			MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026 	navhl20 		Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/
vars
	rowIdx, colIdx	 		: Integer;
	ti 						: CM_TrackedItem;
	isHidden 				: Boolean;
 // ### TFS BUG 58853 10JUL2023 NAVAB1	dynaDict 				: DynaDictionary;
	currentVoyage 			: CM_Voyage;
	currentTable 			: CM_FilterTable;
	cmifMonitor 			: CMIF_Monitor;
	noMonitor 				: Boolean;
	idx, totalParts,
	currentPart, site		: Integer;
	maxStr					: String;
	iter					: Iterator;
	tis						: CM_TIByCargoGroupIdDict;
	cgDetails				: CM_CargoGroupDetail;
	cargoGroup				: CM_CargoGroup;
	plus					: Character;
	progressStr				: String;
begin
	if not self.isInCargoGrouping then
		inheritMethod(_startingTI, _next);
		return;
	endif;

	on Exception do self.handleExceptionVoyage(exception, currentVoyage);
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		currentVoyage.fetchLatest();
	endif;
	
	// Exception handler sets voyage to null if its been deleted
	if currentVoyage = null then
		return;
	endif;
	
	//17Jan2023 navsp1 TFS 56045 / position changed
	currentTable := self.tblOffsite;
	currentTable.rows := currentTable.fixedRows;
	currentTable.clearAllViewObjects( Any_System_Event );
	currentTable.clearSort();
	
	// 28/11/2022	navkc1	#55408
	tis := currentVoyage.allOffsiteTIsByCargoGroupId;
	if tis.isEmpty() then return; endif;
	
	self.myCargoGroup := null;
	
	// 28/11/2022	navkc1	#55408 - Copy the cargo group details to dynamic dictionary and have them sorted so they don't get displayed in random order
	/* // ### TFS BUG 58853 10JUL2023 NAVAB1
	create dynaDict transient;
	dynaDict.setMembership(CM_CargoGroupDetail);
	dynaDict.addMemberKey(CM_CargoGroupDetail::myCargoGroup.name &amp; "." &amp; CM_CargoGroup::id.name, false, true);
	dynaDict.endKeys(true); 
	currentVoyage.allCargoGroupDetails.copy(dynaDict);
	maxStr := dynaDict.size().String;
	*/
	maxStr := currentVoyage.allCargoGroupDtlBySiteCargoGrp.size.String;
	
	isHidden := not self.dkcOffSite.visible;

	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		// This should never be a thing, but instead of breaking because we can't show progress, lets just create a dummy one and not link it anywhere
		noMonitor := true;
		create cmifMonitor transient;
	endif;
	totalParts := cmifMonitor.partsInJob;
	currentPart := cmifMonitor.partsDone;
	
	
	site := self.getSiteForTable(currentTable);
	plus := J_key_Plus.Character;
	
	progressStr := app.getErrorString(Loading_offsite_cargo);	// Loading Off Site Cargo
 // ### TFS BUG 58853 10JUL2023 NAVAB1	foreach cgDetails in dynaDict as CM_CargoGroupDetail where cgDetails.site = site do
	foreach cgDetails in currentVoyage.allCargoGroupDtlBySiteCargoGrp where cgDetails.site = site do
		idx += 1;
		cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
		
		if cargoGroup = null or cargoGroup &lt;&gt; cgDetails.myCargoGroup then
			cargoGroup := cgDetails.myCargoGroup;
			rowIdx := 0;
		else
			// Already added this Cargo Group Detail, skip to the next one
			continue;
		endif;
		
		ti := cgDetails.getFirstTIForVoyage(currentVoyage);		
		self.loadCargoForTable(ti, rowIdx, currentTable, isHidden, true);
	endforeach;
	
	// Now we find out is there any cargo items has unknown cargo group for this table, add Unknown row if there is.
	iter := tis.createIterator();
	tis.startKeyGeq(null, null, iter);
	iter.next(ti);
	
	if ti.myCargoGroup = null then
		rowIdx := currentTable.addItem("");
		if currentTable.getColumnByRowName(ETRow_Id) &lt;&gt; null then
			colIdx := currentTable.getColumnByRowName(ETRow_Id);
			currentTable.accessCell(rowIdx, colIdx).text := " " &amp; app.getErrorString(Unknown);
		endif;
		if currentTable.getColumnByRowName(ETRow_CargoType) &lt;&gt; null then
			colIdx := currentTable.getColumnByRowName(ETRow_CargoType);
			currentTable.accessCell(rowIdx, colIdx).text := app.getErrorString(Unknown_cargo_group);
		endif; 	
		currentTable.accessCell(rowIdx, 1).text := plus &amp; " " &amp; currentTable.accessCell(rowIdx, 1).text;
		currentTable.accessRow(rowIdx).itemObject := ti.myCargoGroup;
		currentTable.accessedRow.backColor := LightYellow;
	endif;
	
	self.colourTableRows(currentTable);
	
	/* //30/07/2025	navkc1 JIRA MTN 35478
	if self.performRefresh = RefreshCurrentViewOnly then
		currentTable.setCurrentViewObjects();
	endif;
	*/
	
	self.restoreCollapseState(currentTable);	// TFS 53889
	
epilog
 // ### TFS BUG 58853 10JUL2023 NAVAB1	delete dynaDict;
	delete iter;
	
	if noMonitor then
		delete cmifMonitor;
	endif;
end;</source>
        <Parameter name="_startingTI" type="CM_TrackedItem"/>
        <Parameter name="_next" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadOnShipTable" id="abde9282-44c5-48b8-b8bb-e04d417b6207">
        <updating/>
        <source>loadOnShipTable(_startingTI : CM_TrackedItem; 	// 08/12/2022	navkc1	#55409
				_next		: Boolean			// 08/12/2022	navkc1	#55409
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
22 Apr 2022		navnk20		Initial creation TFS 53388
22 Jun 2022		navsrk20	Bug 53887: EUP - Items Cargo Type to be shown instead of Cargo Group Type
12 Jul 2022		navdap1		TFS 53889 EUP Collapsed view not kept when moving or updating cargo
25 Oct 2022		navkc1		Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
08 Nov 2022		navmd1		TFS 55379 Refactor VoyageOpsCG Form
28 Nov 2022		navkc1		ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
08 Dec 2022		navkc1		ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
16 Jan 2023		navmp20		Bug 56062: EUP - #3, #4 Incorrect Cargo grouping/heading values
20 Apr 2023		navmd1		TFS 56062 Fix Cargo Group Detail headers not updating correctly
20/02/2024 		navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026		navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/
vars
	rowIdx, colIdx			: Integer;
	ti						: CM_TrackedItem;
 // ### TFS BUG 58853 10JUL2023 NAVAB1	dynaDict 				: DynaDictionary;
	currentVoyage 			: CM_Voyage;
	currentTable 			: CM_FilterTable;
	cmifMonitor 			: CMIF_Monitor;
	noMonitor 				: Boolean;
	idx, totalParts,
	currentPart, site		: Integer;
	maxStr					: String;	
	iter					: Iterator;
	tis						: CM_TIByCargoGroupIdDict;
	cgDetails				: CM_CargoGroupDetail;
	cargoGroup				: CM_CargoGroup;
	plus					: Character;
	progressStr				: String;
begin
	if not self.isInCargoGrouping then
		inheritMethod(_startingTI, _next);
		return;
	endif;

	on Exception do self.handleExceptionVoyage(exception, currentVoyage);
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		currentVoyage.fetchLatest();
	endif;
	
	// Exception handler sets voyage to null if its been deleted
	if currentVoyage = null then
		return;
	endif;
	
	//17Jan2023 navsp1 TFS 56045 / position changed
	currentTable := self.tblOnship;
	currentTable.clearSort();	
	currentTable.rows := currentTable.fixedRows;
	currentTable.clearAllViewObjects( Any_System_Event );
	
	// 28/11/2022	navkc1	#55408
	tis := currentVoyage.allOnshipTIsByCargoGroupId;
	if tis.isEmpty() then return; endif;
	
	self.myCargoGroup := null;
	
	// We're now in our special cargo grouping mode, so lets do things a bit differently
	
	// 28/11/2022	navkc1	#55408 - Copy the cargo group details to dynamic dictionary and have them sorted so they don't get displayed in random order
	/* // ### TFS BUG 58853 10JUL2023 NAVAB1
	create dynaDict transient;
	dynaDict.setMembership(CM_CargoGroupDetail);
	dynaDict.addMemberKey(CM_CargoGroupDetail::myCargoGroup.name &amp; "." &amp; CM_CargoGroup::id.name, false, true);
	dynaDict.endKeys(true); 
	currentVoyage.allCargoGroupDetails.copy(dynaDict);
	maxStr := dynaDict.size().String;
	*/
	
	maxStr := currentVoyage.allCargoGroupDtlBySiteCargoGrp.size.String; // ### TFS BUG 58853 10JUL2023 NAVAB1
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		// This should never be a thing, but instead of breaking because we can't show progress, lets just create a dummy one and not link it anywhere
		noMonitor := true;
		create cmifMonitor transient;
	endif;
	totalParts := cmifMonitor.partsInJob;
	currentPart := cmifMonitor.partsDone;
	
	// 28/11/2022	navkc1	#55408
	site := self.getSiteForTable(currentTable);	
	plus := J_key_Plus.Character;
	
	// When in cargo grouping mode, the display is locked to ACTUAL
	//if self.displayModeOnShip = DISPLAY_MODE_ACTUAL then	
	
	progressStr := app.getErrorString(Loading_onship_cargo);	// Loading On Ship Cargo
 // ### TFS BUG 58853 10JUL2023 NAVAB1	foreach cgDetails in dynaDict as CM_CargoGroupDetail discreteLock where cgDetails.site = site do
	foreach cgDetails in currentVoyage.allCargoGroupDtlBySiteCargoGrp discreteLock where cgDetails.site = site do
		idx += 1;
		cmifMonitor.updateProgress(' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
		
		if cargoGroup = null or cargoGroup &lt;&gt; cgDetails.myCargoGroup then
			cargoGroup := cgDetails.myCargoGroup;
			rowIdx := 0;
		else
			// Already added this Cargo Group Detail, skip to the next one
			continue;
		endif;
		
		ti := cgDetails.getFirstTIForVoyage(currentVoyage);
		self.loadCargoForTable(ti, rowIdx, currentTable, false, true);
	endforeach;
	
	// Now we find out is there any cargo items has unknown cargo group for this table, add Unknown row if there is.
	iter := tis.createIterator();
	tis.startKeyGeq(null, null, iter);
	iter.next(ti);
	// 28/11/2022	navkc1	#55408
	if ti.myCargoGroup = null then
		rowIdx := currentTable.addItem("");
		if currentTable.getColumnByRowName(ETRow_Id) &lt;&gt; null then
			colIdx := currentTable.getColumnByRowName(ETRow_Id);
			currentTable.accessCell(rowIdx, colIdx).text := " " &amp; app.getErrorString(Unknown);
		endif;
		if currentTable.getColumnByRowName(ETRow_CargoType) &lt;&gt; null then
			colIdx := currentTable.getColumnByRowName(ETRow_CargoType);
			currentTable.accessCell(rowIdx, colIdx).text := app.getErrorString(Unknown_cargo_group);
		endif; 	
		currentTable.accessCell(rowIdx, 1).text := plus &amp; " " &amp; currentTable.accessCell(rowIdx, 1).text;
		currentTable.accessRow(rowIdx).itemObject := ti.myCargoGroup;
		currentTable.accessedRow.backColor := LightYellow;
	endif;
	// 28/11/2022	navkc1	#55408
	
	self.colourTableRows(currentTable);
	
	/* //30/07/2025	navkc1 JIRA MTN 35478
	if self.performRefresh = RefreshCurrentViewOnly then
		currentTable.setCurrentViewObjects();
	endif;
	*/
	
	self.restoreCollapseState(currentTable);		// TFS 53889
	
epilog
 // ### TFS BUG 58853 10JUL2023 NAVAB1	delete dynaDict;
	delete iter;
	if noMonitor then
		delete cmifMonitor;
	endif;
end;</source>
