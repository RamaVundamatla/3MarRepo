Date		Who		Reason
04 December 2017	jlger1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	lc : CM_YardController;
	voyage : CM_Voyage;
	carIter : Iterator;
	cargoType : Integer;
	lastCargoType : Integer;
	carCount		: Integer;
begin
		app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	ti := "2365.935889".asOid.CM_TrackedItem;
	//ti:="2365.935895".asOid.CM_TrackedItem;
	//ti :="2365.935878".asOid.CM_TrackedItem;
	ti :="2365.935881".asOid.CM_TrackedItem;
	lc := "10685.2413".asOid.CM_YardController;
	voyage:="4480.283145".asOid.CM_Voyage;
		carIter:=voyage.allOnshipTIsByCargoTypeId.createIterator;
		cargoType:=TI_CargoType_Car;
		voyage.allOnshipTIsByCargoTypeId.startKeyGeq(cargoType,null,carIter);
		
		while carIter.next(ti) do
			if ti.isCar() then
				carCount := carCount + 1;
				break;
			else		
				cargoType:=ti.cargoType + 1;
				voyage.allOnshipTIsByCargoTypeId.startKeyGeq(cargoType,null,carIter);
				
			endif;
		endwhile;
	
	//beginTransaction;
	//lc.CM_RoRoController.setStartOffset(0);
	//commitTransaction;
	/*app.myPassport.setMyTerminal(ti.myTerminal);
	app.myTrxUA.trxRoroVehicleConfirm(ti,lc,null,"RIGHT to LEFT" );*/
epilog

end;</source>
