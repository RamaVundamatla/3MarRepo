    <JadeMethod name="translateForm" id="ca2f120a-4615-4525-a63b-da9b7951c322">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 June 2024 11:19:02.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026632, locale);
	btnCancel.translateBubbleHelp(Xlat_0026633, locale);
	btnCancel.translateCaption(Xlat_0026634, locale);
	btnCriteria.translateCaption(Xlat_0026635, locale);
	btnOK.translateBubbleHelp(Xlat_0026636, locale);
	btnOK.translateCaption(Xlat_0026637, locale);
	grpCriteria.translateCaption(Xlat_0026638, locale);
	lblCriteria.translateCaption(Xlat_0026639, locale);
	lblName.translateCaption(Xlat_0026640, locale);
	lblType.translateCaption(Xlat_0026868, locale);
	optTypeReceive.translateCaption(Xlat_0026869, locale);
	optTypeRelease.translateCaption(Xlat_0026870, locale);
end;</source>
    </JadeMethod>
