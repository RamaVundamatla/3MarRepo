    <JadeMethod name="assignValueSpecial" id="32b7c827-f7f0-4d6d-a729-9e414880eadf">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
//
vars

begin
	if _propName.isOneOf(ETRow_Height, ETRow_Length, ETRow_Width) then
		self.setPropertyValue(_propName, _processedValue.Real);
		return true;
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="152553d3-4bdf-4924-b637-659919ff0b52">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//
vars
	rowName, type	: String;

begin
	if _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(rowName, type);
		return self.getMeasurementStringForAttrib(rowName, type, _short);
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getImExStatusObj" id="ed8add8d-db96-4afe-b1b8-693f84aa2bb6">
        <source>getImExStatusObj() : CM_IMEXStatus;
//
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
//28 Niv 2024   navma1		MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
//
vars
	imexStatus 	   	: CM_IMEXStatus;
	theIMEXStatus  	: CM_IMEXStatus;
	imexStatusUpper	: String;
	
begin
	
	imexStatusUpper :=self.imexStatus.toUpper;						//28.11.2024 navma1 #MTN-19124
	
	foreach imexStatus in app.myRoot.allImexStatuses do
		if imexStatusUpper = imexStatus.code.String.toUpper  or
		   imexStatusUpper = imexStatus.abbreviation.toUpper or
		   imexStatusUpper = imexStatus.description.toUpper  then
			
			theIMEXStatus := imexStatus;
			break;
		endif;
	endforeach;
	return theIMEXStatus;
end;
</source>
        <ReturnType type="CM_IMEXStatus"/>
    </JadeMethod>
