    <JadeMethod name="tblTranslations_dblClick" id="4a0cd5da-fca2-47f3-ac43-8f8b4e6775fb">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTranslations_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2009	cnwmd1	Initial creation

*/

vars
	constantName, text, shortText : String;
	locale : CM_Locale;
begin
	locale := table.accessRow(table.row).itemObject.CM_Locale;
	if locale = null then
		// double clicking on header row (where it says Constant (dbl click to copy) causes a UE 1090!
		return;
	endif;
	self.myTranslatableText.getTranslationText(locale, constantName, text, shortText);
	app.copyStringToClipboard(constantName);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
