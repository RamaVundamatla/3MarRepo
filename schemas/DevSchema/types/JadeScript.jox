// test individual or all TranslatableString instances - check the source can be parsed and parameters
// correctly identified, and source can be converted to 'new' format

vars
	lsts : LStranslatableString;
	ts:TranslatableString;
	count : Integer;
//	scm:Schema;
begin
//	scm := rootSchema.getSchema(PortSchemaName);
	create lsts transient;
	foreach ts in TranslatableString.instances where ts.name = 'AAAParamTest' do break; endforeach;

		lsts.myTranslatableString := ts;
		lsts.getNewformatText();
		app.writeStatement( 'Old:	'&amp; lsts.getTranslatableStringText &amp; CrLf &amp;
			  'Params:	'&amp; lsts.parameterCount.String &amp; CrLf &amp; 
			  'New:	'&amp; lsts.sourceNewFormat);
	//endforeach;
epilog
	delete lsts;
end;
</source>
