    <DbClassMap file="baseshed"/>
    <JadeMethod name="getMinutesAfterMidnight" id="25b75b82-1f8b-44dd-942c-71dd07bc584e">
        <source>getMinutesAfterMidnight(pTime : Time):Integer;

vars
	minutes : Integer;
begin
	minutes := ( pTime.hour * 60 ) + pTime.minute;
	return minutes;
end;</source>
        <Parameter name="pTime" type="Time"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMinutesTillMidnight" id="be659526-fb0e-40fd-84b3-2b95bde820d8">
        <source>getMinutesTillMidnight(pTime : Time):Integer;

vars
	minutes : Integer;
	minutesInADay : Integer;
begin
	minutesInADay := ( 24 * 60 ); 
	minutes := minutesInADay - getMinutesAfterMidnight(pTime);
	return minutes;
end;</source>
        <Parameter name="pTime" type="Time"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTimeFromMinsAfterMidnight" id="e66bc043-87cf-4069-aa32-ffd0b11ebf58">
        <source>getTimeFromMinsAfterMidnight(pMinsAfterMidnight : Integer):Time;

vars
	value	: Integer;
	time	: Time;
	hours	: Integer;
	minutes	: Integer;
	seconds	: Integer;
	millis	: Integer;
begin

	time := null;
	seconds := 1;
	value := pMinsAfterMidnight;
	while value &gt;= 1440 do
		value := value - 1440;
	endwhile; 
	
	hours := ( value / 60 ).Integer;
	minutes := value mod 60;

	time.setTime(hours,minutes,seconds,millis);
	
epilog

	return time;

end;</source>
        <Parameter name="pMinsAfterMidnight" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
