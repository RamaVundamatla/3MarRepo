    <JadeMethod name="setForProxyMasterGenSet" id="443d060c-fc7f-4c48-94bb-515c83dcb3c8">
        <updating/>
        <source>setForProxyMasterGenSet(_id,
						_description	: String;
						_operator 		: CM_Operator;
						_owner			: CM_Operator;
						_isoType		: CM_ISOType;
						_generatorType	: CM_GeneratorType;
						//_tareWeight	: Integer;					// PAR #31155
						_tareWeight		: Decimal;					// PAR #31155
						_stopTables		: CM_StopsTableByIdDict;
						_toDoTaskDesc	: CM_ToDoTaskDescByCode
) updating;
/* ---------------------------------------------------------------------------
Created:	12 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
12/03/2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurement - changed tareWeight parameter to Decimal
------------------------------------------------------------------------------*/
vars

begin

	self.setForProxyMaster( self.cargoType,
							_id,
							_description,
							_tareWeight,
							_operator,
							_owner, 
							_stopTables,
							_toDoTaskDesc,
							app.myRoot);
	
	self.myGeneratorType:= _generatorType;
	
	if _isoType &lt;&gt; null then
		//if not self.myGeneratorType.isUnderSlung then	//Par18144. For generator designed for a chassis, iso types is set as required at the moment
			self.isoType	:= _isoType.code;
		//endif;
	endif;
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_owner" type="CM_Operator"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_generatorType" type="CM_GeneratorType"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_stopTables" type="CM_StopsTableByIdDict"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDescByCode"/>
    </JadeMethod>
