    <JadeMethod name="getTrailerCargoType" id="bf61d1de-c0bf-45ac-a4a2-961c92485f48">
        <source>getTrailerCargoType() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2008	cnwrd1	Initial creation

*/

vars
	root : CM_Root;
	cargoType  : CM_CargoType;
	newIndx : Integer;
begin
	root :=app.myRoot;
	foreach cargoType in root.allCargoTypesById do
		if cargoType.productType = ProductType_Trailer then			
			return cargoType.id;
		endif;
	endforeach;
	app.raiseCMWarning2(ERR_FIELD_VALUE, self.cargoTypeDescr, 'CargoType', ETRow_CargoTypeDescr, self, self);
	return 0;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
