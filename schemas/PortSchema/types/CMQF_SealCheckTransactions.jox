<Class name="CMQF_SealCheckTransactions" id="563cf986-49ea-4e5f-88e6-7384d14774a1">
    <superclass name="CMQF_Transactions"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="imexStatus" id="922b8d26-739c-4901-93a9-7b8628b18942">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="receiptTransportMode" id="4c452584-b30a-4e52-b309-14a0b56df427">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="sealType" id="cd7edd29-5c1d-4128-b0e1-ed2698f2ebb2">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="unMatchedOnly" id="a098b3bb-3d78-400f-8f84-40160f2bdf59">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="filterObjects" id="98b92de7-fb67-4b09-9266-e77fcd43dc71">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	terminal : CM_Terminal;
	startTS : TimeStamp;
	endTS : TimeStamp;
	voyage : CM_Voyage;
	txnType : Integer;
	
begin
	//Seal Check txns only.
	self.allTxnTypes.clear();
	self.allTxnTypes.add(TRANS_TYPE_SEAL_CHECK);
	
	//Set the time/date range.
	self.setDefaultStartEndDates(startTS, endTS);
	if startTS.date &lt; "01 Jun 2010".Date then
		// predates the feature
		self.startDate := "01 Jun 2010".Date;
		startTS.setDate( self.startDate );
	endif;
	
	if self.getMyVoyage &lt;&gt; null and not self.getMyVoyage.archived then
		voyage := self.getMyVoyage;
		foreach txnType in self.allTxnTypes do 
			voyage.getTITxnsByTypeFromTIs(txnType, 
										  false,
										  true,
										  false,
										  true,
										  startTS, 
										  endTS, 
										  CMQF_FilterReports::checkStatusIncludesObject.name, 
										  self, 
										  _collection);	
		endforeach;
	else
		foreach terminal in self.allTerminals do : terminalLoop
			foreach txnType in self.allTxnTypes do
				terminal.getTITxnsByTypeFromOnsiteTIs(txnType, startTS, endTS, null, CMQF_FilterReports::checkStatusIncludesObject.name, self, _collection);
			endforeach;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="ad024ddc-7213-49ac-a94f-c76e90a06bc0">
        <updating/>
        <source>includesObject(_trx: CM_SealCheck; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	imex : Integer;
	
begin
	
	if _trx.myTrackedItem = null then
		return false;
	endif;
	
	if not CM_TITransaction.hasInstance(_trx) then
		return false;
	endif;
	
	if not self.allQryImexStatus.isEmpty then
		imex := _trx.imExStatus;
		if not self.allQryImexStatus.includes( imex ) then
			return false;
		endif;
	endif;
	
	if self.unMatchedOnly then
		if not _trx.includesUnMatched then
			return false;
		endif;
	endif;
	
	if self.sealType &lt;&gt; null then
		if not _trx.includesSealType(self.sealType) then
			return false;
		endif;
	endif;
	
	if self.receiptTransportMode &lt;&gt; 0 then
		if self.receiptTransportMode &lt;&gt; _trx.getReceiptTransportMode then
			return false;
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_SealCheck"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
