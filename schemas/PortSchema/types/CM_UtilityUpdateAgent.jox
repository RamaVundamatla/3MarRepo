    <JadeMethod name="utlUpdateEDIParty" id="b2d488d6-1962-4445-9e72-d146f6d3f51b">
        <source>utlUpdateEDIParty(_proxy :CM_EDIParty; _passport :CM_Passport input);
/*
Date		Who		Reason
16 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	party			: CM_EDIParty;
	expectedEdition	: Integer;

begin
	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_proxy, 'EDI_Party');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_proxy, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	party := self.getRealObjectAndEditionCheck(_proxy, 'EDI Party', _passport).CM_EDIParty;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(party, true);
	endif;

	if _passport.noErrors then
		// do updates
		party.setForUpdate(_proxy);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(party, false);
	endif;

	party.causeEvent (EDI_PARTY_UPDATE_EVENT, false, null);
end;</source>
        <Parameter name="_proxy" type="CM_EDIParty"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDISendRecipFileType" id="02fafa88-4206-4988-baa6-ff5fd8eba5cf">
        <source>utlUpdateEDISendRecipFileType(_proxy : CM_EDISenderRecipFileType; _ediData : CM_EDIData; _passport : CM_Passport input);
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
vars
	real : CM_EDISenderRecipFileType;
	expectedEdition	: Integer;
begin
//	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_proxy, 'CM_EDIFileTypeSenderRecipient');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_proxy, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	real := self.getRealObjectAndEditionCheck(_proxy, 'CM_EDIFileTypeSenderRecipient', _passport).CM_EDISenderRecipFileType;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;

	if _passport.noErrors then
		// do updates
		real.setForUpdate(_proxy, _ediData);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

//	real.causeEvent(EDI_PARTY_UPDATE_EVENT, false, null);
end;
</source>
        <Parameter name="_proxy" type="CM_EDISenderRecipFileType"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
