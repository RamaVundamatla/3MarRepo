        <source>frmGridArea_dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 03 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	gridPoint : CMUI_GridPoint;
begin

	if (not frame.isKindOf(CMUI_GridAreaFrame)) then
		return;
	endif;
	
	// PAR7406 - see YRD_WagonArea::setGridRowColPositions must minus 5 from y .
	gridPoint := frame.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(x, y - 5); 
	self.gridPointRecieveDrop(frame, win, gridPoint, x, y);

end;</source>
