    <JadeMethod name="change" id="cb5a4421-fa22-402a-a360-df2e08845f41">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>change(table: Table input) updating, clientExecution;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	measure 			: CM_MeasurementType;
	pos					: Integer;
	leading, trailing 	: Integer;
	dec 				: Integer;
	decimalSeparator	: String;
	firstChar			: String;
	secondChar			: String;
	value				: Decimal [23,10];
	str					: String;
	textbox				: TextBox;
	overFlowed			: Boolean;
begin
	inheritMethod(table);
	
	decimalSeparator  := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	
	// if the selected measurement type is feet and inches, validate the entry of decimal places
	measure := app.myRoot.allMeasurementTypesByShortName[self.accessCell(1, self.ColumnUnit).text];
	if measure &lt;&gt; null and measure.isFeetAndInches and self.column = self.ColumnValue then
		// are we entering stuff after the decimal place?
		str := self.accessCell(1, self.ColumnValue).text;
		textbox := self.accessedCell.cellControl.TextBox;
		pos := str.pos(decimalSeparator, 1);
		if pos &lt;&gt; null then
			// first character after the decimal palce can be anything, but if it's a zero then the next character can't be non-zero
			if str.length &gt; pos then
				firstChar := str[pos+1:1];
				if str.length &gt; pos+1 then
					secondChar := str[pos+2:1];
					if firstChar = "0" and secondChar.Integer &gt; 0 then
						str := str[1:str.length-1];
						self.accessedCell.text := str;
						textbox.text := str;
						textbox.selStart := str.length;
					elseif firstChar.Integer = 1 and secondChar.Integer &gt; 1 then
						str := str[1:str.length-1];
						self.accessedCell.text := str;
						textbox.text := str;
						textbox.selStart := str.length;
					elseif firstChar.Integer &gt; 1 then
						str := str[1:str.length-1];
						self.accessedCell.text := str;
						textbox.text := str;
						textbox.selStart := str.length;
					endif;
				endif;
			endif;
		endif;
	endif;
						
	if self.comboIndex &lt;&gt; null then
		if measure &lt;&gt; null then
			dec := measure.getDecimalPrecision;
			if dec = null then
				dec := 3;		// default to 3 decimal places 
			endif;
			leading := measure.format.Integer;
			self.accessCell(1, ColumnValue).maxLength := leading + dec + 1;
			self.accessCell(1, ColumnValue).decimals := dec;
		endif;
	endif;
	
	if self.column = self.ColumnUnit and self.selectedType &lt;&gt; null then
		// recalc value to suit new units
		measure := app.myRoot.allMeasurementTypesByShortName[selectedType];
		on Exception do app.handlePrecisionError(exception, overFlowed );	//21/4/2017	epr Tfs 3888
		value := app.convertMeasurementForStorage(measure.shortName, self.accessCell(1, self.ColumnValue).text.Decimal);
		if overFlowed then
			value:=null;
		endif;
		measure := app.myRoot.allMeasurementTypesByShortName[self.accessCell(1, self.ColumnUnit).text];
		str := app.convertMeasurementForDisplay(measure.shortName, value);
		self.accessCell(1, self.ColumnValue).text := str;
	endif;
	self.selectedType := self.accessCell(1, self.ColumnUnit).text;
	
	if self.parent.isKindOf(CM_EntryTable) then
		if self.parent.CM_EntryTable.accessCell(self.parent.CM_EntryTable.row, self.parent.CM_EntryTable.column).cellControl.isKindOf(self.class) then
			self.parent.CM_EntryTable.accessCell(self.parent.CM_EntryTable.row, self.parent.CM_EntryTable.column).text := self.accessCell(1, self.ColumnValue).text &amp; Space &amp; self.accessCell(1, self.ColumnUnit).text;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getConvertedValue" id="9bbb493b-58ca-48b0-a788-0ea8d4b5df39">
        <updating/>
        <source>getConvertedValue() : Decimal updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
11/03/2014	cnwdap1	PAR #33603 Correct measurement handling for different locales - can't just
					type-cast as Decimal here, or we lose locale-specific information
*/
vars
	value, unit : String;

begin
	unit := self.accessCell(1, self.ColumnUnit).text;
	value := self.accessCell(1, self.ColumnValue).text;
	//return app.convertMeasurementForStorage(unit, value.Decimal);			// PAR #33603
	return app.convertMeasurementForStorage(unit, value.asDecimalJMT);		// PAR #33603
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementType" id="77954ec4-d510-453e-a0f2-1ecb580a87eb">
        <source>getMeasurementType():CM_MeasurementType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if self.selectedType &lt;&gt; null then
		return app.myRoot.allMeasurementTypesByShortName[ self.selectedType ];
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_MeasurementType"/>
    </JadeMethod>
