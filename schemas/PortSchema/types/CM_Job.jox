    <JadeMethod name="getSingleRequestInstance" id="d8a798d2-6e55-417b-a079-01bf7e290b42">
        <source>getSingleRequestInstance() : CM_Request;

/*

Purpose:			

	Search through WLEs and return a request object that is restricted to being the only one 
	of its kind allowed to be associated with a job.

Parameters:			

Return Value:		


Date		Who		Reason
18 Feb 2010	cnwjk3	ccms 1071 
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	req : CM_Request;
	wle : CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		if wle.myRequest.isSingleRequestPerJob() then
			req := wle.myRequest;
			break;
		endif;
	endforeach;
	
	return req;
epilog

end;</source>
        <ReturnType type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="getSortingMethods" id="94381f16-e2b2-40c8-8c6f-654bcabfa841">
        <source>getSortingMethods():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
*/

vars
	ti 				: CM_TrackedItem;
	req				: CM_Request;
	resDtl			: CM_ReserveDetail;
	objSet			: ObjectSet;
begin
	ti := self.getFirstTrackedItem();
	if ti &lt;&gt; null then
		return ti.sortingMethod;
	endif;
	
	req := self.allRequests.first;
	if req &lt;&gt; null then
		resDtl := req.myReserveDetail;
	endif;
	if resDtl &lt;&gt; null and resDtl.isKindOf(CM_ReserveSelection) then
		create objSet transient;
		resDtl.CM_ReserveSelection.getMatchingCriteria(objSet,YACriteriaType_SortingMethod);
		if objSet &lt;&gt; null then
			return objSet.listStringNoDuplicate(Comma,CM_SortingMethod::code.name);
		endif;	
		if resDtl.myCargoGroup &lt;&gt; null then								//29.03.2024 navhl20 #63251
			return resDtl.myCargoGroup.sortingMethod;
		endif;
	endif;
epilog
	delete objSet;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSpecialLift" id="d3f45010-8788-4266-878c-64f5776b9107">
        <source>getSpecialLift():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
10 Oct 2024	navpw1	JIRA: MTN-33060 (MTN-33061) - Fixed 1090 caused by unit test run and form notifications whereby request detail has not been created yet.

*/

vars
	ti	 	: CM_TrackedItem;
	req		: CM_Request;
	resDtl	: CM_ReserveDetail;
begin
	ti := self.getFirstTrackedItem();
	if ti &lt;&gt; null then
		return ti.getSpecialLiftsDescriptions();
	endif;
	
	req := self.allRequests.first;
	
	// ### JIRA: MTN-33060 (MTN-33061) 10Oct2024 NAVPW1
	if req = null then
		return null;
	endif;
	// ### JIRA: MTN-33060 (MTN-33061) 10Oct2024 NAVPW1
	
	resDtl := req.myReserveDetail;
	if resDtl &lt;&gt; null and resDtl.isKindOf(CM_ReserveSelection) then
		return resDtl.CM_ReserveSelection.getMatchingCriteriaAsString(Comma,YACriteriaType_SpecialLift);
				
		if resDtl.myCargoGroup &lt;&gt; null then								//29.03.2024 navhl20 #63251
			return resDtl.myCargoGroup.getSpecialLiftsDescriptions();
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSpecialStow" id="db4a5739-5ce9-45b2-a7e7-cb6c2f74fd39">
        <source>getSpecialStow():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
*/

vars
	ti		: CM_TrackedItem;
	req		: CM_Request;
	resDtl	: CM_ReserveDetail;
	str		: String;
begin
	ti := self.getFirstTrackedItem();
	if ti &lt;&gt; null then
		return ti.specialStow;
	endif;
	
	req := self.allRequests.first;
	// ### JIRA: MTN-14770 14Nov2024 NAVPW1
	if req &lt;&gt; null then
		resDtl := req.myReserveDetail;
	endif;
	// ### JIRA: MTN-14770 14Nov2024 NAVPW1
	if resDtl &lt;&gt; null and resDtl.isKindOf(CM_ReserveSelection) then
		return resDtl.CM_ReserveSelection.getMatchingCriteriaAsString(Comma,YACriteriaType_SpecialStow);	
		if resDtl.myCargoGroup &lt;&gt; null then								//29.03.2024 navhl20 #63251
			return resDtl.myCargoGroup.specialStow;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
