    <JadeMethod name="setWebTest" id="936fe5f9-a2b1-4268-958d-d76182b96b6e">
        <updating/>
        <source>setWebTest(pWebTest:CnEcWebTest) updating;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Purpose:		Set a reference to the web test who's list of messages are being
//				maintain.
//
// Parameters:	pWebTest - The web test being maintained.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
