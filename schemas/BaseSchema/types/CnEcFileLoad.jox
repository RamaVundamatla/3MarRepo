    <DbClassMap file="base"/>
    <JadeMethod name="cnEcIniExceptionHandler" id="5aa44f39-ab48-4715-b1b4-9f1694d8e2e9">
        <source>cnEcIniExceptionHandler(pExceptionObj:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Purpose:		Exception handler for adding initialization file sections and keys,
//				to ignore the exception if the section/key already exists.
//
// Parameters:	pExceptionObj - The exception object.
//
// Returns:		A resume next value if the exception is for a 1310 error, otherwise
//				a pass-back value is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	KEY_ALREADY_EXISTS	: Integer = 1310;
	
begin
	if pExceptionObj.errorCode = KEY_ALREADY_EXISTS then
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
