    <JadeMethod name="doMnuGlobalVoyageBuild" id="8409ac8e-e9cd-4217-9ee9-5877f834d981">
        <source>doMnuGlobalVoyageBuild();
//----------------------------------------------------------------
//	Created:	30 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	idx				: Integer;
	aVoyage			: CM_Voyage;
	theGlobalVoyage	: CM_VoyageGlobal;
	subMenu			: MenuItem;
	voy				: CM_Voyage;
begin
	aVoyage := self.myCurrentVoyage;
	
	self.doPurgeSubMenus(self.mnuGlobalVoyageView);
	
	if app.isSingleTerminalSystem 
	or aVoyage.myVoyageGlobalArrival = null then
		self.mnuGlobalVoyage.visible := false;
		return;
	endif;
	
	foreach voy in aVoyage.myVoyageGlobalArrival.allVoyages do
		if voy = aVoyage then
			continue;
		endif;
		
		idx := idx + 1;
		subMenu := self.mnuGlobalVoyageView.getMenuItem(idx);
		if subMenu = null then
			subMenu := self.mnuGlobalVoyageView.loadSubMenu(idx);
		endif;
		
		// need to add date in here if required

		subMenu.caption := "From " &amp; voy.myTerminal.code &amp; " - " &amp; voy.vesselName &amp; ", " &amp; voy.code;
		
		subMenu.visible := true;
		subMenu.userObject := voy;
	endforeach;

	self.mnuGlobalActual.enabled := (self.myCurrentVoyageInterTerm &lt;&gt; null);
	
	if idx = 0 then
		self.mnuGlobalVoyage.visible := false;
	else
		self.mnuGlobalVoyage.visible := true;
	endif;
end;</source>
    </JadeMethod>
