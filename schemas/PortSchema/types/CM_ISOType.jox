    <JadeMethod name="importFromXML" id="d736e7b5-dd64-4ca1-a79a-720e01ada40f">
        <updating/>
        <source>importFromXML(_xmlBlock	: String) updating;
// ---------------------------------------------------------------------------
// Created:     20 November 2002		cnwth2	
//
// Purpose:     Temporary solution to set isoType from XML text
//			 
// ----------   ----------  --------------------------------------------------
vars
	startPos			: Integer;
begin
	self.myRoot := app.myRoot;
	self.myCargoType := app.myRoot.allCargoTypesById[1];
	
	startPos := 1;
	self.code := _xmlBlock.cnEcGetNextTagValueOfName('&lt;code&gt;', startPos).trimBlanks;
	self.description := _xmlBlock.cnEcGetNextTagValueOfName('&lt;description&gt;', startPos).trimBlanks;
	self.colour := _xmlBlock.cnEcGetNextTagValueOfName('&lt;colour&gt;', startPos).Integer;
	self.sizeAttributes := _xmlBlock.cnEcGetNextTagValueOfName('&lt;sizeAttributes&gt;', startPos).Integer;
	self.tiType := _xmlBlock.cnEcGetNextTagValueOfName('&lt;tiType&gt;', startPos).Integer;
	self.typeAttributes := _xmlBlock.cnEcGetNextTagValueOfName('&lt;typeAttributes&gt;', startPos).Integer;
	
	
end;</source>
        <Parameter name="_xmlBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="8582cd0c-f7cd-4664-aac6-b13d92054189">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	navsp1	Initial creation TFS#53569

*/

vars
	n4EquipType		: CMIF_RefEquipType;	
begin
	if _opsViewTable.isKindOf(CMIF_RefEquipType) then
		n4EquipType						:= _opsViewTable.CMIF_RefEquipType;
		n4EquipType.gkey           		:= n4EquipType.generateFullGKey(self, "");		
		if self.is20ftLong then
			n4EquipType.nominal_length	:= "NOM20";
			n4EquipType.basic_length	:= "BASIC20";
			n4EquipType.length_mm		:= 6068;			
		elseif self.is30ftLong then
			n4EquipType.nominal_length	:= "NOM30";
			n4EquipType.basic_length	:= "BASIC20";
			n4EquipType.length_mm		:= 6068;			
		elseif self.is40ftLong then
			n4EquipType.nominal_length	:= "NOM40";
			n4EquipType.basic_length	:= "BASIC40";
			n4EquipType.length_mm		:= 12192;			
		elseif self.is45ftLong then
			n4EquipType.nominal_length	:= "NOM45";
			n4EquipType.basic_length	:= "BASIC40";
			n4EquipType.length_mm		:= 12192;		
		elseif self.is53ftLong then
			n4EquipType.nominal_length	:= "NOM53";
			n4EquipType.basic_length	:= "BASIC40";
			n4EquipType.length_mm		:= 12192;		
		endif;
		if self.isContainer then
			n4EquipType.classStr 		:= "CONTAINER";
		endif;	
		n4EquipType.description 		:= self.description[1:40];		
		if self.is8ftHigh then
			n4EquipType.nominal_height:=  "NOM80";
			n4EquipType.height_mm	:= 2438;			
		elseif self.is8ft6High then
			n4EquipType.nominal_height:=  "NOM86";
			n4EquipType.height_mm	:= 2591;			
		elseif self.is9ft6High then
			n4EquipType.nominal_height:= "NOM96";
			n4EquipType.height_mm	:= 2895;
		elseif self.is4ftHigh then
			n4EquipType.nominal_height:=  "NOM40";
			n4EquipType.height_mm	:= 1219;			
		elseif self.is4ft3High then
			n4EquipType.nominal_height:=  "NOM43";
			n4EquipType.height_mm	:= 1295;			
		endif;
		n4EquipType.id	      			:= self.code;		
		if self.myISOTypeGroup &lt;&gt; null then
			n4EquipType.iso_group	:= self.myISOTypeGroup.code;
		else
			n4EquipType.iso_group	:= "";
		endif;
		n4EquipType.life_cycle_state	:= n4EquipType.n4LifeCycleState(self);
		n4EquipType.safe_weight_kg		:= self.maxTotalWeight;	
		n4EquipType.tare_weight_kg		:= self.tareKilos;	
		n4EquipType.width_mm			:= 2438;
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
