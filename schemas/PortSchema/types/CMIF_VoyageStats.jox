    <JadeMethod name="getStats" id="7fe5f4c2-993e-4880-a537-4140d13c89ae">
        <updating/>
        <source>getStats(_partiallyWorked : Boolean ) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming

*/

vars
	tmpSheetStats	: CMIF_JobSheetStats;
	tmpStatsToDelete : ObjectArray;
	invalidObject : Boolean;
	js : CM_JobSheet;
	
begin
	self.setActualTime(app.actualTimeServer());

	clearStats();
	create tmpStatsToDelete transient;
	
	on Exception do app.handleDeletedObject(exception, js, invalidObject);	//15 Feb 2011	NDL	- Par 26916
	
	//15 Jul 2015	NDL	Par 36610
	//epr TFS 3821 only get stats if the voyage has holds
	if self.myVoyage.myGeneralCargoVoyage &lt;&gt; null and self.myVoyage.myGeneralCargoVoyage.allLocationsByOrdinal.size &gt; 0 then			
		self.getStatsForHolds();
	endif;
	
	foreach tmpSheetStats in self.allJobSheetStats do
		invalidObject := false;							// PAR #27142
		js := tmpSheetStats.myJobSheet;
		
		if js &lt;&gt; null and not js.isTransient then // The transient JS is for HOLD moves i.e. not LOLO or RORO
			tmpSheetStats.getStats(_partiallyWorked);
		endif;
		//epr par 16697 28/5/08
		//if tmpSheetStats.myJobSheet = null then
		if js = null or invalidObject then	//15 Feb 2011	NDL	- Par 26916
			tmpStatsToDelete.add(tmpSheetStats);
			continue;
		endif;
		
		self.jobsCompleted		:= self.jobsCompleted + tmpSheetStats.jobsCompleted;
		self.jobsPartCompleted	:= self.jobsPartCompleted + tmpSheetStats.jobsPartCompleted;
		self.jobsUnactioned		:= self.jobsUnactioned + tmpSheetStats.jobsUnactioned;
		self.movesCompleted		:= self.movesCompleted + tmpSheetStats.movesCompleted;
		self.movesIncomplete	:= self.movesIncomplete + tmpSheetStats.movesIncomplete;
		self.liftsCompleted		:= self.liftsCompleted + tmpSheetStats.liftsCompleted;
		self.liftsIncomplete	:= self.liftsIncomplete + tmpSheetStats.liftsIncomplete;
		self.actualRate 		:= ( self.actualRate + tmpSheetStats.actualRate ).min( 99999999.9999);	//31 Jul 2017	NDL	TFS 5518 - Protect against stupid test data
		self.netRate			:= ( self.netRate + tmpSheetStats.myJobSheet.CM_VoyageJobSheet.getKPINetRate(tmpSheetStats) ).min( 99999999.9999);	//31 Jul 2017	NDL	TFS 5518
		self.estimatedRate		:= ( self.estimatedRate + tmpSheetStats.estimatedRate ).min( 99999999.9999);	//31 Jul 2017	NDL	TFS 5518
		self.plannedLoad		:= self.plannedLoad + tmpSheetStats.plannedLoad;
		self.plannedDischarge	:= self.plannedDischarge + tmpSheetStats.plannedDischarge;
		self.actualLoad			:= self.actualLoad + tmpSheetStats.actualLoad;
		self.actualDischarge 	:= self.actualDischarge + tmpSheetStats.actualDischarge;
		self.actualLoadTEU		:= self.actualLoadTEU + tmpSheetStats.actualLoadTEU;
		self.actualDischargeTEU := self.actualDischargeTEU + tmpSheetStats.actualDischargeTEU;
		//epr par 31764 6/8/13
		self.totalQuantity 		:= self.totalQuantity + tmpSheetStats.totalQuantity;
		self.totalVolume		:= self.totalVolume + tmpSheetStats.totalVolume;
		self.totalWeight		:= self.totalWeight	+ tmpSheetStats.totalWeight;
		self.completeQuantity	:= self.completeQuantity + tmpSheetStats.completeQuantity;
		self.completeVolume  	:= self.completeVolume + tmpSheetStats.completeVolume;
		self.completeWeight 	:= self.completeWeight + tmpSheetStats.completeWeight;
		self.setVoyageStartTime(tmpSheetStats.workStarted);
		self.setEstActualEndTime(tmpSheetStats.estActualEndTime);
		self.setEstTargetEndTime(tmpSheetStats.estTargetEndTime);
	endforeach;
	
	tmpStatsToDelete.purge;
	
epilog
//	self.setActualRate();
	delete tmpStatsToDelete;
end;</source>
        <Parameter name="_partiallyWorked" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getStatsForHolds" id="13a4c501-fc18-4f27-b14c-fdbd1c950fdf">
        <source>getStatsForHolds();
/*
Purpose:			
Date		Who		Reason
20 March 2015	cnwab1	Initial creation
*/

vars
	holdInfo : String;
	tran : CM_TITransaction;
	foundLC : CM_LocationsController;
	strs : StringArray;
	foundHeight : Integer;
	jobSheet, found : CMIF_JobSheetStats;
	js : CM_VoyageJobSheet;
	ti : CM_TrackedItem;
	hasRelReqs, allok : Boolean;
begin
	

	hasRelReqs := self.myVoyage.hasShipReleaseRequests(); // PAR 37130
	
	// ###### MOVED CARGO
	create strs transient;
	foreach tran in self.myVoyage.allTITransactionsByTypeDT discreteLock do
		holdInfo := tran.getHoldInfo();
		found := null;
	
		if holdInfo &lt;&gt; null then
		
			strs.clear();
			
			if holdInfo &lt;&gt; self.myVoyage.code then  // PAR 36019 if it is the ship block stack pass in black it will pass out the ship block stack
				strs.add(holdInfo);
			endif;
			
			found := self.getStatsGetJobSheetByCode(holdInfo);
			found.getStatsFromTransaction(tran);
		endif;
	
	endforeach;
	
	// ###### UN MOVED CARGO
	// ###### DISCHARGE
	foreach ti in self.myVoyage.allOnshipTIsByCargoTypeId discreteLock do
		found := null;
		if ti.isToBeDischargedHere then
			if ti.isPartOfAVoyageHoldJob(false) then // HOLD JOB TFS 4133
				continue;
			endif;
			foundLC := ti.myPrimaryActualLocation;
			
			if foundLC &lt;&gt; null and (foundLC.isGeneralCargoController or foundLC.isShipBlockStack) then
				holdInfo := foundLC.getLocationOrdinal();
				found := self.getStatsGetJobSheetByCode(holdInfo);
				
				found.getStatsFromTrackedItem(ti, false);
			endif;
		endif;
	endforeach;
	
	// ###### LOAD
	foreach ti in self.myVoyage.allOnsiteTIsByCargoTypeId discreteLock do
		found := null;
		if ti.isPlannedToShip() then
			if ti.isPartOfAVoyageHoldJob(true) then // HOLD JOB TFS 4133
				continue;
			endif;
			foundLC := ti.myPrimaryPlannedLocation;
			
			if foundLC &lt;&gt; null and (foundLC.isGeneralCargoController or foundLC.isShipBlockStack) then
				holdInfo := foundLC.getLocationOrdinal();
				found := self.getStatsGetJobSheetByCode(holdInfo);
				
				found.getStatsFromTrackedItem(ti, false);
			endif;
		

		elseif ti.isExport then
			allok := true;// PAR 37130
			if hasRelReqs and ti.isEmpty then // PAR 37130 do not show export MTs if the voyage has ship release requests. Normally MTs have an imex of storage not export; so this would not include them anyway.
				allok := false;// PAR 37130
			endif;
			
			if allok then// PAR 37130
				holdInfo := self.myVoyage.code;
				found := self.getStatsGetJobSheetByCode(holdInfo);
				found.getStatsFromTrackedItem(ti, true);
			endif;// PAR 37130
		endif;
	endforeach;	
	
	self.setGraphPointsFromTransactions();  // PAR 36118
epilog
	delete strs;
end;</source>
    </JadeMethod>
    <JadeMethod name="getStatsGetJobSheetByCode" id="63f72121-5d8c-457f-b868-ab13f191040e">
        <source>getStatsGetJobSheetByCode(_code : String) : CMIF_JobSheetStats;
/*
Purpose:			
Date		Who		Reason
26 March 2015	cnwab1	Initial creation
*/

vars

	tran : CM_TITransaction;
	foundLC : CM_LocationsController;
	strs : StringArray;
	foundHeight : Integer;
	jobSheet, found : CMIF_JobSheetStats;
	js : CM_VoyageJobSheet;
	ti : CM_TrackedItem;

begin
	foreach jobSheet in self.allJobSheetStats discreteLock do
		if jobSheet.myJobSheet.CM_VoyageJobSheet.crane = _code then
			found := jobSheet;
			break;
		endif;
	endforeach;
	
	
	if found = null then
		create found transient;
		create js transient;
		js.setForCreate(self.myVoyage, _code, null);
		
		found.init(js);
		self.allJobSheetStats.add(found);
	endif;
	
	return found;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CMIF_JobSheetStats"/>
    </JadeMethod>
    <JadeMethod name="getVoyageAllocCCAttributes" id="b63d617e-bd03-4d40-b5ae-5e71bae5cbea">
