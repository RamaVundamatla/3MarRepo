    <JadeMethod name="copyToAll" id="6d77858f-010b-4613-b812-8af0d1bc07d5">
        <source>copyToAll();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	table			: CM_DataTable;
	columnIndex 	: Integer;
	rowIndex 		: Integer;
	defColIndex 	: Integer;
	defRowIndex 	: Integer;
	defaultCode		: String;
begin
	table := self.tblTermVoyageOper;	
	defRowIndex := 2;
	defColIndex := 2;
	rowIndex := 2;	//Skip the header
	while rowIndex &lt;= table.rows do				
		columnIndex := 2;				
		defaultCode	 := table.accessCell(defRowIndex, defColIndex).text;

		while columnIndex &lt;= table.columns do
			if(table.accessCell(rowIndex, columnIndex).enabled) then
				table.accessCell(rowIndex, columnIndex).text := defaultCode;
			endif;
			
			columnIndex:=columnIndex+1;		
		endwhile;	
	
		rowIndex := rowIndex + 1;
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="c7537ec9-6ea6-4571-a56c-840177c7cd19">
        <source>doMnuInspectObject();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	anObject : Object;
begin
	if self.tblTermVoyageOper.row &gt; self.tblTermVoyageOper.fixedRows then
		anObject := self.tblTermVoyageOper.accessRow(self.tblTermVoyageOper.row).itemObject;
		if anObject &lt;&gt; null then
			anObject.inspect;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="e1dfdb91-6ace-49af-982d-ad285ccdd7b6">
        <updating/>
        <source>doOK() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	if self.doSave then
		self.modalResult := IDOK;
		self.unloadForm;
	endif;
	
epilog	
	app.mousePointer := Window.MousePointer_Default;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="647e9b3e-6814-497f-8652-2f6bf7689632">
        <updating/>
        <source>doSave():Boolean updating, protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	proxy	: CM_XlationTable;
	translations : CM_XlationSet;
	selectedVoyage : CM_Voyage;
	manifest : String;
	result			:Integer;
begin	
	selectedVoyage := self.cmbVoyage.listObject.CM_Voyage;
	manifest := self.txtManifestCode.text;	
	
	if not self.validateCustomsManifest(manifest) then
		return false;
	endif;
	
	if not self.setProxyFromForm (translations) then
		return false;
	endif;
		
	while true do		

		app.myTrxUA.trxUpdateMultipleEDITrans(selectedVoyage, translations, manifest, app.myPassport);		
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			
			return true;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog	
	delete translations;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="f504db1f-77c9-4c34-adf9-ade9051b0ceb">
        <updating/>
        <source>doTblDataContextMenu(cntrl : Table input; conwin : Window input; mouse : Boolean; x : Integer; y : Integer) : Boolean updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;

	else
		self.mnuInspectObject.visible := false;	
	endif;	   
	
	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);
	
	return false;
	
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXlationTable" id="253e8e2e-051f-404d-b128-18589cde6812">
        <source>getXlationTable(rowIndex: Integer; columnIndex: Integer):CM_XlationTable protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	type			: Integer;
	xlationTable	: CM_XlationTable;
	terminal		: CM_Terminal;
	operator		: CM_Operator;
	opTerm			: CM_OperatorTerminal;
	cargoType 		: CM_CargoType;	
	table			: CM_DataTable;
begin
	type := XLATION_TYPE_VOYAGETERMINAL;	
	table := self.tblTermVoyageOper;
	
	terminal := table.accessRow(rowIndex).itemObject.CM_Terminal;
	operator := table.accessColumn(columnIndex).itemObject.CM_Operator;
	
	if terminal &lt;&gt; null and operator &lt;&gt; null then
		opTerm := terminal.allOperatorTerminals[operator];
		
		if opTerm &lt;&gt; null then
			xlationTable := opTerm.allXlationTables[type, null];
		endif;
	endif;

	return xlationTable;

end;</source>
        <access>protected</access>
        <Parameter name="rowIndex" type="Integer"/>
        <Parameter name="columnIndex" type="Integer"/>
        <ReturnType type="CM_XlationTable"/>
    </JadeMethod>
    <JadeMethod name="initData" id="a42464d6-60cb-45ab-9bab-ede69b47f307">
