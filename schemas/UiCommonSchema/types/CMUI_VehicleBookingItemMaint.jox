    <JadeMethod name="stub_SaveSelectedTrackedItems" id="a613f76e-a91a-4586-9d0c-8582f23a3e1f">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <updating/>
        <source>stub_SaveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_CMUI_TrackedItems interface 
	*/
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
24 Apr 2023 	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
03 May 2023 	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
16 Oct 2023 	navlc30 ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)
18 Dec 2023		naviv1	ChangeRequest 61793: FR | 54329 - VBS - Adding Multiple items from prenoted cargo (without booking)
*/

vars
	ti	: CM_TrackedItem;
	parentForm : CMUI_VehicleBookingAdvMaint;
begin
	

	/*self.myTrackedItem := _allTIs.first;						//24.4.2023 navhl20 #57716[57718]
	self.txtCargo.text := self.myTrackedItem.id;				//24.4.2023 navhl20 #57716[57718]
	self.saveProxyVBTimeSlotItem(myPxyVehicleBookTimeSlotItem);

	self.loadItemTable(self.myTrackedItem);						//03.5.2023 navhl20 #57402[57471]
	self.setTblWeight();
	//self.alignTable();										//03.5.2023 navhl20 #57402[57471]*/
	
	if _allTIs.size = 1 then 	//18.12.2023 naviv1 #61973
		if not self.chkMultipleItems.value then						//16.10.2023 navlc30 #58996  								
			self.myTrackedItem := _allTIs.first;						//24.4.2023 navhl20 #57716[57718]
			self.txtCargo.text := self.myTrackedItem.id;				//24.4.2023 navhl20 #57716[57718]
			self.saveProxyVBTimeSlotItem(myPxyVehicleBookTimeSlotItem);

			self.loadItemTable(self.myTrackedItem);						//03.5.2023 navhl20 #57402[57471]
			self.setTblWeight();
			//self.alignTable();										//03.5.2023 navhl20 #57402[57471]
		else 															//18.12.2023 naviv1 #61973 - For Booking option
			self.myTrackedItem := _allTIs.first;	
			self.cmbCargo.enabled := true;
			self.cmbCargo.text := self.myTrackedItem.id;
			self.cmbCargo_click(self.cmbCargo);
		endif;
	else																												//16.10.2023 navlc30 #58996
		if self.myParentForm.isKindOf(CMUI_VehicleBookingAdvMaint) then
			parentForm := self.myParentForm.CMUI_VehicleBookingAdvMaint;
		endif;
		
		foreach ti in _allTIs do
			self.saveProxyVBTimeSlotItemMulti(ti , myPxyVehicleBookTimeSlotItem);

			if not self.myPxyVehicleBookingSlot.allVehicleBookingItems.includes(myPxyVehicleBookTimeSlotItem) then
				self.myPxyVehicleBookingSlot.allVehicleBookingItems.add(myPxyVehicleBookTimeSlotItem);
			else
				self.myPxyVehicleBookTimeSlotItem := null;
				
				create	self.myPxyVehicleBookTimeSlotItem transient;									
				
				/*if parentForm &lt;&gt; null then						//18.12.2023 naviv1 #61973  -- Redundant code
					parentForm.populateTableBookingItems();		
				endif;*/
			endif;	
			if parentForm &lt;&gt; null then	
				parentForm.populateTableBookingItems();
			endif;	
		endforeach;
		self.unloadForm();
			
	endif;	
	
	return true;
epilog

end;</source>
