    <JadeMethod name="doMnuColumnOrganiserClick" id="e105e0db-a7e9-4a0c-a667-649593374e9d">
        <source>doMnuColumnOrganiserClick(menuItem : MenuItem);
//19 February 2010	cnwml2
//+cnwml2 PAR21663
// Changed On  By         Reason
// ---------- ----------  --------------------------------------------------
// 11 Mar 2022 navhl20    TFS #53052 MTN - Cargo Searcher Issues

vars
	tbl : CM_DataTable;
begin
	tbl := menuItem.userObject.CM_DataTable;
	
	if tbl = self.tblResults then
		self.tblResults.showColumnOrganiserFrm(self.myTerminal, self.tblResults.allTblDataEntRows);
		self.doSearchAll();                       //11 mar 2022 navhl20 TFS #53052
	elseif tbl = self.tblSelectedItems then
		self.tblSelectedItems.showColumnOrganiserFrm(self.myTerminal, self.tblSelectedItems.allTblDataEntRows);
		self.loadSelectedTITable();               //11 mar 2022 navhl20 TFS #53052
