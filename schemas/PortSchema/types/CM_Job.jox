    <JadeMethod name="pxyCreateUpdateProxy" id="983cad43-914c-4215-a3b0-bcf459ef79c7">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyJob	: CM_Job;
	completedOK		: Boolean;
begin

	proxyJob := inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyJob;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyJob;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="rebuildStatus" id="3f9ee7d0-f8d4-4d7b-8da4-5ff3f2aa4671">
        <updating/>
        <source>rebuildStatus() updating;

vars
	wle	:	CM_WorkListEntry;
	req : CM_Request;
begin
	// PAR 15293
	foreach req in self.allRequests discreteLock do
		req.removeSurplusWLE();
	endforeach;
	
	foreach wle in self.workListEntries discreteLock do
		wle.rebuildStatus();
	endforeach;

	self.updateStatus();

end;</source>
    </JadeMethod>
    <JadeMethod name="removeFromAlerts" id="2bbcadee-851c-4222-8bfa-9b2a8ed7195b">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::removeFromAlerts"/>
        </interfaceImplements>
        <updating/>
        <source>removeFromAlerts(alert: CM_SystemAlert) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	terminal : CM_Terminal;
begin
	if not self.alerts.includes(alert) then
		return;
	endif;
	alerts.remove(alert);

	terminal := self.getTerminalForAlert;
	if terminal &lt;&gt; null and alert.mySystemAlertType &lt;&gt; null and not alert.reviewed then
		terminal.causeEvent(alert.mySystemAlertType.type,false,alert);	//25662 24/09/2010 set to false
	endif;
epilog

end;</source>
        <Parameter name="alert" type="CM_SystemAlert"/>
    </JadeMethod>
