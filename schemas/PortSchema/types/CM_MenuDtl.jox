<Class name="CM_MenuDtl" id="15600737-ca7a-42c2-a717-392855087769">
    <superclass name="CM_MenuItem"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="cmenu"/>
    <JadeMethod name="addAsUserItem" id="bbef5e6b-087a-4e94-a2de-846a86eb9bc9">
        <source>addAsUserItem(_parent : CM_MenuEntity input; _menuRoot : CM_MenuRoot) : CM_MenuUserItem;
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pxyUserDtl	: CM_MenuUserDtl;
	realUserDtl	: CM_MenuUserItem;
	pos			: Integer;
	
begin

	create pxyUserDtl transient;
	pxyUserDtl.setProxy(self.heading, self.pictureStringButton, 
				self.pictureStringButtonDown, self.pictureStringIcon,
				self.toolTip, self, _menuRoot);

	if self.myParent &lt;&gt; null then
		pos := self.myParent.allChildren.indexOf(self);
	endif;

//	app.myUtilityCA.utlCreateMenuUserItem(pxyUserDtl, _parent, 0, realUserDtl);	
	create realUserDtl as CM_MenuUserDtl persistent;
	realUserDtl.setForCreate(pxyUserDtl, _parent, pos);

	return realUserDtl;
	
epilog
	delete pxyUserDtl;
	
end;</source>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
        <ReturnType type="CM_MenuUserItem"/>
    </JadeMethod>
    <JadeMethod name="addToUserMenuFromMenu" id="eec4ff45-b218-4993-bcc6-7e7ea7a7ab8f">
        <source>addToUserMenuFromMenu(_menuRoot: CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	sharedLock(self);

	if (not self.canDoForRoot(_menuRoot)) then
		return;
	endif;

	self.addToUserMenuRoot(_menuRoot);
	
	inheritMethod(_menuRoot);

end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToUserMenuRoot" id="9a1bc606-d45c-43d0-a0ca-5635bd33342d">
        <source>addToUserMenuRoot(_menuRoot : CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
begin
	inheritMethod(_menuRoot);
end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canUserDo" id="b587279e-e35c-4655-baf5-54281ab4541b">
        <source>canUserDo(_user: CM_User; _terminal: CM_Terminal; _permValue: Integer): Boolean;
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	return _user.canDo(_terminal, _permValue);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_permValue" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getIdPrefix" id="d755ffa2-4e1c-49aa-a8d4-a586ca355f35">
        <source>getIdPrefix() : String abstract;
// ---------------------------------------------------------------------------
// Created:     29 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------</source>
        <abstract/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateFromUserDtl" id="b90f78b7-f0d4-42b9-828f-1e8305d9594f">
        <updating/>
        <source>setForUpdateFromUserDtl(_parent : CM_MenuEntity input; 
					_pos : Integer; 
					_userDtl : CM_MenuUserItem;
					_menuRoot : CM_MenuRoot input) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myParent := null;
	_parent.addChild(self, _pos);
	self.setMyMenuRoot(_menuRoot);
	
	self.pictureStringButton		:= _userDtl.pictureStringButton;
	self.pictureStringButtonDown	:= _userDtl.pictureStringButtonDown;
	self.pictureStringIcon			:= _userDtl.pictureStringIcon;
	self.toolTip					:= _userDtl.toolTip;

end;</source>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_userDtl" type="CM_MenuUserItem"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="13b3b798-5f51-434b-b3c8-3bd1c7caa7d8">
        <updating/>
        <source>setProxy(_heading : String; 
		_classNameToCreate : String; 
		_pictureButton : String; 
		_pictureButtonDown : String; 
		_pictureIcon : String; 
		_schemaName : String; 
		_windowClassName : String; 
		_permissionValue : Integer;
		_isSystemDetail : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theMenuId	: String;

begin

	theMenuId := self.getIdPrefix() &amp; _permissionValue.String;

	self.setProxyMenuDtl(_heading, theMenuId, _classNameToCreate, 
		_pictureButton, _pictureButtonDown, _pictureIcon,
		_schemaName, _windowClassName,
		_permissionValue, _isSystemDetail);

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_classNameToCreate" type="String"/>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
        <Parameter name="_pictureIcon" type="String"/>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_windowClassName" type="String"/>
        <Parameter name="_permissionValue" type="Integer"/>
        <Parameter name="_isSystemDetail" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyMenuDtl" id="40f19f16-96a8-4e61-89f5-6d79161dc356">
        <updating/>
        <source>setProxyMenuDtl(_heading, _menuId, _classNameToCreate, 
		_pictureButton, _pictureButtonDown, _pictureIcon,
		_schemaName, _windowClassName : String;
		_constValue : Integer;
		_isSystemDetail : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin


end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_menuId" type="String"/>
        <Parameter name="_classNameToCreate" type="String"/>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
        <Parameter name="_pictureIcon" type="String"/>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_windowClassName" type="String"/>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_isSystemDetail" type="Boolean"/>
    </JadeMethod>
</Class>
