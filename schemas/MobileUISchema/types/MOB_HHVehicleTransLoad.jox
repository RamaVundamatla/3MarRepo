    <JadeMethod name="isValidTruckForAction" id="394459c4-115d-4bdc-96f2-8714cdd1c192">
        <source>isValidTruckForAction( _truck : CM_Vehicle io;  errMsg : String output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation	TFS 4460

*/

vars

	wle : CM_WorkListEntry;
	isAnyWle : CM_WorkListEntry;

begin

	if _truck &lt;&gt; null then
		if not _truck.isOnsite or not _truck.myPrimaryActualLocation.CM_YardController.isInsideYard then
			// can't load/unload  it if its not in the yard eh!
			errMsg := app.getErrorString(Truck_Not_In_Yard);
			_truck := null;
		endif;
	endif;
	
	if _truck &lt;&gt; null then
	
		self.myMobileGenericAgent.setTruck( _truck );
		
		foreach wle in self.myMobileGenericAgent.allWlesToLoad do
			if wle.myRequest = null or not wle.myRequest.isAnyId() then
				continue;
			else
				isAnyWle := wle;
				break;
			endif;
		endforeach;
		
		if isAnyWle = null then
			self.myMobileGenericAgent.setTruck( null );
			_truck := null;
			errMsg := app.getErrorString( Task_found_that_would_allow_th );
			return;
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_truck" type="CM_Vehicle" usage="io"/>
        <Parameter name="errMsg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="88a3c764-9199-4f92-85f9-5e6cbf398a11">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2017	cnwndl1	Initial creation	TFS 4849

*/

vars

	errMsg : String;

begin

	if keyCode = J_key_Enter then
		if self.txtTruck &lt;&gt; null and self.txtTruck.text.toUpper &lt;&gt; self.lblTruck.caption.toUpper then
			self.txtTruck.keyDown( self.txtTruck, keyCode, shift );
		elseif self.txtScanTxt.text &lt;&gt; null and self.txtScanTxt.text.toUpper &lt;&gt; self.lblScanTxt.caption.toUpper then
			self.txtScanTxt.keyDown( self.txtScanTxt, keyCode, shift );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processVehicleScanText" id="c9ccbad3-ba44-43e5-8e21-55da1cdb9a9d">
        <source>processVehicleScanText( _errMsg : String output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation	TFS 4460

*/

vars

	scannedValue : String;
	startTi : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;
	
	tiToAdd : CM_TrackedItem;
	wle : CM_WorkListEntry;
	isAnyWle : CM_WorkListEntry;
	
	delReq : CM_DeliveryRequest;
	bulkRelease : CM_BulkRelease;
	moveController : CMIF_MoveController;

begin

	scannedValue := self.txtScanTxt.text;
	
	if scannedValue = self.lblScanTxt.caption.toUpper then
		_errMsg := app.getErrorString( Please_scan_vehicle );
		return;
	elseif scannedValue.trimBlanks = null then
		_errMsg := app.getErrorString( Please_scan_vehicle );
		return;
	endif;
	
	startTi := self.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( scannedValue, null );
	if startTi &lt;&gt; null then
		// Try real cargo ids first.
		iter := self.myTerminal.allOnsiteTIsByIdCargoType.createIterator;
		iter.startAtObject( startTi );
		while iter.next( ti ) do
			if ti.id &lt;&gt; scannedValue then
				break;
			endif;
			if not ti.isCar then
				continue;
			endif;
			tiToAdd := ti;
			break;
		endwhile;	
		delete iter;
	endif;
	
	if tiToAdd = null then
		//Try alternate id next
		startTi := self.myTerminal.allOnsiteTIsByAlternativeId.getAtKeyGeq( scannedValue );
		if startTi &lt;&gt; null then
			iter := self.myTerminal.allOnsiteTIsByAlternativeId.createIterator;
			iter.startAtObject( startTi );
			while iter.next( ti ) do
				if ti.alternativeId &lt;&gt; scannedValue then
					break;
				endif;
				if not ti.isCar then
					continue;
				endif;
				tiToAdd := ti;
				break;
			endwhile;	
		endif;
		delete iter;
	endif;
	
	if tiToAdd = null then
		_errMsg := "'" &amp; scannedValue &amp; "' " &amp; app.getErrorString( Err_Gate_VehicleId );
		return;
	endif;
	
	//OK lets see if we can proces this sucker.
	//Get the "Is Any" Work List Entry
	self.myMobileGenericAgent.setTruck( self.myTruck );
	
	foreach wle in self.myMobileGenericAgent.allWlesToLoad do
		if wle.myRequest = null or not wle.myRequest.isAnyId() then
			continue;
		else
			isAnyWle := wle;
			break;
		endif;
	endforeach;
	
	if isAnyWle = null then
		_errMsg := app.getErrorString( Task_found_that_would_allow_th ) &amp; "[No 'Is Any' Work List Entry]";
		return;
	endif;
	
	//OK we got a valid wle and a car, so is the car on the delivery request.
	delReq := isAnyWle.myRequest.CM_DeliveryRequest;	 // its always a delivery request if its an Any Id
	bulkRelease := delReq.myOriginatingBulkRelease;
	if bulkRelease = null then
		_errMsg := app.getErrorString( Task_found_that_would_allow_th ) &amp; "[No Bulk Release]";
		return;
	endif;
	if not tiToAdd.isTiAvailableForAnyIdSelection() then
		_errMsg := app.getErrorString( Task_found_that_would_allow_th ) &amp; "[" &amp; tiToAdd.id &amp; " not valid for 'Is Any']";
		return;
	endif;
	if not bulkRelease.allTrackedItemsAssigned.includes( tiToAdd ) then
		_errMsg := app.getErrorString2( Cargo_item_assig_relea_again_r, tiToAdd.id, bulkRelease.code );
		return;
	endif;
	
	//Should be all go
	
	create moveController transient;
	moveController.setMyWorkListEntry(isAnyWle);
	moveController.setMyToPrimaryLocation(self.myTruck.locationsController); 
	moveController.setMyTrackedItem(tiToAdd);
	
	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if not app.myPassport.trxCompletedOK then
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				_errMsg := app.myPassport.getAllErrorsAndWarningsAsStr();
			endif;
		endif;
		break;
	endwhile;

epilog

	delete moveController;

end;</source>
        <Parameter name="_errMsg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="registerKeyCodes" id="bd481156-fb7b-4863-978e-73059967a9d2">
        <source>registerKeyCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation	TFS 4460

*/

vars

	keyCodes: IntegerArray;

begin
	create keyCodes transient;
	keyCodes.add(J_key_F1);
	keyCodes.add(J_key_F2);
	keyCodes.add(J_key_F3);
	keyCodes.add(J_key_F4);
	keyCodes.add(J_key_F5);
	keyCodes.add(J_key_F6);
	keyCodes.add(J_key_F7);
	keyCodes.add(J_key_F8);
	keyCodes.add(J_key_F9);
	keyCodes.add(J_key_F10);
	keyCodes.add(J_key_F11);
	keyCodes.add(J_key_F12);
	keyCodes.add(J_key_Delete);
	keyCodes.add(J_key_Enter);
	keyCodes.add(J_key_Tab);
	self.registerFormKeys(keyCodes);
epilog
	delete keyCodes;
end;

</source>
    </JadeMethod>
