    <JadeMethod name="includeCOO" id="ffed3778-c3fe-4f32-b275-1bb5ecd50c4f">
        <source>includeCOO(_ownership : CM_OwnershipChange; _checkDetails : Boolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2023 navtnr20	TFS CR 58224	Task 58226: UI - COO Query
*/

vars
	detailOK, hasCurrent : Boolean;
	contract : CM_OwnershipChange;
	ownershipDetil: CM_OwnershipChangeDetail;
	commodity,cargotype,str,operatorNew, operatorOld,subType : String;
	strArray : StringArray;
	isMatch : Boolean;
	ti : CM_TrackedItem;
begin
	contract :=  _ownership;

	if self.filterQueryRefNumber &lt;&gt; "" then
		if _ownership.refNumber.toUpper().pos(self.filterQueryRefNumber.toUpper(),1) &lt; 1 then
			return false;
		endif;
	endif;
	
	if self.filterQueryCOOFromStart.isValid() then
		if self.systemToLocalTime(_ownership.dateTimeCOO) &lt; self.filterQueryCOOFromStart then
			return false;
		endif;
	endif;
	
	if self.filterQueryCOOFromTime.isValid() then
		if self.systemToLocalTime(_ownership.dateTimeCOO) &lt; self.filterQueryCOOFromTime then
			return false;
		endif;
	endif;
	if self.filterOperatorOld &lt;&gt; "" then
		if contract.myOperatorOld = null then
			return false;
		endif;
		operatorOld := contract.myOperatorOld.code;
		if self.filterOperatorOld.pos(operatorOld,1) &lt;= 0 then
			return false;
		endif;
	
	endif;
	if self.filterOperatorNew &lt;&gt; "" then
		if contract.myOperatorNew = null then
			return false;
		endif;
		operatorNew := contract.myOperatorNew.code;
		if self.filterOperatorNew.pos(operatorNew,1) &lt;= 0 then
			return false;
		endif;
	
	endif;
	
	isMatch := true;
	if _ownership.allDetails.isNotEmpty() then
		if self.filterQueryCargoType &lt;&gt; "" 
		or self.filterCargoSubType &lt;&gt; "" 
		or self.filterQueryCommodity &lt;&gt; "" then
			foreach ownershipDetil in _ownership.allDetails do
				 ti := ownershipDetil.myTrackedItem;
				 
				if self.filterQueryCargoType &lt;&gt; "" then
					cargotype := ti.cargoTypeCode;
					if self.filterQueryCargoType.pos(cargotype,1) &lt;= 0 then
						isMatch := false;
						break;
					endif;
				endif;
				if self.filterCargoSubType &lt;&gt; "" then
					subType := ti.cargoTypeCode;
					if self.filterCargoSubType.pos(subType,1) &lt;= 0 then
						isMatch := false;
						break;
					endif;
				
				endif;
				if self.filterQueryCommodity &lt;&gt; "" then
					commodity := ti.commodity;
					if self.filterQueryCommodity.pos(commodity,1) &lt;= 0 then
						isMatch := false;
						break;
					endif;
				
				endif;
			endforeach;
		endif;
	endif;
	
	return isMatch;

epilog

end;</source>
        <Parameter name="_ownership" type="CM_OwnershipChange"/>
        <Parameter name="_checkDetails" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTblCOOEnquiry" id="9e62ef61-8de3-4341-9241-6933b0aeba99">
        <source>initTblCOOEnquiry(_theEntDef :String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblData;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_OwnershipChange);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblData);	
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
