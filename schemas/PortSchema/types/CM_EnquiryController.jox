    <JadeMethod name="includesObject" id="a7fb3a6d-350e-424c-8586-862f5351bc79">
        <updating/>
        <source>includesObject(_obj : CM_Object; _breakOut : Boolean output; _passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 11/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 04/04/2016	cnwdap1		PAR #35843 make monitor time-based rather than object-count based
vars
	cmifMonitor					: CMIF_Monitor;
	monitorReturnValue			: Integer;
	failedDAC  :CM_DataAccessController;
begin
	self.numItemsSearched := self.numItemsSearched + 1;

	 //+ cnwmd1, Par 22477 - May not be in load state - added test for isInLoadState
	if (self.numItemsSearched mod 400) = 0 and process.isInLoadState then
		endLoad;
		beginLoad;
	endif;
	
	//if (self.numItemsSearched mod 200) = 0 then													// PAR #35843
	if (app.relativeMachineTime - self.lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
		cmifMonitor := app.myPassport.myCMIFMonitor;
		if cmifMonitor &lt;&gt; null then
			cmifMonitor.updateProgress(null, self.numItemsSearched, self.numItemsFound);
			monitorReturnValue := cmifMonitor.monitorReturnValue;
			if (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   (monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
				_breakOut := true;
				CM_BreakOutException.raise_(cmifMonitor.monitorReturnValue, 'Breaking Out');
				return false;
			endif;
		endif;
		self.lastUpdate := app.relativeMachineTime;													// PAR #35843
	endif;
	
	//if not self.myFilterClass.hasInstance(_obj) then
	if not _obj.isKindOf(self.myFilterClass) then					// TFS 55110 navmd1 11/10/2022 - Try and make this check a little faster by using isKindOf instead. We're not doing error 4 checks elsewhere,
		return false;												// 									so the fact that hasInstance works on deleted objects shouldn't inpact our decision to use isKindOf instead.
	endif;
	

	if self.myCriteriaLineHolder &lt;&gt; null then
		if (not _obj.qrySelector(self.myCriteriaLineHolder)) then
			return false;
		endif;
	endif;
	
	//jlger1 42829 10/1/19 found this was more expensive than the qrySelector
	if (not _obj.canUserAccessSelf(null, failedDAC, _passport)) then
		return false;
	endif;
	
	return true;

epilog
	endLoad;				// 11/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
