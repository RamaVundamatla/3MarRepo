<Class name="CMQF_YardAudit" id="a102b909-5f18-4665-a6ad-016ff1c4cabe">
    <superclass name="CMQF_TrackedItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="a2f38e33-fd0e-49c9-a18f-2e9cf2bdea4c">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		22 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	ta			: CM_TerminalArea;
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
begin
	ta := self.getMyTerminalArea;
	
	if ta &lt;&gt; null then
		//
		foreach lc in ta.allLocationsControllers discreteLock do
			foreach ti in lc.allTrackedItems discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
					endif;
				endif;
				
//				if breakOut then
//					return;
//				endif;
			endforeach;
		endforeach;
	else
		//need to scan onsite when no ta specified
		
		//search onsite ti's
		//TI_STATE_NORMAL
		if self.getMyCargoType &lt;&gt; null then
			//limit search to that type (for speed?)
			foreach terminal in self.allTerminals do
				foreach ti in terminal.allOnsiteTIsByCargoTypeId discreteLock where ti.cargoType = self.getMyCargoType.id do
					if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//					if self.includesObject(ti, _passport, breakOut) then
						if not _collection.includes(ti) then
							_collection.add(ti);
						endif;
					endif;
					
//					if breakOut then
//						return;
//					endif;
				endforeach;
			endforeach;
		else
			//search all onsite ti's
			foreach terminal in self.allTerminals do
				foreach ti in terminal.allOnsiteTIsByCargoTypeId discreteLock  do
					if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//					if self.includesObject(ti, _passport, breakOut) then
						if not _collection.includes(ti) then
							_collection.add(ti);
						endif;
					endif;
					
//					if breakOut then
//						return;
//					endif;
				endforeach;
			endforeach;
		endif;
	endif;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="ae8ce104-3c9f-4301-a97d-a394cd57faa8">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		22 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars

begin
	if (not CM_Log.hasInstance(_ti)) and
	   inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
