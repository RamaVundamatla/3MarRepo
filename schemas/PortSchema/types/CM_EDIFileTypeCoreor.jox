<Class name="CM_EDIFileTypeCoreor" id="5f88a1a1-aa91-4352-88a4-9a1e215965bb">
    <superclass name="CM_EDIFileTypeUNEDIFACT"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="1a333850-1136-4233-b595-1df00ff086ac">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "COREOR - Operator Stop Clearance D96B";
	self.type	:= EDIFileType_Coreor;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractFile" id="357fcab7-dc46-4e03-b22f-198be753adbc">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
// ---------------------------------------------------------------------------
// Created:		23 January 2003  by Jason Chapman  (cnwjc2)ccms1063
// ---------------------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET

vars
	ediDataOperatorStop: CM_EDIDataOperatorStop;
//	longString: CM_LongString;
	ediTI: CM_EDITrackedItem;
	file: File;
	tiNumber,count: Integer;
	voyageCode: String;
	operator :CM_Operator;
	firstTime: Boolean;
	str : String;
begin
	if (not CM_EDIDataOperatorStop.hasInstance(_ediFile.ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, _ediFile.ediData.class.name, null, null);
		return;
	endif;

	ediDataOperatorStop := _ediFile.ediData.CM_EDIDataOperatorStop;
	operator := app.myRoot.allOperators[ediDataOperatorStop.operatorCode];

	str := str &amp; "UNB+UNOA:s+CUSMOD:ZZZ+PORTNZWGL:ZZZ+" &amp; "990322:0953" &amp; "+" &amp; _number.String &amp; "'" &amp; CrLf;
	tiNumber := 1;
	firstTime := false;
	foreach ediTI in ediDataOperatorStop.allEDITrackedItems do
//		if voyageCode &lt;&gt; ediTI.CM_EDIOperatorStopTI.voyageCode then	// cnwrl1 09/06/2010 PAR 24299 - what it was
		if voyageCode &lt;&gt; ediTI.CM_EDIOperatorStopTI.getVoyageCode() then
			if firstTime = true then
				count := count + 1;
				str := str &amp; "UNT+" &amp; count.String &amp; "+" &amp; tiNumber.String &amp; "'" &amp; CrLf;
				count := 0;
			endif;
			firstTime := true;
			str := str &amp; "UNH+" &amp; tiNumber.String &amp; "+CUSRES:D:96B:UN+080922'" &amp; CrLf;
			count := count + 1;
			str := str &amp; "BGM+932+" &amp; tiNumber.String &amp; "+:01'" &amp; CrLf;
			count := count + 1;
//			str := str &amp; "TDT+20+" &amp; ediTI.CM_EDIOperatorStopTI.voyageCode.trimBlanks &amp; "+1+++++:::" &amp; ediTI.CM_EDIOperatorStopTI.vesselName.trimBlanks &amp; "'" &amp; CrLf;	// cnwrl1 09/06/2010 PAR 24299 - what it was
			str := str &amp; "TDT+20+" &amp; ediTI.CM_EDIOperatorStopTI.getVoyageCode().trimBlanks &amp; "+1+++++:::" &amp; ediTI.CM_EDIOperatorStopTI.vesselName.trimBlanks &amp; "'" &amp; CrLf;
			count := count + 1;
			str := str &amp; "NAD+FW+" &amp; ediTI.CM_EDIOperatorStopTI.freightForwarder.trimBlanks &amp; ":160" &amp; CrLf;	//31 May 2017	NDL TFS 4456
			count := count + 1;	//31 May 2017	NDL TFS 4456
			str := str &amp; "GIS+834:120:143'" &amp; CrLf;
			count := count + 1;
		endif;
		str := str &amp; self.extractTI(ediTI.CM_EDIOperatorStopTI, tiNumber, operator);
		count := count + 2;
		tiNumber := tiNumber + 1;
//		voyageCode := ediTI.CM_EDIOperatorStopTI.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
		voyageCode := ediTI.CM_EDIOperatorStopTI.getVoyageCode();
	endforeach;
	count := count + 1;
	str := str &amp; "UNT+" &amp; count.String &amp; "+" &amp; tiNumber.String &amp; "'" &amp; CrLf;
	str := str &amp; "UNZ+1+" &amp; _number.String &amp; "'" &amp; CrLf;
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractTI" id="be54ea16-1dcc-4afe-bf58-617c68bb6577">
        <updating/>
        <source>extractTI(_ediTI : CM_EDITrackedItem input; _number : Integer; _operator : CM_Operator) : String updating, protected;
// ---------------------------------------------------------------------------
// Created:		23 January 2003  by Jason Chapman  (cnwjc2)ccms1063
// ---------------------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET

vars
	code: String;
	str : String;
begin
	str := "DOC+25'" &amp; CrLf;

	if _ediTI.fullOrMT = "E" then
		code := "4";
	elseif _ediTI.fullOrMT = "F" then
		code := "5";
	elseif _ediTI.fullOrMT = "L" then
		code := "7";
	elseif _ediTI.fullOrMT = "B" then
		code := "8";
	endif;

	str := str &amp; "EQD+CN+" &amp; _ediTI.id &amp; "++++" &amp; code &amp; "'" &amp; ETRow_NoCrLf;
	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="8c20363d-2681-4069-bddd-e55212c6f68a">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	27 August 2004	by Jason Chapman  (cnwjc2) ccms1063
//----------------------------------------------------------------
vars
	
begin
	_ediDataClass	:=	CM_EDIDataOperatorStop;
	_dataType			:=	EDIDataType_OperatorStop;
	_fileTypeCode	:=	self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIPartyRules" id="83f72d83-1ff4-4916-89c9-3272399f1832">
        <source>getEDIPartyRules(_ediParty: CM_EDIParty): CM_EDIPartyRules protected;
//
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
//
vars

begin
	if _ediParty = null then
		return null;
	endif;
	return _ediParty.getRulesForFileType (EDIFileType_Coreor);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediParty" type="CM_EDIParty"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="ed839778-33df-4bbb-848c-bc52fc7c4a27">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
// ---------------------------------------------------------------------------
// Created:		23 January 2003  by Jason Chapman  (cnwjc2)ccms1063
// ---------------------------------------------------------------------------
// 15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
// 03 Mar 2013	cnwrs1	Par 31383 string too long with customs entry number
// 16 Sep 2013 cnwah9 removed error messages and unnecessary code
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 23 May 2018	jlgrs1	TFS 38357 SNO Fix Xlations from TFS 6797
// 08 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	operatorStopTI			: CM_EDIOperatorStopTI;
	ediDataOperatorStop		: CM_EDIDataOperatorStop;
	ediPartyRules : CM_EDIPartyRules;
	lineStr					: String;
	message					: String;
	int						: Integer;
	generatedContainerNo	: Integer;
	voyageCode				: String;
	vesselName				: String;
	operatorVoyageCode		: String;			// cnwrl1 20/07/2010 PAR 25046
	lloydsNumber			: String;			// cnwrl1 20/07/2010 PAR 25046
	callSign				: String;			// cnwrl1 20/07/2010 PAR 25046
	operatorSenderCode		: String;			// cnwrl1 21/07/2010 PAR 25093
	port					: String;
	group					: Integer;
	code					: String;
	rngType					: String;
	operatorSender			: CM_Operator;		// cnwrl1 21/07/2010 PAR 25093
	operatorVoyage			: CM_Operator;		// cnwrl1 21/07/2010 PAR 25093
	temperature				: Real;
	tmpMin					: Real;
	tmpMax					: Real;
	msgCount				: Integer;
	numMsgs					: Integer;
	passport				: CM_Passport;
	msgHelper				: CMIF_EDIFACTHelper;
//	binaryLine				: Binary;
	overallEntryNumber		: String;
	messageMode				: String; // CCMS1807 cnwrs1 Feb 2009 
	tempRawEDIDataArray : StringArray; //ccms1845
	rawEDIHeaderLine : Integer;
	idx : Integer;
	untCount : Integer;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
	theLines : HugeStringArray;
	rawSenderCode : String;
	creationTS : TimeStamp;
	sequence : String;
	fileType : String;
	version : String;
	recipientCode : String;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	foundMatch : Boolean;
	fileWideFreightFwdr : String; // actually means per header trailer UNH/UNT section.
	fileWideExpiryDate : Date;
	tmpDate : Date;
    ruleFunction : Integer; 	// BGM local variable
	nad1_1Code : String;
	rff1_1Code : String;
	segmentValue : String;
	nad1_1Function : String;
	rff1_1Function : String;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;
	ediDataOperatorStop := _ediFile.ediData.CM_EDIDataOperatorStop;
	create tempRawEDIDataArray transient;
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);
	messageMode := CM_EDITrackedItem.EDI_ACTION_ADD; // CCMS1807 cnwrs1 feb 2009 PAR19528
	
	fileWideExpiryDate := null;	//02 Jun 2017

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		tempRawEDIDataArray.add(lineStr[1:62]);
		msgCount	:=	msgCount + 1;
		untCount := untCount + 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;

		msgHelper.setNextMessage(lineStr);	//set the current message
		
		//get current
		message := msgHelper.currentMessage;
//BGM
		if msgHelper.currentTag = "BGM" then
			group := 0;
			if group = 0 then
				msgHelper.setNextField;
				msgHelper.setNextField;
				msgHelper.setNextField;
				// CCMS1807 cnwrs1 Feb 2009 PAR19528
				if msgHelper.currentField = "1"
				or msgHelper.currentField = "3"	//05 Dec 2017	NDL	TFS 7791
				then
					messageMode := CM_EDITrackedItem.EDI_ACTION_DELETE;
				elseif msgHelper.currentField = "5" then
					messageMode := CM_EDITrackedItem.EDI_ACTION_UPDATE;
				elseif msgHelper.currentField = "9" then
					messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
				else
					// Behaviour as previous 
					 messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
				endif;
				operatorStopTI := null; //04 Jan 2018	NDL	TFS 42199 - so we know if its the first stop in the group or not.
			endif;
//CNT
		elseif msgHelper.currentTag = "CNT" then
			if group &lt; 11 then
				group := 11;
			endif;
			if group = 11 then
				if operatorStopTI &lt;&gt; null then //ccms 1845 we have a previous operatorStopTi so copy the rawEDIData to this operatorStopTi but not this line
					foreach idx in 1 to tempRawEDIDataArray.size-1 do
						operatorStopTI.rawEDIDataArray.add(tempRawEDIDataArray[idx]);
					endforeach;
					foreach idx in tempRawEDIDataArray.size-1 to rawEDIHeaderLine step -1 do
						tempRawEDIDataArray.removeAt(idx);
					endforeach;
				endif;
			endif;
//CTA
		elseif msgHelper.currentTag = "CTA" then
			if group &lt; 4 then
				group := 4;
			endif;
//DGS
		elseif msgHelper.currentTag = "DGS" then
			if group = 7  then //temp should be &gt; 9
				group := 8;
			endif;
			if group = 8 then
				msgHelper.setNextField;
				if msgHelper.currentField = "IMD" then
					msgHelper.setNextField;
				endif;
			endif;
//DIM
		elseif msgHelper.currentTag = "DIM" then
					
			if group = 9 then
				msgHelper.setNextField;
				code := msgHelper.currentField;
				msgHelper.setNextField;
				if msgHelper.currentSubItem = "CMT" or
				   msgHelper.currentSubItem = "CM" then //valid baplie 1 still used by some systems
					msgHelper.setNextSubItem;
//					operatorStopTI.length := msgHelper.currentSubItem.Integer;
					msgHelper.setNextSubItem;
//					operatorStopTI.width := msgHelper.currentSubItem.Integer;
					msgHelper.setNextSubItem;
//					operatorStopTI.height := msgHelper.currentSubItem.Integer;
				endif;
			endif;
			
	
//DTM	
		elseif msgHelper.currentTag = "DTM" then		
			// 02 Jun 2017	NDL	TFS 4455 - looking for the DTM+400  or  DTM+36
			// If it preceeds the first "EQD", then its file wide.
			msgHelper.setNextField;
			code := msgHelper.currentSubItem;
			if ediPartyRules = null or (ediPartyRules.CM_EDIPartyCoreorRules &lt;&gt; null and not ediPartyRules.CM_EDIPartyCoreorRules.ignoreExpiryDates) then 
				if code = "400" or code = "36" then
					if ediPartyRules &lt;&gt; null then
					endif;
					msgHelper.setNextSubItem;
					code := msgHelper.currentSubItem;
					tmpDate := null;
					if code.length &gt;= 8 and code[1:8].isInteger then
						tmpDate.setDate( code[7:2].Integer, code[5:2].Integer, code[1:4].Integer );
					endif;
					if tmpDate.isValid then
						if operatorStopTI &lt;&gt; null then
							operatorStopTI.expiryDate := tmpDate;
						else
							fileWideExpiryDate := tmpDate;
						endif;
					endif;
				endif;
			endif;

//EQD
		elseif msgHelper.currentTag = "EQD" then
			group := 9; //cnwgb1 PAR 18418 CCMS 1743 7.11.08
			if rawEDIHeaderLine = null then //ccms 1845
				rawEDIHeaderLine := tempRawEDIDataArray.size-1; //ignore this line
			endif;
			msgHelper.setNextField;
			if msgHelper.currentField = "CN" then
				if operatorStopTI &lt;&gt; null then //ccms 1845 we have a previous operatorStopTi so copy the rawEDIData to this operatorStopTi but not this line
					foreach idx in 1 to tempRawEDIDataArray.size-1 do
						operatorStopTI.rawEDIDataArray.add(tempRawEDIDataArray[idx]);
					endforeach;
					foreach idx in tempRawEDIDataArray.size-1 to rawEDIHeaderLine step -1 do
						tempRawEDIDataArray.removeAt(idx);
					endforeach;
				endif;
				create operatorStopTI persistent;
				operatorStopTI.setForCreateNew(ediDataOperatorStop);
				operatorStopTI.entryNumber := overallEntryNumber.trimBlanks[1:25];	// 31383 // 13/03/2013 cnwar2 #31282
				operatorStopTI.messageMode := messageMode;
				msgHelper.setNextField;
				operatorStopTI.setId(msgHelper.currentSubItem[1:11]);	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
				if operatorStopTI.id = null then // if the last operatorStopTI has no id
					generatedContainerNo := generatedContainerNo + 1;
					operatorStopTI.setIdDefault(generatedContainerNo.String);
				endif;
				if operatorStopTI.getVoyageCode() = null then
					// Use the operator voyage code translation if it exists.
					voyageCode	:= self.getXlationOperatorVoyageCode(	operatorSender,
																		operatorVoyage,
																		voyageCode,
																		vesselName,
																		lloydsNumber,
																		callSign );
					// make sure the manual collection on CM_EDIConfig gets maintained
					operatorStopTI.setVoyageCode( voyageCode );
				endif;
// cnwdad1 21/01/2010 - PAR #22147.
				if operatorStopTI.vesselName = null then
					operatorStopTI.vesselName := vesselName;
				endif;
				msgHelper.setNextField;
				msgHelper.setNextField;
				msgHelper.setNextField;
				msgHelper.setNextField;
				if msgHelper.currentField = "4" then
					operatorStopTI.fullOrMT := "E";
				elseif msgHelper.currentField = "5" then
					operatorStopTI.fullOrMT := "F";
				endif;
				//31 May 2017	NDL	TFS 4456
				if fileWideFreightFwdr &lt;&gt; null then
					operatorStopTI.freightForwarder := fileWideFreightFwdr;
				endif;
				//02 Jun 2017	NDL	TFS 4455
				if fileWideExpiryDate.isValid then
					operatorStopTI.expiryDate := fileWideExpiryDate;
				endif;
				int := int + 1;
			endif;
//FTX
		elseif msgHelper.currentTag = "FTX" then
			if group = 0 or group = 5 or group = 8 or group = 9 then
				msgHelper.setNextField;
				if msgHelper.currentField = "AAA" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
				endif;
			endif;
//GID
		elseif msgHelper.currentTag = "GID" then
			if group &lt; 5 then
				group := 5;
			endif;
//HAN

//LOC
		elseif msgHelper.currentTag = "LOC" then
			msgHelper.setNextField;
			if group = 10 then
				if msgHelper.currentField = "99" then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
				elseif msgHelper.currentField = "11" then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
				endif;
			endif;
//MEA
		elseif msgHelper.currentTag = "MEA" then
			if group = 6 or group = 7 or group = 8 or group = 9 then
				msgHelper.setNextField;
				if msgHelper.currentField = "WT" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					if msgHelper.currentSubItem = "KGM" then
						msgHelper.setNextSubItem;
					elseif msgHelper.currentSubItem = "LBR" then
						msgHelper.setNextSubItem;
					endif;
				endif;
			endif;
//NAD
		elseif msgHelper.currentTag = "NAD" then
		
			if group &lt; 3 then
				group := 3;
			elseif group &lt; 6 then
				group := 6;
			elseif group &lt; 11 then
				group := 11;
			endif;
			msgHelper.setNextField;
			nad1_1Code := msgHelper.currentSubItem;
			if ediPartyRules &lt;&gt; null then
				ruleFunction := ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_1_1, nad1_1Code, segmentValue);
				if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
					if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
						nad1_1Function := CM_EDIPrenoteTI::freightForwarder.name;
					endif;
					if nad1_1Function &lt;&gt; null then
						msgHelper.setNextField();
						if operatorSender &lt;&gt; null then
							if operatorStopTI &lt;&gt; null then
								operatorStopTI.setPropertyValue(nad1_1Function, operatorSender.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
							else
								fileWideFreightFwdr := operatorSender.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
							endif;
						else
							if operatorStopTI &lt;&gt; null then
								operatorStopTI.setPropertyValue(nad1_1Function, msgHelper.currentSubItem.trimBlanks()[1:30]);
							else
								fileWideFreightFwdr := msgHelper.currentSubItem.trimBlanks()[1:30];
							endif;
						endif;
					endif;	
				endif;
			endif;
			if nad1_1Function = null then
				if group = 3 or group = 6 or group = 11 then
					if nad1_1Code = "CA" then		// Sender Operator
						msgHelper.setNextField;
	//					operatorStopTI.operatorCode := msgHelper.currentSubItem;
	
					elseif nad1_1Code = "FW" then	//31 May 2017	NDL	TFS 4456
						// If it preceeds the first "EQD", then its file wide.
						msgHelper.setNextField;
						
						if operatorSender = null then
							if operatorStopTI &lt;&gt; null then
								operatorStopTI.freightForwarder := msgHelper.currentSubItem[1:30];
							else
								fileWideFreightFwdr := msgHelper.currentSubItem[1:30];
							endif;
						else
							if operatorStopTI &lt;&gt; null then
								operatorStopTI.freightForwarder := operatorSender.getXlationSystemCode( msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch )[1:30];
							else
								fileWideFreightFwdr := operatorSender.getXlationSystemCode( msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch )[1:30];
							endif;
						endif;
					endif;
				endif;
			endif;
//RFF
		elseif msgHelper.currentTag = "RFF" then
			if group = 0  then
				group := 1;
			endif;
			msgHelper.setNextField;
			rff1_1Code := msgHelper.currentSubItem;
			if ediPartyRules &lt;&gt; null then
				ruleFunction := ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_RFF_1_1, rff1_1Code, segmentValue);
/*				if ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ACW then
					rff1_1Code := "ACW";
				elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_ANN then
					rff1_1Code := "ANN";
				elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_BN then
					rff1_1Code := "BN";
				elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_RE then
					rff1_1Code := "RE";
				elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_REO then
					rff1_1Code := "REO";
				elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_SQ then
					rff1_1Code := "SQ";
				elseif ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_VON then
					rff1_1Code := "VON";
				endif;
			endif;*/
				if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
					if ruleFunction = CM_EDIEDIFactRule.Fnct_RFF_1_1_EntryNumber then
						rff1_1Function := CM_EDIOperatorStopTI::entryNumber.name;
					endif;
					if rff1_1Function &lt;&gt; null then
						msgHelper.setNextSubItem();
						if operatorStopTI &lt;&gt; null then
							operatorStopTI.setPropertyValue(rff1_1Function, msgHelper.currentSubItem[1:11]);
						else
							overallEntryNumber := msgHelper.currentSubItem[1:11];
						endif;
					endif;	
				endif;
			endif;
			if nad1_1Function = null then
				if group = 1 or group = 2 or group = 4 or group = 6 then
					if group = 1 //ccms 1743 PAR 18418 cnwgb1 6.11.08
					   and (rff1_1Code = "RE" or rff1_1Code = "REO") then 
						msgHelper.setNextSubItem;
						overallEntryNumber := msgHelper.currentSubItem;
					elseif rff1_1Code = "ACW" then
						msgHelper.setNextSubItem;
						if msgHelper.currentSubItem = "1" then
						endif;
					elseif rff1_1Code = "BN" then
					endif;
				elseif group = 9 then  
					if rff1_1Code = "RE" or
					   rff1_1Code = "REO" then //cnwrs1 May 2008 found this change in JMT753 but not in JMT751 JMT752 
						msgHelper.setNextSubItem;
						operatorStopTI.entryNumber := msgHelper.currentSubItem.trimBlanks[1:11];	//31383
					endif;
				endif;
			endif;
//RNG
		elseif msgHelper.currentTag = "RNG" then
			if group = 9 then
				msgHelper.setNextField;
				if msgHelper.currentField = "4" then
					msgHelper.setNextField;
					rngType := msgHelper.currentField;
					msgHelper.setNextSubItem;
					tmpMin := msgHelper.currentSubItem.asEDIReal();
					msgHelper.setNextSubItem;
					tmpMax := msgHelper.currentSubItem.asEDIReal();
				endif;
			endif;
//SEL

//SGP

//TDT
		elseif msgHelper.currentTag = self.TDT then
			if group &lt; 2 then
				group := 2;
			elseif group &lt; 10 then
				group := 10;
			endif;
			msgHelper.setNextField;
			if group = 2 then
				if msgHelper.currentField = "20" then
					
					// Note: We might not use all of the returned strings but this is a standard method for TDT+20.
					self.getVoyageDetailsFromTDT(	msgHelper,
													voyageCode,
													operatorVoyageCode,
													operatorVoyage,			// cnwrl1 26/07/2010 PAR 25093
													vesselName,
													lloydsNumber,
													callSign );
					if operatorSender = null then
						operatorSender				:= operatorVoyage;
						operatorSenderCode			:= operatorVoyageCode;
					endif;
                    if 	ediDataOperatorStop.operatorCode = null then  	// 24/05/2013 cnwar2 #31532
                        ediDataOperatorStop.operatorCode  := operatorSenderCode;
                    endif;
				endif;
			endif;
//TMP
		elseif msgHelper.currentTag = "TMP" then
			if group = 9 then
				msgHelper.setNextField;
				if msgHelper.currentField = "2" then
					msgHelper.setNextField;
					temperature := msgHelper.currentSubItem.asEDIReal();
					msgHelper.setNextSubItem;
				endif;
			endif;
//TSR

//UNA

//UNB
		elseif msgHelper.currentTag = self.UNB then
			// get The translated Sender Operator and Code.
//			self.getUNB_ElementData(	msgHelper,
//										operatorSenderCode,
//										operatorSender, rawSenderCode, recipientCode, creationTS, sequence);
			self.getUNBData(ediDataOperatorStop, msgHelper, operatorSenderCode, rawSenderCode, recipientCode, ediPartyRules, operatorSender, creationTS, sequence);
			
			ediDataOperatorStop.operatorCode  := operatorSenderCode[1:5];	// 24/05/2013 cnwar2 #31532
//UNH
		elseif msgHelper.currentTag = "UNH" then
			untCount := 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
			self.getUNHData(_ediFile.ediData, msgHelper, fileType, version);
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(rawSenderCode, recipientCode, fileType, version, _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				ediDataOperatorStop.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
//UNT
		elseif msgHelper.currentTag = "UNT" then
			group := 0;
			msgHelper.setNextField;
//UNZ

		endif;
	endforeach;
epilog
	delete theLines;
	delete msgHelper;
	delete tempRawEDIDataArray;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
