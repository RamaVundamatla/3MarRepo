// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	form: JACBackupScheduleEditForm;
begin
	self.myCurrentCntrl := _btn;
	create form;
	form.centreWindow;
	form.mySchedule:=null;
	form.showModal;
	self.resetTable;
end;</source>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnReset_click" id="07cd160b-f942-41cf-8d2a-fd56a63c980b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnReset_click(_btn: Button input) updating;
// Reset a stalled schedule
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	sched: JACBackupSchedule;
begin
	self.myCurrentCntrl := _btn;
	jdtCurrent.column := 1;
	sched := jdtCurrent.itemObject.JACBackupSchedule;
//	if sched.status &lt;&gt; JACBackupComplete then
		beginTransaction;
		sched.setStatus(JACBackupScheduled);
		sched.setFinalMessage(null);
		commitTransaction;
//	else
//		self.statusLine.caption := "Unable to reset completed schedules.";
//	endif;
end;</source>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
