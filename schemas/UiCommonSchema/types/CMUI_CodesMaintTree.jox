    <JadeMethod name="setMyCurrentVMObject" id="bbcc7b76-c625-4418-85d2-8298da66e8c5">
        <updating/>
        <source>setMyCurrentVMObject(_value : SOP_ViewModelObject ) updating;
/*

Purpose:	 myCurrentVMObject.myObject and myCurrentObject can get out of synch hopefully if we update
			myCurrentVMObject in the one method and this updates myCurrentObject to be  myCurrentVMObject.myObject then
			they won't be out of synch and avoid all the exceptions on this form
			
			-- I'll just ignore the question of why we need two references to the same object

Parameters:			

Return Value:		


Date		Who		Reason
17 Jul 2008	cnwer1	Initial creation PAR 16841 - 
17 Jul 2008	cnwer1	Par 16846
*/

vars
	newCurrentObject 	: CM_Object;
	invalidObject 		: Boolean;
	parent	: SOP_ViewModelObject;
	
begin

	on Exception do app.handleDeletedObject(exception,newCurrentObject,invalidObject);
	self.myCurrentVMObject:=_value;
	
	
	if self.myCurrentVMObject &lt;&gt; null and self.myCurrentVMObject.myObject &lt;&gt; null then
		parent:=self.myCurrentVMObject.myParent;
		newCurrentObject:=self.myCurrentVMObject.myObject;	
		if not newCurrentObject.isTransient then
			if not invalidObject then
				self.myCurrentObject:=self.myCurrentVMObject.myObject;
			endif;
		endif;
		
	else
		self.myCurrentObject:=null;
	endif;
epilog
	//epr par 16846 17/7/08 - object has been deleted
	if invalidObject then
		//remove and null everything
		self.allVMObjects.remove(self.myCurrentVMObject);
		delete self.myCurrentVMObject;
		self.myCurrentObject:=null;
		//refresh from parent tree
		self.showTree(self.currentGroupType, false);
		self.selectVMObject(parent, false);
		//show user msg
		app.msgBox(app.getErrorString2(Object_deleted_refreshing,"Code","Codes Group"),"Code Deleted",MsgBox_OK_Only);
	endif;
end;</source>
        <Parameter name="_value" type="SOP_ViewModelObject"/>
    </JadeMethod>
