30 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	harbourRegion : HMS_HarbourRegion;

begin

	harbourRegion := self.getHarbourRegion;
	if harbourRegion &lt;&gt; null then
		return harbourRegion.getHarbour;
	endif;
	
	return null;

epilog

end;</source>
