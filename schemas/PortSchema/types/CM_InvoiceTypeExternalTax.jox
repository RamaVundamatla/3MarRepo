    <JadeMethod name="getRangeStr" id="0bb46345-1da9-4272-91c1-ff8692798943">
        <source>getRangeStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37821

*/

vars

	retString : String;

begin

	retString := self.rangeStart.asStringJMT &amp; " - " &amp; self.rangeEnd.asStringJMT;
	return retString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isTaxExempt" id="93ed06c9-ead7-4704-ac1b-37d582eb903e">
        <source>isTaxExempt():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37821

*/

vars

begin

	return self.externalTaxRule = ExternalTaxRuleExempt;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValueWithinRange" id="aba3c7cb-986b-4893-a1d5-a01501c1d08e">
        <source>isValueWithinRange( _real : Real ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37821

*/

vars

begin

	if _real &gt;= self.rangeStart then
		if _real &lt;= self.rangeEnd then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_real" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
