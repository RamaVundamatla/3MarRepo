    <JadeMethod name="doHeadingsMain" id="fa58892c-bb2f-4d60-8e2c-3bfc41db0f75">
        <updating/>
        <source>doHeadingsMain() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 February 2009 by cnwdad1
//
// Purpose:		Sets up the table's main heading row, i.e. the first row.  The second
//				heading row is dynamic and will be handled by the EntTableDef stuff.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	index	: Integer;
	
begin
	self.rows	:=	2;
	self.setMainHeadings();
	//self.addItemAt(Tab &amp; Tab &amp;  "Total" &amp; Tab &amp; Tab &amp; "Used" &amp; Tab &amp; Tab &amp; "Q In" &amp; Tab &amp; Tab &amp; "Q Out" &amp; Tab &amp; Tab &amp; "Free" &amp; Tab &amp; Tab &amp; "Projected" &amp; Tab &amp; Tab &amp; "Plan In" &amp; Tab &amp; Tab &amp; "Plan Out" &amp; Tab &amp; Tab &amp; "Decking" &amp; Tab &amp; "Seq", 1);
	//self.setCellText(1, 1, Tab &amp; Tab &amp;  "Total" &amp; Tab &amp; Tab &amp; "Used" &amp; Tab &amp; Tab &amp; "Q In" &amp; Tab &amp; Tab &amp; "Q Out" &amp; Tab &amp; Tab &amp; "Free" &amp; Tab &amp; Tab &amp; "Projected" &amp; Tab &amp; Tab &amp; "Plan In" &amp; Tab &amp; Tab &amp; "Plan Out" &amp; Tab &amp; Tab &amp; "Decking" &amp; Tab &amp; "Seq");
//	self.accessCell(1,3).mergeCells		:=	Table.MergeCells_Merge;
//	self.accessCell(1,3).alignment		:=	Table.Alignment_Center_Middle;
//	self.accessCell(1,5).mergeCells		:=	Table.MergeCells_Merge;
//	self.accessCell(1,5).alignment		:=	Table.Alignment_Center_Middle;
//	self.accessCell(1,7).mergeCells		:=	Table.MergeCells_Merge;
//	self.accessCell(1,7).alignment		:=	Table.Alignment_Center_Middle;
//	self.accessCell(1,9).mergeCells		:=	Table.MergeCells_Merge;
//	self.accessCell(1,9).alignment		:=	Table.Alignment_Center_Middle;
//	self.accessCell(1,11).mergeCells	:=	Table.MergeCells_Merge;
//	self.accessCell(1,11).alignment		:=	Table.Alignment_Center_Middle;
//	self.accessCell(1,13).mergeCells	:=	Table.MergeCells_Merge;
//	self.accessCell(1,13).alignment		:=	Table.Alignment_Center_Middle;
//	self.accessCell(1,15).mergeCells	:=	Table.MergeCells_Merge;
//	self.accessCell(1,15).alignment		:=	Table.Alignment_Center_Middle;
//	self.accessCell(1,17).mergeCells	:=	Table.MergeCells_Merge;
//	self.accessCell(1,17).alignment		:=	Table.Alignment_Center_Middle;
//	self.accessCell(1,19).mergeCells	:=	Table.MergeCells_Merge;
//	self.accessCell(1,19).alignment		:=	Table.Alignment_Center_Middle;
	
	self.accessCell(1, self.getColumnByRowName(ETRow_Code)).text := "Location";
	self.accessCell(2, self.getColumnByRowName(ETRow_Code)).text := "   Range";
	self.accessRow(1).backColor	:=	self.backColor; //"0,128,255".asRGB;
	self.accessRow(2).backColor	:=	self.backColor; //"0,128,255".asRGB;
	self.accessColumn(1).width	:=	20;
	self.accessCell(2, 1).text	:=	null;
	
	self.fixedRows	:=	2;
	
	foreach index in self.FirstTotalColumn to self.columns do
		//self.accessColumn(index).width		:=	35;
		self.accessColumn(index).alignment	:=	Table.Alignment_Right_Middle;
	endforeach;
	
	self.fixedRows	:=	2;
	self.clearSort();
	self.alignment	:=	Table.Alignment_Left_Middle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawTableGrid" id="833d7f51-dd2b-4a64-992c-b8475210affa">
        <updating/>
        <source>drawTableGrid() updating;
// --------------------------------------------------------------------------------
// Created:		25 Janurary 2010 by cnwjo3
//
// Purpose:		draw vertical lines and between column areas
//
vars
	r, c: Integer;
	tmpRows,
	tmpCols		: Integer;
begin
	self.gridLines := true;

	tmpRows := self.rows;
	foreach r in 1 to tmpRows do
		self.accessRow(r).gridRight := false;
		self.accessRow(r).gridBottom := false;
	endforeach;

	// Grid AFter Heading and fixed columns
	self.accessColumn(self.fixedColumns).gridRight := true;
	self.accessColumn(self.columns).gridRight := true;
	self.accessRow(self.fixedRows).gridBottom := true;
	
	// Grid between Statistics Groups
	tmpCols := self.columns;
	foreach c in self.fixedColumns to tmpCols do
		if self.accessCell(1, c).text &lt;&gt; "" then
			self.accessColumn(c-1).gridRight := true;
			self.accessCell(1, c).gridRight := true;
		endif;
	endforeach;
epilog
	self.gridLines				:=	false; //epr if not set when there are updates from notes gridlines are drawn everywhere
end;</source>
    </JadeMethod>
    <JadeMethod name="expandAllRows" id="8aa53c8d-5e83-4af5-8d8a-1c4cfb581e26">
        <updating/>
        <source>expandAllRows(_expand: Boolean) updating, protected;
//15 August 2008	cnwdw1	
// Expand/Collapse all the rows
vars
	rowPointer	: Integer;
	
begin
	foreach rowPointer in self.fixedRows + 1 to self.rows do
		self.expandRow(rowPointer, _expand);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_expand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="expandRow" id="6f4cf711-c090-433c-bf9c-1304b1e9ef86">
        <updating/>
        <source>expandRow(_row: Integer; _isExpand: Boolean) updating, protected;
//18 August 2008	cnwdw1	
//
vars
	rowPointer	: Integer;
	isFound		: Boolean;
	
begin
	rowPointer	:=	_row;

	if rowPointer &gt; self.fixedRows then
		if self.accessRow(rowPointer).itemObject.isKindOf(CM_Terminal) then
			rowPointer	:=	rowPointer + 1;
			isFound		:=	false;
			
			while rowPointer &lt;= self.rows
			and (self.accessRow(rowPointer).itemObject.isKindOf(CM_TerminalArea)
			or self.accessRow(rowPointer).itemObject.isKindOf(CM_GridRow)
			or self.accessRow(rowPointer).itemObject.isKindOf(CM_GridColumn)	//28 Mar 2012	NDL	Par 29350
			or self.accessRow(rowPointer).itemObject.isKindOf(CM_RoRoController)) 
			do
				self.accessRow(rowPointer).visible	:=	_isExpand;
				rowPointer	:=	rowPointer + 1;
				isFound		:=	true;
			endwhile;
			
			if isFound then
				if _isExpand then
					self.setExpanded(_row, self.Collapse);
				else
					self.setExpanded(_row, self.Expand);
				endif;
			else
				self.setExpanded(_row, self.NoRows);
			endif;
			
		elseif self.accessRow(rowPointer).itemObject.isKindOf(CM_TerminalArea) then
			rowPointer	:=	rowPointer + 1;
			isFound		:=	false;
			
			while rowPointer &lt;= self.rows and 
					(self.accessRow(rowPointer).itemObject.isKindOf(CM_GridRow) or
					self.accessRow(rowPointer).itemObject.isKindOf(CM_GridColumn) or	//28 Mar 2012	NDL	Par 29350
					self.accessRow(rowPointer).itemObject.isKindOf(CM_RoRoController)) do
				self.accessRow(rowPointer).visible	:=	_isExpand;
				rowPointer	:=	rowPointer + 1;
				isFound		:=	true;
			endwhile;
			
			if isFound then
				if _isExpand then
					self.setExpanded(_row, self.Collapse);
				else
					self.setExpanded(_row, self.Expand);
				endif;
			else
				self.setExpanded(_row, self.NoRows);
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_isExpand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="expandTermArea" id="9fc57cb4-d085-473f-9b5a-335c2d765679">
        <updating/>
        <source>expandTermArea(_termAreaObj:CM_TerminalArea; _isExpand:Boolean) updating, protected;
//15 August 2008	cnwdw1	
//
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.cnEcFindObjectRowNo(_termAreaObj);

	//if self.findObjectInRow(_termAreaObj, rowPointer) then
	if self.cnEcIsValidRow(rowPointer) then
		self.expandRow(rowPointer, _isExpand);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_termAreaObj" type="CM_TerminalArea"/>
        <Parameter name="_isExpand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="expandTerminal" id="623dd603-84e0-4f3d-92cc-5ff0f4a2fcdf">
        <updating/>
        <source>expandTerminal(_terminalObj:CM_Terminal; _isExpand:Boolean) updating, protected;
//15 August 2008	cnwdw1	
//
vars
	rowPointer	: Integer;
	
begin
	if self.findObjectInRow(_terminalObj, rowPointer) then
		self.expandRow(rowPointer, _isExpand);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_isExpand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObject" id="1286df92-65a4-4725-8712-f6cbd3b4a0fa">
        <updating/>
        <source>getSelectedObject(): Object updating;
//27 August 2008	cnwdw1	
//
begin
	if self.row &gt; self.fixedRows then
		return self.accessRow(self.row).itemObject;
	endif;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getSubTitleWidth" id="7c56efac-8cde-4b10-ad2d-7b0888d7702e">
        <updating/>
        <source>getSubTitleWidth(_subTitles : StringArray) : Integer updating;
// --------------------------------------------------------------------------------
// Created:		1 February 2010 by cnwjo3
//
// Purpose:		When we first open screen we can rely on the title width for
//				calculating the subtitle widths.  When there is a resize we
//				need to check the subtitle widths tehmselves
//
vars
	i : Integer;
	subTitlesWidth : Integer;
	colPointer : Integer;
	foundCols : Integer;
begin
	subTitlesWidth := 0;
	foreach i in 1 to _subTitles.size() do
		colPointer := self.getColumnByRowName(_subTitles[i]);
		if colPointer &gt; 0 then
			foundCols := foundCols +1;
			subTitlesWidth := subTitlesWidth + self.accessColumn(colPointer).width;
		endif;
	endforeach;	
	
	if subTitlesWidth &gt; (35*foundCols) then
		return subTitlesWidth;
	else
		return (35*foundCols);
	endif;
end;</source>
        <Parameter name="_subTitles" type="StringArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTitleWidth" id="6ec4f3ef-8981-4824-a052-c0cef8f25d25">
        <source>getTitleWidth(_subTitles : StringArray; _titleName : String) : Integer;
// --------------------------------------------------------------------------------
// Created:		29 Janurary 2010 by cnwjo3
//
// Purpose:		Get title width to calculate individual columns widthes........
//
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	i, foundCols, colPointer : Integer;
	widthValue : Integer;
begin
	foreach i in 1 to _subTitles.size() do
		colPointer := self.getColumnByRowName(_subTitles[i]);
		if colPointer &gt; 0 then
			foundCols := foundCols +1;
		endif;
	endforeach;	

	if foundCols=0 then
		foundCols:=1;  //set as 1 if caulculating titles such as AllowOthers, Priority etc
	endif;	
	
	if form = null or not form.isKindOf(CM_BaseForm) then
		return 35*foundCols;
	endif;
	
	userWindow := form.CM_BaseForm.myUserWindow;
	
	if userWindow = null then
		userWindow := app.getUserWindow(form.name, false);
	endif;

	if userWindow = null then
		return 35*foundCols;
	endif;
	
	theXML := userWindow.xmlInfo;

	if _titleName = app.getErrorString(YAM_Stats_Total) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_LocnStats_totalWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_Used) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_LocnStats_usedWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_QueuedIn) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_LocnStats_qInWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_QueuedOut) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_LocnStats_qOutWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_Free) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_LocnStats_freeWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_Projected) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_LocnStats_projectedWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_PlanIn) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_LocnStats_planInWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_PlanOut) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_LocnStats_planOutWidth);
		widthValue := theXMLValue.Integer;
	endif;

	if widthValue &gt; (35*foundCols) then
		return widthValue;
	else
		return (35*foundCols);
	endif;
	
end;</source>
        <Parameter name="_subTitles" type="StringArray"/>
        <Parameter name="_titleName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalColumns" id="a2797abb-6bfc-42f3-bcf9-5d0b8fa86d94">
        <source>getTotalColumns(_totalColumns: IntegerArray io) protected;
// --------------------------------------------------------------------------------
// Created:		18 February 2009 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allSizes	: StringArray;
	sizePointer	: Integer;
	colPointer	: Integer;
	
begin
	create allSizes transient;
	allSizes.add(ETRow_Total20);
	allSizes.add(ETRow_Total30);
	allSizes.add(ETRow_Total40);
	allSizes.add(ETRow_Total45);
	allSizes.add(ETRow_Total53); 
	
	allSizes.add(ETRow_Used20);
	allSizes.add(ETRow_Used30);
	allSizes.add(ETRow_Used40);
	allSizes.add(ETRow_Used45);
	allSizes.add(ETRow_Used53); 
	
	allSizes.add(ETRow_QueuedIn20);
	allSizes.add(ETRow_QueuedIn30);
	allSizes.add(ETRow_QueuedIn40);
	allSizes.add(ETRow_QueuedIn45);
	allSizes.add(ETRow_QueuedIn53); 
	
	allSizes.add(ETRow_QueuedOut20);
	allSizes.add(ETRow_QueuedOut30);
	allSizes.add(ETRow_QueuedOut40);
	allSizes.add(ETRow_QueuedOut45);
	allSizes.add(ETRow_QueuedOut53); 
	
	allSizes.add(ETRow_Free20);
	allSizes.add(ETRow_Free30);
	allSizes.add(ETRow_Free40);
	allSizes.add(ETRow_Free45);
	allSizes.add(ETRow_Free53); 
	
	allSizes.add(ETRow_Projected20);
	allSizes.add(ETRow_Projected30);
	allSizes.add(ETRow_Projected40);
	allSizes.add(ETRow_Projected45);
	allSizes.add(ETRow_Projected53); 
	
	allSizes.add(ETRow_PlannedIn20);
	allSizes.add(ETRow_PlannedIn30);
	allSizes.add(ETRow_PlannedIn40);
	allSizes.add(ETRow_PlannedIn45);
	allSizes.add(ETRow_PlannedIn53); 
	
	allSizes.add(ETRow_PlannedOut20);
	allSizes.add(ETRow_PlannedOut30);
	allSizes.add(ETRow_PlannedOut40);
	allSizes.add(ETRow_PlannedOut45);
	allSizes.add(ETRow_PlannedOut53); 
	
	foreach sizePointer in 1 to allSizes.size() do
		colPointer	:=	self.getColumnByRowName(allSizes[sizePointer]);
		
		if colPointer &lt;&gt; 0 then
			_totalColumns.add(colPointer);
		endif;
	endforeach;
epilog
	delete allSizes;
end;</source>
        <access>protected</access>
        <Parameter name="_totalColumns" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="1c03a0ed-d6c0-4618-8686-d8c74940a767">
        <updating/>
        <source>initialise(_allTerminalAreas:CM_ObjectArray; fra : Frame; p1, p2, p3 : Picture input) updating;
//15 August 2008	cnwdw1	
//
begin
	self.clear();
	self.gridLines				:=	false;
	self.rows					:=	1;//self.fixedRows;
	self.partialTextIndication	:=	true;
	self.wordWrap 				:=	true;
	self.selectionType			:=	CM_BaseTable.SelectionType_Row;
	self.selectMode				:=	Table.SelectMode_CurrentRow;
	self.multiSelect			:=	CM_BaseTable.MultiSelect_Simple;
	self.disallowColumnSorter	:=	false;
	self.backColor				:=	self.myForm.CM_BaseForm.colorControlBack;
	self.allowResize			:=	Table.AllowResize_Column;

	// Do the Column Headings.
	if self.myEntTableDef = null then
		//replaced for par 20103 cnwjo3
		//self.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_YAMDataTbl));
		self.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_YAMLocDataTbl));
		self.doHeadingsMain();
	else
		self.setColumns(false);
		self.doHeadingsMain();
	endif;
	
	//self.hideColumnByColName(ETRow_DeckingSequence);
	//self.hideColumnByColName(ETRow_Stacking);
//	self.hideColumnByColName(ETRow_PriorityValue); adm 100609 Par 19870 
	self.hideColumnByColPropertyName(ETRow_PriorityValue);
	self.hideColumnByColPropertyName(ETRow_DeckingSequence);
	self.hideColumnByColPropertyName(ETRow_Stacking);

	
	
	self.populateData(_allTerminalAreas);
	
	self.registerNotes();
end;</source>
        <Parameter name="_allTerminalAreas" type="CM_ObjectArray"/>
        <Parameter name="fra" type="Frame"/>
        <Parameter name="p1" type="Picture" usage="input"/>
        <Parameter name="p2" type="Picture" usage="input"/>
        <Parameter name="p3" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isRowExpanded" id="5286c020-f90f-4a62-9586-badca09c5137">
        <source>isRowExpanded(): Boolean protected;
//15 August 2008	cnwdw1	
//
begin
	return (self.accessedCell.picture = app.myRoot.getConfig(PicYAMCollapse).Binary);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateData" id="6443e729-7cc2-4b3a-a50e-a43ca10efcdb">
        <updating/>
        <source>populateData(_allTerminalAreas:CM_ObjectArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 February 2009 by cnwdad1
//
// Purpose:		Populates the table with the Location Statistics data.
//
// Parameters:	_allTerminalAreas - A reference to an array of Terminal Areas.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// --------------------------------------------------------------------------------
vars
	elementObj		: Object;
	areaObj			: CM_TerminalArea;
	
begin
	self.rows	:=	self.fixedRows;
	
	// Make sure nothing changes while loading the Terminal Area collection.
	beginLoad;
	
	foreach elementObj in _allTerminalAreas do
		areaObj	:=	elementObj.CM_TerminalArea;
		

		//if areaObj.isGridArea() then
		//cnwjo3 21189
		if areaObj.isViewableInLocnStatsTable() then
			self.addItemTermAreaAt(areaObj, 0);
		endif;
	endforeach;
	
	endLoad;
	
	self.accessRow(1).backColor := self.myForm.CM_BaseForm.colorHeadingColumn;
	self.accessRow(2).backColor := self.myForm.CM_BaseForm.colorHeadingColumn;
	self.fixedColumns := 2;
	
	// cnwjk3 - SFW1030 open with items initially collapsed 
	self.expandAllRows(false);
	
	self.drawTableGrid();  //cnwjo3 21189
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <access>protected</access>
        <Parameter name="_allTerminalAreas" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="refreshMe" id="4454eb68-72eb-4459-b4a3-fa697c5e52af">
        <updating/>
        <source>refreshMe() updating;
// --------------------------------------------------------------------------------
// Created:		12 February 2009 by cnwdad1
//
// Purpose:		Refreshes the table's data and main column heading.
//
// Parameters:	_allTerminalAreas - A reference to an array of Terminal Areas.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allTerminalAreas	: Collection;
	
begin
	allTerminalAreas	:=	self.form.getAllObjects();

	self.rows	:=	1;
	//self.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_YAMDataTbl));	// Should only do this once when the table is first initialised.
	//self.setColumnsFromUserWindow();		// Don't do this here, otherwise user changes are over-written.
	self.setColumns(true);
	self.doHeadingsMain();
	self.populateData(allTerminalAreas.CM_ObjectArray);
end;</source>
    </JadeMethod>
    <JadeMethod name="registerNotes" id="5cd89b27-b744-4e86-a536-5c979b85b155">
        <source>registerNotes() protected;
// --------------------------------------------------------------------------------
// Created:		13 November 2008 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj : CM_Terminal;
	
begin
	terminalObj	:=	self.getTerminal();
	
	self.beginNotification(terminalObj, terminalObj.getTerminalEvent(EVENT_LOCATION_STATS_CHANGE), Response_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeItemTermAreaAt" id="9be149ee-cd86-4441-9c4e-8cc24aa0be71">
        <updating/>
        <source>removeItemTermAreaAt(_termAreaObj:CM_TerminalArea; _row:Integer): Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 November 2008 by cnwdad1
//
// Purpose:		Remove the row of the specified Terminal Area from the receiver.
//				All child rows (i.e. Grid Rows) will also be removed.
//
// Parameters:	_termAreaObj - A reference to the Terminal Area to remove.
//				_row - The row from which to remove the Terminal Area.
//
// Returns:		The index of the row that was removed.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	removeRow	: Integer;
	rowPointer	: Integer;
	rowObj		: JadeTableRow;
	
begin
	removeRow	:=	_row;
	
	if removeRow &lt;= self.fixedRows then
		self.findObjectInRow(_termAreaObj, removeRow);
	endif;
	
	if removeRow &gt; self.fixedRows then
		//self.removeItemObjWithIndex(CM_TerminalArea, removeRow);
		rowPointer	:= removeRow + 1;
		
		while rowPointer &lt;= self.rows do
			rowObj	:=	self.accessRow(rowPointer);
			
			if rowObj.itemObject.isKindOf(CM_GridRow) then
				self.removeItem(rowPointer);
			else
				break;
			endif;
		endwhile;
		
		self.removeItem(removeRow);
	endif;
	
	return removeRow;	
end;</source>
        <access>protected</access>
        <Parameter name="_termAreaObj" type="CM_TerminalArea"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resizeColumn" id="9f874748-2562-4aac-b22e-c3b17d311a94">
        <controlMethod name="Table::resizeColumn"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>resizeColumn(table: Table input; column: Integer input; previousWidth: Integer input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		1 February 2010 by cnwjo3
//
// Purpose:		resize columsn so they look good.
//
vars
	allSizes	: StringArray;
begin
	create allSizes transient;
	allSizes.add(ETRow_Total20);
	allSizes.add(ETRow_Total30);
	allSizes.add(ETRow_Total40);
	allSizes.add(ETRow_Total45);
	allSizes.add(ETRow_Total53);
	allSizes.add(ETRow_ColTotalTotal);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Total),allSizes, self.getSubTitleWidth(allSizes));
		
	allSizes.clear();
	allSizes.add(ETRow_Used20);
	allSizes.add(ETRow_Used30);
	allSizes.add(ETRow_Used40);
	allSizes.add(ETRow_Used45);
	allSizes.add(ETRow_Used53); 
	allSizes.add(ETRow_ColTotalUsed);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Used),allSizes, self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_QueuedIn20);
	allSizes.add(ETRow_QueuedIn30);
	allSizes.add(ETRow_QueuedIn40);
	allSizes.add(ETRow_QueuedIn45);
	allSizes.add(ETRow_QueuedIn53);
	allSizes.add(ETRow_ColTotalQIn);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_QueuedIn), allSizes,self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_QueuedOut20);
	allSizes.add(ETRow_QueuedOut30);
	allSizes.add(ETRow_QueuedOut40);
	allSizes.add(ETRow_QueuedOut45);
	allSizes.add(ETRow_QueuedOut53); 
	allSizes.add(ETRow_ColTotalQOut);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_QueuedOut),allSizes, self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_Free20);
	allSizes.add(ETRow_Free30);
	allSizes.add(ETRow_Free40);
	allSizes.add(ETRow_Free45);
	allSizes.add(ETRow_Free53); 
	allSizes.add(ETRow_ColTotalFree);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Free), allSizes,self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_Projected20);
	allSizes.add(ETRow_Projected30);
	allSizes.add(ETRow_Projected40);
	allSizes.add(ETRow_Projected45);
	allSizes.add(ETRow_Projected53);
	allSizes.add(ETRow_ColTotalProjected);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Projected), allSizes,self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_PlannedIn20);
	allSizes.add(ETRow_PlannedIn30);
	allSizes.add(ETRow_PlannedIn40);
	allSizes.add(ETRow_PlannedIn45);
	allSizes.add(ETRow_PlannedIn53);
	allSizes.add(ETRow_ColTotalPlanIn);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_PlanIn), allSizes,self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_PlannedOut20);
	allSizes.add(ETRow_PlannedOut30);
	allSizes.add(ETRow_PlannedOut40);
	allSizes.add(ETRow_PlannedOut45);
	allSizes.add(ETRow_PlannedOut53);
	allSizes.add(ETRow_ColTotalPlanOut);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_PlanOut), allSizes,self.getSubTitleWidth(allSizes));
	
	if table.accessColumn(column).width &lt; 35 then
		table.accessColumn(column).width := 35;
	endif;
epilog
	delete allSizes;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="column" type="Integer" usage="input"/>
        <Parameter name="previousWidth" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setExpanded" id="7f75d9aa-2824-4ad1-ae49-0ddd920acfe1">
        <updating/>
        <source>setExpanded(row: Integer; _value: Integer) updating, protected;
//22 August 2008	cnwdw1	
// 
vars
	colPointer	: Integer;
	
begin
	colPointer	:=	self.getColumnByRowName(ETRow_HideShow);
	
	if _value = self.Expand then
		self.accessCell(row, colPointer).picture := app.myRoot.getConfig(PicYAMExpand).Binary;
	elseif _value = self.Collapse then
		self.accessCell(row, colPointer).picture := app.myRoot.getConfig(PicYAMCollapse).Binary;
	elseif _value = self.NoRows then
		self.accessCell(row, colPointer).picture := null;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="row" type="Integer"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMainHeadings" id="2e1214cc-09b9-43c0-9fd0-e44da9338225">
        <updating/>
        <source>setMainHeadings() updating, protected;
// --------------------------------------------------------------------------------
// Created:		18 February 2009 by cnwdad1:2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colPointer	: Integer;
	allSizes	: StringArray;
begin
	self.addItemAt(null, 1);

	create allSizes transient;
	allSizes.add(ETRow_Total20);
	allSizes.add(ETRow_Total30);
	allSizes.add(ETRow_Total40);
	allSizes.add(ETRow_Total45);
	allSizes.add(ETRow_Total53);
	allSizes.add(ETRow_ColTotalTotal);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Total), allSizes,self.getTitleWidth(allSizes,app.getErrorString(YAM_Stats_Total)));
		
	allSizes.clear();
	allSizes.add(ETRow_Used20);
	allSizes.add(ETRow_Used30);
	allSizes.add(ETRow_Used40);
	allSizes.add(ETRow_Used45);
	allSizes.add(ETRow_Used53); 
	allSizes.add(ETRow_ColTotalUsed);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Used), allSizes,self.getTitleWidth(allSizes,app.getErrorString(YAM_Stats_Used)));

	allSizes.clear();
	allSizes.add(ETRow_QueuedIn20);
	allSizes.add(ETRow_QueuedIn30);
	allSizes.add(ETRow_QueuedIn40);
	allSizes.add(ETRow_QueuedIn45);
	allSizes.add(ETRow_QueuedIn53);
	allSizes.add(ETRow_ColTotalQIn);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_QueuedIn), allSizes,self.getTitleWidth(allSizes,app.getErrorString(YAM_Stats_QueuedIn)));

	allSizes.clear();
	allSizes.add(ETRow_QueuedOut20);
	allSizes.add(ETRow_QueuedOut30);
	allSizes.add(ETRow_QueuedOut40);
	allSizes.add(ETRow_QueuedOut45);
	allSizes.add(ETRow_QueuedOut53); 
	allSizes.add(ETRow_ColTotalQOut);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_QueuedOut), allSizes,self.getTitleWidth(allSizes,app.getErrorString(YAM_Stats_QueuedOut)));

	allSizes.clear();
	allSizes.add(ETRow_Free20);
	allSizes.add(ETRow_Free30);
	allSizes.add(ETRow_Free40);
	allSizes.add(ETRow_Free45);
	allSizes.add(ETRow_Free53); 
	allSizes.add(ETRow_ColTotalFree);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Free), allSizes,self.getTitleWidth(allSizes,app.getErrorString(YAM_Stats_Free)));

	allSizes.clear();
	allSizes.add(ETRow_Projected20);
	allSizes.add(ETRow_Projected30);
	allSizes.add(ETRow_Projected40);
	allSizes.add(ETRow_Projected45);
	allSizes.add(ETRow_Projected53);
	allSizes.add(ETRow_ColTotalProjected);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Projected), allSizes,self.getTitleWidth(allSizes,app.getErrorString(YAM_Stats_Projected)));

	allSizes.clear();
	allSizes.add(ETRow_PlannedIn20);
	allSizes.add(ETRow_PlannedIn30);
	allSizes.add(ETRow_PlannedIn40);
	allSizes.add(ETRow_PlannedIn45);
	allSizes.add(ETRow_PlannedIn53);
	allSizes.add(ETRow_ColTotalPlanIn);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_PlanIn), allSizes,self.getTitleWidth(allSizes,app.getErrorString(YAM_Stats_PlanIn)));

	allSizes.clear();
	allSizes.add(ETRow_PlannedOut20);
	allSizes.add(ETRow_PlannedOut30);
	allSizes.add(ETRow_PlannedOut40);
	allSizes.add(ETRow_PlannedOut45);
	allSizes.add(ETRow_PlannedOut53);
	allSizes.add(ETRow_ColTotalPlanOut);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_PlanOut), allSizes,self.getTitleWidth(allSizes,app.getErrorString(YAM_Stats_PlanOut)));

	// Merge all headings
	foreach colPointer in 3 to self.columns do
		if self.accessCell(1, colPointer).text &lt;&gt; "" then
			self.accessCell(1, colPointer).mergeCells	:=	Table.MergeCells_Merge;
			self.accessCell(1, colPointer).alignment	:=	Table.Alignment_Center_Middle;
		endif;
	endforeach;
	
	self.accessCell(1, self.getColumnByRowName(ETRow_Code)).text	:=	"Range";
	self.accessCell(2, self.getColumnByRowName(ETRow_Code)).text	:=	self.accessCell(2, self.getColumnByRowName(ETRow_Code)).text;
	self.accessRow(1).backColor	:=	self.backColor; 
	self.accessRow(2).backColor	:=	self.backColor; 
	self.accessColumn(1).width	:=	20;
	self.accessCell(2, 1).text	:=	null;

	colPointer := self.getColumnByRowName(ETRow_Stacking);
	
	if colPointer &gt; 0 then
		self.accessCell(1, colPointer).text			:=	self.accessCell(2, colPointer).text;
		self.accessCell(1, colPointer).alignment	:=	Table.Alignment_Center_Middle;
		self.accessCell(2, colPointer).text			:=	null;
		self.accessColumn(colPointer).width			:=	60;
	endif;
	
epilog
	delete allSizes;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showDecking" id="a1688090-f1fb-4f05-8517-af393ebc4ca0">
        <updating/>
        <source>showDecking(_yaBlock : CM_YABlock; _row: Integer) updating;
//05/02/2009	cnwwc2	
//
vars
	colPointer	: Integer;
	allTokens	: StringArray;
	cellObj		: JadeTableCell;
	optIn		: Integer;
	optFilling	: Integer;
	optOut		: Integer;
	
begin
	colPointer	:=	self.getColumnByRowName(ETRow_Stacking);
	
	if colPointer = null then
		return; //no stacking column for this screen
	endif;

	create allTokens transient;
	cellObj	:=	self.accessCell(_row, column);
	
	if _yaBlock = null or not _yaBlock.myTerminalArea.isDeckable() then
		cellObj.text	:=	null;
		cellObj.picture	:=	null;
		return;
	endif;
	
	cellObj.text.asStringArrayByDelimiter(allTokens, "/");
	
	if allTokens.size &lt;&gt; 3 then
		return;
	endif;
	
	optIn		 := allTokens[1].Integer;
	optFilling	 := allTokens[2].Integer;
	optOut 		 := allTokens[3].Integer;
 
	if optFilling = DeckingRule_Custom then
		pic1.picture := null;
		pic2.picture := app.myRoot.getConfig(PicYAMDeckCustom).Binary;
		pic3.picture := null;
	else
		if optIn = DeckingRule_Increasing then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckIcrs).Binary;
		elseif optIn = DeckingRule_Decreasing then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckDcrs).Binary;
		elseif optIn = DeckingRule_MiddleOut then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckMO).Binary;
		elseif optIn = DeckingRule_Pyramid then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckPrmd).Binary;
		elseif optIn = DeckingRule_Random then
			pic1.picture := app.myRoot.getConfig(PicYAMDeckRandom).Binary;
		endif;
		
		if optFilling = DeckingRule_Columnwise then
			pic2.picture := app.myRoot.getConfig(PicYAMDeckColW).Binary;
		elseif optFilling = DeckingRule_Tierwise then
			pic2.picture := app.myRoot.getConfig(PicYAMDeckTW).Binary;
		elseif optFilling = DeckingRule_Topup then
			pic2.picture := app.myRoot.getConfig(PicYAMDeckTopup).Binary;
		elseif optFilling = DeckingRule_SideToSide then
			pic2.picture := app.myRoot.getConfig(PicYAMDeckSDS).Binary;
		endif;	
		
		if optOut = DeckingRule_Increasing then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckIcrs).Binary;
		elseif optOut = DeckingRule_Decreasing then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckDcrs).Binary;
		elseif optOut = DeckingRule_MiddleOut then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckMO).Binary;
		elseif optOut = DeckingRule_Pyramid then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckPrmd).Binary;
		elseif optOut = DeckingRule_Random then
			pic3.picture := app.myRoot.getConfig(PicYAMDeckRandom).Binary;
		endif;	
	endif;
	
	cellObj.picture		:=	self.framePics.createPicture(true, true, 32);
	cellObj.text		:=	null;
	cellObj.alignment	:= 	Table.Alignment_Center;
epilog
	delete allTokens;
end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateStats" id="247aaf2a-3e22-48fc-8d21-4312922c1045">
        <updating/>
        <source>updateStats(_stats: CM_LocationStatistics) updating, protected;
//21 August 2008	cnwdw1	
//
vars
	rowPointer	: Integer;
	termAreaObj	: CM_TerminalArea;
	
begin
	if _stats.myParent.isKindOf(CM_TerminalArea) then
		termAreaObj	:=	_stats.myParent.CM_TerminalArea;
	elseif _stats.myParent.isKindOf(CM_YABlock) then
		// Need to check if should return here as this table only shows terminal areas
		termAreaObj	:=	_stats.myParent.CM_YABlock.myTerminalArea;
	endif;

	if termAreaObj &lt;&gt; null then
		rowPointer	:=	self.removeItemTermAreaAt(termAreaObj, 0);
		
		if rowPointer &gt; 0 then
			self.addItemTermAreaAt(termAreaObj, rowPointer);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_stats" type="CM_LocationStatistics"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="b9a4cd60-6f88-47bc-b7df-cc61c75658e7">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, clientExecution;
//21 August 2008	cnwdw1	
//
vars
	localEvent		: Integer;
    invalidObject	: Boolean;
	
begin
	if userInfo &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, userInfo.Object, invalidObject);
	endif;

	localEvent	:=	self.getTerminal.getEventFromTerminalEvent(eventType);
	
	if localEvent = EVENT_LOCATION_STATS_CHANGE and userInfo &lt;&gt; null then
		self.updateStats(userInfo.CM_LocationStatistics);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
