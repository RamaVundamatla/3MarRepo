    <JadeMethod name="doLoadLoggingOperations" id="930c51e9-d7ff-4ec1-aae2-5568c7ab2162">
        <source>doLoadLoggingOperations(_cmb : CMUI_ComboBox input; _op : CM_Operator; _loggingOperationCode : String);
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpCodeGroup	: CM_CodesByCodeDict;
begin

	if _op = null then
		return;
	endif;
	
	tmpCodeGroup := _op.getAllLoggingContractors;

	if tmpCodeGroup = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.listCollectionWithAny(tmpCodeGroup, ETRow_Code);
	
	if _loggingOperationCode &lt;&gt; null then
		_cmb.text := _loggingOperationCode;
	else
		_cmb.text := Any_String;
	endif;
	
	self.setValueByName(ETRow_LoggingOperation, _cmb.text);
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_op" type="CM_Operator"/>
        <Parameter name="_loggingOperationCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadLoggingOperations2" id="f7b92bcb-5819-4ced-a835-392c5ed23bdf">
        <source>doLoadLoggingOperations2(_combobox : CMUI_ComboBox input; _loggingOperationCode : String);
// ---------------------------------------------------------------------------
// Created:     04 October 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	str	: String;
begin
	str := _combobox.text;
	_combobox.clear;
	_combobox.addItem('CF' &amp; Tab &amp; Tab &amp; 'Clear Fell');
	_combobox.addItem('RL' &amp; Tab &amp; Tab &amp; 'Road Line');
	_combobox.addItem('RLTHIN' &amp; Tab &amp; 'Road Line Thinning');
	_combobox.addItem('THIN' &amp; Tab &amp; Tab &amp; 'Thinning');
	_combobox.addItem('WT' &amp; Tab &amp; Tab &amp; 'Wind Throw');
	_combobox.text := str;

	if _loggingOperationCode &lt;&gt; null then
		_combobox.listIndex := _combobox.findString(1,_loggingOperationCode);
		self.setValueByName(ETRow_LoggingOperation, _combobox.text);
	endif;
end;</source>
        <Parameter name="_combobox" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_loggingOperationCode" type="String"/>
