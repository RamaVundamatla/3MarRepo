    <JadeMethod name="addToolbarControls" id="0600cd6d-be02-40e6-85bc-11627079843f">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Date		Who		Reason
22 March 2017	cnwer1	Initial creation TFS

*/

vars
	frm			: CMUI_Toolbar;
begin
	frm := self.frmToolbar;
	frm.addFrame(self.frmQueryVoyage,CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnTBNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBEdit, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBLoadToOps, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnTBMoveUp, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBMoveDown, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnTBRefresh, CMUI_Toolbar.Control_Alignment_Left);
	frm.positionToolbarControls();
	frm.visible := true;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
