    <JadeMethod name="myTerminal" id="6412519c-178f-49c7-ae8e-965df71bc04b">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
// ---------------------------------------------------------------------------
// Created:     20 July 2001 by cnwrs2
//
// Purpose:     This should be overridden at the lower level
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	termArea : CM_TerminalArea;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := null;

	// PAR 11131 belts and braces, protect the reference	
	termArea := self.myTerminalArea; //&lt;&lt; -- mapping method
	
	if termArea &lt;&gt; null then
		_value := termArea.myTerminal;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myTerminalArea" id="3726dd5c-2552-484a-952f-a8dc86324eb2">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myTerminalArea(set: Boolean; _value: CM_TerminalArea io) mapping,updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 May 2008	cnwkpd1		PAR #16791 - discovered exclusiveLock in here when
//							researching this PAR, so removed it
// ---------------------------------------------------------------------------

vars

begin

	if (not set) then
		if self.myTerminalArea = null and
		   self.myTerminalAreaWhenArchived &lt;&gt; null then
			_value := self.myTerminalAreaWhenArchived;
		else
			// Jade will return value of attribute
		endif;
		return;
	endif;

//	exclusiveLock(self);		// removed PAR #16791
	
	if self.myTerminalArea &lt;&gt; _value then 
		self.myTerminalArea := _value;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_TerminalArea" usage="io"/>
    </JadeMethod>
