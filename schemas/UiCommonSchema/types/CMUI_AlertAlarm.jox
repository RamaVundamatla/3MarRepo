    <JadeMethod name="tblData_contextMenu" id="0bb493ec-d570-4d7a-92ee-600254ed6bce">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	xLeft,yTop : Real;
	obj : CM_Object;
begin
	xLeft := x;
	yTop := y;
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop); 
	
	obj := table.accessRow(table.row).itemObject.CM_Object;
	self.mnuReviewed.visible:=true;
	self.mnuReviewed.userObject:=obj;
	self.mnuAllReviewed.visible:=true;
	self.mnuInspectObject.visible := app.isAllowedToInspect;
	self.mnuInspectObject.userObject:=obj;
	
	self.popupMenu(mnuTableContext, xLeft.Integer, yTop.Integer);
	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="a6b3bb48-0577-4c38-ab78-3e0f99fe1118">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	obj : CM_Object;
	
begin
	if not table.cnEcIsValidRow(table.row) then
		return;
	endif;
	
	obj := table.accessRow(table.row).itemObject.CM_Object;
	
	if obj &lt;&gt; null then
		if app.isAllowedToInspect then
			obj.inspect;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="d7aa04bb-ba8d-48c9-a817-b97b1cac6a08">
        <updating/>
        <source>unloadForm(): Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	realUserWindow : CM_UserWindowForOpen;
begin
	
	// save user window settings
	realUserWindow := app.getUserWindow(self.name, true);	
	app.myTrxUA.trxUpdateUserWindow(app.getMyUser,realUserWindow,app.myPassport);
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateAlert" id="5f2c1730-54dc-488a-8573-ee2eafbee1ab">
        <updating/>
        <source>updateAlert(newObject : Object input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 August 2006	cnwer1	Initial creation - PAR#xxxx
02 Jun 2025		navbs1	Bug MTN-34992 : HAT - Error 14051 on Alert Alarm Form
*/
vars
	alert : CM_SystemAlert;
	rowNo,
	cellHeight,
	row,
	totalRows	: Integer;
	tblRow		: JadeTableRow;
	tmpStr		: String;
	newAlert,isValid : Boolean;
begin
	if newObject = null or not newObject.isKindOf(CM_SystemAlert) then
		return;
	endif;
	alert:=newObject.CM_SystemAlert;
	foreach row in 1 to tblData.rows do
		tblRow:=tblData.accessRow(row);
		if tblRow &lt;&gt; null and tblRow.itemObject = newObject then
			rowNo:=row;
			break;
		endif;
	endforeach;
	newAlert:=rowNo = 0;
	isValid:=global.isValidObject(alert);
	if  rowNo = null then
		totalRows := self.tblData.rows;								//02.06.2025 navbs1 #34992
		//epr par 14610 3/8/07
		if not isValid or totalRows &gt;= JadeTableRowLimit then		//02.06.2025 navbs1 #34992
			return;
		endif;
		tmpStr:=alert.details;
		rowNo := tblData.addItem(tmpStr);	
		tblRow := tblData.accessRow(rowNo);
		tblRow.itemObject:=alert;
		tblRow.foreColor := Red;
	else
		//this alert could of been deleted so have to test for it 
		if not isValid or alert.reviewed then
			tblData.removeItem(rowNo);
		endif;
	endif;
	
epilog
	if tblData.rows = null then
		self.unloadForm;
	endif;

	if frmAlert.visible then
		frmAlert.play(0);
		self.frmAlert.setFocus;
		self.frmAlert.refreshNow;
		//app.alert(Snd_Asterisk);
	endif;
end;</source>
        <Parameter name="newObject" type="Object" usage="input"/>
    </JadeMethod>
</GUIClass>
