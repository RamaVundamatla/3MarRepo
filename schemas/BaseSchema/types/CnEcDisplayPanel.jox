end;</source>
        <ReturnType type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="getRowObject" id="98e74159-6bcc-4318-9972-0d9ee74c74ba">
        <source>getRowObject():Object;
// --------------------------------------------------------------------------------
// Created:		13 January 2000 by cnwdad1
//
// Purpose:		Return the object that corresponds to the currently selected row.
//
// Parameters:	None
//
// Returns:		The row object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myDataTable.row &gt; 1 and self.myDataTable.row &lt;= self.myDataTable.rows then
		return self.myDataTable.getRowObject();
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initializeDataTable" id="a93b154c-96ae-4fb1-a231-851a56499fcf">
        <updating/>
        <source>initializeDataTable() protected, updating;
// --------------------------------------------------------------------------------
// Created:		13 August 1999 by cnwdad1
//
// Purpose:		Initial setup for the data table control.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	table	: CnEcDataTable;

begin
	table	:=	self.myDataTable;

	if (table = null) then
		create table transient;
	endif;

	table.parent			:=	self;
	table.show3D			:=	Control.Show3D_Use3D;
	table.rows				:=	1;
	table.fixed3D			:=	false;
	table.displayHotKey		:=	false;
	table.fixedRows			:=	1;
	table.gridLines			:=	true;
	table.readOnly			:=	false;
	table.scrollBars		:=	Window.ScrollBars_Both;
	table.tabStop			:=	false;
	form.addControl(table);
epilog
	self.myDataTable	:=	table;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeDisplayTable" id="3a84bf91-db26-4d4e-ab88-e43363c36bfa">
        <updating/>
        <source>initializeDisplayTable() protected, updating;
// --------------------------------------------------------------------------------
// Created:		13 August 1999 by cnwdad1
//
// Purpose:		Initial setup for the display table control.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	table	: CnEcDisplayTable;

begin
	table	:=	self.myDisplayTable;

	if (table = null) then
		create table transient;
	endif;

	table.parent			:=	self;
	table.show3D			:=	Control.Show3D_Use3D;
	table.columns			:=	2;
	table.rows				:=	0;
	table.fixed3D			:=	false;
	table.displayHotKey		:=	false;
	table.fixedRows			:=	0;
	table.gridLines			:=	false;
	table.readOnly			:=	true;
	table.scrollBars		:=	Window.ScrollBars_Both;
	table.tabStop			:=	false;
	table.backColor			:=	Cn_LightGray;	//SYSTEM_COLOUR + Color_3DFace;
	table.foreColor			:=	Black;
	form.addControl(table);
epilog
	self.myDisplayTable	:=	table;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeVerticalSplitter" id="6090d590-388b-4c29-b7af-5aa3724adbb5">
        <updating/>
