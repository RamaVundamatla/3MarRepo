    <JadeMethod name="utlUpdateCompletedWorkOrder" id="9ca06ce8-a9b5-4a69-83f6-e509f94d784e">
        <source>utlUpdateCompletedWorkOrder(	_pxyWorkOrder : CM_WorkOrder input;
								_passport    : CM_Passport input) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor

*/

vars
	realWorkOrder 			: CM_WorkOrder;
	expectedEdition 		: Integer;
	itemAudit				: CM_UpdateTransactionAuditAgent;
begin
	self.initialiseActivity();

	_pxyWorkOrder.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyWorkOrder.pxyGetRealObjectAndEdition(realWorkOrder, expectedEdition);
	
	if realWorkOrder = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrder.name, null, null);
		return;
	endif;

	app.myValUA.valWorkOrder(_pxyWorkOrder);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	create itemAudit transient;
	
	if _passport.noErrors then
		itemAudit.audUpdateGeneric(realWorkOrder, true);
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realWorkOrder);
	
	if _passport.noErrors and realWorkOrder.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Work Order', null, null);
		return;
	endif;

	realWorkOrder.setForUpdateCompleted(_pxyWorkOrder);
	
	if _passport.noErrors then
		itemAudit.audUpdateGeneric(realWorkOrder, false);
	endif;
	
epilog
	delete itemAudit;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateConfig" id="8256d660-9bd9-442d-ac52-8c027f3b750e">
        <source>utlUpdateConfig(_cmifConfig : CMIF_Config input; _realObject : CM_Object input; _expectedEdition : Integer;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/12/2009	cnwmh5		PAR21655 - Add validation for config objects
// 23/11/2011	cnwdap1		PAR #28733 CCMS SFW 1261 Add auditing for Terminal config changes
// ---------------------------------------------------------------------------
vars
		
begin

	self.initialiseActivity();
	
	// 02/12/2009 cnwmh5 #21655 - Start
	//epr CCMS 1280 15/8/12 - noticed 2 different config validation - moved cmifConfig.validateConfig into valTerminalConfig
	// now valTerminalConfig called
	// only validaton for terminal
	if _realObject.isKindOf(CM_Terminal) then
		app.myValUA.valTerminalConfig(_realObject.CM_Terminal,_cmifConfig.CMIF_ConfigTerminal);
	elseif _realObject.isKindOf(CM_Root) then	//54854, AjitM, navam1
		app.myValUA.valRootConfig(_realObject.CM_Root, _cmifConfig.CMIF_ConfigRoot);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	// 02/12/2009 cnwmh5 #21655 - End
	
	exclusiveLock(_realObject);
	if _passport.noErrors and _realObject.edition &lt;&gt; _expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'System Config', null, null);
		return;
	endif;
	
	// PAR #28733 audit terminal changes
	if _passport.noErrors and CM_Terminal.hasInstance(_realObject) then
		self.myUpdateAuditAgent.audUpdateGeneric(_realObject, true);
	endif;
	// PAR #28733 end
	
	_cmifConfig.updatePersistentObject(_realObject, _passport);
	
	if _passport.noErrors then
		self.updateObjectEdition (_realObject);	// par 30292
	endif;
	
	// PAR #28733 audit terminal changes
	if _passport.noErrors and CM_Terminal.hasInstance(_realObject) then
		self.myUpdateAuditAgent.audUpdateGeneric(_realObject, false);
	endif;


end;</source>
        <Parameter name="_cmifConfig" type="CMIF_Config" usage="input"/>
        <Parameter name="_realObject" type="CM_Object" usage="input"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateConfigAllStateData" id="c3fbc197-90b9-4f63-b2a6-dddaf23c8fac">
        <updating/>
        <source>utlUpdateConfigAllStateData(	_allProxyStateData : CM_StateDataDict;
								_passport : CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2011	cnwer1	Initial creation

*/

vars
	proxyStateData , 
	realStateData: CM_StateData;
	parent 	: CM_Object;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_allProxyStateData, "All State Data");
	
	
	foreach proxyStateData in _allProxyStateData discreteLock do
		realStateData:=proxyStateData.pxyGetRealObject.CM_StateData;
	
		if realStateData = null then
			if proxyStateData.getValue = null then	
				continue;
			endif;
			
			create realStateData as proxyStateData.class;
			
		endif;
	
		if proxyStateData.myParent = app.myRoot then
			parent:=app.myRoot.getStateObject(ConfigGrp_System);
		else
			parent:=proxyStateData.myParent;
		endif;
		
		realStateData.set(proxyStateData.key,proxyStateData.getValue,parent);
		
		
		
		if _passport.hasErrors then
			return;
		endif;		
	endforeach;
epilog

end;</source>
        <Parameter name="_allProxyStateData" type="CM_StateDataDict"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateConfigTA" id="21dba6db-0c67-43ef-993f-562222a8567a">
        <source>utlUpdateConfigTA(_theRealTA : CM_TerminalArea input; _theProxyTest : CM_AutoPlanTests; 
				_theInterface : CMIF_ConfigTerminalArea input;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------
vars
		
begin
	self.initialiseActivity();

	exclusiveLock(_theRealTA);
	
	_theInterface.updatePersistentObject(_theRealTA, _passport);
	_theRealTA.autoPlanTest.setForUpdate(_theProxyTest);
	
	if _passport.noErrors then
		self.updateObjectEdition (_theRealTA);	// par 30292
	endif;
	
end;</source>
        <Parameter name="_theRealTA" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_theProxyTest" type="CM_AutoPlanTests"/>
        <Parameter name="_theInterface" type="CMIF_ConfigTerminalArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateConnect" id="0eb94531-080c-4d3b-9fe6-fb16526bc5f3">
        <updating/>
        <source>utlUpdateConnect(_theConnectParams : CMIF_ConnectParams io; _pxyTI: CM_TrackedItem; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		The proxy TI is stored in the connect Parameters
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/05/2021	navdap1		TFS 51279 POL NReefer App - Update reefer connect to 'Yes' changes Externally Monitored to 'No'
// 17/11/2021	navpw1		TFS 52375 POL - Can't set Is Externally Monitored via Reefer Monitoring tab in MTN
// ---------------------------------------------------------------------------
vars
	realTrackedItem,aProxyTI :CM_TrackedItem;

begin

	self.initialiseActivity();
	
	if _pxyTI = null then
		aProxyTI := _theConnectParams.myTrackedItem;
	else
		aProxyTI := _pxyTI;
	endif;
	self.raiseExceptionIfNull(aProxyTI, 'Connect TI Proxy');	
	//epr par 36103 23/4/15
	if aProxyTI.isTransient then
		aProxyTI.raiseExceptionIfNotProxy(method);
		app.setContinueCMExceptions(true);
		realTrackedItem:=aProxyTI.pxyGetRealObject();
	else
		realTrackedItem:=aProxyTI;
	endif;
	
	if realTrackedItem = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;

	app.myValUA.valConnect(realTrackedItem, _theConnectParams);

	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realTrackedItem);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackedItem, true);
	endif;
	
	if _passport.noErrors then
		_theConnectParams.myTrackedItem := realTrackedItem;
		_theConnectParams.myOtherTrackedItem := realTrackedItem.getOtherTrackedItem(_theConnectParams.action);
		_theConnectParams.locationsController := realTrackedItem.getPrimaryLocation(REAL_MODE);
		
		if _theConnectParams.editMode &lt;&gt; CM_ReeferMtn then // ### TFS 52375 17Nov2021 NAVPW1
			_theConnectParams.hasExternalMonitoring := realTrackedItem.getExternalMonitoring;	// TFS 51279
		endif;
		
		realTrackedItem.setForConnect(_theConnectParams, _passport);
		// redraw the TI Graphics on screen
		if _passport.noErrors then
			realTrackedItem.eraseReeferSystemAlert();
			realTrackedItem.eraseDefrostReeferSystemAlert();
			//notify reeferMonitoring
			realTrackedItem.causeEvent(_theConnectParams.myTerminal.getTerminalEvent(TIEvent_Connect), false, realTrackedItem);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackedItem, false);
	endif;

end;</source>
        <Parameter name="_theConnectParams" type="CMIF_ConnectParams" usage="io"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateConsignGroup" id="5f3ee00a-e7d5-461b-9d17-6f34462062a7">
        <source>utlUpdateConsignGroup(pProxyConsignGroup:CM_ConsigneeConsignorGroup; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realConsignGroup:CM_ConsigneeConsignorGroup;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyConsignGroup.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

