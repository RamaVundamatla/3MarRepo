	endif;
	commitTransaction;

	if tmpTestBOL = null then
		return false;
	endif;
	
	_bolNumber 	:= tmpTestBOL.number;
	_operator	:= tmpTestBOL.myOperator;
	_numLogs	:= tmpTestBOL.numLogs;
	
	beginTransaction;
	delete tmpTestBOL;
	commitTransaction;
	
	return true;

end;</source>
        <Parameter name="_bolNumber" type="String" usage="output"/>
        <Parameter name="_operator" type="CM_Operator" usage="output"/>
        <Parameter name="_numLogs" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNextBOLInNum" id="7db2b6bb-a6a8-415f-a406-51d64e1f74b3">
        <source>getNextBOLInNum() : String;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	nextNum	: Integer;
begin

	beginTransaction;
	exclusiveLock(self.myBOLInNum);
