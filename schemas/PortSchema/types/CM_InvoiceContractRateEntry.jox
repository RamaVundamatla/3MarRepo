    <JadeMethod name="validateForDelete" id="319d4f28-05b4-4758-9f27-ccb7c03279d1">
        <source>validateForDelete();
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55623 TASK 55677
16 October 2023 navmv20 Bug 60896: FR | 54089 - Invoice Contracts - Rate audit trail
25 July    2024 navrv30 Bug 65128: FR | 54089 - Invoice Contracts - Deletion of a Debtor with used rates
*/

vars
	contractRate : CM_InvoiceContractRate; //16 October 2023 navmv20 Bug 60896
	invContractDetail : CM_InvoiceContractDetails;
begin
	//16/10/2023 navmv20 Bug 60896 - start then
	if not app.isJMTUnitTest then
		contractRate := self.myInvoiceContractRate;
		/*
		if contractRate.myService &lt;&gt; null and contractRate.myService.charges.isNotEmpty then
			app.raiseCMException1(Cannot_delete_been_used_invoic,self.auditId(),null,null);
		endif;
		*/
		// ### JIRA 33307 19NOV2024 NAVAB1
		invContractDetail := contractRate.myInvoiceContractDetail;
		if invContractDetail.allInvoiceLines.isNotEmpty then
			app.raiseCMException1(Cannot_delete_been_used_invoic,invContractDetail.auditId(),null,null);
		endif;
		
	endif;
	//16/10/2023 navmv20 Bug 60896 - end
epilog

end;</source>
    </JadeMethod>
