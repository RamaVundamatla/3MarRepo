    <JadeMethod name="validateInvLineDescUsedTranMap" id="1c40b08a-bf68-4964-a3ca-ba534b490585">
        <source>validateInvLineDescUsedTranMap(_invLineDesc : CM_InvoiceLineDesc) : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	map : CM_TransServiceBroker;
	move : CM_MoveServiceBroker;
begin

	foreach map in self.allTransServiceBrokersByType discreteLock do
		if map.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	endforeach;
	
	foreach move in self.moveMap  discreteLock do
		if move.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
