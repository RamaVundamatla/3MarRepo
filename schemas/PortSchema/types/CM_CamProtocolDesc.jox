    <JadeMethod name="createNextCamTaskHistory" id="bc7ecd39-88c1-472d-b4c4-466db6c076d4">
        <source>createNextCamTaskHistory(_camAgent : CM_CamControllerAgent input; _camProtocol : CM_CamProtocol; _seqNo :Integer);
//
// 21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
// 19 June 2012	cnwrs1		Par 29821 - CAMS single transaction per file
// 26/06/0212	cnwcs5		par 29601 - change usage of _camTask
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask

vars
	proxy, history 	: CM_CamTaskHistory;
begin
//write class.name&amp;'::'&amp;method.name&amp;' _camProtocol.code='&amp;_camProtocol.code&amp;' _seqNo='&amp;_seqNo.String&amp;' processSeqNumber='&amp;_camAgent.processSeqNumber.String&amp;' startDateTime='&amp;_camAgent.startDateTime.String&amp;' endDateTime='&amp;_camAgent.endDateTime.String;
	create proxy transient;
	
	proxy.set(_camAgent.runDateTime, 
				_camAgent.startDateTime, 
				_camAgent.endDateTime, 
				_camAgent.logExcludedTransactions, 		// par 29601 July 2012
				null, 									// camProtocol : set later
				_seqNo, 
				_camAgent.dailySeqNumber,
				null, 									// filename : set later
				_camAgent.status, 
				null);
							
	app.myTrxCA.trxCreateCamTaskHistory(proxy, history, _camProtocol, _camAgent, app.myPassport);
epilog
	delete proxy;
end;
</source>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_seqNo" type="Integer"/>
    </JadeMethod>
