    </JadeMethod>
    <JadeMethod name="btnClearAll_click" id="adce9e1e-8cd0-49cb-9dc3-3086528d735e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClearAll_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg('Clearing all selected objects...');
	tblObjects.clearAllSelected;
	btnDelete.enabled	:=	false;
	btnInsert.enabled	:=	false;
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
