*/

vars
	fieldName		: String;
	
begin
	//fieldName := "numChildren";
	//self.initDataExtractField(_fields, CM_TrackedItem.name, "numChildren", fieldName, STRING, "Num Children", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	fieldName := "bookingReference";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "bookingReference", fieldName, STRING, "Booking Reference", "Booking reference", STRING, "Maximum 30 characters");

	fieldName := "myPlannedLocation";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "myPlannedLocation", fieldName, STRING, "Planned Location", "JMT location string for planned position", STRING, "Valid JMT Yard location string");

	fieldName := "myPrimaryQueuedLocation";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "myPrimaryQueuedLocation", fieldName, STRING, "Queued Location", "JMT location string for queued position", STRING, "Valid JMT Yard location string");

	fieldName := "location";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "location", fieldName, STRING, "Location", "JMT location string for current position", STRING, "Valid JMT Yard location string");


epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
