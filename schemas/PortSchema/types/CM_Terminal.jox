    <JadeMethod name="initializeForActivity" id="2c70e560-5f43-428e-9f39-636a907a1471">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
08 February 2022	navab1	TFS 51854
*/

vars

	opsviewtable 	: CMIF_SpatialBins;
	n4Yard 			: CMIF_ArgoYard;
	n4Facility		: CMIF_ArgoFacility;
	mt : CM_MeasurementType;
begin


	if _opsViewTable.isKindOf(CMIF_SpatialBins) then // ### TFS 53369 03MAY2022 NAVAB1
		opsviewtable := _opsViewTable.CMIF_SpatialBins;
		
		//opsviewtable.tableName		:= opsviewtable.Spatial_bins; // ### TFS 53369 27APR2022 NAVAB1 //commented as found duplicates below navsp1 02MAY2022


		opsviewtable.gkey := opsviewtable.generateFullGKey(self, "");
		
		opsviewtable.tableName		:= opsviewtable.Spatial_bins; // ### TFS 53369 27APR2022 NAVAB1

		opsviewtable.bin_level := opsviewtable.SpatialBinLevel_1; // ### TFS 51854 08FEB2022 NAVAB1
		opsviewtable.bin_subclass := "YDM";
		opsviewtable.block_type_enum := "";
		opsviewtable.internal_pos_name := self.code; // ### TFS 51854 08FEB2022 NAVAB1
		opsviewtable.label_scheme_full_position := self.code; // ### TFS 51854 08FEB2022 NAVAB1
		opsviewtable.life_cycle_state := opsviewtable.Life_Cycle_State_ACT; // ### TFS 51854 08FEB2022 NAVAB1
		opsviewtable.parent_bin_gkey := 0; // ### TFS 51854 08FEB2022 NAVAB1
		opsviewtable.yard_gkey := opsviewtable.generateFullGKey(self,""); // ### TFS 53369 27APR2022 NAVAB1  0; // ### TFS 51854 08FEB2022 NAVAB1
		opsviewtable.z_index_last := 0; // not set at this level
		
		opsviewtable.termOid := self.getOidAsString; // ### TFS 53369 27APR2022 NAVAB1
		opsviewtable.oid := self.getOidAsString; // ### TFS 53369 27APR2022 NAVAB1
	elseif _opsViewTable.isKindOf(CMIF_ArgoYard) then // ### TFS 53369 03MAY2022 NAVAB1
		n4Yard :=  _opsViewTable.CMIF_ArgoYard;
		
		n4Yard.gkey := n4Yard.generateFullGKey(self, "");// ### TFS 53369 03MAY2022 NAVAB1
		n4Yard.abm_gkey := n4Yard.generateFullGKey(self, ""); // ### TFS 53369 03MAY2022 NAVAB1
		n4Yard.fcy_gkey := n4Yard.generateFullGKey(self, ""); // ### TFS 53369 03MAY2022 NAVAB1

		n4Yard.id := self.code; // ### TFS 53369 03MAY2022 NAVAB1
		n4Yard.name := self.name; // ### TFS 53369 03MAY2022 NAVAB1
	elseif _opsViewTable.isKindOf(CMIF_ArgoFacility) then 					//navsp1 03MAY2022 TFS#53369
		n4Facility				:= _opsViewTable.CMIF_ArgoFacility;			//navsp1 03MAY2022 TFS#53369
		n4Facility.tableName	:= n4Facility.Argo_facility;				//navsp1 03MAY2022 TFS#53369
		n4Facility.gkey			:= n4Facility.generateFullGKey(self,"");	//navsp1 03MAY2022 TFS#53369
		n4Facility.cpx_gkey 	:= n4Facility.generateCpxGKey();			//navsp1 03MAY2022 TFS#53369
		n4Facility.id 			:= self.code;								//navsp1 03MAY2022 TFS#53369
		n4Facility.name 	    := self.name;								//navsp1 03MAY2022 TFS#53369
		n4Facility.time_zone	:= self.timeZoneID;							//navsp1 03MAY2022 TFS#53369
		n4Facility.termOid 		:= self.getOidAsString; 					//navsp1 03MAY2022 TFS#53369
		n4Facility.oid 			:= self.getOidAsString;						//navsp1 03MAY2022 TFS#53369
		
		mt := self.getDefaultMeasurementForType(Type_Weight); // ### TFS 53105 31MAY2022 NAVAB1
		n4Facility.mu_gkey := n4Facility.generateFullGKey(mt,""); // ### TFS 53105 31MAY2022 NAVAB1
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
