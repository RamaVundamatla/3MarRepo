        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jssSet" id="b82f4edf-2bc6-4387-b4aa-85d370cd0670">
        <updating/>
        <source>jssSet(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Updates the receiver's text with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.text &lt;&gt; pValue then
		self.text	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="jssString" id="c5ff0dd9-288f-4280-9575-ceec49798673">
        <source>jssString():String;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the (trimmed) text value of the receiver.
//
// Parameters:	None
//
// Returns:		String - the trimmed text value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
