    <JadeMethod name="trxCreateRestartCamsRequest" id="d0a5c996-2ca9-4896-94a6-136c13d5c4a4">
        <updating/>
        <source>trxCreateRestartCamsRequest(_camTaskHistory:  CM_CamTaskHistory input; _status : Integer; _resendIndex : Integer; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	//jlier1 TFS 58637 19/6/23
	if _camTaskHistory &lt;&gt; null and _status &lt;&gt; CAM_IDLESTATUS then
		_camTaskHistory.setStatus(_status);
	endif;
	
	app.myUtilityCA.utlCreateRestartCamsRequest(_camTaskHistory,_resendIndex, _passport); //jlier1 TFS 58637 20/6/23
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_resendIndex" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateRestrictionLabour" id="64c9df30-2595-4d79-98dc-1eb58e7aee1c">
        <updating/>
        <source>trxCreateRestrictionLabour(_theProxyRestriction : CM_LabourRestriction; _theNewRestriction : CM_LabourRestriction output;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/03/2011	cnwcs5		CCMS CPL 2027/PAR 27126 - audit changes to locations
//													- replace existing TA audit with TA Location audit
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 23 Apr 2014	NDL			Par 33995 / POL CCMS 2337
// ---------------------------------------------------------------------------
vars
	aTA	: CM_TerminalArea;
	queueEntrySet_after	: CM_RTQueueEntrySet;
	cTA	: CM_TerminalArea;
	childRestriction : CM_LabourRestriction;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	beginLoad;
	app.myValCA.valRestrictionLabour(_theProxyRestriction);
	endLoad;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create queueEntrySet_after transient;
	
	beginTransaction;

	if _passport.noErrors then
		// PAR 17051 (reopened) - need to record before view 
		aTA := _theProxyRestriction.myTerminalArea;
		// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - replace audit of ta with an audit that includes the changes to locations as well
		// app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(aTA, true);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation(aTA, true, null,CM_AuditTALocations.LocnTypeUpdate_LabRestrict, AuditCreated, null);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	create _theNewRestriction persistent;
	_theNewRestriction.setForCreate(_theProxyRestriction);

	if _passport.noErrors then
		_theNewRestriction.getQueueEntries( queueEntrySet_after );
		_theNewRestriction.setQueueTasksStatus( null, queueEntrySet_after );	//ccms1573	cnwvu1
		_theNewRestriction.notifyRecentMachines(); //cnwrd1 15.1.09 ccms JMT 1750
		
		//23 Apr 2014	NDL	Par 33995
		if not _theNewRestriction.allChildLabourRestrictions.isEmpty then
			foreach childRestriction in _theNewRestriction.allChildLabourRestrictions do
				queueEntrySet_after.clear();
				childRestriction.getQueueEntries( queueEntrySet_after );
				childRestriction.setQueueTasksStatus( null, queueEntrySet_after );
				childRestriction.notifyRecentMachines();
			endforeach;
		endif; 
	endif;
	
	if _passport.noErrors then
		aTA := _theNewRestriction.myTerminalArea;
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,aTA);
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Create),false,_theNewRestriction);
		
		//23 Apr 2014	NDL	Par 33995
		if not _theNewRestriction.allChildLabourRestrictions.isEmpty then
			foreach childRestriction in _theNewRestriction.allChildLabourRestrictions do
				cTA := childRestriction.myTerminalArea;
				cTA.causeEvent(cTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,cTA);
				cTA.causeEvent(cTA.myTerminal.getTerminalEvent(Event_TALocation_Create),false,childRestriction);
				app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(childRestriction);
				if _passport.hasErrors() then
					return;
				endif;
				app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation (cTA, false, childRestriction.allLocationControllers,CM_AuditTALocations.LocnTypeUpdate_LabRestrict, 
									AuditCreated, childRestriction.getAuditTALocationDetails);
				if _passport.hasErrors() then
					return;
				endif;
			endforeach;
		endif; 
		
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_theNewRestriction);	// cnwdad1 06/08/2008 - PAR #17673.
		if _passport.hasErrors() then
			return;
		endif;
		// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - replace audit of TA with audit that includes locations changes
 		// app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(aTA, false);	 //cnwgb1 Par 17051 reopened
		app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation (aTA, false, _theNewRestriction.allLocationControllers,CM_AuditTALocations.LocnTypeUpdate_LabRestrict, 
									AuditCreated, _theNewRestriction.getAuditTALocationDetails);
		
		if _passport.hasErrors() then
			return;
		endif;
		
		_theNewRestriction.sendCreateDeleteEmail( app.getErrorString(LOB_Create_Action), _passport);	//08 Jul 2015	NDL	Par 36588
		//navsp1 03MAY2022 TFS#53369
		if app.myPassport.isOpsViewEnabled(aTA.myTerminal) then 
			aTA.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA, aTA); 
		endif;
	endif;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete queueEntrySet_after;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theProxyRestriction" type="CM_LabourRestriction"/>
        <Parameter name="_theNewRestriction" type="CM_LabourRestriction" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateRoadJob" id="6f3f7cfa-c183-4522-a50d-4fd3b8ec42cf">
        <updating/>
        <source>trxCreateRoadJob(pProxyRoadJob:CM_RoadJob input; pNewRoadJob:CM_RoadJob output; _passport : CM_Passport input) updating;
/*
	Created on 08 April 2008
	
	by Debby Hutchison
	
	Purpose:

	28/05/2010	cnwcs5	par24292 - use CM_interchangeArea instead of CM_YardInterchangeArea
	17/06/2010	cnwcs5	par 24418 - tidy up handling default interchange areas
*/

vars
//	icArea 			: CM_InterchangeArea;	// par 24292
	icArea 			: CM_TerminalArea;	//31 Jan 2013	NDL	Par31102
	location		: CM_YardController;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	beginTransaction;
	
	if pProxyRoadJob.myTerminal = null then
		app.raiseCMException(No_Terminal_specified, null, null);
		return;
	endif;

	// use existing code from gate in form
	pNewRoadJob := pProxyRoadJob.myTerminal.createRoadJob(pProxyRoadJob, null, _passport);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	pNewRoadJob.causeEvent(pNewRoadJob.myTerminal.getTerminalEvent(RoadJob_Create_Event), false, pProxyRoadJob);			

	app.myUtilityCA.utlCreateVehicleVisitRecord(pNewRoadJob, _passport);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// we cannot rely on the CM_RoadJob::myGate property being set :-&lt; We do expect the override
	// interchange area to be set for this transaction
	icArea := pNewRoadJob.getDefaultInterchangeArea_IN;	// par 24418

	if icArea = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Yard Interchange Area", null, null);
		app.raiseCMException(Input_required_field_yrdIntAra, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	// could be going to a lane or in-transit-to
	if icArea.isKindOf(CM_CraneTransferArea) then
		location := icArea.CM_CraneTransferArea.getLocationforVehicleMove;
	else
		location := icArea.CM_InterchangeArea.getLocationforVehicleMove;		// par 24418
	endif;
	
	app.myUtilityUA.utlMoveVehicle(pNewRoadJob.myVehicle, location, _passport);

	if  _passport.hasErrors then
		return;
	endif;
	
	pNewRoadJob.rebuildStatus;
epilog
	self.finaliseActivityWithPassport(_passport);
end;	
</source>
        <Parameter name="pProxyRoadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="pNewRoadJob" type="CM_RoadJob" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateRoadJobPrintReceipt" id="8c2a23e6-8fdb-4a23-9ea4-e2d3b23da98b">
        <updating/>
        <source>trxCreateRoadJobPrintReceipt(pRoadJob : CM_RoadJob input; copies : Integer; pPrintPreview, pPerformPrint : Boolean; _passport : CM_Passport input) updating;

//	RDD added pPerformPrint parameter to enable local printing method to be used
//	Part of RDD 22/8/2001 PWL829 / PAR 1297
//	Only called from GateSchema::GTE_RoadExitForm::doPrintCurrent method at present
//
//  Changed On	Changed By  Reason
//  ----------	----------	--------------------------------------------------
//  16 Mar 2010	consw1		PAR #22886 - Leaking report transients

constants
	Tracked_Item_View = 'CM_TrackedItemView';
	Any_Data_View = 'CM_AnyDataObjectView';

vars
	term 			: CM_Terminal;
	reportName		: String;
	jrwManager		: JadeReportWriterManager;
	jrwReport		: JadeReportWriterReport;
	viewName		: String;
	

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);	
	
	if pRoadJob = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'Road Job', null, null);
		return;
	endif;

	//Do the actual report.  This should be done BEFORE going into
	// transaction state as the printPreview could result in an overlong transaction
	// or some printer drivers do a "doWindowsEvents" which can cause other notifications/timers
	// to be processed
	if pPerformPrint then	// enables printing details to be defined in the local schema
		//term := app.getMyTerminalDO_NOT_USE();   //PAR22284 cnwsh3 - Should be getting this from the Road job we're printing.
		term := pRoadJob.myTerminal;
		
		// Par 13155 Changed this to take into account the view 
		//reportName := term.getConfig(GateRoadJobReceipt).String;
		reportName := term.getRoadReceiptReport();//par 13812
		jrwManager := app.createReportWriterManager();
		jrwReport := jrwManager.getReport(reportName);
		
		if reportName = DefRep_GhanaWaybillReport then	//05 Nov 2015	NDL	Par 36777
			pRoadJob.myVehicleVisit.printRoadReceipt(	copies,	//_copies : Integer;
														pPrintPreview,	//_printPreview : Boolean;
														null
														);
		elseif jrwReport = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Gate Road Receipt report class not specified in terminal config (" &amp; reportName &amp; " does not exist)");
			return;
		else
			viewName := jrwReport.getReportingViewName();
			
			if viewName = Tracked_Item_View then
				if pRoadJob.myVehicleVisit = null then
					app.raiseUnexpectedProgramError(class.name, method.name, 'Vehicle Visit record expected');
					return;
				endif;
				//pRoadJob.myVehicleVisit.printReceipt(copies, pPrintPreview, term, null, null, jrwReport);
				//12 Dec 2013	NDL	Par 33184
				pRoadJob.myVehicleVisit.printRoadReceipt(	copies,	//_copies : Integer;
															pPrintPreview,	//_printPreview : Boolean;
															null
															);
				
			elseif viewName = Any_Data_View then
				pRoadJob.printReceipt(copies, pPrintPreview, jrwReport);
			else
				app.raiseUnexpectedProgramError(class.name, method.name, 'Gate Road Receipt report view (' &amp; viewName &amp; ' is not valid for a gate report');
				return;
			endif;
			
		endif;
		
	endif;

	//Do the housekeeping
	beginTransaction;
	if pRoadJob.receiptPrintedDT = null then
		pRoadJob.setReceiptPrintedDT();	//GD do it on the class not &gt;setPropertyValue("receiptPrintedDT", app.getServerTimestamp());
	endif;
	
	pRoadJob.setReceiptCopies(pRoadJob.receiptCopies + copies); //GD do it on the class not &gt;setPropertyValue("receiptCopies", pRoadJob.receiptCopies + copies);

epilog
	delete jrwReport;
	delete jrwManager;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pRoadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="copies" type="Integer"/>
        <Parameter name="pPrintPreview" type="Boolean"/>
        <Parameter name="pPerformPrint" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateRoadJobReceipt" id="897a2c63-a5d4-4c15-a4d5-b1d6008a792d">
        <updating/>
        <source>trxCreateRoadJobReceipt(_roadJob:CM_RoadJob input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	// Always initialize the activity first
