    <JadeMethod name="canCreateCashReceipt" id="49c919c1-1d0b-45e1-a19d-3146c4e84297">
        <source>canCreateCashReceipt(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/09/2018	jlgdap1		Initial creation TFS 40202 PEL1 Estimates SAP Integration
//
vars

begin
	if self.taskStatus = WO_STATUS_USERENTRY or 
		self.taskStatus = WO_STATUS_PENDING  then  //epr TFS 42924 7/2/19
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canReCheckFinance" id="49f0c4ae-85f6-4b99-bc07-226b5a74a6a3">
        <source>canReCheckFinance(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	cashReceipt : CM_CashReceipt;
	cashInvoice : CM_Invoice;
	now 		: TimeStamp; 
begin
	
	cashReceipt := self.myCashReceipt;
	if cashReceipt &lt;&gt; null and cashReceipt.paymentType = PaymentType_PrePay then
		cashInvoice := cashReceipt.myCashInvoice;
		if cashInvoice &lt;&gt; null then
			if cashInvoice.prependDT.isValid then
				now := app.actualTimeServer; 
				if cashReceipt.paymentStatus = CM_CashReceipt.CREDIT_CHECK_REJECTED then
					if cashInvoice.prependDT.differenceInHoursReal(now) &lt;= 24 then
						return true;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCargoToDoTask" id="6750c9e3-cfff-4493-80c9-a24a458156f3">
        <source>createCargoToDoTask();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	wod : CM_WorkOrderDtl;
begin 
	
	foreach wod in self.allWoDtls do
		wod.CM_WorkOrderTIDtl.addCargoToDoTask();
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createPaymenTypeInvoice" id="f03a5d51-ca47-44ec-a446-e48aa0acda80">
        <source>createPaymenTypeInvoice();
/*

Purpose:			
	Create Invoice Lines from cash Receipts 
	TFS 40202 Create an invoice for all my cash receipts	
Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	cashReceipt : CM_CashReceipt;
	root		: CM_Root;
begin
	
	root := app.myRoot;
	
	foreach cashReceipt in self.allCashReceipts discreteLock do						
	
		if cashReceipt.getPaymentType() &lt;&gt; PaymentType_PrePay then	
			continue;
		endif;
		
		if cashReceipt.myCashInvoice = null then								 
			cashReceipt.createInvoiceFromReceipt();	 							 
		endif;
		
		root.deleteFutureActor(cashReceipt, CM_CashStatusAdvanceProcess); 			 
	endforeach;																	 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createPinNumber" id="b21c529f-73e8-4039-a0d9-9ae4bafc95f1">
        <updating/>
        <source>createPinNumber()updating;
/*

Purpose:			
	History
	07 Feb 2019	NDL	TFS 43285 - migrated from CM_WorkOrder ::setForUpdate  so it is always called when status is changed
	to approved, regardless of how it was called.
	
Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	wod 		: CM_WorkOrderDtl;
	createPin	: Boolean;
	pinNo 		: CM_PinNo;
	errMsg 		: String;
	term		: CM_Terminal;
begin
	
	term := self.myTerminal;
	
	foreach wod in self.allWoDtls do
		if wod.isWorkOrderForRelease  		or
		   wod.isWorkOrderForReceival 		or 
		   wod.isWorkOrderForExportReturn then
			createPin := true;
			break;
		endif;
	endforeach;
	
	
	if createPin and self.myPinNo = null then
		if app.generatePinNo(pinNo, errMsg, term) then
			self.myPinNo := pinNo;
		endif;
	endif;
	// end of TFS 43285
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProxyWorkOrderTasks" id="a843d312-5b87-435f-a7c1-67b8747ab10e">
        <source>createProxyWorkOrderTasks(_detailType: Integer; _reqByDT: TimeStamp; _startDT: TimeStamp; _toDoTask: CM_ToDoTaskDesc);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Oct 2018	jlger1	Initial creation 41310
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
04 Nov 2021 cnwma1  ChangeRequest 52249: MTN - Web Portal Cargo Work Orders - Cargo Type Checking when Adding a To Do Task
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	pxyWODtl		    : CM_WorkOrderDtl;
	wodClass   		    : Class;
	workOrderDetailType	: CM_WorkOrderDetailType;
	
begin
	if _toDoTask &lt;&gt; null then
		workOrderDetailType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Cargo,WO_TASK_TODO];
	else
		workOrderDetailType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Cargo,_detailType];
	endif;
	
	if workOrderDetailType &lt;&gt; null then
		
		wodClass := workOrderDetailType.getWodClass(WorkOrderMode_Cargo);
		
		create pxyWODtl as wodClass transient;
		self.setProxyWorkOrderTask( pxyWODtl, _reqByDT, _startDT, false,_detailType, _toDoTask);		//24.01.2023 navma1 #56141 Task#56147
	endif;

epilog

end;</source>
        <Parameter name="_detailType" type="Integer"/>
        <Parameter name="_reqByDT" type="TimeStamp"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_toDoTask" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="createWoDtl" id="4dc2ef17-ec12-47a4-a710-6d6e022f1f96">
        <source>createWoDtl(_workOrderDtl : CM_WorkOrderDtl; _tiSet : CM_TISet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Sep 2023 navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
27 Nov 2023 navhl20 ChangeRequest 61506: EUP | Ship Operations in DD - [54176.010] - [Release] Work Order Detail Grouping
*/

vars
	pxyWod,
	wod			:	CM_WorkOrderDtl;
begin
	if _workOrderDtl.isKindOf(CM_WodReceive) then
		create pxyWod as CM_WodReceive transient;
		create wod as CM_WodReceive persistent;
		
		if _tiSet &lt;&gt; null and _tiSet.isNotEmpty then
			_tiSet.copyNoDups(pxyWod.CM_WorkOrderTIDtl.allSelectedTIs);
			_tiSet.copyNoDups(pxyWod.CM_WorkOrderTIDtl.allAvailableTIs);
		endif;
		pxyWod.CM_WodReceive.setProxyWodReceival(_workOrderDtl.CM_WodReceive.myBookingRef,
												_workOrderDtl.CM_WodReceive.myBookingRefItem, 
												_workOrderDtl.CM_WodReceive.myBillOfLading, 
												_workOrderDtl.CM_WodReceive.myBillOfLadingDtl, 
												_workOrderDtl.CM_WodReceive.customExportEntryNumber, 
												_workOrderDtl.CM_WodReceive.myVoyage,
												_workOrderDtl.CM_WodReceive.transport);
	else																								//27.11.2023 navhl20 #61506
		create pxyWod as CM_WodRelease transient;
		create wod as CM_WodRelease persistent;
		
		if _tiSet &lt;&gt; null and _tiSet.isNotEmpty then
			_tiSet.copyNoDups(pxyWod.CM_WorkOrderTIDtl.allSelectedTIs);
			_tiSet.copyNoDups(pxyWod.CM_WorkOrderTIDtl.allAvailableTIs);
		endif;
		pxyWod.CM_WodRelease.setProxyWodRelease(_workOrderDtl.CM_WodRelease.myReleaseRequest,
												_workOrderDtl.CM_WodRelease.transport, 
												_workOrderDtl.CM_WodRelease.myVoyage, 
												_workOrderDtl.CM_WodRelease.myTrain, 
												_workOrderDtl.CM_WodRelease.myBookingRef, 
												_workOrderDtl.CM_WodRelease.myBookingRefItem,
												_workOrderDtl.CM_WodRelease.myReserveDetail);
	endif;
	
	self.setProxyWorkOrderTask( pxyWod, self.requiredByDT, null, false,null, null);
	wod.setForCreate(pxyWod,self);
	if not self.allWoDtls.includes(wod) then
		self.allWoDtls.add(wod);
	endif;
epilog
	_tiSet.clear();
	delete pxyWod;
end;</source>
        <Parameter name="_workOrderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
