    <JadeMethod name="getBookedTiIds" id="50dc082a-a8f9-4f76-bbf3-3315c0b528ed">
        <source>getBookedTiIds( _deliveryTiIds : StringArray input;
				_pickupTiIds : StringArray input;			// TFS 51248
				_includesDelivery : Boolean output;
				_includesPickUp : Boolean output;
				_addRemarks : String output
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393
19 May 2015	NDL		Par 35930
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
*/

vars

	terminal : CM_Terminal;

	tiId : String;
	ti : CM_TrackedItem;
	
	tiDelivery : Boolean;
	tiPickup : Boolean;
	unknownCargo : Boolean;
	
	currentVoyages : CM_VoyageSet;	//19 May 2015	NDL	Par 35930
	voyage : CM_Voyage;	//19 May 2015	NDL	Par 35930

begin

	_includesDelivery := self.includesDelivery;
	_includesPickUp := self.includesPickup;
	
	if self.allDeliveryTiIds.trimBlanks = null and self.allPuTiIds.trimBlanks = null then
		return;
	endif;
	
	//self.allDeliveryTiIds.getTokensForDelimiter(",", _bookedTiIds);			// TFS 51248
	//self.allPuTiIds.getTokensForDelimiter(",", _bookedTiIds);					// TFS 51248
	self.allDeliveryTiIds.toUpper.getTokensForDelimiter(",", _deliveryTiIds);	// TFS 51248
	self.allPuTiIds.toUpper.getTokensForDelimiter(",", _pickupTiIds);			// TFS 51248
	
	terminal := app.myPassport.myTerminal;
	
	//19 May 2015	NDL	Par 35930
	create currentVoyages transient;
	terminal.getAllCurrentVoyages( currentVoyages, true, false, false );
	
	//if not _bookedTiIds.isEmpty then				// TFS 51248
	//	foreach tiId in _bookedTiIds do				// TFS 51248
	if not _deliveryTiIds.isEmpty then				// TFS 51248
		foreach tiId in _deliveryTiIds do			// TFS 51248
			
			ti := null;
			//Check to see if we have a notified TI.
			ti := terminal.lookupTrackedItem(tiId, TI_CargoType_Null, TI_STATE_NOTIFIED, null, false);
			if ti &lt;&gt; null and tiId = ti.id then
				//Yep its a delvery of a pre-note, nothing more to do here.
				tiDelivery := true;
				continue;
			endif;
			
			// couldn't find it, what to do?		// TFS 51248
			unknownCargo := true;					// TFS 51248
		endforeach;									// TFS 51248
	endif;											// TFS 51248
	
	if not _pickupTiIds.isEmpty then				// TFS 51248
		foreach tiId in _pickupTiIds do				// TFS 51248
			//OK, look to see if its an  on-site cargo to pick-up
			ti := terminal.lookupTrackedItem(tiId, TI_CargoType_Null, TI_STATE_NORMAL, null, false);
			if ti &lt;&gt; null and ti.id &lt;&gt; tiId then
				//not the right one
				ti := null;
			endif;
			if ti = null then
				//nothing found on-site, look for cargo on a current voyage that is an import to pickup
				foreach voyage in currentVoyages do
					ti := voyage.lookupTrackedItem(tiId, TI_CargoType_Null, false);
					if ti &lt;&gt; null and ti.id = tiId and ti.isImport then
						break;
					else
						ti := null;
					endif;
				endforeach;
			endif;
			if ti &lt;&gt; null and tiId = ti.id then	
				//Yep its a pick up, nothing more to do here.
				tiPickup := true;
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Found an onsite or onship for " &amp; tiId, LogTRACE);
				continue;
			endif;
			
			//bugger, don't know what this is
			unknownCargo := true;
			//if _addRemarks &lt;&gt; null then						// TFS 51248
			//	_addRemarks := _addRemarks &amp; ", ";				// TFS 51248
			//endif;											// TFS 51248
			//_addRemarks := _addRemarks &amp; "'" &amp; tiId &amp; "'";	// TFS 51248
		endforeach;
	endif;
	
	if unknownCargo then
		// only alter the ones we know for sure.
		if tiDelivery then
			_includesDelivery := true;
		endif;
		if tiPickup then
			_includesPickUp := true;
		endif;
	else
		//unconditionally set the values
		_includesDelivery := tiDelivery;
		_includesPickUp := tiPickup;
	endif;
	
	
epilog

	delete currentVoyages;	//19 May 2015	NDL	Par 35930

end;</source>
        <Parameter name="_deliveryTiIds" type="StringArray" usage="input"/>
        <Parameter name="_pickupTiIds" type="StringArray" usage="input"/>
        <Parameter name="_includesDelivery" type="Boolean" usage="output"/>
        <Parameter name="_includesPickUp" type="Boolean" usage="output"/>
        <Parameter name="_addRemarks" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefs" id="58d83b06-ea6a-4a4d-adf6-5e021393910c">
        <source>getBookingRefs( _allBookingRefs : CM_BookingRefSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	strArray : StringArray;
	str : String;
	terminal : CM_Terminal;
	bookingRef : CM_BookingRef;

begin

	_allBookingRefs.clear();
	
	if self.allBookingIds.trimBlanks = null then
		return;
	endif;
	
	create strArray transient;
	self.allBookingIds.getTokensForDelimiter(",|", strArray);
	
	if strArray.isEmpty then
		return;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	foreach str in strArray do
		str := str.trimBlanks();
		bookingRef := terminal.allBookingRefsByStatusRef.getAtKey(BR_ACTIVE,str.trimBlanks.toUpper );
		if bookingRef &lt;&gt; null then
			_allBookingRefs.add( bookingRef );
		endif;	
	endforeach;
	
epilog

	delete strArray;

end;</source>
        <Parameter name="_allBookingRefs" type="CM_BookingRefSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBulkReleases" id="31f30503-b97c-49c4-8ae9-beb621965557">
        <source>getBulkReleases( _allBulkReleases : CM_BulkReleaseSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	strArray : StringArray;
	str : String;
	terminal : CM_Terminal;
	bulkRel : CM_BulkRelease;

begin

	_allBulkReleases.clear();
	
	if self.allBulkReleaseIds.trimBlanks = null then
		return;
	endif;
	
	create strArray transient;
	self.allBulkReleaseIds.getTokensForDelimiter(",|", strArray);
	
	if strArray.isEmpty then
		return;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	foreach str in strArray do
		str := str.trimBlanks();
		bulkRel :=terminal.allBulkReleasesByCodeDate.getAtKeyGeq( str.trimBlanks.toUpper, "31/12/3000".Date.TimeStamp ).CM_BulkRelease;
		if bulkRel &lt;&gt; null and bulkRel.code = str then
			_allBulkReleases.add( bulkRel );
		endif;	
	endforeach;
	

epilog

	delete strArray;

end;</source>
        <Parameter name="_allBulkReleases" type="CM_BulkReleaseSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyCarrier" id="314b969c-9eb5-41e2-98ba-81d5b882b0d0">
        <source>getMyCarrier():CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars

	cm_Carrier : CM_Carrier;
	
begin

	//cm_Carrier := self.carrier.asOid.CM_Carrier;		//12.08.2022 navtnr20 52451
	cm_Carrier := app.myPassport.getObjectOfTypeFromOid(self.carrier,CM_Carrier).CM_Carrier;		//12.08.2022 navtnr20 52451
	return cm_Carrier;

epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="getMyDriver" id="fe88168b-a7f8-4e01-ae05-3477f04b9d72">
        <source>getMyDriver():CM_DriverDetails;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars

	cm_carrier : CM_Carrier;
	cm_driver : CM_DriverDetails;

begin

	//cm_driver := self.driver.asOid.CM_DriverDetails;			//12.08.2022 navtnr20 52451
	cm_driver := app.myPassport.getObjectOfTypeFromOid(self.driver,CM_DriverDetails).CM_DriverDetails;		//12.08.2022 navtnr20 52451
	if cm_driver = null then
		return null;
	endif;

	cm_carrier := self.getMyCarrier;
	if cm_carrier = null then
		return null;	
	elseif not cm_carrier.allDrivers.includes( cm_driver ) then
		return null;	
	endif;
	
	return cm_driver;

epilog

end;</source>
        <ReturnType type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="getMyVehicle" id="79f3bd53-9fbe-4a91-9b5a-ccd05ebc1ee4">
        <source>getMyVehicle():CM_Vehicle;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393
20 May 2021 navma1  ChangeRequest 51051: PRP - WebPortal VBS - Driver and Vehicle fields rework
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars

	cm_carrier : CM_Carrier;
	cm_driver  : CM_DriverDetails;
	cm_vehicle : CM_Vehicle;

begin

	//cm_vehicle := self.vehicle.asOid.CM_Vehicle;			//12.08.2022 navtnr20 52451
	cm_vehicle := app.myPassport.getObjectOfTypeFromOid(self.vehicle,CM_Vehicle).CM_Vehicle;		//12.08.2022 navtnr20 52451
	cm_driver  := self.getMyDriver;
	
	// 20.05.2021 navma1 #51051
	if cm_vehicle = null then		
		if cm_driver &lt;&gt; null then
			cm_vehicle 	   := app.myPassport.myTerminal.vehicles[self.vehicle.toUpper, null]; 
			if  cm_vehicle &lt;&gt; null and not cm_driver.allVehicleMachines.includes(cm_vehicle) then
				return null;
			endif;
		endif;
		return cm_vehicle;
	endif;
	// 20.05.2021 navma1 #51051
	
	cm_carrier := self.getMyCarrier;
	if cm_carrier = null then
		return null;
	elseif not cm_carrier.vehicles.includes(cm_vehicle) then
		return null;
	endif;
	
	if cm_driver &lt;&gt; null then
		if not cm_driver.allVehicleMachines.includes(cm_vehicle) then
			return null;
		endif;
	endif;
	
	return cm_vehicle;

epilog

end;</source>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="getRealVehicleBookingTimeslot" id="40b57ab9-4c30-4575-9811-301aff538023">
        <source>getRealVehicleBookingTimeslot():CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars

	vbTimeslot : CM_VehicleBookingTimeSlot;
	
begin

	//vbTimeslot := self.cmObjectId.asOid.CM_VehicleBookingTimeSlot;		//12.08.2022 navtnr20 52451
	vbTimeslot := app.myPassport.getObjectOfTypeFromOid(self.cmObjectId,CM_VehicleBookingTimeSlot).CM_VehicleBookingTimeSlot;		//12.08.2022 navtnr20 52451
	return vbTimeslot;

epilog

end;</source>
        <ReturnType type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
</Class>
