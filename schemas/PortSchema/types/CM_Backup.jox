    <JadeMethod name="createBackupHistory" id="0586dbb8-6b4d-4df7-ad58-34e1b908ee98">
        <updating/>
        <source>createBackupHistory(_realBackupHistory: CM_BackupHistory output): Boolean updating;
//
// CCMS1150 cnwrs1 04 July 2011
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------
vars
	result: Boolean;
	proxyBackupHistory: CM_BackupHistoryDB;
begin

	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	result := false;
	create proxyBackupHistory transient;
	proxyBackupHistory.setProxy(app.actualTimeServer());
	app.myTrxCA.trxCreateBackupHistory(proxyBackupHistory, _realBackupHistory, self, app.myPassport);
	if _realBackupHistory &lt;&gt; null then
		result := true;
	endif;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' fin result='&amp;result.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

epilog
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' epilog result='&amp;result.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	return result;
end;</source>
        <Parameter name="_realBackupHistory" type="CM_BackupHistory" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayStatus" id="19f14043-68dc-4787-b1b3-e4aa4c516e42">
        <methodInvocation>mapping</methodInvocation>
        <source>displayStatus(_set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------
vars

begin
	if _set then
		// do nothing
	else
		_value := self.getDisplayStatus(self.status);
	endif;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
