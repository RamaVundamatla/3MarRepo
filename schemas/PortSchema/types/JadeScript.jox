    <JadeMethod name="addInvoiceStatus" id="43b08fdb-9ec9-4ece-babe-732bb647d538">
        <source>addInvoiceStatus();
/*
Purpose:			

Date		Who		Reason
11 January 2024	navab1	CR 58085 TASK 61346
*/

vars
	pelProcess : CM_InvoiceProcess;

	template : CM_EmailTemplate;
	pxyStatus, realStatus, status : CM_InvoiceStatus;
	rootRole : CM_SecurityRoleTerminalRoot;
	invalidId : Boolean;
begin
	app.initialize();
	pelProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessPelindo];
	
	realStatus := pelProcess.allStatuses[CM_Invoice.INVOICE_VOID];
	
	if realStatus = null then
		create template transient;
		template.setProxyForInvStatus(PINEmail_InvProcPel1Offset,CM_Invoice.INVOICE_VOID,pelProcess.code &amp; " " &amp;  app.getErrorString(Void));

		create pxyStatus transient;
		pxyStatus.setProxy(CM_Invoice.INVOICE_VOID, 8, app.getErrorString(Void), pelProcess, White,template); 
		
		
	beginTransaction;
		app.myUtilityCA.utlCreateInvoiceStatus(pxyStatus, realStatus, app.myPassport);
	commitTransaction;
	endif;

epilog
	delete pxyStatus;

end;
</source>
    </JadeMethod>
