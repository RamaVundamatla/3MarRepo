    <JadeMethod name="checkFileExists" id="854fe20b-7a57-4eec-a099-8e1410bc0f74">
        <source>checkFileExists(_fileName : String; _usePresentationFileSystem : Boolean; _size : Integer output; _lastModifiedTime: TimeStamp output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	f	: File;

begin

	create f transient;
	f.usePresentationFileSystem := _usePresentationFileSystem;
	f.shareMode 	:= File.Share_Read;
	f.kind 			:= File.Kind_Binary;
	f.readOnly 		:= true;
	f.allowCreate 	:= false;
	f.allowReplace 	:= false;
	f.mode 			:= File.Mode_Input;
	f.fileName 		:= _fileName;

	if f.isAvailable then
		f.open;
		_size := f.fileLength;
		f.close;
		_lastModifiedTime := f.lastModifiedTime;
		return true;
	else
		return false;
	endif;

epilog
	if f &lt;&gt; null then
		f.close;
		delete f;
	endif;

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_usePresentationFileSystem" type="Boolean"/>
        <Parameter name="_size" type="Integer" usage="output"/>
        <Parameter name="_lastModifiedTime" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkFileExistsServer" id="553a2780-d0e2-41c1-a738-779f2af5e871">
        <executionLocation>server</executionLocation>
        <source>checkFileExistsServer(_fileName : String; _size : Integer output; _lastModifiedTime: TimeStamp output) : Boolean serverExecution;
// ---------------------------------------------------------------------------
// Created:     17 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.checkFileExists(_fileName, false, _size, _lastModifiedTime);

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_size" type="Integer" usage="output"/>
        <Parameter name="_lastModifiedTime" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkFileFolderExists" id="58843012-c6cb-4097-95e5-5b245ab6be30">
        <source>checkFileFolderExists(_folderName : String; _usePresentationFileSystem : Boolean; _createIfNotPresent : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     20 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	f	: FileFolder;
	
begin

	create f transient;
	f.usePresentationFileSystem := _usePresentationFileSystem;
	f.fileName 		:= _folderName;

	if f.isAvailable then
		return true;
	endif;
	
	if _createIfNotPresent then
		f.make;
		return true;
	endif;

	return false;

epilog
	delete f;

end;</source>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_usePresentationFileSystem" type="Boolean"/>
        <Parameter name="_createIfNotPresent" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcConfirmDelete" id="d0338992-7f87-413e-938c-6871f5316557">
        <source>cnEcConfirmDelete(pEntityName: String): Boolean;

// RBarr 1/9/2006 - override to use XLAT_TranslatableText instead of TranslatableString

vars
	userResponse	: Integer;
	
begin
	userResponse	:=	app.msgBox(	app.getErrorString1(Lit_Confirm_Delete,pEntityName),
									app.getErrorString(Warning),
									MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	return (userResponse = MsgBox_Return_Yes);
