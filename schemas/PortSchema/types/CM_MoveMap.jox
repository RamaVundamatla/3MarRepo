    <JadeMethod name="validateForDefault" id="d216f51b-684e-466b-ad94-d3a96bafd4b3">
        <source>validateForDefault();
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	defMoveMap : CM_MoveMap;
begin
//	defMoveMap := self.terminal.getConfig(AutoPlanDefaultMoveMap).CM_MoveMap;		//SFW1030 30/10/2008
	if defMoveMap = self then
		app.raiseCMException1(Already_system_default,self.id, null,null);
		return;
	endif;
	//----------------------
	//OK, its changed, ask if they really do wish to change it
	//----------------------
	if defMoveMap = null then
		return;
	endif;
	if app.msgBox(app.getErrorString3(ConfirmChange, "system's default MoveMap", defMoveMap.id.trimRight,  self.id.trimRight), "Default Alteration", MsgBox_Question_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_No then
		app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);
	endif;

end;</source>
    </JadeMethod>
