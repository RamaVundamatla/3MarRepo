    <JadeMethod name="pxyCreateUpdateProxy" id="79ae2ce9-b68a-4162-89f2-b5cc6a5b3127">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when	trying to create the proxy
// 12/11/2020   cnwma1		Bug 50335: ASPA - Missing Billing Address in Invoice
vars
	anInvoice 		: CM_Invoice;
	completedOK		: Boolean;
begin
	anInvoice :=  inheritMethod();
		
	anInvoice.debtor      		:= self.debtor;
	anInvoice.myVoyage    		:= self.myVoyage;
	anInvoice.bank        		:= self.bank;
	anInvoice.invoiceType 		:= self.invoiceType;
	anInvoice.myInvoiceNote		:= self.myInvoiceNote;		// ### TFS 52752 17Feb2022 NAVPW1
	anInvoice.myBillingAddress  := self.myBillingAddress;   //12.11.2020 cnwma1 # 50335   
	if anInvoice.isCargoItemSpecific() then					//Par 17895. September 2008
		anInvoice.myTrackedItem := self.myTrackedItem;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return anInvoice;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete anInvoice;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recalculate" id="aa19ac7f-062a-485b-af7b-93ef37578174">
        <updating/>
        <source>recalculate() updating;
// CCMS 1264 recalculate the rate and quantity on demand and not on each access
vars
	line	: CM_InvoiceLine;
begin
	if self.isVoided
	//   or self.status = CM_Invoice.INVOICE_POSTED
	   or self.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759	
	   then
		return;
	endif;
	
	foreach line in self.invoiceLines do
		if line.voided then // TFS 43075 JLGAB1 stop error about changing status to void
			continue; // TFS 43075 JLGAB1
		endif;
		line.recalculate();
	endforeach;
	
	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	self.setTaxDetailsFromLines();
	self.setTotalAmountFromLines();
end;</source>
    </JadeMethod>
    <JadeMethod name="reevaluate" id="2816ec1c-2300-4cc1-9192-9efb0db4c7f2">
        <updating/>
        <source>reevaluate() updating;
/*

Purpose:			Re-Evaluates Debtor address in case a new invoice is created. Before the invoice is posted out.
					Also Re-Evaluates Invoice Locale and Currency Type from the debtor

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
12 September 2022	navpw1	Initial creation TFS: 54564 (54374) (54379) (54376) - EUP - Inv Config - Debtor Currencies and Countries
08 November  2022	navcs2 	Bug 55203: SNO -- Review code fix in method CM_Invoice.reevaluate
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	debtor 				: CM_Debtor;
	terminal			: CM_Terminal;
	debtorTerminal		: CM_DebtorTerminal;
	defaultAddress,
	alternativeAddress	: CM_Address;
	locale				: CM_Locale;
	currency			: CM_CurrencyType;
	msg 				: String;
	canLogExtra			: Boolean;	//27.02.2025 navah1	#34141
	
begin
	canLogExtra			:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	debtor				:= self.debtor;
	terminal			:= app.myPassport.myTerminal;
	debtorTerminal		:= debtor.allDebtorTerminals[terminal];
	
	defaultAddress 		:= debtor.getDefaultDebtorAddress();
	alternativeAddress 	:= debtor.getDebtorAlternativeAddress();
	
	if defaultAddress &lt;&gt; null then
		if self.myBillingAddress &lt;&gt; null then
			msg := "Billing Address changed from '" &amp; self.myBillingAddress.description &amp; "' to '" &amp; defaultAddress.description &amp; "'";
		else
			msg := "Billing Address changed from 'None' to '" &amp; defaultAddress.description &amp; "'";
		endif;
		
		self.myBillingAddress := defaultAddress;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(msg, LogINFO.String);
		endif;
	endif;
	
	if alternativeAddress &lt;&gt; null then
		if self.myAlternativeAddress &lt;&gt; null then
			msg := "Alternative Address changed from '" &amp; self.myAlternativeAddress.description &amp; "' to '" &amp; alternativeAddress.description &amp; "'";
		else
			msg := "Alternative Address changed from 'None' to '" &amp; alternativeAddress.description &amp; "'";
		endif;
		
		self.myAlternativeAddress := alternativeAddress;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(msg, LogINFO.String);
		endif;
	endif;
	
	/*
	*	08 November  2022	Bug 55203 navcs2
	*	Changes Start
	*/	
	if debtorTerminal = null then //If we don't have a debtor terminal try to get it from the terminal collection if its still null then just return
		debtorTerminal := terminal.allDebtorTerminals[debtor];
		if debtorTerminal = null then
			return;
		endif;
	endif;
	/*
	*	08 November  2022	Bug 55203 navcs2
	*	Changes End
	*/
	
	locale := debtorTerminal.myLocale;
	
	if locale &lt;&gt; null then
		if self.myLocale &lt;&gt; null then
			msg := "Locale changed from '" &amp; self.myLocale.vLocaleIdAndDescription &amp; "' to '" &amp; locale.vLocaleIdAndDescription &amp; "'";
		else
			msg := "Locale changed from 'None' to '" &amp; locale.vLocaleIdAndDescription &amp; "'";
		endif;
		
		self.myLocale := locale;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(msg, LogINFO.String);
		endif;
	endif;
	
	currency := debtorTerminal.myCurrencyType;
	
	if currency &lt;&gt; null then
		if self.myCurrencyType &lt;&gt; null then
			msg := "Currency changed from '" &amp; self.myCurrencyType.code &amp; "' to '" &amp; currency.code &amp; "'";
		else
			msg := "Currency changed from 'None' to '" &amp; currency.code &amp; "'";
		endif;
		
		self.myCurrencyType := currency;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(msg, LogINFO.String);
		endif;	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="sendRejectionEmail" id="2eee8678-f3a9-40eb-a9e4-d6360d84c45b">
        <source>sendRejectionEmail(_reasons : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2019	jlger1	Initial creation  moved from BGP_SAPWSRequest

*/

vars
	debtorEmail : String;
	financeEmail: String;
	subject  	: String;
	strNbr      : String;
	type        : String;
begin
	//strNbr      := self.externalFinancialId;
	strNbr      := self.getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
	type        := app.getErrorString(Invoice);

	debtorEmail := self.debtor.getEmailAddress();
	financeEmail := self.myTerminal.getConfig(EmailForFinance).String;
	subject      := type &amp; ": " &amp; strNbr &amp;Tab &amp; app.getErrorString(Debtor_GC) &amp; ": "&amp; self.debtor.name &amp;Tab &amp; "Rejected";
	app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(),	// _alertDescription
										  debtorEmail,		// _toAddress
										  app.myRoot.getConfig(AutoSendersEmailAddress).String,					// _fromAddress
										  financeEmail,		// _ccAddresses
										  null,		// _bccAddresses
										  subject,			// _sendSubject
										  _reasons,				// _sendMessage
										  null,						// _allAttachedFilePaths
										  null,						// _allFileData
										  null,						// _blob
										  null,						// _blobFileName
										  EmailSource_System,		// _sourceOfEmail
										  null,						// _updateCallbackObj
										  app.myPassport);			// _passport

epilog

end;</source>
        <Parameter name="_reasons" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendSAP" id="d1b03096-c2b1-4046-a2a0-7ac2af6ba0f8">
        <updating/>
        <source>sendSAP(_currentStatus ,_newStatus : Integer; _invLines : CM_InvoiceLineSet )updating;

/*

Purpose:
PaymentType_AutoCollection			
	37189.004 Send Release Hold and Debit for Auto-Collection Customer
	WSDL 1.2: Auto-Collection - Release Hold/Debit
	
	37189.005 Send Invoice / Data for Auto-Collection Customer
	WSDL 1.3: Auto-Collection - Revenue Journal + Incoming Cash Journal
	
PaymentType_PostPay
	37189.007 Send Invoice/Data for Post-Billing Customer
	WSDL 1.7: Post-Billing - Billing Payment Process

PaymentType_PrePay
	
	WSDL 1.12: Pre-Billing - Revenue Journal + Incoming Cash Journal
	
	7189.010 Cancel Payment Code
	WSDL 1.11: Pre-Billing - Cancellation
	
	37189.006 Send Invoice/Data for Pre-Billing Customer
	WSDL 1.5: Pre-Billing - Revenue Journal + Incoming Cash Journal
Parameters:			

Return Value:		


Date		Who		Reason
20 Aug 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
02 Oct 2018 cnwma1  Bug 41186: PEL1 - SAP Integration - Unit Test issues
05 Nov 2018 cnwma1  ChangeRequest 41765: PEL1 - SAP Invoice Auto Posting (Auto-collection and Post-pay)
15 Nov 2018 cnwma1  Bug 41992: PEL1 - Disputed Invoice process
22 Nov 2018	cnwma1	ChangeRequest 42118: PEL1 - Generate tax number and invoice date
23 Jan 2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
07 Feb 2019 cnwma1	Bug 43157: PEL1 - SAP - WSDL 1.7 on Posting Invoice
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration
*/

vars
	bgpRequest 		: BGP_ExternalWSRequest;
	proxyBGPRequest : BGP_SAPWSRequest;
	wsdl            : String;
	msg             : String;
	invProcess		: CM_InvoiceProcess;
begin
	
	/*
	Don't Delete SAP Integration not used any more 
	12.06.2025 MTN-34987
	*/
	
	/*
	return; // 11/06/2025	navcs2	MTN-34987  No longer using this so we just return;
	
	if not self.myTerminal.isSapFinancialEnabled then
		return;
	endif;
	
	if self.paymentType = PaymentType_None then
		return;
	endif;
	
	create proxyBGPRequest transient;

	invProcess  := self.getMyInvoiceProcess();			//05.06.2025 navma1 #MTN-34114
	
	msg := method.qualifiedName &amp;
				   ' ' &amp; "SAP**"            &amp;
				   ' ' &amp; "Current Status :" &amp; app.getInvoiceStatusString(invProcess, _currentStatus) &amp;
				   ' ' &amp; "New Status :"     &amp; app.getInvoiceStatusString(invProcess, _newStatus) &amp;
				   ' ' &amp; "Payment Type :"   &amp; app.paymentTypeEnumToString(self.paymentType) &amp;
				   ' ' &amp; "Invoice # : "     &amp; self.exportCurrencyCode;
	app.writeLog(msg,LogINFO) ;
	
	//PaymentType_AutoCollection
	if self.paymentType = PaymentType_AutoCollection then 
		if _newStatus = INVOICE_PENDING  and _currentStatus =  INVOICE_PREPEND then
			/*
			37189.004 Send Release Hold and Debit for Auto-Collection Customer
			WSDL 1.2: Auto-Collection - Release Hold/Debit
			*/
			/*
			proxyBGPRequest.isSAPReleaseHoldDebit:= true;
			proxyBGPRequest.myInvoice := self;
			wsdl := BGP_SAPWSRequest.WSDL12;
		endif;
		
		if _newStatus = INVOICE_POSTED and _currentStatus = INVOICE_PENDING then
			/*
			37189.005 Send Invoice / Data for Auto-Collection Customer
			WSDL 1.3: Auto-Collection - Revenue Journal + Incoming Cash Journal
			*/
			/*
			proxyBGPRequest.isSAPAutoInvReq:= true;
			proxyBGPRequest.myInvoice := self;
			wsdl := BGP_SAPWSRequest.WSDL13;
		endif;
		
		if _newStatus = INVOICE_PENDING  and  _currentStatus = INVOICE_DISPUTED then    //15.11.2018 cnwma1 TFS #41992
			/*
			37189.004 Send Release Hold and Debit for Auto-Collection Customer
			WSDL 1.2: Auto-Collection - Release Hold/Debit
			*/
			/*
			proxyBGPRequest.isSAPReleaseHoldDebit:= true;
			proxyBGPRequest.myInvoice := self;
			wsdl := BGP_SAPWSRequest.WSDL12;
		endif;
	
	//PaymentType_PostPay	
	elseif self.paymentType = PaymentType_PostPay then 
		if _newStatus = INVOICE_PENDING  and _currentStatus =  INVOICE_PREPEND then
			
			/*
			22.11.2018 cnwma1 TFS #42118
			41877.030 Tax number and Invoice Date generation for Pre-pay Invoice
			*/
			/*
			self.generateTax();
			
			/*
			37189.007 Send Invoice/Data for Post-Billing Customer
			WSDL 1.7: Post-Billing - Billing Payment Process
			*/
			/*
			proxyBGPRequest.isSAPPostBillInvReq:= true;
			proxyBGPRequest.myInvoice := self;
			wsdl := BGP_SAPWSRequest.WSDL17;
		endif;	
		
		//02.10.2018 cnwma1 TFS #41186
		if _newStatus = INVOICE_POSTED  and _currentStatus =  INVOICE_PENDING then
			
			if self.myPostedPendingInvoice &lt;&gt; null then
				/*
				In case of replacement only
				37189.007 Send Invoice/Data for Post-Billing Customer
				WSDL 1.7: Post-Billing - Billing Payment Process
				*/
				/*
				proxyBGPRequest.isSAPPostBillInvReq:= true;
				proxyBGPRequest.myInvoice := self;
				wsdl := BGP_SAPWSRequest.WSDL17;
			endif;
			
			/* 07.02.2019 cnwma1 Bug Bug 43157
			if self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
				/*
				05.11.2018 cnwma1 TFS #41765
				Auto Posted in case of success of WSDL 2.2
				37189.007 Send Invoice/Data for Post-Billing Customer
				WSDL 1.7: Post-Billing - Billing Payment Process
				
				proxyBGPRequest.isSAPPostBillInvReq:= true;
				proxyBGPRequest.myInvoice := self;
				wsdl := BGP_SAPWSRequest.WSDL17;
			endif;
			*/
			/*
		endif;
		
		if _newStatus = INVOICE_PENDING  and  _currentStatus = INVOICE_DISPUTED then    //15.11.2018 cnwma1 TFS #41992
				
			/*
			22.11.2018 cnwma1 TFS #42118
			41877.030 Tax number and Invoice Date generation for Pre-pay Invoice
			*/
			/*
			self.generateTax();
			/*
			37189.007 Send Invoice/Data for Post-Billing Customer
			WSDL 1.7: Post-Billing - Billing Payment Process
			*/
			/*
			proxyBGPRequest.isSAPPostBillInvReq:= true;
			proxyBGPRequest.myInvoice := self;
			wsdl := BGP_SAPWSRequest.WSDL17;
		endif;
	
	//PaymentType_PrePay
	elseif self.paymentType = PaymentType_PrePay then    
		
	//	if _newStatus = INVOICE_POSTED and _currentStatus = INVOICE_PENDING then	//09 Apr 2019	NDL	TFS 44348
		if _newStatus = INVOICE_SEND_WSDL112 and _currentStatus = INVOICE_OPEN then	//09 Apr 2019	NDL	TFS 44348
			/*
			WSDL 1.12: Pre-Billing - Revenue Journal + Incoming Cash Journal
			*/
			/*
			proxyBGPRequest.isSAPPreBillProdDataReq:= true;
			proxyBGPRequest.myInvoice := self;
			wsdl := BGP_SAPWSRequest.WSDL112;
		endif;

		if _newStatus = INVOICE_VOID and _currentStatus = INVOICE_PREPEND then
			/*
			37189.010 Cancel Payment Code
			WSDL 1.11: Pre-Billing - Cancellation
			*/
			/*
			proxyBGPRequest.isSAPCancelPaymentCode := true;
			proxyBGPRequest.myInvoice := self;
			wsdl := BGP_SAPWSRequest.WSDL111;
		endif;
		
		if _newStatus = INVOICE_PENDING  and  _currentStatus = INVOICE_PREPEND then       //23.01.2019 cnwma1 TFS #42942
			/*
			37189.006 Send Invoice/Data for Pre-Billing Customer
			WSDL 1.5: Pre-Billing - Revenue Journal + Incoming Cash Journal
			*/
			/*
			proxyBGPRequest.isSAPPreBillInvoiceReq := true;
			proxyBGPRequest.myInvoice := self;
			wsdl := BGP_SAPWSRequest.WSDL15;
		endif;
	endif;
	
	if proxyBGPRequest.myInvoice &lt;&gt; null then
	
		_invLines.copy( proxyBGPRequest.allInvoiceLines );	//09 Apr 2019	NDL	TFS 44248
		
		if self.allSapRequests.isEmpty then
			proxyBGPRequest.setTerminal(self.myTerminal);
			
			msg :=  method.qualifiedName &amp; 
							' ' &amp;"Invoice# : " &amp; self.exportCurrencyCode &amp;
							' ' &amp;"InvLine count# : " &amp; proxyBGPRequest.allInvoiceLines.size.String &amp;	//10 May 2019	NDL	TFS 44248
							' ' &amp; wsdl;
			app.writeLog(msg,LogINFO);
			
			app.myUtilityCA.utlCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
		else
			
			/*
			05.11.2018 cnwma1 TFS #41765
			Auto Post Invoice 
			WSDL 1.7: Post-Billing - Billing Payment Process
			WSDL 1.3: Auto-Collection - Revenue Journal + Incoming Cash Journal
			This case only happen because of the Auto Posting after WSDL 1.2 or WSDL 2.2 Success 
			And The request not been deleted
			*/
			/*
			if self.paymentType = PaymentType_PrePay and proxyBGPRequest.isSAPPreBillProdDataReq then	//06 May 2019	NDL	TFS 44248
				proxyBGPRequest.setTerminal(self.myTerminal);
				msg :=  method.qualifiedName &amp; 
								' ' &amp;"Pre Pay Invoice" &amp;
								' ' &amp;"Invoice# : " &amp; self.exportCurrencyCode &amp;
								' ' &amp;"InvLines size# : " &amp; proxyBGPRequest.allInvoiceLines.size.String &amp;	//10 May 2019	NDL	TFS 44248
								' ' &amp; wsdl;
				app.writeLog(msg,LogINFO);
				app.myUtilityCA.utlCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
				
			elseif self.paymentType = PaymentType_AutoCollection or  self.paymentType = PaymentType_PostPay  then
				if _newStatus = INVOICE_POSTED and _currentStatus = INVOICE_PENDING then
					if proxyBGPRequest.isSAPAutoInvReq or proxyBGPRequest.isSAPPostBillInvReq then
						if proxyBGPRequest.myInvoice = self then
							proxyBGPRequest.setTerminal(self.myTerminal);
						
							msg :=  method.qualifiedName &amp; 
									' ' &amp;"Auto Post Invoice" &amp;
									' ' &amp;"Invoice # : " &amp; self.exportCurrencyCode &amp;
									' ' &amp; wsdl;
							app.writeLog(msg,LogINFO);
							
							app.myUtilityCA.utlCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
							
						endif;
					endif;
				endif;
			endif; 
		endif;
		if app.myPassport.hasErrors then
			msg := method.qualifiedName &amp; 
			' ' &amp; "**SAP**"    &amp;
			' ' &amp; "Invoice :"  &amp; self.exportCurrencyCode &amp;
			' ' &amp; "ERRORS : "  &amp; app.myPassport.getErrorsAndWarningsAsString ;
			app.writeLog(msg,LogINFO);
		endif;
	endif;
	
epilog
	delete proxyBGPRequest;
	*/
end;
</source>
        <Parameter name="_currentStatus" type="Integer"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_invLines" type="CM_InvoiceLineSet"/>
    </JadeMethod>
    <JadeMethod name="sendSAPKinerja" id="e85e9cc4-8679-4a3a-828c-cccd332a45a0">
        <source>sendSAPKinerja();

