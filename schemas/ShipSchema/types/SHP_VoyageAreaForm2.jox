        <updating/>
        <source>dragOver(win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if app.myMoveController &lt;&gt; null then
		self.setFocus();
		self.zOrder(1);
		self.windowState := WindowState_Normal;
	endif;	
	
	
end;</source>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawHolds" id="a6bffc4c-f8b8-4972-8e5f-6d572cf97a2b">
        <updating/>
        <source>drawHolds(_drawSDF : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		In here we have to display the selected holds, in either port or starboard order - this is actually forward or reverse
//				To draw in forward or reverse we basically re assign the row and column of each grid area
//				There is one grid area for on deck with in a bay and one for under deck within a bay - ALWAYS even if it is empty
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------
vars
	
begin
	self.myBayDrawingController.drawSelf(true);
	self.layoutRedraw(false);
	self.frmScrollBackgrd.resizeDragFrame();
	
epilog
	
end;</source>
        <Parameter name="_drawSDF" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableDisableAttributePens" id="41136431-a4b9-4a12-88a3-d6a3c3f86775">
        <source>enableDisableAttributePens(_enabled : Boolean);
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	enabled : Boolean;
begin

