    <JadeMethod name="getCodeDate" id="f566594e-59bf-464a-9ecf-d24841b65dce">
        <source>getCodeDate() : String;
// ---------------------------------------------------------------------------
// Created:     June 2011 by cnwjre1
//	Alternative to getCodeDateString without the (Departed) to keep within 30 chars for selector query use
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	str : String;
begin

	str := self.code;
	if self.scheduledArrivalDT &lt;&gt; null then
		str := str &amp; " " &amp; self.systemToLocalTime(self.scheduledArrivalDT).asStringJMT();// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	return str;
epilog

end;</source>
