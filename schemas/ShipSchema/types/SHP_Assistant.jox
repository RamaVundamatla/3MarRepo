    <JadeMethod name="showOOWForm" id="f19e05b3-839b-4e28-933f-a59230b1c39a">
        <source>showOOWForm(_voyage : CM_Voyage; _crane : CM_Crane input; _menuAction : CMUI_MenuAction );
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	oowForm : SHP_OrderOfWorkForm;
	menuAction : CMUI_MenuAction;
begin
	if _voyage = null and _crane = null then
		return;
	endif;

	menuAction := app.myController.createMenuAction(PmAdmOrdworkView, null, _menuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	oowForm := menuAction.goToObject(null, null, false, null).SHP_OrderOfWorkForm;

	if oowForm = null then
		return;
	endif;
	
	if _voyage &lt;&gt; null then			
		oowForm.showWithObject(_crane, _voyage);	
	endif;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_crane" type="CM_Crane" usage="input"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showOOWorkConfirmationForm" id="ce696724-5742-4f68-a108-1000f5306734">
        <updating/>
        <source>showOOWorkConfirmationForm(_wodVoyageCargoRequest : CM_WorkOrderVoyageDtl; _menuAction : CMUI_MenuAction) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2018	jlgndl1	Initial creation

*/

vars
	form : SHP_OrderOfWorkConfirmation;
	msg : String;

begin
	//NOTE : This method is also called from "YRD_WorkOrderEnquiry::btnOOWConfirm_click" via sendMsg ( Its in a different schema)

	//26 &amp; 28 Nov 2018	NDL	TFS 41980
	if _wodVoyageCargoRequest &lt;&gt; null 
	and ( _wodVoyageCargoRequest.isKindOf( CM_WodVoyageCargoRequest ) or _wodVoyageCargoRequest.isKindOf( CM_WodPermitRequest ) )
	then
		if  _wodVoyageCargoRequest.isKindOf( CM_WodVoyageCargoRequest ) then
			_wodVoyageCargoRequest.CM_WodVoyageCargoRequest.validateWorkPoints( msg );
		elseif _wodVoyageCargoRequest.isKindOf( CM_WodPermitRequest ) then
			_wodVoyageCargoRequest.CM_WodPermitRequest.validateWorkPoints( msg );
		endif;
		if msg &lt;&gt; null then
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			return;
		endif;
	endif;

	form := app.loadForm(SHP_OrderOfWorkConfirmation, SHP_Assistant, false, false, false, self.myTerminal, _menuAction).SHP_OrderOfWorkConfirmation;
	if form = null then
		return;
	endif;
	
	form.setMyWodVoyageCargoRequest(_wodVoyageCargoRequest);	//14 June 2018	NDL	TFS 39197
	
	form.show;
epilog

end;</source>
        <Parameter name="_wodVoyageCargoRequest" type="CM_WorkOrderVoyageDtl"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showOrderOfWorkPrint" id="72485de0-4e67-4997-8241-3c22a86a8738">
        <source>showOrderOfWorkPrint( 	_parent				: CM_BaseForm;
						_menuAction			: CMUI_MenuAction; 
						_term				: CM_Terminal;
						_voyage				: CM_Voyage;
						_jobType			: Integer;
						_filterWorkPoint	: IF_VoyageWorkPoint);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Oct 2012	cnwpjs1	Initial creation  PAR #30631

*/

vars

	reportForm : SHP_OrderOfWorkPrint; 
	
begin

	reportForm := app.loadForm(SHP_OrderOfWorkPrint, SHP_Assistant, false, false, true, _term, _menuAction).SHP_OrderOfWorkPrint;

	if reportForm = null then
		return;
	endif;

	reportForm.setParentForm(_parent);
	reportForm.setMyTerminal(_term);	
	reportForm.setMyCurrentVoyage(_voyage);
	reportForm.setJobType(_jobType);
	reportForm.setFilterWorkPoint(_filterWorkPoint);
	
	reportForm.showModal;

epilog

end;</source>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_jobType" type="Integer"/>
        <Parameter name="_filterWorkPoint" type="IF_VoyageWorkPoint"/>
    </JadeMethod>
