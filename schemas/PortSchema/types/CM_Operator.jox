    <JadeMethod name="getDischargePortFromDest" id="0cd607ce-b92b-4145-985d-740135305000">
        <source>// cnwjk3 PAR 15627 25/11/08
//getDischargePortFromDest(_destination, _voyageCode : String; _shippingLine : CM_ShippingLine) : CM_Port;
getDischargePortFromDest(_destination : String; _voyage : CM_Voyage; _shippingLine : CM_ShippingLine) : CM_Port;

//
// CCMS 1031 find the dischargePort from a destination for this operator and shippingLine or voyage
//
vars
	shippingLine : CM_ShippingLine;
	operatorShippingLine : CM_OperatorShippingLine;
	voyage : CM_Voyage;
	port : CM_Port;
	shippingLineCode : String;
	dischargePort : CM_Port;
	// cnwjk3 PAR 15627 25/11/08
	//theTerminal : CM_Terminal;
	//voyageCode : String
begin
		
	// cnwjk3 PAR 15627 25/11/08
	if _shippingLine = null then
		if _voyage &lt;&gt; null then
			shippingLine := _voyage.myShippingLine;
		else
			return null;
		endif;
		// cnwjk3 PAR 15627 25/11/08
		/*
		if theTerminal &lt;&gt; null then
			voyage := theTerminal.lookupVoyage(_voyageCode, null, true);
			if voyage &lt;&gt; null then
				shippingLine := voyage.myShippingLine;
			else
				return null;
			endif;
		else
			 return null;
		endif;
		*/
	else
		shippingLine := _shippingLine;
	endif;
	
	if shippingLine &lt;&gt; null then
		operatorShippingLine := app.myRoot.allOperatorShippingLines[self, shippingLine];
		if operatorShippingLine &lt;&gt; null then
			port := operatorShippingLine.getDischargePort(_destination);
			if port &lt;&gt; null then
				dischargePort := port;
			endif;
		endif;
	endif;
	return dischargePort;
end;
</source>
        <Parameter name="_destination" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="5656345c-c749-49a2-a807-ef9e5536ddd3">
