    <JadeMethod name="tblResources_gotFocus" id="56cfd79f-5d2d-437f-8aab-d6da695c0bb0">
        <controlMethod name="CM_DataTable::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResources_gotFocus(table: Table input) updating;

/*
Date			Who		Reason
11 January 2011	cnwar2	#26691

*/
vars

begin
	// select first row if none slected and table not empty
	if not (self.tblResources.row &gt; self.tblResources.fixedRows and self.tblResources.row &lt;= self.tblResources.rows)
	and self.tblResources.fixedRows + 1 &lt;= self.tblResources.rows then
		self.tblResources.row := self.tblResources.fixedRows + 1;
	
	
		self.doTblResourcesClick();
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
