    <JadeMethod name="trxArriveWebTrain" id="ec56e128-353d-47ce-82c8-5a7604a45f02">
        <updating/>
        <source>trxArriveWebTrain(_pxyTrain : CM_Train input; _allWagons : CM_WagonArray; _allLines: CM_RailLineArray; _allPositions: IntegerArray; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwmp6	Initial creation

*/
vars
	index: Integer;
	wagon: CM_Wagon;
	line: CM_RailLine;
	position: Integer;
	realTrain: CM_Train;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	if _pxyTrain.pxyIsProxy() then
		app.myUtilityUA.utlUpdateTrain(_pxyTrain, false, true, _passport);
		realTrain := _pxyTrain.pxyGetRealObject().CM_Train;
	else
		app.myUtilityCA.utlCreateTrain(_pxyTrain, realTrain, false, true, _passport);
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	foreach index in 1 to _allWagons.size() do
		wagon := _allWagons[index];
		line := _allLines[index];
		position := _allPositions[index];
		app.myUtilityUA.utlUpdateWagonPosition( null, line, wagon, position, _passport);
		if _passport.hasErrors then
			return;
		endif;
		wagon.setMyTrain(true, realTrain);
		wagon.setMyTrain(false, realTrain);
	endforeach;

	if _passport.hasErrors then
		return;
	endif;
	
	realTrain.confirmWagons(null, true, false, _passport);


epilog
	self.finaliseActivityWithPassport(_passport);
end;

</source>
        <Parameter name="_pxyTrain" type="CM_Train" usage="input"/>
        <Parameter name="_allWagons" type="CM_WagonArray"/>
        <Parameter name="_allLines" type="CM_RailLineArray"/>
        <Parameter name="_allPositions" type="IntegerArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAssignWleToWagonController" id="add213f2-1ba6-4405-8170-881d09127a74">
        <updating/>
        <source>trxAssignWleToWagonController(_wle : CM_YardWLE input; _stackPos : Integer; _primaryWagonCont : CM_WagonController input; _doRtQueue : Boolean; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwndl1	Initial creation	CCMS 1094
12 Sep 2024 navlc30 Bug 65971: When we assign bulk releases to a wagon to create rail jobs, the first warehouse and the number of warehouse locations are not updated.

*/

vars
	controllers : CM_WagonControllerArray;
	isoTypeCode : String;
	isoType : CM_ISOType;
	numControllers : Integer;
	nextController : CM_WagonController;
	isoTypeGroupCode : String;
	isoTypeGroup : CM_ISOTypeGroup;
	wagon : CM_Wagon;
	job   : CM_Job;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _wle = null then
		self.raiseExceptionIfNull(_wle, app.getErrorString(Release_request));
	endif;
	
	if _primaryWagonCont = null then
		self.raiseExceptionIfNull(_primaryWagonCont, app.getErrorString(Null_location_control_passed));
	endif;
	
	//10 Feb 2014	NDL	Par 33439 - CCMS POL 2311
	_primaryWagonCont.validateCargoRestrictions(null,null,_wle);
	if _passport.hasErrors then
		return;
	endif;
	
	if _wle.isRailBreakBulk
	or _primaryWagonCont.isBoxcarCont	//03 Feb 2016	NDL	Par 37492
	or _primaryWagonCont.isSkeletonCarCont	//03 Dec 2020	NDL	TFS 50164
	then
		//break bulk
		 numControllers := 1;
	else
		isoTypeCode := _wle.myRequest.CM_DeliveryRequest.isoType;
		isoTypeGroupCode := _wle.myRequest.CM_DeliveryRequest.isoGroup;	//10 May 2010	NDL Par 24064
		if isoTypeCode &lt;&gt; null then
			isoType	:=	app.myRoot.allISOTypes[isoTypeCode];
			if isoType &lt;&gt; null then
				//numControllers := isoType.getLengthInUnitsForWagon();
				numControllers := _primaryWagonCont.myWagon.getLengthInUnitsForWagon(isoType).Integer;	//Par 35346 / CCMS 1408
			endif;
		elseif isoTypeGroupCode &lt;&gt; null then	//10 May 2010	NDL Par 24064
			isoTypeGroup	:=	app.myRoot.allISOTypeGroups[isoTypeGroupCode];
			if isoTypeGroup &lt;&gt; null then
				//numControllers := isoTypeGroup.getLengthInUnitsForWagon();
				numControllers := _primaryWagonCont.myWagon.getLengthInUnitsForWagon(isoTypeGroup).Integer;	//Par 35346 / CCMS 1408
			endif;
			
		else	//03 Dec 2020	NDL	TFS 50164
			numControllers := 1;
		endif;
		
	endif;
	
	if numControllers = 0 then
		app.raiseCMException1(No_Length_Iso_type,isoTypeCode, null, null);
	endif;
	
	create controllers transient;
	controllers.add(_primaryWagonCont);
	nextController := _primaryWagonCont.myNextController;
	
	while controllers.size &lt; numControllers do
		if nextController = null then
			break;
		else
			controllers.add(nextController);
		endif;
		nextController := nextController.myNextController;
	endwhile;
	
	if controllers.size &lt;&gt; numControllers then
		app.raiseCMException2(ERR_NO_SPACE, _wle.id, _primaryWagonCont.myWagon.id, null, null);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	beginTransaction;

	job := _wle.job;						//12.09.2024 navlc30 #65971
	job.setJobPlannedLocation(true);		//16.09.2024 navlc30 #65971

	app.myUtilityUA.utlAssignWleToWagonControllers(_wle, _stackPos, controllers, _passport);
	
	if _doRtQueue then	//11 May 2010	NDL	Otago CCMS 1935 
		// Queue the wle as well i.e. add the task to the Radio Telemetry Queue
		if _passport.hasErrors then
			return;
		endif;
		_passport.setWarningsIgnored(true);
		app.myUtilityUA.utlUpdateWLEAutoplan(_wle, QUEUE_MODE, _passport);
	
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	delete controllers;
end;</source>
        <Parameter name="_wle" type="CM_YardWLE" usage="input"/>
        <Parameter name="_stackPos" type="Integer"/>
        <Parameter name="_primaryWagonCont" type="CM_WagonController" usage="input"/>
        <Parameter name="_doRtQueue" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
