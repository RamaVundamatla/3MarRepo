    <JadeMethod name="initForm" id="e2ec5dbe-f44c-467d-8a5a-cd989b272da9">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:	2 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
begin
	self.allowPrint		:= true;
	self.allowExportCSV	:= true;
	self.allowSearch	:= false;
	self.allowTblDataSearch := true;
	
	self.setNavigatorHeading(self.caption);

	self.useTblThumb := false;
	self.frmDetailsBottom.visible := true;
	self.mnuTblVPrint.enabled 	:= true;	
	self.mnuTblVExportCSV.enabled := true;	
	
	self.initTblEntDetail();
	self.clearErrorWarnings();	
	
	self.fldEntDetail.useSheetBackColors := true;
	self.fldEntDetail.setDefaultSheetBackColors();
	self.fldEntDetail.initSheetBackColors();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initMSG" id="de5aee9f-a130-4969-97ee-7fb083823d25">
        <source>initMSG();
// ---------------------------------------------------------------------------
// Created:	2 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
	theGroupBox : CMUI_MultiSelectGroupBox;
begin
	theGroupBox := self.msgDebtors;
	theGroupBox.caption := null;
	theGroupBox.distanceFromBottom 	:= 5;
	theGroupBox.distanceFromRight 		:= 5;
	theGroupBox.lockBottom 				:= false;
	theGroupBox.lockRight				:= false;
	theGroupBox.stretchHeight 			:= false;
	theGroupBox.stretchWidth 			:= true;
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := "displayDebtor";
	theGroupBox.availableHeading := app.getErrorString(Available_debtors);
	theGroupBox.selectedHeading := app.getErrorString(Selected_debtors);
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="02152308-a10d-41cb-8534-7f9076e607c4">
        <source>initTblEntDetail();
/// ---------------------------------------------------------------------------
// Created:	2 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
begin
	theTable := self.tblEntDetail;
	theTable.warningMethod := 'entTableWarning';

	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_InvMaintDebtTypeEdit);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theTable.adjustHeight(200);	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadADebtor" id="bfe57a98-b90e-445b-9d4a-3abfe952a639">
        <source>loadADebtor( _availableDebtors : CM_DebtorByNameDict io; _node : CM_DebtorNode );
/// ---------------------------------------------------------------------------
// Created:	4 April 2008 By Graeme Black cnwgb1
// Recursively load all the debtors from the debtor node tree.
// ---------------------------------------------------------------------------
vars
	aNode :CM_DebtorNode;
begin
	if _node.isKindOf(CM_Debtor) then
		_availableDebtors.add(_node.CM_Debtor);
	endif;
	
	if (not _node.allChildDebtorNodes.isEmpty) then
		foreach aNode in _node.allChildDebtorNodes do
			if not aNode.isKindOf(CM_VoidDebtor) then
				self.loadADebtor(_availableDebtors, aNode);
			endif;
		endforeach;
	endif;
end;
</source>
        <Parameter name="_availableDebtors" type="CM_DebtorByNameDict" usage="io"/>
        <Parameter name="_node" type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="loadAvailableDebtors" id="39ef04be-4284-4eb6-b44c-ae8af2337bc3">
        <source>loadAvailableDebtors( _availableDebtors : CM_DebtorByNameDict io );
// ---------------------------------------------------------------------------
// Created:	4 April 2008 By Graeme Black cnwgb1
// Top level of recursive load all the debtors from the debtor node tree.
// ---------------------------------------------------------------------------
vars
	theBank : CM_Bank;
	rootDebtorGroup : CM_RootDebtorGroup;
	aNode : CM_DebtorNode;
begin
	theBank := app.myRoot.myRootCompany;
	rootDebtorGroup := theBank.getRootDebtorGroup;	

	foreach aNode in rootDebtorGroup.allChildDebtorNodes do
		if not aNode.isKindOf(CM_VoidDebtor) then
			self.loadADebtor(_availableDebtors, aNode);
		endif;
	endforeach;
	
end;
</source>
        <Parameter name="_availableDebtors" type="CM_DebtorByNameDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateEntDetailTable" id="891658ca-8863-4282-8a2f-800adf0485bd">
        <source>populateEntDetailTable();
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// Load up data in the Debtor Type Details sheet/table
// ---------------------------------------------------------------------------

vars
	entRow			: EntTableRow;
	debtorType     	: CM_DebtorType;
	displayValue	: String;	
	prodAttr		: String;
	handlingType	: CM_HandlingType;
	sysType			: Boolean;
	entDef		    : EntTableDef;
	idx 			: Integer;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvMaintDebtTypeEdit);

	debtorType := self.myCurrentObject.CM_DebtorType;
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		return;
	endif;	
	if debtorType = null then
		return;
	endif;
	
	foreach entRow in entDef.allEntTableRows do
		if debtorType &lt;&gt; null then
			displayValue := debtorType.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;
		
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;

	
	if debtorType.myDefaultDebtor = null then
		self.cmbDebtor.listIndex := -1;
		tblEntDetail.setValueByName( ETRow_DefDebtor, null);
	else
		if self.cmbDebtor.findObject(debtorType.myDefaultDebtor ) &lt; 0 then
			self.cmbDebtor.listIndex := -1;
			tblEntDetail.setValueByName(ETRow_DefDebtor, null);		
		else
			self.cmbDebtor.listObject := debtorType.myDefaultDebtor;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="28c7ba86-d3cc-4085-9757-02411c6237e1">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
begin
	inheritMethod(_colorControl);
	self.setColorsForEntryTable(self.tblEntDetail);
	self.fldEntDetail.backColor := self.backColor;
	self.shtEntDetail.backColor := self.backColor;
	self.shtDebtors.backColor := self.backColor;
	self.msgDebtors.backColor := self.backColor;
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="54727bf6-bcfc-494e-b287-6d5fa06a636b">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------

begin

	inheritMethod();
	self.fldEntDetail.visible := true;
	self.shtDebtors.visible := true; //epr TFS 4471 29/5/17
	self.msgDebtors.userInputEnabled := true;
	if self.mode = self.Mode_Add then
		self.tblEntDetail.clearValues();
		self.msgDebtors.setSelected(null);
	endif;
	
	self.tblEntDetail.userInputEnabled := true;
	self.tblEntDetail.setFocus;
	self.tblEntDetail.goToRowByName(ETRow_Code);
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="ad99e489-ff48-4730-aee1-0565598ec7b9">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:	5 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars

begin
	self.fldEntDetail.visible := true;
	self.tblEntDetail.userInputEnabled := false;
	self.populateEntDetailTable();
	self.setDebtorsAvailableAndSelected();
	self.msgDebtors.userInputEnabled := false;
	self.fldEntDetail.initSheetBackColors();
end;
</source>
    </JadeMethod>
    <JadeMethod name="setDebtorsAvailableAndSelected" id="5f302a23-b100-4c5f-8912-93c391c7dca4">
        <source>setDebtorsAvailableAndSelected();
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// Propulate the debtors sheet
// ---------------------------------------------------------------------------
vars
	theDebtorType : CM_DebtorType;
	availableDebtors : CM_DebtorByNameDict;
begin
	theDebtorType := self.myCurrentObject.CM_DebtorType;
	if theDebtorType = null then
		return;
	endif;

	create availableDebtors transient;
	self.loadAvailableDebtors( availableDebtors );
	self.msgDebtors.setAvailable(availableDebtors, true);
	delete availableDebtors;
	
	theDebtorType := self.myCurrentObject.CM_DebtorType;
	if self.mode = self.Mode_Add then
		self.msgDebtors.setSelected(null);
	else
		self.msgDebtors.setSelected(theDebtorType.allDebtors);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="b2579678-72cb-4268-ad90-dc5dfb2741d4">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
begin
	self.myDataClass := CM_DebtorType;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9bae766e-3e6e-4b1e-af4c-fcb82b01e357">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------

begin
	inheritMethod();
	
	self.caption := "Debtor Types";

	self.allowDelete := false; 
	
	self.doCmbDefDebtorBuild;

	self.initMSG();
	self.msgDebtors.setAvailable(app.myRoot.allDebtors,true);
	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="d41c584a-1ab8-482b-a18e-92486b4756f6">
        <updating/>
        <source>showThumbnailData(_obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:	5 May 2008 By Graeme Black cnwgb1
// Note we are using the edit sheets for view so that users can view
// the debtors 
// ---------------------------------------------------------------------------
vars
	theDebtorType, realDebtorType  : CM_DebtorType;
begin
	theDebtorType := _obj.CM_DebtorType;
	if theDebtorType.isSystemGenerated() then
		self.btnEditTV.enabled := false;
	else
		self.btnEditTV.enabled := true;
	endif;

	self.setControlsForView();
	
	if theDebtorType.isSystemGenerated() then
		self.shtDebtors.visible := false;
		self.tblEntDetail.hideRowByName(ETRow_DefDebtor, false);
	else
		self.shtDebtors.visible := true;
		self.tblEntDetail.showRowByName(ETRow_DefDebtor, false);
	endif;

	if theDebtorType.isTransient() then
		realDebtorType := theDebtorType.pxyGetRealObject();
	else
		realDebtorType := theDebtorType;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ebbce0af-524b-45bc-9a04-a9bbba2d71c6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006158, locale);
	msgDebtors.translateCaption(Xlat_0006159, locale);
	shtDebtors.translateCaption(Xlat_0006160, locale);
	shtEntDetail.translateCaption(Xlat_0006161, locale);
end;</source>
    </JadeMethod>
</GUIClass>
