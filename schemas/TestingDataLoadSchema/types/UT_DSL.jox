	app.myTrxUA.trxUpdateSlotRequestAttribute(_allSlots, null, true,
						allObjectEditions, CM_SlotRequest.Attribute_Erase, null, app.myPassport);	
						
	self.assertNoTrxErrorsOrWarnings();
epilog
