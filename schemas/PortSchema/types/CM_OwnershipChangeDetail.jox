        <source>setForCreate(_proxy :CM_OwnershipChangeDetail)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
1 June 2023 navtnr20	TFS CR 58507	Task 58210: Jade - TRX CM_OwnershipChangeDetail 

*/

vars

begin
