    <JadeMethod name="getDisplayStringForAttribute" id="4e192a65-79cf-45e8-99d6-7a62e86faa86">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#			Description
============================================================================
09/07/2009	cnwndl1					Initial creation
12/03/2013	cnwdap1	PAR #31155 
					CCMS SFW 1321 	Imperial Measurements
09/05/2019	jlgka1	TFS 44287		Damage Refactoring. Display Damage details
									instead of the Damage Flag.
============================================================================*/
vars
	type 			: String;					// PAR #31155
	str				: String;					// PAR #31155
	value			: Decimal [23,10];			// PAR #31155
begin
	if _attrName = ETRow_AutoCreatedYN then
		return autoCreated.getYes();
	elseif _attrName = ETRow_MaxCargoWeight then
		return self.getMaxCargoWeight.asStringMeasurementJMT;	//Par 21924
	elseif _attrName = ETRow_MaxCargoHeight then
		return self.getMaxCargoHeight.asStringMeasurementJMT;	//Par 21924
	elseif _attrName = ETRow_TareWeight then
		return self.getTareWeight.asStringMeasurementJMT;	//Par 21924		
	//jlgka1 TFS 44287 --&gt;	
	/*elseif _attrName = ETRow_IsDamaged then			//+cnwml2 PAR26399 MSL CCMS 1105
		return app.getYesNo(self.allDamageInstancesByPos.size &gt; 0);*/
	elseif _attrName = ETRow_DamageDetails then 			
		return getDamageDetailsDescr;
	//jlgka1 TFS 44287 &lt;--	
	elseif _attrName = ETRow_HasCargoRestricts then			//13 Feb 2014	NDL	Par 33439
		return app.getYesNo(self.allCargoRestrictionCriteria.size &gt; 0);
		
	elseif _attrName.isMeasurementType then											// PAR #31155
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	// PAR #31155
		_attrName.getRowNameMeasureType(str, type);									// PAR #31155
		return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #31155
			
	endif;

	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxCargoHeight" id="9d0886c5-3359-45eb-8be7-cc3324181382">
        <source>getMaxCargoHeight():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwndl1	Initial creation	Par 21924
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars

	maxHeight : Decimal [12,2];
	invalidObject : Boolean;
	wagonClass	: CM_WagonClass;
begin

	//23 Feb 2010 NDL Par 21924 
	wagonClass := self.myWagonClass;
	if wagonClass &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, wagonClass, invalidObject);
		maxHeight := wagonClass.maxCargoHeight;
		if wagonClass.internalHeight &gt; maxHeight then
			maxHeight := wagonClass.internalHeight;
		endif;
	endif;

	
	return maxHeight;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMaxCargoWeight" id="944c743d-b6bc-4933-baee-57ee9a97cd43">
