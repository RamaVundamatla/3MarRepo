    <JadeMethod name="getLocationsForRotationGroup" id="6c8df6e3-6302-4276-b49d-aae5d54fa021">
        <source>getLocationsForRotationGroup(_items, _split : Integer) : CM_ObjectArray;
/*
Purpose:			
Date				Who			Reason
MAY 2012		CNWAB1		Initial creation
*/
//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed

vars
	nextLocn : CM_ROROLocnDefn;
	covering : CM_DeckItemLayout;
	locns : CM_ObjectArray;
	idx, stIdx, endIdx : Integer;
begin


	create locns transient;
	if _items = 3 or _items = 6 then
		stIdx := 1;
		endIdx := 2;
	elseif _items = 5 or _items = 10 then
		stIdx := 1;
		endIdx := 4;
	endif;
	
	// Checking a grid of 1X3 or 1X5 or 2X3 or 2X5
	
	// So for any of these start with me and go in a straight line for the first 3 or 5 in the group
	if self.orientation = ROROLocn_AftForward then
		nextLocn := self;
		locns.add(nextLocn);
		if stIdx &lt;&gt; 0 and endIdx &lt;&gt; 0 then	// dont check overlapping during rotation for 1X1 OOTL
			foreach idx in stIdx to endIdx discreteLock do
				nextLocn := self.myDeckLayerLayout.getPortSideLocnByPosition(nextLocn.myLayout);
				if nextLocn &lt;&gt; null then // PAR 32186
					covering := nextLocn.myLayout.getCoveredBy(DeckItemLayoutType_Locn,false); // PAR 32186
					if covering = null or (covering &lt;&gt; null and covering.isOOTLDefn) then // PAR 32186 OK if covered by OOTL or not covered at all
						locns.add(nextLocn);
					endif;
				else
					break;
				endif;
			endforeach;
		endif;
	else
		nextLocn := self;
		locns.add(nextLocn);
		if stIdx &lt;&gt; 0 and endIdx &lt;&gt; 0 then	 //dont check overlapping during rotation for 1X1 OOTL
			foreach idx in stIdx to endIdx discreteLock do
				nextLocn := self.myDeckLayerLayout.getFwdSideLocnByPosition(nextLocn.myLayout);
				if nextLocn &lt;&gt; null then
					covering := nextLocn.myLayout.getCoveredBy(DeckItemLayoutType_Locn,false);
					if covering = null or (covering &lt;&gt; null and covering.isOOTLDefn) then // PAR 32186 OK if covered by OOTL or not covered at all
						locns.add(nextLocn);
					endif;
				else
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	// Now if there are 2 'rows' move over to the locn adjacent  to me and then move forward in a straight line
	if _items = 6 or _items = 10 then
		if self.orientation = ROROLocn_AftForward then
			// PAR 29590 nextLocn := self.myDeckLayerLayout.getFwdSideLocnByPosition(self.myLayout); // Right from Me
			nextLocn := self.myAdjacentSlotFwd; 
			if nextLocn &lt;&gt; null then// PAR 32186
				covering := nextLocn.myLayout.getCoveredBy(DeckItemLayoutType_Locn,false);// PAR 32186
				if covering = null or (covering &lt;&gt; null and covering.isOOTLDefn) then // PAR 32186 OK if covered by OOTL or not covered at all
					locns.add(nextLocn);
					// move forward in a straight line
					foreach idx in stIdx to endIdx discreteLock do
						nextLocn := self.myDeckLayerLayout.getPortSideLocnByPosition(nextLocn.myLayout);
						if nextLocn &lt;&gt; null then // PAR 32186
							covering := nextLocn.myLayout.getCoveredBy(DeckItemLayoutType_Locn,false);// PAR 32186
							if covering = null or (covering &lt;&gt; null and covering.isOOTLDefn) then // PAR 32186 OK if covered by OOTL or not covered at all
								locns.add(nextLocn);
							else
								break;
							endif;
						else	//cnwmc5 - PAR 32403 - 03 Sep 2013
							break;
						endif;
					endforeach;
				endif;
			endif;
		else
			// PAR 29590  nextLocn := self.myDeckLayerLayout.getPortSideLocnByPosition(self.myLayout); // UP from ME
			nextLocn := self.myAdjacentSlotAft; 
			if nextLocn &lt;&gt; null then// PAR 32186
				covering := nextLocn.myLayout.getCoveredBy(DeckItemLayoutType_Locn,false); // PAR 32186
				if covering = null or (covering &lt;&gt; null and covering.isOOTLDefn) then // PAR 32186 OK if covered by OOTL or not covered at all
					locns.add(nextLocn);
					//move forward in a straight line
					foreach idx in stIdx to endIdx discreteLock do
						nextLocn := self.myDeckLayerLayout.getFwdSideLocnByPosition(nextLocn.myLayout);
						if nextLocn &lt;&gt; null then // PAR 32186
							covering := nextLocn.myLayout.getCoveredBy(DeckItemLayoutType_Locn,false);  // PAR 32186
							if covering = null or (covering &lt;&gt; null and covering.isOOTLDefn) then // PAR 32186 OK if covered by OOTL or not covered at all
								locns.add(nextLocn);
							else
								break;
							endif;
						else	//cnwmc5 - PAR 32403 - 03 Sep 2013
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;
	return locns;
epilog
 // do not delete locns
end;</source>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <ReturnType type="CM_ObjectArray"/>
    </JadeMethod>
