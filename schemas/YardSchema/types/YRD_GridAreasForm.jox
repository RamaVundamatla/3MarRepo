    <JadeMethod name="mnuYADeckingOptions_click" id="97f808d3-caf6-4206-802c-d5634da055f5">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuYADeckingOptions_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2009	cnwjk3	SFW1030

*/

vars
	terminalArea, proxyTerminalArea : CM_TerminalArea;
	theForm : CMUI_DeckingRulesForm;
begin
	if self.mnuYADeckingOptions.caption = "Decking Options" then
		self.tblYAM.editDeckingOptions();
	else
		if CM_TerminalArea.hasInstance(menuItem.userObject) then
	
			terminalArea := menuItem.userObject.CM_TerminalArea;
	 
			if terminalArea &lt;&gt; null then
				theForm := app.loadForm(CMUI_DeckingRulesForm, CMUI_Assistant, false, false, false, 
						terminalArea.myTerminal, null).CMUI_DeckingRulesForm;
				
				if theForm = null then
					return;
				endif;	
				proxyTerminalArea := app.createUpdateProxy(terminalArea).CM_TerminalArea;	
				theForm.onCreate(proxyTerminalArea.myYADeckingOptions, null, terminalArea);
				theForm.setParentForm(self);
				theForm.showModal();
			endif;		
		endif;
	endif;
epilog
	delete proxyTerminalArea;			
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
