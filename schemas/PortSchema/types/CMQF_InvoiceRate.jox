    <JadeMethod name="getMyBank" id="ea9da04c-1a47-41d4-bebd-fef914bea552">
        <source>getMyBank():CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_Bank;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myBank;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
