    <JadeMethod name="isDirectionDifferent" id="8ae6ceb3-6754-467e-b4ff-6d8de2402606">
        <source>isDirectionDifferent(_other : SelfType):Boolean;
// ---------------------------------------------------------------------------
// Created:     25 August 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
