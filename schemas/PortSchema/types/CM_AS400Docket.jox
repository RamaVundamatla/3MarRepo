    <JadeMethod name="getDate" id="eadb6bc7-3a41-407b-9546-59351a8c9532">
        <source>getDate(_date : String) : Date;

vars

	year	: String;
	month	: String;
	day		: String;
	date	: Date;

begin

	if _date.length = 5 then
		year 	:= _date[1:1];
		month	:= _date[2:2];
		day		:= _date[4:2];
	date.setDate(day.Integer, month.Integer, year.Integer);
	endif;
	return date;


end;</source>
        <Parameter name="_date" type="String"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDateIn" id="70e64880-3704-4843-b28b-02df49fadfc9">
        <source>getDateIn() : Date;

vars

	sixMthsAgo,
	today,
	date		: Date;

begin
	
	sixMthsAgo 	:=  today.cnEcAddMonths(-6);
	date := getDate(self.dateIn);
	if date.isValid then
		if date &gt; sixMthsAgo then
			return date;
		else
			app.writeLog('INFO &gt;&gt; Invalid receival date. Setting docket ' &amp; self.docket &amp; ' to ' &amp; sixMthsAgo.String, LogINFO);
			return sixMthsAgo;
		endif;
	endif;
	app.writeLog('INFO &gt;&gt; Invalid receival date. Setting docket ' &amp; self.docket &amp; ' to ' &amp; today.String, LogINFO);
	return today;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getFellDate" id="70b71003-0797-4f8b-9435-2d88c2551da0">
        <source>getFellDate() :Date;

vars

	sixMthsAgo,
	today,
	date		: Date;

begin

	sixMthsAgo :=  today.cnEcAddMonths(-6);
	date := getDate(self.fellDate);
	if date.isValid and date &gt; sixMthsAgo then
		return date;
	endif;
	date := getDateIn();
	app.writeLog('INFO &gt;&gt; Invalid fell date. Setting docket ' &amp; self.docket &amp; ' to ' &amp; date.String, LogINFO);
	return date;
	
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="processExtra" id="68dce066-17d0-43d5-bd9f-68a02b1b028f">
        <updating/>
        <source>processExtra(_species, _grade, _type : String) updating;

vars

begin

	if _species = 'CH' and _type = 'S' then
		self.type := null;
	else
		self.type := _type;
	endif;
		
	if _species &lt;&gt; 'CH' or _species.length &lt; 2 then
		self.species	:= _species;
		self.grade 		:= _grade;
		return;
	endif;
		
	self.species	:= _species[1:1];
	self.grade		:= _grade &amp; _species[2:end];

end;</source>
        <Parameter name="_species" type="String"/>
        <Parameter name="_grade" type="String"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
