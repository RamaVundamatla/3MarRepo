<CollClass name="CM_TIArray" id="f827bd52-3bf0-42c2-8bb7-86bcd2ccccb7">
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="trakitem"/>
    <JadeMethod name="includesTiThatHasDocActions" id="8c22eca1-0f3e-41af-ada2-736a776bd081">
        <source>includesTiThatHasDocActions():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2017	cnwndl1	Initial creation	TFS 3299

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;

begin

	if self.isEmpty then
		return false;
	endif;
	
	create resDetailSet transient;
	create bookingItemSet transient;

	iter := self.createIterator;
	while iter.next( ti ) do
		if ti.hasDocumentActions( resDetailSet, bookingItemSet ) then
			return true;
		endif;
	endwhile;

	return false;

epilog

	delete iter;
	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
