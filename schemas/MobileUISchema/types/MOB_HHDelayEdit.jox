    <JadeMethod name="handleBtnTwo" id="f2476cb9-cc38-4450-8fbc-02ea5cead48b">
        <updating/>
        <source>handleBtnTwo() updating, protected;
// Delete
vars
	oidString	: String;
begin
	// save off machine oid from delay before delete
	if self.myDelay.myMachine &lt;&gt; null then
		oidString := self.myDelay.myMachine.getOidString();
	endif;
	if not self.doDelete() then
		return;
	endif;
	
	self.myMobileGenericAgent.setStringField1(oidString);
	self.doBackButtonClick();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateControls" id="f038554c-bfc5-4eaf-94e3-995f349a28a5">
        <updating/>
        <source>populateControls() updating, protected;
// populate from the selected delay
vars
	startLocal,
	estEndLocal,
	endLocal:	TimeStamp;
begin

	self.cmbDriver.listCollection(app.myRoot.allUsers, true, 0);
	if self.myDelay.myDriver &lt;&gt; null and
	   self.cmbDriver.findObject(self.myDelay.myDriver) &gt; 0 then
		self.cmbDriver.listObject := self.myDelay.myDriver;
	endif;
	
	self.populateDelayTypeCombo();
	
	self.populateWorkPointsCombo();	// 21 Jun 2012	NDL	Par 29689

	startLocal := self.systemToLocalTime(self.myDelay.startDT);
	estEndLocal := self.systemToLocalTime(self.myDelay.estEndDT);	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
	endLocal := self.systemToLocalTime(self.myDelay.endDT);
	
	// date and time fields are formatted to a given format to avoid users needing to enter '/' and ':' characters on a hand-held
	self.txtStartDate.setDate(startLocal.date);
	self.txtStartTime.setTime(startLocal.time);	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support

	self.txtEstEndDate.setDate(estEndLocal.date);	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
	self.txtEstEndDate.enabled := false;
	self.txtEstEndTime.setTime(estEndLocal.time);	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
	self.txtEstEndTime.enabled := false;

	if endLocal.isValid() then
		self.txtEndDate.setDate(endLocal.date);	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
		self.txtEndTime.setTime(endLocal.time);
	endif;
	
	if self.myDelay.remarks = null then
		self.txtRemarks.text := self.lblRemarks.caption;
	else
		self.txtRemarks.text := self.myDelay.remarks;
	endif;
	if endLocal.isValid() then
		self.txtPlusHrs.enabled := false;
		self.txtPlusMins.enabled := false;
		self.lblPlus.enabled := false;	// disabled text box looks the same as enabled, disabled the labels as well to get a visual effect
		self.lblPlusHrs.enabled := false;
		self.lblPlusMins.enabled := false;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateDelayForSave" id="b979d6c6-651f-4c5f-bb55-116b60f969f0">
        <updating/>
        <source>populateDelayForSave(_delay : CM_Delay input) : Boolean updating, protected;
// populate the delay proxy object from the control values
vars
	errorMsg		: String;
	date			: Date;
	time			: Time;
	endDT,
	startDT,
	estEndDT		: TimeStamp;
	voyage 			: CM_Voyage;
	delayType		: CM_DelayType;
	machine			: CM_Machine;
	driver			: CM_User;
	workPoint		: CM_WorkPoint;
	remarks			: String;
	
begin
	endDT := null;

	date := self.txtEndDate.getDate(errorMsg);
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblEndTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		self.txtEndDate.setFocus();
		return false;
	endif;
	if date.isValid() then
		endDT.setDate(date);
	endif;

	time := self.txtEndTime.getTime(errorMsg);
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblEndTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		self.txtEndTime.setFocus();
		return false;
	endif;
	if time.isValid() then
		endDT.setTime(time);
	endif;
	
	startDT.setDate(self.txtStartDate.getDate(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblStartTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		self.txtStartDate.setFocus();
		return false;
	endif;

	startDT.setTime(self.txtStartTime.getTime(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblStartTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		self.txtStartTime.setFocus();
		return false;
	endif;
	
	estEndDT.setDate(self.txtEstEndDate.getDate(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblEstEndTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		return false;
	endif;

	estEndDT.setTime(self.txtEstEndTime.getTime(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(self.lblEstEndTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		return false;
	endif;

	voyage := self.myDelay.myVoyage;
	delayType := self.cmbDelayType.listObject.CM_DelayType;
	machine := self.myDelay.myMachine;
	driver 	:= self.cmbDriver.listObject.CM_User;
	workPoint := self.cmbWorkPoint.listObject.CM_WorkPoint;	// 21 Jun 2012	NDL	29689
	remarks := self.txtRemarks.text.asStringJMT;
	if remarks = self.lblRemarks.caption then		// default value
		remarks := null;
	endif;
		
	_delay.setProxy(self.myTerminal,
					voyage,
					delayType,
					self.localToSystemTime(startDT),
					self.localToSystemTime(estEndDT),	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
					self.localToSystemTime(endDT),
					machine,
					driver,
					workPoint,	// 21 Jun 2012	NDL	29689
					remarks);
					
	return true;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_delay" type="CM_Delay" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateDelayTypeCombo" id="1bcb99b6-d59c-4141-bd1d-cf08302e3715">
        <updating/>
        <source>populateDelayTypeCombo() updating, protected;
// populate the delay type combo, select the current one
vars
	obj		: Object;
	dd		: DynaDictionary;
	type	: CM_DelayType;
	delayTypeGroup	: CM_DelayTypeGroup;
begin
	create dd transient;
	
	dd.setMembership(CM_DelayType);
	dd.addMemberKey(CM_DelayType::delayTypeOrder.name, false, false);
	dd.endKeys(true);
	
	// get the terminal config delay type group, if any
	delayTypeGroup := self.myTerminal().getConfig(HhDelayTypeGroup).CM_DelayTypeGroup;
	foreach type in app.myRoot.allDelayTypes do
		if type.isNotAvailableForEntry then
			continue;
		endif;
		if delayTypeGroup &lt;&gt; null then
			if not delayTypeGroup.allDelayTypes.includes(type) then
				continue;
			endif;
		endif;
		
		dd.add (type);
	endforeach;
	// make sure we include the type to be selected
	if not dd.includes (self.myDelay.myDelayType) then
		dd.add (self.myDelay.myDelayType);
	endif;
	// load up the combo
	self.cmbDelayType.clear;
	self.cmbDelayType.sorted := false;
	foreach obj in dd do
		type := obj.CM_DelayType;
		self.cmbDelayType.itemObject[self.cmbDelayType.addItem(type.description)] := type;
	endforeach;
	
	// select _type
	self.cmbDelayType.listObject := self.myDelay.myDelayType;

epilog
	delete dd;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateDriverCombo" id="bbb4506f-fb02-4310-91b4-f04f11ec4a5d">
        <updating/>
        <source>populateDriverCombo() updating, protected;
// populate the driver combo, select the current one
vars
	obj		: Object;
	user	: CM_User;
begin
	// load up the combo
	self.cmbDriver.clear;
	self.cmbDriver.sorted := false;
	self.cmbDriver.itemObject[self.cmbDriver.addItem(self.lblDriver.caption)] := null;
	foreach user in app.myRoot.allUsers do
		if user.isNotAvailableForEntry or
		   user.code.trimBlanks.toUpper = 'SUPERUSER' then
			continue;
		endif;
		
		self.cmbDriver.itemObject[self.cmbDriver.addItem(user.userName &amp; ' (' &amp; user.code &amp; ')')] := user;
	endforeach;
	if self.myDelay.myDriver &lt;&gt; null and
	   self.cmbDriver.findObject(self.myDelay.myDriver) &gt; 0 then
		self.cmbDriver.listObject := self.myDelay.myDriver;
	else
		self.cmbDriver.listIndex := 1;
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateWorkPointsCombo" id="5f201739-f44b-4bb9-a92e-b51ead47e437">
        <updating/>
        <source>populateWorkPointsCombo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2012	cnwndl1	Initial creation	par 29689

*/

vars

	voyage : CM_Voyage;
	objSet : CM_ObjectSetActual;
	obj : CM_Object;
	workPoint : CM_WorkPoint;
	index : Integer;
	iter : Iterator;

begin

	self.cmbWorkPoint.clear;
	self.cmbWorkPoint.sorted := false;
	self.cmbWorkPoint.itemObject[self.cmbWorkPoint.addItem(self.lblWorkPoint.caption)] := null;

	if self.myDelay.myVoyage &lt;&gt; null then
		voyage := self.myDelay.myVoyage;
	endif;
	
	if voyage &lt;&gt; null then
		create objSet transient;
		voyage.findAllMyCranesAndWorkpoints( objSet );
		foreach obj in objSet where obj.isKindOf( CM_WorkPoint ) do
			workPoint := obj.CM_WorkPoint;
			index := self.cmbWorkPoint.addItem(workPoint.code);
			self.cmbWorkPoint.itemObject[index] := workPoint;
			self.cmbWorkPoint.itemEnabled[index] := not workPoint.isNotAvailableForEntry;
		endforeach;
		
	elseif self.myTerminal &lt;&gt; null then
		iter := self.myTerminal.allWorkPointsByCode.createIterator;
		while iter.next( workPoint ) do
			if workPoint.isNotAvailableForEntry then
				continue;
			endif;
			index := self.cmbWorkPoint.addItem(workPoint.code);
			self.cmbWorkPoint.itemObject[index] := workPoint;
		endwhile;
		
	endif;

	workPoint := null;
	if self.myDelay &lt;&gt; null then
		workPoint := self.myDelay.myWorkPoint;
	endif;
	
	if workPoint &lt;&gt; null then
		index := self.cmbWorkPoint.findObject(workPoint);
		if index &lt; 1 then
			index := self.cmbWorkPoint.addItem(workPoint.code);
			self.cmbWorkPoint.itemObject[index] := workPoint;
			self.cmbWorkPoint.itemEnabled[index] := false;
		endif;
		self.cmbWorkPoint.listIndex := index;
		
	else
		self.cmbWorkPoint.listIndex := 1;
		
	endif;

epilog

	delete objSet;
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshEstEndTime" id="a28d65da-01a3-4937-8239-515711825e46">
        <updating/>
        <source>refreshEstEndTime() updating, protected;
// called on lostFocus of the start date/time and duration hours/mins text fields to refresh the displayed estimated end time
vars
	errorMsg	: String;
	startDate	: TimeStamp;
	durationHours,
	durationMins	: Integer;
	estEndDate	: TimeStamp;
begin
	if not self.txtPlusHrs.enabled then
		return;
	endif;
	startDate.setDate(self.txtStartDate.getDate(errorMsg));
	startDate.setTime(self.txtStartTime.getTime(errorMsg));
	durationHours := self.txtPlusHrs.text.Integer;
	durationMins := self.txtPlusMins.text.Integer;
	if durationMins &gt; 59 then
		durationMins := 59;
		self.txtPlusMins.text := durationMins.String;	
	endif;
	estEndDate := startDate;
	estEndDate := estEndDate.addHours(durationHours);
	estEndDate := estEndDate.addMinutes(durationMins);

	if estEndDate.isValid then
		self.txtEstEndDate.setDate(estEndDate.date);
		self.txtEstEndTime.setTime(estEndDate.time);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControls" id="e850ac38-12e2-4beb-b82d-bdbd2dfeeaf3">
        <updating/>
        <source>setupControls() updating, protected;
// position the controls
vars
	
begin

	self.doResizeControls(true);
	
	if self.myDelay.myMachine = null then
		self.cmbDriver.enabled := false;
	endif;
	self.cmbDelayType.setFocus();
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1af73650-bdb4-4571-818b-22d1270294c6">
        <updating/>
        <source>setupForm() updating, protected;

vars
	msg	: String;
begin
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	inheritMethod();
	
	self.myDelay := self.myMobileGenericAgent.stringField1.asOid.CM_Delay;
	self.setupCmdButtons( 3, app.getErrorString(Save), app.getErrorString(Delete_Caption), app.getErrorString(Back), null, null );
	
	if self.myDelay.myVoyage &lt;&gt; null then
		msg := app.getErrorString(Voyage) &amp; " " &amp; self.myDelay.myVoyage.code &amp; " ";
	endif;
	if self.myDelay.myMachine &lt;&gt; null then
		msg := msg &amp; app.getErrorString(Machine) &amp; " " &amp; self.myDelay.myMachine.code;
	endif;
	self.lblVoyageMachine.caption := msg;

	self.setupControls();
	
	self.populateControls();

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5958191b-ace3-4c85-b6a9-2db17125b378">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016589, locale);
	lblDelayType.translateCaption(Xlat_0016590, locale);
	lblDriver.translateCaption(Xlat_0016591, locale);
	lblEndTime.translateCaption(Xlat_0016592, locale);
	lblEstEndTime.translateCaption(Xlat_0016593, locale);
	lblPlus.translateCaption(Xlat_0016594, locale);
	lblPlusHrs.translateCaption(Xlat_0016595, locale);
	lblPlusMins.translateCaption(Xlat_0016596, locale);
	lblRemarks.translateCaption(Xlat_0016597, locale);
	lblStartTime.translateCaption(Xlat_0016598, locale);
	lblVoyageMachine.translateCaption(Xlat_0016599, locale);
	lblWorkPoint.translateCaption(Xlat_0018054, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
