    <JadeMethod name="getConnectDTLocalTZ" id="2c170862-2f5d-4a66-a421-e62e08bbd744">
        <source>getConnectDTLocalTZ(): TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
02 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.connectDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="selectionCriteria" id="ba6a1744-0b0d-4f1a-8034-145fa2dfd9cd">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteria(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	04 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
begin
	inheritMethod(set, _value);

	if set then
		return;
	endif;
	
	str :=_value;
	
	if self.connected &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Connected:";
		else
			str :=              "Connected:";
		endif;
	endif;

	if self.connectDT &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Connect Time:";
		else
			str :=              "Connect Time:";
		endif;
	endif;

	if self.qryAvaGradesStr &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Avail. Grades:";
		else
			str :=              "Avail. Grades:";
		endif;
	endif;

	if self.qryPackAreasStr &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Pack Areas:";
		else
			str :=              "Pack Areas:";
		endif;
	endif;

	if self.packByDate.isValid then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Pack By Date:";
		else
			str :=              "Pack By Date:";
		endif;
	endif;
// cnwdad1 16/08/2010 - PAR #25218.
	if self.fromPackByDate.isValid() then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Pack By Date From:";
		else
			str :=              "Pack By Date From:";
		endif;
	endif;
	if self.toPackByDate.isValid() then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Pack By Date To:";
		else
			str :=              "Pack By Date To:";
		endif;
	endif;
epilog
	_value := str;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="selectionCriteriaValues" id="95bee1b6-d000-4c12-9dd5-498370165893">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteriaValues(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	05 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
begin
	inheritMethod(set, _value);

	if set then
		return;
	endif;
	
	str :=_value;
	
	if self.connected &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.connected.getYesNo;
		else
			str :=              self.connected.getYesNo;
		endif;
	endif;

	if self.connectDT &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.connectDT.shortCurrentLocaleFormat;
		else
			str :=              self.connectDT.shortCurrentLocaleFormat;
		endif;
	endif;

	if self.qryAvaGradesStr &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qryAvaGradesStr;
		else
			str :=              self.qryAvaGradesStr;
		endif;
	endif;

	if self.qryPackAreasStr &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qryPackAreasStr;
		else
			str :=              self.qryPackAreasStr;
		endif;
	endif;

	if self.packByDate.isValid then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.packByDate.shortFormat();
		else
			str :=              self.packByDate.shortFormat();
		endif;
	endif;
// cnwdad1 16/08/2010 - PAR #25218.
	if self.fromPackByDate.isValid() then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.fromPackByDate.shortFormat();
		else
			str :=              self.fromPackByDate.shortFormat();
		endif;
	endif;
	if self.toPackByDate.isValid() then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.toPackByDate.shortFormat();
		else
			str :=              self.toPackByDate.shortFormat();
		endif;
	endif;
epilog
	_value := str;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
