<Class name="HMS_MovementEdit" id="27a8457e-2a00-4e18-9efd-ece953b2f91f">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <JadeMethod name="createPropertyChanges" id="3f9d6aa1-5402-4dea-be9a-ed1ea196802d">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	workingMovement : CMIF_HMS_WorkingMovement;
 	tmpProxy : HMS_Object;
begin
	inheritMethod(_cmifTrans);
	workingMovement := _cmifTrans.myWorkingMovement;
	tmpProxy := _cmifTrans.myProxyHMSObject;
	if workingMovement &lt;&gt; null then
		self.myMovement.createPropertyChanges(self, workingMovement);
	elseif HMS_VoyageMovement.hasInstance(tmpProxy) then
		self.myMovement.createPropertyChangesFromProxy(self, tmpProxy.HMS_VoyageMovement);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="fa225e0f-b132-48e6-b96f-5f1553016cc7">
        <updating/>
        <source>setTypeDetails() updating, protected;

vars

begin
 	// Set type and typeString
	type:=TRANS_TYPE_EditMovement;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="c3afc8c3-066c-4dfa-a725-c2d1a8f91246">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myVoyageMovement = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Movement', 'Null', null, null);
		return false;
	endif;	

	if _transController.myWorkingMovement = null
	and _transController.myProxyHMSObject = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Working Movement', 'Null', null, null);
		return false;
	endif;
	
	return rtnValue;
							
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
