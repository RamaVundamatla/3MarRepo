    <JadeMethod name="uDeleteWagonNDL" id="19f31836-92a1-401b-913c-f8db37869f2f">
        <source>uDeleteWagonNDL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2013	cnwndl1	Initial creation

*/

vars

	wagons : CM_WagonSet;
	iter : Iterator;
	wagon : CM_Wagon;
	invalidWagon : Boolean;
	invalidTi : Boolean;
	invalidBulk : Boolean;
	edition : Integer;
	trx : CM_EventTransaction;
	audit : CM_AuditObject;
	ti : CM_TrackedItem;
	bulk : CM_BulkRelease;
	msg : String;
	now : TimeStamp;
	yaType : CM_YATypeTrain;
	term : CM_Terminal;
	train : CM_Train;
	
begin

	term := app.myRoot.allTerminals.getAtKey("T01");
	train := term.getNullTrain;
	
	app.myPassport.setMyTerminal(term);

	if train = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, wagon, invalidWagon );
	create wagons transient;

	iter := train.allWagonsByIdInward.createIterator;
	while iter.next( wagon ) do
		invalidWagon := false;
		edition := wagon.edition;
		if not invalidWagon then
			wagons.addNoDuplicates(wagon,false);
		endif;
	endwhile;
	
/*	delete iter;
	iter := train.allWagonsByIdOutward.createIterator;
	while iter.next( wagon ) do
		invalidWagon := false;
		edition := wagon.edition;
		if not invalidWagon then
			wagons.addNoDuplicates(wagon,false);
		endif;
	endwhile;
*/	
	delete iter;
	iter := wagons.createIterator;
	while iter.next( wagon ) do
		if wagon.myTerminalDeparted = null then
			continue;
		endif;
		write wagon.id;
		self.deleteWagonAndAssociatedObjs(wagon);
	endwhile;
	
	

epilog

	delete wagons;
	delete iter;

end;</source>
