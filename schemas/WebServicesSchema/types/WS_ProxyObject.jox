<Class name="WS_ProxyObject" id="d5c77e57-0e33-4d68-bbad-8bddb5eb181f">
    <superclass name="WS_Object"/>
    <transient/>
    <subclassTransientAllowed/>
    <abstract/>
    <PrimAttribute name="cmObjectEdition" id="b5154286-34e4-4905-be00-d13b0e159ec6">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>The JADE edition of the object.</text>
    </PrimAttribute>
    <PrimAttribute name="cmObjectId" id="0ddb87e2-8f5e-4cb2-958d-cedde9421efe">
        <type name="String"/>
        <access>readonly</access>
        <text>The JADE object identifier (OID).</text>
    </PrimAttribute>
    <JadeMethod name="setOidDetails" id="12f60b6b-6845-4beb-90cd-25932db262e8">
        <updating/>
        <source>setOidDetails(_object : Object) updating;
/*

Date		Who		Reason
03 October 2016	cnwer1	Initial creation TFS 2526

*/

vars

begin
	if _object = null then
		return;
	endif;
	self.cmObjectEdition	:= _object.edition();
	self.cmObjectId			:= _object.getOidAsString();
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setOidDetailsForNonObject" id="6c3ed266-121c-47a0-9853-7dbc72e3a42a">
        <updating/>
        <source>setOidDetailsForNonObject(_quasiOid : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
//
vars

begin
	self.cmObjectId := _quasiOid;
epilog

end;</source>
        <Parameter name="_quasiOid" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="1d08c766-275f-4290-a7c7-d09c21022825">
        <updating/>
        <source>setProxyFromObject(_object : Object) updating;

/*

Purpose:			Set the properties ont he receiver from the persistent it is based on

Parameters:			Persistent CM_Object that is being represented

Return Value:		None


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
23 Sep 2008 KO		Added CM OID &amp; edition attributes
*/

vars

begin
	self.cmObjectEdition	:= _object.edition();
	self.cmObjectId			:= _object.getOidAsString();
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
