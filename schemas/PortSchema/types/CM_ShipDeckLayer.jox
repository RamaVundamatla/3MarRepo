    <JadeMethod name="setForCreate" id="c4673e4e-2ebd-4178-b2b9-a34e1cffc66c">
        <updating/>
        <source>setForCreate(_pxyMe : CM_ShipDeckLayer) updating;
// ---------------------------------------------------------------------------
// Created:     22 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.code := _pxyMe.code;
	self.description := _pxyMe.description;
	self.remarks := _pxyMe.remarks;
	self.visible := _pxyMe.visible;
	
	self.myShipDeck := _pxyMe.myShipDeck.pxyGetRealObject();
	if self.myShipDeck = null then
	self.myShipDeck := _pxyMe.myShipDeck;
	endif;
epilog

end;</source>
        <Parameter name="_pxyMe" type="CM_ShipDeckLayer"/>
    </JadeMethod>
