<GUIClass name="SOP_TerminalAreaDefMaintForm" id="05dadaff-77eb-4c3f-b279-796cb08fb25f">
    <superclass name="SOP_WorkAreaMaintForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="mySubTerminal" id="44d79689-7788-4e4c-8199-8049eea23ddb">
        <embedded/>
        <type name="CM_SubTerminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doLoadSubObjects" id="a720c9cd-277f-465f-a6d8-fb378eef6753">
        <source>doLoadSubObjects(_ta: CM_TerminalArea): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2014	cnwndl1	Initial creation	Par 35295
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	iter : Iterator;
	lc : CM_LocationsController;

begin

	if _ta.mySubTerminalAreaDef &lt;&gt; null then
		return true;
	else
		if _ta.isGeneralCargoAllocArea then													// TFS 49453
			iter := _ta.CM_GeneralCargoAllocRowArea.allRowControllersById.createIterator;	// TFS 49453
		else																				// TFS 49453
			iter := _ta.allLocationsControllers.createIterator;
		endif;																				// TFS 49453
		while iter.next( lc ) do
			if lc.getMySubTerminalAreaDef &lt;&gt; null then
				return true;
				break;
			endif;
		endwhile;
		delete iter;
	endif;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="e154bac7-eb97-4228-b29a-14af3f3e5ac6">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	pxySubTerminalAreaDef : CM_SubTerminalAreaDef;
	load : Boolean;
	warningsResult : Integer;
	realSubTerminalAreaDef : CM_SubTerminalAreaDef;
	msg : String;
	preUpdateTiSet : CM_TISet;

begin

	if self.myCurrentWorkArea &lt;&gt; null then
		app.cmsBeginLoad( load );
		pxySubTerminalAreaDef := self.myCurrentWorkArea.CM_SubTerminalAreaDef.pxyCreateUpdateProxy();
	else
		create pxySubTerminalAreaDef transient;
	endif;
	
	pxySubTerminalAreaDef.setProxy(	self.txtCode.text.trimBlanks[1:10],	//_code : String;
									self.txtDescription.text.trimBlanks,	//_description : String;
									self.chkAvailable.value,	//_notAvailable : Boolean;
									self.allSelectedObjects,	//_allSelectedObjects : ObjectSet;
									self.mySubTerminal,	//_mySubTerminal : CM_SubTerminal;
									self.myTerminal	//_myTerminal : CM_Terminal
									);
								
	while true do
	
		create preUpdateTiSet transient;
		if self.myCurrentWorkArea &lt;&gt; null then
			realSubTerminalAreaDef := self.myCurrentWorkArea.CM_SubTerminalAreaDef;
			self.myCurrentWorkArea.getAllTisInArea( preUpdateTiSet);
			app.myTrxUA.trxUpdateSubTerminalAreaDef(pxySubTerminalAreaDef, app.myPassport);
			
		else
			app.myTrxCA.trxCreateSubTerminalAreaDef(pxySubTerminalAreaDef, realSubTerminalAreaDef, app.myPassport);
			self.myCurrentWorkArea := realSubTerminalAreaDef;
			
		endif;
		
		if app.myPassport.trxCompletedOK then
			//msg := "Do you want to reset the sub-terminal / business unit attributes of effected on-site cargo now?";
			//if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) = MsgBox_Return_Yes then
			//	self.myTerminal.updateSubTermForCargo(false,true);
			app.myTrxUA.trxUpdSubTermForCargoItems( false, false, realSubTerminalAreaDef, preUpdateTiSet, app.myPassport );	//11 May 2015	NDL	Par 36181
			if not app.myPassport.trxCompletedOK then
				if not app.myPassport.trxCompletedOK then
					msg := app.getErrorString(Faile_reset_effec_cargo_pleas_) &amp; " '" &amp; app.getErrorString(Resync_subter_busine_unit_carg) &amp; "'";
					app.createAlert( "Sub Terminal Area definition '" &amp; realSubTerminalAreaDef.mySubTerminal.description &amp; "' updated - " &amp; msg, true );
					app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
				endif;
			endif;
			//endif;
			return true;
		else
			warningsResult := app.showErrorWarningDialog(pxySubTerminalAreaDef.code, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if warningsResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
			else
				self.clearErrorWarnings();
				return false;
			endif;
		endif;
		
	endwhile;

epilog

	delete pxySubTerminalAreaDef;
	delete preUpdateTiSet;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getColourLegendLines" id="edf5ea98-f642-4b56-a2a7-245341445ec2">
        <source>getColourLegendLines(colLegend: CMUI_ColourLegend input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2015	cnwndl1	Initial creation

*/

vars

	areaString : String;

begin
	
	inheritMethod( colLegend );
	
	areaString := app.getErrorString(Sub_terminal);
	
	colLegend.addLegendItem( app.getErrorString1(Item_selected_current, areaString), self.tblAreas.foreColor, self.Colour_SelectedInCurrent, null, false);
	colLegend.addLegendItem( app.getErrorString1(Item_child_items_select_curren, areaString),  self.tblAreas.foreColor, self.Colour_ChildItemsIncluded, null, false);
	colLegend.addLegendItem( app.getErrorString1(Item_inclu_curre_withi_anoth_a, areaString), self.tblAreas.foreColor, self.Colour_IncludedInCurrent, null, false);
	colLegend.addLegendItem( app.getErrorString1(Item_included_another, areaString), self.tblAreas.foreColor, self.Colour_IncludedInAnother, null, false);

epilog

end;</source>
        <Parameter name="colLegend" type="CMUI_ColourLegend" usage="input"/>
    </JadeMethod>
    <JadeMethod name="locationAlreadyUsed" id="7a6802a7-449e-4682-b2fb-ebe51a223e16">
        <source>locationAlreadyUsed(_location: CM_Object): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

begin

	if _location.isKindOf(CM_LocationsController) then
		return _location.CM_LocationsController.isInAnySubTermExcluding( self.myCurrentWorkArea.CM_SubTerminalAreaDef );
	elseif _location.isKindOf(CM_GridObject) then
		return _location.CM_GridObject.isInAnySubTermExcluding( self.myCurrentWorkArea.CM_SubTerminalAreaDef );
	elseif _location.isKindOf(CM_TerminalArea) then
		return _location.CM_TerminalArea.isInAnySubTermExcluding( self.myCurrentWorkArea.CM_SubTerminalAreaDef );
	else
		return inheritMethod(_location);
	endif;

epilog

end;</source>
        <Parameter name="_location" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMySubTerminal" id="37cd0eaa-bfbf-4c6a-94e6-5a2d7f98484f">
        <updating/>
        <source>setMySubTerminal( _subTerm : CM_SubTerminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

begin

	self.mySubTerminal := _subTerm;

	if _subTerm &lt;&gt; null then
		self.setMyCurrentWorkArea( _subTerm.mySubTerminalAreaDef );
	endif;

epilog

end;</source>
        <Parameter name="_subTerm" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="428a911f-38c4-46b9-bd7b-0952a3368119">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	self.chkAvailable.visible := false;
	self.txtCode.enabled := false;
	self.txtCode.maxLength := 30;
	self.txtCode.text := self.mySubTerminal.code;
	self.txtDescription.enabled := false;
	self.txtDescription.maxLength := 100;
	self.txtDescription.text := self.mySubTerminal.description;
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, PmAdmSubTerminalMaint) then
		self.tblAreas.userInputEnabled := false;
		self.btnSave.enabled:= false;
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9042a0eb-cd8d-4480-a6eb-551ce06ae3f9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 05 December 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020003, locale);
end;</source>
    </JadeMethod>
</GUIClass>
