    <JadeMethod name="addButton" id="ddff7286-35dc-4a8a-a9a2-3da33c96fa8d">
        <updating/>
        <source>addButton(_button : CMUI_ButtonForToolbar; _alignment : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
begin

	self.addButtonAt(_button, 0, _alignment);

end;</source>
