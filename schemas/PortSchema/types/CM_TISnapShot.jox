    <JadeMethod name="getCurrentRemarks" id="472f4f46-8f1f-4edf-a86e-6c7c1e5e8ecb">
        <source>getCurrentRemarks() : String;
// ---------------------------------------------------------------------------
// Created:     03 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	returnVal		: String;
	invalid 		: Boolean;
	sShotOf			: CM_Object;
begin
	sShotOf := self.snapShotOf;
	if (not CM_TrackedItem.hasInstance(sShotOf)) then
		return null;
	endif;

	on Exception do app.handleDeletedObject(exception, sShotOf, invalid);
	returnVal := sShotOf.CM_TrackedItem.remarks;
	
	return returnVal;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
