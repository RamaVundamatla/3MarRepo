    <JadeMethod name="getTareWeight" id="2803a8bd-7ee9-4003-86e7-392c35ec026a">
        <source>getTareWeight():Decimal;
// ---------------------------------------------------------------------------
// Created:     18 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Returns either tare weight for the receiver or if this is 0 then
//				default tare weight from container range or iso type
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tareWeight	:Decimal[14,4];
begin
	tareWeight := self.tWeight;
	
	if tareWeight = null then
		tareWeight := self.getDefaultTareWeight;
	endif;
	
	return tareWeight;
epilog

end;</source>
