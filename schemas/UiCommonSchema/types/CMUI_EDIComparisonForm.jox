    <JadeMethod name="handleNotification" id="e9998479-5889-4734-8f2f-b3eba66ece89">
        <updating/>
        <source>handleNotification(_event: Integer; _object: CM_Object; _tag: Integer) updating;
/*
Date		Who		Reason
21 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars

begin
	if _event = Object_Update_Event then
		// something else we displayed has been updated - better re-display the form
		self.doRefreshWithTimer;
	elseif _event = Object_Delete_Event then
		if _object = self.myEDIData then
			// ediData has been deleted - display message and close the form
			app.msgBox (app.getErrorString (User_Deleted_EDIData), self.caption, MsgBox_OK_Only);
			
			self.unloadForm; 
		else
			// something else we displayed has been deleted - better re-display the form
			self.doRefreshWithTimer;
		endif;	
	endif;
epilog

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_tag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="highlightJadeTableElement" id="d1f26ddd-f90b-4396-a3aa-7e00ed6a990c">
