    <JadeMethod name="actionForCancelled" id="45f216b1-e034-4d94-ad9f-d19b48f27298">
        <updating/>
        <source>actionForCancelled(_voyage: CM_Voyage input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2018	jlger1	Initial creation
11 Oct 2021	jlier1	TFs 51963 
*/

vars
	voyage : CM_Voyage;
	departure :HMS_VoyageMovement;
	newStatus : CM_VoyageStatus;
begin
	voyage:=self.getMyVoyageObject;
	//if self.myWorkOrderToCancel.allWoDtls.first &lt;&gt; null and self.myWorkOrderToCancel.allWoDtls.first.isKindOf(CM_WodExtension) and self.myWorkOrderToCancel.taskStatus = WO_STATUS_COMPLETE then
	if self.oldDepartureDT &lt;&gt; null then
		voyage.setDepartureDT(self.oldDepartureDT);
		
		// also change the date on the departure movement
		departure := voyage.getMovementDeparture;
		if departure &lt;&gt; null then
			departure.setOccursOnDT(self.oldDepartureDT);
		endif;
	endif;


epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionItems" id="426fb452-cfa8-4073-a1a0-9ec5a09c5200">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 14/06/2018	jlgdap1		TFS 39165 PEL1 Voyage Work Order Transactions
// 03/04/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels that use a Ramp
//
vars
	voyage : CM_Voyage;
	departure : HMS_VoyageMovement;

begin
	// change my voyage's departure date / time
	voyage := self.getMyVoyageObject;
	if voyage &lt;&gt; null then
		self.oldDepartureDT:=voyage.departedDT;
		voyage.setDepartureDT(self.occursOnDT);
		
		// also change the date on the departure movement
		departure := voyage.myHMSVoyageData.allVoyageMovements.last;
		if departure.moveType = HMSMovementTypeDeparture then
			departure.setOccursOnDT(self.occursOnDT);
				/* Ian says 'don't tick any box automatically and leave it up to the user to confirm on the movement 
									when the vessel moves away from the berth if the ramp was actually used there.'
			if departure.myMarineServiceTimings &lt;&gt; null and self.hasRamp then			// TFS 43694
				departure.myMarineServiceTimings.setHasRamp(self.hasRamp);				// TFS 43694
			endif;																		// TFS 43694
				*/
		endif;
		
		if self.myRelatedPermitRequest &lt;&gt; null then
			//create any cargo equipment resources 
			app.myUtilityCA.utlAddHMSResources(self.myRelatedPermitRequest.allMarineServiceDetails, null, self.getHarbour, departure.myPreviousMovement.HMS_VoyageMovement, _passport);
		endif;
		
		//19 Feb 2019	NDL	TFS 43374
		if not self.allMarineServiceDetails.isEmpty then
			app.myUtilityCA.utlAddHMSResources(self.allMarineServiceDetails, null, self.getHarbour, departure, _passport);
		endif;
		
	endif;
	
	if _passport.noErrors then
		self.setIsComplete;
		// create the appropriate transaction for billing purposes
		//self.createHMSResource(WO_TASK_VOY_EXTENSION);			// TFS 39165
		self.createWorkOrderTransaction(TRANS_TYPE_WO_EXTENSION);		// TFS 39165
	endif;
epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="6f047778-2bcf-4dda-8446-c59715a04f00">
        <source>canCancel(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2018	jlger1	Initial creation

*/

vars
	voyage : CM_Voyage;
begin
	voyage := self.getMyVoyageObject;
	//can't cancel if it will change the voyage departed to a date in the past
	if self.oldDepartureDT &lt;&gt; null and oldDepartureDT &lt;= app.actualTimeServer then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createPxyHMSResourceProformas" id="ee9f0c38-30ad-484a-80da-8821088011f3">
        <source>createPxyHMSResourceProformas(_hmsUsed: HMS_ResourceUsedSet input; _movement: HMS_VoyageMovement input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2019	jlgndl1	Initial creation	TFS 43374

*/

vars

	detail : CM_WodMarineServiceDetail;
	used : HMS_ResourceUsed;

begin
	
	foreach detail in self.allMarineServiceDetails	discreteLock do
		used := detail.createPxyHMSResourceProforma(_movement);
		
		if used&lt;&gt; null then
			_hmsUsed.add(used);
		endif;
		
	endforeach;

epilog

end;</source>
        <Parameter name="_hmsUsed" type="HMS_ResourceUsedSet" usage="input"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
