    <JadeMethod name="getDeliveryRelease" id="717ca809-aba4-4637-b2f7-0b873e02d031">
        <source>getDeliveryRelease(_ti: CM_TrackedItem):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2015	cnwma1	Initial creation  PAR #35260 JH - TDT segment missing delivery release number

*/

vars
	deliveryRelease : String;
	trx				: CM_TITransaction;	
begin
	if _ti.getLastTransOfType(TRANS_TYPE_REL_REQ_ASSIGN) &lt;&gt; null then
			
			trx :=_ti.getLastTransOfType(TRANS_TYPE_REL_REQ_ASSIGN);
			if trx &lt;&gt; null then
				deliveryRelease :=trx.CM_RelRequestAssign.myBulkReleaseCode;
			endif;
	endif;
	return deliveryRelease;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
