    <JadeMethod name="tblCargo_queryRowColChg" id="58ba98b2-720e-4c9e-af01-8270a2ac5f68">
        <controlMethod name="CM_MobEntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2010	cnwndl1	Initial creation	NDL	Par 25744
06 May 2015	NDL	Found during testing of 35923, patched in 35945 

*/

vars

	currentRow : Integer;
	currentColumn : Integer;
	bookingRow : Integer;
	numItemsRow : Integer;
	cargoIdRow : Integer;
	quantity : Integer;
	msg : String;
	weightRow : Integer;
	volumeRow : Integer;
	measurementType : CM_MeasurementType;
	cargoType : CM_CargoType;
	attrName : String;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	density : Decimal [16,4];
	measureTbl : CMUI_MeasurementTable;
	
	cargoIdStr : String;
	cargoTypeInt : Integer;
	cmifID : CMIF_IDConversion;
	rawValue : String;
	
begin

	// moving from booking.
	currentColumn := self.tblCargo.column;
	if currentColumn &lt;&gt; 2 then
		return true;
	endif;
	
	bookingRow := tblCargo.getRow(ETRow_BookingReference);
	numItemsRow := tblCargo.getRow(ETRow_NumItems);
	cargoIdRow :=  tblCargo.getRow(ETRow_CargoId);
	
	cargoType := self.getCargoTypeForMeasurementType();
	if cargoType &lt;&gt; null then		//cnwmc5 - 26 June 2014 - PAR 34385
		if cargoType.isBulkByWeight then
			weightRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Weight,ETRow_TotalWeight);
			density := self.getDensity;
		elseif cargoType.isBulkByVolume then
			volumeRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Volume,ETRow_TotalVolume);
			density := self.getDensity;
		endif;
	endif;							//cnwmc5 - 26 June 2014 - PAR 34385
	
	currentRow := self.tblCargo.row;
	if currentRow = 0 then
		return true;
	endif;
	
	if bookingRow = currentRow then
		if self.getStringValueFromTable( ETRow_BookingReference ).trimBlanks &lt;&gt; null then
			self.populateCmbBRItem();
		endif;
		return true;
	endif;
	
	if numItemsRow = currentRow then
		quantity := self.getStringValueFromTable( ETRow_NumItems ).trimBlanks.Integer;
		if self.myTrackedItem &lt;&gt; null then
			if quantity &gt; self.myTrackedItem.totalQuantity then
				msg := app.getErrorString2( Move_quantity_gtr_cargo, quantity.String, self.myTrackedItem.totalQuantity.String );
				self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true );
			endif;
		endif;
		return true;
	endif;
	
	if weightRow &gt; 0 and weightRow = currentRow then
		attrName := self.tblCargo.allEntRowTransients[weightRow].EntTableRowTransient.controlName;
		if attrName &lt;&gt; null then
			measureTbl := self.allMeasurementControls[attrName].CMUI_MeasurementTable;
			if measureTbl &lt;&gt; null then
				weight := measureTbl.getConvertedValue;
			endif;
		endif;
		if weight = 0 then
			volume := 0;
		else
			if density = 0 then
				volume := 0;
			else
				volume := weight / density;
			endif;
		endif;
		measurementType := cargoType.getMeasurementTypeFor(Type_Volume,true);
		volumeRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Volume,ETRow_TotalVolume);
		if volumeRow &gt; 0 then
			attrName := self.tblCargo.allEntRowTransients[volumeRow].EntTableRowTransient.controlName;
			if attrName &lt;&gt; null then
				measureTbl := self.allMeasurementControls[attrName].CMUI_MeasurementTable;
				if measureTbl &lt;&gt; null then
					measureTbl.setValues(app.convertMeasurementForDisplay(measurementType.shortName, volume) &amp; Space &amp; measurementType.shortName);
					measureTbl.lostFocus( measureTbl );
				endif;
			endif;
		endif;
	endif;
	
	if volumeRow &gt; 0 and volumeRow = currentRow then
		attrName := self.tblCargo.allEntRowTransients[volumeRow].EntTableRowTransient.controlName;
		if attrName &lt;&gt; null then
			measureTbl := self.allMeasurementControls[attrName].CMUI_MeasurementTable;
			if measureTbl &lt;&gt; null then
				volume := measureTbl.getConvertedValue;
			endif;
		endif;
		if volume = 0 then
			weight := 0;
		else
			weight := volume * density;
		endif;
		measurementType := cargoType.getMeasurementTypeFor(Type_Weight,true);
		weightRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Weight,ETRow_TotalWeight);
		if weightRow &gt; 0 then
			attrName := self.tblCargo.allEntRowTransients[weightRow].EntTableRowTransient.controlName;
			if attrName &lt;&gt; null then
				measureTbl := self.allMeasurementControls[attrName].CMUI_MeasurementTable;
				if measureTbl &lt;&gt; null then
					measureTbl.setValues(app.convertMeasurementForDisplay(measurementType.shortName, weight) &amp; Space &amp; measurementType.shortName);
					measureTbl.lostFocus( measureTbl );
				endif;
			endif;
		endif;
	endif;
	
	if cargoIdRow = currentRow then
	
		//06 Jul 2016	NDL	TFS 2275
		cargoTypeInt := self.getStringValueFromTable(ETRow_CargoType).Integer;
		rawValue := self.getStringValueFromTable(ETRow_CargoId).trimBlanks;
		
		create cmifID transient;
		cmifID.scannedValue := rawValue;
		cmifID.myTerminal := self.myTerminal;
		cmifID.cargoType := cargoTypeInt;
		cmifID.callerName := self.class.name;	//18 Aug 2016	NDL	TFS 2567
		cargoIdStr := app.convertScannedCargoId( null, null, false, cmifID );
		self.tblCargo.setValueByName(ETRow_CargoId,cargoIdStr);
		
		self.populateFromPrenote(cargoIdStr, cargoTypeInt);
		
	endif;
	
	return true;	

epilog

	delete cmifID;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2a074fb0-9474-43ae-86e9-f624a84e6d9d">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 November 2016 09:19:28.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014429, locale);
	btnDocActions.translateCaption(Xlat_0021556, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
