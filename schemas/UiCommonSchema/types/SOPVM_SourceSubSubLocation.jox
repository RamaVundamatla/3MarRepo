    <JadeMethod name="createEmptyChild" id="75d05c4d-120b-4407-a084-2811a101967d">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	create myObject as CM_SourceSubSubLocation transient;
	myObject.CM_SourceSubSubLocation.setForProxy(null, null, _parent.myObject.CM_SourceSubLocation.isFSC, false, _parent.myObject.CM_SourceSubLocation);
	myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createEmptyPeer" id="dc4138c9-98ff-4583-958d-22ab4820f15f">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		29 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxySubSub : CM_SourceSubSubLocation;
begin
	create proxySubSub transient;
	proxySubSub.setForProxy(null, null, _parent.myObject.CM_SourceSubLocation.isFSC, false, _parent.myObject.CM_SourceSubLocation);
	self.myObject := proxySubSub;	
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="610fa3e6-4e91-4fa1-8077-e5797c6e20b4">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.myTrxDA.trxDeleteSourceSubSubLocation(self.myObject.CM_SourceSubSubLocation,app.myPassport);
	return app.myPassport.trxCompletedOK();
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="b478cc97-9bab-4bd2-a834-f21de3dfeeda">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyLocation, newLocation : CM_SourceSubSubLocation;
begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_SourceSubSubLocation transient;
	endif;
	
	proxyLocation := self.myForm.myProxyObject.CM_SourceSubSubLocation;
	
	proxyLocation.setForProxy(	self.myForm.tblInput1.getValueByName('code').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
								self.myForm.tblInput1.getValueByName('description').String,
								self.myForm.tblInput1.getValueByName(ETRow_IsFSC).Boolean,
								self.myForm.tblInput1.getValueByName('notAvailableForEntry').Boolean,
								self.myObject.CM_SourceSubSubLocation.mySourceSubLocation);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateSourceSubSubLocation(proxyLocation, newLocation, app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := newLocation;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateSourceSubSubLocation(proxyLocation, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject := proxyLocation;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPeerClass" id="9066b235-ef84-44aa-90de-3985a411368e">
