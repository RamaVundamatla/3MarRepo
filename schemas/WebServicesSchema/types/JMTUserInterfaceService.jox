	resourceType : HMS_ResourceType;
	wsResourceType : WS_HMSResourceType;

begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	foreach resourceType in app.myRoot.allResourceTypes discreteLock do
		create wsResourceType transient;
		wsResourceType.setProxyFromObject(resourceType);
		response.allHMSResourceTypes.add(wsResourceType);
	endforeach;
	
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_HMSResourceTypesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getHMSResources" id="d43d8c6e-81fd-4881-9bf9-231633af5a96">
        <source>getHMSResources( _resourceType : String )  : WS_HMSResourcesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlger1	Initial creation

*/

vars
	response : WS_HMSResourcesResponse;
	completedOK : Boolean;
	resourceType : HMS_ResourceType;
	resource 	: HMS_Resource;
	wsResource 	: WS_HMSResource;
	harbour 	: HMS_Harbour;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	if _resourceType = null then
		completedOK:=true;
		return response;
	endif;
	resourceType:= app.myPassport.getObjectOfTypeFromOid(_resourceType,HMS_ResourceType).HMS_ResourceType;
	if resourceType = null then
		completedOK:=true;
		return response;
	endif;
	
	harbour:= app.myPassport.myTerminal.myHarbour;
	
	if harbour = null then
		app.raiseCMException(HMSNoHarbourForTerminal,null,null);
		completedOK:=true;
		return null;
	endif;
	
	foreach resource in resourceType.allResources discreteLock do
		if resource.myHarbour &lt;&gt; harbour then
			continue;
		endif;
		
		create wsResource transient;
		wsResource.setProxyFromObject(resource);
		response.allHMSResources.add(wsResource);
		
	endforeach;
	
	completedOK := true;
	return response;
	
	
epilog
	
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_resourceType" type="String"/>
        <ReturnType type="WS_HMSResourcesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getHMSVisitType" id="7d0c72ae-ba5b-44a1-b724-cfeb9e610df8">
        <source>getHMSVisitType() : WS_CodeResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlger1	Initial creation tfs 39129

*/

vars
	response 	: WS_CodeResponse;
	completedOK : Boolean;
	visitType 		: HMS_VisitType;
	iter 		: Iterator;
	wsCode 		: WS_Code;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	
	iter := app.myRoot.allVisitTypes.createIterator;
	while iter.next(visitType) do
		create wsCode transient;
		wsCode.setProxyDetails(visitType,visitType.code,visitType.description);
		response.allCodes.add(wsCode);
	endwhile;
	
	completedOK := true;
	return response;
	
	
epilog
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getHatchForActualVoygage" id="bb417113-2f86-408f-99a4-cea6cf5b3c97">
        <source>getHatchForActualVoygage(voyageId : String) : WS_HatchResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars
	ut : CM_UserTerminal;
	termSet			: CM_TerminalSet;
	voyageGlobal    : CM_VoyageGlobal;
	voyage			: CM_Voyage;
	logLot		: CM_LogLot;
	multiTerminal	: Boolean;
	terminalCode,
	str				: String;
	user	    : CM_User;
	pxyHatch		: WS_Hatch;
	response	: WS_HatchResponse;
	obj			: Object;
	completedOK	: Boolean;
	hatchNum : Integer;
	passport : CM_Passport;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	if voyageId = null then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 10/8/17 
	voyageGlobal := app.myPassport.getObjectOfTypeFromOid(voyageId,CM_VoyageGlobal).CM_VoyageGlobal;
	if voyageGlobal = null then
		completedOK := true;
		return response;
	endif;
	
	passport := app.myPassport;
	
	create termSet transient;
	termSet.add(passport.myTerminal);
	
	multiTerminal := (termSet.size &gt; 1);
	
	foreach voyage in voyageGlobal.allVoyages discreteLock where termSet.includes(voyage.myTerminal) do
//		if (not CM_LogVoyage.hasInstance(voyage)) then
		if (voyage.myLogVoyageStructure = null) then
			continue;
		endif;
		terminalCode := voyage.myTerminal.code;
//		foreach logLot in voyage.CM_LogVoyage.allLogLots do
		foreach logLot in voyage.myLogVoyageStructure.allLogLots discreteLock do
			foreach hatchNum in 1 to voyage.myLogVoyageStructure.numHatches do
				if multiTerminal then
					str := hatchNum.String &amp; ' -' &amp; terminalCode;
				else
					str := hatchNum.String;
				endif;
				
				create pxyHatch transient;
				pxyHatch.code := str;
				response.allHatches.add(pxyHatch);	
			endforeach;	
		endforeach;
	endforeach;
	
	completedOK := true;
	return response;
	
	
epilog
	delete termSet;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getHatchForActualVoygage</wsdlName>
        <Parameter name="voyageId" type="String"/>
        <ReturnType type="WS_HatchResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getHazardDetails" id="ada76755-bbc0-4d37-b9a4-240e5fa8d0e6">
        <source>getHazardDetails() : WS_TIHazardResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 June 2010 cnwdz2	PAR #23027 - Development of new RIA Web Service application. Return a list of hazard details.
*/


vars
	response		: WS_TIHazardResponse;
	completedOK		: Boolean;
	
	tmpTIHazard	: WS_TIHazard;
	hazClass	: CM_HazardClass;

	failedDAC		: CM_DataAccessController;
	passport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	
	foreach hazClass in app.myRoot.allHazardClasses do
		if hazClass.isNotAvailableForEntry then 
			continue;
		endif; 		
		
		create tmpTIHazard transient;
		tmpTIHazard.setProxyFromObject(hazClass);
		response.allTIHazards.add(tmpTIHazard);
	endforeach;	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getHazardDetails</wsdlName>
        <ReturnType type="WS_TIHazardResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getHelpFile" id="91473d4f-ac21-4ee2-af6c-6d92ffeb051e">
