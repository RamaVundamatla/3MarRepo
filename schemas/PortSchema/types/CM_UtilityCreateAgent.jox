    <JadeMethod name="utlCreateHoldJobForRelReq" id="7c4e73a5-0f5a-456f-9bfb-6ce67c0693fc">
        <source>utlCreateHoldJobForRelReq(_reserveDetail : CM_ReserveDetail input; _realJob : CM_VoyageHoldJob output; 
										_location : CM_LocationsController input; _wleQty : Integer; _wleWeight : Real);
/*
Purpose:			
Date		Who		Reason
10/02/2017	cnwab1	Initial creation
14/03/2017	cnwdap1	TFS 3516 LNX Hold Planning Quantity
28/10/2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
*/

vars
	jobType : Integer;
	str, jobId, remarks : String;
	jobParams : CMIF_VoyageJobParams;
	holdReq : CM_HoldRequest;
	wle : CM_VoyageWLE;
	pxyJob : CM_VoyageHoldJob;
	tba, ti : CM_TrackedItem;
	terminal : CM_Terminal;
	lcgc : CM_GeneralCargoController;
	hold : CM_VoyageController;
	voyage : CM_Voyage;
	
begin
	if _location = null or not _location.isKindOf(CM_VoyageController) then
		// no voyage location then cant get a voyage
		return;
	endif;
	
	if _location.isKindOf(CM_GeneralCargoController) then
		lcgc := _location.CM_GeneralCargoController;
		voyage := lcgc.myVoyage;
		hold := lcgc;
	else
		voyage := _location.CM_VoyageController.myVoyage;
	endif;
	
	if voyage = null then
		// no voyage, can't create voyage job
		return;
	endif;
	
	voyage.getNextJobNumber(null,null);
	
	terminal := _reserveDetail.getMyTerminal();
	create pxyJob transient;
	
	jobType := JOB_TYPE_LOAD;

	jobId := voyage.getNextJobNumber(null,null);
	
	// TFS 3647 blank remarks means that the remarks on the job are auto generated.
	// TFS 3647 remarks := _reserveDetail.myReserveHeader.code &amp; " - (" &amp; _reserveDetail.getDescription() &amp; ")";
	
	pxyJob.setProxy(jobId, jobType);
	pxyJob.setProxyVoyage(_reserveDetail.myReserveHeader.myVoyage);
	//pxyJob.setProxyVoyageHoldJob(null, jobId, remarks, null, false, jobType, null, null, null, null, false, null, null);		// TFS 3516
	pxyJob.setProxyVoyageHoldJob(null, jobId, remarks, null, false, jobType, null, null, null, null, false, null, null, null,null,null);	// TFS 3516
	
	create _realJob;
	_realJob.setForCreate(pxyJob,terminal);
	_realJob.setMyVoyage(voyage);
	
	create holdReq;
	holdReq.setJob(_realJob);
	holdReq.setLC(lcgc);
	holdReq.setMoveType(LOAD_MOVETYPE);
	holdReq.setMyBulkReleaseReserveDetail(_reserveDetail);
	holdReq.setMyOriginatingBulkRelease(_reserveDetail.myReserveHeader);
	holdReq.setForUpdateQuantity(_wleQty); // TFS 3873
	holdReq.setForUpdateWeight(_wleWeight); // TFS 3873
	holdReq.createWLEs();
	
	if _reserveDetail.isKindOf(CM_ReserveSelection) and  _reserveDetail.CM_ReserveSelection.myCargoType.id = TI_CargoType_Container then
		foreach wle in holdReq.allWorkListEntries as CM_VoyageWLE do
			tba := _reserveDetail.createPlanningTrackedItem(_location.getFullId(), hold,false);
			if tba &lt;&gt; null then
				wle.setMyTrackedItem(tba);
				tba.moveToLocation(_location,_realJob,wle,null,PLANNING_MODE,true, true,false,false,false,false,tba.totalQuantity,tba.totalWeight,null,null,null,app.myPassport);
			endif;
		endforeach;
	
	else
		wle := holdReq.allWorkListEntries.first.CM_VoyageWLE;
		wle.setQuantity(_wleQty);
		wle.setWeight(_wleWeight); // TFS 3873
		tba := _reserveDetail.createPlanningTrackedItem(_location.getFullId(), hold,false);
		if tba &lt;&gt; null then
			wle.setMyTrackedItem(tba);
			tba.setTotalQuantity(_wleQty);
			tba.setTotalWeightWithoutTrans(_wleWeight); // TFS 3873
		endif;
		tba.moveToLocation(_location,_realJob,wle,null,PLANNING_MODE,true, true,false,false,false,false,tba.totalQuantity,tba.totalWeight,null,null,null,app.myPassport);
	endif;
	
	_realJob.setRemarks(_realJob.getAutoRemarks); // TFS 3647
	_realJob.enqueueJob();

	 // ### TFS 53105 02JUN2022 NAVAB1
	app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,_realJob.myTerminal,_realJob);
	foreach wle in _realJob.workListEntries as CM_VoyageWLE discreteLock do 
		if wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		if not wle.isSOBLoad() then
			app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE,wle.getMyTerminal,wle);
			
			/*  // ### TFS 53105 13JUN2022 NAVAB1
			ti := wle.myTrackedItem;
			if ti &lt;&gt; null then
				if ti.myPrimaryActualLocation &lt;&gt; null
				and ti.myPrimaryActualLocation.isVoyageController() then
					app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM,ti.getMyTerminal,ti);
				endif;
			endif;
			*/
		endif;
	endforeach;
	
epilog
	delete pxyJob; // TFS 3873
end;
</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_realJob" type="CM_VoyageHoldJob" usage="output"/>
        <Parameter name="_location" type="CM_LocationsController" usage="input"/>
        <Parameter name="_wleQty" type="Integer"/>
        <Parameter name="_wleWeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="utlCreateHookCode" id="634de4dc-3e3c-4189-a3b7-ddf8ee05ed8f">
        <source>utlCreateHookCode(_cmifHook : CMIF_HookCode; _realHookCode : CM_HookCode output; _passport : CM_Passport input);
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	proxyHookCode	: CM_HookCode;
	

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	_cmifHook.setForUpdate();
	
	if not _passport.noErrors() then
		return;
	endif;
		
	proxyHookCode := _cmifHook.myProxyHookCode;
		
	app.myValCA.valHookCode(proxyHookCode);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _realHookCode persistent;
	
	_realHookCode.setForCreate(proxyHookCode);

end;</source>
        <Parameter name="_cmifHook" type="CMIF_HookCode"/>
        <Parameter name="_realHookCode" type="CM_HookCode" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateHookType" id="bfa5c733-6d00-4e67-a1f1-57892a79ea11">
        <source>utlCreateHookType(_pxyHookType : CM_HookType; _realHookType : CM_HookType output; _passport : CM_Passport input );
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valHookType(_pxyHookType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _realHookType persistent;
	_realHookType.setForCreate(_pxyHookType);


end;</source>
        <Parameter name="_pxyHookType" type="CM_HookType"/>
        <Parameter name="_realHookType" type="CM_HookType" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateHumidityReading" id="52c516b9-95dd-4ada-a802-91cfb7a8a436">
        <updating/>
        <source>utlCreateHumidityReading(_humidityParams: CMIF_HumidReading input; _passport: CM_Passport input): CM_HumidReading updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars
	newHumidityReading	: CM_HumidReading;
	realTI, proxyTI		: CM_TrackedItem;
	expectedEdition		: Integer;

begin
	self.initialiseActivity();
	
	proxyTI := _humidityParams.myTrackedItem;
	proxyTI.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	
	proxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	if realTI = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return null;
	endif;
	
	app.myValCA.valHumidityReading(_humidityParams);
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	app.setContinueCMExceptions(false);
	
	self.exclusiveLock(realTI);

	if _passport.noErrors then
		_humidityParams.myTrackedItem := realTI;
		create newHumidityReading persistent;
		newHumidityReading.setForCreate(_humidityParams);
	endif;
	
	if _passport.noErrors then
		// raise a note
		_humidityParams.myTrackedItem.causeEvent(_humidityParams.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE), false, newHumidityReading);
	endif;
	
	return newHumidityReading; 
	
epilog

end;</source>
        <Parameter name="_humidityParams" type="CMIF_HumidReading" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_HumidReading"/>
    </JadeMethod>
    <JadeMethod name="utlCreateISOType" id="79cff812-a45a-4245-9a72-9024ae8e0b7f">
        <source>utlCreateISOType(pProxyISOType:CM_ISOType; pNewISOType:CM_ISOType output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valISOType(pProxyISOType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create pNewISOType persistent;
	pNewISOType.setForCreate(pProxyISOType);
	
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewISOType);
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(null) then
			pNewISOType.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
												  BGP_OpsViewWSRequest.OPS_TYPE_ISOTYPE,
												  pNewISOType);
        endif;
		//21.09.2020 cnwma1 TFS #49906
	endif;
end;</source>
        <Parameter name="pProxyISOType" type="CM_ISOType"/>
        <Parameter name="pNewISOType" type="CM_ISOType" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateISOTypeGroup" id="a2edade0-d249-412e-8f18-528f735b9c52">
        <source>utlCreateISOTypeGroup(pProxyISOTypeGroup:CM_ISOTypeGroup; pNewISOTypeGroup:CM_ISOTypeGroup output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valISOTypeGroup(pProxyISOTypeGroup);

	if not self.checkValidationWithPassport(_passport) then
