    <JadeMethod name="getMyHMSVoyageMovement" id="e5dbb753-4026-47b2-a631-78dd5693abab">
        <source>getMyHMSVoyageMovement() : HMS_VoyageMovement;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2018	jlgndl1	Initial creation	TFS 41027 Report Writer ...

*/

vars

	voyage : CM_Voyage;
	occursdt : TimeStamp;
	movement : HMS_VoyageMovement;
	wodShiftMov : CM_WodShiftMovement;

begin

	voyage := self.getMyVoyageObject();
	if voyage = null then
		return null;
	endif;

	//08 Nov 2018	NDL	TFS 41161
	if self.isWorkOrderForShift then
		movement := self.allWoDtls.first.CM_WodShiftMovement.myHMSVoyageMovement;
	
	//28 Nov 2018	NDL	TFS 42200
	elseif self.isWorkOrderForIMSR then
		movement := voyage.getMovementArrival();
	elseif self.isWorkOrderForDMSR then
		movement := voyage.getMovementDeparture();
	elseif self.isWorkOrderMarineServiceDtl() then
		wodShiftMov := self.allWoDtls.first.CM_WodMarineServiceDetail.myShiftMovement;
		if wodShiftMov &lt;&gt; null then
			movement := wodShiftMov.myHMSVoyageMovement;
		endif;
	endif;
	
	if movement &lt;&gt; null then
		return movement;
	endif;

	
	
	occursdt := self.getOccursDT();
	if occursdt.date.isValid then
		return voyage.getMovementForDateTime(occursdt);
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
