    <JadeMethod name="clearItem" id="80fb787c-ddc9-4904-93ff-f01c3c599d94">
        <source>clearItem();
/*

Date		Who		Reason
29 April 2016	cnwer1	Initial creation TFS 1923 29/4/16

*/

vars
	defaultSeverity : CM_DamageSeverity;
begin
	self.cmbDamage.listIndex := -1;
	self.cmbPosition.listIndex := -1;
	
	self.cmbSeverity.listIndex := -1;
	
	self.txtQuantity.text :=null;
	self.txtRemarks.text:=null;
	self.optYes.value:=true;
	self.chkRepaired.value:=false;
	
	 // ### TFS BUG 58862 27JUN2023 NAVAB1
	defaultSeverity  := self.myTerminal.getConfig(DamageSeverityDefault).CM_DamageSeverity;
	if defaultSeverity &lt;&gt; null then
		self.cmbSeverity.listObject := defaultSeverity;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="f9fe1511-6f2b-430f-bcde-2f9d669fdac2">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwmd1	Initial creation
14/09/2016  cnwma1  TFS #2673:PAR38205 MSL - Damage details
*/

vars

begin
	self.permissionView  := PmAdmTIDamageView; //14/09/2016 TFS #2673:PAR38205 
	self.permissionMaint := PmAdmTIDamageMaint; //14/09/2016 TFS #2673:PAR38205 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectedItem" id="eb8332b6-d6a8-4adb-b588-7e04630c18a6">
        <updating/>
        <source>displaySelectedItem() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 31/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//   						Display a selected item from the table and populate the controls on the form.
// 30/09/2022	navkc1		ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
// 13/10/2022	navak20		ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//----------------------------------------------------------------------
vars
	damageInstance : CM_DamageInstance;
begin
	if self.tblDamage.row &lt;= self.tblDamage.fixedRows then
		return;
	endif;
	
	damageInstance := self.tblDamage.accessRow(self.tblDamage.row).itemObject.CM_DamageInstance;
	if damageInstance = null then
		return;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.frmControls.enabled:= false;
	endif;
	
	
	self.cmbDamage.listIndex := self.cmbDamage.findObject(damageInstance.myDamageDefinition);
	self.cmbPosition.listIndex := self.cmbPosition.findObject(damageInstance.myDamagePosition);
	self.txtRemarks.text := damageInstance.remarks;
	self.txtQuantity.text := damageInstance.quantity.String;
	self.chkRepaired.value := damageInstance.repaired;
	//Start 13.10.2022 navak20 TFS 53862
	/*if damageInstance.getSeverityLevel &gt; 0 then
		//self.cmbSeverity.listIndex := damageInstance.severity + 1;								// navkc1	30/09/2022	#54463
		self.cmbSeverity.listIndex := self.cmbSeverity.findObject(damageInstance.myDamageSeverity); // navkc1	30/09/2022	#54463 - Fix Severity combobox issue
	endif;*/
	self.cmbSeverity.listIndex := self.cmbSeverity.findObject(damageInstance.myDamageSeverity);
	//End 13.10.2022 navak20 TFS 53862
	self.setOptIsNewDamage(damageInstance);
	self.setSelectedItem(damageInstance);
	
	self.btnRemove.enabled := (self.mode = Mode_Add) or (self.mode = Mode_Update);
	self.btnUpdate.enabled := (self.mode = Mode_Add) or (self.mode = Mode_Update);
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdateClick" id="36172cca-e7cc-448a-8f3b-b1648994fd79">
        <source>doBtnUpdateClick();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	str : String;
begin
	str := self.hasInfoEntered();
	if str &lt;&gt; null then
		app.msgBox(app.getErrorString1(RequiredFields, str),null , MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.updateItem();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="02c6754a-3a8c-4e2e-b64e-95e1ca97aee9">
        <updating/>
        <source>doCancel() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		06 August 2009
//
// Implemented version: JMT 7.7.3
/* Changes

Date		Name	TFS#		Description
============================================================================
06/08/2009 	cnwsh3 	CCMS SFW1066 
					PAR20321 	Recording Damage Details Changes.
06/05/2019	jlgka1	44287		Damage Refactoring. Add a confirmation message
								that any unsaved entry will be lost.
============================================================================*/
vars
	invalidProcess 		: Boolean;
	withUnsavedChanges	: Boolean;
	damageInstance		: CM_DamageInstance;	//jlgka1 TFS 44287
	realObject			: Object;				//jlgka1 TFS 44287
begin
	on Exception do app.handleDeletedObject(exception, self.myParentForm, invalidProcess); // PAR 34997
	
	//jlgka1 TFS 44287 --&gt;
	foreach damageInstance in self.allProxyDamageInstances do		
		realObject := app.myProxyManager.getRealObject(damageInstance);
		if realObject = null then		
			withUnsavedChanges := true;
			break;
		endif;		
	endforeach;
	
	if withUnsavedChanges then
		if 	app.msgBox('You are currently editing an object that has not been saved. Do you want to abandon your changes?', 'Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
		
		foreach damageInstance in self.allProxyDamageInstances do
			realObject := app.myProxyManager.getRealObject(damageInstance);
			if realObject = null then	
				delete damageInstance;	
			endif;
		endforeach;
	endif;
	//jlgka1 TFS 44287 &lt;--
	
	if not self.isParentFormUpdate  and  self.myDamageInterface =  null then //epr par 31845 
		if self.myProxyMasterItem &lt;&gt; null then
			delete self.myProxyMasterItem;
		endif;
		self.allProxyDamageInstances.purge();
	endif;
	
	if self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm) then
		self.myParentForm.CMUI_MasterGeneratorMaintForm.setIsDamageFormInitialised(true);
	elseif self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then
		self.myParentForm.CMUI_MasterContainerMaintForm.setIsDamageFormInitialised(true);
	elseif self.myParentForm.isKindOf(CMUI_TIMasterMaintForm) then
		self.myParentForm.CMUI_TIMasterMaintForm.setIsDamageFormInitialised(true);
	endif;
		
	inheritMethod();

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="3dab554a-d6c8-48fc-95c3-555c8269df02">
        <updating/>
        <source>doMnuFormContextMenu(table : CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 April 2019
TFS#		: 44287
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	isShowDataMenus		: Boolean;
	isDataValidRow		: Boolean;
	x1, y1				: Real;
begin
	if app.isAllowedToInspect() then
		self.mnuTblInspectObject.visible	:=	true;
	else
		self.mnuTblInspectObject.visible	:=	false;
	endif;

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(mnuTblViewContext, x1.Integer, y1.Integer);
	return false;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="9ef4e87c-682b-4648-8c42-b26602132362">
        <updating/>
        <source>doOK() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		06 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 06/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	
begin
	inheritMethod();
	
	if CM_ContainerEnqForm.hasInstance(self.myParentForm)  then
		self.doSaveTrackedItem();
	elseif self.myRealMasterItem.isKindOf(CM_TrackedItem)  then //cwnrd1 par 29415 23.5.2012
		self.doSaveTrackedItemGeneric();		
	elseif self.myRealMasterItem.isKindOf(CM_Wagon) then
		self.doSaveWagon();
	elseif self.myRealMasterItem.isKindOf(CM_WagonMaster) then
		self.doSaveWagonMaster();
	elseif self.myRealMasterItem.isKindOf(CM_TIMaster) then
		self.doSaveTIMaster();
	elseif self.myDamageInterface &lt;&gt; null then
		 //epr par 31845 
		self.doSaveIF_DamageDetails();
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveIF_DamageDetails" id="3fd6a793-0dbf-4a77-95d1-c70f69b06f2b">
        <source>doSaveIF_DamageDetails() protected;
/*

Date		Who		Reason
23 October 2013	cnwer1	Initial creation PAR 31845

*/

vars
	di : CM_DamageInstance;
	coll : CM_DamageInstanceByDmgePos;
begin
	if self.myParentForm = null then
		return;
	endif;
	
	if self.myDamageInterface = null then
		return;
	endif;
	
	
	coll:=self.myParentForm.IF_DamageDetails.getDamageInstances;
	coll.clear;
	foreach di in self.allProxyDamageInstances do
		if not coll.includesObject(di) then
			coll.add(di);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveTIMaster" id="eb7635ed-5bc3-4832-ad1a-cea2aa7289db">
        <updating/>
        <source>doSaveTIMaster() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		21 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	di : CM_DamageInstance;
	collection : CM_DamageInstanceByDmgePos;
	invalidProcess : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myParentForm, invalidProcess); // PAR 34997

	if self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then
		collection := self.myParentForm.CMUI_MasterContainerMaintForm.allDamageInstancesByPos;
		self.myParentForm.CMUI_MasterContainerMaintForm.setIsDamageFormInitialised(true);
	elseif self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm) then
		collection := self.myParentForm.CMUI_MasterGeneratorMaintForm.allDamageInstancesByPos;
		self.myParentForm.CMUI_MasterGeneratorMaintForm.setIsDamageFormInitialised(true);
	elseif self.myParentForm.isKindOf(CMUI_TIMasterMaintForm) then
		collection := self.myParentForm.CMUI_TIMasterMaintForm.allDamageInstancesByPos;
		self.myParentForm.CMUI_TIMasterMaintForm.setIsDamageFormInitialised(true);
	endif;
	
	foreach di in self.allProxyDamageInstances do
		if not collection.includesObject(di) then
			collection.add(di);
		endif;
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveTrackedItem" id="78001a21-272e-48b0-8991-c498cbab9a2f">
        <updating/>
        <source>doSaveTrackedItem() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		18 September 2009
//
// Implemented version: JMT 7.7.3
/* Changes

Date		Name	TFS#	Description
============================================================================
14/05/2019	jlgka1	44287	JMT - Damage Refactoring. If all damage instancer
							has been deleted, reset damaged flag to false.
21 Aug 2023 navhl20 59924 	Defect 59924: MTN - Cargo Enquiry - Wrong title on Warning for when adding damage
============================================================================*/
vars
	pxyTI 		: CM_TrackedItem;
	di 			: CM_DamageInstance;
	theReturn 	: Integer;
begin
	if self.isParentFormUpdate then
		self.myParentForm.CM_ContainerEnqForm.doShowDamageEntriesForCargoEnq(self.myProxyMasterItem.CM_TrackedItem);
		pxyTI := self.myProxyMasterItem.CM_TrackedItem;
		
		if pxyTI.allDamageInstancesByPos.size = 0 then
			pxyTI.setDamaged(false);
			pxyTI.setDamagedDT(true); // ### TFS 54887 21SEP2022 NAVAB1
		endif;		
	else
		pxyTI := self.myProxyMasterItem.CM_TrackedItem;
		
		foreach di in self.allProxyDamageInstances do
			di.setMySubject(pxyTI);
		endforeach;
		
		while true do
			app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				//theReturn := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);			//21.8.2023 navhl20 #59924
				theReturn := app.showErrorWarningDialog(app.getErrorString(Cargo), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);				//21.8.2023 navhl20 #59924
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	endif;
epilog
	if not isParentFormUpdate then
		delete self.myProxyMasterItem;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveTrackedItemGeneric" id="74a36e63-af87-4229-a13c-6662cdcf4d0d">
        <updating/>
        <source>doSaveTrackedItemGeneric() updating;

/*

Purpose: To update the damage on a tracked item i a generic way. We assume the form we are coming from is not in edit mode and we kill the proxy
//cwnrd1 par 29415 23.5.2012			

Parameters:			

Return Value:		


Date		Who		Reason
23 May 2012	cnwrd1	Initial creation

*/

vars
	pxyTI 		: CM_TrackedItem;
	di 			: CM_DamageInstance;
	theReturn 	: Integer;
begin

	pxyTI := self.myProxyMasterItem.CM_TrackedItem;
	
	foreach di in self.allProxyDamageInstances do
		di.setMySubject(pxyTI);
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete self.myProxyMasterItem;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveWagon" id="ec2244ed-08e3-4f56-ab0d-12e8493b3889">
        <updating/>
        <source>doSaveWagon() updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyWagon : CM_Wagon;
	theReturn : Integer;
	di : CM_DamageInstance;
	wagonUpdateCtrl : CMIF_WagonUpdateController;	//03 Nov 2009	NDL	Par 21519
	objectArray : ObjectArray;
begin
	pxyWagon := app.createUpdateProxy(self.myRealMasterItem).CM_Wagon;
	
	foreach di in self.allProxyDamageInstances do
		di.setMySubject(pxyWagon);
	endforeach;
	
	//21 Oct 2009	NDL	Par 21457 - Handle deletion of damage on wagon.
	create objectArray transient;
	foreach di in pxyWagon.allDamageInstanceByPos do
		if not self.allProxyDamageInstances.includes(di) then
			//pxyWagon.allDamageInstanceByPos.removeIfPresent(di);
			delete di;  //cnwjo3 par 21463
			objectArray.add(di);
		endif;
	endforeach;
	
	//03 Nov 2009	NDL	Par 21519
	create wagonUpdateCtrl transient;
	wagonUpdateCtrl.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	self.setCmifFromWagonPxy(pxyWagon, wagonUpdateCtrl);
	
	while true do
		app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);	//03 Nov 2009	NDL	Par 21519
		//app.myTrxUA.trxUpdateTrainWagon(pxyWagon, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;


epilog
	self.allProxyDamageInstances.purge;
	delete pxyWagon;
	delete wagonUpdateCtrl;
	if not objectArray.isEmpty then
		objectArray.purge();
	endif;
	delete objectArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveWagonMaster" id="baf46c70-9224-4140-99e5-51495067f015">
        <updating/>
        <source>doSaveWagonMaster() updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyWagon : CM_WagonMaster;
	theReturn : Integer;
	di : CM_DamageInstance;
	damage : CM_DamageInstance;
	objectArray : CM_ObjectArray;
begin
	pxyWagon := app.createUpdateProxy(self.myRealMasterItem).CM_WagonMaster;
	pxyWagon.setPropogateChanges(false);	//21 Oct 2009	NDL Par 20857
	
	foreach di in self.allProxyDamageInstances do
		di.setMySubject(pxyWagon);
	endforeach;
	
	//21 Oct 2009	NDL	Par 21457 - Handle deletion of damage on wagon master.
	create objectArray transient;
	foreach damage in pxyWagon.allDamageInstancesByPos do
		if not self.allProxyDamageInstances.includes(damage) then
			//pxyWagon.allDamageInstancesByPos.removeIfPresent(damage);
			delete damage;  //cnwjo3 par 21463
			objectArray.add(damage);
		endif;
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateWagonMaster(pxyWagon, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else  
			theReturn := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;


epilog
	self.allProxyDamageInstances.purge;
	if not objectArray.isEmpty then
		objectArray.purge();
	endif;
	delete objectArray;
	delete pxyWagon;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowPhotos" id="318b2222-d32a-406b-8fac-30202aebb354">
        <source>doShowPhotos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Dec 2024 navlc30 JIRA 33478 Match functionality in the thin client for Damage Recording Improvement
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
*/


vars
	photos : ObjectArray;
	menuAction : CMUI_MenuAction;	
begin

	if self.myRealMasterItem = null or (not self.myRealMasterItem.isKindOf(CM_TrackedItem)) then
		return;
	endif;
	create menuAction transient;
	menuAction.setMyForm(self);
	self.myAssistant.showPhotosForm(self.myRealMasterItem.CM_TrackedItem, null, null, null, photos, menuAction);			//08.08.2025 navhl20 #35650	
	
epilog
	delete menuAction;
end;</source>
    </JadeMethod>
    <JadeMethod name="getItemForDisplay" id="7066c6e3-229b-44c0-977a-ce7e4f9fdd6a">
        <source>getItemForDisplay() : CM_Object;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		21 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 21/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars

begin
	if self.myProxyMasterItem &lt;&gt; null then
		return self.myProxyMasterItem;
	else
		return self.myRealMasterItem;
	endif;
epilog
end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="hasInfoEntered" id="1d467f54-4017-41ea-99f3-7b011deadbc7">
        <source>hasInfoEntered() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 13/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	str : String;
begin
	
	if self.cmbDamage.listObject = null then 
		str := app.getErrorString(DamageCode);
	endif;
	
	if self.cmbPosition.listObject = null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp;  app.getErrorString(DamagePosition);//'Damage Position';
	endif;
	
	
	if self.cmbSeverity.listIndex = -1 then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; app.getErrorString(Severity);//'Severity';
	endif;
	
	//quantity won't be visible for bulk cargo
	if self.txtQuantity.visible and self.txtQuantity.text.Integer &lt;= null then //PAR20902 cnwsh3 
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; app.getErrorString(CM_Quantity);
	endif;
	 
	
	return str;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initCombos" id="10d28d1f-1b77-4b3d-a5ad-4733c485cc8c">
        <source>initCombos();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 28 April 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	object : Object;
	interface : IF_DamageDetails;
begin
	object := self.getItemForDisplay();
	if object &lt;&gt; null then
		interface:=object.IF_DamageDetails;
	else
		//epr par 31845 24/10/13
		interface:=self.myDamageInterface;
	endif;	

	self.myAssistant.comboBoxDamageCodes(self.cmbDamage, interface);
	self.myAssistant.comboBoxDamagePositons(self.cmbPosition, interface);
	
	// call to comboBoxDamageSeverity needs a terminal
	if self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then // ### TFS 55313 08NOV2022 NAVAB1
		if self.myAssistant.myTerminal = null then // ### TFS 55313 08NOV2022 NAVAB1
			self.myAssistant.myTerminal := self.myTerminal; // ### TFS 55313 08NOV2022 NAVAB1
		endif;
	endif;
	
	self.myAssistant.comboBoxDamageSeverity( self.cmbSeverity);
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="initDamageTable" id="65a7d0ce-652e-44d7-a6ac-8d8f82192769">
        <source>initDamageTable();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 28 April 2009
//
// Implemented version: 7.7.3
// 
// CCMS SFW1066  - Recording Damage Details Changes.
// 13/10/2022	navkc1	ChangeRequest 54463: MTN - Subscription License, New Feature Support Phase 1
//----------------------------------------------------------------------
vars
	tbl : CM_DataTable;
	row : EntTableRow;
	entDef : EntTableDef;
	
begin
	tbl := self.tblDamage;
	tbl.selectionType := CM_BaseTable.SelectionType_Row;
	tbl.myDataClass := CM_DamageInstance;
	//tbl.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_DamageCodesDataTable));
	tbl.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_DmgCodeTblSimple));	// 13/10/2022	navkc1	#54463 - Separate EntDef for simple form
	
	tbl.userInputEnabled := (self.mode = Mode_Add) or (self.mode = Mode_Update);
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="inspectObject" id="ec870d8f-c75b-4119-86ee-f97e491d71fb">
        <source>inspectObject();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 April 2019
TFS#		: 44287
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	obj 		: Object;
begin
	if self.tblDamage.row &gt; 1  then
		obj := self.tblDamage.allSelectedObjects.first;
		if obj &lt;&gt; null then
			obj.inspect;
		endif;
	else
		obj := self.tblDamage;
			if obj &lt;&gt; null then
			obj.inspect;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDamageItem" id="10580a21-8dcc-4b2c-8476-672de501a555">
        <updating/>
        <source>loadDamageItem(damageInstance : CM_DamageInstance) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		12 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	pxyDam	: CM_DamageInstance;
	str		: String;
begin
	str := self.tblDataDisplayRow(self.tblDamage, damageInstance);
	
	pxyDam := damageInstance.pxyGetProxyObject();
	if pxyDam = null then
		pxyDam := app.createUpdateProxy(damageInstance).CM_DamageInstance;
	endif;
	
	self.allProxyDamageInstances.add(pxyDam);
	self.addPxyToParentForm(pxyDam);
	self.tblDamage.addItemObject(pxyDam, str);
epilog
end;</source>
        <Parameter name="damageInstance" type="CM_DamageInstance"/>
    </JadeMethod>
    <JadeMethod name="loadDamageItems" id="5fa9ec45-45f5-473a-b04a-a5afc7ee65e8">
        <updating/>
        <source>loadDamageItems() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 31/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	pxyDam, 
	damageInstance 	: CM_DamageInstance;
	str 			: String;
	object 			: CM_Object;
	table 			: CM_DataTable;
	idx 			: Integer;
	ti 				: CM_TrackedItem;
begin
	table := self.tblDamage;
	object := self.getItemForDisplay();
	// ## TRACKED ITEM
	if object.isKindOf(CM_TrackedItem) then
		if not object.isTransient then
			// 29944 don't create update proxy from cargo enquiry unless updating
			if not self.mode = Mode_View then
				ti := app.createUpdateProxy(object).CM_TrackedItem;
				self.myProxyMasterItem := ti;
			else
				ti := object.CM_TrackedItem;
			endif;
		else
			ti := self.myProxyMasterItem.CM_TrackedItem;
		endif;
		foreach damageInstance in ti.allDamageInstancesByPos do
			str := self.tblDataDisplayRow(self.tblDamage, damageInstance);
			table.addItemObject(damageInstance, str);
			if damageInstance.isTransient then	// 29944 in view mode these are persistent
				self.allProxyDamageInstances.add(damageInstance);
			endif;
		endforeach;
		self.setCaption(app.getErrorString(Damage) &amp; " " &amp; object.CM_TrackedItem.id);
	// ## WAGONS
	elseif object.isKindOf(CM_Wagon) then
		foreach damageInstance in object.CM_Wagon.allDamageInstanceByPos do
			self.loadDamageItem(damageInstance);
		endforeach;
		self.setCaption(app.getErrorString(Damage) &amp; " " &amp; object.CM_Wagon.id);
	// ## WAGON MASTERS
	elseif object.isKindOf(CM_WagonMaster) then
		foreach damageInstance in object.CM_WagonMaster.allDamageInstancesByPos do
			self.loadDamageItem(damageInstance);
		endforeach;
		self.setCaption(app.getErrorString(Damage) &amp; " " &amp; object.CM_WagonMaster.id); 
	elseif object.isKindOf(CM_TIMaster) then
		if (self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm)and self.myParentForm.CMUI_MasterGeneratorMaintForm.isDamageFormInitialised) or
		   (self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm)and self.myParentForm.CMUI_MasterContainerMaintForm.isDamageFormInitialised) or
		   (self.myParentForm.isKindOf(CMUI_TIMasterMaintForm)and self.myParentForm.CMUI_TIMasterMaintForm.isDamageFormInitialised) then
			self.loadDamageProxyFromParentForm();
		else
			foreach damageInstance in object.CM_TIMaster.allDamageInstancesByPos do
				self.loadDamageItem(damageInstance);
			endforeach;
		endif;
		self.setCaption(app.getErrorString(Damage) &amp; " " &amp; object.CM_TIMaster.id); 
	else
		 //epr par 31845 
		if self.myParentForm.class.implementsInterface(IF_DamageDetails) then
			foreach damageInstance in self.myParentForm.IF_DamageDetails.getDamageInstances do
				str := self.tblDataDisplayRow(self.tblDamage, damageInstance);
				table.addItemObject(damageInstance, str);
				if damageInstance.isTransient then	
					self.allProxyDamageInstances.add(damageInstance);
				endif;
			endforeach;
		endif;
	endif;
	
	if table.rows &gt; table.fixedRows then
		idx := table.fixedRows + 1;
		table.row := idx;
		self.setSelectedItem(table.accessRow(idx).itemObject.CM_DamageInstance);
		table.selectRow(idx, false);
		self.displaySelectedItem();
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDamageProxyFromParentForm" id="43a5d4f7-49ce-48e3-9059-355a620c9503">
        <updating/>
        <source>loadDamageProxyFromParentForm()updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		12 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	damage 	: CM_DamageInstance;
	str 	: String;
	damageColl : CM_DamageInstanceByDmgePos;
begin
	if self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm) then
		damageColl := self.myParentForm.CMUI_MasterGeneratorMaintForm.allDamageInstancesByPos;
	elseif self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then
		damageColl := self.myParentForm.CMUI_MasterContainerMaintForm.allDamageInstancesByPos;
	elseif self.myParentForm.isKindOf(CMUI_TIMasterMaintForm) then
		damageColl := self.myParentForm.CMUI_TIMasterMaintForm.allDamageInstancesByPos;
	endif;
	
	foreach damage in damageColl do
		str := self.tblDataDisplayRow(self.tblDamage, damage);
		self.allProxyDamageInstances.add(damage);
		self.tblDamage.addItemObject(damage, str);
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="mnuTblInspectObject_click" id="313781d3-e4a0-41d8-9589-aac6ecd1fd0f">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuTblInspectObject_click(menuItem: MenuItem input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 April 2019
TFS#		: 44287
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	self.inspectObject();
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeFromParentForm" id="4c3b2107-214d-46d7-a3d4-43d341f55546">
        <updating/>
        <source>removeFromParentForm() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		12 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars

begin
	if self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm) then
		self.myParentForm.CMUI_MasterGeneratorMaintForm.allDamageInstancesByPos.removeIfPresent(self.mySelectedItem);
	elseif self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then
		self.myParentForm.CMUI_MasterContainerMaintForm.allDamageInstancesByPos.removeIfPresent(self.mySelectedItem);
	elseif self.myParentForm.isKindOf(CMUI_TIMasterMaintForm) then
		self.myParentForm.CMUI_TIMasterMaintForm.allDamageInstancesByPos.removeIfPresent(self.mySelectedItem);
	endif;
		
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="removeItem" id="45774932-7fff-4b3c-83a0-b268c5a530cf">
        <updating/>
        <source>removeItem() updating, protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 13/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	idx : Integer;
begin
	if self.mySelectedItem = null then
		app.msgBox('Please select an Item to remove', 'Select Item', 0);
		return;
	endif;
	
	self.tblDamage.findObjectInRow(self.mySelectedItem, idx);
	
	if idx &gt; 0 then
		self.tblDamage.removeItem(idx);
		if self.allProxyDamageInstances.includes(self.mySelectedItem) then
			self.allProxyDamageInstances.remove(self.mySelectedItem);
		endif;
		self.removeFromParentForm();
		delete self.mySelectedItem;
		//epr tfs 1923 29/4/16
		self.clearItem();
	endif;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCmifFromWagonPxy" id="13759866-e62d-442c-9704-ca020fd60ecc">
        <updating/>
        <source>setCmifFromWagonPxy(_pxyWagon : CM_Wagon input; wagonUpdateCtrl : CMIF_WagonUpdateController input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	rake : CM_RailLine;
	wagonPos : Integer;
	realWagon : CM_Wagon;
begin

	realWagon := _pxyWagon.pxyGetRealObject.CM_Wagon;
	if realWagon &lt;&gt; null then
		rake := realWagon.myRailLine;
		if rake &lt;&gt; null then
			wagonPos := rake.allWagons.indexOf(realWagon);
		endif;
	endif;
	
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
										rake,	//_rake : CM_RailLine;
										realWagon.myTrainInwards,	//_train : CM_Train;
										wagonPos,	//_wagonPosition : Integer;
										true	//_trainMode : Boolean
										);
										
	wagonUpdateCtrl.expectedEditionWagon := realWagon.edition;									
	wagonUpdateCtrl.myProxyWagon := _pxyWagon;
	
	if realWagon &lt;&gt; null then
		wagonUpdateCtrl.populateFromExistingWagonAddTi( realWagon, null, 0 );
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="wagonUpdateCtrl" type="CMIF_WagonUpdateController" usage="input"/>
    </JadeMethod>
