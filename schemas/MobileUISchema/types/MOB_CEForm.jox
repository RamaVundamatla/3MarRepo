    </JadeMethod>
    <JadeMethod name="doApplyScreenColors" id="b4beca9a-f116-484e-a50b-26114d0f7e41">
        <updating/>
        <source>doApplyScreenColors()updating;
/*
	Created on 02 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	backColorGen	: Integer;
	foreColorGen	: Integer;
	backColorTable	: Integer;
	foreColorTable	: Integer;
	numControls		: Integer;
	controlIndex	: Integer;
	controlObj		: Control;
	
begin
	backColorGen	:=	app.colorBackGeneral;
	backColorTable	:=	app.colorBackTables;
	foreColorGen	:=	app.colorForeGeneral;
	foreColorTable	:=	app.colorForeTables;
	numControls		:=	self.controlCount();
	
	foreach controlIndex in 1 to numControls do
		controlObj	:=	self.controls(controlIndex);		
		
		if controlObj.isKindOf(Label)
		or controlObj.isKindOf(Sheet) 
		or controlObj.isKindOf(Folder) 
		or controlObj.isKindOf(Frame)
		then
			controlObj.setBackForeColor(backColorGen, foreColorGen);
		elseif controlObj.isKindOf(Table)
		or controlObj.isKindOf(Folder) then
			controlObj.setBackForeColor(backColorTable, foreColorTable);
		endif;
		
		
	endforeach;		
	
	self.backColor := backColorGen;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCloseForm" id="d72b07ec-75aa-4571-a8b5-8204fedd01aa">
        <updating/>
        <source>doCloseForm() updating;
/*
	Created on 28 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if not self.processForCloseForm() then
		return;
	endif;
	
	self.unloadForm();
end;</source>
    </JadeMethod>
