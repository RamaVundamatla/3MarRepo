    <JadeMethod name="getYACriteriaTypeForRow" id="264c5a2c-ccf1-463d-a54c-766e872bd5fa">
        <source>getYACriteriaTypeForRow(_entRow : String) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2022	jlier1	Initial creation
25Oct2022		navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
12 Aug 2024 navlc30 CR 64704 Task 64705 : EUP - Cargo Review Release Req - Sorting Method
*/

vars

begin	
	/* 28/06/2023 navmv20 CR 58410 Task 58411 if _entRow = ETRow_CargoGroupId then
		return YACriteriaType_CargoGroup;
	else */
	if _entRow = ETRow_Colour then
		return YACriteriaType_Colour;
	elseif _entRow = ETRow_ImexStatus then // ### TFS DEFECT 63792 24APR2024 NAVAB1
		return YACriteriaType_ImexStatus; // ### TFS DEFECT 63792 24APR2024 NAVAB1
	elseif _entRow = ETRow_Grammage then
		return YACriteriaType_Grammage;
	elseif _entRow = ETRow_Grade then
		return YACriteriaType_Grade;
	elseif _entRow = ETRow_AllHazardClasses then
		return YACriteriaType_Hazardous;
	elseif _entRow = ETRow_IntendedReleaseMode then
		return YACriteriaType_IntendedRelMode;
	elseif _entRow = ETRow_ReleasedTransportMode then
		return YACriteriaType_RelTransMode;
	elseif _entRow = ETRow_ServiceOrder then
		return YACriteriaType_ServiceOrder;
	elseif _entRow = ETRow_ShippingLine then
		return YACriteriaType_ShippingLine;
	elseif _entRow = ETRow_AllSpecialLifts then
		return YACriteriaType_SpecialLift;
	elseif _entRow = ETRow_DamageParty then		//25.10.2022 navhl20 TFS 53862
		return YACriteriaType_DamageParty;	//25.10.2022 navhl20 TFS 53862
	elseif _entRow = ETRow_SpecialStow then
		return YACriteriaType_SpecialStow;
	elseif _entRow = ETRow_TranshipDischargePort then
		return YACriteriaType_TranshipDischPt;
	elseif _entRow = ETRow_VoyageInbound then
		return YACriteriaType_VoyageInbound;
	elseif _entRow = ETRow_WeightRange then
		return YACriteriaType_Weight;		
	elseif _entRow = ETRow_Stevedore then
		return YACriteriaType_RelStevedore;
	elseif _entRow.isMeasurementType then
		if _entRow.pos(ETRow_RollingLength,6) &gt; 0 then	
			return YACriteriaType_RollingLength;	
		elseif  _entRow.pos(ETRow_Diameter,6) &gt; 0   then
			return YACriteriaType_Diameter;
		elseif  _entRow.pos(ETRow_Width,6) &gt; 0   then
			return YACriteriaType_CargoWidth;
		elseif  _entRow.pos(ETRow_Length,6) &gt; 0   then
			return YACriteriaType_CargoLength;
		elseif  _entRow.pos(ETRow_Height,6) &gt; 0   then
			return YACriteriaType_CargoHeight;
		endif;
	elseif _entRow = ETRow_BookingRef then								//navra1 - BUG 63499 - 22nd April 2024
		return YACriteriaType_BookingRef;								//navra1 - BUG 63499 - 22nd April 2024
	elseif _entRow = ETRow_Commodity then								//navra1 - BUG 63499 - 22nd April 2024
		return YACriteriaType_Commodity;								//navra1 - BUG 63499 - 22nd April 2024
	elseif _entRow = ETRow_SortingMethod then							//12.08.2024 navlc30 #64705[64704]
		return YACriteriaType_SortingMethod;
	
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_entRow" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isCOORow" id="6a46c6e3-f14b-4be1-9e01-438bd23a9f1b">
        <source>isCOORow(_attrName : String) : Boolean;
/*

Purpose:			This method checks whether the entRow is for the Ownership Change

Parameters:			Name of the entRow

Return Value:		

Date		Who		Reason
04/11/2024	navkc1 JIRA Bug MTN-33313: EUP | COO - Cargo Review screen's group table is not showing the Change of Ownership Number

*/

vars

begin
	
	if 	_attrName = ETRow_COODateTime or
		//_attrName = ETRow_CooFreeDaysConfigered or // This value derives from the storage details of the tracked item, not from the ownership change. So, it's not really a ownership row.
		_attrName = ETRow_COOINCOCode or
		_attrName = ETRow_COOINCODesc or
		_attrName = ETRow_OperatorNewCode or
		_attrName = ETRow_OperatorNewDesc or
		_attrName = ETRow_FreeDaysOperatorNew or
		_attrName = ETRow_COONumber or
		_attrName = ETRow_OperatorReceiveCode or
		_attrName = ETRow_OperatorReceiveDesc or
		_attrName = ETRow_FreeDaysOperatorOld or
		_attrName = ETRow_OperatorPreviousCode or
		_attrName = ETRow_OperatorPreviousDesc or
		_attrName = ETRow_OperatorStorageCode or
		_attrName = ETRow_OperatorStorageDesc
											then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseDetailsMatch" id="8da09cfc-fa1f-424e-90fb-4619fa5aa103">
        <source>isReleaseDetailsMatch(_reserveDetails : CM_ReserveDetail; _jdo : JadeDynamicObject) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/05/2024	navkc1 Bug 64182: MTN - COO Release by Type Validation Issue

*/

vars
	index 				: Integer;
	type 				: Type;
	value 				: Any;
	undgCodes			: String;
	receivedDT, 
	releasedDT 			: TimeStamp;
	bol 				: CM_BOLIn;
	mark,
	markNumber,
	clientRef,
	orderNumber, 
	purchaseOrder,
	remarks,
	vesselCode			: String;
	iter 				: Iterator;
	ti 					: CM_TrackedItem;
	reserveSelection 	: CM_ReserveSelection;
	cargoGroup			: CM_CargoGroup;
	colour 				: String;
	voyage 				: CM_Voyage;
	tisInGrouping 		: CM_TIByCargoTypeIdDict;
	
	cargoType 			: CM_CargoType;
	subCargoType 		: CM_Product;
	iso 				: CM_ISOType;
	bolCode 			: String;
	terminal			: CM_Terminal;
	
begin
	terminal := _reserveDetails.getMyTerminal();
	
	if not _reserveDetails.isReserveSelection() then
		return false;
	endif;
	
	reserveSelection := _reserveDetails.CM_ReserveSelection;
	
	// Voyage Code and BOL
			if _jdo.getPropertyInfoByName(ETRow_VoyageCode,index,type,value) then
				voyage := terminal.allVoyagesByCode.getAtKeyGeq(value.String,null);
				if voyage &lt;&gt; null 
				and voyage.code &lt;&gt; value.String then
					voyage := null;
				endif;
			endif;
			
			if _jdo.getPropertyInfoByName(ETRow_BillOfLading,index,type,bolCode) then
				if voyage &lt;&gt; null and bolCode &lt;&gt; null then
					bol := voyage.getBOL(bolCode.String);
				endif;
				
				if bol &lt;&gt; null then
					if bol &lt;&gt; reserveSelection.myBOLIn then
						return false;
					endif;
				endif;
			endif;
	
	// Mark
			if _jdo.getPropertyInfoByName(ETRow_Mark,index,type,value) then
				mark := value.String;
				
				if mark &lt;&gt; null then
					if mark &lt;&gt; reserveSelection.markSelection then
						return false;
					endif;
				endif;
			endif;
	
	// Mark Number
			if _jdo.getPropertyInfoByName(ETRow_MarkNumber,index,type,value) then
				markNumber := value.String;
				if markNumber &lt;&gt; null then
					if markNumber &lt;&gt; reserveSelection.markNumber then
						return false;
					endif;
				endif;
			endif;
			
	// Client Reference
			if _jdo.getPropertyInfoByName(ETRow_ClientRef,index,type,value) then
				clientRef:=value.String;
				if clientRef &lt;&gt; null then
					if clientRef &lt;&gt; reserveSelection.cargoMatchClientReference then
						return false;
					endif;
				endif;
			endif;
	
	// Order Number
			if _jdo.getPropertyInfoByName(ETRow_OrderNumber,index,type,value) then
				orderNumber:=value.String;
				if orderNumber &lt;&gt; null then
					if orderNumber &lt;&gt; reserveSelection.cargoMatchOrderNumber then
						return false;
					endif;
				endif;
			endif;
			
	// Purchase Order
			if _jdo.getPropertyInfoByName(ETRow_PurchaseOrder,index,type,value) then
				purchaseOrder:=value.String;
				if purchaseOrder &lt;&gt; null then
					if purchaseOrder &lt;&gt; reserveSelection.cargoMatchPurchaseOrder then
						return false;
					endif;
				endif;
			endif;
	
	// Receive DT
			receivedDT:=null;
			if _jdo.getPropertyInfoByName(ETRow_ReceivedDT,index,type,value) then
				if value.String &lt;&gt; null then
					receivedDT:=value.String.asTimeStampJMT;
					if receivedDT &lt;&gt; null then
						if receivedDT &lt;&gt; reserveSelection.cargoMatchReceiveDate then
							return false;
						endif;
					endif;
				endif;
			endif;
	
	// Release DT
			releasedDT:=null;
			if _jdo.getPropertyInfoByName(ETRow_ReleasedDT,index,type,value) then
				if value.String &lt;&gt; null then
					releasedDT:=value.String.asTimeStampJMT;
					if releasedDT &lt;&gt; null then
						if releasedDT &lt;&gt; reserveSelection.cargoMatchReleaseDate then
							return false;
						endif;
					endif;
				endif;
			endif;
	
	// Remarks
			if _jdo.getPropertyInfoByName(ETRow_Remarks,index,type,value) then
				remarks:=value.String;
				if remarks &lt;&gt; null then
					if remarks &lt;&gt; reserveSelection.remarks then
						return false;
					endif;
				endif;
			endif;
	
	// Vessel
			if _jdo.getPropertyInfoByName(ETRow_Vessel,index,type,value) then
				vesselCode:=value.String;
				if vesselCode &lt;&gt; null then
					if vesselCode &lt;&gt; reserveSelection.cargoMatchVesselCode then
						return false;
					endif;
				endif;
			endif;
			
	// UNDGCodes
			if _jdo.getPropertyInfoByName(ETRow_AllIMDGCodes,index,type,value) then
				undgCodes:=value.String;
				if undgCodes &lt;&gt; null then
					if undgCodes &lt;&gt; reserveSelection.cargoMatchUNDGcode then
						return false;
					endif;
				endif;
			endif;
	
	// Colour
			if _jdo.getPropertyInfoByName(ETRow_Colour,index,type,value) then
				colour := value.String;
				if colour &lt;&gt; null then
					if colour &lt;&gt; reserveSelection.colour then
						return false;
					endif;
				endif;
			endif;
	
	// Cargo Type, Cargo SubTpye, ISO, BOL (Again?), Cargo Group
			if _jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then		
				tisInGrouping := value.CM_TIByCargoTypeIdDict;
				ti := tisInGrouping.first;
				iter:= tisInGrouping.createIterator;

				if ti &lt;&gt; null then
					
					// Cargo Type
					cargoType := ti.myCargoType;
					if cargoType &lt;&gt; null then
						if cargoType &lt;&gt; reserveSelection.myCargoType then
							return false;
						endif;
					endif;
					
					// Cargo SubType
					subCargoType := ti.myProduct;
					if subCargoType &lt;&gt; null then
						if subCargoType.code &lt;&gt; reserveSelection.getCargoSubType() then
							return false;
						endif;
					endif;
					
					// ISO
					if ti.isContainer then
						iso := ti.getISOTypeObject();
						if iso &lt;&gt; null then
							if iso &lt;&gt; reserveSelection.myISOType then
								return false;
							endif;
						endif;
					endif;
					
					// BOL (again?)
					if bol = null and bolCode &lt;&gt; null then
						if ti.myVoyage &lt;&gt; null then
							bol := ti.myVoyage.getBOL(bolCode);
							if bol &lt;&gt; null then
								if bol &lt;&gt; reserveSelection.myBOLIn then
									return false;
								endif;
							endif;
						endif;
					endif;
					
					// Cargo Group
					if _jdo.getPropertyInfoByName(ETRow_CargoGroupId,index,type,value) then
						cargoGroup := ti.myCargoGroup;
						if cargoGroup &lt;&gt; null then
							if cargoGroup &lt;&gt; reserveSelection.myCargoGroup then
								return false;
							endif;
						endif;
					endif;
					
					// BOL (again again??)
					if ti.myBOLDtl &lt;&gt; null then
						bol := ti.myBOLDtl.myBOL.CM_BOLIn;
						if bol &lt;&gt; null then
							if bol &lt;&gt; reserveSelection.myBOLIn then
								return false;
							endif;
						endif;
					endif;
				endif;
			endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_reserveDetails" type="CM_ReserveDetail"/>
        <Parameter name="_jdo" type="JadeDynamicObject"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseHeaderMatch" id="b0283f9f-e67f-48b1-b756-8c29dc96869d">
        <source>isReleaseHeaderMatch(_reserveHeader : CM_BulkRelease; _jdo : JadeDynamicObject) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/05/2024	navkc1 Bug 64182: MTN - COO Release by Type Validation Issue

*/

vars
	consigneeCode,
	consigneeDesc,
	consignorCode,
	consignorDesc,
	operatorCode,
	ffCode				: String;
	trackedItemArray,
	value				: Any;
	index				: Integer;
	type				: Type;
	
	ti					: CM_TrackedItem;
	cargoGrp			: CM_CargoGroup;
	operator 			: CM_Operator;
	tisInGrouping 		: CM_TIByCargoTypeIdDict;	
	voyage 				: CM_Voyage;
	consignee, 
	consignor,
	ff 					: CM_ConsigneeConsignor;
	destinationPort, 
	loadPort, 
	dischargePort 		: CM_Port;
		
	bookingRef 			: CM_BookingRef;
	tis					: CM_TIByCargoTypeIdDict;
	terminal			: CM_Terminal;
	
begin
	terminal := _reserveHeader.myTerminal;
	
	// Operator
			if  _jdo.getPropertyInfoByName(ETRow_OperatorCode,index,type,value) then
				//it is the operatorCode 
				operator:=app.myRoot.allOperators[value.String];
				if operator &lt;&gt; null then
					operatorCode:=operator.code;
				else
					operator := app.myRoot.getOperatorByDesc(value.String);
				endif;
			else
				if _jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then		
					tisInGrouping := value.CM_TIByCargoTypeIdDict;
					ti := tisInGrouping.first;
					if ti &lt;&gt; null then
						cargoGrp := ti.myCargoGroup;
					endif;
					if cargoGrp &lt;&gt; null then
						operator := cargoGrp.myOperator;
					endif;
				endif;
			endif;
			
			if operator &lt;&gt; _reserveHeader.myOperator then
				return false;
			endif;
	
	// Consignee
			if  _jdo.getPropertyInfoByName(ETRow_Consignee,index,type,value) then
				if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then
					consignee:= app.myRoot.allConsigneeConsignorsForDescr[value.String];
				else
					consignee:= app.myRoot.allConsigneeConsignors[value.String];
				endif;
				if consignee &lt;&gt; null then
					consigneeCode	:= consignee.code;
					consigneeDesc	:= consignee.description;
					
					if consigneeCode &lt;&gt; _reserveHeader.consigneeCode then
						return false;
					endif;
					
					if consigneeDesc &lt;&gt; _reserveHeader.consigneeDesc then
						return false;
					endif;
				endif;
			endif;	
		
	// Consignor
			if  _jdo.getPropertyInfoByName(ETRow_Consignor,index,type,value) then
				if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then			//10.04.2024 navbs1 #63606
					consignor := app.myRoot.allConsigneeConsignorsForDescr[value.String];
				else
					consignor := app.myRoot.allConsigneeConsignors[value.String];
				endif;
				if consignor &lt;&gt; null then
					consignorCode:=consignor.code;
					consignorDesc:=consignor.description;
					
					if consignorCode &lt;&gt; _reserveHeader.consignorCode then
						return false;
					endif;
					
					if consignorDesc &lt;&gt; _reserveHeader.consignorDesc then
						return false;
					endif;
				endif;
			endif;	
	
	// Destination port
			if  _jdo.getPropertyInfoByName(ETRow_DestinationPort,index,type,value) then
				destinationPort := app.myRoot.allPorts[value.String];
				
				if destinationPort &lt;&gt; null then
					if destinationPort &lt;&gt; _reserveHeader.myDestinationPort then
						return false;
					endif;
				endif;
			endif;
	
	// Discharge port
			if  _jdo.getPropertyInfoByName(ETRow_DischargePort,index,type,value) then
				dischargePort := app.myRoot.allPorts[value.String];
				
				if dischargePort &lt;&gt; null then
					if dischargePort &lt;&gt; _reserveHeader.myDischargePort then
						return false;
					endif;
				endif;
			endif;
	
	// Freight forwarder		
			if  _jdo.getPropertyInfoByName(ETRow_FreightForwarderCode,index,type,value) then
				ff := app.myRoot.allConsigneeConsignors[value.String];
				if ff &lt;&gt; null then
					ffCode := ff.code;
				endif;
			else 
				if _jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,trackedItemArray) then
					create tis transient;		
					if trackedItemArray.isKindOf(CM_TIByCargoTypeIdDict) then
						trackedItemArray.CM_TIByCargoTypeIdDict.copy(tis);
					endif;		
					
					if not tis.isEmpty then
						ti := tis.first;
					endif;
					
					if ti &lt;&gt; null then
						ff := app.myRoot.allConsigneeConsignors[ti.freightForwarderCode];
						if ff &lt;&gt; null then
							ffCode:=ff.code;
						endif;
					endif;		
				endif;		
			endif;
			
			if ffCode &lt;&gt; _reserveHeader.freightPayerCode then
				return false;
			endif;
	
	// Load port
			if  _jdo.getPropertyInfoByName(ETRow_LoadPort,index,type,value) then
				loadPort := app.myRoot.allPorts[value.String];
			endif;
			if loadPort = null and terminal &lt;&gt; null then
				loadPort := app.myRoot.allPorts[terminal.getConfig(PortDestCode).String];	
			endif;
			
			if loadPort &lt;&gt; null then
				if loadPort &lt;&gt; _reserveHeader.myLoadPort then
					return false;
				endif;
			endif;
	
	// Voyage code
			if  _jdo.getPropertyInfoByName(ETRow_VoyageCode,index,type,value) then
				if terminal &lt;&gt; null then
					voyage := terminal.lookupVoyage(value.String,null,false);
				endif;
				if voyage &lt;&gt; null then
					if voyage &lt;&gt; _reserveHeader.myVoyage then
						return false;
					endif;
				endif;
			endif;	
			
	//booking ref
			if  _jdo.getPropertyInfoByName(ETRow_BookingRef,index,type,value) then
				bookingRef := terminal.getBookingReferenceExact(operatorCode, value.String,voyage);
				
				if bookingRef &lt;&gt; null then
					if bookingRef &lt;&gt; _reserveHeader.myBookingRefStock then
						return false;
					endif;
				endif;
			endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_reserveHeader" type="CM_BulkRelease"/>
        <Parameter name="_jdo" type="JadeDynamicObject"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseRequestMatchGrouping" id="edf345a0-7452-4e2c-b34e-70c61723a79a">
        <source>isReleaseRequestMatchGrouping(_reserveHeader : CM_BulkRelease; _reserveDetails : CM_ReserveDetail; _jdo : JadeDynamicObject) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/05/2024	navkc1 Bug 64182: MTN - COO Release by Type Validation Issue

*/

vars
	
	
begin
	return self.isReleaseHeaderMatch(_reserveHeader, _jdo) and self.isReleaseDetailsMatch(_reserveDetails, _jdo);
epilog

end;</source>
        <Parameter name="_reserveHeader" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetails" type="CM_ReserveDetail"/>
        <Parameter name="_jdo" type="JadeDynamicObject"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reset" id="c1cfc40b-1976-437f-a812-be776552fbeb">
        <updating/>
        <source>reset(	_terminal : CM_Terminal;
		_criteriaLineHolder : CM_QueryCriteriaLineHolder;
		_allGroupingRows : EntTableRowArray;
		_allAddtionalRows : EntTableRowArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2022	jlier1	Initial creation 53515

*/

vars

begin
	delete self.myEnqController;
	
	create self.myEnqController  transient; 
	create self.myEnqController.allObjects as CM_TISet transient;
	myEnqController.myTerminal := _terminal;
	myEnqController.myCriteriaLineHolder := _criteriaLineHolder;
	self.allGroupingRows:=_allGroupingRows;
	self.allAdditionalRows:=_allAddtionalRows;
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_allGroupingRows" type="EntTableRowArray"/>
        <Parameter name="_allAddtionalRows" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="setAllGroupings" id="6b286c41-72cb-4bb2-9ffa-72677663a157">
        <source>setAllGroupings() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2022	jlier1	Initial creation 53515
//15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV
06 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation
*/

vars
	iter : Iterator;
	ti : CM_TrackedItem;
begin
	self.deleteGroupings();
	
	iter:=self.myEnqController.allObjects.createIterator;
	while iter.next(ti) do
		self.setReleaseCollection(ti);
	endwhile;
	self.setReleaseGrouping();
	delete iter;     //06 Aug 2025 navrv30 MTN 35150 Handle leaks
	iter:=self.myEnqController.allObjects.createIterator;	
	while iter.next(ti) do	
		self.setGrouping(ti);		
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCOORowsGroupValue" id="86d32fc3-4135-4b8b-99ea-0fb2e2ace252">
        <source>setCOORowsGroupValue(_attrName : String; _grouping : JadeDynamicObject input; _allCOOHeaders : CM_OwnershipChangeByRef);
/*

Purpose:			This method set Ownership Change attributes value in the grouping

Parameters:			_attrName - COO ETRow selected
					_grouping - Dynamic object created for the group that we gonna be setting
					_allCOOHeaders - Contains all ownership change of the tracked item

Return Value:		

Date		Who		Reason
04/11/2024	navkc1 JIRA Bug MTN-33313: EUP | COO - Cargo Review screen's group table is not showing the Change of Ownership Number

*/

vars
	
	cooHeader 		: CM_OwnershipChange;
	incoTerm		: CM_InvoiceINCOTerm;
	operator		: CM_Operator;
	str,
	groupValue 		: String;
	index 			: Integer;
	type			: Type;
	value			: Any;
	
begin
	
	// If we don't have the attribute in the grouping, return;
	if not _grouping.getPropertyInfoByName(_attrName, index, type, value) then
		return;
	endif;
	
	// Make sure we keep what we have
	groupValue := value.String;
	
	foreach cooHeader in _allCOOHeaders do
		
		if _attrName = ETRow_COODateTime then
			str := app.systemToLocalTime(cooHeader.dateTimeCOO).asStringJMT();
			
		elseif _attrName = ETRow_COOINCOCode then
			incoTerm := cooHeader.myIncoterm;
			
			if incoTerm = null then
				continue;
			endif;
			
			str := incoTerm.code;
		elseif _attrName = ETRow_COOINCODesc then
			incoTerm := cooHeader.myIncoterm;
			
			if incoTerm = null then
				continue;
			endif;
			
			str := incoTerm.description;
		elseif _attrName = ETRow_OperatorNewCode then
			operator := cooHeader.myOperatorNew;
			
			if operator = null then
				continue;
			endif;
			
			str := operator.code;
		elseif _attrName = ETRow_OperatorNewDesc then
			operator := cooHeader.myOperatorNew;
			
			if operator = null then
				continue;
			endif;
			
			str := operator.description;
		elseif _attrName = ETRow_FreeDaysOperatorNew then
			if cooHeader.freeDaysOperatorNew = null then
				continue;
			endif;
			
			str := cooHeader.freeDaysOperatorNew.String;
		elseif _attrName = ETRow_COONumber then
			if cooHeader.isApproved() then
				str := cooHeader.refNumber;
			else
				str := cooHeader.refNumber &amp; " (na)";
			endif;
		elseif _attrName = ETRow_OperatorReceiveCode then
			operator := cooHeader.myOperatorOrig;
			
			if operator = null then
				continue;
			endif;
			
			str := operator.code;
		elseif _attrName = ETRow_OperatorReceiveDesc then
			operator := cooHeader.myOperatorOrig;
			
			if operator = null then
				continue;
			endif;
			
			str := operator.description;
		elseif _attrName = ETRow_FreeDaysOperatorOld then
			if cooHeader.freeDaysOperatorOld = null then
				continue;
			endif;
			
			str := cooHeader.freeDaysOperatorOld.String;
		elseif _attrName = ETRow_OperatorPreviousCode then
			operator := cooHeader.myOperatorOld;
			
			if operator = null then
				continue;
			endif;
			
			str := operator.code;
		elseif _attrName = ETRow_OperatorPreviousDesc then
			operator := cooHeader.myOperatorOld;
			
			if operator = null then
				continue;
			endif;
			
			str := operator.description;
		elseif _attrName = ETRow_OperatorStorageCode then
			operator := cooHeader.myOperatorStorage;
			
			if operator = null then
				continue;
			endif;
			
			str := operator.code;
		elseif _attrName = ETRow_OperatorStorageDesc then
			operator := cooHeader.myOperatorStorage;
			
			if operator = null then
				continue;
			endif;
			
			str := operator.description;
		endif;
		
		/*
		if str = null or groupValue.pos(str, 1) &gt; 0 then
			continue;
		else
			if groupValue = null then
				groupValue := str;
			else
				groupValue &amp;= Comma &amp; str;
			endif;
		endif;
		*/
		
		groupValue.addStringToList(str, Comma); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	_grouping.setPropertyValue(_attrName, groupValue);
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_grouping" type="JadeDynamicObject" usage="input"/>
        <Parameter name="_allCOOHeaders" type="CM_OwnershipChangeByRef"/>
    </JadeMethod>
    <JadeMethod name="setGrouping" id="54c4ae3d-8d19-4568-9b21-16052f1cc25b">
        <source>setGrouping(_ti : CM_TrackedItem) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2022	jlier1	Initial creation 53515
15/03/2023	navkc1	Bug 56481: EUP - 1035 Error (String Too Long) when trying to group the results with 20+ Grouping Criteria.
05/07/2023 navmv20 CR 58410 Task 58414: UI - Cargo Review - Grouping Table
24 Jul 2023	jlirs1	NFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
24 July 2023 navmv20 CR 58239 Task 58240: UI - New COO columns
18 September 2023 navmv20 Bug 60482: EUP | Cargo Review Quantity Columns
24 November 2023 navmv20 Bug 61267: FR | EUP - Release Request by Type - Cargo Group &lt;&lt;53383&gt;&gt;
23/04/2024 navra1  BUG 63499 - FR | 53383 - Cargo Group Reservation - part III
//15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV
18 September 2024 navrv30 Bug 65897: TPT | Cargo Review Issues
04/11/2024	navkc1 JIRA Bug MTN-33313: EUP | COO - Cargo Review screen's group table is not showing the Change of Ownership Number
09/11/2024 navrv30 JIRA MTN 23312 EUP | FR 53383 - Cargo Group Reservation - part IV
04/01/2025 navrv30 JIRA 34239 EUP | Resolve Cargo Group being displayed from Grouping Criteria which doesnt have a Cargo Group
08 Apr 2025 navrv30	Bug MTN-34345: EUP | FR - Cargo Review - Total Quantity Pending is not correct
23 September 2025	navrv30	 MTN 35904 MTN | Cargo Review Quantities
*/

vars
	groupingName : String;
	grouping : JadeDynamicObject;
	tis  : CM_TIByCargoTypeIdDict;
	attrName : String;
	attrVal : Any;
	index : Integer;
	type : Type;
	str, mtype, relReqNumber : String;
	value : Any;
	numDecimals : Integer;
	posDec : Integer;
	decimalSeparator,newValue, currentValue : String;
	newAmount ,currentAmount: Integer;
	criteriaLine 		: CM_SelectorCriteriaLine;
	entTableRow : EntTableRow;
	currentValues, newValues : StringArray;
	start, pos , i : Integer;
	updateValues : Boolean;
	relReq : CM_BulkRelease;
	reserveDtl : CM_ReserveDetail; //05/07/2023 navmv20 CR 58410 Task 58414
	entTableDef : EntTableDef;
	allAddtionalRowsAndDefaults : EntTableRowArray;
	allAddtionalGroupingDefaults : EntTableRowArray;
	cooHeaders : CM_OwnershipChangeByRef;
	isRowCOO,
	checkedCOO : Boolean;
	
begin
	decimalSeparator := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;	
	 groupingName:=self.getUniqueGroupingName(_ti);
	 //no groupings selected then just add ti.id
	 if groupingName = null then
		groupingName:=_ti.id;
	 endif;
	 
	 grouping:=self.getGrouping(groupingName);
	 
	 if grouping = null then
		create grouping transient;
		//grouping.name:=groupingName; //15/03/2023	navkc1	#Bug 56481 - Do not use JDO.name, it has limited number of chars. Use the run time property "GroupingName" below instead.
		
		//15/03/2023	navkc1	#Bug 56481
		grouping.addProperty(GroupingName, String);
		grouping.setPropertyValue(GroupingName, groupingName);
		
		grouping.addProperty(CargoReviewAllTrackedItems, CM_TIByCargoTypeIdDict);
		create tis transient;
		grouping.setPropertyValue(CargoReviewAllTrackedItems, tis);
		self.allTransients.add(tis);
		self.allGroupings.add(grouping);
	else
		tis:=grouping.getPropertyValue(CargoReviewAllTrackedItems).CM_TIByCargoTypeIdDict;
	endif;
	 
	if tis &lt;&gt; null then
		tis.add(_ti);
	endif;
	
	create cooHeaders transient; //04/11/2024	navkc1 JIRA Bug MTN-33313
	create currentValues transient;
	create newValues transient;
	foreach criteriaLine in self.myEnqController.myCriteriaLineHolder.allCriteriaLines discreteLock do
		if criteriaLine.myQueryProperty = null then
			continue;
		endif;
		attrName:=criteriaLine.propName;
		if attrName = CM_TrackedItem::getContainerNumberText.name then		// 24 Jul 2023	jlirs1	NFS 59187 (59019)
			attrVal := _ti.getContainerNumberText();
		else
			attrVal := criteriaLine.myQueryProperty.getValueForObject(_ti,criteriaLine.myQueryOperator); // _ti.tryGetPropertyValue(attrStr,propertyValid);
		endif;
		if attrVal.isKindOf(TimeStamp) then
			attrVal:=attrVal.TimeStamp.systemToLocalTimeUsingObject(self.myEnqController.myTerminal);
		endif;	
		attrVal:=criteriaLine.myQueryProperty.translateToDisplayValue(attrVal);
		if not grouping.getPropertyInfoByName(attrName,index,type,value) then
			grouping.addProperty(attrName, attrVal.getType());
			grouping.setPropertyValue(attrName, attrVal);
			
		else
			currentValues.clear;
			value.String.getTokensForDelimiter(",",currentValues);
			
			newValues.clear;
			attrVal.String.getTokensForDelimiter(",",newValues);
			foreach newValue in newValues do
				if not currentValues.includes(newValue) then
					grouping.setPropertyValue(attrName,value.String &amp;"," &amp; newValue);
				endif;
			endforeach;
		endif;
		
	endforeach;	
	
	
	foreach entTableRow in self.allGroupingRows discreteLock do
		attrName:=entTableRow.name;
		attrVal := _ti.getDisplayStringForAttribute(attrName,false);
		
		if not grouping.getPropertyInfoByName(attrName,index,type,value) then
			grouping.addProperty(attrName, attrVal.getType());
			grouping.setPropertyValue(attrName, attrVal);
		else
			//??? this is weird if it already exists not sure what to do
			//should be the same since it was grouped like this
			//grouping.setPropertyValue(attrStr, attrVal);
		endif;
	endforeach;
	
	//30.09.2024 navrv30 Bug 65073
	create allAddtionalRowsAndDefaults transient;
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewAdditional);
	allAddtionalRowsAndDefaults.add(entTableDef.getEntTableRow(ETRow_TotalQuantity));
	allAddtionalRowsAndDefaults.add(entTableDef.getEntTableRow(ETRow_QuantityReserved));
	self.allAdditionalRows.copyNoDups(allAddtionalRowsAndDefaults);
	
	foreach  entTableRow in  allAddtionalRowsAndDefaults discreteLock do
		attrName:=entTableRow.name;
		isRowCOO := self.isCOORow(attrName); //04/11/2024	navkc1 JIRA Bug MTN-33313
		//navra1 - BUG 63499 - 23rd April 2024 - start
		//18/09/2023 navmv20 Bug 60482
		/*hasCargoGroup := grouping.getPropertyInfoByName(ETRow_CargoGroupId,index,type,value); // Grouping by Cargo Group?
		if hasCargoGroup
		and self.getDataFromCargoGroup(attrName, _ti) then
		/* //18/09/2023 navmv20 Bug 60482
		//05/07/2023 navmv20 CR 58410 Task 58414 - START
		if attrName = ETRow_Reservations and _ti.myCargoGroup &lt;&gt; null then
			attrVal := _ti.myCargoGroup.getDisplayStringForAttribute(attrName,false);
		//24/07/2023 navmv20 CR 58239 Task 58240 - start
		elseif  grouping.getPropertyInfoByName(ETRow_CargoGroupId,index,type,value)
		and _ti.myCargoGroup &lt;&gt; null
		and _ti.myCargoGroup.allOwnershipChange.isNotEmpty
		and (attrName = ETRow_COONumber
			or attrName = ETRow_COODateTime
			or attrName = ETRow_COOINCOCode
			or attrName = ETRow_OperatorPreviousCode
			or attrName = ETRow_OperatorReceiveCode
			or attrName = ETRow_COOINCODesc
			or attrName = ETRow_OperatorPreviousDesc
			or attrName = ETRow_OperatorReceiveDesc
			or attrName = ETRow_OperatorStorageCode 
			or attrName = ETRow_OperatorStorageDesc 
			or attrName = ETRow_FreeDaysOperatorOld
			or attrName = ETRow_CooFreeDaysConfigered
			or attrName = ETRow_FreeDaysOperatorNew
			or attrName = ETRow_FreeStorageExpiryDate
			or attrName = ETRow_FutureStorageDate
			or attrName = ETRow_FreeDaysAdditional
			or attrName = ETRow_CustDocSequence// ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
			)
		then
		*/
		//navra1 - BUG 63499 - 23rd April 2024 - end
		
		//navra1 - BUG 63499 - 23rd April 2024 - start
		if isRowCOO then //04/11/2024	navkc1 JIRA Bug MTN-33313
			attrVal := "";
			if not checkedCOO then
				_ti.getAlLCOOHeaders(cooHeaders);
			endif;
			checkedCOO := true;
			
		elseif attrName = ETRow_Reservations then
			//attrVal := _ti.myCargoGroup.getDisplayStringForAttribute(attrName,false);
			//attrVal := self.getResFrmCGBOLVoyOrBooking(_ti);
			attrVal := self.getResFrmCGBOLVoyOrBooking(_ti, grouping); //21/05/2024	navkc1 Bug 64182
		elseif self.getDataFromCargoGroup(attrName, _ti) then		
			attrVal := _ti.myCargoGroup.getDisplayStringForAttribute(attrName,false);
		//24/07/023 navmv20 CR 58239 Task 58240- end
		//navra1 - BUG 63499 - 23rd April 2024 - end
		else
			attrVal := _ti.getDisplayStringForAttribute(attrName,false);
		endif;
		//attrVal := _ti.getDisplayStringForAttribute(attrName,false);
		//05/07/2023 navmv20 CR 58410 Task 58414 - END
		
		if attrName.isMeasurementType and attrVal = null then
			attrVal:=0.asStringJMT;
		endif;
		
		if not grouping.getPropertyInfoByName(attrName,index,type,value) then
			if attrVal = null then
				if isRowCOO then
					//04/11/2024	navkc1 JIRA Bug MTN-33313
					// If this is a coo row, we are setting the value at the very end.
					// Still create this with empty value for now
				else
					continue;
				endif;
			endif;
			grouping.addProperty(attrName, attrVal.getType());
			grouping.setPropertyValue(attrName, attrVal);
			//24/11/2023 navmv20 Bug 61267
			/*if attrName = ETRow_Reservations then // ### TFS BUG 56530 21FEB2023 NAVAB1 - only calculate this once
				calcReservedAmounts := true;
			endif;*/
		else
			//20/11/2024	navkc1 JIRA Bug MTN-33313 - Set the value later
			if isRowCOO then
				continue;
			endif;
			//??? this is weird if it already exists not sure what to do
			//should be the same since it was grouped like this
			//grouping.setPropertyValue(attrStr, attrVal);
			if attrName.isMeasurementType then
				//always a string but strip of the measurement name and get number of decimals if any
				posDec:=attrVal.String.pos(decimalSeparator,1);
				if posDec &gt; 0 then
					numDecimals:=attrVal.String.length-posDec;
				endif;
				grouping.setPropertyValue(attrName,(value.Decimal + attrVal.Decimal).asStringJMTWithPrecision(numDecimals,false));
			else
				if value &lt;&gt; null then
					if attrName = ETRow_Reservations then // ### TFS BUG 56530 21FEB2023 NAVAB1, check to see if RelReq num has been included yet, if not need to recalc Rel Req requested numbers
						//calcReservedAmounts := false; //24/11/2023 navmv20 Bug 61267
						//05/07/2023 navmv20 CR 58410 Task 58414 - start
						if _ti.myCargoGroup &lt;&gt; null then
							reserveDtl:=_ti.myCargoGroup.allReserveDetails.first;
							if reserveDtl &lt;&gt; null then
								relReq := reserveDtl.myReserveHeader;
							endif;
						else
						//05/07/2023 navmv20 CR 58410 Task 58414 - end
							relReq := _ti.allBulkReleasesAssigned.first;
						endif; //05/07/2023 navmv20 CR 58410 Task 58414
						if relReq &lt;&gt; null then
							relReqNumber := relReq.code;
							if value.String.pos(relReqNumber,1)  = 0 then
								//calcReservedAmounts := true; //24/11/2023 navmv20 Bug 61267
							endif;
						endif;
					endif;
					//18/09/2023 navmv20 Bug 60482 - start
					//if value.String.isInteger then
					if entTableRow.inputType = Table.InputType_TextNumeric then
					//18/09/2023 navmv20 Bug 60482 - end
						grouping.setPropertyValue(attrName,(value.Integer +  attrVal.Integer).asStringJMT);
					else
						
					
						currentValues.clear;
						value.String.getTokensForDelimiter(",",currentValues);
						
						newValues.clear;
						attrVal.String.getTokensForDelimiter(",",newValues);
						
						//write attrVal;
						
						foreach newValue in newValues do
							newAmount:=null;
							currentAmount:=null;
							if attrName = ETRow_PlannedLocn then	
								
								start:=1;
								pos:=newValue.pos("(",start);
								if pos  &gt; 0 then
									//get the amount
									newAmount:=newValue[pos+1:newValue.length-1].Integer;
									newValue:=newValue[1:pos-1].trimBlanks;									
								endif;
								
								i:=1;
								foreach currentValue in currentValues do
									start:=1;
									pos:=currentValue.pos("(",start);
									if pos  &gt; 0 then	
										//get the amount
										currentAmount:=currentValue[pos+1:currentValue.length-1].Integer;
										currentValue:=currentValue[1:pos-1].trimBlanks;									
									endif;						
									if newValue = currentValue then								
										if newAmount &lt;&gt; null then
											currentValues[i]:=currentValue &amp; "(" &amp; (currentAmount + newAmount).String &amp; ")";
											updateValues:=true;
										endif;
									endif;
									i:=i+1;
								endforeach;
								
								if updateValues then
									grouping.setPropertyValue(attrName,currentValues.asCSV(false));		
								else
									if newAmount &lt;&gt; null then
										grouping.setPropertyValue(attrName,value.String &amp;"," &amp; (newValue &amp; "(" &amp; newAmount.String &amp; ")").trimBlanks );
									else
										grouping.setPropertyValue(attrName,value.String &amp;"," &amp; newValue);
									endif;							
								endif;

							else
								
								if not currentValues.includes(newValue) then
									grouping.setPropertyValue(attrName,value.String &amp;"," &amp; newValue);
								endif;
							endif;
							
						endforeach;
					endif;
				endif;
			endif;
			
		endif;
	endforeach;
	
	// ### TFS BUG 56530 21FEB2023 NAVAB1
	//if calcReservedAmounts then //24/11/2023 navmv20 Bug 61267
		/*if grouping.getPropertyInfoByName(ETRow_QuantityReserved,index,type,value) then			//15.07.2024 navrv30 Bug 65073
			attrVal := self.getRelReqReservedQty(tis);
			grouping.setPropertyValue(ETRow_QuantityReserved,attrVal.Integer.asStringJMT);
		endif;*/
		
		// need to iterate allAdditionalRows and see if attrname includes ETRow_WeightReserved if it does then do this code for each one
		foreach  entTableRow in  allAddtionalRowsAndDefaults discreteLock do
			attrName:=entTableRow.name;	
			isRowCOO := self.isCOORow(attrName); //04/11/2024	navkc1 JIRA Bug MTN-33313
			//15.07.2024 navrv30 Bug 65073
			if attrName = ETRow_QuantityReserved then
				attrVal := self.getRelReqReservedQty(grouping); //21/05/2024	navkc1 Bug 64182
				grouping.setPropertyValue(ETRow_QuantityReserved,attrVal.Integer.asStringJMT);
			//08 Apr 2025 navrv30	Bug MTN-34345 Incorrectly associated with ETRow_PendingQuantity
			//added new row which specifies the quantity that is pending after the TIs being associated to Release requests
			elseif attrName = ETRow_ReservedPending then					//18 September 2024 navrv30 Bug 65897				
				attrVal := self.getRelReqReservedPending(grouping);        //23 Sep 2025 MTN 35904
				grouping.setPropertyValue(ETRow_ReservedPending,attrVal.Integer.asStringJMT);
			elseif attrName = ETRow_ReservedTotal then					//18 September 2024 navrv30 Bug 65897				
				attrVal := self.getRelReqReservedTotal(grouping);        //23 Sep 2025 MTN 35904
				grouping.setPropertyValue(ETRow_ReservedTotal,attrVal.Integer.asStringJMT);
			elseif attrName = ETRow_ReservedPotential then					//18 September 2024 navrv30 Bug 65897				
				attrVal := self.getRelReqReservedPotential(grouping);        //23 Sep 2025 MTN 35904
				grouping.setPropertyValue(ETRow_ReservedPotential,attrVal.Integer.asStringJMT);
			elseif attrName = ETRow_ReservedOffsite then					//18 September 2024 navrv30 Bug 65897				
				attrVal := self.getRelReqReservedOffsite(grouping);        //23 Sep 2025 MTN 35904
				grouping.setPropertyValue(ETRow_ReservedOffsite,attrVal.Integer.asStringJMT);
			elseif attrName.pos(ETRow_WeightReserved,1) &gt; 0 then
				if grouping.getPropertyInfoByName(attrName,index,type,value) then
					attrVal := self.getRelReqReservedWeight(tis);
					attrName.getRowNameMeasureType(str, mtype);
					attrVal := app.convertMeasurementForDisplay(mtype, attrVal.Decimal);
					grouping.setPropertyValue(attrName,attrVal.Decimal.asStringJMT);			
				endif;
			//24/11/2023 navmv20 Bug 61267 - start
			//15.07.2024 navrv30 Bug 65073
			elseif attrName.pos(ETRow_ReservedQtyByRail,1) &gt; 0 then
				//if grouping.getPropertyInfoByName(attrName,index,type,value) then
					attrVal := self.getReservedQtyMode(grouping, BR_TYPE_RAIL);
					grouping.setPropertyValue(attrName,attrVal.Integer.asStringJMT);
				//endif;
			elseif attrName.pos(ETRow_ReservedQtyRoad,1) &gt; 0 then
				//if grouping.getPropertyInfoByName(attrName,index,type,value) then
					attrVal := self.getReservedQtyMode(grouping, BR_TYPE_ROAD);
					grouping.setPropertyValue(attrName,attrVal.Integer.asStringJMT);
				//endif;
			elseif attrName.pos(ETRow_ReservedQtyByShip,1) &gt; 0 then
				//if grouping.getPropertyInfoByName(attrName,index,type,value) then
					attrVal := self.getReservedQtyMode(grouping, BR_TYPE_SHIP);
					grouping.setPropertyValue(attrName,attrVal.Integer.asStringJMT);
				//endif;
			elseif attrName.pos(ETRow_ReservedWtByRail,1) &gt; 0 then
				if grouping.getPropertyInfoByName(attrName,index,type,value) then
					attrVal := self.getReservedWtMode(tis, BR_TYPE_RAIL);
					attrName.getRowNameMeasureType(str, mtype);
					attrVal := app.convertMeasurementForDisplay(mtype, attrVal.Decimal);
					grouping.setPropertyValue(attrName,attrVal.Decimal.asStringJMT);
				endif;
			elseif attrName.pos(ETRow_ReservedWtByRoad,1) &gt; 0 then
				if grouping.getPropertyInfoByName(attrName,index,type,value) then
					attrVal := self.getReservedWtMode(tis, BR_TYPE_ROAD);
					attrName.getRowNameMeasureType(str, mtype);
					attrVal := app.convertMeasurementForDisplay(mtype, attrVal.Decimal);
					grouping.setPropertyValue(attrName,attrVal.Decimal.asStringJMT);
				endif;
			elseif attrName.pos(ETRow_ReservedWtByShip,1) &gt; 0 then
				if grouping.getPropertyInfoByName(attrName,index,type,value) then
					attrVal := self.getReservedWtMode(tis, BR_TYPE_SHIP);
					attrName.getRowNameMeasureType(str, mtype);
					attrVal := app.convertMeasurementForDisplay(mtype, attrVal.Decimal);
					grouping.setPropertyValue(attrName,attrVal.Decimal.asStringJMT);
				endif;
			//24/11/2023 navmv20 Bug 61267 - end
			elseif isRowCOO then //04/11/2024	navkc1 JIRA Bug MTN-33313
				self.setCOORowsGroupValue(attrName, grouping, cooHeaders);
			endif;
		endforeach;
	//endif; //24/11/2023 navmv20 Bug 61267
epilog
	delete currentValues;
	delete newValues;
	delete allAddtionalRowsAndDefaults;
	delete allAddtionalGroupingDefaults;
	delete cooHeaders;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setReleaseCollection" id="99caa814-58ec-466a-b526-866f1546a6e3">
        <source>setReleaseCollection(_ti : CM_TrackedItem) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
*/

vars
	attrName : String;
	entTableRow : EntTableRow;
	bulkRelease : CM_BulkRelease;
	reserveDetailSet : CM_ReserveDetailSet;
	bolIn : CM_BOLIn;
	myCommodity  : CM_Commodity;
begin
	
	
	foreach entTableRow in self.allGroupingRows discreteLock do
		attrName:=entTableRow.name;
		if attrName = ETRow_VoyageCode then
			if _ti.myVoyage &lt;&gt; null then
				foreach bulkRelease in _ti.myVoyage.allBulkReleases do
					reserveDetailSet := bulkRelease.allReserveDetails;		
					if reserveDetailSet &lt;&gt; null then
						reserveDetailSet.copyNoDuplicates(self.allReleaseTransients, false);
					endif;
				endforeach;
			endif;		
		
		elseif attrName = ETRow_CargoGroupId then
			if _ti.myCargoGroup &lt;&gt; null then
				reserveDetailSet := _ti.myCargoGroup.allReserveDetailAssigned;
			endif;
			if reserveDetailSet &lt;&gt; null then
				reserveDetailSet.copyNoDuplicates(self.allReleaseTransients, false);
			endif;		
		
		elseif attrName = ETRow_BillOfLading then
			if _ti.myBOLDtl &lt;&gt; null and  _ti.myBOLDtl.myBOL &lt;&gt; null then
				reserveDetailSet := _ti.myBOLDtl.myBOL.CM_BOLIn.allReserveDetails;						
			elseif _ti.myVoyage &lt;&gt; null then					//06 Sep 2024 navrv30 Bug 65073
				bolIn := _ti.myVoyage.getBOL(_ti.billOfLading);
				if bolIn &lt;&gt; null then
					reserveDetailSet := bolIn.allReserveDetails;
				endif;
			endif;
			if reserveDetailSet &lt;&gt; null then
				reserveDetailSet.copyNoDuplicates(self.allReleaseTransients, false);
			endif;
		//24/04/2025	navrv30	MTN 34319
		elseif attrName = ETRow_Commodity then
			if _ti.commodity &lt;&gt; null then
				 myCommodity := app.myRoot.allCommodities[_ti.commodity];
				reserveDetailSet := myCommodity.allReserveDetails;
			endif;
			if reserveDetailSet &lt;&gt; null then
				reserveDetailSet.copyNoDuplicates(self.allReleaseTransients, false);
			endif;
		endif;
		
		
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setReleaseGrouping" id="47705e42-3832-47ec-9548-950498110afa">
        <source>setReleaseGrouping() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV

*/

vars
	groupingName : String;
	grouping : JadeDynamicObject;
	decimalSeparator : String;
	reserveDtl : CM_ReserveDetail; //05/07/2023 navmv20 CR 58410 Task 58414
	relRequests : CM_ReserveDetailSet;
begin
	decimalSeparator := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;	
	
	foreach reserveDtl in self.allReleaseTransients do		
		
		groupingName := self.getUniqueRelGroupingName(reserveDtl);		 
		grouping:=self.getReleaseGrouping(groupingName);
		 
		if grouping = null then
			create grouping transient;
			
			grouping.addProperty(GroupingName, String);
			grouping.setPropertyValue(GroupingName, groupingName);
			
			grouping.addProperty(CargoReviewAllRelReqs, CM_ReserveDetailSet);
			create relRequests transient;
			grouping.setPropertyValue(CargoReviewAllRelReqs, relRequests);
			self.allGroupedRelRequests.add(relRequests);
			self.allReleaseGroupings.add(grouping);
		else
			relRequests:=grouping.getPropertyValue(CargoReviewAllRelReqs).CM_ReserveDetailSet;
		endif;		 
		relRequests.add(reserveDtl);
	endforeach;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
