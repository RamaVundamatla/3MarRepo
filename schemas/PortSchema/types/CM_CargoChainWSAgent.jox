    <JadeMethod name="addCargoChainEvent" id="51d2a374-e99b-48f4-a39d-efb21839cb8c">
        <updating/>
        <source>addCargoChainEvent(_transaction: CM_TITransaction;   _timeoutOccurred: Boolean io): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlger1	Initial creation

*/

vars
	authToken,
	eventJSON,
	jsonResponse,
	httpHeader,
	url				: String;
	resultCode : Integer;
	invalidTrans : Boolean;
	logMessage		: String;
	authResult		: Boolean;
	errorMessage	: String;
begin
	
	if _transaction = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _transaction,invalidTrans);
	
	//should never be null if we have a request 
	if _transaction.getCCEventType = null then
		return null;
	endif;
	
	if invalidTrans then
		return null;
	endif;
	
	logMessage := "No ID received from CargoChain";
	authResult := self.doAuthenticateUser(authToken, errorMessage, _timeoutOccurred);
	
	if _timeoutOccurred then
		logMessage := logMessage &amp; " - authentication timeout occurred";
		return false;
	endif;
	
	// If the authentication failed for any reason, return
	if not authResult then
		logMessage := logMessage &amp; " - authentication failed. " &amp; errorMessage;
		return false;
	endif;
	
	
	
	url := self.baseEndpoint &amp; _transaction.getCCEndPoint;

	httpHeader := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer " &amp; authToken;
	eventJSON:=_transaction.getCCEventJSON;
	// Send the request
	jsonResponse := self.doSendHTTPRequest(url,
										   "POST",
										   httpHeader,
										   eventJSON,
										   resultCode);
										   
	logMessage := logMessage &amp; resultCode.String;									   
	return resultCode = HttpResponseOK;
epilog
	
	app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_timeoutOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCargoChainIniSection" id="9ac2daad-17fc-4cb1-a302-8ee4a8c68dea">
        <source>createCargoChainIniSection(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2019	jlgmp6	Initial creation	TFS45230

*/
constants
	RestWSApplicationValue:	String = "JMTAppCargoChain";

vars
	iniFile: String;
	webServiceURLValue: String;
	commaPos: Integer;
	result: Boolean;

begin
	iniFile := app.getIniFileName();

	webServiceURLValue := app.getProfileString(iniFile, "WebOptions", "JMTAppHandheld_URLSpecifications", null);
	commaPos := webServiceURLValue.pos(Comma, 1);
	if commaPos &gt; 0 then
		webServiceURLValue := webServiceURLValue[1:commaPos - 1] &amp; "://" &amp; webServiceURLValue[commaPos + 1:end];
		commaPos := webServiceURLValue.pos(Comma, commaPos);
		if commaPos &gt; 0 then
			webServiceURLValue := webServiceURLValue[1:commaPos - 1] &amp; "/" &amp; webServiceURLValue[commaPos + 1:end];
		endif;
	endif;

	result := app.setProfileString(iniFile, CargoChainSection, WebServiceURL, webServiceURLValue);
	result := result and app.setProfileString(iniFile, CargoChainSection, RestWSApplication, RestWSApplicationValue);

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCargoProfile" id="e081f148-e8ae-4652-b02b-209014fe5efd">
        <updating/>
        <source>createCargoProfile(_cargo : CM_TrackedItem input; _timeoutOccurred: Boolean io): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2018	jlger1	Initial creation
15 October  2019    jlgrr1  // TFS47042 Updating activity history for each message
15 October  2019    jlgrr1  // TFS47042 Add Meta Data immediately after profile creation
15 October  2019    jlgrr1  // TFS47042 Return TRUE even if MetaData, Event, Registration messages fail.
11 Nov		2019 	cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)
*/
constants
	ProfilePublicId	: String = "profilePublicId";
	ProfileSecretId	: String = "profileSecretId";

vars
	jsonResponse,
	authToken,
	errorMessage	: String;
	authResult		: Boolean;
	url				: String;
	cargoJSON 		: String;
	jsonHelper		: CMIF_JsonHelper;
	success,
	loadState		: Boolean;
	xml				: JadeXMLDocument;
	xmlElement,
	xmlEvents,
	xmlProperty		: JadeXMLElement;
	xmlHelper		: CM_XmlHelperAgent;
	httpHeader,
	cargoChainID,
	cargoChainSecret,
	logMessage		: String;
	proxyTi			: CM_TrackedItem;
	resultCode		: Integer;
	profileType		: String;
	terminal		: CM_Terminal;

begin
	
	if _cargo = null then
		logMessage := "Null cargo";
		return false;
	endif;

	terminal := _cargo.getMyTerminal();
	if terminal &lt;&gt; null then
		app.myPassport.setMyTerminal(terminal);
	endif;
	
	logMessage := "No ID received from CargoChain";
	authResult := self.doAuthenticateUser(authToken, errorMessage, _timeoutOccurred);
	
	if _timeoutOccurred then
		logMessage := logMessage &amp; " - authentication timeout occurred";
		return false;
	endif;
	
	// If the authentication failed for any reason, return
	if not authResult then
		logMessage := logMessage &amp; " - authentication failed. " &amp; errorMessage;
		return false;
	endif;
	
	// Run As sent successfully				// TFS47042
	self.updateActivityHistory(true);		// TFS47042
	
	// Authenticated OK, so construct the request using the parameter information
	if _cargo.isContainer() then
		profileType := "Container";
	elseif _cargo.isBulkCargo() then
		profileType := "Bulk";
	else
		profileType := "Breakbulk";
	endif;

	create jsonHelper transient;
	create xml transient;
	xml.outputDeclaration := false;
	xml.addElement("root");

	xml.rootElement.addElement("profileType").setText(profileType);
	xml.rootElement.addElement("alias").setText(_cargo.id);

	cargoJSON := jsonHelper.convertXMLToJson(xml.writeToString());

	url := self.baseEndpoint &amp; '/createProfiles';

	httpHeader := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer " &amp; authToken;
	
	// Send the request
	jsonResponse := self.doSendHTTPRequest(url,
										   "POST",
										   httpHeader,
										   cargoJSON,
										   resultCode);

	if resultCode &lt;&gt; HttpResponseOK then
		if resultCode = null then
			logMessage := logMessage &amp; " - response timeout";
		else
			logMessage := logMessage &amp; " - error " &amp; resultCode.String;
		endif;
		return false;
	endif;
	
	// Profile created successfully		// TFS47042
	self.updateActivityHistory(true); 	// TFS47042
	
	// CargoChain is returning (valid) JSON with an array (of one) at root level, which is not valid for XML
	if jsonResponse[1:1] = CN_LEFT_BRACKET and jsonResponse[jsonResponse.length:1] = CN_RIGHT_BRACKET then
		jsonResponse := jsonResponse[2:jsonResponse.length() - 2];
	endif;

	// Interpret the response
	create xmlHelper transient;
	xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);

	// Just check we have a valid XML document
	if xml.rootElement = null then
		logMessage := logMessage &amp; " - null response";
		return false;
	endif;

	xmlElement := xml.rootElement.getElementByTagName(ProfilePublicId);
	if xmlElement = null then
		logMessage := logMessage &amp; " - " &amp; ProfilePublicId &amp; " element not found";
		return false;
	endif;
	cargoChainID := xmlElement.text();
	logMessage := "Received from CargoChain: ID " &amp; cargoChainID;

	xmlElement := xml.rootElement.getElementByTagName(ProfileSecretId);
	if xmlElement = null then
		logMessage := logMessage &amp; ". Element " &amp; ProfileSecretId &amp; " not found";
		return false;
	endif;
	cargoChainSecret := xmlElement.text();
	logMessage := logMessage &amp; ", secret " &amp; cargoChainSecret;

	app.cmsBeginLoad(loadState);
	proxyTi := _cargo.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	app.myTrxUA.trxUpdateTIExternalProfileID(proxyTi, cargoChainID, cargoChainSecret, app.myPassport);

	// TFS47042 - Ensure this is done immediately after creating the profile
	// add the oid as metadata
	resultCode := self.postMetadata(_cargo, authToken, cargoChainSecret,null);        //26.08.2019 cnwma1 TFS #46185
	if resultCode = HttpResponseNoContent then		// NoContent is correct response
		logMessage := logMessage &amp; ". Metadata set";
	else
		logMessage := logMessage &amp; ". Metadata not set; error " &amp; resultCode.String;
		return true;	// TFS47042
	endif;

	// Meta Data sent successfully
	self.updateActivityHistory(true);
	// END TFS47042
	
	// add our create cargo event
	resultCode := self.postCargoEvent(_cargo, authToken, cargoChainSecret);
	if resultCode = HttpResponseOK then
		logMessage := logMessage &amp; ". Cargo event data set";
	else
		logMessage := logMessage &amp; ". Cargo event data not set; error " &amp; resultCode.String;
		return true;	// TFS47042
	endif;

	// Event Data sent successfully
	self.updateActivityHistory(true);
	
	if  self.allCargoChainEventMappings.size  &gt; 0 then
		// register the profile hook
		resultCode := self.postRegisterHook(authToken, cargoChainSecret);
		if resultCode = HttpResponseOK then
			logMessage := logMessage &amp; ". Profile hook registered";
			
			// Profile Hook Registered successfully		// TFS47042
			self.updateActivityHistory(true);			// TFS47042
	
		else
			logMessage := logMessage &amp; ". Profile hook not registered; error " &amp; resultCode.String;
			return true;	// TFS47042
		endif;
	else
		logMessage := logMessage &amp; ". No CC Event Mappings ignoring registering hook";
	endif;
	
	return true;
epilog
	app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	delete xml;
	delete jsonHelper;
	delete xmlHelper;
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_timeoutOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAuthenticateUser" id="46d9e4a7-2d80-43ca-9ea9-abd6fe332663">
        <updating/>
        <source>doAuthenticateUser(_token : String output;
				   _errorMessage : String output;
				   _timeoutOccured : Boolean io) : Boolean /* protected*/  updating;
/*

Purpose:			Call the REST API authentication mechanism with the usercode and password on the receiver

Parameters:			Output _token if successful
					_errorMessage set if we received an error response from the service
					_timeoutOccured set to true if we got no response

Return Value:		True if the authentication was successful

Date		Who		Reason
22 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	xml				: JadeXMLDocument;
	xmlElement		: JadeXMLElement;
	jsonHelper		: CMIF_JsonHelper;
	jsonResponse	: String;
	xmlHelper		: CM_XmlHelperAgent;
	resultCode		: Integer;

begin
	// Create a Json request for the authenticate parameters
	create xml transient;
	xml.outputDeclaration := false;
	
	// Call authenticate
	jsonResponse := self.doSendHTTPRequest(self.authProviderUrl &amp; "/runAs",
										   "POST",
										   self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Basic " &amp; ((self.clientID &amp; Colon &amp; self.clientSecret).Binary.base64EncodeNoCrLf()).String,
										   self.runAsKey,
										   resultCode);
										   
	// Timeout or communication failure will return null response
	if jsonResponse = null then
		_timeoutOccured := true;
		_errorMessage := "No response";
		return false;
	endif;

	_timeoutOccured := false;
	// Now need to interpret the response to see if the authentication worked
	create xmlHelper transient;
	create jsonHelper transient;
	xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	
	// Find token in response
	if resultCode = HttpResponseOK then
		xmlElement := xml.findElementByTagName("accessToken");
		if xmlElement &lt;&gt; null then
			_token := xmlElement.text();
			_errorMessage := "Token " &amp; _token &amp; " returned";
			return true;
		else
			_errorMessage := "No accessToken element";
			return false;
		endif;
	else
		// And the authenticate did not work
		_errorMessage := "(HTTP " &amp; resultCode.String &amp; ")";
		return false;
	endif;
	
epilog
	
	app.writeLog(method.qualifiedName() &amp; Space &amp; _errorMessage, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	delete xml;
	delete jsonHelper;
	delete xmlHelper;
end;</source>
        <Parameter name="_token" type="String" usage="output"/>
        <Parameter name="_errorMessage" type="String" usage="output"/>
        <Parameter name="_timeoutOccured" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAdditionalHeadersForHTTP" id="c0b4d86d-1f72-493e-85c7-6ee67a606b7c">
        <source>getAdditionalHeadersForHTTP(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2018	jlgmp6	Initial creation	TFS41999

*/

vars

begin
	
	return "Content-Type: application/json";
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEvents" id="d88c07a6-1f2c-4d35-9fd3-29f30412b73b">
        <updating/>
        <source>getEvents(_profileSecretId 		: String ;
			_lastProcessedEvent : String io;
			_jsonRespose        : String io;
			_idx                : Integer io;
			_authToken 			: String           ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)

*/

vars
	url,
	httpHeader,
	jsonResponse,
	logMessage		: String;
	resultCode      : Integer;




begin
	if _authToken = null then
		return false;
	endif;

	if _lastProcessedEvent &lt;&gt; null then
		url  := self.baseEndpoint &amp; '/getEvents' &amp; '?' &amp; 'profileSecretId=' &amp; _profileSecretId &amp;'&amp;count=1'   &amp;'&amp;order=asc' &amp; '&amp;lastEvent=' &amp; _lastProcessedEvent ;
	else
		url  := self.baseEndpoint &amp; '/getEvents' &amp; '?' &amp; 'profileSecretId=' &amp; _profileSecretId &amp;'&amp;count=1'   &amp;'&amp;order=asc';
	endif;
	
	httpHeader  := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer " &amp; _authToken;
	
	// Send the request
	jsonResponse := self.doSendHTTPRequest(url,
										   "GET",
										   httpHeader,
										   null,
										   resultCode);
	
	
	if resultCode &lt;&gt; HttpResponseOK then
		if resultCode = null then
			logMessage := logMessage &amp; " - response timeout";
		else
			logMessage := logMessage &amp; " - error " &amp; resultCode.String;
		endif;
		return false;
	endif;
	

	self.updateActivityHistory(true); 	
	

	if resultCode = HttpResponseOK then
		if jsonResponse[1:1] = CN_LEFT_BRACKET and jsonResponse[jsonResponse.length:1] = CN_RIGHT_BRACKET then
			_jsonRespose := jsonResponse[2:jsonResponse.length() - 2];
		endif;
		return true;
	else
		return false;
	endif;

epilog
	app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
end;</source>
        <Parameter name="_profileSecretId" type="String"/>
        <Parameter name="_lastProcessedEvent" type="String" usage="io"/>
        <Parameter name="_jsonRespose" type="String" usage="io"/>
        <Parameter name="_idx" type="Integer" usage="io"/>
        <Parameter name="_authToken" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMetaData" id="cccebd33-358d-4b11-8fd0-7622562e86f3">
        <updating/>
        <source>getMetaData(_profileSecretId 	: String ;
			_terminal	    	: CM_Terminal    io;
			_ti             	: CM_TrackedItem io;
			_lastProcessedEvent : String io;
			_authToken 			: String):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)

*/

vars
	httpHeader,
	oid,
	termCode,
	url,
	jsonPostData,
	jsonResponse   		: String;
	resultCode          : Integer;
	xml					: JadeXMLDocument;
	jsonHelper			: CMIF_JsonHelper;
	xmlHelper		    : CM_XmlHelperAgent;
	xmlElement		    : JadeXMLElement;

begin
	if _authToken = null then
		return false;
	endif;
	

	url 		:= self.baseEndpoint &amp; '/getMetaData' &amp; '?' &amp;'profileSecretId=' &amp; _profileSecretId;
	httpHeader  := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer " &amp; _authToken;
	
	// Send the request
	jsonResponse := self.doSendHTTPRequest(url,
										   "GET",
										   httpHeader,
										   jsonPostData,
										   resultCode);
	

	create xmlHelper  transient;
	create jsonHelper transient;
	create xml        transient;
	
	xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	
	if resultCode = HttpResponseOK then
		//terminalCode
		xmlElement := xml.findElementByTagName("terminalCode");
		if xmlElement &lt;&gt; null then
			termCode := xmlElement.text();
			_terminal := app.myRoot.allTerminals[termCode];
		endif;
		
		//oid
		xmlElement := xml.findElementByTagName("oid");
		if xmlElement &lt;&gt; null then
			oid  := xmlElement.text();
			_ti  := oid.asOid.CM_TrackedItem;
		endif;
		
		//lastProcessedEvent
		xmlElement := xml.findElementByTagName("lastProcessedEvent");
		if xmlElement &lt;&gt; null then
			_lastProcessedEvent := xmlElement.text();
		endif;

		return true;
	else
		return false;
	endif;
	
epilog
	delete xml;
	delete xmlHelper;
	delete jsonHelper;
end;</source>
        <Parameter name="_profileSecretId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_lastProcessedEvent" type="String" usage="io"/>
        <Parameter name="_authToken" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
