        <updating/>
        <source>btnUpdate_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
09 August 2023	navmv20	CR 59391 Task 59392: COO Maint Show Sub Details
*/

vars
	//09 August 2023	navmv20	CR 59391 Task 59392 - start
	/*
	form : CMUI_OwnershipChangeDetail;
	bank :CM_Bank;
	ownership : CM_OwnershipChangeDetail;
	ti : CM_TrackedItem;
	ct : CM_CargoType;*/
	//09 August 2023	navmv20	CR 59391 Task 59392 - end
begin
	//09 August 2023	navmv20	CR 59391 Task 59392 - start
	/*ownership := self.tblData.accessRow(self.tblData.row).itemObject.CM_OwnershipChangeDetail;
	if ownership = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if ownership &lt;&gt; null then
		// ### TFS CR 58230 TASK 58231 26JUL2023 NAVAB1
		ti := ownership.myTrackedItem;
		if not ti.isCargoGroupItem then
			ct := ti.myCargoType;
			if not ct.allowDuplicates then
				app.msgBox(app.getErrorString(This_cargo_item_not_split_need), app.getErrorString(Warning),MsgBox_OK_Only);
				return;
			endif;
		endif;
		
		form := app.loadForm(CMUI_OwnershipChangeDetail, CMUI_Assistant, false, false,false, self.myTerminal,null).CMUI_OwnershipChangeDetail;
		if form &lt;&gt; null then
			form.updateMode := true;
			form.setMyCOODetail(ownership);
			form.setMyOwnershipChange(self.myOwnershipChange);
			form.centreWindow();
