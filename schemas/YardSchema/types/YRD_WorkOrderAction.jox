    <JadeMethod name="translateForm" id="fe1d2976-c7c4-4185-b5d2-7c04e8cb4ad2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 13:34:36.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022888, locale);
	btnSchedule.translateCaption(Xlat_0013856, locale);
	chkAutoPrefill.translateCaption(Xlat_0013857, locale);
	grpActionFromRBT.translateCaption(Xlat_0013858, locale);
	grpKnownCargo.translateCaption(Xlat_0013859, locale);
	lActioned.translateCaption(Xlat_0013860, locale);
	lActionedRBT.translateCaption(Xlat_0013861, locale);
	lAvailable.translateCaption(Xlat_0013862, locale);
	lComplete.translateCaption(Xlat_0013863, locale);
	lCompleteRBT.translateCaption(Xlat_0013864, locale);
	lRequiredByDt.translateCaption(Xlat_0013865, locale);
	lStartbyDt.translateCaption(Xlat_0013866, locale);
	lTotUnactionedRB.translateCaption(Xlat_0013867, locale);
	lTotalActioned.translateCaption(Xlat_0014222, locale);
	lTotalRBT.translateCaption(Xlat_0013868, locale);
	lTotalReq.translateCaption(Xlat_0013869, locale);
	lUnactioned.translateCaption(Xlat_0013870, locale);
	lblAction.translateCaption(Xlat_0013871, locale);
	lblActioned.translateCaption(Xlat_0014223, locale);
	lblActionedRBT.translateCaption(Xlat_0014224, locale);
	lblAvailNow.translateCaption(Xlat_0014225, locale);
	lblComplete.translateCaption(Xlat_0014226, locale);
	lblCompleteRBT.translateCaption(Xlat_0014227, locale);
	lblRequiredBy.translateCaption(Xlat_0013872, locale);
	lblStartBy.translateCaption(Xlat_0013873, locale);
	lblTotalActioned.translateCaption(Xlat_0014228, locale);
	lblTotalRBT.translateCaption(Xlat_0014229, locale);
	lblTotalReq.translateCaption(Xlat_0013874, locale);
	lblUnactioned.translateCaption(Xlat_0014230, locale);
	lblUnactionedRBT.translateCaption(Xlat_0014231, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateOK" id="7c82e359-64de-4800-ba12-73bc1d40b433">
        <source>validateOK() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars
	result : Boolean;
	numRows,
	idx		: Integer;
	noToAction,
	noAvailable : Integer;
	requestDesc : String;
begin


	if self.hasRBT then
	// check rbt values.
	
	numRows := self.tbRequests.rows - self.tbRequests.fixedRows ;
	foreach idx in 1 to numRows+1 do
		noToAction := self.tbRequests.getCellValueByName( ETRow_RbtToAction,  idx ).Integer;
		noAvailable := self.tbRequests.getCellValueByName( ETRow_RbtLeft,  idx ).Integer;
		requestDesc := self.tbRequests.getCellValueByName( ETRow_RbtRequestDesc,  idx ).String;
		
		if noToAction &gt; noAvailable then
			// issue too many!
		 app.msgBox(app.getErrorString3(Numbe_enter_actio_more_than_wh, noToAction.asStringJMT(),noAvailable.asStringJMT() ,requestDesc )  ,"Action Error",MsgBox_OK_Only );		
		 return false;
		endif;
		
	endforeach;
	endif;

	// now validate standard
	
	if self.txtAction.text.asIntegerJMT() &gt; self.lUnactioned.caption.asIntegerJMT() then
		// too many
		 app.msgBox(app.getErrorString(Numbe_actio_from_known_cargo_e )  ,"Action Error",MsgBox_OK_Only );		
		 return false;
	endif;

return true;

epilog

end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
