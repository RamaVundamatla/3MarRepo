    <JadeMethod name="imExStatusToString" id="1cdeb442-2403-4cba-885a-80510e57b58f">
        <source>imExStatusToString(_ti:CM_TrackedItem):String;
//
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
//
vars
	imexString:String;
begin
	if _ti.isRehandle and not _ti.isARework then
		imexString := "7";  //Restow (cell-pier-cell)
	elseif _ti.isSOB and not _ti.isARework then
		imexString := "4";  //Shifter (Cell-cell)
	//elseif _ti.isExport then							// PAR #25021
	elseif _ti.isExport or _ti.isTranshipOutbound then	// PAR #25021
		imexString := "2";
	//elseif _ti.isImport then							// PAR #25021
	elseif _ti.isImport or _ti.isTranshipInbound then	// PAR #25021
		imexString := "3";
	else
		imexString := "";
	endif;
	return imexString;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeBGMSegment" id="0cf52ffa-125b-45b5-bbd5-3a488013def0">
        <source>makeBGMSegment(_protocol :CM_CamProtocol ; _typeCode :String; _number :Integer;_function :Integer; _response :String):String protected;
/*
Purpose:	Make a UNH segment
Parameters:	_type - 
			_number - unique number
			_function - eg. 9 = original
			_response - 
Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
constants
	MESSAGE	= "BGM";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_typeCode &amp; plus;
			
	if _number &lt;&gt; null then
		msg := msg &amp; _number.String;
	endif;
		
	msg := msg &amp; plus &amp; _function.String;
			
	if _response &lt;&gt; null then
		msg := msg &amp; plus &amp; _response;
	endif;

	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_typeCode" type="String"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_function" type="Integer"/>
        <Parameter name="_response" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeCNTSegment" id="1a8b7374-52b4-42cd-979d-0077b5ad5d42">
        <source>makeCNTSegment(_protocol :CM_CamProtocol; _type, _count :Integer):String protected;
/*
Purpose:	Make a CNT segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
constants
	MESSAGE	= "CNT";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_type.String &amp; colon &amp; _count.String 
			&amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_count" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeDAMSegment" id="1ec05fa5-575d-4aef-baea-868011f184c4">
        <source>makeDAMSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input;_qual, _type, _typeQual, _typeAgency, _typeDesc :String):String protected;
/*
Purpose:	Make a DAM segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "DAM";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; _qual &amp; plus &amp;
			_type &amp;  colon &amp; _typeQual &amp; colon &amp; _typeAgency &amp; colon &amp; _typeDesc;
	
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_qual" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_typeQual" type="String"/>
        <Parameter name="_typeAgency" type="String"/>
        <Parameter name="_typeDesc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeDOCSegment" id="804c6258-e2db-4c45-9d3e-991f0aff1fc4">
        <source>makeDOCSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input;_theTi :CM_TrackedItem) : String protected;
//
//20 May 2016	cnwrs1	TFS 2008 - Vermas file changes
//
constants
	MESSAGE	= "DOC";
vars
	msg	: String;
	plus : Character; 
	colon : Character; 
	singleQuote : Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus; 
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
end;
</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_theTi" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeDTMSegment" id="bed51f90-52ad-4015-bd44-7be92c9b40b2">
        <source>makeDTMSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _type : String; _datetime : TimeStamp; _qual :String):String protected;
/*
Purpose:	Make a DTM segment

Date			Who		Reason
09 May 2011		cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//05 Jul 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
constants
	MESSAGE	= "DTM";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
	localDT : TimeStamp;
	localDTStr : String;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	localDT := _datetime.systemToLocalTime(_protocol.terminal.timeZoneID);
	localDTStr := localDT.date.longYearEDI() &amp; localDT.time.shortFormatEDI();
	
	msg := MESSAGE &amp; plus &amp; _type &amp; colon &amp; localDTStr &amp; colon &amp; _qual;
			
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then 
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_datetime" type="TimeStamp"/>
        <Parameter name="_qual" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeDTM_VGMSegment" id="68691879-b38a-4ead-8e7f-6e2998401e9c">
        <source>makeDTM_VGMSegment(_protocol : CM_CamProtocol; _group : HugeStringArray input; _code : String; _time : TimeStamp) : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/07/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
// 24/08/2017	jlgdap1		TFS 6691 Don't include seconds in timestamps
// 04/07/2022	jlizm1		TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
//
constants
	MESSAGE	= "DTM";
	
vars
	msg	: String;
	plus, colon, singleQuote : Character;
	localTime : TimeStamp;
	localTimeString : String;
	
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	localTime := _time.systemToLocalTime(_protocol.terminal.timeZoneID);					// TFS 53754
	//localTimeString := localTime.formatAsYYYYMMDDHHmmSS();								// TFS 6691
	localTimeString := localTime.date.longYearEDI &amp; localTime.time.shortFormatEDI;			// TFS 6691
	
	msg := MESSAGE &amp; plus &amp; 
			_code &amp; colon &amp; 
			localTimeString &amp; colon &amp; "203";
			
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_time" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeEQASegment" id="e88a0159-5059-4fcf-9919-8311a40f167c">
        <source>makeEQASegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _qualifier :String; _ti :CM_TrackedItem):String protected;
/*
Purpose:	Make a EQA segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "EQA";
vars
	msg	:String;
	plus, singleQuote	:Character;
begin
	if _ti.getCou = null then
		return null;
	endif;
	
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; _qualifier &amp; plus &amp; _ti.couId.trimRight;
	
	msg := msg &amp; singleQuote;
			
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_qualifier" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeEQDSegment" id="85ab44a3-5eec-40e3-828a-19600c97b579">
        <source>makeEQDSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _qualifier, _id, 
				_type, _typeQual, _typeAgency, _supplier, _status, _contentsStatus:String):String protected;
/*
Purpose:	Make a EQD segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "EQD";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_qualifier &amp; plus &amp;
			_id &amp; plus &amp;
			_type;
			
	if _typeQual &lt;&gt; null or _typeAgency &lt;&gt; null then
		msg := msg &amp; colon &amp; _typeQual;
		if _typeAgency &lt;&gt; null then
			msg := msg &amp; colon &amp; _typeAgency;
		endif;
	endif;
	
	msg := msg &amp; plus &amp;
			_supplier &amp; plus &amp;
			_status &amp; plus &amp;
			_contentsStatus;
			
	msg := msg &amp; singleQuote;
			
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
