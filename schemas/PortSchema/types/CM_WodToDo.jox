    <JadeMethod name="prepareAuditDetail" id="c8d6a7c3-e8db-4f14-b37d-8ae334db5d57">
        <source>prepareAuditDetail(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders

*/

vars
	tmpStr,
	priority 	: String;
	aCT		 	: CM_CalculationType;
	toDoTask	: CM_ToDoTaskDesc;
begin
	inheritMethod(_str);
	tmpStr := null;
	if self.priority = CM_WorkOrder.WO_Priority_High then
		tmpStr := app.getErrorString(WO_PRIORITY_HIGH) &amp;" "&amp; tmpStr ;
		_str := _str &amp; app.getErrorString(Priority) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := "" &amp;" "&amp; tmpStr ;
		_str := _str &amp; app.getErrorString(Priority) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	foreach aCT in app.myRoot.allCalculationTypesByCode do
		if self.overrideCalcType = aCT.calculationType then
			tmpStr := aCT.description &amp;" "&amp; tmpStr ;
			_str := _str &amp; "Calculation Type" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
			break;
		endif;
	endforeach;
	
	tmpStr := null;
	foreach toDoTask in self.allToDoTasksDescs do
		if tmpStr = null then
			tmpStr := toDoTask.description;
		else
			tmpStr := tmpStr &amp; Comma &amp; toDoTask.description;
		endif;
	endforeach;
	_str := _str &amp; app.getErrorString(Tasks) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="84f14b8d-7b40-4416-aa29-d41dd9b104b7">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 August 2009	cnwmd1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
15 Mar 2023  	navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
//29.3.2023 	navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
13 Dec 2023 	naviv1	ChangeRequest 61543: EUP - Transport  Mode Change should create a new Work Order 
*/

vars
	pxy : SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	//pxy.myToDoTaskDesc := self.myToDoTaskDesc;						//15.3.2023 navhl20	#56614[56615]
	pxy.myOverridingDebtorType	:= self.myOverridingDebtorType;			//29.3.2023 navhl20 57301:[57303]
	pxy.setMyWorkOrderDetail( self.myWorkOrderDetail );					//11 Jul 2018	NDL	TFS 39638
	self.allToDoTasksDescs.copy(pxy.allToDoTasksDescs);					//15.3.2023 navhl20	#56614[56615]
	pxy.requiredByDT	:= self.requiredByDT;							//13.12.2023 naviv1 #61543
	completedOK := true;												// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then												// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9d2918f3-8e6e-4d5e-a7f8-5a7162785ca9">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WorkOrderDtl) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
7 Mar 2023  navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
29 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars

begin
	inheritMethod(_pxyWoDDtl);
	self.allToDoTasksDescs.clear();													//7.3.2023 navhl20	#56614[56615]
	//self.myToDoTaskDesc := _pxyWoDDtl.CM_WodToDo.myToDoTaskDesc;					//7.3.2023 navhl20	#56614[56615]
	_pxyWoDDtl.CM_WodToDo.allToDoTasksDescs.copy(self.allToDoTasksDescs);			//7.3.2023 navhl20	#56614[56615]
	
	self.remarks 				:= _pxyWoDDtl.CM_WodToDo.remarks;					//17.03.2023	navcs2	#56842:[56843]	
	self.noCharge 				:= _pxyWoDDtl.CM_WodToDo.noCharge;					//17.03.2023	navcs2	#56842:[56843]
	self.overrideCalcType 		:= _pxyWoDDtl.CM_WodToDo.overrideCalcType;			//17.03.2023	navcs2	#56842:[56843]
	self.priority 				:= _pxyWoDDtl.CM_WodToDo.priority;					//17.03.2023	navcs2	#56842:[56843]
	self.overrideRate 			:= _pxyWoDDtl.CM_WodToDo.overrideRate;				//17.03.2023	navcs2	#56842:[56843]
	self.contractId				:= _pxyWoDDtl.CM_WodToDo.contractId;				//17.03.2023	navcs2	#56842:[56843]
	self.myOverridingDebtorType := _pxyWoDDtl.CM_WodToDo.myOverridingDebtorType;	//29.3.2023 navhl20 57301:[57303]
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl"/>
    </JadeMethod>
