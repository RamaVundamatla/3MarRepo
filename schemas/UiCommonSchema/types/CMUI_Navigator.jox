    <JadeMethod name="canDisplaySelectedMenuItem" id="3c6c0645-86e6-453f-a6e9-e811b6edb007">
        <source>canDisplaySelectedMenuItem(_menuEntity : CM_MenuEntity) : Boolean;
//
// Purpose:			Callback method for special menu items that may need to be hidden based on config options
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 03/02/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	terminal : CM_Terminal;

begin
	if CM_MenuUserDtl.hasInstance(_menuEntity) then
		if _menuEntity.CM_MenuUserDtl.myMenuDtl.constantValue = PmGteSecurityGateView then
			terminal := _menuEntity.CM_MenuUserDtl.myTerminal;
			if not terminal.getConfig(SiteHasSecurityGate).Boolean then
				return false;
			endif;
		elseif _menuEntity.CM_MenuUserDtl.myMenuDtl.constantValue = PmInvSAPServiceMonView then	//21 Nov 2018	NDL	TFS 42116
			terminal := _menuEntity.CM_MenuUserDtl.myTerminal;
			if not terminal.getConfig(SapFinancialEnabled).Boolean then
				return false;
			endif;
		elseif _menuEntity.CM_MenuUserDtl.myMenuDtl.constantValue = PmGCVoyageOpsView then		// PAR #35397
			if not app.myRoot.client = Client_PortEverett then									// PAR #35397
				return false;																	// PAR #35397
			endif;																				// PAR #35397
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_menuEntity" type="CM_MenuEntity"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDo" id="873869eb-acc5-4620-bbe7-7fc0607f1b9d">
        <source>canDo(_doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user			: CM_User;
	terminal		: CM_Terminal;
	menuEntity		: CM_MenuEntity;
begin
	menuEntity := self.lstTest.listObject.CM_MenuEntity;
	if menuEntity = null then
		return false;
	endif;

	user := app.getMyUser;
	terminal := menuEntity.getMyTerminal();

	if not user.canDo(terminal, _doWhat) then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkOpenWindows" id="8abe5552-e010-4b32-b52f-5b920c46f65e">
        <source>checkOpenWindows() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	listCount,
	idx			: Integer;
	lstBox		: CMUI_ListBox;
begin
	lstBox := self.lstTest;
	//PAR 6853 - insist on closing all windows before resetting menu otherwise the occasional menu action (representing an open window)
	//may not be present on closing the app, and thus not have it's user window preferences recorded
	listCount := lstBox.listCount;
	foreach idx in 1 to listCount do
		if CMUI_MenuAction.hasInstance(lstBox.itemObject[idx]) then
			app.msgBox('You must close all JMT windows before organising/resetting your menu','Close all screens first...', MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endforeach;

	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
