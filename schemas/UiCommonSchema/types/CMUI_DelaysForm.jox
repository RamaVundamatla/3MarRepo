    <JadeMethod name="doBaseFormSave" id="ca6528fc-5107-476d-a38b-70e005601b54">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	delayProxy, realDelay  : 	CM_Delay;
	theReturn : Integer;
	selectedObj : CM_Delay;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	if self.mode = self.Mode_Add then
		create delayProxy transient;
	else
		delayProxy  := app.createUpdateProxy(self.myDelay).CM_Delay;
	endif;
	
	self.populateDelayForSave(delayProxy);
	
	while true do		
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateDelay(delayProxy,realDelay, app.myPassport);
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateDelay(delayProxy, app.myPassport);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.mode.String &amp; ')');
			return;
		endif;
		
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			//app.msgBox('Ship Delay Details Saved successfully', 'Ship Delays', MsgBox_OK_Only);
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog("Ship Delay", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog	
	delete delayProxy;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="b4a42ffb-c146-48b9-818a-7ff6cfaf340d">
        <updating/>
        <source>doResize() updating;
/*
Purpose:			

Date		Who		Reason
20 September 2021	navab1	TFS 51853
*/

vars

begin
	inheritMethod();
	
	self.frmMain.top := self.frmToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1
	
	self.frmMain.height := self.height - self.frmToolbar.height - 30; // ### TFS 50421 17SEP2021 NAVAB1

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initControls" id="8d62e5a5-2e95-4424-a912-438bbffd47b0">
        <updating/>
        <source>initControls() updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
17/12/2015   cnwma1      PAR #37329 System is not saving ship delays and we have a ship in and working	
//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
----------   ----------  --------------------------------------------------*/
vars
	voyage,
 	voy 	: CM_Voyage;
	now 	: TimeStamp;
	delay	: CM_Delay;
	type	: CM_DelayType;
	combo	: CMUI_ComboBox;
	terminal	:CM_Terminal;
	idx 		:Integer;
begin
	//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	now 	:= self.systemToLocalTime(app.actualTimeServer());

// 	load up the voyage combo
	voyage 		:= self.myDefaultVoyage.CM_Voyage;
	combo 		:= self.cmbVoyage;
	terminal	:= self.myTerminal;
	
	combo.clear;
	self.myTerminal.getAllCurrentCellularVoyages(self.allCurrentVoyages,true,false);
	//combo.listCollection(self.allCurrentVoyages,false,0);   //17/12/2015 cnwma1 PAR #37329
	//combo.listObject := voyage;							   //17/12/2015 cnwma1 PAR #37329 
	foreach voy in self.allCurrentVoyages do                    //17/12/2015 cnwma1 PAR #37329
		combo.addItemObject(voy.code &amp; " - " &amp; voy.description, voy);
	endforeach;
	
	if voyage &lt;&gt; null then
		idx := combo.findObject(voyage);
		if idx &lt; 0 then
			combo.addItemObject(voyage.code &amp; " - " &amp; voyage.description, voyage);
		endif;
		combo.listObject := voyage;
	endif;


	
// 	load up the delay type combo
	delay := self.myDelay;
	
	if delay &lt;&gt; null then
		type := self.myDelay.myDelayType;
	endif;
	
	self.myAssistant.comboBoxDelayType (self.cmbDelayType, false, type);
	
// 	Load machines combo - You should only see the machines in this terminal (RJS 17 Mar 2011)
	self.cmbMachine.listCollection(terminal.machines, true, 0);
// 	Load drivers combo
	self.cmbDriver.initialise(false);
// 	set up work point combo
	self.cmbWorkPoint.myTerminal	:= terminal;
	self.cmbWorkPoint.initialise (true);
// 	Set default start date/time
	self.txtStartDate.setDate(now.date());
	self.txtStartTime.setTime(now.time());
// 	Set default end date/time
	now := now.addMinutes(15);	//par 15663
	
	self.txtEstDate.setDate(now.date());
	self.txtEstTime.setTime(now.time());
	
	if self.myTerminal &lt;&gt; null
		and  self.mode= self.Mode_Add
		and self.myTerminal.getConfig(DelayDefaultEstimateEnd).Boolean then   //19/09/2016 cnwma1 TFS #2666 PAR #38198
		self.txtEndDate.setDate(now.date());
		self.txtEndTime.setTime(now.time());
	endif;
	
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="populateDelayForSave" id="dec561c7-1b5b-4027-b40c-fbc065cdf9b1">
        <updating/>
        <source>populateDelayForSave(_delay : CM_Delay input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	endDT, startDT, estEndDT	: TimeStamp;
begin
	endDT := null;

	if self.txtEndDate.text.asDateJMT().isValid() then
		endDT.setDate(self.txtEndDate.text.asDateJMT());
	endif;
	
	if self.txtEndTime.text.asTimeJMT().isValid() then
		endDT.setTime(self.txtEndTime.text.asTimeJMT());
	endif;
	
	startDT.setDate(self.txtStartDate.text.asDateJMT());
	startDT.setTime(self.txtStartTime.text.asTimeJMT());
	
	estEndDT.setDate(self.txtEstDate.text.asDateJMT());
	estEndDT.setTime(self.txtEstTime.text.asTimeJMT());
	
	//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endDT := self.localToSystemTime(endDT); 
	startDT:= self.localToSystemTime(startDT);
	estEndDT:= self.localToSystemTime(estEndDT);
	
	_delay.setProxy(self.myTerminal,
					self.cmbVoyage.listObject.CM_Voyage,
					self.cmbDelayType.listObject.CM_DelayType,
					startDT,
					estEndDT,
					endDT,
					self.cmbMachine.listObject.CM_Machine,
					self.cmbDriver.listObject.CM_User,
					self.cmbWorkPoint.listObject.CM_WorkPoint,
					self.txtRemarks.text.asStringJMT);
epilog
	
end;
</source>
        <Parameter name="_delay" type="CM_Delay" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUpForEdit" id="9e4f5e83-76b1-418a-9b46-657ccd7cfcdf">
        <source>setUpForEdit();
/*
----------   ----------  --------------------------------------------------
Created:	21 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
05/09/2011	cnwcs5		CCMS MES 1033 - RORO KPI
31/12/2014	cnwdap1		PAR #35397 CCMS SFW 1394 Voyge Rationalisation
//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	voyage 		:CM_Voyage;
	delay		:CM_Delay;
	tmpTS		:TimeStamp;
	
	delayType	:CM_DelayType;
	machine		:CM_Machine;
	driver		:CM_User;
	workpoint	:CM_WorkPoint;
	combo		:ComboBox;
begin
	delay	:= self.myDelay;
	
	if delay = null then
		return;
	endif;
		
	if self.isEndDelay then 
		tmpTS := self.systemToLocalTime(app.actualTimeServer());//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.txtEndDate.setDate(tmpTS.date());
		self.txtEndTime.setTime(tmpTS.time());
		
	elseif delay.endDT &lt;&gt; null and delay.endDT.isValid() then //changed by cnwyl1 for par15716
		tmpTS := self.systemToLocalTime(delay.endDT);			//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.txtEndDate.setDate(tmpTS.Date);
		self.txtEndTime.setTime(tmpTS.Time);
	endif;
	
	if delay.startDT &lt;&gt; null and delay.startDT.isValid() then //changed by cnwyl1 for par15716
		tmpTS := self.systemToLocalTime(delay.startDT);			//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.txtStartDate.setDate(tmpTS.Date);
		self.txtStartTime.setTime(tmpTS.Time);
	endif;
	
	if delay.estEndDT &lt;&gt; null and delay.estEndDT.isValid() then //changed by cnwyl1 for par15716
		tmpTS := self.systemToLocalTime(delay.estEndDT);		//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		self.txtEstDate.setDate(tmpTS.Date);
		self.txtEstTime.setTime(tmpTS.Time);
	else
		self.txtEstDate.text := null;				// PAR #35397
		self.txtEstTime.text := null;				// PAR #35397
	endif;
	
	voyage 	:= delay.myVoyage;
	combo	:= self.cmbVoyage;
	
	if voyage &lt;&gt; null then											// par 27612 cnwcs5
		combo.listIndex := combo.findObject (voyage);				// par 27612 cnwcs5
	else															// par 27612 cnwcs5
		combo.listObject := null;									// par 27612 cnwcs5
	endif;															// par 27612 cnwcs5

	delayType	:= delay.myDelayType;
	combo 		:= self.cmbDelayType;
	
	if delayType &lt;&gt; null then
		combo.listIndex := combo.findObject(delayType);
	endif;
	
	machine	:= delay.myMachine;
	combo	:= self.cmbMachine;
	
	if machine &lt;&gt; null then
		combo.listIndex := combo.findObject(machine);
	endif;
	
	driver	:= delay.myDriver;
	combo	:= self.cmbDriver;
	
	if driver &lt;&gt; null then
		combo.listIndex := combo.findObject(driver);
	endif;
	
	workpoint	:= delay.myWorkPoint; 
	combo		:= self.cmbWorkPoint;
	
	if workpoint &lt;&gt; null then
		combo.listIndex := combo.findObject (workpoint);
	endif;
	
	self.txtRemarks.text := delay.remarks;

end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="52176ffb-2371-409f-9f6d-dbdb31b87009">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	voyage : CM_Voyage;
begin
	self.initControls();

	self.toolbarStyle 	:= self.ToolbarStyle_ShowNoHide;	
	self.showToolbar 	:= true;
		
	if self.mode = self.Mode_Update then
		self.setUpForEdit();
		
		if isEndDelay then
			self.txtEndTime.setFocus();
		else 
			self.cmbVoyage.setFocus();
		endif;
	else 
		if self.cmbVoyage.listObject = null then
			self.cmbVoyage.setFocus;
		else
			self.cmbDelayType.setFocus();
		endif;
		
		if self.myDefaultMachine &lt;&gt; null then
			self.cmbMachine.listObject := self.myDefaultMachine;
		endif;
	endif;
	
	if not app.getMyUser.canDo (self.myTerminal , PmShpDelaysMaint) then
		self.cmbVoyage.enabled 		:= false;
		self.cmbDelayType.enabled	:= false;
		self.cmbMachine.enabled		:= false;
		self.cmbDriver.enabled		:= false;
		self.txtStartDate.readOnly	:= true;
		self.txtStartTime.readOnly 	:= true;
		self.txtEndDate.readOnly	:= true;
		self.txtEndTime.readOnly 	:= true;
		self.txtRemarks.readOnly	:= true;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="46929249-4dfd-407a-afbd-5b1179f48773">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016015, locale);
	btnDelete.translateBubbleHelp(Xlat_0016016, locale);
	btnDelete.translateCaption(Xlat_0016017, locale);
	btnNew.translateBubbleHelp(Xlat_0016018, locale);
	btnNew.translateCaption(Xlat_0016019, locale);
	btnReset.translateBubbleHelp(Xlat_0016020, locale);
	btnReset.translateCaption(Xlat_0016021, locale);
	ckbSystemDefault.translateCaption(Xlat_0016022, locale);
	lblDelayType.translateCaption(Xlat_0016023, locale);
	lblDriver.translateCaption(Xlat_0016024, locale);
	lblEndTime.translateCaption(Xlat_0016025, locale);
	lblEstCompltTime.translateCaption(Xlat_0016026, locale);
	lblMachine.translateCaption(Xlat_0016027, locale);
	lblRemarks.translateCaption(Xlat_0016028, locale);
	lblStartTime.translateCaption(Xlat_0016029, locale);
	lblVoyage.translateCaption(Xlat_0016030, locale);
	lblWorkPoint.translateCaption(Xlat_0016886, locale);
end;</source>
