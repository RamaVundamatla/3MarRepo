    <JadeMethod name="allReportTIsInwards" id="663b082a-7c0e-4a1d-95a0-96b940aed493">
        <methodInvocation>mapping</methodInvocation>
        <source>allReportTIsInwards(set: Boolean; _value: CM_TIArray io) mapping;
// -----------------------------------------------------------------------------
// Created:		28 August 2009 by consw1
//
// Purpose:		This virtual collection of inward TIs should only be used by Report Writer.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
//	received : Boolean;
	
begin
	if set then
		return;
	endif;
	
	app.allReportTIs.clear();

//	received := self.myTrainInwards &lt;&gt; null and self.myTrainInwards.isTIsReceived();

//	self.getAllTrackedItems(true, app.allReportTIs, received);

	self.getAllTrackedItems(true, app.allReportTIs, self.confirmed);	//03 Nov 2014	NDL	Par 35118
	
	_value := app.allReportTIs;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allReportTIsOutwards" id="08bcbeb1-2baa-446e-9a41-bbf5882e80d4">
        <methodInvocation>mapping</methodInvocation>
        <source>allReportTIsOutwards(set: Boolean; _value: CM_TIArray io) mapping;
// -----------------------------------------------------------------------------
// Created:		28 August 2009 by consw1
//
// Purpose:		This virtual collection of outward TIs should only be used by Report Writer.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	released : Boolean;
	
begin
	if set then
		return;
	endif;
	
	app.allReportTIs.clear();
	//epr par 35222 18/11/14 need to show release before train has departed so can't use self.confirmedOutwards
	released := self.myTrainOutwards &lt;&gt; null and self.myTrainOutwards.isTIsReleased();

	self.getAllTrackedItems(false, app.allReportTIs, released);
	
//	self.getAllTrackedItems(false, app.allReportTIs, self.confirmedOutwards);	//03 Nov 2014	NDL	Par 35118
	
	_value := app.allReportTIs;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allowsSealType" id="70853853-7228-430b-a324-cd48fd8cc8be">
        <source>allowsSealType( _sealType : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation

*/

vars

begin

	return self.myWagonClass.allowsSealType( _sealType );

epilog

end;</source>
        <Parameter name="_sealType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="arrivalProcess" id="3d764399-b7e5-458e-8a11-4df577fcfc8d">
        <source>arrivalProcess();
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti,
	clonedFrom: CM_TrackedItem;
	tiArray : CM_TIArray;
	bol		: CM_BOL;
	newBOL: CM_BOLIn;
	bols: CM_BOLSet;
	foundBOL: Boolean;
	intFaceBOLIn: CMIF_BOLIn;
	control: CMIF_TIUpdateController;
	lastSuffix: String;
	bolID: String;
	iter: Iterator;
	term: CM_Terminal;
	numberLen: Integer;
	startObj,
	bolIter: CM_BOL;
	wagonMoveControl : CMIF_WagonMoveController;
begin
	create tiArray transient;
	self.getAllTrackedItems(true, tiArray, false);
	
	self.allTIsReceived.clear();
	
	//26 Feb 2021	NDL	TFS 50837
	create wagonMoveControl transient;
	wagonMoveControl.autoSetEffectiveTimeStamp();


	create bols transient;
	foreach ti in tiArray discreteLock do
		self.arrivalProcessForTI( wagonMoveControl, ti);
		clonedFrom := ti.myMoveCloneFromTI;
		if clonedFrom &lt;&gt; null then
			term := clonedFrom.getMyWagon().myDestinationTerminal;
			foundBOL := false;
			if ti.isKindOf(CM_Log) and ti.myReceivalBOL = null and clonedFrom &lt;&gt; null and clonedFrom.myReceivalBOL &lt;&gt; null then		// TFS 2533
				bolID := clonedFrom.myReceivalBOL.number;
				foreach bol in bols do
					if bol.number[1:bol.number.reversePos("_") - 1] = bolID then
						foundBOL := true;
						break;
					endif;
				endforeach;
				if foundBOL then
					bol.allTrackedItems.add(ti);
					bol.allTrackedItemsOrig.add(ti);
					bol.allBOLTerminals[bol.myTerminal].allTrackedItems.add(ti);
					//epr TFS 4157 28/4/17
					bol.myExtension.setJasVolume(bol.myTerminal);
					bol.setNetWeightFromCargo();
				else
					// get next suffix
					numberLen := bolID.length() + 1;
					iter := term.allBOLsReceivedByTypeNumberDT.createIterator;
					startObj := term.allBOLsReceivedByTypeNumberDT.getAtKeyGeq(clonedFrom.myReceivalBOL.bolType, bolID, null);
					if startObj &lt;&gt; null then
						iter.startAtObject(startObj);
						while iter.next(bolIter) do
							if bolIter.bolType &lt;&gt; clonedFrom.myReceivalBOL.bolType or bolIter.number[1:numberLen] &lt;&gt; bolID &amp; "_" then
								break;
							endif;
							lastSuffix := bolIter.number[numberLen + 1:end];
						endwhile;
					endif;
	
					create intFaceBOLIn transient;
					intFaceBOLIn.bolNumber := bolID &amp; "_" &amp; (lastSuffix.Integer + 1).String;
					intFaceBOLIn.bolType := clonedFrom.myReceivalBOL.bolType;	// BOLType_Log;
					intFaceBOLIn.myTerminal := clonedFrom.getMyWagon().myDestinationTerminal;
					intFaceBOLIn.myVoyage := clonedFrom.myVoyage;
					intFaceBOLIn.operatorCode := clonedFrom.operatorCode;
					intFaceBOLIn.myOperator := app.myRoot.allOperators[clonedFrom.operatorCode];
					intFaceBOLIn.transportMode := TI_TRANSMODE_SHIP;
					intFaceBOLIn.headerOnly := true;
					if clonedFrom.mySubTerminal = null then
						intFaceBOLIn.mySubTerminal := intFaceBOLIn.myTerminal.getDefaultSubTerminal(CM_SubTerminal.Type_BOL, null, TI_IMEX_STATUS_NULL, null, false);
					else
						intFaceBOLIn.mySubTerminal := clonedFrom.mySubTerminal;
					endif;
					intFaceBOLIn.weightGrossTonnes := clonedFrom.myReceivalBOL.weightGrossTonnes;
					intFaceBOLIn.weightNetTonnes := clonedFrom.myReceivalBOL.weightNetTonnes;
					intFaceBOLIn.weightTareTonnes := clonedFrom.myReceivalBOL.weightTareTonnes;
					intFaceBOLIn.weightTotal := clonedFrom.myReceivalBOL.weightTotal;
					intFaceBOLIn.consigneeCode := clonedFrom.consignee;
					intFaceBOLIn.consignorCode := clonedFrom.consignor;
					intFaceBOLIn.jasScaled := not ti.CM_Log.isUnscaled;
					intFaceBOLIn.fellDate := ti.CM_Log.fellDate;
					intFaceBOLIn.myPlannedLocation := self.allLocationsControllers.first();
					intFaceBOLIn.logGradeCode := clonedFrom.myReceivalBOL.myLogGrade.code;
					intFaceBOLIn.lengthRandom := clonedFrom.myReceivalBOL.myLogLength.code;
					intFaceBOLIn.logSpeciesCode := clonedFrom.myReceivalBOL.myLogSpecies.code;
					intFaceBOLIn.logTreatmentCode := clonedFrom.myReceivalBOL.myLogTreatment.code;
					intFaceBOLIn.logTypeCode := clonedFrom.myReceivalBOL.myLogType.code;
					intFaceBOLIn.loggingOperation := clonedFrom.myReceivalBOL.loggingOperation;
					intFaceBOLIn.handlingContractor1 := clonedFrom.myReceivalBOL.handlingContractor1Code;
					intFaceBOLIn.handlingContractor2 := clonedFrom.myReceivalBOL.handlingContractor2Code;
					intFaceBOLIn.numberOfLifts := clonedFrom.myReceivalBOL.numberOfLifts;
					intFaceBOLIn.unloadPoint := clonedFrom.myReceivalBOL.unloadPoint;
					intFaceBOLIn.remarks := clonedFrom.myReceivalBOL.remarks;
					if clonedFrom.myReceivalBOL.myExtension &lt;&gt; null then
						intFaceBOLIn.backload := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.backload;
						intFaceBOLIn.chhSupplier := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.chhSupplier;
						intFaceBOLIn.customer := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.customer;
						intFaceBOLIn.gangNumber := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.gangNumber;
						intFaceBOLIn.isFSC := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.isFSC;
						intFaceBOLIn.loaderNumber := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.loaderNumber;
						intFaceBOLIn.loggingOrganisation := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.getLoggingOrganisation();
						intFaceBOLIn.nightshift := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.nightshift;
						intFaceBOLIn.opid := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.getOPID();
						intFaceBOLIn.percentScaled := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.percentScaled;
						intFaceBOLIn.pickupPoint := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.pickupPoint;
						intFaceBOLIn.scalerCode := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.scalerCode;
						intFaceBOLIn.ticketedAll := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.ticketedAll;
						intFaceBOLIn.activity := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.activity;
						intFaceBOLIn.weighbridge := clonedFrom.myReceivalBOL.myExtension.CM_BOLExtLogIn.weighbridge;
					endif;
					intFaceBOLIn.truckNumber := clonedFrom.wagonNumber;
					//epr TFS 4157 1/5/17
					intFaceBOLIn.sourceLocation :=clonedFrom.myReceivalBOL.sourceLocation;
					intFaceBOLIn.sourceSubLocation:=clonedFrom.myReceivalBOL.sourceSubLocation;
					intFaceBOLIn.sourceSubSubLocation:=clonedFrom.myReceivalBOL.sourceSubSubLocation;
					
					intFaceBOLIn.allTrackedItems.add(ti);
					
					create control transient;
					control.setMyUserObject(self);
					app.myUtilityCA.utlCreateBOLInWithTIs(intFaceBOLIn, newBOL, control, app.myPassport);
					
					if app.myPassport.hasErrors then
						return;
					endif;
					
					//epr TFS 4157 27/4/17
					if newBOL &lt;&gt; null then
						newBOL.myExtension.setJasVolume(newBOL.myTerminal);
						newBOL.setNetWeightFromCargo();					
						newBOL.setIsInterTermRailTransfer();
					endif;
					
					bols.add(newBOL);
				endif;
				ti.setBOL(intFaceBOLIn.bolNumber);
			endif;
		endif;
	endforeach;
	
	if self.myTrainInwards &lt;&gt; null then
		self.myTrainInwards.arrivalProcess(self);
	endif;

epilog
	delete tiArray;
	delete bols;
	delete intFaceBOLIn;
	delete control;
	delete iter;
	delete wagonMoveControl;
end;</source>
    </JadeMethod>
    <JadeMethod name="arrivalProcessForTI" id="c010637f-284c-4e90-a9cf-2bd5df68837c">
        <source>arrivalProcessForTI( _moveController : CMIF_WagonMoveController; _ti : CM_TrackedItem input) ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwer1	Initial creation

*/

vars

	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;

	if self.allTIsReceived.includes(_ti) then
		return;
	endif;


	self.allTIsReceived.add(_ti);
	_ti.doWagonArrive;
	self.createTransaction(effectiveDate, EVT_WagonCargoReceive, self.myTrainInwards, null, _ti, true, null, null, null);
		

epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
