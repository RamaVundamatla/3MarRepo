        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtEndDate" id="783ab680-6e3a-4dd4-8b16-820376867bd7">
        <embedded/>
        <type name="CMUI_DateMask"/>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="7bc7193d-26f1-444c-8a0d-b8aae1ec3b0b">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.permissionView  := PmAdmCompaniesView;
	self.permissionMaint := PmAdmCompaniesMaint;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="af17c9f5-dda8-42c6-8976-579a25f11b58">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwndl1	Initial creation

*/

vars

	drTerm : CM_DebtorTerminal;
	endDate : Date;
	theReturn : Integer;
	msg : String;

begin

	drTerm := self.cmbDebtor.listObject.CM_DebtorTerminal;
	endDate := txtEndDate.getDate();
	
	if drTerm = null then
		msg := app.getErrorString(INV_Please_Select_A_Debtor);
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	if not endDate.isValid then
		msg := app.getErrorString(Date_Enter_Valid);
		app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	while true do
	
		app.myTrxUA.trxConsolidateDebtorTermTrans(drTerm, endDate, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.unloadForm();
			return;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Proforma_criteria), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
		
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDebtorTerminal" id="4c6f2ae5-0c9e-44ce-aefa-7d7f89e7ac4d">
        <updating/>
        <source>setMyDebtorTerminal( _myDebtorTerminal : CM_DebtorTerminal ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwndl1	Initial creation

*/

vars

begin

	self.myDebtorTerminal := _myDebtorTerminal;

epilog

end;</source>
        <Parameter name="_myDebtorTerminal" type="CM_DebtorTerminal"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d983245e-4648-433b-967b-db20ed78544b">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwndl1	Initial creation

*/

vars

	drTerm : CM_DebtorTerminal;
	index : Integer;

begin

	inheritMethod();
	
	self.cmbDebtor.clear();
	foreach drTerm in self.myTerminal.allDebtorTerminals discreteLock do
		if drTerm.isCashOnly then
			index := self.cmbDebtor.addItem( drTerm.myDebtor.name);
			self.cmbDebtor.itemObject[ index ] := drTerm;
		endif;
	endforeach;
	
	if self.myDebtorTerminal &lt;&gt; null then
		self.cmbDebtor.listIndex := self.cmbDebtor.findObject( self.myDebtorTerminal );
	endif;
	
	self.lblTerm.caption := self.lblTerm.caption &amp; self.myTerminal.name;
	
	self.centreOverParent(1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8c46f0c5-9ea4-41f1-a08c-bd5e3a056655">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018373, locale);
	lblBefore.translateCaption(Xlat_0018374, locale);
	lblDebtor.translateCaption(Xlat_0018375, locale);
	lblGeneral.translateCaption(Xlat_0018376, locale);
	lblTerm.translateCaption(Xlat_0018377, locale);
end;</source>
    </JadeMethod>
</GUIClass>
