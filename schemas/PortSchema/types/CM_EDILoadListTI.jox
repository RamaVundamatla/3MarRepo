// 03 Apr 2013			cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures

vars
	foundMatch :Boolean;
begin
// cnwdad1 10/02/2010 - PAR #22322.
	self.operatorCode := app.myRoot.getXlationSystemOperatorCode(_operatorObj, _opCode[1:4], foundMatch);
	
epilog
	
end;</source>
        <Parameter name="_operatorObj" type="CM_Operator"/>
        <Parameter name="_opCode" type="String"/>
    </JadeMethod>
