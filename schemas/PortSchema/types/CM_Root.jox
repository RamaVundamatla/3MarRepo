    <JadeMethod name="isGradeUsedInTemplate" id="2fbc6464-6959-475d-bd8a-8c77358b0ef0">
        <source>isGradeUsedInTemplate(_gradeID: Integer): Boolean;
//----------------------------------------------------------------
//	Created:	20 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	templ	: CM_ToDoTemplate;
begin
	
	foreach templ in self.allToDoTaskTemplates do
		if templ.availabilityGrades.includesKey(_gradeID) then
			return true;
		endif;
		if templ.availabilityGradeToApply &lt;&gt; null
		and templ.availabilityGradeToApply.code = _gradeID then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <Parameter name="_gradeID" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
