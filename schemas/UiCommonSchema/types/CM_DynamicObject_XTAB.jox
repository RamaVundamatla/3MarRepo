    <JadeMethod name="createSelf" id="88042889-f012-452a-88f8-ddc158590b93">
        <updating/>
        <source>createSelf(_format :CM_OutputFormat_XTAB; _sa :StringArray; _rowLevel, _colLevel, _summaryLevel :Integer)updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  _format - XTAB that defines rows and columns
//				_sa		- row/column values to use for this entry
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	element		:CM_XTABElement;
	field		:CM_XTABField;
	count, size	:Integer;
	str			:String;
	child		:CM_DynamicObject_XTABField;
begin
	self.rowSummaryLevel	:= _rowLevel;
	self.colSummaryLevel	:= _colLevel;
	self.summaryLevel		:= _summaryLevel;
	// add properties and set values for keys
	foreach element in _format.allRows do
		count 	:= count + 1;
		str		:= element.propertyName;
		
		self.addProperty (str, String);
		self.setPropertyValue (str, _sa[count]);
	endforeach;
	
	size	:= count;
	count 	:= 0;
	
	foreach element in _format.allColumns do
		count 	:= count + 1;
		str 	:= element.propertyName;
		
		self.addProperty (str, String);
		self.setPropertyValue (str, _sa[count + size]);
	endforeach;
	
	// setup children (actual values for cells)
	foreach element in _format.allFields do
		field := element.CM_XTABField;
		if _colLevel = 0 and field.hideDetail or
			_colLevel = 1 and field.hideGrandTotals or
			_colLevel &gt; 1 and field.hideSubtotals then
			// this value does not get output at this level
			continue;
		endif;
		create child transient; child.createSelf (field); self.children.add(child);
	endforeach;
epilog

end;</source>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_sa" type="StringArray"/>
        <Parameter name="_rowLevel" type="Integer"/>
        <Parameter name="_colLevel" type="Integer"/>
        <Parameter name="_summaryLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isDetailColumn" id="65dc02fb-8a23-47a2-99ae-1df952234e6b">
        <source>isDetailColumn():Boolean;
// ---------------------------------------------------------------------------
// Created:     25 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.colSummaryLevel= 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isGrandTotalColumn" id="6c2464fd-a43f-4b2f-9a01-4e2b993f21a9">
        <source>isGrandTotalColumn():Boolean;
// ---------------------------------------------------------------------------
// Created:     25 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.colSummaryLevel= 1;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSubTotalColumn" id="bcba27b2-6b49-4fa2-be08-6a1d4984f055">
        <source>isSubTotalColumn():Boolean;
// ---------------------------------------------------------------------------
// Created:     25 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.colSummaryLevel &gt; 1;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSelf" id="899bf17b-ec15-43d9-9b40-6350d74f33b3">
        <source>updateSelf(_format :CM_OutputFormat_XTAB; _values :StringArray; _obj :Object);
// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	child	:JadeDynamicObject;
	value	:Decimal[23,8];
	int, 
	start	:Integer;
begin
	// key values have been set so just a matter of updating field values
	
	// field values are stored last in the array so based on the size of 
	// the _format.allFields collection we can position ourselves at the right
	// place in the values collection.  The we use the index property on 
	// the child to determine which value we want to use

	start := _values.size - _format.allFields.size;	// last non-field value
	
	foreach child in self.children do
		int :=  start + child.CM_DynamicObject_XTABField.index;
		child.CM_DynamicObject_XTABField.updateSelf (_values[int].Decimal);
	endforeach;

	self.allObjects.add (_obj);	
	
	// now update the next sub-total/total
	if self.myColTotalEntry &lt;&gt; null then
		self.myColTotalEntry.updateSelf (_format,_values, _obj);
	endif;
	
	if self.myRowTotalEntry &lt;&gt; null then
		self.myRowTotalEntry.updateSelf (_format, _values, _obj);
	endif;
epilog

end;</source>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_values" type="StringArray"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
