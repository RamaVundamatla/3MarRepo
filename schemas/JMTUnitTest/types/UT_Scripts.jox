    <JadeMethod name="uGetNamingTableConvents" id="740f106c-52d7-41d1-bfff-09f330da9c16">
        <source>uGetNamingTableConvents();
/*

Purpose:			
// gets the correct naming conventions and adds them into two arrays . "Good array" and " Bad Array"
Parameters:			

Return Value:		
Two arrays of good vs bad naming conventions 
Date		Who		Reason
06 June 2014	cnwdb2	PAR #33977

*/

vars
	str : String;
	badStrArr : StringArray;
	goodStrArr : StringArray;
	myGetFile 	: CMDFileOpen ;
	fil			: File ;
	st, st2		: String ;
	lineArray  : StringArray;  
	index,idx, endIDX		: Integer;

	
	
	int : Integer ; 
	
	
	goodLine  : String	;
	badLine : String	; 
	
begin	



// open the file 

	create myGetFile ; // Create an Open File dialog box
	myGetFile.filter	:="Data fr tables |*.csv" ;		
	if myGetFile.open = 0 then																					
		create fil ;
		fil.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		fil.mode 	 		:= File.Mode_Input;  
		fil.fileName 	:= myGetFile.fileName ;	 
		fil.open ; 


//  loop through the file 
		create goodStrArr	transient	;
		create lineArray	transient	;
		create badStrArr	transient	;

		beginTransaction;
		//while not st[1:5]="&lt;END&gt;" do // Until the file ends do . . . 
		while true do 
			st := fil.readLine ;    // Read a line of the data file
			if st.length &lt;= 1 then
				break;
			endif;
				index := 1;
				st.scanUntil(",", index);				index	:= index +1;
				

				lineArray := st.cnGetTokens(",") ; 
				if lineArray.size = 2 then
					goodStrArr.add(lineArray[1])	;
					badStrArr.add(lineArray[2]) ; 
				endif;
						

		endwhile ;												
		commitTransaction;


		delete fil ;																																
	endif ;				
	delete myGetFile ;																										

	write "Files added"  ; 
	
	goodStrArr.inspectModal; // inspect the array object
	badStrArr.inspectModal; // inspect the array object
	
	endIDX := goodStrArr.size();
	foreach idx in 1 to endIDX do
	 write goodStrArr[idx] &amp; " &gt;&gt;&gt;&gt; " &amp; badStrArr[idx];
	endforeach;
	/*
				write "GOOD ARRAY"  ; 

				foreach str in goodStrArr do
					write	str	;	
				endforeach;  
				
				write  " "  ;
				write  "  "  ;
				write "BAD ARRAY" ; 

				foreach	str	in badStrArr	do
					write str	; 
				endforeach	  ;
			
			*/	
	
	/*
	create badStrArr transient;
	create goodStrArr transient;
	
	goodStrArr.add("User Id");
	goodStrArr.add("Description");
	
	badStrArr.add("User Id");
	badStrArr.add("Name");
	
	foreach str in badStrArr do
		if not goodStrArr.includes(str) then
			write str;
		endif;
	endforeach; */ 
	
epilog	
	delete goodStrArr;
	delete badStrArr;
	delete lineArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uHideAllAgents" id="c0e76c57-4f5b-44fc-bf01-78393d355f9f">
        <source>uHideAllAgents();
//22 October 2014	cnwdw1	
//
vars
	con: CM_ConsigneeConsignor;
begin
	if app.msgBox("This will make ALL Consignees/Consignors/Forwarders unavailable for entry", "Hide All  Consignees/Consignors/Forwarders", MsgBox_OK_Cancel) = MsgBox_Return_OK then
		foreach con in getRoot.allConsigneeConsignors do
			beginTransaction;
				con.setIsNotAvailableForEntry(true);
