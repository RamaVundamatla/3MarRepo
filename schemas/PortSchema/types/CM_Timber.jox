    <JadeMethod name="getDataForDefSpecial" id="a6ee632a-bd48-4ce8-8f03-90b7621d4e1d">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     27 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	firstTime	: Boolean;
	tmpHeading	: String;
	tmpStr      : String;
begin
	if _attrName = ETRow_Wet then
		if self.wet then
			tmpStr := 'Wet';
		else
			tmpStr := 'Dry';
		endif;
		_headings.add(_heading);
		_data.add(tmpStr);
		return true;

	else
		return inheritMethod(_attrName, _heading, _headings, _data);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="835c6df7-f80b-4fba-b0c5-c1da2ca73a06">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	29 September 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
29/10/2010	cnwdap1		PAR #23442 Preslung included
01/07/2025	jlizm1		MTN 35067 Cargo Enquiry table check boxes should be yes/no instead
*/
vars

begin
	if _attrName = ETRow_Wet then
		return self.wet.String;
		
	elseif _attrName = ETRow_WetYesNo then
		return self.wet.getYesNo;
		
	elseif _attrName = ETRow_PreSlung then
		return self.preSlung.String;
		
	elseif _attrName = ETRow_PreSlungYesNo then
		return self.preSlung.getYesNo;
	endif;
	
	return inheritMethod(_attrName, _short);


end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
