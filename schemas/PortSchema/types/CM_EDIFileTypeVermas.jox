<Class name="CM_EDIFileTypeVermas" id="1d170530-ea35-421e-95b4-35e89969f86b">
    <superclass name="CM_EDIFileTypeUNEDIFACT"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="f21d2b78-f483-4f28-8f66-64d00a1c7252">
        <updating/>
        <source>create() updating;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
vars

begin
	self.name := "VERMAS 16A - Verified Cargo Mass";
	self.type := EDIFileType_Vermas;

end;
</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="7bd754cd-82c0-4b2f-8aa1-27b9d184c72c">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType: Integer io; _fileTypeCode: Integer io);
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
vars

begin
	_ediDataClass := CM_EDIDataVGM;
	_dataType := EDIDataType_VGM;
	_fileTypeCode := self.type;
end;
</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="ff255f1b-f72e-4c4f-8554-d21f72fcd23d">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//20 May 2016	cnwrs1	TFS 2008 - Vermas file changes
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
// 22/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 12 Dec 2017	jlgrh7			 TFS 7781  SNO - VERMAS with EDIFACT codes required
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;
vars
	ediTI : CM_EDIVGMTI;
	ediData : CM_EDIDataVGM;
	lineStr : String;
	message : String;
	int : Integer;
	voyageCode : String;
	group : Integer;
	code : String;
	ediTIId : String;
	msgCount : Integer;
	numMsgs : Integer;
	passport : CM_Passport;
	msgHelper : CMIF_EDIFACTHelper;
	strTmp : String;
	debug : Boolean;
	vesselName : String;
	operatorVoyage : CM_Operator;
	operatorSender : CM_Operator;
	operatorVoyageCode : String;
	lloydsNumber : String;
	callSign : String;
	operatorSenderCode : String;
	tdtType : String;
    subTag : String;
	untCount : Integer;
	foundMatch	: Boolean;
	theLines : HugeStringArray;
	rawSenderCode : String;
	creationTS : TimeStamp;
	sequence : String;
	fileType : String;
	version : String;
	recipientCode : String;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	dateTimeStr : String;									// TFS 4492
	vgmDT : TimeStamp;										// TFS 4492
	commsType, commsDetail : String;						// TFS 4492
	mobile, ediTrans, email, fax, mail, phone : String;		// TFS 4492
	docsIssued, determined : TimeStamp;						// TFS 4492
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;
	ediData := _ediFile.ediData.CM_EDIDataVGM;
	debug := false;

	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;lineStr&amp;' '&amp;group.String;
		msgCount := msgCount + 1;
		untCount := untCount + 1;
		
		commsType := null;							// TFS 4492
		commsDetail := null;						// TFS 4492
		mobile := null;								// TFS 4492
		ediTrans := null;							// TFS 4492
		email := null;								// TFS 4492
		fax := null;								// TFS 4492	
		mail := null;								// TFS 4492
		phone := null;								// TFS 4492
		docsIssued := null;							// TFS 4492
		determined := null;							// TFS 4492
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;

		msgHelper.setNextMessage(lineStr);	//set the current message

		//get current
		message := msgHelper.currentMessage;

//BGM
		if msgHelper.currentTag = "BGM" then
			if group = 0 then
				msgHelper.setNextField();
				if msgHelper.currentSubItem = "XXX" then
				endif;
			endif;
//CNT
		elseif msgHelper.currentTag = "CNT" then
//COM
		elseif msgHelper.currentTag = "COM" then							// TFS 4492
			group := 3;														// TFS 4492
			msgHelper.setNextField();										// TFS 4492
			commsDetail := msgHelper.currentSubItem;						// TFS 4492
			msgHelper.setNextSubItem();										// TFS 4492
			if ediTI = null then											// TFS 4492
				commsType := msgHelper.currentSubItem;						// TFS 4492
				if commsType.isOneOf("AL", "AM") then						// TFS 4492
					mobile := commsDetail;									// TFS 4492
				elseif msgHelper.currentSubItem = "EI" then					// TFS 4492
					ediTrans := commsDetail;								// TFS 4492
				elseif msgHelper.currentSubItem = "EM" then					// TFS 4492
					email := commsDetail;									// TFS 4492
				elseif msgHelper.currentSubItem = "FX" then					// TFS 4492
					fax := commsDetail;										// TFS 4492
				elseif msgHelper.currentSubItem = "MA" then					// TFS 4492
					mail := commsDetail;									// TFS 4492
				elseif msgHelper.currentSubItem = "TE" then					// TFS 4492
					phone := commsDetail;									// TFS 4492
				endif;														// TFS 4492
			else															// TFS 4492
				if msgHelper.currentSubItem.isOneOf("AL", "AM") then		// TFS 4492
					ediTI.vgmPhone := commsDetail;							// TFS 4492
				elseif msgHelper.currentSubItem = "EI" then					// TFS 4492
					ediTI.vgmEDITransmission := commsDetail;				// TFS 4492
				elseif msgHelper.currentSubItem = "EM" then					// TFS 4492
					ediTI.vgmElectronicMail := commsDetail;					// TFS 4492
				elseif msgHelper.currentSubItem = "FX" then					// TFS 4492
					ediTI.vgmTelefax := commsDetail;						// TFS 4492
				elseif msgHelper.currentSubItem = "MA" then					// TFS 4492
					ediTI.vgmMail := commsDetail;							// TFS 4492
				elseif msgHelper.currentSubItem = "TE" then					// TFS 4492
					ediTI.vgmTelephone := commsDetail;						// TFS 4492
				endif;														// TFS 4492
			endif;															// TFS 4492
//CTA
		elseif msgHelper.currentTag = "CTA" then
			if group = 2 then
				group := 3;
			endif;
			if group = 8 then
				group := 9;
			endif;
			msgHelper.setNextField();															// TFS 4492
			if msgHelper.currentField = "RP" then												// TFS 4492
				// signature of VGM authorised person											// TFS 4492
				msgHelper.setNextField;															// TFS 4492
				msgHelper.setNextSubItem;														// TFS 4492
				ediTI.vgmAuthSignature := msgHelper.currentSubItem;								// TFS 4492
			elseif msgHelper.currentField = "BN" then											// TFS 4492
				// details on subsequent COM segment											// TFS 4492
			endif;																				// TFS 4492
//DOC
		elseif msgHelper.currentTag = "DOC" then
			if group = 6 then
				group := 7;
			endif;
			msgHelper.setNextField();															// TFS 4492
			if ediTI &lt;&gt; null then																// TFS 4492
				ediTI.vgmCommsType := msgHelper.currentSubItem;									// TFS 4492
			endif;																				// TFS 4492
			msgHelper.setNextSubItem();															// TFS 4492
			msgHelper.setNextSubItem();															// TFS 4492
			msgHelper.setNextSubItem();															// TFS 4492
			if ediTI &lt;&gt; null then																// TFS 4492
				ediTI.vgmDocumentDetails := msgHelper.currentSubItem;							// TFS 4492
			endif;																				// TFS 4492
//DTM
		elseif msgHelper.currentTag = "DTM" then
//			group := 0;
			group := 3;																			// TFS 4492
			msgHelper.setNextField();															// TFS 4492
			if msgHelper.currentSubItem = "798" 											// TFS 4492
				or msgHelper.currentSubItem = "WAT" then							//+TFS 7781   VERMAS 0.4 Version code WAT will be replaced by numerical code once assigned by UN/CEFACT
				msgHelper.setNextSubItem();														// TFS 4492
				// VGM determination date/time													// TFS 4492
				dateTimeStr := msgHelper.currentSubItem.trimBlanks();							// TFS 4492
				msgHelper.setNextSubItem();														// TFS 4492
				vgmDT := dateTimeStr.getUNEDIFACTTimeStamp(msgHelper.currentSubItem.Integer);	// TFS 4492
				if ediTI &lt;&gt; null then															// TFS 4492
					ediTI.vgmDeterminationDT := vgmDT;											// TFS 4492
				else																			// TFS 4492
					determined := vgmDT;														// TFS 4492
				endif;																			// TFS 4492
			elseif msgHelper.currentSubItem = "137" then										// TFS 4492
				msgHelper.setNextSubItem();														// TFS 4492
				// VGM documentation issue date/time											// TFS 4492
				dateTimeStr := msgHelper.currentSubItem.trimBlanks();							// TFS 4492
				msgHelper.setNextSubItem();														// TFS 4492
				vgmDT := dateTimeStr.getUNEDIFACTTimeStamp(msgHelper.currentSubItem.Integer);	// TFS 4492
				if ediTI &lt;&gt; null then															// TFS 4492
					ediTI.vgmDocsIssuedDT := vgmDT;												// TFS 4492
				else																			// TFS 4492
					docsIssued := vgmDT;														// TFS 4492
				endif;																			// TFS 4492
			endif;																				// TFS 4492

//EQD
		elseif msgHelper.currentTag = "EQD" then
			group := 4; 
			msgHelper.setNextField();
			if msgHelper.currentField = "CN" then
				msgHelper.setNextField();
				if msgHelper.currentSubItem.length &gt; 11 then
					ediTIId := msgHelper.currentSubItem[1:4] &amp; msgHelper.currentSubItem[6:7];
				else
					ediTIId := msgHelper.currentSubItem;
				endif;
				create ediTI persistent;
				ediTI.setForCreateNew(ediData);

				//  par 30361 - changed = to &lt;&gt; on next line
 //				if operatorSender &lt;&gt; null then		
 //					ediTI.setOpCode(operatorSender, ediData.myOperator.code);
 //				else
				// no tranlation for operator in file.
 //					ediTI.setOpCode(operatorSender, operatorSenderCode);
 //				endif;

				// The Load and Discharge ports must be set AFTER the Operator has been set.
//				ediTI.setLoadPort(loadPort);
//				ediTI.setDischargePort(dischargePort);
	
				ediTI.setId(ediTIId);

				msgHelper.setNextField();
				msgHelper.setNextField();
				msgHelper.setNextField();
				msgHelper.setNextField();
				if msgHelper.currentField = "4" then
					ediTI.fullOrMT := "E";
				elseif msgHelper.currentField = "5" then
					ediTI.fullOrMT := "F";
				endif;
				
				if commsDetail &lt;&gt; null then							// TFS 4492
					ediTI.vgmCommsType := commsType;				// TFS 4492
					ediTI.vgmEDITransmission := ediTrans;			// TFS 4492
					ediTI.vgmElectronicMail := email;				// TFS 4492
					ediTI.vgmMail := mail;							// TFS 4492
					ediTI.vgmPhone := mobile;						// TFS 4492
					ediTI.vgmTelefax := fax;						// TFS 4492
					ediTI.vgmTelephone := phone;					// TFS 4492
					ediTI.vgmDocsIssuedDT := docsIssued;			// TFS 4492
					ediTI.vgmDeterminationDT := determined;			// TFS 4492
				endif;												// TFS 4492

				int := int + 1;
			endif;
//LOC
		elseif msgHelper.currentTag = "LOC" then
			if group = 4 then
				msgHelper.setNextField();
				if msgHelper.currentField = "9" then
					msgHelper.setNextField();
//					loadPort := msgHelper.currentSubItem[1:5];
				elseif msgHelper.currentField = "11" then
					msgHelper.setNextField();
//					dischargePort := msgHelper.currentSubItem[1:5];
				endif;
			elseif group = 6 then
				msgHelper.setNextField();
				if msgHelper.currentField = "7" then
					msgHelper.setNextField();
//					ediTI.setDestinationPort(msgHelper.currentSubItem[1:5]);
				elseif msgHelper.currentField = "9" then
					msgHelper.setNextField();
//					ediTI.setLoadPort(msgHelper.currentSubItem[1:5]);
				elseif msgHelper.currentField = "11" then
					msgHelper.setNextField();
//					ediTI.setDischargePort(msgHelper.currentSubItem[1:5]);
				endif;
			endif;
//MEA
		elseif msgHelper.currentTag = "MEA" then
			if group = 4 then
				group := 5;
				msgHelper.setNextField();
				if msgHelper.currentField = "AAE" then
					msgHelper.setNextField();
					
					if msgHelper.currentField = "VGM" then	// Weight.
						msgHelper.setNextField();
						msgHelper.setNextSubItem();
						ediTI.totalWeight := msgHelper.currentSubItem.Integer;
					endif;
				endif;
			endif;
//NAD
		elseif msgHelper.currentTag = "NAD" then
			msgHelper.setNextField();
            subTag := msgHelper.currentField;
			if group = 1 then
				group := 2;
			elseif group &gt;= 4 or
			   group &lt;= 7 then
				group := 8;
			endif;
			if group = 8 then
				if subTag = "SPC" then		// Weighter
					msgHelper.setNextField();
					msgHelper.setNextField();
					msgHelper.setNextField();
					if ediTI &lt;&gt; null then
						ediTI.weightCertifiedReference := msgHelper.currentSubItem;
					endif;
				elseif subTag = "AM" then		// Container operator!
					msgHelper.setNextField();
					msgHelper.setNextField();
					msgHelper.setNextField();
					if ediTI &lt;&gt; null then
						ediTI.weightCertifiedName := msgHelper.currentSubItem;
					endif;
				endif;
			endif;

//RFF
		elseif msgHelper.currentTag = "RFF" then
			if group = 0 then
				group := 1;
			endif;
			if group = 4 then
				msgHelper.setNextField();
				if msgHelper.currentSubItem = "BN" then
					msgHelper.setNextSubItem();
//					self.setRawCommodityValue (group, ediTI, msgHelper.currentField);	// par 31259
				endif;
				// 16/10/2014 cnwar2 #35053
			endif;
//SEL
		elseif msgHelper.currentTag = "SEL" then
			if group = 4 then
				msgHelper.setNextField();
//				ediTI.setSealNum(msgHelper.currentField); //ccms 1690 cnwrs1 May 2008
			endif;
//TDT
		elseif msgHelper.currentTag = "TDT" then
			if group = 5 then
				group := 6;
			endif;
			if group = 6 then
				msgHelper.setNextField();
				if msgHelper.currentField = "20" then
					self.getVoyageDetailsFromTDT(	msgHelper,
													voyageCode,
													operatorVoyageCode,
													operatorVoyage,
													vesselName,
													lloydsNumber,
													callSign ); 
					
					// cnwrl1 26/07/2010 PAR 25093 - start of coding
					// Because some of Nelson's clients (ANL and COS) in particular do not send
					// through the mandatory UNB record the operator is not getting set up.
					// To cater for this we will use the first valid TDT+20 operator
					// if and only if the operator is not already set up.
					if operatorSender = null then
						operatorSender := operatorVoyage;
						operatorSenderCode := operatorVoyageCode;
						ediData.setOperator(operatorSender);
					endif;
				endif;
			elseif group = 9 then
				msgHelper.setNextField();
			endif;
//UNA
//		elseif msgHelper.currentTag = "UNA" then
//			msgHelper.setFirstField();
//UNB
		elseif msgHelper.currentTag = self.UNB then
			if group = 0 then
				self.getUNB_ElementData(msgHelper,
											operatorSenderCode,
										operatorSender, rawSenderCode, recipientCode, creationTS, sequence);
				ediData.setOperator(operatorSender);
			endif;
//UNH
		elseif msgHelper.currentTag = "UNH" then
			untCount := 1;
			self.getUNHData(_ediFile.ediData, msgHelper, fileType, version);
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(rawSenderCode, recipientCode, fileType, version, _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				ediData.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
//UNT
		elseif msgHelper.currentTag = "UNT" then
			group := 0;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;msgHelper.currentTag&amp;' '&amp;group.String;
	endforeach;
	
//	self.doTranslations (_ediFile, null);
epilog
	delete theLines;
	delete msgHelper;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
