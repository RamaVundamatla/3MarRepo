    <JadeMethod name="getSaveTableAsTextFileName" id="ee7a9f7b-9812-49bf-8d89-292b3b831f6e">
        <source>getSaveTableAsTextFileName(initialFileName : String) : String protected;

vars
	dlg : CMDFileSave;
	
begin
	create dlg transient;
	
	dlg.createPrompt := false;
	dlg.fileMustExist := false;
	dlg.hideReadOnly := true;
	dlg.noReadOnlyReturn := true;
	dlg.overwritePrompt := true;
	dlg.pathMustExist := true;
	dlg.validate := true;
	dlg.fileName := initialFileName.trimBlanks;
	dlg.filter := "Text Files (*.txt)|*.txt|All Files|*.*";
	dlg.defaultExt := self.ExtensionText;
	
	if dlg.open &lt;&gt; 0 then
		return null;
	endif;
	
	return dlg.fileName.trimBlanks;

epilog
	delete dlg;
end;</source>
        <access>protected</access>
        <Parameter name="initialFileName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeRateGraphs" id="369c6de9-1da3-43b3-abb2-8dea061738f1">
        <updating/>
        <source>initializeRateGraphs() updating, protected;

begin
	if self.myRateGraphUpdTPS &lt;&gt; null and global.isValidObject(self.myRateGraphUpdTPS) then
		delete self.myRateGraphUpdTPS;
	endif;
	create self.myRateGraphUpdTPS transient;
	self.myRateGraphUpdTPS.initialize(self.picGraphUpdTPS, 33023, 5); // orange
	
	if self.myRateGraphReadTPS &lt;&gt; null and global.isValidObject(self.myRateGraphReadTPS) then
		delete self.myRateGraphReadTPS;
	endif;
	create self.myRateGraphReadTPS transient;
	self.myRateGraphReadTPS.initialize(self.picGraphReadTPS, Yellow, 5);

	if self.myRateGraphTotalTPS &lt;&gt; null and global.isValidObject(self.myRateGraphTotalTPS) then
		delete self.myRateGraphTotalTPS;
	endif;
	create self.myRateGraphTotalTPS transient;
	self.myRateGraphTotalTPS.initialize(self.picGraphTotalTPS, Red, 5);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isLastSaveFileTypeValid" id="0c59b5c1-5639-4008-969d-d165093dca20">
        <source>isLastSaveFileTypeValid() : Boolean;

vars
	ft : Integer;
	
begin
	ft := self.lastSaveFileType;
	
	return ft = self.FileTypeHTML or ft = self.FileTypeText;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
