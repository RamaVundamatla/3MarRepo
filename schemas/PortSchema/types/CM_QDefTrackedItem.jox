	self.allQueryProperties.add(tmpProp);//ccms 1023
	
	create tmpProp as CM_QDecimalMethod persistent;				//+TFS38608 add one more option To return TEU Decimal Value, we still needs to keep IntergerMethod though
	tmpProp.set('Number of TEUs Decimal', CM_TrackedItem::getNumTEUDeci.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
