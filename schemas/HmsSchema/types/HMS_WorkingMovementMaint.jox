    <JadeMethod name="pilotExemptEnable" id="ff303eb2-3926-4578-a856-4222ab0fdb6a">
        <source>pilotExemptEnable() protected;
//--------------------------------------------------
// Created:	12 October 2007 By cnwvu1
//--------------------------------------------------
// Changed On	By			Reason
// ========== 	========	===================================================
// 16/08/2011	cnwdap1		PAR #30145 Allow pilot details to be entered for Shift movements if config set
// 15 May 2019	jlgsl4		TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars

begin

	if chkPilotExempt.value=true then
		// Disable pilot movement services
	//	cmbPilot.enabled:=false;
	//	cmbPilot.text:= '';
		self.lstPilots.enabled := false;	//30 Oct 2018	NDL	TFS 41662
		cmbLaunchPosn.enabled:=false;
		txtLOrderActual.enabled:=false;
		txtLaunchRel.enabled:=false;
		lblMins.enabled:=false;
		cmbPilotLaunch.enabled	:=false;
		cmbPilotLaunch.text		:='';
		self.tblPilotLaunch.enabled := false; // TFS 44438
	else
		// Enable pilot movement services
	//	cmbPilot.enabled:=true;
		self.lstPilots.enabled := true;	//30 Oct 2018	NDL	TFS 41662
		self.tblPilotLaunch.enabled := true; // TFS 44438
		//if aMySelectedMovement &lt;&gt; null and aMySelectedMovement.moveType=HMSMovementTypeShift then																	// PAR #30145
		if aMySelectedMovement &lt;&gt; null and aMySelectedMovement.moveType=HMSMovementTypeShift and not self.myTerminal.getConfig(PilotOnShiftMovement).Boolean then	// PAR #30145
			// Pilot launch not required
			cmbLaunchPosn.enabled:=false;
			txtLOrderActual.enabled:=false;
			txtLaunchRel.enabled:=false;
			cmbPilotLaunch.enabled:=false;
		else
			// Pilot launch required
			cmbLaunchPosn.enabled:=true;
			txtLOrderActual.enabled:=true;
			txtLaunchRel.enabled:=true;
			cmbPilotLaunch.enabled:=true;
		endif;
		lblMins.enabled:=true;	
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateBollardResources" id="ceba0c3f-cb1b-4be9-b0a6-c29dd73273f6">
        <source>populateBollardResources(_berth: HMS_Berth);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Sep 2022	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
05 Sep 2023	navdap1	TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
*/

vars
	resource: HMS_Resource;
	idx: Integer;
begin
	self.cmbBowMarkBollard.clear;
	self.cmbSternMarkBollard.clear;
	self.cmbBridgeMarkBollard.clear;
	self.txtBowMarkMeter.text := null;
	self.txtBridgeMarkMeter.text := null;
	self.txtSternMarkMeter.text := null;
	if _berth &lt;&gt; null then
		//foreach resource in _berth.allBerthResources where resource.myResourceType.isBollard do 	// TFS 59472
		foreach resource in _berth.myWharf.allResources where resource.myResourceType.isBollard do 	// TFS 59472
			idx	:=	self.cmbBowMarkBollard.addItem(resource.code);
			self.cmbBowMarkBollard.itemObject[idx] := resource;
			idx	:=	self.cmbSternMarkBollard.addItem(resource.code);
			self.cmbSternMarkBollard.itemObject[idx] := resource;
			idx	:=	self.cmbBridgeMarkBollard.addItem(resource.code);
			self.cmbBridgeMarkBollard.itemObject[idx] := resource;
		endforeach;
	endif;
epilog
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="reloadMarineServicesSheet" id="f82bba41-bfb9-4eed-b9dc-aa75d6607e78">
        <updating/>
        <source>reloadMarineServicesSheet() updating, protected;
//This reloads the marine services sheet after we have ascertained that the movement
//now requires marine services, eg after berth changed from logical to physical
vars
  	posn:				Integer;
  	cbxPosn:			Integer;
  	tug:				HMS_Tug;
	pilot : HMS_Pilot;
	row: Integer;
begin
	if aMySelectedMovement = null then
		return;
	endif;
	// Set pilot exempt state
	chkPilotExempt.value:=aMySelectedMovement.pilotExempt;
	chkPilotExempt.click(chkPilotExempt);


	chkChargeMove.value:= (not self.aMySelectedMovement.chargeForMove);
	txtLineCrewReqd.text:=aMySelectedMovement.numLineCrewRequired.String;
	txtShipsMaster.text:=aMySelectedMovement.shipsMaster;

	setDefaultRelOrderTimes;

	if not (aMySelectedMovement.relativeOrderTimeLines = 0 and
		aMySelectedMovement.relativeOrderTimePlaunch = 0 and
		aMySelectedMovement.relativeOrderTimeTugs = 0) then
		// If movement has rel times already, load Actual relative times
	    if aMySelectedMovement.relativeOrderTimeLines&gt;-1 then
	    	txtLineRelative.text:="+" &amp; aMySelectedMovement.relativeOrderTimeLines.String;
	    else
	    	txtLineRelative.text:=aMySelectedMovement.relativeOrderTimeLines.String;
		endif;
		if aMySelectedMovement.relativeOrderTimePlaunch&gt;-1 then
			txtLaunchRel.text:="+" &amp; aMySelectedMovement.relativeOrderTimePlaunch.String;
		else
			txtLaunchRel.text:=aMySelectedMovement.relativeOrderTimePlaunch.String;
		endif;
		if aMySelectedMovement.relativeOrderTimeTugs&gt;-1 then 
			txtTugRelative.text:="+" &amp; aMySelectedMovement.relativeOrderTimeTugs.String;
		else
			txtTugRelative.text:=aMySelectedMovement.relativeOrderTimeTugs.String;
		endif;
 	endif;

	// setDefaultOrderTimes
	setDefaultActOrderTimes;

	// Modified by Russell 07/04/99
	// -------------------------------------------------------------
	setPLaunchReqdStatus;
	// -------------------------------------------------------------

    // Set list and combobox items
    if aMySelectedMovement.locationPilotLaunch&gt;0 then
    	cmbLaunchPosn.listIndex:=aMySelectedMovement.locationPilotLaunch;
		cmbLaunchPosn.text:=cmbLaunchPosn.itemText[cmbLaunchPosn.listIndex];
	endif;
	if aMySelectedMovement.locationTug&gt;0 then
    	cmbTugPosn.listIndex:=aMySelectedMovement.locationTug;
		cmbTugPosn.text:=cmbTugPosn.itemText[cmbTugPosn.listIndex];
	endif;

//	self.cmbMaster.listIndex := self.cmbPilot.findObject(self.aMySelectedMovement.myMaster);
	self.cmbMaster.listIndex := self.cmbMaster.findObject(self.aMySelectedMovement.myMaster);	// noticed wrong combo during changes, 11 years on....
	// Load Pilot
	//30 Oct 2018	NDL	TFS 41662
	self.lstPilots.setSelected(null);
	foreach pilot in self.aMySelectedMovement.allPilots do											
		if self.lstPilots.findObject(pilot, row) then
			self.lstPilots.setRowSelect(row, true);
		else
			self.lstPilots.accessRow( self.lstPilots.addItem( Tab &amp; self.myAssistant.displayEntryHMSPilot(pilot) ) ).itemObject := pilot;
			self.lstPilots.setRowSelect(self.lstPilots.accessedRow.row, true);
		endif;
	endforeach;
	
//	self.cmbPilot.listIndex := self.cmbPilot.findObject(self.aMySelectedMovement.myPilot);	
	/*if mySelectedMovement.myPilot&lt;&gt;null then
		posn:=cbxPilot.findObject(mySelectedMovement.myPilot);
		if posn&gt;0 then
			cbxPilot.listIndex:=posn;
			cbxPilot.text:=cbxPilot.itemText[cbxPilot.listIndex];
		endif;
	endif;*/

	// Load Pilot Launch
	self.cmbPilotLaunch.listIndex := self.cmbPilotLaunch.findObject(self.aMySelectedMovement.myPilotLaunch);
	/*if mySelectedMovement.myPilotLaunch&lt;&gt;null then
		posn:=cbxPilotLaunch.findObject(mySelectedMovement.myPilotLaunch);
		if posn&gt;0 then
			cbxPilotLaunch.listIndex:=posn;
			cbxPilotLaunch.text:=cbxPilotLaunch.itemText[cbxPilotLaunch.listIndex];
		endif;
	endif;*/

	// Load Line Company
	self.cmbLineCo.listIndex := self.cmbLineCo.findObject(self.aMySelectedMovement.myLineCompany);	
	/*if mySelectedMovement.myLineCompany&lt;&gt;null then
		posn:=cbxLineCo.findObject(mySelectedMovement.myLineCompany);
		if posn&gt;0 then
			cbxLineCo.listIndex:=posn;
			cbxLineCo.text:=cbxLineCo.itemText[cbxLineCo.listIndex];
		endif;
	endif;*/

	// Load tugs used
	self.lstTugsReq.setSelected(self.aMySelectedMovement.allTugsUsed);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="410eb100-3606-404d-b6e7-a5e77024b195">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//---------------------------------------------------
// Created: By:
//---------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 20/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
vars

begin
	inheritMethod(_colorControl);
	return;
	self.grpChkPtDetails.backColor := self.backColor;
	self.grpCustForMove.backColor := self.backColor;
	self.grpLinesmen.backColor := self.backColor;
	self.grpMoveDetail.backColor := self.backColor;
	self.grpMoveFrom.backColor := self.backColor;			
	self.grpMoveTo.backColor := self.backColor;
	self.grpMoveWindow.backColor := self.backColor;
	self.grpPilotLaunch.backColor := self.backColor;
	self.grpTidalClass.backColor := self.backColor;
	self.grpTugs.backColor := self.backColor;
	self.fldMovements.backColor := self.backColor;
	self.lblAftClearFrom.backColor := self.backColor;
	self.lblAftClearTo.backColor := self.backColor;
	self.lblAtArr.backColor := self.backColor;
	self.lblBerthFrom.backColor := self.backColor;
	self.lblBerthTo.backColor := self.backColor;
	self.lblBillingTitle.backColor := self.backColor;
	self.lblBowMarkFrom.backColor := self.backColor;	
	self.lblBowMarkTo.backColor := self.backColor;	
	self.lblClassForMove.backColor := self.backColor;
	self.lblDefaultTidal.backColor := self.backColor;
	self.lblEarliest.backColor := self.backColor;
	self.lblFirstPtReached.backColor := self.backColor;	
	self.lblForeClearFrom.backColor := self.backColor;
	self.lblForeClearTo.backColor := self.backColor;
	self.lblGeneral.backColor := self.backColor;
	self.lblIs.backColor := self.backColor;	
	self.lblLatest.backColor := self.backColor;	
	self.lblLaunchActual.backColor := self.backColor;
	self.lblLaunchOrder.backColor := self.backColor;
	self.lblLaunchPosn.backColor := self.backColor;
	self.lblLaunchRelative.backColor := self.backColor;	
	self.lblLineActual.backColor := self.backColor;	
	self.lblLineCrewReqd.backColor := self.backColor;
	self.lblLineRelative.backColor := self.backColor;
	self.lblLinesCompany.backColor := self.backColor;
	self.lblLinesOrder.backColor := self.backColor;	
	self.lblM.backColor := self.backColor;
	self.optAgent.backColor := self.backColor;
	self.optShippingLine.backColor := self.backColor;
	self.chkChargeMove.backColor := self.backColor;
	self.chkPilotExempt.backColor := self.backColor;	
	self.lblm.backColor := self.backColor;	
	self.lblM_1.backColor := self.backColor;
	self.lblM_2.backColor := self.backColor;
