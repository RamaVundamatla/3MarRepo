    <JadeMethod name="mnuWorkDisplayFlipH_click" id="3936f697-abae-4239-b262-bb3b4a0de1af">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuWorkDisplayFlipH_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     07 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDC :	YRD_ContainerDrawingController;
begin
	tmpDC := self.myCurrentDrawingController;
	tmpDC.setFlip(not tmpDC.flipHorizontal, tmpDC.flipVertically);
	self.xmlFlipH := tmpDC.flipHorizontal;
	self.xmlFlipV := tmpDC.flipVertically;
	tmpDC.drawSelf(true);
	self.doSetCaption();
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuWorkDisplayFlipV_click" id="e0cb2c62-7e06-44fe-b2a1-c1082ee667eb">
