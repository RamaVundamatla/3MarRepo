<ExceptionClass name="Exception">
    <JadeMethod name="isJSSException" id="3610dfe4-bba9-42b4-9932-d4a551f2a95e">
        <source>isJSSException():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 April 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the exception is a JSS
//				exception.
//
// Parameters:	None
//
// Returns:		True if the exception object is a JSS exception, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssGetDetails" id="d79cfeb8-6629-4b2d-b367-34d4cc3aa3f2">
        <source>jssGetDetails():String;
// --------------------------------------------------------------------------------
// Created:		19 November 2002 by cnwdad1
//
// Purpose:		Builds a description of the exception details.
//
// Parameters:	None
//
// Returns:		The exception details.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorDetails	: String;
	theObject		: Object;
	errorShort		: String;

begin
	errorDetails	:=	"* Error " &amp; self.errorCode.String &amp; ": " &amp;
						self.text() &amp; " " &amp;
						self.extendedErrorText;
	
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; " Application: " &amp; app.name &amp; CrLf &amp;
						"      Schema: " &amp; currentSchema.name &amp; CrLf &amp;
						"        Type: " &amp; self.class().name;
	
	if self.reportingMethodDesc &lt;&gt; null then
		if self.reportingMethodDesc.isKindOf(PrimMethodCallDesc) then
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "    Reported: " &amp;
								self.reportingMethodDesc.receiverAsString().String &amp; " " &amp;
								self.reportingMethodDesc.getName();
		else
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "    Reported: " &amp;
								self.reportingMethodDesc.getReceiver().String &amp; " " &amp;
								self.reportingMethodDesc.getName();
		endif;
	endif;

	if self.currentMethodDesc &lt;&gt; null then
		if self.currentMethodDesc.isKindOf(PrimMethodCallDesc) then
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Caused by: " &amp;
								self.currentMethodDesc.receiverAsString().String &amp; " " &amp;
								self.currentMethodDesc.getName();
		else
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Caused by: " &amp;
								self.currentMethodDesc.getReceiver().String &amp; " " &amp;
								self.currentMethodDesc.getName();
		endif;
	endif;

	theObject	:=	self.errorObject();
	errorShort	:=	self.errorItem;

 	if global.isValidObject(theObject) then
		errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "Error Object: " &amp; theObject.String;
	endif;

 	if errorShort &lt;&gt; null then
		errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "  Error Item: " &amp; errorShort;
	endif;
	
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; " Continuable: " &amp; self.continuable.jssFormat("Yes", "No");
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Resumable: " &amp; self.resumable.jssFormat("Yes", "No");
epilog
	return errorDetails;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</ExceptionClass>
