    <JadeMethod name="buildCombosForHarbour" id="ece1f4cb-c9e5-40db-844f-e5ea87356cda">
        <updating/>
        <source>buildCombosForHarbour() updating;

vars

begin

	// Load Terminals
	self.cmbTerminalHMS.myHarbour := self.myHarbour;
	self.cmbTerminalHMS.clear();
	self.cmbTerminalHMS.initialise(false);
	self.cmbTerminalHMS.listIndex := self.cmbTerminalHMS.findObject(self.myTerminal);
	if self.cmbTerminalHMS.listIndex &lt; 1 then
		if self.cmbTerminalHMS.listCount &gt; 0 then
			self.cmbTerminalHMS.listIndex := 1;
		endif;		
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildEntireForeground" id="94048f6e-44cb-44bb-a6ef-38c4ff7c5eca">
        <updating/>
        <source>buildEntireForeground(_workingVoyage : CMIF_HMS_WorkingVoyage)updating;
//--------------------------------------------------
// Created:	12 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.mode = self.Mode_Update
	and self.hasSavedChanges then
		return;
	endif;

	self.setMyCurrentWorkingVoyage(_workingVoyage);
	if self.myCurrentWorkingVoyage &lt;&gt; null then
		self.loadEditVoyage();
	elseif self.mode = self.Mode_Update then
		app.msgBox(self.cmbVessel.text &amp; ' ' &amp; app.getErrorString(HMS_Voyage_Updated), app.getErrorString(Voyage_Updated) &amp; ': ' &amp; self.caption, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);			
		self.unloadForm();
	else
		self.loadAddVoyage();	
	endif;

end;</source>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
