    <JadeMethod name="doSave" id="eeaf76a1-8137-47c2-a24e-77e7f7bd7be2">
        <updating/>
        <source>doSave() : Boolean updating, protected;

/*

Purpose:		Add cargo to a wagon.  Modeled off YRD_WagonForm::doSave....

Parameters:			

Return Value:		


Date		Who		Reason
21 Jul 2009	cnwmd1	Initial creation
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	wagonCode,
	wagonClassId	: String;
	wagonPos		: Integer;
	proxyWagon,
	realWagon 		: CM_Wagon;
	wagonClass 		: CM_WagonClass;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	result			: Integer;
	controller		: CM_WagonController;
	selectedTi		: CM_TrackedItem;
	selectedPosition: Integer; 
	rake 			: CM_RailLine;

begin
	realWagon := self.myCurrentWagon;
	if realWagon = null then
		app.msgBox(app.getErrorString(Please_select_wagon_POP), app.getErrorString(Cargo_ADD), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	selectedTi := self.myCurrentTI;
	if selectedTi = null then
		app.msgBox(app.getErrorString(Please_select_cargo_itemPOP), app.getErrorString(Cargo_ADD), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	controller := self.cmbCargoPosition.listObject.CM_WagonController;
	
	if controller = null and self.myTerminal.getConfig( RailDefaultWCIdFormat ).Integer = Rail_UPSP_Int then
		controller := realWagon.getNextFreeWagonController(selectedTi, REAL_MODE, null, null, false);
		if controller = null then
			app.msgBox(app.getErrorString(ERR_TOO_MUCH_ON_WAGON), app.getErrorString(Cargo_ADD), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endif;
	
	if controller = null then
		app.msgBox(app.getErrorString(Please_select_positionPOP), app.getErrorString(Cargo_ADD), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	selectedPosition := realWagon.allLocationsControllersArray.indexOf(controller);
	
	
	
	self.mousePointer := MousePointer_HourGlass;
	
	//** Setup proxyWagon
	proxyWagon := app.createUpdateProxy(realWagon).CM_Wagon;
	wagonClass := realWagon.myWagonClass;	// 28 Aufg 2009	NDL CCMS 1094
	if wagonClass = null then
		wagonClassId 	:= app.myRoot.getWagonClassViaHookCode(self.myTerminal,wagonCode,null); //20 Jul 2009 NDL CCMS 1067
		wagonClass 		:= app.myRoot.allWagonClasses[wagonClassId];
	endif;
	proxyWagon.setProxy(self.myTerminal, 
						realWagon.id,
						wagonClass,
						realWagon.myTrainInwards,
						realWagon.myTrainOutwards,
						realWagon.remarks, 
						//realWagon.maxCargoHeight,
						0,	//Par 21924
						//realWagon.maxCargoWeight,
						0,	//Par 21924
						0,
						realWagon.myCarrier,
						realWagon.myStevedoreReceive,   //02.10.2020 cnwma1 TFS #50112
						realWagon.myStevedoreRelease);  //02.10.2020 cnwma1 TFS #50112 
	
	//** setup CMIF_WagonUpdateController
	create  wagonUpdateCtrl transient;	
	rake := realWagon.myRailLine;
	if rake &lt;&gt; null then
		wagonPos := rake.allWagons.indexOf(realWagon);
	endif;
	//19 Aug 2009	NDL	CCMS 1094
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
										rake,	//_rake : CM_RailLine;
										self.myCurrentTrain,	//_train : CM_Train;
										wagonPos,	//_wagonPosition : Integer
										true//_trainMode : Boolean
										);
	
	wagonUpdateCtrl.populateFromExistingWagonAddTi( realWagon, selectedTi, selectedPosition );
	
	wagonUpdateCtrl.expectedEditionWagon := self.myCurrentWagon.edition;
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
	//wagonUpdateCtrl.unconfirmWagonInwards := true;	24 Aug 2009	NDL	CCMS1094
	
	
	//*** now pass to the trx Agent.
	while true do
		app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport); //+ cnwmd1, CCMS 1067, Par 19913

		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon_cargo_savePOP), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	
	
	if app.myPassport.trxCompletedOK then
		realWagon.causeEvent(Wagon_Update_Cargo_Event, true, null); //Wagon form is the only current subscriber
		return true;
	else
		return false;
	endif;
	
epilog

	delete proxyWagon;
	delete wagonUpdateCtrl;
	self.mousePointer := MousePointer_Default;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLocationController" id="415c2a00-2202-4689-a5c4-51bdd8c0f94a">
        <source>getLocationController(_pos : Integer) : CM_WagonController protected;

/*

Purpose:		Redundant!	

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2009	cnwmd1	Initial creation

*/

vars
	wagon : CM_Wagon;
