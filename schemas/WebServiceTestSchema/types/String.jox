<PrimType name="String">
    <JadeMethod name="asAnyOfType" id="766c8f90-93fc-44c7-8331-30bbc1891fac">
        <source>asAnyOfType(_type : Type) : Any;

/*

Purpose:			Convert the receiver String into the passed in Type of Any


Return Value:		


Date		Who		Reason
12 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	typeName		: String;
	
begin
	typeName := _type.name;
	if typeName = Binary.name then
		return self.base64Decode();
	elseif typeName = Boolean.name then
		return self.Boolean;
	elseif typeName = Character.name then
		return self.Character;
	elseif typeName = Date.name then
		return self.Date;
	elseif typeName = Decimal.name then
		return self.Decimal;
	elseif typeName = Integer.name then
		return self.Integer;
	elseif typeName = Real.name then
		return self.Real;
	elseif typeName = Time.name then
		return self.Time;
	elseif typeName = TimeStamp.name then
		return self.TimeStamp;
	else
		return self;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_type" type="Type"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="asObjectUsingConvertFromXML" id="e31ad54b-461c-49e2-a5ee-baf1bfc19bc6">
        <source>asObjectUsingConvertFromXML(_createdObjects : ObjectSet input) : Object;

/*

Purpose:			Return the receiver String as a transient Object using the convert from XML
					methods


Return Value:		Object, or null if invalid
					Will populate _createdObjects with any other objects created below the receiver
					in a hierarchy, to allow the caller to tidy them up


Date		Who		Reason
17 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	xml				: JadeXMLDocument;
	obj				: Object;
	
begin
	create xml transient;
	xml.parseString(self);
	
	obj := xml.returnAsObject(true, _createdObjects);
	
	return obj;
	
	
epilog
	delete xml;
	
end;</source>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getSingleXMLValue" id="df0005b2-64c9-4b57-9607-d533dd806f99">
        <source>getSingleXMLValue(tag : String) : String;

constants
	TagStart		= "&lt;";
	TagEnd			= "&gt;";
	
vars
	pos1,
	pos2			: Integer;
	searchString	: String;
	
begin
	searchString := TagStart &amp; tag &amp; TagEnd;
	pos1 := self.pos(searchString, 1);
	if pos1 = 0 then 
		return null;
	endif;
	
	pos1 := pos1 + searchString.length;
	if pos1 &gt; self.length then
		return null;
	endif;
	
	searchString := TagStart &amp; "/" &amp; tag &amp; TagEnd;
	pos2 := self.pos(searchString, pos1);
	
	if pos2 = 0 then
		return null;
	endif;
	
	return self[pos1:pos2 - pos1];


end;</source>
        <Parameter name="tag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="truncateWithEllipsis" id="f5256440-b5e8-4d0e-8122-624e201f9975">
        <source>truncateWithEllipsis(_length : Integer) : String;

/*

Purpose:			


Return Value:		


Date		Who		Reason
25 Aug 2005	cnwkpd1	Initial creation

*/

vars

begin
	if self.length &gt; _length then
		return self[1:_length - 3] &amp; "...";
	else
		return self;
	endif;
	

epilog

end;</source>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
