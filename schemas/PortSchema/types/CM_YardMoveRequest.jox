    <JadeMethod name="setForCreateInternal" id="632906c6-95b5-4d99-bccf-3a28b2c874f5">
        <updating/>
        <source>setForCreateInternal(_myJob : CM_YardInternalJob; _yardInternalJobParam : CMIF_YardWorkJobParams) updating;
/*
 ------------------------------------------------------------------------
Created:			26 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	self.myJob := _myJob;
	self.totalRequested := _yardInternalJobParam.numToMove;
	self.mySourceLocation := _yardInternalJobParam.mySourceLocation;
	// 23098 no source TA available - save the first LC instead and test later if this is for a gridded area -
	//   if so, use the TA of the LC instead
	if _yardInternalJobParam.mySourceLocation = null and
	   _yardInternalJobParam.mySourceTA &lt;&gt; null then
		self.mySourceLocation := _yardInternalJobParam.mySourceTA.allLocationsControllers.first;
	endif;
	self.myTargetLocation := _yardInternalJobParam.myTargetLocation;
	self.myTargetTA			:= _yardInternalJobParam.myTargetTA;
	self.overrideLocnRestrictions := _yardInternalJobParam.overridePlacementRestrictions;
	self.requiredByDT := _yardInternalJobParam.requredByDT; //cnwrd1 29.1.2010
	self.mySelectedRTQueue := _yardInternalJobParam.myQueueToAddTo; //cnwrd1 29.1.2010
	self.remarks := _yardInternalJobParam.remarks; //cnwrd1 par 24961
	self.userCode:=app.getMyUserCode; //epr par 29026 4/5/12
end;</source>
        <Parameter name="_myJob" type="CM_YardInternalJob"/>
        <Parameter name="_yardInternalJobParam" type="CMIF_YardWorkJobParams"/>
    </JadeMethod>
</Class>
