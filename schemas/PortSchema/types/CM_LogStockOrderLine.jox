    <JadeMethod name="getMyLogVoyage" id="2c42e778-f3e0-4263-8bb8-68479a9633c6">
        <source>getMyLogVoyage():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

begin

	
	if self.myLogLot &lt;&gt; null and self.myLogLot.myLogVoyageStructure &lt;&gt; null then
		return self.myLogLot.myLogVoyageStructure.myVoyage;
	endif;
	
	return null;

epilog

end;</source>
