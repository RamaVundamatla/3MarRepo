    <JadeMethod name="getOIDAndDescForAttribute" id="c117747c-ad1d-4ae8-b306-982d0181219a">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
//21/06/2016   cnwma1 	    PAR #37960 TFS #2187 PEN - Report Maintenance Set and Save Default Value
//26/05/2022   navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
vars
	bln : Boolean;
	carrier,subCarrier : CM_Carrier;
	shipLine : CM_ShippingLine;
begin
	if _attrName = ETRow_LogTxnType then
		_oid := app.logTxnTypesStringToEnum(self.transTypeStr).String; 
		return self.transTypeStr;
	elseif _attrName = ETRow_TransactionType then
		return self.getTransTypeString(_oid);//21/07/2010 cnwdz2 24513
		
	elseif _attrName = 	ETRow_DeletedTrans then 
	// display in row is 'include deleted transactions' 
	// this is opposite of Ignore Deleted 
		bln := 	not self.ignoreDeleted;

		return bln.cnEcGetTableCheckBoxValue;
		
	elseif _attrName = 	ETRow_IncludeChildTransactions then //03 Aug 2010	NDL	Par 23056
		bln := 	self.includeChildTransactions;
		return bln.cnEcGetTableCheckBoxValue;
		
	elseif _attrName = ETRow_IMEXStatuses then				//21/06/2016 cnwma1 PAR #37960 TFS #2187
		return self.getQryIMEXLabel(_oid);
	
	//Start 26/05/2022 navhl20 TFS 53430 
	elseif _attrName = ETRow_MyCarrier then
		carrier:= self.getMyCarrier();
		if carrier &lt;&gt; null then
			_oid:=carrier.getOidAsString; //jlier1 TFS 53807 13/6/22
			return carrier.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_MySubCarrier then
		subCarrier := self.getMySubCarrier();
		if subCarrier &lt;&gt; null then
			_oid:=subCarrier.getOidAsString; //jlier1 TFS 53807 13/6/22
			return subCarrier.code;
		endif;
		return Any_String;
	//End 26/05/2022 navhl20 TFS 53430
	
	 // ### TFS BUG 56660 23FEB2023 NAVAB1
	elseif _attrName = ETRow_ShippingLine then
		shipLine := self.getMyShippingLine();
		if shipLine &lt;&gt; null then
			_oid:=shipLine.getOidAsString;
			return shipLine.code;
		endif;
		return Any_String;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQryIMEXLabel" id="d0f1cd45-81dd-4fb2-a33f-80a8126f77df">
        <source>getQryIMEXLabel(_oid:String output): String;
//----------------------------------------------------------------
//	Created:	21/06/2016 CNWMA1 PAR #37960 PEN - Report Maintenance Set and Save Default Value
//----------------------------------------------------------------

vars
	str				:	String;
	imexStatus		:	CM_IMEXStatus;
	imexInteger : Integer;
begin

	foreach imexInteger in self.allQryImexStatus do
		foreach   imexStatus in app.myRoot.allImexStatuses do
			if imexStatus.code = imexInteger then
					if str = "" then
						_oid := imexStatus.getOidAsString(); 
						str := imexStatus.description.trimBlanks;
					else
						_oid := _oid &amp; ", " &amp; imexStatus.getOidAsString(); 
						str := str &amp; ", " &amp;  imexStatus.description.trimBlanks;
					endif;
			endif;
		endforeach;
	endforeach;

	return str[1:80];
end;



</source>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransTypeFromString" id="988d4c17-ff7f-498f-94c2-2fc41efb3755">
        <source>getTransTypeFromString( typeStr : String ) : Integer;
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//constants
//	TRANS_TYPE_UNKNOWN = -1;
	
vars
	cm_TransactionType	: CM_TransactionType;
	dynaDict			: DynaDictionary;
	
begin
	// THIS METHOD IS NOW REDUNDANT and show be deleted when the collection allTransTypeDescriptions is deleted
	if typeStr = null then
		return self.TRANS_TYPE_UNKNOWN;
	endif;
	
	// get a sorted collection on the description of the transaction types
	create dynaDict transient;
	
	// set the membership of our dynamic dictionary
	dynaDict.setMembership( CM_TransactionType );
	
	// specify the required dictionary keys (ascending and not case insensitive)
	dynaDict.addMemberKey( CM_TransactionType::description.name, false, true );
	
	// complete key definition, duplicates NOT allowed.
	dynaDict.endKeys( false );
	
	// now populate the required instances into the dynamic dictionary.
	CM_TransactionType.instances.copy( dynaDict );
	
	// Now attempt to match the transaction type description passed in.
	cm_TransactionType	:= dynaDict[ typeStr ].CM_TransactionType;
	if cm_TransactionType = null or cm_TransactionType.description &lt;&gt; typeStr then
		return TRANS_TYPE_UNKNOWN;
	else
		// found so return the transaction type integer value.
		return cm_TransactionType.trxType;
	endif;
	
	/* cnwrl1 21/07/2009 PAR 20198 - SFW1070 - what it was
	if typeStr = CMQF_ContainerTrans.ATTACH_STRING then
		return TRANS_TYPE_ATTACH;
	elseif typeStr = CMQF_ContainerTrans.CONNECT_STRING then
		return TRANS_TYPE_CONNECT;
	elseif typeStr = CMQF_ContainerTrans.DAMAGE_STRING then
		return TRANS_TYPE_DAMAGED;
	elseif typeStr = CMQF_ContainerTrans.EDIT_STRING then
		return TRANS_TYPE_EDIT;
	elseif typeStr = CMQF_ContainerTrans.FUMIGATE_STRING then
		return TRANS_TYPE_FUMIGATE;
	elseif typeStr = CMQF_ContainerTrans.INFORMATION_STRING then
		return TRANS_TYPE_INFORMATION;
	elseif typeStr = CMQF_ContainerTrans.INSPECT_STRING then
		return TRANS_TYPE_INSPECT;
	elseif typeStr = CMQF_ContainerTrans.MOVE_STRING then
		return TRANS_TYPE_MOVE;
	elseif typeStr = CMQF_ContainerTrans.PACK_STRING then
		return TRANS_TYPE_PACK;
	elseif typeStr = CMQF_ContainerTrans.PRETRIP_STRING then
		return TRANS_TYPE_PRETRIP;
	elseif typeStr = CMQF_ContainerTrans.RECEIPT_STRING then
		return TRANS_TYPE_RECEIVE;
	elseif typeStr = CMQF_ContainerTrans.REFUEL_STRING then
		return TRANS_TYPE_FUELED;
	elseif typeStr = CMQF_ContainerTrans.RELEASE_STRING then
		return TRANS_TYPE_RELEASE;
	elseif typeStr = CMQF_ContainerTrans.REPACK_STRING then
		return TRANS_TYPE_REPACK;
	elseif typeStr = CMQF_ContainerTrans.REPAIR_STRING then
		return TRANS_TYPE_REPAIR;
	elseif typeStr = CMQF_ContainerTrans.SEAL_STRING then
		return TRANS_TYPE_SEALED;
	elseif typeStr = CMQF_ContainerTrans.UNPACK_STRING then
		return TRANS_TYPE_UNPACK;
	elseif typeStr = CMQF_ContainerTrans.WASH_STRING then
		return TRANS_TYPE_WASH;
	elseif typeStr = CMQF_ContainerTrans.WEIGHED_STRING then
		return TRANS_TYPE_WEIGH;
	else
		return TRANS_TYPE_UNKNOWN;
	endif;	
	cnwrl1 21/07/2009 PAR 20198 - SFW1070 - end of what it was */
	
epilog
	delete dynaDict;
	
end;</source>
        <Parameter name="typeStr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTransTypeString" id="dce50a98-fb69-4a81-a003-8efac1716557">
        <source>getTransTypeString(_oid : String output) : String;
// ---------------------------------------------------------------------------
// Created:     13 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str					: String;
	index				: Integer;
	transactionType		: CM_TransactionType;
	
begin
	// cnwrl1 07/09/2009 PAR 20198
	foreach index in self.allTxnTypes do : trans_loop
		transactionType := app.myRoot.allTransactionTypes[ index ];
		if transactionType = null then
			continue;
		endif;
		// needs to be exactly comma and then a space for the Web to default correctly.
		str	:= str &amp; transactionType.description &amp; CNEC_COMMA &amp; Space;
	endforeach trans_loop;
	
	// chop off last delimiter and space
	if str &lt;&gt; null then
		str := str[ 1 : str.length - 2 ];
	endif;
	
	/* cnwrl1 07/09/2009 PAR 20198 - what it was
	foreach transDescr in self.allTransTypeDescriptions do
		str := str &amp; transDescr &amp; ',';
	endforeach;
	
	//chop off last delimiter
	if str &lt;&gt; null then
		str := str[1:str.length-1];
	endif;
	cnwrl1 07/09/2009 PAR 20198 - end of what it was */
	
	return str;
end;
</source>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransTypeStringArray" id="2e31c391-9f3c-452e-bfb5-7338afe22a97">
        <source>getTransTypeStringArray( _stringArray : StringArray input );

/*
Purpose:	This method will return the allTxnTypes descriptions as a StringArray

Date				Who		Reason
04 September 2009	cnwrl1	Initial creation as part of PAR 20198
*/
	
vars
	index				: Integer;
	transactionType		: CM_TransactionType;
	
begin
	foreach index in self.allTxnTypes do : trans_loop
		transactionType := app.myRoot.allTransactionTypes[ index ];
		if transactionType = null then
			continue trans_loop;
		endif;
		_stringArray.add( transactionType.description );
	endforeach trans_loop;
	
epilog
	
end;
</source>
        <Parameter name="_stringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="f4b7041f-f8e7-456e-8364-6ea8b219bb7a">
        <updating/>
        <source>includesObject(_trx : CM_Transaction; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 February 2003		cnwth2	
//
// ----------   ----------  --------------------------------------------------
/*
	27/7/09     JMH		MES1011 Handle new allQry collections
	17/07/2012	cnwcs5	par 29601 - log excluded transactions
	29-APR-2015 cnwma1  PAR #36129 CCMS 1416 TFS 323 Break Bulk Reporting - Batch 1
	22/12/2015	cnwdap1	PAR #36784 If we're running for a single voyage, check both voyages of any tranships
	25/05/2022  navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/
vars
	querySelf			: CMQF_Transactions;
	trackedItem			: CM_TrackedItem;
	cargoType			: Integer;
	callLoggingMethod	: Boolean;	// par 29601 July 2012
	strCargoType		: String;	// par 29601 July 2012	
	shipLine : CM_ShippingLine;
	tranShipLine, qryShipLine : String;
begin
	querySelf 				:= self;
	querySelf.numSearched 	:= querySelf.numSearched + 1;
	// if we are a CAMS query then we may need to log when transaction are excluded from the query
	callLoggingMethod		:= self.callLoggingMethod;	// par 29601 July 2012
	
	if not CM_TITransaction.hasInstance(_trx) then
		return false;
	endif;
	
	if (self.myOperator &lt;&gt; null and (self.myOperator.code &lt;&gt; _trx.CM_TITransaction.operatorCode)) then
		if callLoggingMethod then																		// par 29601 July 2012
			self.logReasonForExclusion (_trx, 'Transaction operator does not match query operator');	// par 29601 July 2012
		endif;																							// par 29601 July 2012
		return false;
	endif;
	
	// cnwrl1 10/09/2010 PAR 23697 - start of coding
	if (self.getMyVoyage &lt;&gt; null and (self.getMyVoyage.code &lt;&gt; _trx.CM_TITransaction.getVoyageCode)) then		// 04/07/2011 cnwar2 #27798
		// PAR #36784 If transaction has a TI, check if it's a Tranship whether either voyage matches							// PAR #36784
		trackedItem :=  _trx.CM_TITransaction.myTrackedItem;																	// PAR #36784
		if trackedItem &lt;&gt; null and trackedItem.isTranshipItem 																	// PAR #36784
		and (trackedItem.myVoyageTranshipExport = self.getMyVoyage or trackedItem.myVoyageTranshipImport = self.getMyVoyage) then		// PAR #36784
			// this is fine - carry on and do other checks																		// PAR #36784
		else																													// PAR #36784
			if callLoggingMethod then																		// par 29601 July 2012
				self.logReasonForExclusion (_trx, 'Transaction voyage does not match query voyage');		// par 29601 July 2012
			endif;																							// par 29601 July 2012
			return false;
		endif;																													// PAR #36784
	endif;
	/// cnwma1    //cnwma1 29/04/2015  PAR #36129
	
	if ( self.id &lt;&gt; null and (self.id &lt;&gt; _trx.CM_TITransaction.id)) then
		if callLoggingMethod then																		
				self.logReasonForExclusion (_trx, 'Transaction  cargo id  does not match query cargo id ');	
		endif;																							
			return false;
	endif;
	
	if (self.getMyCargoType &lt;&gt; null and (self.getMyCargoType.id &lt;&gt; _trx.CM_TITransaction.cargoType)) then		
		if callLoggingMethod then																		
			self.logReasonForExclusion (_trx, 'Transaction CargoType does not match query CargoType');	
		endif;																							
		return false;
	endif;
	
	if( self.getMyProduct &lt;&gt; null and (self.getMyProduct.code &lt;&gt; _trx.CM_TITransaction.myTrackedItem.productCode)) then 
		if callLoggingMethod then																		
			self.logReasonForExclusion (_trx, 'Transaction Cargo SubType does not match query Cargo SubType');	
		endif;																							
		return false;
	endif;
	
	if (self.getMyTerminalArea &lt;&gt; null  and (self.getMyTerminalArea.id  &lt;&gt; _trx.CM_TITransaction.myTrackedItem.terminalAreaId)) then 
			if callLoggingMethod then																		
				self.logReasonForExclusion (_trx, 'Transaction Cargo Terminal Area Id does not match query Cargo Terminal Area Id');	
			endif;																							
			return false;
	endif;
	
	if  self.terminalAreaTypes.size &gt; 0 then
		if _trx.CM_TITransaction.myTrackedItem.myTerminalArea &lt;&gt; null and not self.terminalAreaTypes.includes ( _trx.CM_TITransaction.myTrackedItem.myTerminalArea.type) then		
			if callLoggingMethod then																	
				self.logReasonForExclusion (_trx, 'Cargo Terminal Area Type (' &amp; _trx.CM_TITransaction.myTrackedItem.myTerminalArea.typeString &amp; ') does not match query Terminal Area Type');	// par 29601 July 2012
			endif;																							
			return false;		
		endif;
	endif;
	
	if (self.getMySubTerminal &lt;&gt; null  and (self.getMySubTerminal  &lt;&gt; _trx.CM_TITransaction.myTrackedItem.mySubTerminal)) then 
			if callLoggingMethod then																		
				self.logReasonForExclusion (_trx, 'Transaction Cargo Sub Terminal does not match query Cargo Sub Terminal');	
			endif;																							
			return false;
	endif;
	
	if (self.consignee &lt;&gt; null  and (self.consignee  &lt;&gt; _trx.CM_TITransaction.consignee)) then 
			if callLoggingMethod then																		
				self.logReasonForExclusion (_trx, 'Transaction Cargo Sub Terminal does not match query Cargo Sub Terminal');	
			endif;																							
			return false;
	endif;
		
	if (self.consignor &lt;&gt; null  and (self.consignor  &lt;&gt; _trx.CM_TITransaction.consignor)) then 
			if callLoggingMethod then																		
				self.logReasonForExclusion (_trx, 'Transaction Cargo Sub Terminal does not match query Cargo Sub Terminal');	
			endif;																							
			return false;
	endif;
	
	if self.needFilterUsers then
		if self.allUsers[_trx.CM_TITransaction.userId] = null then
			return false;
		endif;
	endif;
	
	
	if ( self.getMyCarrier&lt;&gt; null and (self.getMyCarrier.code &lt;&gt; _trx.CM_TITransaction.myTrackedItem.carrier)) then
		if callLoggingMethod then																		
				self.logReasonForExclusion (_trx, 'Transaction carrier  does not match query carrier ');	
		endif;																							
			return false;
	endif;
	
	//Start 25/05/2022 navhl20 TFS 53430  
	if ( self.getMySubCarrier&lt;&gt; null and (self.getMySubCarrier.code &lt;&gt; _trx.CM_TITransaction.getVehicleVisitSubCarrierCode)) then
		if callLoggingMethod then																		
				self.logReasonForExclusion (_trx, 'Transaction subCarrier  does not match query subCarrier ');	
		endif;																							
			return false;
	endif;
	//end 25/05/2022 navhl20 TFS 53430 

	 // ### TFS BUG 56660 23FEB2023 NAVAB1
	shipLine := self.getMyShippingLine();
	if shipLine &lt;&gt; null then
		tranShipLine := _trx.CM_TITransaction.shippingLineCode;
		qryShipLine := shipLine.code;
//		write method.qualifiedName &amp; " tranShipLine: " &amp; tranShipLine &amp; " qryShipLine: " &amp; qryShipLine;
		if tranShipLine &lt;&gt; qryShipLine then
			if callLoggingMethod then																		
					self.logReasonForExclusion (_trx, 'Transaction shipping Line does not match query shipping line ');	
			endif;																							
			
			return false;
		endif;
	endif;
	
	//cnwma1 29/04/2015  PAR #36129
	
	//03 Aug 2010	NDL Par 23056
	if _trx.CM_TITransaction.isChild and not self.includeChildTransactions then
		if callLoggingMethod then																		// par 29601 July 2012
			self.logReasonForExclusion (_trx, 'Transaction is child transaction and query does not include child transactions');	// par 29601 July 2012
		endif;																							// par 29601 July 2012
		return false;
	endif;
	
	// ## this doesn't check the ignoreDeleted ? ### JMH
	// ## this doesn't check userCanAccessSelf?
		
	trackedItem :=  _trx.CM_TITransaction.myTrackedItem;
	
	// This handles queries where they only want if it does not have a booking, or it does have a booking 
	if self.onlyBookingRefWith &lt;&gt; Only_State_All then					// Only_State_All = 0
		if self.onlyBookingRefWith = OnlyState_NullValue then			// OnlyState_NullValue = 1
			if trackedItem.bookingReference &lt;&gt; null then
				if callLoggingMethod then																		// par 29601 July 2012
					self.logReasonForExclusion (_trx, 'Cargo has booking but query only includes cargo without booking');	// par 29601 July 2012
				endif;																							// par 29601 July 2012
				return false;
			endif;
			
		elseif self.onlyBookingRefWith = OnlyState_WithValue then		// OnlyState_WithValue = 2
			if trackedItem.bookingReference = null then
				if callLoggingMethod then																		// par 29601 July 2012
					self.logReasonForExclusion (_trx, 'Cargo has no booking but query only includes cargo with booking');	// par 29601 July 2012
				endif;																							// par 29601 July 2012

				return false;
			endif;
		endif;
	endif;
	// This handles queries where they only want if it does not have a consignee, or it does have a consignee 
	if self.onlyConsigneeWith &lt;&gt; Only_State_All then						// Only_State_All = 0
		if self.onlyConsigneeWith = OnlyState_NullValue then				// OnlyState_NullValue = 1
			if _trx.CM_TITransaction.consignee &lt;&gt; null then
				if callLoggingMethod then																		// par 29601 July 2012
					self.logReasonForExclusion (_trx, 'Cargo has consignee but query only includes cargo without consignee');	// par 29601 July 2012
				endif;																							// par 29601 July 2012
				
				return false;
			endif;
		elseif self.onlyConsigneeWith = OnlyState_WithValue then			// OnlyState_WithValue = 2
			if _trx.CM_TITransaction.consignee = null then
				if callLoggingMethod then																		// par 29601 July 2012
					self.logReasonForExclusion (_trx, 'Cargo has no consignee but query only includes cargo with a consignee');	// par 29601 July 2012
				endif;																							// par 29601 July 2012
				return false;
			endif;
		endif;
	endif;
		
	if allQryImexStatus.size &gt; 0 then
		if  trackedItem = null or 	// if no tracked item then cannot match
			not allQryImexStatus.includes (trackedItem.getImExStatus) then
			if callLoggingMethod then																		// par 29601 July 2012
				self.logReasonForExclusion (_trx, 'Cargo imex status (' &amp; trackedItem.getImexStatusStrDesc &amp; ') does not match query imex status');	// par 29601 July 2012
			endif;																							// par 29601 July 2012
			return false;
		endif;
	endif;
	
	if  trackedItem 	&lt;&gt; null then
		cargoType 		:= trackedItem.cargoType;	// treat a null tracked item as a null cargo type
		strCargoType 	:= trackedItem.cargoTypeDescr;	// par 29601 July 2012
	endif;

	if  allQryCargoTypesIncluded.size &gt; 0 and 
		not allQryCargoTypesIncluded.includes(cargoType) then
		if callLoggingMethod then																		// par 29601 July 2012
			self.logReasonForExclusion (_trx, 'Cargo type (' &amp; strCargoType &amp; ') does not  match query cargo types');	// par 29601 July 2012
		endif;																							// par 29601 July 2012
		return false;
	endif;
	
	if  allQryCargoTypesExcluded.size &gt; 0 and 
		allQryCargoTypesExcluded.includes(cargoType) then
		if callLoggingMethod then																		// par 29601 July 2012
			self.logReasonForExclusion (_trx, 'Cargo type (' &amp; strCargoType &amp; ') is excluded from the query');	// par 29601 July 2012
		endif;																							// par 29601 July 2012
		return false;
	endif;

	if  allQryContentStatus.size &gt; 0 and not allQryContentStatus.includes ( _trx.CM_TITransaction.contentsStatus) then
		if callLoggingMethod then																		// par 29601 July 2012
			self.logReasonForExclusion (_trx, 'Cargo contents status (' &amp; _trx.CM_TITransaction.getContentsStatusDesc (false) &amp; ') does not match query contents status');	// par 29601 July 2012
		endif;																							// par 29601 July 2012
		return false;			
	endif;
	
	querySelf.numFound := querySelf.numFound + 1;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
