    <JadeMethod name="create" id="469c2235-603b-46d4-a981-7cd2a7361be6">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.permissionView  := PmAdmInvCashDrTrx;
	self.permissionMaint := PmAdmInvCashDrTrxMaint; // TFS 2198
	self.helpFileName := HelpFile_CashModule;

