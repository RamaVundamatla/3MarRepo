    <JadeMethod name="create" id="d000a4b4-7a8c-4a64-a256-db12afbb75b1">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
