    <JadeMethod name="cnwdad1_Test_GetPrinters" id="c3abeb53-36a0-4baa-bc18-2123c7da2ad1">
        <source>cnwdad1_Test_GetPrinters();
// --------------------------------------------------------------------------------
// Created:		12 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allPrinters	: StringArray;
	printerName	: String;
	
begin
	create allPrinters transient;
	
	write "Local printers:" &amp; CrLf &amp; "--------------";
	
	app.printer.getAllPrinters(allPrinters);
	
	if allPrinters.isEmpty() then
		write "There are no local printers attached.";
	else
		foreach printerName in allPrinters do
			write printerName;
		endforeach;
	endif;
	
	write CrLf &amp; "Server printers:" &amp; CrLf &amp; "---------------";
	allPrinters.clear();
	
	global.cnEcGetAllServerPrinters(allPrinters);
	
	if allPrinters.isEmpty() then
		write "There are no known server printers attached.";
	else
		foreach printerName in allPrinters do
			write printerName;
		endforeach;
	endif;
	
	write CrLf &amp; "Local &amp; Server printers:" &amp; CrLf &amp; "-----------------------";
	allPrinters.clear();
	
	global.cnEcGetAllPrinters(allPrinters);
	
	if allPrinters.isEmpty() then
		write "There are no local or server printers attached.";
	else
		foreach printerName in allPrinters do
			write printerName;
		endforeach;
	endif;
epilog
	delete allPrinters;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_GetURLParts" id="0831749e-08e4-415a-b9be-f1e473a2a52d">
