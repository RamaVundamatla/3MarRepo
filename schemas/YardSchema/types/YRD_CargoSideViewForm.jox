    <JadeMethod name="translateForm" id="7867d112-c6e0-4c6a-b424-3f7899bdc186">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017023, locale);
	btnFlipH.translateBubbleHelp(Xlat_0017024, locale);
	btnFlipH.translateCaption(Xlat_0017025, locale);
	btnFlipV.translateBubbleHelp(Xlat_0017026, locale);
	btnFlipV.translateCaption(Xlat_0017027, locale);
	btnRefresh.translateBubbleHelp(Xlat_0017028, locale);
	btnRefresh.translateCaption(Xlat_0017029, locale);
	frmInfo.translateCaption(Xlat_0017030, locale);
	optViewEnd.translateCaption(Xlat_0017031, locale);
	optViewFace.translateCaption(Xlat_0017032, locale);
end;</source>
    </JadeMethod>
</GUIClass>
