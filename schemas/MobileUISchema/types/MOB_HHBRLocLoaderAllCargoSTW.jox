    <JadeMethod name="checkFullyLoaded" id="6f6b9bc4-8f4e-47f4-8381-bbea25b84514">
        <updating/>
        <source>checkFullyLoaded():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2018	jlgndl1	Initial creation	TFS 38083
19 Dec 2018	NDL	TFS 38083
*/

vars

	roadJob : CM_RoadJob;
	wle : CM_WorkListEntry;
	incompleteWleSet : CM_WLESet;
	msg : String;

begin

	if self.isVehicle then
		roadJob := self.myTruck.allRoadJobs.first.CM_RoadJob;
	elseif self.isTrailer then
		roadJob := self.myTrailer.jobRoadRelease;
	else
		return true;
	endif;
	
	create incompleteWleSet transient;
	foreach wle in roadJob.workListEntries do
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		if wle.isReceipt then
			continue;
		endif;
		if wle.myTrackedItem &lt;&gt; null then
			continue;
		endif;
		incompleteWleSet.add( wle );
	endforeach;
	
	if incompleteWleSet.isEmpty then
		msg := app.getErrorString(Jobs_this_truck_compl_want_com);
		if self.msgBox( msg,  app.getErrorString(Complete) &amp; "?", MsgBox_Yes_No, false ) = MsgBox_Return_Yes then
			self.handleBtnOne;
			return false;
		endif;
	endif;

	return true;

epilog

	delete incompleteWleSet;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clickInYardItem" id="5480577d-8d41-4603-9b2b-1824e3562428">
        <updating/>
        <source>clickInYardItem(obj: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	selectedWle : CM_WorkListEntry;
	checksSubCargo : CM_TrackedItem;
	wleToProcess : CM_WorkListEntry;
	reserveDetail : CM_ReserveDetail;
	mess : String;
	truck : CM_Vehicle;
	wleSet : CM_WLEArray;
	moveController : CMIF_MoveController;
	result : Integer;
	checksToBeDone : String;
	exactRailTarget : CM_LocationsController;
	contextObject : CM_Object;

begin

	if CM_TrackedItem.hasInstance( obj ) then
		ti := obj.CM_TrackedItem;
	endif;
	
	if ti &lt;&gt; null then
	
		//Par 32337 - Attempt to pre-set the quantity based on a Wle that we might have....
		self.myMobileGenericAgent.setStringField1( null );
		self.myMobileGenericAgent.setDecimalField1(0.00);
		
		if ti.canSplitTotalQuantity then
		
			selectedWle := getWleForYardItem( ti );	//19 Jan 2017	NDL	TFS 3198/2877
			
			if selectedWle &lt;&gt; null then
				if selectedWle.quantity &gt; 0 then
					self.myMobileGenericAgent.setStringField1( selectedWle.quantity.String );
				endif;
				if selectedWle.weight &gt; 0 then
					self.myMobileGenericAgent.setDecimalField1(  selectedWle.weight );
				endif;
			endif;
			
		else	//16 Oct 2015	NDL	Par 37033
			
			
			if self.myMobileGenericAgent.myReserveSelection &lt;&gt; null then	//22 Mar 2018	NDL	TFS 37759
				reserveDetail := self.myMobileGenericAgent.myReserveSelection;
			else
				//27 Oct 2015	NDL	Par 37086
				//reserveDetail := self.myHandHeldCheckerAgent.getReserveDetailCargoMatches( ti, ti.totalQuantity, mess );
				reserveDetail := self.myMobileGenericAgent.getReserveDetailCargoMatches( ti, ti.totalQuantity.max(1), ti.totalWeight, mess );	//10 Nov 2015	NDL	Par 37092
			endif;
			
			if reserveDetail = null then
				self.msgBox(app.getErrorString(Cargo_item_release_issue) &amp; mess, app.getErrorString(Error), MsgBox_OK_Only, false);
				return;
			endif;
			
			// 30 Nov 2015	NDL	Par 37153
			wleToProcess :=  self.getWleFromLocation( ti, reserveDetail );
			if wleToProcess = null then
				//19 Jan 2017	NDL	TFS 3198/2877
				foreach wle in ti.allWorklistEntries do
					if wle.status = WLE_COMPLETED then
						continue;
					endif;
					wleToProcess := wle;
					break;
				endforeach;
			
			endif;
			
			if not self.validateLoad( ti, reserveDetail ) then
				return;
			endif;
			
			//if wleToProcess &lt;&gt; null and wleToProcess.myTrackedItem = null then	// 30 Nov 2015	NDL	Par 37153
			if wleToProcess &lt;&gt; null
			and ( wleToProcess.myTrackedItem = null or wleToProcess.myTrackedItem.isRRP ) then	//26 Jan 2017	NDL	TFS 3198/2877
				//25 Jan 2017	NDL	TFS 3198/2877
				if self.isWagon then
					exactRailTarget := wleToProcess.getTargetLocation;
					if exactRailTarget = null and wleToProcess.isYardReleaseAssigned then
						exactRailTarget := wleToProcess.CM_YardWLE.allLocationControllers.first;
					endif;
					if exactRailTarget &lt;&gt; null
					and exactRailTarget.isWagon
					and exactRailTarget.CM_WagonController.myWagon = self.myWagon then
						// all good we will use it
						self.setMyTargetLocation( exactRailTarget );
					endif;
				endif;
	
				// wle from a delivery request that was for Items by type. ( I.e. no associated cargo items yet.)
				create moveController transient;
				moveController.setMyWorkListEntry(wleToProcess);
				moveController.setMyToPrimaryLocation(self.myTargetLocation);
				moveController.setMyTrackedItem(ti);
				moveController.setQuantity( 1 );
				moveController.setWeight( 0 );
				
				//17 Mar 2017	NDL	TFS 3667
				if reserveDetail &lt;&gt; null 
				and reserveDetail.myReserveDetailActions &lt;&gt; null then // TFS 3283 Setting
					// TFS 3283 Direct delivery only add TI if we have not processed before i.e. staged.
					// TFS 3283 Setting this ultimately calls code to create or update (accumulate) the doc actions.
					if not reserveDetail.myReserveDetailActions.includesTi(ti) then
						moveController.setMyDocumentActions( reserveDetail.myReserveDetailActions );
					endif;
				endif;
				
				while true do
					app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
					if not app.myPassport.trxCompletedOK then
						result := app.showErrorWarningDialog(app.getErrorString( Assign_release ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
						if app.myPassport.noErrors and
						   result = IDOK then
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
					endif;
					break;
				endwhile;
				if result = IDOK then
					self.setupCargo();
					self.doResizeControls(false);	//08 Jul 2016	NDL	TFS 2275 / 2216
					self.showWeights();
					self.txtCargoId.text := null;
					self.convertedAltId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216
					self.convertedCargoId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216
					self.txtCargoId.setFocus();
				endif;
			
			else
				//26 Jan 2017	NDL	TFS 3198/2877
				if self.isWagon then
					if wleToProcess &lt;&gt; null then
						exactRailTarget := wleToProcess.getTargetLocation;
						if exactRailTarget = null and wleToProcess.isYardReleaseAssigned then
							exactRailTarget := wleToProcess.CM_YardWLE.allLocationControllers.first;
						endif;
					elseif self.myWagon.allLocationsControllersArray.size &gt; 1 then
						//find first available space on this wagon
						exactRailTarget := self.myWagon.getNextFreeWagonController( ti, REAL_MODE, null, null, true );
					endif;
					if exactRailTarget &lt;&gt; null
					and exactRailTarget.isWagon
					and exactRailTarget.CM_WagonController.myWagon = self.myWagon then
						// all good we will use it
						self.setMyTargetLocation( exactRailTarget );
					endif;
				endif;
				
				//17 Mar 2017	NDL	TFS 3667
				if reserveDetail &lt;&gt; null and reserveDetail.myReserveDetailActions &lt;&gt; null  then
					contextObject :=  reserveDetail.myReserveDetailActions;
				endif;
				
				if self.myMobileGenericAgent.moveTI( ti, null, self.myTargetLocation, wleToProcess, false, 1, 0, contextObject ) then
					self.setupCargo();
					self.doResizeControls(false);	//08 Jul 2016	NDL	TFS 2275 / 2216
					self.showWeights();
					
					//18 Nov 2015	NDL	Par 37152
					self.txtCargoId.text := null;
					self.convertedAltId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216
					self.convertedCargoId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216
					self.txtCargoId.setFocus();
			
				endif;
				
			endif;
			
			return;
			
		endif;
		
		self.myMobileGenericAgent.setMyNextTiToAction(ti);
		self.myMobileGenericAgent.setMyDeliveryRequest(null);
		self.myMobileGenericAgent.setMyLocationsController( self.myTargetLocation );
		self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
		if self.isWagon then
			self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.RailRelease);		//19 Jan 2017	NDL	TFS 3198/2877
		else
			self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckLoad);//28 May 2010	NDL	Par 23698
		endif;
		self.gotoForm( MOB_HHBRLocLoaderCargo, false );
		return;

	endif;

epilog

	//19 Dec 2018	NDL	TFS 38083
	if self.btnThree.caption = app.getErrorString(Refresh) then
		//to indicate a refresh is potentially needed.
		self.btnThree.foreColor := Red;
	endif;

	delete wleSet;
	delete moveController;

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="clickOnTargetLocItem" id="e517909c-30a9-461f-aae2-b9831a4155fd">
        <updating/>
        <source>clickOnTargetLocItem(obj: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	ti : CM_TrackedItem;
	
begin

	if CM_TrackedItem.hasInstance( obj ) then
		ti := obj.CM_TrackedItem;
	endif;
	
	//returning to source
	self.myMobileGenericAgent.setMyNextTiToAction(ti);
	self.myMobileGenericAgent.setMyLocationsController( self.myTargetLocation );
	self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
	if self.isWagon then
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.RailReceipt);		//19 Jan 2017	NDL	TFS 3198/2877
	else
		self.myMobileGenericAgent.setChecksState( self.myMobileGenericAgent.TruckUnload );
	endif;
	
	self.gotoForm( MOB_HHBRLocLoaderCargo, false );

epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="clickOnTruckItem" id="4148e441-c30b-4611-b452-8765a8c545e7">
        <updating/>
        <source>clickOnTruckItem(obj: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2014	cnwndl1	Initial creation`	Par 34717 / CCMS 2384

*/

vars

begin

	self.clickOnTargetLocItem( obj );

epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doFindCargoButton" id="5925d045-dbc8-4dfd-9bdb-921cfa6ed026">
        <updating/>
        <source>doFindCargoButton()updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/08/2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384
11/03/2016	cnwdap1	PAR #37488 Allow find on alternative id as well as id
*/

vars

	altIdStr : String;	//08 Jul 2016	NDL	TFS 2275 / 2216
	cargoIdStr : String;	//08 Jul 2016	NDL	TFS 2275 / 2216
	ti : CM_TrackedItem;
	theTI : CM_TrackedItem;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	value : Real;
	index : Integer;
	obj : Object;

begin

	cargoIdStr := self.convertedCargoId;	//08 Jul 2016	NDL	TFS 2275 / 2216
	if cargoIdStr = null then
		return;
	endif;
	
	if cargoIdStr = self.lblCargoId.caption.trimBlanks.toUpper then
		return;
	endif;
	
	altIdStr := self.convertedAltId;	//08 Jul 2016	NDL	TFS 2275 / 2216
	
	if self.inYardButtonCount &gt; 0 then	//05 Jan 2016	NDL	Par 37349
		foreach buttonNumber in 1 to self.inYardButtonCount do
			menuButton := self.btnInYardTemp.getControl(buttonNumber);
			if menuButton = null then	//05 Jan 2016	NDL	Par 37349
				continue;
			endif;
			obj := menuButton.userObject;
			if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
				ti := obj.CM_TrackedItem;
				//if ti.id = str then								// PAR #37488
				if ti.id = cargoIdStr or ti.alternativeId = altIdStr then		// PAR #37488
					theTI := ti;
					break;
				endif;
			endif;
			if menuButton &lt;&gt; null then
				value := value + menuButton.height;
			endif;
		endforeach;
	endif;
	
	if theTI &lt;&gt; null then
		self.scrCargoInYard.value := value.Integer;
		menuButton := self.btnInYardTemp.getControl(buttonNumber);
		self.setMenuScrollStart( self.scrCargoInYard, self.btnInYardTemp, self.frmCargoInYard, inYardButtonCount );
		menuButton.setFocus();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadAll" id="91b75e95-055f-4709-b558-0ce8aec41203">
        <updating/>
        <source>doLoadAll() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2014	cnwndl1	Initial creation	Par 35146

*/

vars

	buttonNumber : Integer;
	menuButton : MOB_Button;
	ti : CM_TrackedItem;
	quantity : Integer;
	weight : Decimal [16,4];
	wle : CM_WorkListEntry;
	wleToProcess : CM_WorkListEntry;
	mess : String;
	reserveDetail : CM_ReserveDetail;
	tiToAdd : CM_TrackedItem;
	hideMoveConfirmation : Boolean;
	skipVerifyQuestion : Boolean;
	
	moveController : CMIF_MoveController;
	result : Integer;
	
	wagon : CM_Wagon;
	exactRailTarget : CM_LocationsController;

begin
	
	if self.inYardButtonCount &lt; 1 then
		return;
	endif;
	
	//Check the user really wants to do the move...
	hideMoveConfirmation := app.myPassport.myTerminal.getConfig(HhMoveConfirmation).Boolean;
	if not hideMoveConfirmation then
		mess := app.getErrorString1( Move_All_cargo, self.myTargetLocation.getFullId );
		if app.msgBox(mess, app.getErrorString(ConfirmMove), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
	endif;
	skipVerifyQuestion := true;  // we only want to ask once.

	foreach buttonNumber in 1 to self.inYardButtonCount reversed do
		menuButton:= null;
		ti := null;
		menuButton := self.btnInYardTemp.getControl( buttonNumber ).MOB_Button;
		if menuButton = null then
			continue;
		endif;
		if menuButton.userObject = null or not menuButton.userObject.isKindOf(CM_TrackedItem) then
			continue;
		endif;
		ti := menuButton.userObject.CM_TrackedItem;
		if ti = null or ( self.mySourceLocation &lt;&gt; null and ti.myPrimaryActualLocation &lt;&gt; self.mySourceLocation ) then	//27 Oct 2015	NDL	Par 37086
			continue;
		endif;
		
		quantity := ti.totalQuantity;
		weight := ti.totalWeight;
		
		reserveDetail := self.myMobileGenericAgent.getReserveDetailCargoMatches( ti, quantity, weight, mess );//10 Nov 2015	NDL	Par 37092
		if reserveDetail = null then
			self.msgBox(app.getErrorString(Cargo_item_release_issue) &amp; mess, app.getErrorString(Error), MsgBox_OK_Only, false);
			return;
		endif;
		
		//09 Dec 2015	NDL	TFS85-10
		if not self.validateLoad( ti, reserveDetail ) then
			return;
		endif;
		
		//moved down 12 Feb 2016	NDL	Par 37534
		wleToProcess :=  self.getWleFromLocation(ti,reserveDetail);	//05 Jan 2015	NDL	Par 37350
		if wleToProcess = null then
		
			foreach wle in ti.allWorklistEntries do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				wleToProcess := wle;
				break;
			endforeach;
		
		endif;
		
		if wleToProcess &lt;&gt; null and wleToProcess.myTrackedItem = null then
			//05 Jan 2015	NDL	Par 37350
	
			//25 Jan 2017	NDL	TFS 3198/2877
			if self.isWagon then
				exactRailTarget := wleToProcess.getTargetLocation;
				if exactRailTarget &lt;&gt; null
				and exactRailTarget.isWagon
				and exactRailTarget.CM_WagonController.myWagon = self.myTargetLocation.CM_WagonController.myWagon then
					// all good we will use it
					self.setMyTargetLocation( exactRailTarget );
				endif;
			endif;
				
			// wle from a delivery request that was for Items by type. ( I.e. no associated cargo items yet.)
			create moveController transient;
			moveController.setMyWorkListEntry(wleToProcess);
			moveController.setMyToPrimaryLocation(self.myTargetLocation);
			moveController.setMyTrackedItem(ti);
			moveController.setQuantity(quantity);  // PAR 35781
			moveController.setWeight(weight);	//26 Nov 2015	NDL	Par 37092
			
			//23 Sep 2016	NDL	TFS 2648 / 2001
			if reserveDetail &lt;&gt; null 
			and reserveDetail.myReserveDetailActions &lt;&gt; null then // TFS 3283 
				// TFS 3283 Direct delivery only add TI if we have not processed before i.e. staged.
				// TFS 3283 Setting this ultimately calls code to create or update (accumulate) the doc actions.
				if not reserveDetail.myReserveDetailActions.includesTi(ti) then
					moveController.setMyDocumentActions( reserveDetail.myReserveDetailActions );
				endif;
			endif;
			
			while true do
				app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
				if not app.myPassport.trxCompletedOK then
					result := app.showErrorWarningDialog(app.getErrorString( Assign_release ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				break;
			endwhile;
			if result &lt;&gt; IDOK then
				return;
			endif;
		
		elseif not self.myMobileGenericAgent.moveTI( ti, null, self.myTargetLocation, wleToProcess, skipVerifyQuestion, quantity, weight, null ) then
			return;
		endif;
		
		//25 Jan 2017	NDL	TFS 3198/2877
		if self.isWagon then
			tiToAdd := wagon.findTi( ti.id );
		else
			tiToAdd := self.myTargetLocation.allTrackedItemsById.getAtKey( ti.id, ti.cargoType ); // Might have been split off.. 
		endif;
		app.myTrxUA.trxAddToReserveDetail( reserveDetail, tiToAdd, app.myPassport );
		if app.myPassport.hasErrors then
			mess := app.myPassport.getErrorsAndWarningsAsString();
			self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false);
			return;
		endif;
		
		
	endforeach;
	
	//27 Oct 2015	NDL	Par 37086
	//self.handleBtnOne(); - make 'em do this bit manually. Cos it closes any outstanding director tasks
	
//	complete := true;

epilog

//	if not complete then
		self.setupForm();
//	endif;

	delete moveController;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="40b831b2-a649-476a-af09-7b2194b6248a">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	top : Real;
	height : Real;
	singleWidth : Real;
	left : Real;
	buttonWidth : Real;
	index : Integer;
	menuButton : MOB_Button;
	inLocationCount : Integer;
	buttonHeight : Integer;
	buttonTop : Integer;
	inYardCount : Integer;
	weightLoaded : Decimal[16,4];

begin

	self.setResizeableMarginAndFontSize();
	inheritMethod(_initialSetup);
	
	if _initialSetup then
		self.lstRelItems.visible := true;
		self.lstRelItems.enabled := true;
	endif;
	self.lstRelItems.move( self.resizedMargin,
							 self.fldCargo.top,
							 self.fldCargo.width,
							 self.fldCargo.height - self.resizedMargin ); 
							 
							 
	
	top := self.fldCargo.top + self.fldCargo.height + self.resizedMargin;
	height := self.getStdControlHeight;
	singleWidth := (( self.clientWidth - ( self.resizedMargin * 2) ) / 3 ).Integer;
	left := self.resizedMargin;
	
	self.txtCargoId.move(	1,
							1,
							self.shtInYard.width - self.resizedMargin,
							height
							);

	self.lblWeightValue.visible := true;
	self.lblWeightValue.move(	left,
								top,
								singleWidth * 2,
								height );
								
	left := left + lblWeightValue.width + self.resizedMargin;
	self.lblCountValue.visible := true;
	self.lblCountValue.move(	left,
								top,
								singleWidth,
								height );
								
	
	//inLocationCount := self.myTargetLocation.allTrackedItems.size;
	inLocationCount := self.getQuantityLoaded( weightLoaded );	//26 Jan 2017	NDL	TFS 3198/2877
	self.btnDocActsLoaded.visible := false;
	
	if inLocationCount &gt; 0 then
		//23 Sep 2016	NDL	TFS 2648 / 2001
		if not self.docActsToDispLoaded.isEmpty then
			height := self.btnOne.height;
			self.frmCargoOnTruck.height := self.frmCargoOnTruck.height - self.resizedMargin - height;
			top := self.frmCargoOnTruck.height + self.resizedMargin;
			left := self.resizedMargin;
			self.btnDocActsLoaded.parent := self.shtOnTruck;
			self.btnDocActsLoaded.visible := true;
			self.btnDocActsLoaded.move(	left,
										top,
										self.btnOne.width,
										height );
		endif;
								
		buttonHeight := self.getScrollingButtonHeight();
		self.btnOnTruckTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar(inLocationCount,self.frmCargoOnTruck, self.btnOnTruckTemp.height, self.scrCargoOnTruck);
	
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to inLocationCount do
			menuButton := self.btnOnTruckTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
		
	endif;
	
	//30 Nov 2016	NDL	TFS 2967
	inYardCount := self.inYardButtonCount;
	self.btnDocActsToLoad.visible := false;
	
	if inYardCount &gt; 0 then
		if not self.docActsToDispToLoad.isEmpty then
			height := self.btnOne.height;
			self.frmCargoInYard.height := self.frmCargoInYard.height - self.resizedMargin - height;
			top := self.frmCargoInYard.top + self.frmCargoInYard.height + self.resizedMargin;
			left := self.resizedMargin;
			self.btnDocActsToLoad.parent := self.shtInYard;
			self.btnDocActsToLoad.visible := true;
			self.btnDocActsToLoad.move(	left,
										top,
										self.btnOne.width,
										height );
		endif;
								
		buttonHeight := self.getScrollingButtonHeight();
		self.btnInYardTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar(inYardCount,self.frmCargoInYard, self.btnInYardTemp.height, self.scrCargoInYard);
	
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to inYardCount do
			menuButton := self.btnInYardTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
		
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
