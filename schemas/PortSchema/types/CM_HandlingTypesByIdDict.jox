<CollClass name="CM_HandlingTypesByIdDict" id="06d75436-574c-4cb5-a396-0c14e2ad8347">
    <memberType name="CM_HandlingType"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmwarehouse"/>
    <MemberKey>
        <property name="CM_HandlingType::id"/>
    </MemberKey>
    <JadeMethod name="getIdFor" id="d790356f-9164-46fb-93f8-7270c9666b6f">
        <source>getIdFor( _desc : String ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36564

*/

vars

	iter : Iterator;
	handlingType : CM_HandlingType;

begin

	iter := self.createIterator;
	while iter.next( handlingType ) do
		if handlingType.description.toUpper = _desc then
			return handlingType.id;
		endif;
	endwhile;
	
	return null;

epilog

delete iter;

end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
