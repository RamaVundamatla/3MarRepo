    <JadeMethod name="btnPrintRec_click" id="487f3f57-ce38-4ede-a56b-102bdb44b8d3">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrintRec_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	usePreview	: Boolean;
	row : Integer;
	cash : CM_Cash;

begin

	row := self.tblCash.row;
	if row &lt;= self.tblCash.fixedRows then
		return;
	endif;
	if row &gt; self.tblCash.rows then
		return;
	endif;

	cash :=  self.tblCash.accessRow(row).itemObject.CM_Cash;
	if cash = null then
		return;
	endif;
	
	usePreview := app.isDevelopmentSystem() or app.isSpecial();		// from 31154 - users want to print direct, preview is useful for us in testing
	if CM_CashPayment.hasInstance(cash) then

		cash.CM_CashPayment.printReceipt(1, usePreview, null, null);
		
	elseif CM_CashReceipt.hasInstance(cash) then

		self.myAssistant.INV_Assistant.printCashReceipt(cash.CM_CashReceipt, 1, true, null, null, "COPY CASH RECEIPT",false);	// 32851 Cash III print from the cash receipt object
	
	elseif cash.isKindOf(CM_CashCredit) then		// 37141
		
		self.myAssistant.INV_Assistant.printCashCredit(cash.CM_CashCredit, 1, true, null, null, "");
		
	endif;

epilog
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnPrintTbl_click" id="0c36eb6e-cc8f-4948-9ba1-8726a19fc5ef">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrintTbl_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if self.tblCash.rows &lt;= self.tblCash.fixedRows then
		app.raiseCMException(ERR_NoDataToExtract, 'Table Data', self.tblCash);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	on Exception do self.handlePrintTableRowException(exception);
	
	self.doPrintOutTable(self.tblCash, self.caption, true,true, true, false);		// 33404 print landscape

epilog

	app.mousePointer := MousePointer_Default;
	
end;</source>
