<Class name="CM_JRWLocationActivity" id="c887d0f1-7689-44c0-87ec-3c3b9d7d4764">
    <superclass name="CM_JRWTransient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allInventoryLines" id="b9b19e93-1377-48ca-8afd-8566f56adb72">
        <memberTypeInverse/>
        <type name="CMIF_LocActRepInventoryDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allThroughPutLines" id="ddd23b3b-6b0d-4849-80a7-44a0362bf403">
        <memberTypeInverse/>
        <type name="CMIF_LocActRepThroughPutDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allThroughPutSummaryLines" id="60794702-deb3-420c-a205-25028c00c429">
        <memberTypeInverse/>
        <type name="CMIF_LocActRepThruPutSumDict"/>
    </ImplicitInverseRef>
    <PrimAttribute name="fromDate" id="7ce0fb96-b759-4cbc-82af-48ba218a5aa3">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myLocationsController" id="74477f3b-0b2b-474f-ad24-ecf0f3b86ea0">
        <embedded/>
        <type name="CM_LocationsController"/>
    </ImplicitInverseRef>
    <PrimAttribute name="reportingMonthYear" id="cfd7e486-cc56-42c2-aea1-adb12376d639">
        <embedded/>
