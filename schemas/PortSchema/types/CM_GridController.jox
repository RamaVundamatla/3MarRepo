        <updating/>
        <source>setForProxy(pAvail : Integer; pUsage : Integer; pGridRow : Integer; pGridColumn : Integer; pName : String; pWidth : Real; pPower : Boolean; pPowerDamaged : Boolean; pRemarks : String; pGridArea : CM_GridArea; 
				_is45Ft : Boolean; _offset45 : Integer; _is30Ft : Boolean; _offset30 : Integer; _is53Ft : Boolean; _offset53 : Integer) updating;

vars

	gridRow : CM_GridRow;
	gridCol : CM_GridColumn;

begin

	gridRow	:= pGridArea.allGridRows[pGridRow];
	gridCol	:= pGridArea.allGridColumns[pGridColumn];

	self.setForProxyGridController(pName, gridCol, gridRow, pWidth);
	self.setForProxyYardController(pPower, pPowerDamaged, pRemarks);
	self.myTerminalArea := pGridArea;

end;</source>
