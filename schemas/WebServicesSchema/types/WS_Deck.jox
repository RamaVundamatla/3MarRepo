    <JadeMethod name="delete" id="19eab579-0e3e-4d4a-96c1-4c01d1b2f585">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.allStructureSlots.purge;
	self.allLoadSlots.purge;
	self.allDischargeSlots.purge;
	self.allRemainOnBoardSlots.purge;
epilog

end;</source>
