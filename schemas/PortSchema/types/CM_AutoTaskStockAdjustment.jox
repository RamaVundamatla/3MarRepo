    <JadeMethod name="getValueForRow" id="c35f1e21-c984-4d3c-ab53-80a1800062eb">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;

// Created by cnwdvb1 on 24 October 2006

vars

begin
	
	if _rowName = ETRow_BgpAutoDensity then 
		return self.myProduct.myDensityDec.multiplyValue(self.density).String;	// ### TFS 52193 22Nov2021 NAVPW1
	elseif _rowName = ETRow_BgpAutoHeight then 
		return self.myProduct.getMyHeightDisplayValue(self.height).String;      //myHeight.multiplyValue(self.height).String; //30.1.09 cnwrd1 par #18821 
	elseif _rowName = ETRow_BgpAutoLength then 
		return self.myProduct.getMyLengthDisplayValue(self.length).String;  //myLength.multiplyValue(self.length).String; //30.1.09 cnwrd1 par #18821 
	elseif _rowName = ETRow_BgpAutoQuantity then 
		return self.myProduct.myQuantity.multiplyValue(self.quantity).String; 
	elseif _rowName = ETRow_BgpAutoType then 
		//return self.myProduct.myType.multiplyValue(self.type).String;
		return self.type.String;
	elseif _rowName = ETRow_BgpAutoVolume then 
		return self.myProduct.myVolume.multiplyValue(self.volume).String;
	elseif _rowName = ETRow_BgpAutoWeight then 
		return self.myProduct.getMyWeightDisplayValue(self.weight).String; //myWeight.multiplyValue(self.weight).String; //30.1.09 cnwrd1 par #18821 
	elseif _rowName = ETRow_BgpAutoWidth then 
		return self.myProduct.getMyWidthDisplayValue(self.width).String;  //myWidth.multiplyValue(self.width).String; //30.1.09 cnwrd1 par #18821 
	elseif _rowName = ETRow_BgpAutoLocation then 
		if global.isValidObject(self.myLocationsController) then
			_obj := self.myLocationsController;
			return self.myLocationsController.getID();
		endif;
	elseif _rowName = ETRow_BgpAutoProduct then 
		if global.isValidObject(self.myProduct) then
			_obj := self.myProduct;
			return self.myProduct.code &amp; '  ' &amp;self.myProduct.description;
		endif;
	elseif _rowName = ETRow_BgpAutoCargoType then 
		if global.isValidObject(self.myProduct) then
			_obj := self.myProduct.myCargoType;
			return self.myProduct.myCargoType.description;
		endif;
	else
		return inheritMethod(_rowName, _obj);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="onlyBeOnOneScheduleTest" id="119b6b21-212f-41ae-9087-d476d054ccc1">
        <source>onlyBeOnOneScheduleTest(): Boolean;

// Created by cnwdvb1 on 25 October 2006

vars

begin
	
	if not self.allAutoSchedules.isEmpty() then
		return false;
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f2dd33d7-7703-444d-b63e-11a1faf149bc">
        <source>pxyCreateUpdateProxy(): SelfType;

// Created by cnwdvb1 on 24 October 2006
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	task : SelfType;
	completedOK		: Boolean;
	
begin
	
	task := inheritMethod();
	
	task.myLocationsController	:= self.myLocationsController;
	task.myProduct				:= self.myProduct;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return task;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete task;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="50400efd-903f-4e7e-88be-eaabc3bd0966">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskStockAdjustment) updating;

// Created by cnwdvb1 on 24 October 2006

vars

begin

	inheritMethod(_pxyAutoTask);
	self.requestClassName	:= BGP_StockAdjustmentRequest.name;
		
	self.density				:= _pxyAutoTask.density;
	self.height					:= _pxyAutoTask.height;
	self.length					:= _pxyAutoTask.length;
	self.quantity				:= _pxyAutoTask.quantity;
	self.type					:= _pxyAutoTask.type;
	self.volume					:= _pxyAutoTask.volume;
	self.weight					:= _pxyAutoTask.weight;
	self.width					:= _pxyAutoTask.width;
	self.myLocationsController	:= _pxyAutoTask.myLocationsController;
	self.myProduct				:= _pxyAutoTask.myProduct;
	
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskStockAdjustment"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d7d77d5e-7981-4537-9f55-33303627ae13">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskStockAdjustment) updating;

// Created by cnwdvb1 on 24 October 2006

vars

begin
	inheritMethod(_pxyAutoTask);
	
	self.density				:= _pxyAutoTask.density;
	self.height					:= _pxyAutoTask.height;
	self.length					:= _pxyAutoTask.length;
	self.quantity				:= _pxyAutoTask.quantity;
	self.type					:= _pxyAutoTask.type;
	self.volume					:= _pxyAutoTask.volume;
	self.weight					:= _pxyAutoTask.weight;
	self.width					:= _pxyAutoTask.width;
	self.myLocationsController	:= _pxyAutoTask.myLocationsController;
	self.myProduct				:= _pxyAutoTask.myProduct;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskStockAdjustment"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="3ae3c31d-641a-4995-8c16-5f7e3e4d7d41">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;

// Created by cnwdvb1 on 24 October 2006

vars

begin
	
	if _rowName = ETRow_BgpAutoDensity then 
		self.density	:= self.myProduct.myDensityDec.divideValue(_value.Decimal);		// ### TFS 52193 22Nov2021 NAVPW1
	elseif _rowName = ETRow_BgpAutoHeight then 
		self.height		:= self.myProduct.getHeightValueFromDisplay(_value.Decimal); //myHeight.divideValue(_value.Decimal); //30.1.09 cnwrd1 par #18821 
	elseif _rowName = ETRow_BgpAutoLength then 
		self.length		:= self.myProduct.getLengthValueFromDisplay(_value.Decimal);    //myLength.divideValue(_value.Decimal);  //30.1.09 cnwrd1 par #18821 
	elseif _rowName = ETRow_BgpAutoQuantity then 
		self.quantity	:= self.myProduct.myQuantity.divideValue(_value.Decimal);
	elseif _rowName = ETRow_BgpAutoType then 
		//self.type		:= self.myProduct.myType.divideValue(_value.Decimal).Integer;
		self.type		:= _value.Integer;
	elseif _rowName = ETRow_BgpAutoVolume then 
		self.volume		:= self.myProduct.myVolume.divideValue(_value.Decimal);
	elseif _rowName = ETRow_BgpAutoWeight then 
		self.weight		:= self.myProduct.getWeightValueFromDisplay(_value.Decimal);  //myWeight.divideValue(_value.Decimal);  //30.1.09 cnwrd1 par #18821 
	elseif _rowName = ETRow_BgpAutoWidth then 
		self.width		:= self.myProduct.getWidthValueFromDisplay(_value.Decimal);  //myWidth.divideValue(_value.Decimal);  //30.1.09 cnwrd1 par #18821 
	elseif _rowName = ETRow_BgpAutoLocation then 
		self.myLocationsController := _value.CM_LocationsController;
	elseif _rowName = ETRow_BgpAutoProduct then 
		self.myProduct				:= _value.CM_Product;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="7c45e254-fa49-4701-a524-3fe907297af8">
        <source>validate();

// Created by cnwdvb1 on 25 October 2006
// 15/12/2014  cnwdb2	PAR 35364

vars

begin
	inheritMethod();
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.myProduct = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Product), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Product), null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	// NEEDS TO BE PUT IN WHEN LOCATION CONTROLLER DEVELOPED UP.
	if self.myLocationsController = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Location', null, null);
		app.raiseCMException(Input_required_field_location, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.density = 0 and self.myProduct.isAttributeValidForCargoType(ETRow_MyDensity) then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Density', null, null, self);
		app.raiseCMWarning(Input_required_field_density, null, null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.height = 0 and self.myProduct.isAttributeValidForCargoType(ETRow_MyHeight) then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Height', null, null, self);
		app.raiseCMWarning(Input_required_field_height, null, null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.length = 0 and self.myProduct.isAttributeValidForCargoType(ETRow_MyLength) then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Length', null, null, self);
		app.raiseCMWarning(Input_required_field_length, null, null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.quantity = 0 and self.myProduct.isAttributeValidForCargoType(ETRow_MyQuantity) then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Quantity', null, null, self);
		app.raiseCMWarning(Input_required_field_quantity, null, null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.type = 0 and self.myProduct.isAttributeValidForCargoType(ETRow_MyType) then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Type', null, null, self);
		app.raiseCMWarning(Input_required_field_type, null, null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.volume = null and self.myProduct.isAttributeValidForCargoType(ETRow_MyVolume) then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Volume', null, null, self);
		app.raiseCMWarning(Input_required_field_volume, null, null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.weight = null and self.myProduct.isAttributeValidForCargoType(ETRow_MyWeight) then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Weight', null, null, self);
		app.raiseCMWarning(Input_required_field_weight, null, null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.width = 0 and self.myProduct.isAttributeValidForCargoType(ETRow_MyWidth) then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Width', null, null, self);
		app.raiseCMWarning(Input_required_field_width, null, null, self); // cnwdb2	PAR 35364
	endif;

end;</source>
    </JadeMethod>
</Class>
