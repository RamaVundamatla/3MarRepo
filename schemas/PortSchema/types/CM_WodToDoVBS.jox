    <JadeMethod name="getVBSExternalRef" id="50594ab2-093d-42b6-92e7-bb5826cab374">
        <source>getVBSExternalRef() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	job				: CM_Job;
	roadJob			: CM_RoadJob;
	vvr				: CM_VehicleVisitRecord;
	vbs				: CM_VehicleBookingTimeSlot;
	str,
	retStrVBS		: String;
begin
	
	foreach vbs in self.allVBSSlots discreteLock do
		str := vbs.externalReference;
		
		if str = null then
			continue;
		endif;
		
		/*
		if retStrVBS = null then
			retStrVBS := str;
		else
			if retStrVBS.pos(str, 1) &gt; null then
				continue;
			else
				retStrVBS &amp;= Comma &amp; str;
			endif;
		endif;			
		*/
		
		retStrVBS.addStringToList(str, Comma); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return retStrVBS;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
