    <JadeMethod name="addObjectsToTable" id="2825c1c3-ed83-4d50-8b28-fdfbf556d57d">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
vars
	obj					: Object;
	breakOut			: Boolean;
	numItems			: Integer;	
	
begin
	self.tblData.rows := self.tblData.fixedRows;
			
//	foreach obj in app.getMyTerminal().allYATemplates do
	foreach obj in self.allYATemplates do
		numItems := numItems + 1;
		self.addObjectToTable(obj, numItems, breakOut);
		if breakOut then
			break;
		endif;
	endforeach;
	
epilog
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="e80e1d15-9001-498f-b469-b2105fadae8d">
        <source>addToolbarControls() protected;
