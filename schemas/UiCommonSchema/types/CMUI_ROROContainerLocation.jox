    <JadeMethod name="create" id="004441da-c8d0-40dd-9867-7e915a021cf1">
        <updating/>
        <source>create() updating;
/*
Date		    Who			Reason
03 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	self.permissionMaint:=PmShipBayDefMaint;
	self.permissionView:=PmShipBayDefView;
epilog

end;</source>
