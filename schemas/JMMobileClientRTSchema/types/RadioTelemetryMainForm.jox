    <JadeMethod name="doQueryResort" id="b24b762c-a96b-4f94-b288-6a908392fbb9">
        <source>doQueryResort() protected;
// -------------------------------------------
// Created 14 May 2008 by cnwvu1
// -------------------------------------------

vars

begin

	if self.tblResults.row = 1 then
		
		if self.tblResults.sortColumn[1] &lt;&gt; self.tblResults.column then
			self.tblResults.sortColumn[1]	:= self.tblResults.column;
			self.tblResults.sortType[1]		:= self.aQuerySortTypes[ self.tblResults.column ];
			self.tblResults.sortAsc[1]		:= true;
		else
			self.tblResults.sortAsc[1]		:= not self.tblResults.sortAsc[1];
		endif;
		
		self.tblResults.resort;
		self.queryResultTableColours();
		
	endif;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQueryRun" id="c01c7d39-4e61-4027-99dd-3e4454f0fc6f">
