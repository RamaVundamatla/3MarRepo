        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEditItem_click(btn: Button input) updating;
/*
	Created on 18 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	selBRItem : CMIF_BookingRefItem;
begin
	if self.tblBRItems.allSelectedObjects.size = 0 then
		if self.tblBRItems.rows = 1 then
			self.tblBRItems.accessRow(1);
			selBRItem := self.tblBRItems.accessedRow.itemObject.CMIF_BookingRefItem;
		else
			return;
		endif;
	else
		selBRItem := self.getSelectedBRItem.CMIF_BookingRefItem;
	endif;
	self.doEditBookRefItem(selBRItem);
end;</source>
