    <JadeMethod name="aUtlSample" id="d17c7432-f5d7-48fb-b1e8-e4e8ac2a50b9">
        <source>aUtlSample(_obj : CM_TrxTestObject io; _controller : CM_TrxTestController; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     03 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	// note that validation agent locks object
	app.myValDA.aValSample(_obj, _controller);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _passport.noErrors then
		// only requierd if class is audited
		self.myDeleteAuditAgent.audDeleteGeneric(_obj);
	endif;

	if _passport.noErrors then
		// This should be :
		//_obj.erase(NORMAL_ERASE);
		// but is as below so test exceptions can be generated.
		_obj.doDelete(_controller);
	endif;

end;</source>
        <Parameter name="_obj" type="CM_TrxTestObject" usage="io"/>
        <Parameter name="_controller" type="CM_TrxTestController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="f185831d-cb86-48b5-90a8-7076966e19d9">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// deleted via parent-child relationship
	create self.myDeleteAuditAgent transient;

end;</source>
    </JadeMethod>
    <JadeMethod name="utlAutoGateOut" id="f18cfd04-66db-490d-b1cf-a7a8251eeaac">
        <source>utlAutoGateOut(	_vehicle 		 : CM_Vehicle io;
				_gate 			 : CM_Gate;
				_toBeReleasedTis : CM_TIArray input;
				_vvr 			 : CM_VehicleVisitRecord output;
				_passport 		 : CM_Passport input
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2021	navndl1	Initial creation	TFS 50573 - moved from CM_TrxControlCreateAgent.trxAutoGateOut
09 December  2022   navsp1  ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
*/

vars

	lc       : CM_LocationsController;
	roadJob  : CM_RoadJob;
	ti       : CM_TrackedItem;
	wle      : CM_WorkListEntry;
	exitTime : TimeStamp;

begin

	lc      := _vehicle.locationsController;
	_vvr    := _vehicle.getCurrentVisit;
	roadJob := _vehicle.getCurrentRoadJob;
	
	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;
	
	//move any release cargo onto the truck.
	foreach ti in _toBeReleasedTis do
		wle := roadJob.findOrCreateWleForTiOnRelease( ti );
		if wle = null then
			app.raiseCMException1( Cargo_not_found_ident_relea_re, ti.id, null, null );
			return;
		elseif wle.myTrackedItem = null then
			wle.assignTIandBOL( ti, null );
		endif;
		ti.moveToLocation(lc, roadJob, wle, null, REAL_MODE, false, true, false, false, false,  false, null, null, null, null,_vvr,_passport);	// TFS 2651
		if _passport.hasErrors() then
			return;
		endif;
	endforeach;
	
	//09Dec2022 navsp1 TFS 55580
	//Validation to prevent road exit if pregate OUT check is required and not done.
	if _vvr.gateOutCheckStatus = _vvr.InspectionPending then
		app.raiseCMException2(Vehicle_cannot_road_exit, _vehicle.regNumber, _vvr.InspectionPending, null, _vehicle);
		return;
	
	//28.Mar.2023 navsp1 TFS 57268
	elseif _vvr.gateOutCheckStatus = _vvr.InspectionFailed then
		app.raiseCMException2(Vehicle_cannot_road_exit, _vvr.vehicle.regNumber, _vvr.InspectionFailed, null, _vvr.vehicle);
		return;
	endif;
	
	//20 Nov 2015	NDL	Par 37084
	//remove Unused Release 'By Id WLE' with No associated TI.
	
	if roadJob &lt;&gt; null then                            //21.04.2020 #49078
		wle := roadJob.getUnusedReleaseByAnyIdWle();
	endif;
	
	if wle &lt;&gt; null then
		_passport.setWarningsIgnored( true );
		app.myUtilityDA.utlDeleteJobEntry(wle, app.getErrorString(Auto_gate_unused_entry), _passport);
		_passport.setWarningsIgnored( false );
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	_vehicle.roadExitProcess(_passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//19 Nov 2015	NDL	Par 37084
	if _passport.myTerminal.getConfig(SiteHasSecurityGate).Boolean and _vvr &lt;&gt; null then
		exitTime := _vvr.getRoadExitTime().cnEcAddSeconds(1);
		app.myUtilityUA.utlVVRSecurityGateExit(_vvr, exitTime, _passport);
	endif;

epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="io"/>
        <Parameter name="_gate" type="CM_Gate"/>
        <Parameter name="_toBeReleasedTis" type="CM_TIArray" usage="input"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCleanupSeaManifest" id="f03428cf-843e-46d4-bb4a-7597f0f22ac2">
        <source>utlCleanupSeaManifest(_ediData : CM_EDIDataTransManifest; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2023	jlirs1	Initial creation TFS 59324 (58026) EUP

*/

vars
	workOrder : CM_WorkOrder;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	workOrderDetail : CM_WorkOrderDtl;
//	bolDetail : CM_BOLDtl;
	bol : CM_BOL;
	bolSet : CM_ObjectArray;
	cgTISet : CM_TISet;
	obj : Object;
	cargoGroup : CM_CargoGroup;
	manifestNumber : String;
	errorSet : CM_ErrorSet;
	isInvalid : Boolean;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_passport.warningsAcknowledged := true;

	create cgTISet transient;
	create bolSet transient;
	create errorSet transient;
	_passport.moveErrorsToSet(errorSet);
	_passport.clearErrorsWarnings();
	
	app.setContinueCMExceptions(true);
	terminal := _ediData.getMyTerminal();
	manifestNumber := _ediData.manifestNumber;

	on Exception do app.handleDeletedObject(exception, ti, isInvalid);

	workOrder := terminal.allWorkOrders[manifestNumber];
	if workOrder = null then
		return;
	endif;
	foreach workOrderDetail in workOrder.allWoDtls do
		bol := workOrderDetail.CM_WodReceive.myBillOfLading;
		if bol &lt;&gt; null and
		   not bolSet.includes(bol) then
			bolSet.add(bol);
		endif;
		isInvalid := false;
		foreach ti in workOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs do
			if ti.isKindOf(CM_CargoGroup) and
			   not cgTISet.includes(ti) then
				cgTISet.add(ti);
				continue;
			endif;
			
			if ti.isAssignedToMultipleWO(workOrder) then	//22.Aug.2023 navsp1 TFS 59872
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Unable to delete the TI("&amp;ti.id&amp;") as it is attached to another Work Order.", LogDEBUG);
				continue;
			endif;
			if isInvalid then
				isInvalid := false;
				continue;
			endif;
			app.myUtilityDA.utlDeleteTI(ti, false, _passport);
		endforeach;
	endforeach;
	foreach ti in cgTISet do
		cargoGroup := ti.CM_CargoGroup;
		if cargoGroup.allAssignedTrackedItems.isEmpty then
			app.myUtilityDA.utlDeleteTI(cargoGroup, false, _passport);
		endif;
	endforeach;
	if workOrder &lt;&gt; null then
		app.myUtilityDA.utlDeleteWorkOrder(workOrder, _passport);
	endif;
	foreach obj in bolSet do
		bol := obj.CM_BOL;
		app.myUtilityDA.utlDeleteBOL(bol, _passport);	
	endforeach;

epilog
	_passport.addErrorsFromSet(errorSet);
	delete cgTISet;
	delete bolSet;
	delete errorSet;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataTransManifest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteAS400FileLoad" id="2ab559b4-96a2-4745-9c57-965f68f7fa9a">
