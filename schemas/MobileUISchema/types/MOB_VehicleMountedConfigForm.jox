    <JadeMethod name="btnSave_click" id="c1a4ee6a-c581-44e1-ae3d-9ec026d02932">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation
17 Sep 2010 cnwrs2	PAR 25774 - changes for use updateMode
20 Oct 2011	cnwkpd1	PAR #28510 - Problems logging on in Windows Mobile 6.5 device

*/

vars

begin
	//if self.frmPW.visible then
	if self.updateMode = UpdateMode_Password then
		self.doSavePassword();
		
	//elseif self.frmChgLoc.visible then	
	elseif self.updateMode = UpdateMode_Locale then
		self.doSaveChangeLocale();
		
	//elseif self.frmChgQ.visible then
	elseif self.updateMode = UpdateMode_Queue then
		self.doSaveChangeQueue();
	endif;
	
epilog
//	self.updateMode := UpdateMode_None;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="changeDayNight" id="9809e228-4a3d-435b-8d80-92a9551325ee">
        <updating/>
        <source>changeDayNight() updating,  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars

begin
	if self.btnDay.value then
		app.myVMAgent.setDayScreenMode();
	else
		app.myVMAgent.setNightScreenMode();
	endif;
	
	self.doApplyScreenColors();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkErrors" id="a7957dcb-fdee-4278-8aae-6d397d3b68ff">
        <source>checkErrors(_allErrorMsgs: DTO_HandHeldGateErrorDict) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars

	errorMsg		: DTO_HandHeldGateError;
	errors 			: String;
begin

	if _allErrorMsgs.size &gt; 0 then
		foreach errorMsg in _allErrorMsgs do
				errors:=errorMsg.errorDescr &amp; CrLf;
		endforeach;
		app.msgBox(errors,app.getErrorString(Errors),MsgBox_OK_Only);
		return true;
	endif;	

	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allErrorMsgs" type="DTO_HandHeldGateErrorDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
