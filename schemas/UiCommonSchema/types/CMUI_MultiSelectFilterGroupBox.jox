    <JadeMethod name="doDragComplete" id="896aef5a-9308-4e55-8e40-ad6445e40282">
        <source>doDragComplete(_listBox: ListBox input);
/*

Purpose:			
	Resets the selected collection based on drag events
Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.

*/

vars
	draggedItem		: Object;
	draggedItemPos	: Integer;
	parentCollRight	: ObjectArray;
begin
	draggedItemPos := _listBox.dragListIndex;
	if _listBox &lt;&gt; self.mySelectedListBox or
			draggedItemPos &lt; 1 or
			draggedItemPos &gt; self.mySelectedListBox.listCount() then
		return;
	endif;
	
	parentCollRight := self.parentCollectionRight;
	draggedItem := _listBox.itemObject[draggedItemPos];
	if not parentCollRight.includes(draggedItem) then
		return;
	endif;
	_listBox.clearAllSelected();
	_listBox.itemSelected[draggedItemPos] := true;
	_listBox.listIndex := draggedItemPos;
	parentCollRight.remove(draggedItem);
	parentCollRight.insert(draggedItemPos, draggedItem);
	
	app.clearWriteWindow();
epilog

end;</source>
        <Parameter name="_listBox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveAllToLeft" id="d414a2a4-1217-4b65-8096-2f5a2bc67e29">
        <updating/>
        <source>doMoveAllToLeft() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.

*/

vars

begin
	self.parentCollectionRight.copyNoDups(self.parentCollectionLeft);
	self.parentCollectionRight.clear();
	self.showAvailable(self.parentCollectionLeft);
	self.showSelected(self.parentCollectionRight);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveAllToRight" id="a3c5e9bb-66ea-4825-aa42-a9408a54dd6b">
        <updating/>
        <source>doMoveAllToRight() updating;
/*

Purpose:			

Parameters:			

