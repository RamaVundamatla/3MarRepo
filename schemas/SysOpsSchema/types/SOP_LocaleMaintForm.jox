    <JadeMethod name="create" id="df71d4a4-ec0a-4c4a-b6f6-071621df40ca">
        <updating/>
        <source>create() updating;
//
// Changed On   Changed By  PAR             Reason
// ----------   ----------  --------------  ----------------------------------
//  09/10/2009	cnwmh5		21251 		    Help file Added
// ---------------------------------------------------------------------------
//
vars
	canDo : Boolean;
begin
	self.permissionView  := PmAdmLocaleView;
	self.permissionMaint := PmAdmLocaleMaint;
	
	btnDelete.visible		:= false;
	btnSetDefault.visible	:= false;
	btnEdit.visible			:= false;
	self.mode := Mode_View;
	self.showFieldsForDoNewEdit( false );
	
	canDo := app.getMyUser.canDo(null, PmAdmLocaleMaint);
	plinthLocale.enabled := canDo;
	btnNew.visible := canDo;
	
	self.helpFileName := HelpFile_Admin;				// 09/10/2009 mhill PAR 21251
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doChkUserDefinedClick" id="92f1ae2c-d1d4-4e90-9080-4e6ed79223b7">
        <source>doChkUserDefinedClick() protected;
/* ---------------------------------------------------------------------------
Created:	04 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.cmbLocales.enabled		:= not self.chkUserDefined.value;
	self.txtCode.enabled		:= self.chkUserDefined.value;
	self.txtDescription.enabled	:= self.chkUserDefined.value;
	self.lblCode.enabled		:= self.chkUserDefined.value;
	self.lblDescription.enabled	:= self.chkUserDefined.value;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="e7e70f0b-9bfd-43bb-a8d6-c141d6cd6eaf">
        <updating/>
        <source>doDelete() updating;

vars

begin
	if app.msgBox("Confirm delete locale " &amp; myLocale.vLocaleIdAndDescription, caption, MsgBox_Question_Mark_Icon + MsgBox_OK_Cancel + MsgBox_Default_Second) = MsgBox_Return_Cancel then
		return;
	endif;
	
	app.myTrxDA.trxDeleteLocale(self.myLocale, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.hasErrors);
		return;
	endif;

	self.fillTable();
end;</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="c1389bbe-8583-4e95-b776-58c9e29144c2">
        <updating/>
        <source>doEdit() updating, protected;
/* ---------------------------------------------------------------------------
Created:	04 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	
begin

	//to check - locale can be only user defined
	if self.myLocale = null then
		return;
	endif;
	
	if not self.myLocale.isUserDefined then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Locale is not user defined' );
		return;
	endif;

	self.myPxyLocale := app.createUpdateProxy(self.myLocale).CM_Locale;

	self.mode := self.Mode_Edit;
	self.showFieldsForDoNewEdit(true);
	
	btnNew.visible := false;
	btnDelete.visible := false;
	btnSetDefault.visible := false;
	btnEdit.visible	:= false;		// cnwrl1 06/11/2009 PAR 21193
	
	self.txtCode.text		:= self.myPxyLocale.localeId;
	self.txtDescription.text:= self.myPxyLocale.localeDescription;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNew" id="e29f583e-d872-450f-8c0c-85ea07774c19">
        <updating/>
        <source>doNew() updating;

vars

begin
	tblLocales.accessRow(tblLocales.row).selected := false;
	myLocale := null;
	txtXlationCount.text := null;
	txtKeywordCount.text := null;
	btnNew.visible := false;
	btnDelete.visible := false;
	btnSetDefault.visible := false;
	btnEdit.visible	:= false;		// cnwrl1 06/11/2009 PAR 21193
	
	self.mode := self.Mode_Add;
	self.showFieldsForDoNewEdit(true);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="24096f49-ca92-46e1-96df-ec6bafd11a09">
        <updating/>
        <source>doSave() updating;

vars
	row			: Integer;
	localeId	: String;
	localeDesc	: String;
	idx			: Integer;
	result		: Integer;
	
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	
	if self.chkUserDefined.value then
		// this is User Defined Locale
		if self.txtCode.text = null and self.txtDescription.text = null then
			return;
		endif;
		localeId	:= self.txtCode.text;
		localeDesc	:= self.txtDescription.text;

	else
		// this is system locale
		if self.cmbLocales.text = null then
			return;
		endif;
		idx := 1;
		localeDesc := cmbLocales.text.scanUntil(Tab, idx);
		cmbLocales.text.scanWhile(Tab, idx);
		localeId := cmbLocales.text[idx : end];
		cmbLocales.listIndex := -1;
		
	endif;

	
	if self.mode = self.Mode_Add then
	
	elseif self.mode = self.Mode_Edit then
		if self.myLocale = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, "myLocale=null", null, self );
			return;
		endif;
		if self.myPxyLocale = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, "myPxyLocale=null", null, self );
			return;
		endif;
		self.myPxyLocale.setForProxy( localeId, localeDesc );
	else
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Unexpected form.mode=' &amp; self.mode.String, null, self );
		return;
	
	endif;
	
	
	while true do
		if self.mode = self.Mode_Add then
			//agent.trxCreateLocale(myLocale, localeId, localeDesc);
			app.myTrxCA.trxCreateLocale(localeId, localeDesc, self.myLocale, self.chkUserDefined.value, app.myPassport);
		else
			app.myTrxUA.trxUpdateLocale( self.myPxyLocale, self.chkUserDefined.value, app.myPassport );
		endif;
		if not app.myPassport.trxCompletedOK then	
			result := app.showErrorWarningDialog(app.getErrorString(Info_Locale), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			//app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
			self.setAllErrorWarnings(app.myPassport);	
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		else
			self.fillTable();
			foreach row in 1 to self.tblLocales.rows do
				if self.tblLocales.accessRow(row).itemObject = self.myLocale then
					self.tblLocales.row := row;
					self.tblLocales.topRow := row;
					self.tblLocales.accessRow(row).selected := true;
					self.selectLocale();
				endif;
			endforeach;
			return;
		endif;
		break;
	endwhile;
	
	//return false;
	
	
//	if (not app.myPassport.trxCompletedOK) then
//		return;
//	endif;
	
	//when ok
/*	self.fillTable();

	foreach row in 1 to tblLocales.rows do
		if tblLocales.accessRow(row).itemObject = myLocale then
			tblLocales.row := row;
			tblLocales.topRow := row;
			tblLocales.accessRow(row).selected := true;
			selectLocale;
		endif;
	endforeach;
*/
epilog
	if app.myPassport.trxCompletedOK then
		self.mode := Mode_View;
	endif;
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetAsDefault" id="5aff1ffb-53c6-454e-93e4-d68c89cc0840">
        <updating/>
        <source>doSetAsDefault() updating;

vars
	row : Integer;

begin
	//if not app.isDevelopmentSystem then
		agent.trxSetDefaultLocale(myLocale);
		fillTable;
	//endif;

	foreach row in 1 to tblLocales.rows do
		if tblLocales.accessRow(row).itemObject = myLocale then
			tblLocales.row := row;
			tblLocales.topRow := row;
			tblLocales.accessRow(row).selected := true;
			selectLocale;
		endif;
	endforeach;

end;
</source>
    </JadeMethod>
    <JadeMethod name="fillTable" id="484f6cb4-fdf6-4180-a747-84bf74270bc0">
        <updating/>
        <source>fillTable() updating;

vars
	locale 		: CM_Locale;
	row			: Integer;
	sDefault	: String;

begin
	tblLocales.rows := 1;
	tblLocales.setCellText(1, 1, "Description" &amp; Tab &amp; "Locale Id" &amp; Tab &amp; "Default?");

	foreach locale in agent.myRoot.allLocales where locale.localeId &lt;&gt; StandardTextLocale.padLeadingWith("0", 4) do
//		if app.isDevelopmentSystem then
			// development system default
//			sDefault := app.getYesNo(locale.localeId = StandardTextLocale.padLeadingWith("0", 4));
//		else
			// deployed system default
			sDefault := app.getYesNo(locale = app.myRoot.myDefaultLocale);
//		endif;
		row := tblLocales.addItem(locale.localeDescription &amp; Tab &amp; locale.localeId &amp; Tab &amp; sDefault);
		tblLocales.accessRow(row).itemObject := locale;
	endforeach;

	// sort, default at top
	tblLocales.sortColumn[1] := 3;
	tblLocales.sortAsc[1] := false;
	tblLocales.sortColumn[2] := 1;
	tblLocales.sortAsc[2] := true;
	tblLocales.resort;
	
end;</source>
    </JadeMethod>
