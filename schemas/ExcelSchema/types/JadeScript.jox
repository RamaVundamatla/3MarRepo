<Class name="JadeScript">
    <JadeMethod name="createDummyWorkbookDefinition" id="9d12cc04-a981-4537-bde0-819c091866b4">
        <source>createDummyWorkbookDefinition();

/*****************************************************
	Written by	:	cnwpra1		05 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	wbDef	: WorkbookDefinition;
	da		: FileManagementDA;
	str		: String;
	blob	: Binary;
	
begin
	create da;
	da.setUseLocalDirectory(true);
	str := da.copyFileToBlob(blob, 'c:\customers\dhcs\graphing\icpexample.xls');
	
	if str &lt;&gt; null then
		write str;
	else
		write 'OK';
	endif;
	
	beginTransaction;
	create wbDef;
	wbDef.setWorkbook(blob);
	wbDef.setWorkbookName('ICPExample');
	commitTransaction;

epilog
	delete da;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteSomeWorkbookDefinitions" id="59df3903-e22b-4334-9724-55f1aa2edf08">
        <updating/>
        <source>deleteSomeWorkbookDefinitions() updating;

/*****************************************************
	Written by	:	cnwgrp1		06 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	obj : WorkbookDefinition;

begin
	beginTransaction;
		foreach obj in WorkbookDefinition.instances do
			if obj.workbook = null then
				delete obj;
			endif;
		endforeach;
	commitTransaction;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteWorkbookDefinitions" id="748a0962-700a-4bc2-9b34-885c9686f3d4">
        <source>deleteWorkbookDefinitions();

/*****************************************************
	Written by	:	cnwpra1		05 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	beginTransaction;
	WorkbookDefinition.deleteAllInstances;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startExcel" id="eb7f120d-eb96-45ac-8465-1c5f8c19173c">
        <updating/>
        <source>startExcel() updating;

/*****************************************************
	Written by	:	cnwpra1		17 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	da		: ExcelDefnExcelDA;
	excel	: ExcelApplication;

begin
	create excel;
	excel.createAutomationObject;
	
/*
	create da;
	da.initialise(1);
*/	
	app.msgBox('Wait', 'Wait', MsgBox_OK_Only);

epilog
	delete excel;
end;</source>
    </JadeMethod>
    <JadeMethod name="testDefinitionExcelDA" id="a54fc154-503f-46b1-9340-76e1dd6ead1b">
        <source>testDefinitionExcelDA();

/*****************************************************
	Written by	:	cnwpra1		05 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	defDA		: ExcelDefnExcelDA;
	wb			: WorkbookDefinition;
	dispatch		: IDispatch;
	str				: String;
	count			: Integer;
	int				: Integer;

begin
	wb := WorkbookDefinition.firstInstance;
	create defDA;
	defDA.setMyWorkbookDefinition(wb);
	
	defDA.initialise(1);
	
	count := defDA.getMyExcelApplication.activeWorkbook.sheets.count;
	
	while int &lt; count do
		int := int + 1;
		dispatch := defDA.getMyExcelApplication.activeWorkbook.sheets.item(int);
	endwhile;
	
	str := '1' &amp; Tab &amp; '2' &amp; Tab &amp; '3' &amp; Tab &amp; '4';
	app.copyStringToClipboard(str);
	defDA.getMyExcelApplication.activeSheet.I_Worksheet.paste(null,false);
	
	defDA.getMyExcelApplication.activeSheet.I_Worksheet.range('A1', 'D4').select;
	
	app.msgBox('Wait', 'Wait', MsgBox_OK_Only);
	
epilog
	delete defDA;
end;</source>
    </JadeMethod>
    <JadeMethod name="testExcelApplicationDA" id="fda4398f-1255-42ff-a6f8-b93e645c98fc">
        <source>testExcelApplicationDA();
	
vars
	excelAppDA : ExcelApplicationDA;
	sht :I_Worksheet;
begin
	create excelAppDA;

	excelAppDA.makeVisible(true);

	app.msgBox ("Wait","Wait",0);
	sht := excelAppDA.getWorksheet("Result Sheet");
	excelAppDA.activateWorksheet(sht);

	app.msgBox ("Wait","Wait",0);
epilog
	delete excelAppDA;
	
end;</source>
    </JadeMethod>
