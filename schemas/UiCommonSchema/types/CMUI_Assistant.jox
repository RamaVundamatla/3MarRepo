    <JadeMethod name="listTableCellInputReady" id="a274ff94-8cf1-4079-b8d1-6c5a761c754f">
        <source>listTableCellInputReady(pTable : CM_BaseTable input; cheight : Real io; saveHeight : Real io);
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cellTop		: Integer;
	jadeRow		: JadeTableRow;
	
begin

	if saveHeight = 0 then
		jadeRow := pTable.accessRow(pTable.row); 
		saveHeight := jadeRow.height;
		jadeRow.height := 120;
		
		cheight := 69;
//		pTable.scrollBars := Table.ScrollBars_Horizontal;

		// Reset the topRow to ensure that all of this row is
		// always displayed.
		cellTop := pTable.accessCell(pTable.row, pTable.column).positionTop;
		if cellTop + cheight &gt; pTable.height then
			pTable.topRow := pTable.row;
		endif;
	endif;

end;</source>
        <Parameter name="pTable" type="CM_BaseTable" usage="input"/>
        <Parameter name="cheight" type="Real" usage="io"/>
        <Parameter name="saveHeight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="listTableColour" id="72fda723-fd5e-4131-9ada-be6a34f2bd9f">
        <source>listTableColour(_listTable : CMUI_ListTable input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	colour 	: CM_VehicleColour;
	idx		: Integer;
	coll	: CM_VehicleColourByColour;

begin
	create coll transient;
	_listTable.allSelectedObjects.copy(coll);
	_listTable.clearSelected;
	_listTable.rows := _listTable.fixedRows;
	if app.myCurrentUserCan(self.myTerminal, PmAdmVehicleColourMaint) then
		_listTable.addItem(Tab &amp; "Dbl-Click to Add New");
	endif;
	foreach colour in app.myDutyDocRoot.allVehicleColours do
		idx := _listTable.addItem(TableCheckBox_NotSelected &amp; Tab &amp; colour.colour);
		_listTable.accessRow(idx).itemObject := colour;
	endforeach;
	_listTable.setSelected(coll);
	if app.myCurrentUserCan(self.myTerminal, PmAdmVehicleColourMaint) then
		_listTable.accessCell(1,1).inputType := null;
		_listTable.accessCell(1,1).text := null;
	endif;
epilog
	delete coll;
end;</source>
        <Parameter name="_listTable" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="listTableDischarge" id="2b3effed-4f20-43f7-b61d-3ed427d6b1a8">
        <updating/>
        <source>listTableDischarge(pListTable : CMUI_ListTable input; pVoyage : CM_Voyage; pPort : CM_Port) updating;
// Created:     20 December 2000 by cnwrs2
