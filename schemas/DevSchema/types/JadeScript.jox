    <JadeMethod name="ma41121" id="916a6e20-8029-49dc-a888-903c7c5b967c">
        <source>ma41121();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2021		navma1	Initial creation

*/

vars
	appScm		     : Schema;
	const 		     : Constant;
	type			 : String;
	constantCategory : ConstantCategory;
	taskId			 : Integer;
begin
	appScm := currentSchema; 
	
	if appScm.name &lt;&gt; PortSchemaName then
		appScm := rootSchema.getSchema(PortSchemaName);
	endif;
	
	if appScm = null then
		return;
	endif;
	
	constantCategory := appScm.getConstantCategory('XLAT_Permissions');
	
	if constantCategory = null then
		return;
	endif;
	
	
	foreach const in constantCategory.getConstants do
	
		taskId := const.getSource().Integer;
		
		write taskId.String;
		
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ma44905" id="8262eaa3-9d63-4b79-9ddf-b6b85141d6f4">
        <source>ma44905();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2019	jlgma1	Initial creation

*/

vars
	railLine		: CM_RailLine;
	wagon			: CM_Wagon;
	wagonOrginalPos,newPos : Integer;
	orginalWagon    : CM_Wagon;
begin
	app.initialize;
	
	newPos := 4;
	
	wagon :=  app.myPassport.getObjectOfTypeFromOid("12082.169552",CM_Wagon).CM_Wagon;
	railLine := app.myPassport.getObjectOfTypeFromOid("3577.79450",CM_RailLine).CM_RailLine;
	
	wagonOrginalPos := wagon.getWagonPosition().asIntegerJMT();
	
	write "wagonOrginalPos :" &amp; wagonOrginalPos.asStringJMT;
	
	foreach wagon in railLine.allWagonsById discreteLock do 
		if wagon &lt;&gt; null then
			if wagon.getWagonPosition.Integer = newPos then
				break;
			endif;
			
		endif;
		wagon := null;
	endforeach;
	if railLine.allWagons[newPos] &lt;&gt; null then
		orginalWagon := railLine.allWagons[newPos].CM_Wagon;
	endif;
	
	app.finalize();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ma46185" id="555ccc34-0412-4e66-abc4-6cb350ceff77">
        <source>ma46185();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2019	jlgma1	Initial creation

*/

vars
	term 		: CM_Terminal;
	cargoTypeID : Integer;
	cargoID     : String;
	allTIs      : CM_TISet;
	ti : CM_TrackedItem;
	failedDAC	: CM_DataAccessController ;
begin
	app.initialize();
	term := app.myRoot.allTerminals["MA"];
	cargoTypeID := 1;
	create allTIs transient;
	term.lookupAllOnsiteTrackedItems(cargoTypeID, cargoID, allTIs, false, null);
	
	write allTIs.size;
		foreach ti in allTIs do
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
				
		write ti.id;
		
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
