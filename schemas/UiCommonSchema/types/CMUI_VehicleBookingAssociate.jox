    <JadeMethod name="mnuInpsectObj_click" id="c28a4207-264e-4be0-8ed2-880260bb7a6b">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInpsectObj_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2021	navndl1	Initial creation	TFS	TFS 51045

*/

vars

	booking : CM_VehicleBookingTimeSlot;

begin

	if self.tblBookings.row &gt; self.tblBookings.fixedRows and self.tblBookings.row &lt;= self.tblBookings.rows then
		booking := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
	endif;
	
	if booking &lt;&gt; null then
		booking.inspect();
	endif;

epilog

end;</source>
