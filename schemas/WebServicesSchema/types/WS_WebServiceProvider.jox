    </JadeMethod>
    <JadeMethod name="validateCurrentMachine" id="fc592404-6f06-4a72-b242-0d4ccfcb1c4a">
        <source>validateCurrentMachine(_checkOutstandingFaults : Boolean)   protected;
/*

Date		Who		Reason
22 May 2017	cnwer1	Initial creation TFS 995
11/07/2019 		JLGNS1	Bug 45454: SPT - Error 4 in JMTUserInterfaceService machineGetControlMessages

*/

vars
	machine : CM_Machine;
	gotException	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, machine, gotException);
	
	if currentSession = null then
		// PAR #20537 - moved lengthy error message to error text, not errorItem
		self.setError(UNEXPECTED_PROGRAM_ERROR, 
					  null, 
					  app.getErrorString3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, "currentSession is null"));
		return ;
	endif;
	
	machine:=currentSession.myCurrentMachine;
	if currentSession.myCurrentMachine = null then
		app.raiseCMException(ERR_MS_SESSION_NOMACH, null, null);
		return ;
	endif;
	
	if currentSession.myCurrentMachine.user = null or not currentSession.myCurrentMachine.loggedOn then
		app.raiseCMException(ERR_MS_NOT_LOGGED_ON, null, null);
		return ;
	endif;
	//Bug 45454
	if gotException then
		app.raiseCMException(ERR_MS_SESSION_NOMACH, null, null);
		return ;
	endif;	
	
	// should set to true for everything apart from the webservice that is updating the fault questions
	if _checkOutstandingFaults then
		if currentSession.myCurrentMachine.isFaultQuestionOutstanding() then
			app.raiseCMException1(ERR_MACH_FAULTS_OUT, currentSession.myCurrentMachine.id, null, null);
			return ;
		endif;
	endif;
	
	
	app.isRTApp:=true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_checkOutstandingFaults" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCurrentSession" id="ad284af6-be37-4248-99ff-0652171bf6c6">
        <source>validateCurrentSession(_checkUser : Boolean) : Boolean protected;

/*

Purpose:			Validate the currentSession object

Parameters:			_checkUser specifies whether or not to validate that the session has
					a current user or not

Return Value:		True if the session is OK, false if not.  setError will be called to ensure a SOAP fault
					is returned if there is any problem


Date		Who		Reason
17 Dec 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
31 Aug 2009	cnwkpd1	PAR #20537 - Prevent 1035 exception handling non-session input 	(HTML Test Harness)
07 Nov 2019 cnwma1	Bug 47161: JMT - WebService Logout invalid ref to currentSession
14 Jan 2021 jlgmd1	TFS #50644 - Clean up 'temporary' web sessions to mitigate DOS attacks
03 Feb 2021 cmwma1  Bug 50631: AAT - MobileApps Issue - Invalid Web Session Messages
04 Jul 2024 navbk1  Bug 62228: SAL - Anonymous user is able to update the locale, email and send the feedback using the soap requests
31 Jul 2024 navmd1	TFS 62228 Modifed validateCurrentSession to look for 'currentSession' and 'app.myPublicUser' from the unitTestData collection
*/

vars
	invalidSession	: Boolean;
	session			: SWebServiceSchema;
	publicUser		: CM_User;
begin
	
	// Kludge for testing web query messages... NDL Par 31506
	if self.unitTestData.size = 0 then
		executeWhen JMTDevelopmentEnvironment;
		if (app.name = "JMTUnitTest" or app.name = "JMTUnitTestRunner") then
			return true;
		endif;
		endExecuteWhen;
		
		if app.isJMTUnitTest then
			return true;
		endif;
	else
		publicUser := self.unitTestData.obj("myPublicUser").CM_User;
	endif;
	
	if publicUser = null then
		publicUser := app.myPublicUser;
	endif;
	
	session := currentSession;
	if session = null then
		session := self.unitTestData.obj("currentSession").SWebServiceSchema;
	endif;
	
	if session = null then
		// PAR #20537 - moved lengthy error message to error text, not errorItem
		self.setError(UNEXPECTED_PROGRAM_ERROR, 
					  null, 
					  app.getErrorString3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, "currentSession is null"));
		return false;
	endif;
	
	//07.11.2019 cnwma1 #47161
	on Exception do app.handleDeletedObject(exception, session, invalidSession); 
	session.edition;
	if invalidSession then
		self.setError(UNEXPECTED_PROGRAM_ERROR, 
					  null, 
					  app.getErrorString3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, "currentSession is invalid"));
		self.removeUnsuccessfullSession();  //03.02.2021  cnwma1 #50631
		return false;
	endif;
	on Exception do null;
	
	app.writeLog("currentSession=" &amp; session.String &amp; ", myUser=" &amp; session.myUser.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	if _checkUser and session.myUser = null then
		self.setError(ERR_MS_NOT_LOGGED_ON, null, app.getErrorString(ERR_MS_NOT_LOGGED_ON));
		self.removeUnsuccessfullSession();   //03.02.2021  cnwma1 #50631
		return false;
	endif;
	
	// START 04.07.2024 navbk1 #62228
	if session.myUser = publicUser then	
		if not self.isWhiteListedMethod(self.getMethodName()) then
			self.setError(Err_InsufficientPermission, null, app.getErrorString(Err_InsufficientPermission));
			return false;
		endif;
	endif;
	//END 04.07.2024 navbk1 #62228
	
	// Got here, then everything is OK
	return true;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_checkUser" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="webServiceMethodTemplate" id="cdbacb08-46e4-4f42-975f-872c1ca91eb8">
        <updating/>
        <source>webServiceMethodTemplate(request : WS_Request) : WS_Response /* webService, */ protected, updating; /* remove protected, */

/*

Purpose:			Template method for any new webService method on any of the subclass providers.
					Use this code to ensure that all the correct framework requirements are met.
					Note that input parameter name should be changed to a name representative
					of the request class (but not exactly the same) because this then appears in the 
					generated WSDL as a meaningful name.
					
					Note: Please leave a meaningful Purpose description describing what the method does.
					From, either copy this purpose into the methods Text or run the JadeScript 'getPurposeForText'.
					The method Text will be provided in the external documentation to our customers (this also applies
					to attribute and class Text).

Parameters:

Return Value:		


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	//if this is a machine related websession then uncomment below
	//self.validateCurrentMachine(true); //set false for when sending or requesting the fault questions
	
	// Create the response
	create response transient;
		
	if IncompleteWebServiceMethod then		// Remove this when implemented
		app.raiseCMException1(Service_method_implemente,method.qualifiedName,
							null, 
							null);
		completedOK := true;
		return response;
	endif;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(99999);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	
	// Perform validation, start populate response
	// ....
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <access>protected</access>
        <Parameter name="request" type="WS_Request"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="webServiceMethodTemplateExt" id="09efcd41-d21c-4b6c-b7e8-fe9a501e1871">
        <updating/>
        <source>webServiceMethodTemplateExt(request : WS_ExternalRequest) : WS_ExternalResponse /* webService, */ protected, updating; /* remove protected, */

/*

Purpose:			Template method for any new webService method on the JMTExternalInterfaceService provider.
					Use this code to ensure that all the correct framework requirements are met.
					Note that input parameter name should be changed to a name representative
					of the request class (but not exactly the same) because this then appears in the 
					generated WSDL as a meaningful name.
					
					Note: Please leave a meaningful Purpose description describing what the method does.
					From, either copy this purpose into the methods Text or run the JadeScript 'getPurposeForText'.
					The method Text will be provided in the external documentation to our customers (this also applies
					to attribute and class Text).

Parameters:

Return Value:		


Date		Who		Reason
04 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	response		: WS_ExternalResponse;
	completedOK		: Boolean;
	permission 		: Integer;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Initialise the passport for the new transaction
	self.initialisePassportExternal();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check there is a request created (will be null if the input message is invalid)
	if request = null then
		app.raiseCMException(Parameter_Invalid, null, null);
	else
		// Validate the credentials passed in the request
		permission := 99999;		// Replace with appropriate permission
		request.validateCredentials( permission );
		
		// Populate known response attributes from the request
		response.populateFromRequest(request);
	endif;
	
	
	if IncompleteWebServiceMethod then		// Remove this when implemented
		app.raiseCMException1(Service_method_implemente,method.qualifiedName,
							null, 
							null);
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	
	// Perform validation, start populate response
	// ....
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <access>protected</access>
        <Parameter name="request" type="WS_ExternalRequest"/>
        <ReturnType type="WS_ExternalResponse"/>
    </JadeMethod>
</JadeWebServiceProviderClass>
