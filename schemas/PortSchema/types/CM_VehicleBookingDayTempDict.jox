<CollClass name="CM_VehicleBookingDayTempDict" id="94d17283-0824-4d08-9b3a-5ec22614e3e4">
    <loadFactor>66</loadFactor>
    <memberType name="CM_VehicleBookingDayTemplate"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vehicleSchedule"/>
    <MemberKey>
        <property name="CM_VehicleBookingDayTemplate::myCalendar"/>
    </MemberKey>
    <JadeMethod name="getDefaultDayTemplate" id="def86510-1a10-42e6-b6e8-eb905f775ff1">
        <source>getDefaultDayTemplate():CM_VehicleBookingDayTemplate;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	dayTemplate : CM_VehicleBookingDayTemplate;
	
	
	
begin

	iter := self.createIterator;
	while iter.next( dayTemplate ) do
		if dayTemplate.isDefaultTemplate() then
			// there is only allowed to be one of these
			return dayTemplate;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_VehicleBookingDayTemplate"/>
    </JadeMethod>
    <JadeMethod name="getFirstTemplateFor" id="60b0d16d-3efd-4557-9930-36e8e9109233">
        <source>getFirstTemplateFor( _date : Date ) : CM_VehicleBookingDayTemplate;
/*

Purpose:			
				Find the most suitable template to use.
Parameters:			

Return Value:		

Date		Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	iter : Iterator;
	dayTemplate : CM_VehicleBookingDayTemplate;
	default : CM_VehicleBookingDayTemplate;
	calendar : CM_Calendar;
	bestChoice : CM_VehicleBookingDayTemplate;
	
	
begin

	iter := self.createIterator;
	while iter.next( dayTemplate ) do
		if dayTemplate.isDefaultTemplate() then
			// there is only allowed to be one of these
			default := dayTemplate;
			continue;
		endif;
		calendar := dayTemplate.myCalendar;
		if calendar.getFirstCalendarDateForDay(_date) = null then
			continue;
		endif;
		if bestChoice = null or bestChoice.priority &gt; dayTemplate.priority then
			bestChoice := dayTemplate;
		endif;
	endwhile;
	
	if bestChoice = null then
		bestChoice := default;
	endif;
	
	return bestChoice;

epilog

	delete iter;
	
end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="CM_VehicleBookingDayTemplate"/>
    </JadeMethod>
</CollClass>
