    <JadeMethod name="addToolbarControls" id="7e01cc6c-5de2-473d-81fe-4d53d57fdeec">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	10 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
begin

	inheritMethod();
	toolbar := self.frmToolbar;
	
	if self.allowPrint then
		toolbar.addButton(self.btnPrintTV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	endif;

	if self.allowAdd then
		toolbar.addButton(self.btnNewTV, CMUI_Toolbar.Control_Alignment_Left);

		if self.allowAddChild then
			toolbar.addButton(self.btnNewChildTV, CMUI_Toolbar.Control_Alignment_Left);
		endif;		
	endif;

	if self.allowUpdate then
		toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
	endif;

	if self.allowUpdate or self.allowAdd then
		toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
		
		if self.allowNext then
			toolbar.addButton(self.btnNextTV, CMUI_Toolbar.Control_Alignment_Left);
		endif;
		
		toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	endif;

	if self.allowDelete then
		toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addTreeObject" id="da6f2e08-d904-4d7c-a777-045c6e16ed18">
        <source>addTreeObject(_text : String; _obj : Object; _level : Integer; _expanded : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     21 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	: Integer;

begin

	row := self.lstData.addTreeObject(_text, _obj, _level, _expanded);
	self.beginNotification(_obj, Any_System_Event, Response_Continuous, 0);

	return row;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_expanded" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="allowAdd" id="a4623892-a83f-4c0d-9b9a-1948580a335a">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allowAdd(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.allowAdd := _value;
		if _value then
			btnNewTV.visible := true;
		else
			btnNewTV.visible := false;
		endif;
	else
		_value := self.allowAdd;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
