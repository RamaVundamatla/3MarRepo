    <JadeMethod name="getExampleXML" id="3f429caa-2976-4573-b416-8a89ee934ba3">
        <source>getExampleXML():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	tagset : String;
	rules : String;
	exampleXML : String;
	
	cargoBaseId1 : String;
	cargoBaseId2 : String;
	location1 : String;
	location2 : String;
	cargoType1 : String;
	cargoType2 : String;
	
begin

	tagset :=
'XML recognised tags :'  &amp; CrLf &amp;
'&lt;' &amp; TagMultiMoveGroups &amp; '&gt;' &amp; Tab &amp; 'Indicates the EDI message type to JMT and contains the complete XML data set' &amp; CrLf &amp;
'&lt;' &amp; TagMultiMoveGroup &amp; '&gt;' &amp; Tab &amp; 'Represents one complete Multi Move group object.  Requires at least on.  Multiples are permitted in the &lt;' &amp; TagMultiMoveGroups &amp; '&gt; tag set' &amp; CrLf &amp;
'&lt;' &amp; TagCargoIds &amp; '&gt;' &amp; Tab &amp; 'Contains a collection of &lt;' &amp; TagCargoId &amp; '&gt; tag sets that represent cargo associated with the Multi Move Group  One required in a &lt;' &amp; TagMultiMoveGroup &amp; '&gt; tag set' &amp; CrLf &amp;
'&lt;' &amp; TagCargoId &amp; '&gt;' &amp; Tab &amp; 'Represents one available Cargo object.  A minimum of two required in a &lt;' &amp; TagCargoIds &amp; '&gt; tag set' &amp; CrLf &amp; 
'&lt;' &amp; TagTargetLocation &amp; '&gt;' &amp; Tab &amp; 'The default location used in the Hand Held when moving the cargo items. Used only if no location can be derived from a Cargo Group.  One permitted in a &lt;' &amp; TagMultiMoveGroup &amp; '&gt; tag set' &amp; CrLf &amp;
'&lt;' &amp; TagCargoType &amp; '&gt;' &amp; Tab &amp; 'The cargo type of the Cargo Items.  One permitted in a &lt;' &amp; TagMultiMoveGroup &amp; '&gt; tag set.  Used to uniquely identify the on-site cargo items within the set' &amp; CrLf &amp;
'';

write tagset;



	cargoBaseId1 := "ALUM";
	cargoBaseId2 := "PALEALE";
	location1 := "WareHouse1";
	location2 := "WareHouse2";
	cargoType1 := "ALIG";
	cargoType2 := "BEER";

exampleXML :=
'Example :'  &amp; CrLf &amp;
'&lt;?xml version="1.0" encoding="ISO-8859-1"?&gt;' &amp; CrLf &amp;
'&lt;' &amp; TagMultiMoveGroups &amp; '&gt;
	&lt;' &amp; TagMultiMoveGroup &amp; '&gt;
			&lt;' &amp; TagTargetLocation &amp; '&gt;' &amp; location1 &amp; '&lt;/' &amp; TagTargetLocation &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType1 &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagCargoIds &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId1 &amp; '01&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId1 &amp; '02&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId1 &amp; '03&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId1 &amp; '04&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;/' &amp; TagCargoIds &amp; '&gt;
	&lt;/' &amp; TagMultiMoveGroup &amp; '&gt;
	&lt;' &amp; TagMultiMoveGroup &amp; '&gt;
			&lt;' &amp; TagTargetLocation &amp; '&gt;' &amp; location2 &amp; '&lt;/' &amp; TagTargetLocation &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType2 &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagCargoIds &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId2 &amp; '05&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId2 &amp; '06&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId2 &amp; '07&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId2 &amp; '08&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId2 &amp; '09&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId2 &amp; '10&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId2 &amp; '11&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId2 &amp; '12&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;/' &amp; TagCargoIds &amp; '&gt;
	&lt;/' &amp; TagMultiMoveGroup &amp; '&gt;
&lt;/' &amp; TagMultiMoveGroups &amp; '&gt;';

	write exampleXML;

epilog

	return exampleXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="4015d556-1149-45dc-8800-c4b1e4b4b5ea">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	message : String;
	xmlDoc : CM_XMLDocument;
	rootElement : JadeXMLElement;
	xmlElements : JadeXMLElementArray;
	xmlElement : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	xmlIdElement : JadeXMLElement;
	str : String;
	theXMLStr : String;
	
	xmlElementsIds : JadeXMLElementArray;
	idsStrArray : StringArray;
	index : Integer;
	
	ediMMG : CM_EDIMultiMoveGroup;
	location : String;
	cargoType : String;
begin
	create xmlDoc transient;

	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		app.myPassport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", 4, 3, "Loading EDI file Step 3 of 3.");
	endif;
	//epr TFS 1834 15/4/16
	message := _ediFile.getRawDataString();
	
	theXMLStr := message.extractXML();
    if theXMLStr &lt;&gt; null then
	
		xmlDoc.parseString(theXMLStr);
		if xmlDoc.rootElement.tagName = self.TagMultiMoveGroups then
			rootElement := xmlDoc.rootElement;
		else
			rootElement := xmlDoc.rootElement.getElementByTagName(self.TagMultiMoveGroups);
		endif;
		
		if rootElement &lt;&gt; null then
		
			create xmlElements transient;
			rootElement.getAllElementsByTagName(self.TagMultiMoveGroup, xmlElements);
			
			if xmlElements.isEmpty then
				addFileErrors(self.TagMultiMoveGroups &amp; " must include at least one &lt;" &amp; self.TagMultiMoveGroup &amp; "&gt;", 1, _ediFile);
				return;
			endif;
			
			create xmlElementsIds transient;
			create idsStrArray transient;
			
			
			foreach xmlElement in xmlElements do
			
				index := index + 1;
			
				location := null;
				cargoType := null;
				idsStrArray.clear();
				xmlElementsIds.clear();
				
				xmlSubElement := null;
				xmlSubElement := xmlElement.getElementByTagName(self.TagTargetLocation);
				if xmlSubElement &lt;&gt; null then
					location := xmlSubElement.textData.trimBlanks;
				endif;
				
				xmlSubElement := null;
				xmlSubElement := xmlElement.getElementByTagName(self.TagCargoType);
				if xmlSubElement &lt;&gt; null then
					cargoType := xmlSubElement.textData.trimBlanks;
				endif;
				
				
				xmlSubElement := null;
				xmlSubElement := xmlElement.getElementByTagName(self.TagCargoIds);
				if xmlSubElement &lt;&gt; null then
					xmlSubElement.getAllElementsByTagName(self.TagCargoId, xmlElementsIds);
					if not xmlElementsIds.isEmpty then
						foreach xmlIdElement in xmlElementsIds do
							str := xmlIdElement.textData.trimBlanks;
							if str &lt;&gt; null and not idsStrArray.includes( str )then
								idsStrArray.add( str );
							endif;
						endforeach;
					endif;
				else
					addFileErrors( "Tag set " &amp; self.TagCargoIds &amp; " is mossing [record number " &amp; index.String &amp; "]", 1, _ediFile);
					return;
				endif;
				
				if idsStrArray.isEmpty then
					addFileErrors( self.TagCargoIds &amp; " tage set [record number " &amp; index.String &amp; "] has no cargo items", 1, _ediFile);
					return;
				endif;
				
				create ediMMG;
				ediMMG.setMyEDIData( _ediFile.ediData );
				ediMMG.messageMode := "A";
				if not idsStrArray.isEmpty then
					idsStrArray.copy( ediMMG.allCargoIds );
				endif;
				ediMMG.targetLocation := location;
				ediMMG.cargoTypeDescr := cargoType;
				
			endforeach;
		
		endif;
	endif;
	
epilog
	
	delete xmlDoc;
	delete xmlElements;
	delete xmlElementsIds;
	delete idsStrArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
