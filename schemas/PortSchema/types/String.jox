        <source>addLine(line: String) updating;

begin
	self := self &amp; CrLf &amp; line;
end;</source>
        <Parameter name="line" type="String"/>
    </JadeMethod>
    <JadeMethod name="addStringToList" id="17c23af8-d209-4c51-b437-78dc2d45608c">
        <updating/>
        <source>addStringToList(_str : String; _delim : String) updating;
/*

Purpose:			This method add the "_str" to self to build up a list
					If "_str" is already in the list, don't add it.

Parameters:			

Return Value:		

Date		Who		Reason
16/01/2025	navkc1 JIRA Bug MTN-33804: Wagon Number field is displaying all the Wagons on the Work Order Enquiry form

*/

vars
	lastStr		: String;
	pos,
	revPos 		: Integer;
begin
	//24/03/2025	navkc1 JIRA Story MTN-34256 - Nothing to add
	if _str = null then
		return;
	endif;
	
	// We dont have anything, just add it
	if self = null then
		self := _str;
		return;
	endif;
	
	// We have something, and it's the same as the _str we want to add, don't do anything
	if self = _str then
		return;
	endif;
	
	// We have a list of string, and _str is part of it, don't do anything 
	pos := self.pos(_str &amp; _delim, 1);
	if pos &gt; null then
		
		//24/03/2025	navkc1 JIRA Story MTN-34256
		// if the _str is first in the list
		if 	pos = 1 or pos - _delim.length() &lt;= null then
			return;
		else
		//24/03/2025	navkc1 JIRA Story MTN-34256
			// the _str is somewhere in the middle, we want to make sure what we found is exactly the same as _str
			/* 	i.e. "WAGON, WAGON2, 1, 3", and _str is 2
				we found "2," from the "WAGON2", then we check the actual string we found make sure it's "2"
				in this case, the actual string in "WAGON2", not "2", so we want to add _str to the list
			*/
			pos -= _delim.length();
			if self.pos(_delim &amp; _str &amp; _delim, pos) &gt; null then
				return;
			endif;
		endif;
	endif;
	
	// Get the _str from the back
	revPos := self.reversePos(_str);
	
	// Found something - Check whether it's exact match
	if revPos &gt; 0 then
		// Get the last string
		lastStr := self[revPos:end];
		// It's exact match, dont do anything
		if lastStr = _str then
			return;
		endif;
	endif;
	
	// _str is not in the list, add it
	self &amp;= _delim &amp; _str;

epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="appendCommaSeparatedValue" id="35d2df93-6a13-48d3-8122-88424dcbda6e">
        <source>appendCommaSeparatedValue(_value: String; _noSpaces: Boolean): String;
//----------------------------------------------------------------
//	Created:	15 December 2004	by Jason Chapman  (cnwjc2)
//
//	Use when building a CSV line
//----------------------------------------------------------------
vars
	strSeparator 	: String;
	theNewSelf		: String;
begin
	if _noSpaces then
		strSeparator := ",";
	else
		strSeparator := ", ";
	endif;
	
	if self = null then
		theNewSelf := _value;
	else
		theNewSelf := self &amp; strSeparator &amp; _value;
	endif;

epilog
	return theNewSelf;	
end;</source>
        <Parameter name="_value" type="String"/>
        <Parameter name="_noSpaces" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="appendErrorMsg" id="e0ca95c5-d20e-4500-b4ab-dbc5190ca3ea">
        <source>appendErrorMsg(_errorMsg:String):String;
// --------------------------------------------------------------------------------
// Created:		12 October 2006 by cnwdad1
//
// Purpose:		Appends an error message to the receiver, separated by two Cr &amp; Lf
//				pairs so that each message will be displayed separately.
//
// Parameters:	_errorMsg - The errormessage to append to the receiver.
//
// Returns:		The receiver with the appended error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self = null then
		return _errorMsg;
	else
		return self &amp; CrLf &amp; CrLf &amp; _errorMsg;
	endif;
end;</source>
        <Parameter name="_errorMsg" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asAnyOfType" id="d41a60a8-0c4c-4e45-8618-a02e140b6934">
        <source>asAnyOfType(_type : Type) : Any;

/*

Purpose:			Convert the receiver String into the passed in Type of Any


Return Value:		


Date		Who		Reason
12 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service
17 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
31 Aug 2020	NDL	TFS 49778
*/

vars
	typeName		: String;
	
begin
	typeName := _type.name;
	if typeName = Binary.name then
		return self.base64Decode();
	elseif typeName = Boolean.name then
		if self.toUpper.trimBlanks = "YES" or self.trimBlanks = "1" then	//31 Aug 2020	NDL	TFS 49778
			return true;
		endif;
		return self.Boolean;
	elseif typeName = Byte.name then
		return self.Byte;
	elseif typeName = Character.name then
		return self.Character;
	elseif typeName = Date.name then
		return self.Date;
	elseif typeName = Decimal.name then
		return self.Decimal;
	elseif typeName = Integer.name then
		return self.Integer;
	elseif typeName = Integer64.name then
		return self.Integer64;
	elseif typeName = Point.name then
		return self.Point;
	elseif typeName = Real.name then
		return self.Real;
	elseif typeName = StringUtf8.name then
		return self.StringUtf8;
	elseif typeName = Time.name then
		return self.Time;
	elseif typeName = TimeStamp.name then
		return self.TimeStamp;
	elseif typeName = TimeStampInterval.name then
		return self.TimeStampInterval;
	elseif typeName = TimeStampOffset.name then
		return self.TimeStampOffset;
	else
		return self;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_type" type="Type"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="asBooleanJMT" id="f5393059-6a6d-40d8-9185-e5bb5920af0f">
        <source>asBooleanJMT() : Boolean;

/*

Purpose:			Return the Boolean value apropriate for the receiver, as required in
					EDII file import, etc.
					
Parameters:			None

Return Value:		Boolean value equivalent of the receiver


Date		Who		Reason
28 May 2008	cnwkpd1	CCMS Nelson 1637

*/

vars
	lowerCase		: String;
	
begin
	lowerCase := self.toLower;
	
	return lowerCase = "true" or
		   lowerCase = "yes" or
		   lowerCase = "y" or
		   lowerCase = "1";
		   
		   
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
