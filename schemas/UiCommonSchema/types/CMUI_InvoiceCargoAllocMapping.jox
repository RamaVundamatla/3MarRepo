    <JadeMethod name="displayInvoiceLineTypes" id="c5251b48-856f-403f-8992-194d10eab846">
        <source>displayInvoiceLineTypes();
/*
Purpose:			
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
*/

vars

	idx : Integer;
	anILD : CM_InvoiceLineDesc;
	bank : CM_Bank;
begin
	// 35872 use transaction map bank, or default terminal bank
	// allocation is passed into CMUI_InvoiceCargoAllocMapping but not to CMUI_InvoiceFutureStorageMaps
	if self.myAllocation &lt;&gt; null then
		bank := self.myAllocation.getBank();  // ### TFS 51219 25MAY2021 NAVAB1     CM_InvoiceCargoAllocation.myTransactionMap.myBank;
	else
		bank := self.myTerminal.getDefaultCompanyBank();
	endif;
	self.tblData.rows := 0;
	self.tblData.selectMode := Table.SelectMode_Multiple;
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblData.selectionType := 1;
	self.tblData.fixedColumns := 0;
	self.tblData.columns := 1;
	
	foreach anILD in bank.invoiceLineDescriptors where not anILD.isNotAvailableForEntry do
		if (anILD.isCargoCalcType and (self.myAllocation.isKindOf(CM_InvoiceCargoAllocation) or self.myAllocation = null)) // ### TFS 51219 28MAY2021 NAVAB1
		or (anILD.isInventoryCalcType and self.myAllocation.isKindOf(CM_InvoiceInventoryAllocation)) // ### TFS 51219 28MAY2021 NAVAB1
		or anILD.isVoid // ### TFS 51219 03JUN2021 NAVAB1
		then
	
			idx := self.tblData.addItemObject(anILD, anILD.narration);
		endif;
	endforeach;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayQuantityMap" id="508e364c-ff56-47a8-9757-b9f19459ca01">
        <source>displayQuantityMap();
/*
Purpose:			
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
*/

vars
	obj : Object;
	realQM : CM_QuantityMap;
	sb : CM_CargoServiceBroker; // ### TFS 51219 25MAY2021 NAVAB1
	theReturn, mapType, row : Integer;
	gt : CM_TranMapInvoiceLineGroupType;
	map : CM_TranMapInvoiceLineMapping;
	toprow : Integer;
	mapping : CM_TranMapInvoiceLineMapping;
	ild : CM_InvoiceLineDesc;
begin

	if self.myAllocation = null then
		return;
	endif;
	
	sb := self.myAllocation.myServiceBroker; // ### TFS 51219 25MAY2021 NAVAB1
	realQM := sb.myChildQuantityMap;
	
	if realQM &lt;&gt; null then
		if self.cmbQuantityType.findObject(realQM.myCalculationType) &gt; 0 then // ### TFS 51219 28MAY2021 NAVAB1
			self.cmbQuantityType.listObject := realQM.myCalculationType;
		endif; // ### TFS 51219 28MAY2021 NAVAB1
		self.chkChargeZero.value := realQM.chargeZero;
		self.optSingle.value := (realQM.mappingType = CM_QuantityMap.MapType_Single);
	endif;

	if not updateMode then
		self.txtFrom.text := "0";
		self.txtTo.text := CM_QuantityRangeMap.MAX_RANGE.Integer.String;
		self.chkMaximum.value := true;
	else
		self.chkMaximum.value := false;
	endif;
	toprow := 0; // TFS 7496
	if self.myCurrentQuantityRangeMap &lt;&gt; null then
		foreach row in 1 to self.tblData.rows do
			self.tblData.accessRow(row);
	
// TFS 40620			if self.myCurrentQuantityRangeMap.allInvoiceLineMaps.includes(self.tblData.accessedRow.itemObject.CM_InvoiceLineDesc) then
			
			ild := self.tblData.accessedRow.itemObject.CM_InvoiceLineDesc; // TFS 40620
			foreach mapping in self.myCurrentQuantityRangeMap.allTMInvoiceLineMappings do : innerloop // TFS 40620
				if ild = mapping.myTMInvoiceLineDesc then // TFS 40620
					self.tblData.selectRow(row,true);
					if toprow = 0 then // TFS 7496
						toprow := row; // TFS 7496
					endif;
					break innerloop;
				endif;
			endforeach;
		endforeach;
		if toprow &gt; 0 then // TFS 7496
			self.tblData.topRow := toprow; // TFS 7496
		endif; // TFS 7496
		self.txtFrom.text := self.myCurrentQuantityRangeMap.rangeStart.String;
		self.txtTo.text := self.myCurrentQuantityRangeMap.rangeEnd.String;
		
		// Set the grouping from the first, they are all the same
		foreach map in self.myCurrentQuantityRangeMap.allTMInvoiceLineMappings discreteLock do
			if map.myTMInvoiceLineGroupType.isTypeAll then
				self.optGroupAll.value := true;
			elseif map.myTMInvoiceLineGroupType.isTypeHigh then
				self.optGroupGreatest.value := true;
			elseif map.myTMInvoiceLineGroupType.isTypeLow then
				self.optGroupLeast.value := true;
			endif;
			
			break;
			
		endforeach;
	endif;
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboQuantityType" id="a46ae2f2-87bb-4705-9707-7987f20698fd">
        <source>doBuildComboQuantityType();
/*
Purpose:			
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
11/09/2017   	cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
*/

vars

	tmp : Integer;
	haveVTMIS : Boolean;
	haveCARGO : Boolean;
	aCT, defaultCT : CM_CalculationType;
	tmpDesc : String;
begin
	/* // ### JIRA 33505 03DEC2024 NAVAB1
	haveVTMIS := app.myRoot.canDo(Mod_Harbour) ; // VTMIS License //06.10.2017	cnwma1  TFS #7257
	haveCARGO := app.myRoot.canDo(Mod_Container); // CONTAINER LICENSE
	*/
	self.cmbQuantityType.clear;
	self.cmbQuantityType.sorted := true; 

	if self.myAllocation.isKindOf(CM_InvoiceInventoryAllocation) then // ### TFS 51219 03JUN2021 NAVAB1

		foreach aCT in app.myRoot.allCalculationTypesByCode do
			if not aCT.isInventoryType then
				continue;
			endif;

			tmpDesc := aCT.description; 
			
			self.cmbQuantityType.addItem(tmpDesc);
			tmp := self.cmbQuantityType.findString(1, tmpDesc);
			
			self.cmbQuantityType.itemData[tmp] := aCT.calculationType;
			self.cmbQuantityType.itemObject[tmp] := aCT;
			
			if aCT.code = "INV400" then
				defaultCT := aCT;
			endif;
		endforeach;
	
	else

		foreach aCT in app.myRoot.allCalculationTypesByCode do
			if not aCT.isCargoCalcType then // TFS 39198
				continue;
			endif;

			tmpDesc := aCT.description; //11/09/2017 cnwma1 TFS #6897
			
			self.cmbQuantityType.addItem(tmpDesc);
			tmp := self.cmbQuantityType.findString(1, tmpDesc);
			
			self.cmbQuantityType.itemData[tmp] := aCT.calculationType;
			self.cmbQuantityType.itemObject[tmp] := aCT;
			
			if aCT.code = "CCT00" then
				defaultCT := aCT;
			endif;
		endforeach;
	endif;
	
	if defaultCT &lt;&gt; null then
		self.cmbQuantityType.listObject := defaultCT;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doNew" id="7954a03b-6dc4-4ccf-b3e0-c7c4eb2285c1">
        <updating/>
        <source>doNew()  updating;
/*
Purpose:			
Date		Who		Reason
23 March 2015	cnwab1	Initial creation
*/

vars

begin
	self.updateMode := false;
	
	self.txtFrom.text := "";
	self.txtTo.text := "";
	self.chkMaximum.value := false;
	
	self.tblData.deselectAll();

	if self.myAllocation &lt;&gt; null then
		self.lblDescription.caption := self.myAllocation.description &amp; " " &amp; app.getErrorString(InvCargoAllocMapNEW);
	endif;
	self.setForNew(); // TFS 7496
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNoMaintPermDisableControls" id="8829e6ce-eff0-46a6-afd4-f5b2b000af04">
        <source>doNoMaintPermDisableControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin
	
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.btnNew.enabled := false;
	self.btnSave.enabled := false;
	self.btnSaveNext.enabled := false;
	self.grpQuantityMap.enabled := false;
	self.grpQuantity.enabled := false;	
	self.tblData.userInputEnabled := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="07a09ca0-b574-482f-9db6-cdb7f8e43f06">
        <updating/>
        <source>doSave(_close : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
*/

vars
	pxyQM : CM_QuantityMap;
	pxyQRM : CM_QuantityRangeMap;
	sb : CM_CargoServiceBroker; // ### TFS 51219 25MAY2021 NAVAB1
	theReturn, mapType : Integer;
	gt : CM_TranMapInvoiceLineGroupType;
	bu : CM_Bank;
begin

	sb := self.myAllocation.myServiceBroker.CM_CargoServiceBroker; // ### TFS 51219 25MAY2021 NAVAB1
	bu := sb.getBank();
	
	if updateMode then // UPDATE
		beginLoad;
		pxyQM := sb.myChildQuantityMap.pxyCreateUpdateProxy().CM_QuantityMap;
		if self.myCurrentQuantityRangeMap &lt;&gt; null then 
			pxyQRM := self.myCurrentQuantityRangeMap.pxyCreateUpdateProxy().CM_QuantityRangeMap;
		endif;
		endLoad;
	else // CREATE
		beginLoad;
		pxyQM := sb.myChildQuantityMap.pxyCreateUpdateProxy().CM_QuantityMap;
		endLoad;
		create pxyQRM transient;
	endif;
	
	if optSingle.value then
		mapType := CM_QuantityMap.MapType_Single;
	else
		mapType := CM_QuantityMap.MapType_Escalate;
	endif;
	
	if self.optGroupAll.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeAll);
	elseif self.optGroupGreatest.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeHigh);
	elseif self.optGroupLeast.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeLow);
	endif;
	
	pxyQM.setProxy(sb,self.chkChargeZero.value, mapType,self.cmbQuantityType.listObject.CM_CalculationType, null);
	pxyQRM.setProxy(sb.myChildQuantityMap,txtFrom.text.Integer, txtTo.text.Integer, 0);
	pxyQRM.setProxyInvoiceLineTypes(self.tblData.allSelectedObjects, gt);
	
	while true do
		app.myTrxUA.trxUpdateInvoiceCargoAllocMap(updateMode, pxyQM,pxyQRM, sb ); 
		if app.myPassport.trxCompletedOK then
			global.beep;
			if _close then
				self.unloadForm();
			endif;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Allocation),  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;


epilog
	delete pxyQRM;
	delete pxyQM;
end;</source>
        <Parameter name="_close" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForNew" id="a65e55b1-8cb2-4d2a-9641-d6f60011cf2c">
        <source>setForNew();
/*

Purpose:			TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation

*/

vars
	qm : CM_QuantityMap;
	qrm : CM_QuantityRangeMap;
	sb : CM_CargoServiceBroker;
begin
	if self.updateMode then
		return;
	endif;
	
	self.chkChargeZero.value := false;
	self.optSingle.value := false;
	self.txtFrom.text := "0";
	self.txtTo.text := CM_QuantityRangeMap.MAX_RANGE.Integer.String;
	self.chkMaximum.value := true;
	self.optGroupAll.value := true;
	self.optSingle.value := true; 
	
	 // TFS 7496
	sb := self.myAllocation.myServiceBroker;
	if sb &lt;&gt; null then
		qm := sb.myChildQuantityMap;
		if qm &lt;&gt; null then
			qrm := qm.allQuantityRanges.last;
			
			if qrm &lt;&gt; null and qrm.rangeEnd &lt; CM_QuantityRangeMap.MAX_RANGE then
					self.txtFrom.text := (qrm.rangeEnd + 1).String;

			endif;
		endif;
	endif;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="57589e98-cede-4d93-a082-68c2a6390d76">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			
Date			Who		Reason
19 March 2015	cnwab1	Initial creation
04/05/2023		navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions
24/03/2025		navlw1	MTN-34434: MTN | Text Filter For Cargo Invoice Allocations
*/

vars
	filterControl : CMUI_ToolbarFrameTableFilter;
begin
	inheritMethod();
	
	// Start #JIRA-34434 navlw1 24/03/2025
	filterControl := self.txtFilterInvoiceLines;
	filterControl.visible := true;
	filterControl.setupControl(self.tblData, 300);
	// End #JIRA-34434 navlw1 24/03/2025
	
	self.btnOk.visible := false;
	self.btnCancel.visible := false;
	
	if self.myAllocation &lt;&gt; null then
		self.lblDescription.caption := self.myAllocation.description;
	endif;
	
	if updateMode then
		self.lblDescription.caption := self.lblDescription.caption&amp; " " &amp; app.getErrorString(InvCargoAllocMapUPDATE);
	else
		self.lblDescription.caption := self.lblDescription.caption&amp; " " &amp; app.getErrorString(InvCargoAllocMapNEW);
	endif;

	self.doBuildComboQuantityType();

	self.displayInvoiceLineTypes();

	self.displayQuantityMap();
	
	self.setForNew(); // TFS 7496
	
	if self.myAllocation.isKindOf(CM_InvoiceCargoAllocation) then // ### TFS 51219 25MAY2021 NAVAB1
		self.translateCaption(Xlat_0020323, null);
	else
		self.setCaption(app.getErrorString(Inventory_allocation_mapping)); // ### TFS 51219 25MAY2021 NAVAB1
	endif;
	
	// 04/05/2023	navkc1	Bug 57484
	self.doNoMaintPermDisableControls();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="366c7cd9-1982-44d6-b957-1a98fb0ec420">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 May 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	

	// The following code invokes text translation for controls defined on this form.
	if self.myAllocation.isKindOf(CM_InvoiceCargoAllocation) then // ### TFS 51219 25MAY2021 NAVAB1
		self.translateCaption(Xlat_0020323, locale);
	else
		self.translateCaption(Inventory_allocation_mapping, locale); // ### TFS 51219 25MAY2021 NAVAB1
	endif;
	
	btnClose.translateCaption(Xlat_0020346, locale);
	btnNew.translateCaption(Xlat_0020347, locale);
	btnSave.translateCaption(Xlat_0020324, locale);
	btnSaveNext.translateCaption(Xlat_0020325, locale);
	chkChargeZero.translateCaption(Xlat_0020326, locale);
	chkMaximum.translateCaption(Xlat_0020327, locale);
	grpLines.translateCaption(Xlat_0020328, locale);
	grpQuantity.translateCaption(Xlat_0020329, locale);
	grpQuantityMap.translateCaption(Xlat_0020692, locale);
	lblDescription.translateCaption(Xlat_0020330, locale);
	lblFrom.translateCaption(Xlat_0020331, locale);
	lblInvoiceLines.translateCaption(Xlat_0020332, locale);
	lblMappingType.translateCaption(Xlat_0020333, locale);
	lblQuantityType.translateCaption(Xlat_0020334, locale);
	lblTo.translateCaption(Xlat_0020335, locale);
	optEscalate.translateCaption(Xlat_0020336, locale);
	optGroupAll.translateCaption(Xlat_0020337, locale);
	optGroupGreatest.translateCaption(Xlat_0020338, locale);
	optGroupLeast.translateCaption(Xlat_0020339, locale);
	optSingle.translateCaption(Xlat_0020340, locale);
end;</source>
    </JadeMethod>
</GUIClass>
