    <JadeMethod name="initTables" id="1b72a410-58f4-441a-98a6-32bf8529f70d">
        <updating/>
        <source>initTables(pTbl : CM_BaseTable io; pFull : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 12 Jan 2026  navlc30     JIRA 36954 Story MTN | Highlight Mandatory fields
// ---------------------------------------------------------------------------
vars
	str	: String;
	idx	: Integer;
	entRow			: EntTableRow;	
begin

	pTbl.rows		:= 1;
	pTbl.fixedRows 	:= 1;
	
	if pFull then
		//pTbl.columns 	:= 13;			// PAR #31155
		//pTbl.columns 	:= 14;			// PAR #31155
		pTbl.columns    := 15;			//12.01.2026 navlc30 #36954
		pTbl.selectMode := Table.SelectMode_CurrentRow; // NAVAB1
	else
		pTbl.columns	:= 2;
	endif;
	
	pTbl.fixedColumns := 0;

	// add the heading row
	str := 'name' &amp; Tab &amp;
		   'heading';
	
	if pFull then
		str := str &amp; Tab &amp;
				 'shortHeading' &amp; Tab &amp;
				 'inputType' &amp; Tab &amp;		// refer InputType column below
				 'controlName' &amp; Tab &amp;
				 'webInputType' &amp; Tab &amp;
				 'terminologyType' &amp; Tab &amp;
				 'visible' &amp; Tab &amp;
				 'displayNullIfZero' &amp; Tab &amp;
				 'clickMethodName' &amp; Tab &amp;
				 'GotFocus Mth' &amp; Tab &amp;
				 'LostFocus Mth' &amp; Tab &amp;
				 'Error Return String' &amp; Tab &amp;
				 'Measurement Type' &amp; Tab &amp;			// PAR #31155	//12.01.2026 navlc30 #36954
				 'isMandatoryField';								//12.01.2026 navlc30 #36954
	endif;
	
	pTbl.accessCell(1, 1).text := str;

	foreach idx in 1 to pTbl.columns do
		if idx = Col_InputType or
		   idx = Col_InputTypeWeb or
		   idx = Col_TerminologyType or
		   idx = Col_MeasurementType then		// PAR #31155
			// Input Type column
			pTbl.accessColumn(idx).inputType := Table.InputType_ComboBox;
		elseif idx = Col_Visible or
		   idx = Col_DisplayNullIfZero or
		   idx = Col_IsMandatoryField then							//12.01.2026 navlc30 #36954
			pTbl.accessColumn(idx).inputType := Table.InputType_CheckBox;
		else
			pTbl.accessColumn(idx).inputType := Table.InputType_TextBox;
		endif;
	endforeach;

	
end;</source>
        <Parameter name="pTbl" type="CM_BaseTable" usage="io"/>
        <Parameter name="pFull" type="Boolean"/>
    </JadeMethod>
