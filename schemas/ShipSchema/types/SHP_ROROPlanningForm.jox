        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoCreateGCAread_click(menuItem: MenuItem input) updating;
/*
Purpose:			
Date		Who		Reason
05 August 2016	cnwab1	Initial creation
*/

vars
	locationLabel : String;
	x1,y1 : Decimal[12,2];
	ct : CM_CargoType;
begin
	// Cargo Position (top left) in metres
	x1 := (((self.origMouseX/self.scaleFactor)/ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre));
	y1 := (-1 *  ((ROROStructureCentreLine/ROROStructurePixelsPerMetre) - ((self.origMouseY/self.scaleFactor) /ROROStructurePixelsPerMetre)));
					
		


	app.msgBox("Click OK to Enter Location Id" &amp; CrLf &amp; "for the New GC Location" &amp; CrLf &amp; "at " &amp; x1.String &amp; "m x " &amp; y1.String &amp; "m","Create New GC Location",MsgBox_OK_Only);
	read locationLabel;

	if not self.myCurrentRORO.createQuickGCLocation(null,x1,y1,self.myCurrentDeck,locationLabel) then
		app.msgBox(app.getErrorString(GeneralCargo) &amp; " " &amp; app.getErrorString(Cargo_not_created),app.getErrorString(No_new) &amp; " " &amp; app.getErrorString(CMQF_GeneralCargo), MsgBox_OK_Only + MsgBox_Information_Icon);
		app.myPassport.inspect;
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
