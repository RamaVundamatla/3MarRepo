    <JadeMethod name="rmbTestFindLiterals" id="1e0119e6-44f8-4157-a661-78a334df472c">
        <source>rmbTestFindLiterals();

vars
	literals 	: HugeStringArray;
	startPosits : IntegerArray;
	meth 		: Method;
	str			: String;
	idx			: Integer;
	pos			: Integer;
	contextType	: String;
	contextItem	: String;
begin
	meth := currentSchema.getClass(JadeScript.name).getMethod(JadeScript::rmbMethodContainingLiterals.name);
	write meth;
	create literals transient;
	create startPosits transient;
	meth.findLiterals(literals, startPosits);

	foreach idx in 1 to literals.size do
		str := literals[idx];
		meth.getContextInCode(startPosits[idx], contextType, contextItem);
		app.writeStatement( Tab&amp; contextType&amp;Tab&amp; contextItem &amp;Tab&amp;Tab&amp; str);
	endforeach;

epilog
	delete literals;
	delete startPosits;
end;</source>
    </JadeMethod>
