<GUIClass name="CMUI_ComboCellularVessel" id="3794cf40-9ec1-49bf-979a-76244ae615b4">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="checkCanCreateVoyages" id="93bac0a5-be9d-4ae0-ae6e-45d19e2853c9">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isDisplayByName" id="c5771fbf-f16e-428d-8b9d-d78f64d5c34a">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="52734708-f936-42f5-9fde-8e9087f2213f">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>displayEntry(combobox: ComboBox input; _vesselStructure : CM_VesselStructure; lstIndex: Integer): String updating;
//-----------------------------------------
// Created: September 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpVessel : CM_Vessel;
begin
	if _vesselStructure = null then
		return null;
	endif;

	tmpVessel := _vesselStructure.myVessel;
	if tmpVessel = null then
		return null;
	endif;	
	
	if self.checkCanCreateVoyages then
		// Only display if voyages can be created for the vessel
		if (not tmpVessel.canCreateVoyages) then
			return null;
		endif;
	endif;
	
	if self.isDisplayByName then
		return tmpVessel.name &amp;  " - (" &amp; tmpVessel.code &amp; ")" ;
	else
		return tmpVessel.code &amp; Tab &amp; tmpVessel.name;		
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_vesselStructure" type="CM_VesselStructure"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="b4ec3eca-e08f-4c4c-8bab-4ecf02f7bcf3">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	07 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return app.myRoot.allVesselCellularStructures;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
