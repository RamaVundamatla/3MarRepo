    <JadeMethod name="writeHeaderToFile" id="c61cbb7f-e480-4f0d-9ae0-c83ba6d5d622">
        <source>writeHeaderToFile(file: File io; invoice: CM_Invoice);
// ### TFS 3551 - Added inward voyage code
// 11/04/2017	cnwdap1	TFS 4050 LNX Job ID Enhancements
constants
	FIELD_DELIMITER    = ",";
	//NUM_HEADER_FIELDS  = 78;
	//COLUMN_HEADINGS : String = "Customer code,Debtor name,Sequence no.,Description,Invoice from,Invoice to,User code,Date run,Purchase order,Tax code,Tax rate,General ledger year, General ledger period,Batch date,Entity code,Ledger code,Terminal,Terms of trade,Terms of trade code,Vessel name,Voyage code, Voyage inward code";
	NUM_HEADER_FIELDS  = 79;																																																																																	// TFS 4050
	COLUMN_HEADINGS : String = "Customer code,Debtor name,Sequence no.,Description,Invoice from,Invoice to,User code,Date run,Purchase order,Tax code,Tax rate,General ledger year, General ledger period,Batch date,Entity code,Ledger code,Terminal,Terms of trade,Terms of trade code,Vessel name,Voyage code, Voyage inward code,Voyage external code";		// TFS 4050
vars
	maximiseHeaderFields: StringArray;
	exportHeaderStr,str, tmp: String;
	d: Date;
	isZeroRatedTax : Boolean;
	taxRate : Real;
begin
	isZeroRatedTax := invoice.isZeroRatedTax ; // CCMS 1269
	 // CCMS 1172
	if isZeroRatedTax then
		taxRate := 0;
	else
		taxRate := invoice.bank.parentCompany.taxPercentageRate / 100;
	endif;

	
	//   cust_code
	exportHeaderStr := invoice.debtor.decfinName &amp; FIELD_DELIMITER;
	exportHeaderStr := exportHeaderStr &amp; invoice.debtor.name.String &amp; FIELD_DELIMITER;
	//   inv_num
	exportHeaderStr := exportHeaderStr &amp; invoice.sequenceNum.String &amp; FIELD_DELIMITER;
	//   purchase_code
	if invoice.voyageCode &lt;&gt; null then
		exportHeaderStr := exportHeaderStr &amp; invoice.voyageCode.String &amp; FIELD_DELIMITER;
	elseif invoice.invoiceType.description.toLower.pos("storage", 1) &lt;&gt; null then
		exportHeaderStr := exportHeaderStr &amp; "Storage" &amp; FIELD_DELIMITER;
	else
		exportHeaderStr := exportHeaderStr &amp;  FIELD_DELIMITER;
	endif;
	//   inv_date from
	exportHeaderStr := exportHeaderStr &amp; invoice.fromDT.date.shortFormatJMT() &amp;  FIELD_DELIMITER;
	//   inv_date to
	exportHeaderStr := exportHeaderStr &amp; invoice.toDT.date.shortFormatJMT() &amp;  FIELD_DELIMITER;
	//   User Code
	exportHeaderStr := exportHeaderStr &amp; app.getMyUserCode.trimRight &amp;  FIELD_DELIMITER;
	//   NOW
	exportHeaderStr := exportHeaderStr &amp; d.shortFormatJMT() &amp;  FIELD_DELIMITER;
	//   sale_code
	exportHeaderStr := exportHeaderStr &amp; invoice.debtor.purchaseOrderCode &amp;  FIELD_DELIMITER;
	
	// Tax Code
	if isZeroRatedTax then
		exportHeaderStr := exportHeaderStr &amp; "Z" &amp;  FIELD_DELIMITER;
	else
		exportHeaderStr := exportHeaderStr &amp; "A" &amp;  FIELD_DELIMITER;
	endif;

	// Tax Rate
	exportHeaderStr := exportHeaderStr &amp; taxRate.String &amp;  FIELD_DELIMITER;
	// GL Year/Period
	exportHeaderStr := exportHeaderStr &amp; invoice.decfinGLYear.String &amp; FIELD_DELIMITER &amp; invoice.decfinGLPeroid.String &amp;  FIELD_DELIMITER;
	exportHeaderStr := exportHeaderStr &amp; invoice.decfinBatchDate.shortFormatJMT()  &amp;  FIELD_DELIMITER;
	exportHeaderStr := exportHeaderStr &amp; invoice.decfinEntityCode.String  &amp;  FIELD_DELIMITER;
	exportHeaderStr := exportHeaderStr &amp; invoice.decfinLedgerCode.String  &amp;  FIELD_DELIMITER;
	if invoice.myTerminal &lt;&gt; null then
		exportHeaderStr := exportHeaderStr &amp; invoice.myTerminal.code.String  &amp;  FIELD_DELIMITER;
	else
		exportHeaderStr := exportHeaderStr   &amp;  FIELD_DELIMITER;
	endif;
	exportHeaderStr := exportHeaderStr &amp; invoice.termsOfTrade.String  &amp;  FIELD_DELIMITER;
	exportHeaderStr := exportHeaderStr &amp; invoice.termsOfTradeCode.String  &amp;  FIELD_DELIMITER;
	exportHeaderStr := exportHeaderStr &amp; invoice.vesselName.String  &amp;  FIELD_DELIMITER;
	
	
	

	exportHeaderStr := exportHeaderStr &amp; invoice.voyageCode.String  &amp;  FIELD_DELIMITER;
	
	// ### NOTE NO DELIMITER
	// TFS 3551
	if invoice.myVoyage &lt;&gt; null then
		exportHeaderStr := exportHeaderStr &amp; invoice.myVoyage.inwardCode;
		exportHeaderStr := exportHeaderStr &amp; FIELD_DELIMITER &amp; invoice.myVoyage.voyageCodeExternal;			// TFS 4050
	endif;
	
	file.writeLine(COLUMN_HEADINGS); //par 18567
	file.writeLine(exportHeaderStr);

epilog
end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="writeInvoiceLinesToFile" id="91c1f59d-bb5b-4658-a421-4caaa4b627b1">
        <source>writeInvoiceLinesToFile(file: File io; invoice: CM_Invoice);

constants
	FIELD_DELIMITER    = ",";
	NUM_HEADER_FIELDS  = 78;
	NUM_LINE_FIELDS    = 45;
	COLUMN_HEADINGS : String = "Customer code,Debtor name,Sequence no.,Quantity,Rate,GL code,Service name";
vars
	maximiseLineFields: StringArray;
	invLine: CM_InvoiceLine;
	charge: CM_Charge;
	glSumm : CM_GLSummaryByGLCodeRateDict;
	glStat : CM_GLSummary;
	str, tmp, exportLineStr: String;
//	cashTotal	: Decimal[12,2];
	d: Date;
	cashTotal	: Decimal[16,2];	//11 May 2018	NDL	TFS 38528
begin
	create glSumm;

	foreach invLine in invoice.invoiceLines do
		foreach charge in invLine.charges do
			charge.getGLRateSummaryStats(glSumm);
		endforeach;
	endforeach;

	file.writeLine(COLUMN_HEADINGS);  //par 18567

	foreach glStat in glSumm do
		exportLineStr := invoice.debtor.decfinName &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; invoice.debtor.name.String &amp; FIELD_DELIMITER;
		//   inv_num
		exportLineStr := exportLineStr &amp; invoice.sequenceNum.String &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; glStat.quantity.String &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; glStat.rate.String &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; glStat.glCode.String &amp; FIELD_DELIMITER;
		// ### NOTE NO DELIMITER
		exportLineStr := exportLineStr &amp; glStat.serviceName.String ;

		file.writeLine(exportLineStr);
	endforeach;

	// 32973 extract cash payments as well
	cashTotal := invoice.getCashPaid();
	if cashTotal &lt;&gt; 0 then
		exportLineStr := invoice.debtor.decfinName &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; invoice.debtor.name.String &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; invoice.sequenceNum.String &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; "1" &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; cashTotal.String &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; invoice.myTerminal.getConfig(CashACforGL).String &amp; FIELD_DELIMITER;
		exportLineStr := exportLineStr &amp; "" ;

		file.writeLine(exportLineStr);
	endif;
epilog
	glSumm.purge;
	delete glSumm;
end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="invoice" type="CM_Invoice"/>
    </JadeMethod>
</Class>
