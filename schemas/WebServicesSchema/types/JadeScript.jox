    <JadeMethod name="ndl50833" id="3dc58a73-789e-4be8-929c-cdd3162bc218">
        <source>ndl50833();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2021	navndl1	Initial creation	TFS 

*/

vars

	obj : Object;
	user : CM_User;
	appName : String; 

begin

	foreach obj in SWebServiceSchema.instances do
		user := obj.getPropertyValue("myUser").CM_User;
		appName := obj.getPropertyValue("appName").String;
		if user &lt;&gt; null then
			write user.code &amp; " " &amp; appName;
		else
			write"null user " &amp; appName;
		endif;
	endforeach;

epilog

end;</source>
