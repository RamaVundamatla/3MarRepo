    <JadeMethod name="cmbReleaseRequest_click" id="5ef8eab8-8cd3-4852-8693-b79d4b28e19c">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbReleaseRequest_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2022	navcs2	Initial creation
03 Feb 2023	navcs2	ChangeRequest 55440: EUP - Cargo Work Order Enhancements (54990)
25 Jan 2022 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
17 Apr 2023	navhl20 ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
24 Apr 2023	navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
03 Jul 2023 navma1  ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation
01 Nov 2023 navhl20 Bug 61057: EUP - Invalid Property exception when selecting a Pack Task to the already existing Work Order
19 Dec 2023 navhl20 Bug 61242: EUP | Release Cargo Work order progress not based on the Total Quantity of the cargo items
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
12 Aug 2024 navhl20	Bug 65586: Pack Work order - Issues
*/
vars
	release : CM_BulkRelease;
begin
	if self.cmbReleaseRequest.listObject = null then
		//self.btnSelectCargo.enabled 		   	:= false;										//03.07.2023 navma1 #58849
		self.btnAttachCargo.enabled 			:= false;
		self.cmbReserveDetail.clear();															//17.04.2023 navma1 #57324:[57325]
		self.cmbReserveDetail.listObject        := null;										//17.04.2023 navma1 #57324:[57325]
		self.btnMaintainRelease.caption 		:= "Add Release Request";						//30.03.2023 navcs2 #55440:[54990]
	else
		release := self.cmbReleaseRequest.listObject.CM_BulkRelease;
		self.btnMaintainRelease.caption 		:= "Edit Release Request";						//30.03.2023 navcs2 #55440:[54990]
		if release.releaseByType then															//29.03.2023 navcs2 #55440:[54990]
			self.cmbReserveDetail.visible 		:= true;										//29.03.2023 navcs2 #55440:[54990]
			self.lblReserveDetail.visible 		:= true;										//29.03.2023 navcs2 #55440:[54990]
			self.btnSelectCargo.enabled 		:= false;										//29.03.2023 navcs2 #55440:[54990]
			self.btnSelectChildCargo.enabled    := self.btnSelectCargo.enabled;					//17.04.2023 navma1 #55442:[54989]
			self.btnAttachCargo.enabled 		:= false;										//29.03.2023 navcs2 #55440:[54990]
			if self.myPxyTask.isKindOf(CM_WodRelease) then										//18.04.2023 navhl20#55442[57629]
				self.buildCmbReserveDetails(release);
			endif;																				//18.4.2023 navhl20 #55442[57629]
		else
			self.cmbReserveDetail.visible 		:= false;										//29.03.2023 navcs2 #55440:[54990]
			self.lblReserveDetail.visible 		:= false;										//29.03.2023 navcs2 #55440:[54990]
			self.cmbReserveDetail.listObject    := null;										//19.12.2023 navhl20 #61242
			self.btnSelectCargo.enabled 		:= not self.isApproved;							//18.04.2023 navhl20#55442[57629]
			self.btnSelectChildCargo.enabled    := self.btnSelectCargo.enabled;					//17.04.2023 navma1 #55442:[54989]
		endif;																					//29.03.2023 navcs2 #55440:[54990]
		self.btnAttachCargo.enabled 			:= self.btnSelectCargo.enabled;					//06.03.2023 navma1 #56457:[56458]
	endif;
	if self.tblItems.visible then																//01.11.2023 navhl20 #61057
		self.loadItemTable(combobox.listObject); 												//25.1.2023 navhl20 #55443[54991]
	endif;
	
	self.maintainBtnAttachCargo();																//30.03.2023	navcs2  #55440:[54990]
	if self.myPxyTask.isKindOf(CM_WodRelease) and 												//18.4.2023 navhl20 #55442[57629]
	release &lt;&gt; null and																			//19.7.2023 navhl20 #59175
	release &lt;&gt; self.myPxyTask.CM_WodRelease.myReleaseRequest then								//30.03.2023	navcs2  #55440:[54990]		
		self.resetProxyTaskTIs();																//30.03.2023	navcs2  #55440:[54990
		self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.clear();								//17.4.2023 navhl20 #57322[57323]
	endif;																						//30.03.2023	navcs2  #55440:[54990]
	
	if self.myPxyTask.isKindOf(CM_WodPack) and release &lt;&gt; null then 							//18.4.2023 navhl20 #55442[57629]	//05.07.2024 navhl20 #61368
		self.cmbPackVoyage.setObject(release.myVoyage);
		self.cmbPackOperator.resetCollectionForVoyage(release.myVoyage);
		self.cmbPackOperator.setObject(release.myOperator);
		if release.myDischargePort &lt;&gt; null then													//12.08.2024 navhl20 #65586
			self.cmbPackDishPort.setObjectFromCodeAndVoyage(release.myDischargePort.code, release.myVoyage);
		endif;
		self.buildCmbReserveDetails(release);
	endif;
	
	
	/*
		Reload Todo List 
		17.04.2023 navma1 #57324:[57325]
	*/
	self.cmbReserveDetail_click(self.cmbReserveDetail);		

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbReserveDetail_click" id="b3bb8b7a-8a39-4a48-8b0a-c027b1b1b1d4">
