    <JadeMethod name="getID" id="db9ccde5-7bbe-48c2-8dcc-d40b0d75c832">
        <source>getID(): String;
// ---------------------------------------------------------------------------
// Created:     14 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myGridArea = null then
		return self.ident;
	endif;
	
	return self.myGridRow.label.trimBlanks &amp; " O/H";
end;</source>
