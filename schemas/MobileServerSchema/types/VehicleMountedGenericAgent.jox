    <JadeMethod name="setupTableHeadings" id="f4106d66-5cce-4aa4-99da-dc0ac14efc60">
        <updating/>
        <source>setupTableHeadings(_table : Table input) updating;
/*
Purpose:			

Parameters:	 _headerIsTopColumn if true set header on the first row for each column
			if falsee header is the first column down each row

Return Value:		

Date		Who		Reason
13/04/2010	cnwer1	Initial creation
04/04/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Impeial Measurements - show default measurement short name in row heading
*/

vars
	entTableRow : EntTableRow;
	entTableView : EntTableView;
	i, numFields			 : Integer;
	heading		 : String;
	headerIsTopRow : Boolean;
	tableType 		: Integer;
	measure			: CM_MeasurementType;		// PAR #31155
begin

	if self.myVMInterface = null then
		return;
	endif;

	self.myVMInterface.getTableOrientation( _table, headerIsTopRow);

	entTableView:=self.getEntTableView(_table);
	numFields:=entTableView.allEntTableRows.size + self.myVMInterface.sortTableInRTQueueOrder(_table).Integer;
	if headerIsTopRow then
		_table.columns := numFields;
		_table.rows:=1;
	else
		_table.rows := numFields;
		_table.columns:=1;	
	endif;
	_table.userObject:=entTableView;
	i:=1;
	foreach entTableRow in entTableView.allEntTableRows do																																			// PAR #31155
		heading:=entTableRow.getHeading(null, self.myTerminal, app.myCurrentLocale);
																																					// PAR #31155
		if headerIsTopRow then
			_table.accessColumn(i).itemObject:=entTableRow;
			_table.accessCell(1,i).text:=heading;
			_table.accessColumn(i).visible:=true;
		else
			_table.accessRow(i).itemObject:=entTableRow;
			_table.accessCell(i,1).text:=heading;
			_table.accessRow(i).visible:=true;
		endif;
		i:=i+1;
	endforeach;
	
	if not headerIsTopRow then
		//epr par 30678 5/11/12 changed margin from 20 to a smaller 5
		_table.accessColumn(1).marginLeft:=5;
		_table.fitColumnWidth(1,5);
		
	endif;

	self.doToggleSortOrder(_table);
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="startNotes" id="6b9aa1e6-5e84-468a-bc99-49cd500f7167">
