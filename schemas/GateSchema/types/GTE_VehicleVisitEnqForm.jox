    <JadeMethod name="showSubCarrierUpdateForm" id="6c3d37f3-86d6-4832-9e7b-6e01a035b29a">
        <source>showSubCarrierUpdateForm(vvr : CM_VehicleVisitRecord);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN

*/

vars
	frm : GTE_SubCarrierUpdateForm;
begin
	app.mousePointer := MP_HOURGLASS;

	create frm;
	frm.myCurrentVvr  := vvr;
	frm.myTerminal := self.myTerminal;
	
	frm.createMyAssistant(GTE_Assistant);
	
	frm.show;

epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
