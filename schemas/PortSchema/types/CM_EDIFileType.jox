    <JadeMethod name="processFileData" id="37687653-30c4-4201-9884-576c99d24557">
        <updating/>
        <source>processFileData(_ediFile: CM_EDIFile input; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	30 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 01 Augg 2012	cnwcs5	par 30136 - change usage of _file parameter
//14 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
// 23 Feb 2018	jlgrs1	TFS 36963 - add tranlog timings
// 17 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	tmpStr : String;
begin

	tmpStr := method.qualifiedName;
	app.writeLog(tmpStr&amp;' '&amp;_ediFile.fileName, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	self.cnStartTransaction(tmpStr[1:60]);

	self.processFile(_ediFile);
//	_ediFile.ediData.doTranslations();	
		
	if (_passport.myCMIFMonitor &lt;&gt; null) then
		_passport.myCMIFMonitor.updateProgress("Processing file", 1, 1);
	endif;
epilog
	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processSenderRecipientSeq" id="5386e043-3e3d-486e-872d-a7e3ab762f7a">
        <updating/>
        <source>processSenderRecipientSeq(_rawSenderCode, _recipientCode, _fileType, _version, _fileName : String; _creationTS : TimeStamp; _sequence : String; _ediData : CM_EDIData; _terminal : CM_Terminal) : Boolean updating;
//
//16 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
//19 Nov 2015	cnwrs1	Par 37206 - EDI return true as default
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	ediSenderRecipFileType : CM_EDISenderRecipFileType;
	proxy, real : CM_EDISenderRecipFileType;
	sequence : Integer;
	result : Boolean;
	fileDateTime : TimeStamp;
begin
	result := true;
	sequence := _sequence.extractInteger;
	fileDateTime := null;
	if _creationTS.isValid then
		fileDateTime := _creationTS;
	endif;
	ediSenderRecipFileType := _terminal.allEDISenderRecipFileType[_rawSenderCode, _recipientCode, _fileType];
	if ediSenderRecipFileType = null then
		app.writeLog("Filedetails "&amp;_fileName&amp;" from "&amp;_rawSenderCode&amp;" to "&amp;_recipientCode&amp;" type "&amp;_fileType&amp;' '&amp;_version&amp;' '&amp;fileDateTime.String&amp;" seq "&amp;_sequence&amp;'.', LogINFO);
		create proxy transient;
		proxy.setProxy(fileDateTime, _fileType, _version, _fileName, _recipientCode, _rawSenderCode, false, false, false, _sequence);
		app.myUtilityCA.utlCreateEDISendRecipFileType(proxy, real, _ediData, _terminal, app.myPassport);
	else
		if sequence &lt;&gt; 0 and
		   app.isBackGroundApp and
			ediSenderRecipFileType.seqNumber = _sequence then
			// do nothing and dont write out filedetails this should only happen for files with multiple unb's
		else
			if sequence &lt;&gt; 0 and
			   app.isBackGroundApp and
			   ((ediSenderRecipFileType.seqNumber &gt; _sequence and
			     ediSenderRecipFileType.processInSeqOrder) or
				(ediSenderRecipFileType.fileDateTime &gt; fileDateTime and
			     ediSenderRecipFileType.processInDateOrder)) then
//				app.writeLog('Filedetails sender='&amp;_rawSenderCode&amp;' recipient='&amp;_recipientCode&amp;' '&amp;fileDateTime.String&amp;' '&amp;_sequence&amp;' '&amp;_fileType&amp;' '&amp;_version, LogAlways);
				app.writeLog("Filedetails "&amp;_fileName&amp;" from "&amp;_rawSenderCode&amp;" to "&amp;_recipientCode&amp;" type "&amp;_fileType&amp;' '&amp;_version&amp;' '&amp;fileDateTime.String&amp;" seq "&amp;_sequence&amp;" is out of sequence. Already processed "&amp;ediSenderRecipFileType.seqNumber.String, LogINFO);
				app.createAlert("File "&amp;_fileName&amp;" from "&amp;_rawSenderCode&amp;" to "&amp;_recipientCode&amp;" type "&amp;_fileType&amp;' '&amp;_version&amp;' '&amp;fileDateTime.String&amp;" seq "&amp;_sequence&amp;" is out of sequence. Already processed "&amp;ediSenderRecipFileType.seqNumber.String, true);
				result := false;
			else
				app.writeLog("Filedetails "&amp;_fileName&amp;" from "&amp;_rawSenderCode&amp;" to "&amp;_recipientCode&amp;" type "&amp;_fileType&amp;' '&amp;_version&amp;' '&amp;fileDateTime.String&amp;" seq "&amp;_sequence&amp;'.', LogINFO);
				proxy := app.myProxyManager.getProxyObject(ediSenderRecipFileType).CM_EDISenderRecipFileType;
				if proxy = null then
					beginLoad;
					proxy := ediSenderRecipFileType.pxyCreateUpdateProxy();
					endLoad;
				endif;
				if proxy &lt;&gt; null then
					proxy.setFileDetails(fileDateTime, _fileName, _sequence, _version);
					app.myUtilityUA.utlUpdateEDISendRecipFileType(proxy, _ediData, app.myPassport);
					app.myProxyManager.deleteProxyLink(proxy);
				else
					app.writeLog("Filedetails "&amp;_fileName&amp;" from "&amp;_rawSenderCode&amp;" to "&amp;_recipientCode&amp;" type "&amp;_fileType&amp;' '&amp;_version&amp;' '&amp;fileDateTime.String&amp;" seq "&amp;_sequence&amp;' lost my proxy.', LogINFO);
					result := false;
				endif;
			endif;
		endif;
	endif;
	return result;
epilog
	delete proxy;
end;
</source>
        <Parameter name="_rawSenderCode" type="String"/>
        <Parameter name="_recipientCode" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_version" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_creationTS" type="TimeStamp"/>
        <Parameter name="_sequence" type="String"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
