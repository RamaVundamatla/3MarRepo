    <JadeMethod name="updateJobRemoveStats" id="f3844c3a-d9d3-4a8e-a6e8-9a46d89043e8">
        <source>updateJobRemoveStats(_job : Object)  : CMIF_JobStats protected;
/*

Date		Who		Reason
21 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	jobSheetStats : CMIF_JobSheetStats;
	foundStats : CMIF_JobStats;
	tblStage : CM_DataTable;
	i 		: Integer;
begin
	
	foreach jobSheetStats in self.myVoyageStats.allJobSheetStats discreteLock do
		foundStats:=jobSheetStats.allJobStatsByJob[_job.CM_VoyageJob];
		if foundStats &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	if foundStats = null then
		return null;
	endif;
	
	i:= self.myVoyageStats.allJobSheetStats.indexOf(foundStats.myCMIFJobSheetStats);
	tblStage := self.tblStage.getControl(((i).String &amp; self.tblStage.tabIndex.String).Integer);
	
	if tblStage &lt;&gt; null then		
		tblStage.removeItemObject(foundStats);		
	endif;
	
	return foundStats;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_job" type="Object"/>
        <ReturnType type="CMIF_JobStats"/>
    </JadeMethod>
    <JadeMethod name="updateJobSheetTotals" id="dad5838a-a4db-4c53-b5ce-4db34bb336ac">
        <source>updateJobSheetTotals(_jobSheetStats : CMIF_JobSheetStats input) protected;
/*

Date		Who		Reason
12 April 2017	cnwer1	Initial creation TFS

*/

vars
	frmCrane : Frame;
	totalMovesComplete,
	totalMovesIncomplete : Integer;
	i : Integer;
	jobStats 		: CMIF_JobStats;
	lblMoveNum, lblMoveToDoNum : Label;
begin
	if _jobSheetStats = null then
		return;
	endif;
	
	i:= self.myVoyageStats.allJobSheetStats.indexOf(_jobSheetStats);
	frmCrane:= self.frmStage.getControl(((i).String &amp; self.frmStage.tabIndex.String).Integer);
	
	if frmCrane = null then
		return;
	endif;
	
	foreach jobStats in _jobSheetStats.allJobStatsByJob do
		totalMovesComplete:=totalMovesComplete + jobStats.completeMoves;
		totalMovesIncomplete:=totalMovesIncomplete + jobStats.incompleteMoves;
	endforeach;
	
	_jobSheetStats.setMovesCompleted(totalMovesComplete);
	_jobSheetStats.setMovesIncomplete(totalMovesIncomplete);

	lblMoveNum:= self.getClonedControl(self.lblMovesDoneNum,i, frmCrane).Label;
	lblMoveNum.caption:=_jobSheetStats.movesCompleted.asStringJMT;
	lblMoveToDoNum:= self.getClonedControl(self.lblMovesToDoNum,i, frmCrane).Label;
	lblMoveToDoNum.caption:=_jobSheetStats.movesIncomplete.asStringJMT;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_jobSheetStats" type="CMIF_JobSheetStats" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateJobStats" id="cc5b36f4-9f80-42f7-b41c-1f84733fbbb3">
        <source>updateJobStats(_job : CM_VoyageJob) protected;
/*

Date			Who		Reason
21 March 2017	cnwer1	Initial creation TFS
18 June	2019	jlgmd1	TFS 45232 - UE 14051 when updating job stats on Order Of Work Monitor form

*/

vars
	jobSheetStats : CMIF_JobSheetStats;
	jobStats		: CMIF_JobStats;
	tblStage 		: CM_DataTable;
	foreColour,backColour,
	theTopRow,
	i 				: Integer;
	selectedObj : Object;
	selectedIdx 	: Integer;
	hadException	: Boolean;
begin
	// Ignore any updates to rows via notifications which have been deleted/don't exist on our view
	on Exception do app.handleUE14051(exception, hadException);	//TFS 45232

	jobStats:=self.updateJobRemoveStats(_job.CM_VoyageJob);
	
	if jobStats &lt;&gt; null and  jobStats.myCMIFJobSheetStats.myJobSheet &lt;&gt; _job.myJobSheet then
		delete jobStats;
		jobStats:=null;
	endif;
	
	
	jobSheetStats:= self.myVoyageStats.allJobSheetStats[_job.myJobSheet];
	if jobSheetStats = null then
		return;
	endif;
	
	i:= self.myVoyageStats.allJobSheetStats.indexOf(jobSheetStats);
	tblStage := self.tblStage.getControl(((i).String &amp; self.tblStage.tabIndex.String).Integer);
	
	if tblStage = null then	
		return;
	endif;
	
	selectedIdx := tblStage.row;	
	selectedObj := tblStage.accessRow(tblStage.row).itemObject;

	//remove from table if there
	if jobStats &lt;&gt; null then
		jobStats.clearStats;
		_job.getJobStats(jobStats,self.myVoyageStats);
	else
		//create the stats
		create jobStats transient;
		jobStats.setMyJob(_job);
		_job.getJobStats(jobStats,self.myVoyageStats);
		jobStats.setDetails(jobSheetStats,null,null,null,null);
	endif;
	
	theTopRow := self.myCurrentVoyage.getOOWJobIndex(CMQF_VoyageOrderOfWork.JobType_Crane ,false, _job);
	theTopRow := theTopRow + tblStage.fixedRows;
	
	_job.getRowColour(foreColour, backColour);
	tblStage.addObjectAt(jobStats,theTopRow);
			
	tblStage.accessRow(theTopRow).backColor := backColour;
	tblStage.accessRow(theTopRow).foreColor := foreColour;
	
	tblStage.selectObject(jobStats, false);
	
	self.updateJobSheetTotals(jobSheetStats);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="updateWLEStats" id="676e2722-3d35-42db-92a6-df963cf653ad">
        <updating/>
        <source>updateWLEStats(_wle : CM_VoyageWLE) updating, protected;
/*

Date		Who		Reason
21 March 2017	cnwer1	Initial creation TFS

*/

vars
	jobSheetStats : CMIF_JobSheetStats;
	jobStats 		: CMIF_JobStats;
	foreColour,backColour,
	i				: Integer;
	tblStats : CM_DataTable;
begin
	if _wle = null then
		return;
	endif;
	
	jobSheetStats:= self.myVoyageStats.allJobSheetStats[_wle.myJobSheet];
	if jobSheetStats = null then
		return;
	endif;
	
	jobStats := jobSheetStats.allJobStatsByJob[_wle.job];
	if jobStats &lt;&gt; null then
		jobStats.clearStats;
		_wle.job.getJobStats(jobStats,self.myVoyageStats);
	endif;
	
	
	i:= self.myVoyageStats.allJobSheetStats.indexOf(jobSheetStats);
	tblStats := self.tblStage.getControl(((i).String &amp; self.tblStage.tabIndex.String).Integer);
	
	if tblStats = null then
		return;
	endif;	
	
	_wle.job.getRowColour(foreColour, backColour);
	tblStats.updateItemObject(jobStats,foreColour,backColour,app.myPassport);
	
	self.updateJobSheetTotals(jobSheetStats);
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ff175c76-beec-4104-9743-a7d8d8063957">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Date		Who		Reason
24 March 2017	cnwer1	Initial creation TFS

*/

vars
	event : Integer;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	if eventType = EVENT_WLE_COMPLETE and theObject = self.myCurrentVoyage then
		
		if userInfo.isKindOf(CM_VoyageWLE) then
			self.updateWLEStats(userInfo.CM_VoyageWLE);
		endif;
	elseif event = VoyageJob_Delete_Event  or not global.isValidObject(userInfo.Object) then 
		self.updateJobRemoveStats(userInfo.Object);		
	elseif userInfo.isKindOf(CM_VoyageJob) then
		//voyage job update i.e. reorder etc
		self.updateJobStats(userInfo.CM_VoyageJob);
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
