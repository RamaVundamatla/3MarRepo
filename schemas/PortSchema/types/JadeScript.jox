    <JadeMethod name="deleteTi" id="bcdb22ac-4b22-442a-9a1c-a75e63600bbd">
        <source>deleteTi();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jan 2025	navhl20 Task MTN-33743: MTN - 22.0.24.12 - Unit Tests Review - [3]

*/

vars
	ti : CM_CargoGroup;
	count : Integer;
begin
    foreach ti in CM_CargoGroup.instances do
		if ti.id = "OCLU0240556" or ti.id = "OCLU0240559" then
			count := count + 1;
			beginTransaction;
			delete ti;
			commitTransaction;
		endif;
	endforeach;
	write count;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteWO" id="c3f9fc2b-df58-4d3c-a206-11786b0ecf3b">
        <source>deleteWO();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2023	navhl20	Initial creation

*/

vars
	workOrder : CM_WorkOrder;
	term      : CM_Terminal;
	wod       : CM_WorkOrderDtl;
	job		  : CM_Job;
	jobArr    : CM_JobArray;
	terminal  : CM_Terminal;
begin
	create jobArr transient;
	
	foreach terminal in app.myRoot.allTerminals  do
		if terminal.code = "WO" then
			term := terminal;
		endif;
	endforeach;
	workOrder := term.allWorkOrders["CWO1286"];
	if workOrder &lt;&gt; null then
		
		foreach wod in workOrder.allWoDtls do
			
			if wod.isKindOf(CM_WorkOrderTIDtl) then
				foreach job in wod.CM_WorkOrderTIDtl.allJobs do
					jobArr.add(job);
				endforeach;
				
			elseif wod.isKindOf(CM_WorkOrderToDoDtl) then
				foreach job in wod.CM_WorkOrderToDoDtl.allJobs do
					jobArr.add(job);
				endforeach;
			endif;
		endforeach;
		
		beginTransaction;
		
		jobArr.purge();
		
		workOrder.erase(NORMAL_ERASE);
		
		commitTransaction;
	endif;
epilog
	delete jobArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteWP" id="097cd46e-4c7f-4d36-92de-6549067641c1">
