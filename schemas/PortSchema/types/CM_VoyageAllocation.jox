    <JadeMethod name="getIsEmpty" id="729f8347-8eb4-4f22-ad5e-21aaa4d97c7f">
        <source>getIsEmpty() : Boolean;
/*
Purpose:			
Date		Who		Reason
20 May 2014	cnwab1	Initial creation
*/

vars

	criteria : CM_YACriteria;	
	commGroup : CM_CommodityGroup;
	comm : CM_Commodity;
begin
	
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_CommodityGroup); 
	if criteria &lt;&gt; null then
		commGroup := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CommodityGroup;	
		if commGroup &lt;&gt; null then
			return commGroup.isEmptyCommodity();
		endif;
	else
		criteria := self.getCriteriaOfTypeValue(YACriteriaType_Commodity); 
		if criteria &lt;&gt; null then
			comm := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Commodity;	
			if comm &lt;&gt; null then
				return comm.isEmpty;
			endif;
		endif;
	endif;		


epilog

end;</source>
