    <JadeMethod name="setMyVoyage" id="8b79424f-4888-484c-9b0e-51f5e97edbe6">
        <updating/>
        <source>setMyVoyage(_voyage : CM_Voyage) updating;
/* ---------------------------------------------------------------------------
Created:     01 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	self.myVoyage := _voyage;
	if not self.isTransient and self.myVoyage &lt;&gt; null then
		self.myVoyage.causeEvent(EventTransaction_Create_Event,false,self);
	endif;
epilog

end;</source>
