    <JadeMethod name="getFloorTypeDisplay" id="e303cfc4-e43b-4736-9e63-c5af5e0ae00c">
        <source>getFloorTypeDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2025	navcs2	MTN-34843  Development - Fleet file Form implementation
*/

begin
	if self.floorType = null then		
		return app.getErrorString(FloorType_UndefinedDesc);
	endif;
	
	if self.floorType = CM_TILC.FloorType_Floored then
		return app.getErrorString(FloorType_FlooredDesc);
	elseif self.floorType = CM_TILC.FloorType_Skeleton then
		return app.getErrorString(FloorType_SkeletonDesc);
	endif;
	
	return app.getErrorString(FloorType_UndefinedDesc);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
