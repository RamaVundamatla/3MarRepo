    <JadeMethod name="updateTI" id="13784e66-dc13-4ba0-86f9-3266d5c065af">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2001 by cnwrs2
//
// Purpose:     Update TI fields.  This is assumed that the Transaction can NOT
//				be updated.
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1	PAR #25021 review use of isImport/isExport for tranships
// 22 Mar 2017	cnwrs1	TFS3577 update the receive date
// 20 Nov 2017	cnwkpd1	TFS 7466 - Make update of chilled dict more consistent
// 31 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
// 09 Dec 2019	jlgdap1	TFS 47334 JMT Refactor Seals Transactions (contd)
// 25 May 2024  navma1	ChangeRequest 63027: MTN - Improve Performance of Cargo Bulk Edit - Second Enhancement
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
vars
	ti				 : CM_TrackedItem;
	wsRequest 		 : BGP_AllocWSRequest;
begin
	inheritMethod(_passport);
	
	if self.type = TRANS_TYPE_CREATED then
		return;
	endif;
	
	ti := self.myTrackedItem;

	if ti = null then
		return;
	endif;
	

	ti.setReceivedDTfromTrxs();	//07 Dec 2017	NDL	TFS 8116
	
	ti.updateChilledDict();		//PAR 2984: Chilled reefer alarm
	
	ti.assignToDoTasks(false,_passport);

	if ti.isExport or ti.isTranshipItem then		// PAR #25021
		//11 Jul 2016	NDL	TFS 2296
		if self.myTerminal &lt;&gt; null and app.myPassport.myTerminal &lt;&gt; self.myTerminal then
			app.myPassport.setMyTerminal(self.myTerminal);
		endif;
		app.myUtilityCA.utlCreateEDIBGPRequest(ti.id, _passport);
	endif;
	
	// CCMS 1284
	// cnwdad1 23/09/2009 - PAR #19974.
	ti.myTerminal.actionEventRequestStops(ti, _passport);

	// CCMS 1318
	app.myHookAgent.runHookLinkPublic(HookType_ReceivalTransaction, ti.myTerminal, ti);
	
	if ti.isReefer then
		self.checkTimeOffPower(ti, _passport);
	endif;
	
	// CCMS 1295
	ti.evaluateFreeStorageDays(null,true);  // TFS 2937 added null		//28.05.2024 navma1 #64224 added false. JIRA 11720 changed to true
	
	//12 Jul 2017	NDL	TFS 5314
	// TFS 47334 only do seals transactions for cargo that wasn't a prenote - prenotes will already have had
	// seals transactions done in the gating in process
	if ti.hasSealTypes then															//25.05.2024 navma1 #63027
		if not ti.wasPrenotified then
			ti.createSealCheckTranForAllSeals( SEAL_CHECK_RECORDED, self );
		endif;
	endif;
		
	//04 Aug 2020	NDL	TFS 49869
	ti.createAllotracBGPRequest( self, wsRequest );
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
