<Class name="CM_QStrResourceTypeMethod" id="128a2b14-d9e2-4623-866c-21686ee445f5">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="2a0a06a3-a600-4313-9b08-6a3bd610df1c">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 September 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="2c50b357-5f2f-42c6-9583-8f7299c96b5c">
        <source>setComboValues(comboBox 				: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 September 2018
TFS#		: 40200
Function	: Populate comboBox List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	resourceType			: HMS_ResourceType;
	storeIdx				: Integer;
	idx						: Integer;
	selectStr				: String;
	str						: String;
	selectedResourceType	: HMS_ResourceType;
begin
	comboBox.clear();
	comboBox.sorted := true;
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	foreach resourceType in app.myRoot.allResourceTypes do		
		
		str := resourceType.code &amp; Tab &amp; ' (' &amp; resourceType.description &amp; ')';
		idx := comboBox.addItem(str);
		comboBox.itemObject[idx] := resourceType;
		
		if resourceType.code = selectStr then
			selectedResourceType := resourceType;
		endif;
	endforeach;
	
	storeIdx  := comboBox.findObject(selectedResourceType);
	if storeIdx &gt; 0 and storeIdx &lt; comboBox.listCount then
		comboBox.listIndex := storeIdx;
	endif;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="b756da50-0547-4569-9a07-7e3941b5bd82">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 September 2018
TFS#		: 40200
Function	: Populate Selection List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	resourceType			: HMS_ResourceType;
	selectionValue			: Integer;
	idx						: Integer;
	array					: ObjectArray;
begin
	
	table.rows := table.fixedRows;
	
	array := table.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach resourceType in app.myRoot.allResourceTypes do	
	
		selectionValue := 0;
		if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(resourceType.code) then
			selectionValue := 1;
			array.add(resourceType);
		endif;
		
		idx := table.addItem(selectionValue.String &amp; Tab  &amp; resourceType.code &amp; ' (' &amp; resourceType.description&amp; ')');
		
		table.accessRow(idx).itemObject := resourceType;
	endforeach;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="b0864ee1-1388-4196-bc1e-b2c62960b90d">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 September 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	resourceType	: HMS_ResourceType;
	str				: String;
	numRows			: Integer;
	idx				: Integer;
	strArray		: StringArray;

begin

	create strArray transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			resourceType := table.accessRow(idx).itemObject.HMS_ResourceType;
			strArray.add(resourceType.code);
		endif;
	endforeach;
	
	queryOperator.setSearchValue(strArray);

epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="88401157-f96e-4a2d-942a-e35df16d6853">
        <source>translateToDisplayValue(_value: Any): String;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 September 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	
	if _value.isKindOf(HMS_ResourceType) then
		if _value &lt;&gt; null then
			return _value.HMS_ResourceType.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	return null;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="4aade632-297c-4b10-9ff2-f5f30ffa8301">
        <source>translateToSearchValue(_value: Any): Any;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 September 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 		: Boolean;
	object			: HMS_ResourceType;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then		
			return _value;
		endif;

		if _value.isKindOf(HMS_ResourceType) then
			object := _value.HMS_ResourceType;
		endif;
		
		if _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
