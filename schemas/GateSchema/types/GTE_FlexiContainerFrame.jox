end;</source>
    </JadeMethod>
    <JadeMethod name="select" id="7e1fee8f-d94e-45b4-9ad7-f915d6a2d9dd">
        <updating/>
        <source>select() updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
