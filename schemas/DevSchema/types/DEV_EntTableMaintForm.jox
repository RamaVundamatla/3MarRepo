    <JadeMethod name="addDefRow" id="33faeffc-3f04-432c-8172-ceb01f960b70">
        <updating/>
        <source>addDefRow(pRow : EntTableRow) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newRow		: Integer;

begin

	if pRow &lt;&gt; null then
		newRow := tblDef.addItem(displayEntTableRow(pRow, false));
		tblDef.accessRow(newRow).itemObject := pRow;
	endif;

end;</source>
        <Parameter name="pRow" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="addViewRow" id="9da874b0-bb62-408e-a44d-c420fa5b97b0">
        <updating/>
        <source>addViewRow(pRow : EntTableRow) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newRow		: Integer;

begin

	if pRow &lt;&gt; null then
		newRow := tblView.addItem(displayEntTableRow(pRow, false));
		tblView.accessRow(newRow).itemObject := pRow;
	endif;

end;</source>
        <Parameter name="pRow" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="btnAddDefinition_click" id="3ed35860-9ff2-4c8d-9a43-7f657a53bbd2">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddDefinition_click(btn: Button input)updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.myCurrentGroup &lt;&gt; null then
		doAddDefinition();
	else
		app.msgBox("You first select a group.","",0);
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAddGroup_click" id="58056e6a-6ce8-4de2-af6e-b9df22d9058f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddGroup_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.doAddGroup();
			
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAddView_click" id="cd1c441a-3492-4b0f-bef7-0a0fddfc048e">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddView_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	viewName	: String;

begin
	
	
	if not self.checkViewName(viewName) then
		return;
	endif;
	
	self.initTables(tblView, false);
	self.enableViewEdit();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancelGroup_click" id="f91e5c43-12b8-425d-915d-8abc26df4846">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancelGroup_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.disableGroupEdit();
	self.setGroup(myCurrentGroup, self.currentSortKey);

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
