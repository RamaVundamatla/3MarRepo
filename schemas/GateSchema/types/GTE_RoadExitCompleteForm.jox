    <JadeMethod name="tbWorkEntryChange" id="a35b0778-e086-41a3-919e-e041fa3583d5">
        <updating/>
        <source>tbWorkEntryChange(_tbl : CM_DataTable io) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 25 June 2007
//
//----------------------------------------------------------------------

vars
	obj : CM_Object;
begin
	
	//self.myCurrentWLE := null;		

	obj := _tbl.accessRow(_tbl.row).itemObject.CM_Object;
	
	if self.myCurrentWLE = obj then
		return;
	endif;
	
	if not global.isValidObject(obj) then
		return;
	endif;
	
	if obj.isKindOf(CM_WorkListEntry) and self.myCurrentWLE &lt;&gt; obj then
		self.myCurrentWLE := obj.CM_WorkListEntry;
		self.doTblExtraInfo(obj);
	endif;
	
	self.setTblDataDetailCellText(_tbl);
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblReceivals_contextMenu" id="e2bcff27-b0b8-4c91-b261-1b639e4f2bd7">
