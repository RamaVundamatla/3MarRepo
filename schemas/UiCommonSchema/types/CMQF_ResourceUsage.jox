<Class name="CMQF_ResourceUsage">
    <JadeMethod name="setFromAgent" id="420bf8fc-4ec7-410f-8a09-1eeeccf500b0">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation	Par 23800

*/
// 03/03/2017 cnwrh7         TFS3515       #TEMPLATE FOR TASK "TRASPORTI" NOT RUN CORRECTLY
vars

begin

	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_Tasks) then
		_agent.getSelectedToDoTaskDescs( self.allToDoTaskDescs );
	endif;
	
	if _agent.isRowIncluded(ETRow_Voyage) then												//+TFS3515
		if _agent.useCurrentDefaultVoyage() then
			self.doUseAppDefaultVoyage := true;
		else
			self.doUseAppDefaultVoyage := false;
			self.setMyVoyage( _agent.getSelectedCellularVoyage() );
		endif;
		//self.setMyVoyage( _agent.getSelectedCellularVoyage() );					//-TFS3515
	endif;
	
	self.cargoId := _agent.getValueByNameIfVisible(ETRow_Id).String.toUpper()[1:20];
	
	self.bookingRef := _agent.getValueByNameIfVisible(ETRow_BookingReference).String.toUpper()[1:30];

epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
