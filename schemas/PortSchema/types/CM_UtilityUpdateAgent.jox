    <JadeMethod name="utlUpdateVoyageProcPelindo1" id="f5155f6a-7e35-4a81-9c67-939d9b8550d5">
        <source>utlUpdateVoyageProcPelindo1(_passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2018	jlgdap1		Initial creation TFS 38851 Voyage Statuses INAPORTNET
// 11/08/2018   cnwma1		ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
//
vars
	pxyProcess, realProcess, pelindoProcess : CM_VoyageProcess;

begin
	if CM_VoyageProcessPEL1.instances.isEmpty then
		delete pxyProcess;
		create pxyProcess as CM_VoyageProcessPEL1 transient;
		pxyProcess.setProxy(VoyageProcessPelindo1, "Pelindo 1",null,null,null,null, null, null);
		app.myUtilityCA.utlCreateVoyageProcess(pxyProcess, realProcess, app.myPassport);
		if not app.myPassport.noErrors then
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageProcessPEL1!!!", LogINFO);
			return;
		endif;
		pelindoProcess := realProcess;
	else
		pelindoProcess := app.myRoot.allVoyageProcesses[VoyageProcessPelindo1];
	endif;
	
	// in case there's been a change in status priority, get everything in priority order out of the way
	// Add 10000 to all priorities
	self.setupVoyageStatusMovePriority(pelindoProcess);
	
	// now create / update all statuses
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_VoyRequested, 		1, 		"Voyage Requested (Manual PKK)");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_VoyReqSubmitted, 	2, 		"ETMAL Calculated");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_VoyReqRejected, 	3, 		"Voyage Request Rejected");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_CargoReqPending, 	4, 		"Cargo Request Pending");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_CargoRequested, 	5, 		"Cargo Requested");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_CargoReqRejected, 	6, 		"Cargo Request Rejected");
	//epr 19/8/2018 decided not needed can just look at the work order status
	//self.setupVoyageStatus(pelindoProcess, Voyage_Status_FinPending,	 	7, 		"Cargo Request Financial Pending");  //11.08.2018 cnwma1	TFS #39698
	//self.setupVoyageStatus(pelindoProcess, Voyage_Status_FinRejected,	 	8, 		"Cargo Request Financial Rejected"); //11.08.2018 cnwma1	TFS #39698
	
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_ServicesPending, 	9, 		"Initial Marine Services Pending");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_InitSerRequested, 	10, 	"Initial Marine Services Requested");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_ApprovalPending, 	11, 	"Approval Pending");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_ApprovalRejected, 	12, 	"Approval Rejected");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_VoyageApproved, 	13, 	"Voyage Approved");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_VoyageArrived, 	14, 	"Voyage Arrived");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_CargoPreInvGen, 	15, 	"Cargo Pre-Invoice Generated");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_CargoTaxInvGen, 	16, 	"Cargo Tax Invoice Generated");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_DepServPending, 	17, 	"Departure Marine Services Pending");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_DepServRequested, 	18, 	"Departure Marine Services Requested");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_DepServApproved, 	19, 	"Departure Marine Services Approved");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_ServPreInvGen, 	20, 	"Marine Pre-Invoice Generated");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_ServTaxInvGen, 	21, 	"Marine Tax Invoice Generated");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_VesselDeparted, 	22, 	"Vessel Departed");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_VesselArchived, 	23, 	"Vessel Archived");
	self.setupVoyageStatus(pelindoProcess, Voyage_Status_VoyCancelled, 		24, 	"Voyage Cancelled");	//02 Aug 2018	NDL	TFS 39924
	
	// now check for any statuses left with priorities above 10000
	self.setupVoyageStatusDelPriority(pelindoProcess);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
