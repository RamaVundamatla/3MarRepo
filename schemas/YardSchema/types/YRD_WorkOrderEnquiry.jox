    <JadeMethod name="sysNotify" id="009f45e1-65e5-4acc-a57e-5e0248dba3e1">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24/08/2009	cnwrd1	Initial creation
25/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
16/12/2022	navma1  Bug 54234: MTN - Work Order Maintenance - Work Order tasks are duplicated when adding a todo task to the Receive Cargo
22/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
15 Apr 2024 navhl20 Bug 62758: EUP | FR | Work Order status - complete without loading all items
23 May 2024 navma1	Bug 64191: EUP - Lock and Freeze issue
23 May 2024 navma1	Bug 64255: MTN - Work Order Enquiry Screen Freeze due to notifications - Phase 1
*/

vars
	invalid : Boolean;
	obj		: Object;
	idx		: Integer;
begin
	
	//07/05/2025	navkc1 JIRA MTN-34592
	if self.notificationLevel = self.NoteLevelDoNotes then
		self.beginTimerForNotifications(theObject, eventType, eventTag, null);
	endif;
	
/* //07/05/2025	navkc1 JIRA MTN-34592 Use notification framework
	on Exception do app.handleDeletedObject(exception, theObject, invalid);	
	
	theObject.edition;
	
	if invalid then
		self.tblDataSysNotifyDelete(eventType, theObject, eventTag);			// 22/11/2023	navcs2	ChangeRequest 60866
		return;
	endif;
	
	/*
	23.05.2024 navma1 #64255
	*/
/*	if theObject.isKindOf(CM_WorkOrderTIDtl) then
		if theObject.CM_WorkOrderTIDtl.getTransport = TI_TRANSMODE_SHIP then
			return;
		endif;
	endif;
	
	obj := theObject;																					//15.04.2024 navhl20 #62758
	if self.enquiryType = self.EnqType_WorkOrder and theObject.isKindOf(CM_WorkOrderDtl) then			//15.04.2024 navhl20 #62758
		obj := theObject.CM_WorkOrderDtl.myParent;
	endif;
	
	if ( self.enquiryType = self.EnqType_Task  	   and obj.isKindOf( CM_WorkOrderDtl)) or
	   ( self.enquiryType = self.EnqType_WorkOrder and obj.isKindOf( CM_WorkOrder)) then
	
		if eventType = Object_Update_Event then
			self.tblDataSysNotifyUpdate(eventType, obj, eventTag);
		elseif eventType = Object_Create_Event then
			self.tblDataSysNotifyCreate(eventType, obj, eventTag);
		elseif eventType = Object_Delete_Event then
			self.tblDataSysNotifyDelete(eventType, obj, eventTag);
		endif;
	endif;
*/	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyCreate" id="2e0b9273-36e2-4f3f-aae9-835c627598bf">
        <updating/>
        <source>tblDataSysNotifyCreate(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24/08/2009	cnwrd1	Initial creation
25/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
16/08/2022	navcs2	Bug 54237: MTN - Work Order Maintenance - Lookup Work Order Type
15/12/2022  navcs2	ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
22/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
04/06/2025	navsp1  JIRA-34585 MTN | Work Order Enquiry Query Refactor
*/

vars

	theTable 		 : CM_DataTable;	
	include 		 : Boolean;
	theRow			 : Integer;
	theWO			 : CM_WorkOrder;
begin
	include := false;
	
	if _theObject.isKindOf( CM_WorkOrder) then		// TFS 38560 15.12.2022 navcs2	 #54698:[54264]			

		include := self.includeObject(_theObject.CM_WorkOrder);			            //JIRA-34585
		theWO   := _theObject.CM_WorkOrder;
	else
		if _theObject.CM_WorkOrderDtl.myParent &lt;&gt; null then
		
			include := self.includeObject(_theObject.CM_WorkOrderDtl.myParent);     //JIRA-34585
			theWO := _theObject.CM_WorkOrderDtl.myParent.CM_WorkOrder;
		endif;
	endif;

	if not include then
		return;
	endif;

	// 16/08/2022 navcs2 #54237 
	// TFS 38560 
	//15.12.2022 navcs2	 #54698:[54264]
	
	if not self.tblData.findObjectInRow(theWO, theRow) then		
		self.addRowToTable( theWO , self.tblData, self.filterVoyWOdtlTaskNos, self.filterCargoWOdtlTaskNos, self.filterToDoWOdtlTasksNos); //JIRA-34585
	endif;
	
	self.updateStatusBarCount();		// 22/11/2023	navcs2	ChangeRequest 60866

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyDelete" id="6ba8ec09-3614-49e3-9b28-37dfdb034fcd">
        <updating/>
        <source>tblDataSysNotifyDelete(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwrd1	Initial creation

*/

vars

begin

	self.removeFromTable(_theObject.CM_Object);
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyUpdate" id="f638dcda-5d62-41d1-b070-700f39f28c03">
        <updating/>
        <source>tblDataSysNotifyUpdate(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Aug 2009	cnwrd1	Initial creation
15 Dec 2022 navcs2	ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
16 Dec 2022	navma1  Bug 54234: MTN - Work Order Maintenance - Work Order tasks are duplicated when adding a todo task to the Receive Cargo
16 May 2024	navdap1	TFS 64055 EUP - lock/1038 when loading an EDI file while Work Order Screen is open
04 Jun 2025	navsp1  JIRA-34585 MTN | Work Order Enquiry Query Refactor
*/

vars

	workOrderDtl 		: CM_WorkOrderDtl;
	workOrder	 		: CM_WorkOrder;
	theRow		 		: Integer;
	dataLine		 	: String;
begin
	// somethings been update we need to find if we have it in the table and update.
	
	if _theObject.isKindOf(CM_WorkOrder) then
		workOrder := _theObject.CM_WorkOrder;
		workOrderDtl := null;
	else
		workOrderDtl := _theObject.CM_WorkOrderDtl;
		workOrder := workOrderDtl.myParent;
	endif;
	
	if self.isEnqType_WorkOrder and workOrderDtl = null then
		// TFS 64055 just store off the work order, don't update it now
		// Timer event is used to cater for notification floods
		self.allNotifiedWOs.addNoDuplicates(workOrder, false);
		
		// in work order mode with a work order so check and update if we are displaying
		//self.tblData.findObjectInRow(workOrder, theRow);

		//if theRow &gt; 0 then
		//	self.tblData.accessCell(theRow, 1).text := workOrder.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);	
		//	self.displayExtraInfoForObj(workOrder); // TFS 42401
		//endif;

	elseif self.isEnqType_Task then
	
		//if we have been sent a work order (i.e. no work order dtl)  then we want to update all of its details if they are in the list
		if workOrderDtl = null then
			foreach workOrderDtl in workOrder.allWoDtls do	
				// TFS 64055 just store the work order details, and deal with thm in a timer event
				// to prevent notification floods
				self.allNotifiedWODetails.addNoDuplicates(workOrderDtl, false);
				//self.tblData.findObjectInRow(workOrderDtl, theRow);	
				//if theRow &gt; 0 then
				//	self.tblData.accessCell(theRow, 1).text := workOrderDtl.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);			
				//endif;
			endforeach;
		endif;
		
		// else update the one work order detail.
		// TFS 46055 don't update yet, just store it
		self.tblData.findObjectInRow(workOrderDtl, theRow);
		if theRow &gt; 0 then
			self.allNotifiedWODetails.addNoDuplicates(workOrderDtl, false);
			//self.tblData.accessCell(theRow, 1).text := workOrderDtl.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);			
		endif;
		
		if self.includeObject( workOrder) then       //15.12.2022 navcs2 #56006:[56007]     //JIRA-34585
			foreach workOrderDtl in workOrder.allWoDtls do	
				// TFS 46055 store for later dealing with in a timer event
				self.allNotifiedWODetails.addNoDuplicates(workOrderDtl, false);
				
				//dataLine := workOrderDtl.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				//self.tblData.removeItemObject(workOrderDtl);
				//self.tblData.accessRow(self.tblData.addItem(dataLine)).itemObject := workOrderDtl;
			endforeach;	
		endif;
	endif;


epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="ffeb8e96-20e4-43a7-9c4a-6c40447d45a9">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Mar 2022	navma1	Initial creation
24 Mar 2023	navhl20	ChangeRequest 57315:[57316] EUP - [Framework] - Allow Text filtering on the work order screen
16 May 2024	navdap1	TFS 64055 EUP - lock/1038 when loading an EDI file while Work Order Screen is open
*/

vars
	workOrder : CM_WorkOrder;
	workOrderDtl : CM_WorkOrderDtl;
	tblRow : Integer;
	dataLine : String;
	option, timeRemaining : Integer;

begin
	
	inheritMethod(eventTag); //07/05/2025	navkc1 JIRA MTN-34592 using notification framework
	
	/*
	//25/06/2024	navkc1 CR 64823 Task 64824
	if eventTag = self.Timer_TableData_Filter then		//24.3.2023 navhl20	#57315[57316]
		self.doFilterTable();
		*/
	// TFS 64055 start
/*	//07/05/2025	navkc1 JIRA MTN-34592 using the notification framework
	if eventTag = self.Timer_Notification then
		// we've been storing notified objects in 2 sets - refresh the table from those sets now
		if self.isEnqType_WorkOrder then
			foreach workOrder in self.allNotifiedWOs do
				self.tblData.findObjectInRow(workOrder, tblRow);
				if tblRow &gt; 0 then
					self.tblData.accessCell(tblRow, 1).text := workOrder.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
					self.displayExtraInfoForObj(workOrder);
				endif;
			endforeach;
			self.allNotifiedWOs.clear;
			
		elseif self.isEnqType_Task then
			foreach workOrderDtl in self.allNotifiedWODetails do
				self.tblData.findObjectInRow(workOrderDtl, tblRow);	
				if tblRow &gt; 0 then
					self.tblData.accessCell(tblRow, 1).text := workOrderDtl.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				else
					dataLine := workOrderDtl.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
					self.tblData.accessRow(self.tblData.addItem(dataLine)).itemObject := workOrderDtl;
				endif;
			endforeach;
			self.allNotifiedWODetails.clear;
		endif;
		
	// TFS 64055 end
	endif;
*/	
epilog
/*	//07/05/2025	navkc1 JIRA MTN-34592 using the notification framework
	// TFS 46055 restart the timer
	if not self.getTimerStatus(self.Timer_Notification, option, timeRemaining) then
		self.beginTimer(500, Timer_OneShot, self.Timer_Notification);
	endif;
*/
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1d6012b0-f9ad-42af-b39c-c3fad0e94887">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 June 2025 09:55:42.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022690, locale);
	btnAttachments.translateCaption(Xlat_0024542, locale);
	btnClearFilterValues.translateBubbleHelp(Xlat_0027095, locale);
