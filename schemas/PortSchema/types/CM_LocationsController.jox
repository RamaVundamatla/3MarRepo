	self.offset40		:= _pxyLC.offset40;
	self.is40ft			:= _pxyLC.is40ft;
	self.is20ft			:= _pxyLC.is20ft;
	
	// cnwjk3 CCMS 1032 15/12/2008
	self.doorDirection := _pxyLC.doorDirection;

end;</source>
