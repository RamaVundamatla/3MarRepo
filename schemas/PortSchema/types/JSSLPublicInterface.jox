    <JadeMethod name="isJSSException" id="610a9ef6-d0cb-4490-af5c-444a2871fda6">
        <source>isJSSException(pTheException: Exception): Boolean;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		This method is for application schemas exception handling.  In most
//				cases, peer schemas will raise exceptions of type JSSException to
//				report any detected errors.  For the application schema to easily
//				determine whether their exception is a peer schema one or not, they
//				can simply call this method, and then treat the error according to
//				the application's needs.
//
// Parameters:	pTheException - The exception object.
//
// Returns:		True if the exception is a JSS exception, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pTheException).Boolean;
end;</source>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLicenseRegistered" id="ce5874bc-d929-44bc-a2a9-c7e928ba90c9">
        <source>isLicenseRegistered(pCustomerName:String; pProductCode:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 April 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether a license has been
//				registered for the requested Customer/Product name.
//
// Parameters:	pCustomerName - The name of the customer.
//				pProductCode - The unique code of the licensed product.
//
// Returns:		True if the Customer/Product is registered, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCustomerName, pProductCode).Boolean;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLicensed" id="4d896583-f2c5-4d29-8de7-944dc7ce176c">
        <updating/>
        <source>isLicensed(pCustomerName:String; pProductCode:String; pComponentId:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the specified product
//				component is registered for use.
//
// Parameters:	pCustomerName - The name of the customer to whom the product component
//				pProductCode - The unique code of the licensed product.
//					is registered.
//				pComponentId - The identifer of the product component.
//
// Returns:		True if the component is registered, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCustomerName, pProductCode, pComponentId).Boolean;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pComponentId" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLicensedEWS" id="b99ff529-ab2f-4af2-bfce-ffba77ba60a8">
        <updating/>
        <source>isLicensedEWS(pCustomerName:String io; pProductCode:String io; pComponentId:Integer; pExpDate : Date io) : Boolean updating;
/*
Purpose:	

Date		Who		Reason
16 December 2024	navab1	JIRA 33545
*/

vars
	lclDate : Date;
	candothis : Boolean;
	customerName:String; 
	productCode:String; 
	componentId:Integer;
begin
	customerName := pCustomerName;
	productCode := pProductCode;
	componentId := pComponentId;
	
	candothis :=  self.myServiceObject.sendMsgWithIOParams(method.name, customerName, productCode, componentId, lclDate).Boolean;

	pExpDate := lclDate;
	
	return candothis;
epilog

end;</source>
        <Parameter name="pCustomerName" type="String" usage="io"/>
        <Parameter name="pProductCode" type="String" usage="io"/>
        <Parameter name="pComponentId" type="Integer"/>
        <Parameter name="pExpDate" type="Date" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSubsLicensed" id="cb845f33-b746-45f4-9a03-6c9d2a8c25f8">
        <updating/>
        <source>isSubsLicensed(pCustomerName : String io; pProductCode : String io; pComponentId : Integer io; pExpDate : Date io):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

	retValue : Boolean;
	cutomerName : String;
	productCode:String;
	componentId : Integer;
	expDate : Date;

begin

	cutomerName := pCustomerName;
	productCode := pProductCode;
	componentId := pComponentId;
	expDate := null;

	retValue := self.myServiceObject.sendMsgWithIOParams(method.name, cutomerName, productCode, componentId, expDate).Boolean;
	
	pExpDate := expDate;
	
	return retValue;

epilog

end;</source>
        <Parameter name="pCustomerName" type="String" usage="io"/>
        <Parameter name="pProductCode" type="String" usage="io"/>
        <Parameter name="pComponentId" type="Integer" usage="io"/>
        <Parameter name="pExpDate" type="Date" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
