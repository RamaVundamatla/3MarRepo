    <JadeMethod name="btnTBRefresh_click" id="a789d055-2356-435d-a179-79d7e0207dba">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTBRefresh_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 09/08/2011	cnwcs5	CCMS MES 1033 - RORO KPI
vars
	voyage	:CM_Voyage;
	sheet	:Sheet;
	table	:Table;
begin
	voyage := self.myCurrentVoyage;
	
	if (voyage &lt;&gt; null) and (self.flipH = voyage.starboardBerthed) then
		self.btnTBFlipH_click(self.btnTBFlipH);
	else
		sheet := self.fldMain.topSheet;
		
		if sheet = self.shtProfile then
			self.sdf01.drawSelf();
			self.updateStats();
			self.doResize();
			
		elseif sheet = self.shtBays then
			table 		:= self.tblBays;
			table.rows 	:= table.fixedRows;
			
			self.showBayStats();
			
		elseif sheet = self.shtMoves then
			table		:= self.tblStats;
			table.rows 	:= table.fixedRows;
			
			self.showMoveStatsByJS();
			self.showHideDetail();
	
		elseif sheet = self.shtDelays then
			table		:= self.tblDelays;
			table.rows 	:= table.fixedRows;
			
			self.showDelaysStats();
		elseif sheet = self.shtROROMoves then
			self.tblROROMoves.rows 	:= 0;
			
			self.showROROMovesStats();
		elseif sheet = self.shtRORODecks then
			self.tblRORODecks.rows := 0;
			
			self.showRORODecksStats();
		endif;
		
		self.showTimings();
	endif;
epilog
	// belts &amp; braces to ensure no locks are left behind
	endLoad;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
