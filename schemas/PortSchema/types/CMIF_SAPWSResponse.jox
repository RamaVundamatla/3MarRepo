    </PrimAttribute>
    <JadeMethod name="delete" id="b3f0491f-43ca-4a16-8b34-21fd8eae7654">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	self.allItems.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getReferenceId" id="f5a9176e-f6cc-451b-ab32-71f99b70295d">
        <source>getReferenceId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

	item : CMIF_SAPReturnItem;
	pos : Integer;
	startPos : Integer;

begin

	//Looking for the value immediately after the text "Doc No" in the S record.

	foreach item in self.allItems do
		if item.type &lt;&gt; 'S' then
			continue;
		endif;
		pos := item.message.pos( "Doc No", 1 );
		if pos &gt; 1 then
			startPos := pos + 6;
			if startPos &lt; item.message.length then
				return item.message[ startPos : end ].trimBlanks;
			endif;
		endif;
	endforeach;

	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSoapTagForProperty" id="74a6c894-0b05-45f4-9468-483aa5507dda">
        <source>getSoapTagForProperty(_property: Property): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2019	jlger1	Initial creation

*/

vars

begin
	if _property = CMIF_SAPWSResponse::allItems then
		return "T_Return";
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromRealWSObject" id="1ecbd840-04d5-45be-a0fa-c22069eb91ef">
        <updating/>
        <source>setFromRealWSObject(_realWSObject: ImportedWebServiceProxy) updating;
/*

Purpose:			Special code for SAP only - all the responses have the same structure, so we're populating
					the contents using generic code.

Parameters:			

Return Value:		

Date		Who		Reason
08 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	realReturn		: Object;
	coll			: Collection;
	realItem		: Object;
	iter			: Iterator;
	item			: CMIF_SAPReturnItem;
	
begin
	inheritMethod(_realWSObject);

	self.status := _realWSObject.getPropertyValue("status").String;
	realReturn := _realWSObject.getPropertyValue("t_Return").Object;
	
	coll := realReturn.getPropertyValue("item").Collection;
	
	iter := coll.createIterator();
	while iter.next(realItem) do
		create item transient;
		item.type := realItem.getPropertyValue("type").String;
		item.message := realItem.getPropertyValue("message").String;
		self.allItems.add(item);
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_realWSObject" type="ImportedWebServiceProxy"/>
    </JadeMethod>
    <JadeMethod name="setValuesForSOAPFault" id="0d0cf822-5f56-43be-a39a-d8eef92a120f">
        <updating/>
        <source>setValuesForSOAPFault() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	item			: CMIF_SAPReturnItem;
	
begin
	inheritMethod();

	self.status := null;
	
	create item transient;
	item.type := "E";
	item.message := "Service returned a SOAP Fault";
	
	self.allItems.add(item);
	
epilog

end;</source>
    </JadeMethod>
</Class>
