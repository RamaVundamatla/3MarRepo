    <JadeMethod name="createBatNumbersInitial" id="06ae2db3-a31e-4d58-a5d3-d9fe8e65e5f3">
        <source>createBatNumbersInitial();
// ---------------------------------------------------------------------------
// Created:     11 March 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	nextBat : CM_BatNumber;
	idx		: Integer;

begin

	foreach idx in 1 to 99 do
		create nextBat persistent;
		nextBat.code := idx.padLeadingWith('0', 2);
		self.batNumbers.add(nextBat);
		nextBat.setMyTerminal(self);	
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="createBillOfLading" id="b8b556d1-4061-4928-b5f8-e0d24c0e98b3">
        <updating/>
        <source>createBillOfLading(_pxyBOL : CM_BOL; _passport : CM_Passport input) : CM_BOL updating;
//Takes a proxy copy of a tracked item, and adds it to the system.
//Returns the object created.
//We assume that the validate method has been called prior to calling this method.
vars
	newBOL : CM_BOL;
	tiDesc : String;
	vehicle : CM_Vehicle;
begin
	//----------------
	//If passed in oid is NOT a transient object, then complain.
	//----------------
	if _pxyBOL = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "Transient Object", null, null);
		return null;
	endif;
	
	//----------------
	//Does BOL already exist?
	//----------------
	if _pxyBOL.isKindOf(CM_BOLIn) then
		if self.allBOLsReceivedByTypeNumberDT.includesKey(_pxyBOL.bolType, _pxyBOL.number, _pxyBOL.dateTime) then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_Duplicate_BOL, _pxyBOL.bolTypeDesc, _pxyBOL.number, null, null);
		endif;
	elseif _pxyBOL.isKindOf(CM_BOLOut) then	
		if self.allBOLsReleasedByTypeNumberDT.includesKey(_pxyBOL.bolType, _pxyBOL.number, _pxyBOL.dateTime) then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_Duplicate_BOL, _pxyBOL.bolTypeDesc, _pxyBOL.number, null, null);
		endif;
	endif;
	
	//--------------------------------------------------------------
	//Check vehicle does not already have a bol on it with the same number
	//--------------------------------------------------------------
	if _pxyBOL.vehicle &lt;&gt; null then
		vehicle := _pxyBOL.myTerminal.vehicles[_pxyBOL.vehicle, ""];
		if vehicle &lt;&gt; null and not vehicle.allRoadJobs.isEmpty then
			app.setContinueCMExceptions(false);	
			vehicle.validateBOLNumber(_pxyBOL);
		endif;	
	endif;
	//----------------
	//Create the new object	
	//----------------
	create newBOL as (_pxyBOL.class) persistent;
	//---------------- 
	//Update object
	//----------------
	newBOL.setForCreate(_pxyBOL, _passport);

	return newBOL;
end;</source>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="createCarrier" id="18c499e9-e24d-4e97-9166-920075cedd7f">
        <updating/>
        <source>createCarrier(_carrierDesc : String; _passport : CM_Passport input) : CM_Carrier updating;
//12/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
vars
	newCarrier	: CM_Carrier;
	tmpCode		: String;
	proxyCarrier:CM_Carrier;	
begin

	tmpCode := _carrierDesc[1:10].toUpper;
	if app.myRoot.allCarriers[tmpCode] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, tmpCode, null, null);
		return null;
	endif;

	create proxyCarrier as CM_Carrier transient;
	//proxyCarrier.setProxy(tmpCode, _carrierDesc.toUpper, null, false, false, false, null, null, null, null);		//12/05/2022 navhl20 TFS 53430
	proxyCarrier.setProxy(tmpCode, _carrierDesc.toUpper, null, false, false, false, false, null, null, null, null);		//12/05/2022 navhl20 TFS 53430
	app.myUtilityCA.utlCreateCarrier(proxyCarrier, newCarrier, _passport);

	return newCarrier;
end;</source>
        <Parameter name="_carrierDesc" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="createCommitStringAlertWithSev" id="3f42d1cf-e032-414a-b9dd-cf0e4bf112db">
        <source>createCommitStringAlertWithSev(heading : String; detail : String; pSeverity :Integer);
// based on createAndCommitStringAlert
vars
	alert : CM_SystemAlert;
begin
	create alert;
	alert.details := heading;
	alert.addLogEntry(detail.trimRight);
	alert.setSeverity(pSeverity);
	alert.add();

	app.commitAlert();
end;
</source>
        <Parameter name="heading" type="String"/>
        <Parameter name="detail" type="String"/>
        <Parameter name="pSeverity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createDebtorTerminals" id="912d4d95-74d4-49f8-9adf-8ff7c8bf53cb">
        <source>createDebtorTerminals();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 October 2022	navcs2	Bug 55222: MTN - allDebtorsTerminal collection not updating for debtor when new Terminal Created

*/

vars
	debtorNode				: CM_DebtorNode;
	paymentType			 	: Integer;					
	usesCash 				: Boolean;
	currencyType 			: CM_CurrencyType; 
	locale 					: CM_Locale; 		
	defaultInvoiceJRW 		: String;
	theBank					: CM_Bank;
	rdg						: CM_RootDebtorGroup;
begin
	theBank := app.myRoot.myRootCompany;
	rdg := theBank.getRootDebtorGroup();
	
	foreach debtorNode in rdg.allChildDebtorNodes where debtorNode.isGroup = false do
		if not debtorNode.CM_Debtor.allDebtorTerminals.includesKey( self ) then
			paymentType			:= PaymentType_None; 
			usesCash 			:= false;
			currencyType 		:= null; 	
			locale 				:= null; 
			defaultInvoiceJRW 	:= null; 

			//debtorNode.CM_Debtor.createDebtorTerminal( self, usesCash, paymentType, currencyType, locale, defaultInvoiceJRW); 
			debtorNode.CM_Debtor.createDebtorTerminal( self, usesCash, paymentType, currencyType, locale, defaultInvoiceJRW, "", ""); //navra1 - TFS 57086 - 1st May 2023
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createDutyDocTerminalRoot" id="d6ddf848-aabd-4507-b118-7afb7f812939">
        <source>createDutyDocTerminalRoot();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	dutyDocRoot : CM_DutyDocRoot;
	dutyDocTerminalRoot : CM_DutyDocTerminalRoot;
begin
	dutyDocRoot:=app.myDutyDocRoot();
	
	dutyDocTerminalRoot:=dutyDocRoot.allDutyDocTerminalRoots[self];
	if dutyDocTerminalRoot &lt;&gt; null then
		return;
	endif;
	
	create dutyDocTerminalRoot persistent;
	dutyDocTerminalRoot.setForCreate(dutyDocRoot, self);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createJobSheets" id="8efc5bc2-d092-4f2f-9717-81231c281077">
        <updating/>
        <source>createJobSheets() updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 May 2023	navma1	ChangeRequest 57932:[54556] EUP - Delivery Dispatch [Framework] Required
// ---------------------------------------------------------------------------
vars
	jobSheet	: CM_JobSheet;

begin

	if self.isTransient then
		return;
	endif;

	if self.myRailJobSheet = null then
		create self.myRailJobSheet persistent;
		self.myRailJobSheet.initialise;
	endif;

	if self.myRoadJobSheet = null then
		create self.myRoadJobSheet persistent;
	endif;

	if self.myYardJobSheet = null then
		create self.myYardJobSheet persistent;
	endif;
	
	if self.myWOJobSheet = null then						//12.05.2023 navma1 #57932:[54556]
		create self.myWOJobSheet persistent;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createNullVoyage" id="5a4a5b2d-6c32-4573-8367-fc791a75f7f0">
        <updating/>
        <source>createNullVoyage() updating, protected;

vars
	theNullVoyage : CM_Voyage;
	theGraphic : CM_VoyageLayoutGraphic;
begin

	create theNullVoyage;
	
	theNullVoyage.setMyTerminal(self);
	theNullVoyage.setPropertyValue(CM_Voyage::code.name, NULL_VOYAGE_CODE);
	create theGraphic;
	theNullVoyage.setMyLayoutGraphic(theGraphic);
	self.addVoyageToDict(null, null, theNullVoyage);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createRoadJob" id="265a08f9-9182-4532-a204-aae6e2e6d9cb">
        <updating/>
        <source>createRoadJob(pRoadJobProxy : CM_RoadJob input; pUserObject : Object; _passport : CM_Passport input) : CM_RoadJob updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/1/01		AJA			Added code to set up the bat number in use
// 28/2/01		AJA			Removed direct ref to vehicle object
// ---------------------------------------------------------------------------
vars
	theJob		: CM_RoadJob;
	theVehicle	: CM_Vehicle;
	gate		: CM_Gate;
begin

	if (not pRoadJobProxy.isTransient) then
		self.raiseExceptionIfNotTransient(method);
		return null;
	endif;
	
	// Following code moved from CMIF_InOutCommon::actionForCreate to put in common place as this method is now
	// called from elsewhere (29 April 08)  RS2
	
	theVehicle := pRoadJobProxy.myVehicle;
	
	if theVehicle = null or theVehicle.isTransient then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, "Vehicle is null",null,self);
		return null;
	endif;

	gate := pRoadJobProxy.myGate;
	
	// If the road job is coming via a gate, then myGate will be set,
	// but if the road job has not been to a cut the roadTransAreaId will have the
	// interchange area the vehicle is located
	if gate = null and pRoadJobProxy.roadTransAreaId = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, "VTA/Gate is null",null,self);
		return null;
	endif;
	
	// cnwjk3 PAR 20923 29/10/09
	// If a job already exists, then we return that job, rather than create a new one.  This can happen for instance
	// if the road job has been created and subsequently, more cargo needs to be recorded for the same truck at the gate
	if theVehicle.allRoadJobs.size &gt; 0 then
		// Return the existing Road Job for the vehicle
		return theVehicle.allRoadJobs.first.CM_RoadJob;
	endif;
	
	//th2 added 22/01/07 - deadlocks on self.myRoadJobSheet.allJobsByOrder so:
	exclusiveLock(self.myRoadJobSheet);
	
	create theJob persistent;
	theJob.setForCreate(pRoadJobProxy, self);
	
	if theJob.batNumber &lt;&gt; null then
		theJob.validateBatNumber(true, pUserObject);
		
		if _passport.hasErrors then
			// The delete should not really be necessary as this should cause an 
			// abortTransaction which will delete the job created.  The delete is
			// done for completeness.
			delete theJob;
			return null;
		endif;
	endif;
	
	//updates the vehicles carrier from the road jobs carrier
	theJob.updateVehicleCarrier();

	if _passport.hasErrorsIgnored()  then // PAR 17703
//	if _passport.hasErrors then
		// The delete should not really be necessary as this should cause an 
		// abortTransaction which will delete the job created.  The delete is
		// done for completeness.
		delete theJob;
		return null;
	endif;

	
	//Gdansk work when road jobs created need to add them to the pre gate area
	
	
	//And create the VVR and first dwell time record
	
	self.myRoadJobSheet.addJob(theJob, 0);
	
	if _passport.isOpsViewEnabled(theJob.myTerminal) then
		theJob.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB, theJob);		 // ### TFS 51853 27AUG2021 NAVAB1
	endif;

	return theJob;
		
end;</source>
        <Parameter name="pRoadJobProxy" type="CM_RoadJob" usage="input"/>
        <Parameter name="pUserObject" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="createStringAlert" id="67d8510e-aa67-43ca-9ea1-70cf6569df3f">
        <source>createStringAlert(level : Integer; heading : String; detail : String);
/* AA 1/10/01: NFS 3814: Creates but does not commit an alert

*/
vars
	alert : CM_SystemAlert;
begin

	create alert;
	alert.details := heading;
	alert.addLogEntry(detail.trimRight);
	alert.setSeverity(level);
	alert.add;
end;</source>
        <Parameter name="level" type="Integer"/>
        <Parameter name="heading" type="String"/>
        <Parameter name="detail" type="String"/>
    </JadeMethod>
    <JadeMethod name="createSystemEquipmentChecks" id="7468ace0-8a20-475a-aea8-a4d3dafe9ffb">
        <source>createSystemEquipmentChecks();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/07/2010	cnwndl1	Initial creation	Par 24973
20/04/2015	cnwdap1	PAR #36094 CCMS 1413 Cold Store Enhancements - added ROAD_REL context
24/01/2023	jlika1	TFS 62138 62139 CUX | Add Voyage Live Ops Check types
*/

constants

vars

	pxyCargoCheck : CM_CargoCheck;
	realCargoCheck : CM_CargoCheck;
	cargoCheckValues : IntegerArray;
	value : Integer;
	doAddRailDamage : Boolean;
	
begin

	//18 Mar 2015	NDL	Par 35828
	doAddRailDamage := self.allCargoChecks[WAGON_CHECK_CONTEXT_PLACE_IN] = null;

	create cargoCheckValues transient;
	
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_GATE_REC);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_GATE_REL);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_RAIL_REC);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_RAIL_REL);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_SHIP_DISC);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_SHIP_LOAD);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_YARD);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_TRUKLOAD);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_TRUKUNLOAD);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_PACK);	//04 Jul 2011	NDL	Par 26476
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_UNPACK);//04 Jul 2011	NDL	Par 26476
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_TMANLOAD);	// CCMS MSL 1026
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_TMANDISC); // CCMS MSL 1026
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_ROAD_REC);	//07 May 2014	NDL	Par 34076
	cargoCheckValues.add(WAGON_CHECK_CONTEXT_PLACE_IN);	//11 Mar 2015	NDL	Par 35828
	cargoCheckValues.add(WAGON_CHECK_CONTEXT_PLACE_OUT);	//11 Mar 2015	NDL	Par 35828
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_ROAD_REL);		// PAR #36094
	cargoCheckValues.add(CONT_CHECK_CONTEXT_PACK);	//08 Mar 2017	NLD	TFS 3635
	cargoCheckValues.add(CONT_CHECK_CONTEXT_UNPACK);	//08 Mar 2017	NLD	TFS 3635
	cargoCheckValues.add(WAGON_CHECK_LOAD_COMPLETE); //19/10/2022 jlizm1 TFS 54118
	cargoCheckValues.add(TRUCK_CHECK_LOAD_COMPLETE); //13/09/2023 jlizm1 TFS 59985
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_VOYOP_LOAD);
	cargoCheckValues.add(CARGO_CHECK_CONTEXT_VOYOP_DISC);
	
	app.myPassport.setMyTerminal(self);
	create pxyCargoCheck transient;
	
	foreach value in cargoCheckValues do
		realCargoCheck := self.allCargoChecks[value];
		if realCargoCheck = null then
			pxyCargoCheck.setProxy( value, false, null, app.myPassport );
			app.myUtilityCA.utlCreateCargoCheck( pxyCargoCheck, realCargoCheck, app.myPassport );
		endif;
	endforeach;
	
	//18 Mar 2015	NDL	Par 35828
	if doAddRailDamage then
		// We did not alreday have the Wagon Placement Contexts,
		// But thety will have now been added, so we now need to add the 'Damage' Check Item if appropriate.
		// part of the 8.4.2 conversion
		self.doConsiderSetUpRailDamageCheck();
	endif;

epilog

	delete cargoCheckValues;
	delete pxyCargoCheck;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createTI" id="fd974d97-238a-445c-9726-4752e6ffebe0">
        <source>createTI(pCargoType : CM_CargoType; pTransient : Boolean) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     03 January 2001 by cnwrs2
//
// Purpose:     Creates a tracked item of the type specified
//
// Parameters:  The TI type to create.
//				Flag to indicate if ti created is persistent or transient
//
// Returns:     The TI created.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	class	: Class;

begin

	class := pCargoType.myClassToCreate;
	
	if pTransient then
		create ti as class transient;
	else
		create ti as class persistent;
	endif;
	
	ti.setCargoType(pCargoType.id);
	
	return ti;
	
end;</source>
        <Parameter name="pCargoType" type="CM_CargoType"/>
        <Parameter name="pTransient" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createTerminalAreaForOps" id="682e3e55-c0b1-4395-968a-31933fe2fdc9">
        <source>createTerminalAreaForOps() protected;
// ---------------------------------------------------------------------------
// Created:     14 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 17/09/2009	cnwcs5	ccms 1061 - change to create gate/interchange area rather than VTA
// 23/02/2010	cnwcs5	par 18061 - prompt for rfid tag
// 18/06/2010	cnwcs5	par 24418 - new parameter for setProxy method
constants
	GATE	= 'GATE';
	ICAREA	= 'ICA';
	AGATE	= 'AGATE';
vars
	pxyArea			:CM_YardInterchangeArea;
	area			:CM_TerminalAreaMaster;
	pxyGate, gate	:CM_Gate;
	pxyGateArea, gateArea	:CM_GateArea;
begin
	//create interchange area
	create pxyArea transient;
	pxyArea.setProxy (ICAREA, 'Default', self, false, false, CM_InterchangeArea.Access_VehicleMachines, null,  null, 0);// par 14428
	pxyArea.pxyCreateNewLane (true);
	
	app.myUtilityCA.utlCreateTerminalArea (pxyArea, area, app.myPassport);
	
	// create gate
	create pxyGate transient;
	pxyGate.setProxy (GATE, false, true, true, false, area.CM_YardInterchangeArea, self);	// 23/02/2010 cnwcs5 par 18061
	create pxyGateArea transient;
	pxyGateArea.setProxy (AGATE, 'Default', self, CM_GateArea.AreaType_A, true, false, 0);
	pxyGateArea.pxyCreateNewLane (true);
	pxyGateArea.pxyCreateNewLane (false);
	pxyGate.pxyAddGateArea (pxyGateArea, true, false);
	
	gate := app.myUtilityCA.utlCreateGate (pxyGate, app.myPassport);
	
	// update default gate for interchange area
	area.CM_YardInterchangeArea.setPropertyValue (CM_YardInterchangeArea::myDefaultOutGate.name, gate);
	
epilog
	delete pxyArea;									// 04/02/2014 cnmwh5
	delete pxyGate;									
	delete pxyGateArea;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createTrackedItem" id="456a2914-d3a8-41bb-be20-650bc5acf98c">
        <updating/>
        <source>createTrackedItem(_transientTI : CM_TrackedItem; _passport : CM_Passport input) : CM_TrackedItem updating;
//Takes a proxy copy of a tracked item, and adds it to the system.
//Returns the object created.
//We assume that the validate method has been called prior to calling this method.
/*
	When		Who		What
	----------	-------	------------------------------------------------------
	27/10/2009	cnwdap1	PAR #21360 set tracked item cargoType from the transient if they're different
	18/03/2010	cnwcs5	par 23159 - notification of booking reconciliation changes
*/
vars
	newTI : CM_TrackedItem;
begin
	//----------------
	//If passed in oid is NOT a transient object, then complain.
	//----------------
	if _transientTI = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "Transient Object", null, null);
		return null;
	endif;

	// if using deferred updates we do not want to lock the
	// ti dict at this stage so do not check unique id.  This
	// should have already been done in earlier validation
	if (not _passport.useTIDictDeferUpdate) then
		if not self.isTIUniqueIdCargoType(_transientTI, _passport) then
			//return here - we are now continuing exceptions for notified and
			//don't want to create a TI if there are errors
			return null;
		endif;
	endif;	
	//----------------
	//Create the new object	
	//----------------
	create newTI as (_transientTI.class) persistent;
	if newTI.cargoType &lt;&gt; _transientTI.cargoType then	// PAR #21360
		newTI.setCargoType(_transientTI.cargoType);		// PAR #21360
	endif;												// PAR #21360
	//---------------- 
	//Update object
	//----------------
	newTI.setForCreate(_transientTI, _passport);
	
	newTI.createBookingRefDiscrepEvent(); //24 Sep 2009	NDL	Par 20521 CCMS 1609 

	if newTI.myBookingRef &lt;&gt; null then	// par 23159
		app.myEventManager.createSingleObjInfoNoteEvt(newTI, self.getTerminalEvent(EVENT_TI_BOOKING_RECON), null); // par 23159
	endif;								// par 23159
	
	if _passport.myStateChangeController &lt;&gt; null then	
		_passport.myStateChangeController.setAfterValuesForObject(newTI); //jlier1 TFS 61676 14/12/23
	endif;
	
	return newTI;
end;</source>
        <Parameter name="_transientTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createVehicle" id="6a96c766-5895-46a2-9cf6-4b18cc2b3442">
        <updating/>
        <source>createVehicle(pRegNumber : String; pCarrier : CM_Carrier) : CM_Vehicle updating;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theVehicle	: CM_Vehicle;
//	tmpCarrier	: CM_Carrier;
	
begin

	create theVehicle persistent;
	
	theVehicle.set(pRegNumber, pCarrier);
	theVehicle.setMyTerminal(self);
	
	return theVehicle;
	
end;</source>
        <Parameter name="pRegNumber" type="String"/>
