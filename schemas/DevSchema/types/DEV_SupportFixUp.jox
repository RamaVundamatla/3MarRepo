	self.cmbTopic.addItem('Voyage Definition');
	self.cmbTopic.addItem('Voyage Operations');
	self.cmbTopic.addItem('Voyage Planning');
	self.cmbTopic.addItem('VTMIS - Harbour Mgmt');
	self.cmbTopic.addItem('Web Interface');
	self.cmbTopic.addItem('Work-orders');
	self.cmbTopic.addItem('Yard');
	self.cmbTopic.addItem('Yard Allocations');

end;</source>
    </JadeMethod>
    <JadeMethod name="loadContactDetails" id="00cb44ac-fbbb-49c7-b542-438c60504d69">
        <source>loadContactDetails();

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	i 			: Integer;
	dateString  : String;
	contact 	: DEV_SupportContact;
	state		: DEV_SupportState;
	
begin
	self.clearContactDetails();
	
	contact := self.myCurrentContact;
	if contact = null then
		return;
	endif;
	
	self.txtContact.text := contact.number.String;
	if contact.tfsNumber = 0 then
		self.txtTFS.text := "";
	else
		self.txtTFS.text := contact.tfsNumber.String;
	endif;
	
	i := self.cmbCustomer.findString(1, contact.customer);
	if i &lt;&gt; -1 then
		self.cmbCustomer.listIndex := i;
	endif;
	
	self.txtDescription.text := contact.description;
	
	i := self.cmbTopic.findString(1, contact.topic);
	if i &lt;&gt; -1 then
		self.cmbTopic.listIndex := i;
	endif;
	
	self.txtRelease.text := contact.releaseOpened;
	
	i := self.cmbOwned.findString(1, contact.owner);
	if i &lt;&gt; -1 then
		self.cmbOwned.listIndex := i;
	endif;
	
	dateString := contact.openedTS.date.format("dd/MM/yyy") &amp; " " &amp; contact.openedTS.time.format("HH:mm");
	self.txtOpened.text := dateString;
	
	self.chkKPI1.value 	 		:= contact.kpi1Done;
	self.txtKPI1FailedBy.text	:= contact.kpi1FailedBy;
	self.chkKPI2.value 	 		:= contact.kpi2Done;
	self.txtKPI2FailedBy.text	:= contact.kpi2FailedBy;
		
	self.cmbState.clear;
	self.cmbState.listCollection(contact.allStates, true, 0);
	
	self.cmbState.listIndex := 1;
	state 		:= contact.allStates.first;
	self.txtStateType.text := state.type;
	dateString 	:= state.startTS.date.format("dd/MM/yyy") &amp; " " &amp; state.startTS.time.format("HH:mm");
	self.txtStateStart.text := dateString;
	
	if state.endTS.isValid then
		dateString 	:= state.endTS.date.format("dd/MM/yyy") &amp; " " &amp; state.endTS.time.format("HH:mm");
		self.txtStateEnd.text := dateString;
	else
		self.txtStateEnd.text := "";
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="optClosed_click" id="29af1562-c927-4e97-b374-d89b2b83111d">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optClosed_click(optionbutton: OptionButton input) updating;

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	contact : DEV_SupportContact;
	
begin
	if not optionbutton.value then
		return;
	endif;
		
	cmbContact.clear;
	foreach contact in self.myRoot.allContacts where contact.getCurrentState = 'Closed' do
		self.cmbContact.addItem(contact.number.String);
	endforeach;

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="optOpen_click" id="96f1e30d-0c83-4ff3-b491-94a673c5b796">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optOpen_click(optionbutton: OptionButton input) updating;

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	contact : DEV_SupportContact;
	
begin
	if not optionbutton.value then
		return;
	endif;
		
	cmbContact.clear;
	foreach contact in self.myRoot.allContacts where contact.getCurrentState &lt;&gt; 'Closed' do
		self.cmbContact.addItem(contact.number.String);
	endforeach;

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
</GUIClass>
