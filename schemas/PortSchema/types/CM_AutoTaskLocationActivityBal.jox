    </JadeMethod>
    <JadeMethod name="validate" id="95d9898d-34ac-49aa-83c5-f95aa2d4c9fb">
        <source>validate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	real : CM_AutoTaskLocationActivityBal;
	autoSchedule : CM_AutoSchedule;

begin

	inheritMethod();
	
	if self.isTransient then
		real := self.pxyGetRealObject().CM_AutoTaskLocationActivityBal;
	else
		real := self;
	endif;
	
	if real &lt;&gt; null then
		foreach autoSchedule in real.allAutoSchedules do
			self.validateFrequency( autoSchedule );
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateFrequency" id="664a643e-5264-4d4e-9e98-b06f874b7951">
        <source>validateFrequency( _inAutoSchedule : CM_AutoSchedule );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	runTime : Time;
	prevRunTS : TimeStamp;
	runTS : TimeStamp;
	date : Date;
	oneHour : TimeStampInterval;

begin
	if _inAutoSchedule = null then
		return;
	endif;
	
	if not self.recalculateOnly then
		//Not allowed to be scheduled to run more frequently than once per day.
		if _inAutoSchedule.allRunTimes.size &gt; 1 then
			//more than once a day
			app.raiseCMException1(Locat_activ_balan_calcu_task_n, _inAutoSchedule.description, null, null);
		endif;
		if _inAutoSchedule.recurUnit = CM_AutoSchedule.RecurUnit_Hours then
			if _inAutoSchedule.recurValue &lt; 24 then
				app.raiseCMException1(Locat_activ_balan_calcu_task_n, _inAutoSchedule.description, null, null);
			endif;
		elseif _inAutoSchedule.recurUnit = CM_AutoSchedule.RecurUnit_Minutes then
			if _inAutoSchedule.recurValue &lt; 1440 then
				app.raiseCMException1(Locat_activ_balan_calcu_task_n, _inAutoSchedule.description, null, null);
			endif;
		elseif _inAutoSchedule.recurUnit = CM_AutoSchedule.RecurUnit_Seconds then
			if _inAutoSchedule.recurValue &lt; 86400 then
				app.raiseCMException1(Locat_activ_balan_calcu_task_n, _inAutoSchedule.description, null, null);
			endif;
		endif;
	
	else
		//Not allowed to be scheduled to run more frequently than once per hour.
		if not _inAutoSchedule.allRunTimes.isEmpty then
			oneHour.set( 0, 3600000 );
			date := app.actualTimeServer.date;
			runTS.setDate( date );
			prevRunTS.setDate( date - 1 );
			prevRunTS.setTime( _inAutoSchedule.allRunTimes.last );
			foreach runTime in _inAutoSchedule.allRunTimes do
				runTS.setTime( runTime );
				if (prevRunTS + oneHour) &gt; runTS then
					//less than an hour apart
					app.raiseCMException1( Locat_activ_balan_calcu_hourly, _inAutoSchedule.description, null, null );
				endif;
				prevRunTS := runTS;
			endforeach;
		endif;
		if _inAutoSchedule.recurUnit = CM_AutoSchedule.RecurUnit_Minutes then
			if _inAutoSchedule.recurValue &lt; 60 then
				app.raiseCMException1( Locat_activ_balan_calcu_hourly, _inAutoSchedule.description, null, null );
			endif;
		elseif _inAutoSchedule.recurUnit = CM_AutoSchedule.RecurUnit_Seconds then
			if _inAutoSchedule.recurValue &lt; 3600 then
				app.raiseCMException1( Locat_activ_balan_calcu_hourly, _inAutoSchedule.description, null, null );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_inAutoSchedule" type="CM_AutoSchedule"/>
    </JadeMethod>
</Class>
