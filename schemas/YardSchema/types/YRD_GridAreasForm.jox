    <JadeMethod name="getTableColumFilters" id="797cbb04-8736-4e61-8456-c5cb9c37d76a">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );
	
	

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTermAreaDetailsForQuery" id="10f211d2-a8ff-4b9f-bdd9-b9e2f2f70050">
        <source>getTermAreaDetailsForQuery( _terminal : CM_Terminal output;
							_terminalAreas : CM_TAMasterByIdDict io;
							_gridRows : CM_GridObjectSet io;
							_enqController : CM_EnquiryController output;
							_viewMode : Integer output
							);

/*

Purpose:			
						used by "frmSelectorPane"
Parameters:			

Return Value:		


Date		Who		Reason
28 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	_terminal := self.myTerminal;
	
	if not self.allTerminalAreas.isEmpty then
		self.allTerminalAreas.copy( _terminalAreas );
	endif;
	
	_enqController := self.mySelectorEnquiryController;

	if self.myCurrentDrawingController &lt;&gt; null then
		_viewMode := self.myCurrentDrawingController.viewMode;
	else
		_viewMode := VIEW_VOYAGE;
	endif;
	
	return;
	
	// not called because of the return above, just here to give a reference
	// so some clown doesn't delete the high level one.
	inheritMethod(  _terminal, _terminalAreas, _gridRows, _enqController, _viewMode );
	

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="output"/>
        <Parameter name="_terminalAreas" type="CM_TAMasterByIdDict" usage="io"/>
        <Parameter name="_gridRows" type="CM_GridObjectSet" usage="io"/>
        <Parameter name="_enqController" type="CM_EnquiryController" usage="output"/>
        <Parameter name="_viewMode" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getXMLEndViewValueFor" id="1b6b1d0b-addd-455a-a73e-69c694452038">
        <source>getXMLEndViewValueFor( _area : CM_TerminalAreaMaster ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2010	cnwndl1	Initial creation	Par 24331

*/

vars

	taTypeIndex : Integer;
	
begin

	if _area &lt;&gt; null then
		taTypeIndex := _area.type + 1;
		if self.xmlEndViewByType.size &gt;= taTypeIndex then
			return self.xmlEndViewByType[taTypeIndex];
		endif;
	endif;
	
	return self.xmlEndView;
	
epilog

end;</source>
        <Parameter name="_area" type="CM_TerminalAreaMaster"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForExit" id="fffd5b8b-548f-417c-a604-79376e18b970">
        <updating/>
        <source>getXMLSettingsForExit(): String updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpObj : Object;
	theXML		: String;

begin
	theXML := inheritMethod();
	foreach tmpObj in self.allTerminalAreas do
		theXML := theXML &amp; global.formatAsXML(XML_TA, tmpObj.CM_TerminalArea.id);
	endforeach;
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="85df39d7-c2b7-45bf-bc24-d551da102327">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------

vars
	theXML		: String;
	hideMacro	: Boolean;
	pos : Integer;
	tagName : String;
	
begin
	theXML := inheritMethod();
	// NOTE if these menus have a caption saying SHOW it means that the item is hidden
	hideMacro :=  (self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW);
	theXML := theXML &amp; 
			global.formatAsXML(XML_FH,self.xmlFlipH.Integer.String) &amp;
			global.formatAsXML(XML_FV,self.xmlFlipV.Integer.String) &amp;
			global.formatAsXML(XML_EV,self.xmlEndView.Integer.String) &amp;
			global.formatAsXML(XML_ZE,self.xmlZoomEndView.String) &amp;
			global.formatAsXML(XML_ZS,self.xmlZoomFactor.String) &amp;
			global.formatAsXML(XML_HM,hideMacro.Integer.String) &amp;
			global.formatAsXML(XML_GRID,self.showOSGrid.Integer.String) &amp;
			global.formatAsXML(XML_HT,(self.mnuGridHideToolbar.caption = self.MNU_TOOLBAR_SHOW).Integer.String) &amp;
			global.formatAsXML(XML_SE,(self.mnuHideSelectorPanel.caption = self.MNU_SELECTOR_SHOW).Integer.String) &amp;	 //28 Jul 2011	NDL	Par 27890 
			global.formatAsXML(XML_HL,(self.mnuGridHideLegend.caption = self.MNU_LEGEND_SHOW).Integer.String) &amp;
			global.formatAsXML(XML_YA,(self.btnViewYardAlloc.value).String) &amp;
			global.formatAsXML(XML_HE,(self.dkcExtraInfo.height/self.dkcSubMain.height).String) &amp;  //epr par 19289 2/4/09
			self.tblYAM.getXmlStrForColumns(false);
			
	//03 Jun 2010	NDL Par 24331
	foreach pos in 1 to self.xmlEndViewByType.size do
		if self.xmlEndViewByType[pos] &lt;&gt; self.xmlEndView then
			tagName := XML_EV &amp; pos.String;
			theXML := theXML &amp; global.formatAsXML(tagName, (not self.xmlEndView).Integer.String );
		endif;
	endforeach;
	
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="2b5681c2-1727-4961-a675-1e446031b10f">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		Get the user preferences from the user details for this form
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, hideL,hideT,hideM : Boolean;
	endView : Boolean;
	zoomScale : Real;
	zoomEndView : Real;
	ya : Boolean;
	height : Real;
	
	taType : CM_TerminalAreaType;
	taTypeIndex : Integer;
	tagName : String;
	taEndView : Boolean;
	hideS : Boolean; //28 Jul 2011	NDL	Par 27890
	
begin
	// par 11163 rs jan 2006
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;
	
	//28 Jul 2011	NDL	Par 27890
	// #### HIDE SELECTOR
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_SE);
 	hideS := false;
 	if theXMLValue &lt;&gt; null then
 		hideS := theXMLValue.Integer.Boolean;
 	endif;

 	// #### HIDE LEGEND
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HL);
 	hideL := false;
 	if theXMLValue &lt;&gt; null then
 		hideL := theXMLValue.Integer.Boolean;
 	endif;
 	// #### HIDE MACRO
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HM);
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
 	// #### HIDE TOOLBAR
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HT);
 	hideT  := false;
 	if theXMLValue &lt;&gt; null then
 		hideT := theXMLValue.Integer.Boolean;
 	endif;

 	// #### SHOW INVISIBLE GRID for odd lengths
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_GRID);
 	self.showOSGrid  := false;
 	if theXMLValue &lt;&gt; null then
 		self.showOSGrid := theXMLValue.Integer.Boolean;
 	endif;
 	
	// #### FLIP HORIZONTAL
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FH);
 	flipH := false;
 	if theXMLValue &lt;&gt; null then
 		flipH := theXMLValue.Integer.Boolean;
 	endif;
 	
 	// #### FLIP VERTICAL
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FV);
 	flipV := false;
 	if theXMLValue &lt;&gt; null then
 		flipV := theXMLValue.Integer.Boolean;
 	endif;

	// #### ZOOM SCALE
 	zoomScale := theXML.cnEcGetTagValueOfName(XML_ZS).Real;
 
 	if zoomScale = 0 then
	 	zoomScale := CMUI_GridDrawingController.ScaleFactor_2;
	endif;
	self.xmlZoomFactor := zoomScale;
	
	// #### END VIEW
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_EV);
 	endView := false;
 	if theXMLValue &lt;&gt; null then
 		endView := theXMLValue.Integer.Boolean;
 	endif;
	
	//03 Jun 2010	NDL Par 24331
	foreach taType in app.myRoot.allTerminalAreaTypes do
		if taType.type &gt; 100 then
			continue;
		endif;
		taTypeIndex := taType.type + 1;
		tagName := XML_EV &amp; taTypeIndex.String;
		theXMLValue := theXML.cnEcGetTagValueOfName(tagName);
		if theXMLValue &lt;&gt; null then
			taEndView := theXMLValue.Integer.Boolean;
			xmlEndViewByType[taTypeIndex] := taEndView;
		else
			xmlEndViewByType[taTypeIndex] := endView;
		endif;
	endforeach;

	// #### ZOOM FACTOR FOR END VIEW
 	zoomEndView := theXML.cnEcGetTagValueOfName(XML_ZE).Real;
 	if zoomEndView = 0 then
	 	zoomEndView := CMUI_GridDrawingController.ScaleFactor_3;
 	endif;

	ya := theXML.cnEcGetTagValueOfName(XML_YA).Boolean;
	height := theXML.cnEcGetTagValueOfName(XML_HE).Real;
 	// ### SET CONTROLS
 
	self.xmlFlipH := flipH;
	self.xmlFlipV := flipV;
	self.xmlLegend := hideL;
	self.xmlToolbar := hideT;
	self.xmlMacro := hideM;
	self.xmlZoomFactor := zoomScale;
	self.xmlEndView := endView;
	self.xmlZoomEndView := zoomEndView;
	self.xmlYA := ya;
	self.xmlHeight := height;
	self.xmlSelector := hideS;	//28 Jul 2011	NDL	Par 27890
	
epilog

 	if self.xmlZoomFactor = 0 then
	 	self.xmlZoomFactor := CMUI_GridDrawingController.ScaleFactor_2;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getYardAllocString" id="1cd75bb9-972e-4d9e-8842-e53f2f9b56ed">
        <source>getYardAllocString(_objs : ObjectArray) : String;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	anLC : CM_LocationsController;
	locTxt : String;
	ta : CM_TerminalArea;
begin
	
	if _objs = null then
		return null;
	endif;
	
	if _objs.isEmpty then
		return null;
	endif;
	
	foreach anObject in _objs do
		anLC := anObject.CM_LocationsController;

		if ta &lt;&gt; anLC.myTerminalArea then
			if ta &lt;&gt; null then // not the first time
				locTxt := locTxt &amp;  "; ";
			endif;
			ta := anLC.myTerminalArea;
			locTxt := locTxt &amp; ta.id &amp; " " &amp; anLC.ident;
		else
			locTxt := locTxt &amp;  "," &amp; anLC.ident;
		endif;
	endforeach;
	
	return locTxt;
end;</source>
        <Parameter name="_objs" type="ObjectArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
