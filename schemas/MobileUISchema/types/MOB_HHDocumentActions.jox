    <JadeMethod name="doClickSelect" id="019024c1-6653-4453-9db4-cf6058108e8c">
        <source>doClickSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2016	cnwndl1	Initial creation	TFS 3110 / 2001

*/

vars

	doSelect : Boolean;
	table  : Table;
	rowIndex : Integer;

begin

	doSelect := ( self.btnSelect.caption = app.getErrorString( SelectAll ) );
	
	if ( self.fldMain.topSheet = self.shtStops ) then
		table := self.tblCargoStops;
	elseif ( self.fldMain.topSheet = self.shtTasks ) then
		table := self.tblCargoTasks;
	endif;
	
	
	if table.rows &gt; table.fixedRows then
		foreach rowIndex in 2 to table.rows do
			if not table.accessRow( rowIndex ).enabled then
				continue;
			endif;
			if doSelect then
				table.accessCell( rowIndex, 2 ).text := "1";
			else
				table.accessCell( rowIndex, 2 ).text := "0";
			endif;
		endforeach;
	endif;

	if doSelect then
		self.btnSelect.caption := app.getErrorString( SHP_UnSelect_Al );
	else
		self.btnSelect.caption := app.getErrorString( SelectAll );
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCompleteActions" id="4ed7bcb0-7606-4dcb-954c-7ae9bdce30b3">
        <updating/>
        <source>doCompleteActions()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	processingStops : Boolean;
	processingTasks : Boolean;
	stop : CM_StopsTable;
	task : CM_ToDoTaskDesc;
	table : Table;
	documentActions : CM_DocumentActions;
	rowIndex : Integer;
	selected : Boolean;
	ti : CM_TrackedItem;
	qty : Real;
	remaining : Real;
	errMess : String;
	tiArray : CM_TIArray;
	qtyArray : RealArray;
	stopArray : ObjectArray;
	taskArray : ObjectArray;
	
	index : Integer;
	cmifDAC : CMIF_DocumentActionTrxCont;
	txnControllerSet : CMIF_TITxnControllerSet;
	newTrxSet : CM_TITransactionSet;
	
	result : Integer;
	daError : Boolean;
	
	resourceTypeForm : MOB_ResourceTypeUsageForm;
	
	handlingType : CM_HandlingType;

begin

	processingStops := ( self.fldMain.topSheet = self.shtStops );
	processingTasks := ( self.fldMain.topSheet = self.shtTasks );
	
	if processingStops then
		table := self.tblCargoStops;
	elseif processingTasks then
		table := self.tblCargoTasks;
	endif;
	
	create tiArray transient;
	create qtyArray transient;
	create stopArray transient;
	create taskArray transient;
	
	foreach rowIndex in 2 to table.rows do
		selected := (table.accessCell( rowIndex, 2 ).text.String = '1');
		if not selected then
			continue;
		endif;
		if processingStops then
			stop := table.accessCell( rowIndex, 6 ).itemObject.CM_StopsTable;
			if stop = null then
				errMess := "Row " &amp; rowIndex.String &amp; " Stop Object not identified";
				app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
				daError := true; // TFS 3283
				break;
			endif;
		elseif processingTasks then
			task := table.accessCell( rowIndex, 6 ).itemObject.CM_ToDoTaskDesc;
			if task = null then
				errMess := "Row " &amp; rowIndex.String &amp; " Task Object not identified";
				app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
					daError := true; // TFS 3283
			break;
			endif;
		endif;
		
		documentActions := table.accessCell( rowIndex, 3 ).itemObject.CM_DocumentActions;
		if documentActions = null then
			errMess := "Row " &amp; rowIndex.String &amp; " Document Actions Object not identified";
			app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
				daError := true; // TFS 3283
			break;
		endif;
		
		ti := table.accessRow( rowIndex ).itemObject.CM_TrackedItem;
		if ti &lt;&gt; null then
			qty := table.accessCell( rowIndex, 5 ).text.String.Real;
			if qty &lt;= 0 then
				errMess := app.getErrorString2(Quantit_complet_not_valid, ti.id, qty.String);
				app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
				daError := true; // TFS 3283
				break;
			endif;
			remaining := table.accessCell( rowIndex, 5 ).text.String.Real;
			if qty &gt; remaining then
				errMess := app.getErrorString3(Quant_compl_inval_not_great_th, ti.id, qty.String, remaining.String);
				app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
				daError := true; // TFS 3283
				break;
			endif;
			tiArray.add( ti );
			qtyArray.add( qty ) ;
			stopArray.add( stop );
			taskArray.add( task );
		endif;
		
	endforeach;
	
	if tiArray.isEmpty and not daError then // TFS 3283
		errMess := app.getErrorString(CMUI_Nothing_Selected);
		app.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;

	if processingTasks then
	
		if not self.allNewProxyResourceTypeUsages.isEmpty then
			self.allNewProxyResourceTypeUsages.purge();
		endif;
		
		//18 Apr 2017	NDL	TFS 3414
		foreach ti in tiArray do
			handlingType := ti.getHandlingType;
			if handlingType &lt;&gt; null and not handlingType.isPallet then
				handlingType := null;
			endif;
			if handlingType &lt;&gt; null then
				//we ahave at least one that may require pallet details
				break;
			endif;
		endforeach;
	
		task := self.cmbTasks.listObject.CM_ToDoTaskDesc;
		if task &lt;&gt; null and not task.allResourceTypes.isEmpty then
		
			self.resourceTICount := tiArray.size;
			//collect up a template of the resources used
			create resourceTypeForm transient;
			resourceTypeForm.myToDoTask := task;
			resourceTypeForm.setTemplateOnly( true, self );
			resourceTypeForm.doNotCentreWindow := true; 
			resourceTypeForm.move(self.left, self.top, self.width, self.height );
			resourceTypeForm.myHandlingType := handlingType;	//18 Apr 2017	NDL	TFS 3414
			resourceTypeForm.showModal();
			if resourceTypeForm.modalResult &lt;&gt; IDOK then
				return;
			endif;
			
		endif;
		
	endif;
	
	create txnControllerSet transient;
	
	foreach index in 1 to tiArray.size do
		create cmifDAC transient;
		if processingStops then
			cmifDAC.type := TRANS_TYPE_STOPCLEARDA;
			cmifDAC.myStopsTable := stopArray[index].CM_StopsTable;
		elseif processingTasks then
			cmifDAC.type := TRANS_TYPE_TASKCOMPLETEDA;
			cmifDAC.myToDoTaskDesc := taskArray[index].CM_ToDoTaskDesc;
			if not self.allNewProxyResourceTypeUsages.isEmpty then
				self.allNewProxyResourceTypeUsages.copy( cmifDAC.allResourceUsageProxys );
			endif;
		endif;
		cmifDAC.noCharge := false; //TFS 3844 changed to false
		cmifDAC.myTerminal := self.myTerminal;
		cmifDAC.myTrackedItem := tiArray[index];
		cmifDAC.amount := qtyArray[index];
		cmifDAC.myDocumentActions := documentActions;
		txnControllerSet.add( cmifDAC );
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateTITransactions( txnControllerSet, newTrxSet, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getString(Create_locatio_check_transac), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;

		break;
	endwhile;
		
	self.populateStopsTasks();
	
	self.populateTable( self.tblCargoStops );
	self.populateTable( self.tblCargoTasks );
	
epilog

	delete tiArray;
	delete qtyArray;
	delete stopArray;
	delete taskArray;
	
	if txnControllerSet &lt;&gt; null and not txnControllerSet.isEmpty then
		txnControllerSet.purge();
	endif;
	delete txnControllerSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="af579f77-6135-4acf-9da8-cca881ce9507">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;
	folderHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	folderHeight := (self.clientHeight - cTop - ( self.getCMDButtonsHeight() * 2 ) - ( self.resizedMargin * 3 ) );
	
	if _initialSetup then
		self.fldMain.setAndIncrementTabIndex( tabIndex );
		self.fldMain.visible := true;
		self.fldMain.enabled := true;
	endif;
	self.fldMain.move(	self.resizedMargin,
						 cTop,
						 cWidth,
						 folderHeight );
						 
	if _initialSetup then
		self.shtStops.setAndIncrementTabIndex( tabIndex );
		self.shtStops.visible := true;
		self.shtStops.enabled := true;
	endif;
						
	if _initialSetup then
		self.shtTasks.setAndIncrementTabIndex( tabIndex );
		self.shtTasks.visible := true;
		self.shtTasks.enabled := true;
	endif;

	cTop := self.resizedMargin;
	if _initialSetup then
		self.cmbStops.setAndIncrementTabIndex( tabIndex );
		self.cmbStops.visible := true;
		self.cmbStops.enabled := true;
		self.cmbStops.parent := self.shtStops;
	endif;
	self.cmbStops.move(	1,
						cTop,
						self.shtStops.width - 2,
						cHeight ); 
								
	if _initialSetup then
		self.cmbTasks.setAndIncrementTabIndex( tabIndex );
		self.cmbTasks.visible := true;
		self.cmbTasks.enabled := true;
		self.cmbTasks.parent := self.shtTasks;
	endif;
	self.cmbTasks.move( 	1,
						cTop,
						self.shtTasks.width - 2,
						cHeight ); 
						
	cTop := cTop + self.cmbTasks.height + self.resizedMargin;
	
	if _initialSetup then
		self.tblCargoStops.setAndIncrementTabIndex( tabIndex );
		self.tblCargoStops.visible := true;
		self.tblCargoStops.enabled := true;
		self.tblCargoStops.parent := self.shtStops;
	endif;
	self.tblCargoStops.move( 1,
							cTop,
							self.shtStops.width - 2,
							self.shtStops.height - cTop - self.resizedMargin ); 
							
	if _initialSetup then
		self.tblCargoTasks.setAndIncrementTabIndex( tabIndex );
		self.tblCargoTasks.visible := true;
		self.tblCargoTasks.enabled := true;
		self.tblCargoTasks.parent := self.shtTasks;
	endif;
	self.tblCargoTasks.move( 1,
							cTop,
							self.shtTasks.width - 2,
							self.shtTasks.height - cTop - self.resizedMargin ); 
							
	//12 Dec 2016	NDL	TFS 3110/2001
	cTop := self.fldMain.top + self.fldMain.height + self.resizedMargin;
	if _initialSetup then
		self.btnSelect.setAndIncrementTabIndex( tabIndex );
		self.btnSelect.visible := true;
		self.btnSelect.enabled := true;
	endif;
	self.btnSelect.move(	self.btnOne.left,
							cTop,
							self.btnOne.width,
							self.btnOne.height
							); 
								
	inheritMethod(_initialSetup);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
