    <JadeMethod name="convertForCCMS1405" id="d5c1e8a9-820a-4ff6-9be1-f3e8c18e8fcd">
        <source>convertForCCMS1405(): CMEVT_WagonTransaction protected;
/*

Date		Who		Reason
04 December 2014	cnwer1	Initial creation PAR

*/

vars
	i : CM_InvoiceLine;
	t			: CMEVT_WagonTransaction;
begin
	if self.class = CMEVT_WagonTransaction then
		return null;
	endif;
	
	t:=self.cloneSelfAs(CMEVT_WagonTransaction,false).CMEVT_WagonTransaction;		
	t.setPropertyValue(CMEVT_WagonTransaction::mySubject.name,self.mySubject);
	t.setPropertyValue(CMEVT_WagonTransaction::myTrackedItem.name,self.myTrackedItem);
	t.setPropertyValue(CMEVT_WagonTransaction::myTrain.name,self.myTrain);
	self.myWagon.allTransactions.add(t);
	//t.setPropertyValue(CMEVT_WagonTransaction::myWagon.name,self.myWagon);
	t.setPropertyValue(CM_EventTransaction::myTerminal.name,self.myTerminal);
	t.setPropertyValue(CM_EventTransaction::myEventType.name,self.myEventType);
	t.setPropertyValue(CM_EventTransaction::myDebtor.name,self.myDebtor);
	
/*	if self.isKindOf(CMEVT_WagonDamage) then
		t.setPropertyValue(CMEVT_WagonTransaction::damage.name,self.getDamageDescription);
	endif;
	if self.isKindOf(CMEVT_WagonCargoMoved) then
		t.setPropertyValue(CMEVT_WagonTransaction::isSwapMove.name,self.getIsSwapMove);
	endif;*/
	
	foreach i in self.allInvoiceLines do
		i.setMyTransactionEvent(t);
	endforeach;	
	
	
	
	return t;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CMEVT_WagonTransaction"/>
    </JadeMethod>
    <JadeMethod name="delete" id="03877459-3253-46f6-9d54-ef1f8398180c">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2015	cnwndl1	Initial creation	Par 36658

*/

vars

	any	: Any;
	allSealCheckDetails : CM_SealCheckDetailSet;

begin

	if self.type = EVT_WagonSealCheck then
	
		any := self.getExtraData( self.AllSealCheckDetails );
		if any &lt;&gt; null then
			if any.isKindOf( CM_SealCheckDetailSet ) then
				allSealCheckDetails := any.CM_SealCheckDetailSet;
				if not allSealCheckDetails.isEmpty then
					allSealCheckDetails.purge();
				endif;
				delete allSealCheckDetails;
			endif;	
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doesRequireSnapShot" id="f240fc2f-9df7-4e8a-b79c-1d5699ee6c91">
        <methodInvocation>mapping</methodInvocation>
        <source>doesRequireSnapShot(set: Boolean; _value: Boolean io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2021	navndl1	Initial creation	TFS 50835

*/

vars

begin

	if not set then
		if self.type = EVT_WagonCargoConfirmed
		or self.type = EVT_WagonCargoMoved
		or self.type = EVT_WagonCargoReceive
		or self.type = EVT_WagonCargoRelease
		then
			_value := true;
			
		else
			inheritMethod(set, _value);
			
		endif;
		
	else
		inheritMethod(set, _value);
		
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
