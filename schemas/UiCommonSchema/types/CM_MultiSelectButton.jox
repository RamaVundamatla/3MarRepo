    <JadeMethod name="click" id="391251f0-c417-42ac-877b-fc7b677dc2c4">
        <updating/>
        <source>click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myMultiSelectGroupBox.handleBtnClick(btn.CM_MultiSelectButton);

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
