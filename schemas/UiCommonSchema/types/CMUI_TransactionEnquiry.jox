        <source>checkSearchReturnOption(_numFound : Integer) updating, protected, clientExecution;

vars

begin

	if self.numItemsSearched &gt; 200 and (not self.frmModalDialog.visible) then
		// code below will set text and buttons in modalDialogFrame
		self.frmModalDialog.visible := true;
	endif;
	
	if self.frmModalDialog.visible then
		self.modalDialogShow(null, app.getErrorString(Cancel), null, null,
						app.getErrorString(Searching_Data),
						app.getErrorString(Searched)  &amp; ' ' &amp; self.numItemsSearched.String &amp; ' ' &amp; app.getErrorString(Found) &amp; ' ' &amp; _numFound.String);
	endif;
	
	self.btnModalDefault.doWindowEvents(0);
	if self.modalDialogReturnValue = ModalDialogReturn_Null then
		// see if the user has pressed the Cancel button
		self.btnModalOpt1.doWindowEvents(0);
	endif;
	
end;</source>
