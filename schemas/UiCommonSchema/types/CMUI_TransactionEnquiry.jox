    <JadeMethod name="setFilterDefaults" id="c16ee6f0-4fa1-4f1f-bbd5-4bd41ed1df8e">
        <updating/>
        <source>setFilterDefaults() updating, protected;

vars

begin
	self.filterBusinessUnit := null;
	self.filterCharged := 0;
	self.filterDateFrom := null;
	self.filterTimeFrom := null;
	self.filterDateTo := null;
	self.filterTimeTo := null;
	self.filterDebtor := null;
	self.filterInvoiceNumber := 0;
	self.filterEventType := null;
	self.filterTransactionType := null;
	self.filterUser := null;
	self.filterVoyage := null;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="d2150691-b36b-4b1a-89e8-1ff38e826001">
        <updating/>
        <source>setFilterValues() updating, protected;
/*

Date		Who		Reason
06 Apr 2016	cnwkpd1	TFS 488 - Multi Timezone Support
	
*/

vars
	swapDate		: Date;
	swapTime		: Time;
	obj				: Object;
	swapTS,
	localFromTS,
	localToTS,
	systemFromTS,
	systemToTS		: TimeStamp;
	
begin
	self.mode := self.cmbSearchEnqType.itemData[self.cmbSearchEnqType.listIndex];

	if self.cmbSearchBU.listIndex &gt; 0 then
		self.filterBusinessUnit := self.cmbSearchBU.listObject.CM_Bank;
	else
		self.filterBusinessUnit := null;
	endif;
	if self.cmbSearchCharged.listIndex &gt; 0 then
		self.filterCharged := self.cmbSearchCharged.itemData[self.cmbSearchCharged.listIndex];
	else
		self.filterCharged := 0;
	endif;
	
	// Timezone handling - values on form are local
	localFromTS.setDate(self.mskSearchDateFrm.getDate());
	localFromTS.setTime(self.mskSearchTimeFrm.getTime());
	localToTS.setDate(self.mskSearchDateTo.getDate());
	localToTS.setTime(self.mskSearchTimeTo.getTime());
	
	// if dates are the wrong way round, just swap and update the form
	if localFromTS &lt;&gt; null and 
	   localToTS &lt;&gt; null and
	   localToTS &lt; localFromTS then
		swapTS := localFromTS;
		localFromTS := localToTS;
		localToTS := swapTS;
		
		self.mskSearchDateFrm.setDate(localFromTS.date());
		self.mskSearchTimeFrm.setTime(localFromTS.time());
		self.mskSearchDateTo.setDate(localToTS.date());
		self.mskSearchTimeTo.setTime(localToTS.time());
	endif;
	
	// Convert from local to system
	systemFromTS := self.localToSystemTime(localFromTS);
	systemToTS := self.localToSystemTime(localToTS);
		
	self.filterDateFrom := systemFromTS.date();
	self.filterTimeFrom := systemFromTS.time();
	self.filterDateTo := systemToTS.date();
	self.filterTimeTo := systemToTS.time();
	if self.filterTimeTo &lt;&gt; null then
		//  set 'to' time to end of hour/minute period
		swapTime := self.filterTimeTo;
		self.filterTimeTo.setTime(swapTime.hour, swapTime.minute, 59, 999);
	endif;
	
	if self.cmbSearchDebtor.listIndex &gt; 0 then
		self.filterDebtor := self.cmbSearchDebtor.listObject.CM_Debtor;
	else
		self.filterDebtor := null;
	endif;
	self.filterInvoiceNumber := self.txtSearchInvNo.text.Integer;
	self.filterEventType := null;
	self.filterTransactionType := null;
	if self.cmbSearchTranTyp.listIndex &gt; 0 then
		obj := self.cmbSearchTranTyp.listObject;
		if self.mode = self.Mode_Event_Transaction_Enquiry then
			self.filterEventType := obj.CM_EventType;
		else
			self.filterTransactionType := obj.CM_TransactionType;
		endif;
	endif;
	if self.cmbSearchUser.listIndex &gt; 0 then
		self.filterUser := self.cmbSearchUser.listObject.CM_User;
	else
		self.filterUser := null;
	endif;
	if self.cmbSearchVoyage.listIndex &gt; 0 then
		self.filterVoyage := self.cmbSearchVoyage.listObject.CM_Voyage;
	else
		self.filterVoyage := null;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="7b1758fb-3b9b-43d8-89df-336e0b68f5d2">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//25/10/2016 cnwma1  TFS #2820:PAR38298 STWO-Transaction menu system fault
//14 Aug 2023 navhl20 ChangeRequest 59284:[59669] EUP | FR - VAS Work Order Transactions
vars
	table : CM_DataTable;
	entrow1,entrow2 : EntTableRow;
begin

	if _theTable = self.tblTrans then	//28 Apr 2016	NDL	TFS 1903
		
		 // 25/10/2016 cnwma1 TFS #2820 PAR #38298
		table :=_theTable;  
		entrow2 := table.allTblDataEntRows.getEntRowNamed(ETRow_RowKey);
		entrow1 := table.allTblDataEntRows.getEntRowNamed(ETRow_SortKey);
		if entrow1 &lt;&gt; null and entrow2 &lt;&gt; null then	//28 Nov 2019	Found during TFS 47727
			table.allTblDataEntRows.remove(entrow1);
			table.allTblDataEntRows.remove(entrow2);
			table.allTblDataEntRows.insert(1,entrow1);
			table.allTblDataEntRows.insert(2,entrow2);
		endif;
		 // 25/10/2016 cnwma1 TFS #2820 PAR #38298
		//_theTable.setXMLStrForTblColumns(false, self.xmlStrTblTrans);  // 25/10/2016 cnwma1 TFS #2820 PAR #38298
		table.setXMLStrForTblColumns(false, self.xmlStrTblTrans);
			
		if self.myBOL &lt;&gt; null then     // 25/10/2016 cnwma1 TFS #2820 PAR #38298
			self.loadDataForBOL();
		endif;
		//self.populateTransactionTable();              // 25/10/2016 cnwma1 TFS #2820 PAR #38298
		self.doRefresh();
	else
		self.populateTransactionTable();
		self.saveXMLStrForTblColumns(self.tblTransactions);						//14.8.2023 navhl20 #59284[59669]
		self.doRefresh();														//14.8.2023 navhl20 #59284[59669]
	endif;
	
end;
</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUpForWO" id="64fd9001-25ec-405d-9502-ef5275bd643d">
        <updating/>
        <source>setUpForWO()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2023	navhl20	Bug 59047: MTN - The Refresh button on the Transaction Enquiry is refreshing all the transactions.
11 Jul 2023 navhl20 Defect 59116: MTN - The Resync option is not working on the Work Order Transactions form
*/

vars
	tableHeight : Real;
begin
	if self.myWorkOrder &lt;&gt; null then
		self.setCaption("WorkOrder Transactions for " &amp; self.myWorkOrder.id);
	elseif self.myWorkOrderDtl &lt;&gt; null then
		self.setCaption("WorkOrder Detail Transactions for " &amp; self.myWorkOrderDtl.taskID);
	endif;
		
	self.fldTrans.useSheetBackColors:=true;
	self.fldTrans.setDefaultSheetBackColors();
	self.fldTrans.initSheetBackColors();
	
	self.shtEventRequests.visible	:=false;
	self.shtTemperatures.visible	:=false;
	self.shtDiscrepancies.visible	:=false;
	self.shtCharges.visible 		:=false;
	self.shtTransactions.visible	:=false;												//11.7.2023 navhl20 #59116

	self.btnAdd.visible				:=false;
	self.btnEdit.visible			:=false;
	self.btnResync.visible			:=false;

	self.chkTransAudit.value 		:=false;
	self.tblTransactions.visible 	:=true;
	
	if app.myCurrentUserCan(self.myTerminal, PmTransEnquiryInvoiceDtls) then				//11.7.2023 navhl20 #59116
		// show the charges table under the transaction table
		self.tblCharges.visible := true;
		self.tblCharges.parent := self;
		self.tblCharges.height := 100;
		self.tblCharges.left := 0;
		self.tblCharges.width := self.clientWidth -1;
		self.tblCharges.top := self.clientHeight - self.staLine.height - self.tblCharges.height;
		tableHeight := self.tblCharges.height + 4;
	else
		self.tblCharges.visible := false;
		tableHeight := 0;
	endif;
	
	self.tblTransactions.top := 40;
	self.tblTransactions.left := 0;
	self.tblTransactions.width := self.clientWidth -1;
	self.tblTransactions.height := self.clientHeight - self.tblTransactions.top - tableHeight - self.staLine.height;
	self.showCharges();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupDefaultHelpKeyword" id="2be6f44c-48ac-47e0-aede-d3ecba38c610">
        <updating/>
        <source>setupDefaultHelpKeyword() updating;
/*

Purpose:			

