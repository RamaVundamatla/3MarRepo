<Class name="CMQF_ExportLoadReport" id="c572caf9-4978-44a4-9e9a-3a81a4c1b62e">
    <superclass name="CMQF_Export"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="244f92ef-2785-4470-a479-125ccb70beb6">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	ti				: CM_TrackedItem;
	breakOut		: Boolean;
begin
	//need a voyage
	if self.getMyVoyage &lt;&gt; null then
	
		//search ship
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
		//search onsite
		foreach ti in self.getMyVoyage.allOnsiteTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
