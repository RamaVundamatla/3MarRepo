    <JadeMethod name="tCoparnSNOBookPrenoteNADRFF" id="2c5857fc-0b42-4dff-918f-20b036d07235">
        <source>tCoparnSNOBookPrenoteNADRFF();
//
// 25 May 2018	jlgrs1	TFS 38357 SNO Fix Xlations from TFS 6797
//
// 05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
constants
	HSDExample : String = "HSDExample";
	KKKExample : String = "KKKExample";
	GBExample : String = "GBExample";
	USER_DEF_NAME	: String = "SNO_COPARN";
	VesselCode : String = "SNOVESSEL";
	Voyage_Code : String = "7905N";
	EDIPartyName : String = "SNO_COPARN7905";
	BookingNo : String = "0530215931";
	Prenote1 : String = "GSLM2012170";
	VehicleId : String = "UTTRUCK1";
vars
	terminal : CM_Terminal;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	subTerminal : CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
	coparnInput : String;
	errorMsg : String;
	booking : CM_BookingRef;
//	bookingItems : Integer;
	prenote : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	vgmDetails : CM_VGMDetails;
	receive: CM_Receive;
	sealNumbers : StringArray;
	
begin
//	self.doCoparnSNOBookPrenoteVGM(false);
//	self.doCoparnSNOBookPrenoteVGM(true);
//return;
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	self.setTerminalConfig(EdiUseOldCoparn, false);
	terminal := self.getTerminal;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	self.deleteVessel(VesselCode);
	vessel := self.getVessel(VesselCode);
	self.assertIsDeleted(vessel);
	self.deleteVoyage(Voyage_Code);
	voyage := self.getVoyage(Voyage_Code);
	self.assertIsDeleted(voyage);
	self.createVoyageVessel(Voyage_Code, VesselCode, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	// Create the party rules.
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, "TOFU", operator);
	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;

	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::createPrenotesForEQDWithID.name, true);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;

	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '12', CM_EDIEDIFactRule.Function_BGM_1_1_Release);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '27', CM_EDIEDIFactRule.Function_BGM_1_1_Prenote);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_1_1, 'CNE', CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_1_1, 'CNR', CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_1_1, 'CUA', CM_EDIEDIFactRule.Fnct_NAD_n_1_CustomAgent);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_1_1, 'FFR', CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_1_1, 'RCC', CM_EDIEDIFactRule.Fnct_NAD_n_1_RecCarrier);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_1_1, 'RLC', CM_EDIEDIFactRule.Fnct_NAD_n_1_RelCarrier);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_3_1, 'WCN', CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_3_1, 'WCR', CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_RFF_1_1, 'BOK', CM_EDIEDIFactRule.Fnct_RFF_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_RFF_1_1, 'BOL', CM_EDIEDIFactRule.Fnct_RFF_1_1_BOL);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_RFF_1_1, 'CRF', CM_EDIEDIFactRule.Fnct_RFF_1_1_CarrierRef);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_RFF_1_1, 'CLR', CM_EDIEDIFactRule.Fnct_RFF_1_1_CustomerRef);

	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;

	coparnInput := self.zCoparnFileSNONAD1;
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"1"&amp;method.name);
	self.assertNotNull(ediFile);
//	filesToDelete.add(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 5);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	booking := self.getBooking(BookingNo);
	self.assertNotNull(booking);
	self.assertEqual(booking.bookingReference, BookingNo);
	self.assertEqual(booking.consigneeCode, "DUGEE");
	self.assertEqual(booking.consignorCode, "DUGOR");
	self.assertEqual(booking.customsAgent, "DEB");
	self.assertEqual(booking.myCarrier.code, "DOUG");
	self.assertEqual(booking.getFreightForwarderCode, "DUGFF");
	self.assertEqual(booking.getCarrierReference, "CARRIER REF");
	
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.isWeightCertified, false);
	self.assertEqual(prenote.consignee, "DUGEE");
	self.assertEqual(prenote.consignor, "DUGOR");
	self.assertEqual(prenote.freightForwarderCode, "DUGFF");
	self.assertEqual(prenote.myCustomsAgent.code, "DEB");
	self.assertEqual(prenote.carrier, "DOUG");
	self.assertEqual(prenote.releaseCarrier, "APP");
	self.assertEqual(prenote.billOfLading, "BOLID1");
	self.assertEqual(prenote.clientRef, "CLIENT REF");
	vgmDetails := prenote.getMyVGMDetails;
	self.assertNull(vgmDetails);

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	
	process.sleep(1000); //01 Jul 2020	NDL	TFS 49606 - so we get a different time on the receive transaction.
	
	// gate in the container with no carrier
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.opts.addAssoc("AutoComplete", true);
	vvr := self.gateInPrenote(VehicleId, "", "", prenote, singleGate);
	self.assertNotNull(vvr);
	assertTrue(getTrackedItem(Prenote1).isOnSite);
	beginTransaction;
	ediParty.allEDIPartyRules.first.setPropertyValue(CM_EDIPartyCoparnRules::updateVGMForOnsiteCargo.name, true);
	commitTransaction;
	coparnInput := self.zCoparnFileSNONAD3;
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
//		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.isWeightCertified, true);
	self.assertEqual(prenote.consignee, "DUGEE");
	self.assertEqual(prenote.consignor, "DUGOR");
	self.assertEqual(prenote.freightForwarderCode, "DUGFF");
	vgmDetails := prenote.getMyVGMDetails;
	self.assertNotNull(vgmDetails);
	self.assertEqual(vgmDetails.vgmAuthSignature, "NORMIS BATES");
	self.assertEqual(vgmDetails.weightCertifiedName, "JOHN P. SMITH");
	self.assertEqual(vgmDetails.weightCertifiedReference, "UT_CL_VOY1");
	
	//01 Jul 2020	NDL	TFS 49606
	self.assertTrueMsg( prenote.isOnSite, prenote.id &amp; " is not on site");
	receive := prenote.getTransReceive();
	self.assertTrueMsg( receive &lt;&gt; null, prenote.id &amp; " has no receive");
	create sealNumbers transient;
	receive.getSealsAtReceiveArray( "SHIP", sealNumbers);
	self.assertTrueMsg( not sealNumbers.isEmpty, prenote.id &amp; " has no SHIP seal checks");
	self.assertTrueMsg( sealNumbers.first = "3125304", prenote.id &amp; " SHIP seal number not correct");
	//04 Feb 2021	NDL	TFS 50749
	sealNumbers.clear();
	receive.getUnknownSealsAtReceiveArray( "SHIP", sealNumbers);
	self.assertTrueMsg( not sealNumbers.isEmpty, prenote.id &amp; " has no UNKNOWN seal checks");
	self.assertTrueMsg( sealNumbers.first = "UNKSEAL001", prenote.id &amp; " UNKNOWN seal number not correct");
	
epilog

	delete sealNumbers;
//	delete strArray;

end;</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="tCoparnSNOBookPrenoteVGM" id="842297bc-cc1d-4506-a8b3-11a6ae55a218">
        <source>tCoparnSNOBookPrenoteVGM();
//
// 13 Feb 2018	jlgrs1	TFS 36945 CTA+RP not working in COPARN
// 30 Jul 2019	jlgsl4	TFS 45766 - SNO - Inconsistent weight information
//
constants
	HSDExample : String = "HSDExample";
	KKKExample : String = "KKKExample";
	GBExample : String = "GBExample";
	USER_DEF_NAME	: String = "SNO_COPARN";
	VesselCode : String = "SNOVESSEL";
	Voyage_Code : String = "7905N";
	EDIPartyName : String = "SNO_COPARN7905";
	BookingNo : String = "0530215931";
	Prenote1 : String = "GSLM2012170";
	VehicleId : String = "UTTRUCK1";
vars
	terminal : CM_Terminal;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	subTerminal : CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
	coparnInput : String;
	errorMsg : String;
//	booking : CM_BookingRef;
//	bookingItems : Integer;
	prenote : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	vgmDetails : CM_VGMDetails;
begin
	self.doCoparnSNOBookPrenoteVGM(false);
	self.doCoparnSNOBookPrenoteVGM(true);
//return;
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	self.setTerminalConfig(EdiUseOldCoparn, false);
	terminal := self.getTerminal;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	self.deleteVessel(VesselCode);
	vessel := self.getVessel(VesselCode);
	self.assertIsDeleted(vessel);
	self.deleteVoyage(Voyage_Code);
	voyage := self.getVoyage(Voyage_Code);
	self.assertIsDeleted(voyage);
	self.createVoyageVessel(Voyage_Code, VesselCode, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	// Create the party rules.
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, "TOFU", operator);
	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;

	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::createPrenotesForEQDWithID.name, true);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;

	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '12', CM_EDIEDIFactRule.Function_BGM_1_1_Release);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '27', CM_EDIEDIFactRule.Function_BGM_1_1_Prenote);

	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;

	coparnInput := self.zCoparnFileSNO;
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"1"&amp;method.name);
	self.assertNotNull(ediFile);
//	filesToDelete.add(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.isWeightCertified, false);
	vgmDetails := prenote.getMyVGMDetails;
	self.assertNull(vgmDetails);

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	
	// gate in the container with no carrier
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.opts.addAssoc("AutoComplete", true);
	vvr := self.gateInPrenote(VehicleId, "", "", prenote, singleGate);
	self.assertNotNull(vvr);
	assertTrue(getTrackedItem(Prenote1).isOnSite);
	beginTransaction;
	ediParty.allEDIPartyRules.first.setPropertyValue(CM_EDIPartyCoparnRules::updateVGMForOnsiteCargo.name, true);
	commitTransaction;
	coparnInput := self.zCoparnFileSNO3;
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
//		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.isWeightCertified, true);
	self.assertEqual(prenote.getTareWeight().Integer, 3800); // TFS 45766
	self.assertEqual(prenote.weightCargo.Integer, 19200); // TFS 45766
	vgmDetails := prenote.getMyVGMDetails;
	self.assertNotNull(vgmDetails);
	self.assertEqual(vgmDetails.vgmAuthSignature, "NORMIS BATES");
	self.assertEqual(vgmDetails.weightCertifiedName, "JOHN P. SMITH");
	self.assertEqual(vgmDetails.weightCertifiedReference, "UT_CL_VOY1");
epilog

end;</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="tCoparnSNOBookPrenoteVGM2" id="85c782d0-2a9e-49ac-b55d-a417f4ad8661">
        <source>tCoparnSNOBookPrenoteVGM2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgns1	Initial creation
30 Jul 2019	jlgsl4	TFS 45766 - SNO - Inconsistent weight information
*/
constants
	HSDExample : String = "HSDExample";
	KKKExample : String = "KKKExample";
	GBExample : String = "GBExample";
	USER_DEF_NAME	: String = "SNO_COPARN";
	VesselCode : String = "SNOVESSEL";
	Voyage_Code : String = "7905N";
	EDIPartyName : String = "SNO_COPARN7905";
	BookingNo : String = "0530215931";
	Prenote1 : String = "GSLM2012170";
	VehicleId : String = "UTTRUCK1";
vars
	terminal : CM_Terminal;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	subTerminal : CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
	coparnInput : String;
	errorMsg : String;
//	booking : CM_BookingRef;
//	bookingItems : Integer;
	prenote : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	vgmDetails : CM_VGMDetails;
begin
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	self.setTerminalConfig(EdiUseOldCoparn, false);
	terminal := self.getTerminal;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	self.deleteVessel(VesselCode);
	vessel := self.getVessel(VesselCode);
	self.assertIsDeleted(vessel);
	self.deleteVoyage(Voyage_Code);
	voyage := self.getVoyage(Voyage_Code);
	self.assertIsDeleted(voyage);
	self.createVoyageVessel(Voyage_Code, VesselCode, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	// Create the party rules.
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, "TOFU", operator);
	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;

	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::createPrenotesForEQDWithID.name, true);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;

	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '12', CM_EDIEDIFactRule.Function_BGM_1_1_Release);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '27', CM_EDIEDIFactRule.Function_BGM_1_1_Prenote);

	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;
	
//	if self.opts.includesKey("DoCoparn4") then
//		coparnInput := self.zCoparnFileSNO4;
//	else
		coparnInput := self.zCoparnFileSNO;
//	endif;
	
	
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"1"&amp;method.name);
	self.assertNotNull(ediFile);
//	filesToDelete.add(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.isWeightCertified, false);
	vgmDetails := prenote.getMyVGMDetails;
	self.assertNull(vgmDetails);

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	
	// gate in the container with no carrier
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.opts.addAssoc("AutoComplete", true);
	vvr := self.gateInPrenote(VehicleId, "", "", prenote, singleGate);
	self.assertNotNull(vvr);
	assertTrue(getTrackedItem(Prenote1).isOnSite);
	beginTransaction;
	ediParty.allEDIPartyRules.first.setPropertyValue(CM_EDIPartyCoparnRules::updateVGMForOnsiteCargo.name, true);
	commitTransaction;
	
	coparnInput := self.zCoparnFileSNO4;
	
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
//		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	self.assertEqual(prenote.bookingReference, BookingNo);
	self.assertEqual(prenote.isWeightCertified, true);
	self.assertEqual(prenote.getTareWeight().Integer, 3800); // TFS 45766
	self.assertEqual(prenote.weightCargo.Integer, 19200); // TFS 45766
	vgmDetails := prenote.getMyVGMDetails;
	
	self.assertNullMsg(vgmDetails,"VGM is not null");
	
epilog

end;</source>
