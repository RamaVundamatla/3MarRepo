    <JadeMethod name="create" id="e0f28405-77e9-49a6-9859-77344eb95aa4">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2017	cnwndl1	Initial creation

*/

vars

begin

	self.permissionView  := PmGteMTReleaseView;
	self.permissionMaint := PmGteEmptyReleaseMaintAll;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="a819b09c-7ae5-4972-93ea-cc6df6de0582">
        <updating/>
        <source>doOK() updating;
/*

Date		Who		Reason
24 February 2017	cnwndl1	Initial creation	TFS 3514

*/

vars

begin

	if self.perWagonAmount then
		if not self.validPerWagonAmount() then
			return;
		endif;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getQuantity" id="cecbe03c-a850-4912-85d1-e4bcf800fdda">
        <source>getQuantity() : Integer;
/*

Date		Who		Reason
24 February 2017	cnwndl1	Initial creation	TFS 3514

*/

vars

	quantity : Integer;
	
begin
	quantity := self.txtQuantity.text.Integer;
	
	if quantity &lt;= 0 or quantity &gt; self.maxQuantity then
		quantity:= self.maxQuantity;
	endif;
	
	return quantity;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWeightMovedKgs" id="80b9dccc-d278-4089-9a0c-50cdfaeabc1d">
        <source>getWeightMovedKgs() : Decimal;
/*

Date		Who		Reason
24 February 2017	cnwndl1	Initial creation	TFS 3514

*/

vars

	kgValue, volume  : Decimal[14,4];

begin
	if self.myCargoType = null then
		return null;
	endif;
	
	if self.myCargoType.isTrackByWeight then
		kgValue:=self.tblAmount.getConvertedValue();
		
	else
		volume:=self.tblAmount.getConvertedValue();
		kgValue:= volume * self.myReserveDetail.getDensity;

	endif;
	
	if kgValue &lt;= 0 or kgValue &gt; self.maxWeight then
		kgValue := self.maxWeight;
	endif;
	
	return kgValue;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="70da1a8c-2b2c-4ab9-89fc-98dea3cb7e55">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
24 February 2017	cnwndl1	Initial creation	TFS 3514

*/

vars
	
	convertedAmount : String;
	measurementType : CM_MeasurementType;
	amountStr : String;
	
begin
	inheritMethod();

	self.byQuantity:=false;
	
	if self.myReserveDetail &lt;&gt; null and self.myWagon &lt;&gt; null then
		self.lblInfo.caption := app.getErrorString1( AssignTo, self.myReserveDetail.getDescription ) &amp; self.myWagon.id;
	elseif self.myCargoType &lt;&gt; null and not self.allWagons.isEmpty then	//02 Dec 2020	NDL	TFS 50164
		self.perWagonAmount := true;
	endif;
	
	self.tblAmount.top:=self.txtQuantity.top;
	self.tblAmount.left:=self.txtQuantity.left;
	self.frmMain.transparent:=true;
	
	
	if self.myCargoType.isBreakBulkMulti then
		self.byQuantity := true;
		self.txtQuantity.visible := true;
		self.txtQuantity.zOrder(1);
		self.txtQuantity.dataType := TextBox.DataType_Numeric;
		self.txtQuantity.decimals := 0;	
		if self.perWagonAmount then		//02 Dec 2020	NDL	TFS 50164
			lblAmount.caption := app.getErrorString(CM_Quantity) &amp; " " &amp; app.getErrorString(Per_Wagon);
			self.txtQuantity.text := ( maxQuantity / self.allWagons.size ).Integer.String;
		else
			lblAmount.caption := app.getErrorString(CM_Quantity);
			self.txtQuantity.text := maxQuantity.String;
		endif;
		self.tblAmount.visible:=false;
		self.caption:=app.getErrorString(Confirm_quantity_assign);
		
	elseif self.myCargoType.isBulkMulti then
		self.txtQuantity.visible:=false;
		self.tblAmount.visible:=true;
		self.tblAmount.zOrder(1);
		if self.myCargoType.isTrackByWeight then	
			self.caption:=app.getErrorString(Confirm_weight_assign);
			self.tblAmount.setup(Type_Weight, self.backColor);
			measurementType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
			if self.perWagonAmount then		//02 Dec 2020	NDL	TFS 50164
				self.lblAmount.caption:= app.getErrorString(CM_Weight) &amp; " " &amp; app.getErrorString(Per_Wagon);
				convertedAmount := app.convertMeasurementForDisplay(measurementType.shortName, self.maxWeight / self.allWagons.size );
			else
				self.lblAmount.caption:= app.getErrorString(CM_Weight);
				convertedAmount := app.convertMeasurementForDisplay(measurementType.shortName, self.maxWeight);
			endif;
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; measurementType.shortName);
		else
			self.caption:=app.getErrorString(Confirm_volume_assign);		
			self.tblAmount.setup(Type_Volume, self.backColor);	
			measurementType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
			if self.perWagonAmount then		//02 Dec 2020	NDL	TFS 50164
				self.lblAmount.caption:= app.getErrorString(CM_Volume) &amp; " " &amp; app.getErrorString(Per_Wagon);
				convertedAmount := app.convertMeasurementForDisplay(measurementType.shortName, self.maxVolume / self.allWagons.size );
			else
				self.lblAmount.caption:= app.getErrorString(CM_Volume);
				convertedAmount := app.convertMeasurementForDisplay(measurementType.shortName, self.maxVolume);
			endif;
			self.tblAmount.setValues(convertedAmount &amp; " " &amp; measurementType.shortName);
		endif;
		self.tblAmount.tabKey:=J_key_Tab;
		
	else	//02 Dec 2020	NDL	TFS 50164
		self.byQuantity := true;
		self.txtQuantity.visible := true;
		self.txtQuantity.zOrder(1);
		self.txtQuantity.dataType := TextBox.DataType_Numeric;
		self.txtQuantity.decimals := 0;	
		if self.perWagonAmount then
			lblAmount.caption := app.getErrorString(CM_Quantity) &amp; " " &amp; app.getErrorString(Per_Wagon);
			self.txtQuantity.text := ( maxQuantity / self.allWagons.size ).Integer.String;
		else
			lblAmount.caption := app.getErrorString(CM_Quantity);
			self.txtQuantity.text := maxQuantity.String;
		endif;
		self.tblAmount.visible:=false;
		self.caption:=app.getErrorString(Confirm_quantity_assign);
		
	endif;
	
	//02 Dec 2020	NDL	TFS 50164
	if self.perWagonAmount then
		if self.myCargoType.isBreakBulkMulti then
			amountStr := maxQuantity.String;
		elseif self.myCargoType.isBulkMulti then
			if self.myCargoType.isTrackByWeight then
				amountStr := app.convertMeasurementForDisplay(measurementType.shortName, self.maxWeight) &amp; " " &amp; measurementType.shortName;
			else
				amountStr := app.convertMeasurementForDisplay(measurementType.shortName, self.maxVolume) &amp; " " &amp; measurementType.shortName;
			endif;
		else
			amountStr := maxQuantity.String;
		endif;
		self.lblInfo.caption := app.getErrorString1( AssignTo, self.myCargoType.description &amp; " (x" &amp; amountStr &amp; ") " ) &amp; " " &amp; self.allWagons.size.String &amp; " wagons";
	endif;
			
epilog

	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="59971ded-50ec-44d6-97e0-29e3655fbe9f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 February 2017 08:19:27.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021912, locale);
	lblAmount.translateCaption(Xlat_0021913, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validPerWagonAmount" id="1275e131-796c-4ece-a7c0-d0f85b1e67b4">
        <source>validPerWagonAmount():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2020	jlgndl1	Initial creation	TFS 50164

*/

vars

	qty: Integer;
	wt : Decimal[14,4];
	volume : Decimal[14,4];
	msg : String;

begin

	if not self.perWagonAmount then
		return true;
		
	else
		if self.myCargoType.isBreakBulkMulti then
			qty := self.getQuantity;
			if qty * self.allWagons.size &gt; maxQuantity then
				msg := app.getErrorString1( Not_assign_more_than_wagon, ( maxQuantity / self.allWagons.size ).Integer.asStringJMT );
				return false;
			endif;
			
		elseif self.myCargoType.isBulkMulti then
			if self.myCargoType.isTrackByWeight then
				wt := self.getWeightMovedKgs;
				if wt * self.allWagons.size &gt; maxWeight then
					msg := app.getErrorString1( Not_assign_more_than_wagon, ( self.maxWeight / self.allWagons.size ).asStringJMT );
					return false;
				endif;
			else
				volume := self.tblAmount.getConvertedValue();
				if volume * self.allWagons.size &gt; maxVolume then
					msg := app.getErrorString1( Not_assign_more_than_wagon, ( self.maxVolume / self.allWagons.size ).asStringJMT );
					return false;
				endif;

			endif;
	
		endif;	
		
		return true;
	
	endif;

	

epilog

	if msg &lt;&gt; null then
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
