    <JadeMethod name="setControlsForAddEdit" id="31a754dd-5f4d-4496-9a7d-fc5932bb4cdf">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation  JIRA-35632

*/

vars
	theForm 	: SOP_TableMaintForm;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;

begin
   	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	entTableDef := app.myController.getEntTableDef(self.getEntTableDef);
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
	endforeach;
	
	
	
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.myAssistant.comboBoxBestPickDateType(theForm.tblInput1, ETRow_BestPickDateType,app.getErrorString(Receival_DT));	
		theForm.tblInput1.gotFocus(theForm.tblInput1);	
		self.allCriteria.purge();
	else
		self.showThumbnail(theForm.myCurrentObject.CM_BestPickPriority);
	endif;
    theForm.tblInput1.cnEcResizeContents;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="0818226d-d7d3-4998-b24e-f24fc7424dcf">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation  JIRA-35632

*/

vars
	tmpMenu : MenuItem;
	theForm : SOP_TableMaintForm;

begin

	inheritMethod(conwin);
	
	theForm := self.myForm;
	theForm.mnuContext1.caption	:= app.getErrorString(Updat_onsit_cargo_best_pick_pr);
	if theForm.tblData.row &gt; theForm.tblData.fixedRows
	and app.getMyUser.canDo( self.myForm.myTerminal, self.permissionMaint ) 
	then
		theForm.mnuContext1.userObject := theForm.tblData.accessRow( theForm.tblData.row ).itemObject;
		theForm.mnuContext1.visible := true;
	else
		theForm.mnuContext1.userObject := null;
		theForm.mnuContext1.visible := false;
	endif;
	
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false );

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="687a0693-a3ea-4cc3-9f87-10f5d4329823">
        <updating/>
        <source>showThumbnail(pObj: CM_BestPickPriority) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation  JIRA-35632

*/

vars
	form : CM_BaseForm;
	table : CM_EntryTable;
	str  : String;
	height,
	rowIdx : Integer;
	row : JadeTableRow;
	criteria, 
	proxyCriteria	: CM_YABestPickCriteria;	
begin
	form:=self.myForm;
	table:=self.myForm.tblInput1;
		
	if pObj = null then
		self.myForm.tblInput1.setValueByName(ETRow_Criteria, 'Dbl-Click to update');	
	endif;
	
	table.clearValues;
	
	table.setValueByName(ETRow_Code, pObj.code);
	table.setValueByName(ETRow_Priority, pObj.priority);	
	form.myAssistant.comboBoxBestPickDateType(self.myForm.tblInput1, ETRow_BestPickDateType, CM_BestPickPriority@getBestPickDateTypeDesc(pObj.bestPickDateType));
	
	if not pObj.pxyIsProxy then		// new table row (not just refreshing from proxy), reload criteria
	
		self.allCriteria.purge();
		foreach criteria in pObj.allCriteria do
				create proxyCriteria transient;
				proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
				self.allCriteria.add( proxyCriteria.getTransient() );
		endforeach; 
	
	endif;
	
	str :=pObj.getCriteriaText();
	
	if str &lt;&gt; null then
		table.setValueByName(ETRow_Criteria,str);
		rowIdx 		:= table.getRowByName(ETRow_Criteria);
		if rowIdx &gt; 0 then
			table.accessCell(rowIdx, CM_EntryTable.ColumnValue).wordWrap := true;
			height 		:= table.getTextHeightForWidth(str, table.accessColumn(CM_EntryTable.ColumnValue).width - 18).Integer + 10;
			row 		:= table.accessRow(rowIdx);
			row.height 	:= height;
		endif;
	endif;
	
	table.cnEcResizeContents();

epilog

end;</source>
        <Parameter name="pObj" type="CM_BestPickPriority"/>
    </JadeMethod>
</Class>
