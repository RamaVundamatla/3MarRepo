        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSampleData_rowColumnChg(table: Table input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.lblCharPos.caption := 'Character Pos:' &amp; table.column.String;

end;


</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblUserFieldCode_contextMenu" id="a14c979e-3240-449f-8dd4-0d4b38a5765f">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblUserFieldCode_contextMenu(table: CM_DataTable input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Date		Who		Reason
11 Sep 2008	cnwrd1	Initial creation
23/09/2009	cnwcs5	par 20320 - multiple record types
*/

vars
	tmpComboList : ObjectArray;
begin
	//par #18402 ++ show list on edi data type selected
	if self.cmbEDIDataType.listIndex &lt; 1 then
		return false;
	endif;
	
	if mode = MODE_VIEW then
		return false;
	endif;
	
	if table.accessRow(table.row).itemObject &lt;&gt; null  then
		self.mnuDeleteCodeHook.visible 	:= true;
		self.mnuEditCodeHook.visible 	:= true;//par #18402
	else
		self.mnuDeleteCodeHook.visible 	:= false;	
		self.mnuEditCodeHook.visible 	:= false;//par #18402
	endif;
	
	tmpComboList :=  self.buildHookFieldNewList(table);
	
	if tmpComboList.size &gt; 0 then
		self.mnuAddCodeHook.visible := true;
	else
		self.mnuAddCodeHook.visible := false;
	endif;
	
	self.mnuContextCHTbl.userObject := table;	// cnwcs 23/09/2009
	
	return self.showContextMenu(self.mnuContextCHTbl, table, conwin, mouse, x, y);
epilog
	delete tmpComboList;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblUserFieldCode_dblClick" id="f5f39577-711a-4f20-a33e-42a1603eae9d">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblUserFieldCode_dblClick(_table: CM_DataTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2008	cnwrd1	Initial creation

*/

vars
	
begin
	if _table.column = _table.getColumnByRowName(ETRow_Code) then
		if _table.userInputEnabled = false then
			self.showHookCodeMaintForm(true, _table);
		else
			self.showHookCodeMaintForm(false, _table);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b5f7bb6a-343b-44bd-8990-783c9a235b8c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 April 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007417, locale);
	btnBrowse.translateCaption(Xlat_0005025, locale);
	btnDelete.translateCaption(Xlat_0000372, locale);
	btnEdit.translateCaption(Xlat_0000374, locale);
	btnExportDef.translateBubbleHelp(Xlat_0005026, locale);
	btnExportDef.translateCaption(Xlat_0005027, locale);
	btnImportDef.translateBubbleHelp(Xlat_0005028, locale);
	btnImportDef.translateCaption(Xlat_0005029, locale);
	btnLineHookAdd.translateCaption(Xlat_0009856, locale);
	btnLineHookDel.translateCaption(Xlat_0009857, locale);
	btnLineHookView.translateCaption(Xlat_0009858, locale);
	btnLoad.translateCaption(Xlat_0005030, locale);
	btnNew.translateCaption(Xlat_0000376, locale);
	btnSettings.translateCaption(Xlat_0009859, locale);
	btnUserTypes.translateCaption(Xlat_0000370, locale);
	chkActive.translateCaption(Xlat_0014547, locale);
	chkXlations.translateCaption(Xlat_0014548, locale);
	grpAutoEmail.translateCaption(Xlat_0005033, locale);
//	grpFieldMap.translateCaption(Xlat_0000377, locale);
	grpFileDetails.translateCaption(Xlat_0005034, locale);
	grpHookCode.translateCaption(Xlat_0013432, locale);
	grpMappings.translateCaption(Xlat_0013433, locale);
	grpSampleData.translateCaption(Xlat_0005035, locale);
	grpXlate.translateCaption(Xlat_0013434, locale);
	lLineCode.translateCaption(Xlat_0009860, locale);
	lblCharPos.translateCaption(Xlat_0005036, locale);
	lblControlCol.translateCaption(Xlat_0013435, locale);
	lblControlColVal.translateCaption(Xlat_0013436, locale);
	lblDataType.translateCaption(Xlat_0014549, locale);
	lblDateDelimiter.translateCaption(Xlat_0014550, locale);
	lblDateFormat.translateCaption(Xlat_0014551, locale);
	lblFieldDelim.translateCaption(Xlat_0014552, locale);
	lblFileDef.translateCaption(Xlat_0014553, locale);
	lblFileName.translateCaption(Xlat_0014554, locale);
	lblFormatType.translateCaption(Xlat_0014555, locale);
	lblIgnoreFirst.translateCaption(Xlat_0014556, locale);
	lblKeywords.translateCaption(Xlat_0013437, locale);
	lblLines.translateCaption(Xlat_0014557, locale);
	lblLines2.translateCaption(Xlat_0014558, locale);
	lblLines3.translateCaption(Xlat_0013438, locale);
	lblLoadLines.translateCaption(Xlat_0014559, locale);
	lblName.translateCaption(Xlat_0014560, locale);
	lblNoFields.translateCaption(Xlat_0014561, locale);
	lblSearch.translateCaption(Xlat_0013439, locale);
	lblXlatOperator.translateCaption(Xlat_0013440, locale);
	mnuAddCodeHook.translateCaption(Xlat_0009861, locale);
	mnuContextCHTbl.translateCaption(Xlat_0009862, locale);
	mnuContextMapping.translateCaption(Xlat_0019112, locale);
	mnuDeleteCodeHook.translateCaption(Xlat_0009863, locale);
	mnuDeleteMapping.translateCaption(Xlat_0019113, locale);
