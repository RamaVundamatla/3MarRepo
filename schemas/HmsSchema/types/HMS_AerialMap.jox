    <JadeMethod name="setupForm" id="e9385436-70d0-4ea7-84fe-d0080b2a0376">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 18 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();
	self.first := true;
	self.picBackground.autoRedraw := true;
	// setup the hotspots
	self.buildBerthArrayHotspots();
	self.setNavigatorHeading(self.caption);	
	self.btnClose.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="snapAerialView" id="ea83219a-e057-4080-afb1-f6b226a77c7d">
        <updating/>
        <source>snapAerialView(pBerth:HMS_Berth)updating;

vars
	i : Integer;
	c : Control;
begin
	
	if pBerth &lt;&gt; null then
		if self.berthArray.indexOf(pBerth) = self.currentIndex then
			// already selected
			return;
		endif;	
		i := 1;
		while i &lt;= controlCount do
			c := controls(i);
			if c.userObject = pBerth then
				drawHotspot(c,Green);
				break;
			endif;
			i := i + 1;
		endwhile;
	else
		// showing all wharves/berths - so clear circles
		picBackground.clearGraphics;
	endif;

end;</source>
        <Parameter name="pBerth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="snapGraphicalView" id="c16c071b-76d0-4b89-ada7-2aee50c7ff7a">
        <updating/>
        <source>snapGraphicalView(pict:Control)updating, protected;

vars

begin
	
	self.myGraphicalViewForm.snapBerthPointer;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="pict" type="Control"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="286eb849-dd0e-4b24-a3af-df92251ae71b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005817, locale);
	btnClose.translateCaption(Xlat_0001392, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMovement" id="7eac4f80-bba0-4da0-8b0b-b6971c35b0d9">
        <updating/>
        <source>updateMovement(berth:HMS_Berth):Boolean updating, protected;

vars
	origCurrent			: CMIF_HMS_WorkingMovement;
	origNext			: CMIF_HMS_WorkingMovement;
	clonedMovement		: CMIF_HMS_WorkingMovement;
	clonedMovementNext	: CMIF_HMS_WorkingMovement;
	clonedVoyage		: CMIF_HMS_WorkingVoyage;
	wp					: CMIF_HMS_WharfPosnCheckParams;
	cntrl				: HMS_GraphicalDragPicture;
	changeOK			: Boolean;
	harbourObj			: HMS_Harbour;

begin
	// Set default for changeOK
	changeOK := false;
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();		

	cntrl := self.myGraphicalViewForm.myCurrentDragPicture;
	origCurrent 	:= cntrl.myWorkingMovement;
	origNext		:= cntrl.myNextWorkingMovement;

	// Clone voyage and movements
	//origCurrent.myWorkingVoyage.createClone;
	clonedVoyage:= origCurrent.myWorkingVoyage.createClone();//myViewController.ofCurrentClonedVoyage;
    clonedMovement 		:= origCurrent.myClone;
	clonedMovementNext	:= clonedMovement.getMovementNext;


	if origCurrent &lt;&gt; null then
		// Auto Calculate new marks for ship on this berth 
		// -------------------------------------------------------------
		create wp transient;
		wp.berth:=berth;
		wp.myWorkingMovementToCheck:=clonedMovement;
		wp.bowMark:=clonedMovement.bowMarkTo;
		wp.sternMark:=clonedMovement.sternMarkTo;
		wp.foreClearance:=clonedMovement.foreClearanceTo;
		wp.aftClearance:=clonedMovement.aftClearanceTo;
		wp.controller:=myViewController;
		wp.orientation:=clonedMovement.sideTo;
		//wp.ship:=clonedMovement.myWorkingVoyage.getMyVessel;
		wp.myHMSVoyageData:=clonedMovement.myWorkingVoyage.myHMSVoyageData;		
		if	clonedMovement.berthing_AutoPositionOnBerth(wp) then
			changeOK := true;			
			clonedMovement.myBerth 			:= wp.berth;
			clonedMovement.bowMarkTo 		:= wp.bowMark;
			clonedMovement.sternMarkTo		:= wp.sternMark;
			clonedMovement.foreClearanceTo	:= wp.foreClearance;
			clonedMovement.aftClearanceTo	:= wp.aftClearance;
			clonedMovement.sideTo			:= wp.orientation; 
		endif;
		// ----------------------------------------------------------------

		if changeOK then
			// Continue with checks
			clonedMovement.cloneHasChanged:=true;
		else
			return false;
		endif;

	endif;
	
	if self.myTerminal &lt;&gt; null then
		harbourObj	:=	self.myTerminal.myHarbour;
	endif;
	
	//	Validate voyage
	if harbourObj &lt;&gt; null and (not clonedVoyage.validateVoyage(harbourObj.isDoClearanceCheck)) then
		return false;
	endif;

	if app.myPassport.hasErrorsOrWarnings() then
		if app.showErrorWarningDialog('Update Movement', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings) = IDOK then
			//Warnings have been accepted
		else
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
	endif;
	self.clearErrorWarnings();
	// disarm the validation ex handler	
	on CM_Exception do null;	
		
	// Update views following the result of the validation
	foreach clonedMovement in clonedVoyage.allClonedMovements where clonedMovement.CMIF_HMS_WorkingMovement.cloneHasChanged=true do
		clonedMovement.createWorkingMovement(null,false,false, false);
	endforeach;
	clonedVoyage.ofViewController.view_BuildEntireForeground();
	return true;

epilog
	// Delete clonedVoyage, resources and movements
	foreach clonedMovement in clonedVoyage.allClonedMovements do
		clonedMovement.allWorkingResUsed.purge;
	endforeach;
	clonedVoyage.allClonedMovements.purge;
	delete clonedVoyage;
	delete wp;	
end;</source>
        <access>protected</access>
        <Parameter name="berth" type="HMS_Berth"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
