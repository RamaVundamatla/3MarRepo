<Class name="BGP_FutureTimerController" id="22c510b5-cbec-4f2f-ac1b-1768e1da0b1d">
    <superclass name="BGP_TimerController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;This future processing controller must be running in order for timed future requests to be processed.&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="doTimerEvent" id="bfd2fe58-aec6-42ee-8c98-ca728339d321">
        <updating/>
        <source>doTimerEvent() updating, protected;
// this fires once, from the BGP_TimerController initApp code, then uses a CM_OfflineFutureActorHandler for the actual processing
vars

	error 		: Integer;
	errorText	: String;

begin

	on Exception do app.alertExceptionHandler(exception, null,'Timer BGP Controller Event', error, errorText, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	self.processTimer();

epilog

	self.endTimer(AutoTimer_Event_Tag);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="cf94d094-a7fa-485a-b18c-69b68045c437">
        <source>getDisplay() : String;

vars
	start,
	queued	: String;
	request : BGP_Request;
	invalid	: Boolean;
	
begin
	on Exception do self.xHandlerDisplay(exception);

	queued := app.myRoot.allOfflineFutureActors.size.String;

	return Tab &amp; Tab &amp; Tab &amp; self.displayString &amp; Tab &amp; self.machineName &amp; Tab &amp; self.dateTimeLastStarted.bgpDisplay() &amp;  Tab &amp; queued &amp; 
	Tab &amp; start &amp; Tab &amp; self.dateTimeLastCompleted.bgpDisplay() &amp; Tab &amp; self.isRunning().asRunningStopped(self.isSetup) &amp; Tab &amp; self.isRunningSDSDisplay();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTimer" id="c28382cd-4bb3-451a-a1df-183dfaede4b3">
        <updating/>
        <source>processTimer() updating, protected;
// one-off, from timerEvent here.  Set up a CM_OffflineActorHandler and CM_OfflineFutureActorHandler to do the actual processing
vars
	actorHandler	: CM_OfflineActorHandler; 
	futureHandler	: CM_OfflineFutureActorHandler; 
begin
	create actorHandler transient;
	actorHandler.start(self);

	create futureHandler transient;
	futureHandler.start(self);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="06c4523a-78c2-4830-9e93-8cf54cfbccf1">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

vars

begin
	inheritMethod();
	self.name			:= 'Future Timer Runner';
	self.timerInterval	:= 1;		// non-zero for the isSetup method but low to get the first timer event just after it starts
	self.isEditable		:= true;
end;
</source>
        <access>protected</access>
    </JadeMethod>
</Class>
