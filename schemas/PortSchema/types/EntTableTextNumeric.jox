    <JadeMethod name="initialiseCellControl" id="9ff9c77c-d53e-4464-b5f0-afac74c6508a">
        <source>initialiseCellControl(pCell : JadeTableCell input);
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txtBox	: TextBox;

begin

	pCell.inputType	:= Table.InputType_TextNumeric;

	pCell.decimals	:= self.decimals;
	pCell.maxLength	:= self.maxLength;

	inheritMethod(pCell);

end;</source>
        <Parameter name="pCell" type="JadeTableCell" usage="input"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="620ee363-a66b-479a-b99f-43d3eb8c7b86">
        <source>outputAsXML(): String;
// ---------------------------------------------------------------------------
// Created:     27 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.xmlPrefix &amp;
	       self.formatAsXML(XMLTag_Decimals, self.decimals.String) &amp;
	       self.formatAsXML(XMLTag_MaxLength, self.maxLength.String) &amp;
	       self.xmlSuffix;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="98e08bbd-0db2-4f34-a87d-467250babfc6">
        <updating/>
        <source>setForCreate(pProxy: EntTableTextNumeric; pRow: EntTableRow) updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.decimals	:= pProxy.decimals;
	self.maxLength	:= pProxy.maxLength;

	inheritMethod(pProxy, pRow);

end;</source>
        <Parameter name="pProxy" type="EntTableTextNumeric"/>
        <Parameter name="pRow" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="setFromXMLElement" id="bcba1993-e96b-4ae3-ad63-3d865c18d20d">
        <updating/>
        <source>setFromXMLElement(_xmlElement : JadeXMLElement; pRow : EntTableRow) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.decimals	:= _xmlElement.getTagValueOfName(XMLTag_Decimals).Integer;
	self.maxLength	:= _xmlElement.getTagValueOfName(XMLTag_MaxLength).Integer;

	return inheritMethod(_xmlElement, pRow);

end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <Parameter name="pRow" type="EntTableRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
