    <JadeMethod name="doBtnRateSaveClick" id="1a97cdca-22cb-43a6-bbeb-95f396277a26">
        <updating/>
        <source>doBtnRateSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//20/03/2018	jlgrh7 TFS 37476 ADP - FW: Cannot Override the rate on Discount Line.
// ---------------------------------------------------------------------------

vars
	theController : CMIF_ChargesController;
	pxyCharges : CM_ChargeByServiceRateOvrdDict;
	index:                  Integer;
	theService:             CM_Service;
	currentlyOverridden:          Boolean;
	rateCurrent, rateNew:                Real;
	strrateNew:             String;
	chargeCount, theReturn :            Integer;
	theTable : CM_DataTable;
	col,row, rowSt, rowEnd, idx : Integer;
	aCharge, pxyCharge : CM_Charge;
	isReinstateRate : Boolean;									//+TFS37476
	
begin
	// ### Get all the rates off the table
	create theController transient;
	create pxyCharges transient;
	foreach aCharge in self.allORCharges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		theController.allCharges.add(pxyCharge);
	endforeach;

	theController.allCharges.copy(pxyCharges);
	
	theTable := self.tblRatesOR;

	theTable.column := 1;
	rowSt := theTable.fixedRows + 1;
	rowEnd := theTable.rows;
	
	foreach index in rowSt to rowEnd do
		theService := theTable.accessRow(index).itemObject.CM_Service;
// cnwdad1 20/05/2009 - PAR #17633.
//		rateCurrent := theTable.getCellValueByName(ETRow_CurrentRate,index).Real;
		rateCurrent := theTable.getCellValueByName(ETRow_CurrentRate,index).asRealJMT();
		currentlyOverridden := theTable.getCellValueByName(ETRow_Overridden,index).convertToBoolean(); 
		chargeCount := theTable.getCellValueByName(ETRow_Charges,index).Integer; 
		strrateNew := theTable.getCellValueByName(ETRow_NewRate,index);
		
		if strrateNew = "" then
			//rateNew := -1;												//-TFS37476
			isReinstateRate := true;								//+TFS37476
		else
// cnwdad1 20/05/2009 - PAR #17633.
//			rateNew := strrateNew.Real;
			isReinstateRate := false;
			rateNew := strrateNew.asRealJMT();
		endif;
		//self.setProxyCharge(theController.allCharges,theService, rateCurrent, currentlyOverridden, chargeCount, rateNew);													//-TFS37476
		self.setProxyCharge(theController.allCharges,theService, rateCurrent, currentlyOverridden, chargeCount, rateNew, isReinstateRate);					//+TFS37476
	endforeach;	
	theController.allCharges.clear;
	pxyCharges.copy(theController.allCharges);

	
	// ### Update in TRX
	if not theController.allCharges.isEmpty then
		while true do
			app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				self.frmRatesOR.visible := false;
				
				// ### TFS BUG 62926 02APR2024 NAVAB1 - have turned off NOTES for big rate changes, for performance, quicker to refresh.
				if theController.allCharges.size &gt;= 1000 then
					self.doQuery();
				endif;
				
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Charges_Update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	endif;
epilog
	foreach pxyCharge in theController.allCharges do 
		delete pxyCharge;
	endforeach;
	delete theController;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRateSetClick" id="e7c8079a-064a-4108-bcec-b6ad161c9cc1">
        <source>doBtnRateSetClick();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTable : CM_DataTable;
	col,row : Integer;
begin
	
	theTable := self.tblRatesOR;

	if theTable.row &lt;= theTable.fixedRows then
		app.msgBox("Please select a charge to update.","Rate Override Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	col := theTable.getColumnByRowName(ETRow_NewRate);
	row := theTable.row;

	theTable.accessCell(row,col).text := self.txtRateOR.text;


end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnStatusApprovedClick" id="f53998fe-b891-45f4-b809-8a406bdcaa19">
