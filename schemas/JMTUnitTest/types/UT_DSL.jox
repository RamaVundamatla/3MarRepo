	objSet : ObjectSet;
	weighBridgeObj : CM_WeighBridgeObj;
	genericController : BGP_GenericController;
	vehicleBookingSlotCont : BGP_VehicleBookingSlotCont;
	cargoRestrictionCriteria : CM_CargoRestrictionCriteria;
	consigneeConsignorTerminal : CM_ConsigneeConsignorTerminal;
	eDIDataBOLOutLog : CM_EDIDataBOLOutLog;
	//glblVoyageCommodityPlanning : CM_GlblVoyageCommodityPlanning; // jlgka1 TFS 45620 
	handHeldConfig : CM_HandHeldConfig;
	locationsController : CM_LocationsController;
	mTPoolingPartner : CM_MTPoolingPartner;
	masterQueue : CM_MasterQueue;
	menuAction : CM_MenuAction;
	menuUserItem : CM_MenuUserItem;
	multiMoveGroup : CM_MultiMoveGroup;
	request : CM_Request;
	sOHLocation : CM_SOHLocation;
	tISnapShot : CM_TISnapShot; 
	tempReading : CM_TempReading;
	toDoTask : CM_ToDoTask;
	trackedItem : CM_TrackedItem;
	voyageJob : CM_VoyageJob;
	trxCreateInOut : TST_trxCreateInOut;
	menuUserDtl : CM_MenuUserDtl;
	menuUserHdr : CM_MenuUserHdr;
	menuUserQuery : CM_MenuUserQuery;
	menuUserReport : CM_MenuUserReport;
	menuUserToolbar : CM_MenuUserToolbar;
	menuUserXTAB : CM_MenuUserXTAB;
	
begin

	fromUnitTestMethod := self.opts.bool("FromUnitTestMethod");

	if not fromUnitTestMethod then 
		if not app.isDevelopmentSystemMain() then
			// to prevent accidental use in DMAST until its going properly
			self.assertTrueMsg( false, "DMAST ONLY,  Not valid in this environment...." );
			return;
		endif;
	endif;
	
	process.isNDLref;

	app.isGarbageCollectionProcess := true;
		
	//term := '2351.397'.asOid.CM_Terminal;	//Terminal BLAH
	
	if self.opts.includesKey("TerminalToDelete") then
		term := app.myRoot.allTerminals[self.opts.str("TerminalToDelete")];
	endif;
	
	if term = null and not fromUnitTestMethod then
		app.msgBox(termName &amp; "No terminal selected.", "Bugger", MsgBox_OK_Only);
	endif;
	
