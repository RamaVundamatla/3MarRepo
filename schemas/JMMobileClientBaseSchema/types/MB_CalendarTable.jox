    <JadeMethod name="dragDrop" id="9de0f9fa-95db-48a6-aae5-f191ff262b1a">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(table, win, x, y);
	
	if self.dragRow &gt; 1 and self.dragColumn &gt; 0 then
		self.row	:=	self.dragRow;
		self.column	:=	self.dragColumn;
		
		if self.text &lt;&gt; null then
			self.myCalendar.changeType	:=	self.myCalendar.ChangeType_Day;
			self.myCalendar.date.setDate(text.Integer, self.myCalendar.date.month, self.myCalendar.date.year);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="f73676e8-621b-4980-b365-2a71680d1caf">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myCalendar.mouseDown(self.myCalendar, button, shift, table.left + x, table.top + y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="9d841f4f-92b7-4981-b1bb-01882cb1d97d">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>rowColumnChg(table: Table input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(table);
	
	if row &gt; 1 and text &lt;&gt; "" then
		self.myCalendar.changeType	:=	self.myCalendar.ChangeType_Day;
		self.myCalendar.date.setDate(text.Integer, self.myCalendar.date.month, self.myCalendar.date.year);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectDay" id="f33fb0d1-c038-43bc-9d86-39ef716ba942">
        <updating/>
        <source>selectDay(_date:Date) updating;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		Selects a date on the calendar control.
//
// Parameters:	_date - The date to select.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	colPointer	: Integer;
	
begin
	self.accessMode	:=	Table.AccessMode_Cell;
	rowPointer		:=	2;
	
	while rowPointer &lt;= self.rows do
		self.row	:=	rowPointer;
		colPointer	:=	1;
		
		while colPointer &lt;= self.columns do
			self.column	:=	colPointer;	
			
			if text = _date.day.String then
				self.foreColor	:=	self.myCalendar.backColor;
				self.backColor	:=	self.myCalendar.foreColor;
			else
				self.foreColor	:=	self.myCalendar.foreColor;
				self.backColor	:=	self.myCalendar.getSystemColor(Color_BtnFace);
			endif;
			
			colPointer	:=	colPointer + 1;
		endwhile;
		
		rowPointer	:=	rowPointer + 1;
	endwhile;
	
	self.row	:=	1;
	self.column	:=	1;
end;</source>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setCalendar" id="ddfa0a74-04e7-4bf8-a884-b74fc1b487ed">
        <updating/>
        <source>setCalendar(_calendarObj:MB_Calendar) updating;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		Sets a reference to the receiver's calendar control.
//
// Parameters:	_calendarObj - A reference to the calendar control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myCalendar	:=	_calendarObj;
end;</source>
        <Parameter name="_calendarObj" type="MB_Calendar"/>
    </JadeMethod>
    <JadeMethod name="showDays" id="fb1d689c-b3db-4507-a327-d8dc9134c09e">
        <updating/>
        <source>showDays(_date:Date) updating;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		Fills the calendar control with the days of the specified date's
//				month.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	colPointer	: Integer;
	dayDate		: Date;
	
begin
	rowPointer	:=	1;
	
	while rowPointer &lt;= self.rows do
		self.row	:=	rowPointer; 
		colPointer	:=	1;
		
		while colPointer &lt;= self.columns do
			self.column	:=	colPointer; 
			self.text	:=	null; 
			colPointer	:=	colPointer + 1;
		endwhile;
		
		rowPointer	:=	rowPointer + 1;
	endwhile;
	
	self.row	:=	1;
	dayDate.setDate(1, _date.month, _date.year);
	
	while dayDate.day &lt;= MB_Calendar.DaysOfWeek do
		self.column	:=	dayDate.dayOfWeek;
		self.text	:=	dayDate.dayName[1:myCalendar.dayNameLength];
		dayDate		:=	dayDate + 1;
	endwhile;
	
	self.row	:=	2;
	dayDate.setDate(1, _date.month, _date.year);
	
	while dayDate.month = _date.month do
		self.column	:=	dayDate.dayOfWeek;
		self.text	:=	dayDate.day.String;
		
		if self.column &gt;= self.columns then
			if self.row &gt;= self.rows then
				self.row	:=	2;
			else			
				self.row	:=	self.row + 1;
			endif;
		endif;
		
		dayDate	:=	dayDate + 1;
	endwhile;
end;</source>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
