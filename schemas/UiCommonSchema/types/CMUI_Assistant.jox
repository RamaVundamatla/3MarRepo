//----------------------------------------------------------------
//	Created:	24 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars

	 failedDAC  :CM_DataAccessController;

begin

	if _voyJob = null then
		return null;
	endif;

	if (not _voyJob.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	if _selected then
		return TableCheckBox_Selected &amp; Tab &amp; _voyJob.myVoyage.code &amp; " - " &amp; _voyJob.id;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; _voyJob.myVoyage.code &amp; " - " &amp; _voyJob.id;
	endif;
	
end;</source>
