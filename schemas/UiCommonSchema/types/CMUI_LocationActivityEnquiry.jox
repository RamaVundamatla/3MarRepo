    <JadeMethod name="setFilterValues" id="e3a77f4a-558a-44a0-bf6c-1ce3ea326e1e">
        <updating/>
        <source>setFilterValues()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	self.filterDateFrom := self.txtOpenDate.getDate();
	self.filterDateTo := self.txtCloseDate.getDate();
	
	self.filterCargoType := null;
	if self.cmbCargoType.listIndex &gt; 0 then
		self.filterCargoType := self.cmbCargoType.itemObject[ self.cmbCargoType.listIndex ].CM_CargoType;
	endif;
	
	self.filterOperator := null;
	if self.cmbOperator.listIndex &gt; 0 then
		self.filterOperator := self.cmbOperator.itemObject[ self.cmbOperator.listIndex ].CM_Operator;	
	endif;
	
	self.filterTrain := null;
	self.filterVoyage := null;
	self.filterVehicleVisitRecord := null;
	self.filterTerminalArea := null;
	self.filterLocation := null;
	
	if self.cmbLocationType.text = app.getErrorString(TerminalAreas) then
		if self.cmbLocationArea.listIndex &gt; 0 then
			self.filterTerminalArea := self.cmbLocationArea.itemObject[ self.cmbLocationArea.listIndex ].CM_TerminalArea;
		endif;
		if self.cmbLocation.listIndex &gt; 0 then
			self.filterLocation := self.cmbLocation.itemObject[ self.cmbLocation.listIndex ].CM_LocationsController;
		endif;
		
	elseif self.cmbLocationType.text = app.getErrorString(Voyages) then
		if self.cmbLocationArea.listIndex &gt; 0 then
			self.filterVoyage := self.cmbLocationArea.itemObject[ self.cmbLocationArea.listIndex ].CM_Voyage;
		endif;
		
	elseif self.cmbLocationType.text = app.getErrorString(Trains) then
		if self.cmbLocationArea.listIndex &gt; 0 then
			self.filterTrain := self.cmbLocationArea.itemObject[ self.cmbLocationArea.listIndex ].CM_Train;
		endif;
		
	elseif self.cmbLocationType.text = app.getErrorString(Vehicle_visit_records) then
		if self.cmbLocationArea.listIndex &gt; 0 then
			self.filterVehicleVisitRecord := self.cmbLocationArea.itemObject[ self.cmbLocationArea.listIndex ].CM_VehicleVisitRecord;
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setLocationCombos" id="b8109fa5-5528-4027-9c9b-8e74ae5c3bf7">
        <updating/>
        <source>setLocationCombos() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	selectedObject : Object;
	selectedLc : CM_LocationsController;
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	typeString : String;
	index : Integer;
	
	train : CM_Train;
	voyage : CM_Voyage;								
	vvr : CM_VehicleVisitRecord;
	trainSet : CM_TrainSet;
	voyageSet : CM_VoyageSet;								
	vvrSet : CM_VehicleVisitRecordSet;

begin
	
	if self.cmbLocationArea.listIndex &gt; 0 then
		selectedObject := self.cmbLocationArea.itemObject[self.cmbLocationArea.listIndex].Object;
	endif;
	if self.cmbLocation.listIndex &gt; 0 then
		selectedLc := self.cmbLocation.itemObject[self.cmbLocation.listIndex].CM_LocationsController;
	endif;
		
	self.cmbLocationArea.clear();
	self.cmbLocation.clear();
	self.lblTerminalArea.visible := false;
	self.lblLocation.visible := false;
	self.cmbLocationArea.visible := false;
	self.cmbLocation.visible := false;
	
	typeString := self.cmbLocationType.text;
	self.lblTerminalArea.caption := typeString &amp; ":";
	
	if typeString = app.getErrorString(TerminalAreas) then
		self.lblTerminalArea.visible := true;
		self.cmbLocationArea.visible := true;
		self.lblLocation.visible := true;
		foreach ta in self.myTerminal.allTerminalAreas discreteLock do
			index := self.cmbLocationArea.addItem( ta.id );
			self.cmbLocationArea.itemObject[ index ] := ta;
		endforeach;
		
	elseif typeString = app.getErrorString(Trains) then
		self.lblTerminalArea.visible := true;
		self.cmbLocationArea.visible := true;
		create trainSet transient;
		self.myTerminal.getValidLocationActivityObjs( trainSet, null, null, null );
		foreach train in trainSet discreteLock do
			index := self.cmbLocationArea.addItem( train.getCodeDateString );
			self.cmbLocationArea.itemObject[ index ] := train;
		endforeach;
		
	elseif typeString = app.getErrorString(Voyages) then
		self.lblTerminalArea.visible := true;
		self.cmbLocationArea.visible := true;
		create voyageSet transient;
		self.myTerminal.getValidLocationActivityObjs( null, voyageSet, null, null );
		foreach voyage in voyageSet discreteLock do
			index := self.cmbLocationArea.addItem( voyage.idForLocationActivity );
			self.cmbLocationArea.itemObject[ index ] := voyage;
		endforeach;
		
	elseif typeString = app.getErrorString(Vehicle_visit_records) then
		self.lblTerminalArea.visible := true;
		self.cmbLocationArea.visible := true;
		create vvrSet transient;
		self.myTerminal.getValidLocationActivityObjs( null, null, vvrSet, null );
		foreach vvr in vvrSet discreteLock do
			index := self.cmbLocationArea.addItem( vvr.idForLocationActivity );
			self.cmbLocationArea.itemObject[ index ] := vvr;
		endforeach;
		
	endif;
	
	if selectedObject &lt;&gt; null then
		index := self.cmbLocationArea.findObject( selectedObject );
		if index &gt; 0 and index &lt;= self.cmbLocationArea.listCount then
			self.cmbLocationArea.listIndex := index;	
		endif;
	endif;
	
	self.cmbLocationAreaClick();
	if selectedLc &lt;&gt; null then
		index := self.cmbLocation.findObject( selectedLc );
		if index &gt; 0 and index &lt;= self.cmbLocation.listCount then
			self.cmbLocation.listIndex := index;
		endif;
	endif;
	
	

epilog

	delete trainSet;
	delete voyageSet;								
	delete vvrSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMoveDirections" id="2f4015ac-40db-4f01-bce8-98d47f4687e3">
        <updating/>
        <source>setMoveDirections() updating;
/*
Purpose:			

Date		Who		Reason
13 July 2021	navab1	TFS 51515
*/

vars
	criteria : CM_YACriteriaPriority;
	criteriaFrame : CMUI_YACriteriaCntl;
	i : Integer;
	propCount : Integer;
	critType : CM_YACriteriaType;
	allCriteriaStr : String;
begin
	criteriaFrame := self.frmMoveDirection;
	criteriaFrame.transparent := true;
	criteriaFrame.setMasterControl(null);
	critType := CM_YATypeLocnEventMoveDir.firstInstance();
	
	if critType &lt;&gt; null then
		criteriaFrame.setCriteriaType( critType );
		criteriaFrame.setLabelVisible(true);
		
		allCriteriaStr := CMEVT_LocationActivity@allMovementDirectionsForYA();
		
		criteriaFrame.setWidth(560);			
		criteriaFrame.move(0, 110, 560, 40);
		criteriaFrame.visible := true;
		criteriaFrame.txtCriteriaValue.text := allCriteriaStr;
		self.valueMoveDirections := allCriteriaStr.toUpper();

	endif;
	criteriaFrame.formCriteriaChangeMethodName := CMUI_LocationActivityEnquiry::handleYAInventoryTypeChange.name;

epilog

end;</source>
