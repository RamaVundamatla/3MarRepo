    <JadeMethod name="cmbMaster_click" id="11ee9cf4-b554-437e-a520-d7f5de4be0f7">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMaster_click(combobox: ComboBox input) updating;
//-----------------------------------------------------------------------
//	Created:	31 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	master	: HMS_Master;
	harbour : HMS_Harbour;
	pilotExempt : HMS_PilotExemptionCertificate;
begin
	master := combobox.listObject.HMS_Master;
	if master &lt;&gt; null then
		self.txtShipsMaster.text := master.description &amp; ' ('&amp; master.code &amp; ')';
		if self.aMySelectedMovement &lt;&gt; null then
			harbour := self.aMySelectedMovement.myHarbour;	//30 Apr 2012	NDL	Par 29496
			if master.isValidForVessel (harbour, self.aMySelectedMovement.getMyVessel, self.aMySelectedMovement.occursOnDT.Date) then
				pilotExempt := master.getPECforVessel( harbour, self.aMySelectedMovement.getMyVessel, self.aMySelectedMovement.occursOnDT.Date );
				self.lblMasterStatus.caption := "Exempt Status valid" &amp; CrLf &amp; "Exp Date : " &amp;  pilotExempt.expiryDate.format("dd/MM/yyy");
				/*self.chkPilotExempt.value 		:= true;	Par15027 - giving the possibility to enable / disable Pilot exempt all the time
				self.chkPilotExempt.enabled 	:= false;
				self.cmbPilot.listIndex			:= -1;
				self.cmbPilot.enabled 			:= false;
				self.cmbPilotLaunch.enabled 	:= false;
				self.txtLaunchRel.enabled 		:= false;*/
			else
				self.lblMasterStatus.caption := "Exempt Status invalid" &amp; CrLf ;
				/*self.chkPilotExempt.value 		:= false;	Par15027 - giving the possibility to enable / disable Pilot exempt all the time
				self.chkPilotExempt.enabled 	:= true;
				self.cmbPilot.enabled 			:= true;
				self.cmbPilotLaunch.enabled 	:= true;
				self.txtLaunchRel.enabled 		:= true;*/
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
