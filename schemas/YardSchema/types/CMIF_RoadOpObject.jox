    <JadeMethod name="getVehicleCountForArea" id="c4df1d62-0ed0-4a22-9539-b7d828d7b7bd">
        <source>getVehicleCountForArea(_area :CM_TerminalArea):Integer protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	vm		:CM_VehicleMachine;
	vehicle	:CM_Vehicle;
	count	:Integer;
	invalid	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, vehicle, invalid);

	foreach vm in self.allVehicles do
		if not CM_Vehicle.hasInstance (vm) then
			continue;
		endif;
		
		vehicle := vm.CM_Vehicle;
		
		if vehicle.myPrimaryActualLocation = null or
			vehicle.myPrimaryActualLocation.myTerminalArea &lt;&gt; _area then
			continue;
		endif;
		
		if invalid then
			self.allVehicles.remove (vehicle);
			invalid := false;
			continue;
		endif;
		
		count := count + 1;
	endforeach;
	
	return count;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_area" type="CM_TerminalArea"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWLECountForArea" id="dd7cb51c-903b-4aff-8c37-4e202af078ec">
        <source>getWLECountForArea(_area :CM_TerminalArea; 
					_vehicleCount,
					_rec, _rel :Integer output) protected;
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	vm		:CM_VehicleMachine;
	vehicle	:CM_Vehicle;
	invalid	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, vehicle, invalid);

	foreach vm in self.allVehicles do
		if vm = null then
			continue;
		endif;
		vehicle := vm.CM_Vehicle;
		
		if vehicle.myPrimaryActualLocation = null or
			vehicle.myPrimaryActualLocation.myTerminalArea &lt;&gt; _area then
			continue;
		endif;
		
		if invalid then
			self.allVehicles.remove (vehicle);
			invalid := false;
			continue;
		endif;
		
		vehicle.getAllWLEs_count (_rec, _rel);
		//epr TFS 7828 24/11/17 added vehicles
		_vehicleCount:=_vehicleCount +1;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_area" type="CM_TerminalArea"/>
        <Parameter name="_vehicleCount" type="Integer" usage="output"/>
        <Parameter name="_rec" type="Integer" usage="output"/>
        <Parameter name="_rel" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleObjectNotInCollection" id="a78dab52-b8c4-4eef-9467-5fb22d23d368">
        <source>handleObjectNotInCollection(_exc :Exception) :Integer protected;

constants
	ObjectNotInColl	= 1301;
vars

begin
	if _exc.errorCode = ObjectNotInColl then			
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="f8d3b0a4-e8c2-4d1b-81b9-05c86115b691">
        <source>includeObject(_object :CM_Object; _controller :CMIF_RoadOpController):Boolean protected;
/*
Date		Who		Reason
23 October 2012	cnwcs5	Initial creation - par 29653
*/
vars

begin
	if _controller.filterHasCurrentAlerts then
		if not _object.hasNonReviewedAlerts(_controller.filterFromHandhelds) then
			return false;
		endif;
		
		return true;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_controller" type="CMIF_RoadOpController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="2d0f2f77-67fb-4f6d-a773-4633eb77638a">
        <source>init();
/*
Purpose:			
Return Value:		

Date			Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx
11/08/2009		cnwcs5	ccms1061 - optimise deleteing rows
19/03/2010		cnwcs5	par 23193 - tracked item notifications
*/
vars

begin
	if self.myDataTable &lt;&gt; null then
		// much more efficient to just reset number of rows
		// rather than deleting rows individually
		self.myDataTable.rows := self.myDataTable.fixedRows;
	endif;
	
	self.allVehicles.clear;
	self.allWLEs.clear;
	self.doNotableClear;	// par 23193
	
	self.getAllVehicles();
	self.getAllWLEs();
epilog

end;</source>
    </JadeMethod>
