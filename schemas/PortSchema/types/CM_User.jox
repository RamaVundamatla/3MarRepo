    <JadeMethod name="getTerminals" id="205a7ad4-9974-483e-9fcb-54a44ed9d11c">
        <source>getTerminals( _userTerminals :  CM_TerminalByCodeDict input );
/* ---------------------------------------------------------------------------
Created:	19 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	ut		: CM_UserTerminal;
	iter	: Iterator;

begin

	_userTerminals.clear();
	
	iter := self.allUserTerminals.createIterator();
	while iter.next(ut) do
		_userTerminals.add(ut.getRealTerminal());
	endwhile;

epilog
	delete iter;
	
end;</source>
        <Parameter name="_userTerminals" type="CM_TerminalByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getToDoTaskDescList" id="86936d74-7149-4d22-9d21-8bef0245a9fb">
        <source>getToDoTaskDescList(_taskDict  : CM_ToDoTaskDescByCode io;
					_cargoType : CM_CargoType;
					_terminal  : CM_Terminal;
					_type	   : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2023 navma1 ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen

*/

vars
	tmpUserTerm	 : CM_UserTerminal;
	toDoTaskDesc : CM_ToDoTaskDesc;
begin

	if _terminal = null then
		return;
	endif;
	
	tmpUserTerm := self.getUserTerminal(_terminal);
	
	if tmpUserTerm = null then
		return;
	endif;
	
	if tmpUserTerm.mySecurityRole = null then
		return;
	endif;
	
	
	foreach toDoTaskDesc in tmpUserTerm.mySecurityRole.allToDoTasksAddRemove do
		
		if toDoTaskDesc.type &lt;&gt; _type then
			continue;
		endif;
		
		if _cargoType &lt;&gt; null then												
			if not toDoTaskDesc.allCargoTypes.includes( _cargoType ) then
				continue;
			endif;
		endif;
		
		_taskDict.add(toDoTaskDesc);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_taskDict" type="CM_ToDoTaskDescByCode" usage="io"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getToDoTasksAddRemoveForTerm" id="63bc316e-59b9-4c7c-838f-5518ebbdb2bf">
        <source>getToDoTasksAddRemoveForTerm(_terminal : CM_Terminal; _taskDict : CM_ToDoTaskDescByCode io);
// ---------------------------------------------------------------------------
// Created:     01 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpUserTerm	: CM_UserTerminal;
	toDoTaskDesc : CM_ToDoTaskDesc;

begin
	if _terminal = null then
		return;
	endif;
	tmpUserTerm := self.getUserTerminal(_terminal);
	if tmpUserTerm = null then
		return;
	endif;
	if tmpUserTerm.mySecurityRole = null then
		return;
	endif;
	
	foreach toDoTaskDesc in tmpUserTerm.mySecurityRole.allToDoTasksAddRemove do
		// ### TFS BUG 61158 16NOV2023 NAVAB1
		if toDoTaskDesc.isForCargoWorkOrder() then	
			continue;
		endif;

		if not toDoTaskDesc.requiresWorkOrder then
			_taskDict.add(toDoTaskDesc);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_taskDict" type="CM_ToDoTaskDescByCode" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getToDoTasksAddRemoveForWOTerm" id="9518e09f-c672-4ff9-8b19-2047bb2d2cf1">
        <source>getToDoTasksAddRemoveForWOTerm(_terminal : CM_Terminal; _cargoType : CM_CargoType; _taskDict : CM_ToDoTaskDescByCode io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwrd1	Initial creation to populate work order todo task lists with all todotasks
*/

vars

	tmpUserTerm	 : CM_UserTerminal;
	toDoTaskDesc : CM_ToDoTaskDesc;

begin
	
	if _terminal = null then
		return;
	endif;
	
	tmpUserTerm := self.getUserTerminal(_terminal);
	
	if tmpUserTerm = null then
		return;
	endif;
	
	if tmpUserTerm.mySecurityRole = null then
		return;
	endif;
	
	foreach toDoTaskDesc in tmpUserTerm.mySecurityRole.allToDoTasksAddRemove do
		if _cargoType &lt;&gt; null then												//12 Jul 2018	NDL	TFS 39638
			if not toDoTaskDesc.allCargoTypes.includes( _cargoType ) then
				continue;
			endif;
		endif;

		_taskDict.add(toDoTaskDesc);
	endforeach;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_taskDict" type="CM_ToDoTaskDescByCode" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getToDoTasksCompleteForTerm" id="af53e80f-80ad-4fa7-a982-7b107697335d">
        <source>getToDoTasksCompleteForTerm(_terminal : CM_Terminal) : CM_ToDoTaskDescByCode;
// ---------------------------------------------------------------------------
// Created:     01 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpUserTerm	: CM_UserTerminal;
begin
	if _terminal = null then
		return null;
	endif;
	tmpUserTerm := self.getUserTerminal(_terminal);
	if tmpUserTerm = null then
