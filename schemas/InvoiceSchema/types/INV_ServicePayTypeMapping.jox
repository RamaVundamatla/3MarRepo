    <JadeMethod name="doSave" id="0c0fcb7c-6daa-4ccd-985d-479fd6ec7189">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	realPaymentTypeMapping : CM_ServicePayTypeMapping;
	pxyPaymentTypeMapping : CM_ServicePayTypeMapping;
	ls : Boolean;
	bank : CM_Bank;
	dr : CM_Debtor;
	service : CM_Service;
	paymentType : Integer;
	theReturn: Integer;

begin

	bank := self.myCurrentBank;
	dr := self.cmbDebtors.listObject.CM_Debtor;
	service := self.cmbServices.listObject.CM_Service;
	if self.cmbPaymentTypes.listIndex &gt; 0 then
		paymentType := self.cmbPaymentTypes.itemData[ self.cmbPaymentTypes.listIndex ];
	endif;
	
	realPaymentTypeMapping := bank.getServicePayTypeMapping( service, dr, false );	// the specific one for this debtor only.
	
	if realPaymentTypeMapping &lt;&gt; null then	
		app.cmsBeginLoad(ls);
		pxyPaymentTypeMapping := app.createUpdateProxy(realPaymentTypeMapping).CM_ServicePayTypeMapping;
		app.cmsEndLoad(ls);
	else
		create pxyPaymentTypeMapping transient;
	endif;
	
	pxyPaymentTypeMapping.setProxy(	bank,	//_bank : CM_Bank;
									service,	//_service : CM_Service;
									dr,	//_debtor : CM_Debtor;
									paymentType	//_paymentType : Integer
									);

	while true do
		if realPaymentTypeMapping &lt;&gt; null then
			app.myTrxUA.trxUpdatePaymentTypeMap(pxyPaymentTypeMapping, app.myPassport);
		else
			app.myTrxCA.trxCreatePaymentTypeMap(pxyPaymentTypeMapping, realPaymentTypeMapping, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Payment_type_mapping), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog

	app.cmsEndLoad(ls);
	delete pxyPaymentTypeMapping;

end;</source>
    </JadeMethod>
