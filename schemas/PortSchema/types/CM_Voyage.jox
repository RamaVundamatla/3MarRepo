    <JadeMethod name="getMyVerifiedEDIShipManifests" id="278decbd-0647-4213-b742-c5bf773af670">
        <source>getMyVerifiedEDIShipManifests( _ediDatas : CM_EDIDataArray io );

/*
Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
24 Oct 2024			navra1	Initial Creation for //navra1 - MTN-33087 - 23rd Oct 2024
14/07/2025			naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
*/
	
vars
	ediData		: CM_EDIData;
	ediConfig	: CM_EDIConfig;
	iter		: Iterator;
	keyType		: Integer;
	keyID		: Integer;
	
begin
	ediConfig := self.myTerminal.myEdiConfig;
	
	if ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(ERR_NO_EDI_CONFIG));
		return;
	endif;
	
	iter := ediConfig.allEDIDatasByTypeNumber.createIterator();
	ediConfig.allEDIDatasByTypeNumber.startKeyGeq(EDIDataType_ShipManifest,0,iter);
	
	while iter.next(ediData) do
		iter.getCurrentKeys(keyType,keyID); //MTN-35226
		
		if keyType &lt;&gt; EDIDataType_ShipManifest then
			break;
		endif;
		
		if ediData.CM_EDIDataShipManifest.getMyVoyageObject() &lt;&gt; null and ediData.CM_EDIDataShipManifest.getMyVoyageObject().code = self.code then
			if ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED or ediData.status = CM_EDIFile.EDI_STATUS_AUTO_PAUSED then
				_ediDatas.add(ediData);
			endif;
		endif;
	endwhile;
	
epilog
	delete iter;	
end;
</source>
