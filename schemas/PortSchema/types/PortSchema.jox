    <JadeMethod name="getROROLayerTypeString" id="788f1850-4897-4c5b-81b9-3258bd8f6321">
        <source>getROROLayerTypeString(_type : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     April 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin 
	if _type = ROROLayerType_Structure then
		return app.getErrorString(ROROLayerString_Structure);
	elseif _type = ROROLayerType_Lanes then
		return app.getErrorString(ROROLayerString_Lanes);
	elseif _type = ROROLayerType_Cargo then
		return app.getErrorString(ROROLayerString_Cargo);
	elseif _type = ROROLayerType_GC then
		return app.getErrorString(ROROLayerString_GC);
	elseif _type = ROROLayerType_CCDischarge then
		return app.getErrorString(ROROLayerString_DischCC);
	elseif _type = ROROLayerType_CCLoad then
		return app.getErrorString(ROROLayerString_LoadCC);
	elseif _type = ROROLayerType_OOTL then
		return app.getErrorString(ROROLayerString_OOTL);
	endif;

	return "N/A";
end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReportPageOptionsFromDesign" id="cd257bed-69a4-434d-b5d9-a67b01bfc0d5">
        <updating/>
        <source>getReportPageOptionsFromDesign(_jrwReport : JadeReportWriterReport;
							   _documentType ,
							   _oriention,
							   _copies,
							   _topOfPage,
							   _bottomOfPage,
							   _leftMargin,
							   _rightMargin,
							   _borderWidth : Integer output;
							   _collate  : Boolean output;
							   _duplex : Integer output) updating;
							  
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 12 October 2010
//
// Implemented version: JMT 7.9.1
// Date  		User  		Change
// 12/10/2010	cnwsh3		PAR25837 - Need the ability to get the values from the report design.
//							In some case we were setting a default setting even though the report
//							we had selected was not designed with those settings in mind 
//							(ie. page orientation - result was layout was skewiff
//----------------------------------------------------------------------
vars

begin
	if _jrwReport = null then
		return;
	endif;
	
	_jrwReport.getPageOptions(_documentType, 
							  _oriention, 
							  _copies, 
							  _topOfPage, 
							  _bottomOfPage, 
							  _leftMargin, 
							  _rightMargin, 
							  _borderWidth, 
							  _collate, 
							  _duplex);
epilog
end;</source>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
        <Parameter name="_documentType" type="Integer" usage="output"/>
        <Parameter name="_oriention" type="Integer" usage="output"/>
        <Parameter name="_copies" type="Integer" usage="output"/>
        <Parameter name="_topOfPage" type="Integer" usage="output"/>
        <Parameter name="_bottomOfPage" type="Integer" usage="output"/>
        <Parameter name="_leftMargin" type="Integer" usage="output"/>
        <Parameter name="_rightMargin" type="Integer" usage="output"/>
        <Parameter name="_borderWidth" type="Integer" usage="output"/>
        <Parameter name="_collate" type="Boolean" usage="output"/>
        <Parameter name="_duplex" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getRowHeadingFromMeasure" id="e42bdcde-af9d-432d-8218-b48b9174d5ad">
        <source>getRowHeadingFromMeasure(	_row : EntTableRow; 
							_measure : CM_MeasurementType; 
							_prefix, _heading, _rowName  : String output	);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321  Imperial Measurements
*/
vars

begin
	_prefix := self.getMeasurementPrefixFromType(_measure.measurementType);
	_rowName := _prefix &amp; _row.name &amp; "_" &amp; _measure.shortName;
	_heading := _row.getHeadingUnaltered &amp; " " &amp; _measure.shortName;
epilog

end;</source>
        <Parameter name="_row" type="EntTableRow"/>
        <Parameter name="_measure" type="CM_MeasurementType"/>
        <Parameter name="_prefix" type="String" usage="output"/>
        <Parameter name="_heading" type="String" usage="output"/>
        <Parameter name="_rowName" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSegCondClassForType" id="80f396eb-6313-4489-b35f-8f2adf97ea9e">
        <source>getSegCondClassForType(_segregationType : Integer) : Class;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _segregationType = Segregation_Type_Road then
		return CM_SegregationConditionRoad;
	elseif _segregationType = Segregation_Type_Rail then
		return CM_SegregationConditionRail;
	elseif _segregationType = Segregation_Type_Ship then
		return CM_SegregationConditionShip;
	elseif _segregationType = Segregation_Type_Yard then
		return CM_SegregationConditionYard;
	elseif _segregationType = Segregation_Type_Warehouse then	//28 Jul 2015	NDL	Par 36660
		return CM_SegregationConditionWHouse;
	endif;

	app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled type (' &amp; _segregationType.String &amp; ')');
end;


</source>
        <Parameter name="_segregationType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getServerLocale" id="598e54ca-9695-4132-80de-b309b3a62c87">
        <source>getServerLocale() : Integer;//: Locale serverExecution;

/*Changes: 
	cnwmd1 Par #21721, 24/11/2009 - Replace server execution method with Node::getDefaultLCID()
*/
vars
	//info: LocaleFullInfo;
begin
	//create info transient;
	return node.getDefaultLCID;
epilog
	//delete info;
end;

