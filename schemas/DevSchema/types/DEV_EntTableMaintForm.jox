    <JadeMethod name="doRenameGrp" id="ea6830eb-955e-4e85-be8a-3c42d006ea37">
        <source>doRenameGrp();
// ---------------------------------------------------------------------------
// Created:     25 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newName		: String;
	oldGroup : EntTableGroup;
begin

	if self.myCurrentGroup = null then
		app.msgBox('No group has been selected', 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	read newName;
	
	if newName &lt;&gt; null then
		self.myEntTableAgent.trxUpdateGroupName(self.myCurrentGroup.name, newName);
		
		app.msgBox('After saving to global constants, you must go and remove ' &amp; CrLf &amp;
		           'the group constant with the old name','WARNING',MsgBox_OK_Only);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveDataToGlobalConstants" id="c3f61be3-663d-4d10-a0a6-1f0613b777d6">
        <updating/>
        <source>doSaveDataToGlobalConstants() updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	hasWarnings : Boolean;
	msg : String;
	userCode : String;
	
begin
	userCode := process.getUserCode();
	if userCode = null then
		//Maybe fallback to JADELOADER???
		app.msgBox(app.getErrorString(UnknownUser) &amp; ' - Could not find user code. Please check with a developer'&amp; CrLf &amp; 'NO CHANGES HAVE BEEN SAVED!!!!', 'Oi!', MsgBox_OK_Only);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	if self.isReorgPending then
		app.msgBox('Reorg is pending - this operation terminated!', 'Oi!', MsgBox_OK_Only);		
		return;
	else
		self.myEntTableAgent.trxSaveDataToGlobalConstants( hasWarnings, userCode );
	endif;
	
	self.isDataChanged := false;
	
	msg := 'Data Saved';
	if hasWarnings then
		msg := msg &amp; " with warnings!" &amp; CrLf &amp; "Please run UNIT Test" &amp; CrLf
					&amp; "'UT_ZJMTLogicalCertifyConstXLAT tCheckEntTableConstants' " &amp; CrLf
					&amp; "and address the issues raised.";
		app.msgBox(msg, 'WARNING', MsgBox_OK_Only);
	else
		app.msgBox(msg, '', MsgBox_OK_Only);
	endif;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveDef" id="c8be2f05-61f9-4d50-9259-de8323a9b406">
        <updating/>
        <source>doSaveDef() updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	def			: EntTableDef;
	entTableRow	: EntTableRow;
	defName		: String;
	numRows		: Integer;
	idx			: Integer;
	
begin
	defName := txtDefName.text;

	if not self.checkDefName(defName) then
		return;
	endif;

	beginTransaction;

	if not checkGroupEdition() then
		abortTransaction;
		return;
	endif;

	if self.myCurrentDef &lt;&gt; null then
		if self.myCurrentDef.name = defName then
			def := self.myCurrentDef;
		else
			create def;
		endif;
	else
		create def;
	endif;
	
	def.set(defName, txtDefDescr.text, null, null, myCurrentGroup, app.myRoot.myEntTableDataRoot);

	// cannot clear rows and re-add as this screws up the views.
	
	numRows := tblDef.rows -1;	// ignore the heading row
	
	foreach idx in 1 to numRows do
		entTableRow := tblDef.accessRow(idx+1).itemObject.EntTableRow;
		if entTableRow &lt;&gt; null then
			if not def.addRow(idx, entTableRow) then
				app.msgBox('The row ' &amp; entTableRow.name &amp; ' has already been entered', 'Error', MsgBox_OK_Only);
			endif;
		endif;
	endforeach;

	def.clearRowsGreaterThan(numRows);
	
	commitTransaction;

	self.isDataChanged := true;
	self.setDefinition(def);
	self.setView(self.myCurrentView);
	
	self.myEntTableAgent.showAddGlobalConstantMsg(self.myEntTableAgent.DefType, defName);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveGroup" id="e1756560-d758-493f-b7a5-8f915906d807">
        <updating/>
        <source>doSaveGroup() updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	proxyEntTableRow,
	entTableRow		: EntTableRow;
	deleteSet		: ObjectSet;
	
begin

	if self.myCurrentGroup = null then
		app.writeStatement( 'Error &gt;&gt; myCurrentGroup = null');
		return;
	endif;
	
	self.saveGroupProxyData();
	
	// setup all the rows for deletion.  These are removed from this set as they are updated
	create deleteSet transient;
	self.myCurrentGroup.allEntTableRowsByName.copy(deleteSet);

	beginTransaction;
	
	if not checkGroupEdition() then
		abortTransaction;
		return;
	endif;
	
	foreach proxyEntTableRow in self.allProxyEntTableRows do
		if proxyEntTableRow.EntTableRowProxy.myRealObject &lt;&gt; null then
			entTableRow := proxyEntTableRow.EntTableRowProxy.myRealObject;
			entTableRow.setForUpdate(proxyEntTableRow.EntTableRowProxy);

			// remove the real row from the set to delete
			deleteSet.remove(entTableRow);
		else
			create entTableRow persistent;
			entTableRow.setForCreate(proxyEntTableRow.EntTableRowProxy, self.myCurrentGroup);
		endif;
	endforeach;

	// delete the rows that were deleted in the edit.	
	if deleteSet.size &gt; 0 then
		deleteSet.purge;
	endif;
	
	commitTransaction;
		
	self.isDataChanged := true;
	self.disableGroupEdit();
	self.setGroup(self.myCurrentGroup, self.currentSortKey);
	self.setDefinition(self.myCurrentDef);
	self.setView(self.myCurrentView);

epilog
	if deleteSet &lt;&gt; null then
		delete deleteSet;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSortRows" id="169d37ef-c4c6-4a63-a9d5-945e4834d99a">
        <updating/>
        <source>doSortRows(table : Table) protected, updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	col			: Integer;
	sortKey		: String;
begin
	if self.btnSaveGroup.enabled then
		app.msgBox("Can't sort while editing" , 'Error', 0);
		return;
	endif;
	
	col := table.column;
	if col &lt; 0 or col &gt; 6 then
		app.msgBox("Can't sort by this row (yet?)" , 'Error', 0);
		return;
	endif;

	sortKey := table.getCellText(1, col);
	self.currentSortKey := sortKey;	
	self.setGroup(self.myCurrentGroup, self.currentSortKey);
	
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table"/>
    </JadeMethod>
    <JadeMethod name="doUnloadAsScm" id="9f30451d-4784-4731-a721-d60a98c237fe">
        <source>doUnloadAsScm();
// ---------------------------------------------------------------------------
// Created:     04 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cmdFileOpen	: CMDFileOpen;

begin

	create cmdFileOpen;
	cmdFileOpen.createPrompt := false;
	cmdFileOpen.fileMustExist := false;
	cmdFileOpen.fileTitle := 'entTable.scm';
	cmdFileOpen.fileName := 'entTable.scm';
	
	if cmdFileOpen.open() = 0 then
		self.myEntTableDataRoot.unloadAsSchemaFile(cmdFileOpen.fileName);
		app.msgBox('Groups unloaded', '', MsgBox_OK_Only);
	endif;	

epilog
	delete cmdFileOpen;

end;</source>
    </JadeMethod>
    <JadeMethod name="enableDefEdit" id="4f30669f-58b2-4a87-9ef1-482a81b843b8">
        <updating/>
        <source>enableDefEdit() updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/01/2022   navma1		Enable Save/Delete Def btns for EMAST
// ---------------------------------------------------------------------------
vars

begin

	if myCurrentGroup = null then
		app.msgBox('You must select a group first', 'Error', MsgBox_OK_Only);
		return;
	endif;

	beginLoad;
	sharedLock(self.myCurrentGroup);
	self.expectedGroupEdition := self.myCurrentGroup.edition;

	// need to reload details here
	endLoad;
	
	tblDef.enabled := true;
	
	btnDefExclAll.enabled := true;
	btnDefExclOne.enabled := true;
	btnDefInclAll.enabled := true;
	btnDefInclOne.enabled := true;
	
	//cnwrs1 disable all update buttons Mar 2009 in all environments except cnwdmast
	// PAR #19397 - 
	btnSaveDef.enabled := app.isDevelopmentSystemMain()	  or app.isDevelopmentSystemEMAST;		//17.01.2022 navma1 
	btnDeleteDef.enabled := app.isDevelopmentSystemMain() or app.isDevelopmentSystemEMAST;		//17.01.2022 navma1 
	
	
epilog
	endLoad;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="enableGroupEdit" id="4423fa23-c59c-4af0-a8b8-b32a91943c4d">
        <updating/>
        <source>enableGroupEdit() updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTableRow	: EntTableRow;
	proxyRow	: EntTableRowProxy;
	currentRow,
	currentCol,
	topRow		: Integer;
	iter		: Iterator;
begin

	if self.myCurrentGroup = null then
		app.msgBox('You must select a group first', 'Error', MsgBox_OK_Only);
		return;
	endif;

	self.grpEditEnabled := true;
	
	btnEditGroup.enabled := false;
	btnCancelGroup.enabled := true;
	btnSaveGroup.enabled := true;
	
	self.allProxyEntTableRows.purge;
	
	// Save the current position
	topRow := tblGroup.topRow;
	currentRow := tblGroup.row;
	currentCol := tblGroup.column;

	// clear out the existing details in the table
	tblGroup.rows := tblGroup.fixedRows;
	
	beginLoad;
	
	sharedLock(self.myCurrentGroup);
	self.expectedGroupEdition := self.myCurrentGroup.edition;
	iter := self.myRowDynaDict.createIterator;
	while iter.next(entTableRow) do
		create proxyRow transient;
		proxyRow.setFromRealObject(entTableRow);
		self.allProxyEntTableRows.add(proxyRow);
		
		tblGroupAddRow(proxyRow);
	endwhile;	
	// Restore the current position in the table
	if topRow &gt; 0 and topRow &lt;= tblGroup.rows then
		tblGroup.topRow := topRow;
	endif;
	if currentRow &gt; 0 and currentRow &lt;= tblGroup.rows then
		tblGroup.row := currentRow;
	endif;
	if currentCol &gt; 0 and currentCol &lt;= tblGroup.columns then
		tblGroup.column := currentCol;
	endif;
	
	tblGroup.userInputEnabled := true;
	tblGroup.setFocus;
	
epilog
	endLoad;
	delete iter;		// PAR #26678
			
end;</source>
    </JadeMethod>
    <JadeMethod name="enableViewEdit" id="d4bbe1a9-e4f7-494a-9f64-c0d737435463">
