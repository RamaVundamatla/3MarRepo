    <JadeMethod name="doNotableClear" id="5ea1be26-9381-48fd-b529-0e0d7a05de17">
        <source>doNotableClear();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint

*/

vars

	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvContractRateEntUpdate));
		endNotification(anObject, EventFileAdd);
		endNotification(anObject, EventFileDelete);
	endforeach;
	
	self.allNotableObjects.clear;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissions" id="47f2f2d9-63f9-4b36-96a8-742bd7d0ef63">
        <source>doPermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details
03 Sep 2024	navnk30		Bug 65602: FR - 54089 - Invoice Contract - permissions

*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnRemoveRate.enabled := false;
		self.btnRemoveRtEnt.enabled := false;
		self.btnAdd.enabled := false;
		self.btnUpdate.enabled := false;
		//self.tblData.enabled := false;	//03.09.2024 navnk30 #65602
		self.btnClose.enabled := true;
		self.btnSave.enabled := false;
		self.btnNew.enabled := false;
		self.cmbUnitOfMeasure.enabled := false;
		self.cmbInvoiceLine.enabled := false;
		self.cmbShippingTerm.enabled := false;
		self.cmbCalculationTypes.enabled := false; // ### TFS CR 61579 TASK 62453 13FEB2024 NAVAB1
		self.cmbService.enabled := false;
		self.mskContractFromEnd.enabled := false;
		self.mskContractFromEndTime.enabled := false;
		self.mskContractFromStart.enabled := false;
		self.mskContractFromStartTime.enabled := false;
		self.chkVolume.enabled := false;
		self.btnCriteria.enabled := false;
		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="286f22ba-08a0-4dee-94c7-cac2af78e108">
        <updating/>
        <source>doRemove(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details

*/

vars
	theReturn : Integer;
	contractRate	: CM_InvoiceContractRateEntry ;

begin
	contractRate := _obj.CM_InvoiceContractRateEntry;
	if contractRate = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox(app.getErrorString2(Sure_want_remov_invoi_contr_ra, null,null), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
 	app.myTrxDA.trxDeleteInvContractDtlRtEntry(contractRate, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doRemoveRate" id="f4cae7fa-277c-426f-94f8-5f1c82c41e59">
        <updating/>
        <source>doRemoveRate(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2023  	CR 55646 Task 55667: UI - Contracts Rates

*/

vars
	theReturn : Integer;
	contractRate	: CM_InvoiceContractRate ;
	service : CM_Service;

begin
	service := self.cmbService.listObject.CM_Service;
	
	if service = null then
		return;
	endif;
	contractRate := self.myContractDetails.allInvContractRatesByService[service];
	if contractRate = null then
		app.msgBox ("No records to delete for selected service", app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	if app.msgBox("Are you sure you want to remove rate and rate entries for service " &amp; service.name, 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	while true do
 	app.myTrxDA.trxDeleteInvContractDtlRt(contractRate, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoic_contra_rate_entry_delet), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doRemoveRateEntryDates" id="1b4824e4-b36a-4c04-8e5f-9716fc1648d0">
