    <JadeMethod name="cmbWagonPrenote_click" id="310203d7-5fe9-410a-986e-e764e864763b">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbWagonPrenote_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     07 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	origTrain : CM_Train;
	origMode : Integer;
begin

	origTrain := self.myCurrentTrain;
	origMode := self.mode;
	
	self.myCurrentWagon := combobox.listObject.CM_Wagon;
	self.doWagonDisplay(true);
	
	// PAR 20408 Adding wagon to a particular train, but they have chosen a pre note wagon that may have been setup for a different train
	if origTrain &lt;&gt; self.myCurrentWagon.myTrainInwards and origMode = self.Mode_Add then
		self.cmbTrainIncoming.listObject := origTrain;
		self.cmbTrainOutgoing.listObject := origTrain;
	endif;
	
	if not self.isTrainMode  then
		if self.myCurrentWagon &lt;&gt; null then
			self.mode := Mode_Update;
		endif;
		if self.myRailArea &lt;&gt; null and self.myRailRake &lt;&gt; null then
			self.cmbRailArea.listObject := self.myRailArea;
			self.buildComboPosition(self.myRailArea);
			self.cmbRailArea.enabled := true;
			self.cmbRake.enabled := true;
		endif;
	endif;
	self.loadCargo(optDirInTB.value);
	self.setControlsForAddEditDelete(true);
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
