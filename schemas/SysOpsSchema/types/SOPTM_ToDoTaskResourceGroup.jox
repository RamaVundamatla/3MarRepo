    <JadeMethod name="includeObject" id="8556533e-4c85-4985-95ab-c0a1698ede03">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

begin
	if self.includeNotAvailableEntries then
		return true;
		
	endif;
	
	return not _obj.CM_ResourceTypeGroup.isNotAvailableForEntry;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="dc67968e-0a04-4989-a4cc-e605f7275acc">
        <source>initShtMultiSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)
08/05/2025			navlw1	JIRA-34582: MTN | Filtering order Issue in system Admin Table as terminal collection cannot be re-ordered

*/

vars
	theForm				: SOP_TableMaintForm;
	allResourceTypes	: CM_ResourceTypeDict;
	
begin
	theForm := self.myForm;
	inheritMethod;	
	
	create allResourceTypes transient;
	app.myRoot.allTaskResourceTypes.copyNoDups(allResourceTypes);
	self.setupMultiSelect1(app.getErrorString(To_Do_Task_Res), allResourceTypes, SOP_TableMaintForm::displayToDoResourceType.name);
	theForm.mulSelect1.setVisibleButtons(true,true,false);
	theForm.mulSelect1.myBaseForm	:= theForm;
	theForm.mulSelect1.mySelectedListBox.sorted := false;
	
epilog
	delete allResourceTypes;
	
end;</source>
    </JadeMethod>
