    <JadeMethod name="clearOtherSelected" id="05992f73-6d65-4df6-80f5-3b62c5937d9b">
        <source>clearOtherSelected(pTheListBox : ListBox) protected;

vars
	otherListboxObj	: ListBox;
	controlObj		: Control;
	controlPointer	: Integer; 
	
begin
	foreach controlPointer in 1 to self.controlCount do
		controlObj	:=	self.controls(controlPointer);
		
		if controlObj.isKindOf(ListBox)then
			otherListboxObj := controlObj.ListBox;
			
			if otherListboxObj &lt;&gt; pTheListBox then
				otherListboxObj.listIndex := CNEC_NULL_INDEX;
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListBox" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="deleteAllTasks" id="f9e81340-72d0-4653-b141-8bd08f880923">
        <source>deleteAllTasks() protected;
// -----------------------------------------------------------------------------
// Created:		15 December 2001 by cnwdad1
//
// Purpose:		Delete all tasks from the schedule queue.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	listboxObj	: ListBox;
	taskObj		: CnEcBackShedTask;
	
begin
	listboxObj	:=	self.aMyMenuListbox;
	
	if global.cnEcConfirmDelete("All " &amp; self.getQueueName(listboxObj) &amp; " Tasks") then
		beginTransaction;
		
		while listboxObj.listCount &gt; 0 do
			taskObj	:=	listboxObj.itemObject[1].CnEcBackShedTask;
			listboxObj.removeItem(listboxObj.findObject(taskObj));
			
			delete taskObj;
		endwhile;
		
		commitTransaction;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteTask" id="75ec82d7-ac84-455c-95fc-9185606e9fac">
        <source>deleteTask() protected;

vars
	taskObj		: CnEcBackShedTask;
	
begin
	taskObj	:=	self.getTask(self.aMyMenuListbox);
	
	if taskObj = null then
		app.msgBox("Please select the task to delete.", "Task Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	else
		if global.cnEcConfirmDelete(taskObj.getIdentification()) then
			beginTransaction;
				delete taskObj;
			commitTransaction;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="47ebe2f2-239c-4c34-a670-6be6c9cbf544">
        <updating/>
        <source>doFormLoad() updating, protected;

begin
	self.centreWindow();
	
	self.refreshCurrent();
	
	beginClassNotification(	CnEcBackShedTask,	//theClass : Class;
							false,	//transients : Boolean;
							Any_System_Event,	//eventType : Integer;
							Response_Continuous,	//responseType : Integer;
							REFRESH	//eventTag : Integer
							);
	
	lblPreQueued.backColor		:=	app.myBackShedManager.getColorPrequeued();
	lblPreQueuedRead.backColor	:=	app.myBackShedManager.getColorPrequeuedReady();
	lblQueued.backColor			:=	app.myBackShedManager.getColorQueued();
	lblRunning.backColor		:=	app.myBackShedManager.getColorActive();
	lblComplete.backColor		:=	app.myBackShedManager.getColorCompleted();
	lblFailed.backColor			:=	app.myBackShedManager.getColorFailed();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="editTask" id="3486804e-b473-4c33-9478-d5a95a110c00">
        <source>editTask() protected;
// -----------------------------------------------------------------------------
// Created:		15 December 2001 by cnwdad1
//
// Purpose:		Edit the selected schedule task.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	taskFormObj	: CnEcTaskDetailsForm;
	taskObj		: CnEcBackShedTask;
	
begin
	taskObj	:=	getTask(self.aMyMenuListbox);
	
	if taskObj = null then
		app.msgBox("Please select the task to edit.", "Task Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	else
		create taskFormObj;
		taskFormObj.setTask(taskObj);
		taskFormObj.showModal();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableMenus" id="a4554825-e804-431e-a8b4-7d65d4d39c14">
        <source>enableMenus(pListboxObj:ListBox) protected;
// -----------------------------------------------------------------------------
// Created:		31 December 2001 by cnwdad1
//
// Purpose:		Set the currently enabled menus according to the selected listbox.
//
// Parameters:	pListboxObj - The listbox to set the menus for.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if pListboxObj.listIndex = CNEC_NULL_INDEX then
		mnuQueueDelete.enabled	:=	false;
		mnuQueueEdit.enabled	:=	false;
	else
		mnuQueueDelete.enabled	:=	true;
		mnuQueueEdit.enabled	:=	true;
	endif;
	
	if pListboxObj.listCount = 0 then
		mnuQueueDeleteAll.enabled	:=	false;
	else
		mnuQueueDeleteAll.enabled	:=	true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="getQueueName" id="6a20688b-7198-44c7-b285-823d4e209409">
        <source>getQueueName(pListboxObj:ListBox):String protected;
// -----------------------------------------------------------------------------
// Created:		31 December 2001 by cnwdad1
//
// Purpose:		Returns the descriptive name of the queue name for the specified
//				listbox.
//
// Parameters:	pListboxObj - The listbox who's name to return.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if pListboxObj = lstCompleted then
		return "Completed";
	elseif pListboxObj = lstPreQueue then
		return "Pre-queued";
	elseif pListboxObj = lstQueue then
		return "Queued";
	elseif pListboxObj = lstRunning then
		return "Running";
	else
		return "Unknown";
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="ListBox"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTask" id="ae2d2433-a095-4a6e-9cf8-702ceb12a605">
        <source>getTask(pListboxObj:ListBox):CnEcBackShedTask protected;
// -----------------------------------------------------------------------------
// Created:		15 December 2001 by cnwdad1
//
// Purpose:		Return a reference to the currently selected schedule task in
//				the specified listbox.
//
// Parameters:	pListboxObj - The listbox containing the schedule task.
//
// Returns:		A reference to the currently selected task.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	taskObj	: CnEcBackShedTask;
	
begin
	if pListboxObj.listIndex &lt;&gt; CNEC_NULL_INDEX then
		taskObj	:=	pListboxObj.listObject.CnEcBackShedTask;
	endif;
	
	return taskObj;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="ListBox"/>
        <ReturnType type="CnEcBackShedTask"/>
    </JadeMethod>
    <JadeMethod name="load" id="949838c2-7a9b-4ad3-82c9-6f21540d9bc8">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
