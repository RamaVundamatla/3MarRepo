        <source>displayMachinesForSecondaryQ(_selectedQueue : CM_RadioTelemetryQueue) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	 27747
Machiens that have the selected queue as one of their defined secondary queues	
*/

vars
	machine : CM_Machine;
begin
	
	foreach machine in _selectedQueue.allMachines discreteLock do
		if machine.isCrane() and not machine.hasRadioTelemetry then
			continue;
		endif;
			
		if allViewedMachines.includes(machine) then
			continue;
