    <JadeMethod name="setMyTrackedItem" id="f4d134a2-5c07-45ec-829a-8268cc28c7ad">
        <updating/>
        <source>setMyTrackedItem(_ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars

begin
	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
epilog

end;</source>
