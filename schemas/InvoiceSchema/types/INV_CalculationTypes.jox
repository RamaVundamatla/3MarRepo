    <JadeMethod name="doSave" id="b8e7d5b0-bb47-4a8c-be9b-b55d8aa96581">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	pxyCalculationType	: CM_CalculationType;
	theReturn			: Integer;

begin

	if self.mode = Mode_Add then
		create pxyCalculationType transient;
	elseif self.mode = Mode_Update then
		pxyCalculationType := self.myProxyObject.CM_CalculationType;
	else
		return false;
	endif;
	
	self.setProxyFromTable(pxyCalculationType);
	
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateCalculationType(pxyCalculationType,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateCalculationType(pxyCalculationType, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return true;
		else
			global.beep;
			theReturn := app.showErrorWarningDialog("Calculation Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			pxyCalculationType.allQuantityRanges.purge();		// delete these as will get recreated in setProxyFromTable above
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete pxyCalculationType;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doThumbnailDClick" id="f3785767-e756-4e32-ae39-692ee048c3fd">
        <updating/>
        <source>doThumbnailDClick() updating;
// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
vars
	calculationType	: CM_CalculationType;
	rowInTable	: Integer;
begin
	calculationType := self.myCurrentObject.CM_CalculationType;
	rowInTable := self.tblThumb.getRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_QuantityHookCode));
	if self.tblThumb.row = rowInTable and rowInTable &gt; 0 then
		if calculationType &lt;&gt; null and
		   calculationType.isVoyageCalcType then
			self.showHookCodeMaintForm(HookType_HMSInvoiceQuantity);
		else
			self.showHookCodeMaintForm(HookType_InvoiceQuantity);
		endif;
		return;
	endif;
	rowInTable := self.tblThumb.getRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_RateHookCode));
	if self.tblThumb.row = rowInTable and rowInTable &gt; 0 then
		if calculationType &lt;&gt; null and
		   calculationType.isVoyageCalcType then
			self.showHookCodeMaintForm(HookType_HMSInvoiceRate);
		else
			self.showHookCodeMaintForm(HookType_InvoiceRate);
		endif;
		return;
	endif;
	rowInTable := self.tblThumb.getRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_RemarksHookCode));	// 22/2/18 MAP TFS37124
	if self.tblThumb.row = rowInTable and rowInTable &gt; 0 then
		if calculationType &lt;&gt; null then
			self.showHookCodeMaintForm(HookType_InvoiceRemarks);
		endif;
		return;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getEscalatingRangeString" id="63cc33e3-0ad1-41a1-9afc-4c6cbf7b9a39">
        <source>getEscalatingRangeString() : String protected;

vars
	tot,idx : Integer;
	theFrom, theTo : Integer;
	theDays	: Integer;
	
	theString : String;

begin
	tot := self.rangeStart.size;
	foreach idx in 1 to tot do
		theFrom := self.rangeStart[idx];
		theTo := self.rangeEnd[idx];
		theDays := self.days[idx];
		if theTo &gt; 0 then
			if theString &lt;&gt; null then
				theString := theString &amp; ",";
			endif;
			theString := theString &amp; theFrom.String &amp; "-" &amp; theTo.String;
			if theDays &gt; 0 then
				theString := theString &amp; " every " &amp; theDays.String &amp; " days";
			endif;
		endif;
	endforeach;
	
	return theString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRangeString" id="156f2a19-46a2-4e76-b977-a534ffb4d5a8">
        <source>getRangeString() : String;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tot,idx : Integer;
	theFrom, theTo : Integer;
	
	theString : String;

begin
	tot := self.range.size;
	theString := "1";
	foreach idx in 2 to tot do
		if idx &gt; 2 then
			theFrom := (self.range[idx -1] + 1);
		endif;
		theTo := self.range[idx];
		if theTo &gt; 0 then
			if theString &lt;&gt; null then
				theString := theString &amp; ",";
			endif;
			theString := theString &amp; theFrom.String &amp; "-" &amp; theTo.String;
		endif;
	endforeach;
	
	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleViews" id="73602ff4-b0a1-4167-aeac-1a9e57e7c8e7">
        <source>handleViews(_calcType : Integer;_clearFirst : Boolean);
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/03/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels with a Ramp
// 22/08/2022	jlika1		TFS 54420 - PRP - Enstructure - Financial Requirements
// 23/08/2022	jlika1		TFS 54897 MTN - Days being charged is incorrect
vars
	calcType, idx : Integer;
	viewName : String;
	code, desc, calcTypeDesc : String;
	availEntry : Boolean;
	calculationType : CM_CalculationType;
	hideRateType : Boolean;						// TFS 43694
begin
	calculationType := self.myCurrentObject.CM_CalculationType;

	if _clearFirst then
		//## clear out what is on screen in case they change the calc type
		code := self.tblEntDetail.getValueByName(ETRow_Code).String;
		desc := self.tblEntDetail.getValueByName(ETRow_Description).String;
		calcTypeDesc := self.tblEntDetail.getValueByName(ETRow_CalcTypeDesc).String;
		availEntry  := self.tblEntDetail.getValueByName(ETRow_IsNotAvailableForEntryCk).Boolean;
		idx := self.cmbCalcTypes.listIndex;
		
		self.tblEntDetail.clearValues();
		
		self.tblEntDetail.setValueByName(ETRow_TimeFrom, NULL_TIME); 
		self.tblEntDetail.setValueByName(ETRow_TimeTo, NULL_TIME); 
		self.tblEntDetail.setValueByName(ETRow_Code,code);
		self.tblEntDetail.setValueByName(ETRow_Description,desc);
		self.tblEntDetail.setValueByName(ETRow_IsNotAvailableForEntryCk,availEntry);
		self.cmbCalcTypes.listIndex := idx;
		self.tblEntDetail.setValueByName(ETRow_CalcTypeDesc,calcTypeDesc);
		// 24024
		self.tblEntDetail.setValueByName(ETRow_QuantityHookCode, app.getErrorString(Doubleclick_edit));
		self.tblEntDetail.setValueByName(ETRow_RateHookCode, app.getErrorString(Doubleclick_edit));
		self.tblEntDetail.setValueByName(ETRow_RemarksHookCode, app.getErrorString(Doubleclick_edit));		// 22/2/18 MAP TFS37124
	endif;
		
	self.doCmbBlockUnitBuild(); // PAR 30681
	
	calcType := _calcType;
	if calcType = INV_CALC_TYPE_BUSINESS_HRS_QTY then
		viewName := "InvCalcViewDays";
	elseif (calcType = INV_CALC_TYPE_VESSEL_TON_RANGE or calcType = INV_CALC_TYPE_VESSEL_TON_QTY1) then 
		viewName := "InvCalcViewIntRange";
	elseif calcType = INV_CALC_TYPE_TIMEBLCK_HRS then
// PAR 36104		viewName := "InvViewHoursBlock";
		viewName := "InvViewHoursBlockCharge"; // PAR 36104
	elseif calcType = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
		viewName := "InvCalcViewBusHrsCargoValue";
		self.doCmbBlockUnitBuildCargo();
	elseif calcType = INV_CALC_TYPE_BUSHRSVESELVALUE then // PAR 30681
		viewName := "InvCalcViewBusHrsVesValue";
	elseif (calcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT or calcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE) then 
		viewName := "InvViewHoursBlockUnit";
	elseif calcType = INV_CALC_TYPE_CARGOLENGTHCONVT then // PAR 31615
      	viewName := "InvCalcViewCargoConvert";
		self.doCmbMesTypeBuild(INV_CALC_TYPE_CARGOLENGTHCONVT);
		self.doCmbBlockUnitBuildConvert("CARGO");
	elseif calcType = INV_CALC_TYPE_CARGOWEIGHTCONVT then // PAR 31615
      	viewName := "InvCalcViewCargoConvert";
		self.doCmbMesTypeBuild(INV_CALC_TYPE_CARGOWEIGHTCONVT);
		self.doCmbBlockUnitBuildConvert("CARGO");
		self.doCmbWeightToUseBuild(); //02/10/2025	navkc1 JIRA 36144 
	elseif calcType = INV_CALC_TYPE_INVENT_WEIGHT then  // ### TFS 51219 28MAY2021 NAVAB1
      	viewName := "InvCalcViewCargoConvert"; // ### TFS 51219 28MAY2021 NAVAB1
		self.doCmbMesTypeBuild(INV_CALC_TYPE_INVENT_WEIGHT); // ### TFS 51219 28MAY2021 NAVAB1
		self.doCmbBlockUnitBuildConvert("INVENTORY"); // ### TFS 51219 28MAY2021 NAVAB1
	elseif calcType = INV_CALC_TYPE_INVENT_VOLUME then  // ### TFS 51219 28MAY2021 NAVAB1
      	viewName := "InvCalcViewCargoConvert"; // ### TFS 51219 28MAY2021 NAVAB1
		self.doCmbMesTypeBuild(INV_CALC_TYPE_INVENT_VOLUME); // ### TFS 51219 28MAY2021 NAVAB1
		self.doCmbBlockUnitBuildConvert("INVENTORY"); // ### TFS 51219 28MAY2021 NAVAB1
	elseif calcType = INV_CALC_TYPE_INVENT_QUANTITY then  // ### TFS 51219 28MAY2021 NAVAB1
      	viewName := "InvCalcViewInvent"; // ### TFS 51219 28MAY2021 NAVAB1
		self.doCmbBlockUnitBuildConvert("INVENTORY"); // ### TFS 51219 28MAY2021 NAVAB1
	elseif calcType = INV_CALC_TYPE_CARGOVOLUMECONVT then // PAR 31615
      	viewName := "InvCalcViewCargoConvert";
		self.doCmbMesTypeBuild(INV_CALC_TYPE_CARGOVOLUMECONVT);
		self.doCmbBlockUnitBuildConvert("CARGO");
	elseif calcType = INV_CALC_TYPE_TIME_PERIOD_HRS 
	or calcType = INV_CALC_TYPE_TIME_PERIOD_HRMN   then// ### TFS CR 65326 TASK 65327 06AUG2024 NAVAB1
		viewName := "InvViewHours";
		// 30680 CCMS QNS 2178
	elseif calcType = INV_CALC_TYPE_VESSEL_TON then
		viewName := "InvCalcViewVesselAttribute";
		
	elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then		// 34489 CCMS 11327
		viewName := "InvCalcViewTidalClass"; // PAR 34764
		self.doCmbBlockUnitBuildTidal();
		// 24024
	elseif calcType = INV_CALC_TYPE_DAYS_SINCE_RECVL or
	   calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM or	//28 Jun 2018	NDL	TFS 39338
	   calcType = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
	   calcType = INV_CALC_TYPE_DAYSINCE_SHIP_EN or
	   calcType = INV_CALC_TYPE_DAYSINCE_VOY_IN or
	   calcType = INV_CALC_TYPE_DAYSINCE_VOY_OUT or
	   calcType = INV_CALC_TYPE_DAYSINCE_REC_RT or	//08 May 2018	NDL	TFS 38525
	   calcType = INV_CALC_TYPE_DAYSINCE_REC_TEU then
		viewName := "InvCalcStorage";
	// TFS 39198
	elseif calcType = INV_CALC_TYPE_WO_ETMAL_DAYS  or
	   calcType = INV_CALC_TYPE_WO_ETMAL_HOURS  or
	   calcType = INV_CALC_TYPE_WO_ETMAL_MINUTES  or
	   calcType = INV_CALC_TYPE_WO_VALUEOF1  or
	   calcType = INV_CALC_TYPE_WO_CARGOWEIGHT  or
	   calcType = INV_CALC_TYPE_WO_CARGOVOLUME  or	
	   calcType = INV_CALC_TYPE_WO_CARGOREVTONS   or	
	   calcType = INV_CALC_TYPE_WO_UNITS   or
	   calcType = INV_CALC_TYPE_WO_CARGOQUANTITY  then
		viewName := "InvCalcWO";
		self.doCmbBlockUnitBuildWO();
	// TFS 39198	
	elseif calcType = INV_CALC_TYPE_WO_EXTRA then	//27 Jun 2018	NDL	TFS 39246
		viewName := "InvCalcWO";
		doCmbBlockUnitBuildWOPermit();
		hideRateType := true;								// TFS 43694
	
	elseif calcType = INV_CALC_TYPE_WO_PERMIT  then
		viewName := "InvCalcWO";
		
		doCmbBlockUnitBuildWOPermit();
		hideRateType := true;								// TFS 43694
		
	//22 Mar 2019	NDL	TFS 43687
	elseif calcType = INV_CALC_TYPE_RESOURCE_QTY
		or calcType = INV_CALC_TYPE_RESOURCE_DAYS
		or calcType = INV_CALC_TYPE_QUOTED_RATE then
		viewName := "InvCalcViewQuoteNQty";
		
	elseif self.cargoCalcTypes.includes(calcType) then
		viewName := "InvCalcCargo";
	elseif calcType = INV_CALC_TYPE_EVENT_TIME_DAYS
		or calcType = INV_CALC_TYPE_EVENT_TIME_HOURS
		or calcType = INV_CALC_TYPE_EVENT_TIME_MINUT
		or calcType = INV_CALC_TYPE_EVENT_DAYS_FULL
		then
		
		viewName := "InvCalcEventTime"; 
		self.doCmbEventBlockUnitBuild();
	else
		viewName := "InvCalcViewBasic";
	endif;	

	self.tblEntDetail.showHideRowsByViewName(viewName,CM_EntryTable.ShowHideRows, false);
	self.doHideRateTypeRow(hideRateType);					// TFS 43694
	
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="2ac2d0d2-307d-4ca3-9249-cc9f5637f50c">
