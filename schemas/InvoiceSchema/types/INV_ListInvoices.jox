    <JadeMethod name="mnuInvCreateCrdFromInvClick" id="7d4ca3bb-9ea4-44bf-99a6-27b4a7177652">
        <source>mnuInvCreateCrdFromInvClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2023	navkc1	Initial creation TFS CR 55305 TASK 55537

*/

vars
	form 					: INV_CreditNoteMaint;
	allSelectedInvoices,
	allInvoicesToCopy		: ObjectArray;
	invoice					: CM_Invoice;
	mainInvoiceProcess,
	invoiceProcessToCheck	: CM_InvoiceProcess;
	hasNotPosted			: Boolean;
	msg						: String;
	mainDebtor : CM_Debtor;
begin
	
	form := app.loadForm(INV_CreditNoteMaint, INV_Assistant, false, false, false, self.myTerminal, null).INV_CreditNoteMaint;
	
	if form = null then
		return;
	endif;
	
	allSelectedInvoices := self.tblData.allSelectedObjects;
	
	invoice := allSelectedInvoices.first().CM_Invoice;
	
	if invoice = null then
		return;
	endif;
	
	if invoice.isCreditNote() then
		form.myCreditNote := invoice; 
		form.mode := INV_CreditNoteMaint.Mode_UpdateCreditNote;
	else
		form.mode := INV_CreditNoteMaint.Mode_CreateCreditNote;
	endif;
	
	create allInvoicesToCopy transient;
	
	foreach invoice in allSelectedInvoices as CM_Invoice where not invoice.isCreditNote() do
		if mainInvoiceProcess = null then
			mainInvoiceProcess := invoice.getMyInvoiceProcess();
		else
			invoiceProcessToCheck := invoice.getMyInvoiceProcess();
			if invoiceProcessToCheck &lt;&gt; mainInvoiceProcess then
				app.msgBox(app.getErrorString(InvoicesInDifferentInvProcess), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
				return;
			endif;
		endif;
		
		// ### TFS BUG 59698 07AUG2023 NAVAB1
		if mainDebtor = null then
			mainDebtor := invoice.debtor;
		else
			if mainDebtor &lt;&gt; invoice.debtor then
				app.msgBox(app.getErrorString(Unabl_creat_credi_note_from_in), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
				return;
			
			endif;
		endif;
		
		if not invoice.isPosted() then
			hasNotPosted := true;
			if msg = null then
				msg := invoice.sequenceNum.String;
			else
				msg &amp;= ", " &amp; invoice.sequenceNum.String;
			endif;
			continue;
		endif;
		
		allInvoicesToCopy.add(invoice);
	endforeach;
	
	if hasNotPosted then
		app.msgBox(app.getErrorString1(OnlyPostedInvLinkToCrdNote, msg), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
		if allInvoicesToCopy.isEmpty() then
			return;
		endif;
	endif;

	allInvoicesToCopy.copy(form.allInvoicesFromParent);
	form.myFirstInvoiceFromParent := allInvoicesToCopy.first().CM_Invoice;
	
	form.setMyBank(self.myCurrentBank);
	form.myParentForm := self;
	form.showModal();

epilog
	delete allInvoicesToCopy;
end;</source>
    </JadeMethod>
    <JadeMethod name="mnuInvShowFOActivity_click" id="c1689611-cfed-4f3c-b03e-76c010a3b07c">
