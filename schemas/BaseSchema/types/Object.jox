    <JadeMethod name="cnEcIsPersistent" id="47ba0a24-3328-4ef2-a030-8548d1162224">
        <source>cnEcIsPersistent():Boolean;
// --------------------------------------------------------------------------------
// Created:		08 September 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is NOT a
//				transient object.  This is the opposite to JADE's "isTransient".
//
// Parameters:	None
//
// Returns:		True if the reciever is persistent, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (not self.isTransient());
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcJDBrowserExceptionDetails" id="d4686c6b-2d45-4ea5-9396-cdd4066f192f">
        <source>cnEcJDBrowserExceptionDetails(pExceptionObj:Exception):String;
// --------------------------------------------------------------------------------
// Created:		29 April 1999 by cnwdad1
//
// Purpose:		Returns a string containing the details of an exception.
//
// Parameters:	pExceptionObj - The object of the Exception that was raised.
// Returns:		String - The details of the exception.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	message	: String;

begin
	message	:=	'Error: ' &amp; pExceptionObj.text() &amp; ' (' &amp; pExceptionObj.errorCode.String &amp; ') ' &amp; pExceptionObj.errorItem;

	if (pExceptionObj.reportingMethodDesc &lt;&gt; null) then
		if (pExceptionObj.reportingMethodDesc.isKindOf(PrimMethodCallDesc)) then
			message	:=	message &amp; CrLf &amp; CrLf &amp; 'Reported: ' &amp;
						pExceptionObj.reportingMethodDesc.receiverAsString().String &amp;
						' ' &amp; pExceptionObj.reportingMethodDesc.getName();
		else
			message	:=	message &amp; CrLf &amp; CrLf &amp; 'Reported: ' &amp;
						pExceptionObj.reportingMethodDesc.getReceiver().String &amp;
						' ' &amp; pExceptionObj.reportingMethodDesc.getName();
		endif;
	endif;

	if (pExceptionObj.currentMethodDesc &lt;&gt; null) then
		if (pExceptionObj.currentMethodDesc.isKindOf(PrimMethodCallDesc)) then
			message	:=	message &amp; CrLf &amp; CrLf &amp; 'Current:  ' &amp;
						pExceptionObj.currentMethodDesc.receiverAsString() &amp;
						' ' &amp; pExceptionObj.currentMethodDesc.getName();
		else
			message	:=	message &amp; CrLf &amp; CrLf &amp; 'Current:  ' &amp;
						pExceptionObj.currentMethodDesc.getReceiver().String &amp;
						' ' &amp; pExceptionObj.currentMethodDesc.getName();
		endif;
	endif;

	message	:=	message &amp; CrLf &amp; CrLf &amp; 'Extended: ' &amp; pExceptionObj.extendedErrorText;
epilog
	return message;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcJDBrowserExceptionHandler" id="a43142b5-f392-4933-893e-e22e5093fb10">
        <source>cnEcJDBrowserExceptionHandler(pExceptionObj:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		29 April 1999 by cnwdad1
//
// Purpose:		Global exception handler for the JADE Database Browser application.
//				This will only be called if an unhandled exception occurs where a
//				trap has not been armed.
//
// Parameters:	pExceptionObj - The object of the Exception that was raised.
// Returns:		Integer - The action to take (see return value global constants
//				in the Exception Class section of the JADE help file).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	message	: String;

begin
	message	:=	self.cnEcJDBrowserExceptionDetails(pExceptionObj);

	if (process.isInTransactionState) then
		abortTransaction;
		message	:=	message &amp; CrLf &amp; CrLf &amp; 'This transaction has been aborted.';
	endif;

	app.msgBox(message, 'JDBrowser Error', MsgBox_Stop_Icon + MsgBox_OK_Only);

	return Ex_Abort_Action;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcJDBrowser_Update" id="4f9cdcc8-d74a-4edd-8098-de93f890e103">
        <updating/>
        <source>cnEcJDBrowser_Update(pProperties:StringArray; pValues:HugeStringArray; pObjects:ObjectArray; pErrorMessage:String output):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Purpose:		This method, when reimplemented at a local class level, will override
//				any updating logic performed by the JDBrowser application.  This means
//				that developers can implement their own updating logic to cater for
//				manual collections or any other dependencies that JDBrowser does not
//				have visibility to.
//
// Parameters:	pProperties (StringArray) - An array of the class's property names.
//				pValues (HugeStringArray) - An array of property values.
//				pObjects (ObjectArray)    - An array of objects (references, collections etc).
//				pErrorMessage (String)	  - A message to be displayed in the event of an error.
//
// Returns:		Boolean -	Indicates whether this method should take precedence over
//							updating logic performed by the JDBrowser application.
//
// The following is an example of the type of data the parameters may contain:
//
//	Array Element	pProperties		pValues						pObjects
//	-------------	-------------	------------------------	-------------------------------------------------
//		  1			address			12 George Street, Sydney	null
//		  2			allTimeSheets	null						allTimeSheets (collection of TimeSheet instances)
//		  3			myCompany		null						myCompany (instance of the Company class)
//		  4			name			Blinky Bill					null
//		  5			phoneNumber		(03) 1234-5678				null
//
// It is up to the developer to cast values accordingly.  The Begin and Commit/Abort
// transactions will be handled automatically - do not use these in your implementation.
//
// **********************************************************************************
// * NOTE - Boolean values will be represented by either "0" (false) or "1" (true). *
// **********************************************************************************
// * NOTE - Binary values will be passed in the pValues array, however the data     *
// *        will have been cast as a string, therefore the integrity if the binary  *
// *        data when cast back into a binary cannot be guaranteed.                 *
// **********************************************************************************
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <Parameter name="pProperties" type="StringArray"/>
        <Parameter name="pValues" type="HugeStringArray"/>
        <Parameter name="pObjects" type="ObjectArray"/>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcLog" id="0f94a4cc-ee7d-4c8a-87d7-9f9861b96839">
        <source>cnEcLog(pMessage:String);
// --------------------------------------------------------------------------------
// Created:		20 October 2000 by cnwdad1
//
// Purpose:		Write a message to the CardSchema log.
//
// Parameters:	pMessage - The message to be logged.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 06/02/2001	cnwdad1		Changed to use the CardSchema log method.
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
begin
	if app.myCnCntrl = null then
		global.ecWriteServerFile(CNEC_MESSAGE_LOG, app.actualTimeServer().Date.String	// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
								&amp; " " &amp; app.actualTimeServer().Time.String				// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
								&amp; " " &amp; pMessage);
	else
		app.myCnCntrl.cnWriteLog(CnCntrl.CnLogComment, pMessage, null);
	endif;
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcMonitor" id="dd04fb0a-3ff1-46f4-9819-f55c1bb2c667">
        <source>cnEcMonitor(pMessage:String);
// --------------------------------------------------------------------------------
// Created:		25 May 2000 by cnwdad1
//
// Purpose:		Write a message to the BaseSchema Monitor.
//
// Parameters:	pMessage (String) - The message to be monitored.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/01/2003	cnwdad1		Added check for the length of the monitor message.  The
//							maximum allowable length of userInfo data is 48k.
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
vars
	monitorMessage	: String;
	
begin
	monitorMessage	:=	app.name &amp; "|" &amp; app.actualTimeServer().Time.String &amp; " " &amp; pMessage;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if monitorMessage.length() &gt; CNEC_USERINFO_MAX_LENGTH then
		monitorMessage	:=	monitorMessage[1:CNEC_USERINFO_MAX_LENGTH];
	endif;
	
	system.causeEvent(CNEC_MONITOR, true, monitorMessage);
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcReportDisplay" id="91402307-d64d-4dc6-9ef5-a53684daeedb">
        <source>cnEcReportDisplay():String;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
