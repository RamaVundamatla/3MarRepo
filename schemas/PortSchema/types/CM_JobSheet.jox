    <JadeMethod name="getWorkStarted" id="3d1152d1-aa14-40a7-8a64-c25ddf521fb8">
        <source>getWorkStarted() : TimeStamp;

vars
	tmpWorkStarted : TimeStamp;
	aWLE : CM_WorkListEntry;
begin
	tmpWorkStarted := self.workStarted;
	
	foreach aWLE in self.allCompletedWLEsByDate discreteLock do
		if aWLE.completedDate &lt;&gt; null then
			tmpWorkStarted := aWLE.completedDate;
			break;
		endif;
	endforeach;

	return tmpWorkStarted;
epilog
	

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkTotalMovesCompleted" id="b4a83ddc-acee-4878-9c95-74778c761f6a">
        <source>getWorkTotalMovesCompleted() : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
	aJob : CM_Job;
	aReq : CM_Request;
	theWLE : CM_WorkListEntry;
	total,completed : Integer;
	ls : Boolean;
begin
	app.cmsBeginLoad(ls);
	foreach aJob in self.allJobsByOrder discreteLock do
		foreach theWLE in aJob.workListEntries discreteLock do
			if aJob.isVoyageJob()  then  // ### TFS 51853 31AUG2021 NAVAB1
				if theWLE.myRequest.CM_SlotRequest.getAttrIsBackend() // PAR 21746
				// PAR 21746 if  theWLE.myRequest.CM_SlotRequest.fortyBack 
				// PAR 21746 or  theWLE.myRequest.CM_SlotRequest.isBackend // PAR 19945
				or  theWLE.myRequest.CM_SlotRequest.moveType = NULL_MOVETYPE then
					continue;
				endif;
			endif;
			if theWLE.status = WLE_COMPLETED then// and not theWLE.myRequest.CM_SlotRequest.fortyBack then
				completed := completed + 1;
			endif;
		endforeach;
	endforeach;

	return completed;
epilog
	app.cmsEndLoad(ls);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkTotalMovesIncomplete" id="644fbe01-3384-4e1d-bc42-de23235c78a8">
        <source>getWorkTotalMovesIncomplete() : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
	aJob : CM_Job;
	aReq : CM_Request;
	theWLE : CM_WorkListEntry;
	total,unactioned : Integer;
	ls : Boolean;
begin
	app.cmsBeginLoad(ls);

	foreach aJob in self.allJobsByOrder discreteLock do
//		if aJob.status = JOB_COMPLETE then
//			continue;
//		endif;
		foreach theWLE in aJob.workListEntries discreteLock do
			if aJob.isVoyageJob()  then  // ### TFS 51853 31AUG2021 NAVAB1
				if theWLE.myRequest.CM_SlotRequest.getAttrIsBackend() // PAR 21746
				// PAR 21746 if  theWLE.myRequest.CM_SlotRequest.fortyBack 
				// PAR 21746 or  theWLE.myRequest.CM_SlotRequest.isBackend // PAR 19945
				or  theWLE.myRequest.CM_SlotRequest.moveType = NULL_MOVETYPE then
					continue;
				endif;
			endif;
			if theWLE.status &lt;&gt; WLE_COMPLETED   then
				unactioned := unactioned + 1;
			endif;
		endforeach;
	endforeach;

	return unactioned;
epilog
	app.cmsEndLoad(ls);

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkTotals" id="1277f196-05b3-4fb1-a068-340b5d958d20">
        <source>getWorkTotals(_jobCompleted, _jobPartCompleted, _jobUnactioned,
			_moveCompleted, _moveIncomplete,  _liftCompleted, _liftIncomplete,
			_plannedLoad, _plannedDischarge, _actualLoad, _actualDischarge,
			_actualLoadTEU, _actualDischargeTEU : Integer output; _partiallyWorked : Boolean);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJob : CM_Job;
	aReq : CM_Request;
	theWLE : CM_WorkListEntry;
	done, notDone : Real;
	teu : Integer;
begin

	foreach aJob in self.allJobsByOrder discreteLock do
		if aJob.status = JOB_COMPLETE then
			_jobCompleted := _jobCompleted + 1;
		elseif aJob.status = JOB_UNACTIONED then
			_jobUnactioned := _jobUnactioned + 1;
		elseif aJob.status = JOB_PART_COMPLETE then
			_jobPartCompleted := _jobPartCompleted + 1;
		endif;
		done := 0;
		notDone := 0;
		foreach theWLE in aJob.workListEntries discreteLock do
			aReq := theWLE.myRequest;
			if not aReq.isValidForJobStats() then
				continue;
			endif;
			
			theWLE.getLiftTotals(done, notDone);
			
			if theWLE.status = WLE_COMPLETED and (_partiallyWorked or theWLE.allRTQueueEntries.size() = 0) then	//the wle wasn't actually complete, need to check queue size also
				_moveCompleted := _moveCompleted + 1;
			else
				_moveIncomplete := _moveIncomplete + 1;
			endif;
			
			//cnwmc5 - changes for KEA only
			if aJob.isKindOf(CM_VoyageJob) then
				teu := 0;
				if theWLE.myTrackedItem &lt;&gt; null then
					teu := theWLE.myTrackedItem.getNumTEU().Integer;
				endif;
				if aJob.CM_VoyageJob.isDischarge then
					_plannedDischarge := _plannedDischarge + 1;
					if theWLE.status = WLE_COMPLETED and theWLE.allRTQueueEntries.size() = 0 then
						_actualDischarge := _actualDischarge + 1;
						_actualDischargeTEU := _actualDischargeTEU + teu;
					endif;
				else
					_plannedLoad := _plannedLoad + 1;
					if theWLE.status = WLE_COMPLETED and theWLE.allRTQueueEntries.size() = 0 then
						_actualLoad := _actualLoad + 1;
						_actualLoadTEU := _actualLoadTEU + teu;
					endif;
				endif;
			endif;
		endforeach;
		
		_liftCompleted := _liftCompleted + done.Integer;
		_liftIncomplete := _liftIncomplete + notDone.Integer;
		
	endforeach;

end;</source>
        <Parameter name="_jobCompleted" type="Integer" usage="output"/>
        <Parameter name="_jobPartCompleted" type="Integer" usage="output"/>
        <Parameter name="_jobUnactioned" type="Integer" usage="output"/>
        <Parameter name="_moveCompleted" type="Integer" usage="output"/>
        <Parameter name="_moveIncomplete" type="Integer" usage="output"/>
        <Parameter name="_liftCompleted" type="Integer" usage="output"/>
        <Parameter name="_liftIncomplete" type="Integer" usage="output"/>
        <Parameter name="_plannedLoad" type="Integer" usage="output"/>
        <Parameter name="_plannedDischarge" type="Integer" usage="output"/>
        <Parameter name="_actualLoad" type="Integer" usage="output"/>
        <Parameter name="_actualDischarge" type="Integer" usage="output"/>
        <Parameter name="_actualLoadTEU" type="Integer" usage="output"/>
        <Parameter name="_actualDischargeTEU" type="Integer" usage="output"/>
        <Parameter name="_partiallyWorked" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasUnpackJob" id="b656d62c-65c9-4113-9f13-2c2d1bdb9b36">
        <source>hasUnpackJob(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 April 2023	navcs2	ChangeRequest 57557: [57396]: EUP - INB/MOB - New Scanning App - JADE

*/

vars
	job : CM_Job;
begin
	foreach job in allJobsByOrder do
		if job.isKindOf(CM_WOUnpackJob) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMatchingWorkPointType" id="e0a91f5c-3031-4cea-bf24-afe9c2863b89">
        <source>isMatchingWorkPointType(_type : Integer):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Dec 2023	navma1	ChangeRequest 58400: EUP | Ship Operations in DD - [54176.050] Mobile App changes

*/

vars
	wp     : CM_WorkPoint;
	wpType : CM_WorkPointType;
begin
	
	wp := self.myWorkPoint;
	
	if wp = null then
		return false;
	endif;
	
	wpType := wp.myWorkPointType;
	
	if wpType = null then
		return false;
	endif;
	
	if wpType.type = _type then
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
