    <JadeMethod name="setValueForRow" id="e0e5586a-69ae-4957-8aa6-4887cbbce437">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

	objArray : ObjectArray;
	obj : Object;
begin
	if _rowName = ETRow_BgpHarbours then
		self.myHarbour:=_value.HMS_Harbour;
	elseif _rowName = ETRow_BgpCheckToDate then
		self.checkToDate := _value.Date;
	elseif _rowName = ETRow_EmailRecipient then
		self.emailRecipient:=_value.String;
	elseif _rowName = ETRow_ServerFilePath then
		self.networkPath := _value.String;
	else
		inheritMethod(_rowName, _value);
	endif;


epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="6d7b78bd-26a6-4029-ab8b-19b9c9c5b7ba">
        <source>validate();
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod();

	if self.checkToDate = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Check to Date', null, null);
		app.raiseCMException(Input_required_field_chkToDate, null, null); // cnwdb2	PAR 35364
	else
		if self.checkToDate &lt; app.actualTimeServer.date then
			//app.raiseCMException1(Full_Replacement_Message,'The Check to Date must be greater than todays date',null,null); //- cnwmd1, Par 20524
			app.raiseCMException(Check_date_must_great_than_tod,null,null); //+ cnwmd1, Par 20524
		endif;
	endif;
	
	if self.networkPath = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Network Path',null,null);
		app.raiseCMException(Input_required_field_NetwrkPat,null,null);// cnwdb2	PAR 35364
	endif;
	
	//if self.emailRecipient = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Email Recipient', null, null);
	//endif;
	
	if self.myHarbour= null then
	//	app.raiseCMException1(REQUIRED_FIELD,'Harbour',null,null);
		app.raiseCMException(Input_required_field_harbour,null,null); // cnwdb2	PAR 35364


		
		
		
	endif;


epilog

end;</source>
    </JadeMethod>
</Class>
