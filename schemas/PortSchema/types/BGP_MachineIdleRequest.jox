<Class name="BGP_MachineIdleRequest" id="7b1baa88-1c8d-45a4-b9c8-60dc6872cefd">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Machine Idle Time&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="054ec7f8-d018-46d6-86a4-2bf48b3eb242">
        <updating/>
        <source>action(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
// 20/01/2021   cnwma1      Bug 50433: MTN - 1090 error in RTQ screen (Idle Time settings not inherited)
// 03/10/2022	navds21	    TFS 50083 MTN - Machine Delay Idle Time
//
vars
	errCode : Integer;
	errText : String;
	iter : Iterator;
	machineSet : CM_MachineSet;
	machine : CM_Machine;
	mins : Integer;
	idleHist, delayHist,newHist,newDelayHist : CM_MachineHistory;
	rtConfig : CM_RTVehicleConfig;

begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errText, true, true);
	on LockException do app.alertLockExceptionHandler(exception);

	self.setUser();
	
	/*if self.myTerminal = null or not self.myTerminal.getConfig(IdleTimeEnabled).Boolean then
		app.writeLog("Terminal " &amp; self.myTerminal.code &amp; " is not configured to track machine idle time - stopping", LogINFO);*/ //03.10.2022 navds21 TFS 50083
	if self.myTerminal = null or (not self.myTerminal.getConfig(IdleTimeEnabled).Boolean and not self.myTerminal.getConfig(DelayTimeEnabled).Boolean) then //03.10.2022 navds21 TFS 50083
		app.writeLog("Terminal " &amp; self.myTerminal.code &amp; " is not configured to track machine idle or delay time - stopping", LogINFO);//03.10.2022 navds21 TFS 50083
		return true;
	endif;
	
	//app.writeLog("Processing machines for Terminal " &amp; self.myTerminal.code &amp; " to check for idle machines", LogINFO);//03.10.2022 navds21 TFS 50083
	app.writeLog("Processing machines for Terminal " &amp; self.myTerminal.code &amp; " to check for idle/delay machines", LogINFO); //03.10.2022 navds21 TFS 50083
	create machineSet transient;
	self.myTerminal.getAllMachines(machineSet, false);
	iter := machineSet.createIterator;
	while iter.next(machine) do
		// ignore cranes
		if machine.isCrane then
			continue;
		endif;
		// ignore machines not logged on
		if not machine.loggedOn then
			continue;
		endif;
		
		//rtConfig := machine.myRTVehicleConfig;                               //20.01.2021 cnwma1 #50433
		rtConfig := self.myTerminal.getRTVehicleConfigForObject(machine);      //20.01.2021 cnwma1 #50433
		
		if rtConfig = null then
			continue;
		endif;
		
		// is this machine idle?
		mins := null;
		idleHist := null;
		if machine.isIdle(mins, idleHist) then
			app.writeLog("Machine " &amp; machine.code &amp; " has been idle for " &amp; mins.String &amp; " minutes", LogINFO);
			// does it already have an Idle history? If not, create one, and an alert if necessary
			app.myTrxCA.trxCreateMachineIdleHistory(machine, idleHist, newHist, mins, app.myPassport);
			// and a note to update the RTQ screen
			machine.causeEvent(self.myTerminal.getTerminalEvent(Event_MachineIdle), false, machine);
		else
			// create a note in case it was idle and now it's not
			machine.causeEvent(machine.myTerminal.getTerminalEvent(Event_MachineIdleStop), false, machine);
		endif;
		//Start 03.10.2022 navds21 TFS 50083
		if machine.isSetdownDelayed(mins, delayHist) then
			app.writeLog("Machine " &amp; machine.code &amp; " has been delayed for " &amp; mins.String &amp; " minutes", LogINFO);
			// does it already have a Delay history? If not, create one, and an alert if necessary
			app.myTrxCA.trxCreateMachineDelayHistory(machine, delayHist, newDelayHist, mins, app.myPassport);
			// and a note to update the RTQ screen
			machine.causeEvent(self.myTerminal.getTerminalEvent(Event_MachineDelay), false, machine);
		else 
			// create a note in case it was delayed and now it's not
			machine.causeEvent(machine.myTerminal.getTerminalEvent(Event_MachineDelayStop), false, machine);
		endif;
	    //End 03.10.2022 navds21 TFS 50083
	endwhile;
	
epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errText, app.myPassport);
	endif;
	inheritMethod();
	delete machineSet;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="87c2562f-1d72-49de-9051-9ba0198560d8">
        <source>getDisplay(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
// 03/10/2022	navds21	TFS 50083 MTN - Machine Delay Idle Time
vars
	detail : String;

begin
	detail := inheritMethod();
	
	//return detail &amp; Tab &amp; 'Checking for idle machines.'; //03.10.2022 navds21 TFS 50083
	return detail &amp; Tab &amp; 'Checking for idle and delayed machines.'; //03.10.2022 navds21 TFS 50083

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="045c02e2-d99f-494e-b135-c73e8c625770">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTask) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
// 03/10/2022	navds21	    TFS 50083 MTN - Machine Delay Idle Time
vars

begin
	inheritMethod(_task);
	
	//if self.myTerminal = null or not self.myTerminal.getConfig(IdleTimeEnabled).Boolean then //03.10.2022 navds21 TFS 50083
	if self.myTerminal = null or (not self.myTerminal.getConfig(IdleTimeEnabled).Boolean and not self.myTerminal.getConfig(DelayTimeEnabled).Boolean) then //03.10.2022 navds21 TFS 50083
		return;
	endif;
epilog

end;</source>
        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
</Class>
