    <JadeMethod name="calculateAllContaineSizeTotals" id="9f13243a-a2ee-4ab9-84fe-30ea3b2ee845">
        <updating/>
        <source>calculateAllContaineSizeTotals(lc : CM_LocationsController;
                               total20Containers : Integer io;
							   total30Containers : Integer io;
							   total40Containers : Integer io;
							   total45Containers : Integer io;
							   total53Containers : Integer io;
							   set               : CM_GridControllersByRowColumn;
							   oa                : ObjectArray io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2008	conkc1	Initial creation

*/

vars
	count             : Integer;
	maxStackingHeight : Integer;

begin
	maxStackingHeight := lc.getMaxStackingHeight;
	total20Containers := total20Containers + maxStackingHeight;
	if lc.isKindOf(CM_GridController) then
			
		count := lc.CM_GridController.getMaxAllowedStackingHeight(set, oa);
		total40Containers := total40Containers + count;

	endif;
	//
	// Needs code for 30 and 45 and 50 foot containers
	//

epilog

end;</source>
        <Parameter name="lc" type="CM_LocationsController"/>
        <Parameter name="total20Containers" type="Integer" usage="io"/>
        <Parameter name="total30Containers" type="Integer" usage="io"/>
        <Parameter name="total40Containers" type="Integer" usage="io"/>
        <Parameter name="total45Containers" type="Integer" usage="io"/>
        <Parameter name="total53Containers" type="Integer" usage="io"/>
        <Parameter name="set" type="CM_GridControllersByRowColumn"/>
        <Parameter name="oa" type="ObjectArray" usage="io"/>
    </JadeMethod>
