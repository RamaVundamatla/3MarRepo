// ---------------------------------------------------------------------------
// Created:     25 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myOutputFormat.getAllFields.indexOf (self);
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDecimals" id="01bda100-bd6f-4632-a0e8-40ec4ed472de">
        <updating/>
        <source>setDecimals( _value : Integer ) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/01/2009	cnwrl1		Stop exception when not actually doing any updating (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------
vars
	
begin
	if self.decimals = _value then	// because this is being called on lost focus when not real updating is being done.
		return;
	endif;
	
	self.raiseExceptionIfNotTransient(method);
	
	self.decimals := _value;
epilog
	
end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFunction" id="581a6956-f42f-413f-b932-6b56137843f9">
        <updating/>
        <source>setFunction( _value : Integer ) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/01/2009	cnwrl1		Stop exception when not actually doing any updating (CCMS SFW 1047 - Totals Only Lists)
// 12/02/2010	cnwcs5		par 22140 - New functions
// ---------------------------------------------------------------------------
vars
	
begin
	if self.function = _value then	// because this is being called on lost focus when not real updating is being done.
		return;
	endif;
	
	self.raiseExceptionIfNotTransient(method);
	
	if not _value.isOneOf(	self.Function_Count,
							self.Function_Count_True,		// 12/02/2010 cnwcs5 par 22140
							self.Function_Count_False,		// 12/02/2010 cnwcs5 par 22140
							self.Function_Count_Null,		// 12/02/2010 cnwcs5 par 22140
							self.Function_Count_NotNull,	// 12/02/2010 cnwcs5 par 22140	
							self.Function_Count_Zero,		// 15/02/2010 cnwcs5 par 22140
							self.Function_Count_NotZero,	// 15/02/2010 cnwcs5 par 22140	
							self.Function_Sum,
							self.Function_Average,
							self.Function_Max,
							self.Function_Min ) then
		// this will only happen if there is a coding error
		app.raiseUnexpectedProgramError( self.class.name, method.name, 'Invalid function' );
	endif;

	self.function := _value;
epilog
	
end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
