	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	_proxyGroup.pxyGetRealObjectAndEdition(realEmailGroup, expectedEdition);
	
	if realEmailGroup = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EmailGroup.name, null, null);
		return;
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realEmailGroup);

	if _passport.noErrors and realEmailGroup.edition &lt;&gt; expectedEdition then
