    <JadeMethod name="setControlsForAddEdit" id="aee653f9-a97b-4595-89c2-984079115a03">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// 19 Sep 2019	cnwrs1	TFS 46087 SFTP
//
vars
	theForm : SOP_TableMaintForm;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;
begin
   	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	entTableDef := app.myController.getEntTableDef(ETDef_SFTPEntityMaint);
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
	endforeach;
	
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
	else
		self.showThumbnail(theForm.myCurrentObject.CM_SFTPEntity);
	endif;
    theForm.tblInput1.cnEcResizeContents;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="91e738b7-a7a5-490e-b88b-569e8bb6a527">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// 19 Sep 2019	cnwrs1	TFS 46087 SFTP
//
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_SFTPEntityTbl);

	theForm.txtBox01.passwordField := true;

	theForm.shtTblInput1.caption := 'SFTP Entity Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_SFTPEntityMaint);
	theForm.shtTblInput1.visible := true;
end;
</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="d3bf7d40-2af3-49d8-8ae2-ad09ed8f5996">
        <updating/>
        <source>showThumbnail(_ftpEntity: CM_SFTPEntity) updating;
//
// 19 Sep 2019	cnwrs1	TFS 46087 SFTP
//
vars
	theForm : SOP_TableMaintForm;
	entTableDef	: EntTableDef;
	entTableRow	: EntTableRow;
begin
  	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	entTableDef := app.myController.getEntTableDef(ETDef_SFTPEntityMaint);
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.setValueByName(entTableRow.name, _ftpEntity.getDisplayStringForAttribute(entTableRow.name, false));
	endforeach;
	if _ftpEntity.password &lt;&gt; null then
		theForm.setEnteredPassword(_ftpEntity.password);
		theForm.tblInput1.setValueByName(ETRow_Password, '******');
	endif;
	//06 Sep 2021	NDL	TFS 51165
	if _ftpEntity.passPhrase &lt;&gt; null then
		theForm.setEnteredPassword2(_ftpEntity.passPhrase);
		theForm.tblInput1.setValueByName(ETRow_PassPhrase, '******');
	else
		theForm.setEnteredPassword2(null);
	endif;
end;
</source>
        <Parameter name="_ftpEntity" type="CM_SFTPEntity"/>
    </JadeMethod>
</Class>
