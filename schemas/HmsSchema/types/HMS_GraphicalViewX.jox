    <JadeMethod name="dkbWharfDrawCntr_mouseDown" id="9d614efa-3790-4d79-93c7-fafcf6753bb6">
        <controlMethod name="JadeDockBar::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dkbWharfDrawCntr_mouseDown(dockBar: JadeDockBar input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------
// Created:	06 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	timeOfNote		: TimeStamp;
	
begin
	self.setSelectedMovement(null, false);
	
	if button = 1 then
		return;
	endif;

	self.origXPos	:=	x;
	self.origYPos	:=	y;
	
	if self.getTimeForPosition(y, timeOfNote) then
		self.planningNoteDate		:=	timeOfNote.date();
		self.mnuPlanNotes.caption	:=	"Planning Notes for " &amp; timeOfNote.date().shortFormatJMT() &amp; "...";
	endif;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuPlanNotes.enabled:= false;
	endif;
	
	self.popupMenu(self.mnuDetailArea, x.Integer, y.Integer);
end;</source>
        <Parameter name="dockBar" type="JadeDockBar" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
