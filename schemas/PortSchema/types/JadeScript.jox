    <JadeMethod name="tfs4259" id="8021eaf2-6ca1-49df-b06d-45a5cf295f4a">
        <source>tfs4259();
//
// 23 Jun 2016	cnwrs1	TFS4259
//
vars
	class : Class;
	str : String;
	camProtocol : CM_CamProtocol;
begin
	foreach class in currentSchema.allClasses where class.name = "CM_CamSEABX12322Desc" do
		beginTransaction;
		class.instances.purge;
		commitTransaction;
	endforeach;
	foreach camProtocol in CM_CamProtocol.instances do
		if camProtocol.protocolDesc = null then
write class.name&amp;'::'&amp;method.name&amp;' '&amp;camProtocol.code;
			beginTransaction;
			delete camProtocol;
			commitTransaction;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
