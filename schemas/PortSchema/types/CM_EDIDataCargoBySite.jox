    <JadeMethod name="loadDB" id="dcab6abe-2f79-47ea-b7ce-87218bedf734">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport: CM_Passport input) updating;
//----------   ----------  --------------------------------------------------
//Created:	09 Jan 2010 cnwrs1
//
//Purpose:	
//
//Changed On   Changed By  Reason
//	
//----------   ----------  --------------------------------------------------
// 20/06/2012	cnwcs5		par 29747 - refactor into trx
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
vars
	terminal : CM_Terminal;
	cmifEDICargoBySite : CMIF_EDICargoBySite;
	tmpStatus : Integer;
	allowPartialLoad : Boolean;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	allowPartialLoad := self.getMyTerminal.getConfig(EdiCargoByAllowPartial).Boolean;
	app.setContinueCMExceptions(false);
	
	terminal := self.getMyTerminal();
	
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
		
	//17 May 2012	NDL	Par 29587
	if _passport.hasErrors then
		return;
	endif;
	if not allowPartialLoad then
		_passport.setWarningsIgnored(true);			//12.Oct.2023 navsp1 TFS 58058 - To fix the transient leak for CMIF_TrxActionCargoGroup while processing the update EDI process.
		app.myTrxUA.trxProcessEDITIsCargo(self, false, _passport);
	else
		create cmifEDICargoBySite transient;
//		self.allEDITrackedItems.copy(cmifEDIShipManifest.allEDITrackedItems);
//		self.ediFileArray.copy(cmifEDIRequestMultiLine.ediFileArray);
		cmifEDICargoBySite.loadOrVerifyForDB(self, _passport, false);
		tmpStatus := self.getStatusFromEDITrackedItems(false);
		if tmpStatus &lt;&gt; 0 then
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
		endif;
	endif;
epilog
	delete cmifEDICargoBySite;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
