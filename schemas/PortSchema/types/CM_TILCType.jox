    <JadeMethod name="pxyCreateUpdateProxy" id="5e47d85e-c7b2-4e67-bb39-2074f444981a">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 07 December 2005 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy		: SelfType;
	pxyState	: CM_StateObject;
	completedOK	: Boolean;
begin
	proxy := inheritMethod();
	
	proxy.myCargoTypeExtTILC := self.myCargoTypeExtTILC;
	
	if self.myStateObject &lt;&gt; null then
		pxyState 			:= self.myStateObject.pxyCreateUpdateProxy();
		proxy.myStateObject := pxyState;
	endif;
	
	proxy.myRoot		:= self.myRoot;
	proxy.myCargoType 	:= self.myCargoType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	
	return proxy;	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
