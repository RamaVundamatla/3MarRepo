    <JadeMethod name="cmbOperator_click" id="1ba35fc1-1745-4669-9fea-2dd6f3cf34de">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_click(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------  ---------- 	--------------------------------------------------
22/12/2016	cnwdap1		TFS 3039 SNO Empty Container Pool Management
*/
vars
	op : CM_Operator;									// TFS 3039
	opTerm : CM_OperatorTerminal;						// TFS 3039
	poolParty : CM_MTPoolingParty;						// TFS 3039
	
begin
	self.myAssistant.listTableMTGrade(lstMTGrade, combobox.listObject.CM_Operator, self.cmbOperatorGroup.listObject.CM_OperatorGroup);
	if combobox.listObject.CM_Operator &lt;&gt; null then									// TFS 3039
		op := combobox.listObject.CM_Operator;										// TFS 3039
		opTerm := op.allOperatorTerminals[self.myTerminal];							// TFS 3039
		if opTerm &lt;&gt; null then														// TFS 3039
			poolParty := op.allOperatorTerminals[self.myTerminal].myPoolingParty;	// TFS 3039
			if poolParty &lt;&gt; null then												// TFS 3039
				self.tblEntry.setValueByName(ETRow_PoolParty, poolParty.code);		// TFS 3039
			else																	// TFS 3039
				self.tblEntry.setValueByName(ETRow_PoolParty, null);				// TFS 3039
			endif;																	// TFS 3039
		else																		// TFS 3039
			self.tblEntry.setValueByName(ETRow_PoolParty, null);					// TFS 3039
		endif;																		// TFS 3039
	endif;																			// TFS 3039

end;


</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
