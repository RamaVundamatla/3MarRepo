    <JadeMethod name="addReleaseToHistory" id="24d24c4b-d132-4f5e-adfc-f9290f9202a5">
        <source>addReleaseToHistory(_wle :CM_VoyageWLE) protected;
// ---------------------------------------------------------------------------
// Created:     07 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	crane		:CM_Crane;
	history		:CM_MachineMoveHistory;
begin
	crane := self.getCrane;
		
	if crane = null then
		// nowhere to add history
		return;
	endif;

	history := crane.addReceiveReleaseToHistory (self, _wle);
	
	history.setMyShipReleaseTrx (self);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="canEditAmount" id="f3c607bd-b62c-4fe9-9805-2b0c3f59b437">
        <source>canEditAmount(): Boolean;
/*

Date		Who		Reason
07 December 2016	cnwer1	Initial creation TFS 2996

*/

vars
	ct : CM_CargoType;
	subType : CM_Product;
begin
	
	self.getCargoTypeAndSubType(ct,subType);
	
	if ct = null or not ct.allowDuplicates then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createKPIController" id="77666c18-102b-458b-8bb2-c67dcab10b94">
        <source>createKPIController();
// ---------------------------------------------------------------------------
// Created:		28 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Delimiter = "^";
	Header = "~";

vars
	infoString : String;
begin
	if self.myJobSheet = null then
		return;
	endif;
	
	if self.myJobSheet.myVoyage = null then
		return;
	endif;
	
	if self.isChild then	//27 Jul 2010	NDL	Par 23056
		return;
	endif;
	
	
	/* PAR 33644
	if self.myJobSheet.myVoyage.isNonPlannedVoyage 
	or self.myJobSheet.myVoyage.isNonWorkedVoyage then
		// PAR 21745 CCMS MES 1031 - We do now include RORO/Planned voyages
		if self.myJobSheet.myVoyage.isNonPlannedOrNotCellularRORO then
			return;
		endif;
	endif;
	*/
	
	if not self.myJobSheet.myVoyage.isLOLOorRORO() then
		return;
	endif;

	infoString := CMIF_KPIShipMove.name &amp; Header &amp; self.getOidStringForObject(self) &amp; Delimiter &amp; self.getOidStringForObject(self.myJobSheet);
	system.causeEvent(KPIAgent_UpdateEvent, false, infoString);
end;</source>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="1bcb3c3e-4000-46d5-9564-be24ece6c6ae">
        <source>createTransaction(_passport: CM_Passport input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Aug 2012	cnwer1	Initial creation CCMS SFW 1280 Cash System
06 Apr 2023	navdap1	TFS 57362 CUX - Changes to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
*/

vars
	ti			: CM_TrackedItem;
	txnParams	: CMIF_StorageTransController;
	wsRequest	: BGP_EDBICWSRequest;	// ### TFS 55215 30Nov2022 NAVPW1
	extService	: CM_ExternalWebServiceDef;		// TFS 58722
	
begin
	if app.isInProformaMode then
		ti:=self.myTrackedItem;
		// Create storage transactions
		create txnParams transient;
		txnParams.type 			:= TRANS_TYPE_STORAGE;
		// release ship is to happen in the future get this date from ti's voyage departure date
		// otherwise storage is not charge because date Time is same as the received road trx date time
		if ti.myVoyage &lt;&gt; null and ti.myVoyage.departedDT.isValid then
			txnParams.dateTime :=	ti.myVoyage.departedDT;
		else
			txnParams.dateTime 		:= self.dateTime;
		endif;
		txnParams.noCharge 		:= self.noCharge;
		// PAR 16898 - RJS June 2008
		txnParams.freightForwarderCode	:= self.freightForwarderCode;
		txnParams.operatorCode 	:= self.operatorCode;
		txnParams.urNumber		:= self.urNumber;
		txnParams.userId		:= self.userId;
		ti.createTransaction(txnParams, _passport);
	else
		inheritMethod(_passport);
	endif;
	
	// ### TFS 55215 22Nov2022 NAVPW1 - START
	extService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_ShipReleaseEDBIC );	// TFS 58722
	if extService &lt;&gt; null and extService.isEDBIC and not app.isJMTUnitTest then			// TFS 58722
		create wsRequest persistent;
		wsRequest.setDetails(self.myTrackedItem,					//_trackedItem	: CM_TrackedItem;
								null,								//_vehicleVisit	: CM_VehicleVisitRecord;
								null,								//_train 		: CM_Train			// TFS 57362
								null,								//_voyage 		: CM_Voyage			// TFS 57362
								self.myTrackedItem.myTerminal,		//_terminal		: CM_Terminal		// TFS 57362
								BGP_EDBICWSRequest.Type_ShipRelease	//_dataType		: Integer
							);
		wsRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);
	endif;
	// ### TFS 55215 22Nov2022 NAVPW1 - END
	
epilog
	delete txnParams;
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doesRequireSnapShot" id="3608cea2-c1f4-4906-8b43-df15bf063df5">
        <methodInvocation>mapping</methodInvocation>
        <source>doesRequireSnapShot(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     20 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := true;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCrane" id="8e3ce161-342b-483e-9234-f5e77c371c01">
        <source>getCrane():CM_Crane;
// ---------------------------------------------------------------------------
// Created:     08 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	terminal	:CM_Terminal;
	machine		:CM_Machine;
	result		:CM_Crane;
begin
	terminal := self.myTerminal;
	
	if terminal = null then
		//get it from job
		terminal := self.myJob.myTerminal;
	endif;
	
	machine := terminal.machines[self.craneID];
	
	if machine &lt;&gt; null and machine.isKindOf (CM_Crane) then
		result :=  machine.CM_Crane;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="91c0ee71-a3f6-44e3-a658-5c32ac0d341c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// Jan 2012 CCMS 1262 Transaction enquiry
// 28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
vars
	lDetail : String;
	amountDisplay : String;
begin

	if _attrName = ETRow_ReleaseShipCrane then
		return self.craneID;
	elseif _attrName = ETRow_ReleaseShipFrom then
		return self.locationShip;
	elseif _attrName = ETRow_ReleaseShipTo then
		return self.locationYard;
	elseif _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 25/10/18 MAP TFS41191
		else
			if locationShip &lt;&gt; null and locationYard &lt;&gt; null then
				lDetail:= app.getErrorString2(MOVE_FROMTO,locationYard,locationShip);
			endif;
			amountDisplay :='(' &amp; self.getAmountDisplay() &amp; ') '; //epr TFS 2996 7/12/16
			if amountDisplay &lt;&gt; null then
				lDetail:= app.getErrorString(ReleasedStr) &amp; " " &amp; amountDisplay &amp; " "  &amp; lDetail;
			else
				lDetail:= app.getErrorString(ReleasedStr) &amp; " " &amp; lDetail;
			endif;
			return lDetail;
		endif;
	elseif _attrName = ETRow_TransferType then //22.11.2018 cnwma1 TFS #42141
		return app.vesselAccessTypeEnumToStr(self.transferType);
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExchangeStats" id="f09e7ab3-4282-4312-88ed-aff1233cd19f">
        <source>getExchangeStats(_aCandHRpt : CMIF_CandHRpt input);
//----------------------------------------------------------------
//	Created:	21 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tiSnapShot	: CM_TISnapShot;
begin

	if self.myTrackedItem = null
	or self.mySnapShot = null then
		return;
	endif;

	if self.transitStatus = TI_TransitStatusDLR then
		// don't count the load side of the DLR operation
		return;
	endif;

	tiSnapShot := self.mySnapShot.CM_TISnapShot;
	
	//if tiSnapShot.myUserTISnapShot &lt;&gt; null then
	//	tiSnapShot.myUserTISnapShot.getExchangeStats(_aCandHRpt);	
	//else
		tiSnapShot.getExchangeStats(_aCandHRpt);
	//endif;
	
end;</source>
        <Parameter name="_aCandHRpt" type="CMIF_CandHRpt" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getHoldInfo" id="1e103577-dbdb-41b1-97ce-ea65654585a1">
        <source>getHoldInfo(): String;
/*
Purpose:			this is used by moves to a hold so are not part of a LOLO or RORO move.
Date		Who		Reason
20 March 2015	cnwab1	Initial creation
*/

vars

begin
	if self.myBay = null and self.myDeck =  null then
		return self.craneID;
	endif;
	
	return "";
	
epilog

end;</source>
        <ReturnType type="String"/>
