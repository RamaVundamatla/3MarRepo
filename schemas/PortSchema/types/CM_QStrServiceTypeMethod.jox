<Class name="CM_QStrServiceTypeMethod" id="a7f130f7-7840-478d-8a40-883f38d5a5ba">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="da039be2-27ea-449b-ab7f-82c311105982">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2022	navkc1	Initial creation - ChangeRequest 54570: EUP - Inv Config - Selector Query

*/

vars
	operator : CM_QStringIsOneOf;
begin
	if self.isTransient then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="ab4c5dfe-d156-46f0-8297-da844fbef27e">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2022	navkc1	Initial creation - ChangeRequest 54570: EUP - Inv Config - Selector Query

*/

vars

begin
	
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbServiceType';
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="7ecefacd-3467-40f9-8fc1-c5000cbc1390">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2022	navkc1	Initial creation - ChangeRequest 54570: EUP - Inv Config - Selector Query

*/

vars
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	bank					: CM_Bank;
	allBanks				: CM_CompanyByCodeDict;
	userTerminal			: CM_UserTerminal;
	objSetTerminal,
	objSetBank				: ObjectSet;
	multiTerminal			: Boolean;
	obj						: Object;
	serviceType				: CM_ServiceType;
begin
	
	_combo.clear();
	
	// Create transients
	create objSetTerminal transient;
	create allBanks transient;
	create objSetBank transient;
	
	foreach selectorCriteriaLine in _params.allCriteriaLines do
		// Get selected Terminals
		if selectorCriteriaLine.myQueryProperty.propertyName = 'myTerminal' or
			selectorCriteriaLine.myQueryProperty.propertyName = 'getTerminal' then
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objSetTerminal);
		endif;
		// Get selected Banks
		if selectorCriteriaLine.myQueryProperty.propertyName = 'bank' then
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objSetBank);
		endif;
	endforeach;
	
	// If no Terminal selected, get it from user's access
	if objSetTerminal.isEmpty() then
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			if userTerminal.getMyTerminal() &lt;&gt; null then
				objSetTerminal.add(userTerminal.getMyTerminal());
			endif;
		endforeach;
	endif;
	
	// Set is more than 1 terminal
	multiTerminal := (objSetTerminal.size() &gt; 1);
	
	foreach obj in objSetTerminal do
	
		allBanks.clear();
		
		obj.CM_Terminal.getAvailableCompanies(allBanks);
		
		foreach bank in allBanks do
			// Only process selected banks
			if (objSetBank.size() = 0) or (objSetBank.size() &gt; 0 and objSetBank.includes(bank)) then 
				foreach serviceType in bank.allServiceTypes do
					if multiTerminal then
						_combo.itemObject[_combo.addItem(serviceType.code &amp; Tab &amp; " (" &amp; bank.code &amp; " - " &amp; obj.CM_Terminal.code &amp; ")" )] := serviceType;
					else
						_combo.itemObject[_combo.addItem(serviceType.code &amp; Tab &amp; " (" &amp; bank.code &amp; ")" )] := serviceType;
					endif;
				endforeach;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete objSetTerminal;
	delete allBanks;
	delete objSetBank;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="bedf9890-f3dd-4e58-9ead-ad055ef24738">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2022	navkc1	Initial creation - ChangeRequest 54570: EUP - Inv Config - Selector Query

*/

vars
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	serviceType				: CM_ServiceType;
	bank					: CM_Bank;
	allBanks				: CM_CompanyByCodeDict;
	selectionValue			: Integer;
	idx						: Integer;
	userTerminal			: CM_UserTerminal;
	objSetTerminal, 
	objSetBank 				: ObjectSet;
	obj						: Object;
	multiTerminal			: Boolean;
begin
	
	_tbl.clear();
	_tbl.rows := 0;
	
	create objSetTerminal transient;
	create allBanks transient;
	create objSetBank transient;
	
	foreach selectorCriteriaLine in _params.allCriteriaLines do
		// Get selected Terminals
		if selectorCriteriaLine.myQueryProperty.propertyName = 'myTerminal' or
			selectorCriteriaLine.myQueryProperty.propertyName = 'getTerminal' then
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objSetTerminal);
		endif;
		// Get selected banks
		if selectorCriteriaLine.myQueryProperty.propertyName = 'bank' then
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objSetBank);
		endif;
	endforeach;
	
	// If no Terminal selected, get it from user's access
	if objSetTerminal.isEmpty() then
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			if userTerminal.getMyTerminal() &lt;&gt; null then
				objSetTerminal.add(userTerminal.getMyTerminal());
			endif;
		endforeach;
	endif;
	
	// Set is more than 1 terminal
	multiTerminal := (objSetTerminal.size() &gt; 1);
	
	foreach obj in objSetTerminal do
	
		allBanks.clear();
		
		obj.CM_Terminal.getAvailableCompanies(allBanks);
		
			foreach bank in allBanks do
				// Only process selected banks
				if (objSetBank.size() = 0) or (objSetBank.size() &gt; 0 and objSetBank.includes(bank)) then 
					foreach serviceType in bank.allServiceTypes do
						selectionValue := 0;
						if _operator &lt;&gt; null then
							if _operator.CM_QStringIsOneOf.allSelectionValues.includes(serviceType.code) then
								selectionValue := 1;
							endif;
						endif;
						
						if multiTerminal then
							idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; serviceType.code &amp; " (" &amp; bank.code &amp; " - " &amp; obj.CM_Terminal.code &amp; ")");
						else
							idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; serviceType.code &amp; " (" &amp; bank.code &amp; ")");
						endif;
						_tbl.accessRow(idx).itemObject := serviceType;
						_tbl.row := idx;
						_tbl.change(_tbl);
					endforeach;
				endif;
			endforeach;
	endforeach;

epilog
	delete allBanks;
	delete objSetTerminal;
	delete objSetBank;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="cf30b108-219e-4711-ab3f-421c7facb8b0">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2022	navkc1	Initial creation - ChangeRequest 54570: EUP - Inv Config - Selector Query

*/

vars
	serviceType		: CM_ServiceType;
	stringArray		: StringArray;
	numRows,
	index			: Integer;
	string			: String;
begin
	
	create stringArray transient;

	numRows := _tbl.rows;
	
	foreach index in (_tbl.fixedRows + 1) to numRows do
		string := _tbl.accessCell(index, 1).text;
		
		if string = TableCheckBox_Selected then
			serviceType := _tbl.accessRow(index).itemObject.CM_ServiceType;
			stringArray.add(serviceType.code);
		endif;
	endforeach;
	
	_op.setSearchValue(stringArray);

epilog
	delete stringArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="2b4c64fe-adb1-4f84-baed-2606d9c44e3e">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2022	navkc1	Initial creation - ChangeRequest 54570: EUP - Inv Config - Selector Query

*/

vars

begin
	
	if _value.isKindOf(CM_ServiceType) then
		if _value &lt;&gt; null then
			return _value.CM_ServiceType.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="80462fe6-baf3-4b85-94cb-bfa76eb1ac26">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2022	navkc1	Initial creation - ChangeRequest 54570: EUP - Inv Config - Selector Query

*/

vars
	invalidObj 	: Boolean;
	object 		: CM_ServiceType;
	returnVal 	: String;
begin
	
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_ServiceType) then
			object := _value.CM_ServiceType;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
