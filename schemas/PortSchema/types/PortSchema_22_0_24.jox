    <JadeMethod name="convertEDIDataXlationOperator" id="b3e79522-5324-4c14-82e6-9467ea1e1be7">
        <source>convertEDIDataXlationOperator(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading

*/

vars
	root  			     : CM_Root;
	terminal			 : CM_Terminal;
	ediData				 : CM_EDIData;
	xlationOperatorCode	 : String;
	stateData 			 : CM_StateData;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting xlationOperatorCode to be stored into CM_EDIData::xlationOperatorCode attribute", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting xlationOperatorCode to be stored into CM_EDIData::xlationOperatorCode attribute") ;	
	endif;
	
	root := app.myRoot;
	
	beginTransaction;
	
	foreach terminal in root.allTerminals  do 
		foreach ediData in terminal.myEdiConfig.ediDatas do
			
			if ediData.allExtraData.isEmpty then
				continue;
			endif;
			
			/*
			1- ETRow_XlateOperatorCode
			*/
			stateData			:= null;
			xlationOperatorCode := null;
			
			stateData 			:= ediData.allExtraData[ETRow_XlateOperatorCode];
			
			if stateData &lt;&gt; null then
				xlationOperatorCode	:= stateData.getValue().String;
				ediData.zSetXlationOperatorCode(xlationOperatorCode[1:4]);
				
				delete  stateData;
			endif;		
			
		endforeach;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Converting xlationOperatorCode to be stored into CM_EDIData::xlationOperatorCode attribute complete", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting xlationOperatorCode to be stored into CM_EDIData::xlationOperatorCode attribute complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertEDITIExtraData" id="8f5dd121-e8ac-4980-a279-06364587d7ea">
        <source>convertEDITIExtraData(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
12 Oct 2023	navmd1	Modified slightly to perform better with larger datasets. This can still take AGES (read: hours) when there are millions of active EDIDatas/StateData :(

*/

vars
	ediTi					: CM_EDITrackedItem;	
	ediData  			    : CM_EDIData;
	extraVoyageCode,
	extraCommodity,
	extralClientRef1,
	extraClientRef2,
	extraVehicle,
	extraSalesOrderNo		: String;
	root					: CM_Root;
	term					: CM_Terminal;
	extaData 			 	: CM_StateData;
	extraDataToPurge		: CM_ObjectArray;
	nextCommitTime			: TimeStamp;
	ref1Name,
	ref2Name,
	vehicleName				: String;
	count,
	total,
	lastCommit				: Integer;
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting CM_EDITrackedItem.allExtraData to be stored into rawDataVoyageCode,rawDataCommodity,clientRef1,clientRef2,vehicle and clientRef ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting CM_EDITrackedItem.allExtraData to be stored into rawDataVoyageCode,rawDataCommodity,clientRef1,clientRef2,vehicle and clientRef") ;	
	endif;
	
	root := app.myRoot;
	create extraDataToPurge transient;
	
	ref1Name := CM_BOL::clientRef1.name;
	ref2Name := CM_BOL::clientRef2.name;
	vehicleName := CM_BOL::vehicle.name;
	
	beginTransaction;
	nextCommitTime := app.actualTimeServer().addSeconds(30);
	
	foreach term in root.allTerminals  do 
		foreach ediData in term.myEdiConfig.ediDatas do
			//count := 0;
			total += ediData.allEDITrackedItems.size;
			foreach ediTi in ediData.allEDITrackedItems do 
				count += 1;
				
				if ediTi.getAllExtraData.isEmpty then
					continue;
				endif;
				
				if nextCommitTime &lt; app.actualTimeAppServer() then
					app.writeLog("[" &amp; term.code &amp; "] Commiting " &amp; (count-lastCommit).String &amp; " (" &amp; count.String &amp; "/" &amp; total.String &amp; ")...", LogINFO);
					lastCommit := count;
					extraDataToPurge.purge();
					commitTransaction;
					app.writeLog("Done, continuing...", LogINFO);
					beginTransaction;
					nextCommitTime := app.actualTimeServer().addSeconds(30);
				endif;
				
				/*
				1- Key = ETRow_VoyageCode , CM_EDITrackedItem::rawDataVoyageCode
				*/
				//extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[ETRow_VoyageCode];
				if extaData &lt;&gt; null then
					extraVoyageCode := extaData.getValue().String;
					ediTi.saveRawVoyageCode(extraVoyageCode);
					//delete  extaData;
					extraDataToPurge.add(extaData);
				endif;
				
				/*
				2- Key = ETRow_Commodity , CM_EDITrackedItem::rawDataCommodity
				*/
				//extaData						:= null;
				extaData 					    := ediTi.getAllExtraData[ETRow_Commodity];
				if extaData &lt;&gt; null then
					extraCommodity := extaData.getValue().String;
					ediTi.saveRawCommodityCode(extraCommodity);
					//delete  extaData;
					extraDataToPurge.add(extaData);
				endif;
				
				//if ediTi.isKindOf(CM_EDIBOLHdrTI) then
				if ediTi.isEDIBOLHdrTI then
					/*
					3- Key = CM_BOL::clientRef1.name , CM_EDIBOLHdrTI::clientRef2 
					*/
					//extaData						:= null;
					extaData 					    := ediTi.getAllExtraData[ref1Name];
					if extaData &lt;&gt; null  then
						extralClientRef1 := extaData.getValue().String;
						ediTi.CM_EDIBOLHdrTI.setServiceOrderNbr(extralClientRef1);
						//delete  extaData;
						extraDataToPurge.add(extaData);
					endif;
					
					/*
					4-Key = CM_BOL::clientRef2.name , CM_EDIBOLHdrTI::clientRef2
					*/
					//extaData						:= null;
					extaData 					    := ediTi.getAllExtraData[ref2Name];
					if extaData &lt;&gt; null  then
						extraClientRef2 := extaData.getValue().String;
						ediTi.CM_EDIBOLHdrTI.setPONbr(extraClientRef2);
						//delete  extaData;
						extraDataToPurge.add(extaData);
					endif;
					
					/*
					5- Key = CM_BOL::vehicle.name , CM_EDIBOLHdrTI::vehicle
					*/
					//extaData						:= null;
					extaData 					    := ediTi.getAllExtraData[vehicleName];
					if extaData &lt;&gt; null   then
						extraVehicle := extaData.getValue().String;
						ediTi.CM_EDIBOLHdrTI.setVehicle(extraVehicle);
						//delete  extaData;
						extraDataToPurge.add(extaData);
					endif;
				endif;
				
				//if ediTi.isKindOf(CM_EDICargoTI) then
				if ediTi.isEDICargo then
					/*
					6- Key = ETRow_SalesOrderNbr , CM_EDICargoTI::clientRef
					*/
					//extaData						:= null;
					extaData 					    := ediTi.getAllExtraData[ETRow_SalesOrderNbr];
					if extaData &lt;&gt; null   then
						extraSalesOrderNo := extaData.getValue().String;
						ediTi.CM_EDICargoTI.setSalesOrderNbr(extraSalesOrderNo);
						//delete  extaData;
						extraDataToPurge.add(extaData);
					endif;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	extraDataToPurge.purge();
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Converting CM_EDITrackedItem.allExtraData to be stored into rawDataVoyageCode,rawDataCommodity,clientRef1,clientRef2,vehicle and clientRef complete", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting CM_EDITrackedItem.allExtraData to be stored into rawDataVoyageCode,rawDataCommodity,clientRef1,clientRef2,vehicle and clientRef complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete extraDataToPurge;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertHookCodeInvLog" id="a64b6ff3-1541-41c2-8563-bd227e04a3c4">
        <source>convertHookCodeInvLog(_controller : CnEcReleaseController);
// ### JIRA 33364 05NOV2024 NAVAB1

// upgrade hook code that uses app.invLog to have the new second parameter
vars
	iter01 : Iterator;
	hook : CM_HookCode;
	oArray : ObjectArray; 
	code : CM_HookCodeHistory;
	 a, b : String;
	pos, idx, idy, idz : Integer;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Hook Code InvLog", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Hook Code InvLog") ;	
	endif;
	
	create oArray transient;
	CM_HookCode.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	while iter01.next(hook) do : outerloop

		code := hook.allHookCodeHistory.first;
		
		if code &lt;&gt; null then
			if code.jadeCode.pos("LogINFO.String",1) &gt; 0 then
				continue; // already converted
			endif;
			
			if code.jadeCode.pos("app.invLog",1) &gt; 0 then
				
				a := code.jadeCode;			
				b := "";
				pos := 1;
				idx := 0;
				idy := 0;
				idz := 0;
				
				while true do : innerloop
					idx := a.pos("app.invLog",pos);
					if idx &gt; 0 then
						idy := idx;
						idx := a.pos(");",idy);
						
						idz := (idx-pos);
						b := b &amp;  a[pos:idz] &amp; ", LogINFO.String";
						
						pos := idx;
					else
						b := b &amp;   a[pos:end];
						break innerloop;
					endif;
				endwhile;
				
				beginTransaction;
				code.setPropertyValue("jadeCode",b);
				commitTransaction;

			endif;
		endif;
	
	endwhile;

	
	app.writeLog(method.qualifiedName &amp; " all Hook Code InvLog converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all Hook Code InvLog converted") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete oArray;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertIndextoLineNumber" id="e37cef8f-a61e-4847-a252-1b26c0bbbf0b">
        <updating/>
        <source>convertIndextoLineNumber(_controller: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level

*/

vars
	reserveSelection : CM_ReserveSelection;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Convert Index to LineNumber", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Convert Index to LineNumber") ;	
	endif;
	beginTransaction;
		foreach reserveSelection in CM_ReserveSelection.instances do
			if reserveSelection.lineNumber = null and reserveSelection.myReserveHeader &lt;&gt; null then
				reserveSelection.setLineNumber(reserveSelection.myReserveHeader.allReserveDetails.indexOf(reserveSelection));
			endif;
		endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all line numbers converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all line numberss converted") ;
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
