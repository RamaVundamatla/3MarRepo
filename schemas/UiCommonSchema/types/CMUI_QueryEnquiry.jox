    <JadeMethod name="translateForm" id="c4c23ae5-175c-4cd4-bc93-17a868513b52">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 January 2026 10:37:31.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007962, locale);
	btnCancel.translateCaption(Xlat_0005103, locale);
//	btnClearFilter.translateBubbleHelp(Xlat_0024518, locale);
//	btnClearFilter.translateCaption(Xlat_0024453, locale);
	btnDelete.translateCaption(Xlat_0005104, locale);
	btnEditItem.translateCaption(Xlat_0005105, locale);
	btnExportCSVQE.translateCaption(Xlat_0013465, locale);
	btnHideSearcher.translateCaption(Xlat_0005106, locale);
	btnPopupClose.translateBubbleHelp(Xlat_0005107, locale);
