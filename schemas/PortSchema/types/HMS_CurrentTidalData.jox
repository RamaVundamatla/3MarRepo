<Class name="HMS_CurrentTidalData" id="852c5988-f94d-4ed4-b42a-f284ab52c7ea">
    <superclass name="HMS_TidalData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hms"/>
    <PrimAttribute name="flow" id="8da30646-ba2a-4d3b-be57-c4abbadcbc70">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDataType" id="380e593f-13d1-426a-9a46-dd7dadbf54ae">
        <source>getDataType(): Integer;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return HMS_TidalDataType_Current;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="3dff594a-65d2-4b19-ac26-f82ea27dee62">
        <source>getValue(): Decimal;

/*
----------   ----------  --------------------------------------------------
Created:	18 October 2006 By cnwth2

Purpose:	

Date		Who		Reason
02 May 2008	cnwkpd1	PAR #16642 - signature change to return a Decimal, to correct issues with
					Real imprecision

*/

vars

begin
	return flow.Decimal.roundedTo(2);


end;


</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e7923844-af54-49be-b718-bbba18db5780">
        <updating/>
        <source>setForUpdate(_pxyTidalData: HMS_CurrentTidalData; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_pxyTidalData, _passport);
	
	self.flow := _pxyTidalData.flow;

end;


</source>
        <Parameter name="_pxyTidalData" type="HMS_CurrentTidalData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9ca07336-9d23-4c8a-bb73-0862ec39f408">
        <updating/>
        <source>setProxy(_ts : TimeStamp;
		_tidalModelDef : HMS_TidalModelDefinition;
		_flow : Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.ts 		:= _ts;
	self.myTidalModelDefinition := _tidalModelDef;
	self.flow 	:= _flow;
	
end;


</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_tidalModelDef" type="HMS_TidalModelDefinition"/>
        <Parameter name="_flow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="e5237dcd-d51d-4963-924b-8272d88433ac">
        <source>validateForUpdate(_passport: CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_passport);
	
	if self.flow = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tidal Data: Flow', null,  null);
		app.raiseCMException(Input_required_field_tidalData, null,  null); // cnwdb2	PAR 35364
	endif;
	
end;


</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
