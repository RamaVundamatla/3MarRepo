    <JadeMethod name="getAllCriteriaValues" id="213dbe85-d7a6-4433-a8f7-b7ec10b6dd43">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
begin
	app.myRoot.allVesselTypes.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="903c8fe9-ccc9-40a0-a110-bcd11818a982">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="b5d8dbd0-5f8d-4cae-91ea-6d5eaed87409">
        <source>getDisplay(dataObj : Object) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria
13 Feb 2025		navlw1 	JIRA-12608: MTN - Invoice Cargo Allocations Review (Mapping and Extract/Load)

*/
begin
	return dataObj.HMS_VesselType.code;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="7ca4a932-1e85-444c-a88f-221e37fd2782">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
vars
	vesselType : HMS_VesselType;
begin
	foreach vesselType in app.myRoot.allVesselTypes do
		objects[vesselType.getYAIdentifier] := vesselType;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
