    <JadeMethod name="setMutliDirectorComplete" id="4dd25cff-4e22-448a-8318-41131ad760e4">
        <source>setMutliDirectorComplete();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwrd1	Initial creation
//cnwrd1 par 25681 18.11.2010 multi machine director moves
*/

vars
	nextEntry : CM_RTQueueEntry;
begin

	
	//called from task.addTIToDirectorTask
	
	if self.allTasks.first &lt;&gt; null and self.allTasks.first.taskType = TASK_DIRECTOR and self.allTasks.first.status &lt;&gt; TASK_COMPLETE then
		self.allTasks.first.setStatusComplete();
	endif;
	nextEntry:=self.getNextRelatedEntry(); //epr par 35702 CCMS 2457 17/2/15
	if nextEntry &lt;&gt; null then
		nextEntry.setMutliDirectorComplete();
	endif;
epilog

end;</source>
