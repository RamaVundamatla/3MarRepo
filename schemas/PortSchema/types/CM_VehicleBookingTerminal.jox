    </JadeMethod>
    <JadeMethod name="getTimeslotsForCarrier" id="bd0143ca-2ab4-417c-8844-d2a9147716b1">
        <source>getTimeslotsForCarrier(	_futureOnly 	 : Boolean;	
						_carrier 		 : CM_Carrier;
						_driver 		 : CM_DriverDetails;
						_vehicle 		 : CM_Vehicle;
						_type 		     : CM_VehicleBookingTimeSlotType;	//28 Oct 2014	NDL	Par 35008
						_includeUnBooked : Boolean;
						_includeBooked   : Boolean;
						_startDate 		 : TimeStamp; //27.9.2021 NAVMJ1 #51070
						_endDate 	     : TimeStamp; //27.9.2021 NAVMJ1 #51070
						_maxStartSet 	 : Integer;
						_localColl 	     : CM_VehicleBookingByTs input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31506
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
26 Jun 2020 cnwma1  TFS 49570: Web Portal - VBS - Add / Search / Edit Vehicle Bookings UI changes
27 Sept 2021 navmj1 Bug 51070: PRP - Vehicle Booking Date / Time Bug
*/

vars
	now 			 : TimeStamp;
	startTs 		 : TimeStamp;
	iter 		     : Iterator;
	startObject 	 : Object;
	vbTs		     : CM_VehicleBookingTimeSlot;
	endIsValid 		 : Boolean;
	maxCheck 		 : Boolean;
	count 			 : Integer;
	startLessThanNow : Boolean;		//28 Oct 2014	NDL	Par 35008
	failedDAC		 : CM_DataAccessController;
begin

	now        := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	startTs    := now;
	endIsValid := _endDate.isValid;
	maxCheck   := ( _maxStartSet &gt; 0 );
	count 	   := 0;
	
	if _startDate.isValid then
		if not _futureOnly or _startDate &gt; now then
			startTs := _startDate; 				//27.9.2021 NAVMJ1 #51070
			// startTs.setDate(_startDate); 	//27.9.2021 NAVMJ1 #51070
			// startTs.setTime("00:00".Time);	//27.9.2021 NAVMJ1 #51070
		endif;
		//28 Oct 2014	NDL	Par 35008
		if not _futureOnly then
			startLessThanNow := startTs &lt; now;	
		endif;
	endif;
	
	if _includeUnBooked then
		startObject := self.allUnBookedBookingsByTS.getAtKeyGeq( startTs, null );
		if startObject &lt;&gt; null then
			iter := self.allUnBookedBookingsByTS.createIterator;
			iter.startAtObject( startObject );
			while iter.next( vbTs ) do
				//28 Oct 2014	NDL	Par 35008
				if startLessThanNow then
					if vbTs.bookingTSstart &lt; now then
						// unbooked and before now, don't show regardless...
						continue;
					endif;
				endif;
				//28 Oct 2014	NDL	Par 35008
				if _type &lt;&gt; null then
					if vbTs.myVBTimeSlotType &lt;&gt; _type then
						continue;
					endif;
				endif;
				if endIsValid then
					if vbTs.bookingTSstart &gt; _endDate then 			//27.9.2021 NAVMJ1 #51070
					// if vbTs.bookingTSstart.Date &gt; _endDate then	//27.9.2021 NAVMJ1 #51070
						break;
					endif;
				endif;
				
				if maxCheck then
					count := count + 1;
					//if count &gt;= _maxStartSet then       //26.06.2020 cnwma1 #49570
					if count &gt; _maxStartSet then          //26.06.2020 cnwma1 #49570
						break;
					endif;
				endif;
				_localColl.addNoDuplicates( vbTs,false );
			endwhile;
			delete iter;
		endif;
	endif;
	
	//26.06.2020 cnwma1 #49570
	if _includeBooked then
		startObject := self.allBookingsByTS.getAtKeyGeq( startTs, null );
		if startObject &lt;&gt; null then
			iter := self.allBookingsByTS.createIterator;
			iter.startAtObject( startObject );
			while iter.next( vbTs ) do
				if startLessThanNow then
					if vbTs.bookingTSstart &lt; now then
						// unbooked and before now, don't show regardless...
						continue;
					endif;
				endif;

				if _type &lt;&gt; null then
					if vbTs.myVBTimeSlotType &lt;&gt; _type then
						continue;
					endif;
				endif;
				if _carrier &lt;&gt; null then
					if vbTs.myCarrier &lt;&gt; _carrier then
						continue;
					endif;
				endif;
				
				if vbTs.myCarrier &lt;&gt; null then
					if not vbTs.myCarrier.canUserAccessSelf(null, failedDAC, app.myPassport) then
						continue;
					endif;
				endif;
				
				if _driver &lt;&gt; null then
					if vbTs.myDriver &lt;&gt; _driver then
						continue;
					endif;
				endif;
				
				if _vehicle &lt;&gt; null then
					if vbTs.myVehicle &lt;&gt; _vehicle then
						continue;
					endif;
				endif;
				
				if vbTs.getStatusString = CM_VehicleBookingTimeSlot.AvailableNotBooked then
					continue;
				endif;
				
				if endIsValid then
					if vbTs.bookingTSstart &gt; _endDate then 			//27.9.2021 NAVMJ1 #51070
					// if vbTs.bookingTSstart.Date &gt; _endDate then	//27.9.2021 NAVMJ1 #51070
						break;
					endif;
				endif;
				if maxCheck then
					count := count + 1;
					if count &gt; _maxStartSet then
						break;
					endif;
				endif;
				_localColl.addNoDuplicates( vbTs,false);
			endwhile;
			delete iter;
		endif;
	endif;
	
	if _includeBooked then
		return;
	endif;
	//26.06.2020 cnwma1 #49570
	
	count := 0;
	if _carrier &lt;&gt; null then
		if not _futureOnly then	//General enquiry
			startObject := self.allBookingsByCarrierTS.getAtKeyGeq( _carrier, startTs );
		else // enquiry for updating
			startObject := self.allUnusedBookingsByCarrierTS.getAtKeyGeq( _carrier, startTs );
		endif;
		if startObject &lt;&gt; null then
			if not _futureOnly then
				iter := self.allBookingsByCarrierTS.createIterator;
			else
				iter := self.allUnusedBookingsByCarrierTS.createIterator;
			endif;
			iter.startAtObject( startObject );
			while iter.next( vbTs ) do
				if vbTs.myCarrier &lt;&gt; _carrier then
					break;
				endif;
				if _driver &lt;&gt; null then
					if vbTs.myDriver &lt;&gt; null then
						if vbTs.myDriver &lt;&gt; _driver then
							continue;
						endif;
					endif;
				endif;
				if _vehicle &lt;&gt; null then
					if vbTs.myVehicle &lt;&gt; null then
						if vbTs.myVehicle &lt;&gt; _vehicle then
							continue;
						endif;
					endif;
				endif;
				//28 Oct 2014	NDL	Par 35008
				if _type &lt;&gt; null then
					if vbTs.myVBTimeSlotType &lt;&gt; _type then
						continue;
					endif;
				endif;
				if endIsValid then
					if vbTs.bookingTSstart &gt; _endDate then 			//27.9.2021 NAVMJ1 #51070
					// if vbTs.bookingTSstart.Date &gt; _endDate then 	//27.9.2021 NAVMJ1 #51070
						break;
					endif;
				endif;
				if maxCheck then
					count := count + 1;
					if count &gt;= _maxStartSet then
						break;
					endif;
				endif;
				//_localColl.add( vbTs );                    //26.06.2020 cnwma1 #49570
				_localColl.addNoDuplicates( vbTs,false );    //26.06.2020 cnwma1 #49570
			endwhile;
			delete iter;
		endif;
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_futureOnly" type="Boolean"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_type" type="CM_VehicleBookingTimeSlotType"/>
        <Parameter name="_includeUnBooked" type="Boolean"/>
        <Parameter name="_includeBooked" type="Boolean"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_maxStartSet" type="Integer"/>
        <Parameter name="_localColl" type="CM_VehicleBookingByTs" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnusedBookingsMadeFor" id="705e2ec8-2737-4cdf-b98e-d90c328ce9e8">
        <source>getUnusedBookingsMadeFor(	_allVehicleBookings : CM_VehicleBookingByTs input;
							_startTS : TimeStamp;
							_endTS : TimeStamp;
							_carrier : CM_Carrier;
							_driver : CM_DriverDetails;
							_vehicle : CM_Vehicle
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	iter : Iterator;
	startObject : CM_VehicleBookingTimeSlot;
	booking : CM_VehicleBookingTimeSlot;
	checkEndTS : Boolean;

begin

	if _allVehicleBookings = null then
		return;
	endif;
	
	if _carrier = null then
		return;
	endif;
	
	self.allUnusedBookingsByCarrierTS.createIterator;
	startObject := self.allUnusedBookingsByCarrierTS.getAtKeyGeq(_carrier,_startTS);
	
	if startObject = null or startObject.myCarrier &lt;&gt; _carrier then
		return;
	endif;
	
	if _endTS.date.isValid then
		checkEndTS := true;
	endif;
	
	while iter.next( booking ) do
		if _carrier &lt;&gt; booking.myCarrier then
			break;
		endif;
		if checkEndTS then
			if _endTS &lt; booking.bookingTSstart then
				break;
			endif;
		endif;
		if _driver &lt;&gt; null then
			if _driver &lt;&gt; booking.myDriver then
				continue;
			endif;
		endif;
		if _vehicle &lt;&gt; null then
			if _vehicle &lt;&gt; booking.myVehicle then
				continue;
			endif;
		endif;					
		_allVehicleBookings.add( booking );
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_allVehicleBookings" type="CM_VehicleBookingByTs" usage="input"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="hasDefaultDayTemplate" id="ed7315b0-fa94-4ecb-a85e-e238f5588239">
        <source>hasDefaultDayTemplate():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	if self.allVehicleBookingDayTemplates.getDefaultDayTemplate() &lt;&gt; null then
		return true;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasVbsSlotTemplate" id="88e51398-4788-4570-a24a-d7c7dbecd89f">
        <source>hasVbsSlotTemplate():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
20 Dec 2022	navak20 Task 55978: EUP - VBS MTN - [1] - VBS Slot Types - Review Changes
*/

vars
	vbsDayTemplate : CM_VehicleBookingDayTemplate;
	slotTemplate   : CM_VehicleBookingTimeTemplate;
	term           : CM_Terminal;
	termVbsSlotType: CM_VehicleBookingTimeSlotType;
	vbsDayTemplateColl : CM_VehicleBookingDayTempDict;	// 20.12.2022 navak20 TFS 55978
begin
	// 20.12.2022 navak20 TFS 55978
	vbsDayTemplateColl := self.allVehicleBookingDayTemplates;
	if vbsDayTemplateColl.isEmpty then
		return false;
	endif;
	// 20.12.2022 navak20 TFS 55978
	//foreach vbsDayTemplate in self.allVehicleBookingDayTemplates discreteLock do	// 20.12.2022 navak20 TFS 55978
	foreach vbsDayTemplate in vbsDayTemplateColl discreteLock do	// 20.12.2022 navak20 TFS 55978
		if vbsDayTemplate.allTimeTemplates.isNotEmpty then
			return true;
		endif;
	
	endforeach;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideTheVbsAssocForm" id="c8c446bb-3be5-478f-a149-a0d137263994">
        <source>hideTheVbsAssocForm( _vvr : CM_VehicleVisitRecord ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2015	cnwndl1	Initial creation	Par 36234

*/

vars

begin

	if self.myExclusionCriteria = null then
		//No exclusions implemented, don't hide it
		return false;
	else
		return self.myExclusionCriteria.hideTheVbsAssocForm( _vvr );
	endif;

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="5a3e6dd1-b4e0-4dee-b26a-4b66d37de453">
        <updating/>
        <source>setDetails(	_term : CM_Terminal; _vbRoot : CM_VehicleBookingRoot ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation

*/

vars

begin

	self.myTerminal := _term;
	self.myVehicleBookingRoot := _vbRoot;

epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_vbRoot" type="CM_VehicleBookingRoot"/>
    </JadeMethod>
</Class>
