        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doesBOLAlreadyExist" id="cbad49c5-9e35-4ba0-9d09-627c08ea8a01">
        <source>doesBOLAlreadyExist(_bolNum : String) : CM_BOLIn;
// ---------------------------------------------------------------------------
// Created:		April 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Jul 2008	cnwkpd1	PAR #17272 - Enable the existing BOL check for non-CentrePort clients
					to resolve CAR file load 1310 exceptions

*/

vars
	bolNumber : String;
	bolIn : CM_BOLIn;
	intFaceBOLIn : CMIF_BOLIn;
begin
/*
	PAR #17272 - This check is valid for all clients
	
	if app.myRoot.client &lt;&gt; Client_CentrePort then
		return null;
	endif;
*/
	
	bolNumber := _bolNum;
	if bolNumber = null then
		return null;
	endif;
	
	bolIn := self.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL, bolNumber, null);
	if bolIn = null then 
		bolIn := self.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralDocket, BOL_STATUS_NORMAL, bolNumber, null);
	else
		if bolIn.number &lt;&gt; bolNumber then 
			bolIn := self.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralDocket, BOL_STATUS_NORMAL, bolNumber, null);
		endif;
	endif;
	if bolIn &lt;&gt; null and //par 14463 cnwrs1 July 2007
	   bolIn.number &lt;&gt; bolNumber then
		bolIn := null;
	endif;
	return bolIn;
end;</source>
        <Parameter name="_bolNum" type="String"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="emptySlotRequests" id="edd1137f-a1b8-4831-81fd-bd9d2d1841cf">
        <source>emptySlotRequests();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	cnwas3	Initial creation ccms 1028

*/

vars
	voyAlloc : CM_YardAllocation;
	vc : CM_LocationsController;
begin
	
	foreach vc in self.allVoyageLocations  discreteLock do
		vc.CM_VoyageController.removeColourCoding();
	endforeach;
	
	foreach voyAlloc in self.allVoyageAllocations where not voyAlloc.CM_VoyageAllocation.allSlotRequests.isEmpty() do		
		voyAlloc.CM_VoyageAllocation.allSlotRequests.purge();		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="5040aeed-af3c-4902-a564-d4c11fb77db0">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// 25 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259
// 15 Nov 2017	jlgkpd1	Move YA objects cleanup to erase for Garbage Collection
// 08 Sep 2018	jlgmd1	Clean up an YA criteria for tranship
// 21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// 17 Jul 2025	navhl20 Bug MTN-35323: MSL - Cargo Enquiry search Fails for ?Anywhere? or ?Offsite? Locations
// ---------------------------------------------------------------------------
vars
	txnSet			: CM_TITransactionSet;
	txn				: CM_TITransaction;
	ti				: CM_TrackedItem;
	theDefaultVoyage: CM_Voyage;
	tmpTerminal		: CM_Terminal;
	jobSheet		: CM_JobSheet;
	iter 			: Iterator;
	cmqfHM 			: CMQF_HMSVoyages;
	cmqfTT			: CMQF_TerminalTIs;
	cmqfTL 			: CMQF_TrainLoadListTIs;
	yaType 			: CM_YATypeVoyage;
	hmsMove			: HMS_VoyageMovement;
	passport		: CM_Passport;
begin

	passport := app.myPassport;
	
	if not self.isTransient then
		create txnSet transient;
		self.allTITransactions.copy(txnSet);
		foreach txn in txnSet do
			txn.eraseForVoyage(_eraseLevel);
		endforeach;

		// PAR 20155
		txnSet.clear;
		self.allTITransactionsByDTType.copy(txnSet);
		foreach txn in txnSet do
			txn.setForDelete(null);
			txn.generateEditAuditForDelete(passport, self); // PAR 20155
		endforeach;
		
		
		tmpTerminal := self.myTerminal;
		if tmpTerminal &lt;&gt; null then
			theDefaultVoyage := tmpTerminal.getConfig(DefVoyage).CM_Voyage;
			if theDefaultVoyage &lt;&gt; null then	
				foreach ti in self.allOnsiteTIsByCargoTypeId do
					ti.setMyVoyage(theDefaultVoyage, passport);
				endforeach;
				
				foreach ti in self.allDeletedTIsByCargoTypeId do			//epr par 19255 27/3/09
					ti.setMyVoyage(theDefaultVoyage, passport);
				endforeach;	
				
				foreach ti in self.allOffsiteTIsByCargoTypeId do			//17.07.2025 navhl20 #35323
					ti.setMyVoyage(theDefaultVoyage, passport);
				endforeach;
			endif;
			
			if tmpTerminal.myEdiConfig &lt;&gt; null then
				tmpTerminal.myEdiConfig.removeVoyageFromProcessing(self);
			endif;
		endif;
		
		if self.myHMSVoyageData &lt;&gt; null	and (not _eraseLevel = FORCED_ERASE) then
			// Create HMS voyage deleted transaction
			// Harbour keeps a record of the deleted voyage vessel/DTs/user attributes only
			self.myHMSVoyageData.createTransaction(TRANS_TYPE_HMSVoyageDeleted, null, null, null, passport);
		endif;
	endif;

	if _eraseLevel = FORCED_ERASE then
	// remove all non on-site tracked items
	// remove any links to labour restrictions, dont delete restrictions with links to other voyages
	elseif self.archived then
		// remove on ship tracked Items
		foreach ti in self.allOnshipTIsByCargoTypeId do
			// TFS 7465 ti.erase(_eraseLevel);
			ti.erase(FORCED_ERASE); // TFS 7465
		endforeach;
		// Remove Job sheets.
		foreach jobSheet in self.allJobSheets do
			jobSheet.erase(_eraseLevel);
		endforeach;
	endif;
	// if non planned erase blck stack
	// erase xlations
	// remove bayplans
	// remove bays
	// remove colour codes
	// remove from operator
	// remove from vessel
	// remove both entries from terminal all voyages

	self.eraseBlockStack(_eraseLevel);
	self.eraseXlations(self.allXlations, _eraseLevel);
	
	if self.myLogVoyageStructure &lt;&gt; null then //par 17743 cnwrs1 Aug 2008
		self.myLogVoyageStructure.erase(_eraseLevel);
	endif;
	
	//cnwjo3 par 23105
	if app.getMyCurrentVoyage() = self then
		app.setMyCurrentVoyage(null);
	endif;
	
	if not self.isTransient then
		//15 Jul 2016	NDL	TFS 2329
		iter := CMQF_HMSVoyages.instances.createIterator;
		while iter.next(cmqfHM) do
			if cmqfHM.allVoyages.includes(self) then
				cmqfHM.allVoyages.remove(self);
			endif;
		endwhile; 
		delete iter;
		
		iter := CMQF_TerminalTIs.instances.createIterator;
		while iter.next(cmqfTT) do
			if cmqfTT.allVoyages.includes(self) then
				cmqfTT.allVoyages.remove(self);
			endif;
		endwhile; 
		delete iter;
		
		iter := CMQF_TrainLoadListTIs.instances.createIterator;
		while iter.next(cmqfTL) do
			if cmqfTL.allOnShipVoyages.includes(self) then
				cmqfTL.allOnShipVoyages.remove(self);
			endif;
		endwhile; 
		delete iter;
		
		yaType := CM_YATypeVoyage.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(self);
		endif;
		
		// Clean up any tranship criteria too
		yaType := CM_YATypeVoyageOutbound.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(self);
		endif;
		
		yaType := CM_YATypeVoyageInbound.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(self);
		endif;
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then
		if self.hasHmsMovement then
			foreach hmsMove in self.myHMSVoyageData.allVoyageMovements do
				hmsMove.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
									 BGP_OpsViewWSRequest.OPS_TYPE_HMSMOVE,
									 hmsMove);
				
			endforeach;
			
		endif;
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
									 BGP_OpsViewWSRequest.OPS_TYPE_VOYAGE,
									 self);
	endif;
	//21.09.2020 cnwma1 TFS #49906
	inheritMethod(_eraseLevel);

epilog
	delete iter;
	delete txnSet;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseAllEDIBayPlans" id="9e5a202a-f414-402f-8f27-1f246c491a1f">
        <updating/>
        <source>eraseAllEDIBayPlans() protected, updating;
/*
------------------------------------------------------------------------
Created:			25 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	ediBP : CM_VoyageEDIBayPlanController;
begin
	while self.allEDIBayPlans.isEmpty = false do
		ediBP := self.allEDIBayPlans.last;
		if ediBP = null then
			break;
		endif;
		self.eraseEDIBayPlan(ediBP);
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="eraseAllOnshipCargo" id="62e142d8-0c9e-48ab-9b6d-a424e8602e56">
        <updating/>
        <source>eraseAllOnshipCargo() updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 cnwrs1 ccms 1022
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	iter : Iterator;
	ti : CM_TrackedItem;
begin
	iter := self.allOnshipTIsByCargoTypeId.createIterator();
	while iter.next(ti) do
		ti.erase(NORMAL_ERASE);
	endwhile;

epilog
	delete iter;		// PAR #26678
	
end;</source>
    </JadeMethod>
    <JadeMethod name="eraseBlockStack" id="49ebd74d-d468-47a4-80a1-45fdd372596b">
        <updating/>
        <source>eraseBlockStack(_eraseLevel: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/12/2009	cnwmh5		PAR 21751 - set myShipBlockStack to null once erased
// 19 May 2010	cnwkpd1		PAR #20728 - remove isValidObject calls for performance
// ---------------------------------------------------------------------------

vars
	invalid 		: Boolean;

begin
	if self.myShipBlockStack &lt;&gt; null then		// and global.isValidObject(self.myShipBlockStack ) then // PAR 8387
		on Exception do app.handleDeletedObject(exception, self.myShipBlockStack, invalid);
		self.myShipBlockStack.erase(_eraseLevel); 
		self.myShipBlockStack := null;					// 17/12/2009 cnwmh5 #21751
	endif;
	
	//09 Sep 2011	NDL	Par 28173
	if self.myNotNotifiedStack &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, self.myNotNotifiedStack, invalid);
		self.myNotNotifiedStack.erase(_eraseLevel); 
		self.myNotNotifiedStack := null;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseEDIBayPlan" id="9e683f17-4d59-440f-93cd-711ff0c800d1">
        <source>eraseEDIBayPlan(_controllerToDel : CM_VoyageEDIBayPlanController io);
/*
------------------------------------------------------------------------
Created:			24 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin
	exclusiveLock(self);
	if _controllerToDel = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_controller', null, null);
	endif;
	if self.allEDIBayPlans.includes(_controllerToDel) = false then
		app.raiseCMException(Err_EDIMoveNotValid, null, null);		
	endif;
	exclusiveLock(_controllerToDel);
	
	//---------------------
	//Nuke it, there is a destructor in the cm_futureMoveEDI's that nukes the tis.
	//---------------------
	_controllerToDel.erase(NORMAL_ERASE);

end;</source>
        <Parameter name="_controllerToDel" type="CM_VoyageEDIBayPlanController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="excludeReport" id="891acebb-a23a-4622-a0e5-89a9449e2b92">
