    <JadeMethod name="btnRemBmrk_click" id="6f1dea5e-9393-4c41-8a4a-9473d8426dbe">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemBmrk_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2023	navra1	Initial creation

*/

vars
	folderSelected : UM_BookmarkFolder;
	methodNameSelected : UM_MethodName;
	methodName : UM_MethodName;
begin	
		
	if self.lstBookMarks.itemObject[lstBookMarks.listIndex].isKindOf(UM_MethodName) then
		methodNameSelected := self.lstBookMarks.itemObject[lstBookMarks.listIndex].UM_MethodName;
		beginTransaction;			
			folderSelected := methodNameSelected.bkMarkfolder;
			foreach methodName in folderSelected.methodNames do
				if methodName.methodNameString = methodNameSelected.methodNameString then
					folderSelected.methodNames.remove(methodName);
					delete methodName;
					break;
				endif;
			endforeach;						
		commitTransaction;	
	else
		app.msgBox(	"Select a bookmark to remove", "Select bookmark",MsgBox_OK_Only + MsgBox_Stop_Icon);		
		return;
	endif;
	
	reloadBookmarks();
epilog
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRemoveFolder_click" id="c0209cad-81cd-4564-8dee-ab7fb41c3897">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemoveFolder_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2023	navra1	Initial creation

*/

vars
	folderSelected : UM_BookmarkFolder;
	methodName : UM_MethodName;
begin	
	if lstBookMarks.listIndex &lt;&gt; -1 and self.lstBookMarks.itemObject[lstBookMarks.listIndex] &lt;&gt; null then
		if self.lstBookMarks.itemObject[lstBookMarks.listIndex].isKindOf(UM_BookmarkFolder) then
			folderSelected := self.lstBookMarks.itemObject[lstBookMarks.listIndex].UM_BookmarkFolder;
			beginTransaction;			
				folderSelected.methodNames.purge();
				foreach methodName in folderSelected.methodNames do
					delete methodName;
				endforeach;			
				delete folderSelected;
			commitTransaction;
		else
			app.msgBox(	"Select a bookmark folder to remove", "Select folder",MsgBox_OK_Only + MsgBox_Stop_Icon);		
			return;
		endif;
	else
		app.msgBox(	"Select a bookmark folder to remove", "Select folder",MsgBox_OK_Only + MsgBox_Stop_Icon);		
		return;
	endif;
	
	reloadBookmarks();
epilog
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
