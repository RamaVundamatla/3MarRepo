    <JadeMethod name="myContainer" id="b672c615-b2e0-4496-9fec-0e84ffec185e">
        <methodInvocation>mapping</methodInvocation>
        <source>myContainer(set : Boolean; _value : CM_Container io) mapping;
/* ---------------------------------------------------------------------------
Created:	23 November 2010	by cnwvu1

Purpose:	#26334
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	reeferProperties	: CM_ReeferProperties;
	
begin

	if set then
	
	else
		if self.myContainer &lt;&gt; null then
			_value := self.myContainer;
		else
			reeferProperties := self.myReeferProperties;
			if reeferProperties &lt;&gt; null then
				if reeferProperties.myParent.isKindOf(CM_Container) then
					_value := reeferProperties.myParent.CM_Container;
				endif;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Container" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="88f8bc3f-dd84-41a4-bfd6-c62f7057e6a6">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
// ---------------------------------------------------------------------------
// Created:     13 August 2003 by cnwrs2
//
// Purpose:     Used for data extract
// ---------------------------------------------------------------------------
// 11/12/2009	cnwdap1		CCMS MES 1007 myContainer reference now redundant, use myReeferProperties instead
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.myContainer &lt;&gt; null then
		_value := self.myContainer.myTerminal;
	elseif self.myReeferProperties &lt;&gt; null then
		_value := self.myReeferProperties.myParent.CM_TrackedItem.myTerminal;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
