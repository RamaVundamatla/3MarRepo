    <JadeMethod name="truncateString" id="950a6e39-427b-4734-b191-e435a58923cf">
        <source>truncateString(pString:String; pLength:Integer):String protected;
// --------------------------------------------------------------------------------
// Created:		25 March 2002 by cnwdad2
//
// Purpose:		Truncates a string to a specified length.
//
// Parameters:	pString - The string to truncate.
//				pLength - The desired length of the truncated sring.
//
// Returns:		The truncated string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	returnValue	:=	pString.trimBlanks;
	
	if pLength &lt; 1 or returnValue.length &lt;= pLength then
		return returnValue;
	endif;
	
	return returnValue[1:pLength];
end;</source>
        <access>protected</access>
        <Parameter name="pString" type="String"/>
        <Parameter name="pLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
