    <JadeMethod name="iTwinLiftShipCreateReceiveTxn" id="88461c03-3ffc-4ccd-934d-ba25808899d2">
        <source>iTwinLiftShipCreateReceiveTxn();

/*

Purpose:		Twin Lift from Ship, make sure creates Received - Ship txns.	

Date			Who		Reason
26 October 2011	cnwmh5	Initial creation

*/

constants
	
	BlockStackId			: String = "UTMHBS1";
	YardAllocationId		: String = "UTMHBS1All";
	CraneTransferAreaId		: String = "UTC1TX";
	VesselId				: String = "UTMHHH2";
	VoyageId				: String = "UTMHHH2";
	ContainerTwin1Id		: String = "UTMDHTW0001";
	ContainerTwin2Id		: String = "UTMDHTW0002";
	Container3Id			: String = "UTMDH000001";	
	CraneId					: String = "UTC1";
	QueueId					: String = "QUEID1";
	ForkliftId				: String = "UTF2";
	
vars

	blockStack				: CM_BlockStack;
	cta						: CM_CraneTransferArea;
	operator				: CM_Operator;
	dischargePort			: CM_Port;
	vessel					: CM_Vessel;
	voyage					: CM_Voyage;
	cargo1,
	cargo2, 
	cargo3,
	cargo4					: CM_TrackedItem;
	theSlot 				: CM_LocationsController;
	crane					: CM_Machine;
	voyageDischJob			: CM_VoyageJob;
	tmpLoadCC				: CMIF_LoadColorCode;
	forkLift				: CM_Machine;
	craneQueue				: CM_RadioTelemetryQueue;
	receiveTxn				: CM_Receive;

	locations				: CM_LCArray;
	slotsFrom				: CM_SlotControllerArray;
	
	strs 					: StringArray;
	tas						: StringArray;
	
	idx 					: Integer;
	
begin

	// get general values
	operator := app.myRoot.allOperators["UTOP"];
	dischargePort := app.myRoot.allPorts["NZPOE"];
	
	// create the block stack
	self.deleteTerminalArea(BlockStackId);
	blockStack := addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(blockStack);
	
	// create the crane transfer area
	self.deleteMachine(CraneId);
	self.opts.purge();
	self.opts.addAssoc("SetCraneLaneCages", true);
	self.deleteTerminalArea(CraneTransferAreaId);
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	// create yard allocation;
	self.deleteYA(YardAllocationId);
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	self.addYA1(YardAllocationId, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	// create Voyage
	deleteVoyage(VoyageId);
	deleteVessel(VesselId);
	vessel := addVesselCellular(VesselId, operator);
	voyage := addVoyageWithContainerStructur(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	// add the container(s)
	create strs transient;
	deleteContainer(ContainerTwin1Id);
	strs.clear;
	strs.add("010682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo1 := self.addContainerAtLocnDisch(ContainerTwin1Id, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
	deleteContainer(ContainerTwin2Id);	
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo2 := self.addContainerAtLocnDisch(ContainerTwin2Id, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
	deleteContainer(Container3Id);
	strs.clear;
	strs.add("010684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addContainerAtLocnDisch(Container3Id, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
	strs.clear;
	
	// discharge colour code
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
				
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 1, 1, 2, slotsFrom);
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
	// queue the ti's
	self.autoplanDischargeItems(voyage, blockStack, crane.CM_Crane);
	self.moveAllCargoOnVoyage(voyage, QUEUE_MODE);
	
	// get the crane queue
	craneQueue := crane.CM_Crane.allCraneQueues.first;
	
	// setup the twin lift forklift
	self.opts.purge();
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	tas.add(blockStack.id);
	self.deleteMachine(ForkliftId);
	forkLift := self.addForkLift(ForkliftId, 95, tas, null);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		forkLift.addToQueue(craneQueue, true, 0);
		commitTransaction;
	endif;
	
	app.isRTApp:=true;  
	self.machineLogon(forkLift);
	
	// action crane pickup
	self.machineCraneActionPickup(forkLift, cargo1, cargo2);
	self.assertNoTrxErrorsOrWarnings();
	
	// check to see if the Received - Ship txn created
	//receiveTxn := cargo1.getTransReceiveFirst();
	//self.assertNotNullMsg(receiveTxn, "Tracked item (" &amp; cargo1.id &amp; ") doesn't have a Received - Ship transaction");
	//receiveTxn := cargo2.getTransReceiveFirst();
	//self.assertNotNullMsg(receiveTxn, "Tracked item (" &amp; cargo2.id &amp; ") doesn't have a Received - Ship transaction");
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_REC_SHIP);		// 16/08/2012 cnwmh5
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_WHARFAGE);
	self.checkTIForTxnOfType(cargo2, TRANS_TYPE_REC_SHIP);		// 16/08/2012 cnwmh5
	self.checkTIForTxnOfType(cargo2, TRANS_TYPE_WHARFAGE);
	
	// pickup and setdown the twinlift
	self.opts.purge();
	self.opts.addAssoc("UseEntryFirstTask", true);
	self.machineAcceptSpecifiedTwinTask(forkLift, 
		cargo1.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first,
		cargo2.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first);
	self.machinePickup(forkLift);
	self.machineSetdownTwinTask(forkLift, 
		cargo1.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first.allTasks.last,
		cargo2.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first.allTasks.last, blockStack.id);
	
	// non twin lift check
	self.opts.purge();
	self.opts.addAssoc("UseEntryFirstTask", true);
	cargo4 := null;
	self.machineCraneActionPickup(forkLift, cargo3, cargo4);
	//receiveTxn := cargo3.getTransReceiveFirst();
	//self.assertNotNullMsg(receiveTxn, "Tracked item (" &amp; cargo3.id &amp; ") doesn't have a Received - Ship transaction");
	
	self.machineAcceptSpecifiedTask(forkLift, cargo3.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first);
	self.machinePickup(forkLift);
	self.machineSetdownTask(forkLift, 
		cargo3.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first.allTasks.last, blockStack.id);
	
	self.checkTIForTxnOfType(cargo3, TRANS_TYPE_REC_SHIP);		// 16/08/2012 cnwmh5
	self.checkTIForTxnOfType(cargo3, TRANS_TYPE_WHARFAGE);
		
epilog

	self.deleteYA(YardAllocationId);
	
	self.machineLogOff(forkLift);
	app.isRTApp:=false;  
	
	delete strs;
	delete locations;
	delete slotsFrom;
	delete tmpLoadCC;
	delete tas;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;MDHFAILSTEST&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tChangeRTEntryMoveRule" id="c87ae7f5-cea2-49d1-8dec-2cf51172511b">
        <source>tChangeRTEntryMoveRule();

/*

Purpose:		trxChangeRTEntryMoveRule, trxUpdateQueueEntryStatus

Date			Who		Reason
24/06/2015		cnwmh5	Initial creation

*/

constants

	StraddleStackId				: String = "UTSSM8";
	BlockStackId				: String = "UTBSM8";

vars

	bs							: CM_BlockStack;
	ss							: CM_StraddleStack;
	ti							: CM_TrackedItem;
	newMoveMethodRule 			: CM_RTMoveMethodRule;
	rtqMultiRule				: CM_RTQueueMultiRule;
	
	addRulesMethArray			: IntegerArray;
	tiArray						: CM_TIArray;
	
	status						: Integer;

begin

	create tiArray transient;

	bs := self.addBlockStack(BlockStackId, 100, null);
	self.assertNotNull(bs);
	
	ss := self.addStraddleStack(StraddleStackId, 5, 6, 4);
	self.assertNotNull(ss);
	self.opts.purge();
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(ss, null, 10, tiArray);
	self.assertFalse(tiArray.isEmpty);
	
	create addRulesMethArray transient;
	addRulesMethArray.add(RTMoveMethod_19);
	
	self.opts.purge();
	self.opts.addAssoc("AdditionalRulesMethod", addRulesMethArray);
	self.opts.addAssoc("FullMoveQueueing", true);
	self.addMachineRule(ss, bs, RTMoveMethod_16);
	
	ti := tiArray[1].CM_TrackedItem;
	self.assertNotNull(ti);
	
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.move(ti, bs);
	self.assertEqual(ti.getQueueEntry().getRTMoveMethod().type, RTMoveMethod_16);
	
	rtqMultiRule := self.getTerminal().allRTQueueMultiRuleTAMasters[ss, bs];
	self.assertNotNull(rtqMultiRule);
	newMoveMethodRule := rtqMultiRule.allOtherRTMoveMethodRules.first;
	self.assertNotNull(newMoveMethodRule);
	
	app.myTrxUA.trxChangeRTEntryMoveRule(ti.getQueueEntry(), newMoveMethodRule, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.getQueueEntry().getRTMoveMethod().type, RTMoveMethod_19);
	
	status := QSTATUS_HELD;
	app.myTrxUA.trxUpdateQueueEntryStatus(ti.getQueueEntry(), status, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.getQueueEntry().status, ENTRY_SYSTEM_HELD);
	
epilog

	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tChangeStatusToUnactioned" id="f4317260-8eab-4a57-8213-e9235419f6d4">
        <source>tChangeStatusToUnactioned();
/*

Purpose:			

Date		Who		Reason
19 January 2016	cnwmk3	Initial creation

*/
constants
	ContainerName1	= 'RJD0109911';
	BlockStackName	= 'BLOCKSTACK';
	PackAreaName	= 'PACKAREA';
	QueueName		= "UT_QUEUE";
vars
	tempStr					: String;
	container1				:CM_Container;
	operator 				: CM_Operator;
	passport 				: CM_Passport;
	bs 						: CM_BlockStack;
	pack 					:CM_Depot;
	queue 					:CM_SubQueue;
	tas 					:StringArray;
	locations 				: CM_LCArray;
	rtqt1					: CM_RTQueueTask;
	theRealJob				: CM_YardInternalJob;
	theYardWorkJobParams	: CMIF_YardWorkJobParams;
	status					: Integer;
begin
//	=========== stuff we need to get started =============================================================================	
	passport := app.myPassport;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).display);
	

//	=========== DELETES =============================================================================	

	// delete the cargo
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	// delete queue
	self.deleteQueue (QueueName);
	queue := self.getQueue (QueueName).CM_SubQueue;
	self.assertIsDeleted(queue);
	// delete block stack
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	// delete pack area
	self.deleteTerminalArea(PackAreaName);
	pack := self.getTerminalArea(PackAreaName).CM_Depot;
	self.assertIsDeleted(pack);
		
	
//	=========== CREATES =============================================================================	
	create locations transient;
	// create block stack
	bs := self.addBlockStack(BlockStackName, 0, null);
	self.assertNotNull (bs);
	// create pack area
	pack := self.addPackArea(PackAreaName, 0, null);
	self.assertNotNull (pack);
	// create queue
	queue := self.addQueueToTA (QueueName, BlockStackName);
	assertNotNull (queue);
	
	create tas transient;
	tas.add(bs.id); tas.add(pack.id);

	container1 	 := self.addContainerOpts(ContainerName1, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString)).CM_Container;
	tempStr		:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	self.move(container1, bs);
	
	locations.add(bs.myLocationsController);	
	locations.add(pack.myLocationsController);
	
	// create internal move to pack area

	create theYardWorkJobParams transient;
	theYardWorkJobParams.defaultQueueToHeld := true;
	theYardWorkJobParams.addToQueue := true;
	theYardWorkJobParams.mySourceTA := bs;	
	theYardWorkJobParams.priority := 3;	
	theYardWorkJobParams.myTargetTA := pack;
	theYardWorkJobParams.myTargetLocation := pack.getLocationsController;
	theYardWorkJobParams.numToMove := null;
	theYardWorkJobParams.overridePlacementRestrictions := false;
	theYardWorkJobParams.typeToCreate := Controller_Strip;
	theYardWorkJobParams.jobId := "MOVE_JOB";
	theYardWorkJobParams.myQueueToAddTo := queue;
	app.myTrxCA.trxCreateYardInternalJob(theYardWorkJobParams,theRealJob,self.getTerminal(), app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(queue.allEntries[1].getFirstUncompletedTask.statusString, "Manually Held");
	
	status := Unactioned;
	app.myTrxUA.trxUpdateQueueEntryStatus(queue.allEntries[1], status, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(queue.allEntries[1].getFirstUncompletedTask.status, ENTRY_UNACTIONED);
epilog
	opts.purge();
	delete tas;
	delete locations;
	delete theYardWorkJobParams;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tDirectorReserveCargo" id="0a743909-d565-4320-833a-f16fafcc3b0f">
        <updating/>
        <source>tDirectorReserveCargo() updating;
// cnwer1
// cnwdw1	
// CCMS 2098 Director Task Cargo Assignment for Gridded Stacks
constants
	LabourRestrict		: String = "HOLD";
vars
	forkStack: CM_ForkLiftStack;
	blockStack: CM_BlockStack;
	ti1, ti2, ti3 : CM_TrackedItem;
	operator : CM_Operator;
	moveRequest1, moveRequest2, moveRequest3, moveRequest4: CM_YardDeliveryRequest;
	forkLift: CM_Machine;
	tas: StringArray;
	queue: CM_RadioTelemetryQueue;
	queueEntry: CM_RTQueueEntry;
	configUBP,
	configDNCBR	: Boolean;
	configMTStrategy: Integer;
	sourceBays: CM_GridObjectArray;
	ta : CM_TerminalArea;
	lob : CM_LabourRestriction;
	
begin
	self.setTerminalConfig(UseBestPickDirector, true);
	self.setTerminalConfig(DoNotCreateBulkRelease, true);
	configMTStrategy := self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyTerminal).Integer;

	forkStack := self.addForkLiftStack("UTFKS", 4,5,2);
	queue := self.addQueueToTA("UTFRKSQ", forkStack);
	blockStack := self.addBlockStack("UTBS1", 100, null);
	operator :=  self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_STORAGE);
	ti1 := self.addContainerOpts("UTTEST0001", "2200", "MT", operator);
	
	move(ti1, self.getGridLocation(forkStack, 1, 1));
	ti2 := self.addContainerOpts("UTTEST0002", "2200", "MT", operator);		
	
	move(ti2, self.getGridLocation(forkStack,1, 1));
	ti3 := self.addContainerOpts("UTTEST0003", "2200", "MT", operator);	
	
	move(ti3, self.getGridLocation(forkStack,2, 1));
	beginTransaction;
		ti3.setPropertyValue(CM_TrackedItem::mySubTerminal.name,null);
	commitTransaction;
	create sourceBays transient;
	moveRequest1 := self.moveDirector("UTYJ11", 1, operator.code, "2200", forkStack, sourceBays, blockStack); 
		assertEqual(moveRequest1.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.getSourceLocationId, "UTFKS(0002)");
	
	moveRequest2 := self.moveDirector("UTYJ12", 1, operator.code, "2200", forkStack, sourceBays, blockStack); 
		assertEqual(moveRequest2.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.getSourceLocationId, "UTFKS(0001)");
	
	moveRequest3 := self.moveDirector("UTYJ13", 1, operator.code, "2200", forkStack, sourceBays, blockStack); 
		assertEqual(moveRequest3.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.getSourceLocationId, "UTFKS(0001)");
	
	self.expectTrxError(Request_failed_auto_plan);  // Should fail as only 3 boxes to allocate
	moveRequest4 := self.moveDirector("UTYJ14", 1, operator.code, "2200", forkStack, sourceBays, blockStack); 
	self.clearExpectedTrxErrors();

	create tas transient;
	tas.add("UTFKS");
	tas.add("UTBS1");

	self.addMachineRule (forkStack, blockStack, RTMoveMethod_24);  // Forklift
	forkLift := self.addForkLift("UTF1", 91, tas, "UTFRKSQ");
	self.machineAssignToQueue(forkLift, queue);
	self.machineLogon(forkLift);

	queueEntry := moveRequest1.allWorkListEntries.first.allRTQueueEntries.first;
		assertEqual(queueEntry.allTasks.size, 1);
	self.machineAcceptSpecifiedTask(forkLift, queueEntry);		// director task completed and ti pickup/setdowneated
		assertEqual(queueEntry.allTasks.size, 3);
	self.machinePickup(forkLift);
	self.machineSetdownTask(forkLift, queueEntry.allTasks.last , "UTBS1");
	
	queueEntry := moveRequest2.allWorkListEntries.first.allRTQueueEntries.first;
		assertEqual(queueEntry.allTasks.size, 1);
	self.machineAcceptSpecifiedTask(forkLift, queueEntry);		// director task completed and ti pickup/setdowneated
		assertEqual(queueEntry.allTasks.size, 3);
	self.machineCancelTask(forkLift);							// should only have director task left
		assertEqual(queueEntry.allTasks.size, 1);
		assertEqual(queueEntry.allTasks.first.status, TASK_ACCEPTED);
	self.machineCancelTask(forkLift);							// this should set the task unactioned
		assertEqual(forkLift.allCurrentQueueTasks.size, 0);	
		assertEqual(queueEntry.allTasks.first.status, TASK_UNACTIONED);
		
	//16 Mar 2021	NDL	TFS 50845
	queueEntry := moveRequest2.allWorkListEntries.first.allRTQueueEntries.first;
	self.machineAcceptSpecifiedTask(forkLift, queueEntry);
	ta := moveRequest2.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.targetLocation.myTerminalArea;
	lob := self.addLabourRestriction( LabourRestrict, ta, true );
	self.machineCancelTask(forkLift);
	self.machineCancelTask(forkLift);
	assertEqual(queueEntry.allTasks.first.status, TASK_SYS_HELD);
	self.deleteLabourRestriction(lob);
	assertEqual(queueEntry.allTasks.first.status, TASK_UNACTIONED);
	
	self.deleteTask(queueEntry);
		assertEqual(moveRequest2.allWorkListEntries.first.allRTQueueEntries.size, 0);
	self.machineLogOff(forkLift);
	
epilog
	delete tas;
	delete sourceBays;
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, configMTStrategy);
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Emmet_Fails&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
