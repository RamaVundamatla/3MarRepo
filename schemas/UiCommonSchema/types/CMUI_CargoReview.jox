    <JadeMethod name="doHandle1066AfterCancel" id="2abaad85-792c-4596-92fe-bacfc32d77a5">
        <source>doHandle1066AfterCancel(_exc : Exception) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwndl1	Initial creation	Par 29508

*/

vars

	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = 1066 then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

epilog

	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doInitQueryFolder" id="cf243b6a-85af-4a14-a704-19de2bc53a5d">
        <source>doInitQueryFolder();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars
	qryMenuRoot		: CM_MenuRootQuery;
	menuEntity		: CM_MenuEntity;
	menuUserItem	: CM_MenuUserItem;
	menuUserQry		: CM_MenuUserQuery;
	menuUserHdr		: CM_MenuUserHdr;
	menuUserSubHdr	: CM_MenuUserHdr;
	menuUserSubHdrs	: CM_MenuUserHdrSet;
begin
	
	qryMenuRoot := app.myRoot.myQueryMenuRoot;
	
	if qryMenuRoot = null then
		return;
	endif;
	
	create menuUserSubHdrs transient;
	
	self.cmbFolder.clear();
	self.cmbQuery.clear();
	
	foreach menuEntity in qryMenuRoot.allChildren discreteLock where menuEntity.isMenuUserItem() do 
		menuUserItem := menuEntity.CM_MenuUserItem;
		// Header/Folder
		if menuUserItem.isHeader() then
			menuUserHdr := menuUserItem.CM_MenuUserHdr;
			self.cmbFolder.addItemObject(menuUserHdr.heading, menuUserHdr);
			menuUserSubHdrs.clear();
			menuUserHdr.getAllChildHeaders(menuUserSubHdrs);
			// Sub headers
			foreach menuUserSubHdr in menuUserSubHdrs do 
				self.cmbFolder.addItemObject(menuUserSubHdr.heading, menuUserSubHdr);
			endforeach;
		// Query
		elseif menuUserItem.isQuery() then
			menuUserQry := menuUserItem.CM_MenuUserQuery;
			// We only want Tracked Item query atm
			if menuUserQry.queryMode &lt;&gt; CM_QueryDefinition.TrackedItem_Query_Mode then
				continue;
			endif;
			self.cmbQuery.addItemObject(menuUserQry.heading, menuUserQry);
		endif;
	endforeach;
	
	
epilog
	delete menuUserSubHdrs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateQueryCmb" id="fd1f8ff8-58b8-49ac-8ce4-8722cc0d63ab">
        <source>doPopulateQueryCmb(_menuUserHeader : CM_MenuUserHdr);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars
	menuEntity		: CM_MenuEntity;
	menuUserItem	: CM_MenuUserItem;
	menuUserQry		: CM_MenuUserQuery;
begin
	self.cmbQuery.clear();
	
	if _menuUserHeader = null then
		return;
	endif;
	
	foreach menuEntity in _menuUserHeader.allChildren discreteLock where menuEntity.isMenuUserItem() do
		menuUserItem := menuEntity.CM_MenuUserItem;
		
		if not menuUserItem.isQuery() then
			continue;
		endif;
		
		menuUserQry := menuUserItem.CM_MenuUserQuery;
		// Only want TI
		if menuUserQry.queryMode &lt;&gt; CM_QueryDefinition.TrackedItem_Query_Mode then
			continue;
		endif;
		self.cmbQuery.addItemObject(menuUserQry.heading, menuUserQry);
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_menuUserHeader" type="CM_MenuUserHdr"/>
    </JadeMethod>
    <JadeMethod name="doRemoveQueryLine" id="4a348ea3-6e2c-456a-b998-135ca42a1897">
        <source>doRemoveQueryLine();
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 June 2025	navrv30	MTN 34823 MTN | Cargo Review Auto Update Selector
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	crit	: CM_SelectorCriteriaLine;	
	
begin

	idx := self.tblCriteria.row;
	if idx = 0 or not self.tblCriteria.accessRow(idx).selected then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, app.getErrorString(CMUI_Selector_Line), app.getErrorString(Delete)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	crit := self.tblCriteria.accessRow(idx).itemObject.CM_SelectorCriteriaLine;
	if not self.validateCriteriaLineRemoval(crit) then
		return;
	endif;

	delete crit;
	self.tblCriteria.removeItem(idx);
	self.tblCriteria.accessedRow:=null;
	self.setCriteriaLabel(); //02/10/2023	navkc1	CR 60423 Task 60763	
	
	// 23 June 2025	navrv30	MTN 34823
	self.cmbAttr.listIndex := -1;
	self.cmbOperator.listIndex := -1;
	self.cmbArgument.listIndex := -1;
	self.txtArgumentFrom.text := "";
	self.txtArgumentTo.text := "";
	self.txtFromDate.text := "";
	self.txtToDate.text := "";
	self.txtFromTime.text := "";
	self.txtToTime.text	:= "";
 end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="41d63dfc-f4a4-4045-a626-5d7e03dd31db">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60764: UI - Cargo Review Cust Doc Summary

*/

vars
	
begin
	self.frmJadeDock.top := self.frmToolbar.height + 1;
	self.frmJadeDock.parentBottomOffset := 21;
	
	if self.frmToolbar.showCaptions then
		self.setEntRowsLabel(self.lblAdditional,self.allAdditionalRows,5);
		self.setEntRowsLabel(self.lblGroupedBy,self.allGroupingRows,5);
	else
		self.setEntRowsLabel(self.lblAdditional,self.allAdditionalRows,2);
		self.setEntRowsLabel(self.lblGroupedBy,self.allGroupingRows,3);
	endif;

	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="cb103a2f-6272-4a1c-868d-7dcd651a4a69">
        <updating/>
        <source>doSearch() updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// 26/10/2023	navkc1	CR 60974 Task 60976: UI - Cargo Review Selector Columns Used
// 23 June 2025	navrv30	MTN 34823 MTN | Cargo Review Auto Update Selector
// ----------   ----------  --------------------------------------------------
vars
	cmifMonitor				: CMIF_Monitor;
	returnValue 			: Integer;
	tbl						: CM_DataTable;
	startTime : TimeStamp;	//14 Oct 2019	NDL	TFS 47010
	endTime : TimeStamp;	//14 Oct 2019	NDL	TFS 47010
	timeInterval : TimeStampInterval;	//14 Oct 2019	NDL	TFS 47010
	query	: CM_MenuUserQuery;
	pos		: Integer;
	xml,
	xmlValue: String;
	mode : Integer;
begin

	startTime := app.actualTimeAppServer;	//14 Oct 2019	NDL	TFS 47010

	tbl := self.tblCriteria;
	//self.tblCargo.allSelectedObjects.clear();
	mode := self.isCriteriaUpdate();
	
	// 23 June 2025	navrv30	MTN 34823
	if mode = CMUI_CargoReview.Mode_Update then		
		updateCriteriaLine();
		self.doWindowEvents(0);	
	elseif mode = CMUI_CargoReview.Mode_Add then
		if (not self.addCriteriaLine()) then 
				return;
		endif;
		self.doWindowEvents(0);
	endif;

	self.queryLineChanged := false;	
	on Exception do self.doHandle1066AfterCancel(exception); //18 Jun 2012	NDL	Par 29508 - After a Cancel during a search
																// some objects are registered for notes and some are not...
	
	/*if self.myCargoGroupQuery.myEnqController &lt;&gt; null then
		foreach obj in self.myCargoGroupQuery.myEnqController.allObjects discreteLock do
			self.endNotification(obj.Object, Object_Delete_Event);
		endforeach;
	endif;*/
	on Exception do null;

	self.orderCriteriaLines(); // clicking up and down just changes how they are displayed in the table -need to change them in the crit line holder
	self.myCargoGroupQuery.reset(self.myTerminal,self.myCriteriaLineHolder,self.allGroupingRows,self.allAdditionalRows);
	
	
	delete app.myPassport.myCMIFMonitor;
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	self.frmModalDialog.zOrder(1);	
	self.modalDialogShow(null, app.getErrorString(Cancel),null ,app.getErrorString(CMUI_Return_Data) , app.getErrorString(CMUI_Retreiving_Data), cmifMonitor.message);

			

	returnValue := self.myCargoGroupQuery.doSearch();
	
	if returnValue = CMIF_Monitor.MonitorReturnValue_Cancel then
		return;		
	endif;
	
	//26/10/2023	navkc1	CR 60974 Task 60976
	query := self.cmbQuery.listObject.CM_MenuUserQuery;
	if query &lt;&gt; null then
		xml := app.getMyUser().getStateData(ConfigGrp_ExtraData, query.heading).String;
		if xml &lt;&gt; null then
			pos := 1;
			xmlValue := xml.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_Table &amp; self.tblCargo.name, pos);
			if xmlValue &lt;&gt; null then
				self.tblCargo.setColumnsFromXMLStr(xmlValue);
			endif;
		endif;
	endif;
  	
	self.displayCargoGroupResults();
	
		
	endTime := app.actualTimeAppServer;	//14 Oct 2019	NDL	TFS 47010
	timeInterval := endTime - startTime;
	//self.doPerformanceCheck( timeInterval );
	
epilog
	endLoad;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectQuery" id="a174be5d-3c9f-41c7-bc7c-1daa9a6ecf4b">
        <source>doSelectQuery(_query : CM_MenuUserQuery);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes
26/10/2023	navkc1	CR 60974 Task 60976: UI - Cargo Review Selector Columns Used
*/

vars
	transCrit,
	persistentCrit,
	tmpCrit					: CM_SelectorCriteriaLine;
	tmpProp					: CM_QueryProperty;
	tmpOperator				: CM_QueryOperator;
	persistentCritHolder	: CM_QueryCriteriaLineHolder;
	pos,
	idx 					: Integer;
	tbl 					: CM_DataTable;
	entName,
	xmlValue,
	xml						: String;
	entRowName 				: EntTableRow;
begin
	tbl := self.tblCriteria;
	self.myCriteriaLineHolder.allCriteriaLines.purge();
	tbl.columns := 1;
	tbl.rows := 0;
	
	if _query = null then
		return;
	endif;
	
	foreach persistentCritHolder in _query.allCriteriaLineHolders do
		self.myCriteriaLineHolder.allCriteriaLines.purge();
		foreach persistentCrit in persistentCritHolder.allCriteriaLines do
			tmpCrit := persistentCrit.cloneSelf(true);
			tmpProp := tmpCrit.myQueryProperty.cloneSelf(true);
			tmpCrit.myQueryProperty.cloneReferences(tmpProp);
			tmpOperator := tmpCrit.myQueryOperator.cloneSelf(true);
			tmpCrit.myQueryOperator.cloneReferences(tmpOperator);
			
			create transCrit transient;
			transCrit.set(tmpProp, tmpOperator, tmpCrit.isUnavailableAtRunTime);
			transCrit.setMyCriteriaLineHolder(self.myCriteriaLineHolder);	
			idx := tbl.addItemObject(transCrit,transCrit.getDescriptionString);
			tbl.accessRow(idx).itemObject := transCrit;
			tbl.accessRow(idx).backColor := tmpCrit.getPerformanceColour;
		endforeach;
	endforeach;
	
	//26/10/2023	navkc1	CR 60974 Task 60976
	xml := app.getMyUser().getStateData(ConfigGrp_ExtraData, _query.heading).String;
	
	if xml = null then
		return;
	endif;
	
	xmlValue := xml.cnEcGetTagValueOfName(self.XMLTag_Grouping);
	if xmlValue &lt;&gt; null then
		pos := 1;
		self.allGroupingRows.clear();
		while (pos &gt; 0) do
			entName := xmlValue.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_Column, pos);
			entRowName:=self.allGroupingRowsAvailable.getEntRowNamed(entName);
			if entRowName &lt;&gt; null then
				self.allGroupingRows.addExclusive(entRowName);
			endif;
		endwhile;
		if self.frmToolbar.showCaptions then
			self.setEntRowsLabel(self.lblGroupedBy,self.allGroupingRows,5);
		else
			self.setEntRowsLabel(self.lblGroupedBy,self.allGroupingRows,3);
		endif;
	endif;
	
	xmlValue:= xml.cnEcGetTagValueOfName(XMLTag_Additional);
	
	if xmlValue &lt;&gt; null then
		pos := 1;
		self.allAdditionalRows.clear();
		while (pos &gt; 0) do
			entName := xmlValue.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_Column, pos);
			entRowName:=self.allAdditionalRowsAvailable.getEntRowNamed(entName);
			if entRowName &lt;&gt; null then
				self.allAdditionalRows.addExclusive(entRowName);
			endif;
		endwhile;
		 if self.frmToolbar.showCaptions then
			self.setEntRowsLabel(self.lblAdditional,self.allAdditionalRows,5);
		else
			self.setEntRowsLabel(self.lblAdditional,self.allAdditionalRows,2);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_query" type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="doSetQueryCriteriaFromDialog" id="14ea3eb6-f9e6-4f9d-bff9-36bbd4a86eb7">
