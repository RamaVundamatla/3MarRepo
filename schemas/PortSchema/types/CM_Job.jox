    <JadeMethod name="initializeForActivity" id="ae4d99bd-3ef9-4861-aa3b-f67612fbbdba">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars
	xpsCraneShift	    	: CMIF_XpsCraneshift;
	xpsPointOfWorkCmif      : CMIF_XpsPointOfWork;
	invWqCmif               : CMIF_InvWq;
	machine : CM_Object;
	voyage : CM_Voyage;
begin

	if _opsViewTable.isKindOf(CMIF_XpsCraneshift) then
		xpsCraneShift := _opsViewTable.CMIF_XpsCraneshift;
		xpsCraneShift.tableName	:= xpsCraneShift.Xps_craneshift;
		
		xpsCraneShift.gkey := xpsCraneShift.generateFullGKey(self, "");
		xpsCraneShift.pkey := xpsCraneShift.generateFullGKey(self, "");	
		xpsCraneShift.owner_pow := xpsCraneShift.generateFullGKey(self, "");
		xpsCraneShift.owner_pow_gkey := xpsCraneShift.generateFullGKey(self, "");
		
	elseif _opsViewTable.isKindOf(CMIF_XpsPointOfWork) then
		xpsPointOfWorkCmif := _opsViewTable.CMIF_XpsPointOfWork;
		xpsPointOfWorkCmif.tableName := xpsPointOfWorkCmif.Xps_pointofwork;

		xpsPointOfWorkCmif.gkey := xpsPointOfWorkCmif.generateFullGKey(self, "");
		xpsPointOfWorkCmif.name := self.jobId; // ### TFS 53569 04MAY2022 NAVAB1 NEW was not mapped before
		
		machine := xpsPointOfWorkCmif.getMachine(self);
		if machine &lt;&gt; null then
			if machine.isKindOf(CM_Machine) then // ### TFS 53105 13JUN2022 NAVAB1
				xpsPointOfWorkCmif.che_id := machine.CM_Machine.code.getStringValueAsInteger64();
			elseif machine.isKindOf(CM_WorkPoint) then // ### TFS 53105 13JUN2022 NAVAB1
				xpsPointOfWorkCmif.che_id := machine.CM_WorkPoint.code.getStringValueAsInteger64(); // ### TFS 53105 13JUN2022 NAVAB1
			endif;
		endif;
		
	elseif _opsViewTable.isKindOf(CMIF_InvWq) then
		invWqCmif := _opsViewTable.CMIF_InvWq;
		invWqCmif.tableName	:= invWqCmif.Inv_wq;

		invWqCmif.gkey := invWqCmif.generateFullGKey(self, "");
		invWqCmif.pkey := invWqCmif.generateFullGKey(self, "");
		invWqCmif.first_shift_gkey := invWqCmif.generateFullGKey(self, "");
		invWqCmif.first_shift_pkey := invWqCmif.generateFullGKey(self, "");
	
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
