<Class name="CMIF_RectangleStretch" id="d5646c29-bf66-406c-b3e9-054e49bc469a">
    <superclass name="CMIF_RectangleManipulator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <PrimAttribute name="index1" id="6a177bf3-52bb-49f1-92e2-b2246a73d5f2">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="index2" id="da983d75-d34c-4e02-931a-52f9d51c18f3">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="stretchLeftRight" id="ad517c33-da51-4b58-b203-f76a6fd2ad18">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="stretchUpDown" id="2daf11b3-410c-40ca-9012-2c09cb166898">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doStretch" id="79b08e51-9278-4051-9557-8cd7d5573362">
        <source>doStretch(_newX, _newY : Integer);
/*
Purpose:			
Date		Who		Reason
12 April 2011	cnwab1	Initial creation
*/

vars

	tmpPoint, newPoint : Point;
	newPoints : PointArray;
begin

	if self.originalPoints.size &lt; self.index2 then
		return;
	endif;
	

	if self.stretchLeftRight then
		tmpPoint := self.originalPoints[self.index1];
		newPoint.setX(_newX);
		newPoint.setY(tmpPoint.y);
		self.originalPoints[self.index1] := newPoint;
		
		tmpPoint := self.originalPoints[self.index2];
		newPoint.setX(_newX);
		newPoint.setY(tmpPoint.y);
		self.originalPoints[self.index2] := newPoint;
		
		if self.index2 = self.originalPoints.size then
			tmpPoint := self.originalPoints[1];
			newPoint.setX(_newX);
			newPoint.setY(tmpPoint.y);
			self.originalPoints[1] := newPoint;
		endif;
	elseif self.stretchUpDown then
		tmpPoint := self.originalPoints[self.index1];
		newPoint.setX(tmpPoint.x);
		newPoint.setY(_newY);
		self.originalPoints[self.index1] := newPoint;
		
		tmpPoint := self.originalPoints[self.index2];
		newPoint.setX(tmpPoint.x);
		newPoint.setY(_newY);
		self.originalPoints[self.index2] := newPoint;
		if self.index1 = 1 then
			tmpPoint := self.originalPoints[self.originalPoints.size];
			newPoint.setX(tmpPoint.x);
			newPoint.setY(_newY);
			self.originalPoints[self.originalPoints.size] := newPoint;
		endif;
	endif;
	
	self.newPoints.clear;
	foreach tmpPoint in self.originalPoints do
		newPoint.setX(tmpPoint.x);
		newPoint.setY(tmpPoint.y);
		self.newPoints.add(newPoint);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_newX" type="Integer"/>
        <Parameter name="_newY" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupStretch" id="f209ae41-e71f-4366-96a7-67849a403bbf">
        <updating/>
        <source>setupStretch(_index1, _index2 : Integer; _lr, _ud : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
13 April 2011	cnwab1	Initial creation
*/

vars

begin
	
	self.index1 := _index1;
	self.index2 := _index2;
	self.stretchLeftRight := _lr;
	self.stretchUpDown := _ud;
	
end;</source>
        <Parameter name="_index1" type="Integer"/>
        <Parameter name="_index2" type="Integer"/>
        <Parameter name="_lr" type="Boolean"/>
        <Parameter name="_ud" type="Boolean"/>
    </JadeMethod>
</Class>
