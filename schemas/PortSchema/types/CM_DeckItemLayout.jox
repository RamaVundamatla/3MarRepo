    <JadeMethod name="setLocnDefnsToRotate" id="7233ce29-6baa-45dd-baad-6016a1cafb9b">
        <updating/>
        <source>setLocnDefnsToRotate(_direction : Integer; _startPoint : Point; _hide : Boolean; _allStateData : CM_StateDataDict) updating;
/*
Purpose:	CCMS 1009 28479		
Date		Who		Reason
13 July 2011	cnwab1	Initial creation
21 Feb 2012	cnwrs1	Par 29157 - remove unit test leaks
*/

vars
	startX, startY : Integer;
	aVes : CM_Vessel;
	startPoint, newPoint : Point;
	newPoints : PointArray;
	hide : Boolean;
	locnGap, locnLength, locnWidth : Decimal[12,2];
	rotateLabel : String;
begin
	global.getExtraData(_allStateData,RoRoLocationGap,locnGap);
	global.getExtraData(_allStateData,RoRoLocationWidth,locnWidth);
	global.getExtraData(_allStateData,RoRoLocationLength,locnLength);
	global.getExtraData(_allStateData,RoRoRotatedLabel,rotateLabel);

	if _hide then
		self.isVisible := false;
		self.myDeckItem.addRotateLabel(rotateLabel); // PAR 28990 
		return;
	endif;

	create newPoints transient;
	
	
	locnGap := locnGap * ROROStructurePixelsPerMetre;
	locnWidth := (locnWidth * ROROStructurePixelsPerMetre) - 1; // PAR 28317
	locnLength := (locnLength * ROROStructurePixelsPerMetre) - 1; // PAR 28317

	startX := _startPoint.x;
	startY := _startPoint.y;
	
	self.myDeckItem.addRotateLabel(rotateLabel); // PAR 28990 - being rotated does not matter what orientation you end up with. You have been rotated
	if _direction = SPAF_Value then // Was Vertical make Horizontal
		// Remove Rotated Label
// PAR 28990		self.myDeckItem.removeRotateLabel(rotateLabel);
		self.code := self.myDeckItem.code; // 28479 CCMS 1009 EDI
		// Top Left
		newPoint.setX(startX);
		newPoint.setY((startY - locnWidth).Integer);
		newPoints.add(newPoint);
		// Top Right
		newPoint.setX((startX + locnLength).Integer);
		newPoint.setY((startY - locnWidth).Integer);
		newPoints.add(newPoint);
		// Bottom Right
		newPoint.setX((startX + locnLength).Integer);
		newPoint.setY(startY);
		newPoints.add(newPoint);
		// Bottom Left
		newPoint.setX(startX);
		newPoint.setY(startY);
		newPoints.add(newPoint);
		// Top Left
		newPoint.setX(startX);
		newPoint.setY((startY - locnWidth).Integer);
		newPoints.add(newPoint);
		
		self.setPointsPolygon(newPoints);
	else // Was Horizontal make Vertical
		// Add Rotated Label
// PAR 28990		self.myDeckItem.addRotateLabel(rotateLabel);
		self.code := self.myDeckItem.code; // CCMS 1009 EDI
		// Top Left
		newPoint.setX(startX);
		newPoint.setY((startY - locnLength).Integer);
		newPoints.add(newPoint);
		// Top Right
		newPoint.setX((startX + locnWidth).Integer);
		newPoint.setY((startY - locnLength).Integer);
		newPoints.add(newPoint);
		// Bottom Right
		newPoint.setX((startX + locnWidth).Integer);
		newPoint.setY(startY);
		newPoints.add(newPoint);
		// Bottom Left
		newPoint.setX(startX);
		newPoint.setY(startY);
		newPoints.add(newPoint);
		// Top Left
		newPoint.setX(startX);
		newPoint.setY((startY - locnLength).Integer);
		newPoints.add(newPoint);
		
		self.setPointsPolygon(newPoints);
	
	endif;
epilog
	delete newPoints;	// 21 Feb 2012	cnwrs1	Par 29157
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_startPoint" type="Point"/>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_allStateData" type="CM_StateDataDict"/>
    </JadeMethod>
    <JadeMethod name="setLocnDefnsToUnrotate" id="f2f5a0d2-97c3-40df-88bf-59154b43414e">
        <updating/>
        <source>setLocnDefnsToUnrotate(_oldPoints : PointArray) updating;
/*
Purpose:			
Date		Who		Reason
14 July 2011	cnwab1	Initial creation
*/

vars
	allStateData : CM_StateDataDict;
	rotateLabel : String;
//	aVes : CM_Vessel;
begin
	self.isVisible := true;
	self.setPointsPolygon(_oldPoints);
	
	allStateData := self.getStateData();
/*	28971
	// CCMS 1009 28479
	if  self.myDeckItem &lt;&gt; null 
	and self.myDeckItem.CM_ROROLocnDefnVoyage.myVoyageStructure &lt;&gt; null 
	and self.myDeckItem.CM_ROROLocnDefnVoyage.myVoyageStructure.myVoyage &lt;&gt; null then
		aVes := self.myDeckItem.CM_ROROLocnDefnVoyage.myVoyageStructure.myVoyage.getMyVessel();
	endif;
	if aVes &lt;&gt; null then
		allStateData:= aVes.allStateData;
	endif;
	
	if allStateData.size= 0 then
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	*/
	
	global.getExtraData(allStateData,RoRoRotatedLabel,rotateLabel);

	self.myDeckItem.removeRotateLabel(rotateLabel);
	self.myDeckItem.removeRotateLabel("#"); // PAR 29884
	self.code := self.myDeckItem.code; // CCMS 1009 EDI
	
epilog

end;</source>
        <Parameter name="_oldPoints" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="setMyDeckLayer" id="952de8d0-5269-4018-b950-80c18c9da943">
        <updating/>
        <source>setMyDeckLayer(_layer : CM_DeckLayerLayout) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myDeckLayer := _layer;
epilog

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="setPointsPolygon" id="e85f55e5-92c8-4676-89f4-10cd66292843">
        <updating/>
        <source>setPointsPolygon(_newPoints: PointArray) updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	x1, y1 : Decimal[12,2];
	aPoint : Point;
	xP, yP, pixelPerMetre : Integer;
	deckItem : CM_DeckItem;
	req : CM_RORORequest;
	lc : CM_VoyageROROController;
	
	isLoad : Boolean;
begin
	self.pointsPolygon.clear; 
	if _newPoints = null then
		return;
	endif;


	
	_newPoints.copy(self.pointsPolygon);
	
	self.myPolygonPixels.clear;
	self.pointsPolygon.copy(self.myPolygonPixels);
	self.myPolygonCMs.clear;
	
	// ### CONVERT
	foreach aPoint in self.myPolygonPixels discreteLock do
		xP := aPoint.x;
		yP := aPoint.y;
		
		// 10 pixels = 1 metre
		x1 := ((xP/ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre));
		y1 := (-1 *  ((ROROStructureCentreLine/ROROStructurePixelsPerMetre) - (yP /ROROStructurePixelsPerMetre)));
		
		self.myPolygonCMs.add(x1);
		self.myPolygonCMs.add(y1);
	endforeach;

	self.areaM2 := self.myPolygonPixels.calculateArea/(ROROStructurePixelsPerMetre * ROROStructurePixelsPerMetre);
	
	// Get the GC Discharge Request and update its polygon as well
	if self.type = DeckItemLayoutType_GCDischarge  // Actual GC Cargo created by EDI Deck Plan or otherwise directly on deck
	or self.type = DeckItemLayoutType_GCLoad then // PAR 31166 - Includes worked export GC areas being moved as well
		deckItem  := self.myDeckItem;
		if deckItem &lt;&gt; null then
			if deckItem.isLocnGC() or deckItem.isLocnLanePosition() then
			
				if deckItem.isLocnGC() then
					self.myDeckLayer.myDeckLayout.hideContainerPositionsUnderGC(self); // PAR 27749
				endif;
				
				lc := deckItem.getLC().CM_VoyageROROController;
				if lc &lt;&gt; null then
					req := lc.myRORORequestDischarge;
					if req &lt;&gt; null and req.myLayout &lt;&gt; null then
						req.myLayout.setPointsPolygon(self.pointsPolygon);
					endif;
				endif;
			endif;
		endif;
	// PAR 28879
	elseif self.type = DeckItemLayoutType_Locn then // Actual OOTL Cargo created by EDI Deck Plan or otherwise directly on deck
		deckItem  := self.myDeckItem;
		if deckItem &lt;&gt; null then
			if deckItem.isLocnContainer() and deckItem.isOOTL() then
				isLoad := self.myDeckLayer.type = ROROLayerType_CCLoad; // PAR 28886
				deckItem.setPointsOnRequests(isLoad); // PAR 28886
				if not self.isOnLayerLoad() then // PAR 30231
					deckItem.myDeck.myDeckLayout.hideContainerPositionsUnderGC(self);
				endif;
			endif;
		endif;
	elseif self.type = DeckItemLayoutType_Graphic then // 29178 Equipment Area created by EDI Deck Plan or otherwise directly on deck
		deckItem  := self.myDeckItem;
		
		if deckItem &lt;&gt; null and (deckItem.isMachinery or deckItem.isGeneralItem) then
			deckItem.myDeck.myDeckLayout.hideContainerPositionsUnderGA(self);
		endif;
		
	 endif;

epilog

end;</source>
        <Parameter name="_newPoints" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="setPointsPolygonCMs" id="4992f8f7-46a4-4d1d-85d4-27fe0788bdef">
        <updating/>
        <source>setPointsPolygonCMs( _newPoints : DecimalArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	pointCM,
	pointX,
	pointY : Decimal[12,2];
	aPoint : Point;
	i : Integer;
begin
	if _newPoints = null then
		return;
	endif;
		
	self.myPolygonCMs.clear; 
	_newPoints.copy(self.myPolygonCMs);
	
	self.myPolygonPixels.clear;
	self.pointsPolygon.clear;

	
	// ### CONVERT
	i := 1; 
	//epr par 29646 31/5/12 was continuing if pointCM was null or 0.00 
	// now done in pairs first is x second is y 
	foreach pointCM in self.myPolygonCMs discreteLock do
		if i.isOdd then
			pointX:= pointCM;
		else
			pointY:=pointCM;
			aPoint.setX( ((pointX* ROROStructurePixelsPerMetre).Integer + ROROStructureRearLine));
			aPoint.setY( ((pointY* ROROStructurePixelsPerMetre).Integer + ROROStructureCentreLine));
			self.pointsPolygon.add(aPoint);
			self.myPolygonPixels.add(aPoint);
		endif; 
		 i:= i + 1;
	endforeach;

	self.areaM2 := self.myPolygonPixels.calculateArea/(ROROStructurePixelsPerMetre * ROROStructurePixelsPerMetre);
epilog

end;</source>
        <Parameter name="_newPoints" type="DecimalArray"/>
    </JadeMethod>
    <JadeMethod name="setPointsPolygonMove" id="8ebd3b37-a9f4-4707-b93a-84c1b9617a34">
        <updating/>
        <source>setPointsPolygonMove(_xMetres, _yMetres : Decimal) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	x1, y1 : Decimal[12,2];
	aPoint, newPoint : Point;
	xDiff, yDiff, xP, yP, pixelPerMetre : Integer;
	deckItem : CM_DeckItem;
	req : CM_RORORequest;
	lc : CM_VoyageROROController;
	newPoints : PointArray;
begin
	// 10 pixels = 1 metre
	xP := ((_xMetres * ROROStructurePixelsPerMetre) + ROROStructureRearLine).Integer;
	yP := ((_yMetres * ROROStructurePixelsPerMetre) + ROROStructureCentreLine).Integer;

	
	xDiff := xP - self.myPolygonPixels[1].x;
	yDiff := yP - self.myPolygonPixels[1].y;
	
	
	create newPoints transient;
	
	foreach aPoint in self.pointsPolygon discreteLock do
		newPoint.setX(aPoint.x + xDiff);
		newPoint.setY(aPoint.y + yDiff);
		
		newPoints.add(newPoint);
	endforeach;
	
	self.setPointsPolygon(newPoints);
epilog
	delete newPoints;
end;</source>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setPolyCMsByIndex" id="e012a9db-960c-4f22-a22e-6405bc02f7b3">
        <updating/>
        <source>setPolyCMsByIndex(_index : Integer; _length : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, xP, yP : Integer;
	aPoint : Point;
begin
	if _index &lt; 1 then
		return;
	endif;
	
	self.myPolygonCMs[_index] := _length;
	
	// ### CONVERT to PIXELS
	idx := (_index / 2).roundedUp;
	aPoint  := self.myPolygonPixels[idx];
	

	if _index.isOdd() then
		xP := (self.myPolygonCMs[_index] * ROROStructurePixelsPerMetre).Integer;
		xP := xP + ROROStructureRearLine;
		yP := (self.myPolygonCMs[_index + 1] * ROROStructurePixelsPerMetre).Integer;
		yP := yP + ROROStructureCentreLine;
		
		aPoint.setX(xP);
		aPoint.setY(yP);
	else
		xP := (self.myPolygonCMs[_index - 1] * ROROStructurePixelsPerMetre).Integer;
		xP := xP + ROROStructureRearLine;
		yP := (self.myPolygonCMs[_index] * ROROStructurePixelsPerMetre).Integer;
		yP := yP + ROROStructureCentreLine;
		
		aPoint.setX(xP);
		aPoint.setY(yP);
	endif;
	self.myPolygonPixels[idx] := aPoint;
	self.pointsPolygon[idx] := aPoint;
	self.causeEvent(EVENT_RORO_ITEM_UPDATE,true,self); // PAR 27773
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_length" type="Decimal"/>
    </JadeMethod>
