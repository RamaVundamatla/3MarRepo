    <JadeMethod name="doSummaryQuery" id="69d24e39-c445-45ed-a2e6-9309fe1d2fd5">
        <source>doSummaryQuery();
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	filter				: CMQF_TrainLoadListSummary;//CMQF_VoyageLoadListSummary;
	allSummaryObjects	: CMIF_LoadListSumByTrainDestISO;	//CMIF_LoadListSumByDestAndISO;
	llSummaryObject		: CMIF_LoadListSummaryObject;
	tmpClock			: Integer;
begin
	
	if self.mySummaryReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(REP_GRP_YO_NO_FOUNDA));
		return;
	endif;

	filter	:=	self.mySummaryFilterTrain;
	self.resetSummaryCriteria();
	
	create allSummaryObjects transient;
	self.tblAll.allTableObjects.copy(filter.allTIs);
	
	filter.filterObjects(allSummaryObjects, app.myPassport);

	self.mySummaryReport.reset();
//	self.mySummaryReport.addGroupProperty(CMIF_LoadListSummaryObject::extraKey.name, CMIF_LoadListSummaryObject::extraKey.type);
	self.mySummaryReport.addGroupProperty(CMIF_LoadListSummaryObject::train.name, CMIF_LoadListSummaryObject::train.type);
	self.mySummaryReport.addGroupProperty(CMIF_LoadListSummaryObject::destinationPort.name, CMIF_LoadListSummaryObject::destinationPort.type);
	self.mySummaryReport.addGroupProperty(CMIF_LoadListSummaryObject::isoGroupingKey.name, CMIF_LoadListSummaryObject::isoGroupingKey.type);

	foreach llSummaryObject in allSummaryObjects do
	
		self.mySummaryReport.groupObject(llSummaryObject);
	
	endforeach;

	self.initSummaryTable();

	self.mySummaryReport.populateTable(self.tblSummary);
	self.mySummaryReport.addTableTotal(self.tblSummary);
	
	

epilog
	delete allSummaryObjects;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="b6e18c73-7358-4a5e-afdc-c30446b5ff72">
        <updating/>
        <source>doSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	05 November 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------
// 08/11/2010	cnwdap1		PAR #23794 Cater for WLE updates as well as TI updates
vars
	ti : CM_TrackedItem;
	theRow : Integer;
	dataTbl		: CM_DataTable;
	ts : TimeStamp;
begin

	app.mousePointer	:=	Busy;
	inheritMethod(eventType, theObject, eventTag);

	//if not theObject.isKindOf(CM_TrackedItem) then												// PAR #23794
	if not theObject.isKindOf(CM_TrackedItem) and not theObject.isKindOf(CM_WorkListEntry) then		// PAR #23794
		return;
	endif;
	if self.ignorePlanUnplanNotes then
		return;
	endif;
	//ti := theObject.CM_TrackedItem;				// PAR #23794

	// ### PAR 13388 15FEB2007. re begin the timer for each TI update. The TimerEvent will update the screen
	//self.endTimer(TI_Note_Tag);
	//self.beginTimer(500, Timer_OneShot, TI_Note_Tag);
	
	//if ti  &lt;&gt; null then										// PAR #23794
	if theObject  &lt;&gt; null then									// PAR #23794
		//self.doCentralisedTINoteUpdate(ti);
		//self.doNotesStorageStartTimer(ti);					// PAR #23794
		self.doNotesStorageStartTimer(theObject.CM_Object);		// PAR #23794
	endif;

epilog
	endLoad;
	app.mousePointer	:=	Idle;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataClick" id="bd3c4ae5-c953-4044-a3ff-06866b90da73">
        <updating/>
        <source>doTblDataClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theColumn : Integer;
	theTI : CM_TrackedItem;
begin
	if table.row &lt;= table.CM_DataTable.fixedRows then
		theColumn := table.CM_DataTable.getColumnByRowName(ETRow_RowNumber);
		if theColumn = table.column then // no sort by this column
			return;
		endif;
		
		//self.sortByColumn := table.column;
		return;
	endif;
	theColumn := table.CM_DataTable.getColumnByRowName(ETRow_ReadyToShip);
	//changed by cnwyl1 27/7/2006 For PAR 12158
	if theColumn = table.column and table.CM_DataTable.allSelectedObjects.size &lt;&gt; 0 then
		self.doBtnRTSClick(table);
	endif;

	theTI := table.CM_DataTable.accessRow(table.row).itemObject.CM_TrackedItem;
	//PAR13157 
	if theTI &lt;&gt; null and theTI.myPrimaryActualLocation &lt;&gt; null then
		self.btnLocate.enabled := theTI.myPrimaryActualLocation.isKindOf(CM_GridController);
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="55af7d18-1a4a-48e9-a8b7-3ee95a763c14">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theRow : Integer;
	theTI : CM_TrackedItem;

begin

	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;
	
	self.doContextMenuBuild(cntrl);
	theRow := cntrl.CM_BaseTable.getRowFromY(y);

	if theRow &gt; cntrl.fixedRows then
		theTI := cntrl.accessRow(theRow).itemObject.CM_TrackedItem;
		self.mnuInspectObject.userObject := theTI;
	endif;

	if self.fldMain.topSheet = self.shtNonplanned then
		if not self.splMain.getControlByName(self.tblInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.mnuLLUnplan.visible := true;
		if not self.splPlanned.getControlByName(self.tblPlannedInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtAll then
		if not self.splAll.getControlByName(self.tbAllInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuContextTrainAssign.visible := false;
		self.mnuTrainAP.visible := false;
	endif;
	

	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x,y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="3ce057d4-4a11-4f6e-a43e-ae6f719f8f3e">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	theRow : Integer;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	
	inheritMethod(table);
	
	theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
	if theTI &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
	endif;
end;</source>
