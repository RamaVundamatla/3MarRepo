    <JadeMethod name="setForProxyGridController" id="d5b475e3-de7e-4cd4-9c56-6b65d4afb390">
        <updating/>
        <source>setForProxyGridController(pId : String; 
						  pGridColumn : CM_GridColumn;
						  pGridRow : CM_GridRow;
						  pWidth : Real) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);

	// Make sure if you remove name you fix up the collections to
	// use ident instead or the whole thing will collapse.
	self.name	:= pId;
	self.ident	:= pId;
	self.width	:= pWidth;
	
	self.myGridColumn	:= pGridColumn;
	self.myGridRow		:= pGridRow;

end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pGridColumn" type="CM_GridColumn"/>
        <Parameter name="pGridRow" type="CM_GridRow"/>
        <Parameter name="pWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3e7441bb-bfbe-4298-8a09-907f7ffc299c">
        <updating/>
        <source>setForUpdate(pProxy : CM_GridController; pGridArea : CM_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/03/2011	cnwcs5		CCMS CPL 2017/PAR 27126 - audit location changes
// ---------------------------------------------------------------------------
vars

begin

	self.name	:= pProxy.name; // PAR 9036  put back in. // PAR 8080 removed. This has already been done in set new labels on the grid area
	self.ident 	:= pProxy.ident;
	self.width	:= pProxy.width;
	
	self.createTALocationsAudits_Twin (pProxy, pGridArea);	// CCMS CPL 2017/PAR 27126
	
	// cnwjk3 CCMS 1032 15/12/2008
	self.canTwinLiftWithPrevController := pProxy.canTwinLiftWithPrevController;
	self.canTwinLiftWithNextController := pProxy.canTwinLiftWithNextController;

	self.myGridRow		:= pGridArea.allGridRows[pProxy.row];
	self.myGridColumn	:= pGridArea.allGridColumns[pProxy.column];
	
	self.setMyAssocGridInterchangeArea(pProxy.myAssocGridInterchangeArea);
	//epr par 20313
	self.setMy40ftGridArea(null);
	if pGridArea.use40ftIds then
		self.setId40ft(pProxy.id40ft); //par 20313
		if self.id40ft &lt;&gt; null then
			self.setMy40ftGridArea(pGridArea);
		endif;
	else
		self.setId40ft(null);
	endif;
	inheritMethod(pProxy, pGridArea);

end;</source>
        <Parameter name="pProxy" type="CM_GridController"/>
        <Parameter name="pGridArea" type="CM_GridArea"/>
    </JadeMethod>
