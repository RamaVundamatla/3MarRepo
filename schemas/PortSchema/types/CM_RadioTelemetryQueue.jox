    <JadeMethod name="getMachinesForInheritedQueue" id="75e76662-b820-4f0e-bb2d-ddc46b39b659">
        <source>getMachinesForInheritedQueue(_machines : CM_MachineByIdDict input;  _includeCranes : Boolean);
//17/08/2011 cnwdz2 27747

vars

	machine : CM_Machine;

begin
	if self.myParentQueue &lt;&gt; null then
		self.myParentQueue.getMachinesForInheritedQueue(_machines, _includeCranes);
	endif;
	
	self.getPrimaryMachines(_machines, false,_includeCranes);
end;</source>
