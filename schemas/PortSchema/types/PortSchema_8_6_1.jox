    <JadeMethod name="setVoyageStatusSecurityRoles" id="2509431a-4349-4f0f-96e1-54560e941336">
        <source>setVoyageStatusSecurityRoles(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/03/2018	jlgdap1		Initial creation TFS 37445 PEL1 Voyage Status Security
//
vars
	voyageStatus : CM_VoyageStatus;
	role : CM_SecurityRoleTerminal;
	rootRole : CM_SecurityRoleTerminalRoot;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Add all Voyage Statuses to every Terminal Security Role", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Add all Voyage Statuses to every Terminal Security Role") ;	
	endif;
	
	beginTransaction;
	foreach voyageStatus in app.myRoot.allVoyageStatuses do
		foreach role in CM_SecurityRoleTerminal.instances do
			role.allVoyageStatusesMaint.addNoDuplicates(voyageStatus, false);
		endforeach;
		foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
			rootRole.allVoyageStatusesMaint.addNoDuplicates(voyageStatus, false);
		endforeach;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Add all Voyage Statuses to every Terminal Security Role Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Add all Voyage Statuses to every Terminal Security Role Completed") ;
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setWeighBridgePermissions" id="2d721815-a375-4b5d-bfb3-e10a889d607e">
        <source>setWeighBridgePermissions( _updController : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

	newPerms : IntegerArray;
	srt : CM_SecurityRoleTerminal;
	hasCargoEnqView : Boolean;

begin

	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; 'Configuring Weigh Bridge for permissions ', LogINFO);
	
	create newPerms transient;
	newPerms.add(PmWeighForm);
	
	foreach srt in CM_SecurityRoleTerminal.instances do
		if srt.permissions.size &lt; PmAdmCargoEnquiryView then
			continue;
		endif;
		hasCargoEnqView := srt.permissions[PmAdmCargoEnquiryView];
		if hasCargoEnqView then
			beginTransaction;
			srt.setPermissionsFromIntArray(newPerms,true);
			commitTransaction;
		endif;
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; 'Completed Configuring Weigh Bridge for permissions ', LogINFO);
	
	self.addScriptRun(method.name);
	
epilog

	delete newPerms;

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setupCashCreditSequNum" id="1e6a98cb-5b7f-4c9e-83df-8be5d4a291bb">
        <updating/>
        <source>setupCashCreditSequNum(_controller: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Sep 2019	jlgsl4	TFS 45872 - JMT - Cash Credit UI changes
*/

vars
	keySeries : CM_KeySeries;
	seriesKey : CM_SeriesKey;
	bank : CM_Bank;
	objectArray : ObjectArray; 
	iterator : Iterator;
	isOK : Boolean;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);

	create objectArray transient;
	CM_Bank.allInstances(objectArray, 0, false);
	iterator := objectArray.createIterator;
	app.writeLog(method.qualifiedName &amp; "***** Started -&gt; Create Cash Credit sequence numbers for banks listed:-", LogINFO);

	if _controller &lt;&gt; null then
		_controller.logEntry(" Start Create Cash Credit sequence numbers");
	endif;

	while iterator.next(bank) do
		if not bank.isBusinessUnit then
			continue;
		endif;
		if bank.keySeries[SN_CashCredit] = null then
			beginTransaction;
			create keySeries;
			keySeries.set(SN_CashCredit, "Cash Credit External Id", null);
			create seriesKey;
			keySeries.nextKey := seriesKey;
			seriesKey.setForUpdate(null, "CTL", 10000, null, null);
			bank.keySeries.add(keySeries);
			commitTransaction;
			app.writeLog(method.qualifiedName &amp; " -&gt; terminal " &amp; bank.getMyTerminal().code &amp; ", bank " &amp; bank.code, LogINFO);
		endif;
	endwhile;
	app.writeLog(method.qualifiedName &amp; "***** Finished -&gt; Create Cash Credit sequence numbers", LogINFO);	
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Create Cash Credit sequence numbers");
	endif;
	self.addScriptRun(method.name);
	isOK := true;
epilog
	if not isOK then
		abortTransaction;
	endif;
	delete objectArray;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setupDefaultVoyageProcess" id="ff387e91-365d-4e8f-b25c-92fdef0b8161">
        <source>setupDefaultVoyageProcess(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL 1 Voyage Status Enhancements
// 16/03/2018	jlgdap1		TFS 37540 PEL1 Voyage Statuses Pelindo 1
//
vars
	defaultProcess : CM_VoyageProcess;
	terminal : CM_Terminal;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Set up Default Voyage Process for all terminals", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Set up Default Voyage Process for all terminals") ;	
	endif;
	
	defaultProcess := app.myRoot.allVoyageProcesses[VoyageProcessDefault];
	if defaultProcess = null then
		app.writeLog(method.qualifiedName &amp; " NO Default Voyage process found!!!!", LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry("NO Default Voyage process found!!!!");
		endif;
		return;
	endif;
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		terminal.setConfig(DefaultVoyageProcess, defaultProcess.code);
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Set up Default Voyage Process for all terminals Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Set up Default Voyage Process for all terminals Completed") ;
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setupIMEXTransition" id="b01342da-7382-4896-b117-8994e30872f0">
        <updating/>
        <source>setupIMEXTransition(_controller: CnEcReleaseController) updating;
/*

Purpose: create IMEXTransitionCriteria for terminals needing one
		 on basis of MTImportIfIntendedOffsite config value

Parameters:			

