    <JadeMethod name="rel812_par30707" id="f6d2f0c2-cfac-412e-a4f1-e2303272c722">
        <source>rel812_par30707();
/*
Purpose		Remove all Voyage KPI entities for which the associated voyage has been deleted

Date		Who		Reason
12 Nov 2012	cnwcs5	Initial creation - par 30707
*/
vars
	kpi		:CM_KPIVoyageEntity;
	voyage	:CM_Voyage;
	coll	:ObjectArray;
	obj		:Object;
	count	: Integer;
	str		: String;
begin
	str := 'Cleaning up KPI data for deleted voyages.';
	
	write str;
	
	create coll transient;
	
	// find all instances of the voyage KPI classes
	CM_KPIVoyageEntity.allInstances (coll, null, true);
	
	beginTransaction;
	
	foreach obj in coll do
		kpi 	:= obj.CM_KPIVoyageEntity;
		voyage	:= kpi.myVoyage;
		
		// if voyage has been deleted we expect inverse maintenance to have set the voyage reference to null.
		// the code will handle an invalid voyage reference even though we don't expect to find one.
		if voyage &lt;&gt; null and global.isValidObject (voyage) then
			// voyage has NOT been deleted
			continue;
		endif;
		
		// need to get rid of these KPI figures as the voyage no longer exists
		// parent-relationships will cause the following collections to be purged:
		// - allKPIVoyageMoveDtls_All
		// - allKPIVoyageMoveDtls_Container
		// - allKPIVoyageMoveDtls_GC
		
		count := count + 1;

		delete kpi;
	endforeach;
	
	commitTransaction;
	
	str := 'Deleted ' &amp; count.String &amp; ' orphaned KPI instances';
	
	write str;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rel812_par30728" id="c2c767c7-2617-40bb-a339-0cf7b2dc98b1">
        <source>rel812_par30728();
//
//21 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
//
vars
	transAgent 	: CM_TranslationAgent;
	tmpArray 	: StringArray;
begin
	app.initialize();
	create transAgent transient;
	create tmpArray transient;
	tmpArray.add('ERR_CAMS_MAKEDIR');
	tmpArray.add('ERR_CAMS_OPENFILEFAIL');
	tmpArray.add('ERR_CAMS_PURGEFILEFAIL');
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	return;
	
	write ERR_CAMS_MAKEDIR;
	write ERR_CAMS_OPENFILEFAIL;
	write ERR_CAMS_PURGEFILEFAIL;
epilog
	delete tmpArray;
	delete transAgent;
end;
</source>
    </JadeMethod>
