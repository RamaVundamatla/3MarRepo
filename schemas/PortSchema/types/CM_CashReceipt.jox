			voyageCode := ti.voyageCode;
			if voyageCode &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;
	
	return voyageCode;
	
epilog
	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726
end;
</source>
