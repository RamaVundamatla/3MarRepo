        <source>tblUsers_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
24 Jan 2005	cnwkpd1	PAR #5174 - Programme Planning

*/

vars
	userTracker		: AuditAccessUserTracker;
	
begin
	userTracker := obj.AuditAccessUserTracker;
	
	return userTracker.userIndex.String &amp; Tab &amp; 
		   userTracker.userName &amp; Tab &amp;
