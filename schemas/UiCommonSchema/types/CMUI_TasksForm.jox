    <JadeMethod name="tblCargo_contextMenu" id="e5f430ad-a39e-4898-b9da-c7ca06c3bb3d">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Jul 2024	navbs1	CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client

*/

vars

begin

	self.mnuColOrganizer.userObject := table;
	return self.showContextMenu(self.mnuTaskForm,table, conwin,mouse,x,y);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblTasksAdd_click" id="9ec457f9-ee44-475c-8f88-7243428c79fe">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTasksAdd_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
11 Oct 2022 navtnr20 	ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
18 Feb 2025	navlw1		JIRA-33941: MTN | To Do Task List UI Change

*/

vars
	control				: Control;
	row, currentRow, 
	currentCol,
	posit,
	lastRow,
	lastCol				: Integer;
	text				: String;
begin

	self.doInstructions();
	if self.mode = CM_ContainerEnqForm.TASK_MODE_INSTRUCTION then
		self.tblTasksAdd.selectMode := Table.SelectMode_CurrentRow;
	endif;
	// remarksCol := table.getColumnByRowName (ETRow_Remarks);
	
	// Start navlw1 #JIRA-33941 18/02/2025
	currentRow := table.accessedCell.row;
	currentCol := table.accessedCell.column;
	
	posit := self.helpKeyword.pos("/",1);
	if posit &gt; 0 then
		lastRow := self.helpKeyword[1: posit - 1].Integer;
		lastCol := self.helpKeyword[posit + 1:end].Integer;

		table.accessRow(lastRow);
		table.accessColumn(lastCol);
		table.accessCell(lastRow,lastCol);
		
		control := table.accessedCell.cellControl;
		if control.isKindOf(TextBox) then
			table.rowHeight[lastRow] := 18;
		endif;

	endif;
	
	table.accessRow(currentRow);
	table.accessColumn(currentCol);
	table.accessCell(currentRow,currentCol);

	control := table.accessedCell.cellControl;
	currentRow := table.accessedCell.row;
	if control.isKindOf(TextBox) then
		table.rowHeight[currentRow] := 60;
		table.wordWrap := true;	
	endif;
	
	self.helpKeyword     := currentRow.String &amp; "/" &amp; currentCol.String;
	// End navlw1 #JIRA-33941 18/02/2025
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
