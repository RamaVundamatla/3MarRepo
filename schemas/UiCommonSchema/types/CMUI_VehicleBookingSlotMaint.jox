/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	carrier : CM_Carrier;
	driver : CM_DriverDetails;
	vehicle : CM_Vehicle;

begin

	carrier := self.cmbCarrier.listObject.CM_Carrier;
	if carrier &lt;&gt; null then
		driver := self.cmbDriver.listObject.CM_DriverDetails;
		vehicle := self.cmbVehicle.listObject.CM_Vehicle;
	endif;
	self.setupVehicleCombo( driver, vehicle );

epilog

end;</source>
