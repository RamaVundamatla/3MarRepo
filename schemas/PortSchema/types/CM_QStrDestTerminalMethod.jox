    <JadeMethod name="create" id="a06deb26-1ce3-442c-9655-4a094d46b7b0">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 23 August 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="4a33186f-767f-4754-b37b-188bf81b5863">
