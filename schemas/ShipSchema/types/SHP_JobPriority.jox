    <JadeMethod name="doDelete" id="e79201fb-530b-430a-921c-b3c5f8efe39a">
        <source>doDelete();
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	str : String;
	list : CMUI_ListBox;
	idx, item : Integer;
	tmpType : IntegerArray;
begin
	create tmpType transient;
	list := self.lstJobPriority;
	idx := list.listIndex;
	if idx &lt; 0 or idx &gt; list.listCount() then
		return;
	endif;
	if list.itemData[idx] = 1 then
		app.msgBox(app.getErrorString(Cannot_delete_priority),app.getErrorString(Delete_error),MsgBox_Exclamation_Mark_Icon); // PAR 34655
		return;
	endif;
	
	str := list.itemText[idx];
	
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, str), app.getErrorString(Confirm_Delete), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then // PAR 34655
		return;
	endif;
	
	foreach item in idx + 1 to list.listCount() do
		if list.itemLevel[item] = self.LevelJobType then
			tmpType.add(list.itemData[item]);
		else
			break;
		endif;	
	endforeach;
	
	list.removeItem(idx);

	foreach item in 1 to tmpType.size do
		list.addItemAt(app.getJobPriorityJobName(tmpType[item]),idx);
		list.itemData[idx] := tmpType[item];
		list.itemLevel[idx] := self.LevelJobType;
	endforeach;

	self.reNumberPriorities(JobTypePriority_Crane1);
	self.reNumberPriorities(JobTypePriority_Crane2);
epilog
	delete tmpType;
end;</source>
    </JadeMethod>
    <JadeMethod name="doLstBoxMouseMove" id="dd2dec84-dc54-414b-a88f-7e1e3d313796">
        <updating/>
        <source>doLstBoxMouseMove(listbox:CM_QueueListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	drag, isDragable : Boolean;
	leftButton : Boolean;
	noKeyboard : Boolean;
begin


	isDragable := (listbox.itemLevel[listbox.listIndex] = self.LevelJobType)
						or (listbox.itemLevel[listbox.listIndex] = self.LevelPriority); // PAR 34655
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		isDragable := false;
	endif;

	if not isDragable then
		return;
	endif;
	drag := app.dragDetected(x,y,listbox.origXPos,listbox.origYPos);
	leftButton := (button = Window.MouseButton_Left);
	noKeyboard := (shift.hasNoKeyboardPressed() );
	
	if isDragable
	and drag
	and leftButton 
	and noKeyboard then
			//changed by cnwyl for par 12216
		//it was...
		//listbox.dragMode := Window.DragMode_Drag;
		self.dragMode := DragMode_Drag;
	endif;
//added by cnwyl1 for par 12216
epilog	
	self.origXPos := null;
	self.origYPos := null;	
//add end
end;</source>
        <Parameter name="listbox" type="CM_QueueListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
