    <JadeMethod name="getDisplayStringForAttribute" id="11ce3dec-143e-48c5-99c6-0ab81dcd2c90">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33680

*/

vars

begin

	if  _attrName = ETRow_Code then
		return self.code;
		
	elseif  _attrName = ETRow_Description then
		return self.description;
		
	elseif  _attrName = ETRow_GramsConv then
		if self.myGramsMeasureType &lt;&gt; null then
			return self.myGramsMeasureType.name;
		endif;
		
	elseif  _attrName = ETRow_KilosConv then
		if self.myKilosMeasureType &lt;&gt; null then
			return self.myKilosMeasureType.name;
		endif;
		
	elseif  _attrName = ETRow_OuncesConv then
		if self.myOuncesMeasureType &lt;&gt; null then
			return self.myOuncesMeasureType.name;
		endif;
		
	elseif  _attrName = ETRow_PoundsConv then
		if self.myPoundsMeasureType &lt;&gt; null then
			return self.myPoundsMeasureType.name;
		endif;
		
	elseif  _attrName = ETRow_TonsConv then
		if self.myTonsMeasureType &lt;&gt; null then
			return self.myTonsMeasureType.name;
		endif;
		
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestString" id="92a9faa4-f5cf-452c-8bb4-49ed62c7b15f">
        <source>getRequestString( _weighBridge : CM_WeighBridgeObj ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if self.code = self.IQ710 then
		return self.getRequestStringForIQ710();
	elseif self.code = self.SeriesW then	//24 May 2017	NDL	TFS 4383
		return self.getRequestStringForSeriesW( _weighBridge );
	else
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_weighBridge" type="CM_WeighBridgeObj"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestStringForIQ710" id="da69cb64-9b75-4c00-a346-13cc0af4829e">
        <source>getRequestStringForIQ710():String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2014	cnwndl1	Initial creation	Par 33268

*/

constants

	RequestWeightString : String = "s" &amp; CrLf;
	
vars

begin

	return RequestWeightString;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestStringForSeriesW" id="2ef0dd5d-716d-4344-9ed3-f2409b6eff8c">
        <source>getRequestStringForSeriesW( _weighBridge : CM_WeighBridgeObj ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2017	cnwndl1	Initial creation	TFS 4383

*/

constants
	
vars

	requestWeightString : String;
	deviceInt : Integer;
	type : String;
	deviceIntStr : String;
	char1 : Character;
	char2 : Character;
	char3 : Character;
	int1 : Integer;
	int2 : Integer;
	int3 : Integer;
	checkSum : String;

begin

	/*
	
	Manual says $aatckckCR
	
	
	normal request message format - length = 7.
	stx 			1 		= '$'
	deviceAddress	2-3		= A two digit numerical field representing the weigh bridge internal address.
	type			4		= "t" = Gross weight
	checksum		5-6		= 
	etx				7		= Cr, The 'Carriaage return' character	
	*/

	type := "t";
	deviceInt := _weighBridge.deviceAddress;	//needs to be the internal address of the weigh brifge. (Integer maximum value 99, default to 1)
	deviceIntStr := deviceInt.padLeadingWith("0",2);
	
	char1 := deviceIntStr[1].Character;
	char2 := deviceIntStr[2].Character;
	char3 := type[1].Character;
	
	int1 := char1.Integer;
	int2 := char2.Integer;
	int3 := char3.Integer;
	
	//Provides a binary asicci 8 bit code derived from the XOR of teh binary ascii values
	//of the 3 integer values, then converts back to a hex ascii value, whihc is then converted to a decimal  value.
	
	//e.g. if our characters are 0,1,t (whihc is highly likely), the HEX Ascii values are 30,31 and 74.  The binary ascii values for these are 
	//30 =     	00110000
	//31 = 		00110001
	//74 =		01110100
	//
	//XOR these three gives	01110101, which represents 75 and is the checksum value.
	
	
	
	checkSum := int1.bitXor(int2).bitXor(int3).asHex(2);
	
	requestWeightString := "$" &amp; deviceIntStr &amp; "t" &amp; checkSum &amp; Cr;
	
	return requestWeightString;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_weighBridge" type="CM_WeighBridgeObj"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeightInterfaceClass" id="e9a04d42-f097-48ea-b4d0-487bb147a93d">
        <source>getWeightInterfaceClass() : Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2019	jlger1	Initial creation 44965

*/

vars
	
begin
	if self.code = self.IQ710 then
		return CM_QPlusWeightController;
	elseif self.code = self.MT226 then
		return null;
	elseif self.code = self.SeriesW then
		return CM_SeriesWeightController;
	elseif self.code = self.Kubota then	//08 Jul 2019	NDL	TFS 44965
		return CM_KubotaWeightController;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getWeightResponseForIQ710" id="49276fc1-34a1-424a-8147-743a9ef40a35">
        <source>getWeightResponseForIQ710(	_binResponse : Binary;
							_weightType : CM_MeasurementType output;
							_rawWeight : Integer output;
							_errorString : String output
							) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2014	cnwndl1	Initial creation	Par 33268

*/
constants
	// 14/3/16  cnwns1 PAR 36286 unicode version
	S 	: Binary = #[73];
	CR 	: Binary = #[0d];
	LF 	: Binary = #[0a];
	NEG : Binary = #[2d];

vars

	stx : Binary;
	isPositive : Boolean;
	unitString : String;
	mode : String;
	status : String;
	etx : Binary;

begin

	/*
	response message format - length = 18.
	stx 		1-3 	= 's' &amp; Cr &amp; Lf
	plus/minus 	4 		= "-" for negative, or space for positive.
	weight	 	5-12	= a numbers with leading spaces to represent the number of units of weight
	units		13		= "L" = lbs, " " = none, 'K' = Kgs, 'T' = tons, 'G' = grams, 'O' = ounces
	mode		14		= "G" = gross,  "N" = nett
	status		15		= " " = valid, "I" = invalid, "M" = motion, "O" = over capacipty
	etx 		16-18 	= Cr &amp; Lf &amp; Lf
	*/
	
	if _binResponse.length &lt;&gt; 18 then
		_errorString := "Response string is not 18 characters long - Invalid format.";
		return;
	endif;
	stx := ( S &amp; CR &amp; LF ).Binary;	// 14/3/16  cnwns1 PAR 36286 unicode version
	if _binResponse[1:3] &lt;&gt; stx then
		_errorString := "Response string has invalid 'stx' value - Invalid format.";
		return;
	endif;
	etx := ( CR &amp; LF &amp; LF ).Binary;	// 14/3/16  cnwns1 PAR 36286 unicode version
	if _binResponse[16:3] &lt;&gt; etx then
		_errorString := "Response string has invalid 'etx' value - Invalid format.";
		return;
	endif;
	
	isPositive := not _binResponse[4:1] =  NEG.Binary;	// 14/3/16  cnwns1 PAR 36286 unicode version
	_rawWeight := _binResponse[5:8].ansiToString().trimBlanks.Integer;	// 14/3/16  cnwns1 PAR 36286 unicode version
	unitString := _binResponse[13:1].String;
	mode := _binResponse[14:1].String;
	status := _binResponse[15:1].String;
	
	if not isPositive and _rawWeight &lt;&gt; 0 then
		_errorString := "Weigh Bridge returned a negative weight.";
		return;
	endif;
	
	if status = " " then
		//all good
	elseif status = "I" then
		_errorString := "Weigh Bridge indicates an 'Invalid' weighing.";
		return;
	elseif status = "M" then
		_errorString := "Weigh Bridge indicates this is an 'in Motion' weighing.";
	elseif status = "O" then
		_errorString := "Weigh Bridge indicates an 'Over Capacity' weighing.";
	else
		_errorString := "Response string has invalid 'status' value - Invalid format.";
		return;
	endif;
	
	if mode = "G" then
		//all good -Gross weight
	elseif mode = "N" then
		_errorString := "Weigh Bridge indicates this is a 'Nett' weighing.";
	else
		_errorString := "Response string has invalid 'mode' value - Invalid format.";
		return;
	endif;
	
	if unitString = "L" then	//lbs
		_weightType := self.myPoundsMeasureType;
		if _weightType = null then
			_errorString := "Weigh Bridge Type 'setup issue', No pounds measure declared.";
			return;
		endif;
	elseif unitString = 'K' then	//Kgs
		_weightType := self.myKilosMeasureType;
		if _weightType = null then
			_errorString := "Weigh Bridge Type 'setup issue', No kilos measure declared.";
			return;
		endif;
	elseif unitString = 'T' then	//tons
		_weightType := self.myTonsMeasureType;
		if _weightType = null then
			_errorString := "Weigh Bridge Type 'setup issue', No tons measure declared.";
			return;
		endif;
	elseif unitString = 'G' then	//grams
		_weightType := self.myGramsMeasureType;
		if _weightType = null then
			_errorString := "Weigh Bridge Type 'setup issue', No grams measure declared.";
			return;
		endif;
	elseif unitString = 'O' then	//ounces
		_weightType := self.myOuncesMeasureType;
		if _weightType = null then
			_errorString := "Weigh Bridge Type 'setup issue', No ounces measure declared.";
			return;
		endif;
	else
		_errorString := "Response string has invalid 'units' value - Invalid format.";
		return;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_binResponse" type="Binary"/>
        <Parameter name="_weightType" type="CM_MeasurementType" usage="output"/>
        <Parameter name="_rawWeight" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getWeightResponseForSeriesW" id="a896166a-3c39-49ac-923e-618c8638e1df">
        <source>getWeightResponseForSeriesW(	_binResponse : Binary;
								_weightType : CM_MeasurementType output;
								_rawWeight : Integer output;
								_errorString : String output
								) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2017	cnwndl1	Initial creation	TFS 4383

*/

constants
	Ampersand : Binary = #[26];	// &amp;, Ascii 38
	Hash : Binary = #[23];	// #, Ascii 35
	Slower  : Binary = #[73];//	s,  Ascii 115 
	Tlower  : Binary = #[74];//	t,  Ascii 116 
	CarrRet : Binary = #[0d];  //  Cr, Ascii 13
	BackSlash : Binary = #[5c];	//  /, Ascii 92
	QuestMark : Binary = #[3f];	//	?, Ascii 63
	SpaceChar : Binary = #[20];	//  Space, Ascii 32
	Negative : Binary = #[2d];	//  -, Ascii 45
	Oupper : Binary = #[4f];	//  O, Ascii 79
	Fupper : Binary = #[46];	//  F, Ascii 70
	Lupper : Binary = #[4c];	//  L, Ascii 76
vars

	testValue : Binary;
	stx : Binary;
	backSlash : Binary;
	lowerTee : Binary;
	etx : Binary;
	rawWeight : Binary;

begin

	/*
	normal response message format - length = 13.
	stx 			1 		= '&amp;'
	deviceAddress	2-3		= A two digit numerical field representing the weigh bridge internal address.
	weight	 		4-9 	= 6 characters to represent the number of units of weight the first may be a '-' indcating a negative value
	type			10		= 't' = Gross weight
	backslash		11		= '\'
	checksum		12-13	= 
	etx				14		= Cr, The 'Carriaage return' character	
	
	This is as best we can determine based on Page 5, item 2 of the PDF attached to TFS 2862
	
	*/
	
	

	// Untested as at 24 May 2017
	// - Upadted 14 Sep 2017 to match latest attempt by Salerno to config weigh bridge resposnes
	
	_weightType := self.myKilosMeasureType;
	if _weightType = null then
		_errorString := "Weigh Bridge Type 'setup issue', No kilos measure declared.";
		return;
	endif;
	
	if _binResponse.length &lt;&gt; 14 then
		//Check for one of the known Weigh Bridge error response responses
		//&amp;aa?\ckckCR  'Incorrect Reception'
		if _binResponse.length = 9 then
			testValue := (  Ampersand &amp; Ampersand ).Binary;
			if _binResponse[1:2] = testValue then
				if _binResponse[5:1] = QuestMark.Binary then
					_errorString := "Response string is '" &amp; _binResponse.String &amp; "' - The manual says this means the weigh bridge has detected an 'Incorrect Reception'.";
					return;
				endif;
			endif;
		endif;

		_errorString := "Response string is not 14 characters long - Invalid format.";
		return;
	endif;
	
	stx := ( Ampersand ).Binary;
	if _binResponse[1:1] &lt;&gt; stx then
		_errorString := "Response string has invalid 'stx' value at pos 1, i.e. not '&amp;' - Invalid format.";
		return;
	endif;
	
	lowerTee := ( Tlower ).Binary;
	if _binResponse[10:1] &lt;&gt; lowerTee then
		_errorString := "Response string has invalid value at pos 10, i.e. not 't' - Invalid format.";
		return;
	endif;
	
	backSlash := ( BackSlash ).Binary;
	if _binResponse[11:1] &lt;&gt; backSlash then
		_errorString := "Response string has invalid value at pos 11, i.e. not '\' - Invalid format.";
		return;
	endif;
	
	etx := ( CarrRet  ).Binary;
	if _binResponse[14:1] &lt;&gt; etx then
		_errorString := "Response string has invalid 'etx' value at pos 14, i.e. not a 'Cr' - Invalid format.";
		return;
	endif;
	
	rawWeight := _binResponse[4:6];
	testValue := (  SpaceChar &amp; SpaceChar ).Binary;
	if rawWeight[1:2] = testValue then
		testValue := (  Oupper &amp; Negative &amp; Lupper &amp; Slower ).Binary;
		if rawWeight[3:4] = testValue then
			_errorString := "Response string is " &amp; _binResponse.String &amp; " - The manual says this means the weigh bridge is 'exceeding 110% of the full scale or 9 divisions above the parameter value nA55'.";
			return;
		endif;
		testValue := (  Oupper &amp; Negative &amp; Fupper &amp; Slower ).Binary;
		if rawWeight[3:4] = testValue then
				_errorString := "Response string is " &amp; _binResponse.String &amp; " - The manual says this means the weigh bridge has a 'faulty connection of the load cells or of another alarm.";
			return;
		endif;
	endif;
	
	if rawWeight[1:1] = (  Negative ).Binary then
		_errorString := "Weight value is a negative i.e. '-' at pos 4.";
		return;
	endif;
	
	_rawWeight := rawWeight.ansiToString().trimBlanks.Integer;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_binResponse" type="Binary"/>
        <Parameter name="_weightType" type="CM_MeasurementType" usage="output"/>
        <Parameter name="_rawWeight" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getWeightResponseString" id="d2323714-e76f-4890-99f7-0e82023eec1c">
        <source>getWeightResponseString(	_binResponse : Binary;
							_weightType : CM_MeasurementType output;
							_rawWeight : Integer output;
							_errorString : String output
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2014	cnwndl1	Initial creation	Par 33268
*/

vars

begin

	if self.code = self.IQ710 then
		self.getWeightResponseForIQ710(	_binResponse, _weightType, _rawWeight, _errorString );
	elseif self.code = self.SeriesW then	//24 May 2017	NDL	TFS 4383
		self.getWeightResponseForSeriesW( _binResponse, _weightType, _rawWeight, _errorString );
	else
		_errorString := "Unknown Weigh Bridge Type";
	endif;

epilog

end;</source>
        <Parameter name="_binResponse" type="Binary"/>
        <Parameter name="_weightType" type="CM_MeasurementType" usage="output"/>
        <Parameter name="_rawWeight" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="isValidCode" id="0bd43519-f5ba-4ef1-b9be-63b8f528431e">
        <source>isValidCode( _testCode : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2014	cnwndl1	Initial creation	Par 33268
//24/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars

	sttrArray : StringArray;
	str : String;

begin

	create sttrArray transient;
	sttrArray.add( self.IQ710 );
	sttrArray.add( self.Kubota );	//05 Jul 2019	NDL	TFS 44965
	sttrArray.add( self.GenericScanAPI );	// ### TFS 52773 31Mar2022 NAVPW1
	sttrArray.add( self.MT226 );
	sttrArray.add( self.SeriesW );
	
	
	if not sttrArray.includes( _testCode ) then
		str := sttrArray.asCSV(false);
		app.raiseCMException2(ValidWeighBridgeCodes,_testCode,str,null,null);
	endif;
	
epilog

	delete sttrArray;

end;</source>
        <Parameter name="_testCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e62bb425-a813-40d9-959d-d2e8acbafdda">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars
	proxy : CM_WeighBridgeObjType;
	completedOK		: Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.myGramsMeasureType := self.myGramsMeasureType;
	proxy.myKilosMeasureType := self.myKilosMeasureType;
	proxy.myOuncesMeasureType := self.myOuncesMeasureType;
	proxy.myPoundsMeasureType := self.myPoundsMeasureType;
	proxy.myTonsMeasureType := self.myTonsMeasureType;
	
	completedOK := true;
	return proxy;
	
epilog
	if not completedOK then
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="fdfe31f6-fe73-412e-adac-d8f01458c3ce">
        <updating/>
        <source>setForCreate( _proxy : CM_WeighBridgeObjType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	self.setForUpdate( _proxy );

epilog

end;</source>
        <Parameter name="_proxy" type="CM_WeighBridgeObjType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c3620819-f401-4a14-888c-4ebe7f5532d8">
        <updating/>
        <source>setForUpdate( _proxy : CM_WeighBridgeObjType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	self.code := _proxy.code;
	self.description := _proxy.description;
	
	self.myGramsMeasureType := _proxy.myGramsMeasureType;
	self.myKilosMeasureType := _proxy.myKilosMeasureType;
	self.myOuncesMeasureType := _proxy.myOuncesMeasureType;
	self.myPoundsMeasureType := _proxy.myPoundsMeasureType;
	self.myTonsMeasureType := _proxy.myTonsMeasureType;
	
	self.myRoot := _proxy.myRoot;

epilog

end;</source>
