	self.btnTransPrimary.top:=self.mulPrimaryTask.myBottomSelectedBtn.top + self.mulPrimaryTask.myBottomSelectedBtn.clientHeight + 5;

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="4486ce4c-4bb4-4ffc-af8c-1fb995a3bb74">
        <source>doSave();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2010	cnwer1	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
9/11/2018 	JLGNS1	Bug 41489: MSL - Vehicle RT config
15/09/2020	jlgdap1	TFS 49316 MTN Machine Idle Time
01/07/2021	navdap1	TFS 51409 PNL Queued Jobs in Driver Mode
15/07/2021	navdap1	TFS 51286 STWR Vehicle Apps Notification Message
01 Sep 2021 navma1  ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement
03/10/2022 navds21  TFS 50083  MTN Machine Delay Time
21 Mar 2023	jlika1	TFS 57126	CUX - Make VMT filtering configurable per RT Config
11 DEC 2025  JIRA 33504 check boxes are not saving.
18 Mar 2025	navpw1	JIRA: MTN-34259 - Added a config option to be set on a vehicle basis to Retain Cargo Id in Driver Mode for Overstowed containers

*/

vars
	realRTVehicleConfig,
	pxyRTVehicleConfig : CM_RTVehicleConfig;
	taskViewMode, 
	defaultTaskViewMode,
	defaultGraphicView : Integer;
	allAvailableViews 	: IntegerArray;
	pxyDayScreenConfig,
	pxyNightScreenConfig : CM_RTScreenConfig;
	pxyTaskView,
	pxyCargoView,
	pxyDirectorView,
	pxyPrimaryView,
	pxySeondaryView,
	pxyPrimaryCargoView,
	pxySeondaryCargoView,
	pxyPrimaryDirectorView,
	pxySeondaryDirectorView 	: EntTableView;
	selectorQuery : 	CM_SelectorQueryAccess;
	lstObject		: Object;
	terminal		: CM_Terminal;
	machineType		: CM_MachineType;
	machine 		: CM_Machine;
	allTransientCriteriaObj	: CMIF_Array;
	columnLabelsPlacement,
	rowLabelsPlacement      : Integer;
	theReturn : Integer;
begin

	if self.lstObject.listIndex &lt; 0 then
		app.msgBox(app.getErrorString(Please_select_item_update),app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	lstObject := self.lstObject.listObject;//Bug 41489
	
	realRTVehicleConfig:=self.getSelectedRTConfig(terminal,machineType,machine);
	
	create allAvailableViews transient;
	if realRTVehicleConfig = null then
		create pxyRTVehicleConfig transient;
	else
		beginLoad;
		pxyRTVehicleConfig:=realRTVehicleConfig.pxyCreateUpdateProxy;
		endLoad;
	endif;
	
	create pxyPrimaryView transient;
	self.mulPrimaryTask.getSelected(pxyPrimaryView.allEntTableRows);
	
	create pxySeondaryView transient;
	self.mulSecondaryTask.getSelected(pxySeondaryView.allEntTableRows);
	
	create pxyPrimaryCargoView transient;
	self.mulPrimaryCargo.getSelected(pxyPrimaryCargoView.allEntTableRows);
	
	create pxySeondaryCargoView transient;
	self.mulSecondaryCargo.getSelected(pxySeondaryCargoView.allEntTableRows);
	
	create pxyPrimaryDirectorView transient;
	self.mulPrimaryDirector.getSelected(pxyPrimaryDirectorView.allEntTableRows);
	
	create pxySeondaryDirectorView transient;
	self.mulSecondaryDirector.getSelected(pxySeondaryDirectorView.allEntTableRows);
	
	
	if self.chkTaskList.value and 
		self.chkTaskGetNext.value then
		taskViewMode:=CM_RTVehicleConfig.TASKVIEW_BOTH;
		if self.lblDefList.caption =   app.getErrorString(Default) then 
			defaultTaskViewMode:=CM_RTVehicleConfig.TASKVIEW_LIST;
		else	
			defaultTaskViewMode:=CM_RTVehicleConfig.TASKVIEW_GETNEXT;
		endif;
	else
		if self.chkTaskList.value  then
			taskViewMode:=CM_RTVehicleConfig.TASKVIEW_LIST;	
		elseif self.chkTaskGetNext.value then
			taskViewMode:=CM_RTVehicleConfig.TASKVIEW_GETNEXT;
		endif;
		defaultTaskViewMode:=taskViewMode;
	endif;
	
	// YA Criteria. CCMS MES 1080, #24294	15/09/2010
	if not self.chkAllowNonRT.value then
		if not self.allCriteria.isEmpty() then
			self.allCriteria.purge;	// no criteria, when checkbox unchecked
		endif;
	endif;
	if lstObject.isKindOf(CM_Terminal) then
		create allTransientCriteriaObj transient;
		self.getCriteriaAllCMIF(realRTVehicleConfig, allTransientCriteriaObj);
	endif;
	
	pxyRTVehicleConfig.setDetails(	
									taskViewMode,
									defaultTaskViewMode,
									self.chkAutoGetNext.value,
									false, // JIRA 33504 self.chkAllowEnquiry.value,
									self.chkAllowNonRT.value,
									false, // JIRA 33504 self.chkSepPickSet.value,
									self.chkAllowChgSet.value,
									self.chkAllowChgQ.value,
									self.chkAutoReseq.value,
									
									self.cmbOstowMode.listIndex-1,
									0, // JIRA 33504 self.txtHighlightHigh.text.Integer,//07/03/2011 cnwdz2 25644
									self.chkIgnoreWarn.value,
									false, // JIRA 33504 self.chkEnqCurrentQ.value,
									self.txtNumOstow.text.Integer,
									0, // JIRA 33504 self.txtNumQueries.text.Integer,
									self.txtNumQEntries.text.Integer,
									0, // JIRA 33504 self.txtNumEnquiry.text.Integer, 
									
									allAvailableViews,
									defaultGraphicView,
									columnLabelsPlacement,
									rowLabelsPlacement,
									selectorQuery,
									pxyNightScreenConfig,
									pxyDayScreenConfig,
									0, // JIRA 33504 self.txtFontSize.text.Integer,
									0, // JIRA 33504 self.txtSelFontSize.text.Integer,
									pxyCargoView,
									pxyDirectorView,
									pxyTaskView,
									
									false, // JIRA 33504 self.chkShowSecQueues.value,
									false, // JIRA 33504 self.chkDtViewPickup.value,
									false, // JIRA 33504 self.chkDtViewSetdown.value,
									false, // JIRA 33504 self.chkDisplayLeft.value,
									false, // JIRA 33504 self.chkRemoveSplit.value,
									self.locationHookCode,
									self.isoTypeHookCode,
									self.doorDirHookCode,
									self.txtAcceptDelay.text.Integer, //epr par 36549 30/6/15
									self.txtPickupDelay.text.Integer,
									false, // JIRA 33504 self.chkAutoSrchDirMatch.value, //_autoSearchDirector : Boolean		//10 Nov 2017	NDL	TFS 7427
									self.chkTandemToDiffTargets.value,	// 20/11/19 MAP TFS47394
									self.chkAllowNonRTQ.value,				// TFS 51409
									self.chkWarnChgSet.value,				// TFS 51409
									self.chkDriverMultiMove.value,           //01.09.2021 navma1 #51485
									self.chkRetainCargoIdDriverMode.value,	// ### JIRA: MTN-34259 18Mar2025 NAVPW1
									self.chkDoSwapChangeCargo.value			//29/10/2025	navkc1 JIRA 36186
									); 
	
	pxyRTVehicleConfig.setVehicleAppDetails(self.txtMachPoll.text.Integer,
											self.txtListPoll.text.Integer,
											pxyPrimaryView,
											pxySeondaryView,
											pxyPrimaryCargoView,
											pxySeondaryCargoView,
											pxyPrimaryDirectorView,
											pxySeondaryDirectorView,
											self.chkAutoPlanDriver.value, 			// epr TFS 6846 8/9/17
											self.chkDriverDismiss.value,			// TFS 51286
											self.cmbLocationDisplay.listData, 		// jlier1 TFS 51260 1/11/21		
											self.chkAllowColumnFiltering.value);	// jlika1 TFS 57126
											
	pxyRTVehicleConfig.setMachineIdleTimeDetails(self.txtIdleTime.text.trimBlanks.Integer,	// TFS 49316
												 self.txtIdleAlert.text.trimBlanks.Integer,	// TFS 49316
												 self.txtDelayTime.text.trimBlanks.Integer, //03.10.2022 navds21 TFS 50083
												 self.txtDelayAlert.text.trimBlanks.Integer, //03.10.2022 navds21 TFS 50083
												 self.chkIdleandDelayHistory.value);		//03.10.2022 navds21 TFS 50083
	// call the create trx
	//epr par 35664 2/3/15
	while true do
		if realRTVehicleConfig = null then
			app.myTrxCA.trxCreateRTVehicleConfig(pxyRTVehicleConfig, realRTVehicleConfig, allTransientCriteriaObj, terminal,machineType,machine,app.myPassport);
		else
		//call the update trx
			app.myTrxUA.trxUpdateRTVehicleConfig(pxyRTVehicleConfig, allTransientCriteriaObj, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyRTVehicleConfig;
	delete allAvailableViews;
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
		delete allTransientCriteriaObj;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getCriteriaAllCMIF" id="f805ce8c-0592-4287-962f-5d1d5f35be0e">
        <source>getCriteriaAllCMIF(_realRTVehicleConfig: CM_RTVehicleConfig; _cmifArray: CMIF_Array input);
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	MES CCMS 1080
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	criteria		: CM_YARTVConfigCriteria;
	cmifCriteria	: CMIF_YACriteriaPriority;
	cmifObject		: CMIF_Object;

begin
	
	// Create transient maintenance objects for all existing persisten criteria and mark for delete action
	if _realRTVehicleConfig &lt;&gt; null then
		foreach criteria in _realRTVehicleConfig.allCriteria do
			cmifCriteria := criteria.getTransient();
			cmifCriteria.setFlag(false, false, true);
			_cmifArray.add(cmifCriteria);
		endforeach;
	endif;
	
	// Now do all criteria on myself. Updates existing pxy criteria for existing deleted persistent criteria or create new pxy criteria for non-existing persistent one. Hope this helps.
	foreach cmifObject in self.allCriteria do
		criteria := cmifObject.CMIF_YACriteriaPriority.myProxy.CM_YARTVConfigCriteria;
		self.getCriteriaSingleCMIF(_realRTVehicleConfig, _cmifArray, criteria.myYACriteriaType, criteria.myYAData.getDataValue());
	endforeach;

end;</source>
        <Parameter name="_realRTVehicleConfig" type="CM_RTVehicleConfig"/>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaSingleCMIF" id="00ea16dc-9244-425e-8d45-37c8991510db">
        <source>getCriteriaSingleCMIF(_realRTVehicleConfig: CM_RTVehicleConfig; _cmifArray : CMIF_Array input; _criteriaType :CM_YACriteriaType; _value : Any);
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	Updates existing pxy criteria for existing deleted persistent criteria or create new pxy criteria for non-existing persistent one. Hope this helps.
			MES CCMS 1080
			
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cmifObject		: CMIF_Object;
	cmifCriteria	: CMIF_YACriteriaPriority;
	proxyCriteria	: CM_YARTVConfigCriteria;
	itemCode		: String;

begin
	// Check if a maintenance object already exists - if it does it will have a Delete action
	// Convert it to a Change action
	if _realRTVehicleConfig &lt;&gt; null then
		foreach cmifObject in _cmifArray do
			cmifCriteria 	:= cmifObject.CMIF_YACriteriaPriority;
			proxyCriteria	:= cmifCriteria.myProxy.CM_YARTVConfigCriteria;
			if proxyCriteria.myYACriteriaType = _criteriaType and cmifCriteria.isDeleted then
				// change value of existing criteria
				proxyCriteria.setProxy(proxyCriteria.myYACriteriaType, _value, proxyCriteria.code);
				cmifCriteria.setFlag(false, true, false);
				return;
			endif;
		endforeach;
	endif;
	
	// Create an Add action Criteria request
	create proxyCriteria transient;
	itemCode := _criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(_criteriaType, _value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	_cmifArray.add(cmifCriteria);
	
end;</source>
        <Parameter name="_realRTVehicleConfig" type="CM_RTVehicleConfig"/>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getHookCodeSource" id="048cacd3-8e5f-4548-96c4-2820a57f1ecf">
        <source>getHookCodeSource(rtConfig : CM_RTVehicleConfig input; _hookType : Integer; hookCode : CM_HookCode output; hookTypeObj : CM_HookType output; sourceCode : String io);
/*

Date		Who		Reason
05 February 2014	cnwer1	Initial creation PAR

*/

vars

begin
    if rtConfig &lt;&gt; null then
		if _hookType = HookType_RTConfigIsoType  then
			hookCode:=rtConfig.myIsoTypeHookCode;
		elseif _hookType = HookType_RTConfigDoorDir	 then
			hookCode:=rtConfig.myDoorDirectionHookCode;
		elseif _hookType = HookType_RTConfigLocation then	
			hookCode:=rtConfig.myLocationHookCode;
		endif;
		if hookCode &lt;&gt; null then
			hookTypeObj:=hookCode.myHookType;
			sourceCode:=hookCode.getCurrentJadeCode()	;
		endif;
	endif;
	
	if sourceCode = null then
		hookTypeObj	:=	app.myRoot.allHookTypes[_hookType];			
		if hookTypeObj &lt;&gt; null then
		
			sourceCode:= hookTypeObj.hookMethodTemplate;
		else
			return;
		endif;
	endif;
end;</source>
        <Parameter name="rtConfig" type="CM_RTVehicleConfig" usage="input"/>
        <Parameter name="_hookType" type="Integer"/>
        <Parameter name="hookCode" type="CM_HookCode" usage="output"/>
        <Parameter name="hookTypeObj" type="CM_HookType" usage="output"/>
        <Parameter name="sourceCode" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMainInfo" id="71a5319e-d16a-477b-935b-9f1675485a45">
        <source>getMainInfo(_object : Object; _rtConfig : CM_RTVehicleConfig) : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2010	cnwer1	Initial creation

*/

vars
	title : String;
begin

	if _object.isKindOf(CM_Machine) then
		title:=_object.CM_Machine.code;
		if _rtConfig.myTerminalMachineType &lt;&gt; null then
			title:= title &amp; " inherited settings from Machine Type";
		elseif _rtConfig.myTerminal &lt;&gt; null then
			title:= title &amp; " inherited settings from Terminal";// &amp; _rtConfig.myTerminal.code;
		endif;
	elseif _object.isKindOf(CM_MachineType) then
		title:=_object.CM_MachineType.description;
		if _rtConfig.myTerminal &lt;&gt; null then
			title:= title &amp; " inherited settings from Terminal";// &amp; _rtConfig.myTerminal.code;
		endif;
	elseif  _object.isKindOf(CM_Terminal) then
		title:=_object.CM_Terminal.code;
	endif;

	return title;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_rtConfig" type="CM_RTVehicleConfig"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedRTConfig" id="54b4d3e5-b883-40ff-9b06-95fc76d187a9">
        <source>getSelectedRTConfig(_terminal : CM_Terminal io;
					_machineType : CM_MachineType io;
					_machine : CM_Machine io) :CM_RTVehicleConfig protected;
/*

Date		Who		Reason
05 February 2014	cnwer1	Initial creation PAR

*/

vars
	realRTVehicleConfig : CM_RTVehicleConfig;
	termMachConfig : CM_RTTermMachTypeConfig;
	lstObject 	:  Object;
begin
	if self.lstObject.listIndex &lt; 0 then
		return null;
	endif;
	
	lstObject:=self.lstObject.listObject;
	if lstObject.isKindOf(CM_Terminal) then
		_terminal:=lstObject.CM_Terminal;
		realRTVehicleConfig:=_terminal.myRTVehicleConfig;
		
	elseif lstObject.isKindOf(CM_MachineType) then
		_machineType:=lstObject.CM_MachineType;
		_terminal:=self.myTerminal;
		termMachConfig:=_terminal.allRTTermMachTypeConfigs[_machineType];
		if termMachConfig &lt;&gt; null then
			realRTVehicleConfig:=termMachConfig.myRTVehicleConfig;
		endif;
	elseif lstObject.isKindOf(CM_Machine) then
		_machine:=lstObject.CM_Machine;
		realRTVehicleConfig:=_machine.myRTVehicleConfig;
	endif;
	
	return realRTVehicleConfig;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal" usage="io"/>
        <Parameter name="_machineType" type="CM_MachineType" usage="io"/>
        <Parameter name="_machine" type="CM_Machine" usage="io"/>
        <ReturnType type="CM_RTVehicleConfig"/>
    </JadeMethod>
