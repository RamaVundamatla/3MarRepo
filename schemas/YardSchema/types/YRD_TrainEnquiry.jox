    <JadeMethod name="addToolbarControls" id="193de246-38c2-45e0-b2e6-b84a481b6988">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// Changed On   	Changed By  	Reason
// 20 Apr 2022      navtnr20			TFS 53142 Cargo Forecast on Voyage &amp; Train
// ---------------------------------------------------------------------------
vars
	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
// PAR 23176 	frm.addButton(self.btnPrintCargo, CMUI_Toolbar.Control_Alignment_Left);
// PAR 23176	frm.addButton(self.btnPrintManifest, CMUI_Toolbar.Control_Alignment_Left);	// PAR 19913
// PAR 23176	frm.addButton(self.btnPrintPlainM, CMUI_Toolbar.Control_Alignment_Left);	// cnwjo3
	frm.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCopyTrain, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCargoForecast,CMUI_Toolbar.Control_Alignment_Left);		//25-Apr-2022	TFS 53142
	
	//frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnAddRequest, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnMoveToRail, CMUI_Toolbar.Control_Alignment_Left); DQ SAID NO 5/8/9
//	frm.addButton(self.btnConfirmIn, CMUI_Toolbar.Control_Alignment_Left); DQ SAID NO
//	frm.addButton(self.btnConfirmOut, CMUI_Toolbar.Control_Alignment_Left); DQ SAID NO
//	frm.addButton(self.btnClearRake, CMUI_Toolbar.Control_Alignment_Left); taken out for now, problems with it currently not cleaning up its jobs and if then this is re run might lose TI info on wagons.
	
	frm.addButton(self.btnRemarks, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnWagonIn, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnWagonOut, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEnquiryRec, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEnquiryRel, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left);
	
		

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	
	inheritMethod();
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addFrame(self.frmSwitchViews,CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="29fc9065-c263-4104-ae80-910c376f4257">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	queryToolbar			: CMUI_Toolbar;
begin
	inheritMethod();
	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnSetToday, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnDefault, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="beginTimerForRefresh" id="68a113a5-0381-41c1-9ab2-53ea98728dc7">
        <updating/>
        <source>beginTimerForRefresh()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2009	cnwmd1	Initial creation

*/

vars

begin
	if (not self.timerRefreshActive) then
		self.timerRefreshActive := true;
		self.beginTimer(60000, Timer_OneShot, Timer_Refresh);
	endif;
epilog

end;</source>
    </JadeMethod>
