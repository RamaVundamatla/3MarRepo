    <JadeMethod name="utlUpdateDataAccessController" id="26626ad7-6ae2-490a-88c9-cd4b539c72fa">
        <source>utlUpdateDataAccessController(_dAC : CM_DataAccessController io; _allObjects : CM_ObjectSetActual; 
							_mustNotBeIncluded, _includeNull : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	// Always initialize the activity first
	initialiseActivity;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_dAC, true);
	endif;

	_dAC.setForUpdate(_allObjects, _mustNotBeIncluded, _includeNull);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_dAC, false);
	endif;

end;</source>
        <Parameter name="_dAC" type="CM_DataAccessController" usage="io"/>
        <Parameter name="_allObjects" type="CM_ObjectSetActual"/>
        <Parameter name="_mustNotBeIncluded" type="Boolean"/>
        <Parameter name="_includeNull" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDataDumpClass" id="57202fb5-bd5e-4916-ba61-1dcda42179b4">
        <source>utlUpdateDataDumpClass(_proxyDataDumpClass:CM_DataDumpClass; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
	realDataDumpClass : CM_DataDumpClass;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();

	_proxyDataDumpClass.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyDataDumpClass.pxyGetRealObjectAndEdition(realDataDumpClass, expectedEdition);
	
	if realDataDumpClass = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DataDumpClass.name, null, null);
		return;
	endif;

	app.myValUA.valDataDumpClass(realDataDumpClass, _proxyDataDumpClass);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realDataDumpClass);

	if _passport.noErrors and realDataDumpClass.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'dataDumpClass', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDataDumpClass, true);
	endif;
	
	if _passport.noErrors then
		realDataDumpClass.setForUpdate(_proxyDataDumpClass);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDataDumpClass, false);
	endif;
end;</source>
        <Parameter name="_proxyDataDumpClass" type="CM_DataDumpClass"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDataDumpExtrClassCmpt" id="9b80ade8-b044-4d06-be51-a7ef9d45bc19">
        <source>utlUpdateDataDumpExtrClassCmpt(
		_realExtractClass : CM_DataDumpExtractClass input; _expectedEdition: Integer;
		_updateExtractedUpTo: Boolean; _extractedFromDateTime, _extractedUpTo, _startTs, _finishTs: TimeStamp;
		_numCreates, _numUpdates, _numDeletes: Integer; _systemAlertCreated: Boolean;
		_userCode, _userName: String; _deleteOids, _addOids, _updateOids : StringArray; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.initialiseActivity();
	
	if _realExtractClass = null then
		self.raiseExceptionIfNull(_realExtractClass, 'dataDumpExtractClass');
	endif;

	_realExtractClass.raiseExceptionIfTransient(method);

	app.setContinueCMExceptions(true);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_realExtractClass);

	if _passport.noErrors and _realExtractClass.edition &lt;&gt; _expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'dataDumpExtractClass', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realExtractClass, true);
	endif;
	
	if _passport.noErrors then
		_realExtractClass.setExtractUpToCreateHistory(
				_updateExtractedUpTo, _extractedFromDateTime, _extractedUpTo,
				_startTs, _finishTs, _numCreates, _numUpdates, _numDeletes,
				_systemAlertCreated, _userCode, _userName, _deleteOids, _addOids, _updateOids);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realExtractClass, false);
	endif;
end;</source>
        <Parameter name="_realExtractClass" type="CM_DataDumpExtractClass" usage="input"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_updateExtractedUpTo" type="Boolean"/>
        <Parameter name="_extractedFromDateTime" type="TimeStamp"/>
