        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbStevedore_displayEntry(_combobox: CMUI_FieldComboBoxControl input; _obj: Any; _index: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
03 Aug 2022 navds20	Bug 54202: EUP - Combo Boxes not adhereing to configuration (operator and Stevedore)

*/

vars

begin
	if _obj.CM_Stevedore.notAvailableForEntry then							
		return null;															
	endif;																		
	
	//return _obj.CM_Stevedore.code &amp; Tab &amp; _obj.CM_Stevedore.description; // 03/08/2022 NAVDS20 TFS 54202
	
	//start 03/08/2022 NAVDS20 TFS 54202
	if app.myRoot.getConfig(ComboByNameStevedore).Boolean then
		return _obj.CM_Stevedore.description;
	else
		return _obj.CM_Stevedore.code &amp; Tab &amp; _obj.CM_Stevedore.description;
	endif;
	//end 03/08/2022 NAVDS20 TFS 54202
	
epilog

end;</source>
