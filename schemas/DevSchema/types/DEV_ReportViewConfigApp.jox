    <JadeMethod name="displayMessages" id="ae4edf67-fad1-42bf-a755-c0b2e3860a69">
        <source>displayMessages(_msg : String; _color : Integer; _obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023	navkc1	Initial creation

*/

vars
	idx		: Integer;
begin
	
	idx := self.tblOutput.addItemObject(_obj, _msg);
	self.tblOutput.accessRow(idx).backColor := _color;
	
epilog

end;</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="displayView" id="c1fdf734-5f8d-428a-88a4-581fbefe8328">
        <source>displayView(_theObject : Object) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023	navkc1	Initial creation

*/

vars

begin
	if _theObject = null then
		return null;
	else
		return _theObject.getPropertyValue("name").String;
	endif;
epilog

end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doAddFieldToView" id="71a5f2da-9e19-4cca-92d7-98ba6958b1e7">
        <source>doAddFieldToView();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2023	navkc1	Initial creation

*/

vars
	
	allTypes				: MemberKeyDictionary;
	allFields				: MemberKeyDictionary;
	
	scm						: Schema;
	
	jrdFeatureClass			: Class;
	jrdPathClass			: Class;
	
	view 					: Object;
	type					: Object;
	field					: Object;
	obj						: Object;
	
	typeEnabled				: Boolean;
	fieldEnabled			: Boolean;
	added					: Boolean;
	
	selectedType			: String;
	viewName				: String;
	typeName				: String;
	fieldName				: String;
	msg						: String;
	selectedAttrName		: String;
	selectedAttrNameNew		: String;
	alias					: String;
	
	counter					: Integer;
	row						: Integer;
	
	allSelectedFields		: ObjectArray;
	allSelectedViews		: ObjectArray;
	
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create allSelectedViews transient;
	create allSelectedFields transient;
	
	self.tblOutput.rows := self.tblOutput.fixedRows;
	
	self.getAllSelectedAttributes(allSelectedFields);
	
	if allSelectedFields.isEmpty() then
		msg := "Please select a field";
		self.displayMessages(msg, Red, null);
		return;
	endif;
	
	self.msgViewsAddType.getSelected(allSelectedViews);
	
	if allSelectedViews.isEmpty() then
		msg := "Please select a view";
		self.displayMessages(msg, Red, null);
		return;
	endif;
	
	scm := rootSchema.getSchema(JadeReportWriterSchema);
	jrdFeatureClass := scm.getClass(JRDReportingFeatureDefn);
	jrdPathClass := scm.getClass(JRDReportingPathDefn);
	
	selectedType := self.cmbClass.listObject.Class.name;
	
	// Loop selected views
	foreach view in allSelectedViews do : viewLoop
		typeEnabled := false;
		viewName := view.getPropertyValue("name").String;
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		// Loop all the types 
		foreach type in allTypes discreteLock do : typeLoop
			typeName := type.getPropertyValue("typeName").String;
			
			if typeName &lt;&gt; selectedType then
				continue;
			endif;
			
			// Found the Type
			typeEnabled := true;
			
			allFields := type.getPropertyValue("allReportingFields").MemberKeyDictionary;
			
			// Loop selected attributes
			counter := 0;
			foreach obj in allSelectedFields do : selectedAttrLoop
				
				// Find the object in the Fields table, get the Alias text
				alias := null;
				row := 0;
				if self.tblAttributesData.findObjectInRow(obj, row) then
					alias := self.tblAttributesData.accessCell(row, 3).text;
				endif;
				
				if obj.isKindOf(Method) then
					selectedAttrName := obj.Method.name;
				elseif obj.isKindOf(Property) then
					selectedAttrName := obj.Property.name;
				endif;
				
				fieldEnabled := false;
				
				// Loop enabled fields
				foreach field in allFields discreteLock do : fieldLoop
					if field.class().name = JRDReportingFeatureDefn then
						fieldName := field.getPropertyValue("featureName").String;
					else
						fieldName := field.getPropertyValue("pathName").String;
					endif;
					
					if fieldName &lt;&gt; selectedAttrName then
						continue;
					endif;
					
					// Found the feature
					fieldEnabled := true;
					msg := selectedAttrName &amp; " is already enabled in " &amp; viewName;
					self.displayMessages(msg, Red, null);
					break fieldLoop;
				endforeach;
				
				// Feature is not enabled, we want to enable it
				if not fieldEnabled then
					beginTransaction;
					// This is for references, i.e. myBank.code; // Not available yet
					if selectedAttrName.cnContains(".") then
						create field as jrdPathClass persistent;
						field.setPropertyValue("pathName", selectedAttrName);
					// This is for attributes
					else
						create field as jrdFeatureClass persistent;
						field.setPropertyValue("featureName", selectedAttrName);
					endif;
					
					// Need to check for duplicate key alias
					if alias &lt;&gt; null then
						selectedAttrNameNew := alias;
					else
						selectedAttrNameNew := selectedAttrName;
					endif;
					
					while true do
						if allFields.getAtKey(selectedAttrNameNew) = null then
							break;
						endif;
						
						counter += 1;
						selectedAttrNameNew := selectedAttrName &amp; "_" &amp; counter.String;
					endwhile;
					
					field.setPropertyValue("alias", selectedAttrNameNew);
					field.setPropertyValue("myReportingTypeDefn", type);
					commitTransaction;
					
					msg := selectedAttrName &amp; " (Alias - " &amp; selectedAttrNameNew &amp; ") is now added to " &amp; viewName;
					self.displayMessages(msg, LightGreen, field);
					added := true;
				endif;
			endforeach;
		endforeach;
		
		// Type is not enabled
		if not typeEnabled then
			msg := selectedType &amp; " is not enabled in " &amp; viewName;
			self.displayMessages(msg, Red, null);
			continue;
		endif;
		
	endforeach;
	
	if added then
		self.btnUndo.visible := true;
	endif;
	
	// Refresh the table to have the color updated
	self.doPopulateTblAttributes(self.cmbClass.listObject.Class, allSelectedFields);
	self.doSelectField();
	
epilog
	delete allSelectedViews;
	delete allSelectedFields;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddTypeToView" id="c715f83d-d40f-4ea7-9dcc-6fb6e7aa9353">
        <source>doAddTypeToView();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navkc1	Initial creation

*/

vars
	allSelectedViews		: ObjectArray;
	
	allTypes				: MemberKeyDictionary;
	
	scm						: Schema;
	
	jrdTypeClass			: Class;
	
	view 					: Object;
	type					: Object;
	
	typeEnabled				: Boolean;
	added					: Boolean;
	
	selectedType			: String;
	viewName				: String;
	typeName				: String;
	msg						: String;
	
	
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create allSelectedViews transient;
	
	self.tblOutput.rows := self.tblOutput.fixedRows;
	
	scm := rootSchema.getSchema(JadeReportWriterSchema);
	jrdTypeClass := scm.getClass(JRDReportingTypeDefn);
	
	self.msgViewsAddType.getSelected(allSelectedViews);
	
	selectedType := self.cmbClass.listObject.Class.name;
	
	if allSelectedViews.isEmpty() then
		msg := "Please select a view";
		self.displayMessages(msg, Red, null);
		return;
	endif;
	
	// Loop selected views
	foreach view in allSelectedViews do : viewLoop
		typeEnabled := false;
		viewName := view.getPropertyValue("name").String;
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		// Loop all the types 
		foreach type in allTypes discreteLock do : typeLoop
			typeName := type.getPropertyValue("typeName").String;
			
			if typeName &lt;&gt; selectedType then
				continue;
			endif;
			
			// Found the Type
			typeEnabled := true;
			break typeLoop;
		endforeach;

		// Type is enabled, display message
		if typeEnabled then
			msg := selectedType &amp; " is already enabled in " &amp; viewName;
			self.displayMessages(msg, Red, null);
		// Type is not enabled, enable it
		else
			beginTransaction;
			create type as jrdTypeClass persistent;
			type.setPropertyValue("alias", selectedType);
			type.setPropertyValue("myReportingView", view);
			type.setPropertyValue("typeName", selectedType);
			commitTransaction;
			
			msg := selectedType &amp; " is now enabled in " &amp; viewName;
			self.displayMessages(msg, LightGreen, type);
			added := true;
		endif;
		
	endforeach;
	
	if added then
		self.btnUndo.visible := true;
	endif;
	
epilog
	delete allSelectedViews;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckForDuplicateFields" id="9ea36072-0650-4ba4-8d8a-9e94bd893fb6">
        <source>doCheckForDuplicateFields();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2023	navkc1	Initial creation

*/

vars
	allTypes				: MemberKeyDictionary;
	allFields				: MemberKeyDictionary;
	
	allFieldsToCheckSorted	: DynaDictionary;
	
	jdo						: JadeDynamicObject;
	
	view 					: Object;
	type					: Object;
	field					: Object;
	obj						: Object;
	
	msg						: String;	
	viewName				: String;
	typeName				: String;
	fieldName				: String;
	prevField				: String;
	
	viewHasDuplicates		: Boolean;
	
	color					: Integer;
	
	allSelectedViews		: ObjectArray;
	allFieldsToCheck		: StringArray;
	
	scm						: Schema;
	
	jrdFeatureClass			: Class;
	jrdPathClass			: Class;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create allFieldsToCheck transient;
	create allFieldsToCheckSorted transient;
	create allSelectedViews transient;
	
	self.msgViewsChkDup.getSelected(allSelectedViews);
	
	// If nothing is selected, do all views
	if allSelectedViews.isEmpty() then
		self.allViews.copy(allSelectedViews);
	endif;
	
	self.tblOutput.rows := self.tblOutput.fixedRows;
	
	scm := rootSchema.getSchema(JadeReportWriterSchema);
	jrdFeatureClass := scm.getClass(JRDReportingFeatureDefn);
	jrdPathClass := scm.getClass(JRDReportingPathDefn);
	
	allFieldsToCheckSorted.setMembership(JadeDynamicObject);
	allFieldsToCheckSorted.addMemberKey(JadeDynamicObject::name.name, false, true);
	allFieldsToCheckSorted.endKeys(true);

	// Report Views
	foreach view in allSelectedViews do
		viewName := view.getPropertyValue("name").String;
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		
		viewHasDuplicates := false;
		// Types/Classes
		foreach type in allTypes discreteLock do
			typeName := type.getPropertyValue("typeName").String;
			allFields := type.getPropertyValue("allReportingFields").MemberKeyDictionary;
			
			allFieldsToCheck.clear();
			allFieldsToCheckSorted.clear();
			// First round to get all fields we have - Create DynaObject for each fields and add them to sorted array, so that they are grouped together in output message;
			foreach field in allFields discreteLock do
				create jdo transient;
				
				if field.class().name = JRDReportingFeatureDefn then
					fieldName := field.getPropertyValue("featureName").String;
				else
					fieldName := field.getPropertyValue("pathName").String;
				endif;
				
				jdo.setPropertyValue("name", fieldName);
				jdo.addProperty("alias", String);
				jdo.setPropertyValue("alias", field.getPropertyValue("alias").String);
				
				allFieldsToCheck.add(fieldName);
				allFieldsToCheckSorted.add(jdo);
			endforeach;
			
			// Second round to check for duplicates
			foreach obj in allFieldsToCheckSorted discreteLock do
				
				jdo := obj.JadeDynamicObject;
				fieldName := jdo.getPropertyValue("name").String;
				
				// We have duplicates here
				if allFieldsToCheck.countOf(fieldName) &gt; 1 then
					viewHasDuplicates := true;
					
					msg := "Duplicate field '" &amp; fieldName &amp; "'" &amp; " - Alias '" &amp; jdo.getPropertyValue("alias").String &amp; "' found in Type " &amp; typeName &amp; " , View " &amp; viewName;
					
					if prevField = fieldName then
						color := self.tblOutput.accessRow(self.tblOutput.rows).backColor;
					else
						if self.tblOutput.rows = 0 or self.tblOutput.accessRow(self.tblOutput.rows).backColor = LightBlue then
							color := White;
						else
							color := LightBlue;
						endif;
					endif;
					self.displayMessages(msg, color, null);
					prevField := fieldName;
					
				endif;
			endforeach;
			
		endforeach;
		
		if not viewHasDuplicates then
			msg := viewName &amp; " does not have duplicate fields.";
			self.displayMessages(msg, White, null);
		endif;
	endforeach;
	
epilog
	delete allFieldsToCheck;
	allFieldsToCheckSorted.purge();
	delete allFieldsToCheckSorted;
	delete allSelectedViews;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doChkShowMethodClick" id="0d10dccf-a9e3-4532-9502-e2c2e10df085">
        <source>doChkShowMethodClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2023	navkc1	Initial creation

*/

vars
	startRow			: Integer;
	row					: Integer;
	rows				: Integer;
	
	obj					: Object;
	view				: Object;
	type				: Object;
	
	mtd					: Method;
	
	showMethod			: Boolean;
	class				: Class;
	className			: String;
	
	allSelectedViews	: ObjectArray;
	
	allTypes			: MemberKeyDictionary;
	
begin
	
	create allSelectedViews transient;
	
	class := self.cmbClass.listObject.Class;
	
	if class = null then
		return;
	endif;
	
	className := class.name;
	
	self.msgViewsAddType.getSelected(allSelectedViews);
	
	showMethod := self.chkShowMethod.value;
	
	beginTransaction;
	foreach view in allSelectedViews do
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		
		type := allTypes.getAtKey(className, null);
		
		if type = null then
			continue;
		endif;
		
		type.setPropertyValue("showMethodsWithParameters", showMethod);
		
	endforeach;
	commitTransaction;
	
	startRow := self.tblAttributesData.fixedRows + 1;
	rows := self.tblAttributesData.rows;
	
	foreach row in startRow to rows do
		obj := self.tblAttributesData.accessRow(row).itemObject;
		
		if obj = null or not obj.isKindOf(Method) then
			continue;
		endif;
		
		mtd := obj.Method;
		
		if mtd.getParameters().size() = 0 then
			continue;
		endif;
		
		if mtd.getParameters().size() &gt; 0 and showMethod then
			self.tblAttributesData.accessedRow.visible := true;
		else
			self.tblAttributesData.accessedRow.visible := false;
		endif;
		
	endforeach;
	
epilog
	delete allSelectedViews;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteSelectedErrors" id="bc0f4538-4f77-4c4f-b0dd-34d840840b6f">
        <updating/>
        <source>doDeleteSelectedErrors() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2023	navkc1	Initial creation

*/

vars
	obj	: Object;
	tbl	: CM_DataTable;
begin
	tbl := self.tblOutput;
	
	if tbl.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	if app.msgBox("Confirm delete the selected object(s)? This action cannot be undone", "Confim", MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	
	beginTransaction;
		foreach obj in tbl.allSelectedObjects do
			if not app.isValidObject(obj) then
				continue;
			endif;
			delete obj;
		endforeach;
	commitTransaction;
	
	self.doFindPotentialErrors();
	
	app.msgBox("Selected object(s) are deleted", "Deleted", MsgBox_OK_Only);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterFieldTable" id="c833c2f8-29c4-4b34-a4b7-086c9eaabfd6">
        <source>doFilterFieldTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2023	navkc1	Initial creation

*/

vars
	text		: String;
	cellText	: String;

	row			: Integer;
	start		: Integer;
	totalRows	: Integer;
	totalCols	: Integer;
	col			: Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	text := self.txtFilter.text.toUpper();
	
	start := self.tblAttributesData.fixedRows + 1;
	totalRows := self.tblAttributesData.rows;
	
	// Clear filter, display all rows;
	if text = null then
		foreach row in start to totalRows do
			self.tblAttributesData.accessRow(row);
			self.tblAttributesData.accessedRow.visible := true;
		endforeach;
		self.tblAttributesData.topRow := 1;
		return;
	endif;
	
	totalCols := self.tblAttributesData.columns;
	// Filter table
	foreach row in start to totalRows do : rowLoop
		self.tblAttributesData.accessRow(row);
		
		foreach col in 1 to totalCols do : cellLoop
			cellText := self.tblAttributesData.accessCell(row, col).text.toUpper();
			
			if cellText.length() &gt; 0 and cellText.pos(text, 1) &gt; 0 then
				self.tblAttributesData.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblAttributesData.accessedRow.visible := false;
	endforeach;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFindPotentialErrors" id="d0d46bd3-6f96-47f6-b286-232590ffd33d">
        <updating/>
        <source>doFindPotentialErrors() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2023	navkc1	Initial creation

*/

vars
	allTypes				: MemberKeyDictionary;
	allFields				: MemberKeyDictionary;
	
	view 					: Object;
	type					: Object;
	field					: Object;
	
	msg						: String;	
	viewName				: String;
	typeName				: String;
	fieldName				: String;
	
	allSelectedViews		: ObjectArray;
	
	scm						: Schema;
	
	jrdFeatureClass			: Class;
	jrdPathClass			: Class;
	
	validateMsg				: String;
begin

	app.mousePointer := MousePointer_HourGlass;
	
	create allSelectedViews transient;
	
	self.msgViewPotentialErr.getSelected(allSelectedViews);
	
	// If nothing is selected, do all views
	if allSelectedViews.isEmpty() then
		self.allViews.copy(allSelectedViews);
	endif;
	
	self.tblOutput.rows := self.tblOutput.fixedRows;
	
	scm := rootSchema.getSchema(JadeReportWriterSchema);
	jrdFeatureClass := scm.getClass(JRDReportingFeatureDefn);
	jrdPathClass := scm.getClass(JRDReportingPathDefn);
	
	// Report Views
	foreach view in allSelectedViews do
		viewName := view.getPropertyValue("name").String;
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		
		// Types/Classes
		foreach type in allTypes discreteLock do
			typeName := type.getPropertyValue("typeName").String;
			allFields := type.getPropertyValue("allReportingFields").MemberKeyDictionary;
			
			foreach field in allFields discreteLock do
				validateMsg := null;
				if field.class().name = JRDReportingFeatureDefn then
					fieldName := field.getPropertyValue("featureName").String;
				else
					fieldName := field.getPropertyValue("pathName").String;
				endif;
				
				// Get Validate message
				validateMsg := field.sendMsg("validate").String;
				
				// There could be other validate message, this one is our concern for now
				if validateMsg = "Feature does not exist" then
					msg := "View " &amp; viewName &amp; ", Type " &amp; typeName &amp; ", Field "  &amp; fieldName &amp; " - " &amp; validateMsg;
					self.displayMessages(msg, Red, field);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
epilog
	delete allSelectedViews;
	app.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenReportConfig" id="d3a20f14-9167-4c3a-ad71-1f4d3ee047bf">
        <source>doOpenReportConfig();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navkc1	Initial creation

*/

vars
	jrwm	: JadeReportWriterManager;
begin
	create jrwm transient;
	jrwm.startReportWriterConfiguration(app.userName(), CM_ReportWriterSecurity);
epilog
	delete jrwm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateTblAttributes" id="2e0f94d3-e6a0-42b5-b1c0-e3836ce1a3b7">
        <source>doPopulateTblAttributes(_class : Class; _allSelectedFields : ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023	navkc1	Initial creation

*/

vars
	allProps				: PropertyColl;
	prop					: Property;
	
	allMethods				: MethodSet;
	mtd						: Method;
	
	allTypes				: MemberKeyDictionary;
	
	view 					: Object;
	type					: Object;
	obj						: Object;
	
	typeName				: String;
	propName				: String;
	selectedClass			: String;
	string					: String;
	
	index					: Integer;
	
	found					: Boolean;
	allEnabled				: Boolean;
	halfEnabled				: Boolean;
	notEnabled				: Boolean;
	isMethod				: Boolean;
	updateSelectedOnly		: Boolean;
	mtdWithParam			: Boolean;
	
	foundInAllTypes			: BooleanArray;
	
	allSelectedViews		: ObjectArray;
	allFieldsToProcess		: ObjectArray;
	
	returnType				: Type;

begin
	app.mousePointer := MousePointer_HourGlass;
	
	create allProps transient;
	create allSelectedViews transient;
	create allMethods transient;
	create foundInAllTypes transient;
	create allFieldsToProcess transient;
	
	allProps := _class.allPropertiesUpTo(_class);
	_class.allMethods(allMethods);
	
	// If we have something in the collection, do those only
	updateSelectedOnly := _allSelectedFields &lt;&gt; null and _allSelectedFields.isNotEmpty();
	
	if updateSelectedOnly then
		_allSelectedFields.copy(allFieldsToProcess);
	else
		self.tblAttributesData.rows := self.tblAttributesData.fixedRows;
		allProps.copy(allFieldsToProcess);
		allMethods.copy(allFieldsToProcess);
	endif;
	
	self.msgViewsAddType.getSelected(allSelectedViews);
	
	selectedClass := _class.name;
	
	// Loop Properties
	foreach obj in allFieldsToProcess do
		isMethod := false;
		found := false;
		mtdWithParam := false;
		foundInAllTypes.clear();
		
		if obj.isKindOf(Method) then
			isMethod := true;
			mtd := obj.Method;
			propName := mtd.name;
			if not mtd.returnIsPrim() then
				continue;
			endif;
			if mtd.getParameters().size() &gt; 0 then
				mtdWithParam := true;
			endif;
		else
			prop := obj.Property;
			propName := prop.name;
		endif;
		
		// Loop Views
		foreach view in allSelectedViews do : loopView
			allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
			found := false;
			// Loop Types
			foreach type in allTypes discreteLock do  : loopType
				
				typeName := type.getPropertyValue("typeName").String;
				
				if typeName &lt;&gt; selectedClass then
					continue;
				endif;
				
				// Check is prop enabled in view
				if self.isPropEnabled(view, type, propName) then
					found := true;
					foundInAllTypes.add(found);
					continue loopView;
				endif;
				
			endforeach;
			foundInAllTypes.add(found);
		endforeach;
		
		// Add property to table
		if isMethod then
			returnType := mtd.getTypeOfReturnType();
			string := propName &amp; Tab &amp; "Method: " &amp; returnType.name;
		else
			string := propName &amp; Tab &amp; prop.type.name;
		endif;
		
		if updateSelectedOnly then
			// Update selected only, fields already in the table, find and update it;
			index := 0;
			self.tblAttributesData.findObjectInRow(obj, index);
		else
			// Refreshing whole table, add this to table
			index := tblAttributesData.addItemObject(obj, string);
		endif;
		// Check is Property enabled in all views, set color
		allEnabled := foundInAllTypes.size() &gt; 0 and foundInAllTypes.countOf(false) = 0;
		halfEnabled := foundInAllTypes.countOf(true) &gt; 0 and foundInAllTypes.countOf(false) &gt; 0;
		notEnabled := foundInAllTypes.size() &gt; 0 and foundInAllTypes.countOf(true) = 0;
		
		// Set color 
		if allEnabled then
			self.tblAttributesData.accessRow(index).backColor := LightGreen;
		elseif halfEnabled then
			self.tblAttributesData.accessRow(index).backColor := Cn_Orange;
		elseif notEnabled then
			self.tblAttributesData.accessRow(index).backColor := LightRed;
		endif;
		
		if mtdWithParam then
			if self.chkShowMethod.value then
				self.tblAttributesData.accessRow(index).visible := true;
			else
				self.tblAttributesData.accessRow(index).visible := false;
			endif;
		endif;
		
	endforeach;
	
epilog
	delete allProps;
	delete allSelectedViews;
	delete allMethods;
	delete foundInAllTypes;
	delete allFieldsToProcess;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_allSelectedFields" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doResetMsgColor" id="09804bc6-1c97-45c0-8518-a68c72dc0f38">
        <source>doResetMsgColor();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2023	navkc1	Initial creation

*/

vars
	index		: Integer;
	listSize	: Integer;
	
begin
	listSize := self.msgViewsAddType.myAvailableListBox.listCount();
	
	foreach index in 1 to listSize do
		self.msgViewsAddType.myAvailableListBox.itemBackColor[index] := White;
	endforeach;
	
	listSize := self.msgViewsAddType.mySelectedListBox.listCount();
	
	foreach index in 1 to listSize do
		self.msgViewsAddType.mySelectedListBox.itemBackColor[index] := White;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="7223b822-c536-418f-9069-070b976f7baa">
        <source>doResize();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023	navkc1	Initial creation

*/

vars

begin
	self.msgViewsAddType.cnEcResizeContents();
	self.msgViewsChkDup.cnEcResizeContents();
	self.msgViewPotentialErr.cnEcResizeContents();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectField" id="50422899-0e09-4b6a-90cc-32e79a97dabc">
        <source>doSelectField();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2023	navkc1	Initial creation

*/

vars
	index	 				: Integer;
	listSize 				: Integer;
	typeName				: String;
	
	allSelectedViews		: ObjectArray;
	found					: Boolean;
	
	allTypes				: MemberKeyDictionary;
	
	view 					: Object;
	type					: Object;
	
	selectedProp			: Object;
	
	propName				: String;
	class					: Class;
	
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create allSelectedViews transient;
	
	selectedProp := self.tblAttributesData.allSelectedObjects.last();
	
	if selectedProp.isKindOf(Method) then
		propName := selectedProp.Method.name;
	elseif selectedProp.isKindOf(Reference) then
		propName := selectedProp.Reference.name;
	elseif selectedProp.isKindOf(Property) then
		propName := selectedProp.Property.name;
	else
		return;
	endif;
	
	class := self.cmbClass.listObject.Class;
	
	// MSG reset all color to white
	self.doResetMsgColor();	
	
	// Get selected views
	self.msgViewsAddType.getSelected(allSelectedViews);
	
	// Loop views
	foreach view in allSelectedViews do : viewLoop
		
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		found := false;
		
		// Loop types
		foreach type in allTypes do : viewType
			typeName := type.getPropertyValue("typeName").String;
			
			if typeName &lt;&gt; class.name then
				continue;
			endif;
			
			// Property/Method is enabled in the view
			if self.isPropEnabled(view, type, propName) then
				found := true;
				break viewType;
			endif;
		endforeach;
		
		// MSG set view color 
		listSize := self.msgViewsAddType.mySelectedListBox.listCount();
		
		foreach index in 1 to listSize do
			if self.msgViewsAddType.mySelectedListBox.itemObject[index] &lt;&gt; view then
				continue;
			endif;
			// Prop/Method is enabled, Green color
			if found then
				self.msgViewsAddType.mySelectedListBox.itemBackColor[index] := LightGreen;
			// Prop/Method is enabled, Red color
			else
				self.msgViewsAddType.mySelectedListBox.itemBackColor[index] := LightRed;
			endif;
		endforeach;
	endforeach;
	
	
epilog
	delete allSelectedViews;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableContext" id="4be0dcce-06b6-4e05-84d0-972bc291d2af">
        <updating/>
        <source>doTableContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	xLeft	: Real;
	yTop	: Real;
	
begin
	
	if not self.shtPotentialError.isMySheetVisible() then
		return false;
	endif;
	
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);	
	self.screenToWindow(xLeft, yTop);
	
	self.mnuContext.userObject := cntrl;
	
	self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);
	
	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUndo" id="e212761c-3769-4f26-8e13-e29547788ce8">
        <source>doUndo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2023	navkc1	Initial creation

*/

vars
	obj		: Object;
	
	row		: Integer;
	maxRow	: Integer;
	
	allSelectedFields		: ObjectArray;
	
begin
	
	if app.msgBox("Are you sure you want to delete the Types/Fields added in the last action?", "Really?", MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	
	maxRow := self.tblOutput.rows;
	
	beginTransaction;
	foreach row in 1 to maxRow do
		obj := self.tblOutput.accessRow(row).itemObject;
		
		if obj = null then
			continue;
		endif;
		
		delete obj;
		
	endforeach;
	commitTransaction;
	
	app.msgBox("Types/Fields added in the last action are now deleted", "Information", MsgBox_Information_Icon + MsgBox_OK_Only);
	
	self.tblOutput.rows := 0;
	
	self.btnUndo.visible := false;
	
	create allSelectedFields transient;
	self.getAllSelectedAttributes(allSelectedFields);
	self.doPopulateTblAttributes(self.cmbClass.listObject.Class, allSelectedFields);
	self.doSelectField();
epilog
	delete allSelectedFields;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAllSelectedAttributes" id="2394ad45-a463-4b39-9755-b49c9b4ccaf6">
        <source>getAllSelectedAttributes(_allSelectedProps : ObjectArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023	navkc1	Initial creation

*/

vars

begin
	self.tblAttributesData.allSelectedObjects.copy(_allSelectedProps);
epilog

end;</source>
        <Parameter name="_allSelectedProps" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllViews" id="9661e0e0-09e8-49eb-97b9-3beb4f5936d3">
        <source>getAllViews();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023	navkc1	Initial creation

*/

vars
	rwSchema			: Schema;
	
	allViews			: MemberKeyDictionary;
	
	root				: Object;
	view				: Object;
	
	viewName			: String;
	
	
	releasedViews,
	releasedTemplates,
	releasedReports		: StringArray;
	
	
begin
	rwSchema := rootSchema.getSchema(JadeReportWriterSchema);
	
	if rwSchema = null then
		return;
	endif;
	
	root := rwSchema.getClass(JRDRoot).firstInstance();
	root.sendMsg("getContext");
	if root = null then
		return;
	endif;
	
	create releasedViews transient;
	create releasedTemplates transient;
	create releasedReports transient;
	
	allViews := root.getPropertyValue("allReportingViews").MemberKeyDictionary;
	
	DEV_ReleaseExtractAgent@getJRWDetails(releasedViews, releasedTemplates, releasedReports);
	
	foreach view in allViews discreteLock do
		viewName := view.getPropertyValue("name").String;
		if not releasedViews.includes(viewName) then
			continue;
		endif;
		self.allViews.add(view);
	endforeach;
epilog
	delete releasedViews;
	delete releasedTemplates;
	delete releasedReports;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAllViewsHaveType" id="6c41f5f9-6902-4541-92dc-d98827ec93ea">
        <source>getAllViewsHaveType(_type : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navkc1	Initial creation

*/

vars
	
	allViewsHaveType		: ObjectArray;
	
	allTypes				: MemberKeyDictionary;
	
	view 					: Object;
	type					: Object;
	
	typeName				: String;
	
	showMethod				: Boolean;
begin
	
	create allViewsHaveType transient;
	
	//Set to true here, if one clas is not enabled then false it.
	showMethod := true;
	
	foreach view in self.allViews do
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		
		foreach type in allTypes discreteLock do
			typeName := type.getPropertyValue("typeName").String;
			if typeName &lt;&gt; _type then
				continue;
			endif;
			
			// Does the class have show Method enabled?
			if not type.getPropertyValue("showMethodsWithParameters").Boolean then
				showMethod := false;
			endif;
			
			allViewsHaveType.add(view);
			break;
		endforeach;
	endforeach;
	
	// Set show method check box
	self.chkShowMethod.value := showMethod;
	
	self.msgViewsAddType.setSelected(allViewsHaveType);
	
epilog
	delete allViewsHaveType;
end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="2c070d8e-7fc6-4f33-b6db-ca8b56688ab3">
        <updating/>
        <source>init() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023	navkc1	Initial creation

*/
vars
	schema : Schema;
begin
	
	if app.msgBox("Would you like to go through the WIKI page of this app?", "Open Wiki Page", MsgBox_Yes_No) = MsgBox_Return_Yes then
		call josShellExecute(null, "open", self.WIKIURL, "", "", 0);
	endif;
	app.mousePointer := MousePointer_HourGlass;
	
	schema := rootSchema.getSchema("PortSchema");
	
	self.cmObjectClass := schema.getClass("CM_Object");
	self.cmQueryClass := schema.getClass("CM_Query");
	self.cmTransientClass := schema.getClass("CM_Transient");
	self.cmifObjectClass := schema.getClass("CMIF_Object");
	
	self.initCmbClass();
	self.initTblAttributes();
	self.initTblOutput();
	self.initMsg();
	self.initLabel();
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="initCmbClass" id="c27c6306-5cc3-4d4c-b8a4-4f29e23ec918">
        <source>initCmbClass();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023	navkc1	Initial creation

*/

vars
	schema			: Schema;
	
	subclasses		: ClassColl;
	
	cmObjectClass	: Class;
	class			: Class;
begin

	
	create subclasses transient;
	
	// Get all sub classes of CM_Object;
	self.cmObjectClass.allSubclasses(subclasses);
	self.cmQueryClass.allSubclasses(subclasses);
	self.cmTransientClass.allSubclasses(subclasses);
	self.cmifObjectClass.allSubclasses(subclasses);
	
	foreach class in subclasses do
		self.cmbClass.addItemObject(class.name, class);
	endforeach;
	
epilog
	delete subclasses;
end;</source>
    </JadeMethod>
