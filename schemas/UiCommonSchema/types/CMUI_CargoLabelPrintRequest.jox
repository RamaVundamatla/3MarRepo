    <JadeMethod name="setSelectedObjects" id="f386ee85-644c-4b2f-b557-a946a310ada1">
        <updating/>
        <source>setSelectedObjects( _collection : CM_ObjectArrayActual ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	firstObject : CM_Object;
	selectionMsg : String;
	recInfo : CM_GTEReceivalInfo;
	recReqInfo : CM_ReceivalRequestInfo;
	quantity : Integer;
	
begin

	self.allSelectedObjects.clear();
	
	if _collection = null or _collection.isEmpty then
		self.setFormForEmptyCollection();
		return;
	endif;

	self.txtNumIds.text := '1';
	self.txtNumIds.enabled := false;
	
	firstObject := _collection.first;
	
	if firstObject.isKindOf(CM_TrackedItem) then
		selectionMsg := app.getErrorString(Cargo);
		self.chkAuto.value := false;
		self.chkAuto.enabled := false;
		
	elseif firstObject.isKindOf(CM_BookingRef) then
		selectionMsg := app.getErrorString(BookingRef);
		self.chkAuto.value := true;
		self.chkAuto.enabled := false;
		self.txtNumIds.enabled := true;
		
	elseif firstObject.isKindOf(CM_BOL) then
		selectionMsg := app.getErrorString(CM_BOL_GC);
		chkAuto.value := true;
		chkAuto.enabled := false;
		
	elseif firstObject.isKindOf(CMGTE_Receival) then
		selectionMsg := app.getErrorString(Gate_receival);
		self.chkAuto.value := false;
		self.chkAuto.enabled := true;
		
	elseif firstObject.isKindOf(CMGTE_ReceivalByType) then	//06 Aug 2010	NDL	Par 25335
		selectionMsg := app.getErrorString(Gate_receival_by_type);
		recInfo := firstObject.CMGTE_ReceivalByType.myReceivalInfo;
		if recInfo &lt;&gt; null then
			recReqInfo := recInfo.myReceivalRequestInfo;
			//quantity := recInfo.getQuantity;			//-cnwml2 PAR25613
			quantity := recInfo.quantity;				//+cnwml2 PAR25613
		endif;
		//+cnwml2 PAR25613
		if quantity = 0 and recInfo &lt;&gt; null then		
			quantity := recInfo.getQuantity;		
		endif;
		if quantity &gt; 1 then
			self.txtNumIds.text := quantity.String;
		endif;
		self.chkAuto.value := true;
		self.chkAuto.enabled := false;
		self.txtNumIds.enabled := true;					//+cnwml2 PAR25613
	else
		app.msgBox(app.getErrorString(Invalid_class_objects) &amp; " - [" &amp; firstObject.class.name &amp; "]",app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		self.btnCancel.click(btnCancel);
		return;
	endif;
	
	_collection.copy(self.allSelectedObjects);
	
epilog

	self.setButtons();

end;</source>
        <Parameter name="_collection" type="CM_ObjectArrayActual"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="da2c793d-f35b-4aca-a2fb-41c31422a390">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

//	printerDef : CM_PrinterDef;
	selectionMsg : String;
//	obj : CM_Object;
	
begin

	self.handleMenusForModalDisplay();
	if self.myTerminal = null then	//16 Mar 2011	NDL Par 27204
		self.myTerminal := app.getMyTerminalDO_NOT_USE;
	endif;
	self.btnConfig.visible := app.getMyUser.canDo(self.myTerminal,PmCargoLabelPrintConfigMaint) 
		or app.getMyUser.canDo(self.myTerminal,PmCargoLabelPrintConfigView);

	inheritMethod();
	
	if self.allSelectedObjects.isEmpty then
		self.setFormForEmptyCollection();
		self.setButtons();
		self.chkAddSuffix.visible := true;

	else
		selectionMsg := self.allSelectedObjects.size.String &amp; " " &amp; app.getErrorString1(Items_Selected, selectionMsg);
		self.lblSelection.caption := selectionMsg;
		self.chkAddSuffix.value := false;
		self.chkAddSuffix.visible := false;
		if self.allSelectedObjects.size = 1 then
			self.myBreakBulkObject := self.allSelectedObjects.first;
			if CM_BreakBulkGeneric.hasInstance(self.myBreakBulkObject) then
				if self.myBreakBulkObject.CM_BreakBulkGeneric.canSplitTotalQuantity then
					self.chkAddSuffix.visible := true;
				endif;
			elseif CMGTE_Receival.hasInstance(self.myBreakBulkObject) then
				if self.myBreakBulkObject.CMGTE_Receival.canSplitTotalQuantity then
					self.chkAddSuffix.visible := true;
				endif;
			elseif CMGTE_ReceivalByType.hasInstance(self.myBreakBulkObject) then
				if self.myBreakBulkObject.CMGTE_ReceivalByType.canSplitTotalQuantity then
					self.chkAddSuffix.visible := true;
				endif;
			endif;
		endif;

	endif;

	self.setupPrinterCombo();
	
	if not self.checkAutoCargoIdConfigure() then
		if self.btnConfig.enabled then
			self.doBtnConfig();
		endif;
	endif;
	
	self.clickBreakBulk();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupPrinterCombo" id="7a5f53a0-c8ae-4172-a9e3-57a0912c6edb">
        <source>setupPrinterCombo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwndl1	Initial creation	CCMS MES 1004 
14 Mar 2011	NDL		Par 26484 - Change to use local printer list only.

*/

vars

	// 14 Mar 2011	NDL Par 26484
	printerNameArray : CnStringArray;	// 31581 May 2013 extended from StringArray to handle long printer names
	printerName : String;	//14 Mar 2011	NDL Par 26484
	
begin

	self.cmbPrinter.clear();
	self.cmbPrinter.addItem( app.getErrorString(Default_printer) );
	
	//14 Mar 2011	NDL Par 26484
	create printerNameArray transient;
	app.printer.getAllPrinters( printerNameArray );
	foreach printerName in printerNameArray do	
		self.cmbPrinter.addItem( printerName );
	endforeach;
	
	if self.initialPrinterSetting = null then
		self.cmbPrinter.listIndex := 1;
	else
		self.cmbPrinter.listIndex := self.cmbPrinter.findStringExact(1,self.initialPrinterSetting);
	endif;

epilog

	delete printerNameArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b55e8eeb-b3fb-434f-8d43-050913f69a28">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014102, locale);
	btnConfig.translateCaption(Xlat_0014103, locale);
	chkAddSuffix.translateCaption(Xlat_0019082, locale);
	chkAuto.translateCaption(Xlat_0014104, locale);
	chkPrintPreview.translateCaption(Xlat_0014540, locale);
	lblFirst.translateCaption(Xlat_0019083, locale);
	lblLastSuffix.translateCaption(Xlat_0019084, locale);
	lblMainIdValue.translateCaption(Xlat_0019085, locale);
	lblNumCopys.translateCaption(Xlat_0014105, locale);
	lblNumIds.translateCaption(Xlat_0014106, locale);
	lblPrinter.translateCaption(Xlat_0014107, locale);
	lblSelection.translateCaption(Xlat_0014108, locale);
	lblSeparator.translateCaption(Xlat_0019086, locale);
end;</source>
    </JadeMethod>
