<Class name="CM_MultiMoveGroup" id="366a98da-5775-498f-aff1-5b8a2d996f25">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="multiMoveGroup"/>
    <ExplicitInverseRef name="allAssociatedCargo" id="93b5dc97-0ce8-455b-83bb-45fdf9b8abf8">
