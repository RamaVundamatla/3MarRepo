    <JadeMethod name="getJob" id="3dd12853-2bd8-4cbe-8e8e-7fe8ca1f8602">
        <source>getJob() : CM_Job;
// ---------------------------------------------------------------------------
// Created:		03 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// par20150 the self.myJob is not inversed so can be invalid so must be protected
// 07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	isInvalid : Boolean;
	str : String;
	voyageJob	: CM_VoyageJob;
begin
	voyageJob := self.myJob;
	if voyageJob = null then //par20150 cnwrs1 July 2009
		return null;
	endif;
	on Exception do app.handleDeletedObject(exception, voyageJob, isInvalid);
	str := voyageJob.id;
	if not isInvalid then
		return voyageJob;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="CM_Job"/>
    </JadeMethod>
