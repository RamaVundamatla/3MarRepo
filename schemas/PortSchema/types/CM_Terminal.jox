	descr : String; */
begin

	return; //15 Sep 2021	NDL	TFS 51142 - No longer used, replaced by "addUpdateTerminalMutexes" which creates CM_Mutex objects

	/*
	if _constant.valueAsInteger &lt;= Mutex_Permissions or
	   _constant.valueAsInteger &gt;= Mutex__Max then
	   	return;
	endif;
	text := _constant.text;
	if text  = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No text for cargo type constant (' &amp; _constant.name &amp; ')');
		return;
	endif;
	descr := text.cnEcGetTagValueOfName('Name');
	create pxyBGPMutex transient;
	pxyBGPMutex.update(_constant.valueAsInteger, descr, 0, null, self, "TerminalObj"); 
	app.myUtilityCA.utlCreateBGPMutex(pxyBGPMutex, mutex, app.myPassport);
