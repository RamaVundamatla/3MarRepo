<Class name="CM_EDIFileTypeJSONCallOff" id="821f85d9-2725-4806-9e23-2c07ff4dc51a">
    <superclass name="CM_EDIFileTypeJSON"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
