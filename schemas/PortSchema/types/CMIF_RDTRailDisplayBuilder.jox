    <JadeMethod name="clear" id="729e20da-5125-4982-a669-35af2c7b72ca">
        <source>clear();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars

begin
	inheritMethod();
	
	// We have to purge these collections as they hold transients
	self.allWagonPartsByGridPos.purge();
	self.allTracksByGridPos.purge();
	self.allBoxcarLoadPositions.purge();	//26 Mar 2013	NDL Par 31278

epilog

end;</source>
