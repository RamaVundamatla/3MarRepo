/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	inheritMethod();
	
	// Set up application environmental stuff from the interface
	app.setMyTerminal(self.myInterfaceDefinition.myTerminal);
	app.setLocale(self.myInterfaceDefinition.myLocale);	
	
	// Start listening
	self.initializeConnection();
	
	// Go idle, and wait for connections
	
	
epilog

end;</source>
