    <JadeMethod name="readJournal" id="6e6a6be4-9461-4af5-9dc0-c1b5677c39ea">
        <updating/>
        <source>readJournal(pServerExecution : Boolean;
			pType      : Integer output;   pTranId   : Decimal output;
			pTimeStamp : TimeStamp output; pOid      : String output; 
