        <type name="Binary"/>
    </Constant>
    <Constant name="TimeoutEventMinimum" id="75e27d0a-d1ec-47ab-bc14-5da188778358">
        <constantUsages>
            <GlobalConstant name="MillisecondsPerMinute"/>
        </constantUsages>
        <source>1 * MillisecondsPerMinute</source>
        <type name="Integer"/>
        <text>Minimum period of time (in milliseconds) until next timeout processing.</text>
    </Constant>
    <Constant name="Timer_ResetTcpConnection" id="2544f63f-9582-4d9d-a3d1-bd406b036924">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Timer_Timeout" id="5e18a628-f096-42d2-94d6-d0030d1a62a7">
