    <JadeMethod name="setMyDutyDoc" id="7f62b1a0-5da6-4ba9-857d-51253b848a4d">
        <updating/>
        <source>setMyDutyDoc(_dutyDoc : CM_DutyDoc) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if self.myDutyDoc &lt;&gt; null then
		self.endNotification(self.myDutyDoc,self.myTerminal.getTerminalEvent(EVENT_DUTYDOCITEM_UPDATE));
		self.endNotification(self.myDutyDoc,self.myTerminal.getTerminalEvent(EVENT_DUTYDOC_UPDATE));
		self.endNotification(self.myDutyDoc,Object_Delete_Event);
	endif;
	self.myDutyDoc:=_dutyDoc;
	if self.myDutyDoc &lt;&gt; null then
		self.beginNotification(self.myDutyDoc,self.myTerminal.getTerminalEvent(EVENT_DUTYDOCITEM_UPDATE),0,null);
		self.beginNotification(self.myDutyDoc,self.myTerminal.getTerminalEvent(EVENT_DUTYDOC_UPDATE),0,null);
		self.beginNotification(self.myDutyDoc,Object_Delete_Event,0,null);
	endif;
epilog

end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
    </JadeMethod>
    <JadeMethod name="setPermissions" id="89d91931-cf19-409d-9035-d6d6e7845637">
        <updating/>
        <source>setPermissions() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	self.hasPermDataEntry:= app.myCurrentUserCan(self.myTerminal,PmGteDutyDocDataEntry);
	self.hasPermSupervisor:=app.myCurrentUserCan(self.myTerminal,PmGteDutyDocSupervisor);
	self.hasPermDocInCharge:=app.myCurrentUserCan(self.myTerminal,PmGteDutyDocInCharge);
	self.hasPermCustomsInspector:=app.myCurrentUserCan(self.myTerminal,PmGteDutyDocCustomsSuper);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setPrintCarVisibility" id="3b13e1b9-a264-40e2-be28-6926d6b2fe4d">
        <source>setPrintCarVisibility();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2013	cnwndl1	Initial creation

*/

vars

	row : Integer;
	dutyDocItem : CM_DutyDocItem;

begin

	self.btnPrintCar.visible := false;
	
	row := self.tblDutyDocItems.row;
	if row &gt; self.tblDutyDocItems.fixedRows and row &lt;= self.tblDutyDocItems.rows then
		dutyDocItem := self.tblDutyDocItems.accessRow(row).itemObject.CM_DutyDocItem;
		if dutyDocItem &lt;&gt; null and dutyDocItem.isCar then
			self.btnPrintCar.visible := true;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyDetails" id="f7c39f00-fd57-4e1e-a697-9f2317b7f5da">
        <source>setProxyDetails(_updateDataEntry: Boolean)  : CM_DutyDoc protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	dutyDocProxy : CM_DutyDoc;
	dutyDocTerminalRoot : CM_DutyDocTerminalRoot;
	userId : String;
	delExpiryTS : TimeStamp;
	effectiveTS : TimeStamp;
begin
	
	if self.myDutyDoc = null then
		create dutyDocProxy transient;
	else
		dutyDocProxy:=app.createUpdateProxy(self.myDutyDoc).CM_DutyDoc;
	endif;
	
	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	delExpiryTS.cnEcSetDateAndTime(self.txtDelExpiry.getDate,TimeEndOfDay);
	effectiveTS.cnEcSetDateAndTime(self.txtEffectiveDate.getDate,TimeStartOfDay);

	
	dutyDocTerminalRoot:=app.myDutyDocRoot.allDutyDocTerminalRoots[self.myTerminal];
	//set proxy details
	dutyDocProxy.setProxy(	dutyDocTerminalRoot,
							self.txtTicket.text,
							self.cmbBillType.text,
							self.txtManifest.text,
							self.cmbForwarder.listObject.CM_ConsigneeConsignor,
							self.txtDelivery.text,
							self.localToSystemTime(delExpiryTS).date(),//	self.txtDelExpiry.getDate,// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
							self.txtReexport.text,
							self.txtDriver.text,
							self.txtShipTruck.text,
							self.cmbBorder.text,
							self.cmbGCCountry.text,
							self.txtExitPort.text,
							self.cmbInvTerms.text,
							self.chkDocDeposit.value, // chkDocDeposit;
							self.cmbStatus.listData,
							self.txtDeposit.text.Decimal,
							self.cmbCustomsInsp.text,
							self.txtReason.text,
							self.txtCustRemarks.text,
							self.txtRemarks.text,
							self.localToSystemTime(effectiveTS).date(),// self.txtEffectiveDate.getDate,// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
							self.cmbVoyage.listObject.CM_Voyage,
							self.cmbConsignee.listObject.CM_ConsigneeConsignor,
							self.txtGoodsDesc.text.trimBlanks,
							self.txtDestination.text.trimBlanks
							);
	
	userId := app.myPassport.userCode;
	if self.chkGroupSuper.value then
		dutyDocProxy.setCustomsUserId(userId);
	else
		dutyDocProxy.setCustomsUserId(null);
		self.lblGroupSuper.caption:=null;
	endif;
	
	if _updateDataEntry then
		if self.chkDataEntry.value then
			dutyDocProxy.setDataEntryUserId(userId);
		else
			dutyDocProxy.setDataEntryUserId(null);
			self.lblDataEntryUser.caption:=null;
		endif;
	endif;
	
	if self.chkSupervisor.value then
		dutyDocProxy.setSupervisorUserId(userId);
	else
		dutyDocProxy.setSupervisorUserId(null);
		self.lblSupervisor.caption:=null;
	endif;

	if self.chkDocInCharge.value then
		dutyDocProxy.setDocInChargeUserId(userId);
	else
		dutyDocProxy.setDocInChargeUserId(null);
		self.lblDocInCharge.caption:=null;
	endif;
	
	return dutyDocProxy;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_updateDataEntry" type="Boolean"/>
        <ReturnType type="CM_DutyDoc"/>
    </JadeMethod>
