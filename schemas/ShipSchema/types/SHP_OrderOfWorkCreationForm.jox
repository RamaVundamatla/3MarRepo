    <JadeMethod name="doBtnVoyageSave" id="62f63971-b197-4423-9c73-93a883495475">
        <updating/>
        <source>doBtnVoyageSave() updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	returnSaveVoyage : Integer;
	controller : CMIF_OOWVoyageUpdate;
begin
	if not self.doCheckVoyage(true) then
		return;
	endif;

	returnSaveVoyage := app.msgBox(app.getErrorString1(Want_save_voyage_details, self.myCurrentVoyage.code) , 
										app.getErrorString(Confirmation),MsgBox_Yes_No + MsgBox_Question_Mark_Icon);

	if returnSaveVoyage = MsgBox_Return_No then
		return;
	endif;
	
	self.doUpdateVoyageDetails();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckCraneJobsSetup" id="79b2e013-d8e8-4485-9988-1898fb69657b">
        <updating/>
        <source>doCheckCraneJobsSetup(_theJobSheets : CM_VoyageJobSheetByCraneDict) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		04 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
		aTerm : CM_Terminal;
		autoBoomUp, autoLid : Boolean;
		aJS : CM_VoyageJobSheet;
		aCrane : CM_Crane;
		boomJob, removeJob, replaceJob, longTravel : CM_JobType;
		mess : String;
begin
	aTerm := self.myTerminal;
	if aTerm &lt;&gt; null then
		autoBoomUp := aTerm.getConfig(AutoCreateBoomUpJob).Boolean;
		autoLid := aTerm.getConfig(AutoCreateHatchLidJob).Boolean;
	endif;
	
	if not autoBoomUp and not autoLid then
		return true;
	endif;
	
	foreach aJS in _theJobSheets do
		aCrane := aJS.getMyCrane();
		if aCrane = null then
			continue;
		endif;
		boomJob := aCrane.allHatchJobTypes[CM_Crane.HatchJobType_BoomUp];
		removeJob := aCrane.allHatchJobTypes[CM_Crane.HatchJobType_LidRemove];
		replaceJob := aCrane.allHatchJobTypes[CM_Crane.HatchJobType_LidReplace];
		longTravel := aCrane.allHatchJobTypes[CM_Crane.HatchJobType_LongTravel]; // PAR 20474
		
		if autoBoomUp and boomJob = null then 
			mess := mess &amp; app.getErrorString1(NO_CRANE_BOOM, aCrane.id) &amp; Cr; // PAR 20474
		endif;
		if autoLid and removeJob = null then 
			mess := mess &amp; app.getErrorString1(NO_CRANE_UP_LID, aCrane.id) &amp; Cr; // PAR 20474
		endif;
		if autoLid and replaceJob = null then 
			mess := mess &amp; app.getErrorString1(NO_CRANE_DOWN_LID, aCrane.id) &amp; Cr; // PAR 20474
		endif;
	endforeach;
	
	if mess &lt;&gt; null then
		mess := mess &amp; Cr &amp; app.getErrorString(Cannot_create_order_work); // PAR 21287 noticed that  the global constant that was being used had the same number as another text translation so created a new one.
		// PAR 20474 
		app.msgBox(mess,app.getErrorString(JOBUPSET), MsgBox_Exclamation_Mark_Icon);
		
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_theJobSheets" type="CM_VoyageJobSheetByCraneDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCheckOOWJobs" id="f807912c-7c98-437d-a448-7a3215f68c6f">
        <source>doCheckOOWJobs() : Boolean;
// ---------------------------------------------------------------------------
// Created:		30 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	if not doCheckVoyage(false) then	// before searching there is null voyage	- cnwvu1
		return false;
	endif;

	if self.myCurrentVoyage.myCellularVoyageStructure.hasOOWCreationGotJobs() or
		(self.myCurrentVoyage.myROROStructure &lt;&gt; null and  self.myCurrentVoyage.myROROStructure.hasOOWCreationGotJobs())  then
		app.msgBox("Jobs have been created for this voyage." &amp; Cr &amp; "To continue you must delete all jobs in Order Of Works.",  app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCheckVoyage" id="5272ec96-dc02-4fd0-97a3-9f15c1516c81">
        <source>doCheckVoyage(_checkJS : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		02 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(Please_select_voyage), app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	if _checkJS  and self.myCurrentVoyage.allJobSheets.isEmpty() then
		app.msgBox("Please allocate some cranes to the voyage.",  app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_checkJS" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="6fab8362-aeb7-48f7-8b54-d274b48cefe9">
        <source>doCmbVoyageBuild();
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aVoyage			: CM_Voyage;
	idx				: Integer;
	theVoyages		: CM_VoyageSet;
	
begin
	self.cmbVoyage.clear;
	self.cmbVoyage.sorted := true;
	
	create theVoyages transient;
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages, false, false);
	
	foreach aVoyage in theVoyages do
		if aVoyage.myCellularVoyageStructure = null then	//13 Aug 2019	NDL	TFS 45684
			continue;
		endif;
		idx := self.cmbVoyage.addItem(aVoyage.code &amp; " - " &amp; aVoyage.description);
		self.cmbVoyage.itemObject[idx] := aVoyage;
	endforeach;
	
	// cnwrl1 16/04/2009 PAR 19440
	// default the navigation heading.
	self.setNavigatorHeading( self.caption );
	
	//cnwjo3 par 23105
	aVoyage := app.getMyCurrentVoyage();
	
	if aVoyage &lt;&gt; null then
		idx := self.cmbVoyage.findObject(aVoyage);
		if idx &gt; 0 then
			self.cmbVoyage.listIndex := idx;
		endif;
		self.cmbVoyage.click(self.cmbVoyage);
	endif;
	
epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageClick" id="5918019f-cf99-477f-b50b-493143901fd6">
        <updating/>
        <source>doCmbVoyageClick() updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	
	if self.myCurrentVoyage &lt;&gt; null then
		self.endNotification(self.myCurrentVoyage.myCellularVoyageStructure, self.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE));		
		self.endNotification(self.myCurrentVoyage.myCellularVoyageStructure, self.myTerminal.getTerminalEvent(EVENT_CRANE_UPDATE));		
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_OOWVOYAGE_UPDATE));		
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(JobSheet_Update_Event));		
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event));		
	endif;
	
	self.myCurrentVoyage := self.cmbVoyage.listObject.CM_Voyage;
	
	if self.myCurrentVoyage = null then
		// cnwrl1 16/04/2009 PAR 19440
		// default the navigation heading.
		self.setNavigatorHeading( self.caption );
		return;
	endif;
	
	//app.myCurrentVoyage := self.myCurrentVoyage;
	//cnwjo3 par 23105
	app.setMyCurrentVoyage(self.myCurrentVoyage);
	
	self.dteStart.setDate(self.myCurrentVoyage.shipExchangeDate.date);
	self.timeStart.setTime(self.myCurrentVoyage.shipExchangeDate.time);
	if self.myCurrentVoyage.starboardBerthed then
		self.cmbBerthage.listIndex := 2;
	else
		self.cmbBerthage.listIndex := 1;
	endif;	
	self.craneClearance := self.myCurrentVoyage.craneClearance;
	
	self.beginNotification(self.myCurrentVoyage.myCellularVoyageStructure, self.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), Response_Continuous, null);	
	self.beginNotification(self.myCurrentVoyage.myCellularVoyageStructure, self.myTerminal.getTerminalEvent(EVENT_CRANE_UPDATE), Response_Continuous, null);	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_OOWVOYAGE_UPDATE), Response_Continuous, null);	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(JobSheet_Update_Event), Response_Continuous, null);	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event), Response_Continuous, null);	
	
	self.caption := "Order Of Works Creation (" &amp; self.myCurrentVoyage.code &amp; ")";
	self.setNavigatorHeading(self.myCurrentVoyage.code); 
	self.doQuery();
end;</source>
    </JadeMethod>
    <JadeMethod name="doColourBayCell" id="b195bf87-9cc3-4d9f-9288-5ce93323b8d7">
        <source>doColourBayCell( _table : CM_DataTable input;
				_oowc : CM_OOWCreation; 
				_idx : Integer; 
				_deck : Integer; 
				_tl : Boolean);
// ---------------------------------------------------------------------------
// Created:		04 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : Table;
	tmpColour : Integer;
begin
	theTable := _table;
	if _oowc.ordinalDeck = _deck and not _tl then //_oowc.myBay.isTwinLiftUD then
		tmpColour := self.xmlColourBay;
		if tmpColour = 0 then
			tmpColour := self.myTerminal.getConfig(ShipTransitBoxColor).Integer;
		endif;

		theTable.accessCell(_idx,1).backColor := tmpColour;
		theTable.accessCell(_idx,1).foreColor := tmpColour.getInverseColour();
		
	endif;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_oowc" type="CM_OOWCreation"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_deck" type="Integer"/>
        <Parameter name="_tl" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDragDropBay" id="c2f9b9e5-ac31-43e9-876a-2e6f911a3c70">
        <updating/>
        <source>doDragDropBay(_table : Table input; targetObj : Object; theRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJS : CM_VoyageJobSheet;
	mess, mess2 : String;
	oowc, toowc : CM_OOWCreation;
begin
	
	if targetObj = null then
		self.doUndoDrag(_table);
		return;
	endif;

	oowc := self.origObject.CM_OOWCreation;
	if targetObj.respondsTo(IF_VoyageWorkPoint) then
		mess2 := targetObj.IF_VoyageWorkPoint.getID &amp; "?";
		aJS := self.myCurrentVoyage.allJobSheets[targetObj.IF_VoyageWorkPoint.getID];
		toowc := aJS.allOOWCreations.last;
	else
		toowc := targetObj.CM_OOWCreation;
		aJS := targetObj.CM_OOWCreation.myCraneJobSheet;
		if aJS = null then	//19 Apr 2012	NDL	Par 28735
			self.doUndoDrag(_table);
			return;
		endif;
		mess2 := aJS.crane &amp; "?";
	endif;					

	if toowc = null then
		self.doUndoDrag(_table);
		return;
	endif;
	
	if toowc &lt;&gt; null and toowc.myCraneJobSheet = oowc.myCraneJobSheet then
		mess := "Do you want to move "  &amp; self.origTextExtra &amp; " " &amp; self.origText &amp; " within Crane ";
		mess := mess &amp; mess2;
	else
		mess := "Do you want to move "  &amp; self.origTextExtra &amp; " " &amp; self.origText &amp; " to Crane ";
		mess := mess &amp; mess2;
	endif;	
	if app.msgBox(mess, app.getErrorString(Confirmation), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		self.doUpdateMoveBay(oowc, toowc);
	else
		self.doUndoDrag(_table);
	endif;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="targetObj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDragDropCrane" id="2297e730-c489-4968-b5cc-d0dbf9ee1b3d">
        <updating/>
        <source>doDragDropCrane(theTable : Table input; theRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.origObject.isKindOf(CM_Crane) and not self.validateCraneMove(theTable,theRow,self.origObject.CM_Crane) then
		return;
	endif;
	
	theTable.moveRow(self.origRow,theRow);	
	self.doTableReset(theTable,theRow);	

	// ### UPDATE!!!!!
	self.doUpdateBayJobSheet(theTable);
		

end;</source>
        <Parameter name="theTable" type="Table" usage="input"/>
        <Parameter name="theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLstCranesBuild" id="aeda46dc-279d-4651-9366-1c3398759968">
        <source>doLstCranesBuild();
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theMachines : CM_MachineSet;
	aCrane : CM_Machine;
	aMachine : CM_Machine;
begin
	self.lstCranes.accessColumn(2).width := 100;
	foreach aMachine in self.myTerminal.machines 
	where (aMachine.available and not aMachine.isNotAvailableForEntry) do	// 16/05/2012 cnwar2 #28342
		if not CM_Crane.hasInstance(aMachine) then
			continue;
		endif;
		self.lstCranes.addItemObject(aMachine.id,aMachine);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuContextLoadOOW" id="ba171fe2-4af6-49a7-926d-6e15a0b5529e">
        <updating/>
        <source>doMnuContextLoadOOW(_js : CM_VoyageJobSheet) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2006 By Andrew Bishop cnwab1
// renamed 10 Aug 2009	NDL Rework for CCMS 1031 par 20474
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theJobSheets : CM_VoyageJobSheetByCraneDict;
begin
	if app.msgBox("Are you sure that you want to create the OOW for crane " &amp; _js.crane &amp; "?", 
					app.getErrorString(Confirmation),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	create theJobSheets transient;
	theJobSheets.add(_js);
	
	self.doUpdateOOW(theJobSheets);
epilog
	delete theJobSheets;


end;</source>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
    </JadeMethod>
    <JadeMethod name="doMnuOOWCraneEdit" id="60799c60-4051-4037-a053-fc8c74c38ad5">
        <updating/>
        <source>doMnuOOWCraneEdit(menuItem: MenuItem input) updating;

