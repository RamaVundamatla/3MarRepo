    <JadeMethod name="setStatus" id="0c957b0f-04cb-4009-bc58-9271db6cbf33">
        <updating/>
        <source>setStatus(_value: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		18 November 2010 by cnwjo3
//
// Purpose:		if a VoyageWLEs status has been changed we may need to update the voyage jobs start and end time.
//				cnwjo3 par 26149
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 17/12/2010	cnwdap1		PAR #26426 CCMS MES 1102 Release requests on hip load list 
//							If status is Complete, remove me from the release request "being actioned" collection
// 07/02/2011	cnwer1		PAr 25573 - moved below code into setCompletedDate which is called in CM_WorkListEntry::setStatus - method can be deleted 
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 11/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 07/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
vars
	ti, prenote : CM_TrackedItem;	// TFS 51935
	fm : CM_FutureMove;				// TFS 51935
	wle : CM_WorkListEntry;			// TFS 52360
	updateWle : CM_VoyageWLE;		// TFS 52360
	adjustment : Integer;			// TFS 52360
	comparison : Integer;			// TFS 52360
	
begin
	inheritMethod(_value);
	
	if self.status = WLE_COMPLETED then
		if self.job.isAllowOutOfOrderLoading then
			self.completeOutOfOrderLoad(self.myTrackedItem);
		endif;
		
		// TFS 51935 If WLE is completed, and a future move linked to this WLE is also linked to a prenote,
		// delete the future move
		ti := self.myTrackedItem;
		//if ti &lt;&gt; null and ti.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then	// TFS 52293
		if ti &lt;&gt; null and self.job.isDirectDeliveryJob then									// TFS 52293
			prenote := ti.myVoyage.allNotifiedTIsByIdCargoType[ti.id, ti.cargoType];
			if prenote &lt;&gt; null and self.myFutureMove &lt;&gt; null and self.myFutureMove.isKindOf(CM_FutureMovePlanned)
			and self.myFutureMove.CM_FutureMovePlanned.myTrackedItem = prenote then
				fm := self.myFutureMove;
			endif;
			if fm &lt;&gt; null then
				delete fm;
			endif;
			// TFS 52360 If there's no prenote, everything is on site. If I'm complete, make sure other WLEs
			// for this job have their amounts adjusted 
			if prenote = null then
				foreach wle in self.job.workListEntries where wle &lt;&gt; self and wle.isKindOf(CM_VoyageWLE) do
					updateWle := null;
					adjustment := null;
					if wle.CM_VoyageWLE.subSeqNum &lt;&gt; null and wle.locationTarget = self.locationTarget and wle.status = WLE_UNACTIONED then
						updateWle := wle.CM_VoyageWLE;
					endif;
					if updateWle &lt;&gt; null then
						if ti.isBulkByQuantity then
							comparison := self.quantity;
						else
							comparison := self.weight.Integer;
						endif;
						if self.subSeqNum = comparison and self.subSeqNum = self.job.CM_VoyageHoldJob.originalJobAmount then
							if ti.isBulkByQuantity then
								updateWle.setSubSeqNumNullAndAdjust(updateWle.myDirectDeliveryParentWLE.quantity);
							else
								updateWle.setSubSeqNumNullAndAdjust((updateWle.myDirectDeliveryParentWLE.weight).Integer);
							endif;
						else
							if self.subSeqNum &lt; self.weight and (ti.isBulkByVolume or ti.isBulkByWeight) then
								adjustment := (self.weight - self.subSeqNum).Integer;
							elseif self.subSeqNum &gt;= self.weight and (ti.isBulkByVolume or ti.isBulkByWeight) then
								adjustment := (self.subSeqNum - self.weight).Integer;
							elseif self.subSeqNum &lt; self.quantity and ti.isBulkByQuantity then
								adjustment := self.quantity - self.subSeqNum;
							elseif self.subSeqNum &gt;= self.quantity and ti.isBulkByQuantity then
								adjustment := self.subSeqNum - self.quantity;
							endif;
							if adjustment &gt; null or (updateWle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isOnTruck) then
								updateWle.setSubSeqNum(adjustment);
							endif;
						endif;
					endif;
				endforeach;
			endif;
			// TFS 52360 end of this bit
		endif;
		// TFS 51935 end
		
		self.subSeqNum := null;			// TFS 52360
	endif;

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSubSeqNum" id="5ddb5725-3f23-45bb-8e18-48e28abee5b2">
        <updating/>
        <source>setSubSeqNum(_value : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/11/2021	navdap1		Initial creation TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
//
vars

begin
	self.subSeqNum := _value.max(0);
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSubSeqNumNullAndAdjust" id="a1db6b9c-12e4-4865-b5cc-90b995c0ef9d">
        <updating/>
        <source>setSubSeqNumNullAndAdjust(_adjustment : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/11/2021	navdap1		Initial creation TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
//
vars
	wle : CM_WorkListEntry;

begin
	self.subSeqNum := null;
	
	// Convoluted trail to follow here - there may be another voyage WLE associated with the job
	// So: this WLE -&gt; TI -&gt; allWorkListEntries -&gt; find an unactioned one 
	// This unactioned one will be there because there's some more cargo onsite on another truck
	foreach wle in self.myTrackedItem.allWorklistEntries do
		if wle = self or wle.status = WLE_COMPLETED or not wle.isKindOf(CM_VoyageWLE) then
			continue;
		endif;
		if wle.CM_VoyageWLE.subSeqNum &lt;&gt; null and wle.myTrackedItem.locationId &lt;&gt; self.myTrackedItem.locationId then
			// reduce this WLE's subSeqNum to the amount passed in
			wle.CM_VoyageWLE.setSubSeqNum(_adjustment);
			break;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_adjustment" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setUseBoldOrDifferentColour" id="5d78228b-1df6-432f-b2f7-a74af1f92387">
        <updating/>
        <source>setUseBoldOrDifferentColour(_useDifferentColour : Integer) updating;
// -------------------------------------------
// Created 06 October 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.useBoldOrDifferentColour := _useDifferentColour;


end;</source>
        <Parameter name="_useDifferentColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="a9eff715-557e-4f9e-8b0e-8a7c3cd66914">
        <methodInvocation>mapping</methodInvocation>
        <source>statusString(set: Boolean; value: String io) mapping;

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	inheritMethod(set,value);
	/*
	if status = WLE_UNACTIONED then
		value := "Unactioned";
	elseif status = WLE_ASSIGNED then
		value := "Assigned"; 
	elseif status = WLE_COMPLETED then
		value := "Complete"; 
	else
		value := "Unknown!";
	endif;*/

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="unQueueWLE" id="f60fb10d-82c9-40da-95a1-0342c3dc695b">
        <updating/>
        <source>unQueueWLE(_passport: CM_Passport input) updating;
/*
Purpose:			
Date		Who		Reason
20 November 2015	cnwab1	Initial creation
*/

vars
	voyage : CM_Voyage;
	term : CM_Terminal;

begin
	inheritMethod(_passport);

	if self.isBulkRelease() then // PAR 37122 ship release request
		voyage := self.getVoyage(); // PAR 37122
		term := self.getMyTerminal(); // PAR 37122
		
		if term &lt;&gt; null and voyage  &lt;&gt; null then // PAR 37122
			app.myEventManager.createSingleObjInfoNoteEvt(voyage, term.getTerminalEvent(WLE_Update_Event), self);	 // PAR 37122
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unassignTI" id="115839c1-76f5-4c14-8cd1-c199919de3f7">
        <updating/>
        <source>unassignTI() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myRequest &lt;&gt; null then
		self.myRequest.setSequenced(false);
	endif;
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="unplanDRSplit" id="60a2235e-9cd1-481b-ac89-4aa0f14eb8e3">
        <updating/>
        <source>unplanDRSplit(_mergeWLE : CM_WorkListEntry input): Boolean updating;
/*

Purpose:			Handles the unplanning, merging and deleting of Direct Release WLEs
					where the cargo was to be split. The WLEs on both sides of the move
					need to be merged back together.
					Expected that self is the destination wle for the direct release
					ie self.myFutureMove is not null

Parameters:			_mergeWLE : the other wle that needs merging

Return Value:		true if wles unplanned succesfully

Date				Who		Reason
05 July 2019		jlgzm1	TFS 42863 MSL - Direct Delivery Between RORO Voyages and Rail - Break Bulk

*/

vars
	drWle 			: CM_WorkListEntry;
	otherMergeWLE 	: CM_WorkListEntry;
	deleteSelf		: Boolean;
begin
	if not process.isInTransactionState then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Process not in transaction state');
		return false;
	endif;
	
	if self.isDRLinkedByFM and 
	   self.myTrackedItem &lt;&gt; null and
	   self.myTrackedItem.canMergeBreakBulk and
	   _mergeWLE &lt;&gt; null then
		deleteSelf := true;
		// If _mergeWLE is not planned then merge amount, and delete the spare wle
		if _mergeWLE.isKindOf(CM_YardWLE) and
		   not _mergeWLE.isDRLinkedByFM() then
			_mergeWLE.setQuantity(_mergeWLE.quantity + self.quantity);
			_mergeWLE.setWeight(_mergeWLE.weight + self.weight);
			if _mergeWLE.job &lt;&gt; null then	// TFS 42872
				_mergeWLE.causeEvent(_mergeWLE.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), false, _mergeWLE); // TFS 42872
			endif;
		
			drWle := self.getDRLinkedWLE();
			drWle.causeEvent(drWle.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, drWle);
			delete drWle;
		endif;
		
		if self.job &lt;&gt; null and self.myRequest &lt;&gt; null then
			// possible that wles were split on both sides of move, 
			// find if a split wle on this side of the move exists
			otherMergeWLE := self.job.getUnplannedWLEForRequest(self.myRequest);
			if otherMergeWLE = null and self.myRequest.allWorkListEntries.size &gt; 1 then
				deleteSelf := false;
			endif;
		endif;
		if otherMergeWLE &lt;&gt; null then
			otherMergeWLE.setQuantity(otherMergeWLE.quantity + self.quantity);
			otherMergeWLE.setWeight(otherMergeWLE.weight + self.weight);
			app.myEventManager.createSingleObjInfoNoteEvt(self.job.getMyVoyageObject, self.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), otherMergeWLE);
		endif;

		if self.myFutureMove &lt;&gt; null then
			self.myFutureMove.erase(NORMAL_ERASE);
		else
			self.myFutureMoveDR.erase(NORMAL_ERASE);
		endif;
		
		if self.job &lt;&gt; null and self.job.isRelease then
			self.job.updateTICollectionsUnassign( self.myTrackedItem);
		endif;
		
		if deleteSelf then
			self.causeEvent(self.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, self);
			app.myEventManager.createSingleObjInfoNoteEvt(self.job.getMyVoyageObject, self.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), self);
			delete self;
		endif;
		
		return true;
		
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_mergeWLE" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="unplanForDRHoldJob" id="88dc27b2-ae94-4d9e-abbe-a3c52ca61439">
        <updating/>
        <source>unplanForDRHoldJob(_mergeWLE : CM_WorkListEntry input): Boolean updating;
/*

Purpose:			Handles the unplanning, unlinking, and deleting of Direct Release WLEs
					planned to a hold voyage job.
					Expected that self is the destination wle for the direct release
					ie self.myFutureMove is not null

Parameters:			_mergeWLE : the other wle that needs merging.

Return Value:		true if wles unplanned succesfully

Date				Who		Reason
19 August 2019		jlgzm1	Initial creation TFS 42872  Direct Release Between HOLD Voyages and Rail
31 October 2019		jlgzm1	TFS 47085 Direct Release Ship to Ship

*/

vars
	otherWLE 	: CM_WorkListEntry;
	theFM 		: CM_FutureMove;			// TFS 47085
	plannedFM	: CM_FutureMovePlanned;		// TFS 47085
	newFM		: CM_FutureMovePlanned;		// TFS 47085
	moveCtrl	: CMIF_MoveController;		// TFS 47085
	tmpLC 		: CM_LocationsController;	// TFS 47085
	height 		: Integer;		// TFS 47085
	terminal 	: CM_Terminal;	// TFS 47085
	updateEvent : Integer;		// TFS 47085
	deleteEvent	: Integer;		// TFS 47085
	wleDeleted	: Boolean;		// TFS 47085
begin
	if not process.isInTransactionState then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Process not in transaction state');
		return false;
	endif;
	
	if self.job = null or not self.job.isKindOf(CM_VoyageHoldJob) then
		return false;
	endif;
	
	if not self.isDRLinkedByFM then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception, otherWLE, wleDeleted);
	
	// Get terminal events to be used later
	terminal := self.getMyTerminal;
	if terminal &lt;&gt; null then
		updateEvent := terminal.getTerminalEvent(WLE_Update_Event);
		deleteEvent := terminal.getTerminalEvent(WLE_Delete_Event);
	endif;
	
	otherWLE := self.getDRLinkedWLE();
	theFM := self.myFutureMove;
	
	if otherWLE = null then
		// at this point otherWLE should not be null, but for sake of safety
		return false;
	endif;
	
	if theFM &lt;&gt; null then
		// Clear out any RT Queue Entries
		while not self.allRTQueueEntries.isEmpty do						// TFS 47085
			self.allRTQueueEntries.last.deleteEntry(false, null);		// TFS 47085
		endwhile;
		while not otherWLE.allRTQueueEntries.isEmpty do					// TFS 47085
			otherWLE.allRTQueueEntries.last.deleteEntry(false, null);	// TFS 47085
		endwhile;
		
		// Destination WLE can't have been split, but the Source Wle could have been
		// Merge them back together
		if _mergeWLE &lt;&gt; null then
			if _mergeWLE.isKindOf(CM_YardWLE) and
			not _mergeWLE.isDRLinkedByFM() then
				_mergeWLE.setQuantity(_mergeWLE.quantity + self.quantity);
				_mergeWLE.setWeight(_mergeWLE.weight + self.weight);
				if _mergeWLE.job &lt;&gt; null then
					_mergeWLE.causeEvent(updateEvent, false, _mergeWLE);
				endif;
				if otherWLE &lt;&gt; _mergeWLE then
					otherWLE.causeEvent(deleteEvent, false, otherWLE);
					delete otherWLE;
				endif;
			endif;
		endif;
		
		// if move is queued, revert to a planned move
		if theFM &lt;&gt; null and theFM.isKindOf(CM_FutureMoveQueued) then	// TFS 47085
			plannedFM := theFM.CM_FutureMoveQueued.myFutureMovePlanned;	// TFS 47085
			theFM.erase(NORMAL_ERASE);				// TFS 47085
			theFM := plannedFM;						// TFS 47085
		endif;
		if theFM &lt;&gt; null then
			theFM.setMyWorkListEntryDR(null, true);
		endif;
		
		otherWLE.edition;
		if not wleDeleted then	// if other wle was deleted then nothing else needs to be done
			if otherWLE.job &lt;&gt; null and otherWLE.job.isVoyageHoldJob then		// TFS 47085
				// Discharge end of tranship, need to restore original discharge future move to yard
				create moveCtrl transient;								// TFS 47085
				moveCtrl.setMyTrackedItem(otherWLE.myTrackedItem);		// TFS 47085
				moveCtrl.setMoveMode(PLANNING_MODE);					// TFS 47085
				moveCtrl.setMyWorkListEntry(otherWLE);					// TFS 47085
				otherWLE.job.getMyTerminal.findLocationFromString(otherWLE.locationTarget, true, tmpLC, height);	// TFS 47085
				moveCtrl.setMyToPrimaryLocation(tmpLC);					// TFS 47085
				
				create newFM;											// TFS 47085
				newFM.setForCreate(moveCtrl, TI_FutureMovePlanned, 0);	// TFS 47085
			else
				otherWLE.causeEvent(updateEvent, false, otherWLE);
			endif;
		endif;
	
		self.causeEvent(updateEvent, false, self);
		app.myEventManager.createSingleObjInfoNoteEvt(self.job.getMyVoyageObject, updateEvent, self);
		
		return true;
	
	elseif self.myFutureMoveDR &lt;&gt; null then
		otherWLE := self.getDRLinkedWLE();
		theFM := self.myFutureMoveDR;
		self.myFutureMoveDR.setMyWorkListEntryDR(null, true);
		theFM.setMyWorkListEntry(self, false);
		delete otherWLE;
		return true;
	endif;
	
	return false;
epilog
	delete moveCtrl;	// TFS 47085
end;</source>
        <Parameter name="_mergeWLE" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForAssignTI" id="c6e0522f-9ffa-4a58-9250-8d710b111a7b">
        <source>validateForAssignTI(_theTI: CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 25/10/2011	cnwdap1		PAR #28524 CCMS POL 2096 Warning if booking voyage differs from planned voyage
vars

	otherWLE : CM_VoyageWLE;
	otherTI : CM_TrackedItem;
	maxTwinLiftDiff : Integer;
	maxLiftWeightTL : Decimal [12,0];
	aCrane : CM_Crane;
	maxTwinLiftDiffSource : String;
	weightDifference : Decimal [12,0];
	totalWeight : Decimal [12,0];
	weightId : String;
	term : CM_Terminal;
	tlslWeight : Boolean;
	theBookingRef : CM_BookingRef;	// PAR #28524
	
	wle : CM_WorkListEntry;
begin
	inheritMethod(_theTI);
	
	//14 June 2010 NDL	Par 24108
	if self.isTwinLift and self.job &lt;&gt; null then
	
		self.job.CM_VoyageJob.getWeightValidationValues( maxTwinLiftDiffSource, aCrane, maxLiftWeightTL, maxTwinLiftDiff);
		
		if maxTwinLiftDiff &gt; 0 or maxLiftWeightTL &gt; 0 then
		
			totalWeight := _theTI.totalWeight;
			weightId :=  "'" &amp; _theTI.id &amp; "'";
				
			otherWLE := self.getTwinLiftWLE().CM_VoyageWLE;
			if otherWLE &lt;&gt; null then
				otherTI := otherWLE.myTrackedItem;
			endif;
			
			if otherTI &lt;&gt; null then
				if maxTwinLiftDiff &gt; 0 then
					weightDifference := ( _theTI.totalWeight - otherTI.totalWeight ).abs;
					if ( weightDifference &gt; maxTwinLiftDiff) then
						app.raiseCMException5(MAX_TWIN_LIFT_WEIGHT_DIFF, maxTwinLiftDiffSource, maxTwinLiftDiff.asStringJMT, _theTI.id, otherTI.id, weightDifference.asStringWeightJMT, 
												null, self);
					endif;
				endif;
				totalWeight := totalWeight + otherTI.totalWeight;
				weightId :=  weightId &amp; "', '" &amp; otherTI.id &amp; "'";
			endif;
			// PAR 26858
			term := _theTI.myTerminal;
			tlslWeight := true;
			if term &lt;&gt; null then
				tlslWeight := not term.getConfig(ShipSLiftIfTLWELoadPlan).Boolean; // 'Apply Make S/L rules during load planning'
			endif;
			if  tlslWeight and maxLiftWeightTL &gt; 0 then
				if _theTI.totalWeight &gt; maxLiftWeightTL then
					app.raiseCMException3(Max_20Foot_weight_exceeded, aCrane.description, maxLiftWeightTL.asStringWeightJMT, _theTI.id, null, self);	
				endif;
				if otherTI &lt;&gt; null and otherTI.totalWeight &gt; maxLiftWeightTL then
					app.raiseCMException3(Max_20Foot_weight_exceeded, aCrane.description, maxLiftWeightTL.asStringWeightJMT, otherTI.id, null, self);
				endif;
			endif;
			
			
			if totalWeight &gt; aCrane.maxLiftWeight then
				app.raiseCMException5(MACH_MAX_LIFT_WEIGHT_TWIN,aCrane.description,aCrane.maxLiftWeight.asStringWeightJMT,_theTI.id,otherTI.id,totalWeight.asStringWeightJMT, null, self);	
			endif;
			
		
		endif;
			
	endif;
	
	// PAR #28524 If operator bookings are unique by number, raise warning if booking voyage differs from voyage being planned to
	if _theTI.myOperator.bookingsUniqueByNumber and (_theTI.myBookingRef &lt;&gt; null or _theTI.bookingReference &lt;&gt; null) then
		if _theTI.myBookingRef &lt;&gt; null then
			theBookingRef := _theTI.myBookingRef;
		else
			theBookingRef := self.getMyTerminal.getBookingReference(_theTI.myOperator.code, _theTI.bookingReference, null);
		endif;
		if theBookingRef &lt;&gt; null then
			if self.job.CM_VoyageJob.myVoyage &lt;&gt; theBookingRef.myVoyage and theBookingRef.myVoyage &lt;&gt; null then
				app.raiseCMWarning2(BookingVoyageMatch, theBookingRef.myVoyage.code, self.job.CM_VoyageJob.myVoyage.code, "bookingReference", null, self);
			endif;
		endif;
	endif;
	// PAR #28524 end
	
	if self.isForLoadJob then
		//epr par 31831 18/6/13
		foreach wle in _theTI.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
			//if wle.CM_VoyageWLE.isForLoadJob and wle &lt;&gt; self and wle.status &lt;&gt; WLE_COMPLETED  then
			if wle.job &lt;&gt; null and wle.CM_VoyageWLE.isForLoadJob and wle &lt;&gt; self and wle.status &lt;&gt; WLE_COMPLETED  then		// 29/06/2013 cnwar2 #31923 - check job not null before calling isForLoadJob
				if not wle.isDRLinkedByFM then	// TFS 42863 jlgzm1 26/07/2019
					app.raiseCMException1(Cargo_already_assigned_load,wle.CM_VoyageWLE.job.jobId,null,null);
				endif;
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForAutoplan" id="92d10b52-cad5-44b6-a04b-fc9f4b974bac">
        <source>validateForAutoplan();
//--------------------------------------------------
// Created:	25 June 2004 By: cnwgd1
//--------------------------------------------------
vars
	request : CM_Request;
begin
	
	if self.job = null then
		//not associated with job
		app.raiseCMException3(ERR_QUEUE_WLE_STAT, self.seqNumAsString, 'not associated with a job', 'auto-planned', null, null);
		return;
	endif;
	
	request := self.myRequest;
	
	//epr par 29057 7/5/12
	if (request.getIsDischarge and not request.isSOB) or request.getBulkReleaseReserveDetail &lt;&gt; null or //epr par 30393 9/1/14
	   self.isVoyageAllocDirector then
		//Carry on
	else
		//Cannot autoplan load jobs at this stage
		app.raiseCMException3(ERR_QUEUE_WLE_STAT, self.seqNumAsString, 'not a discharge job', 'auto-planned', null, null);		
		return;
	endif;
	
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForMove" id="b0d5461b-7c11-486a-a903-523de4a6bc38">
        <source>validateForMove(_controller: CMIF_MoveController; _passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	lJob,dJob : CM_VoyageJob;
	dReq : CM_Request;
	
	ti : CM_TrackedItem;
begin
	inheritMethod(_controller, _passport);

	ti := self.myTrackedItem;
	if _controller.moveMode = QUEUE_MODE 
	and ti &lt;&gt; null 
	and not ( _controller.isFullyUnplan or _controller.isUndoMove) then
		// ### PAR 9559. warning about queuing a load DLR before the discharge DLR
		
		if ti.isRehandle 
		and ti.isOnShip 
		and self.status &lt;&gt; WLE_COMPLETED 
		and not self.isReceipt then // load 
			lJob := self.job.CM_VoyageJob;
			dReq := self.myRequest.getLinkedRequest(false); // PAR 28968 CM_SlotRequest.mySlotRequestDLRSOBDischarge;
			if dReq &lt;&gt; null then
				dJob := dReq.myJob.CM_VoyageJob;
			else
				foreach lJob in ti.allJobsShipReceive reversed do
					if lJob.isRehandle then
						dJob := lJob.CM_VoyageJob;
						break;
					endif;
				endforeach;
			endif;
			
			if dJob &lt;&gt; null and not dJob.isJobComplete then
				app.raiseCMWarning2(TI_DLRDischargeNotComplete, ti.id,dJob.jobId, null, null,self);		
			endif;	
		endif;
	endif;	
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
