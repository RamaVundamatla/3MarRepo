    <JadeMethod name="shouldAuditProperty" id="fb379ff2-d443-4f8e-b586-a6e5f7d46396">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/// ---------------------------------------------------------------------------
// Created:		26 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	propName	: String;
	
begin
	propName := _property.name;
	if propName = CM_RadioTelemetryDevice::allRemoteDataHdr.name then
	   	return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
