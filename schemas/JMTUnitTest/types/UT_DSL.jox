        <Parameter name="_slots" type="CM_SlotControllerArray"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deleteStops" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="planTIsRORO" id="dacd13d3-c6e7-443e-8a08-8182dc02a3e8">
        <updating/>
        <source>planTIsRORO(_tis : CM_TIArray; _lcs : CM_LCArray; _primeReq : CM_RORORequest) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		NAVAB1		Initial creation
*/

vars
	moveController	: CMIF_MoveController;
	result	: Integer;
	theSlotRequest : CM_RORORequest;
	tmpErr	: CM_Error;
	tmpString : String;
begin
	create moveController transient;

	moveController.isRehandleMove := false;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;
	moveController.myVoyageRequest := _primeReq;	

	app.myPassport.setWarningsIgnored(true);

	// ### BULK LOAD PLAN
	app.myTrxUA.trxMoveTIsAUTOAssignToJob(_tis, _lcs, moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();						// 23/07/2015 cnwmh5
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_lcs" type="CM_LCArray"/>
        <Parameter name="_primeReq" type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="planWagon" id="99e99b89-b495-4ed4-8c72-489e78f5128d">
        <source>planWagon(_allWagon : CM_WagonArray;_railLine : CM_RailLine);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	moveController : CMIF_WagonMoveController;
	wagon			: CM_Wagon;
begin
	create moveController transient;
	foreach wagon in _allWagon do
		moveController.allWagons.add(wagon);
	endforeach;
	moveController.myTargetRailLine := _railLine;
	moveController.setMoveMode(PLANNING_MODE);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxMoveWagons(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete moveController;
end;</source>
        <Parameter name="_allWagon" type="CM_WagonArray"/>
        <Parameter name="_railLine" type="CM_RailLine"/>
    </JadeMethod>
    <JadeMethod name="planWagonsToMove" id="070e6ab7-5c9a-4d1d-9af8-9133e787f337">
        <source>planWagonsToMove(_allWagon : CM_WagonArray;_railLine : CM_RailLine);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/
vars
	moveController : CMIF_WagonMoveController;
	wagon			: CM_Wagon;
begin
	create moveController transient;
	foreach wagon in _allWagon do
		moveController.allWagons.add(wagon);
	endforeach;
	moveController.myTargetRailLine := _railLine;
	moveController.setMoveMode(CMIF_WagonMoveController.MOVE_TO_PLAN);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxMoveWagons(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete moveController;
end;</source>
        <Parameter name="_allWagon" type="CM_WagonArray"/>
        <Parameter name="_railLine" type="CM_RailLine"/>
    </JadeMethod>
    <JadeMethod name="postInvoices" id="f46dc798-5402-4bad-bd01-595b27bf3601">
        <source>postInvoices() : Boolean;

/*

Purpose:		Post Invoices for terminal(s) and possibly a date range as well

				Terminals and date ranges are passed via opts

Date			Who		Reason
14/02/2014		cnwmh5	Initial creation
11/06/2015		cnwmh5  Change to use new CleanUpDetails Classes
*/
constants

	DELIM							: String = Tab;
	
vars

	terminal						: CM_Terminal;
	bank							: CM_Bank;
	invoice							: CM_Invoice;
	pxyInvoice						: CM_Invoice;
	theStatus 						: CMIF_InvoiceStatus;
	//cleanUpDetails					: UM_CleanUpResultsDetails;
	cleanUpDetails					: UM_CleanUpDetails;
	obj								: Object;
	
	terminalArray					: CM_TerminalArray;
	termInvPostStatusArray			: BooleanArray;
	statuses						: CMIF_Array;
	oa								: ObjectArray;
	invoices						: CM_InvoiceBySeqNumDict;
	
	iter							: Iterator;
	
	index							: Integer;
	startTS							: TimeStamp;
	endTS							: TimeStamp;
	debtorName 						: String;
	trackedItemId					: String;
	narration						: String;
	count							: Integer;
	methodStartTS					: TimeStamp;
	noErrors						: Boolean;

begin

	// transients
	create termInvPostStatusArray transient;
	create statuses transient;
	create oa transient;
	create invoices transient;
	
	noErrors := false;
	
	methodStartTS := app.cnGetServerTime();
	
	// get the terminal(s)
	if self.opts.includesKey("TerminalArray") then
		terminalArray := self.opts.obj("TerminalArray").CM_TerminalArray;
	endif;
	self.assertNotEqual(terminalArray.size, 0);
	
	// get the start and end timestamps
	startTS := null;
	if self.opts.includesKey("StartDate") then
		startTS.setDate(self.opts.str("StartDate").TimeStamp.date);
		startTS.setTime("00:00:00".Time);
	endif;
	if not startTS.isValid() then
		startTS:= null;
	endif;
	endTS := null;
	if self.opts.includesKey("EndDate") then
		endTS.setDate(self.opts.str("EndDate").TimeStamp.date);
		endTS.setTime("23:59:59".Time);
	endif;
	if not endTS.isValid() then
		endTS := null;
	endif;
	
	foreach terminal in terminalArray do
	
		// set the terminals InvPostWithoutAuditQual
		termInvPostStatusArray.add(terminal.getConfig(InvPostWithoutAuditQual).Boolean);
		if self.opts.includesKey("Terminal") then
			self.opts.removeAssoc("Terminal");
		endif;
		self.opts.addAssoc("Terminal", terminal.code);
		self.setTerminalConfig(InvPostWithoutAuditQual, true);
		self.opts.removeAssoc("Terminal");
		self.assertNotEqual(terminal.getConfig(InvPostWithoutAuditQual), true);
		
		// set the passports termina = required in trx level
		app.myPassport.setMyTerminal(terminal);
		
		// PENDING
		foreach bank in terminal.companies discreteLock do
			
			statuses.clear();
			
			delete iter;
			iter := bank.allInvoicesByToDate.createIterator;
			bank.allInvoicesByToDate.startKeyGeq(bank.terminal, bank, startTS, CM_Invoice.INVOICE_OPEN, 0, iter);
			
			while iter.next(invoice) do
			
				// don't care if not open
				if invoice.status &lt;&gt; CM_Invoice.INVOICE_OPEN then
					continue;
				endif;
			
				// dates specified so do that checking
				if endTS &lt;&gt; null and invoice.toDT &gt; endTS then
					continue;
				endif;
			
				pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
				oa.add(pxyInvoice);	
				if not invoices.includes(invoice) then
					invoices.add(invoice);
				endif;
				
				create theStatus transient;
				theStatus.myInvoice := pxyInvoice;
				theStatus.newStatus := CM_Invoice.INVOICE_PENDING;
				theStatus.purchaseOrderNumber := 666.String;
				theStatus.narration := invoice.narration;
				theStatus.isZeroRatedTax := invoice.isZeroRatedTax;
				theStatus.myTermsOfTrade := invoice.invoiceType.myInvTermsOfTrade;
				theStatus.debtorReference := invoice.debtorReference;
				theStatus.toDT.setDate(invoice.toDT.date);
				theStatus.toDT.setTime('23:59:59.999'.Time);
				theStatus.doExport := false;
				statuses.add(theStatus);
				
				debtorName := null;
				trackedItemId := null;
				if invoice.debtor &lt;&gt; null then
					debtorName := invoice.debtor.name;
				endif;
				if invoice.myTrackedItem &lt;&gt; null then
					trackedItemId := invoice.myTrackedItem.id;
				endif;
		
				narration := invoice.narration;
				narration := narration.replaceString(CrLf, " ");
				
	//			app.writeLog("Changing invoice (" &amp; invoice.sequenceNum.String &amp; ") status from OPEN to PENDING.  " &amp; 
	//				terminal.code &amp; DELIM &amp; bank.code &amp; DELIM &amp; invoice.fromDT.String &amp; DELIM &amp; debtorName &amp; DELIM &amp; 
	//				trackedItemId &amp; DELIM &amp; narration, LogINFO);
				
				count := count + 1;
								
			endwhile;
			
			// update the invoice / invoices lines 1st to PENDING then to POSTED			
			if not statuses.isEmpty() then
				// update the invoice / invoice lines to PENDING
				app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
				if not app.myPassport.trxCompletedOK then
			//		app.writeLog("Error during PENDING" &amp; Tab &amp; app.myPassport.getAllErrorsAndWarningsAsStr(), LogINFO);
					if app.isOvernightRun then
						beginTransaction;
						create cleanUpDetails persistent;
						//cleanUpDetails.createRecord(startTS, app.cnGetServerTime(), count, "Posted - Error", 0, 0);
						cleanUpDetails.updateDetails(startTS, app.cnGetServerTime(), count, UM_CleanUpDetails.TaskDescriptionPostInvoiceErr, null);
						commitTransaction;
					endif;
					return noErrors;
				endif;
			endif;
		
		endforeach;
	
	endforeach;
	
	// POST
	statuses.clear();
	if oa &lt;&gt; null then
		oa.purge;
	endif;
	delete oa;
	create oa transient;
	foreach invoice in invoices do
	
		// set the passports terminal - required in trx level
		app.myPassport.setMyTerminal(invoice.myTerminal);
		
		pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
		oa.add(pxyInvoice);		
	
		create theStatus transient;
		theStatus.myInvoice := pxyInvoice;
		theStatus.newStatus := CM_Invoice.INVOICE_POSTED;
		theStatus.purchaseOrderNumber := 666.String;
		theStatus.narration := invoice.narration;
		theStatus.isZeroRatedTax := invoice.isZeroRatedTax;
		theStatus.myTermsOfTrade := invoice.invoiceType.myInvTermsOfTrade;
		theStatus.debtorReference := invoice.debtorReference;
		theStatus.toDT.setDate(invoice.toDT.date);
		theStatus.toDT.setTime('23:59:59.999'.Time);
		theStatus.doExport := false;
		statuses.add(theStatus);
	
		debtorName := null;
		trackedItemId := null;
		if invoice.debtor &lt;&gt; null then
			debtorName := invoice.debtor.name;
		endif;
		if invoice.myTrackedItem &lt;&gt; null then
			trackedItemId := invoice.myTrackedItem.id;
		endif;

		narration := invoice.narration;
		narration := narration.replaceString(CrLf, " ");

	//	app.writeLog("Changing invoice (" &amp; invoice.sequenceNum.String &amp; ") status from PENDING to POSTED.  " &amp; 
	//		terminal.code &amp; DELIM &amp; bank.code &amp; DELIM &amp; invoice.fromDT.String &amp; DELIM &amp; debtorName &amp; DELIM &amp; 
	//		trackedItemId &amp; DELIM &amp; narration, LogINFO);

	endforeach;
	
	// update the invoice / invoice lines to POSTED
	if not statuses.isEmpty() then
		app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
		if not app.myPassport.trxCompletedOK then
	//		app.writeLog("Error during POSTING" &amp; Tab &amp; app.myPassport.getAllErrorsAndWarningsAsStr(), LogINFO);
			if app.isOvernightRun then
				beginTransaction;
				create cleanUpDetails persistent;
				//cleanUpDetails.createRecord(startTS, app.cnGetServerTime(), count, "Posted - Error", 0, 0);
				cleanUpDetails.updateDetails(startTS, app.cnGetServerTime(), count, UM_CleanUpDetails.TaskDescriptionPostInvoiceErr, null);
				commitTransaction;
			endif;
			return noErrors;
		endif;
	endif;
	
	if app.isOvernightRun then
		beginTransaction;
		create cleanUpDetails persistent;
		//cleanUpDetails.createRecord(methodStartTS, app.cnGetServerTime(), count, "Posted", 0, 0);
		cleanUpDetails.updateDetails(startTS, app.cnGetServerTime(), count, UM_CleanUpDetails.TaskDescriptionPostInvoice, null);
		commitTransaction;
	endif;

	noErrors := true;
	return noErrors;
	
epilog

	if oa &lt;&gt; null then
		oa.purge;
	endif;
	delete oa;
	if statuses &lt;&gt; null then
		foreach obj in statuses do
			delete obj;
		endforeach;
	endif;
	delete statuses;
	delete iter;
	
	delete terminalArray;
	delete termInvPostStatusArray;
	delete invoices;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
