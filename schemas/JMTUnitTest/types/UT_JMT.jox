    <JadeMethod name="uCheck_getDisplayString" id="5771d5c6-0265-4e53-b91b-77fe92b8e1dc">
        <source>uCheck_getDisplayString();
/*
Date			Who		Reason
25 Jul 2025	navbs1	Initial creation Story MTN-35186: MTN - Investigate getDisplayStringForAttribute Improvements
*/
vars
	schema			: Schema;
	klass			: Class;
	meth			: Method;
	classes			: ClassColl;
	tokens			: HugeStringArray;
	methodSource	: String;
	tokensSize		: Integer;
	token			: String;
	tokenPos		: Integer;
	count			:Integer;
	columnString 	:StringArray;
	column			:String;
	totalelseIf 	:Integer;
 

begin
	// get the schema
	schema := rootSchema.getSchema("PortSchema");
	assertNotNull(schema);
	// get the class
	klass := schema.getClass("CM_Object");
	assertNotNull(klass);
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	create columnString transient;
	// go throught the class and check pxyCreateUpdateProxy
	foreach klass in classes do
		// check that the class actually has the method
		meth := klass.getMethod('getDisplayStringForAttribute');
		if meth = null then
			continue;
		endif;
	methodSource := self.removeCommentsFromSource(meth.getSource());
	methodSource.replaceChar(Cr, " ");
	methodSource.replaceChar(Lf, " ");
	// Break method source into tokens
	delete tokens;
	tokens := methodSource.getHugeTokens;
	tokensSize := tokens.size;
 

	foreach tokenPos in 1 to tokensSize do
	token := tokens[tokenPos];
		if( token = "elseif" or token = "if" )and tokens[tokenPos+3].startsWith("ETRow") then 
		totalelseIf:= totalelseIf+1;
		endif;
		if( token = "elseif" or token = "if" )and self.xcheckReturnStatement(tokens[tokenPos+3],tokens[tokenPos+6]) then 
		count := count +1;
		columnString.add(tokens[tokenPos+3]);
		endif;
	endforeach;		
	write klass.name&amp; ","&amp; totalelseIf.String &amp; "," &amp; count.String;
	//write  " total Elseif's" &amp; " : "&amp; totalelseIf.String ; 
	//write  " Matching Regex" &amp; " : "&amp; count.String ;
	
	count := 0;
	totalelseIf :=0;
	columnString.clear;
	endforeach;
 
epilog
 
	delete classes;
	delete tokens;
	delete columnString;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCheck_pxyCreateUpdateProxyOK" id="592522af-96e3-41be-9c7c-0c4b8a268f1b">
        <source>uCheck_pxyCreateUpdateProxyOK();

/*

Purpose:			Check that all pxyCreateUpdateProxy methods have completedOK / epilog changes

Date			Who		Reason
20 April 2011	cnwmh5	Initial creation #27401

*/

vars

	schema		: Schema;
	klass		: Class;
	meth		: Method;
	
	sourceNotOK	: HugeStringArray;
	classes		: ClassColl;
	
	str			: String;

begin

	// get the schema
	schema := rootSchema.getSchema("PortSchema");
	assertNotNull(schema);
	
	// get the class
	klass := schema.getClass("CM_Object");
	assertNotNull(klass);
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	
	create sourceNotOK transient;
	
	// go throught the class and check pxyCreateUpdateProxy
	foreach klass in classes do
	
		// check that the class actually has the method
		meth := klass.getMethod('pxyCreateUpdateProxy');
		if meth = null then
			continue;
		endif;
		
		self.check_pxyCreateUpdateProxyCode(meth, sourceNotOK);
				
	endforeach;
	
	// if something in here then need to know about it
	if sourceNotOK.size &gt; 0 then
		foreach str in sourceNotOK do
			app.writeStatement(str);
		endforeach;
	endif;
	
	assertEqual(sourceNotOK.size, 0);	
	
epilog

	delete classes;
	delete sourceNotOK;

end;</source>
    </JadeMethod>
    <JadeMethod name="uCodeCoverage" id="0e49e8eb-b1e1-499f-bde9-5353ec4d48da">
        <source>uCodeCoverage();

/*

Purpose:		Check code coverage	

Date		Who		Reason
07/02/2011	cnwndl1	Initial creation
03/08/2012	cnwmh5	Convert to a unit test to be run at the end of the Sunday logResult run

*/

vars
	
	classMeth 					: UM_ClassMethod;
	root 						: UM_Root;
	schema 						: Schema;
	portSchema 					: Schema;
	cMIF_ObjectClass 			: Class;
	cM_ObjectClass 				: Class;
	cM_QueryClass 				: Class;
	cM_TransientClass 			: Class;
	class 						: Class;
	rootClass 					: Class;
	rootClasses 				: ClassColl;
	allClasses 					: ClassColl;
	
	meths 						: MethodNDict;
	
	iter 						: Iterator;
	
	asAtDate 					: Date;
	fileLine 					: String;
	methCount 					: Integer;
	methCover 					: Integer;
	totalCount 					: Integer;
	classCover 					: Integer;
	
begin

	root := UM_Root.firstInstance;
	asAtDate := root.allTestRuns.last.startTimestamp.Date;
	schema := currentSchema;
	while portSchema = null do
		if schema.superschema.name = "PortSchema" then
			portSchema := schema.superschema;
			break;
		else
			schema := schema.superschema;
		endif;
	endwhile;
	
	cMIF_ObjectClass := portSchema.getClass("CMIF_Object");
	cM_ObjectClass := portSchema.getClass("CM_Object");
	cM_QueryClass := portSchema.getClass("CM_Query");
	cM_TransientClass := portSchema.getClass("CM_Transient");
	
	create rootClasses transient;
	rootClasses.add(cMIF_ObjectClass);
	rootClasses.add(cM_ObjectClass);
	rootClasses.add(cM_QueryClass);
	rootClasses.add(cM_TransientClass);
	
	allClasses := portSchema.getAllClasses(false);
	
	iter := root.allClassMethods.createIterator;
	create meths transient;
	
	fileLine := "As at " &amp; asAtDate.asStringJMT &amp;  ", , , ";
	app.writeStatement(fileLine);
	fileLine := "RootClass,SubClass,Methods covered,Total methods";
	app.writeStatement(fileLine);
	
	foreach rootClass in rootClasses do
	
		fileLine :=  rootClass.name &amp; ",,,";
		app.writeStatement(fileLine);
		app.writeStatement(",,,");
	
		foreach class in allClasses where class.inheritsFrom(rootClass) do
			totalCount := totalCount + 1;
			classMeth := root.allClassMethods.getAtKeyGeq(class.name,null);
			class.getMethods(meths);
			methCount := meths.size;
			if methCount = 0 then
				continue;
			endif;
			meths.clear;
			methCover := 0;
			if classMeth &lt;&gt; null and classMeth.classString = class.name then
				
				classCover := classCover + 1;
				iter.reset;
				iter.startAtObject( classMeth );
				while iter.next( classMeth ) do
					if classMeth.classString = class.name then
						methCover := methCover + 1;
					endif;
				endwhile;
			endif;
			fileLine := "," &amp; class.name &amp; ", " &amp; methCover.String &amp; "," &amp; methCount.String;
			app.writeStatement(fileLine);
		endforeach;
	
		fileLine := rootClass.name &amp; " subclass cover,, " &amp; classCover.String &amp; "," &amp; totalCount.String;
		app.writeStatement(fileLine);
		app.writeStatement(",,,");
		
		classCover := 0;
		totalCount := 0;
	
	endforeach;

epilog

	delete allClasses;
	delete rootClasses;
	delete iter;
	delete meths;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uGetTIsToDelete" id="f025f0e6-ee34-4d4d-a278-5908f48492ea">
        <source>uGetTIsToDelete();

/*

Purpose:		Get Tracked Items to delete.  Need to get all of those with invalid
				objects before we can delete as need to have all the invalid objects
				set to null or a dummy value

Date			Who		Reason
02/06/2015		cnwmh5	Initial creation

*/

vars

	root						: UM_Root;
	schema						: Schema;
	klass						: Class;
	prop						: Property;
	obj							: Object;
	propObjValue				: Object;
	objToDelete					: UM_ObjectsToDelete;
	currentObj					: Object;
	newTerm						: CM_Terminal;
	operator					: CM_Operator;
	obj2						: Object;
	passport					: CM_Passport;
	cou							: CM_ClipOnUnit;
	
	classes						: ClassColl;
	tiSet						: CM_TISet;
	dict						: DynaDictionary;
	nullRefsDelObjArray			: StringArray;
	objArray					: ObjectArray;
	
	properties					: PropertyColl;
	
	iter						: Iterator;
	iter2						: Iterator;
	
	objFound					: Boolean;
	countAll					: Integer;
	errorFound					: Boolean;
	nullRefsDelObj				: Boolean;
	oidStr						: String;
	reason						: String;
	propName					: String;
	noTIsToDelete				: Integer;
	errorHasBeenFound			: Boolean;

begin

	root := UM_Root.firstInstance;
	self.assertNotNull(root);
	
	// TO BE REMOVED
	beginTransaction;
	foreach newTerm in app.myRoot.allTerminals do
		self.opts.purge();
		self.opts.addAssoc("Terminal", newTerm.code);
		if newTerm.getConfig("DefVoyage") = null then
			newTerm.setConfig("DefVoyage", newTerm.getNullVoyage());
		endif;
	endforeach;
	commitTransaction;
	
	create objArray transient;
	
	newTerm := app.getTerminalByName("Unit Test") ; 
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// get the classes to look check
	schema := rootSchema.getSchema("PortSchema");
	self.assertNotNull(schema);
	
	klass := schema.getClass("CM_TrackedItem");
	self.assertNotNull(klass);
	
	create nullRefsDelObjArray transient;
	nullRefsDelObjArray.add("myTerminal");
	nullRefsDelObjArray.add("myCargoType");
	nullRefsDelObjArray.add("myVoyage");
		
	create dict transient;
	dict.setMembership(Object);
	dict.addExternalKey(String, 50, false, false);				// reason for fail
	dict.addExternalKey(String, 50, false, false);				// objects oid as string
	dict.addExternalKey(String, 50, false, false);				// field failing
	dict.endKeys(false);
	
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	create tiSet transient;
	create properties transient;
	iter := classes.createIterator;
	while iter.next(klass) do
	
		///if klass.name &lt;&gt; "CM_Container" then
		///	continue;
		///endif;
	
		objFound := false;
	
		delete iter2;
		iter2 := klass.instances.createIterator;
		while iter2.next(obj) do
		
			///if obj.CM_TrackedItem.id &lt;&gt; "RJD10100604" then
			///	continue;
			///endif;
			
			app.writeLog(obj.CM_TrackedItem.String &amp; Tab &amp; obj.CM_TrackedItem.id &amp; Tab &amp; obj.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp;
				obj.creationTime.time.String, LogINFO);
			
			delete properties;
			properties := obj.class.allProperties();
			
			errorHasBeenFound := false;
			countAll := countAll + 1;
			
			foreach prop in properties do
			
				errorFound := false;
			
				if prop.isKindOf(Reference) and prop.name &lt;&gt; "schema" and prop.name[1:1] &lt;&gt; "_" and
						not prop.virtual then
					
					propObjValue := obj.getPropertyValue(prop.name).Object;
					nullRefsDelObj := nullRefsDelObjArray.includes(prop.name);
					
					if self.xCheckIsDeleted(propObjValue) then
						//write obj.String &amp; Tab &amp; obj.getPropertyValue('id').String &amp; Tab &amp; prop.name &amp; Tab &amp; 
						//	obj.getPropertyValue(prop.name).Object.String &amp; Tab &amp; "**DELETED**";
						////dict.putAtKey(obj.getOidAsString(), "**DELETED**", prop.name, obj);
						if not errorFound then
							errorFound := true;
						endif;
					elseif propObjValue &lt;&gt; null and not global.isValidObject(propObjValue) then
						//write obj.String &amp; Tab &amp; obj.getPropertyValue('id').String &amp; Tab &amp; prop.name &amp; Tab &amp; 
						//	obj.getPropertyValue(prop.name).Object.String &amp; Tab &amp; "**INVALID**";
						////dict.putAtKey(obj.getOidAsString(), "**INVALID**", prop.name, obj);
						if not errorFound then
							errorFound := true;
						endif;
					elseif propObjValue = null then
						if nullRefsDelObjArray.includes(prop.name) then
							//write obj.String &amp; Tab &amp; obj.getPropertyValue('id').String &amp; Tab &amp; prop.name &amp; Tab &amp; 
							//	obj.getPropertyValue(prop.name).Object.String &amp; Tab &amp; "**NULL**";
							////dict.putAtKey(obj.getOidAsString(), "**NULL**", prop.name, obj);
							if not errorFound then
								errorFound := true;
							endif;
						endif;
					endif;
					
				endif;
				
				if not errorFound then
					continue;
				endif;
				
				// set the known problem fields
				beginTransaction;
				if prop.name = "myCargoType" then
					obj.setPropertyValue("cargoType", "11202");
				elseif prop.name = "myTerminal" then
					obj.setPropertyValue(prop.name, newTerm);
				elseif prop.name = "myOperator" then
					obj.setPropertyValue(prop.name, operator);
				elseif prop.name = "myVoyage" then
					if global.isValidObject(obj.getPropertyValue("myTerminal").CM_Terminal) then
						obj.setPropertyValue(prop.name, obj.getPropertyValue("myTerminal").CM_Terminal.getNullVoyage());
					else
						obj.setPropertyValue(prop.name, null);
					endif;
				else
					obj.setPropertyValue(prop.name, null);
				endif;
				commitTransaction;
				
				errorHasBeenFound := true;
			
			endforeach;
			
			if not errorHasBeenFound then
				continue;
			endif;
			
			objToDelete := root.allObjectsToDeleteByObject[obj.getOidAsString()];
			if objToDelete &lt;&gt; null then
				continue;
			endif;
			
			beginTransaction;
			
			create objToDelete persistent;
			objToDelete.updateDetails(obj, UM_ObjectsToDelete.WhenToDeleteNext);
			noTIsToDelete := noTIsToDelete + 1;
			
			obj.CM_TrackedItem.setPropertyValue("readyToShip", false);
		
			// check that locations are not invalid
			if not global.isValidObject(obj.CM_TrackedItem.myPrimaryActualLocation) then
				obj.CM_TrackedItem.setPropertyValue("myPrimaryActualLocation", null);
			endif;
			if not global.isValidObject(obj.CM_TrackedItem.myPrimaryPlannedLocation) then
				obj.CM_TrackedItem.setPropertyValue("myPrimaryPlannedLocation", null);
			endif;
			if not global.isValidObject(obj.CM_TrackedItem.myPrimaryQueuedLocation) then
				obj.CM_TrackedItem.setPropertyValue("myPrimaryQueuedLocation", null);
			endif;		
			
			if not obj.CM_TrackedItem.allQueuedFutureMoves.isEmpty() or 
					not obj.CM_TrackedItem.allPlannedFutureMoves.isEmpty() then
				objArray.clear();
				obj.CM_TrackedItem.allQueuedFutureMoves.copyNoDups(objArray);
				obj.CM_TrackedItem.allPlannedFutureMoves.copyNoDups(objArray);
			
				foreach obj2 in objArray do
					delete obj2;
				endforeach;
			endif;
			
			// if child then need to detach from parent
			if obj.CM_TrackedItem.isChild() then
				if obj.isKindOf(CM_ClipOnUnit) and obj.CM_TrackedItem.myParent = null then
						obj.CM_ClipOnUnit.setPropertyValue("myParent", obj.CM_ClipOnUnit.myReefer);
					endif;
				obj.CM_TrackedItem.myParent.detachChild(obj.CM_TrackedItem);
			endif;
			
			if obj.CM_TrackedItem.hasChildren then
				obj.CM_TrackedItem.detachChildren();
			endif;
			
			if obj.isKindOf(CM_Container) then
				cou := obj.CM_Container.getCou();
				if cou &lt;&gt; null and cou.myReefer &lt;&gt; null then
					if cou.myParent = null then
						cou.setPropertyValue("myParent", cou.myReefer);
					endif;
					cou.myReefer.detachCOU(passport);
				endif;
			endif;
			
			commitTransaction;
		
			/*******************************************************************************
			* Anything that needs updating but has begin/commitTransaction
			*******************************************************************************/
			
			if obj.CM_TrackedItem.isQueued() then
				self.unqueueTI(obj.CM_TrackedItem);
			endif;
			
			if obj.CM_TrackedItem.isPlanned(PLANNING_MODE) then
				self.unplanTI(obj.CM_TrackedItem);
			endif;
			
			///if obj.CM_TrackedItem.id &lt;&gt; "RJD10100604" then
			///	break;
			///endif;
			
			if noTIsToDelete &gt;= 50000 then
				break;
			endif;
		
		endwhile;
		
		if noTIsToDelete &gt;= 50000 then
			break;
		endif;
		
	endwhile;
	
	app.writeLog("No of TI's to Delete = " &amp; noTIsToDelete.String, LogINFO);
	app.writeLog("UM_ObjectsToDelete.instances.size: " &amp; UM_ObjectsToDelete.instances.size.String, LogINFO);
	
epilog

	delete iter;
	delete iter2;
	delete classes;
	delete tiSet;
	delete properties;
	dict.clear();
	delete dict;
	delete nullRefsDelObjArray;
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="uMPDCleanTerminal" id="cdf53466-fabb-4463-9675-ef9f08279f99">
        <source>uMPDCleanTerminal();
/*

Purpose:			Get rid of 'stuff' every so often

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2017	jlgmd1	Initial creation

*/

vars
	term	: CM_Terminal;
	voy		: CM_Voyage;
	veh		: CM_Vehicle;
	b		: CM_BookingRef;
	rel		: CM_BulkRelease;
	dump	: CM_DataDumpExtractDef;
	ti		: CM_TrackedItem;
	trn		: CM_Train;
begin

	term := app.myRoot.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	if term = null or term.code = "UT" then
		self.logMessage("Error, Terminal [" &amp; self.getProfileSetting(UT_Profile.P_TERMINAL).asString &amp; "] not found");
		return;
	endif;
	
	// Clean up voyages and cargo
	self.logMessage("Clean up voyages and cargo");
	foreach voy in term.allVoyagesSet where voy.code &lt;&gt; NULL_VOYAGE_CODE do
		self.deleteVoyageJobs(voy);
		self.deleteVoyage(voy.code);
	endforeach;	
	
	// Clean up any trains
	self.logMessage("Clean up trains");
	foreach trn in term.allTrainsArrival do
		self.deleteTrainAndAssociatedObjs(trn);
	endforeach;
	foreach trn in term.allTrainsDeparted do
		self.deleteTrainAndAssociatedObjs(trn);
	endforeach;
	
	// Clean up any vehicles and visits
	self.logMessage("Clean up vehciles");
	foreach veh in term.vehicles do
		self.deleteVehicle(veh.regNumber);
	endforeach;
	
	// Clean up any bookings
	self.logMessage("Clean up bookings");
	foreach b in term.allBookingRefsByRef do
		self.deleteBooking(b.bookingReference);
	endforeach;
	
	// Clean up releases
	self.logMessage("Clean up releases");
	foreach rel in term.allBulkReleasesByCodeDate do
		self.deleteReleaseRequest(rel.code);
	endforeach;
	
	// Other 'stuff'
	self.logMessage("Clean up misc collections");
	beginTransaction;
	term.allAuditObjectsForClass.purge();
	term.allBatNumbersInUse.purge();
	term.allCargoChecks.purge();
	commitTransaction;
	
	// Any remaining TIs
	self.logMessage("Clean up non voyage TIs");
	foreach ti in term.allOnsiteTIsByCargoTypeId do
		self.deleteTrackedItem(ti, false);
	endforeach;
	
	// And the transactions
	self.logMessage("Clean up TI transactions");
	beginTransaction;
	term.allTITransactions.purge();
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uMPDCreateVoyages" id="fd122d52-2434-4fe4-b9a6-9c1f48618d8d">
        <source>uMPDCreateVoyages();
/*

Purpose:			Create some new voyages in the terminal with some cargo on them.

Parameters:						*** NOT YET COMPLETE ***

Return Value:		

Date		Who		Reason
19 August 2019	jlgmd1	Initial creation

*/

constants
	VESSEL 				: String = "MPDAM1";
	VOY_CODE_MASK 		: String = "MPDAM";
	ContainerId			: String = "GENCARG00";
vars
	term 		: CM_Terminal;
	voy			: CM_Voyage;
	lastVoyCode,
	nextVoyCode	: String;
	operator	: CM_Operator;
	
	voyage		: CM_Voyage;
	port		: CM_Port;
	cargo		: CM_TrackedItem;
	cargoCount,
	idx			: Integer;
	strs		: StringArray;
	theSlot		: CM_LocationsController;
begin
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertNotNull(operator);

	term := app.myRoot.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	self.assertNotNull(term);
	
	foreach voy in term.allVoyagesSet where voy.code &lt;&gt; NULL_VOYAGE_CODE do
		if voy.code[1:VOY_CODE_MASK.length] = VOY_CODE_MASK then
			if lastVoyCode = null then
				lastVoyCode := voy.code;
				continue;
			endif;
			if voy.code[VOY_CODE_MASK.length+1:end].Integer &gt; lastVoyCode[VOY_CODE_MASK.length+1:end].Integer then
				lastVoyCode := voy.code;
			endif;
		endif;
	endforeach;
	if lastVoyCode = null then
		lastVoyCode := VOY_CODE_MASK &amp; "0000";
	endif;
	
	
	nextVoyCode := VOY_CODE_MASK &amp; (lastVoyCode[VOY_CODE_MASK.length+1:end].Integer + 1).Integer.padLeadingWith("0",4);
	voyage := self.addVoyageWithContainerStructur(nextVoyCode, VESSEL, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage);
	
	port := app.myRoot.allPorts[term.getConfig(PortDestCode).String];
	cargoCount := 1;
	
	
	/*******************************************************************************
		For screen
	********************************************************************************/
	
	// 20 General
	create strs transient;
	strs.add("010688");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010686");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010488");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010486");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010484");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010288");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010286");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010284");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
			
	
	// 40 General
	strs.clear();
