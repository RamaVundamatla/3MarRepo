    <JadeMethod name="setForCreate" id="6bc6393a-593d-4907-9d17-fe3c987ad4ba">
        <updating/>
        <source>setForCreate(_pxyFaultRespomse : CM_FaultResponse;
				_terminal : CM_Terminal ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	fault : CM_Fault;
begin

	setForUpdate(_pxyFaultRespomse);
	self.myTerminal:=_terminal;
	
	if self.myFaultQuestion.myFaultType &lt;&gt; null then
		if self.myFaultQuestion.failureCondition = self.response then
			create fault persistent;
			fault.setFromFaultResponse(self);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyFaultRespomse" type="CM_FaultResponse"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="30447743-4321-4f97-bcfa-7f36efb9ff44">
        <updating/>
        <source>setForUpdate(_pxyFaultResponse : CM_FaultResponse) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.myFaultQuestion:=_pxyFaultResponse.myFaultQuestion;
	self.myMachine:=_pxyFaultResponse.myMachine;
	self.myReportedByUser:=_pxyFaultResponse.myReportedByUser;
	self.previousUser:=_pxyFaultResponse.previousUser;
	self.question:=_pxyFaultResponse.question;
	self.reportedTS:=_pxyFaultResponse.reportedTS;
	self.response:=_pxyFaultResponse.response;

epilog

end;</source>
        <Parameter name="_pxyFaultResponse" type="CM_FaultResponse"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b938b239-2cc9-4206-912a-5887be724434">
        <updating/>
        <source>setProxy( _machine : CM_Machine;
		 _reportedUser : CM_User;		
		 _previousUser : String;
		 _faultQuestion : CM_FaultQuestion;
		 _question :String;
		 _reportedTS : TimeStamp;
		 _response : String) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.myMachine:=_machine;
	self.myReportedByUser:=_reportedUser;
	self.previousUser:=_previousUser;
	self.myFaultQuestion:=_faultQuestion;
	self.question:=_question;
	self.reportedTS:=_reportedTS;
	self.response:=_response;

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_reportedUser" type="CM_User"/>
        <Parameter name="_previousUser" type="String"/>
        <Parameter name="_faultQuestion" type="CM_FaultQuestion"/>
        <Parameter name="_question" type="String"/>
        <Parameter name="_reportedTS" type="TimeStamp"/>
        <Parameter name="_response" type="String"/>
    </JadeMethod>
