    <JadeMethod name="getContractById" id="40ad2333-ce52-42c2-8b74-38917a703711">
        <source>getContractById(_contractId : String) : CM_InvoiceContract;
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1
vars
		contract : CM_InvoiceContract;
begin
	foreach contract in self.allInvoiceContracts discreteLock do
		if contract.contractId = _contractId then
			return contract;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_contractId" type="String"/>
