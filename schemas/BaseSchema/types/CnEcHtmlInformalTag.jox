    <DbClassMap file="basehtml"/>
    <PrimAttribute name="contentValue" id="0084f318-5f93-475e-b4a8-cb5ff0c22698">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="isBold" id="978adec9-7198-4f82-b498-945dc66844d3">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isEmphasised" id="21053f4c-9a4a-4b80-b4dd-f3ba7304dcc4">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isItalic" id="9d9b279a-02c8-4b51-904f-238135598c64">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isLineBreakEnd" id="38eef0c6-db45-45f8-a166-46a75ca51337">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isLineBreakStart" id="3e6fba17-63ea-472d-90a2-656678a31010">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isStrong" id="091259cc-567c-48bb-9f4c-82bb80006061">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isSubscript" id="5638670a-16da-4a91-b70e-a7818baced14">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isSuperscript" id="62526048-222c-4a4d-a216-24b996edc649">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="0ad3ca3b-b068-4b81-a62b-92e762f083dd">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	htmlString	:=	self.contentValue;
	
	if self.isLineBreakStart then
		htmlString	:=	'&lt;BR&gt;' &amp; htmlString;
	endif;
	
	if self.isBold then
		htmlString	:=	'&lt;B&gt;' &amp; htmlString &amp; '&lt;/B&gt;';
	endif;
	
	if self.isEmphasised then
		htmlString	:=	'&lt;EM&gt;' &amp; htmlString &amp; '&lt;/EM&gt;';
	endif;
	
	if self.isItalic then
		htmlString	:=	'&lt;I&gt;' &amp; htmlString &amp; '&lt;/I&gt;';
	endif;
	
	if self.isStrong then
		htmlString	:=	'&lt;STRONG&gt;' &amp; htmlString &amp; '&lt;/STRONG&gt;';
	endif;
	
	if self.isSubscript then
		htmlString	:=	'&lt;SUB&gt;' &amp; htmlString &amp; '&lt;/SUB&gt;';
	endif;
	
	if self.isSuperscript then
		htmlString	:=	'&lt;SUP&gt;' &amp; htmlString &amp; '&lt;/SUP&gt;';
	endif;
	
	if self.isLineBreakEnd then
		htmlString	:=	htmlString &amp; '&lt;BR&gt;';
	endif;
epilog
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="cab59fe3-e472-416a-a52a-382dfde63e6b">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.buildTagBody() &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
