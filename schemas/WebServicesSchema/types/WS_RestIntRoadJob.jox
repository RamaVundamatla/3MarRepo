<Class name="WS_RestIntRoadJob" id="bd43a2ab-7afd-46ae-ab0b-a28871d341e9">
    <superclass name="WS_RestIntJob"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="regNumber" id="efbd36c9-433f-4f97-9629-ce7ac3ff0da5">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="releaseRequest" id="95a73019-998a-47de-a61f-395ee61171a3">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="sourceLocation" id="0f195b28-aad5-4280-b09a-044256cb4535">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="targetLocation" id="8a347e19-24df-484c-82a3-bbfb9dc9b154">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="73ea5af2-80f8-468a-9b7b-4a2e91589d42">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2023	navma1 ChangeRequest 60525: EUP | Mobile DD - [BackEnd] Mobile App list of Jobs
19 Sep 2023	navma1 ChangeRequest 60527: EUP | Mobile DD - [BackEnd] Truck Jobs - Receive Jobs
21 Nov 2023 navhl20 Bug 60924: MTN - Unable to sort the jobs using Source and Target Locations on the Work Order Operations app
03 Jan 2023 navhl20 Bug 61873: FR | 53891 - Mobile App changes for Delivery Dispatch (EP Tickets)
24 Jan 2024	navhl20	ChangeRequest 62056:[62122] FR | 53891 - Mobile App changes for Delivery Dispatch - multiple Release Line Items
01 Aug 2024 navlc30 Bug 65063: FR | 53891 - Mobile App changes for Delivery Dispatch (FR issues)
13 Jan 2025 navtr3  Bug MTN-33693: EUP | WO Ops Mobile App is Displaying Interchange Area as the Source Location
24 Feb 2025	navhl20 Defect Sub-task MTN-34180: Source Location is null on the WO Operations app for the Release Road Jobs
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	bulkRelease 		: CM_BulkRelease;
	request				: CM_Request;
	reserveDetail		: CM_ReserveDetail;
	strArr				: StringArray;
	location			: String;				//29.01.2025 navtr3 #MTN-33693
	index				: Integer;				//29.01.2025 navtr3 #MTN-33693
	sl,tl				: String;
	job					: CM_Job;
begin
	inheritMethod(_object);
	
	job := _object.CM_Job;												//24.02.2025 navhl20 #34180

	bulkRelease 			:= job.getMyBulkRelease();
	request    				:= job.allRequests.first;
	
	if request &lt;&gt; null then
		if request.isKindOf(CM_DeliveryRequest) then
			reserveDetail    := request.CM_DeliveryRequest.myReserveDetail;
		endif;
	endif;
	
	self.regNumber  		:= _object.CM_RoadJob.myVehicle.regNumber;
	self.waitingTime		:=  _object.CM_RoadJob.dwellTime;
	
	create strArr transient;											//24.01.2023 navhl20 #62056[62122]
	foreach request in job.allRequests discreteLock do					//24.01.2023 navhl20 #62056[62122] //06.03.2025 navma1 #MTN-34179
		bulkRelease := request.myOriginatingBulkRelease;
		if bulkRelease &lt;&gt; null and not strArr.includes(bulkRelease.code) then
			strArr.add(bulkRelease.code);
		endif;
	endforeach;
	self.releaseRequest			:= strArr.concatenate(Comma);			//24.01.2023 navhl20 #62056[62122]

	
	if self.sourceLocation = null then									//01.08.2024 navlc30 #65063
		if job.plannedTerminalAreas &lt;&gt; null then //26/08/2024	navkc1 CR 63588 Task 63589
			//self.sourceLocation := _object.CM_Job.plannedLocations;
			index := 1;
			location := job.plannedTerminalAreas.scanUntil(Comma, index);
			self.sourceLocation := location; //26/08/2024	navkc1 CR 63588 Task 63589 
			self.targetLocation := location; //13.01.2025 navtr3 #MTN-33693
		endif;
	endif;	
	
	if (job.isRelease and self.sourceLocation = null) or (self.targetLocation = null and not job.isRelease ) then	//24.02.2025 navhl20 #34180	//06.03.2025 navma1 #MTN-34179
		job.getLocations(sl,tl);
		
		self.sourceLocation := sl;
		self.targetLocation := tl;
	endif;
epilog
	delete strArr;
end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
