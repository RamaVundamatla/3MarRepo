    <JadeMethod name="getQuantity" id="64573a84-61d5-4e4f-a85a-2864c90b4261">
        <source>getQuantity() : Integer;
/*

Date		Who		Reason
20 March 2014	cnwer1	Initial creation PAR

*/

vars
	quantity : Integer;
begin
	quantity:=self.txtQuantity.text.Integer;
	
	if quantity = 0 then
		
		quantity:= self.myInitQueueTask.getQuantityForMoveHistory();
	endif;
	
	return quantity;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
