    <JadeMethod name="validateMe" id="f531597d-d5c1-437e-afee-2f3a76db04dc">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation

*/

vars

begin

	if self.cashValue = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Cash_value), null, null); DELETED
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Cash_value), null, null); // cnwdb2	PAR 35364
	endif;
	if not self.dateTime.Date.isValid then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Transaction_date), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Transaction_date), null, null); // cnwdb2	PAR 35364
	endif;

epilog

end;</source>
    </JadeMethod>
