<Class name="CnEcHtmlCheckBoxTag" id="1a16c325-7b29-4ad3-8393-2c32199bab8b">
    <superclass name="CnEcHtmlInputTag"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
