<Class name="CM_HookCodeHistory" id="bc3fc613-4e2c-4703-8095-79f564dcf6fd">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <PrimAttribute name="codeCreatedTs" id="612d4161-1036-4867-ad82-a6a0e6d7c172">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="jadeCode" id="a6307bb8-a18d-4f8a-8b95-689c6f2141b1">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myHookCode" id="4095a02a-5a10-498d-803f-f4ec68aa33ba">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_HookCode"/>
        <access>readonly</access>
        <Inverse name="CM_HookCode::allHookCodeHistory"/>
    </ExplicitInverseRef>
    <PrimAttribute name="userCode" id="e5c8005b-6842-4751-a28d-94411a4d719a">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setForCreate" id="6a1446a4-1bf0-4572-8d78-08e0f2a93211">
        <updating/>
        <source>setForCreate(_pxyHistory : CM_HookCodeHistory; _hookCode : CM_HookCode) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _pxyHistory = null then
		// Should already be handled by validation.
		return;
	endif;
	
	self.codeCreatedTs	:= _pxyHistory.codeCreatedTs;
	self.jadeCode		:= _pxyHistory.jadeCode;
	self.userCode		:= _pxyHistory.userCode;
	self.myHookCode		:= _hookCode;

end;</source>
        <Parameter name="_pxyHistory" type="CM_HookCodeHistory"/>
        <Parameter name="_hookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="627d00f0-7130-4869-b2e7-8ebb4af14ab4">
        <updating/>
        <source>setForProxy(_jadeCode, _userCode	: String; _hookCode	: CM_HookCode) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.codeCreatedTs	:= app.actualTimeServer();
	self.jadeCode 		:= _jadeCode;
	self.userCode		:= _userCode[1:10];
	self.myHookCode		:= _hookCode;


end;</source>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_hookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="setMyHookCode" id="ae7e050c-c2d9-47bd-bc1a-696ae4e56a3d">
        <updating/>
        <source>setMyHookCode(_hookCode	: CM_HookCode) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myHookCode := _hookCode;

end;</source>
        <Parameter name="_hookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="validate" id="86e10d6c-e1d3-48e7-a5fa-7201d62abe9b">
        <source>validate();
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	hookType	: CM_HookType;
	
begin

	if self.userCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User Code', null, null);
		app.raiseCMException(Input_required_field_userCode, null, null); // cnwdb2	PAR 35364
	endif;
	
	hookType := self.myHookCode.myHookType;
	hookType.validateJadeCode(self.jadeCode);

end;</source>
    </JadeMethod>
</Class>
