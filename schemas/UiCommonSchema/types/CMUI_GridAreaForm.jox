    <JadeMethod name="doMnuStockMovementsClick" id="0013ca1d-591d-45b6-b0d4-86bb129b363b">
        <updating/>
        <source>doMnuStockMovementsClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stkMoveForm	: CMUI_StockMovementsForm;

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if  menuItem.userObject = null then
		return;
	endif;

	if (not menuItem.userObject.isKindOf(CM_LocationsController)) then
		return;
	endif;

	create stkMoveForm transient;
	stkMoveForm.setMyTerminal(self.myTerminal);	
	stkMoveForm.initForm(menuItem.userObject.CM_LocationsController);
	stkMoveForm.show();
	
epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuStopClick" id="bf67b969-d81e-48a2-9118-b46060df7b77">
        <updating/>
        <source>doMnuStopClick( menuItem : MenuItem input ) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
// 16/06/2010	cnwcs5		par 24342 - New for for stops
// ---------------------------------------------------------------------------
	
vars
	lTI			: CM_TrackedItem;
begin
	// just maintains the last ti selected
	lTI := menuItem.userObject.CM_TrackedItem;
	
	self.myAssistant.showStopsForm_TI (lTI, null, app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012
	
	return;
/*	app.mousePointer	:= Busy;						// cnwrl1 27/01/2010 PAR 21889
	
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	// cnwrl1 27/01/2010 PAR 21889 - start of coding
	// NOTE: This reproduces the release 7.7.3 behaviour - ie it only handles the last TrackedItem clicked on.
	create tiSet transient;
	stopsTable	:= app.myRoot.allStopsTable[ menuItem.index ];
	while true do : update_TrackedItems
		self.myAssistant.contextMenuTIsStop( stopsTable, lTI, tiSet );
		
		if app.myPassport.noErrors then
			self.clearErrorWarnings();
			return;
		endif;
		result	:= app.showErrorWarningDialog(	app.getString( EWD_Cannot_Continue, app.getString( HeadingSaved ) ),
												app.myPassport,
												ErrWarnMode_Add + ErrWarnMode_CanAckWarnings );
		if app.myPassport.noErrors and result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue update_TrackedItems;
		endif;
		self.setAllErrorWarnings( app.myPassport );	// copies errors to this form and shows in err/warnings window
		return;
	endwhile update_TrackedItems;*/
	// cnwrl1 27/01/2010 PAR 21889 - end of coding
	
	/* cnwrl1 28/01/2010 PAR 21889 - what it was
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	create lStops transient;
	create tiSet transient;			// cnwrl1 12/05/2009 PAR 19574 - CCMS 1791
	
	lStops.add(menuItem.index);
//	if lTI.getStopByID(menuItem.index) = null then	// cnwrl1 14/12/2009 PAR 21889 - what it was
	if not lTI.isStopSet( menuItem.index ) then
		// cnwrl1 12/05/2009 PAR 19574 - CCMS 1791 - start of coding
		tiSet.add( lTI );
		app.myTrxCA.trxCreateStopsForTIs( tiSet, lStops, app.myPassport );
//		app.myTrxCA.trxCreateStops(lTI, lStops, aOK, app.myPassport);	what it was
		// cnwrl1 12/05/2009 PAR 19574 - CCMS 1791 - end of coding
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog('Grid Area Form', app.myPassport, ErrWarnMode_Add);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	else
//		stopTable := lTI.getStopByIDAsAtDate(menuItem.index).myStopsTable;	// cnwrl1 11/01/2010 PAR 21889 - what it was
		stopTable := lTI.getStopByIDAsAtDate( menuItem.index, null ).myStopsTable;
		if stopTable.requiresInfo then
			self.processStopInfo(lTI, stopTable, lStops);
		else
			app.myTrxDA.trxDeleteStops(lTI, lStops, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog(app.getErrorString(Cargo_Enquiry), app.myPassport, ErrWarnMode_Update);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	endif;
	
	menuItem.checked := not menuItem.checked;
	//refresh table
//	self.showExtraInfoForObject(lTI);	note takes care of this

epilog
	delete lStops;
	delete tiSet;
	mousePointer := MousePointer_Default;
end;
	cnwrl1 28/01/2010 PAR 21889 - end of what it was */
	
epilog
	
	
end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
