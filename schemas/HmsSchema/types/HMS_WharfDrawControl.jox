    <JadeMethod name="dragPictureMouseUpEvent" id="5d675d0a-fe10-4edf-9c68-5b19f2421285">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragPictureMouseUpEvent(pict: HMS_GraphicalDragPicture input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//--------------------------------------------------
// Created:	04 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpMoveStyle	: Integer;
	isPictDragging	: Boolean;
	viewForm		: HMS_GraphicalViewX;
begin
	viewForm := self.myGraphicalViewForm;
	// move pointers
	viewForm.myDrawTimeLabel.movePointer(true, pict.top, pict.top + pict.height);
	self.movePointers(true, pict.left, pict.left + pict.width);		
	
	isPictDragging := pict.isDragging;
	pict.isDragging := false;
//	if pict.height &lt;= 0 th
//		return;
//	endif;
	if viewForm.isReadOnly then
		// read only user cannot move sprite
		return;
	elseif viewForm.myCurrentWorkingMovement = null then
		// nothing selected
		return;
	elseif viewForm.myCurrentWorkingMovement.myWorkingVoyage.voyageStatus = HMS_VoyageIsLocked then
		// movement locked and cannot be moved
		return;
	endif;
	
	tmpMoveStyle := viewForm.controlMoveStyle;

	if pict.hasChangedPosition(tmpMoveStyle) or 
	   pict.hasChangedTime(tmpMoveStyle) then
		// NOTE the following will delete "pict" if the move is successful
		// as it rebuilds the entire screen (not sure if this is required or not - rjs
		if (not viewForm.updateMovementToController(pict, pict.myWorkingMovement, false, false, null, null, null)) then
			pict.myCurrentWharfDrawControl.backoutSpriteChanges(pict);
		endif;	
	else
		// PAR 15674 - need to set current drag pic so that times
		// at top of screen are drawn correctly
		viewForm.myCurrentDragPicture := pict;
	endif;

	viewForm.showSelectedPosDetails();	

epilog
	if isPictDragging and
	   viewForm &lt;&gt; null then
		// Notify controller that the movement has finished being edited
		viewForm.myViewController.set_AddEditMovementActiveState(false);
	endif;
	app.mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="pict" type="HMS_GraphicalDragPicture" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawMe" id="ee9f4449-9294-49a5-8391-c06db58579cd">
        <updating/>
        <source>drawMe()updating;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------
begin
	self.removeControls();
 	self.myScrollingFrame.clearGraphics();
	self.myScrollableLabelFrame.clearGraphics;
	self.wharfZoom := self.myGraphicalViewForm.wharfZoom;
	self.setMyLabelFrmWidth();
	
	if self.myWharf = null then
		return;
	endif;
	
	if self.myWharf.displayLeftToRight then
		self.drawWharfScaleLeftToRight();
	else
		self.drawWharfScaleRightToLeft();
	endif;
	
	self.drawWharfLegend();
	self.drawWharfResourceIcons();
	self.drawWharfLockouts();
end;</source>
    </JadeMethod>
