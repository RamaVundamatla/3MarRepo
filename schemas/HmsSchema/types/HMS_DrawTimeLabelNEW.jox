    <JadeMethod name="movePointer" id="bbd4d7ea-fe2b-4976-9115-7e932a0db226">
        <source>movePointer(pShow : Boolean; pP1, pP2 : Real);

vars

begin
	if self.pointer1 = null then
		return;
	endif;
	if pShow then
		self.pointer1.visible := true;
		self.pointer2.visible := true;
		self.pointer1.top	 := pP1;
		self.pointer2.top	 := pP2;
	else
		self.pointer1.visible := false;
		self.pointer2.visible := false;
	endif;		
end;</source>
        <Parameter name="pShow" type="Boolean"/>
        <Parameter name="pP1" type="Real"/>
        <Parameter name="pP2" type="Real"/>
    </JadeMethod>
