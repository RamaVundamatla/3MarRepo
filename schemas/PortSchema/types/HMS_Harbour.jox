    <JadeMethod name="validateForDelete" id="80b653fb-ce9d-4fdf-8569-5fdf7ec99f08">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_passport);
	if (not self.allVoyageMovements.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.description, "Voyage Movement", null, null);	
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="3103c4b7-c32b-4c16-bd9f-e4272c7f07a6">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	tmpHarbour : HMS_Harbour;
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null); 
		app.raiseCMException(Input_required_field_desc, ETRow_Description,  null); // cnwdb2	PAR 35364
	endif;

	if self.myRoot = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Harbour Root', null,  null);
		app.raiseCMException(Input_required_field_harbRoot, null,  null); // cnwdb2	PAR 35364
	endif;	
		
	if _passport.hasErrors then
		return;
	endif;

	tmpHarbour := app.myRoot.allHarbours.getAtKey(self.code);
	if tmpHarbour &lt;&gt; null then
		if self.isTransient and tmpHarbour &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Harbour', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Harbour already exists for %1 : Harbour_already_exists
			app.raiseCMException1(Harbour_already_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;

	if _passport.hasErrors() then
		return;
	endif;

	// 33174 CCMS 1124, skip the warnings for C3 berth maintenance
	if not app.myRoot.isClientC3  then
		if self.defaultArrvBerth = null then
		//	app.raiseCMWarning1(REQUIRED_FIELD, 'Default Arrival Berth', null,  null, self);
			app.raiseCMWarning(Input_required_field_dfltArBrt, null,  null, self); // cnwdb2	PAR 35364
		endif;
		if self.defaultDepartBerth = null then
		//	app.raiseCMWarning1(REQUIRED_FIELD, 'Default Departure Berth', null,  null, self);
			app.raiseCMWarning(Input_required_field_dfltDpBrt, null,  null, self); // cnwdb2	PAR 35364
		endif;		
		if self.myEmailGroup = null then
		//	app.raiseCMWarning1(REQUIRED_FIELD, 'Harbour Email Group', null,  null, self);
			app.raiseCMWarning(Input_required_field_harbEmail, null,  null, self); // cnwdb2	PAR 35364
		endif;
	endif;
	
	self.validateTerminals(_passport);		

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateTerminals" id="b06450dd-b721-4506-861e-6f37622d9d51">
        <source>validateTerminals(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	07 January 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 22/05/2015	cnwdap1		When deleting a voyage, we create a "Voyage Deleted" HMS transaction.
//							If the only HMS transactions remaining are "Voyage Deleted" ones,
//							don't prevent the removal of the terminal from the harbour.
vars
	tmpTerm		: CM_Terminal;
	realHarbour : HMS_Harbour;
	user		: CM_User;
	failedDAC  	: CM_DataAccessController;
begin
	
	user := _passport.myUser;
	
	realHarbour := self.pxyGetRealObject();
	if realHarbour = null then
		return;
	endif;
	if realHarbour.allTerminalsByCode.isEmpty then
		return;
	endif;
	
	foreach tmpTerm in realHarbour.allTerminalsByCode do
		if (not self.allTerminalsByCode.includes(tmpTerm)) then
			//They are removing terminal from harbour
			if (not tmpTerm.canUserAccessSelf(user, failedDAC, _passport)) then
				// PAR 10905
				app.raiseCMException1(NoPermission, 'remove Terminal (' &amp; tmpTerm.name &amp; ')', null, null);	
			endif;			
			if (not tmpTerm.allHMSTransactions.isEmpty) then
				//Terminal has movements, therefore it cannot be removed
				app.raiseCMException3(HMSObjectHasEntries, 'Terminal (' &amp; tmpTerm.name &amp; ')', "Movement", self.getDisplayString(), null, null);	
			endif;
		endif;
	endforeach;

	// PAR 10905
	foreach tmpTerm in self.allTerminalsByCode do
		if (not tmpTerm.canUserAccessSelf(user, failedDAC, _passport))
		and (not realHarbour.allTerminalsByCode.includes(tmpTerm)) then
			// they are trying to add a terminal they do not have access to
			app.raiseCMException1(NoPermission, 'add Terminal (' &amp; tmpTerm.name &amp; ')', null, null);	
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateVesselInPort" id="393eccd8-c722-4629-8436-87303afe1a42">
        <source>validateVesselInPort(_arriveDT, _departDT : TimeStamp; 	_theVessel : CM_Vessel; _theVoyage : CM_Voyage; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	15 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpVessel : CM_Vessel;
	tmpTerm : CM_Terminal;
	iter : Iterator;
begin
 	
 	if (not _arriveDT.isValid) then
		app.raiseCMException1(AutoScheduleDateError, 'Arrive Date/Time', ETRow_ArriveDT, null);
		return;
	endif;
	if (not _departDT.isValid) then
 		app.raiseCMException1(AutoScheduleDateError, 'Departure Date/Time', ETRow_DepartDT, null);
		return;
 	 endif;
 	 
	if _theVoyage = null then
		return;
	endif; 
	
	tmpVessel := _theVessel;
	if tmpVessel = null then
		// see if we can find it
		tmpVessel := _theVoyage.getMyVessel();
 	endif;
 	if tmpVessel = null then
 		return;
 	endif;		
 		
	iter := self.allTerminalsByCode.createIterator();
	
	while iter.next(tmpTerm) do
		
		tmpTerm.validateVesselInPort(_arriveDT, _departDT, tmpVessel, _theVoyage, _passport);
		
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_arriveDT" type="TimeStamp"/>
        <Parameter name="_departDT" type="TimeStamp"/>
        <Parameter name="_theVessel" type="CM_Vessel"/>
        <Parameter name="_theVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
