    <JadeMethod name="kpdGenerateWSWrapIPNAgentTest" id="5117521a-7bd3-49f4-a071-fafb4c7cde39">
        <source>kpdGenerateWSWrapIPNAgentTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	ca				: CM_InaportnetWSConsumerAgent;
	req				: CMIF_ExternalWebServiceObject;
	resp 			: CMIF_ExternalWebServiceObject;
	
	wsMethods		: StringArray;
	requestClasses,
	responseClasses	: ObjectArray;
	i				: Integer;
		
begin
	app.initialize();
	
	write app.myPassport.myTerminal.String;
		
	create ca transient;
	ca.usercode := "bup-pelindo1-dumai";
	ca.password := "dum@i#p3l1nd01$bup";
	ca.timeoutSeconds := 2;
	
	write ca.getDefaultBaseEndpoint;
	ca.setBaseEndpoint("https://inaportdev.dephub.go.id/");
	
	ca.createActivityHistory := true;
	
	create wsMethods transient;
	create requestClasses transient;
	create responseClasses transient;
		
	wsMethods.add(CM_InaportnetWSConsumerAgent::entryRpkro.name);
	requestClasses.add(CMIF_IPNEntryRpkroRequest);
	responseClasses.add(CMIF_IPNEntryRpkroResponse);

	wsMethods.add(CM_InaportnetWSConsumerAgent::entryRpkroDetail.name);
	requestClasses.add(CMIF_IPNEntryRpkroDetailReq);
	responseClasses.add(CMIF_IPNEntryRpkroDetailResp);
	
	wsMethods.add(CM_InaportnetWSConsumerAgent::sendRealisasiPandu.name);
	requestClasses.add(CMIF_IPNSendRealPanduReq);
	responseClasses.add(CMIF_IPNSendRealPanduResp);
	
	wsMethods.add(CM_InaportnetWSConsumerAgent::sendRealisasiTambat.name);
	requestClasses.add(CMIF_IPNSendRealTambatReq);
	responseClasses.add(CMIF_IPNSendRealTambatResp);
	
	wsMethods.add(CM_InaportnetWSConsumerAgent::sendRealisasiTunda.name);
	requestClasses.add(CMIF_IPNSendRealTundaReq);
	responseClasses.add(CMIF_IPNSendRealTundaResp);
	
	wsMethods.add(CM_InaportnetWSConsumerAgent::setSpkPandu.name);
	requestClasses.add(CMIF_IPNSetSpkPanduReq);
	responseClasses.add(CMIF_IPNSetSpkPanduResp);
	
	foreach i in 1 to wsMethods.size() do
		delete req;
		delete resp;
		
		create req as requestClasses[i].Class;
		req.populateWithTestingData();
		
		write req.returnAsXMLString() &amp; CrLf;
		
		write "Calling Web Service " &amp; wsMethods[i];
		
		resp := ca.sendMsgWithParams(wsMethods[i], req).CMIF_ExternalWebServiceObject;
		
		if resp &lt;&gt; null then
			if resp.class &lt;&gt; responseClasses[i] then
				write "&gt;&gt;&gt;&gt; Error, wrong response class";
			endif;
			
			write resp.returnAsXMLString();
		else
			write "&gt;&gt;&gt;&gt; Error, null response";
		endif;
		
		write CrLf;
	
	endforeach;
	
epilog
	delete wsMethods;
	delete requestClasses;
	delete responseClasses;
	delete ca;
	delete req;
	delete resp;
	app.finalize();

end;
	</source>
    </JadeMethod>
