    <JadeMethod name="setProxy" id="23c50e90-a2b7-4eee-b6ea-9e15e6dc24a3">
        <updating/>
        <source>setProxy(pCode, pDescription : String;_notAvailableForEntry :Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setSuperClassDetailsForProxy(pCode, pDescription,_notAvailableForEntry,null);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7046fbf0-b88b-4f19-9193-fd0abacbff1f">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allLogConditionCodes.includesKey(self.code) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	if self.code.length &gt; 4 then
		app.raiseCMException2(CodeInvalid, "Code length must not be greater than 4 characters", self.code, null, null);
	endif;
	inheritMethod();

end;</source>
    </JadeMethod>
</Class>
