    </JadeMethod>
    <JadeMethod name="utlUpdateTIToDoTasks" id="623c4d81-e39a-425e-bd4b-b5285ff8d4c3">
        <updating/>
        <source>utlUpdateTIToDoTasks(_allTasksToAdd,
					_allTasksToComplete,
					_allTasksToRemove : IntegerArray;
					_ti : CM_TrackedItem input;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//15/07/2019 	JLGNS1	Bug 45588: PNL - To Do Task Description no Planning / Queueing when To Do Task Terminals setup
vars
	taskDesc 			: CM_ToDoTaskDesc;
	taskDict			: CM_ToDoTaskDescByCode;
	idx					: Integer;
//	tdtd				: CM_ToDoTaskDesc;
begin
	
	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "TrackedItem", null, null);
	endif;
	
	taskDict := app.myRoot.allToDoTaskDescriptions;

	app.setContinueCMExceptions(true);
	exclusiveLock(_ti);

	if _allTasksToAdd &lt;&gt; null and (not _allTasksToAdd.isEmpty) then
		foreach idx in 1 to _allTasksToAdd.size do
			taskDesc := taskDict[_allTasksToAdd[idx]];
			if taskDesc &lt;&gt; null then
				_ti.addToDoTask(taskDesc.description, _passport);
			endif;
		endforeach;
	endif;
	
	if (not _passport.noErrors) then
		return;
	endif;
	
	if _allTasksToComplete &lt;&gt; null and (not _allTasksToComplete.isEmpty) then
		foreach idx in 1 to _allTasksToComplete.size do
//			_ti.setToDoTaskComplete(taskDict[_allTasksToComplete[idx]].description, _passport);
			_ti.setToDoTaskComplete(_allTasksToComplete[idx], _passport);
		endforeach;
		_passport.doPostUpdateAutoPlansFor( _ti );	//Bug 45588
	endif;
	
	if (not _passport.noErrors) then
		return;
	endif;
	
	if _allTasksToRemove &lt;&gt; null and (not _allTasksToRemove.isEmpty) then
		foreach idx in 1 to _allTasksToRemove.size do
//			_ti.removeToDoTask(taskDict[_allTasksToRemove[idx]].description, _passport);
			_ti.removeToDoTask(_allTasksToRemove[idx].String, _passport);
		endforeach;
	endif;

end;</source>
        <Parameter name="_allTasksToAdd" type="IntegerArray"/>
        <Parameter name="_allTasksToComplete" type="IntegerArray"/>
        <Parameter name="_allTasksToRemove" type="IntegerArray"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIToDoTasksWarehouse" id="07bbd337-361d-42d8-ba77-59b8c4959cf3">
        <updating/>
        <source>utlUpdateTIToDoTasksWarehouse(	_toDoTaskDesc : CM_ToDoTaskDesc;
								_allTIs : CM_TISet;
								_status : Integer;
								_resourceUsageProxys : CM_ResourceTypeUsageSet input;
								_passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/06/2015	cnwdap1		Initial creation PAR #36231 New for this PAR
//
vars
	ti	: CM_TrackedItem;

begin
	app.setContinueCMExceptions(false);
	
	if _allTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_allTIs set", null, null);
	endif;
	
	if _toDoTaskDesc = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_toDoTaskDesc", null, null);
	endif;
	
	if _toDoTaskDesc.description = null then
		app.raiseCMException1(ERR_TODOTASK_ADD, 'Task has a null description (' &amp; _toDoTaskDesc.description &amp; '). This operation cannot proceed.', null, null);
	endif;
	
	app.setContinueCMExceptions(true);
	
	foreach ti in _allTIs do
		ti.updateToDoTasksForMobile(_toDoTaskDesc, _status, _resourceUsageProxys, _passport);
	endforeach;

epilog

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_allTIs" type="CM_TISet"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTITransaction" id="5d1fc958-f254-4d8d-bb69-01bb295e9cc0">
        <source>utlUpdateTITransaction(_tiTransactionController:CMIF_TITransactionController input; 
				_origTrans :CM_TITransaction input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTI 		: CM_TrackedItem;
	receivalTxn	: CM_Receive;
	receivalDt 	: TimeStamp;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	self.raiseExceptionIfNull(_tiTransactionController, '_tiTransactionController');
	
	theTI := _tiTransactionController.myTrackedItem;
	self.raiseExceptionIfNull(theTI, 'Tracked Item');
	
	//Set properties on the _tiTransactionController off the TI
	theTI.setTITransControllerFromSelf(_tiTransactionController, _origTrans, _passport);
		
	app.myValUA.valTITransaction(_tiTransactionController, _origTrans, theTI, _passport);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	exclusiveLock(theTI);

	//Update the transaction
	_tiTransactionController.updateTransaction(_passport, _origTrans);

	/* 07 Dec 2017	NDL	TFS 8116 - moved into trx.updateTI for CM_Receive via ti.setReceivedDTfromTrxs
	// 12/01/2011 cnwar2 #26175
	// if a receival txn was edited and after edit the date/time of the first receival txn is now different to Received Date/Time, need to update
	if global.isTiTxnOfType(_origTrans.type, TRANS_TYPE_RECEIVE) then
		receivalTxn:=theTI.getTransReceiveFirst;
		if receivalTxn &lt;&gt; null then
			receivalDt := receivalTxn.dateTime;
			if receivalDt &lt;&gt; theTI.receivedDT then
				theTI.setReceivedDT(receivalDt);
			endif;
		endif;
	endif;	*/
end;</source>
        <Parameter name="_tiTransactionController" type="CMIF_TITransactionController" usage="input"/>
        <Parameter name="_origTrans" type="CM_TITransaction" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTITransactionExtRef" id="27f3ee5f-45c3-4718-98af-fe99ec40ac6e">
        <source>utlUpdateTITransactionExtRef(_trans: CM_TITransaction input; _extRef: String; _dateTime: TimeStamp; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2019	jlgmp6	Initial creation	TFS42015

*/

vars

begin
	self.initialiseActivity();

	exclusiveLock(_trans);

	_trans.setExternalReferenceId(_extRef);
	if _dateTime &lt;&gt; null then
		_trans.updateDateTime(_dateTime);
	endif;
epilog

end;</source>
        <Parameter name="_trans" type="CM_TITransaction" usage="input"/>
        <Parameter name="_extRef" type="String"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTITransactions" id="d17d06a7-8ea9-489d-bf7e-c4b094fdb6aa">
        <source>utlUpdateTITransactions(	_tiTransactionController : CMIF_TITransactionController input;
							_origTransactions : CM_TITransactionSet input;
							_passport : CM_Passport input
							);
/*

Purpose:			

Parameters:			For updating date and time on multiple like transactions.

Return Value:		

Date		Who		Reason
21 March 2014	cnwndl1	Initial creation
07 Nov   2017   cnwma1 TFS # 7277: GUQ - Multi -Cargo Transaction Date Edit Not reflecting on the respective columns in selector and Cargo Enquiry
*/

vars

	tiTransAction : CM_TITransaction;
	newDateTime : TimeStamp;
	ti : CM_TrackedItem;
	tmpOrderNo	: Integer;
	receivalTxn	: CM_Receive;
	receivalDt 	: TimeStamp;
begin

	newDateTime := app.actualTimeServer;
	newDateTime := _tiTransactionController.dateTime;

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	foreach tiTransAction in _origTransactions do
		exclusiveLock(tiTransAction);
	endforeach;
	
	foreach tiTransAction in _origTransactions do
		tiTransAction.savePreviousVersion();
		tiTransAction.generateEditAudit(_passport);
		//epr par 37116 21/1/16
		ti := tiTransAction.myTrackedItem;
		if ti &lt;&gt; null then
			if ti.allTransactions.includesKey(newDateTime, tiTransAction.orderNo) then
				tmpOrderNo	:= tiTransAction.orderNo;
				while ti.allTransactions.includesKey(newDateTime, tmpOrderNo) do
					tmpOrderNo := tmpOrderNo + 1;
				endwhile;
				tiTransAction.setOrderNo( tmpOrderNo);
			endif;
		endif;
		
		tiTransAction.updateDateTime( newDateTime );
		
		tiTransAction.updateTI(_passport);	//07 Dec 2017	NDL	TFS 8116
		
	/*	//07.11.2017 cnwma1 TFS #7277
		if global.isTiTxnOfType(tiTransAction.type, TRANS_TYPE_RECEIVE) then
			receivalTxn:=ti.getTransReceiveFirst;
			if receivalTxn &lt;&gt; null then
				receivalDt := receivalTxn.dateTime;
				if receivalDt &lt;&gt; ti.receivedDT then
					ti.setReceivedDT(receivalDt);
				endif;
			endif;
		endif; */
	endforeach;

epilog

end;</source>
        <Parameter name="_tiTransactionController" type="CMIF_TITransactionController" usage="input"/>
        <Parameter name="_origTransactions" type="CM_TITransactionSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTITransitStatus" id="888772e5-5337-4485-8a24-28d742928d30">
        <source>utlUpdateTITransitStatus(_theProxyTI: CM_TrackedItem input; _theStatus : Integer;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
//	txnParams			: CMIF_TITransactionController;
//	txn : CM_TITransaction;
	theRealTI : CM_TrackedItem;
	expectedEdition : Integer;
//	strs : CM_Strings;
//	beforeStr, afterStr : String;
begin
	self.initialiseActivity();

	_theProxyTI.raiseExceptionIfNotProxy(method);
	_theProxyTI.pxyGetRealObjectAndEdition(theRealTI, expectedEdition);

	exclusiveLock(theRealTI);

	if _passport.noErrors and theRealTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TI Remarks', null, null);
		return;
	endif;
	
	/*
	if theRealTI.getTransitStatus = TI_TransitStatusDLR then
		beforeStr := "DLR";
	elseif theRealTI.getTransitStatus = TI_TransitStatusSOB then
		beforeStr := "SOB";
	else
		beforeStr := "NONE";
	endif;
	*/


	theRealTI.setTransitStatus(_theStatus, true, _passport);

	
	/*
	if theRealTI.getTransitStatus = TI_TransitStatusDLR then
		afterStr := "DLR";
	elseif theRealTI.getTransitStatus = TI_TransitStatusSOB then
		afterStr := "SOB";
	else
		afterStr := "NONE";
	endif;		
	
	create txnParams transient;
	txnParams.type := TRANS_TYPE_EDIT;
	txnParams.myTrackedItem := theRealTI;
	txn := theRealTI.createTransaction(txnParams, _passport);	

	strs := txn.CM_Edit.fieldsValues;
	strs.add(CM_TrackedItem::transitStatus.name&amp; ' ' &amp; beforeStr &amp; " =&gt; " &amp; afterStr);
	*/

epilog
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIUnassignPack" id="8cfdd9ba-7e05-4035-9ecc-24370152245c">
        <updating/>
        <source>utlUpdateTIUnassignPack(_pxyTI : CM_TrackedItem; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/07/2015	cnwdap1		Initial creation PAR #36484 Remove TI from booking and booking item,
//							unassign from release request
//
vars
	realTI 			: CM_TrackedItem;
	expectedEdition : Integer;

begin
	self.initialiseActivity();

	_pxyTI.raiseExceptionIfNotProxy(method);
	_pxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);

	if _passport.noErrors and realTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Tracked Item', null, null);
		return;
	endif;
	
	exclusiveLock(realTI);

	// do the updates - clear the TI's booking ref and item, and remove it from the release
	realTI.setBookingReference(null);
	realTI.allBulkReleasesAssigned.clear();

epilog

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIUnpackComplete" id="89e9a385-cf98-4a6a-82fd-382f57e9184f">
        <updating/>
        <source>utlUpdateTIUnpackComplete(_theProxyTI, _realTI: CM_TrackedItem input; _retroDate : TimeStamp; _passport: CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		27 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 27/03/2023 	navma1 		ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
// 09 Jan 2024	navma1  	Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
// 14 Mar 2024  navhl20 	ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
// -----------------------------------------------------------------------------

vars
	theWLE 						: CM_WorkListEntry;
	theWOD 						: CM_WodUnpack; 
	expectedEdition			    : Integer;
	realTI					    : CM_TrackedItem;
	theTransactionController	: CMIF_TITransactionController;
	txnControllerDict 			: CMIF_TITxnContrlrByTypeDTDict;
	connectParams 				: CMIF_ConnectParams;
begin
	
	self.initialiseActivity();
	_theProxyTI.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	
	_theProxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	
	if _realTI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;
	
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realTI);

	if _passport.noErrors and realTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'realTI', null, null);
		return;
	endif;
	
	create theTransactionController transient;
	create txnControllerDict transient;
	
	
	//complete the WLE and Work Order detail
	app.myUtilityUA.utlUpdateTIPackComplete(_theProxyTI, realTI, _passport);

	if _passport.hasErrors() then
		return;
	endif;
	
	theTransactionController.myTrackedItem 		:= realTI;
	theTransactionController.myOtherTrackedItem := null;
	theTransactionController.noCharge 			:= false;
	theTransactionController.type 				:= TRANS_TYPE_UnpackComplete;
	if _retroDate.isValid then															//14.03.2024 navhl20 #62861
		theTransactionController.dateTime := _retroDate;
	endif;
	
	txnControllerDict.add(theTransactionController);
	
	//05 May 2015	NDL	Par 36154 
	if _theProxyTI.allChildren.isEmpty
	and  realTI.myTerminal.getConfig(DoAutoUnpackClearFields).Boolean
	and realTI.isConnected
	then
		create connectParams transient;
		connectParams.doDisconnect( realTI, _passport );
		
		if _passport.hasErrors() then
			return;
		endif;
	
		app.myProxyManager.allReals[realTI].originalRealEdition := realTI.edition;
		
		if _theProxyTI.myReeferProperties &lt;&gt; null then
			_theProxyTI.myReeferProperties.erase(NORMAL_ERASE);
			_theProxyTI.setPropertyValue( CM_TrackedItem::myReeferProperties.name, null);
		endif;
		
	endif;

	if _passport.hasErrors() then
		return;
	endif;
	
	//cnwmc5 - 23 May 2014 - PAR 33979
	_theProxyTI.clearDetailsForUnpack();
	
	//update the container 
	app.myUtilityUA.utlUpdateTrackedItem(_theProxyTI, null, TI_UPDMODE_NORMAL, txnControllerDict, null, null, _passport);//cnwrd1 28.8.09 par 20545

	if _passport.hasErrors() then
		return;
	endif;

	// Set any unpack complete stops cnwrs1 may 2007
	realTI.setStopsToBeApplied(StopApplyUnpackComplete, true, _passport); //par15193 cnwrs1 oct 2007
	
	//26.10.21 navma1 #52255
	realTI.doWorkOrderUnpackCompletion();									//08.02.2023 navma1 #56457:[56458]
	
epilog
	delete theTransactionController;
	delete txnControllerDict;
	
	if connectParams &lt;&gt; null then
		delete connectParams;
	endif;
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_retroDate" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIWOToDoTaskAdd" id="2409f51f-f4f6-4bd3-8d46-ea28990dd6a7">
        <updating/>
        <source>utlUpdateTIWOToDoTaskAdd(	_theTI : CM_TrackedItem input;
							_toDoCode : Integer;
							_wodToDo : CM_WodToDo input;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2018	jlgndl1	Initial creation	TFS 40216

*/

vars

	taskDesc : CM_ToDoTaskDesc;
	newToDo : CM_ToDoTask;

begin

	taskDesc := app.myRoot.allToDoTaskDescriptions[_toDoCode];
	if taskDesc = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No todo task found for (' &amp; _toDoCode.String &amp; ')');
		return;
	endif;
	if (not taskDesc.canUserAdd(_passport)) then
		return;
	endif;
	
	// ### TFS BUG 61158 16NOV2023 NAVAB1 - ignore it, these are not created on TIs only on WO
	if taskDesc.isForCargoWorkOrder() then	
		return;
	endif;
	
	newToDo := _theTI.addToDoTask(taskDesc.description, _passport);
	newToDo.setMyWodToDo( _wodToDo );

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_toDoCode" type="Integer"/>
        <Parameter name="_wodToDo" type="CM_WodToDo" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIsAssignToTrain" id="93770001-e2ed-4257-9b6b-14102cb29121">
        <updating/>
        <source>utlUpdateTIsAssignToTrain(	_ti 		: CM_TrackedItem input; 
							_train 		: CM_Train;
							_passport 	: CM_Passport input
							) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwndl1	Initial creation

*/

vars

	theTI : CM_TrackedItem;
	theTrain : CM_Train;
	
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	if not _passport.noErrors then
		return;
	endif;
	
	self.myUpdateAuditAgent.audUpdateGeneric(_ti, true);
	theTI := _ti;
	if theTI = null then
		app.raiseCMWarning(Container_not_found, null, null, theTI);
		return;
	endif;
		
	theTI.setMyTrainAssigned(_train, _passport);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_ti, false);
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIsAutoplanToWagon" id="0e098acd-364f-43ce-bd4a-d85f2e5c05cb">
        <updating/>
        <source>utlUpdateTIsAutoplanToWagon(_ti 		: CM_TrackedItem input; 
							_moveMode 	: Integer; 
							_railArea	: CM_Rail;
							_train 		: CM_Train;
							_wagon 		: CM_Wagon;
							_passport 	: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theTI		: CM_TrackedItem;
	arbiter		: CM_RTQueueArbiter;
	theJob : CM_Job;
	theTrain : CM_Train;
	wagon : CM_Wagon;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

//	app.myValUA.valAutoplan(_wle);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	if not _passport.noErrors then
		return;
	endif;
	
	self.myUpdateAuditAgent.audUpdateGeneric(_ti, true);
	theTI := _ti;
	if theTI = null then
		app.raiseCMWarning(RAIL_NO_AUTOPLAN_TI, null, null, theTI);
		return;
	endif;
		
//###
	theJob := theTI.jobRailRelease;	
	if theJob = null then
		theTrain := _train;
		
		
		theJob := theTI.createRailReleaseJob(null, theTrain);
		if _passport.hasErrorsOrWarnings() 
		and not _passport.warningsAcknowledged then // PAR 20028
			return;
		endif;
	elseif theJob.CM_RailJob.requestNum = null then
		app.raiseCMException2(Alrea_rail_relea_job_canno_co, theTI.id, theJob.jobId, null, theTI); // PAR 20028
	endif;

//###	
	theTI.autoPlanToWagon(_moveMode, theJob, _railArea, _train, _wagon, _passport);
	if _moveMode = QUEUE_MODE and theTI.myPrimaryQueuedLocation = null then
		app.raiseCMWarning1(Failed_auto_plan_wagon, theTI.id, null, null, null);
	elseif _moveMode = PLANNING_MODE and theTI.myPrimaryPlannedLocation = null then
		app.raiseCMWarning1(Failed_auto_plan_wagon, theTI.id, null, null, null);
	else
		app.myEventManager.createSingleObjInfoNoteEvt(_ti, _passport.myTerminal.getTerminalEvent(EVENT_TI_MOVE), _ti);	
		
		// If the train has arrived then at the moment the new job that we just created is on the train jobsheet.
		// If the train has arrived it needs to be on the ACTUAL RAIL job sheet
		// This method will move the job to the rail JS IF the train has arroved.
		if _passport.noErrors then
			if theJob &lt;&gt; null and theJob.myJobSheet.isTrainJS() then
				if theTrain &lt;&gt; null then
					theTrain.moveOutwardJobToRail(theJob.CM_RailJob);
				endif;
			endif;
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_ti, false);
	endif;

	// ### TFS 54010 28JUN2022 NAVAB1 The job needs to send the train code, this can only be done after the TI is planned to a wagon. see Rail Job.getMyTrain().
	if app.myPassport.isOpsViewEnabled(theJob.getMyTerminal()) then // ### TFS 54010 28JUN2022 NAVAB1
	
		theJob.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB, theJob);	 // ### TFS 54010 28JUN2022 NAVAB1
	endif;

epilog
	delete arbiter;	

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIsBRSetReleased" id="5c2d4590-652e-4158-98ef-e08fa813660f">
        <source>utlUpdateTIsBRSetReleased(	_tiSet : CM_TISet;
							_bulkRelease: CM_BulkRelease input;// #26529 10/01/2011
							_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwrd1	Initial creation

*/


vars
	childTI,
	ti				: CM_TrackedItem;
	//children		: CM_TISet;
	tmpBR			: CM_BulkRelease;
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	app.myValUA.valTIsBulkReleased(_tiSet, _bulkRelease, _passport);
	app.setContinueCMExceptions(false);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _bulkRelease &lt;&gt; null then	
		exclusiveLock(_bulkRelease);
	else
		return;
	endif;


	if _passport.noErrors then //cnwrd1 par 31782
		self.myUpdateAuditAgent.audUpdateGeneric(_bulkRelease, true);
	endif;
	
	foreach ti in _tiSet do : tiLoop
		_bulkRelease.addTIReleased(ti, CM_ReserveDetail.PackType_Parent);
	endforeach;
	
	
	if _bulkRelease &lt;&gt; null then	//26529 10/01/2011
		if _bulkRelease.isComplete then
			_bulkRelease.setStatus(BR_COMPLETE, null, false);
		endif;
	endif;
	
	if _passport.noErrors then//cnwrd1 par 31782
		self.myUpdateAuditAgent.audUpdateGeneric(_bulkRelease, false);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIsBulkReleased" id="215b956d-41e3-4db8-a8f2-2808901309e2">
        <source>utlUpdateTIsBulkReleased(	_tiSet : CM_TISet;
							_theUnpackTIs: CM_TIArray;				// #26529 10/01/2011
							_bulkReleaseBefore,						// #26529 10/01/2011
							_bulkReleaseAfter: CM_BulkRelease input;// #26529 10/01/2011
							_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     22 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	childTI,
	ti				: CM_TrackedItem;
	//children		: CM_TISet;
	tmpBR			: CM_BulkRelease;
	
begin

	self.initialiseActivity();
	
	/* commented by #26529 10/01/2011. Now, packing/unpacking process can have bulk release null.
	if _realBulkRelease = null then	
		app.raiseUnexpectedProgramError(class.name, method.name, 'Persistent bulk release passed in is null');
		return;
	endif;*/
	
	app.setContinueCMExceptions(true);
	app.myValUA.valTIsBulkReleased(_tiSet, _bulkReleaseAfter, _passport);
	app.setContinueCMExceptions(false);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _bulkReleaseAfter &lt;&gt; null then	//#26529 05/01/2011
		exclusiveLock(_bulkReleaseAfter);
	endif;
	if (_bulkReleaseBefore &lt;&gt; null) and (_bulkReleaseBefore &lt;&gt; _bulkReleaseAfter) then
		exclusiveLock(_bulkReleaseBefore); //#26529 10/01/2011. Now, a container can be re-assigned to another bulk release when packing/unpacking.
	endif;
	
	//th2 07/06/2007 - _clearFirst was always being passed in as null -so removed
	//if _clearFirst then
	//	_realBulkRelease.allTrackedItemsAssigned.clear;
	//endif;
	//create children transient;//PAR 22954
	
	//th2 added 07/06/2007 - reconcile packing release
	foreach ti in _tiSet do : tiLoop
	
		//if ti.allChildren.isEmpty then
		if not ti.hasChildren then	//PAR 22954
			//# 26529 05/01/2011. when there are no children on ti, it means there is an unpacking process.
			// When the last child was removed, the ti has to follow Release Request field on the Pack / Unpack screen.
			if _bulkReleaseAfter = null then	//# 26529 05/01/2011
				if _bulkReleaseBefore &lt;&gt; null then
					_bulkReleaseBefore.removeTIReleased(ti);	// removing empty ti from bulk release according to blank release request value on the UI creen.
					_bulkReleaseBefore.removeTIAssigned(ti);	// removing empty ti from bulk release according to blank release request value on the UI creen.
				endif;
				
			else	// when _bulkReleaseAfter not null
				// if a parent ti has no children anymore, its reference should be moved back from Released collection to Assigned one on the bulk release.
				// I.e. empty parent is considered now as Assigned instead of Packed.
				if (_bulkReleaseBefore &lt;&gt; null) and (_bulkReleaseBefore &lt;&gt; _bulkReleaseAfter) then
					_bulkReleaseBefore.removeTIReleased(ti);	// removing empty ti from bulk release according to blank release request value on the UI creen.
					_bulkReleaseBefore.removeTIAssigned(ti);	// removing empty ti from bulk release according to blank release request value on the UI creen.
				endif;
				
				// cnwrd1 POL packing stuff CCMS 2103 par 27856 13.7.2011
				if not _bulkReleaseAfter.myTerminal.getConfig(PackingRelAsInternalRel).Boolean then	
					_bulkReleaseAfter.addTIAssigned(ti, CM_ReserveDetail.PackType_Parent);
				endif;
				
			endif;
			
			continue;
		endif;
		
		
		// When a container has children.
		if _bulkReleaseAfter &lt;&gt; null then	//26529 10/01/2011
			//ti.getAllChildren(children);//PAR 22954
			foreach childTI in ti.allChildren do : childLoop
			//foreach childTI in children do : childLoop
				// firstly, if a child is assigned to another release, it should be re-assigned here. #266529 05/01/2011
				tmpBR := childTI.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_PACKING,null,null,null);
				if tmpBR &lt;&gt; null and tmpBR &lt;&gt; _bulkReleaseAfter then
					tmpBR.removeTIAssigned(childTI);	// a child could be assigned to another release before, so, it is re-assigned here.
					//childBR.removeTIReleased(ti); // this is commented, because, a packed child is Released and cannot be packed to another box (we cannot select a packed children on the screen).
				endif;
				_bulkReleaseAfter.addTIReleased(childTI, CM_ReserveDetail.PackType_Child);
			endforeach;
			
			//Assigning parent to the bulk release. When any child is packed, prent becomes Released
			tmpBR := ti.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_PACKING,null,null,null);
			if tmpBR &lt;&gt; null and tmpBR &lt;&gt; _bulkReleaseAfter then
				tmpBR.removeTIAssigned(ti);	// When the first child is packed, the parent could be assigned to another release before, so, the parent is re-assigned here.
			endif;
			
			_bulkReleaseAfter.addTIReleased(ti, CM_ReserveDetail.PackType_Parent);
			
		endif;	
		
	endforeach;
	
	// #26529 05/01/2011. Any unpacked child should be connected to its original bulk release and a corresponding reserve selection
	// and have its reference moved back from Released collection to Assigned one on the bulk release. 
	// I.e. a child is considered now as Assigned instead of Packed.
	if _bulkReleaseBefore &lt;&gt; null then
		foreach ti in _theUnpackTIs do
			if not _bulkReleaseBefore.allReservePackingChildren.isEmpty then	// there are no reserve selection lines for children, so remove
				_bulkReleaseBefore.addTIAssigned(ti, CM_ReserveDetail.PackType_Child);
			endif;
		endforeach;
	endif;
	
	
	if _bulkReleaseAfter &lt;&gt; null then	//26529 10/01/2011
		if _bulkReleaseAfter.isComplete then
			_bulkReleaseAfter.setStatus(BR_COMPLETE, null, false);
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_theUnpackTIs" type="CM_TIArray"/>
        <Parameter name="_bulkReleaseBefore" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_bulkReleaseAfter" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIsForBulkEditSimple" id="46f57ab6-164a-4cde-a918-76f0934e9b63">
        <updating/>
        <source>utlUpdateTIsForBulkEditSimple(_agent : CMIF_TIBulkUpdateAgent input; _passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
08 May 2024	navab1	CR 64033 TASK 64035
*/
vars
	ti : CM_TrackedItem;
	props : PropertyNDict;
	propAgent : CMIF_TIBulkUpdateProperty;
	beforeStr, afterStr, fieldValue : String;
	editTrn : CM_Edit;
	stopsBeforeChanges : IntegerArray;
	lastUpdate		: Decimal [20];
	chunk : Integer;
	cmifMonitor			: CMIF_Monitor;
	tisCompleted : Integer;
	customsEntryAdded : Boolean;
	
begin
	on Exception do agtPassportExHandler(exception, _passport);
	
	if process.isRam() then
		app.createAlert("CAME TO USE SIMPLE UPDATE", true);
	endif;
	
	self.initialiseActivity();
	
	// do validation
	self.raiseExceptionIfNull(_agent, 'CMIF_TIBulkUpdateAgent');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateBulkTISimple(_agent);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	_passport.useTIDictDeferUpdate			:= true;
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useOfflineFutureActorDeferUpd	:= true;
	
	create stopsBeforeChanges transient;	

	lastUpdate := app.relativeMachineTime;
	cmifMonitor := app.myPassport.myCMIFMonitor;
	
	foreach ti in _agent.allTIs discreteLock do
		customsEntryAdded := false;
		if ti.customExportEntryNumber = null and _agent.masterHasCustomsEntryNumber = true then
			customsEntryAdded := true;
		endif;
		
		tisCompleted := tisCompleted + 1;
		editTrn := null;
		
		if _agent.canStopBeAffected then						//navra1 - BUG 64464 - 17th June 2024
			stopsBeforeChanges.clear();
			ti.getAllMatchingStopIDs(stopsBeforeChanges, 		// Get all stops that has criteria matches this TI before changes
												null); 
		endif;													//navra1 - BUG 64464 - 17th June 2024
		
		_agent.updateChangedPropertiesOfTI(ti);					//navra1 - BUG 64464 - 8th July 2024
		
		_agent.updateStopsForTI(ti, stopsBeforeChanges, customsEntryAdded, _passport);				//navra1 - BUG 64464 - 1st July 2024
		
		CMIF_TrxActionCargoGroup@createAction(ti, ti.myCargoGroup, _passport);
		
		//do chunking
		if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then			
			chunk := chunk + 1;
			
			if cmifMonitor &lt;&gt; null then
				cmifMonitor.partsDone := tisCompleted;
				cmifMonitor.updateProgressWithCaption(null, cmifMonitor.partsInJob, cmifMonitor.partsDone, null);
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
			endif;		
			
			_passport.doDeferredUpdates();
			
			_passport.useTIDictDeferUpdate			:= true;
			_passport.useTITransactionDeferUpdate	:= true;
			_passport.useOfflineFutureActorDeferUpd	:= true;
			
			if _passport.hasErrors() then
				if not process.isInTransactionState() then
					beginTransaction;
				endif;
			
				continue;
			endif;			
			
			commitTransaction;
			process.sleep(100);			
			lastUpdate := app.relativeMachineTime;
			beginTransaction;
		endif;		
		
	endforeach;	
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();						//navra1 - TFS 64033 - 28th May 2024 - do the final deferred updates
		// send update note
	endif;
epilog
	delete stopsBeforeChanges;	
	delete props;	
end;</source>
        <Parameter name="_agent" type="CMIF_TIBulkUpdateAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTSWWebService" id="ed2b6d41-b24d-4a9b-9887-d318ac810317">
        <updating/>
        <source>utlUpdateTSWWebService(	_pxyTSWWebService : CM_TSWWebService; 
						_cmifConfig : CMIF_ConfigRoot input;	// TFS 52746
						_expectedEdition : Integer;				// TFS 52746
						_passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
// 10/03/2022	navdap1		TFS 52746 PNL Custom Hold Clearance for Export Units using BOL with TSW EDI
//
vars
	realTSWWebService : CM_TSWWebService;
	expectedEdition : Integer;

begin
	self.initialiseActivity();

	_pxyTSWWebService.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyTSWWebService.pxyGetRealObjectAndEdition(realTSWWebService, expectedEdition);
	
	if realTSWWebService = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TSWWebService.name, null, null);
		return;
	endif;

	app.myValUA.valTSWWebService(realTSWWebService, _pxyTSWWebService);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realTSWWebService);

	if _passport.noErrors and realTSWWebService.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TSWWebService', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTSWWebService, true);
	endif;
	
	if _passport.noErrors then
		realTSWWebService.setForUpdate(_pxyTSWWebService);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTSWWebService, false);
	endif;

	if _passport.noErrors then																	// TFS 52746
		app.myUtilityUA.utlUpdateConfig(_cmifConfig, app.myRoot, _expectedEdition, _passport);	// TFS 52746
	endif;																						// TFS 52746

epilog

end;</source>
        <Parameter name="_pxyTSWWebService" type="CM_TSWWebService"/>
        <Parameter name="_cmifConfig" type="CMIF_ConfigRoot" usage="input"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTaAutoRestrictions" id="2ce73613-e695-4393-993d-71d557ed371e">
        <source>utlUpdateTaAutoRestrictions(_pxyTA : CM_TerminalArea input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	realTA		 	: CM_TerminalArea;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	_pxyTA.raiseExceptionIfNotProxy(method);
	_pxyTA.pxyGetRealObjectAndEdition(realTA, expectedEdition);

	if realTA = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TerminalArea.name, null, null);
		return;
	endif;

	if expectedEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(realTA);

	realTA.setAutoRetrictionsEnabled(_pxyTA.autoRestrictionsEnabled);
	
	if _passport.noErrors then
		// update the graphic display of the yard
		realTA.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,realTA); //epr 11/6/08  par 16956 
	endif;

end;</source>
        <Parameter name="_pxyTA" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTaskAllocateMachine" id="02246e59-b307-4ce2-8546-a7727b0a498d">
        <source>utlUpdateTaskAllocateMachine(pProxyRTQueueTask:CM_RTQueueTask input; 
							_sendMachineMessage : Boolean;
							_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	cancelSave:Boolean;
	realRTQueueTask:CM_RTQueueTask;
	expectedEdition:Integer;
	lCMIF_Object	: CMIF_Object;
	lTIArray	: CM_TIArray;

begin

	self.initialiseActivity();

	pProxyRTQueueTask.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	app.myValUA.valTaskAllocateMachine(pProxyRTQueueTask);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	pProxyRTQueueTask.pxyGetRealObjectAndEdition(realRTQueueTask, expectedEdition);
	
	if realRTQueueTask = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_RTQueueTask.name, null, null);
		return;
	endif;

	exclusiveLock(realRTQueueTask);

	if _passport.noErrors and realRTQueueTask.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Task Allocate Machine', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRTQueueTask, true);
	endif;
	
	if _passport.noErrors then
		realRTQueueTask.allocateMachineToTask(pProxyRTQueueTask.intendedMachine, _sendMachineMessage, true);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRTQueueTask, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyRTQueueTask" type="CM_RTQueueTask" usage="input"/>
