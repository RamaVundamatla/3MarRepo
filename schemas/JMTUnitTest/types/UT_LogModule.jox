	//				I am not interested in data from XML_BolMntRq constant - I use it as patern.
	//----------------------------------------------------------------------------------------------------------

	
	

	
	//------------------------------------------------------------------
	//						setting XML session
	//------------------------------------------------------------------
	//see CM_XMLWorker::DoTheWork()
	tmpStruct := struct.findStructure(XML_BOLNOLOOKUP);			
	tmpStruct.initializeWithTagData(tmpStruct.tagName, _bolNoLookup, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_DEVICEID);	tmpStruct.initializeWithTagData(tmpStruct.tagName, _deviceId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_USERID);		tmpStruct.initializeWithTagData(tmpStruct.tagName, userId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TERMINAL);	tmpStruct.initializeWithTagData(tmpStruct.tagName, terminalCode, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_SUPPLIERLOOKUP);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _operatorLookup, tmpStruct.tagAttribute);	
	xmlVersion:= struct.findStructure(XML_VERSION).tagData;


	xmlSession.set(userId, _deviceId, terminalCode, xmlVersion, null);	
	
	self.assertNotNull(xmlSession.myTerminal);
	self.assertNotNull(xmlSession.myUser);
	self.assertNotNull(xmlSession.myDevice);
	
	
	//------------------------------------------------------------------
	//						creating a BOLIn
	//------------------------------------------------------------------
	
	remoteManager.processExternal(xmlStr, struct, xmlSession);
	self.assertNoTrxErrorsOrWarnings();
	
	bolIn := self.getBOL(_number, BOLType_Log, _operatorLookup).CM_BOLIn;
	
	self.assertNotNull(bolIn);
	
	return bolIn;
	*/


 //original test source
 
	xmlStr			:= XML_BolMntRq;
	if app.userName().toUpper = "CNWER1" then
		userId			:= app.myPassport.myUser.code; 
	else
		//userId := app.userName().toUpper;
		userId := self.testProfile.getSetting(UT_Profile.P_USER).asString;	// 19/04/2011 cnwmh5
	endif;
	if userId = null then		// 19/49/2011 cnwmh5
		userId := 'UNITTEST';
	endif;
		
	terminalCode	:= self.getTerminal().code;
	fellingDate		:= app.actualTimeServer().Date;
	
	if _fellDate = null then
		fellDate := fellingDate.formatAsYYYYMMDD();
	endif;
	
	create remoteManager transient;
	create xmlSession transient;

	//------------------------------------------------------------------
	//					Creating XML structure
	//------------------------------------------------------------------
	
	create struct as CnEcXmlGroupInstance transient;
	create parser transient;
	parser.parseToMsgStructure(xmlStr, struct);

	//----------------------------------------------------------------------------------------------------------
	//				Setting current parameters into XML data, 
	//				I am not interested in data from XML_BolMntRq constant - I use it as patern.
	//----------------------------------------------------------------------------------------------------------
	tmpStruct := struct.findStructure(XML_ACTIVITY);			
	tmpStruct.initializeWithTagData(tmpStruct.tagName, _activity, tmpStruct.tagAttribute);					
	tmpStruct := struct.findStructure(XML_BACKLOAD);			
	tmpStruct.initializeWithTagData(tmpStruct.tagName, _backLoad, tmpStruct.tagAttribute);		
	tmpStruct := struct.findStructure(XML_BOLNOLOOKUP);			
	tmpStruct.initializeWithTagData(tmpStruct.tagName, _bolNoLookup, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_CARRIERID);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _carrierCode, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_CHHSUPPLIER);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _chhSupplier, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_COMPARTMENT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _compartment, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_CUSTOMER);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _customer, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_DOCKETERROR);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _docketError, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_DRIVERID);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _driverId, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_PIECECOUNTERROR);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _pieceCountError, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_DRIVERSPIECECOUNT);	tmpStruct.initializeWithTagData(tmpStruct.tagName, _driversPieceCount, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_FELLINGDATE);			tmpStruct.initializeWithTagData(tmpStruct.tagName, fellDate, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_FOREST);				tmpStruct.initializeWithTagData(tmpStruct.tagName, _forest, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_GANG);				tmpStruct.initializeWithTagData(tmpStruct.tagName, _gang, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_GROSSWEIGHT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _grossWeight, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_FSC);					tmpStruct.initializeWithTagData(tmpStruct.tagName, _isFSC, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_NIGHTSHIFT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _isNightShift, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LOADERNO);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _loaderNumber, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_LOADINGCONT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _loadingContractor, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_LOGGINGCONT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _loggingContractor, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_LOGGINGOP);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _loggingOperation, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_LOGGINGORG);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _loggingOrg, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_NETWEIGHT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _netWeight, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_BOLNO);				tmpStruct.initializeWithTagData(tmpStruct.tagName, _number, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_SUPPLIERLOOKUP);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _operatorLookup, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_OPID);				tmpStruct.initializeWithTagData(tmpStruct.tagName, _opid, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_PICKUPPOINT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _pickupPoint, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_REMARKS);				tmpStruct.initializeWithTagData(tmpStruct.tagName, _remarks, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_STAND);				tmpStruct.initializeWithTagData(tmpStruct.tagName, _stand, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_SUBSUPPLIER);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _subSupplier, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_TAREWEIGHT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _tareWeight, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_TRAILERNO);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _trailerNumber, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TRUCKNO);				tmpStruct.initializeWithTagData(tmpStruct.tagName, _truckNumber, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_UNLOADPOINT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _unloadPoint, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_VEHICLEID);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _vehicle, tmpStruct.tagAttribute);	
	tmpStruct := struct.findStructure(XML_WEIGHBRIDGE);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _weighBridge, tmpStruct.tagAttribute);
	
	

	
	//------------------------------------------------------------------
	//						setting XML session
	//------------------------------------------------------------------
	//see CM_XMLWorker::DoTheWork()
	tmpStruct := struct.findStructure(XML_DEVICEID);	tmpStruct.initializeWithTagData(tmpStruct.tagName, _deviceId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_USERID);		tmpStruct.initializeWithTagData(tmpStruct.tagName, userId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TERMINAL);	tmpStruct.initializeWithTagData(tmpStruct.tagName, terminalCode, tmpStruct.tagAttribute);
	xmlVersion:= struct.findStructure(XML_VERSION).tagData;


	xmlSession.set(userId, _deviceId, terminalCode, xmlVersion, null);	
	
	self.assertNotNull(xmlSession.myTerminal);
	self.assertNotNull(xmlSession.myUser);
	self.assertNotNull(xmlSession.myDevice);
	
	
	//------------------------------------------------------------------
	//						creating a BOLIn
	//------------------------------------------------------------------
	
	remoteManager.processExternal(xmlStr, struct, xmlSession);
	self.assertNoTrxErrorsOrWarnings();
	
	bolIn := self.getBOL(_number, BOLType_Log, _operatorLookup).CM_BOLIn;
	
	self.assertNotNull(bolIn);
	
	return bolIn;
	

epilog
	delete remoteManager;
	delete xmlSession;
	delete struct ;
	delete parser;
end;
</source>
