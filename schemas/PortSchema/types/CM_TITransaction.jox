    <JadeMethod name="getName" id="1a98dc13-97b8-480c-9ae8-d66f790f67f5">
        <source>getName() : String;

// 20/08/2018	jlgmd1		TFS 40386 - Jade 2016 Changes

vars
	returnStr	: String;
	term 		: CM_Terminal;
	ti 			: CM_TrackedItem;
	invalid 	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, term, invalid);		// TFS 40386
	on Exception do app.handleDeletedObject(exception, ti, invalid);		// TFS 40386
	
	returnStr	:= inheritMethod();
	
	
	if self.deleted then // TFS 43075 JLGAB1
		returnStr	:= returnStr &amp; " (DELETED) ";	 // TFS 43075 JLGAB1
	endif; // TFS 43075 JLGAB1

	if self.myTerminal &lt;&gt; null then
		term := self.myTerminal;
		returnStr	:= returnStr &amp; Tab &amp; term.code;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		ti := self.myTrackedItem;
		returnStr	:= returnStr &amp; Tab &amp; ti.id;
	endif;
	
	returnStr	:= returnStr &amp; Tab &amp; self.dateTime.cnEcShortFullFormat; // TFS 45953 changed to dateTime.
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
