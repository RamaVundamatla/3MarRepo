<Class name="CM_TcpipSendAgent" id="a608f9d3-59d7-4dbb-925e-985a7c658497">
    <superclass name="CM_Transient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="address" id="cd62d25a-c30d-4cbd-87ed-68475c0842dc">
        <length>129</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="bufferLength" id="2ea97ee0-1bea-4644-ad0d-68eaf0344670">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="dataToSend" id="24a69805-e08a-44f7-8c41-4c34ecab4785">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="isReadResultAsync" id="457fd647-aaec-43bd-a3b1-c1c8231bf968">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myConnection" id="18dd3d89-e430-4132-86de-4074a2781592">
        <embedded/>
        <type name="TcpIpConnection"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <PrimAttribute name="port" id="a6b46441-880d-426b-95b8-2328240b7e38">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="responseStr" id="83cdad11-e8a2-4385-a3fa-5fa9a031d45d">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="responseTerminator" id="74ccaf66-8f30-45e7-bf6a-c817c67cfb87">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timeout" id="6cb7f5bf-eb01-4365-a036-1d52b7b7d019">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="e53d4c1a-4893-4191-bbd9-50c35920ac7e">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	create self.myConnection transient;
	self.bufferLength := 10240;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="c282820c-99db-408f-aafe-fd971bddba05">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myConnection &lt;&gt; null then
		self.myConnection.close();
	endif;
	delete self.myConnection;
end;</source>
    </JadeMethod>
    <JadeMethod name="doConnectionClose" id="8d5d68d7-ddf2-4b0a-bbf1-1951ef92fbf6">
        <source>doConnectionClose() protected;
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myConnection.close();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConnectionOpen" id="e58fae64-0ff4-4360-a49f-e4f77bf3080a">
        <source>doConnectionOpen() protected;
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myConnection.name := self.address;
	self.myConnection.port := self.port;
	self.myConnection.open();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSend" id="e8f5fbaa-b65a-4cbc-b745-2054f7eaf488">
        <updating/>
        <source>doSend() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	sendBlob1	: Binary;
	rtnCode		: Boolean;
	tmpStr		: String;
	
begin

	on ConnectionException do self.xhandlerConnection(exception);

	self.responseStr := null;

	self.myConnection.timeout	:= self.timeout;

	if self.myConnection.state &lt;&gt; TcpIpConnection.Connected then
		self.doConnectionOpen();
	endif;
	
	if self.myConnection.state &lt;&gt; TcpIpConnection.Connected then
		self.responseStr := 'ERROR &gt;&gt; Connection not open';
		return rtnCode;
	endif;
	
	if self.dataToSend = null then 
		self.responseStr := 'ERROR &gt;&gt; No data to send';
		return rtnCode;
	endif;		
	
	sendBlob1 := self.dataToSend.asANSI(0);// 15/3/16  cnwns1 PAR 36286 unicode version
	self.myConnection.writeBinary(sendBlob1);

	if self.isReadResultAsync then
		self.myConnection.readBinaryAsynch(self.bufferLength, self, 'readBinaryAsynchCB');
	elseif self.responseTerminator &lt;&gt; null then
		tmpStr := self.myConnection.readUntil(self.responseTerminator.asANSI(0), 0).ansiToString();// 15/3/16  cnwns1 PAR 36286 unicode version
		if tmpStr &lt;&gt; null then
			self.responseStr := tmpStr &amp; self.responseTerminator.String;
		else
			self.responseStr := 'Response timed out';
		endif;
	else
		tmpStr := self.myConnection.readBinary(self.bufferLength).ansiToString();// 15/3/16  cnwns1 PAR 36286 unicode version
		if tmpStr &lt;&gt; null then
			self.responseStr := tmpStr;
		else
			self.responseStr := 'Response timed out';
		endif;
	endif;
	
	rtnCode := true;

epilog
	return rtnCode;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="2fa05650-c186-4ab5-b36a-9030d0ae82b3">
        <updating/>
        <source>init(_address : String; _port : Integer; _isReadResultAsync : Boolean;
	_responseTerminator : String; _timeout : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.address	:= _address;
	self.port		:= _port;
	
	self.isReadResultAsync	:= _isReadResultAsync;
	self.responseTerminator	:= _responseTerminator;
	self.timeout 			:= _timeout;		// milliseconds

end;</source>
        <Parameter name="_address" type="String"/>
        <Parameter name="_port" type="Integer"/>
        <Parameter name="_isReadResultAsync" type="Boolean"/>
        <Parameter name="_responseTerminator" type="String"/>
        <Parameter name="_timeout" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="readBinaryAsynchCB" id="81b92701-4555-4587-a3d4-8aca60f06e57">
        <updating/>
        <source>readBinaryAsynchCB(_tcp : TcpIpConnection; _buffer : Binary) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _tcp = self.myConnection then
		self.responseStr := self.responseStr &amp; _buffer.ansiToString();// 16/3/16  cnwns1 PAR 36286 unicode version
		self.myConnection.readBinaryAsynch(self.bufferLength, self, 'readBinaryAsynchCB');		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_tcp" type="TcpIpConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="xhandlerConnection" id="d311416e-dee8-4b3b-ac53-68c084f2c649">
        <updating/>
        <source>xhandlerConnection(_exObj : ConnectionException) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _exObj.errorCode = 31001 then
		app.msgBox('no target host name specified', 'Error', MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31002 then
		app.msgBox('target host not found', 'Error', MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31003 then
		app.msgBox('invalid port specification', 'Error', MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31004 then
		app.msgBox('failed to connect', 'Error', MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31008 or _exObj.errorCode = 31009 or _exObj.errorCode = 31017 then
		self.doConnectionClose();
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
