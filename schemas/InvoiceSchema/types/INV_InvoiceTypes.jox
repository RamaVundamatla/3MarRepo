	self.doCmbAccuralTypeBuild();
	self.doCmbFieldBuild(self.cmbField1);
	self.doCmbFieldBuild(self.cmbField2);
	self.doCmbFieldBuild(self.cmbField3);
	self.doCmbFieldBuild(self.cmbField4);
	self.doCmbFieldBuild(self.cmbField5);
	self.doCmbSepInvoicesBuild();
