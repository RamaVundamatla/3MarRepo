    <JadeMethod name="selectBookingRefTIs" id="dfc4a784-c71c-4b4f-af9f-68c8d203d667">
        <source>selectBookingRefTIs(_opCode, _voyageCode, _bookingRef : String; _receiveDT : TimeStamp) : Integer;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	br : CM_BookingRef;
	checkOperator, checkReceipt : Boolean;
	operator : CM_Operator;
	ti : CM_TrackedItem;
begin
	operator := app.myRoot.allOperators[_opCode];
	checkOperator := (operator &lt;&gt; null);
	checkReceipt := (_receiveDT &lt;&gt; null);
	
	foreach br in allBookingRefs do
		if checkOperator and br.myOperator &lt;&gt; operator then
			continue;		//Ignore this b/r		
		endif;
		
		if checkReceipt then
			foreach ti in br.allTIs do
				if ti.receivedDT &lt;&gt; null and ti.receivedDT &gt; _receiveDT then
					app.allReportTIs.add(ti);
				endif;
			endforeach;
		else
			br.allTIs.copy(app.allReportTIs);
		endif;			
		
	endforeach;
	return app.allReportTIs.size;
end;</source>
        <Parameter name="_opCode" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_receiveDT" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sendCargoToOpsView" id="8d5f3d49-7b11-4a7d-b8e2-68f70b004747">
        <source>sendCargoToOpsView();
/*
Purpose:	Inform OpsView about all the cargo on the voyage - to change some N4 state fields
			

Date		Who		Reason
07 June 2022	navab1	TFS 53105
*/

vars
	ti : CM_TrackedItem;
begin

	if not app.myPassport.isOpsViewEnabled(self.myTerminal) then
		return;
	endif;
	
	foreach ti in self.allOnshipTIsByCargoTypeId discreteLock do
		if ti.allJobsShipReceive.isEmpty() then
			ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti); 
		endif;
	
	endforeach;
	
	foreach ti in self.allOnsiteTIsByCargoTypeId discreteLock do
		if ti.allJobsShipRelease.isEmpty() then
			ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti); 
		endif;
	
	endforeach;
	
	
	foreach ti in self.allNotifiedTIsByCargoTypeId discreteLock do
		ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti); 
	endforeach;
						 

epilog

end;</source>
    </JadeMethod>
