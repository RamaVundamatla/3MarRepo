    <JadeMethod name="cnwdad1_SetFont" id="efef624e-483d-4a6e-ab6d-8a4adb7e9f1e">
        <source>cnwdad1_SetFont() protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2006 by cnwdad1
//
// Purpose:		Sets the default font on all instances of the Application class for
//				apps that are in BaseSchema and below.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	applicationObj	: Application;
	schemaObj		: Schema;

begin
	foreach applicationObj in Application.instances do
		schemaObj	:=	applicationObj.getPropertyValue(Application::schema.name).Schema;
		
		if schemaObj = currentSchema or schemaObj.jssIsSubschemaOf(currentSchema) then
			write applicationObj.name &amp; Tab &amp; applicationObj.getPropertyValue(Application::schema.name).Schema.name;
			beginTransaction;
			applicationObj.fontName	:=	'Verdana';
			commitTransaction;
		endif;	

	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_StartService" id="b9f26d80-9eca-4d96-8c39-a6390eece987">
        <source>cnwdad1_StartService();
// --------------------------------------------------------------------------------
// Created:		06 February 2001 by cnwdad1
//
// Purpose:		Starts an NT Service by name for the Application Server.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startResult	: Integer;
	serviceName	: String;
	
begin
	serviceName	:=	app.getProfileString(app.getIniFileName(), JSS_INI_SECTION_BASESCHEMA, JSS_INI_APPSERV_SERVICENAME, "");

	if serviceName &lt;&gt; null then
		// Start the application server's service.
		node.createExternalProcess('', 'NET START "' &amp; serviceName &amp; '"', null, '', false, true, startResult);
	endif;

	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_ArrayRandomSelect" id="1b151051-6867-404d-9382-561225ba497f">
        <source>cnwdad1_Test_ArrayRandomSelect();
// --------------------------------------------------------------------------------
// Created:		23 March 2003 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allCandidates		: StringArray;
	selectedCandidate	: String;
	counter				: Integer;
	
begin
	create allCandidates transient;
	
	allCandidates.add("Phar Lap");
	allCandidates.add("Sunline");
	allCandidates.add("Northerly");
	allCandidates.add("Ella Vajoy");
	allCandidates.add("Monaro");
	allCandidates.add("Halogen");
	allCandidates.add("Lyell Creek");
	allCandidates.add("Young Rufus");
	allCandidates.add("O'Reilly");
	allCandidates.add("Bob Dobalino");
	allCandidates.add("Desert Holly");
	allCandidates.add("Tuk Tuk");
	
	allCandidates.jssRandomSelect(10);
	allCandidates.jssSort(false);
	counter	:=	0;
	write "";
	
	foreach selectedCandidate in allCandidates do
		counter	:=	counter + 1;
		write counter.String &amp; ": " &amp; selectedCandidate;
	endforeach;
epilog
	delete allCandidates;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_ArrayScramble" id="f16acdcd-a3d9-49e2-8fd4-82feca37e6eb">
        <source>cnwdad1_Test_ArrayScramble();
// --------------------------------------------------------------------------------
// Created:		23 March 2003 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allCandidates		: StringArray;
	selectedCandidate	: String;
	counter				: Integer;
	
begin
	create allCandidates transient;
	
	allCandidates.add("Phar Lap");
	allCandidates.add("Sunline");
	allCandidates.add("Northerly");
	allCandidates.add("Ella Vajoy");
	allCandidates.add("Monaro");
	allCandidates.add("Halogen");
	allCandidates.add("Lyell Creek");
	allCandidates.add("Young Rufus");
	allCandidates.add("O'Reilly");
	allCandidates.add("Bob Dobalino");
	allCandidates.add("Desert Holly");
	allCandidates.add("Tuk Tuk");
	
	allCandidates.jssSort(false);
	counter	:=	0;	
	write CrLf &amp; "Unscrambled:";
	
	foreach selectedCandidate in allCandidates do
		counter	:=	counter + 1;
		write counter.String &amp; ": " &amp; selectedCandidate;
	endforeach;
	
	allCandidates.jssScramble();
	counter	:=	0;
	write CrLf &amp; "Scrambled:";
	
	foreach selectedCandidate in allCandidates do
		counter	:=	counter + 1;
		write counter.String &amp; ": " &amp; selectedCandidate;
	endforeach;
epilog
	delete allCandidates;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Array_Sort" id="003f7be6-ea40-44b8-9059-c1ab4d94f1a9">
        <source>cnwdad1_Test_Array_Sort();
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDecimalArray	: DecimalArray;
	decimalValue	: Decimal[23,2];
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	create theDecimalArray transient;
	
	theDecimalArray.add(12.34);
	theDecimalArray.add(49.27);
	theDecimalArray.add(8.03);
	theDecimalArray.add(91.10);
	theDecimalArray.add(36.6);
	theDecimalArray.add(73.43);
	theDecimalArray.add(1.553);
	theDecimalArray.add(68.8);
	theDecimalArray.add(88.21);
	theDecimalArray.add(25.67);
	theDecimalArray.add(31.09);
	theDecimalArray.add(43.54);
	theDecimalArray.add(98.98);

	write CrLf &amp; "Unsorted:";
	
	foreach decimalValue in theDecimalArray do
		write decimalValue;
	endforeach;
	
	// Sort the array in descending order...
	theDecimalArray.jssSort(true);

	write CrLf &amp; "Sorted:";
	
	foreach decimalValue in theDecimalArray do
		write decimalValue;
	endforeach;
epilog
	delete theDecimalArray;
	
	write "Sort completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_AsWords_Decimal" id="755a7e18-0d27-4711-abda-3c9583d081c5">
        <source>cnwdad1_Test_AsWords_Decimal();
// -----------------------------------------------------------------------------
// Created:		05 November 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	value			: Decimal[18,2];
	wholeAmount		: String;
	decimalAmount	: String;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	value		:=	"123456789012345.23".Decimal;
	write value.numberFormat();
	value.jssAsWords(null, wholeAmount, decimalAmount);
	
	write wholeAmount;
	write decimalAmount;
epilog
	write "Decimal words completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
