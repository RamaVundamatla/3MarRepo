    <JadeMethod name="addToolbarControls" id="f3704790-179e-4cc9-b2cd-5818e9d14dcd">
        <updating/>
        <source>addToolbarControls() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3129 LNX Voyage Operations Enhancements
//
vars
	toolbar : CMUI_Toolbar;

begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnNewTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnVoyageDef, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShipDelays, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShipDelaysEnq, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHoldSorting, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEventTrans, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEventAlloc, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTranship, CMUI_Toolbar.Control_Alignment_Left); // TFS 3561
	toolbar.addButton(self.btnAlloc, CMUI_Toolbar.Control_Alignment_Left); // TFS 3646
	//toolbar.addButton(self.btnCopyCargo, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHoldJobOps, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
