    <JadeMethod name="setupForm" id="c05bfda6-52ab-45d5-be32-655d778f8743">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	09 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars

	ti : CM_TrackedItem;
	
begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	

	
	inheritMethod();
	//epr par 33025 20/11/13
	self.setupCmdButtons( 3, app.getErrorString(Edit), app.getErrorString(Cancel), BACK_BUTTON, null, null );
	self.setupControls();
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMenu" id="4735fd14-3651-45e0-bf0d-116b5d1498ae">
        <updating/>
        <source>setupMenu() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

	passport : CM_Passport;
	term : CM_Terminal;
	
begin

	passport := app.myPassport;
	term := passport.myTerminal;
	
	if not app.myCurrentUserCan(term, PmHHMove) then
		self.mnuMove.visible := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHMaintainStops) then
		self.mnuStops.visible := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHMaintainTasks) then
		self.mnuTasks.visible := false;
	endif;
	
	self.isMenuItemsVisible := self.mnuMove.visible or
						self.mnuStops.visible or
						self.mnuTasks.visible;
							
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="e44da79c-e50c-4f9d-bd9f-093363f1967c">
        <source>setupTable() protected;
/*
Date		Who		Reason
28 January 2009	cnwcp2	Initial creation
*/

vars

begin
	
	self.tblGrades.parentAspect:=Control.ParentAspect_StretchBoth;
	self.tblGrades.columns := 2;
	self.tblGrades.accessColumn(1).inputType := Table.InputType_CheckBox;
	self.tblGrades.accessColumn(1).width := 30;
	self.tblGrades.accessColumn(2).inputType := Table.InputType_None;
	self.tblGrades.selectMode := Table.SelectMode_WholeRows;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblGrades_change" id="63911bc5-be1b-4975-a4e6-e2a11b8d1a76">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGrades_change(table: Table input) updating;
/*
Date		Who		Reason
28 January 2009	cnwcp2	Initial creation
*/

vars

begin
	somethingChanged := true;
	self.btnOne.enabled := true;
	self.btnOne.caption := app.getErrorString(Save);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblGrades_click" id="09ba472f-15f1-4fb2-bc9f-b2fbad8278f3">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGrades_click(table: Table input) updating;

/*

Purpose:		 	

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwrd1	Initial creation par 29204

*/


vars
	row, column : Integer;
begin

	row := table.row;
	column := table.column;
	
	if column &lt;&gt; 1 then
		return;
	endif;
	
	if table.rows &lt;= 1 or row &gt; table.rows then
		return;
	endif;
	
	if not self.tblGrades.userInputEnabled  then
		return;
	endif;
	
	if self.selectedRow = 0 then
		self.selectedRow := row;
		table.accessCell(selectedRow,1).enabled := false;
		return;
	endif;
	
	
	
	if row &lt;&gt; self.selectedRow then
		table.accessCell(self.selectedRow,1).text := "0";
		table.accessCell(self.selectedRow,1).enabled := true;
		self.selectedRow := row;
		table.accessCell(selectedRow,1).enabled := false;
	else
		// PAR 36458 
		table.accessCell(self.selectedRow,1).text := "1";
		table.accessCell(selectedRow,1).enabled := false;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblGrades_contextMenu" id="070f0baf-5536-4910-8748-36ad7f1c2ba4">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGrades_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

begin

	if not self.wasCalledViaContext(false) then
		return false;
	endif;

	// we only want to show these contexts if we started at the enquiry form.

	return buildContextMenu(table, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7ac1abe0-1d38-4d85-b562-306e45bde4ca">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013035, locale);
	lblCargoId.translateCaption(Xlat_0019045, locale);
	mnuContext.translateCaption(Xlat_0015221, locale);
	mnuMove.translateCaption(Xlat_0015222, locale);
	mnuStops.translateCaption(Xlat_0015223, locale);
	mnuTasks.translateCaption(Xlat_0015224, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="549df6a1-fd56-46a4-9030-11709c0f9f2d">
