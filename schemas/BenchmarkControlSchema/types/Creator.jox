	if myBmkControl.owner[1:6] = 'cnwjbl'  then
		copies:=20;
		port:=myBmkControl.bmkBasePort.Integer + appSequenceId mod myBmkControl.appServers;
	else
		copies:=20;
		port:=myBmkControl.bmkBasePort.Integer + appSequenceId mod myBmkControl.appServers;
	endif;
end;</source>
