    <JadeMethod name="getClassChangesNumber" id="21d56b61-6d92-4514-b6e6-123dc83d571c">
        <updating/>
        <source>getClassChangesNumber(_className: String; _strArray : StringArray io): Integer updating;
/*
// 17 Jun 2014	cnwrs1	Par 34413 lost updates in DSS
*/
vars
	retValue : Integer;
begin
	retValue := self.myExternalInterface.sendMsgWithParams(method.name, _className, _strArray).Integer;
	return retValue;
end;
</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_strArray" type="StringArray" usage="io"/>
        <ReturnType type="Integer"/>
