    <JadeMethod name="doTblDtlDataContext" id="04ae4d2f-c500-428d-a666-aa1dcbc4eb72">
        <updating/>
        <source>doTblDtlDataContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
	visibleBeforeSep : Boolean;
	visibleAfterSep : Boolean;
	
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
	self.doMnuContextDetailBuild();

	self.popupMenu(self.mnuDetailContext, xLeft.Integer, yTop.Integer);

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
