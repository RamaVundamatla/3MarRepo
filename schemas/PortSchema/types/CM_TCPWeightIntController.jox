    <JadeMethod name="connectedState" id="3b4b79ca-db25-48f0-bd44-48acf4e25cd1">
        <source>connectedState() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwrh7	Initial creation

*/

vars

begin
	return (self.myTCPConnection.state = Connection.Connected);
epilog

end;</source>
