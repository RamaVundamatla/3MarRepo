    <JadeMethod name="doNotesForLegend" id="1063f60d-2604-4ea1-a29a-5f3ef242b94e">
        <source>doNotesForLegend(_startNote : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	idx, numRows : Integer;
	theTable : Table;
begin
	theTable := self.frmColLegendTIs.myLegendTable;
	numRows := theTable.rows;
	foreach idx in 2 to numRows do
		anObject := theTable.accessRow(idx).itemObject;
		if anObject &lt;&gt; null then
			if _startNote then
				self.beginNotification(anObject, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			else
				self.endNotification(anObject, EVENT_CODE_COLOUR_CHANGE);
			endif;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_startNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegendStartStop" id="cabaa966-8361-4755-a10e-63cafe08c531">
        <updating/>
        <source>doNotesForLegendStartStop(_theIndex : Integer; _ydc : YRD_ContainerDrawingController) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.doNotesForLegend(false);
	if (not self.frmColLegendTIs.displayCodesForMode(_ydc.viewMode, _ydc.myDrawingAttrController)) then
		// could not find any codes/colours in controller so display them all
		self.frmColLegendTIs.doChangeViewMode(_theIndex);
	endif;
	self.doNotesForLegend(true);

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_ydc" type="YRD_ContainerDrawingController"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="c5687f7e-2b5a-4d75-b496-e88eeb246f88">
        <updating/>
        <source>doQuery(_viewMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numDB : Integer;
	cdc : YRD_CargoRowDrawingController;
	ydb : YRD_ContainerGridAreaDockBar;
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	tmpController	: YRD_ContainerDrawingController;
	tmpDkbGridArea	: CMUI_GridAreaDockBar;
	breakOut : Boolean;
	aTA : Object;
	obj : Object;
	aTI : CM_TrackedItem;
begin

	self.dkbGridArea.visible := false;
	self.dkcGridArea.visible := true;
	self.tblGridAreaInfo.rows := 0;
	
	// PAR 26858
	ydb := self.allDockBars.first().YRD_ContainerGridAreaDockBar;

	if ydb = null then
		// NOTE. the create of YDB creates the frames etc.
		ydb := self.dkbGridArea.cloneSelf(true);
		self.allDockBars.add(ydb);

		self.addControl(ydb);
		ydb.parent := self.dkcGridArea;
		ydb.visible := true;
		ydb.postCreate();
		ydb.left := 1;
	endif;
	
	self.myDrawingFrame := ydb.myDrawingFrame; 
	self.myDrawingFrame.isEnquiry := true;
	
	self.myDrawingFrame.doAutoScrolling := true;
	cdc := ydb.myDrawingController.YRD_CargoRowDrawingController;
	self.setMyCurrentDrawingController(cdc, true);
	cdc.showDrawingFrame(false);
	cdc.allSelectorTIs.clear(); // PAR 26858

	self.myDrawingFrame.changeBackColor(self.defYardBackColSelected);

	ydb.setScrolledCallbackMethod('handleGridAreaScrolledEvent');

	ydb.setHLabelDetails(0, false);
	ydb.setVLabelDetails(0, false);
	// when able add labels as virtual to CMUI_GridAreaDockBar and
	// make dkbGridArea.myScrollableFrame protected
	tmpScrollableFrame := ydb.myScrollableFrame;
	tmpScrollableFrame.labels := ScrollBars_Both;

	cdc.allSelectorTIs.clear;
	
	if self.mySelectorEnquiryController &lt;&gt; null then
		self.useSelector := true;
		
		foreach obj in self.allTIs do
			aTI := obj.CM_TrackedItem;
			if self.mySelectorEnquiryController.includesObject(aTI, breakOut, app.myPassport) then
			
				cdc.allSelectorTIs.add(aTI);
			endif;
		endforeach;
//		self.allTIs.copy(cdc.allSelectorTIs);
		cdc.mySelectorEnquiryController := self.mySelectorEnquiryController;
	endif;
	
	cdc.setFlip(self.xmlFlipH,self.xmlFlipV);
	cdc.setScale(self.xmlZoomFactor, true, true); //CMUI_GridDrawingController.ScaleFactor_2);
	cdc.moveMode := self.moveModeForm;
	cdc.onlySelectSelectorTIs := self.onlySelectSelectorTIs;
	
	cdc.init(null,self.allGridRows);
	self.viewForMode(_viewMode, false);
	cdc.setViewMode(_viewMode);
	
	//cnwjo3 par 25479.  Don't need this since it will be done in setDisplayMode
	//cdc.drawSelf(true); // ### &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;

	cdc.notableObjectsClear();
	foreach aTA in self.allTerminalAreas do
		cdc.notableObjectAdd(aTA);
	endforeach;
	cdc.changeBackColor(self.defYardBackColSelected);
	ydb.cnEcResizeContents();

	self.myCurrentDrawingController.setScale(self.xmlZoomFactor, true, true);
	self.myDrawingFrame.myDragSelectFrame.visible := true;
	self.myDrawingFrame.myDragSelectFrame.zOrder(1);
	ydb.myScrollableFrame.myHLabels.height := 0;
	ydb.myScrollableFrame.myHLabels.backColor := Red;
	ydb.myScrollableFrame.myScrollingFrame.top := 0;
	ydb.myScrollableFrame.myTopLeftFillerFrame.visible := false;
	self.setDisplayMode(DISPLAY_MODE_ACTUAL);
	
	if self.initMoveMode &gt; null then
		self.frmStatusLine.doMenuMoveClick(self.initMoveMode);
	endif;



end;</source>
        <Parameter name="_viewMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="6eaf230b-daf8-4ef8-b0c6-cec40ab7954c">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpController	: YRD_ContainerDrawingController;
	anObj : Object;
	tmpVM : Integer;
	wasYALOC : Boolean;
begin
	inheritMethod();
	tmpController := self.myCurrentDrawingController;
	
	if tmpController.viewMode = VIEW_YARD_ALLOC then
		wasYALOC := true;
		tmpVM := self.viewModePrev4YardAlloc;
	else
		tmpVM := tmpController.viewMode;
	endif;
	
	if tmpVM &lt;&gt; 0 then
		tmpController.setViewMode(tmpVM);
	else
		tmpController.setViewMode(VIEW_VOYAGE);
	endif;
	tmpController.drawSelf(true);
	if wasYALOC then
		tmpController.setViewMode(VIEW_YARD_ALLOC);
	endif;
//		tmpController.getYardAllocationPoints(false); // draw on viewing frame
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="4e440d4a-cdf1-4cbc-abe1-0baa7ff68562">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	anObj : Object;
	cdb : YRD_ContainerGridAreaDockBar;
begin

	

	inheritMethod();
	
	self.frmSelectorPane.cnEcResizeContents;	//28 July 2011	NDL	Par 27890
	
	foreach anObj in self.allDockBars do
		cdb := anObj.YRD_ContainerGridAreaDockBar;
		cdb.cnEcResizeContents();
	endforeach;

	self.frmStatusLine.doResize();
	self.setLastColumnMaxWidth(self.tblGridAreaInfo);
	self.doResizeColumnWidths(self.tblGridAreaInfo, true);
	
	
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doRestrictionOpenLabour" id="d9a0150d-11df-4309-8871-13ed30b0e7fd">
        <source>doRestrictionOpenLabour(_ta : CM_TerminalArea)protected;
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - replace YRD_LocationMaintForm constants with YRDPadArea Constants
vars

	rowNum		: Integer;
