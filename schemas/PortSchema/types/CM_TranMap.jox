    <JadeMethod name="shouldAuditProperty" id="9fc75539-2c43-425a-a13b-d4d7c475bfa6">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Dec 2016	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TranMap::myChildQuantityMap.name 
		
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="44a30043-bd19-4a16-8b8b-67b81642d867">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 09/12/2014 cnwdb2 PAR 35364
// ---------------------------------------------------------------------------

vars

begin
	// cnwrl1 06/11/2009 PAR 19717 - start of coding
	if self.name = null then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getString( Name ), self.name, null );
		app.raiseCMException1( Input_required_field_Required, app.getString( Name ), self.name, null ); // cnwdb2	PAR 35364
	endif;
	// cnwrl1 06/11/2009 PAR 19717 - end of coding
	// cnwjre1 May 2010 duplicate test added from general transaction map development, to avoid 1310 exception
	if self.bank &lt;&gt; null then
		if self.bank.myCurrentTranMapCargo[self.name] &lt;&gt; null then
		//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Transaction map",self.name,null,null,null);
			app.raiseCMException1(TransactionMap_already_exists,self.name,null,null); // cnwdb2 PAR 35364
		endif;
	endif;
end;</source>
    </JadeMethod>
