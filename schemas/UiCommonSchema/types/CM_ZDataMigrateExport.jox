        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2014	cnwndl1	Initial creation

*/

vars

begin

	self.minimumWidth := 600;
	self.minimumHeight := 550;
	self.width := 600;
	self.height := 550;
	
	self.initAppStuff();
	
	inheritMethod();
	
	self.populateFormats();
	self.populateClasses();
	
	self.fldBaseCode.topSheet := self.shtExtract;

epilog

end;</source>
