    <JadeMethod name="requiresVentilation" id="6999fdf0-54fa-468e-a350-579b900b1efa">
        <source>requiresVentilation(): Boolean;
// ---------------------------------------------------------------------------
// Created:     05 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myOperator = null then
		return false;
	endif;
	
	if (not self.myOperator.requiresVentilation) then
		return false;
	endif;
	
	// If this is a Reefer and the commodity requres a temperature
	if (self.typeAttributes.bitAnd(ISO_REEFER) &lt;&gt; 0) and self.requiresTemperature then
		return true;
	endif;
	
	if (self.typeAttributes.bitAnd(ISO_FAN) &lt;&gt; 0) and self.requiresPower then
		return true;
	endif;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="revalidateISOType" id="0860d568-6c3b-4585-8c12-28c505520605">
        <updating/>
        <source>revalidateISOType(_passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			14 January 2002 by cnwdwq1
Purpose:			
//Wrapper method called on a TI to validate ISO type. We simply pass a call to
//changeISOtype, this looks after the update if it is required.
//This is called from the ISOTYPE table, whenever an iso type is required to
//be validated against ALL TI's for the type.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	tISO : String;
begin
	//-------------
  //Update the ISOType
	//-------------
	tISO := self.isoType;	//get current
	self.isoType := null;		//null out so we can check
	self.changeISOType(tISO, null, _passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
