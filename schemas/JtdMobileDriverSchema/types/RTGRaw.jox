        <source>rr002_VMRF_fldMain_click():Integer updating;

vars
	keyCode:Integer;
begin
	myVehicleMounted_RTGForm_1:=app.getForm('VehicleMounted_RTGForm').VehicleMounted_RTGForm;
	if unexpected(1, 'myVehicleMounted_RTGForm_1', '', 'FormNotNull', null, myVehicleMounted_RTGForm_1, null, method.qualifiedName) then return 1; endif;
	keyCode:=9;
	myVehicleMounted_RTGForm_1.tblJobs.keyUp(myVehicleMounted_RTGForm_1.tblJobs, keyCode, 0);
	app.doWindowEvents(shortPause);
	app.doWindowEvents(shortPause);
	myVehicleMounted_RTGForm_1.fldMain.click(myVehicleMounted_RTGForm_1.fldMain);  // Jobs - Lane 01  // 16:12:47
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
