    <PrimAttribute name="doValidateStops" id="4c2be6c1-8088-4b3b-b62b-780c4982f859">
        <embedded/>
        <type name="Boolean"/>
        <text>
Set to true in constructor.
This is normally true for updating a TI, but false for bulk editing where
validation of stops added/removed is done up front, not for each item - for
performance reasons.
see CM_TrackedItem.validateStops</text>
    </PrimAttribute>
