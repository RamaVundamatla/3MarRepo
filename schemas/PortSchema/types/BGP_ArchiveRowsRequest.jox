<Class name="BGP_ArchiveRowsRequest" id="bb50bcdd-c402-46ae-a7e1-a20423f6c52d">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Archive Rows&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="hoursAhead" id="a06980ce-557b-4011-a946-c1dc572225b0">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="terminalAreaType" id="a2418987-eaae-494c-a58c-628888074d4b">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="action" id="03997cbf-b9cf-4582-8a12-7ea6abb5f5e0">
        <updating/>
        <source>action(): Boolean updating;

// cnwdvb1 17 January 2003 
vars

	errCode		: Integer;
	errText		: String;
	errorSet	: CM_ErrorSet;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errText, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	if self.myTerminal = null then
		app.raiseCMException1(BackgroundErrorGeneral, app.getErrorString(UnableToArchiveRows), null, null);
		return true;
	endif;
	if app.myPassport &lt;&gt; null then
		app.myPassport.setMyTerminal(myTerminal);
	endif;
	create errorSet transient;
	myTerminal.archiveEmptyLocationsByType(self.terminalAreaType, self.hoursAhead, false, errorSet);
	if not errorSet.isEmpty then
		app.remoteErrorWarningToAlert(app.getErrorString(Background_Error_Right_Click), null, errorSet, null, true, true);
	endif;
	
epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errText, app.myPassport);
	else
		app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, app.getErrorString1(Successfully_Archived_Rows, self.myTerminal.code), false, false);
	endif;
	if errorSet &lt;&gt; null then
		errorSet.purge();
		delete errorSet;
	endif;
	inheritMethod();
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="592d1985-a301-4aa9-9bca-abaae636cac3">
        <source>getDisplay(): String;

// cnwdvb1 17 February 2003 

vars

	str, detail : String;

begin
	
	str := inheritMethod();
	detail := app.getErrorString2(Processing_Terminal, self.myTerminal.code, self.hoursAhead.String);
	return str &amp; Tab &amp; detail;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="f5992069-b833-4555-acc1-b2c66ba6227a">
        <updating/>
        <source>initRequestFromTask(_task : CM_AutoTaskArchiveRows) updating;

// cnwdvb1 17 January 2003 

vars

begin

	self.hoursAhead			:= _task.hoursAhead;
	self.terminalAreaType	:= _task.terminalAreaType;
	inheritMethod(_task);

end;</source>
        <Parameter name="_task" type="CM_AutoTaskArchiveRows"/>
    </JadeMethod>
</Class>
