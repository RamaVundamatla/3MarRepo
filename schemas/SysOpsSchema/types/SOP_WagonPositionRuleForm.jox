        <source>showWithObjectMode(_object: Object; _doMode: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwndl1	Initial creation

*/

vars

begin

	self.setMyRealWagonClass(_object.CM_WagonClass);
	if _doMode then
		self.editMode := self.ViewMode;
	endif;

epilog

end;</source>
