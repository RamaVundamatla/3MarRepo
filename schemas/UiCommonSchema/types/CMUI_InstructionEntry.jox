    <JadeMethod name="updateInstructionEntry" id="97b9c9a5-4de6-4968-b627-5c239fa21ce6">
        <updating/>
        <source>updateInstructionEntry()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
16 Dec 2022 navmv20  TFS ChangeRequest 55858 Task 55867 : EUP - Instruction code refactor
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
06 Nov 2023	navnk30	ChangeRequest 60933: EUP - Operational Instructions - CM_TrackedItem Inverse
*/

vars
	myInstruction : CM_InstructionType;
	instIssued,          //16/12/2022 navmv20 TFS CR 55858 Task 55867
	pxyInstructionIssued,
	realInstructionIssued: CM_InstructionsIssued;
	theReturn : Integer;
	internalInstruct,
	externalinstruct : String;
	pxyobj : CM_InstructionsIssued;
begin
	beginTransaction;
		//16/12/2022 navmv20 TFS CR 55858 Task 55867 - START
		/*if self.myObject.isKindOf(CM_PreNote) then
			pxyInstructionIssued := self.myObject.CM_PreNote.myInstructions.pxyCreateUpdateProxy();
		elseif self.myObject.isKindOf(CM_BookingRefItem) then
			pxyInstructionIssued := self.myObject.CM_BookingRefItem.myInstructions.pxyCreateUpdateProxy();
		elseif self.myObject.isKindOf(CM_BulkRelease) then
			pxyInstructionIssued := self.myObject.CM_BulkRelease.myInstructions.pxyCreateUpdateProxy();
		elseif self.myObject.isKindOf(CM_ReserveDetail) then
			pxyInstructionIssued := self.myObject.CM_ReserveDetail.myInstructions.pxyCreateUpdateProxy();
		elseif self.myObject.isKindOf(CM_BOL) then
			pxyInstructionIssued := self.myObject.CM_BOL.myInstructions.pxyCreateUpdateProxy();
		elseif self.myObject.isKindOf(CM_BOLDtl) then
			pxyInstructionIssued := self.myObject.CM_BOLDtl.myInstructions.pxyCreateUpdateProxy();
		elseif self.myObject.isKindOf(CM_WorkOrder) then
			pxyInstructionIssued := self.myObject.CM_WorkOrder.myInstructions.pxyCreateUpdateProxy();
		elseif self.myObject.isKindOf(CM_WorkOrderDtl) then
			pxyInstructionIssued := self.myObject.CM_WorkOrderDtl.myInstructions.pxyCreateUpdateProxy();
		elseif self.myObject.isKindOf(CM_ToDoTask) then
			pxyInstructionIssued := self.myObject.CM_ToDoTask.myInstructions.pxyCreateUpdateProxy();
		elseif self.myObject.isKindOf(CM_TrackedItem) then
			pxyInstructionIssued := self.myObject.CM_TrackedItem.myInstructions.pxyCreateUpdateProxy();
		endif;*/
		instIssued := self.myObject.getInstructions();
		if instIssued &lt;&gt; null then
			pxyInstructionIssued := instIssued.pxyCreateUpdateProxy();
		endif;
		//16/12/2022 navmv20 TFS CR 55858 Task 55867 - END
	commitTransaction;
	if self.txtExternalReference &lt;&gt; null then
		externalinstruct := self.txtExternalReference.text.String;
	endif;
	if self.txtInternalInstructions &lt;&gt; null then
		internalInstruct := self.txtInternalInstructions.text.String;
	endif;
	if self.cmbInstructions.listIndex &lt;&gt; -1 then
		myInstruction := self.cmbInstructions.itemObject[self.cmbInstructions.listIndex].CM_InstructionType;
	endif;
	
	pxyInstructionIssued.setProxy(internalInstruct,externalinstruct,myInstruction,pxyInstructionIssued.myParent);
	
	while true do
		app.myTrxUA.trxUpdateInstructionIssued(pxyInstructionIssued, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			/*beginTransaction;				//06.11.2023 navnk30 #60933
				realInstructionIssued := app.myProxyManager.getRealObject(pxyInstructionIssued).CM_InstructionsIssued;
				if self.myObject.isKindOf(CM_TrackedItem) then
					self.myObject.CM_TrackedItem.setmyInstructions(realInstructionIssued);
				endif;
			commitTransaction;
			*/
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Instructio_entry_created), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
	if self.myParentForm.isKindOf(CMUI_Instructions) then					//16.10.2023 navnk30 #59946
		self.causeEvent(CMUI_InstructionEntry.InstructionEntryUpdated, true, self.myObject);
	endif;
	self.unloadForm();
epilog
	delete pxyInstructionIssued;
end;</source>
    </JadeMethod>
    <JadeMethod name="updatePxyInstructions" id="e0be816a-84e4-4931-8c9b-959552219758">
        <source>updatePxyInstructions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2024	navnk30	ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial

*/

vars
	insType : CM_InstructionType;
	internalIns,
	externalIns : String;
begin
	if self.txtExternalReference &lt;&gt; null then
		externalIns := self.txtExternalReference.text;
	endif;
	if self.txtInternalInstructions &lt;&gt; null then
		internalIns := self.txtInternalInstructions.text;
	endif;
	if self.cmbInstructions.listIndex &lt;&gt; -1 then
		insType := self.cmbInstructions.itemObject[self.cmbInstructions.listIndex].CM_InstructionType;
	endif;
	self.myObject.getInstructions().setProxy(internalIns, externalIns, insType, self.myObject);
epilog

end;</source>
    </JadeMethod>
</GUIClass>
