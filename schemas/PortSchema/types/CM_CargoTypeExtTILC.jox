<Class name="CM_CargoTypeExtTILC" id="637def0f-8ae7-44b2-a11a-60342eeac7d4">
    <superclass name="CM_CargoTypeExtension"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allTILCTypes" id="2ef7108f-9943-4f3c-a8ee-f17c0dcee8ea">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_TILCTypeSet"/>
        <access>readonly</access>
        <Inverse name="CM_TILCType::myCargoTypeExtTILC"/>
    </ExplicitInverseRef>
    <PrimAttribute name="numControllers" id="2d8d8a4d-021f-4218-be73-10e7276613e6">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="buildLocationControllers" id="6eaa41b6-588d-46a0-aca3-447fddaa3f1d">
        <source>buildLocationControllers(_ti : CM_TILC input; _numOfController : Integer; _typeOfController : Class) protected;
// -------------------------------------------
// Created 24 November 2005 by cnwdvb1
// -------------------------------------------
vars

	lc		: CM_TILCController;
	count	: Integer;

begin

	foreach count in 1 to _numOfController do
		create lc as _typeOfController persistent;
		lc.setMYTILC(_ti);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TILC" usage="input"/>
        <Parameter name="_numOfController" type="Integer"/>
        <Parameter name="_typeOfController" type="Class"/>
    </JadeMethod>
    <JadeMethod name="createTILCType" id="bc47fa0c-90e0-4312-bb14-2366c0e13742">
        <source>createTILCType() : CM_TILCType;
// -------------------------------------------
// Created 06 December 2005 by cnwdvb1
// -------------------------------------------
vars

	type	: CM_TILCType;

begin

	create type transient;
	
	type.setCargoExtension(self);
	
	type.updateAttributeOfType(CM_TILCType.Type_NumLocationControllers, self.numControllers);	
	
	return type;


end;</source>
        <ReturnType type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="getExtraDetailForType" id="96400e4f-6555-412f-a035-ef955907c7ad">
        <source>getExtraDetailForType(_allData: StringArray input; _type	: CM_TILCType);
// -------------------------------------------
// Created 07 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	_allData.add(app.getErrorString(Description) &amp; Tab &amp; _type.description);
	_allData.add(app.getErrorString(Colour) &amp; Tab &amp; _type.colour.String);
	

end;</source>
        <Parameter name="_allData" type="StringArray" usage="input"/>
        <Parameter name="_type" type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f89a587d-b299-4359-94b4-2f1d527df6f7">
        <updating/>
        <source>setForCreate(_pxyExtension: CM_CargoTypeExtTILC; _realCargoType: CM_CargoType) updating;
// -------------------------------------------
// Created 08 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.numControllers	:= _pxyExtension.numControllers;
	inheritMethod(_pxyExtension, _realCargoType);



end;</source>
        <Parameter name="_pxyExtension" type="CM_CargoTypeExtTILC"/>
        <Parameter name="_realCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromCMIF" id="c5739943-bbaa-4cf7-8d94-c01cca2ef785">
        <updating/>
        <source>setProxyFromCMIF(_cmif: CMIF_CargoTypeExt) updating;
// -------------------------------------------
// Created 07 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_cmif);
	self.numControllers	:= _cmif.numberOfLocationControllers;


end;</source>
        <Parameter name="_cmif" type="CMIF_CargoTypeExt"/>
    </JadeMethod>
    <JadeMethod name="setPxyTypeFromCMIF" id="d64c3d09-d04f-4efa-ad7b-629e6fb1e1a0">
        <updating/>
        <source>setPxyTypeFromCMIF(_type : CM_TILCType input; _cmif : CMIF_CargoTypeExt) updating;
// -------------------------------------------
// Created 08 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	_type.updateAttributeOfType(CM_TILCType.Type_Description, _cmif.description);
	_type.updateAttributeOfType(CM_TILCType.Type_NumLocationControllers, _cmif.numberOfLocationControllers);
	_type.updateAttributeOfType(CM_TILCType.Type_Colour, _cmif.colour);


end;</source>
        <Parameter name="_type" type="CM_TILCType" usage="input"/>
        <Parameter name="_cmif" type="CMIF_CargoTypeExt"/>
    </JadeMethod>
    <JadeMethod name="setTrackedItemDtl" id="02a3096d-7933-4d9c-88c5-42839af461e3">
        <source>setTrackedItemDtl(_ti: CM_TrackedItem input; _type: CM_TILCType);
// -------------------------------------------
// Created 12 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	_ti.CM_TILC.setMyType(_type);
	inheritMethod(_ti, _type);
	


end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_type" type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="413fc70d-cebf-4103-ac5e-bcc24fc6cf01">
        <source>validateForDelete();
// -------------------------------------------
// Created 12 December 2005 by cnwdvb1
// -------------------------------------------
vars

	cargoType	: Integer;
	tiMaster	: CM_TIMaster;
	root		: CM_Root;

begin

	inheritMethod();
	
	cargoType := self.myCargoType.id;
	
	root := app.myRoot;
	
	foreach tiMaster in root.allTiMasters discreteLock do
		if tiMaster.cargoType = cargoType then
			app.raiseCMException2(ObjectStillHasEntries, self.myCargoType.description, "Master Item", null, null);
		endif;
	endforeach;
	
	if not self.allTILCTypes.isEmpty() then
		app.raiseCMException2(ObjectStillHasEntries, self.myCargoType.description, "Type", null, null);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
