    <JadeMethod name="clickBtnCargo" id="fef18b6a-7a02-4e4a-a832-6c701de0bbf8">
        <updating/>
        <source>clickBtnCargo( _btn : Button ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	ti : CM_TrackedItem;
	
begin

	app.mousePointer :=	Busy;

	ti := _btn.userObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;

	self.myMobileGenericAgent.setMyCurrentWagon(cmbWagon.listObject.CM_Wagon);
	self.myMobileGenericAgent.setMyLocationsController(ti.myPrimaryActualLocation);
	self.myMobileGenericAgent.setMyNextTiToAction(ti);

	self.gotoForm( MOB_HHRailPlaceCargo, false );

epilog

	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="_btn" type="Button"/>
    </JadeMethod>
