    <JadeMethod name="setObjectString" id="814d6c14-8d45-4f4a-b4d2-f00f75b55d57">
        <source>setObjectString(_toDoTasks : Cm_ToDoTaskSet);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 December 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
15 Jul 2024	navbs1	CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client

*/

vars
	str 		: String;
	wod			: CM_WorkOrderToDoDtl;
begin
	self.tblCargo.visible:=false;	//15.07.2024  navbs1  CR 64901 Task 64903
	self.txtTop.visible:=true;		//15.07.2024  navbs1  CR 64901 Task 64903
	if _toDoTasks.first.isKindOf(CM_TrainToDoTask) then
		str := "Trains: ";
		wod := _toDoTasks.first.myWODetailToDo;
		str := str &amp; wod.CM_WodToDoTrain.allTrainsActioned.listString(Comma,CM_Train::code.name);
	elseif _toDoTasks.first.isKindOf(CM_VBSToDoTask) then
		str := "Vehicle Bookings: ";
		wod := _toDoTasks.first.myWODetailToDo;
		str := str &amp; wod.CM_WodToDoVBS.allVBSSlotsActioned.listString(Comma,CM_VehicleBookingTimeSlot::id.name);
	elseif _toDoTasks.first.isKindOf(CM_NonOpsToDoTask) then
		str := "Debtors: ";
		wod := _toDoTasks.first.myWODetailToDo;
		str := str &amp; wod.CM_WodToDoNonOperational.allDebtorsActioned.listString(Comma,CM_Debtor::name.name);
	elseif _toDoTasks.first.isKindOf(CM_WagonToDoTask) then
		str := "Wagons: ";
		wod := _toDoTasks.first.myWODetailToDo;
		str := str &amp; wod.CM_WodToDoWagon.allWagonsActioned.listString(Comma,CM_Wagon::id.name);
	elseif _toDoTasks.first.isKindOf(CM_VoyageToDoTask) then
		str := "Voyages: ";
		wod := _toDoTasks.first.myWODetailToDo;
		str := str &amp; wod.CM_WodToDoVoyage.allVoyagesActioned.listString(Comma,CM_Voyage::code.name);
	elseif _toDoTasks.first.isKindOf(CM_VehicleVisitRecordToDoTask) then
		str := "Vehicle Visits: ";
		wod := _toDoTasks.first.myWODetailToDo;
		str := str &amp; wod.CM_WodToDoVehicleVisit.allVehiclesActioned.listString(Comma,CM_VehicleVisitRecord::visitNumber.name);
	endif;

	self.txtTop.text := "Work Order: " &amp; wod.myParent.id &amp; CrLf &amp; str;
epilog

end;</source>
        <Parameter name="_toDoTasks" type="Cm_ToDoTaskSet"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="2bc3d970-5aec-4ab8-bde9-fe627a0cff07">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Jul 2024	navbs1	CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client
*/

vars
	
begin
	self.defTblCargo:=tblCargo.getXmlStrForColumns(true);
	if _theTable = self.tblCargo then
		self.setTblCargo();
	endif;
epilog
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblCargo" id="d61c51ff-6702-47fa-b958-c19b6fc29d17">
        <source>setTblCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Jul 2024	navbs1	CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client
*/

vars
	entTableDef		: EntTableDef;
	ti				:CM_TrackedItem;
	dataLine		:String;
	tbl 			:CM_DataTable;
begin
	self.txtTop.visible:=false;
	self.tblCargo.visible:=true;
	
	tbl:=self.tblCargo;
	tbl.userInputEnabled := false;
	tbl.selectMode := CM_EntryTable.SelectMode_FixedRow;
	tbl.selectionType  := CM_EntryTable.SelectionType_Row;
	tbl.fixedRows := 1;
	tbl.rows := 1;
	
	entTableDef 		:= app.myController.getEntTableDef(ETDef_LlHeadings);
	if entTableDef &lt;&gt; null then
		tbl.setTblDataEntRowsFromXML(entTableDef, self.defTblCargo);	
	endif;
	
	if self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS then
		dataLine := self.myTrackedItem.getAttributeStringForDefArray(self.tblCargo.allTblDataEntRows);
		tbl.accessRow(tbl.addItem(dataLine)).itemObject := self.myTrackedItem;
		
	else
		foreach ti in  self.allTrackedItems do			
			if tbl.rows &gt;= JadeTableRowLimit then
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
						JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			dataLine := ti.getAttributeStringForDefArray(self.tblCargo.allTblDataEntRows);
			tbl.accessRow(tbl.addItem(dataLine)).itemObject := ti;
		endforeach;
	endif;
	

epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="setToDoTasks" id="186177ab-0484-4e18-a5e9-27c72ed886d8">
        <updating/>
        <source>setToDoTasks(_allToDoTasks : Cm_ToDoTaskSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 December 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
17 Mar 2023			navhl20	Defect 57175: MTN - 1090 exception on the Complete ToDo Tasks form when clicking on the Instructions button
*/

vars
	control				: Control;	
	table				: CM_DataTable;
	row					: Integer;
	minHeight,
	colWidth,
	textHeight			: Integer;
	addCol,
	remarksCol,
	col					: Integer;
	sortKey				: Integer;
	allToDoTasksDesc 	: CM_ToDoTaskDescByCode;
	taskDesc 			: CM_ToDoTaskDesc;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
	task 				: CM_ToDoTask;
	itemEnabled 		: Boolean;
	user				: CM_User;
	gotException		: Boolean;
begin	
	// Setup the table
	self.mode := self.TODO_TASK;

	passport 			:= app.myPassport;
	user				:= passport.myUser;
	terminal			:= self.myTerminal;
	table				:= self.tblTasksAdd;
	self.btnInstruction.visible	:= false;		//17.3.2023 navhl20	#57175			

	self.initTasksTable(table);
	
	table.rows	:= table.fixedRows;
	col := table.getColumnByRowName (ETRow_Add);
	addCol := col;
	remarksCol := table.getColumnByRowName (ETRow_Remarks);
	
	table.hideColumnByColName(ETRow_Instruction);
	
	if col &lt;&gt; 0 then
		table.accessCell(1, col).text := app.getErrorString(Complete);
	endif;
	
	// Add the todo tasks if the same type has not already been added
	create allToDoTasksDesc transient;
	
	foreach task in _allToDoTasks do
		if not allToDoTasksDesc.includes(task.toDoTaskDesc) then
			allToDoTasksDesc.add(task.toDoTaskDesc);
			row := table.addItemObject (task.toDoTaskDesc, "");		// add this task description entry with blank details
			table.setCellValueByName (ETRow_Description, row, task.toDoTaskDescDesc);
			table.accessCell (row, remarksCol).wordWrap := true;
			minHeight := 18;						// standard row height
			colWidth := table.accessColumn(remarksCol).width;
			textHeight := self.getTextHeightForWidth(task.remarks, colWidth) + 4;	// margins of 2 top and bottom
			if textHeight &lt; minHeight then
				textHeight := minHeight;						// standard row height
			endif;
			table.rowHeight[row] := textHeight;			// room for actual remarks
			table.setCellValueByName (ETRow_Remarks, row, task.remarks);
			if task.myInstructions &lt;&gt; null then	
				table.setCellValueByName (ETRow_Instruction.formatWithEllipsis(1,100,true), row,task.myInstructions.internalInstructions &amp;" "&amp; task.myInstructions.externalInstruction);//28.10.2022 navtnr20 TFS 54967
			endif;	
			sortKey := 0;
			if task.toDoTaskDesc &lt;&gt; null then
				sortKey := task.toDoTaskDesc.sortKey;
			endif;
			table.setCellValueByName (ETRow_SortKey, row, sortKey.padLeadingWith('0', 6));
		endif;
	endforeach;
	
	// sort in sort key then description order, so that if sort keys are not used or are not unique then the description is used as well
	col := table.getColumnByRowName (ETRow_SortKey);
	if col &lt;&gt; null then
		table.sortColumn [1] := col;
	endif;
	col := table.getColumnByRowName (ETRow_Description);
	if col &lt;&gt; null then
		table.sortColumn [2] := col;
	endif;
	table.resort;
epilog
	delete allToDoTasksDesc;
end;</source>
        <Parameter name="_allToDoTasks" type="Cm_ToDoTaskSet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e03ba471-f4b7-4461-aac5-485e45983187">
        <updating/>
        <source>setupForm() updating;
//10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
//13 Dec 2022 navcs2   ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
//15 Jul 2024 navbs1   CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client
vars
	
	ti :CM_TrackedItem;
begin
	inheritMethod();
	
	ti := self.myTrackedItem;
	if ti = null then
		if self.allTrackedItems.isEmpty then
			self.caption := "Complete To Do Tasks";								//13 Dec 2022 navcs2   #56691:[56120] 
			self.grpBottom.caption := app.getErrorString(Task_to_Complete);		//13 Dec 2022 navcs2   #56691:[56120]
			return;																//13 Dec 2022 navcs2   #56691:[56120]
		else
			self.myTrackedItem := self.allTrackedItems.first;
			ti := self.myTrackedItem;
		endif;		
	endif;
	
	// make sure we have the selected TI in our coll
	self.allTrackedItems.addNoDuplicates (ti, false);
	
	if self.left &lt; app.mainForm.left then
		self.left := app.mainForm.left + self.left;
	endif;
	if self.top &lt; app.mainForm.top then
		self.top := app.mainForm.top + self.top;
	endif; 
	
	
	if app.getApplicationSkin &lt;&gt; null then
		self.jdbTop.ignoreSkin	 	:= true;
		self.jdbBottom.ignoreSkin	:= true;
	endif;
	
	self.initTasksTable (self.tblTasksAdd);
	
	if not self.canUpdate then
		self.btnSave.enabled			:= false;
		self.btnSaveAndClose.enabled	:= false;	
	endif;
	
	self.modalResult := IDCANCEL;
	self.loadTasks (ti);
	//self.listCargo();		//15.07.2024  navbs1  CR 64901 Task 64903
	self.setTblCargo();		//15.07.2024  navbs1  CR 64901 Task 64903
	
	self.setCaption (ti.id);

	self.beginNotification (ti, Object_Update_Event, Response_Continuous, null);
	self.beginNotification (ti, Object_Delete_Event, Response_Continuous, null);
	//Start 17.10.2022 navtnr20 TFS 54967
	if self.mode = CM_ContainerEnqForm.TASK_MODE_INSTRUCTION then
		self.btnInstruction.enabled := false;
	else
		self.btnInstruction.visible := false;
	endif;
	// End 17.10.2022 navtnr20 TFS 54967
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="648ff71e-35ab-4434-811f-234e0e9bd8d5">
