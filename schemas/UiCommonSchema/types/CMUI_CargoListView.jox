    <JadeMethod name="setupForm" id="90ddad19-cd15-4365-82cf-380075a01670">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"
16 Apr 2025 navnk30	JIRA 34545: EUP | Cargo List View screen - ISO Type field shows for non-containerized cargo
12 May 2025	navnk30 JIRA 34841: Total items displayed was not shown in Cargo List View form

*/

vars

begin
	inheritMethod();
	
	self.initTblData();
	//self.myThumbDef := app.myController.getEntTableDef(ETDef_CargoQuickViewThumb);	//16.04.2025 navnk30 JIRA 34545
	self.myThumbDef := app.myController.getEntTableDef(ETDef_CargoListViewThumb);		//16.04.2025 navnk30 JIRA 34545
	self.allowSearch := true;
	self.tblThumb.scrollBars := ScrollBars_None;
	//self.staMain.visible := true;														//12.05.2025 navnk30 JIRA 34841
	self.showDataOnStartup := true;														//12.05.2025 navnk30 JIRA 34841
	self.useNumRowsShown := true;
	self.btnNewTV.enabled:= false;
	self.btnEditTV.enabled := false;
	self.btnDeleteTV.enabled:= false;
	self.btnCancelBase.visible := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="84e3f5df-86da-4688-9d92-a0b7fe8918eb">
        <updating/>
        <source>showThumbnailData(_ti: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"
16 Apr 2025 navnk30	JIRA 34545: EUP | Cargo List View screen - ISO Type field shows for non-containerized cargo

*/
constants
	Product_Row_Pos		: Integer = 3;
	ISO_Type_Row_Pos	: Integer = 4;
vars
	str,
	dataStr		: String;
	count,
	i,
	rowIdx,
	dataSize,
	rowHeight	: Integer;
	invalidTI	: Boolean;
	
begin

	self.tblThumb.rows := 0;

	self.allHeadings.clear;
	self.allDetails.clear;

	if _ti = null or not CM_TrackedItem.hasInstance(_ti) then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _ti, invalidTI);
	
	self.myCurrentObject := _ti;
	
	_ti.CM_TrackedItem.getDataForDef(self.myThumbDef, self.allHeadings, self.allDetails, self.myTerminal);

	if invalidTI then
		return;
	endif;
	
	dataSize := self.allDetails.size;
	foreach str in self.allHeadings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		dataStr := self.allDetails[i];
		rowIdx := self.tblThumb.addItem(str &amp; Tab &amp; dataStr);
		
		count := dataStr.countOccurrences(Cr);
		if count &gt; 0 then
			rowHeight := self.tblThumb.accessRow(rowIdx).height;
			self.tblThumb.accessedRow.height := rowHeight * (count+1);
		endif;
	endforeach;
	
	if self.allHeadings.isEmpty() then			//16.04.2025 navnk30 JIRA 34545
		return;
	endif;
	if _ti.CM_TrackedItem.isContainer() then	//16.04.2025 navnk30 JIRA 34545
		self.tblThumb.hideRowFromHeading(self.allHeadings[Product_Row_Pos]);
	else
		self.tblThumb.hideRowFromHeading(self.allHeadings[ISO_Type_Row_Pos]);
	endif;
	self.tblThumb.fitTableHeight();
end;</source>
        <Parameter name="_ti" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="22274810-e9c0-45b6-8201-fc1c8ef61d6e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 17 March 2025 09:27:23.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0027039, locale);
end;</source>
    </JadeMethod>
</GUIClass>
