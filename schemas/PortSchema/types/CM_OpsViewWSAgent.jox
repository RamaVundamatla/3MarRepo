        <ReturnType type="CMIF_OpsViewTablesArray"/>
    </JadeMethod>
    <JadeMethod name="setupVesselForActivity" id="e3d91830-0470-40cd-b973-b22c4b656a1c">
        <source>setupVesselForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
*/

vars
	vslVesslsCmif		 	: CMIF_VslVessels;
	vslVesselClassesCmif	: CMIF_VslVesselClasses;					// navra1 - 8th Sep 2022 - TFS53105
	data                   	: Any;
begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
	endif;
	
	create vslVesselClassesCmif transient;								// navra1 - 8th Sep 2022 - TFS53105
	vslVesselClassesCmif.initializeForActivity(data,_ewsOpsView);		// navra1 - 8th Sep 2022 - TFS53105
	
	create vslVesslsCmif transient;
	vslVesslsCmif.initializeForActivity(data,_ewsOpsView);	

	_cmifArray.add(vslVesselClassesCmif);								// navra1 - 8th Sep 2022 - TFS53105
	_cmifArray.add(vslVesslsCmif);
	return _cmifArray;
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <ReturnType type="CMIF_OpsViewTablesArray"/>
    </JadeMethod>
    <JadeMethod name="setupVoyageForActivity" id="600d903c-87a4-437d-950e-e7eaf6762b65">
        <source>setupVoyageForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
*/


vars
	carrierVisitCmif    	: CMIF_ArgoCarrierVisit;
	vslVesselsCmif          : CMIF_VslVessels;
	data                    : Any;
begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
	endif;
	
	create carrierVisitCmif transient;
	carrierVisitCmif.initializeForActivityPrefix(data,_ewsOpsView, "");
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_UPDATE then
		create vslVesselsCmif transient;
		vslVesselsCmif.initializeForActivity(data,_ewsOpsView);
		_cmifArray.add(vslVesselsCmif);
	endif;
	
	_cmifArray.add(carrierVisitCmif);
	
	return _cmifArray;
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <ReturnType type="CMIF_OpsViewTablesArray"/>
    </JadeMethod>
    <JadeMethod name="setupWagonClassForActivity" id="3b136fd2-77c3-43a2-8640-151e1680fd80">
        <source>setupWagonClassForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;


 // ### TFS 52914 04MAR2022 NAVAB1 - NOT USED CURRENTLY





/*
Purpose:	

Date		Who		Reason
14 December 2021	navab1	TFS 51855
*/

vars
/*
	wagonClass : CMIF_RailCars;
	wagonWell : CMIF_RailCarPlatforms; // ### TFS 52914 04MAR2022 NAVAB1 - Manoj says not to bother sending these
	data : Any; // CM_WagonClass
	wclass : CM_WagonClass;
	wwell : CM_WagonWellDefinition;
*/
begin
/*  // ### TFS 53569 12MAY2022 NAVAB1 WAGON CLASS IS NOT NEEDED IN OPSVIEW
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
		wclass := data.CM_WagonClass;
	endif;


	create wagonClass transient;
	wagonClass.initializeForActivity(data,_ewsOpsView);	
	_cmifArray.add(wagonClass);
	
	if wclass &lt;&gt; null
	and wclass.allWagonWellDefArray.isNotEmpty() then
		foreach wwell in wclass.allWagonWellDefArray discreteLock do
			create wagonWell transient;
			wagonWell.initializeForActivity(data,_ewsOpsView);	
			_cmifArray.add(wagonWell);
		endforeach;
	endif;
	
	*/
	return _cmifArray;


epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <ReturnType type="CMIF_OpsViewTablesArray"/>
    </JadeMethod>
    <JadeMethod name="setupWagonForActivity" id="a6e06a7d-4eeb-4e9c-ab9f-b84db6a7ecc6">
        <source>setupWagonForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:	N4 and MTN have 1 record per wagon visit

Date		Who		Reason
14 December 2021	navab1	TFS 51855
*/

vars
	opsviewData : CMIF_RailCarVisits;
	wagonFleet : CMIF_RailCars;
	data : Any; // CM_Wagon

begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
	endif;

	create opsviewData transient;
	opsviewData.initializeForActivity(data,_ewsOpsView);	
	_cmifArray.add(opsviewData);


	create wagonFleet transient; // ### TFS 53938 21JUN2022 NAVAB1
	wagonFleet.initializeForActivity(data,_ewsOpsView);	 // ### TFS 53938 21JUN2022 NAVAB1
	_cmifArray.add(wagonFleet); // ### TFS 53938 21JUN2022 NAVAB1
	
	return _cmifArray;


epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <ReturnType type="CMIF_OpsViewTablesArray"/>
    </JadeMethod>
    <JadeMethod name="setupWleForActivity" id="10daea9e-17a3-405a-8858-94bdc1ff5e4e">
        <source>setupWleForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
21FEB2022	NAVAB1	TFS 52925 removed TI data, TI data is a seperate message type now
*/

vars
	invWiCmif	   	: CMIF_InvWi;
	
	roadTruckCmif : CMIF_RoadTruckTransactions;
	data            : Any;
	isRoadJob : Boolean;
	opsviewyrdvisit : CMIF_InvUnitYrdVisit;
begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;

		if data.isKindOf(CM_YardWLE)
		and data.CM_YardWLE.isRoad then
			isRoadJob := true;
		endif;
	endif;

	
	create invWiCmif transient;
	invWiCmif.initializeForActivity(data,_ewsOpsView);
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		invWiCmif.initializeForDelete(_ewsOpsView.myOpsviewObject,_ewsOpsView);
	endif;
	_cmifArray.add(invWiCmif);

	
	 // ### TFS 51853 26AUG2021 NAVAB1 
	 if isRoadJob then
		create roadTruckCmif transient;
		roadTruckCmif.initializeForActivity(data,_ewsOpsView);
		_cmifArray.add(roadTruckCmif);
	endif;

	
	create opsviewyrdvisit transient;
	opsviewyrdvisit.initializeForActivity(data,_ewsOpsView);
	_cmifArray.add(opsviewyrdvisit);
	
	
	return _cmifArray;
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <ReturnType type="CMIF_OpsViewTablesArray"/>
    </JadeMethod>
</Class>
