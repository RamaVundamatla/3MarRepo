    <JadeMethod name="importFromXMLDocReference" id="f3474e9d-0643-41a6-96f2-f4620c4108b9">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwer1	Initial creation

*/

vars
	pxyDeckLayout 		: CM_DeckLayout;
	allDeckItemElements : JadeXMLElementArray;
	deckItemElement 	: JadeXMLElement;
	ramp				: CM_RORORampInternal;
	machinery 			: CM_ROROEquipment;
	lift 				: CM_ROROLift;
	genItem				: CM_ROROGeneralArea;
	
begin
	if _property = CM_Deck::myDeckLayout then
		create pxyDeckLayout transient;
		pxyDeckLayout.setMyDeck(self);
		pxyDeckLayout.importFromXMLDoc(_xmlElement);
		
		
	elseif _property = CM_Deck::allRamps then
		create allDeckItemElements transient;
		_xmlElement.getAllElementsByTagName(CM_RORORampInternal.name,allDeckItemElements);
	
		foreach deckItemElement in allDeckItemElements do
			create ramp transient;
			ramp.setMyDeck(self);
			ramp.importFromXMLDoc(deckItemElement);
			
		endforeach;
		
	elseif _property = CM_Deck::allMachinery then
		create allDeckItemElements transient;
		_xmlElement.getAllElementsByTagName(CM_ROROEquipment.name,allDeckItemElements);
	
		foreach deckItemElement in allDeckItemElements do
			create machinery transient;
			machinery.setMyDeck(self);
			machinery.importFromXMLDoc(deckItemElement);
			
		endforeach;
		
	elseif _property = CM_Deck::allGeneralItems then
		create allDeckItemElements transient;
		_xmlElement.getAllElementsByTagName(CM_ROROGeneralArea.name,allDeckItemElements);
	
		foreach deckItemElement in allDeckItemElements do
			create genItem transient;
			genItem.setMyDeck(self);
			genItem.importFromXMLDoc(deckItemElement);
			
		endforeach;
		
	elseif _property = CM_Deck::allLifts then
		create allDeckItemElements transient;
		_xmlElement.getAllElementsByTagName(CM_ROROLift.name,allDeckItemElements);
	
		foreach deckItemElement in allDeckItemElements do
			create lift transient;
			lift.setMyDeck(self);
			lift.importFromXMLDoc(deckItemElement);
		endforeach;
	endif;

epilog
	delete allDeckItemElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initLayout" id="50a84ef6-172b-479c-9209-f2e3c2b66e89">
        <source>initLayout(_proxyDeck : CM_Deck);
/*---------------------------------------------------------------------------
// Created:     March 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
 
17 May 2011 	cnwer1		Par 27519 had to stop the copy also calling this method	
// ---------------------------------------------------------------------------*/

vars
	pxyItemLayout, realItemLayout: CM_DeckItemLayout;
	pxyDeck, aDeck : CM_DeckLayout;
	pxyLayer, aLayer : CM_DeckLayerLayout;
begin
	if self.isTransient then
		return;
	endif;
	
	if self.myDeckLayout &lt;&gt; null then
		return;
	endif;
	
	// ### DECK
	create  pxyDeck transient;	
	pxyDeck.setProxy(_proxyDeck.code, _proxyDeck.description, null, self);//cnwas3 par 27498
	app.myUtilityCA.utlCreateDeckLayout(pxyDeck, aDeck, app.myPassport); 

	// ### LAYER
	create pxyLayer transient;
	pxyLayer.setProxy(app.getErrorString(Layer) &amp; " 1", app.getErrorString(Layer) &amp; " " &amp; app.getErrorString(One), null, aDeck, true,ROROLayerType_Structure);
	app.myUtilityCA.utlCreateDeckLayerLayout(pxyLayer, aLayer, false, app.myPassport);  // PAR 28330
	
	// ### BASIC GRAPHIC
	pxyLayer.setProxyNewItem();
	pxyItemLayout := pxyLayer.allDeckItemLayouts.first;
	pxyItemLayout.setMyDeckLayer(aLayer);
	app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, app.myPassport); 

	
epilog
	delete pxyDeck;
	delete pxyLayer;
	delete 	pxyItemLayout;
end;</source>
