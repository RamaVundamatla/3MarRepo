    <JadeMethod name="validateForCreateSubClasses" id="a3eadd7b-bc84-462f-80d3-11d6a55fe9c7">
        <updating/>
        <source>validateForCreateSubClasses(_passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

end;</source>
