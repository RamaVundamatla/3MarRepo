        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="focusColor" id="59217f59-904c-474f-86fb-5ff530f9a9dc">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="isFocusColorUsed" id="6beaec27-5b6d-491f-b08f-8539440bc070">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isRequired" id="a8d8abdf-faed-4e2f-b11c-bd54ae98e46e">
