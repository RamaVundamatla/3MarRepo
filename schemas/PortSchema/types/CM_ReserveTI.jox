	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShortDescription" id="5fa81ed0-df53-4e13-8439-b73aa37b63c7">
        <source>getShortDescription(): String;
/*

Date		Who		Reason
24 September 2014	cnwer1	Initial creation PAR 34935

*/

vars

	ti			: CM_TrackedItem;
	str			: String;
begin
	
	ti := getTI();
	
	if ti = null then
		if app.isSpecial and app.isDevelopmentSystem then
			app.raiseUnexpectedProgramError(class.name, method.name, self.String &amp; ' has an allTrackedItems size of &gt; 1');
		endif;
		
		return 'No item assigned';
	endif;


	return self.getTotalRequestedDisplay &amp; ' x ' &amp; ti.cargoTypeDescr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStwHHCmbDetails37200" id="e596540e-54aa-4ef4-8367-d5fd839309eb">
        <source>getStwHHCmbDetails37200(_defColour : Integer; _colour : Integer output ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2018	jlgndl1	Initial creation	TFS 38083 / 37200

*/

vars

	cargoGroupId : String;
	cargoId : String;
	retStr : String;
	workStr : String;
	lc : CM_LocationsController;
	isForBulk : Boolean;
	weightRequested : Decimal [16,4];
	weightReleased : Decimal [16,4];
	weightUnit : String;
	volumeUnit : String;
	unit : String;
	density : Decimal [16,4];
	qtyRequested : Integer;
	qtyReleased : Integer;
	qtyStaged : Integer;
	
	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	
	delReq : CM_Request;
	qtyActioned : Integer;
	weightActioned : Decimal [16,4];
	volumeActioned : Decimal [16,4];
	weightActionedString : String;
	
	qtyOutstanding : Integer;
	weightOutstanding : Decimal [16,4];
	weightOutstandingString : String;

begin

	ti := self.getTI;
	if ti = null then
		return null;
	endif;
	
	cargoType := ti.myCargoType;
	
	if cargoType &lt;&gt; null then
		isForBulk := cargoType.isBulkMulti;
		workStr := cargoType.abbreviation;
		if self.getProductCode &lt;&gt; null then
			workStr := workStr &amp; " / " &amp; self.getProductCode;
		endif;
		if workStr &lt;&gt; null then
			retStr := workStr;
			workStr := null;
		endif;
	endif;
	
	retStr := self.getTotalRequestedDisplay &amp; " x " &amp; retStr;	//	20 Feb 2017	NDL	TFS 3476
	
	cargoGroupId := ti.getMyCargoGroupId;
	if cargoGroupId = null then
		cargoId := ti.id;
	endif;
	
	if cargoGroupId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoGroupId;
	elseif cargoId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoId;
	endif;
	
	//Quotes from TFS 38083 from Tomek in the Discussion section
	//- By 'No. of items actioned', we mean how many items of a Release Item are currently being actioned
	// at the Terminal = being requested to load or loaded on a Truck, or packed in a Container.
	foreach delReq in self.myReserveHeader.allRequestsBeingActioned do
		if delReq.isKindOf(CM_DeliveryRequest) then
			if delReq.myReserveDetail = self then
				if isForBulk then
					weightActioned := weightActioned + delReq.CM_DeliveryRequest.weightRequested;
				else
					qtyActioned := qtyActioned + delReq.CM_DeliveryRequest.totalRequested;
				endif;
			endif;
		endif;
	endforeach;
	
	retStr := retStr &amp; ",";	//06 Mar 2017	NDL	TFS 3477
	
	_colour := _defColour; // default colour for background
	
	if isForBulk then
		weightReleased := self.getWeightReleased();
		weightRequested := ti.totalWeight;
		weightOutstanding := weightRequested - ( weightReleased + weightActioned );
		
		if cargoType.isBulkByVolume then
			if cargoType &lt;&gt; null and cargoType.myVolumeMeasurementType &lt;&gt; null then
				volumeUnit := cargoType.myVolumeMeasurementType.shortName;
				unit := volumeUnit;
			endif;
			density := self.getDensity;
			volumeActioned := weightActioned / density;
			if volumeActioned = 0 then
				weightActionedString := "0";
			elseif volumeUnit &lt;&gt; null then
				weightActionedString := app.convertMeasurementForDisplay( volumeUnit, volumeActioned );
			else
				weightActionedString := weightActioned.Integer.String &amp; " " &amp; volumeUnit;
			endif;
		else
			if cargoType &lt;&gt; null and cargoType.myWeightMeasurementType &lt;&gt; null then
				weightUnit := cargoType.myWeightMeasurementType.shortName;
				unit := weightUnit;
			endif;
			if weightActioned = 0 then
				weightActionedString := "0";
			elseif weightUnit &lt;&gt; null then
				weightActionedString := app.convertMeasurementForDisplay( weightUnit, weightActioned );
			else
				weightActionedString := weightActioned.Integer.String &amp; " " &amp; weightUnit;
			endif;
		endif;
		
		retStr := retStr &amp; ", (" &amp; weightActionedString &amp; " " &amp; unit &amp; " " &amp; app.getErrorString(Actioned) &amp; ")";
		retStr := retStr &amp; " (" &amp; weightOutstandingString &amp; " " &amp; app.getErrorString(Outstanding)&amp; ")";
		
		if weightRequested = weightReleased then
			_colour := Red;
		elseif weightActioned &gt; 0 and weightActioned &lt;= weightRequested then
			_colour := LightBlue;	
		endif;
		
	else
		qtyRequested := self.getTotalRequested;
		qtyReleased := self.getTotalReleased;
		qtyOutstanding := qtyRequested - ( qtyReleased + qtyActioned );
		
		retStr := retStr &amp; ", (" &amp; qtyActioned.String &amp; " " &amp; app.getErrorString(Actioned)&amp; ")";
		retStr := retStr &amp; " (" &amp; qtyOutstanding.String &amp; " " &amp; app.getErrorString(Outstanding)&amp; ")";
		
		if qtyRequested = qtyReleased then
			_colour := Red;
		elseif qtyActioned &gt; 0 and qtyActioned &lt;= qtyRequested then
			_colour := LightBlue;	
		endif;
		
	endif;
	
	//15 Jan 2019	NDL	TFS 42906
	//count of released
	if not self.myReserveHeader.isPackingType then
		retStr := retStr &amp; " (" &amp; self.getTotalReleasedDisplay() &amp; " "&amp; app.getErrorString(ReleasedStr) &amp; ")";
	endif;
	
	return retStr;

epilog

end;</source>
        <Parameter name="_defColour" type="Integer"/>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStwHandHeldCmbDetails" id="0e5b1839-0026-4d73-b73d-e2e31af81356">
        <source>getStwHandHeldCmbDetails( _changeColour : Boolean output ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2016	cnwndl1	Initial creation	TFS	3037/2369

*/

vars

	cargoGroupId : String;
	cargoId : String;
	retStr : String;
	workStr : String;
	lc : CM_LocationsController;
	isForBulk : Boolean;
	weightRequested : Decimal [16,4];
	weightReleased : Decimal [16,4];
	weightStaged : Decimal [16,4];
	volumeStaged : Decimal [16,4];
	weightUnit : String;
	volumeUnit : String;
	unit : String;
	weightStagedString : String;
	density : Decimal [16,4];
	qtyRequested : Integer;
	qtyReleased : Integer;
	qtyStaged : Integer;
	
	ti : CM_TrackedItem;
	cargoType : CM_CargoType;

begin

	ti := self.getTI;
	if ti = null then
		return null;
	endif;
	
	cargoType := ti.myCargoType;
	
	if cargoType &lt;&gt; null then
		isForBulk := cargoType.isBulkMulti;
		workStr := cargoType.abbreviation;
		if self.getProductCode &lt;&gt; null then
			workStr := workStr &amp; " / " &amp; self.getProductCode;
		endif;
		if workStr &lt;&gt; null then
			retStr := workStr;
			workStr := null;
		endif;
	endif;
	
	retStr := self.getTotalRequestedDisplay &amp; " x " &amp; retStr;	//	20 Feb 2017	NDL	TFS 3476
	
	cargoGroupId := ti.getMyCargoGroupId;
	if cargoGroupId = null then
		cargoId := ti.id;
	endif;
	
	if cargoGroupId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoGroupId;
	elseif cargoId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoId;
	endif;
	
	retStr := retStr &amp; ",";	//06 Mar 2017	NDL	TFS 3477
	
	if isForBulk then
		weightReleased := self.getWeightReleased();
		weightRequested := ti.totalWeight;
		
		if cargoType.isBulkByVolume then
			if cargoType &lt;&gt; null and cargoType.myVolumeMeasurementType &lt;&gt; null then
				volumeUnit := cargoType.myVolumeMeasurementType.shortName;
				unit := volumeUnit;
			endif;
			density := ti.getDensity;
			volumeStaged := self.getWeightStaged / density;
			if volumeStaged = 0 then
				weightStagedString := "0";
			elseif volumeUnit &lt;&gt; null then
				weightStagedString := app.convertMeasurementForDisplay( volumeUnit, volumeStaged );
			else
				weightStagedString := weightStaged.Integer.String &amp; " " &amp; volumeUnit;
			endif;
		else
			if cargoType &lt;&gt; null and cargoType.myWeightMeasurementType &lt;&gt; null then
				weightUnit := cargoType.myWeightMeasurementType.shortName;
				unit := weightUnit;
			endif;
			weightStaged := self.getWeightStaged;
			if weightStaged = 0 then
				weightStagedString := "0";
			elseif weightUnit &lt;&gt; null then
				weightStagedString := app.convertMeasurementForDisplay( weightUnit, weightStaged );
			else
				weightStagedString := weightStaged.Integer.String &amp; " " &amp; weightUnit;
			endif;
		endif;
		
		retStr := retStr &amp; " (" &amp; weightStagedString &amp; " " &amp; unit &amp; " " &amp; app.getErrorString(CM_Staged) &amp; ")";
		
		_changeColour := ( weightReleased + weightStaged &gt;= weightRequested );
		
	else
		qtyRequested := self.getTotalRequested;
		qtyReleased := self.getTotalReleased;
		qtyStaged := self.getTotalStaged(null,lc,null);
		
		retStr := retStr &amp; " (" &amp; qtyStaged.String &amp; " " &amp; app.getErrorString(CM_Staged)&amp; ")";
		
		_changeColour := ( qtyReleased + qtyStaged &gt;= qtyRequested );
		
	endif;
	
	retStr := retStr &amp; " (" &amp; self.getTotalLoadedDisplay &amp; " " &amp; app.getErrorString(Loaded)&amp; ")";	//06 Mar 2017	NDL	TFS 3477
	retStr := retStr &amp; " (" &amp; getTotalReleasedDisplay &amp; " " &amp; app.getErrorString(ReleasedStr)&amp; ")";
	
	return retStr;

epilog

end;</source>
        <Parameter name="_changeColour" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStwHandHeldDetails" id="2cffcbb8-38ee-4bff-9723-9c53818d9261">
        <source>getStwHandHeldDetails(  _isSTWComplete : Boolean output ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2015	cnwndl1	Initial creation	Par 37033

*/

vars

	ti : CM_TrackedItem;
	retStr : String;
	workStr : String;
	lc : CM_LocationsController;

begin
	
	ti := self.getTI;
	if ti = null then
		return null;
	endif;
	
	retStr := ti.id;
	
	if ti.myCargoGroup &lt;&gt; null then
		workStr := ti.myCargoGroup.id;
		if workStr &lt;&gt; null then
			retStr := retStr &amp; ", " &amp; workStr;
		endif;
		workStr := null;
	endif;
	
	workStr := ti.myCargoType.abbreviation;
	if ti.myProduct &lt;&gt; null then
		workStr := workStr &amp; " / " &amp; ti.getDisplayStringForAttribute(ETRow_CargoSubType,true);
	endif;
	if workStr &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; workStr;
		workStr := null;
	endif;
	
	if self.isPackingChild then
		if self.isFullyPacked then
			retStr := retStr &amp; " - ";
			return app.getErrorString1(Fully_packed, retStr);
		endif;
	elseif self.myReserveHeader.isPackingType and self.isPackingParent then
		//??
	else
		if self.isFullyLoaded then
			retStr := retStr &amp; " - ";
			return app.getErrorString1(Fully_loaded, retStr);
		endif;
	endif;
	
	workStr := app.getErrorString1(RackItems, self.getTotalStaged(null,lc,null).String &amp; "/" &amp; self.getTotalOutstanding.String );
	retStr := retStr &amp; ", " &amp; workStr;

	retStr := retStr &amp; " " &amp; app.getErrorString(Staged);
	
	if self.myReserveDetailActions &lt;&gt; null then
		if self.myReserveDetailActions.hasActions then
			retStr := retStr &amp; " " &amp; self.myReserveDetailActions.getActionsSummary(true);
		endif;
	endif;
	
	return retStr;

epilog

end;</source>
        <Parameter name="_isSTWComplete" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="e263fdcb-21d1-482e-a804-5627101b78ac">
        <source>getTI() : CM_TrackedItem;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
----------   ----------  --------------------------------------------------
*/
vars
	ti			: CM_TrackedItem;
begin
	//ti := self.allTrackedItems.first;
	ti := self.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
	if ti = null then
		ti := self.allTrackedItemsReleased.first;
	endif;
	
	return ti;

end;


</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTIBookingReference" id="69014c66-9265-4b21-bb42-cd2773f98dd0">
