    <JadeMethod name="setupForm" id="0219da5b-ebfd-4455-ac0d-41dba89d2a02">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
31 July 2023	navmv20 Bug 58739: LNX - Invoice Line Type Combo Box
25 Aug 2025	navbs1	Bug 35755: Adding a new invoice line is not updating the invoice line table when there are more than 32000 invoice lines

*/

vars
	debtor 	   : CM_Debtor;
	tblResults : CM_DataTable;
	entTableDef : EntTableDef;
begin
	inheritMethod();
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	if not app.defaultMdi then
		self.centreWindow;
	endif;
	
	self.handleMenusForModalDisplay();
	self.doMsgLineTypeBuild();
	
	if self.myCurrentInvoice &lt;&gt; null then
		debtor := self.myCurrentInvoice.debtor;
	endif;
	
	tblResults := self.tblResults;
	tblResults.clear();
	
	self.shtItems.caption := "Items (" &amp; allTIs.size().String &amp; ")";
	
	if self.cmbDebtor.listCount() = 0 then
		self.doCmbDebtorBuild();
	endif;
	
	if self.cmbInvNumber.listCount() = 0 then
		if debtor = null then
			self.doCmbInvoiceBuild(null);
		else
			self.doCmbInvoiceBuild(debtor);
		endif;
	endif;
	
	//31/07/2023 navmv20 Bug 58739 - start
	if self.cmbLineType.listCount() = 0 then
		self.doCmbLineTypeBuild();
	endif;
	//31/07/2023	navmv20 Bug 58739 - end
	
	if self.myCurrentInvoice &lt;&gt; null 
	and self.myParentForm.INV_ListLines.getStatusGood() then
		if self.cmbDebtor.findObject(debtor) &lt;&gt; -1 then 
			self.cmbDebtor.listObject := debtor;
		endif;
		if self.cmbInvNumber.findObject(self.myCurrentInvoice) &lt;&gt; -1 then
			self.cmbInvNumber.listObject := self.myCurrentInvoice;
		endif;
		self.cmbDebtor.lostFocus(self.cmbDebtor);
		self.cmbInvNumber.lostFocus(self.cmbInvNumber);
	endif;
	
	entTableDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);
	self.tblResults.setTblDataEntRowsFromDef(entTableDef);
	self.tblResults.setMyDataClass(CM_TrackedItem);
	self.tblResults.fixedColumns := 0;
	self.tblResults.fixedRows := 1;
	self.tblResults.selectMode := CM_DataTable.SelectMode_FixedRow;
	self.tblResults.selectionType := CM_DataTable.SelectionType_Row;
	self.tblResults.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(self.tblResults);
	self.tblResults.clearAllData();
		
	if self.myCurrentInvoice = null then
		app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice),app.getErrorString(INV_Invoice_Update_Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//19/05/2025	navkc1 JIRA EPIC-34131 STORY-34822
	if app.myRoot.isClientGhana() then
		self.txtQuantity.decimals := 10;
	endif;
	
	
	self.displayInvoiceLine();

	self.getXMLSettingsForSetup();// ### TFS BUG 58793 26JUN2023 NAVAB1
epilog
	/*if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(INV_ListLines) then			//25.08.2025 navbs1 #35755
		self.myParentForm.INV_ListLines.btnQuery.enabled := false;
	endif;*/
end;</source>
    </JadeMethod>
    <JadeMethod name="shtLineTypes_mouseEnter" id="85d5059d-6371-4b47-aa39-bf302f64d45d">
        <controlMethod name="GroupBox::mouseEnter"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>shtLineTypes_mouseEnter(groupbox: GroupBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2023	navmv20	Bug 58739: LNX - Invoice Line Type Combo Box

*/

vars
	allLineTypes : CM_InvoiceLineDescSet;
	invLineType  : CM_InvoiceLineDesc;
begin
	create allLineTypes transient;
	self.msgInvLineType.getSelected(allLineTypes);
	
	if allLineTypes.size() = 1 then
		invLineType := allLineTypes.first;
		self.cmbLineType.listIndex := self.cmbLineType.findObject(invLineType);
	else
		self.cmbLineType.listIndex := -1;
	endif;
epilog
	delete allLineTypes;
end;</source>
        <Parameter name="groupbox" type="GroupBox" usage="input"/>
