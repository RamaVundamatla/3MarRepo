    <JadeMethod name="updateJobRemove" id="d1a5f74f-9f80-4b35-bc05-ef40deae792d">
        <updating/>
        <source>updateJobRemove(_theObj : Object) updating;
/*
Date		    Who			Reason
27 September 2011	cnwas3	  Initial creation: 
*/

vars
	idx,
	selectedIdx : Integer;
	theTable : CM_DataTable;
	selectedObj : Object;	
begin

	theTable := self.tblJobsData;
	if (not theTable.findObjectInRow(_theObj, idx)) then
		return;
	endif;

	selectedIdx := theTable.row;		
	selectedObj := theTable.accessRow(selectedIdx).itemObject;
	
	if selectedObj.String = _theObj.String then
		selectedObj := null;
		selectedIdx := -1;
		if selectedIdx &lt;= theTable.fixedRows then
			selectedIdx := theTable.fixedRows+1;
		endif;
	endif;	

	theTable.removeItem(idx);

	if (not theTable.selectObject(selectedObj, false)) then
		theTable.selectRow(selectedIdx, false);
	endif;

end;</source>
        <Parameter name="_theObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="updateRORORequestQuantity" id="8d722afd-3932-407a-a553-f7ffb18eba9d">
        <updating/>
        <source>updateRORORequestQuantity(_qty : Integer) updating,protected;

/*
Purpose:			
Date				Who			Reason
JANUARY 2012		CNWAB1		Initial creation
*/

vars
	theReturn, numItems : Integer;
begin
	
	
	numItems := _qty;
	if numItems &lt;= 0 then
		numItems := 1;
	endif;

	if self.myCurrentRORORequest = null then
		return;
	endif;
	
	while true do 
		app.myTrxUA.trxUpdateROROLoadCCQty(self.myCurrentRORORequest, numItems, app.myPassport);	
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Assign_roro_request_attribute), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_qty" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateRequestBulkRelease" id="1cb7d54e-bb5a-49f9-b051-2dd3100a6d08">
        <updating/>
        <source>updateRequestBulkRelease( _bulkReleasereserveDetail : CM_ReserveDetail) updating,protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2012	cnwrd1	Initial creation

*/

vars
	isLoad : Boolean;
	theSlots,sortSlots,
	theSlotsAlt		: CM_LCArray;
	anLC, aftLC, fwdLC  : CM_LocationsController;
	aReq : CM_RORORequest;
	obj : Object;
	tmpLoadCC	: CMIF_LoadColorCode;
	theReturn, numItems : Integer;
	itemLayout :CM_DeckItemLayout;
	editions : CM_ObjectByOidEditionDict;
	is40 : Boolean;
begin
	
	isLoad := (self.modeView = ShpDisplayMode_ColCodeLoad);
	
	if not isLoad then //only for load mode
		return;
	endif;

	create sortSlots transient;
	create theSlotsAlt transient;
	create theSlots transient;
	
	
	// Get the selected objects on the side view, if that has none then use the selected objects on the deck view
	if self.mySideViewForm &lt;&gt; null then
		if  not self.mySideViewForm.myROROLocnDrawingController.getSelectedObjectsAndALT(theSlots, theSlotsAlt) then
			self.myROROPlanDrawController.getSelectedObjectsAndALT(theSlots, theSlotsAlt);
			editions := self.myROROPlanDrawController.allObjectEditions;
		else
			editions := self.mySideViewForm.myROROLocnDrawingController.allObjectEditions;
		endif;
	else
		self.myROROPlanDrawController.getSelectedObjectsAndALT(theSlots, theSlotsAlt);
		editions := self.myROROPlanDrawController.allObjectEditions;
	endif;

	while true do
		if theSlots.isEmpty() then	//14 Jan 2020 NDL	TFS 46815
			break;
		endif; 	
		app.myTrxUA.trxROROControlerUpdateRelease(theSlots, _bulkReleasereserveDetail,  app.myPassport);		
		//app.myTrxUA.trxUpdateRORORequestVA(theSlots, theSlotsAlt, isLoad,editions	, _voyAllocation, numItems, app.myPassport);	
		
		if app.myPassport.trxCompletedOK then
			self.hasChanged := false;
			self.myROROPlanDrawController.updateEditionForSelectedObjs(theSlots);
			if theSlotsAlt &lt;&gt; null then
				self.myROROPlanDrawController.updateEditionForSelectedObjs(theSlotsAlt);
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Assign_roro_request_attribute), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
					theReturn = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	delete theSlotsAlt;
	delete theSlots;
	delete sortSlots;
	
end;</source>
        <access>protected</access>
        <Parameter name="_bulkReleasereserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestAttribALTGC" id="1c1242c8-c9bb-4d43-ba95-4b0c291502a8">
        <updating/>
        <source>updateSlotRequestAttribALTGC(_moveType : Integer) updating;
vars
	isLoad : Boolean;
	theReturn : Integer;
	theSlots,
	theSlotsAlt		: CM_LCArray;
	editions : CM_ObjectByOidEditionDict;
	x1,y1 : Decimal[12,2];
begin
		// Cargo Position (top left) in metres
		x1 := (((self.origMouseX/self.scaleFactor)/ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre));
		y1 := (-1 *  ((ROROStructureCentreLine/ROROStructurePixelsPerMetre) - ((self.origMouseY/self.scaleFactor) /ROROStructurePixelsPerMetre)));
	
//	isLoad := self.modeView = ShpDisplayMode_ColCodeLoad;

	// NOTE. IF IN  LOAD CC MODE ALT STUFF WILL BE IGNORED.
	
	create theSlotsAlt transient;
	create theSlots transient;
	create editions transient;
	
	app.getSelectedDLRGCSlots(theSlots, editions); // get 1 GC Discharge GC Request

	while true do
		if theSlots.isEmpty() then	//14 Jan 2020 NDL	TFS 46815
			break;
		endif;
		app.myTrxUA.doRORORequestDLRGCALT(theSlots, isLoad,_moveType, editions,self.myCurrentDeck, x1,y1, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Dlr_alt), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	delete theSlots;
	delete theSlotsAlt;
	delete editions;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestAttribDLRSoB" id="273335cb-cdc7-4698-ad3b-d25badb1780c">
        <updating/>
        <source>updateSlotRequestAttribDLRSoB(_moveType : Integer) updating;
vars
	anLC, aftLC, fwdLC, actualLC : CM_LocationsController;
//	  : CM_VoyageROROController;
	isLoad : Boolean;
	theReturn, idx : Integer;
//	theSlots,
//	theSlotsAlt,
//	sortSlots: CM_VoyageROROControllerArray;
	theSlots,
	theSlotsAlt,
	sortSlots: CM_LCArray;
	
	editions : CM_ObjectByOidEditionDict;
begin

	isLoad := self.modeView = ShpDisplayMode_ColCodeLoad;
	// NOTE. SLOT are always Discharge, Alt Slots are always Load
	
	create theSlotsAlt transient;
	create theSlots transient;
	create sortSlots transient;
	create editions transient;
	
	app.getSelectedDLRSOBSlots(theSlots, theSlotsAlt, editions, isLoad); // PAR 31144
	
	// ### PAR 29054
	// ### if colour coding for 40s the user does not need to select the forward and aft positions
	// ### so if they have, remove the aft positions as they just get an error otherwise and they get confused
	if not isLoad then
		theSlots.copy(sortSlots);
		foreach anLC in sortSlots discreteLock do
			aftLC := anLC.getAftLC();
			if sortSlots.includes(aftLC) then
			if aftLC.hasTIsOfMode40(REAL_MODE,false) then // only 40s
				theSlots.remove(aftLC);
			endif;
			endif;
		endforeach;

		// PAR 31116 for ALT selected -  Allow the user to do 40s by selecting the AFT 20 slot, but ONLY IF that selected LC has no AFT itself. If this is the case then get the FWD
		sortSlots.clear();
		theSlotsAlt.copy(sortSlots);
		foreach anLC in sortSlots discreteLock do
			aftLC := anLC.getAftLC();
			if sortSlots.includes(aftLC) then
				theSlotsAlt.remove(aftLC);
			endif;
		endforeach;
		
		foreach anLC in sortSlots discreteLock do
			aftLC := anLC.getAftLC();
			if aftLC = null then
				fwdLC := anLC.getFwdLC();
				if fwdLC &lt;&gt; null // PAR 28883
				and not theSlotsAlt.includes(fwdLC) then
					idx := theSlotsAlt.indexOf(anLC);
					actualLC := theSlots[idx];
					
					if actualLC.hasTIsOfMode40(REAL_MODE,true) then //  PAR 31652 only 40s
						theSlotsAlt[idx] := fwdLC;//  PAR 31652
//  PAR 31652						theSlotsAlt.add(fwdLC);
//  PAR 31652					theSlotsAlt.remove(anLC);
						editions.add(fwdLC);
					endif;
				endif;
			endif;
		endforeach;
		
	endif;
	
	
	while true do
		if theSlots.isEmpty() then	//14 Jan 2020 NDL	TFS 46815
			break;
		endif;
		app.myTrxUA.doRORORequestDLRSoB(theSlots, theSlotsAlt, isLoad,_moveType, editions, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(VoyJob_DLR), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	delete theSlots;
	delete theSlotsAlt;
	delete sortSlots;
	delete editions;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestAttributes" id="64b56595-fbc0-40dc-a6ec-0e29e37090fc">
        <updating/>
        <source>updateSlotRequestAttributes(_voyAllocation : CM_VoyageAllocation; _qty : Integer) updating,protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2009	cnwas3	Initial creation

*/

vars
	isLoad : Boolean;
	theSlots,sortSlots,
	theSlotsAlt		: CM_LCArray;
	anLC, aftLC, fwdLC  : CM_LocationsController;
	aReq : CM_RORORequest;
	obj : Object;
	tmpLoadCC	: CMIF_LoadColorCode;
	theReturn, numItems : Integer;
	itemLayout :CM_DeckItemLayout;
	editions : CM_ObjectByOidEditionDict;
	is40 : Boolean;
	
begin
	
	isLoad := (self.modeView = ShpDisplayMode_ColCodeLoad);
	is40 := _voyAllocation.getIs40();
	
	create sortSlots transient;
	create theSlotsAlt transient;
	create theSlots transient;
	
	
	// Get the selected objects on the side view, if that has none then use the selected objects on the deck view
	if self.mySideViewForm &lt;&gt; null then
		if  not self.mySideViewForm.myROROLocnDrawingController.getSelectedObjectsAndALT(theSlots, theSlotsAlt) then
			self.myROROPlanDrawController.getSelectedObjectsAndALT(theSlots, theSlotsAlt);
			editions := self.myROROPlanDrawController.allObjectEditions;
		else
			editions := self.mySideViewForm.myROROLocnDrawingController.allObjectEditions;
		endif;
	else
		self.myROROPlanDrawController.getSelectedObjectsAndALT(theSlots, theSlotsAlt);
		editions := self.myROROPlanDrawController.allObjectEditions;
	endif;

	// ### PAR 28787
	// ### if colour coding for 40s the user does not need to select the forward and aft positions
	// ### so if they have, remove the aft positions as they just get an error otherwise and they get confused
	if isLoad and  is40 then
		theSlots.copy(sortSlots);



		foreach anLC in sortSlots discreteLock do
			aftLC := anLC.getAftLC();
			if sortSlots.includes(aftLC) then
				theSlots.remove(aftLC);
			endif;
		endforeach;
		
		// PAR 28900 Allow the user to do 40s by selecting the AFT 20 slot, but ONLY IF that selected LC has no AFT itself. If this is the case then get the FWD
		foreach anLC in sortSlots discreteLock do
			aftLC := anLC.getAftLC();
			if aftLC = null then
				fwdLC := anLC.getFwdLC();
				if fwdLC &lt;&gt; null // PAR 28883
				and not theSlots.includes(fwdLC) then
					theSlots.add(fwdLC);
					theSlots.remove(anLC);
					editions.add(fwdLC);
				endif;
			endif;
		endforeach;
	endif;


	
	numItems := _qty;
	if numItems &lt;= 0 then
		numItems := 1;
	endif;

	while true do
		if theSlots.isEmpty() then	//14 Jan 2020 NDL	TFS 46815
			break;
		endif;
		app.myTrxUA.trxUpdateRORORequestVA(theSlots, theSlotsAlt, isLoad,editions	, _voyAllocation, numItems, app.myPassport);	
		
		if app.myPassport.trxCompletedOK then
			self.hasChanged := false;
			self.myROROPlanDrawController.updateEditionForSelectedObjs(theSlots);
			if theSlotsAlt &lt;&gt; null then
				self.myROROPlanDrawController.updateEditionForSelectedObjs(theSlotsAlt);
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Assign_roro_request_attribute), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
					theReturn = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	delete theSlotsAlt;
	delete theSlots;
	delete sortSlots;
	
end;</source>
        <access>protected</access>
        <Parameter name="_voyAllocation" type="CM_VoyageAllocation"/>
        <Parameter name="_qty" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="c5242172-ff63-473b-89d3-e8a20a08c5f6">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date		Who		Reason
22 June 2011	cnwab1	Initial creation
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars

	lController : CM_LocationsController;
	event : Integer;
	gotException	: Boolean;
	
begin
//write class.name &amp; '::' &amp; method.name &amp; ' 1. eventType: ' &amp; eventType.String &amp; " theObject: " &amp; theObject.String &amp; " userInfo: " &amp; userInfo.String;

	// PAR 32121 - noticed this during testing
	on Exception do app.handleDeletedObject (exception, self.myCurrentDeckItem, gotException);
	if self.myCurrentDeckItem &lt;&gt; null and self.myCurrentDeckItem.code = null then
	endif;
	if gotException then
		self.myCurrentDeckItem := null;
	endif;

	if eventType = EVENT_RORO_LAYER_UPDATE 
	or  eventType = EVENT_RORO_ITEM_UPDATE 
	or  eventType = EVENT_RORO_ITEM_DELETE  then
		self.doUserNotifyLayers(eventType, theObject, eventTag, userInfo);	// 28750 Jan 2012 job deletion
	endif;
	
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if event = VoyageJob_Delete_Event or not global.isValidObject(theObject) or CM_VoyageJob.hasInstance(theObject) then
		self.doJobNotificationUpdate(event,theObject.CM_Object,userInfo.CM_Object);	// 28750 Jan 2012 job deletion
	endif;

	// this is eventType
	if eventType = EVENT_PLANNING_GET_NEXT_IN_SEQ then
		if self.modeWork &lt;&gt; WorkMode_Plan then
			return;
		endif;
		if not userInfo.isKindOf(CM_LocationsController) then 
			return;
		endif;
		lController := userInfo.CM_LocationsController;
		if lController &lt;&gt; null then
			
		//	self.doPlanningGetNextPointInSeq(lController);
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' TO DO - NEXT PLANNING SLOT');
		endif;

	elseif event = EVENT_UPDATE_VOYAGE_AREA then

		on Exception do app.handleDeletedObject(exception, lController, gotException);		
		
		if not userInfo.isKindOf(CM_VoyageROROController) then  // PAR 31077 ignore ShipBlockController and LOLO
			return;
		endif;
		if self.myCurrentVoyage = theObject then
			lController := userInfo.CM_LocationsController;
		else
			return;
		endif;

		if lController &lt;&gt; null then

			// PAR 28544 self.myROROPlanDrawController.doDrawObject(lController);
			self.doNotesOnTimer(lController); // PAR 28544

			if gotException then
				// Exception handler resumes here if lController was invalid.
				return;
			endif;
		endif;

	endif;
	
	inheritMethod(eventType, theObject, eventTag, userInfo);
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
