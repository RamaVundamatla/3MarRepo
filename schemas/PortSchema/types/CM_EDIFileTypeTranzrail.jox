	endif;
	longString.string := "EQD+CN+" &amp; ediTI.id &amp; "++++" &amp; code &amp; "'";
	messages.add(longString);
*/
end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
