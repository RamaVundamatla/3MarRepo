    <JadeMethod name="doClearRTTasks" id="669fb9b0-0bb6-4fc7-b206-47c79eeb7ef5">
        <source>doClearRTTasks();

vars

	theForm 	: SOP_TableMaintForm;
	obj			: Object;
	allTasks	: CM_RTQueueTaskArray;

begin

	theForm := self.myForm;
	if theForm.mode &lt;&gt; theForm.Mode_View then
		return;
	endif;
	create allTasks transient;
	foreach obj in theForm.tblView2.allSelectedObjects do
		allTasks.add(obj.CM_RTQueueTask);
	endforeach;
	if allTasks.size &gt; 0 then
		app.myTrxUA.trxUpdateMachineRejectedRTTsks(theForm.myCurrentObject.CM_Machine, allTasks, app.myPassport);
	endif;
	theForm.tblView2.displayCollection(theForm.myCurrentObject.CM_Machine.rejectedRTQueueTasks, false, Table.DisplayCollection_Reversed, null);
	theForm.tblView2.allSelectedObjects.clear;
epilog	
	delete allTasks;
end;</source>
    </JadeMethod>
    <JadeMethod name="doColumnHeadingsHistoryTbl" id="3216e476-1187-4106-b9bf-95878b0e40c7">
        <source>doColumnHeadingsHistoryTbl();
// ---------------------------------------------------------------------------
// Created:     22 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 24/11/2010	cnwcs5		par 23714/ccms 1132 - extra column
vars
	table : CM_DataTable;
	headingStr : String;
begin
	table := self.myForm.tblDataView1;
	
//	table.setCellText (1, 1, 'Date' &amp; Tab &amp; 'User' &amp; Tab &amp; 'Action' &amp; Tab &amp; 
//							'Item ID' &amp; Tab &amp; 'From' &amp; Tab &amp;  'To' &amp; Tab &amp;  'Quantity'  &amp; Tab &amp; 'Remarks');
							
	headingStr := app.getErrorString(DateStr) &amp; Tab &amp;
					app.getErrorString(User) &amp; Tab &amp;
					app.getErrorString(Action) &amp; Tab &amp; 
					app.getErrorString(ItemId) &amp; Tab &amp;
					app.getErrorString(CM_From) &amp; Tab &amp;
					app.getErrorString(CM_To) &amp; Tab &amp;
					app.getErrorString(Move_amount) &amp; Tab &amp;
					app.getErrorString(Remarks);
					
	table.setCellText (1, 1, headingStr);
	
end;</source>
