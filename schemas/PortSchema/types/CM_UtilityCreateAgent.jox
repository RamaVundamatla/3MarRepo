    <JadeMethod name="utlCreateWorkOrderVoyage" id="f18da776-a6e9-410e-9d85-2deabbfe8637">
        <source>utlCreateWorkOrderVoyage(	_voyage : CM_Voyage;
							_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/06/2018	jlger1	Initial creation
03/07/2018	jlgdap1	TFS 39165 PEL1 Voyage Work Order Transactions
16/9/2021 	jlier1	TFS 51963 - for a start voyages created at status User Entry and stay at that status
18/08/2022	jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars
	realWorkOrder  : CM_WorkOrder; 
	pxyWorkOrder: CM_WorkOrderVoyage;
	pxyVOVoyageRequest : CM_WodVoyageRequest;
	cmifWOAction : CMIF_WorkOrderAction;			// TFS 39162
	status : Integer;
begin
	self.initialiseActivity();
	create pxyWorkOrder transient;
	
	status:=WO_STATUS_USERENTRY;
	if _voyage.status = Voyage_Status_VoyReqSubmitted or  _voyage.status = Voyage_Status_EUP_VoyReqSubm then
		status:=WO_STATUS_PENDING;
		
	elseif _voyage.status = Voyage_Status_EUP_VoyReq and not app.isWebApp then
		// EUP Voyage created from within MTN not Web Portal
		status := WO_STATUS_APPROVED;
		
	endif;
	
	pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,_passport.myUser,null,null,_voyage.myTerminal,null,null,null, status);
	pxyWorkOrder.setMyVoyage(_voyage);
	if app.isWebApp then //if created from Web Portal the voyage code will be the voyage work order code
		pxyWorkOrder.setID(_voyage.code); //epr TFS 51963 27/9/21 - when it was created voyage had a work order id
	endif;	
	create pxyVOVoyageRequest transient;
	pxyVOVoyageRequest.setFromVoyage(_voyage);
	pxyVOVoyageRequest.setParent(pxyWorkOrder);
	
	self.utlCreateWorkOrder(pxyWorkOrder, realWorkOrder, app.myPassport);
	
	
epilog
	delete pxyWorkOrder;
	delete cmifWOAction;										// TFS 39162
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateWorkPoint" id="d0c7509c-aad0-40ce-b721-8d49478c33fe">
