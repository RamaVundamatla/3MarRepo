    <JadeMethod name="create" id="f0065eae-e128-4bc6-ae92-d4c2112b3156">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 08 September 2004 by cnwdvb1
//09/02/2016 cnwma1 PAR #36654 Reports run through the web interface missing port logo
// -------------------------------------------
vars


begin

	/*if app.isWebApp then   //09/02/2016 cnwma1 PAR #36654 
		return;
	endif;
	*/
	create self.jmtLogo transient;
	self.jmtLogo.picture := app.getPicLogoProduct(); 	
		
end;</source>
    </JadeMethod>
