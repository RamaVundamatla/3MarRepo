    <JadeMethod name="doResize" id="64696397-4b63-4d84-b701-b82140782752">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
25 August 2008	consw1	Initial creation

*/

vars

begin
	inheritMethod();

	self.btnOK.top := self.clientHeight - VerticalSpacing - self.btnOK.height;
	self.btnCancel.top := self.btnOK.top;
	self.btnCancel.left := self.tblAvailable.left + self.tblAvailable.width - self.btnCancel.width;
	self.btnOK.left := self.btnCancel.left - self.btnCancel.width - HorizontalSpacing;	

//	self.tblAvailable.move(self.tblAvailable.left, self.tblAvailable.top, self.width - WinRightMargin-WinLeftMargin, self.btnOK.top - WinBottomMargin-self.tblAvailable.top);
	self.tblAvailable.cnEcResizeContents();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUnload" id="db5670c2-5b7a-4b85-a65c-bd01e6448bf5">
        <updating/>
        <source>doUnload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
27 August 2008	consw1	Initial creation

*/

vars

begin
	self.allTransients.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCriteriaValue" id="837525e6-84b3-4ebf-8097-78713e6b5d2e">
        <source>getCriteriaValue() : String;

/*

Purpose:		Get the correct criteriaValue

Date			Who		Reason
12 July 2011	cnwmh5	Initial creation #27772
13 Aug 2013		cnwdap1	PAR #32123 Colour is a bit different - it doesn't have a comma, but we need to insert one 
									to make the criteria pattern matching work
*/

vars

begin
	//epr TFS 1822 28/4/16
	
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(ValidateColour).Boolean and self.myCriteriaType.isKindOf(CM_YATypeColour) then	// PAR #32123
		return self.criteriaValue.replace(" ", ",");																// PAR #32123
	else
		return self.criteriaValue;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeDependencies" id="bf1e01ba-137c-472e-9f59-ed5da35a73d9">
        <source>getTypeDependencies(_allObjs : CM_ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2013	cnwmc5	Initial creation	PAR 31255

*/

vars
	dependentTypes		: IntegerArray;
	
	i					: Integer;
	type				: Integer;
	
	criteriaCtrl		: CMUI_YACriteriaCntl;
begin
	if masterControl = null then
		return;
	endif;
	
	create dependentTypes transient;
	
	self.myCriteriaType.getDependentTypes(dependentTypes);
	
	if dependentTypes.size &lt;&gt; 0 then
		while true do
			i := i + 1;
			criteriaCtrl := self.masterControl.getControl(i);
			if criteriaCtrl = null then
				break;
			endif;
			if criteriaCtrl.visible  and criteriaCtrl.hasValue() then
				foreach type in dependentTypes do				
					if criteriaCtrl.getCriteriaType().type = type then
						self.myCriteriaType.getDependentObjects(_allObjs, criteriaCtrl.getValue(), criteriaCtrl.getCriteriaType());
					endif;
				endforeach;
			endif;
		endwhile;
	endif;
epilog
	delete dependentTypes;
end;</source>
        <Parameter name="_allObjs" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="a4124584-81a5-4bdc-816e-4065217f97d3">
        <source>getValue( _obj : Object ) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
26 August 2008	consw1	Initial creation

*/

vars
	txt : String;
	
begin
	on Exception do self.getValueExHandler(exception);

	txt := "???";
	txt := _obj.getYAIdentifier;
	
	return txt;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueExHandler" id="c3fd31cb-e5d5-4d54-9302-1a4af0955d29">
        <source>getValueExHandler(exObj : Exception) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
26 August 2008	consw1	Initial creation

*/

vars

begin
	if exObj.errorCode = 4 then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWeightCriteria" id="f00ba2b5-48f1-4a8f-8f93-7c4c0e2b7794">
        <source>getWeightCriteria(_criteriaColl, _selectedColl : ObjectSet input);
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
02/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	criteriaValue	: String;
	criteriaObj		: Object;

begin
	self.myCriteriaType.getAllCriteriaValues(self.myTerminal, _criteriaColl, self.filter, null);	//cnwmc5 - PAR 31255
	criteriaValue := self.getCriteriaValue();
	if criteriaValue &lt;&gt; null then
		self.myCriteriaType.resolvePattern(criteriaValue, _selectedColl, false);
	endif;
	foreach criteriaObj in _selectedColl where not _criteriaColl.includes(criteriaObj) do
		_criteriaColl.add(criteriaObj);
	endforeach;

epilog

end;</source>
        <Parameter name="_criteriaColl" type="ObjectSet" usage="input"/>
        <Parameter name="_selectedColl" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getYAMaintOperationalCriteria" id="63d4bc95-3a2d-458b-be78-9e7d1a99a10e">
        <source>getYAMaintOperationalCriteria(_cmifArray : CMIF_Array input);
/*
Purpose:			Return a array containing one proxy YA criterion, which is the currently-selected
					criterion from the CMUI_YAMaintForm

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
02/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	form			: CMUI_YAMaintForm;
	criteriaFrame	: CMUI_YACriteriaCntl;
	criterion		: CM_YACriteriaType;
	proxyCrit		: CM_YACriteria;
	itemCode		: String;
	value			: Any;
	cmifCriteria	: CMIF_YACriteriaPriority;

begin
	form := self.myParentForm.CMUI_YAMaintForm;
	if form.myCurrentYAControl &lt;&gt; null and form.myCurrentYAControl.cmbCriteriaType &lt;&gt; null and form.myCurrentYAControl.cmbCriteriaType.listObject &lt;&gt; null then
		criteriaFrame := form.myCurrentYAControl;
		criterion := form.myCurrentYAControl.cmbCriteriaType.listObject.CM_YACriteriaType;
	else
		return;
	endif;
	
	create proxyCrit transient;
	itemCode := criterion.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := criteriaFrame.getValue();
	proxyCrit.setProxy(criterion, value, itemCode);
	cmifCriteria := proxyCrit.getTransient();
	_cmifArray.add(cmifCriteria);
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getYATypeProductText" id="8b79e008-b568-4a72-971b-dcce1c792724">
        <source>getYATypeProductText(_value : String) : String;

/*

Purpose:		

Date			Who		Reason
11 July 2011	cnwmh5	Initial creation #27772

*/

vars

	subtype		: CM_Product;

	tokens		: StringArray;
	
	str 		: String;
	subtypeStr	: String;

begin

	create tokens transient;
	tokens := _value.getTokens();
	foreach subtypeStr in tokens do 
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		subtype := subtypeStr.asObject.CM_Product;
		if subtype &lt;&gt; null then
			str := str &amp; subtype.getYADisplay();
		endif;
	endforeach;

	return str;
	
epilog
	delete tokens;
end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
