    <JadeMethod name="postProcessInaportnetResponse" id="8694fbfe-5e9b-4cf4-976e-78915bf82232">
        <source>postProcessInaportnetResponse(_reply: String): String protected;
/*

Purpose:			Modify the reply to match the required output. For INAPORTNET this means ensuring the 
					child node of the main response is tagged "return"

Parameters:			Original reply XML string

Return Value:		Modified reply XML string

Date		Who		Reason
06 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	returnVal		: String;
	xml 			: JadeXMLDocument;
	parseError		: Boolean;
	documentChanged	: Boolean;
	responseTag		: String;
	elements		: JadeXMLElementArray;
	element			: JadeXMLElement;
	attribute :	JadeXMLAttribute;
begin
	// Start by parsing the message so that it can be more easily analysed
	on JadeXMLException do self.handleXMLException(exception, parseError);
		
	create xml transient;
	xml.parseString(_reply);
	
	if parseError then
		// No nothing
		return _reply;
	endif;
	
	//epr 30/7/18 
	create elements transient;
	responseTag := self.getMethodName() &amp; "Result";
	xml.findElementsByTagName(responseTag, elements);
		
	foreach element in elements do
		element.tagName :=  "return";
		element.localName :=  "return";
		attribute:=element.getAttributeByName("xsi:type");
		if attribute  &lt;&gt; null then
			delete attribute;
		endif;
		documentChanged := true;
	endforeach;
	
	// The child of the main response will be named &lt;methodName&gt;Result
	
	
	// Firstly convert INAPORTNET names to JMT names
	//xmlHelper.translateElementNames(xml, responseTag,  "return", documentChanged);
	
	//self.xmlTranslateElementNames(xml, responseTag, "return", documentChanged);
	
	// If a change was made, log the fact
	if documentChanged then
		app.writeLog(method.qualifiedName &amp; " updated reply", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		returnVal := xml.writeToString();
	else
		returnVal := _reply;
	endif;
	
	return returnVal;
	
epilog
	delete xml;
	delete elements;
end;</source>
        <access>protected</access>
        <Parameter name="_reply" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="postProcessResponse" id="746b2628-230c-49cb-83a5-946d7f1bd298">
        <source>postProcessResponse(_reply: String): String protected;
/*

Purpose:			Modify the reply to match the required output

Parameters:			Original reply XML string

Return Value:		Modified reply XML string

Date		Who		Reason
06 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	returnVal		: String;
	xml 			: JadeXMLDocument;
	parseError		: Boolean;
	documentChanged	: Boolean;
	
begin
	returnVal := inheritMethod(_reply);
	
	if self.currentRequestIsInaportnet() then
		returnVal := self.postProcessInaportnetResponse(returnVal);
	endif;
	
	return returnVal;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reply" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="preProcessEntryPPK" id="6adb0948-cec6-4a2c-81a1-6946aced5ddf">
        <updating/>
        <source>preProcessEntryPPK() updating, protected;
/*

Purpose:			Modify the incomingMessage to ensure JADE Web Service framework can correctly parse it
					
Parameters:			None

Return Value:		None

Date		Who		Reason
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
18 Apr 2018	jlgkpd1	TFS #37190 - refactor to CM_XmlHelperAgent
09 May 2018	jlgkpd1	TFS #37190 - changes as per new INAPORTNET documentation of 08/05/2018
*/

vars
	xml 			: JadeXMLDocument;
	parseError		: Boolean;
	documentChanged	: Boolean;
	xmlHelper 		: CM_XmlHelperAgent;
	
begin
	// Start by parsing the message so that it can be more easily analysed
	on JadeXMLException do self.handleXMLException(exception, parseError);
		
	create xml transient;
	xml.parseString(self.incomingMessage);
		
	if parseError then
		// No nothing
		return;
	endif;

	create xmlHelper transient;
	
	// Firstly convert INAPORTNET names to JMT names
	xmlHelper.translateElementNames(xml,"urn:JadeWebServices/JMTExternalInterfaceService/", "detailPpk", WS_DetailPPK.name, documentChanged);
	
	// Ensure any WS_DetailPPK are correctly parented
	xmlHelper.reparentElements(xml, WS_DetailPPK.name, WS_EntryPPKRequest::allDetailPPK.name, documentChanged);
	
	if documentChanged then
		app.writeLog(method.qualifiedName &amp; " modified input", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.incomingMessage := xml.writeToString();
		self.logIncomingMessage();
	endif;
	
epilog
	delete xml;
	delete xmlHelper;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="preProcessEntryRKBM" id="871e4fab-ed79-4d83-ab5c-e54eb589f1a7">
        <updating/>
        <source>preProcessEntryRKBM() updating, protected;
/*

Purpose:			Modify the incomingMessage to ensure JADE Web Service framework can correctly parse it
					
