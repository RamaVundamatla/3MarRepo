        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_rules" type="CM_EDIPartyCoparnRules" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_UpdateChecksBlocked" id="2798ac25-cc47-4b8a-867e-3b793123a092">
        <source>doCoparn_UpdateChecksBlocked(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode :String ) protected;
/*
Date		Who		Reason
30/04/2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
16/05/2012	cnwcs5	par 29575
08/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 16 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
*/
constants
	RELEASEIDA = 'UT_BlockA01';
	RELEASEIDP = 'UT_BlockP01';
	ADD = '9';
	UPDATE = '5';
	DELETE = '1';
	MTGRADE	= 'DAIRY';
	ISOTYPE = '22G1';
	MT = '4';
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDITrackedItem;
	release	:CM_BulkRelease;
	releaseId	:String;
	isPartial	:Boolean;
	ediItem : CM_EDITrackedItem;
begin
	isPartial := self.getTerminal().getConfig(EdiReleaseAllowPartial).Boolean;
	
	if isPartial then
		releaseId := RELEASEIDP;
	else
		releaseId := RELEASEIDA;
	endif;
	
	self.deleteReleaseRequest (releaseId);
//	------------------------------------------------------
// 	create a new release request which we will block later
//	------------------------------------------------------
	text 	:= self.zCoparn_mtrel_dates (_sender, ADD, _voyageCode, _vesselName, _consignorCode, _consigneeCode, releaseId, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "NEW RELEASE COPARN"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		isPartial := true;
	endif;
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
	self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED, 'EDI TI should be DB Loaded (' &amp;   ')');

	release := self.getReleaseRequest (releaseId);
	
	self.assertNotNull (release);
	self.assertEqualMsg (release.totalRequested, 2, 'Quantity is incorrect');
//	---------------------------------------------------
// 	update the release request (change qty - no errors)
//	---------------------------------------------------
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, releaseId, MTGRADE, ISOTYPE, '1', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "UPDATE QTY COPARN"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');

	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);

	release := self.getReleaseRequest (releaseId);
	
	self.assertNotNull (release);
	self.assertEqualMsg (release.totalRequested, 1, 'Quantity has not been changed');
//	---------------------------------------------------------	
// 	set the blocked property and try update - should be error
//	---------------------------------------------------------
	beginTransaction;
	release.setBlockEDIUpdates (true);
	commitTransaction;
	
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, releaseId, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "BLOCKED UPDATES COPARN"&amp;method.name);			
	
	self.assertNotNull(ediFile); 
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile); 
	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_BLOCKED, "Expecting error - can't UPDATE (blocked)");
		self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, 'EDI TI should be Skip Processing (*)');
	else
		self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, 'EDI TI should be Skip Processing (*)');
	endif;
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should have failed');
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
//	endif;
	
//	---------------------------------------------------------	
// 	now try deleting - should be error
//	---------------------------------------------------------
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, releaseId, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "BLOCKED DELETE COPARN"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile); 
	
	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertTrxErrorMsg (EDI_RELEASE_DEL_BLOCKED, "Expecting error - can't DELETE (blocked)");	
		self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, 'EDI TI should be Skip Processing (*)');
	else
		if isPartial then
			if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
				self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'DB Load should have failed');
			else
				self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should have failed');
			endif;
		else
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
		endif;
	endif;
//	-----------------------------------------
//	reset blocked flag - delete should be OK
//	-----------------------------------------	
	beginTransaction;
	release.setBlockEDIUpdates (false);
	commitTransaction;
	
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, releaseId, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "NOT BLOCKED DELETES COPARN"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
	self.assertDeleted (release.String);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_UpdateChecksCCMS2221" id="d937b0cf-40e5-4c45-bff7-9339aca3a119">
        <source>doCoparn_UpdateChecksCCMS2221(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode :String; 
							_operator :CM_Operator; _ta :CM_TerminalArea; _rules :CM_EDIPartyCoparnRules input) protected;
/*
Date		Who		Reason
12 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
//20 Mar 2015	cnwrs1	Par 35827 - for error 88612 set the status to skip processing
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 16 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 10 Apr 2018	jlgrs1	TFS 38021 - JMT - Fix issues shown by TFS 37610, delete errors not handled correctly
// 09 Aug 2018	jlgmd1	TFS 39693 - Bulk Release deleting inconsistency between Bulk Release Form and EDI
*/
constants
	RELEASEID 	= 'UT_REL2221001';
	RELEASEID2 	= 'UT_REL2221002';
	RELEASEID3 	= 'UT_REL2221003';
	RELEASEID4 	= 'UT_REL2221D004';
	CONTAINER 	= 'UT_TI222101';
	CONTAINER2 	= 'UT_TI222102';
	VEHICLE 	= 'UT_TRUCK2221';
	DRIVER 		= "CMS2221";
	ADD = '9';
	UPDATE = '5';
	DELETE = '1';
	MTGRADE	= 'DAIRY';
	ISOTYPE = '2200';
	MT = '4';
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDITrackedItem;
	release	:CM_BulkRelease;
	coll	:CM_BulkReleaseSet;
	ti		:CM_TrackedItem;
	vvr		:CM_VehicleVisitRecord;
	gate	:CM_Gate;
	wle		:CM_WorkListEntry;
	error	:CM_EDIError;
	set	:CM_EDITISet;
	isPartial	:Boolean;
	ediItem : CM_EDITrackedItem;
begin
	isPartial := self.getTerminal().getConfig(EdiReleaseAllowPartial).Boolean;
//	-------------------------------------
//	get rid of left overs from last time
//	-------------------------------------
	self.deleteReleaseRequest (RELEASEID);
	self.deleteReleaseRequest (RELEASEID2);
	self.deleteReleaseRequest (RELEASEID3);
	self.deleteReleaseRequest (RELEASEID4);
	self.deleteContainer (CONTAINER);
	self.deleteContainer (CONTAINER2);
	self.deleteVehicle (VEHICLE);
	self.deleteDriverDetails (DRIVER);
//	-----------------------------------------------------------------
//	add cargo, truck, terminal area so we can assign release to truck
//	------------------------------------------------------------------
	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignee, _consigneeCode);
	self.opts.addAssociation(UTTI_Consignor, _consignorCode);
	self.opts.addAssociation(UTTI_DeliveryRelease, 'christina');
	self.opts.addAssociation('deliveryNumber', 'christina');
	self.opts.addAssociation(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	
	ti := self.addContainerOpts (CONTAINER, ISOTYPE, "MT", _operator);
	
	self.assertEqual (ti.consignee, _consigneeCode);
	self.assertEqual (ti.consignor, _consignorCode);
	self.assertEqual (ti.deliveryRelease, 'christina');
	
	self.move (ti, _ta);
	assertEqual(ti.myPrimaryActualLocation, _ta.allLocationsControllers.first);
	
	foreach gate in self.getTerminal.allGates do
		if not gate.hasPGateAreas then
			// single
			break;
		endif;
		gate := null;
	endforeach;
	
	self.assertNotNull (gate);
//	----------------------------------------------------------------
// 	create a new release request which we will change to road later
//	----------------------------------------------------------------
	text 	:= self.zCoparn_mtrel_dates (_sender, ADD, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '5', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN1"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		isPartial := true;
	endif;
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);

	release := self.getReleaseRequest (RELEASEID);
	
	self.assertNotNull (release);
	self.assertEqualMsg (release.totalRequested, 5, 'Quantity is incorrect'); 
//	---------------------------------------------------------------------------------
// 	Change release type to road - update the release request
//	---------------------------------------------------------------------------------
	create coll transient;
	coll.add (release);
	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_ACTIVE, coll, app.myPassport);
	self.assertEqual (release.status, BR_ACTIVE);
	
	app.myTrxUA.trxSetReleaseRequestsType (BR_TYPE_ROAD, coll, app.myPassport);
	self.assertEqual (release.type, BR_TYPE_ROAD);	
	
//	---------------------------------------------------------	
// 	load to road ops and set block actioned updates flag 
//	---------------------------------------------------------
	beginTransaction;
	release.setPropertyValue (CM_BulkRelease::mySubTerminal.name, ti.mySubTerminal);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdActioned.name, false);
	commitTransaction;
	
	self.opts.addAssoc("release", release);
	vvr := self.gateOutContainer(VEHICLE, "", DRIVER, ti.CM_Container, true, gate , _ta.id);
	self.assertNotNull (vvr);
	
	// At this point there will be a queued entry on the road ops form
	self.assertEqualMsg (release.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, ti);
//	---------------------------------------------------------	
// 	attempt update to quantity - should be error
//	---------------------------------------------------------
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '10', null, null, MT);
	ediFile := self.ediLoadFileName(text,  EDIFileType_Coparn, "COPARN", "COPARN - test block updates actioned false"&amp;method.name);	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	// expecting trx error
	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_ACTIONED, "Expecting error - can't UPDATE (actioned)");
		// we should have verified errors
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed'); 
	else
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_ACTIONED, "Expecting error - can't UPDATE (actioned)");
		// we should have verified errors
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed'); 
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed'); 
	endif;
	// qty shouldnot have changed
	self.assertEqualMsg (release.totalRequested, 5, 'Quantity is incorrect'); 
	
	self.assertEqual (ediData.allErrorWarnings.size, 1);
	self.assertEqualMsg (ediTI.status, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X, 'EDI TI should be Skip Processing (*)');
	self.assertEqual (ediTI.getKeepPersistentErrors, true);
	
	foreach error in ediData.allErrorWarnings do
		self.assertTrue (error.myUserObject = ediTI and not error.isTransient);
	endforeach;
//	---------------------------------------------------------	
// 	set the EDI TI to be processed - file should go to DB Loaded
//	---------------------------------------------------------
	create set transient;
	set.add (ediTI);
	
	app.myTrxUA.trxEDIProcessEDITrackedItem(set, app.myPassport); 
	
	self.assertTrue (ediTI.status = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED);
	self.assertEqual (ediTI.getKeepPersistentErrors, false);
	self.assertEqual (ediTI.getIsToBeProcessed, true);

	
	self.ediDBLoad(ediFile);
		
	self.assertTrueMsg (ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED, 'EDI TI should be DB Loaded');
	self.assertEqualMsg (ediTI.getKeepPersistentErrors, false, 'EDI TI - keep errors should be false');
	// *** not sure if force processing should be false or not
	// self.assertEqualMsg (ediTI.getIsToBeProcessed, false,'EDI TI - force processing should be false');
	
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');

	self.assertEqual (ediData.allErrorWarnings.size, 0);
	
	// qty should have changed
	self.assertEqualMsg (release.totalRequested, 10, 'Quantity is incorrect'); 
	
//	------------------------------------------------------------------
// 	move container to truck and gate out - set block updates actioned - should be error on updating
//	------------------------------------------------------------------
	self.moveQueuedCargo (wle);
	self.roadExit (vvr);
	
	self.assertNullMsg (vvr.vehicle.myPrimaryActualLocation, 'Vehicle is still on site');
	
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdActioned.name, false);
	commitTransaction;
	
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '15', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN - test block updates actioned true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_ACTIONED, "Expecting error - can't UPDATE (actioned)");
	else
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_ACTIONED, "Expecting error - can't UPDATE (actioned)");
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
	endif;
//	---------------------------------------------------------	
// 	set the EDI TI to be processed - file should go to DB Loaded
//	---------------------------------------------------------
	set.clear; 
	set.add (ediTI);
	
	app.myTrxUA.trxEDIProcessEDITrackedItem(set, app.myPassport); 
	
	self.assertTrue (ediTI.status = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED);
	self.assertEqual (ediTI.getKeepPersistentErrors, false);
	self.assertEqual (ediTI.getIsToBeProcessed, true);

	self.ediDBLoad(ediFile);
		
	self.assertTrueMsg (ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED, 'EDI TI should be DB Loaded');
	self.assertEqualMsg (ediTI.getKeepPersistentErrors, false, 'EDI TI - keep errors should be false');
	// *** not sure if force processing should be false or not
	// self.assertEqualMsg (ediTI.getIsToBeProcessed, false,'EDI TI - force processing should be false');
	
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');

	self.assertEqual (ediData.allErrorWarnings.size, 0);
	
	// qty should have changed
	self.assertEqualMsg (release.totalRequested, 15, 'Quantity is incorrect'); 
	
//	---------------------------------------------------------	
// 	now try deleting with blocked deleted actioned - should be error
//	---------------------------------------------------------
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelActioned.name, false);
	commitTransaction;
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN - testing block deletes actioned true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg(EDI_RELEASE_DEL_ACTIONED, "Expecting error - can't DELETE (actioned)");
	else
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg(EDI_RELEASE_DEL_ACTIONED, "Expecting error - can't DELETE (actioned)");
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
	endif;
//	self.assertTrxErrorMsg(ReleaseRequestAlreadyHasItems, "Expecting error - can't DELETE (actioned)");	

//	-----------------------------------------
//	complete the release - update should fail
//	-----------------------------------------	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_COMPLETE, coll, app.myPassport);
	self.assertEqual (release.status, BR_COMPLETE);

	
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdCompleted.name, false);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelCompleted.name, false);
	commitTransaction;
	
	// update
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN - tests block update completed true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_COMPLETE, "Expecting error - can't UPDATE (complete)");
	else
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_COMPLETE, "Expecting error - can't UPDATE (complete)");
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
	endif;
//	-----------------------------------------
//	complete the release - delete should fail
//	-----------------------------------------	
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN - test block deletes completed true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg(EDI_RELEASE_DEL_COMPLETED, "Expecting error - can't DELETE (complete)");	
	else
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg(EDI_RELEASE_DEL_COMPLETED, "Expecting error - can't DELETE (complete)");	
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
	endif;
//	self.assertTrxErrorMsg(ReleaseRequestAlreadyHasItems, "Expecting error - can't DELETE (complete)");	
	
//	-------------------------------------------------------------------
// 	set the EDI TI to be processed - there will still be verify errors
//	-------------------------------------------------------------------
	set.clear; 
	set.add (ediTI);
	
	app.myTrxUA.trxEDIProcessEDITrackedItem(set, app.myPassport); 
	
	self.assertTrue(ediTI.status = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED);
	self.assertEqual(ediTI.getKeepPersistentErrors, false);
	self.assertEqual(ediTI.getIsToBeProcessed, true);
	
	release := self.getReleaseRequest (RELEASEID);
	self.assertNotNull(release);
	
	beginTransaction;
	// Deleting a Release Request should now only fail if the request is Active
	release.setStatus(BR_ACTIVE, false, true);
	commitTransaction;
	
//beginTransaction;
//ediData.allErrorWarnings.purge;
//	self.assertEqual(ediData.allErrorWarnings.size, 0);
	self.ediDBLoad(ediFile);
	if ediData.isKindOf(CM_EDIDataGateDoc) then	
		if not isPartial then
			self.assertTrueMsg(ediTI.status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS, 'EDI TI should be DB Loaded');
			self.assertEqualMsg(ediTI.getKeepPersistentErrors, false, 'EDI TI - keep errors should be false');
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, 'DB Load should NOT have failed');
		else
			self.assertTrueMsg(ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS, 'EDI TI should be DB Loaded');
			self.assertEqualMsg(ediTI.getKeepPersistentErrors, false, 'EDI TI - keep errors should be false');
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS, 'DB Load should NOT have failed');
		endif;
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		if not isPartial then
			self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS, 'EDI TI should be DB Loaded');
			self.assertEqualMsg(ediTI.getKeepPersistentErrors, false, 'EDI TI - keep errors should be false');
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, 'DB Load should NOT have failed');
		else
			self.assertEqualMsg(ediTI.status, CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS, 'EDI TI should be DB Loaded');
			self.assertEqualMsg(ediTI.getKeepPersistentErrors, false, 'EDI TI - keep errors should be false');
			self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS, 'DB Load should NOT have failed');
		endif;
	endif;
	// *** not sure if force processing should be false or not
	// self.assertEqualMsg (ediTI.getIsToBeProcessed, false,'EDI TI - force processing should be false');

	if not isPartial then
		self.assertEqual (ediData.allErrorWarnings.size, 1);
	else
		self.assertEqual (app.myPassport.allErrorWarnings.size, 1);
	endif;
	self.assertTrxErrorMsg (ReleaseRequestAlreadyHasItems, "Expecting error - can't DELETE (items rewleased)");	

//	if ediData.isKindOf(CM_EDIDataGateDoc) then	
		// release should not be deleted
		self.assertTrue(global.isValidObject(release));
//	endif;
//	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
//		self.assertTrue(global.isValidObject(release));
//	endif;

	beginTransaction;
	// Change the Release Request back to Pending, so it can be deleted later
	release.setStatus(BR_PENDING, false, true);
	commitTransaction;

epilog
	delete set;
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_rules" type="CM_EDIPartyCoparnRules" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_UpdateChecksRail" id="1f463ca6-7f8b-448b-9e85-ab9048327067">
        <source>doCoparn_UpdateChecksRail(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode :String; 
							_operator :CM_Operator; _ta :CM_TerminalArea; _rules :CM_EDIPartyRules input ) protected;
/*
Date		Who		Reason
30/04/2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
16/05/2012	cnwcs5	par 29575
03/09/2012	cnwcs5	par 30097
08/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 16 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
*/
constants
	RELEASEID = 'UT_RELRAIL001';
	CONTAINER1 = 'UT_TIRAIL1';
	CONTAINER2 = 'UT_TIRAIL2';
	TRAIN = 'UT_CMS01';
	WAGON = "UK_CMS1";
	
	WAGONCLASS		: String = "UK";
	WAGONMASTERCODE	: String = "UK2102";
	RAILAREA 		: String = "RA_CMS";
	
	ADD = '9';
	UPDATE = '5';
	DELETE = '1';
	MTGRADE	= 'GP';
	ISOTYPE = '2200';
	MT = '4';
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDITrackedItem;
	release	:CM_BulkRelease;
	coll	:CM_BulkReleaseSet;
	ti1, ti2		:CM_TrackedItem;
	wle		:CM_WorkListEntry;
	wagonClass	:CM_WagonClass;
	wagonMaster, pxyMaster	:CM_WagonMaster;
	train,pxyTrain		:CM_Train;
	railArea	:CM_Rail;
	railIORake 	:CM_RailJSInOutRake;
	railLine	:CM_RailLine;
	tiColl		:CM_TIByIdDups;
	wagon		:CM_Wagon;
	cmifObjects : ObjectArray;
	intFaceBP	: CMIF_BuildPriority;
	cmifRequest	: CMIF_Request;
	obj			: Object;
	controller	: CMIF_MoveController;
	lc			: CM_LocationsController;
	trainSet	: CM_TrainSet;
	cmifRakeRegion	: CMIF_RakeRegion;
	isPartial	:Boolean;
	ediItem : CM_EDITrackedItem;
begin
	isPartial := self.getTerminal().getConfig(EdiReleaseAllowPartial).Boolean;
	//on LockException do self.lockExceptionHander (exception);
	
//	-------------------------------------
//	get rid of left overs from last time
//	-------------------------------------
	self.deleteReleaseRequest (RELEASEID);
	self.deleteContainer (CONTAINER1);
	self.deleteContainer (CONTAINER2);
	
	wagonMaster := self.getRoot.allWagonMasters[WAGONMASTERCODE];

	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteTrain(TRAIN,null);

	self.deleteRailArea(RAILAREA);
	
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdActioned.name, false);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelActioned.name, false);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdArchived.name, false);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelArchived.name, false);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdCompleted.name, false);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelCompleted.name, false);

	commitTransaction;
	
//	-----------------------------------------------------------------
//	add cargo, train, raill area, wagon class, wagons, terminal area so we can assign release to train
//	------------------------------------------------------------------
	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignee, _consigneeCode);
	self.opts.addAssociation(UTTI_Consignor, _consignorCode);
	self.opts.addAssociation(UTTI_DeliveryRelease, 'christina');
	self.opts.addAssociation('deliveryNumber', 'christina');
	self.opts.addAssociation(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	self.opts.addAssociation (UTTI_AvailabilityGrade, '0');
//	self.opts.addAssociation(UTTI_VoyageCode, _voyageCode);
	
	ti1 := self.addContainerOpts (CONTAINER1, ISOTYPE, "MT", _operator);
	
	self.assertEqual (ti1.consignee, _consigneeCode);
	self.assertEqual (ti1.consignor, _consignorCode);
	self.assertEqual (ti1.deliveryRelease, 'christina');
	self.assertEqual (ti1.CM_Container.availabilityGrade, 0);
	
	self.move (ti1, _ta);
	assertEqual(ti1.myPrimaryActualLocation, _ta.allLocationsControllers.first);
	self.assertEqualMsg (ti1.CM_Container.availabilityGrade, 0, 'Availability grade is no longer 0');
	
	ti2 := self.addContainerOpts (CONTAINER2, ISOTYPE, "MT", _operator);
	
	self.assertEqual (ti2.consignee, _consigneeCode);
	self.assertEqual (ti2.consignor, _consignorCode);
	self.assertEqual (ti2.deliveryRelease, 'christina');
	self.assertEqual (ti2.CM_Container.availabilityGrade, 0);
	
	self.move (ti2, _ta);
	assertEqual(ti2.myPrimaryActualLocation, _ta.allLocationsControllers.first);
	self.assertEqualMsg (ti2.CM_Container.availabilityGrade, 0, 'Availability grade is no longer 0');
	
	train := self.addTrain(TRAIN,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	railArea := self.addRailArea(RAILAREA, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	
	self.assertNotNull(railIORake);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
		
	create pxyMaster transient;
	
	pxyMaster.setProxy(	WAGONMASTERCODE, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	// create wagon - no cargo 
	create tiColl transient;
	
	wagon := self.addWagonToTrainOption2(train, wagonMaster, tiColl, false);

	self.assertNotNullMsg(wagon, "Couldn't create a wagon");
	self.assertEqualMsg (ti1.CM_Container.availabilityGrade, 0, 'Availability grade is no longer 0');
	// we have a train and wgaon but it has not arrived yet
//	----------------------------------------------------------------
// 	create a new release request which we will change to rail later
//	----------------------------------------------------------------
	text 	:= self.zCoparn_mtrel_dates (_sender, ADD, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '1', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN1"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		isPartial := true;
	endif;
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);

	release := self.getReleaseRequest (RELEASEID);
	
	self.assertNotNull (release);
	self.assertEqualMsg (release.totalRequested, 1, 'Quantity is incorrect');
	self.assertTrueMsg (release.getAllAvailabilityGrades.includes (0), release.getAvailabilityGrades&amp;". Availability grade is not 0");
	self.assertEqualMsg (ti1.CM_Container.availabilityGrade, 0, 'Availability grade is no longer 0');
//	---------------------------------------------------------------------------------
// 	Change release type to rail - update the release request (change qty - no errors)
//	---------------------------------------------------------------------------------
	create coll transient;
	coll.add (release);
	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_ACTIVE, coll, app.myPassport);
	self.assertEqual (release.status, BR_ACTIVE);
	
	app.myTrxUA.trxSetReleaseRequestsType (BR_TYPE_RAIL, coll, app.myPassport);
	self.assertEqual (release.type, BR_TYPE_RAIL);
	
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN2"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);

	release := self.getReleaseRequest (RELEASEID);
	
	self.assertNotNull (release);
	self.assertEqualMsg (release.totalRequested, 2, 'Quantity has not been changed');
	self.assertTrueMsg (release.getAllAvailabilityGrades.includes (0), release.getAvailabilityGrades&amp;". Availability grade is not 0");
//	---------------------------------------------------------	
// 	assign to rail - try an update should be error
//	---------------------------------------------------------
	beginTransaction;
	release.setPropertyValue (CM_BulkRelease::mySubTerminal.name, ti1.mySubTerminal);
	commitTransaction;
	
	self.opts.addAssoc("release", release);
	
	// assign to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	
	cmifObjects.add(intFaceBP);
	
	intFaceBP.mode := 1;
	
	release.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	release.setInterfaceBP(intFaceBP, railIORake);
	
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	
	cmifRequest.quantityTxt := release.allReserveDetails.first.totalRequested;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	// At this point the releases are showing on the rail ops form but with no TI assigned
	self.assertEqualMsg (release.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN3"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, 'Verify should have failed');
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_ACTIONED, "Expecting error - release is actioned");
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
//	self.assertTrxErrorMsg(ReleaseBeingActioned, "Expecting error - can't DELETE (actioned)");	
//	----------------------------------------------------------------------------------------------------------
// 	assign TIs to the release, assign releases to wagon and complete the moves - try an update should be error
//	----------------------------------------------------------------------------------------------------------
	wle := release.allRequestsBeingActioned.first.allWorkListEntries.first;
	
	create controller transient;
	controller.setMyOriginatingLocation(ti1.myPrimaryActualLocation);
	controller.setMyTrackedItem(ti1);
	controller.setMyWorkListEntry(wle);
	self.assertEqualMsg (ti1.CM_Container.availabilityGrade, 0, 'Availability grade is no longer 0');
	app.myTrxUA.trxUpdateWLEAssignTI(controller, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	wle := release.allRequestsBeingActioned.first.allWorkListEntries.last;
	
	controller.setMyOriginatingLocation(ti2.myPrimaryActualLocation);
	controller.setMyTrackedItem(ti2);
	controller.setMyWorkListEntry(wle);

	app.myTrxUA.trxUpdateWLEAssignTI(controller, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(app.actualTimeServer);	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// now the train has arrived - assign the releases to the wagons and move cargo
	wle := release.allRequestsBeingActioned.first.allWorkListEntries.first;
	lc 	:= wagon.getNextFreeWagonContForRequest(wle.myRequest.CM_DeliveryRequest);
	
	app.myTrxUA.trxAssignWleToWagonController(wle.CM_YardWLE, 1, lc.CM_WagonController, false, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings ();
	
	self.queueWLE (wle);
	self.moveQueuedCargo (wle);
	
	wle := release.allRequestsBeingActioned.first.allWorkListEntries.last;
	lc 	:= wagon.getNextFreeWagonContForRequest(wle.myRequest.CM_DeliveryRequest);
	
	app.myTrxUA.trxAssignWleToWagonController(wle.CM_YardWLE, 1, lc.CM_WagonController, false, app.myPassport);

	self.assertNoTrxErrorsOrWarnings ();
	
	self.queueWLE (wle);
	self.moveQueuedCargo (wle);
	
	// now depart the train
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);  //iout
	
	// clear the entire train.
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add (wagon);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	// update should fail
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN4"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_COMPLETE, "Expecting error - can't UPDATE (completed)");
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
	// delete should fail
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN5"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_DEL_COMPLETED, "Expecting error - can't DELETE (complete)");
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
	
//	self.assertTrxErrorMsg(ReleaseRequestAlreadyHasItems, "Expecting error - can't DELETE (actioned)");	
//	-----------------------------------------
//	archive the release - update/delete should fail
//	-----------------------------------------	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_ARCHIVE, coll, app.myPassport);
	// update
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN6"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_ARCHIVED, "Expecting error - can't UPDATE (archived)");
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
	
	// delete
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN7"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_DEL_ARCHIVED, "Expecting error - can't DELETE (archived)");
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
	
//	self.assertTrxErrorMsg (ReleaseRequestAlreadyHasItems, "Expecting error - can't DELETE (archived)");

	//finished clean up
	self.deleteReleaseRequest (RELEASEID);
	self.deleteContainer (CONTAINER1);
	self.deleteContainer (CONTAINER2);
	wagonMaster := self.getRoot.allWagonMasters[WAGONMASTERCODE];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteTrain(TRAIN,null);
	self.deleteRailArea(RAILAREA);
	
epilog
	delete coll;
	delete tiColl;
	delete controller;
	delete pxyTrain;
	delete pxyMaster;
	delete trainSet;
	delete cmifRakeRegion;

	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_rules" type="CM_EDIPartyRules" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_UpdateChecksRoad" id="3285e810-b504-480e-8bb5-618df7fd0c5f">
        <source>doCoparn_UpdateChecksRoad(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode :String; 
							_operator :CM_Operator; _ta :CM_TerminalArea; _rules :CM_EDIPartyCoparnRules input) protected;
/*
Date		Who		Reason
30/04/2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
16/05/2012	cnwcs5	par 29575
03/09/2012	cnwcs5	par 30097
08/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 16 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
*/
constants
	RELEASEID = 'UT_RELROAD001';
	RELEASEID2 = 'UT_RELROAD002';
	RELEASEID3 = 'UT_RELROAD003';
	RELEASEID4 = 'UT_RELROAD004';
	CONTAINER = 'UT_TIROAD1';
	CONTAINER2 = 'UT_TIROAD2';
	VEHICLE = 'UT_TRUCK001';
	DRIVER = "CMS";
	ADD = '9';
	UPDATE = '5';
	DELETE = '1';
	MTGRADE	= 'DAIRY';
	ISOTYPE = '2200';
	MT = '4';
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDITrackedItem;
	release	:CM_BulkRelease;
	coll	:CM_BulkReleaseSet;
	ti		:CM_TrackedItem;
	vvr		:CM_VehicleVisitRecord;
	gate	:CM_Gate;
	wle		:CM_WorkListEntry;
	isPartial	:Boolean;
	ediItem : CM_EDITrackedItem;
begin
	isPartial := self.getTerminal().getConfig(EdiReleaseAllowPartial).Boolean;
//	-------------------------------------
//	get rid of left overs from last time
//	-------------------------------------
	self.deleteReleaseRequest (RELEASEID);
	self.deleteReleaseRequest (RELEASEID2);
	self.deleteReleaseRequest (RELEASEID3);
	self.deleteReleaseRequest (RELEASEID4);
	self.deleteContainer (CONTAINER);
	self.deleteContainer (CONTAINER2);
	self.deleteVehicle (VEHICLE);
//	-----------------------------------------------------------------
//	add cargo, truck, terminal area so we can assign release to truck
//	------------------------------------------------------------------
	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignee, _consigneeCode);
	self.opts.addAssociation(UTTI_Consignor, _consignorCode);
	self.opts.addAssociation(UTTI_DeliveryRelease, 'christina');
	self.opts.addAssociation('deliveryNumber', 'christina');
	self.opts.addAssociation(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	
	ti := self.addContainerOpts (CONTAINER, ISOTYPE, "MT", _operator);
	
	self.assertEqual (ti.consignee, _consigneeCode);
	self.assertEqual (ti.consignor, _consignorCode);
	self.assertEqual (ti.deliveryRelease, 'christina');
	
	self.move (ti, _ta);
	assertEqual(ti.myPrimaryActualLocation, _ta.allLocationsControllers.first);
	
	foreach gate in self.getTerminal.allGates do
		if not gate.hasPGateAreas then
			// single
			break;
		endif;
		gate := null;
	endforeach;
	
	self.assertNotNull (gate);
//	----------------------------------------------------------------
// 	create a new release request which we will change to road later
//	----------------------------------------------------------------
	text 	:= self.zCoparn_mtrel_dates (_sender, ADD, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '1', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN01"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		isPartial := true;
	endif;
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);

	release := self.getReleaseRequest (RELEASEID);
	
	self.assertNotNull (release);
	self.assertEqualMsg (release.totalRequested, 1, 'Quantity is incorrect');
//	---------------------------------------------------------------------------------
// 	Change release type to road - update the release request (change qty - no errors)
//	---------------------------------------------------------------------------------
	create coll transient;
	coll.add (release);
	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_ACTIVE, coll, app.myPassport);
	self.assertEqual (release.status, BR_ACTIVE);
	
	app.myTrxUA.trxSetReleaseRequestsType (BR_TYPE_ROAD, coll, app.myPassport);
	self.assertEqual (release.type, BR_TYPE_ROAD);
	
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN02 - update unactioned release"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);

	release := self.getReleaseRequest (RELEASEID);
	
	self.assertNotNull (release);
	self.assertEqualMsg (release.totalRequested, 2, 'Quantity has not been changed');
	
	
//	---------------------------------------------------------	
// 	load to road ops and set block actioned updates flag - should be error
//	---------------------------------------------------------
	beginTransaction;
	release.setPropertyValue (CM_BulkRelease::mySubTerminal.name, ti.mySubTerminal);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdActioned.name, false);
	commitTransaction;
	
	self.opts.addAssoc("release", release);
	vvr := self.gateOutContainer(VEHICLE, "", DRIVER, ti.CM_Container, true, gate , _ta.id);
	self.assertNotNull (vvr);
	
	// At this point there will be a queued entry on the road ops form
	self.assertEqualMsg (release.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, ti);

	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text,  EDIFileType_Coparn, "COPARN", "COPARN03 - test block updates actioned false"&amp;method.name);	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_ACTIONED, "Expecting error - can't UPDATE (actioned)");
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
	
	
//	---------------------------------------------------------	
// 	reset block actioned updates flag - should be OK to update
//	---------------------------------------------------------
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdActioned.name, true);
	commitTransaction;

	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN04 - test block updates actioned false"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');

	self.ediDBLoad(ediFile);
	
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');

//	------------------------------------------------------------------
// 	move container to truck and gate out - set block updates actioned - should be error on updating
//	------------------------------------------------------------------
	self.moveQueuedCargo (wle);
	self.roadExit (vvr);
	
	self.assertNullMsg (vvr.vehicle.myPrimaryActualLocation, 'Vehicle is still on site');
	
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdActioned.name, false);
	commitTransaction;
	
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN05 - test block updates actioned true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_ACTIONED, "Expecting error - can't UPDATE (actioned)");
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;

//	------------------------------------------------------------------
// 	reset block updates actioned - should be error on updating
//	------------------------------------------------------------------
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdActioned.name, true);
	commitTransaction;

	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN06 - test block updates actioned false"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');
	
//	---------------------------------------------------------	
// 	now try deleting with blocked deleted actioned - should be error
//	---------------------------------------------------------
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelActioned.name, false);
	commitTransaction;
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN07 - testing block deletes actioned true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg(EDI_RELEASE_DEL_ACTIONED, "Expecting error - can't DELETE (actioned)");
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;	
	
//	self.assertTrxErrorMsg(ReleaseRequestAlreadyHasItems, "Expecting error - can't DELETE (actioned)");	

//	-----------------------------------------
//	complete the release - update/delete should fail
//	-----------------------------------------	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_COMPLETE, coll, app.myPassport);
	self.assertEqual (release.status, BR_COMPLETE);

	
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdCompleted.name, false);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelCompleted.name, false);
	commitTransaction;
	
	// update
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN08 - tests block update completed true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_COMPLETE, "Expecting error - can't UPDATE (complete)");	
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
	
	// delete
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN09 - test block deletes completed true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_DEL_COMPLETED, "Expecting error - can't DELETE (complete)");
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
	
//	self.assertTrxErrorMsg(ReleaseRequestAlreadyHasItems, "Expecting error - can't DELETE (actioned)");	
	
//	-----------------------------------------
//	archive the release - update/delete should fail
//	-----------------------------------------	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_ARCHIVE, coll, app.myPassport);
	self.assertEqual (release.status, BR_ARCHIVE);
	
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdArchived.name, false);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelArchived.name, false);
	commitTransaction;

	// update
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN10 - tests block update archive true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_UPD_ARCHIVED, "Expecting error - can't UPDATE (archived)");	
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
	// delete
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN11 - test block delete archived true"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
//	if isPartial then
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, 'DB Load should have failed');
//	else
//	if ediTI.isKindOf(CM_EDIReleaseRequestTI) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, 'Verify should have failed');
		self.assertTrxErrorMsg (EDI_RELEASE_DEL_ARCHIVED, "Expecting error - can't DELETE (archived)");	
//	else
//		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'Verify should have failed');
//	endif;
	
//	self.assertTrxErrorMsg(ReleaseRequestAlreadyHasItems, "Expecting error - can't DELETE (actioned)");	

//	-----------------------------------------
//	reset false - update/delete should be OK
//	-----------------------------------------	
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdArchived.name, true);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelArchived.name, true);
	commitTransaction;


	// add release so we can set status to archive and test delete archive.
	text 	:= self.zCoparn_mtrel_dates (_sender, ADD, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID2, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN12 - add release to archive"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI; 
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	app.myPassport.clearErrorsWarnings;
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');

	release := self.getReleaseRequest (RELEASEID2);
	
	coll.clear; coll.add (release);
		
	app.myTrxUA.trxSetReleaseRequestsType (BR_TYPE_ROAD, coll, app.myPassport);
	self.assertEqual (release.type, BR_TYPE_ROAD);
	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_ARCHIVE, coll, app.myPassport);
	self.assertEqual (release.status, BR_ARCHIVE);

	// update
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID2, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN14 - tests block update archived false"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');

	// delete
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID2, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN15 - test block delete archived false"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');
	
//	-----------------------------------------
//	set completed flags to false - add then update/delete
//	-----------------------------------------	
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdCompleted.name, true);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelCompleted.name, true);
	commitTransaction;

	// add release so we can set status to complete and test delete complete.
	text 	:= self.zCoparn_mtrel_dates (_sender, ADD, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID3, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN16 - add release to be completed"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');

	// update
	text 	:= self.zCoparn_mtrel_dates (_sender, UPDATE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID3, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN17 - tests block update archive false"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');

	// delete
	release := self.getReleaseRequest (RELEASEID3);
	
	coll.clear; coll.add (release);
	
	app.myTrxUA.trxSetReleaseRequestsType (BR_TYPE_ROAD, coll, app.myPassport);
	self.assertEqual (release.type, BR_TYPE_ROAD);
	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_COMPLETE, coll, app.myPassport);
	self.assertEqual (release.status, BR_COMPLETE);

	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID3, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN18 - test block delete archived false"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
		
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');
//	----------------------------------------------------------------
// 	check block delete actioned false
//	----------------------------------------------------------------
	beginTransaction;
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelActioned.name, true);
	commitTransaction;
	text 	:= self.zCoparn_mtrel_dates (_sender, ADD, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID4, MTGRADE, ISOTYPE, '1', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN19 - add"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);

	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);

	release := self.getReleaseRequest (RELEASEID4);
	
	self.assertNotNull (release);

	coll.clear;
	coll.add (release);
	
	app.myTrxUA.trxSetReleaseRequestsStatus (BR_ACTIVE, coll, app.myPassport);
	self.assertEqual (release.status, BR_ACTIVE);
	
	app.myTrxUA.trxSetReleaseRequestsType (BR_TYPE_ROAD, coll, app.myPassport);
	self.assertEqual (release.type, BR_TYPE_ROAD);
	
	beginTransaction;
	release.setPropertyValue (CM_BulkRelease::mySubTerminal.name, ti.mySubTerminal);
	_rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdActioned.name, true);
	commitTransaction;
	
	ti := self.addContainerOpts (CONTAINER2, ISOTYPE, "MT", _operator);
	
	self.assertEqual (ti.consignee, _consigneeCode);
	self.assertEqual (ti.consignor, _consignorCode);
	self.assertEqual (ti.deliveryRelease, 'christina');
	
	self.move (ti, _ta);
	assertEqual(ti.myPrimaryActualLocation, _ta.allLocationsControllers.first);

	
	self.opts.addAssoc("release", release);
	vvr := self.gateOutContainer(VEHICLE, "", DRIVER, ti.CM_Container, true, gate , _ta.id);
	self.assertNotNull (vvr);
	
	// At this point there will be a queued entry on the road ops form
	self.assertEqualMsg (release.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, ti);
	
	// delete
	text 	:= self.zCoparn_mtrel_dates (_sender, DELETE, _voyageCode, _vesselName, _consignorCode, _consigneeCode, RELEASEID4, MTGRADE, ISOTYPE, '2', null, null, MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN20 - test block delete archived false"&amp;method.name);			
	
	self.assertNotNull(ediFile);
	
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');

//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	self.ediDBLoad(ediFile);
	
	self.assertNotEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DB Load should NOT have failed');	//wrong?
epilog

	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_rules" type="CM_EDIPartyCoparnRules" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_CCMS2243_byID" id="b3503964-6c9d-4f4a-842c-21419dc18132">
        <source>doCoparn_mtrel_CCMS2243_byID(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo:String; _operator :CM_Operator;  _ediPartyRules :CM_EDIPartyCoparnRules input)protected;
/*
Date		    Who		Reason
20/02/2013		cnwcs5	Initial creation - CCMS PNL 2243 / par 31185   
20 Aug 2013		cnwcs5	CCMS POL 2221 / par 32094(2)
// 17 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/
constants
	ISOTYPE 		= '2200';
	QUANTITY		= 1;
	CONTAINER1		= 'UT_2243011';
	CONTAINER2		= 'UT_2243022';
	VEHICLE			= 'UT_2243A';
	BS				= 'BS2243A';
	DRIVER			= 'CMS';
vars
	text			:String;
	ediFile			:CM_EDIFile;
	ediData			:CM_EDIData;
	ediHeaderTI			:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release			:CM_BulkRelease;
	item			:CM_ReserveTI;
	ediAgent		:CM_EDIControllerAgent;
	status, type	:Integer;
	resetComplete	:Boolean;
	ti				:CM_Container;
	ta				:CM_TerminalArea;
	gate			:CM_Gate;
	vvr				:CM_VehicleVisitRecord;
	wle				:CM_WorkListEntry;
	ediTI : CM_EDITrackedItem;
	allTis	: CM_TISet;
begin 
// 	---------------------------------------
// 	delete stuff from last time
// 	---------------------------------------
	self.deleteReleaseRequest(_releaseNo);
	self.deleteContainer (CONTAINER1);
	self.deleteContainer (CONTAINER2);
	self.deleteVehicle (VEHICLE);
	self.deleteTerminalArea (BS);
	self.deleteDriverDetails (DRIVER);
// 	---------------------------------------
// 	set defaults type/status to road/active
// 	---------------------------------------
	type 		:= _ediPartyRules.defaultReleaseType;
	status		:= _ediPartyRules.defaultReleaseStatus;
	resetComplete:= _ediPartyRules.resetCompletedOnQtyIncrease;
	
	create allTis transient;
	
	beginTransaction;
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_ROAD);
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::defaultReleaseStatus.name, BR_ACTIVE);
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::resetCompletedOnQtyIncrease.name, false);
	commitTransaction;

	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignee, _consigneeCode);
	self.opts.addAssociation(UTTI_Consignor, _consignorCode);
	self.opts.addAssociation(UTTI_DeliveryRelease, 'christina');
	self.opts.addAssociation('deliveryNumber', 'christina');
	self.opts.addAssociation(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	
	ti := self.addContainerOpts (CONTAINER1, ISOTYPE, 'MT', _operator).CM_Container;
	
	self.assertEqual (ti.consignee, _consigneeCode);
	self.assertEqual (ti.consignor, _consignorCode);
	self.assertEqual (ti.deliveryRelease, 'christina');
	
	ta := self.addBlockStack (BS, null, null);
	
	self.move (ti, ta);
	assertEqual(ti.myPrimaryActualLocation, ta.allLocationsControllers.first);
	
	foreach gate in self.getTerminal.allGates do
		if not gate.hasPGateAreas then
			// single
			break;
		endif;
		gate := null;
	endforeach;
	
	self.assertNotNull (gate);

// 	--------------------------------------------------------------------------------------------------------------------------
// 	get edi file to load - adding release, invalid voyage should be used for EDI TI, default voyage should be used for release
// 	--------------------------------------------------------------------------------------------------------------------------
	text := self.zCoparn_mtrel_CCMS2243_byID("12", '9', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, CONTAINER1);
//  ---------------------------------------
//  load edi file to create EDI tracked items
//  ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN1"&amp;method.name);
	self.assertNotNull(ediFile);
//  ---------------------------------------
//  find the release request ediData
//  ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	self.assertNotNullMsg(ediData, 'No edi data for release requests');
// 	---------------------------------------
// 	find the edi tracked item
// 	---------------------------------------
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediTI in ediData.allEDITrackedItems do
			if  ediTI.isKindOf(CM_EDIRequestHeaderTI) then
				ediHeaderTI := ediTI.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediHeaderTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediHeaderTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName, _operator.code, _consignorCode, _consigneeCode, ISOTYPE, null,null, null, 1, _ediPartyRules, null, null, false, true, false, false, false, false);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediTI in ediData.allEDITrackedItems do
			if  ediTI.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediTI.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName, _operator.code, _consignorCode, _consigneeCode, ISOTYPE, null,null, null, 1, _ediPartyRules, null, null, false, true, false, false, false, false);
	endif;
// 	destination - LOC+8+AUMEL:139:6'
	if ediHeaderTI &lt;&gt; null then
		self.assertEqualMsg(ediHeaderTI.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
	// 	load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg(ediHeaderTI.loadPort, "NZPOE", "Load port should be NZPOE");
	// 	discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg(ediHeaderTI.dischargePort, "NZAKL", "Destination shoudl be NZAKL");
	endif;
	if ediRelReq &lt;&gt; null then
	// 	destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg(ediRelReq.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
	// 	load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg(ediRelReq.loadPort, "NZPOE", "Load port should be NZPOE");
	// 	discharge port - LOC+11+NZAKL:139:6'
	self.assertEqualMsg(ediRelReq.dischargePort, "NZAKL", "Destination shoudl be NZAKL");
	endif;
// 	---------------------------------------
// 	do verify(all edi data)  
// 	---------------------------------------
	self.ediVerify(ediFile);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, 'Expecting status of verify' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	load to DB
// 	---------------------------------------
	self.ediDBLoad(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	find the release
// 	---------------------------------------
	release := self.getReleaseRequest(_releaseNo);		self.assertNotNull(release);
// 	---------------------------------------
// 	do standard checks
// 	---------------------------------------
	self.doCheckPartyRules_AddRelease(release, _ediPartyRules, false, true, false);
	
	self.assertFalseMsg(release.releaseByType, 'Release by ID is not set');
	self.assertEqualMsg(release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg(release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg(release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg(release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertFalseMsg(release.needsReview, 'Needs review should not be set');
	self.assertEqualMsg(release.mySubTerminal, _ediPartyRules.myDefaultSubTerminal, "Sub Terminal incorrect");
	self.assertEqualMsg(release.carrierId, "UT_OTHER", "Carrier Id incorrect");
	self.assertEqualMsg(release.type, BR_TYPE_ROAD, "Type is incorrect");
	self.assertEqualMsg(release.status, BR_ACTIVE, "Status is incorrect");
	self.assertEqualMsg(release.myVoyage.code, _voyageCode, "MyVoyage is incorrect");
	self.assertEqualMsg(release.deliveryReasonCode, DEL_SNT, "my delivery Release Code is incorrect");
//	self.assertEqualMsg(release.getAllAvailabilityGrades.first, 4, release.getAvailabilityGrades&amp;". The Availability Grade is incorrect");
	
	item := release.allReserveDetails.first.CM_ReserveTI;
	
	self.assertNotNull(item);
	item.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	self.assertEqualMsg(allTis.size, 1, 'Total requested not set');
	self.assertTrueMsg(allTis.includes(ti), 'Release does not include container');
	
	// check ediFile collection has been updated
	self.assertTrueMsg(release.allEDIFiles.includes(ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg(release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');

// 	---------------------------------------
// 	load to road ops and complete release
// 	---------------------------------------
	
	beginTransaction;
	release.setPropertyValue (CM_BulkRelease::mySubTerminal.name, ti.mySubTerminal);
	commitTransaction;
	
	self.opts.addAssoc("release", release);
	
	vvr := self.gateOutContainer(VEHICLE, "", DRIVER, ti.CM_Container, true, gate , ta.id);
	self.assertNotNull (vvr);
	
	// At this point there will be a queued entry on the road ops form
	self.assertEqualMsg (release.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, ti);

	self.moveQueuedCargo (wle);
	self.roadExit (vvr);
	
	self.assertNullMsg (vvr.vehicle.myPrimaryActualLocation, 'Vehicle is still on site');
	
	self.assertTrueMsg (release.status = BR_COMPLETE, 'Release Should be completed'); 
	self.assertTrueMsg (release.getTotalReleased = 1, 'Release should have 1 item released');  
//	----------------------------------------------------------------------------------------------------------------------------
// 	make sure we can update a completed release
//	-----------------------------------------------------------------------------------------------------------------------------	
	beginTransaction;
	_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdCompleted.name, true);
	commitTransaction;
//	----------------------------------------------------------------------------------------------------------------------------
// 	create a second tracked item for the release
//	-----------------------------------------------------------------------------------------------------------------------------
	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignee, _consigneeCode);
	self.opts.addAssociation(UTTI_Consignor, _consignorCode);
	self.opts.addAssociation(UTTI_DeliveryRelease, 'christina');
	self.opts.addAssociation('deliveryNumber', 'christina');
	self.opts.addAssociation(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	
	ti := self.addContainerOpts (CONTAINER2, ISOTYPE, 'MT', _operator).CM_Container;
//	----------------------------------------------------------------------------------------------------------------------------
// 	now update the release - change the tracked item.  release should still stay completed (this time)
//	-----------------------------------------------------------------------------------------------------------------------------
	text := self.zCoparn_mtrel_CCMS2243_byID2("12", '9', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, CONTAINER1, CONTAINER2);
// 	---------------------------------------
// 	load edi file to create EDI tracked items
// 	---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN2"&amp;method.name);
	self.assertNotNull(ediFile);
// 	---------------------------------------
// 	find the release request ediData
// 	---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg(ediData, 'No edi data for release');
// 	---------------------------------------
// 	do verify(all edi data)  
// 	---------------------------------------
	self.ediVerify(ediFile);		
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	load to DB
// 	---------------------------------------
	self.ediDBLoad(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	find the release
// 	---------------------------------------
	release := self.getReleaseRequest(_releaseNo);
	self.assertNotNull(release);
	// because the release is complete any unused TIs will be detached so we should just have our original in there
	self.assertEqualMsg(release.type, BR_TYPE_ROAD, "Type is incorrect");
	self.assertEqualMsg(release.status, BR_COMPLETE, "Status is incorrect");
	self.assertEqualMsg (release.getTotalRequested, 1, "Quantity is incorrect after UPDATE"); 
	
	beginTransaction;
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::resetCompletedOnQtyIncrease.name, true);
	commitTransaction;

// 	---------------------------------------
// 	load same edi file to create EDI tracked items
// 	---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN3"&amp;method.name);
	self.assertNotNull(ediFile);
// 	---------------------------------------
// 	find the release request ediData
// 	---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg(ediData, 'No edi data for release');

// 	---------------------------------------
// 	verify then load  same edi file to create EDI tracked items
// 	---------------------------------------
	self.ediVerify(ediFile);		
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
	
	self.ediDBLoad(ediFile);		
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);

// 	---------------------------------------
// 	find the release
// 	---------------------------------------
	release := self.getReleaseRequest(_releaseNo);
	self.assertNotNull(release);
	// now the release should be active
	self.assertEqualMsg(release.type, BR_TYPE_ROAD, "Type is incorrect");
	self.assertEqualMsg(release.status, BR_ACTIVE, "Status is incorrect");
	self.assertEqualMsg (release.getTotalRequested, 2, "Quantity is incorrect after UPDATE"); 
	
// 	---------------------------------------
// 	reset default type/status  
// 	---------------------------------------	
	beginTransaction;
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::defaultReleaseType.name, type);
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::defaultReleaseStatus.name, status);
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::resetCompletedOnQtyIncrease.name, resetComplete);
	commitTransaction;
epilog
	delete 	ediAgent;
	delete allTis;
end;

</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_releaseNo" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_CCMS2243_byType" id="13a0b39a-b248-4e87-a1d0-2d9e063b634d">
        <source>doCoparn_mtrel_CCMS2243_byType(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo:String; _operator :CM_Operator;  _ediPartyRules :CM_EDIPartyCoparnRules input)protected;
/*
Date		    Who		Reason
20/02/2013		cnwcs5	Initial creation - CCMS PNL 2243 / par 31185 
20 Aug 2013		cnwcs5	CCMS POL 2221 / par 32094(2)  
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
constants
	ISOTYPE 		= '22G1';
	QUANTITY		= 1;
	CONTAINER1		= 'UT_2243001';
	CONTAINER2		= 'UT_2243002';
	VEHICLE			= 'UT_2243';
	BS				= 'BS2243';
vars
	text, code		:String;
	ediFile			:CM_EDIFile;
	ediData			:CM_EDIData;
	ediTI			:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release			:CM_BulkRelease;
	item			:CM_ReserveSelection;
	ediAgent		:CM_EDIControllerAgent;
	status, type	:Integer;
	resetComplete	:Boolean;
	ti				:CM_Container;
	ta				:CM_TerminalArea;
	gate			:CM_Gate;
	vvr				:CM_VehicleVisitRecord;
	wle				:CM_WorkListEntry;
	terminal		:CM_Terminal;
	subTerminal		:CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
begin 
// 	---------------------------------------
// 	delete stuff from last time
// 	---------------------------------------
	self.deleteReleaseRequest(_releaseNo);
	self.deleteContainer (CONTAINER1);
	self.deleteContainer (CONTAINER2);
	self.deleteVehicle (VEHICLE);
	self.deleteTerminalArea (BS);
// 	---------------------------------------
// 	set defaults type/status to road/active
// 	---------------------------------------
	type 			:= _ediPartyRules.defaultReleaseType;
	status			:= _ediPartyRules.defaultReleaseStatus;
	resetComplete	:= _ediPartyRules.resetCompletedOnQtyIncrease;
	terminal		:= self.getTerminal;
	
	if terminal.isSubTerminalsOn then
		subTerminal		:= terminal.getDefaultSubTerminal (CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;
	
	beginTransaction;
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_ROAD);
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::defaultReleaseStatus.name, BR_ACTIVE);
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::resetCompletedOnQtyIncrease.name, false);
		
		if terminal.isSubTerminalsOn then
			_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
		endif;
	commitTransaction;
	
// 	--------------------------------------------------------------------------------------------------------------------------
// 	get edi file to load - adding release, invalid voyage should be used for EDI TI, default voyage should be used for release
// 	--------------------------------------------------------------------------------------------------------------------------
	text := self.zCoparn_mtrel_CCMS2243_byType("12", '9', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ISOTYPE, QUANTITY.String);
//  ---------------------------------------
//  load edi file to create EDI tracked items
//  ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN1"&amp;method.name);
	self.assertNotNull(ediFile);
//  ---------------------------------------
//  find the release request ediData
//  ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	self.assertNotNullMsg(ediData, 'No edi data for release requests');
// 	---------------------------------------
// 	find the edi tracked item
// 	---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;		
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, null,null, null, QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, null,null, null, QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediTI &lt;&gt; null then
	// 	destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg(ediTI.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
	// 	load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg(ediTI.loadPort, "NZPOE", "Load port should be NZPOE");
	// 	discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg(ediTI.dischargePort, "NZAKL", "Destination shoudl be NZAKL");
	endif;
	if ediRelReq &lt;&gt; null then
	// 	destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg(ediRelReq.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
	// 	load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg(ediRelReq.loadPort, "NZPOE", "Load port should be NZPOE");
	// 	discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg(ediRelReq.dischargePort, "NZAKL", "Destination shoudl be NZAKL");
	endif;
// 	---------------------------------------
// 	do verify(all edi data)  
// 	---------------------------------------
	self.ediVerify(ediFile);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, 'Expecting status of verify' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	load to DB
// 	---------------------------------------
	self.ediDBLoad(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	find the release
// 	---------------------------------------
	release := self.getReleaseRequest(_releaseNo);		self.assertNotNull(release);
// 	---------------------------------------
// 	do standard checks
// 	---------------------------------------
	self.doCheckPartyRules_AddRelease(release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg(release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg(release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg(release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg(release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg(release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertFalseMsg(release.needsReview, 'Needs review should not be set');
	self.assertEqualMsg(release.mySubTerminal, _ediPartyRules.myDefaultSubTerminal, "Sub Terminal incorrect");
	self.assertEqualMsg(release.carrierId, "UT_OTHER", "Carrier Id incorrect");
	self.assertEqualMsg(release.type, BR_TYPE_ROAD, "Type is incorrect");
	self.assertEqualMsg(release.status, BR_ACTIVE, "Status is incorrect");
	self.assertEqualMsg(release.myVoyage.code, _voyageCode, "MyVoyage is incorrect");
	self.assertEqualMsg(release.deliveryReasonCode, DEL_SNT, "my delivery Release Code is incorrect");
	self.assertEqualMsg(release.getAllAvailabilityGrades.first, 4, release.getAvailabilityGrades&amp;". The Availability Grade is incorrect");
	
	item := release.allReserveDetails.first.CM_ReserveSelection;
	
	self.assertNotNull(item);
	self.assertNotNullMsg(item.myISOType, 'ISO Type not set');
	self.assertEqualMsg(item.myISOType.code, ISOTYPE, 'ISO type is incorrect');
	self.assertEqualMsg(item.totalRequested, QUANTITY, 'Total requested not set');
	
	// check ediFile collection has been updated
	self.assertTrueMsg(release.allEDIFiles.includes(ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg(release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');

// 	---------------------------------------
// 	load to road ops and complete release
// 	---------------------------------------
	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignee, _consigneeCode);
	self.opts.addAssociation(UTTI_Consignor, _consignorCode);
	self.opts.addAssociation(UTTI_DeliveryRelease, 'christina');
	self.opts.addAssociation('deliveryNumber', 'christina');
	self.opts.addAssociation(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	
	ti := self.addContainerOpts (CONTAINER1, ISOTYPE, 'GENL', _operator).CM_Container;
	
	self.assertEqual (ti.consignee, _consigneeCode);
	self.assertEqual (ti.consignor, _consignorCode);
	self.assertEqual (ti.deliveryRelease, 'christina');
	
	ta := self.addBlockStack (BS, null, null);
	
	self.move (ti, ta);
	assertEqual(ti.myPrimaryActualLocation, ta.allLocationsControllers.first);
	
	foreach gate in self.getTerminal.allGates do
		if not gate.hasPGateAreas then
			// single
			break;
		endif;
		gate := null;
	endforeach;
	
	self.assertNotNull (gate);
	
	beginTransaction;
	release.setPropertyValue (CM_BulkRelease::mySubTerminal.name, subTerminal);
	ti.setPropertyValue (CM_TrackedItem::mySubTerminal.name, subTerminal);
	commitTransaction;
	
	self.opts.addAssoc("release", release);
	vvr := self.gateOutContainer(VEHICLE, "", self.getDriverName , ti.CM_Container, true, gate , ta.id);
	self.assertNotNull (vvr);
	
	// At this point there will be a queued entry on the road ops form
	self.assertEqualMsg (release.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, ti);

	self.moveQueuedCargo (wle);
	self.roadExit (vvr);
	
	self.assertNullMsg (vvr.vehicle.myPrimaryActualLocation, 'Vehicle is still on site');
	
	self.assertTrueMsg (release.isComplete, 'Release Should be completed - 1 item released');
//	----------------------------------------------------------------------------------------------------------------------------
// 	make sure we can update a completed release
//	-----------------------------------------------------------------------------------------------------------------------------	
	beginTransaction;
	_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdCompleted.name, true);
	commitTransaction;

//	----------------------------------------------------------------------------------------------------------------------------
// 	now update the release - increase the quantity
//	-----------------------------------------------------------------------------------------------------------------------------
	text := self.zCoparn_mtrel_CCMS2243_byType("12", '5', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ISOTYPE, (QUANTITY+1).String);
// 	---------------------------------------
// 	load edi file to create EDI tracked items
// 	---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN2"&amp;method.name);
	self.assertNotNull(ediFile);
// 	---------------------------------------
// 	find the release request ediData
// 	---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg(ediData, 'No edi data for booking');
// 	---------------------------------------
// 	do verify(all edi data)  
// 	---------------------------------------
	self.ediVerify(ediFile);		
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	load to DB
// 	---------------------------------------
	self.ediDBLoad(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	find the release
// 	---------------------------------------
	release := self.getReleaseRequest(_releaseNo);
	self.assertNotNull(release);
	self.assertEqualMsg(release.type, BR_TYPE_ROAD, "Type is incorrect");
	self.assertEqualMsg(release.status, BR_COMPLETE, "Status is incorrect");
	self.assertEqualMsg (release.getTotalRequested, QUANTITY+1, "Quantity is incorrect after UPDATE");
	
// 	---------------------------------------------
// 	load to road ops and complete release (again)
// 	---------------------------------------------
	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignee, _consigneeCode);
	self.opts.addAssociation(UTTI_Consignor, _consignorCode);
	self.opts.addAssociation(UTTI_DeliveryRelease, 'christina');
	self.opts.addAssociation('deliveryNumber', 'christina');
	self.opts.addAssociation(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	
	ti := self.addContainerOpts (CONTAINER2, ISOTYPE, 'GENL', _operator).CM_Container;
	
	self.assertEqual (ti.consignee, _consigneeCode);
	self.assertEqual (ti.consignor, _consignorCode);
	self.assertEqual (ti.deliveryRelease, 'christina');
	
	self.move (ti, ta);
	assertEqual(ti.myPrimaryActualLocation, ta.allLocationsControllers.first);
	
	beginTransaction;
	release.setPropertyValue (CM_BulkRelease::mySubTerminal.name, subTerminal);
	ti.setPropertyValue (CM_TrackedItem::mySubTerminal.name, subTerminal);
	commitTransaction;
	
	self.opts.addAssoc("release", release);
	vvr := self.gateOutContainer(VEHICLE, "", self.getDriverName , ti.CM_Container, true, gate , ta.id);
	self.assertNotNull (vvr);
	
	// At this point there will be a queued entry on the road ops form
	self.assertEqualMsg (release.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, ti);

	self.moveQueuedCargo (wle);
	self.roadExit (vvr);
	
	self.assertNullMsg (vvr.vehicle.myPrimaryActualLocation, 'Vehicle is still on site');
	
	self.assertTrueMsg (release.isComplete, 'Release Should be completed - 1 item released');	
	self.assertEqualMsg (release.getTotalReleased, 2, 'Number released should be 2');	
	
	beginTransaction;
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::resetCompletedOnQtyIncrease.name, true);
	commitTransaction;
	
//	------------------------------------------------
// 	now update the release - increase quantity by 1
//	------------------------------------------------
	text := self.zCoparn_mtrel_CCMS2243_byType("12", '5', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ISOTYPE, (QUANTITY+2).String);
// 	---------------------------------------
// 	load edi file to create EDI tracked items
// 	---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN3"&amp;method.name);
	self.assertNotNull(ediFile);
// 	---------------------------------------
// 	find the release request ediData
// 	---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg(ediData, 'No edi data for release');
// 	---------------------------------------
// 	do verify(all edi data)  
// 	---------------------------------------
	self.ediVerify(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	load to DB
// 	---------------------------------------
	self.ediDBLoad(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	find the release
// 	---------------------------------------
	release := self.getReleaseRequest(_releaseNo);
	self.assertNotNull(release);
	self.assertEqualMsg(release.type, BR_TYPE_ROAD, "Type is incorrect");
	self.assertEqualMsg(release.status, BR_ACTIVE, "Status is should be active");
	self.assertEqualMsg(release.getTotalOutstanding, 1, "Total outstanding should be 1");
// 	---------------------------------------
// 	reset default type/status  
// 	---------------------------------------	
	beginTransaction;
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::defaultReleaseType.name, type);
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::defaultReleaseStatus.name, status);
		_ediPartyRules.setPropertyValue (CM_EDIPartyCoparnRules::resetCompletedOnQtyIncrease.name, resetComplete);
	commitTransaction;
epilog
	delete 	ediAgent;
end;

</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_releaseNo" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_DefaultUpdate" id="43152b92-bb22-4569-8802-0b9ac06a5c42">
        <source>doCoparn_mtrel_DefaultUpdate(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo:String; _mt :Character; _operator :CM_Operator;  _ediPartyRules :CM_EDIPartyCoparnRules io)protected;
/*
Date		        Who		Reason
12 Mar 2012	        cnwrs1	Initial creation - PAR29264 update default values
26 Mar 2012	        cnwrs1	Par 29321 add other changed value tests
07/05/0212	        cnwcms5	par 29402 - checks for adding/updating default voyage
23/08/2012	        cnwcs5	par 30096
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
08/08/2013			cnwcs5	CCMS POL 2221 / par 32094(2)
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
constants
	ADDITIONAL_TEXT	= "//IF NO 20GP AVAILABLE PLEASE RELEASE DAIRY UNITS";
	ISOTYPE 		= '22G1';
	QUANTITY		= 10;
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	item	:CM_ReserveSelection;
	ediAgent: CM_EDIControllerAgent;
	subTerminal : CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
begin
// 	---------------------------------------
// 	delete the release if it already exists
// 	---------------------------------------
	self.deleteReleaseRequest(_releaseNo);
// 	--------------------------------------------------------------------------------------------------------------------------
// 	get edi file to load - adding release, invalid voyage should be used for EDI TI, default voyage should be used for release
// 	--------------------------------------------------------------------------------------------------------------------------
	text := self.zCoparn_mtrel_DefaultUpdate("12", '9', _sender, "ABC123", _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);
//  ---------------------------------------
//  load edi file to create EDI tracked items
//  ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN DEFAULT UPDATE1"&amp;method.name);
	self.assertNotNull(ediFile);
//  ---------------------------------------
//  find the release request ediData
//  ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	self.assertNotNullMsg(ediData, 'No edi data for release requests');
// 	---------------------------------------
// 	find the edi tracked item
// 	---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, "ABC123", _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, "ABC123", _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediTI &lt;&gt; null then
	// 	destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg(ediTI.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
	// 	load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg(ediTI.loadPort, "NZPOE", "Load port should be NZPOE");
	// 	discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg(ediTI.dischargePort, "NZAKL", "Destination shoudl be NZAKL");
	endif;
	if ediRelReq &lt;&gt; null then
	// 	destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg(ediRelReq.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
	// 	load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg(ediRelReq.loadPort, "NZPOE", "Load port should be NZPOE");
	// 	discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg(ediRelReq.dischargePort, "NZAKL", "Destination shoudl be NZAKL");
	endif;
// 	---------------------------------------
// 	do verify(all edi data)  
// 	---------------------------------------
	self.ediVerify(ediFile);
	self.assertTrxWarning(ERR_INVALID_VOYAGE);	// expecting warning in this case
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, 'Expecting status of verify warnings' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	load to DB
// 	---------------------------------------
	self.ediDBLoad(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	find the release
// 	---------------------------------------
	release := self.getReleaseRequest(_releaseNo);		self.assertNotNull(release);
// 	---------------------------------------
// 	do standard checks
// 	---------------------------------------
	self.doCheckPartyRules_AddRelease(release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg(release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg(release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg(release.myVoyage.code, "UT_HOLD" &amp; self.getTerminal.code, 'Voyage code is incorrect');
	self.assertEqualMsg(release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg(release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertFalseMsg(release.needsReview, 'Needs review should not be set');
	// we expect the release cargo remarks to include the addition text
	item := release.allReserveDetails.first.CM_ReserveSelection;		
	self.assertNotNull(item);
	self.assertTrueMsg(item.remarks.pos(ADDITIONAL_TEXT, 1) &gt; 0, 'Additionl text from FTX+AAI not stored in cargo remarks');
	self.assertTrueMsg(item.remarks.pos("TEXTSIN", 1) &gt; 0, 'Additionl text from FTX+SIN not stored in cargo remarks');
	self.assertTrueMsg(item.remarks.pos("TEXTHAN", 1) &gt; 0, 'Additionl text from FTX+HAN not stored in cargo remarks');
	self.assertNotNullMsg(item.myISOType, 'ISO Type not set');
	self.assertEqualMsg(item.myISOType.code, ISOTYPE, 'ISO type is incorrect');
	// Availability grade - defaults for this file
	
	// total requested
	self.assertEqualMsg(item.totalRequested, QUANTITY, 'Total requested not set');
	// check ediFile collection has been updated
	self.assertTrueMsg(release.allEDIFiles.includes(ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg(release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');
	self.assertEqualMsg(release.mySubTerminal, _ediPartyRules.myDefaultSubTerminal, "Sub Terminal incorrect");
	self.assertEqualMsg(release.carrierId, "UT_OTHER", "Carrier Id incorrect");
	self.assertEqualMsg(release.type, BR_TYPE_UNKNOWN, "Type is incorrect");
	self.assertEqualMsg(release.status, BR_PENDING, "Status is incorrect");
	self.assertEqualMsg(release.myVoyage.code, "UT_HOLD" &amp; self.getTerminal.code, "MyVoyage is incorrect");
	self.assertEqualMsg(release.deliveryReasonCode, DEL_SNT, "my delivery Release Code is incorrect");
	self.assertEqualMsg(release.getAllAvailabilityGrades.first, 4, release.getAvailabilityGrades&amp;". The Availability Grade is incorrect");

	foreach subTerminal in self.getTerminal.allSubTerminals do
		if subTerminal &lt;&gt; _ediPartyRules.myDefaultSubTerminal then
			// just looking for another sub terminal
			break;
		endif;
	endforeach;
	
	beginTransaction;
	release.setPropertyValue(CM_BulkRelease::mySubTerminal.name, subTerminal);
	release.setPropertyValue(CM_BulkRelease::carrierId.name, "UTCAR2");
	release.setPropertyValue(CM_BulkRelease::type.name, BR_TYPE_ROAD);
	release.setPropertyValue(CM_BulkRelease::status.name, BR_ACTIVE);
	release.setPropertyValue(CM_BulkRelease::deliveryReasonCode.name, DEL_SNT);
	release.setPropertyValue(CM_BulkRelease::bookingConfirmation.name, "Booking Confirmed");
	release.setPropertyValue(CM_BulkRelease::canBeHiLoCube.name, true);
	release.setPropertyValue(CM_BulkRelease::doorsDirection.name, TI_DOORSDIRN_FWD);
	release.setPropertyValue(CM_BulkRelease::dispatchLocation.name, "Outer Space");
	release.allPackLocations.add("Pack1");
	release.allPackLocations.add("Pack2");
	release.setPropertyValue(CM_BulkRelease::myAssignedTrain.name, CM_Train.firstInstance);
	release.setPropertyValue(CM_BulkRelease::myPoolPartner.name, CM_Operator.firstInstance);
	release.setPropertyValue(CM_BulkRelease::mySubTerminalTarget.name, CM_SubTerminal.firstInstance);
//	item.setPropertyValue(CM_ReserveSelection::allAvailabilityGrades.name, "");
	release.allReserveDetails.first.CM_ReserveSelection.allAvailabilityGrades.clear();
	release.allReserveDetails.first.CM_ReserveSelection.allAvailabilityGrades.add(2);
//	release.allAvailabilityGrades.add(5);
	commitTransaction;
//	----------------------------------------------------------------------------------------------------------------------------
// 	now update the release - none of the default fields should be updated. Voyage is invalid in the file but the release is for the 
//	default voyage so it should just cause a warning (par 30096)
//	-----------------------------------------------------------------------------------------------------------------------------
	text := self.zCoparn_mtrel_DefaultUpdate("12", '5', _sender, "ABC4345", _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);
// 	---------------------------------------
// 	load edi file to create EDI tracked items
// 	---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN2"&amp;method.name);
	self.assertNotNull(ediFile);
// 	---------------------------------------
// 	find the release request ediData
// 	---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg(ediData, 'No edi data for booking');
// 	---------------------------------------
// 	do verify(all edi data)  
// 	---------------------------------------
	self.ediVerify(ediFile);		
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
	self.assertTrxWarning (ERR_INVALID_VOYAGE);
// 	---------------------------------------
// 	load to DB
// 	---------------------------------------
	self.ediDBLoad(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	find the release
// 	---------------------------------------
	release := self.getReleaseRequest(_releaseNo);
	self.assertNotNull(release);
	self.assertEqualMsg(release.mySubTerminal, subTerminal, "Sub Terminal incorrect");
	self.assertEqualMsg(release.carrierId, "UTCAR2", "Carrier Id incorrect");
	self.assertEqualMsg(release.type, BR_TYPE_ROAD, "Type is incorrect");
	self.assertEqualMsg(release.status, BR_ACTIVE, "Status is incorrect");
	self.assertEqualMsg(release.myVoyage.code, "UT_HOLD" &amp; self.getTerminal.code, "MyVoyage is incorrect"); 
	self.assertEqualMsg(release.deliveryReasonCode, DEL_SNT, "my delivery Release number is incorrect");
	self.assertEqualMsg(release.getAllAvailabilityGrades.first, 4, release.getAvailabilityGrades&amp;". The Availability Grade is incorrect");
	self.assertEqualMsg(release.bookingConfirmation, "Booking Confirmed", "the Booking bookingConfirmation is incorrect");
	self.assertEqualMsg(release.canBeHiLoCube, true, "the Booking canBeHiLoCube is incorrect");
	self.assertEqualMsg(release.doorsDirection, TI_DOORSDIRN_FWD, "the Booking doorsDirection is incorrect");
	self.assertEqualMsg(release.dispatchLocation, "Outer Space", "the Booking dispatchLocation is incorrect");
	self.assertEqualMsg(release.myAssignedTrain, CM_Train.firstInstance, "the Booking myAssignedTrain is incorrect");
	self.assertEqualMsg(release.myPoolPartner, CM_Operator.firstInstance, "the Booking myPoolPartner is incorrect");
	self.assertEqualMsg(release.mySubTerminalTarget, CM_SubTerminal.firstInstance, "the Booking mySubTerminalTarget is incorrect");
	
//	----------------------------------------------------------------------------------------------------------------------------
// 	now update the release - none of the default fields should be updated. Voyage is valid in the file so this should be updated
//	-----------------------------------------------------------------------------------------------------------------------------
	text := self.zCoparn_mtrel_DefaultUpdate("12", '5', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);
// 	---------------------------------------
// 	load edi file to create EDI tracked items
// 	---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN3"&amp;method.name);
	self.assertNotNull(ediFile);
// 	---------------------------------------
// 	find the release request ediData
// 	---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg(ediData, 'No edi data for booking');
// 	---------------------------------------
// 	do verify(all edi data)  
// 	---------------------------------------
	self.ediVerify(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	load to DB
// 	---------------------------------------
	self.ediDBLoad(ediFile);		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString);
// 	---------------------------------------
// 	find the release
// 	---------------------------------------
	release := self.getReleaseRequest(_releaseNo);
	self.assertNotNull(release);
	self.assertEqualMsg(release.mySubTerminal, subTerminal, "Sub Terminal incorrect");
	self.assertEqualMsg(release.carrierId, "UTCAR2", "Carrier Id incorrect");
	self.assertEqualMsg(release.type, BR_TYPE_ROAD, "Type is incorrect");
	self.assertEqualMsg(release.status, BR_ACTIVE, "Status is incorrect");
	self.assertEqualMsg(release.myVoyage.code, _voyageCode, "MyVoyage is incorrect");
	self.assertEqualMsg(release.deliveryReasonCode, DEL_SNT, "my delivery Release number is incorrect");
	self.assertEqualMsg(release.getAllAvailabilityGrades.first, 4, release.getAvailabilityGrades&amp;". The Availability Grade is incorrect");
	self.assertEqualMsg(release.bookingConfirmation, "Booking Confirmed", "the Booking bookingConfirmation is incorrect");
	self.assertEqualMsg(release.canBeHiLoCube, true, "the Booking canBeHiLoCube is incorrect");
	self.assertEqualMsg(release.doorsDirection, TI_DOORSDIRN_FWD, "the Booking doorsDirection is incorrect");
	self.assertEqualMsg(release.dispatchLocation, "Outer Space", "the Booking dispatchLocation is incorrect");
	self.assertEqualMsg(release.myAssignedTrain, CM_Train.firstInstance, "the Booking myAssignedTrain is incorrect");
	self.assertEqualMsg(release.myPoolPartner, CM_Operator.firstInstance, "the Booking myPoolPartner is incorrect");
	self.assertEqualMsg(release.mySubTerminalTarget, CM_SubTerminal.firstInstance, "the Booking mySubTerminalTarget is incorrect");
//	----------------------------------------------------------------------------------------
// 	now update the release - Voyage is invalid in the file so there should be a verify error
//	-----------------------------------------------------------------------------------------
	text := self.zCoparn_mtrel_DefaultUpdate("12", '5', _sender, "ABC124", _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);
// 	---------------------------------------
// 	load edi file to create EDI tracked items
// 	---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN4"&amp;method.name);
	self.assertNotNull(ediFile);
// 	---------------------------------------
// 	find the release request ediData
// 	---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg(ediData, 'No edi data for booking');
// 	---------------------------------------
// 	do verify(all edi data)  
// 	---------------------------------------
	self.ediVerify(ediFile);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, 'Verify should have failed');
	self.assertTrxError (ERR_INVALID_VOYAGE);
epilog
	delete 	ediAgent;
end;

</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_releaseNo" type="String"/>
        <Parameter name="_mt" type="Character"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_DeleteAndAdd" id="f59ce76a-154d-44c8-8adc-22af12f568c1">
        <source>doCoparn_mtrel_DeleteAndAdd(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseAdd, _releaseDel :String; _mt :Character; _operator :CM_Operator;  _ediPartyRules :CM_EDIPartyCoparnRules)protected;
/*
Date		        Who		Reason
17 January 2012	    cnwrs1	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
constants
	ADDITIONAL_TEXT	= "//IF NO 20GP AVAILABLE PLEASE RELEASE DAIRY UNITS";
	ISOTYPE 		= '22G1';
	QUANTITY		= 10;
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediItem	: CM_EDITrackedItem;
	ediTI	:CM_EDIRequestHeaderTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	ediItemTI : CM_EDIRequestDetailTI;
	release	:CM_BulkRelease;
	item	:CM_ReserveSelection;
	isoType	:CM_ISOType;
	tempStr : String;
begin
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest(_releaseAdd);
	
	// ---------------------------------------
	// add the one that will be deleted via EDI
	// ---------------------------------------
	self.addReleaseByTypeRequest(_releaseDel, BR_TYPE_ROAD, TI_CargoType_Container, "22G1");
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_DeleteAndAdd("12", _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseAdd, _releaseDel, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if ediItem.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD and
			    ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseAdd, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if ediItem.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD and
			    ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseAdd, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediTI &lt;&gt; null then
		// destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg (ediTI.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
		// load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg (ediTI.loadPort, "NZPOE", "Load port should be NZPOE");
		// discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg (ediTI.dischargePort, "NZAKL", "Destination shoudl be AUSYS");
	endif;
	if ediRelReq &lt;&gt; null then
		// destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg (ediRelReq.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
		// load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg (ediRelReq.loadPort, "NZPOE", "Load port should be NZPOE");
		// discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg (ediRelReq.dischargePort, "NZAKL", "Destination shoudl be AUSYS");
	endif;
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseAdd);
	
	self.assertNotNull (release);
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, _releaseAdd, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertFalseMsg (release.needsReview, 'Needs review should not be set');

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_releaseAdd" type="String"/>
        <Parameter name="_releaseDel" type="String"/>
        <Parameter name="_mt" type="Character"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_DeleteAndAddOLD" id="fea7ade9-e7f1-437a-9ea3-7513009e5f40">
        <source>doCoparn_mtrel_DeleteAndAddOLD(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo:String; _mt :Character; _operator :CM_Operator;  _ediPartyRules :CM_EDIPartyCoparnRules)protected;
/*
Date		        Who		Reason
17 January 2012	    cnwrs1	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
constants
	ADDITIONAL_TEXT	= "//IF NO 20GP AVAILABLE PLEASE RELEASE DAIRY UNITS";
	ISOTYPE 		= '22G1';
	QUANTITY		= 10;
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	item	:CM_ReserveSelection;
	isoType	:CM_ISOType;
	tempStr : String;
	ediItem : CM_EDITrackedItem;
begin
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest(_releaseNo);
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_DeleteAndAddOLD("12", _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "D", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "D", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	
	// destination - LOC+8+AUMEL:139:6'
	self.assertEqualMsg (ediTI.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
	// load port - LOC+9+NZPOE:139:6'
	self.assertEqualMsg (ediTI.loadPort, "NZPOE", "Load port should be NZPOE");
	// discharge port - LOC+11+NZAKL:139:6'
	self.assertEqualMsg (ediTI.dischargePort, "NZAKL", "Destination shoudl be AUSYS");
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNotNull (release);
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertFalseMsg (release.needsReview, 'Needs review should not be set');

	// we expect the release cargo remarks to include the addition text
	item := release.allReserveDetails.first.CM_ReserveSelection;
	
	self.assertNotNull (item);
	self.assertTrueMsg (item.remarks.pos (ADDITIONAL_TEXT, 1) &gt; 0, 'Additionl text from FTX+AAI not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ("TEXTSIN", 1) &gt; 0, 'Additionl text from FTX+SIN not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ("TEXTHAN", 1) &gt; 0, 'Additionl text from FTX+HAN not stored in cargo remarks');

	self.assertNotNullMsg (item.myISOType, 'ISO Type not set');
	self.assertEqualMsg (item.myISOType.code, ISOTYPE, 'ISO type is incorrect');
	
	// Availability grade - defaults for this file
	
	// total requested
	self.assertEqualMsg (item.totalRequested, QUANTITY, 'Total requested not set');
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');
	
	// now do load the file to do the delete
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_addthendelete ("12", '1', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN2"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for delete release requests');	

	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify of delete failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad for delete failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNullMsg (release, 'Release request has not been deleted');

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
