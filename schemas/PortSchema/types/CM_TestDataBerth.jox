    <JadeMethod name="setForCreate" id="f0a32a7d-e1e7-4943-a209-fe79af7fdda8">
        <updating/>
        <source>setForCreate(_berth : HMS_Berth) updating;
// ---------------------------------------------------------------------------
// Created:     14 January 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myBerth	:= _berth;
	self.maxDepartureTime := null;
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setMaxDepartureTime" id="22937b4c-fad3-4c66-8608-13d46a291fc2">
        <updating/>
        <source>setMaxDepartureTime(_ts : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     14 January 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	beginTransaction;
	self.maxDepartureTime := _ts;
	commitTransaction;

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
