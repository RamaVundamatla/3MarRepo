<CollClass name="CM_TIDictByCargoTypeId" id="4d4a653d-edda-49a1-9c68-65287fb9138e">
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_TrackedItemDicts"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="voyages"/>
    <JadeMethod name="lookupAllTIsUsingIdCargoType" id="1d5ff4f3-a1e8-4519-a00e-86ff70e0cecc">
        <source>lookupAllTIsUsingIdCargoType(pId: String; pCargoType: Integer; _set: CM_TISet input; _cmifMonitor : CMIF_Monitor input) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			18 October 2002 by cnwdwq1
Purpose:			This can be used on the dicts that have ID and cargoType only
							as the keys.  If cargoType = TI_CargoType_Null then 
							return ALL LIKE TI with this id
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
//5th July 2017		NDL			TFS 5238 - Reverted to the way the was for performance reasons.
//14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
---------------------------------------------------------------------------
*/
vars
	tmpTI	: CM_TrackedItem;
	iter	: Iterator;
	keyId	: String;
	keyType	: Integer;
begin
	if _set = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'TISet', null, null);
		return false;
	endif;

	iter := self.createIterator;
	self.startKeyGeq(pCargoType, pId, iter);
	
	while iter.next(tmpTI) do
		if _cmifMonitor &lt;&gt; null then
			if (not self.checkProgress(_cmifMonitor)) then
				return false;
			endif;
		endif;
		iter.getCurrentKeys(keyType,keyId); //MTN-35226
		if pCargoType &lt;&gt; TI_CargoType_Null and keyType &lt;&gt; pCargoType or
		   	(not keyId.startsWith(pId)) then
			break;
		endif;
		_set.addNoDuplicates(tmpTI, false);
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.numFound := _cmifMonitor.numFound + 1;
		endif;
	endwhile;
	
	return true;
	
epilog
	delete iter;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="_set" type="CM_TISet" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lookupTIUsingIdCargoType" id="7ab621b8-f72a-4407-98cc-4eb1f91cdc67">
        <source>lookupTIUsingIdCargoType(pId: String; pCargoType: Integer): CM_TrackedItem;
/*
 ------------------------------------------------------------------------
Created:			18 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tmpTI	: CM_TrackedItem;
begin

	if pCargoType &lt;&gt; TI_CargoType_Null then
		tmpTI := self[pCargoType, pId];
		return tmpTI;
	endif;
	
	tmpTI := self.getAtKeyGeq(pCargoType, pId);
//not checking key
	if tmpTI = null then
		return null;	//Make it a bit obvious
	endif;
	if tmpTI.id = pId then
		return tmpTI;
	endif;
	return null;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
</CollClass>
