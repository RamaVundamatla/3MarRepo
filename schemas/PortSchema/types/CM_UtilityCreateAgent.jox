    <JadeMethod name="utlGenReportAndCopy" id="36b0aa79-2395-4a57-acc6-15c67ba72c50">
        <source>utlGenReportAndCopy(_invoice : CM_Invoice;
					_directory : String;
					_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2024	navra1	Initial creation for 61803 - EUP |  API - Save a printout of the invoice and its attachments in the directory specified - Tasks :61804

*/


vars	
	internalUser : CM_User;
	reportTemplate : CM_ReportTemplate;
	pdfPrinter : CM_PrinterDef;
	outputDestination : String;
	filter : CMQF_Invoice;
	chosenReportTemplate : CM_ReportTemplate;
	directoryObj : FileFolder;
begin

	foreach reportTemplate in CM_ReportTemplate.instances where reportTemplate.myQryReport &lt;&gt; null and reportTemplate.myQryReport.reportType = CM_QryReportUser.ReportType_Invoice do
		chosenReportTemplate := reportTemplate;
		if chosenReportTemplate.name = "DEFAULT" then
			break;			
		endif;
	endforeach;

	if chosenReportTemplate = null then
		app.writeLog("No reports templates found, will not be able to generate a report", LogERROR);
		return;
	endif;
	
	if chosenReportTemplate.name &lt;&gt; "DEFAULT" then
		app.writeLog("No report named DEFAULT was found, so generating with a different template named - " &amp; chosenReportTemplate.name, LogERROR);		
	endif;

	foreach pdfPrinter in CM_PrinterDef.instances do
		if pdfPrinter.printerIsPDF then
			break;
		endif;
	endforeach;
	
	if pdfPrinter = null or pdfPrinter.printerIsPDF &lt;&gt; true then
		app.writeLog("Could not find a PDF printer, exiting!", LogERROR);		
		return;
	endif;	
	
	outputDestination := _directory &amp; "\" &amp; _invoice.externalNumber;
	
	create directoryObj transient;	
	directoryObj.usePresentationFileSystem := false;
	directoryObj.fileName := outputDestination;	

	//this directory should have been created in the previous utl that copys over the invoice attachments, if it does not exist, return
	if not directoryObj.isAvailable() then	
		app.writeLog("The directory to put the invoice report does not exist, so returning without creating the report", LogERROR);
		return;
	endif;	
	
	create filter transient;
	filter.initialize();
	filter.invoiceNumber := _invoice.sequenceNum;
	filter.allCompaniesByCode.add(_invoice.bank);	
	
	app.myUtilityCA.utlCreateAndRunBackgroundRpt(false,
											chosenReportTemplate.name,
											chosenReportTemplate.description,
											null,
											pdfPrinter.getName(),
											outputDestination,											
											CM_QryReport.PDF_Format,
											BGP_ReportRequest.SaveAndPrint,
											true,											
											filter,
											chosenReportTemplate.myQryReport,
											null,
											chosenReportTemplate.myEmailTemplate,
											chosenReportTemplate.myUserToRunAs.code,
											chosenReportTemplate.allUsersToGetOutput,
                                            null, //MTN-36668
											app.myPassport
											);											
	
	
epilog
	delete filter;
	delete directoryObj;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlImportSurcharges" id="63c24e41-4d18-4904-af97-ee523f95cae5">
        <source>utlImportSurcharges(	_realInvType : CM_InvoiceDesc input;
						_newProxy : CM_InvoiceTypeSurchargeExempt;
						_passport : CM_Passport input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2018	jlgndl1	Initial creation	TFS 42061

*/

vars

begin

	self.initialiseActivity();
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(_realInvType);
	
	_realInvType.loadSurcharges( _newProxy, _passport );
	
epilog

end;</source>
