		//self.chkCommunicating.value := false;
		//self.chkHeavyLift.value 	:= false;
		//self.cmbVoltageType.text	:= null;
		//self.cmbCoolingType.text	:= null;
		//self.txtWeight.text			:= null;
		//self.txtMaxWeight.text		:= null;
		//self.txtIntHeight.text		:= null;
		//self.txtIntWidth.text		:= null;
		//self.txtIntLength.text		:= null;
		//self.txtExtHeight.text		:= null;
		//self.txtExtWidth.text		:= null;
		//self.txtExtLength.text		:= null;		
		//self.txtVolume.text			:= null;
		
		//self.lstTblStops.clearSelected() ;
		//self.lstTblToDoTasks.clearSelected();
		//self.tblDamage.init();
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="d1597ffe-9c35-4f7b-aba9-bfc36ed2151d">
        <updating/>
        <source>doSave() : Boolean updating, protected;
/* ---------------------------------------------------------------------------
Created:	12 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
12/03/2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
26/09/2013		cnwdap1	PAR #32552 Weight and volume are now measurement tables as well
04/03/2014		cnwdap1	PAR #33638 Correct handling of internal and external dimensions fields
27 Feb 2018		cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
------------------------------------------------------------------------------*/
vars

	realMaster,
	pxyMaster		: CM_TIMasterContainer;
	id, idend		: String;
	operator 		: CM_Operator;
	owner 		: CM_Operator;	
	isoType			: CM_ISOType;
	//tareWeight	: Integer;							// PAR #31155
	tareWeight		: Decimal [23,10];					// PAR #31155
	allStopTables 	: CM_StopsTableByIdDict;
	allToDoTasks 	: CM_ToDoTaskDescByCode;
	result			: Integer;
	errors 			: String;
	isCommunicating, 
	isHeavyLift : Boolean;
	coolingType,voltageType  : Integer;
	//extHeight, extLength, extWidth : Integer;			// PAR #31155
	//intHeight, intLength, intWidth : Integer;			// PAR #31155
	extHeight, extLength, extWidth : Decimal [23,10];	// PAR #31155
	intHeight, intLength, intWidth : Decimal [23,10];	// PAR #31155
	//maxWeight  : Integer;								// PAR #31155
	maxWeight  : Decimal [23,10];						// PAR #31155
	volume : Real;
	
	totalToCreate, rtValue , rStart, rEnd: Integer;
	rangeTxt : String;
	looper : Integer;
	newID : String;
	pxyMasterUpdate		: CM_TIMasterContainer;
	objectArray : CM_ObjectArray;
	damage : CM_DamageInstance;
	
	weightType		: CM_MeasurementType;				// PAR #31155
//	linearType		: CM_MeasurementType;				// PAR #31155
	volumeType		: CM_MeasurementType;				// PAR #31155
	lengthType		: CM_MeasurementType;
	widthType		: CM_MeasurementType;
	heightType		: CM_MeasurementType;
	generatorMaster : CM_TIMaster;
	
begin
	id :=self.txtID.text;
	idend := self.txtIDend.text;
	
	weightType := app.getDefaultMeasurementForType(Type_Weight);			// PAR #31155
	//linearType := app.getDefaultMeasurementForType(Type_Linear);			// PAR #31155
	volumeType := app.getDefaultMeasurementForType(Type_Volume);			// PAR #31155
	lengthType := app.getDefaultMeasurementForType(Type_Length);
	widthType := app.getDefaultMeasurementForType(Type_Width);
	heightType := app.getDefaultMeasurementForType(Type_Height);

	isCommunicating := self.chkCommunicating.value;
	isHeavyLift := self.chkHeavyLift.value;
	//extHeight := self.txtExtHeight.text.Integer;
	//extLength:= self.txtExtLength.text.Integer;
	//extWidth := self.txtExtWidth.text.Integer;
	//intHeight := self.txtIntHeight.text.Integer;
	//intLength := self.txtIntLength.text.Integer;
	//intWidth := self.txtIntWidth.text.Integer;
	//maxWeight := self.txtMaxWeight.text.Integer;
	//volume := self.txtVolume.cnEcReal();
	//volume	:= self.txtVolume.getTextAsDecimal();	//#25592 16/11/2010 **
	if heightType.isFeetAndInches then
		extHeight := app.convertMeasurementForStorage(heightType.shortName, self.txtFtExtHeight.getFeetInches.Decimal);
		intHeight := app.convertMeasurementForStorage(heightType.shortName, self.txtFtIntHeight.getFeetInches.Decimal);
	else
		//extHeight := app.convertMeasurementForStorage(heightType.shortName, self.txtExtHeight.text.Decimal);	// PAR #33638
		//intHeight := app.convertMeasurementForStorage(heightType.shortName, self.txtIntHeight.text.Decimal);	// PAR #33638
		extHeight := self.txtExtHeight.getConvertedValue();														// PAR #33638
		intHeight := self.txtIntHeight.getConvertedValue();														// PAR #33638
	endif;
	if lengthType.isFeetAndInches then
		extLength := app.convertMeasurementForStorage(lengthType.shortName, self.txtFtExtLength.getFeetInches.Decimal);
		intLength := app.convertMeasurementForStorage(lengthType.shortName, self.txtFtIntLength.getFeetInches.Decimal);
	else
		//extLength := app.convertMeasurementForStorage(lengthType.shortName, self.txtExtLength.text.Decimal);	// PAR #33638
		//intLength := app.convertMeasurementForStorage(lengthType.shortName, self.txtIntLength.text.Decimal);	// PAR #33638
		extLength := self.txtExtLength.getConvertedValue();														// PAR #33638
		intLength := self.txtIntLength.getConvertedValue();														// PAR #33638
	endif;
	if widthType.isFeetAndInches then
		extWidth := app.convertMeasurementForStorage(widthType.shortName, self.txtFtExtWidth.getFeetInches.Decimal);
		intWidth := app.convertMeasurementForStorage(widthType.shortName, self.txtFtIntWidth.getFeetInches.Decimal);
	else
		//extWidth := app.convertMeasurementForStorage(widthType.shortName, self.txtExtWidth.text.Decimal);		// PAR #33638
		//intWidth := app.convertMeasurementForStorage(widthType.shortName, self.txtIntWidth.text.Decimal);		// PAR #33638
		extWidth := self.txtExtWidth.getConvertedValue();														// PAR #33638
		intWidth := self.txtIntWidth.getConvertedValue();														// PAR #33638
	endif;
	//maxWeight := app.convertMeasurementForStorage(weightType.shortName, self.txtMaxWeight.text.Decimal);	// PAR #32552
	//volume := app.convertMeasurementForStorage(volumeType.shortName, self.txtVolume.text.Decimal);		// PAR #32552
	maxWeight := self.txtMaxWeight.getConvertedValue();														// PAR #32552
	volume := self.txtVolume.getConvertedValue();															// PAR #32552
	
	create objectArray transient;
	
	if cmbOperator.listIndex &gt; 0 then
		operator := self.cmbOperator.itemObject[cmbOperator.listIndex].CM_Operator;
	endif;
	
	if cmbOwner.listIndex &gt; 0 then
		owner := self.cmbOwner.itemObject[cmbOwner.listIndex].CM_Operator;
	endif;
	
	if cmbISOType.listIndex &gt; 0 then
		isoType := self.cmbISOType.itemObject[cmbISOType.listIndex].CM_ISOType;
	endif;
	
	if cmbGenerator.listIndex &gt;0 then   													//27.02.2018 cnwma1 ChangeRequest #36813
		generatorMaster := self.cmbGenerator.itemObject[cmbGenerator.listIndex].CM_TIMaster;
	endif;
	
	coolingType := app.coolingTypeStringToENum( self.cmbCoolingType.text );
	voltageType := app.voltageTypeStringToENum( self.cmbVoltageType.text );


	///tareWeight := self.txtWeight.text.Integer;
	//tareWeight := app.convertMeasurementForStorage(weightType.shortName, self.txtWeight.text.Decimal);	// PAR #32552
	tareWeight := self.txtWeight.getConvertedValue();														// PAR #32552
	
	create allStopTables transient;
	self.lstTblStops.allSelectedObjects.copy(allStopTables);
	
	create allToDoTasks transient;
	self.lstTblToDoTasks.allSelectedObjects.copy(allToDoTasks);
	
	if isoType &lt;&gt; null then
		if not isoType.isReefer then
			coolingType := 0;
			voltageType := 0;
			isCommunicating := false;
		endif;
	endif;
	
	if chkRange.value then
	//creating a range
		if not self.validateRangeDetails(id , idend , totalToCreate, rStart, rEnd, rangeTxt ) then
			//error in range values
			app.msgBox("Incorrect Container Range values " ,"Range Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		else
		rtValue := app.msgBox("Creating/Updating about " &amp; (totalToCreate div 10).asStringJMT &amp; " container master records." &amp; Cr &amp; "Do you want to continue?","Confirm update",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if rtValue = MsgBox_Return_No then
				return false;
			endif;	
		// create/update multiple records
			foreach looper in rStart to rEnd do
				newID := rangeTxt &amp; looper.String.padZeros(7);
				
				pxyMasterUpdate := app.myRoot.allTiMasters.getAtKey(TI_CargoType_Container, newID ).CM_TIMasterContainer;
				
				if pxyMasterUpdate &lt;&gt; null then
					if chkOverwrite.value then
					//update existing
						beginLoad;
						pxyMaster := app.createUpdateProxy(pxyMasterUpdate).CM_TIMasterContainer;
						endLoad;
						
						pxyMaster.setForProxyMasterContainer( newID, 
							isCommunicating, isHeavyLift , 
							coolingType, voltageType, tareWeight, extHeight, extLength, extWidth, intHeight, intLength, intWidth , maxWeight, volume, 
							operator, owner,
							isoType,
							allStopTables, allToDoTasks ,generatorMaster );  //27.02.2018 cnwma1 ChangeRequest #36813
						
						if self.isDamageFormInitialised then
							foreach damage in pxyMaster.allDamageInstancesByPos do
								if not self.allDamageInstancesByPos.includes(damage) then
									//pxyMaster.allDamageInstancesByPos.removeIfPresent(damage);
									delete damage;  //cnwjo3 par 21463
									objectArray.add(damage);
								endif;
							endforeach;
						endif;
						self.setDamageParent(pxyMaster);
						//self.tblDamage.setProxyFromTable(pxyMaster,errors);
						while true do
							app.myTrxUA.trxUpdateTIMasterContainer(pxyMaster, app.myPassport);
			
							if not app.myPassport.trxCompletedOK then	
								result := app.showErrorWarningDialog('Create Master Item', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
								self.setAllErrorWarnings(app.myPassport);	
								if app.myPassport.noErrors and  result = IDOK then
									app.myPassport.warningsAcknowledged	:= true;
									continue;
								endif;
							else
								self.clearErrorWarnings();
								delete pxyMaster;
							endif;							
							break;					
						endwhile;
					endif;
				else
					//check if ID is valid
					if app.checkDigitContainerId( newID) then
					//create new
						create pxyMaster transient;
						realMaster := null;
						pxyMaster.setForProxyMasterContainer( newID, 
							isCommunicating, isHeavyLift , 
							coolingType, voltageType, tareWeight, extHeight, extLength, extWidth, intHeight, intLength, intWidth , maxWeight, volume, 
							operator, owner,
							isoType,
							allStopTables, allToDoTasks ,generatorMaster ); //27.02.2018 cnwma1 ChangeRequest #36813
						
						if self.isDamageFormInitialised then
							foreach damage in pxyMaster.allDamageInstancesByPos do
								if not self.allDamageInstancesByPos.includes(damage) then
									//pxyMaster.allDamageInstancesByPos.removeIfPresent(damage);
									delete damage;  //cnwjo3 par 21463
									objectArray.add(damage);
								endif;
							endforeach;
						endif;
						self.setDamageParent(pxyMaster);
						//self.tblDamage.setProxyFromTable(pxyMaster,errors);
						while true do
							app.myTrxCA.trxCreateTIMasterContainer( pxyMaster, realMaster, false, app.myPassport );
			
							if not app.myPassport.trxCompletedOK then	
								result := app.showErrorWarningDialog('Create Master Item', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
								self.setAllErrorWarnings(app.myPassport);	
								if app.myPassport.noErrors and  result = IDOK then
									app.myPassport.warningsAcknowledged	:= true;
									continue;
								endif;
							else
								delete pxyMaster;
								self.clearErrorWarnings();
							endif;
							break;
							
						endwhile;
					endif;		
				endif;
						
				pxyMasterUpdate := null;
			endforeach;
			return true;
		endif;
		return true;
	endif;
	
	beginLoad;
		if self.isEdit then
			pxyMaster := app.createUpdateProxy(self.myTiMaster).CM_TIMasterContainer;
		else
			create pxyMaster transient;
		endif;
	endLoad;
	
	pxyMaster.setForProxyMasterContainer( id, 
	isCommunicating, isHeavyLift , 
	coolingType, voltageType, tareWeight, extHeight, extLength, extWidth, intHeight, intLength, intWidth , maxWeight, volume, 
	operator, owner,
	isoType,
	allStopTables, allToDoTasks ,generatorMaster ); //27.02.2018 cnwma1 ChangeRequest #36813
	
	//self.tblDamage.setProxyFromTable(pxyMaster,errors);
	//pxyMaster.allDamageInstancesByPos.purge();
	if self.isDamageFormInitialised then
		foreach damage in pxyMaster.allDamageInstancesByPos do
			if not self.allDamageInstancesByPos.includes(damage) then
				//pxyMaster.allDamageInstancesByPos.removeIfPresent(damage);
				delete damage;  //cnwjo3 par 21463
				objectArray.add(damage);
			endif;
		endforeach;
	endif;
	self.setDamageParent(pxyMaster);
	
	if pxyMaster = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;

	while true do
		if not self.isEdit then
			app.myTrxCA.trxCreateTIMasterContainer( pxyMaster, realMaster, false, app.myPassport );
		else
			app.myTrxUA.trxUpdateTIMasterContainer(pxyMaster, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then	
			result := app.showErrorWarningDialog('Create Master Item', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			self.setAllErrorWarnings(app.myPassport);	
			if app.myPassport.noErrors and  result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		else
			self.clearErrorWarnings();
			if self.isEdit then				
			else
				self.myTiMaster := realMaster;
			endif;
			
			self.myParentForm.CMUI_TIMasterForm.setMyCurrentTiMaster( self.myTiMaster );
			self.btnDamage.enabled := true;	// cnwrd1 par 20799 27/10/09
			return true;			
		endif;
		break;
	endwhile;
	
	return false;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	pxyMaster.allDamageInstancesByPos.purge();
	delete pxyMaster;
	objectArray.purge();
	delete objectArray;
	self.allDamageInstancesByPos.purge();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="firstChange" id="dbc5978d-50cc-4573-b730-92770f77cf86">
