    <JadeMethod name="getAuditTextForProperty" id="b0d39a70-41b6-48d7-a8c3-62b762f8ce4d">
        <source>getAuditTextForProperty(_property: Property): String;
// --------------------------------------------------------------------------------
// Created:		17 November 2008 by cnwdad1
//
// Purpose:		This is a reimplementation of a superclass method to get the required
//				audit string sequence for the the specified property of the receiver.
//
// Parameters:	_property - A reference to the property who's text is required.
//
// Returns:		Formatted Audit text (using CM_Object::formatAuditText) for the property 
//				text value, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27 Apr 2009	cnwkpd1		PAR #19538 - Auditing of CA fields is incorrect
// --------------------------------------------------------------------------------

vars
	propName	: String;
	
begin
	// 30/04/2009 cnwar2 #19538 - moved to getAuditText (these values should come off the item)
	
	/*propName	:=	_property.name;
	
	if propName = CM_BookingRef::temperature.name then
		if self.temperature = NULL_TEMPERATURE then
			return self.formatAuditText(propName, null);			// PAR #19538
		else
			return self.formatAuditText(propName, self.temperature.String);		// PAR #19538
		endif;
	elseif propName = CM_BookingRef::humidity.name then //cnwrs1 Par19451 Aopr 2009
		if self.humidity = NULL_HUMIDITY then
			return self.formatAuditText(propName, null);			// PAR #19538
		else
			return self.formatAuditText(propName, self.humidity.String);
		endif;
	elseif propName = CM_BookingRef::ventilation.name then  //cnwrs1 Par19451 Aopr 2009
		if self.ventilation = NULL_VENTILATION then
			return self.formatAuditText(propName, null);			// PAR #19538
		else
			return self.formatAuditText(propName, self.ventilation.String);
		endif;
	else
		return inheritMethod(_property);
	endif;*/
	
	return inheritMethod(_property);
end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefItemForTI" id="d7a90967-ebf4-42c4-af66-c2754a1e726a">
        <source>getBookingRefItemForTI( _ti : CM_TrackedItem ):CM_BookingRefItem;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	brItem : CM_BookingRefItem;
	
begin
	
	if _ti = null then
		return null;
	endif;
	
	foreach brItem in self.allBookingRefItems do
		if brItem.allTIs.includes(_ti) then
			return brItem;
		endif;
	endforeach;

	return null;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_BookingRefItem"/>
    </JadeMethod>
