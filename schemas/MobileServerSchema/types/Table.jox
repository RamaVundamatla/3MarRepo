<GUIClass name="Table">
    <JadeMethod name="mbCanScroll" id="9b219b06-9255-426c-a4fb-9209e9196dba">
        <updating/>
        <source>mbCanScroll():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 February 2006 by cnwdad1
//
// Purpose:		Returns a booelan flag to indicate whether the receiver can scroll
//				(i.e. if there are rows that are not currently visible.
//
// Parameters:	None
//
// Returns:		True if the receiver can scroll, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowCount	: Integer;
	theRow		: Integer;
	theHeight	: Integer;
	
begin
	rowCount	:=	self.rows;
	
	foreach theRow in 1 to rowCount do
		theHeight := theHeight + self.accessRow(theRow).height;
	endforeach;

	return self.height &lt; theHeight;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbScrollPage" id="706c07af-3c67-4c54-9373-3972eccd1ecc">
        <updating/>
        <source>mbScrollPage(_isDown : Boolean)updating;
/*
	Created on 12 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	rowCount	: Integer;
	rowsPerPage	: Integer;
	firstRow	: Integer;
	rowHeightToUse	: Integer;	//15 Oct 2009	NDL	Par 21311
	
begin
	if _isDown then
	else
		if self.topRow = 1 then
			return;
		endif;
	endif;
	
	rowCount	:=	self.rows;
	//rowsPerPage	:=	(self.height div self.defaultRowHeight) - 1;
	
	//15 Oct 2009	NDL	Par 21311 - divide by zero issue.
	rowHeightToUse := self.defaultRowHeight;
	if rowHeightToUse &lt; 1 then
		rowHeightToUse := self.accessRow(1).height; 
	endif;
	rowsPerPage	:=	(self.height div rowHeightToUse) - 1;
	
	if _isDown then
		firstRow	:=	self.topRow + rowsPerPage;
		
		if firstRow &gt; rowCount then
			firstRow	:=	rowCount;
		elseif firstRow &lt; 1 then
			firstRow	:=	1;
		endif;
	else
		firstRow	:=	self.topRow - rowsPerPage;
		
		if firstRow &lt; 1 then
			firstRow	:=	1;
		endif;
	endif;
	
	if firstRow &lt;&gt; 0 then
		self.topRow	:=	firstRow;
	endif;
end;
/*
vars
	rowCount	: Integer;
	rowsPerPage	: Integer;
	firstRow	: Integer;
	rowHeight	: Integer;
	
begin
	if _isDown then
		if self.topRow &gt;= rows then
			// We can't scroll down any further.
			return;
		endif;
		
		self.topRow := self.topRow + 1;
	else
		if self.topRow &lt;= 1 then
			return;
		endif;
		
		self.topRow := self.topRow - 1;
	endif;
end;
*/</source>
        <Parameter name="_isDown" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="scrollOld" id="f3967ec2-7717-45b2-bdd9-22e6b270b425">
        <updating/>
        <source>scrollOld(_isDown:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2006 by cnwdad1
//
// Purpose:		Scrolls the receiver one page, up or down.
//
// Parameters:	_isDown - True if the receiver is to be scrolled down, otherwise
//					scroll up.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowCount	: Integer;
	rowsPerPage	: Integer;
	firstRow	: Integer;
	rowHeight	: Integer;
	
begin
	if _isDown then
	else
		if self.topRow = 1 then
			// We can't scroll up any further.
			return;
		endif;
	endif;
	
	rowCount	:=	self.rows;
	
	if self.defaultRowHeight = 0 then
		rowHeight	:=	self.accessRow(1).height;
	else
		rowHeight	:=	self.defaultRowHeight;
	endif;
	
	rowsPerPage	:=	(self.height div rowHeight) - 1;
	
	if _isDown then
		firstRow	:=	self.topRow + rowsPerPage;
		
		if firstRow &gt; rowCount then
			firstRow	:=	rowCount;
		elseif firstRow &lt; 1 then
			firstRow	:=	1;
		endif;
	else
		firstRow	:=	self.topRow - rowsPerPage;
		
		if firstRow &lt; 1 then
			firstRow	:=	1;
		endif;
	endif;
	
	if firstRow &lt;&gt; 0 then
		self.topRow	:=	firstRow;
	endif;
end;</source>
        <Parameter name="_isDown" type="Boolean"/>
    </JadeMethod>
</GUIClass>
