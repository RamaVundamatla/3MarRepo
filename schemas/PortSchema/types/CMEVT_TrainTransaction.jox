    <JadeMethod name="hasTaskThatIsComplete" id="a7b8cef4-d201-4090-9f29-01ad82c3bedc">
        <source>hasTaskThatIsComplete(): Boolean;
/*
Purpose:			

Date		Who		Reason
16JUN2023	NAVAB1	 CR 54345 TASK 58281 
05 Dec 2024 navma1	 MTN-33567 MTN - Charges Are Not Created When adding Events
*/


vars
	taskDesc 	: CM_ToDoTaskDesc;
	task 		: CM_ToDoTask;
	myWodToDo 	: CM_WodToDo;
	train		: CM_Train;
begin

	if self.myToDoTask = null then
		return false;
	endif;
	
	train := self.myTrain;
	
	if train = null then
		return false;
	endif;
	
	return train.allToDoTasksCompleted.includes(self.myToDoTask);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6a023119-58de-472c-bfbd-5a4a6f8ed02e">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
30 October 2009	cnwndl1	Initial creation	Par 21519
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	if proxy &lt;&gt; null then
		proxy.myTrain 	:= self.myTrain;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
