<Class name="CMIF_KRFCheckInRefrigeration" id="9363fb88-bfa0-4fcf-b972-fabdc39fa0bb">
    <superclass name="CMIF_KRFWSProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="generatorID" id="4cd919ce-81e7-4ec8-a5d6-66458c092cb9">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="maximumOffPowerHours" id="03b41f32-7750-4138-8556-5376d49d646b">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="offPowerTimestamp" id="25eec841-6119-481e-a874-180f8639ba8b">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="productTemperature" id="8986b7cc-6017-4a9e-acc1-9593557857a1">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="refrigerationType" id="146e2b8a-26e0-4929-a5d1-58a72bd0de1d">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="setTemperature" id="a5dfbe07-cdfc-4edc-86d0-c2da4516e636">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <JadeMethod name="copyToRealWSObject" id="bbb8bcf1-1d10-4247-9f85-d2b72f376a60">
        <source>copyToRealWSObject(_realRequest: KRF_CheckInRefrigeration input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2019	jlgsl4	TFS 40360 - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.generatorID := self.generatorID;
	_realRequest.maximumOffPowerHours := self.maximumOffPowerHours;
	_realRequest.offPowerTimestamp := self.offPowerTimestamp;
	_realRequest.productTemperature := self.productTemperature;
	_realRequest.refrigerationType := self.refrigerationType;
	_realRequest.setTemperature := self.setTemperature;

epilog

end;</source>
        <Parameter name="_realRequest" type="KRF_CheckInRefrigeration" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromContainer" id="688e6813-2f3d-4271-b0ab-a547f1e627d8">
        <updating/>
        <source>setFromContainer(_container : CM_Container) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2019	jlgsl4	Initial creation

*/

vars
	timestamp : TimeStamp; 
begin
	self.generatorID := _container.generatorId;
	self.maximumOffPowerHours := _container.getAllowableTimeOffPower();
	self.setTemperature := _container.getTemperature();
	if _container.getLastConnectDT() &lt;&gt; null then
		self.offPowerTimestamp := _container.getLastConnectDT().localToUTCTime(); // GMT timestamp
	else
		self.offPowerTimestamp := timestamp.localToUTCTime();
	endif;
	if _container.isChilled then
		self.refrigerationType := "CHILLED";
	else
		self.refrigerationType := "INSULATED";
	endif;
epilog

end;</source>
        <Parameter name="_container" type="CM_Container"/>
    </JadeMethod>
</Class>
