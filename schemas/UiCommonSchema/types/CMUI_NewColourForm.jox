<GUIClass name="CMUI_NewColourForm" id="b8ebbc96-3156-49da-8745-6a117844bddc">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lblColour" id="10f342ef-a1bb-4f9e-9a6e-0869151f4db7">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtColour" id="ae16ccc3-a1a9-42ed-8a01-fddf4464894c">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="7d4a9be8-c1ca-4f8a-89fc-0bac70dca75a">
        <updating/>
        <source>doOK() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	pxyColour, colour 	: CM_VehicleColour;
	theReturn			: Integer;

begin
	create pxyColour transient;
	pxyColour.setProxy(self.txtColour.text.trimBlanks);
	
	while true do
		app.myTrxCA.trxCreateVehicleColour(pxyColour, colour, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	if app.myPassport.noErrors then
		inheritMethod();
		self.createMyAssistant(CMUI_Assistant);
		self.myAssistant.refreshColourList(self.myParentForm, colour);
	endif;
epilog
	if self.myAssistant &lt;&gt; null then
		delete self.myAssistant;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6383386d-27a0-4497-91c4-e37c255f32eb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019210, locale);
	lblColour.translateCaption(Xlat_0019211, locale);
end;</source>
    </JadeMethod>
</GUIClass>
