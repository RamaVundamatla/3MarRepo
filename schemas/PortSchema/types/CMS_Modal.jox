    <JadeMethod name="setSize" id="d82ce182-67de-4854-8299-93c9eab7cdc3">
        <updating/>
        <source>setSize(newHeight: Real; newWidth: Real) updating;

constants
	All_Btn_Top_Height_Offset     = -60;
	OK_Btn_Left_Width_Offset      = -235;
	Cancel_Btn_Left_Width_Offset  = -159; // AJA 10/7/00: Was -126;
	Help_Btn_Left_Width_Offset    = -83;
vars
begin
	height := newHeight;
	width := newWidth;

//	btnOK.top := height + All_Btn_Top_Height_Offset;
//	btnCancel.top := btnOK.top;
//	btnHelp.top := btnOK.top;

//	btnOK.left := width + OK_Btn_Left_Width_Offset;
//	btnCancel.left := width + Cancel_Btn_Left_Width_Offset;
//	btnHelp.left := width + Help_Btn_Left_Width_Offset;
end;</source>
        <Parameter name="newHeight" type="Real"/>
        <Parameter name="newWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="showErrorWarningMsgBox" id="6394c167-074a-4008-9a84-0c34b0dee3c2">
        <source>showErrorWarningMsgBox(_heading : String; _passport : CM_Passport) : Integer;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	err			: CM_Error;
	rowNo,
	cellHeight, theReturn	: Integer;
	tblRow		: JadeTableRow;
	tmpStr		: String;
	buttonStr : Integer;
begin

	foreach err in _passport.allErrors do
		buttonStr := MsgBox_OK_Only;
		tmpStr := tmpStr &amp; "ERROR: " &amp; err.text &amp;  Cr;
	endforeach;

	foreach err in _passport.allWarnings do
		buttonStr := MsgBox_OK_Cancel;
		tmpStr := tmpStr &amp; "Warning: " &amp; err.text &amp;  Cr;
	endforeach;
	
	theReturn := app.msgBox(tmpStr,_heading,buttonStr);
	app.mousePointer := MousePointer_Default;

	return theReturn;
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="c21fe604-cd69-4ab0-829e-fe2229303dff">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars

begin

	if self.myProxyObject &lt;&gt; null then
		delete self.myProxyObject;
	endif;

end;</source>
