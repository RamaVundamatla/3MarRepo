    </JadeMethod>
    <JadeMethod name="extractMethodsByUNL" id="59b37c53-4d46-4ee9-b08f-52e834436513">
        <source>extractMethodsByUNL(_doExtract: Boolean; 
					_fileUNL, 
					_schemaName, 
					_schemaNameUNL, 
					_extractDirJadeMaster, 
					_extractDirEncrypted: String; 
					_isThinClient : Boolean;
					_strResult : String output ) : Boolean;

/*--------------------------------------------------------------------
Created:	10 April 2007 By cnwvu1
Purpose:	Purpose - extract classes and methods onto disk by UNL file
Parameters	doExtract = true - do exctract; For developing purpose not to waste time.
			fileUNL - file UNL
			extractDirJadeMaster - JadeMaster/Schemas
			extractDirEncrypted - ParNo/Schemas

Date		Who		Reason
22 Mar 2010	cnwkpd1	Allow for Thin client patch creation
28 Aug 2019 jlgmd1	If we hit an error this far down, we can't show message boxes as we're still in transaction state

*/

vars
	dir,
	command			: String;
	args			: StringArray512;
	result,
	result2			: Integer;
	
	message,
	serverPath,
	tempFileName,
	iniFileName,
	unlFileName,
	sourceName,
	encryptedName	: String;
	
begin
	if not _doExtract then
		app.writeLogMessage('Extraction from JADE has not been done. Check HotfixesCommonSchema::SchemaINPatch::DO_EXTRACT_BY_UNL_FILE');
		return true;
	endif;

	// cnwkpd1 - Removed - this should not be done, it should be up to a developer to keep their fat client binaries 
	// up to date if they need them
//	if not self.extractFilesDllFromServer() then
//		return false;
//	endif;
	
	// Now set up all the locally required file parameters, based on whether we are running with the thin client option or not
	if _isThinClient then
	
		message := "(App Server)";
	
		// If we're using the thin client mode, need to create all the files as temporary ones on the App Server, and
		// remove them later
		
		tempFileName	:= app.relativeMachineTime.String &amp; "_" &amp; self.getInstanceIdForObject(process).String;
		
		serverPath		:= app.cnGetServerMiscPath &amp; "\";
		
		iniFileName		:= node.getIniFileName();
		unlFileName		:= serverPath &amp; "unl_" &amp; tempFileName &amp; ".unl";
		sourceName		:= serverPath &amp; "source_" &amp; tempFileName;
		encryptedName	:= serverPath &amp; "encrypted_" &amp; tempFileName;
		
		// Copy the unl file to the App Server
		if not app.copyAFile(_fileUNL, true, unlFileName, false) then
			return false;
		endif;
		
		// Get the correct binary directory
		dir := node.getJadeInstallDirectory();
		
	else

		message := "(Locally)";

		// If we are using fat client mode, then we can create the files diirectly
		
		iniFileName 	:= process.getIniFileName();
		unlFileName 	:= _fileUNL;
		sourceName 		:= _extractDirJadeMaster &amp; _schemaNameUNL;
		encryptedName 	:= _extractDirEncrypted &amp; _schemaNameUNL;
		
		dir := process.getJadeInstallDirectory();
		
	endif;

	// Now run the jadclient process to do the extracts
	command := 'jadclient';
	
	// -------------------------------------------------------------------------------------------
	// 											extraction
	// -------------------------------------------------------------------------------------------
	create args transient;
	args.add("path=" &amp; app.dbPath);
	args.add("ini=" &amp; iniFileName);
	args.add("server=multiUser");	
	args.add("schema=JadeSchema");
	args.add("app=JadeBatchExtract");
	args.add("endJade");
	args.add("File");
	args.add(sourceName &amp; '.scm');
	args.add(sourceName &amp; '.ddb');
	args.add(unlFileName);
	args.add(_schemaName);
		
	// Now run the process (run modally, so we wait until it's complete)
	app.writeLogMessage("Running " &amp; message &amp; " command " &amp; command &amp; Space &amp; args.concatenate(Space));
	result := node.createExternalProcess(dir, dir &amp; command, args, null, not _isThinClient, true, result2);

	if result &lt;&gt; Node.ExternalProcess_Successful or result2 &lt;&gt; 0 then
		//app.msgBox('jadclient.exe failed to extract ' &amp; _schemaNameUNL &amp; '. Result=' &amp; result.String &amp;'. Please extract manually.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);	//trx state, can't show msgBoxes
		app.writeLogMessage('jadclient.exe failed to extract ' &amp; _schemaNameUNL &amp; '. Result=' &amp; result.String &amp;'. Please extract manually.');
		return false;
	endif;

	// -------------------------------------------------------------------------------------------
	// 									encrypted extraction
	// -------------------------------------------------------------------------------------------
	args.clear();
	args.add("path=" &amp; app.dbPath);
	args.add("ini=" &amp; iniFileName);
	args.add("server=multiUser");	
	args.add("schema=JadeSchema");
	args.add("app=JadeBatchExtract");
	args.add("endJade");
	args.add("File");
	args.add(encryptedName &amp; '.scm');
	args.add(encryptedName &amp; '.ddb');
	args.add(unlFileName);
	args.add(_schemaName);
	args.add ("&lt;encrypt&gt;");
	
	// Now run the process (run modally, so we wait until it's complete)
	app.writeLogMessage("Running " &amp; message &amp; " command " &amp; command &amp; Space &amp; args.concatenate(Space));
	result := node.createExternalProcess(dir, dir &amp; command, args, null, not _isThinClient, true, result2);

	if result &lt;&gt; Node.ExternalProcess_Successful or result2 &lt;&gt; 0 then
		//app.msgBox('jadclient.exe failed to extract ' &amp; _schemaNameUNL &amp; '. Result=' &amp; result.String &amp;'. Please extract manually.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);	//trx state, can't show msgBoxes
		app.writeLogMessage('jadclient.exe failed to extract ' &amp; _schemaNameUNL &amp; '. Result=' &amp; result.String &amp;'. Please extract manually.');
		return false;
	endif;

	// Now, if the extracts were successful, and we are running thin client mode, then copy the extracted
	// files to the final destination and delete the temporary files
	if _isThinClient then
		app.deleteAFile(unlFileName, false);
		
		app.copyAFile(sourceName &amp; '.scm', false, _extractDirJadeMaster &amp; _schemaNameUNL &amp; ".scm", true);
		app.copyAFile(sourceName &amp; '.ddb', false, _extractDirJadeMaster &amp; _schemaNameUNL &amp; ".ddb", true);

		app.deleteAFile(sourceName &amp; '.scm', false);
		app.deleteAFile(sourceName &amp; '.ddb', false);
				
		app.copyAFile(encryptedName &amp; '.scm', false, _extractDirEncrypted &amp; _schemaNameUNL &amp; ".scm", true);
		app.copyAFile(encryptedName &amp; '.ddb', false, _extractDirEncrypted &amp; _schemaNameUNL &amp; ".ddb", true);
	
		app.deleteAFile(encryptedName &amp; '.scm', false);
		app.deleteAFile(encryptedName &amp; '.ddb', false);

	endif;
	
	return true;
	
epilog
	if args &lt;&gt; null then
		delete args;
	endif;

end;
</source>
        <Parameter name="_doExtract" type="Boolean"/>
        <Parameter name="_fileUNL" type="String"/>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_schemaNameUNL" type="String"/>
        <Parameter name="_extractDirJadeMaster" type="String"/>
        <Parameter name="_extractDirEncrypted" type="String"/>
        <Parameter name="_isThinClient" type="Boolean"/>
        <Parameter name="_strResult" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAppInSchema" id="761d89cf-cc50-4fd5-9df5-c5414df0de3c">
        <source>getAppInSchema( _appName : String ) : AppInSchema;
// created by cnwvu1	08 April 2008
vars

begin

	return self.allAppsInSchema[ _appName, self.name, self.myPatch.parNo ];
	
end;
</source>
        <Parameter name="_appName" type="String"/>
        <ReturnType type="AppInSchema"/>
    </JadeMethod>
    <JadeMethod name="getClassInSchema" id="31641dc0-37e6-47fe-a132-dffd0c606ac3">
        <source>getClassInSchema( _className : String ) : ClassInSchema;

vars

begin

	return self.allClassesInSchema[ _className, self.name, self.myPatch.parNo ];
	
end;
</source>
        <Parameter name="_className" type="String"/>
        <ReturnType type="ClassInSchema"/>
    </JadeMethod>
    <JadeMethod name="getFileNameUNL" id="c17ab24c-a177-4d6d-8560-a054ebeede36">
        <source>getFileNameUNL(strSortOrder : String) : String;
/* Changes

Date		Name	TFS#	Description
============================================================================
05/06/2019	jlgka1	41865	Add Prefix in the filename based on the Schema Order.
============================================================================*/
begin
	return self.myPatch.getPatchDirJademasterSchemas() &amp; strSortOrder &amp; self.name &amp;'_'&amp; app.myRootHotFix.releaseVersionNo &amp;'_'&amp; self.myPatch.patchNo &amp; '.' &amp; app.myRootHotFix.FILE_TYPE_UNL;
end;
</source>
        <Parameter name="strSortOrder" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSchemaInJADE" id="84fbd594-5a91-457e-ab21-013f489e65d3">
        <source>getSchemaInJADE() : Schema;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	scm	: Schema;
	
begin
	
	scm := rootSchema.getSchema( self.name );
	if scm = null then
		app.msgBox('The schema not found - ' &amp; self.name, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return null;
	endif;

	return scm;
	
end;
</source>
        <ReturnType type="Schema"/>
    </JadeMethod>
    <JadeMethod name="set" id="16c7b2c0-1b56-417f-936b-f6f384b4127b">
        <updating/>
        <source>set( _name : String ) updating;
// created by cnwvu1 on 10/03/2007

vars
	s : String;
	
begin

	self.name				:= _name;
	self.dateOfLastEdition	:= app.actualTimeServer();
	
end;
</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="00e8e28b-a0be-41c9-9915-5477572d20ba">
        <updating/>
        <source>setForCreate( _name: String; _patch: Patch ) updating;
// created by cnwvu1 on 10/03/2007
/* Changes

Date		Name	TFS#	Description
============================================================================
10/06/2019 jlgka1	41865	As a result of the deleted inverse in Patch::allSchemasInPatchArray
							we need to manually add the schema in the SchemaInPatch.
============================================================================*/
begin

	self.set( _name );
	self.myPatch := _patch;
	
	_patch.addOrderedSchema(self);
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_patch" type="Patch"/>
    </JadeMethod>
    <JadeMethod name="validate" id="f6f9345b-cd53-48ff-8db7-2cd4448f6dbc">
        <source>validate() : Boolean;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	cls		: ClassInSchema;
	schema	: Schema;
	appl	: AppInSchema;
	
begin

	schema := self.getSchemaInJADE();
	if schema = null then
		app.writeLogMessage('Schema ' &amp; self.name &amp; ' - not found.');
		return false;
	else
		app.writeLogMessage('Schema ' &amp; self.name &amp; ' - ok.');
	endif;
	
	foreach cls in self.allClassesInSchema do
		if not cls.validate() then
			return false;
		endif;
	endforeach;

	foreach appl in self.allAppsInSchema do
		if not appl.validate() then
			return false;
		endif;
	endforeach;

	return true;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeClassesToFileUNL" id="8b540117-9d0a-4e69-b509-62b507b01292">
        <source>writeClassesToFileUNL( fInst: File; sortOrderStr : String );
// created by cnwvu1 on 10/03/2007
// app.writeLogMessage(to fileUNL either:
//		schema's methods or
//		Class className - for whole class export
/* Changes

Date		Name	TFS#	Description
============================================================================
05/06/2019	jlgka1	41865	Add Prefix in the filename based on the Schema Order.
============================================================================*/
vars
	file : File;
	clss : ClassInSchema;
	mtd	 : MethodInClass;
	appl : AppInSchema;	
begin	
	create file transient;
	file.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
	file.fileName	:= self.getFileNameUNL(sortOrderStr); //jlgka1 TFS 41865
	file.open;

	foreach clss in self.allClassesInSchema do
		
		if clss.extractWholeClass then
			if not clss.extractSubClassesWhenExtrClass then	
				file.writeLine( self.TXT_CLASS &amp;' '&amp; clss.name );
			else
				file.writeLine( self.TXT_CLASS &amp;' '&amp; clss.name &amp; app.myRootHotFix.EXTRACT_SUBCLASSES_STR );	// adding "..." to extract sub-classes
			endif;
		else
			foreach mtd in clss.allMethodsInClass do
				file.writeLine( 'Method ' &amp; clss.name &amp;' '&amp; mtd.name );
			endforeach;
		endif;
		
	endforeach;
	
	foreach appl in self.allAppsInSchema do
		if appl.name &lt;&gt; SchemaInPatch.JMT_RELEASE then  //13/07/2017 cnwma1	TFS #4847
			fInst.writeLine ( app.myRootHotFix.JMT_INSTALL_STR_RUNJADE 
							&amp; app.myRootHotFix.JMT_INSTALL_STR_SP
							&amp; self.name
							&amp; app.myRootHotFix.JMT_INSTALL_STR_SP
							&amp; appl.name
							&amp; app.myRootHotFix.JMT_INSTALL_STR_END);
		endif;
	endforeach;
	
	file.commit;
	file.close;
 	app.writeLogMessage(' Created ' &amp; file.fileName);

epilog
	delete file;

end;
</source>
        <Parameter name="fInst" type="File"/>
        <Parameter name="sortOrderStr" type="String"/>
    </JadeMethod>
</Class>
