        <Parameter name="pSplitContainer" type="CMUI_SplitContainer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="62fedbcd-222a-4c1c-b1e3-2ad6c74bb50e">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any TI can now be a reefer
vars
begin

//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '  receiving note for ' &amp; theObject.String);
	inheritMethod(eventType,theObject,eventTag); // PAR 10328 AKB2005JUL
	
	//if  theObject.isKindOf(CM_Container) or 	// CCMS 1007
	if  theObject.isKindOf(CM_TrackedItem) or 	// CCMS 1007
		eventTag = TAG_TEMPREADING then
		self.handleNotification(eventType, theObject, eventTag, null);
	endif;
epilog
	endLoad;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="6d9a7698-ab2f-42e1-a6ec-59a5a03fd7eb">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//----------------------------------------------------------------
//	Created:	14 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 10/12/2009 	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
// 11/10/2012	cnwdap1		PAR #30552 Inter-terminal transfers that haven't been connected at this terminal
//							should show as Not Connected colour, not Disconnected colour
vars
	//reefer : CM_Container;	// CCMS 1007
	reefer : CM_TrackedItem;	// CCMS 1007
	defrostHours, defrostLimit : Integer;
	now : TimeStamp;
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	inheritMethod(_idxRow, _obj);
	defrostLimit := self.myTerminal.getConfig(ReeferDefrostAlarmTime).Integer; //Aug 2007 cnwrs1 CCMS1551

	//if _obj.isKindOf(CM_Container) then	// CCMS 1007
		//reefer := _obj.CM_Container;		// CCMS 1007
	if _obj.isKindOf(CM_TrackedItem) then	// CCMS 1007
		reefer := _obj.CM_TrackedItem;		// CCMS 1007
		if reefer.getDefrostDate &lt;&gt; null and //Aug 2007 cnwrs1 CCMS1551
		   defrostLimit &lt;&gt; 0 then
			defrostHours := (reefer.getDefrostDate.differenceInHours(now));
		endif;
		if defrostHours &gt; defrostLimit and
		   defrostLimit &lt;&gt; 0 then
			tblData.accessRow(_idxRow).backColor := ColourVioletBright;
		elseif reefer.isConnected then
			tblData.accessRow(_idxRow).backColor := White;
		else
			if reefer.getLastConnectDT.isValid then
				if reefer.myMoveCloneFromTI = null then											// PAR #30552
					tblData.accessRow(_idxRow).backColor := self.ColorGreenLight;
				else																			// PAR #30552
					if reefer.getLastConnectDT = reefer.myMoveCloneFromTI.getLastConnectDT then	// PAR #30552
						tblData.accessRow(_idxRow).backColor := LightRed;						// PAR #30552
					else																		// PAR #30552
						tblData.accessRow(_idxRow).backColor := self.ColorGreenLight;			// PAR #30552
					endif;																		// PAR #30552
				endif;																			// PAR #30552
			else
				tblData.accessRow(_idxRow).backColor := LightRed;
			endif;	
		endif;
	endif;

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
