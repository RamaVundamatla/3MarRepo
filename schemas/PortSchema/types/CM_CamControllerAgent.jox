    <JadeMethod name="setupCams" id="f54ce34e-6fcc-4595-b5e0-752cd0f31fb1">
        <source>setupCams() protected;

// cnwdvb1	17 March 2003	 
// cnwjc2	25/08/2004		TRX'd
//
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging

vars
    addCountCams,
    addCountEDI		: Integer;
begin
    
    app.myTrxUA.trxSetupEDI(addCountCams, addCountEDI, app.myPassport);
	if app.myPassport.noErrors then
		app.writeLog(addCountCams.String &amp; " new protocol descriptions added.", LogINFO);
	endif;
epilog
	app.myPassport.clearErrorsWarnings();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="startTask" id="22226286-6207-48ad-9699-1c808f12ab6b">
        <updating/>
        <source>startTask(_runDateTime : TimeStamp; _startDateTime : TimeStamp; _endDateTime : TimeStamp) updating, protected;
// ---------------------------------------------------------------------------
// Created:		19 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
// 21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
// 17 Jul 2012	cnwcs5		par 29601 - log excluded transactions
//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//14 Aug 2012	cnwrs1	Par 30197 - restart not working
vars
	passport		: CM_Passport;
	seqNumber,
	dSeqNumber		: Integer;
	camTaskHistory	: CM_CamTaskHistory;
	endDateTime 	: TimeStamp;
	protocol		: CM_CamProtocol;	// cnwcs5 July 2012
begin
	endDateTime := _endDateTime;
	
	if _runDateTime &lt; _endDateTime then 
		// cnwrs1 par15573 Feb 2008 I have seen this happen in a CAMS log but dont know why
		self.writeLog("Rundate (" &amp; _runDateTime.String &amp; ") is less than endDate (" &amp; _endDateTime.String &amp; ") so resetting the end date to run date.");
		endDateTime := _runDateTime;
	endif;

	passport := app.myPassport;
	protocol := self.myCurrentCamProtocol;	// cnwcs5 July 2012
	
	if self.armExceptionHandler then
		on Exception do protocol.protocolExceptionHandler(exception);
	endif;

	app.writeLog(protocol.code.String &amp; app.getErrorString(MSG_CAMS_CreatingTask), LogWARN);
		
	seqNumber 	:= null;
	dSeqNumber 	:= null;
	
	if self.isAdhoc then
		seqNumber := Adhoc_Seq;
		// find previous and reuse
		camTaskHistory := protocol.taskHistoryByProtocolSeq[protocol, Adhoc_Key];
		
		app.writeLog("Retrieved history " &amp; camTaskHistory.String, LogWARN);
		
		if camTaskHistory &lt;&gt; null then
			dSeqNumber := camTaskHistory.dailySeqNumber + 1;
		endif;
	endif;

	self.setForInit(protocol, _runDateTime, _startDateTime, endDateTime, self.logExcludedTransactions, self.protocolLog, dSeqNumber, seqNumber, 0);	//par 30197 // par 29601 July 2012

	if not passport.trxCompletedOK() then
		self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;self.getCurrentProtocolCode(), " " &amp; app.getErrorString(Error) &amp; app.getErrorString(MSG_CAMS_CreatingTask), true, true, true);	//par 26290 cnwrs1 11 nov 2010
		passport.clearErrorsWarnings();
		return;
	endif;

	self.writeLog("===        " &amp; app.getErrorString1(InitialisedOK, app.getErrorString(MSG_CAM_TASK)) &amp; "        ===");
	self.writeLog(app.getErrorString2(ProcessPeriod, self.startDateTime.String, self.endDateTime.String));
	app.writeLog(protocol.code.String &amp; " " &amp; app.getErrorString1(InitialisedOK, app.getErrorString(MSG_CAM_TASK)) &amp; " " &amp; self.processSeqNumber.String,LogWARN);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_endDateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="1842f13f-efaa-47cf-b154-2235f265eb2b">
        <source>statusString(): String;
// ---------------------------------------------------------------------------
// Created:		22 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
begin
    if self.status = CAM_IDLESTATUS then
        return "Idle";
    elseif self.status = CAM_EXTRACTSTATUS then
        return "Extract";
    elseif self.status = CAM_SENDSTATUS then
        return "Send";
    elseif self.status = CAM_COMPLETESTATUS then
        return "Complete";
    elseif self.status = CAM_RESENDSTATUS then
        return "Resend";
    elseif self.status = CAM_HOLDSTATUS then
        return "Hold";
    elseif self.status = CAM_ERRORSTATUS then
        return "ERROR";
    else
        return self.status.String;
    endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="transferFile" id="93d0f2d7-fb07-4eac-8949-e4d003534e7f">
        <source>transferFile(_camTaskHistory : CM_CamTaskHistory; _destinationFilePath, _fileNameCreated : String input) : Boolean;
//
// 23 Feb 2017	cnwrs1 TFS3346 allow Cams file Transfer to work on onn user defined files
vars
	fileFolder : FileFolder;
	file : File;
	isFileError : Boolean;
	errorInfo : String;
	camTaskHistory : CM_CamTaskHistory;
	length : Integer;
	truncatedName : String;
begin
	create fileFolder transient;
	create file transient;
	// transfer another copy of the file to the specified destination folder
	fileFolder.fileName := _destinationFilePath;
	app.writeLog(class.name &amp; "::" &amp; method.name &amp; " transferDirectory " &amp; _destinationFilePath, LogDEBUG);
	
	if not fileFolder.isAvailable then
		on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 16 Nov 2012	cnwrs1	Par 30728
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " make transfer Directory " &amp; _destinationFilePath, LogINFO);
		fileFolder.make;
		if isFileError then
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
			self.logMessage(app.getErrorString2(ERR_CAMS_MAKEDIR, fileFolder.fileName, self.getCurrentProtocolCode()), null, true, true, false);
			return false;
		endif;
		on FileException do null;
	endif;
	
	file.fileName := _destinationFilePath.stripTrailingSlashes &amp; "/" &amp; _fileNameCreated;
	app.writeLog(class.name &amp; "::" &amp; method.name &amp; " transfer file " &amp; file.fileName, LogDEBUG);
	
	if _camTaskHistory.isUsingFileDataStorage then
		file.kind := file.Kind_Binary;
	endif;
	
	on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 16 Nov 2012	cnwrs1	Par 30728
	file.open();
	if isFileError then
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
		self.logMessage(app.getErrorString2(ERR_CAMS_OPENFILEFAIL, file.fileName, self.getCurrentProtocolCode()), null, true, true, false);	//par 26290 cnwrs1 	15 nov 2010
		return false;
	endif;
	on FileException do null;
	
	// now actual write the data out to the file
	app.writeLog(class.name &amp; "::" &amp; method.name &amp; " write " &amp; file.fileName, LogDEBUG);
	_camTaskHistory.writeFileDataToFile(file);
	camTaskHistory := _camTaskHistory;
	
	//05 May 2017	NDL TFS 4349
	length := file.fileName.length;
	if length &gt; 60 then	
		truncatedName := "..." &amp; file.fileName[( length - 55 ) : end];
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " transfer file name stored truncated to " &amp; truncatedName, LogDEBUG);
		camTaskHistory.setTransferFileName( truncatedName );
	else
		camTaskHistory.setTransferFileName(file.fileName);
	endif;
	file.close;
	return true;
epilog
	delete file;
	delete fileFolder;
end;
</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory"/>
        <Parameter name="_destinationFilePath" type="String" usage="input"/>
        <Parameter name="_fileNameCreated" type="String" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeCrashLogAlertAndEmail" id="d73fd330-18ad-43b3-8d69-c0de5a968fdb">
        <updating/>
        <source>writeCrashLogAlertAndEmail(_passport : CM_Passport) updating;
//
//25 Jun 2013	cnwrs1	Par31047 - Cams Exception Handler
//
vars
	processingErrorMsg : String;
	errStr	: String;
	errorArray : StringArray512;
	error : CM_Error;
	errorCode : Integer;
	errorText : String;
begin
	processingErrorMsg := app.getErrorString(ERR_CAMS_Process);
  	create errorArray transient;
	foreach error in _passport.allErrors do
		errorCode := error.errorCode;
		errorText := error.text;
		errStr := 'Error (' &amp; errorCode.String &amp; '). ' &amp; errorText;
		self.logMessage(errStr&amp;' '&amp;self.getErrorDesc(), null, true, true, true);
		
		errStr := processingErrorMsg &amp; " "  &amp; errorCode.String;
		
		if errorText &lt;&gt; null then
			errStr	:=	errStr &amp; ". " &amp; errorText;
		endif;
		if self.protocolLog &lt;&gt; null then
			self.logMessage(errStr&amp;' '&amp;self.getErrorDesc(), null, false, false, true);
		else
			app.writeLog(errStr&amp;' '&amp;self.getErrorDesc(), LogINFO);	//14 Nov 2012 cnwrs1 par 30728
		endif;
	endforeach;
//	app.alertMe(0, true, null, errStr, method, errorArray);
	self.setStatus(CAM_ERRORSTATUS);
epilog
 	delete errorArray;
end;
</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="writeDebugLog" id="e10e2abc-f5cc-4160-9caa-f3f9d78e6c50">
        <source>writeDebugLog(_message : String);
//
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask
//
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
vars

begin
	if self.myCurrentCamProtocol &lt;&gt;  null then
		if self.myCurrentCamProtocol.debug then
			app.writeLog(_message, LogINFO);
		endif;
	endif;
end;
</source>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeLog" id="7176e5f5-a803-483b-85c3-f595b6394675">
        <source>writeLog(_text: String);
// ---------------------------------------------------------------------------
// Created:		26 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Write to the current protocol log
//21 Nov 2012	cnwrs1		Par 30728 - 
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
vars
	log : File;
	now	: TimeStamp;
	isFileError : Boolean;
	errorInfo : String;
begin
	log := self.protocolLog;
	
	if log = null then
		app.writeLog("Protocol log file not initialised.", LogINFO);
		app.writeLog(_text, LogINFO);	//safety
		return;
	endif;
	
	if not log.isOpen then 
		log.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		log.allowReplace := false;
		log.mode := File.Mode_Append;
		on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 02 May 2012	cnwrs1	Par xxxx handle exceptions from file system
		isFileError	:=	false;
		log.open;
		if isFileError then
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
			self.logMessage(app.getErrorString2(ERR_CAMS_OPENFILEFAIL, log.fileName, self.getCurrentProtocolCode()), null, true, true, false);	//par 26290 cnwrs1 	15 nov 2010
			return;
		else
			on FileException do null;
		endif;
	endif;
	
	log.writeLine(now.literalFormat() &amp; Tab &amp; _text);
	
end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="xHandlerFile" id="bc02a069-0505-42f8-bc01-2e5d5ab8da30">
        <source>xHandlerFile(_exceptionObj:FileException; _isFailed:Boolean io; _errorInfo:String io):Integer protected;
// --------------------------------------------------------------------------------
// Created:		12 August 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	details		: String;
	errorMsg	: String;
	causedBy	: String;
	nodeObj		: FileNode;
	
begin
	_isFailed	:=	true;
	errorMsg	:=	process.getErrorText(_exceptionObj.errorCode);
	causedBy	:=	_exceptionObj.errorItem;
	nodeObj		:=	_exceptionObj.fileNode;
	
	details	:=	"'" &amp; nodeObj.fileName &amp; "' caused error " &amp; _exceptionObj.errorCode.String &amp; " (" &amp; errorMsg &amp; ")";
	
	if causedBy = null then
		details	:=	details &amp; ", the cause could not be identified.";
	else
		details	:=	details &amp; ", which was caused by '" &amp; causedBy &amp; "'.";
	endif;
	
	_errorInfo	:=	details;
	
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="FileException"/>
        <Parameter name="_isFailed" type="Boolean" usage="io"/>
        <Parameter name="_errorInfo" type="String" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
