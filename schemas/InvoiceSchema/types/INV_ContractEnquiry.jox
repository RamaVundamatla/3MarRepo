    <JadeMethod name="doTblDataContextMenu" id="7a204f36-9400-47a1-a7e0-53dfb181d619">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*
Purpose:			

Date		Who		Reason
14 December 2022	navab1	TFS CR 55645 TASK 55662
18 March 2024 navrv30 Bug 62682: FR - 54089 - Primary status - Invoice contracts
*/

vars
	xLeft 	: Real;
	yTop	: Real;
	obj1,
	obj2 : CM_InvoiceContract;
	
begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;	   
	
	self.mnuColOrganiser.visible := true;
	//18 March 2024 navrv30 Bug 62682
	self.mnuSwitchPrimary.visible := false;
	if self.tblData.allSelectedObjects.size = 2 then 		
		obj1 := self.tblData.allSelectedObjects.first.CM_InvoiceContract;
		obj2 := self.tblData.allSelectedObjects.last.CM_InvoiceContract;
		if obj1.myDebtor = obj2.myDebtor then
			if obj1.primary or obj2.primary then
				self.mnuSwitchPrimary.visible := true;
			endif;
		endif;
	endif;	
	self.popupMenu(mnuContext, xLeft.Integer, yTop.Integer);
	
	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateContract" id="7cc4d075-33a7-44a0-adb7-5c952697ecbb">
        <updating/>
        <source>doUpdateContract() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
14 Nov 2024 navrv30 JIRA 33346 EUP | Invoice Contract Maintenance - Access issue
*/

vars
	form : INV_ContractMaint;
	invcontract : CM_InvoiceContract;
begin
		// Code Moved from doBtnUpdateClick																								//14.10.2024 navlc30 #19508
		invcontract := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContract;
		if invcontract = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		if invcontract &lt;&gt; null then
			//16/10/2023 navmv20	Bug 60893 - start
			form := self.myContractMaintForm;
			if form &lt;&gt; null then
				form.unloadForm();
			endif;
			form := app.loadForm(INV_ContractMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractMaint;
			//14 Nov 2024 navrv30 JIRA 33346
			if form = null then
				return;
			endif;
			self.myContractMaintForm := form;
			form.myParentForm := self;
			/*if form = null then
				form := app.loadForm(INV_ContractMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractMaint;
				self.myContractMaintForm := form;
				form.myParentForm := self;
			else
				return;
			endif;*/
			//form := app.loadForm(INV_ContractMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractMaint;
			//16/10/2023 navmv20	Bug 60893 -end
			
			if form &lt;&gt; null then
				form.updateMode := true;
				form.setInvContract(invcontract);
				form.setMyCurrentBank(self.myCurrentBank);
				form.centreWindow();
				//form.showModal; //16/10/2023 navmv20	Bug 60893
				form.show; //16/10/2023 navmv20	Bug 60893
			endif;
		endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateContractDetail" id="d767e499-9eea-4398-a02d-c1e6b0c7c8ff">
        <updating/>
        <source>doUpdateContractDetail() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results

*/

vars
	invoiceDetail : CM_InvoiceContractDetails;
	form : INV_ContractRateMaint;
begin
		invoiceDetail := self.tblDetails.accessRow(self.tblDetails.row).itemObject.CM_InvoiceContractDetails;
		if invoiceDetail = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		if invoiceDetail &lt;&gt; null then
			form := self.myContractRateMaintForm;
			if form &lt;&gt; null then
				form.unloadForm();
			endif;
			form := app.loadForm(INV_ContractRateMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateMaint;
			self.myContractRateMaintForm := form;
			form.myParentForm := self;
			
			if form &lt;&gt; null then
				//form.updateMode := true;	//31/01/2023	navkc1 Bug 61578
				form.mode := INV_ContractRateMaint.MODE_UPDATE; //31/01/2023	navkc1 Bug 61578
				form.setInvContract(invoiceDetail.myInvoiceContract);
				form.setMyCurrentBank(self.myCurrentBank);
				form.setInvContractDetail(invoiceDetail);
				form.centreWindow();
				//form.showModal; //16/10/2023	navmv20	Bug 60893
				form.show; //16/10/2023	navmv20	Bug 60893
			endif;			
			
		endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateContractRate" id="db931998-f634-4378-ae47-332396944cb8">
        <updating/>
        <source>doUpdateContractRate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results

*/

vars
	form : INV_ContractRateEntryMaint;
	bank :CM_Bank;
//	contractRate : CM_InvoiceContractRateEntry;
	rateEntriesMaintForm : INV_ContractRateEntriesMaint; ///25/10/2023 navmv20 CR 60503 Task 60505
	rateEntryDates : CMIF_ContractRateEntryDates; //25/10/2023 navmv20 CR 60503 Task 60505
	
	contractRate : CM_InvoiceContractRate;  //25/10/2023 NAVAB1 CR 60503 Task 60505
begin
		//25/10/2023 navmv20 CR 60503 Task 60505 - start
		rateEntryDates := self.tblRates.accessRow(self.tblRates.row).itemObject.CMIF_ContractRateEntryDates;
		if rateEntryDates = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		//25/10/2023 navmv20 CR 60503 Task 60505 - end
		
		/*if self.myInvLineDescription &lt;&gt; self.myContractDetails.myInvoiceLineType then
			app.msgBox(app.getErrorString(Invoi_line_type_chang_pleas_sa), app.getErrorString(Problem), MsgBox_OK_Only);
			return;
		endif;*/
		
		//25/10/2023 navmv20 CR 60503 Task 60505 - start
		if rateEntryDates &lt;&gt; null then
			if self.myRateEntriesMaintForm = null then // ### TFS BUG 61268 28NOV2023 NAVAB1
				self.myRateEntriesMaintForm := app.loadForm(INV_ContractRateEntriesMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateEntriesMaint;  // ### TFS BUG 61268 28NOV2023 NAVAB1
			endif;
			if self.myRateEntriesMaintForm &lt;&gt; null then
				contractRate := rateEntryDates.allInvoiceContractRateEntries.first.myInvoiceContractRate; //25/10/2023 NAVAB1 CR 60503 Task 60505
				self.myCurrentInvContractRate := contractRate; //25/10/2023 NAVAB1 CR 60503 Task 60505
				self.myCurrentInvContractDetail := self.myCurrentInvContractRate.myInvoiceContractDetail; //25/10/2023 NAVAB1 CR 60503 Task 60505
				
				
				rateEntriesMaintForm := self.myRateEntriesMaintForm; // ### TFS BUG 61268 28NOV2023 NAVAB1
				rateEntriesMaintForm.updateMode := true;
				rateEntriesMaintForm.setCMIFRateEntryDates(rateEntryDates);
				rateEntriesMaintForm.setInvoiceContractRate(self.myCurrentInvContractRate);
				rateEntriesMaintForm.setMyCurrentBank(self.myCurrentBank);
				rateEntriesMaintForm.myContractDetail := self.myCurrentInvContractDetail;
				rateEntriesMaintForm.myService := self.myCurrentInvContractRate.myService;
				rateEntriesMaintForm.myCalculationType := self.myCurrentInvContractRate.myCalculationType; // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
				rateEntriesMaintForm.myParentForm := self;
				rateEntriesMaintForm.centreWindow();
				rateEntriesMaintForm.mdiChild := Form.MdiChild_IsMdi;
				rateEntriesMaintForm.show;
			endif;
		endif;
	//25/10/2023 navmv20 CR 60503 Task 60505- end
epilog

end;</source>
    </JadeMethod>
