<PrimType name="Decimal">
    <JadeMethod name="jssAsKilobytes" id="e6a8f7f8-79ea-4aaf-8892-1b0b61641e2a">
        <source>jssAsKilobytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent kilobytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into kilobytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_KILOBYTE	: Integer = 1024;
	
begin
	return self / BYTES_PER_KILOBYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jssAsMegabytes" id="e7bbe70a-e723-4ecf-ab2c-fa0b11c77d82">
        <source>jssAsMegabytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent megabytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into megabytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_MEGABYTE	: Integer = 1048576;
	
begin
	return self / BYTES_PER_MEGABYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jssAsPercent" id="adb2d374-1a07-4fac-9c23-5ec2d80a75e8">
        <source>jssAsPercent(pDecimalPlaces:Integer; pIsRounded:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the receiver as a string formatted with a percent sign.
//
// Parameters:	pDecimalPlaces (Integer) - The number of places to truncate or
//					round off to.
//				pIsRounded (Boolean) - If true, residuals will be rounded off,
//					otherwise residuals will be discarded.
//
// Returns:		A string with the resulting percent value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	PERCENT_SIGN	: Character = "%";

vars
	stringResult	: String;
	
begin
	if pDecimalPlaces = 0 then
		if pIsRounded then
			stringResult	:=	self.rounded.String;
		else
			stringResult	:=	self.truncated.String;
		endif;
	else
		if pIsRounded then
			stringResult	:=	self.roundedTo(pDecimalPlaces).String;
		else
			stringResult	:=	self.truncatedTo(pDecimalPlaces).String;
		endif;
	endif;
	
	return stringResult &amp; PERCENT_SIGN;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pDecimalPlaces" type="Integer"/>
        <Parameter name="pIsRounded" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssAsWords" id="f86290f4-ce33-47d6-8ef3-adfe074d7e95">
        <source>jssAsWords(pTheFullLocale:LocaleFullInfo; pWordedWholeAmount:String io; pWordedDecimalAmount:String io);
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Converts the receiver into a string, expressed in words.
//
// Parameters:	pTheNumberFormat - The locale of the number format information to
//					apply to the receiver, for example, the US "Billion" versus the
//					UK "Thousand Million".
//				pWordedWholeAmount - The receiver's whole amount expressed in words.
//				pWordedDecimalAMount - The receiver's decimal amount expressed in words.
//
// Returns:		The whole and decimal amount parameters, expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFullLocale		: LocaleFullInfo;
	wholeAmount			: Real;
	decimalAmount		: Real;
	stringValue			: String;
	decimalSeparator	: String;
	separatorPosition	: Integer;
	
begin
	if pTheFullLocale = null then
		theFullLocale	:=	app.currentLocaleInfo;
	else
		theFullLocale	:=	pTheFullLocale;
	endif;
	
	stringValue			:=	self.String;
	decimalSeparator	:=	theFullLocale.numericInfo.decimalSeparator;
	separatorPosition	:=	stringValue.reversePos(decimalSeparator);
	
	if separatorPosition = 0 then
		wholeAmount		:=	self;
		decimalAmount	:=	0;
	else
		wholeAmount		:=	(stringValue.String[1:(separatorPosition - 1)]).Real;
		decimalAmount	:=	(stringValue.String[(separatorPosition + 1):end]).Real;
	endif;
	
	pWordedWholeAmount	:=	wholeAmount.jssAsWordsWhole(theFullLocale);
	
	if decimalAmount = 0 then
		pWordedDecimalAmount	:= $JSS_NUM_ZERO;
	else
		pWordedDecimalAmount	:=	decimalAmount.jssAsWordsWhole(theFullLocale);
	endif;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pTheFullLocale" type="LocaleFullInfo"/>
        <Parameter name="pWordedWholeAmount" type="String" usage="io"/>
        <Parameter name="pWordedDecimalAmount" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssFractionValue" id="b7285b42-9075-4f32-80e2-50dd2245d64c">
        <source>jssFractionValue():Integer;
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		Returns the fractional value of the receiver.
//
// Parameters:	None
//
// Returns:		The fraction part of the receiver, as a whole number (Integer).
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	fractionValue	: Real;
	decimalPlaces	: Integer;
	
begin
	decimalPlaces	:=	self.getDeclaredScaleFactor();
	
	if decimalPlaces = 0 then
		return 0;
	else
		fractionValue	:=	self mod 1;
		fractionValue	:=	fractionValue * (10 ^ decimalPlaces);
		
		return fractionValue.Integer;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssNumberFormat" id="9c412258-5cb3-42c0-89ad-7063b6d15b53">
        <source>jssNumberFormat():String;
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		Formats the receiver as a string value, i.e. 1234.56 will be
//				returned as "1,234.56".
//
// Parameters:	None
//
// Returns:		The receiver formatted as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.getDeclaredScaleFactor() = 0 then
		return self.userNumberFormat($CNEC_NO_DECIMALS);
	else
		return self.numberFormat();
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssRoundToFiveCents" id="337fac5b-44c1-40aa-89b2-6e095e12d422">
        <source>jssRoundToFiveCents():Decimal;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Rounds the receiver to the nearest five cents.
//
// Parameters:	None
//
// Returns:		The rounded dollar value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dollarAmount		: Integer;
	centsAmount			: Integer;
	remainingAmount		: Integer;
	roundedAmount		: Decimal[12, 2];
	
begin
	dollarAmount	:=	self.Integer;
	centsAmount		:=	((self - dollarAmount) * 100).Integer;
	remainingAmount	:=	centsAmount mod 5;

	if remainingAmount &lt; 3 then					// We must round down.
		centsAmount	:=	centsAmount - remainingAmount;
	else										// We are rounding up.
		centsAmount	:=	centsAmount + (5 - remainingAmount);

		if centsAmount = 100 then
			centsAmount		:=	0;
			dollarAmount	:=	dollarAmount + 1;
		endif;
	endif;

	roundedAmount	:=	dollarAmount + (centsAmount / 100);
	
	return roundedAmount;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="jssRoundToFiveCentsMod" id="df36e4c6-f520-4dfc-8d8a-ebf17cda5bb6">
        <source>jssRoundToFiveCentsMod(pRemainder:Integer io):Decimal;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Rounds the receiver to the nearest five cents, and returns the
//				remainder in the I/O parameter.
//
// Parameters:	pRemainder (Integer) - An I/O parameter which will return the
//				remainder of the receiver after rounding.
//
// Returns:		The rounded dollar value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dollarAmount		: Integer;
	centsAmount			: Integer;
	remainingAmount		: Integer;
	roundedAmount		: Decimal[12, 2];
	
begin
	dollarAmount	:=	self.Integer;
	centsAmount		:=	((self - dollarAmount) * 100).Integer;
	remainingAmount	:=	centsAmount mod 5;

	if remainingAmount &lt; 3 then					// We must round down.
		centsAmount	:=	centsAmount - remainingAmount;
	else										// We are rounding up.
		centsAmount	:=	centsAmount + (5 - remainingAmount);

		if centsAmount = 100 then
			centsAmount		:=	0;
			dollarAmount	:=	dollarAmount + 1;
		endif;
	endif;

	roundedAmount	:=	dollarAmount + (centsAmount / 100);
	pRemainder		:=	remainingAmount;
	
	return roundedAmount;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pRemainder" type="Integer" usage="io"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="jssWholeValue" id="21d44d8d-5d62-48e1-a8b6-fcee1895df06">
        <source>jssWholeValue():Integer;
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		Returns the whole value of the receiver.
//
// Parameters:	None
//
// Returns:		The whole part of the receiver, as an integer.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return (self.truncatedTo(0)).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
