	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pCnEcEmailAddressToUpdate.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out-of-date.
			self.agentSetError('Object is out-of-date.');
		endif;
	endif;

	// If we're still error free, then perform the operation.
	if self.lastError = null then
		pCnEcEmailAddressToUpdate.updateMe(
			pEmailAddress,
			pMyBaseData,
			pName);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
