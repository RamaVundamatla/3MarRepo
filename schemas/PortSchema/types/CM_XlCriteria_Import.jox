    <PrimAttribute name="isImport" id="4b15e9f8-3afe-4493-bdb6-c7d78a0120d2">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getCriteriaDisplay" id="c6cc86c7-4ff7-40d2-a5cf-b6daf777c515">
        <source>getCriteriaDisplay(_short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
*/

vars

begin
	if self.isImport then
		return "Import on";
	else
		return "Import off";
	endif;
epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCriteriaMatch" id="23656bd1-b6db-40bb-9f15-8f805c63b6a9">
        <source>isCriteriaMatch(_score : Integer output; _params : ParamListType): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
*/

vars
	param : Any;
	value : Boolean;
	count : Integer;
begin
	count := app.getParamListTypeLength(_params);
	if count &lt;&gt; 1 then
		return false;
	endif;
	param := app.getParamListTypeEntry(1, _params);
	
	if param.isKindOf(Boolean) then
		value := param.Boolean;
	else
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'Method called with incorrect parameter type');
	endif;
	if value = self.isImport then
		_score := 1;
		return true;
	endif;
	return false;

epilog

end;</source>
        <Parameter name="_score" type="Integer" usage="output"/>
        <Parameter name="_params" type="ParamListType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameAs" id="dde58c29-60b6-41f8-8184-cf1d6347d4fb">
        <source>isSameAs(_criteria : CM_XlCriteria_Import): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
*/

vars

begin
