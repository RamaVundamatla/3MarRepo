    <JadeMethod name="loadSerialDetails" id="bd897816-decf-4f3d-bd48-9c836c79fe4f">
        <source>loadSerialDetails();
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 March 2007	cnwer1	Initial creation - PAR#xxxx
//22/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/
vars
	serialConnDetails : CM_WinCEJadeSerialDetails;
	indx : Integer;
begin
	
	if self.myDevice &lt;&gt; null then
		serialConnDetails:=self.myDevice.myWinCESerialDetails;
	else
		serialConnDetails:=self.myWeighbridgeObj.mySerialDetails;
	endif;
	
	if serialConnDetails = null then
		return;
	endif;
	
	indx:=self.cmbDataBits.findStringExact(1,self.myAssistant.getDataBitsDesc(serialConnDetails.dataBits));
	if indx &lt;&gt; - 1 then
		self.cmbDataBits.listIndex:=indx;
	endif;
	
	indx := self.cmbFlowControl.findStringExact(1,self.myAssistant.getFlowControlDesc(serialConnDetails.flowControl));
	if indx &lt;&gt; - 1 then
		self.cmbFlowControl.listIndex:=indx;
	endif;

	indx := self.cmbParity.findStringExact(1,self.myAssistant.getParityDesc(serialConnDetails.parity));
	if indx &lt;&gt; - 1 then
		self.cmbParity.listIndex:=indx;
	endif;
	
	indx:=self.cmbStopBits.findStringExact(1,self.myAssistant.getStopBitsDesc(serialConnDetails.stopBits));
	if indx &lt;&gt; - 1 then
		self.cmbStopBits.listIndex:=indx;
	endif;
	
	//cnwjo3 par 23992
	indx:=self.cmbDeviceType.findStringExact(1,self.myAssistant.getDeviceTypeDesc(serialConnDetails.serialDeviceType));
	if indx &lt;&gt; -1 then
		self.cmbDeviceType.listIndex:=indx;
	endif;
	
	self.txtName.text :=serialConnDetails.portName;
	self.txtSpeed.text:=serialConnDetails.speedBps.String;
	self.txtTimeout.text:=serialConnDetails.timeout.String;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDevice" id="b740135f-c570-4754-b09f-49011343ef96">
        <updating/>
        <source>setMyDevice(_device : CM_RadioTelemetryDevice input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if self.myDevice &lt;&gt; _device then
		self.myDevice:=_device;
	endif;
epilog

end;</source>
        <Parameter name="_device" type="CM_RadioTelemetryDevice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyWeighbridge" id="b97c6e27-f629-4d37-adf5-561a0bf9d579">
        <updating/>
        <source>setMyWeighbridge(_weighBridgeObj: CM_WeighBridgeObj input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2017	cnwns1	Initial creation
//22/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars

begin
	if self.myWeighbridgeObj &lt;&gt; _weighBridgeObj then
		self.myWeighbridgeObj:=_weighBridgeObj;
	endif;
epilog

end;</source>
        <Parameter name="_weighBridgeObj" type="CM_WeighBridgeObj" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5b711e5e-eb78-4028-b67a-9fa658f8d8da">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 February 2007	cnwer1	Initial creation - PAR#xxxx
//22/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/
vars
	
	serialConnDetails : CM_WinCEJadeSerialDetails;		
	ownerId : String;
	isWeighbridge : Boolean;

begin
	inheritMethod();
	
	if self.myDevice = null and self.myWeighbridgeObj = null then
		self.unloadForm;
	endif;
	
	if self.myDevice &lt;&gt; null then
		serialConnDetails:=self.myDevice.myWinCESerialDetails;
		ownerId := self.myDevice.id;
		isWeighbridge := false;
	else
		serialConnDetails:=self.myWeighbridgeObj.mySerialDetails;
		ownerId := self.myWeighbridgeObj.name;
		isWeighbridge := true;
		self.cmbDeviceType.visible := false;	//05 Jul 2019	NDL	TFS 44965
		self.lblDeviceType.visible := false;	//05 Jul 2019	NDL	TFS 44965
	endif;
	
	self.grpDetails.left := (self.clientWidth/2)-(self.grpDetails.width/2);
	//self.grpDetails.top := (self.clientHeight/2)-(self.grpDetails.height/2);
	self.grpDetails.top := 10;
	
	self.caption:="Serial Connection details";
	self.lblDeviceName.caption:= ownerId;//	self.myDevice.id;
	self.myAssistant.comboSerialDataBits(self.cmbDataBits);
	self.myAssistant.comboSerialFlowControl(self.cmbFlowControl);
	self.myAssistant.comboSerialParity(self.cmbParity);
	self.myAssistant.comboSerialStopBits(self.cmbStopBits);
	self.myAssistant.comboSerialDeviceType(self.cmbDeviceType,isWeighbridge);  //cnwjo3 par 23992
	if serialConnDetails &lt;&gt; null then
		self.loadSerialDetails();
	endif;
	
	// cnwrl1 13/03/2009 - PAR 18239
	self.txtName.setFocus;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="934f4866-f79d-43d6-82f7-5dfbe7cfb4ed">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017473, locale);
	lblDataBits.translateCaption(Xlat_0005195, locale);
	lblDevice.translateCaption(Xlat_0005196, locale);
	lblDeviceType.translateCaption(Xlat_0015081, locale);
	lblFlowControl.translateCaption(Xlat_0005197, locale);
	lblParity.translateCaption(Xlat_0005198, locale);
	lblPortName.translateCaption(Xlat_0005199, locale);
	lblSpeedBps.translateCaption(Xlat_0005200, locale);
	lblStopBits.translateCaption(Xlat_0005201, locale);
	lblTimeOut.translateCaption(Xlat_0005202, locale);
end;</source>
    </JadeMethod>
</GUIClass>
