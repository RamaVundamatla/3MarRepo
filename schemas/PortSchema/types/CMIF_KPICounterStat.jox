    <JadeMethod name="getTEUGC" id="4dd6dd43-f884-444d-aca5-fd8b526fee97">
        <source>getTEUGC() : Decimal;
/*

Date		Who		Reason
09 July 2015	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	teu : Decimal[8,2];
begin
	ct:=self.getCargoType;
	if ct.isContainer then
		return null;
	endif;
	teu := ct.getTEUConversionValue(TEUConversionIndexGC);
	if ct.teuMultiplier = TEUMultiplierIndexQ then
		return teu * self.totalQuantity;
	elseif ct.teuMultiplier =  TEUMultiplierIndexW then
		return teu * self.totalWeight;
	endif;
	
	return teu;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalTEU" id="5bc3c94a-c1dd-42f5-8436-eb6d7af254f6">
        <source>getTotalTEU() : Decimal;
/*

Date		Who		Reason
15 July 2015	cnwer1	Initial creation PAR

*/

vars
	ct  : CM_CargoType;
begin
	ct:=self.getCargoType;
	
	if ct.isContainer then
		return self.getTEU20() + self.getTEU30 + self.getTEU40 + self.getTEU45 + self.getTEU53;
	else
		return self.getTEUGC();
	endif;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="isForContainer" id="cc7e0451-b013-444a-8035-1064e7ec2c07">
        <source>isForContainer() : Boolean;
/*

Date		Who		Reason
14 July 2015	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
begin
	
	ct:=self.getCargoType;
	if ct = null then
		return false;
	endif;
	
	
	return self.getCargoType.id = TI_CargoType_Container;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromKPICargo" id="6c5b3a15-167e-4b79-88f1-a75398a61bd5">
        <updating/>
        <source>setFromKPICargo(cargoEntity : CM_KPICargoEntity input) updating;
/*

Date		Who		Reason
10 July 2015	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	cargoDtl 		: CM_KPICargoDtl;
	ti : CM_TrackedItem;
begin
	self.totalQuantity:=self.totalQuantity + cargoEntity.totalQty;
	self.totalVolume := self.totalVolume + cargoEntity.totalVolume;
	self.totalWeight := self.totalWeight + cargoEntity.totalWeight;
	ct:=self.getCargoType;
	if ct.isContainer  then	
		cargoDtl:=cargoEntity.allKPICargoDetails[20];
		if cargoDtl &lt;&gt; null then
			self.total20:=self.total20 + cargoDtl.totalItems;
		endif;
		cargoDtl:=cargoEntity.allKPICargoDetails[30];
		if cargoDtl &lt;&gt; null then
			self.total30:=self.total30 + cargoDtl.totalItems;
		endif;
		cargoDtl:=cargoEntity.allKPICargoDetails[40];
		if cargoDtl &lt;&gt; null then
			self.total40:=self.total40 + cargoDtl.totalItems;
		endif;
		cargoDtl:=cargoEntity.allKPICargoDetails[45];
		if cargoDtl &lt;&gt; null then
			self.total45:=self.total45 + cargoDtl.totalItems;
		endif;
		cargoDtl:=cargoEntity.allKPICargoDetails[53];
		if cargoDtl &lt;&gt; null then
			self.total53:=self.total53 + cargoDtl.totalItems;
		endif;		
	endif;
	
	foreach ti in cargoEntity.allTrackedItems discreteLock do
		if not self.allTIs.includes(ti) then
			self.allTIs.add(ti);
		endif;
	endforeach;
	
	
	
epilog

end;</source>
        <Parameter name="cargoEntity" type="CM_KPICargoEntity" usage="input"/>
    </JadeMethod>
</Class>
