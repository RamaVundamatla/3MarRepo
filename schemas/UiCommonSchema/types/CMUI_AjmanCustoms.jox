    <JadeMethod name="setDataFieldsFromObject" id="7c224a89-5041-47c3-afe7-cddeb5dc821e">
        <updating/>
        <source>setDataFieldsFromObject(_obj: CM_Object; _lineUp: Boolean; _showLabelArea: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

begin

	if _showLabelArea then
		//app.printer.print( self.testFrame );
		self.printLabelFieldAreaBoundary();	//21 July 2014	NDL Par 34611
	endif;
		
	if _lineUp then
		self.populateLineUp();
		return;
			
	elseif _obj &lt;&gt; null then
	
		self.myPopulatingObject := _obj;	//31 Jan 2014	NDL	Par 33181
	
		if _obj.isKindOf( CM_DutyDoc ) then
			self.setFromDutyDoc( _obj.CM_DutyDoc );
		else
			self.populateLineUp();
		endif;
	
		return;
		
	endif;
	
	inheritMethod( _obj, _lineUp, _showLabelArea );

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_lineUp" type="Boolean"/>
        <Parameter name="_showLabelArea" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromDutyDoc" id="382c1ce6-3db1-4f7e-9d5a-649d530ba179">
        <updating/>
        <source>setFromDutyDoc( _dutyDoc : CM_DutyDoc ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901
16 July		2014	cnwma1 PAR#34407 Duty Doc bill print issues

*/

vars

	items : CM_DutyDocItemSet;
	dutyCharges : Decimal [12,4];	//18 Dec 2013	NDL	Par 33182
	termCharges : Decimal [12,4];
	storageCharges : Decimal [12,4];
	otherCharges : Decimal [12,4];
	totalCharges : Decimal [12,4];
	cashReceipt : CM_CashReceipt;
	consignee, forwarder: CM_ConsigneeConsignor;
							
	item : CM_DutyDocItem;
	count : Integer;
	nextPageItems : CM_DutyDocItemByCargoId;
	
	allCashReceipts : CM_CashReceiptDict;	//18 Dec 2013	NDL	Par 33182
	
	i: Integer;

begin

	self.allDutyDocItems.clear();
	if not _dutyDoc.allDutyDocItems.isEmpty then
		_dutyDoc.allDutyDocItems.copy( self.allDutyDocItems );
	endif;
	
	items := _dutyDoc.allDutyDocItems;
	_dutyDoc.getChargesFor(	items,	//_items : CM_DutyDocItemByCargoId;
							dutyCharges,	//_dutyCharges : Decimal output;	//18 Dec 2013	NDL	Par 33182
							termCharges,	//_termCharges : Decimal output;
							storageCharges,	//_storageCharges : Decimal output;
							otherCharges,	//_otherCharges : Decimal output;
							totalCharges	//_totalCharges : Decimal output
							);
							
	create allCashReceipts transient;	//18 Dec 2013	NDL	Par 33182
	 _dutyDoc.getCashReceipts( allCashReceipts );
	//cashReceipt := _dutyDoc.getCashReceipt();  // currently this can only ever return null... 21 Dec 2012 NDL
	
	self.lblD.caption := _dutyDoc.id;	// Field 1
	self.lblC.caption := _dutyDoc.createdTime.Date.shortFormatJMT;	// Field 2	- declaration Date
	self.lblB.caption := _dutyDoc.getDutyDocTypeObject.description;	// Field 3   // PAR 33195
	self.lblA.caption := "SEA PORT";	// Field 4  Port type
	self.lblG.caption := _dutyDoc.deliveryOrder;	// Field 5
	consignee := _dutyDoc.getMyConsignee;
	if consignee &lt;&gt; null then
		self.lblF.caption := consignee.description;	// Field 6   // PAR 33195
	endif;
	self.lblE.caption := _dutyDoc.getNetWeightOf( items ).asStringWeightJMT;	// Field 7 - Net Weight of Cargo
	self.lblJ.caption := _dutyDoc.driver;	// Field 8
	forwarder := _dutyDoc.getMyForwarder;    // PAR 33195
	if forwarder &lt;&gt; null then
		self.lblI.caption := forwarder.description;	// Field 9
	endif;
	self.lblH.caption := _dutyDoc.getGrossWeightOf( items ).asStringWeightJMT;	// Field 10 - Gross Weight of Cargo
	if _dutyDoc.voyage = null then    // PAR 34219
		self.lblM.caption := _dutyDoc.transportation;	// Field 11
	else
		self.lblM.caption := _dutyDoc.getMyVoyage().vesselName;	// Field 11
	endif;
	if forwarder &lt;&gt; null then
		self.lblL.caption := forwarder.licenseExpiryDate.asStringJMT();	// Field 12 // PAR 33195
	endif;
	self.lblK.caption := _dutyDoc.getTotalVolumeOf( items ).jasVolumeString;	// Field 13 - Total Volume of Cargo
	self.lblP.caption := _dutyDoc.voyage;	// Field 14
	self.lblO.caption := _dutyDoc.destination;	// Field 15
	self.lblN.caption := _dutyDoc.getTotalNumPackagesFor( items ).String;	// Field 16
	self.lblBT.caption := _dutyDoc.getBOL;	// Field 17
	self.lblBU.caption := _dutyDoc.getLoadPort;	// Field 18	
	//self.lblBS.caption := _dutyDoc.getCargoIdsFor( _dutyDoc.allDutyDocItems );	// Field 19  //16 July 2014 cnwma1 PAR#34407
	self.lblQ.caption := _dutyDoc.getDischargePort;	// Field 20	
	self.lblR.caption := _dutyDoc.destination;	// Field 21
	
	self.lblAA.caption := _dutyDoc.goodsDescription;	// Field 23	//07 Aug 2013 NDL Par 32305
	
	self.lblBE.caption := _dutyDoc.forwarder;	// Field 38
	self.lblBF.caption := _dutyDoc.forwarderLicenseNo;	// Field 39
	
	self.lblBM.caption := _dutyDoc.reason;	// Field 45
	self.lblBN.caption := _dutyDoc.groupSuperUserId;	// Field 46
	self.lblBO.caption := _dutyDoc.customsInspectorUser;	// Field 47
	self.lblBP.caption := _dutyDoc.remarks;	// Field 48
	self.lblBQ.caption := _dutyDoc.approvedDate.shortFormatJMT;	// Field 49
	self.lblBG.caption := _dutyDoc.getRoute;	// Field 50
	self.lblBH.caption := _dutyDoc.exitPort;	// Field 51
	self.lblBI.caption := null;	// Field 52
	self.lblBJ.caption := null;	// Field 53
	self.lblBK.caption := null;	// Field 54
	self.lblBL.caption := null;	// Field 55
	self.lblAN.caption := dutyCharges.asCurrencyJMT;	////18 Dec 2013	NDL	Par 33182	// _dutyDoc.getTotalDutyOf( items ).asCurrencyJMT;	// Field 56
	self.lblAO.caption := termCharges.asCurrencyJMT;	// Field 57
	self.lblAP.caption := storageCharges.asCurrencyJMT;	// Field 58
	self.lblAQ.caption := otherCharges.asCurrencyJMT;	// Field 59
	self.lblAR.caption := totalCharges.asCurrencyJMT;	// Field 60				// PAR 31516
	self.lblAS.caption := _dutyDoc.dutyDeposit.asCurrencyJMT;	// Field 61     // PAR 31516
/*	if cashReceipt &lt;&gt; null then
		self.lblAT.caption := cashReceipt.myPaymentMethod.description;	// Field 62
		self.lblAU.caption := cashReceipt.sequenceNum.String;	// Field 63
		if cashReceipt.chequeNumber = null then
			self.lblAV.caption := cashReceipt.getAmountForBalanceTotal(null).asCurrencyJMT;	// Field 64
		else
			self.lblAW.caption := cashReceipt.getAmountForBalanceTotal(null).asCurrencyJMT;	// Field 65
			self.lblAX.caption := cashReceipt.chequeNumber;	// Field 66
			self.lblAY.caption := cashReceipt.chequeDate.shortFormatJMT;	// Field 67
			self.lblAZ.caption := cashReceipt.chequeBank;	// Field 68
		endif;
	endif; */
	//18 Dec 2013	NDL	Par 33182
	if not allCashReceipts.isEmpty then
		self.lblAT.caption := allCashReceipts.getMopsString();	// Field 62
		self.lblAU.caption := allCashReceipts.getSequencesString();	// Field 63
		self.lblAV.caption := allCashReceipts.getNonChqBalanceTotalDecimal.asCurrencyJMT;	// Field 64
		self.lblAW.caption := allCashReceipts.getChqBalanceTotalDecimal.asCurrencyJMT;	// Field 65
		self.lblAX.caption := allCashReceipts.getChequeNumbers;	// Field 66
		self.lblAY.caption := allCashReceipts.getChequeDates;	// Field 67
		self.lblAZ.caption := allCashReceipts.getChequeBanks;	// Field 68
	endif;
	
	self.lblBA.caption := _dutyDoc.getPortRemarksString( items );	// Field 69	// 19 Dec 2013	NDL	Par 33229
	self.lblBB.caption := _dutyDoc.supervisorUserId &amp; _dutyDoc.getConfirmationDateSupervisor.Time.shortFormatJMT;	// Field 70
	self.lblBC.caption := _dutyDoc.dutyDocUserId;	// Field 71
	self.lblBD.caption := _dutyDoc.getConfirmationDateDutyDocUser.Time.shortFormatJMT;	// Field 72
	
	self.pageNo := 1;
//	self.lblBR.caption := self.pageNo.String;	// Page No
	self.setTotalPages( self.pageNo );
	
	
	self.lblBV.caption := _dutyDoc.ticket;	    // Ticket No   PAR 33229 19 Dec 2013
	foreach item in _dutyDoc.allDutyDocItems do 
		count := count+ 1;

		if count &lt;7 then
			// the first six will fit on this page
			self.setFromDutyDocItem( item, count  ); // Fields 22, 24 - 37  and  40 - 44.
		else 			//create a new page for the rest
			if count =7 then
				create nextPageItems transient;
			endif;
			nextPageItems.add( item );

		endif;
	endforeach;
	if nextPageItems &lt;&gt; null then
		self.createNextPage( nextPageItems );
	endif;

epilog

	delete nextPageItems;

end;</source>
        <access>protected</access>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
    </JadeMethod>
    <JadeMethod name="setFromDutyDocItem" id="113240e1-59b0-4055-90b1-4984ceb14c87">
        <source>setFromDutyDocItem( _item : CM_DutyDocItem; _count : Integer  ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwndl1	Initial creation	Par 30901
16 July		2014	cnwma1 PAR#34407 Duty Doc bill print issues


*/

vars

	localSep : String;

begin

	if _count = self.allDutyDocItems.size or _count = 6 then
		localSep := null;
	else
		localSep := self.separator;
	
	endif;

	self.lblAB.caption := self.lblAB.caption &amp; _item.hsCode &amp; localSep;	// Field 22
//	self.lblAA.caption := self.lblAA.caption &amp; _item.cargoDetails &amp; localSep;	// Field 23 //07 Aug 2013	NDL	Par 32305 Now populated from Duty Doc not items.
	self.lblZ.caption := self.lblZ.caption &amp; _item.origin &amp; localSep;	// Field 24
	self.lblY.caption := self.lblY.caption &amp; _item.foreignValue.asCurrencyJMT &amp; localSep;	// Field 25
	self.lblX.caption := self.lblX.caption &amp; _item.currency &amp; localSep;	// Field 26
	self.lblW.caption := self.lblW.caption &amp; _item.currencyRate.asStringJMTWithPrecision(4,false) &amp; localSep;	// Field 27
	self.lblV.caption := self.lblV.caption &amp; _item.localValue.asCurrencyJMT &amp; localSep;	// Field 28
	self.lblU.caption := self.lblU.caption &amp; _item.dutyRate.asStringJMTWithPrecision(1,false) &amp; localSep;	// Field 29
	self.lblT.caption := self.lblT.caption &amp; " " &amp; localSep;	// Field 30	Not used
	self.lblS.caption := self.lblS.caption &amp; _item.duty.asCurrencyJMT &amp; localSep;	// Field 31
	
	self.lblAK.caption := self.lblAK.caption &amp; _item.quantity.String &amp; localSep;	// Field 32
	self.lblAJ.caption := self.lblAJ.caption &amp; _item.getPackingTypeString() &amp; localSep;	// Field 33
	self.lblAI.caption := self.lblAI.caption &amp; " " &amp; localSep;	// Field 34
	self.lblAH.caption := self.lblAH.caption &amp; " " &amp; localSep;	// Field 35
	self.lblAG.caption := self.lblAG.caption &amp; _item.netWeight.asStringWeightJMT &amp; localSep;	// Field 36
	self.lblAF.caption := self.lblAF.caption &amp; _item.grossWeight.asStringWeightJMT &amp; localSep;	// Field 37
	
	self.lblAM.caption := self.lblAM.caption &amp; " " &amp; localSep;	// Field 40
	self.lblAL.caption := self.lblAL.caption &amp; " " &amp; localSep;	// Field 41
	self.lblAE.caption := self.lblAE.caption &amp; _item.exemptDutyCode &amp; localSep;	// Field 42
	self.lblAD.caption := self.lblAD.caption &amp; _item.exemptSource &amp; localSep;	// Field 43
	self.lblAC.caption := self.lblAC.caption &amp; _item.exemptBenefit &amp; localSep;	// Field 44

	if self.lblBS.caption.trimBlanks &lt;&gt; null then 	// Field 19					//16 July 2014 cnwma1 PAR#34407
		self.lblBS.caption := self.lblBS.caption  &amp; ' ';
	endif;
	
	self.lblBS.caption := self.lblBS.caption &amp; _item.cargoId; // Field19	   //16 July 2014 cnwma1 PAR#34407
	
	epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="CM_DutyDocItem"/>
        <Parameter name="_count" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTotalPages" id="06d30544-ff25-4c6d-bfc6-031397ef470d">
        <updating/>
        <source>setTotalPages( _tot : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2014	cnwndl1	Initial creation

*/

vars

begin

	self.totalPages := _tot;
	self.lblBR.caption := self.pageNo.String &amp; "/" &amp; self.totalPages.String;
	
	if self.myPreviousPage &lt;&gt; null then
		self.myPreviousPage.setTotalPages( _tot );
	endif;

epilog

end;</source>
        <Parameter name="_tot" type="Integer"/>
    </JadeMethod>
</GUIClass>
