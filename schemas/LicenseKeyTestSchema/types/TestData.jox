<Class name="TestData" id="39b5a0d1-becf-4e85-8711-c5ea02d4ea44">
    <superclass name="PersistentModel"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="license_test"/>
    <ExplicitInverseRef name="allLicenseInfos" id="0cbf6365-d42a-48c0-8f31-985245b6216b">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="LicenseInfoByNameDict"/>
        <access>readonly</access>
        <Inverse name="LicenseInfo::myTestData"/>
    </ExplicitInverseRef>
    <JadeMethod name="createLicenseInfo" id="1de650ce-d188-4e50-9b05-a9add60bd3c0">
        <source>createLicenseInfo(pCustomerName:String; pProductCode:String; pLicenseKey:String):LicenseInfo;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Purpose:		Create a new LicenseInfo object, update its properties, and return
//				the new object.
//
// Parameters:	pCustomerName - The name of the customer to whom the product is licensed.
//				pProductCode - The unique code of the product being licensed.
//				pLicenseKey - The customer's product license key.
//
// Returns:		The new license info object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicenseInfo	: LicenseInfo;
	
begin
	beginTransaction;
	create theLicenseInfo;
	theLicenseInfo.updateMe(pCustomerName, pProductCode, pLicenseKey, self);
	commitTransaction;
	
	return theLicenseInfo;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="LicenseInfo"/>
    </JadeMethod>
    <JadeMethod name="deleteLicenseInfo" id="5598fdd1-2b8e-47f8-abda-062696a75fdf">
        <source>deleteLicenseInfo(pTheLicenseInfo:LicenseInfo io);
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Purpose:		Delete the specified prodict license object.
//
// Parameters:	pTheLicenseInfo - The license object to delete.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTransaction;
	delete pTheLicenseInfo;
	commitTransaction;
end;</source>
        <Parameter name="pTheLicenseInfo" type="LicenseInfo" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateLicenseInfo" id="0665bef2-a9da-4869-91eb-b99f03cf705f">
        <source>updateLicenseInfo(pTheLicenseInfo:LicenseInfo input; pCustomerName:String; pProductCode:String; pLicenseKey:String);
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Purpose:		Update the properties of the specified LicenseInfo object.
//
// Parameters:	pTheLicenseInfo - The license info object to update.
//				pCustomerName - The name of the customer to whom the product is licensed.
//				pProductCode - The unique code of the product being licensed.
//				pLicenseKey - The customer's product license key.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTransaction;
	pTheLicenseInfo.updateMe(pCustomerName, pProductCode, pLicenseKey, self);
	commitTransaction;
end;</source>
        <Parameter name="pTheLicenseInfo" type="LicenseInfo" usage="input"/>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
    </JadeMethod>
</Class>
