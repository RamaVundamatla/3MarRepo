    <JadeMethod name="addUser" id="9703a2a8-17f0-4b34-a849-331fe2b5376a">
        <updating/>
        <source>addUser(_userIndex : Integer; _userName : String) : JSSCTUser updating;
//
//16 Sep 2013	cnwrs1	CCMS 2238 C3 Change Tracker User code
//
vars
	user	: JSSCTUser;
	iter : Iterator;
begin

	iter := self.myChangeTrackingRoot.allUsersByIndex.createIterator;
	// need to tidy up any old users with this index. cnwrd1 par 34666
	self.myChangeTrackingRoot.allUsersByIndex.startKeyGeq(_userIndex, iter);
	
	while iter.next(user) do
		if user.index &lt;&gt; _userIndex then
			break;
		else
			delete user;
		endif;
	endwhile;
	
	create user;
	user.update(_userIndex, _userName, self.myChangeTrackingRoot);

	return user;
epilog
	delete iter;
end;</source>
        <Parameter name="_userIndex" type="Integer"/>
        <Parameter name="_userName" type="String"/>
        <ReturnType type="JSSCTUser"/>
    </JadeMethod>
    <JadeMethod name="changeUser" id="88ac9035-7e8e-440f-aab8-8e4b185b65b6">
        <updating/>
        <source>changeUser(_userIndex : Integer; _userName : String) updating;
//
//16 Sep 2013	cnwrs1	CCMS 2238 C3 Change Tracker User code
//
vars
	user : JSSCTUser;
begin
	user := self.myChangeTrackingRoot.allUsersByIndex[_userIndex];
//	beginTransaction;
	if user = null then
		user := self.addUser(_userIndex, _userName);
	else
		user.update(_userIndex, _userName, self.myChangeTrackingRoot);
	endif;
//	commitTransaction;
end;
</source>
        <Parameter name="_userIndex" type="Integer"/>
        <Parameter name="_userName" type="String"/>
    </JadeMethod>
    <JadeMethod name="checkForIniFileClasses" id="28710561-0ded-44dd-8ba4-35b4f5aa4fb9">
        <updating/>
        <source>checkForIniFileClasses(pJournalInterface: JSSCTAuditLogInterface) updating, protected;

vars
	changeClass: JSSCTChangeTrackingClass;
	class: String;
	classNumber: Integer;
	iniFile: String;
	serverExecuteLog: Boolean;
	journalInterface: JSSCTAuditLogInterface;
	subClasses: Boolean; // JETkgd
	pos: Integer; // JETkgd
begin 
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);

	journalInterface := pJournalInterface;
	if journalInterface = null then
		create journalInterface transient;
		journalInterface.myPersistentInstance := JSSCTAuditLogInterface.firstInstance;
		journalInterface.myNibblerManager := self;
		create self.myChangeObjectTA transient;
		self.myChangeObjectTA.myChangeTrackingRoot := self.myChangeTrackingRoot;
		create self.myChangeTrackingClassTA transient;
		self.myChangeTrackingClassTA.myChangeTrackingRoot := self.myChangeTrackingRoot;
		create self.myClassInitializeRequestTA transient;
	endif;
	//	process journal locally or on the server
	serverExecuteLog := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "ReadLogServerExecution", 'true').toLower = "true";
	journalInterface.clearClasses(serverExecuteLog);

	iniFile := app.getIniFileNameAppServer();
	self.trackAllClassesByDefault := app.getProfileStringAppServer(iniFile, "JSSChangeTracker", "TrackAllClassesByDefault", 'true').toLower = 'true';

	if self.trackAllClassesByDefault then
		//	first, get all the classes that we are to IGNORE
		self.checkForIniFileIgnores(journalInterface);
	else
		//	first, get all the classes that we are to INCLUDE
		self.checkForIniFileIncludes(journalInterface);
	endif;
	//	now get any definitions for ignoring deletes of a class within a specified instance range
	self.checkForIniFileIgnoreDeletes();
	//	now get any collections that we need to track the owning objects for
	self.checkForIniFileCollectionIncl(journalInterface);

// kgd 310ct
	//	now get all the classes that we need to initialize up front
	foreach classNumber in 1 to 999 do
		class := app.getProfileStringAppServer(iniFile, "JSSChangeTracker", "LoadClass" &amp; (classNumber+1000).String[2:3], '');
		if class = null then
			break;
		endif;
		//	check if [optional] sub classes specified
		pos := class.pos(',',1);
		if pos &gt; 0 then
			subClasses := class[pos+1:1].toUpper = 'Y';
			class := class[1:pos - 1];
		else
			subClasses := false;
		endif;
		if self.trackAllClassesByDefault then
			//	check if we have been asked to ignore this class
			if self.allClassIniFileEntries[class] &lt;&gt; null then
				self.monitor("Class '" &amp; class &amp; "' has an Ignore Class entry specified. It will be ignored", MONITOR_ALWAYS);
				continue;
			endif;
		else
			//	check if we have NOT been asked to include this class
			if self.allClassIniFileEntries[class] = null then
				self.monitor("Class '" &amp; class &amp; "' does not have an Include Class entry specified. It will be ignored", MONITOR_ALWAYS);
				continue;
			endif;
		endif;

		if subClasses then
			self.getLoadClassSubclasses(class);
		else
			changeClass := self.myChangeTrackingRoot.allChangeClasses[class, false];
			if changeClass = null then
				//	start the initialization process for this class
				self.createChangeDictForClass(class, false, false);
			elseif changeClass.initializing then

				self.myClassInitializeRequestTA.applicationClass := class;
				self.myClassInitializeRequestTA.myNotificationObject := self.myNotificationObject.mySharedTransientInstance;
				if self.isStartedApplication then
					self.myClassInitializeRequestTA.applicationSchema := self.myNotificationObject.mySharedTransientInstance.applicationSchema;
				else
					self.myClassInitializeRequestTA.applicationSchema := currentSchema;
				endif;
				self.myClassInitializeRequestTA.createEntitySharedTransient();

				//	start an app to initialize the collection for this class
				self.startClassInitializerApp(self.myClassInitializeRequestTA.myInitializeClassRequest);
			endif;
		endif;
// kgd 31Oct
/*
		//	check if we already have started tracking this class
		changeDict := self.myChangeTrackingRoot.allChangesByTimeDicts[class];
		if changeDict = null then

			//	start the initialization process for this class
			self.createChangeDictForClass(class, false, false);

		elseif changeDict.initializing then

			self.myClassInitializeRequestTA.applicationClass := class;
			self.myClassInitializeRequestTA.myNotificationObject := self.myNotificationObject.mySharedTransientInstance;
			if self.isStartedApplication then
				self.myClassInitializeRequestTA.applicationSchema := self.myNotificationObject.mySharedTransientInstance.applicationSchema;
			else
				self.myClassInitializeRequestTA.applicationSchema := currentSchema;
			endif;
			self.myClassInitializeRequestTA.createEntitySharedTransient();

			//	start an app to initialize the collection for this class
			self.startClassInitializerApp(self.myClassInitializeRequestTA.myInitializeClassRequest);

		endif;
*/
		process.sleep(0);

		//	check if we have been asked to stop
		if self.interruptProcessing then
			break;
		endif;
	endforeach;

epilog
	if pJournalInterface = null then
		delete journalInterface;
		delete self.myClassInitializeRequestTA;
		delete self.myChangeTrackingClassTA;
		delete self.myChangeObjectTA;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pJournalInterface" type="JSSCTAuditLogInterface"/>
    </JadeMethod>
    <JadeMethod name="checkForIniFileCollectionIncl" id="62c0ea95-1a94-4c53-a907-66236b43a883">
        <updating/>
        <source>checkForIniFileCollectionIncl(pJournalInterface: JSSCTAuditLogInterface) updating, protected;

/*

Date		Who		Reason
22 May 2009	cnwkpd1	CCMS SFW 1007 - For performance, always register at least one collection
					class is registered

*/

vars
	serverExecuteLog: Boolean;
	ownerClass: Class;
	collClass: Class;
	subclass: Class;
	classColl: ClassColl;
	collectionEntry: String;
	collectionName: String;
	collectionNumber: Integer;
	className: String;
	classNumber: Integer;
	iniFile: String;
	theSchema: Schema;
	posFrom: Integer;
	posTo: Integer;

	changeClass: JSSCTChangeTrackingClass;
	deleteClass: JSSCTChangeTrackingClass;
begin
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	//	process journal locally or on the server
	serverExecuteLog := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "ReadLogServerExecution", 'true').toLower = "true";

	iniFile := app.getIniFileNameAppServer();
	create classColl transient;

	if self.isStartedApplication then
		theSchema := self.myNotificationObject.mySharedTransientInstance.applicationSchema;
	else
		theSchema := currentSchema;
	endif;
	//	first, get all the classes that we are to IGNORE (clean out any old ones first)
	self.allClassCollectionEntries.purge;
	self.allCollectionClassEntries.purge;
	foreach classNumber in 1 to 999 do
		collectionEntry := app.getProfileStringAppServer(iniFile, "JSSChangeTracker", "IncludeCollection" &amp; (classNumber+1000).String[2:3], '');
		if collectionEntry = null then
			break;
		endif;
		//	get the parameters from the ini file entry (IncludeCollectionnnn=collectionName,className)
		posFrom := 1;
		posTo := collectionEntry.pos(',', posFrom);
		if posTo &lt;= posFrom then
			self.monitor("IncludeCollection" &amp; (classNumber+1000).String[2:3] &amp; " entry invalid format - " &amp; collectionEntry, MONITOR_ONLY);
			continue;
		endif;
		collectionName := collectionEntry[posFrom:posTo-1];

		//	check that the specified collection exists
		collClass := theSchema.getClass(collectionName);
		if collClass = null then
			self.monitor("Collection class " &amp; collectionName &amp; " not found in currentSchema " &amp; theSchema.name, MONITOR_ONLY);
			continue;
		endif;
		//	get the class to track the collection for
		posFrom := posTo + 1;
		if posFrom &gt; collectionEntry.length then
			self.monitor("IncludeCollection" &amp; (classNumber+1000).String[2:3] &amp; " entry, Collection " &amp; collectionName &amp; " invalid Class name format - " &amp; collectionEntry, MONITOR_ONLY);
			continue;
		endif;
		className := collectionEntry[posFrom:posTo-1];

		//	check that the specified class exists
		ownerClass := theSchema.getClass(className);
		if ownerClass = null then
			self.monitor("Collection class " &amp; collectionName &amp; ", Class " &amp; className &amp; " not found in currentSchema " &amp; theSchema.name, MONITOR_DEBUG);
			continue;
		endif;
		//	build the includeCollection entry for this collection and class
		self.createCollectionClassEntry(collectionName, className);

		pJournalInterface.registerClass(serverExecuteLog, collClass.number, ownerClass.number);

	endforeach;

	monitor ("Including " &amp; self.allCollectionClassEntries.size.String &amp; " collections", MONITOR_DEBUG);

	// KPD 22/05/2009 - If there are no collections to monitor, then call a dummy register to stop 
	// getting any collections
	if self.allCollectionClassEntries.isEmpty then
		pJournalInterface.registerClass(serverExecuteLog, JSSCTObjectByTimeDict.number, JSSCTChangeTrackingRoot.number);
	endif;
	
	
epilog
	delete classColl;
end;</source>
        <access>protected</access>
        <Parameter name="pJournalInterface" type="JSSCTAuditLogInterface"/>
    </JadeMethod>
    <JadeMethod name="checkForIniFileIgnoreDeletes" id="0d642c7f-cd19-4c85-9449-efc830b36f81">
        <updating/>
        <source>checkForIniFileIgnoreDeletes() updating, protected;

vars
	class: Class;
	subclass: Class;
	classColl: ClassColl;
	className: String;
	classNumber: Integer;
	deletesEntry: String;
	instanceStart: Integer;
	instanceEnd: Integer;
	iniFile: String;
	theSchema: Schema;
	posFrom: Integer;
	posTo: Integer;
begin
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	iniFile := app.getIniFileNameAppServer();
	create classColl transient;

	if self.isStartedApplication then
		theSchema := self.myNotificationObject.mySharedTransientInstance.applicationSchema;
	else
		theSchema := currentSchema;
	endif;
	//	get all the classes (and instance range) that we are to IGNORE object deletes for (clean out any old ones first)
	self.allClassIgnoreDeletesEntries.purge;
	foreach classNumber in 1 to 999 do
		deletesEntry := app.getProfileStringAppServer(iniFile, "JSSChangeTracker", "IgnoreDeletes" &amp; (classNumber+1000).String[2:3], '');
		if deletesEntry = null then
			break;
		endif;
		//	get the parameters from the ini file entry (IgnoreDeletesnnn=className,instanceStart,instanceEnd)
		posFrom := 1;
		posTo := deletesEntry.pos(',', posFrom);
		if posTo &lt;= posFrom then
			self.monitor("IgnoreDeletes" &amp; (classNumber+1000).String[2:3] &amp; " entry invalid format - " &amp; deletesEntry, MONITOR_ONLY);
			continue;
		endif;
		className := deletesEntry[posFrom:posTo-1];

		//	check that the specified class exists
		class := theSchema.getClass(className);
		if class = null then
			self.monitor("Class " &amp; className &amp; " not found in currentSchema " &amp; theSchema.name, MONITOR_ONLY);
			continue;
		endif;
		//	check if we are actually tracking this class
		if self.trackAllClassesByDefault then
			//	check if this class is in the list of classes to ignore
			if self.allClassIniFileEntries[className] &lt;&gt; null then
				self.monitor("IgnoreDeletes Class " &amp; className &amp; " has been specified to be ignored. This entry will not be processed.", MONITOR_ONLY);
				continue;
			endif;
		else
			//	check if this class is in the list of classes to include
			if self.allClassIniFileEntries[className] = null then
				self.monitor("IgnoreDeletes Class " &amp; className &amp; " has not been specified to be tracked. This entry will not be processed.", MONITOR_ONLY);
				continue;
			endif;
		endif;
		//	get the instance range
		posFrom := posTo + 1;
		posTo := deletesEntry.pos(',', posFrom);
		if posTo &lt;= posFrom then
			self.monitor("IgnoreDeletes" &amp; (classNumber+1000).String[2:3] &amp; " entry, Class " &amp; className &amp; " invalid instance range format - " &amp; deletesEntry, MONITOR_ONLY);
			continue;
		endif;
		instanceStart := deletesEntry[posFrom:posTo-1].Integer;
		posFrom := posTo + 1;
		if posFrom &gt; deletesEntry.length then
			self.monitor("IgnoreDeletes" &amp; (classNumber+1000).String[2:3] &amp; " entry, Class " &amp; className &amp; ", instanceStart " &amp; instanceStart.String &amp; " invalid instance end format - " &amp; deletesEntry, MONITOR_ONLY);
			continue;
		endif;
		instanceEnd := deletesEntry[posFrom:end].Integer;
		//	check that we have a valid start-end range
		if instanceEnd &lt;= instanceStart then
			self.monitor("IgnoreDeletes" &amp; (classNumber+1000).String[2:3] &amp; " entry, Class " &amp; className &amp; ", instanceStart " &amp; instanceStart.String &amp; ", instanceEnd " &amp; instanceEnd.String &amp; " invalid instance range - " &amp; deletesEntry, MONITOR_ONLY);
			continue;
		endif;
		//	build the ignoreDeletes entry for this class
		self.createIgnoreDeletesEntry(className, instanceStart, instanceEnd);

	endforeach;
epilog
	delete classColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkForIniFileIgnores" id="51d66e2b-b2ed-455d-af5f-55dc5f11d893">
        <updating/>
        <source>checkForIniFileIgnores(pJournalInterface: JSSCTAuditLogInterface) updating, protected;

vars
	serverExecuteLog: Boolean;
	class: Class;
	subclass: Class;
	classColl: ClassColl;
	className: String;
	classNumber: Integer;
	iniFile: String;
	theSchema: Schema;
begin
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	//	process journal locally or on the server
	serverExecuteLog := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "ReadLogServerExecution", 'true').toLower = "true";

	iniFile := app.getIniFileNameAppServer();
	create classColl transient;

	if self.isStartedApplication then
		theSchema := self.myNotificationObject.mySharedTransientInstance.applicationSchema;
	else
		theSchema := currentSchema;
	endif;
	//	first, get all the classes that we are to IGNORE (clean out any old ones first)
	self.allClassIniFileEntries.purge;
	foreach classNumber in 1 to 999 do
		className := app.getProfileStringAppServer(iniFile, "JSSChangeTracker", "IgnoreClass" &amp; (classNumber+1000).String[2:3], '');
		if className = null then
			break;
		endif;
		//	do the same for any/all subclass of this class
		class := theSchema.getClass(className);
		if class = null then
			self.monitor("Class " &amp; className &amp; " not found in currentSchema " &amp; theSchema.name, MONITOR_ONLY);
			continue;
		endif;
		//	build the ignoreClass entry for this class and all subclasses of it
		self.getIgnoreClassSubclasses(class, pJournalInterface, serverExecuteLog);

	endforeach;
epilog
	delete classColl;
end;</source>
        <access>protected</access>
        <Parameter name="pJournalInterface" type="JSSCTAuditLogInterface"/>
    </JadeMethod>
    <JadeMethod name="checkForIniFileIncludes" id="8e2d8260-12db-4c84-a727-6d7e86d7953f">
        <updating/>
        <source>checkForIniFileIncludes(pJournalInterface: JSSCTAuditLogInterface) updating, protected;

vars
	serverExecuteLog: Boolean;
	class: Class;
	subclass: Class;
	classColl: ClassColl;
	className: String;
	classNumber: Integer;
	subClasses: Boolean;
	pos: Integer;
	iniFile: String;
	theSchema: Schema;

	changeClass: JSSCTChangeTrackingClass;
	deleteClass: JSSCTChangeTrackingClass;
begin
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	//	process journal locally or on the server
	serverExecuteLog := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "ReadLogServerExecution", 'true').toLower = "true";

	iniFile := app.getIniFileNameAppServer();
	create classColl transient;

	if self.isStartedApplication then
		theSchema := self.myNotificationObject.mySharedTransientInstance.applicationSchema;
	else
		theSchema := currentSchema;
	endif;
	//	first, get all the classes that we are to IGNORE (clean out any old ones first)
	self.allClassIniFileEntries.purge;
	foreach classNumber in 1 to 999 do
		className := app.getProfileStringAppServer(iniFile, "JSSChangeTracker", "IncludeClass" &amp; (classNumber+1000).String[2:3], '');
		if className = null then
			break;
		endif;
		//	check if [optional] sub classes specified
		pos := className.pos(',',1);
		if pos &gt; 0 then
			subClasses := className[pos+1:1].toUpper = 'Y';
			className := className[1:pos - 1];
		else
			subClasses := false;
		endif;
		//	validate the class name specified
		class := theSchema.getClass(className);
		if class = null then
			self.monitor("Class " &amp; className &amp; " not found in currentSchema " &amp; theSchema.name, MONITOR_ONLY);
			continue;
		endif;
		if subClasses then

			//	build the includeClass entry for this class and all subclasses of it
			self.getIncludeClassSubclasses(class, pJournalInterface, serverExecuteLog);

		else
			//	build the includeClass entry for this class
			self.createIncludeClassEntry(className);

			pJournalInterface.registerClass(serverExecuteLog, class.number, 0);
		endif;
	endforeach;

	//	check if we are no longer tracking any classes that we have started tracking
	foreach changeClass in self.myChangeTrackingRoot.allChangeClasses do
		if self.tryShareLockingObject(changeClass) then
			if self.allClassIniFileEntries[changeClass.className] = null then
				self.monitor("Current Tracking of Class '" &amp; changeClass.className &amp; "' no longer has an include entry, will now be deleted.", MONITOR_ALWAYS);
				self.myChangeTrackingClassTA.isDelete := false;
				self.myChangeTrackingClassTA.myChangeTrackingClass := changeClass;
				self.myChangeTrackingClassTA.deleteEntity();
			endif;
			self.unlock(changeClass);
		endif;
	endforeach;
	//	check if we are no longer tracking any classes that we have started delete tracking
	foreach deleteClass in self.myChangeTrackingRoot.allDeleteClasses do
		if self.tryShareLockingObject(deleteClass) then
			if self.allClassIniFileEntries[deleteClass.className] = null then
				self.monitor("Current Delete Tracking of Class '" &amp; deleteClass.className &amp; "' no longer has an include entry, will now be deleted.", MONITOR_ALWAYS);
				self.myChangeTrackingClassTA.isDelete := true;
				self.myChangeTrackingClassTA.myChangeTrackingClass := deleteClass;
				self.myChangeTrackingClassTA.deleteEntity();
			endif;
			self.unlock(deleteClass);
		endif;
	endforeach;

	monitor ("Including " &amp; self.allClassIniFileEntries.size.String &amp; " classes", MONITOR_ALWAYS);

epilog
	delete classColl;
end;</source>
        <access>protected</access>
        <Parameter name="pJournalInterface" type="JSSCTAuditLogInterface"/>
    </JadeMethod>
    <JadeMethod name="checkForMissedAuditLogs" id="05a91471-5c4b-4bb6-b6f8-839058a99344">
        <updating/>
        <source>checkForMissedAuditLogs() updating, protected/*, serverExecution*/;
/*
*/
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	self.myStartedProcess := app.startApplicationWithParameter("JSSChangeTrackingSchema", "JSSChangeTracker", self.myNotificationObject.mySharedTransientInstance);
	self.myStartedProcessString := self.myStartedProcess.getOidString();
//	self.processAuditLog(168);
end;</source>
        <access>protected</access>
    </JadeMethod>
