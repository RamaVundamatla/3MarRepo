    <JadeMethod name="categorizeClassProperties" id="d6a0fae7-5753-4dab-993a-5b7af72e058e">
        <updating/>
        <source>categorizeClassProperties() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    exportProp: CM_ExportImportProperty;
begin
    if self.myExportImportClass = null then
        return;
    endif;
    // Clear previous categorization
    self.clearPropertyCollections();
    
    foreach exportProp in self.myExportImportClass.allProperties do
        if not exportProp.includeInExport then
            continue;
        endif;
        
        if exportProp.isAttribute then
            self.attributes.add(exportProp);
        elseif exportProp.isReference then
            if exportProp.expandReference then
                self.referencesToExpand.add(exportProp);
            else
                self.references.add(exportProp);
            endif;
        elseif exportProp.isCollection then
            if exportProp.expandReference then
                self.collectionsToExpand.add(exportProp);
            else
                self.collections.add(exportProp);
            endif;
        endif;
    endforeach;
end;</source>
    </JadeMethod>
