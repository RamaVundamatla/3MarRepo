		return CARGO_CHECK_CONTEXT_PACK;
	elseif _cargoCheckString = CARGO_CHECK_UNPACK_STRING then//04 Jul 2011	NDL Par 26476
		return CARGO_CHECK_CONTEXT_UNPACK;
	elseif _cargoCheckString = CARGO_CHECK_TMANLOAD_STR then //CCMS MSL 1026
		return CARGO_CHECK_CONTEXT_TMANLOAD;
	elseif _cargoCheckString = CARGO_CHECK_TMANDISC_STR then //CCMS MSL 1026
		return CARGO_CHECK_CONTEXT_TMANDISC;
	elseif _cargoCheckString = CARGO_CHECK_ROADGATE_IN_STRING then	//07 May 2014	NDL	Par 34076
		return CARGO_CHECK_CONTEXT_ROAD_REC;
	elseif _cargoCheckString = TRUCK_CHECK_LOAD_COMPLETE_STR then	//13 Sep 2023 jlizm1 TFS59985
		return TRUCK_CHECK_LOAD_COMPLETE;
	elseif _cargoCheckString = WAGON_CHECK_PLACEMENT_OUT_STR then	//11 Mar 2015	NDL	Par 35828
		return WAGON_CHECK_CONTEXT_PLACE_IN;
	elseif _cargoCheckString = WAGON_CHECK_PLACEMENT_IN_STR then	//11 Mar 2015	NDL	Par 35828
		return WAGON_CHECK_CONTEXT_PLACE_OUT;
	elseif _cargoCheckString = WAGON_CHECK_LOAD_COMPLETE_STR then	//04 Nov 2022 	jlizm1 TFS 54118
		return WAGON_CHECK_LOAD_COMPLETE;
	elseif _cargoCheckString = CARGO_CHECK_ROADGATE_OUT_STRNG then		// PAR #36094
		return CARGO_CHECK_CONTEXT_ROAD_REL;							// PAR #36094
	elseif _cargoCheckString = CONT_CHECK_PACK_STR then		//08 Mar 2017	NDL	TFS 3635
		return CONT_CHECK_CONTEXT_PACK;
	elseif _cargoCheckString = CONT_CHECK_UNPACK_STR then		//08 Mar 2017	NDL	TFS 3635
		return CONT_CHECK_CONTEXT_UNPACK;
	elseif _cargoCheckString = CARGO_CHECK_VOYOP_LOAD_STR then
		return CARGO_CHECK_CONTEXT_VOYOP_LOAD;
	elseif _cargoCheckString = CARGO_CHECK_VOYOP_DISC_STR then
