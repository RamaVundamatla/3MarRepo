<Class name="BGP_AutoReportRequests" id="78caae06-2edc-401f-bae5-9cc24a73f80a">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Template Reporting(Required to run reports from template)&lt;/display&gt;
&lt;displayShort&gt;Template Reporting&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="allReportTemplates" id="fda32121-31b2-4e92-9ea6-54910d17177a">
        <memberTypeInverse/>
        <type name="CM_ReportTemplateByNameDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="reportNames" id="45269875-dc86-4a90-9991-a6609802fc0a">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="action" id="552436cb-9a88-4702-af10-8b2810b20de9">
        <updating/>
        <source>action(): Boolean updating;

// cnwdvb1 13 December 2002 
vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	self.createReportsNew();
epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createReportsNew" id="7e5d8e09-8b8b-48b7-93e9-d80ffbfb4670">
        <source>createReportsNew() protected;

// cnwdvb1 20 February 2003 
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

	user					: CM_User;
	report					: CM_ReportTemplate;
	bgpReportRequestStatic	: BGP_ReportRequestStatic;
	msg : String;
begin

	app.myPassport.setMyTerminal(null);
		
	foreach report in self.allReportTemplates do
		bgpReportRequestStatic := report.myReportRequest.BGP_ReportRequestStatic;
		if bgpReportRequestStatic = null then
			msg := 'Could not locate request for template ' &amp; report.name &amp; ' user ' &amp; report.myUserToRunAs.code;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			continue;
		endif;
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		bgpReportRequestStatic.createReportRequestNew(self.allEventData);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;self.String, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="56cf91cb-9527-4e13-9885-3b0c530c1a8b">
        <source>getDisplay(): String;

// cnwdvb1 17 February 2003 

vars

	str, detail	: String;

begin

	str := inheritMethod();
	detail := 'Attempting to run report(s) ' &amp; self.reportNames &amp; ' for user ' &amp; self.getUserCode;
	return str &amp; Tab &amp; detail;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestLimit" id="d293ff16-f396-44d3-af08-ded5a59d9910">
        <source>getRequestLimit(): Integer;
// -------------------------------------------
// Created 28 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	// No limit.
	return 0;


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="c17d4a8c-595f-49a6-8a10-57d2a49f33ef">
        <updating/>
        <source>initRequestFromTask(_task : CM_AutoTaskRunReports) updating;

// cnwdvb1 13 December 2002 

vars

begin

	self.reportNames	:= _task.reportNames;
	_task.allReportTemplatesNew.copy(self.allReportTemplates);
	inheritMethod(_task);

end;</source>
        <Parameter name="_task" type="CM_AutoTaskRunReports"/>
    </JadeMethod>
    <JadeMethod name="setEventData" id="d4768259-f4a1-4e79-93ca-ba7f2f400b3a">
