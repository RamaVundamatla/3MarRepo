<Class name="CM_KPIAgent" id="c111a418-88e8-4e9b-9f87-51d459d09397">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="admin"/>
    <ImplicitInverseRef name="allKPIControllers" id="56bc5015-a541-4f88-b7f6-565b2d758d1e">
        <embedded/>
        <type name="CMIF_ObjectSet"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="finalizeAgent" id="e23a0a7b-2ca6-48f8-9c35-08b08beb394f">
        <updating/>
        <source>finalizeAgent() updating;
// ---------------------------------------------------------------------------
// Created:      21 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.endNotification(system, KPIAgent_UpdateEvent);
//	self.endClassNotification(CMIF_KPIController, false, null);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeAgent" id="c4d7e6a7-d2e0-441b-80e7-2ee523f1081e">
        <updating/>
        <source>initializeAgent() updating;
// ---------------------------------------------------------------------------
// Created:      21 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars

begin

	app.writeLog('KPI Agent', LogINFO);

	self.beginNotification(system, KPIAgent_UpdateEvent, Response_Continuous, null);
//	self.beginClassNotification(CMIF_KPIController, false, Object_Create_Event, Response_Continuous, 0); 

end;</source>
    </JadeMethod>
    <JadeMethod name="processController" id="11437dab-3fe1-4d63-917a-7c67c54f8891">
        <updating/>
        <source>processController(_controller : CMIF_KPIController input) updating;
// ---------------------------------------------------------------------------
// Created:		06 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	_controller.processKPI();
end;</source>
        <Parameter name="_controller" type="CMIF_KPIController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="44b16669-4a79-4ba0-a7ca-6ea8e38b5ce3">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		31 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	controller : CMIF_KPIController;
	ls : Boolean;
begin
	controller := theObject.CMIF_KPIController;
//		app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 2. ' &amp; controller.String &amp; " " &amp; global.isValidObject(controller).String, true);

	controller.processKPI();
	
epilog
	beginTransaction;
	delete controller;
	commitTransaction;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="a19d09e5-e72a-4958-b7d2-51143efa4b50">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

// ---------------------------------------------------------------------------
// Created:		December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Delimiter = "^";
	Header = "~";

vars
	controller : CMIF_KPIController;
	hdrStr, tranStr, jsStr : String;
	idx, idxHdr : Integer;
	
	//cnwmc5
	deviceNoteAgent : CM_DeviceNotificationAgent;
begin
	//app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; eventType.String &amp; " " &amp; theObject.String &amp; " " &amp; userInfo.String, true);

	if eventType = KPIAgent_UpdateEvent then
		idxHdr := userInfo.String.pos(Header,1);
		if idxHdr  &lt;= 0 then
			return;
		endif;
		hdrStr := userInfo.String[1:idxHdr -1];
	//app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; hdrStr , true);
		
		if hdrStr = CMIF_KPIShipMove.name then
		
			idx := userInfo.String.pos(Delimiter,idxHdr);
			if idx  &lt;= 0 then
				return;
			endif;
			tranStr := userInfo.String[idxHdr +1:idx -1];
			jsStr := userInfo.String[idx + 1 : end];
			
			create controller as CMIF_KPIShipMove transient ;
			controller.myTiTransaction := tranStr.asOid.CM_TITransaction;
			controller.CMIF_KPIShipMove.myJobSheet := jsStr.asOid.CM_VoyageJobSheet;
			
			controller.processKPI();
			
			//cnwmc5
			create deviceNoteAgent transient;
			deviceNoteAgent.calculateCraneRates(controller.CMIF_KPIShipMove);
		elseif hdrStr = CMIF_KPIYardMove.name then
		
			create controller as CMIF_KPIYardMove transient ;
			controller.setControllerFromUserInfo(userInfo.String[idxHdr +1:end]);
			controller.processKPI();
		elseif hdrStr = CMIF_KPITruckTurnaround.name then
		
			create controller as CMIF_KPITruckTurnaround transient ;
			controller.setControllerFromUserInfo(userInfo.String[idxHdr +1:end]);
			controller.processKPI();
		endif;
	endif;
epilog
	delete controller;
	delete deviceNoteAgent;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
