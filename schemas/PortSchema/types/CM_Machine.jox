    <JadeMethod name="userNotification" id="254c2352-3309-4590-b50c-9b09df743bb2">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	event			: Integer;
	rfidTag			: CM_RFIDTag;
begin
	if (not self.loggedOn) then
		return;
	endif;
	
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if event = Event_RFIDTagRead and CM_RFIDTag.hasInstance(userInfo.Object) then
		rfidTag := userInfo.CM_RFIDTag;
		
		//th2 to do
		
	endif;
	
end;


</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="21eea1df-5b5d-4795-94b1-81edcaec6991">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if myTerminal.machines[id] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.id, null, null);
	endif;
	
	//24 Nov 2017	NDL	TFS 7792
	if self.myTerminal.allWorkPointsByCode[self.id] &lt;&gt; null then
		app.raiseCMException(Not_have_same_existi_workpo, null, null);
	endif;
	
	// 29099 Mar 2012 machines are now unique by terminal, not across the system
	///if app.myRoot.allMachines[id] &lt;&gt; null then
	///	app.raiseCMException1(VB_DUPLICATED_ITEM, self.id, null, null);
	///endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="e14d34bd-d8c3-4f45-8a87-22c3f2ab9e56">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
begin

	if app.isUnitTestGarbageCollect then
		return;
	endif;

	if self.myRTDevice &lt;&gt; null then
		app.raiseCMException2(ERR_MACH_HAS_RTDEVICE, self.id &amp; " - " &amp; self.description, self.myRTDevice.id &amp; " - " &amp; self.myRTDevice.model, 'myRTDevice', null);
	endif;
	
	if self.myPrimaryQueue &lt;&gt; null then
		if not self.myPrimaryQueue.isKindOf(CM_MasterQueue) and self.allQueues.size &gt; 1 then
			app.raiseCMException1(ERR_MACH_INQUEUES, self.id &amp; " - " &amp; self.description, null, null);
		endif;
	endif;
	
	if self.currentQueueTask &lt;&gt; null then
		app.raiseCMException1(ERR_MACH_HASTASK, self.id &amp; " - " &amp; self.description, 'currentQueueTask', null);
	endif;
	
	if self.loadWLE &lt;&gt; null or self.dischargeWLE &lt;&gt; null then
		app.raiseCMException1(ERR_MACH_HASWLE, self.id &amp; " - " &amp; self.description, null, null);
	endif;
	if self.machineStatus &lt;&gt; STATUS_OFFLINE and self.machineStatus &lt;&gt; STATUS_IDLE then
	//	app.raiseCMException1(ERR_MACH_ONLINE, self.id &amp; " - " &amp; self.description, 'machineStatus', null);
	endif;
	if self.loggedOn and self.myRTDevice &lt;&gt; null then
		app.raiseCMException1(ERR_MACH_LOGGEDON, self.id &amp; " - " &amp; self.description, 'loggedOn', null);
	endif;
	if self.hasAllocatedQueueTasks then
		app.raiseCMException2(ERR_MACH_BUSY, self.id &amp; " - " &amp; self.description, self.allAllocatedQueueTasks.first.queueId,'nextAllocatedQueueTask', null);	
	endif;
	
	// PAR 17890
	if self.myMachineController &lt;&gt; null then
		if not self.myMachineController.allTrackedItems.isEmpty() then
			tmpTI := self.myMachineController.allTrackedItems.first;
			app.raiseCMException2(ERR_MACH_HAS_CARGO, self.id," Item '" &amp; tmpTI.id &amp; "' is on " &amp; self.id &amp; ".", null, null);	
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForMove" id="b3b501b8-1184-4b8e-909e-4e9deabd209b">
        <source>validateForMove(_location : CM_LocationsController; _ti : CM_TrackedItem; _strickAccessCheck : Boolean) : Boolean;
/*

Purpose:	refactored from the MobileServerSchema CM_VlaidationRTAgent validateMachineForMove		

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2010	cnwer1	Initial creation
14 Sep 2010 	cnwer1	 par 25735
23 Feb 2012 	cnwer1 	par 28126
*/

vars
	source	: CM_LocationsController;
	ta		: CM_Object;
	str		: String;
	messageLogger : CM_IndentedMessageLogger;
	crane : CM_Crane;
	craneQueue : CM_VoyageCraneQueue;
	workPointQueue : CM_VoyageWorkPointQueue;
	theQueue : CM_RadioTelemetryQueue;
	dischargeUsesShipLander,
	loadQueueUsesShipLander : Boolean;
	workPoint : CM_WorkPoint;
	transferArea  : CM_TerminalArea;
begin


	source	:= _ti.getPrimaryLocation(REAL_MODE);
	theQueue:=self.getQueue;
	if theQueue &lt;&gt; null then
		if theQueue.isKindOf(CM_VoyageCraneQueue) then
			craneQueue:=theQueue.CM_VoyageCraneQueue;
			loadQueueUsesShipLander:=craneQueue.loadMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp;
			dischargeUsesShipLander:=craneQueue.dischargeMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp;
			crane:=craneQueue.crane;
			if crane &lt;&gt; null then
				transferArea:=crane.transferArea;
			endif;
		elseif  theQueue.isKindOf(CM_VoyageWorkPointQueue) then // epr CCMS 1033 30/8/2011
			workPointQueue:=theQueue.CM_VoyageWorkPointQueue;
			loadQueueUsesShipLander:=workPointQueue.loadMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp;
			dischargeUsesShipLander:=workPointQueue.dischargeMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp;	
			workPoint:=workPointQueue.myWorkPoint;
			if workPoint &lt;&gt; null then
				transferArea:=workPoint.myWorkPointInterchangeArea;
			endif;
		endif;
	endif;
	
	//if the ti is on the vehicle the we have access and there are no restrictions
	if source &lt;&gt; null then 
		ta := source.getParentForMachine(self);
		if ta &lt;&gt; null then
			//epr par 25735
			if ta.isKindOf(CM_Voyage) then
				if dischargeUsesShipLander then
					if transferArea &lt;&gt; null then
						if not self.canMachineAccessTAObj(transferArea, true) then
							app.raiseCMException2(MACH_ACCESS_TARGET,  self.id,source.getFullIdTI(_ti), null, null);
							return false;			
						endif;
					endif;
					
				endif;
				
			elseif not ta.isKindOf(CM_TerminalArea) or not self.canMachineAccessTAObj(ta.CM_TerminalArea, false) then
				app.raiseCMException2(MACH_ACCESS_SOURCE, self.id, source.getFullId(), null, null);
				return false;
			endif;
		endif;
	endif;
	
	if _location &lt;&gt; null then
		ta:=_location.getParentForMachine(self);
		if ta &lt;&gt; null  then
			
			// PAR 23819 - RORO
			if  not ta.isKindOf(CM_TerminalArea) and ta.isKindOf(CM_Voyage) and (_location.isKindOf(CM_ShipBlockController) or _location.isKindOf(CM_GeneralCargoController)) then
				crane := ta.CM_Voyage.getCraneWithNoJS();
				if crane &lt;&gt; null then
					if not self.canMachineAccessTAObj(crane.transferArea, true) then
						app.raiseCMException2(MACH_ACCESS_TARGET,  self.id,_location.getFullId(), null, null);
						return false;			
					endif;
				endif;
			elseif  ta.isKindOf(CM_Voyage) and (_location.isKindOf(CM_SlotController) or _location.isKindOf(CM_VoyageROROController)) then
			//epr par 25213 28 July 2010 also using lc.getFullIdTI so it returns the 40ft bay ids
				if  loadQueueUsesShipLander then
					if transferArea &lt;&gt; null then
						if not self.canMachineAccessTAObj(transferArea, true) then
							app.raiseCMException2(MACH_ACCESS_TARGET,  self.id,_location.getFullIdTI(_ti), null, null);
							return false;			
						endif;
					endif;
				endif;
			elseif  not ta.isKindOf(CM_TerminalArea) or not self.canMachineAccessTAObj(ta.CM_TerminalArea, true) then
				app.raiseCMException2(MACH_ACCESS_TARGET,  self.id,_location.getFullIdTI(_ti), null, null);
				return false;
			endif;
		endif;
	endif;
	
	create messageLogger transient;
	if not self.canMachineMoveTI(_ti, null,  _location, _strickAccessCheck,messageLogger) then
		str:=messageLogger.allMessages.concatenate(",");
		//epr par 36103 23/4/15
		app.raiseMultiReasonExcOrWarning( messageLogger.allErrorCodesUsed, str, false, null,  _ti );	//13 Sep 2012	NDL	Par 30366
		return false;
	endif;
		
		
	return true;

epilog
	delete messageLogger;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_strickAccessCheck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForMultiMove" id="e9571b07-e238-40d7-9ed5-1f5f2504bd74">
        <source>validateForMultiMove(_cargo : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	jlier1	Initial creation

*/

vars

begin
	if _cargo = null then
		return;
	endif;
	
	//jlier1 TFS 54170 18/7/22
	if not  _cargo.isKindOf(CM_BreakBulk) or _cargo.isLog then
		app.raiseCMException1(Follo_cargo_not_break_bulk_car,_cargo.id,null,null);
		return;
	endif;
	
	
	if _cargo.myCargoType.allowDuplicates then
		app.raiseCMException1(Follo_cargo_not_suita_multi_mo,_cargo.id,null,null);
		return;
	endif;
	
	if  _cargo.getPrimaryLocation(PLANNING_MODE) = null then
		app.raiseCMException1(Follo_cargo_does_not_have_plan,_cargo.id,null,null);
		return;
	endif;
epilog

end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0c5dd630-3d2a-485f-8c37-c293e53cedf1">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForVehicleApp" id="c58922e8-6efc-44d9-9936-3361bfd707d9">
        <source>validateForVehicleApp(_checkOutstandingFaults : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation 52595

*/

vars

begin
	if self.user = null or not self.loggedOn then
		app.raiseCMException(ERR_MS_NOT_LOGGED_ON, null, null);
		
		return ;
	endif;
	
	if _checkOutstandingFaults then
		if self.isFaultQuestionOutstanding() then
			app.raiseCMException1(ERR_MACH_FAULTS_OUT, self.id, null, null);
		
			return ;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_checkOutstandingFaults" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="0087753f-f860-4794-bd9e-1e4714036220">
        <source>validateMe() protected;

vars

begin
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Machine Id', null, null);
		app.raiseCMException(Input_required_field_machineID, null, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Machine Description', null, null);
		app.raiseCMException(Input_required_field_machDesc, null, null);// cnwdb2	PAR 35364


	endif;
	if self.hasRadioTelemetry  then
		if self.allAllowedCargoTypes.isEmpty then
			app.raiseCMWarning1(WARN_NO_SELECT,app.getErrorString(CargoTypes),null,null,self);
		endif;
		//epr 14/9/06 changed from allowedTerminalAreas to allowedTAMasters
		if self.allowedTAMasters.isEmpty then
			app.raiseCMWarning1(WARN_NO_SELECT,app.getErrorString(TerminalAreas),null,null,self);
		endif;
	endif; 

	if self.myTerminal.allTerminalAreas[self.id.trimBlanks] &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, "ID","A terminal area exists with the same ID", null, null);
	
	endif;
	
	if self.isNotAvailableForEntry and self.myRTDevice &lt;&gt; null then
		app.raiseCMException1(MACH_ATTACHED_DEVICE, self.myRTDevice.id, null, null);
	endif;
	if self.canCertifyWeight and not
	   self.canWeighCargo then
		app.raiseCMException(Machine_Certify_Weight, null, null);
	endif;
	if (self.myPhysicalStartBay &lt;&gt; null and 
		self.myPhysicalEndBay = null) then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Physical_limits)&amp; " - " &amp; app.getErrorString(End_bay), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Physical_limits)&amp; " - " &amp; app.getErrorString(End_bay), null, null);	
	elseif (self.myPhysicalStartBay = null and 
		self.myPhysicalEndBay &lt;&gt; null) then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Physical_limits)&amp; " - " &amp; app.getErrorString(Start_bay), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Physical_limits)&amp; " - " &amp; app.getErrorString(Start_bay), null, null); // cnwdb2	PAR 35364		
	elseif  (self.myPhysicalStartBay &lt;&gt; null and 
		self.myPhysicalEndBay &lt;&gt; null) then
		
		self.validateWorkzone(self.myPhysicalStartBay,self.myPhysicalEndBay,Physical_limits);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validatePickupTask" id="32ed2072-a1dc-4605-aca8-fba3d3e01583">
        <source>validatePickupTask(_thisRTQueueTask ,_nextRTQueueTask: CM_RTQueueTask) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Feb 2009	cnwer1	Initial creation Refactored - moved code block from executePickupNew
06 Jul 2010 cnwer1  new method validateForMove calls canMachineMoveTI which does the labour
					restriction validation
23 Feb 2012 	cnwer1 	par 28126
*/

vars
	ti			: CM_TrackedItem;
	strictAccessCheck : Boolean;
begin
	
	if _nextRTQueueTask = null then
		//A worry! Nothing to do after the pickup!
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_NOTASKOFTYPE, TASK_SETDOWN_DESC, queueId, null, null);
		return false;
	endif;
	
	strictAccessCheck:=true;
	if self.isTandemLift and self.allCurrentQueueTasks.size &gt; 1 then
		strictAccessCheck:=false;
	endif;
	
	ti := _thisRTQueueTask.ti;
	if not self.validateForMove(_nextRTQueueTask.targetLocation,ti, strictAccessCheck) then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_thisRTQueueTask" type="CM_RTQueueTask"/>
        <Parameter name="_nextRTQueueTask" type="CM_RTQueueTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
