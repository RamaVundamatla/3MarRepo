        <source>utlUpdateVoyageAllocHolds( _voyage : CM_Voyage input;  _cranesWPByHolds : CM_ObjectByObject input);
/*
Purpose:			
Date		Who		Reason
03 February 2015	cnwab1	Initial creation
*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	self.raiseExceptionIfNull(_voyage, 'Voyage');	
