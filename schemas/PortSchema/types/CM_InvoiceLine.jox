    <JadeMethod name="getVoyageForProforma" id="a4d3ae54-8966-42ec-867c-f5bb97f6b084">
        <source>getVoyageForProforma() : CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2018	jlgab1	Initial creation

*/

vars

begin
	// TFS 42161if self.myTransactionEvent = null 
	// TFS 42161and self.myTransactionHMS = null then
	// TFS 42161	return null;
	// TFS 42161endif;
	
	if self.myTransactionHMS &lt;&gt; null then
		return self.myTransactionHMS.myVoyage;
	endif;
	
	if self.myTransactionWO &lt;&gt; null then // TFS 42161
		return self.myTransactionWO.getMyVoyageObject(); // TFS 42161
	endif;

	if self.myTransactionEvent &lt;&gt; null then// TFS 42161
		return self.myTransactionEvent.getVoyage();
	endif;	
	
	if self.myTransactionBOL &lt;&gt; null then	//31 Oct 2019	NDL	TFS 47100
		return self.myTransactionBOL.getMyVoyage();
	endif;
	
	return null;// TFS 42161
epilog

end;</source>
