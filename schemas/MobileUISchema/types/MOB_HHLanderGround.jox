    <JadeMethod name="populateTerminalAreas" id="40413ec7-7e56-4d5a-8a37-0b53b2f5be70">
        <source>populateTerminalAreas() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwndl1	Initial creation	Par 23603
30 Aug 2011 cnwer1	CCMS 1033 roro voyage operations
18 Jun 2012	NDL		Par 29745
*/

vars

begin

	self.popWithCraneWorkPointTermAreas( self.myMobileGenericAgent.myVoyage, self.cmbTerminalArea );
	
	self.doChangeTerminalArea();
	
epilog

end;</source>
