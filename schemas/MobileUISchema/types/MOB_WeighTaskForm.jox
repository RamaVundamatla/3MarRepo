    <JadeMethod name="adjustWeights" id="1add2e58-2454-47ae-9db6-22537023ccfa">
        <source>adjustWeights( _fromControl : Control );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2018	jlgndl1	Initial creation	TFS 36697

*/

vars

	totalWeight : Decimal[14,4];
	cargoWeight : Decimal[14,4];
	tareWeight : Decimal[14,4];
	
begin

	if self.myTrackedItem = null or not self.myTrackedItem.myCargoType.useTareCargoWeight then
		return;
	endif;

	totalWeight := self.tblTotalWeight.getConvertedValue();
	cargoWeight := self.tblCargoWeight.getConvertedValue();
	tareWeight := self.tblTareWeight.getConvertedValue();
	
	self.adjustTotalCargoTareWeights(	self.myTrackedItem,	//_originalTi : CM_TrackedItem;
										_fromControl,	//_fromControl : Control;	// the one that just lost focus
										totalWeight,	//_totalWeightKgs : Decimal; // the current value in the table for total weight . May actually be populated with volume
										cargoWeight,	//_cargoWeightKgs : Decimal; // the current value in the table for cargo weight
										tareWeight,	//_tareWeightKgs : Decimal;// the current value in the table for tare weight
										self.tblTotalWeight,	//_tblWeight : CMUI_MeasurementTable io;
										self.tblCargoWeight, //_tblCargoWeight : CMUI_MeasurementTable io;
										self.tblTareWeight,	//_tblTareWeight : CMUI_MeasurementTable io;
										false	//_isSplitForm : Boolean
										);

epilog

end;</source>
        <Parameter name="_fromControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="cmbCertify_click" id="0852d2d9-8ea9-45f8-aff0-5139bc73b43c">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCertify_click(combobox: ComboBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/07/2017	jlgdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	weighAuth, wa : CM_WeighAuthority;
	iter : Iterator;
	idx : Integer;

begin
	self.cmbAuthor.clear();
	weighAuth := combobox.listObject.CM_WeighAuthority;
	if weighAuth = null then
		return;
	endif;
	
	iter := app.myRoot.allWeighAuthorities.createIterator;
	app.myRoot.allWeighAuthorities.startKeyGeq(weighAuth.certifiedName, null, iter);
	while iter.next(wa) do
		if wa.certifiedName &lt;&gt; weighAuth.certifiedName then
			break;
		endif;
		idx := self.cmbAuthor.addItem(wa.authorisedName);
		self.cmbAuthor.itemObject[idx] := wa;
	endwhile;
	if self.cmbAuthor.listCount = 1 then
		self.cmbAuthor.listIndex := 1;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="85d4a164-3005-4e38-9f5b-84ed97cf9060">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604
07 Jun 2016	NDL	TFS 2099
30 Jun 2016	cnwdap1	TFS #2174 Replace weight text box with measurement table
04 Jan 2019 - NDL TFS 42495 - swap the field order to appease STWR
*/

vars

	stdHeight : Real;
	stdWidth : Real;
	halfWidth : Real;
	vTop : Real;
	vLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdHeight := self.getStdControlHeight;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	halfWidth := ( stdWidth - self.resizedMargin ) / 2;
	
	vTop := stdHeight;
	
	if self.myTrackedItem.myCargoType &lt;&gt; null and self.myTrackedItem.myCargoType.useTareCargoWeight then
		
		if _initialSetup then
			self.lblTareWeight.setAndIncrementTabIndex( tabIndex );
			self.lblTareWeight.visible := true;
		endif;
		self.lblTareWeight.move(	self.resizedMargin,
									vTop,
									halfWidth,
									stdHeight);
		
		vLeft := halfWidth + self.resizedMargin;
		if _initialSetup then
			self.tblTareWeight.setAndIncrementTabIndex( tabIndex );
			self.tblTareWeight.visible := true;
		endif;
		self.tblTareWeight.move(	vLeft,
									vTop,
									halfWidth,
									stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
									);
									
		vTop := vTop + self.tblTareWeight.height + self.resizedMargin;
		
		if _initialSetup then
			self.lblCargoWeight.setAndIncrementTabIndex( tabIndex );
			self.lblCargoWeight.visible := true;
		endif;
		self.lblCargoWeight.move(	self.resizedMargin,
								vTop,
								halfWidth,
								stdHeight);
		
		vLeft := halfWidth + self.resizedMargin;
		if _initialSetup then
			self.tblCargoWeight.setAndIncrementTabIndex( tabIndex );
			self.tblCargoWeight.visible := true;
		endif;
		self.tblCargoWeight.move(	vLeft,
									vTop,
									halfWidth,
									stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
									);
	
		vTop := vTop + self.tblCargoWeight.height + self.resizedMargin;	
									
	else
		self.lblCargoWeight.visible := false;
		self.lblTareWeight.visible := false;
		self.tblCargoWeight.visible := false;
		self.tblTareWeight.visible := false;
		
	endif;
	
	if _initialSetup then
		self.lblTotalWeight.setAndIncrementTabIndex( tabIndex );
		self.lblTotalWeight.visible := true;
	endif;
	self.lblTotalWeight.move(	self.resizedMargin,
							vTop,
							halfWidth,
							stdHeight);
	
	vLeft := halfWidth + self.resizedMargin;
	if _initialSetup then
		self.tblTotalWeight.setAndIncrementTabIndex( tabIndex );			
		self.tblTotalWeight.visible := true;							
	endif;
   
    self.tblTotalWeight.move(	vLeft,									
							vTop,
							halfWidth,
							stdHeight + self.resizedMargin
							);
	
	vTop := vTop + self.tblTotalWeight.height + self.resizedMargin;
	
	if _initialSetup then
		self.lblIsCertified.setAndIncrementTabIndex( tabIndex );
		self.lblIsCertified.visible := true;
	endif;
	self.lblIsCertified.move(	self.resizedMargin,
								vTop,						   
								halfWidth,
								stdHeight);
						   
	if _initialSetup then
		self.chkIsCertified.setAndIncrementTabIndex( tabIndex );
		self.chkIsCertified.visible := true;
	endif;
	self.chkIsCertified.move(	vLeft,
								vTop,	
								stdHeight,
								stdHeight);	
								
	
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isContainer then
	
		vTop := vTop + self.lblIsCertified.height + self.resizedMargin;
		if _initialSetup then
			self.lblCertify.setAndIncrementTabIndex( tabIndex );
			self.lblCertify.visible := true;
		endif;
		self.lblCertify.move(	self.resizedMargin,
								vTop,
								halfWidth,
								stdHeight);
								
		if _initialSetup then
			self.cmbCertify.setAndIncrementTabIndex( tabIndex );
			self.cmbCertify.visible := true;
		endif;
		self.cmbCertify.move(	vLeft,
								vTop,
								halfWidth,
								stdHeight);
							
		vTop := vTop + self.cmbCertify.height + self.resizedMargin;
		if _initialSetup then
			self.lblAuthor.setAndIncrementTabIndex( tabIndex );
			self.lblAuthor.visible := true;
		endif;
		self.lblAuthor.move(	self.resizedMargin,
								vTop,
								halfWidth,
								stdHeight);
								
		if _initialSetup then
			self.cmbAuthor.setAndIncrementTabIndex( tabIndex );
			self.cmbAuthor.visible := true;
		endif;
		self.cmbAuthor.move(	vLeft,
								vTop,
								halfWidth,
								stdHeight);
							
	else
		self.lblCertify.visible := false;
		self.cmbCertify.visible := false;
		self.lblAuthor.visible := false;
		self.cmbAuthor.visible := false;
		
	endif;

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="9204f69d-4d7c-4ddc-ad3d-50efc5bfc2c2">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17/02/2010	#cnwdz2	 
30/06/2016 	cnwdap1	TFS #2174 Replace weight text box with measurement table
29/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/

vars
	pxyTiSet : CM_TISet;
	result : Integer;
	weight : Decimal [18,4];					// TFS #2174
	vgmDetails : CM_VGMDetails;							// TFS 4492
	authSig, commsType, docDetails, ediTrans, email, 	// TFS 4492
	mail, phone, fax, telephone : String;				// TFS 4492
	docsIssued, determination : TimeStamp;				// TFS 4492
	cargoWeight : Decimal [16,4];	//26 Jan 2018	NDL	TFS 36697
	tareWeight : Decimal [16,4];	//26 Jan 2018	NDL	TFS 36697
begin
	//if self.txtWeight.text = null then																// TFS #2174
	weight := self.tblTotalWeight.getConvertedValue();														// TFS #2174
	if weight = null then																				// TFS #2174
		app.msgBox(app.getErrorString(NULL_WEIGHT_ENTERED), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.tblTotalWeight.setFocus();
		return;
	endif;
	
	if self.myTrackedItem.isWeightCertified then
		result := app.msgBox(app.getErrorString(CARGO_ALREADY_CERFIFIED), '', MsgBox_Yes_No);
		if result = MsgBox_Return_No then
			self.tblTotalWeight.setFocus();
			return;
		endif;
	endif;
	
	if self.pxyTrackedItem = null then
		self.pxyTrackedItem := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;							
	endif;
	
	//self.pxyTrackedItem.setTotalWeight(self.txtWeight.text.asDecimalJMT(), null, app.myPassport);		// TFS #2174
	self.pxyTrackedItem.setTotalWeight(weight, null, app.myPassport);									// TFS #2174
	self.pxyTrackedItem.setIsWeightCertified(self.chkIsCertified.value, null, app.myPassport);
	
	if self.tblCargoWeight.visible and self.tblTareWeight.visible then	//26 Jan 2018	NDL	TFS 36697
		cargoWeight := self.tblCargoWeight.getConvertedValue();	//26 Jan 2018	NDL	TFS 36697
		tareWeight := self.tblTareWeight.getConvertedValue();	//26 Jan 2018	NDL	TFS 36697
		self.pxyTrackedItem.setWeightCargo( cargoWeight );	//26 Jan 2018	NDL	TFS 36697
		self.pxyTrackedItem.setWeightTare( tareWeight );	//26 Jan 2018	NDL	TFS 36697
	endif;
	
	//self.pxyTrackedItem.setWeightCertifiedReference(self.txtCertify.text, null, app.myPassport);	//03 Jun 2016	NDL	TFS 2099	// TFS 4492
	//self.pxyTrackedItem.setWeightCertifiedName(self.txtAuthor.text, null, app.myPassport);	//03 Jun 2016	NDL	TFS 2099		// TFS 4492
	vgmDetails := self.myTrackedItem.getMyVGMDetails();																				// TFS 4492
	if vgmDetails &lt;&gt; null then																										// TFS 4492
		authSig := vgmDetails.vgmAuthSignature;																						// TFS 4492
		commsType := vgmDetails.vgmCommsType;																						// TFS 4492
		docDetails := vgmDetails.vgmDocumentDetails;																				// TFS 4492
		ediTrans := vgmDetails.vgmEDITransmission;																					// TFS 4492
		email := vgmDetails.vgmElectronicMail;																						// TFS 4492
		mail := vgmDetails.vgmMail;																									// TFS 4492
		phone := vgmDetails.vgmPhone;																								// TFS 4492
		fax := vgmDetails.vgmTelefax;																								// TFS 4492
		telephone := vgmDetails.vgmTelephone;																						// TFS 4492
		docsIssued := vgmDetails.vgmDocsIssuedDT;																					// TFS 4492
		determination := vgmDetails.vgmDeterminationDT;																				// TFS 4492
	endif;																															// TFS 4492
	self.pxyTrackedItem.setMyVGMDetails(	self.cmbCertify.text, self.cmbAuthor.text,												// TFS 4492
											authSig, commsType, docDetails, ediTrans, email, mail, 									// TFS 4492
											phone, fax, telephone, docsIssued, determination, null	);								// TFS 4492
	
	create pxyTiSet transient;
	pxyTiSet.add(self.pxyTrackedItem);
	if self.getSessionAgent.updateTIToDoTaskCmpltBulk(self.myToDoTask, pxyTiSet, null) then
		self.unloadForm();
	endif;

epilog
	delete pxyTiSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="6fe49714-9e1c-49ba-8550-f6db003cdb19">
