    <JadeMethod name="getSizeInPixels" id="dd755524-f772-4463-96d3-fd6ba1836d7f">
        <source>getSizeInPixels(_ft, _scaleFactor : Real) : Real protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars

begin
	return _ft * self.PIXELS_PER_FT * _scaleFactor;
epilog

end;</source>
