begin
	
//	if 	app.msgBox("Continue","Continue",MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
//		return;
//	endif; 
	
	app.initialize;
	
	create 	hhs transient;
		
	hhs.httpStatusCode := 666;
		
	create request  transient;	
	//request.location := "BS2";
		
	response := hhs.getCargoToStageForRelease("2161.850431","7753.877152","-1", "ID");
		
	response.inspectModal;

epilog
