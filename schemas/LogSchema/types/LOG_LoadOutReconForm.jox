    <JadeMethod name="showCurrentObjContextMenu" id="404bfc09-d6e9-4210-a6f4-d26c41aa188a">
        <updating/>
        <source>showCurrentObjContextMenu(_obj : Object; cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1, y1	: Real;

begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if tblData.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.mnuContextInspectObj.userObject := _obj;
	self.mnuContextInspectObj.visible := app.isAllowedToInspect();
	
	popupMenu(self.mnuContext, x1.Integer, y1.Integer);

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
