    <JadeMethod name="initLogBolSets" id="9b3223a5-4fad-4838-8099-1562dd1cfc9e">
        <source>initLogBolSets(_terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     26 April 2004 by cnwrs2
//
// Purpose:     This can be called at the start of a test to set the sets
//				the current unmatched data.
/*
app.initialize;
CM_TestDataRoot.firstInstance.initLogBolSets(CM_Terminal.firstInstance);
*/
// ---------------------------------------------------------------------------
vars
	tmpTestData	: CM_TestDataLogBOL;
	tmpExt		: CM_BOLExtLogIn;
	tmpBOL		: CM_BOL;
	tmpLogHdr	: CM_LogScalingHdr;
	tmpOperator	: CM_Operator;
	
begin

	beginTransaction;
	self.allLogBolsAsBols.purge();
	self.allLogBolsAsScalingDtls.purge();
	commitTransaction;

	beginTransaction;
	foreach tmpExt in _terminal.allLogBOLsUnmatched do
		tmpBOL := tmpExt.myBOL;
		create tmpTestData persistent;
		tmpTestData.set(tmpBOL.number, tmpBOL.numItems, tmpBOL.myOperator);
		self.allLogBolsAsBols.add(tmpTestData);
	endforeach;
	commitTransaction;

	beginTransaction;
	foreach tmpLogHdr in _terminal.allLogScalingHdrsUnmatched do
		tmpOperator := app.myRoot.allOperators[tmpLogHdr.operatorCode];
		if tmpOperator = null then
			continue;
		endif;
		create tmpTestData persistent;
		tmpTestData.set(tmpLogHdr.bolNumber, tmpLogHdr.allLogScalingDtls.size, tmpOperator);
		self.allLogBolsAsScalingDtls.add(tmpTestData);
	endforeach;
	commitTransaction;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="initTcpipSendAgent" id="91f61b89-1d9f-43a1-9a91-dac7af34f13c">
        <source>initTcpipSendAgent(_tcpipAgent : CM_TcpipSendAgent input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	bgpController	: BGP_XMLListenController;
begin
	if _tcpipAgent = null then
		return false;
	endif;
	
	bgpController	:= BGP_XMLListenController.firstInstance;
	if bgpController = null then
		return false;
	endif;
	
	_tcpipAgent.init(bgpController.tcpIpInterfaceAddress, bgpController.tcpIpPort, false, self.formatAsXMLSuffix(XML_MSG), 5000);

	return true;
	
end;</source>
        <Parameter name="_tcpipAgent" type="CM_TcpipSendAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMoveData" id="f58e253c-d2e6-4580-b8a0-ce17428cc2e7">
        <updating/>
        <source>setMoveData() updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2004 by cnwrs2
//
// Purpose:   
/*
CM_TestDataRoot.firstInstance.setMoveData();
*/  
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Removed commented out line which included beginLoad and endLoad
vars
	tmpLCs	: CM_LCSet;
	tmpTIs	: CM_TISet;
	tmpTA	: CM_TerminalArea;
	tmpTerm	: CM_Terminal;
	tmpLC	: CM_LocationsController;
	tmpTI	: CM_TrackedItem;
begin

	create tmpLCs transient;
	create tmpTIs transient;
	
	tmpTerm := CM_Terminal.firstInstance;
	tmpTA := tmpTerm.allTerminalAreas['DAVESSTRAD'];
	
	beginLoad;
	tmpTA.allLocationsControllers.copy(tmpLCs);
	foreach tmpLC in tmpTA.allLocationsControllers do
		foreach tmpTI in tmpLC.allTrackedItems do
			if (not tmpTIs.includes(tmpTI)) then
				tmpTIs.add(tmpTI);
			endif;
		endforeach;
	endforeach;
	endLoad;
	
	beginTransaction;
	if self.myTestDataMove = null then
		create self.myTestDataMove persistent;
	endif;
	commitTransaction;
	self.myTestDataMove.setup(tmpLCs, tmpTIs);

epilog
	endLoad;				// 11/04/2011 cnwmh5 #27347
	delete tmpLCs;
	delete tmpTIs;

end;</source>
    </JadeMethod>
    <JadeMethod name="setNextBOLInNumUnmatched" id="0ac4f588-fe84-4fee-9e11-051a54014c2e">
        <source>setNextBOLInNumUnmatched(_value : Integer);
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	beginTransaction;
	exclusiveLock(self.myBOLInNumUnmatched);
	self.myBOLInNumUnmatched.setNumberIfGreater(_value);
	commitTransaction;
	
end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupLogBOLInTestData" id="0a0432da-8579-45dd-bda1-5134795457cd">
        <updating/>
        <source>setupLogBOLInTestData(_terminal : CM_Terminal; intFaceCommon : CMIF_InOutCommon input; intFaceArray : CMIF_TIObjectArray input) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     Sets up test data for loading a Log BOL
// ---------------------------------------------------------------------------
vars
	intFaceBOLIn	: CMIF_BOLIn;
	truck			: String;
	tmpController	: CM_LogController;
	locnDict		: CM_LCByIdExtKeyDict;
	tmpLCSearch		: CMIF_SearchTypes;
	tmpOperator		: CM_Operator;
	tmpProd			: CM_TestDataProductCode;
	tmpVehicle		: CM_TestDataVehicle;
	testOperator	: CM_TestDataOperator;
	tmpNumber		: String;
	numLogs			: Integer;
	tmpTestLogBOL	: CM_TestDataLogBOL;

begin

	truck := self.getNextVehicle(_terminal).CM_TestDataVehicle.regNumber;

	create intFaceBOLIn transient;											// RS 031120

	if self.getNextBOLAsScalingDtlsToMatch(tmpNumber, tmpOperator, numLogs) then
		testOperator := self.allTestOperators[tmpOperator.code];
	endif;
	if testOperator &lt;&gt; null then
		app.writeLog('Adding docket to match scaling details for ' &amp; tmpNumber, LogINFO); 
		tmpProd := testOperator.getNextTestProduct();
		tmpProd.setIntFaceBOLIn(intFaceBOLIn);
	else
		tmpNumber := self.getNextBOLInNum();
		tmpProd	:= self.getNextTestProduct();
		tmpProd.setIntFaceBOLIn(intFaceBOLIn);
		tmpOperator := intFaceBOLIn.myOperator;	
		numLogs := 52;

		app.writeLog('Adding docket for no scaling details ' &amp; tmpNumber, LogINFO); 

		// need to add into local test dict
		beginTransaction;
		create tmpTestLogBOL persistent;
		tmpTestLogBOL.set(tmpNumber, numLogs, tmpOperator);
		self.allLogBolsAsBols.add(tmpTestLogBOL);
		commitTransaction;
	endif;
	
	// create data 
	intFaceCommon.carrierCode 		:= app.myRoot.allCarriers.first.code;
	intFaceCommon.myTerminal 		:= _terminal;
	intFaceCommon.autoComplete 		:= true;
	intFaceCommon.hasAttachments 	:= false;
	intFaceCommon.batNumber			:= null;
	intFaceCommon.regNumber 		:= truck;
	intFaceCommon.roadTransAreaId 	:= _terminal.getConfig(DefRoadOpsArea).String;
	
//	create intFaceBOLIn transient;											// RS 031120
	intFaceBOLIn.setMyInOutCommon(intFaceCommon);
	intFaceArray.add(intFaceBOLIn);
	
	intFaceBOLIn.bolNumber 			:= tmpNumber;
	intFaceBOLIn.bolType 			:= BOLType_Log;
	intFaceBOLIn.carrierCode 		:= intFaceCommon.carrierCode;
	intFaceBOLIn.consignorCode 		:= CM_ConsigneeConsignor.firstInstance.code;
//	intFaceBOLIn.myOperator			:= tmpOperator;							// RS 031120
//	intFaceBOLIn.myPlannedLocation 	:= controller;
	intFaceBOLIn.myTerminal 		:= _terminal;
	intFaceBOLIn.numItems 			:= numLogs;
//	intFaceBOLIn.operatorCode 		:= intFaceBOLIn.myOperator.code;		// RS 031120
	intFaceBOLIn.truckNumber	 	:= truck;
	intFaceBOLIn.trailerNumber 		:= null;
	intFaceBOLIn.transportMode 		:= TI_TRANSMODE_ROAD;
	intFaceBOLIn.fellDate 			:= app.actualTimeServer.date - 1;					// RS 031120
	intFaceBOLIn.loggingOperation	:= 'TestLogOrg';
	intFaceBOLIn.jasScaled 			:= true;
//	intFaceBOLIn.lengthRandom 		:= '2.1';								// RS 031120
//	intFaceBOLIn.logGradeCode 		:= 'SXM';								// RS 031120
//	intFaceBOLIn.logSpeciesCode 	:= 'R';									// RS 031120
//	intFaceBOLIn.logTypeCode 		:= 'S';									// RS 031120
	intFaceBOLIn.numberOfLifts 		:= 1;
	intFaceBOLIn.percentScaled 		:= 100;
	intFaceBOLIn.ticketedAll 		:= true;
//	intFaceBOLIn.logTreatmentCode 	:= null;								// RS 031120
	intFaceBOLIn.forest				:= null;
	intFaceBOLIn.sourceLocation		:= null;
	intFaceBOLIn.compartment		:= null;
	intFaceBOLIn.sourceSubLocation	:= null;
	intFaceBOLIn.stand				:= null;
	intFaceBOLIn.sourceSubSubLocation:= null;
	intFaceBOLIn.weightGrossTonnes	:= null;
	intFaceBOLIn.weightNetTonnes	:= null;
	intFaceBOLIn.weightTareTonnes	:= null;
	intFaceBOLIn.remarks			:= null;
	intFaceBOLIn.scalerCode				:= app.getMyUserCode;
	intFaceBOLIn.gangNumber				:= null;
	intFaceBOLIn.handlingContractor1	:= null;
	intFaceBOLIn.handlingContractor2	:= null;
	intFaceBOLIn.loaderNumber			:= null;
	
	// get a location

	create tmpLCSearch transient;
	tmpLCSearch.myOperator 	:= tmpOperator;
	tmpLCSearch.mySpecies 	:= tmpOperator.getLogSpecies(intFaceBOLIn.logSpeciesCode);
	tmpLCSearch.myGrade 	:= tmpLCSearch.mySpecies.allLogGrades[intFaceBOLIn.logGradeCode].CM_LogGrade;
	tmpLCSearch.myType 		:= tmpLCSearch.myGrade.allLogTypes[intFaceBOLIn.logTypeCode].CM_LogType;
	tmpLCSearch.myTreatment := tmpLCSearch.myGrade.allLogTreatments[intFaceBOLIn.logTreatmentCode].CM_LogTreatment;
	tmpLCSearch.myLength 	:= tmpLCSearch.myGrade.allLogLengths[intFaceBOLIn.lengthRandom].CM_LogLength;

	create locnDict transient;
	_terminal.availableLocationsForType(tmpLCSearch, locnDict, TA_TYPE_LOGAREA);

	intFaceBOLIn.myPlannedLocation 	:= locnDict.first;

	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  creating bol ' &amp; intFaceBOLIn.bolNumber);

epilog
	delete locnDict;
	delete tmpLCSearch;
					
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="intFaceCommon" type="CMIF_InOutCommon" usage="input"/>
        <Parameter name="intFaceArray" type="CMIF_TIObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupLogScalingData" id="6404d6fb-bdd8-4d01-96b0-fafed2be7917">
        <source>setupLogScalingData(_terminal : CM_Terminal; _logScaleHdrPxy : CM_LogScalingHdr input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	logDetailPxy	: CM_LogScalingDtl;
	bolExt			: CM_BOLExtension;
	tmpBOL			: CM_BOL;
	idx,
	startId,
	numLogs			: Integer;
	logId			: String;
	minSED,
	maxSED			: Decimal[6,2];

begin

	bolExt := _terminal.allLogBOLsUnmatched.first;
	if bolExt = null then
		// there are no unmatched bols to deal with
		return false;
	endif;
	
	tmpBOL := bolExt.myBOL;

	_logScaleHdrPxy.setProxy(tmpBOL.number, tmpBOL.myOperator.code, null, app.actualTimeServer, _terminal);
	
	numLogs := tmpBOL.numItems;
	startId := self.getLogIds(numLogs);

	foreach idx in 1 to numLogs do
		logId := 'TDX' &amp; (startId + idx - 1).String;
		minSED := 14;
		maxSED := 18;
		
		create logDetailPxy transient;
		logDetailPxy.setProxy(logId, 'OK', minSED, maxSED, _logScaleHdrPxy, 'CNWRS2');
	endforeach;
	
	return true;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_logScaleHdrPxy" type="CM_LogScalingHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupVTMISVoyageData" id="61c52dad-bfb3-4303-beb8-63cd1c6db7a2">
        <updating/>
        <source>setupVTMISVoyageData(_passport : CM_Passport input; _pxyVoyage : CM_Voyage input; _realVessel : CM_Vessel output) updating;
/****Changes

Date		Name	TFS#			Description
============================================================================
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
08/06/2020  nwma1   ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
============================================================================*/
vars
	tmpTerminal			: CM_Terminal;
	tmpTestDataVessel	: CM_TestDataVesselForVTMIS; 
	tmpVessel			: CM_Vessel;
	tmpGlobalVoyage		: CM_VoyageGlobal;
	tmpOperator			: CM_Operator; 
	tmpTrade			: CM_Trade;	 
	tmpBank				: CM_Bank;
	tmpShippingLine		: CM_ShippingLine;
	tmpShipPortGroup	: CM_ShipPortGroup;
	tmpLineGroupDebtor	: CM_LineGroupDebtor;
	aLineGroupDebtor	: CM_LineGroupDebtor;
	tmpLloydsNumber		: String;
	tmpCode				: String;
	tmpInwardCode		: String; 
	tmpRemarks			: String;
	tmpCallSign			: String;
	tmpVesselName		: String; 
	tmpVesselCode 		: String; 		
	tmpNonPlanned		: Boolean;
	tmpNonWorked		: Boolean;
	tmpArchived			: Boolean;
	tmpIsTransferable	: Boolean; 
	tmpStarboardBerth 	: Boolean;
	tmpArchivedDT		: TimeStamp;
	tmpArrivedDT		: TimeStamp;
	tmpDepartedDT		: TimeStamp;
	tmpNonPlannedEffDT	: TimeStamp;
	tmpTime 			: TimeStamp;
    tmpColour			: Integer;
	tmpVesselType 		: Integer;    
    tmpTestBerth		: CM_TestDataBerth;    
    tmpDT				: TimeStamp;
    xArriveDT			: TimeStamp;
    xDepartDT			: TimeStamp;
begin

	beginTransaction;
	self.createChildren();
	commitTransaction;

	if _pxyVoyage = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy Voyage is null.');
		return;
	endif;

	tmpTerminal := _passport.myTerminal;
	
	tmpTestBerth	:= self.getNextBerth(tmpTerminal);
	tmpTestDataVessel := self.getNextVesselForVTMIS();
	tmpVessel := tmpTestDataVessel.myVessel;
	_realVessel := tmpVessel;

	//write class.name &amp; '::' &amp; method.name &amp; ' adding to berth ' &amp; tmpTestBerth.myBerth.code; // jlgka1 TFS 37102 comment out
	
	// set arrive time based on next space on berth
	if tmpTestBerth.maxDepartureTime.isValid() then
		xArriveDT := tmpTestBerth.maxDepartureTime;
	else
		xArriveDT := app.actualTimeServer;
	endif;
	
	// now check last arriveDT for vessel
	tmpDT := tmpTerminal.getMaxDepartDateForVessel(tmpVessel);
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' getMaxDepartDateForVessel for ' &amp; tmpVessel.name &amp; ' -&gt; ' &amp; tmpDT.String);
	if tmpDT.isValid and tmpDT &gt; xArriveDT then
		xArriveDT := tmpDT;
	endif;
	
	xArriveDT := xArriveDT.cnEcAddDays(app.random(5));
	xArriveDT := xArriveDT.cnEcAddHours(app.random(24));
	
	xDepartDT	:= xArriveDT.cnEcAddDays(app.random(10));
	xDepartDT	:= xArriveDT.cnEcAddHours(app.random(24));
	
	if xArriveDT = xDepartDT then
		// always ensure departs date is later
		xDepartDT := xArriveDT.cnEcAddDays(1);
	endif;
	
	tmpTestBerth.setMaxDepartureTime(xDepartDT);
	
//	if CM_CellularVoyage.hasInstance(_pxyVoyage) then
//		self.doSetProxyVoyageCellular(_pxyVoyage.CM_CellularVoyage);
//	endif;

	tmpCode 		:= self.getNextVoyageCodeNum();
	tmpInwardCode 	:= null;
	tmpNonPlanned 	:= false;
	tmpNonWorked 	:= false;
	tmpColour 		:= Red;
		
	tmpOperator 	:= app.myRoot.allOperators['ANL'];
	tmpShippingLine := app.myRoot.allShippingLines['ANZ'];
	//tmpBank 		:= tmpTerminal.getConfig(DefCompany).CM_Bank;
	tmpBank 		:= tmpTerminal.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	tmpTrade 		:= app.myRoot.allTradesByDescription['Chief Tasman'];
	
	tmpShipPortGroup := tmpShippingLine.shipPortGroups.first;
	if tmpShipPortGroup &lt;&gt; null then
		tmpLineGroupDebtor := tmpShipPortGroup.lineGroupDebtors.first;
	endif;
	
	
//	tmpSeedJobNumD 	:= 100;
//	tmpSeedJobNumL 	:= 300;
	tmpNonPlannedEffDT := null;
	tmpRemarks 		:= null;	
	

	tmpArchived := false;
	tmpIsTransferable := false;
	tmpStarboardBerth := false;

	tmpCallSign := tmpVessel.callSign;
	tmpVesselName := tmpVessel.name;
	tmpLloydsNumber  := tmpVessel.lloydsNumber;
	tmpVesselCode  := tmpVessel.code;
	
	tmpArrivedDT.setDate(xArriveDT.date); 
	tmpArrivedDT.setTime(xArriveDT.time.roundToNearestMinute());
	tmpDepartedDT.setDate(xDepartDT.date); 
	tmpDepartedDT.setTime(xDepartDT.time.roundToNearestMinute());		
	
	if tmpArrivedDT &gt; tmpDepartedDT then
		//Arrives after departure, swap them around
		tmpTime := tmpArrivedDT;
		tmpArrivedDT := tmpDepartedDT;
		tmpDepartedDT := tmpTime;
	endif;

	// ========== Setup Global Voyage Details ===========
	tmpGlobalVoyage := app.myRoot.allVoyagesGlobal[tmpCode];
	
	if tmpGlobalVoyage = null then
		create tmpGlobalVoyage transient;
		tmpGlobalVoyage.setProxy(tmpCode, tmpVesselName, null, null, null, null, null,0, null, app.myRoot);
	endif;
	
	_pxyVoyage.setMyVoyageGlobalArrival(tmpGlobalVoyage);
	// ==================================================
	
	//set up voyage first as data used by HMS movements
	_pxyVoyage.setProxyVoyage(	tmpVessel.bitmap,
								tmpCallSign,
								tmpCode,
								tmpInwardCode,
								tmpRemarks,
								tmpVesselCode,
								tmpVesselName,
								tmpLloydsNumber,
								tmpArchived, 
/* PAR 33644								tmpNonPlanned,
								tmpNonWorked, */
								tmpIsTransferable,
								tmpStarboardBerth,
								tmpVessel.craneClearance,
								VoyageDisplayDefault,
								tmpColour,
								_pxyVoyage.status,
								tmpVesselType,
								tmpArchivedDT,
								tmpArrivedDT,
								tmpDepartedDT,
								_pxyVoyage.loadStartDT,
								_pxyVoyage.loadEndDT,
								tmpNonPlannedEffDT,
								null,
								tmpLineGroupDebtor,
								tmpBank,
								tmpOperator,
								tmpTrade,
								tmpShippingLine,
								tmpTerminal,
								_pxyVoyage.myVoyageGlobalArrival,
								null,
								Voyage_Invoice_Status_NotReq,
								null,
								null,
								null,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								_pxyVoyage.allOperators,
								_pxyVoyage.allReceivalCutoffs,	// 27/05/2009 cnwar2 CCMS1040
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,
								false,				//ccms 2209
								tmpArrivedDT,				// PAR #35826
								tmpDepartedDT,				// PAR #35826
								null,						//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null,						// TFS 4050
								_pxyVoyage.paymentType,
								_pxyVoyage.isBarge, 		// jlgka1 TFS 37102
								_pxyVoyage.voyageGroupCode,  //03/06/2020 cnwma1 Tfs #49400
								false	// 31.Aug.2023 navsp1 TFS 57809
								);		

	//Save HMSVesselData
	self.setupVTMISVoyageDataHMSVoyData(_pxyVoyage, tmpVessel, tmpTestBerth.myBerth, _passport);							
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_realVessel" type="CM_Vessel" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setupVTMISVoyageDataHMSVoyData" id="69fecda7-d102-400d-af09-52297ac867ff">
        <updating/>
        <source>setupVTMISVoyageDataHMSVoyData(_pxyVoyage : CM_Voyage input; _vessel : CM_Vessel; _berth : HMS_Berth; _passport : CM_Passport input) updating, protected;

vars
	tmpCategory	: HMS_VesselCategory;
	tmpTidalClass	: HMS_TidalClass;
	row,
	numFix,
	numRows : Integer;
	obj : Object;
	pxyDelay,
	voyageDelay : HMS_VoyageDelay;
	pxyHMSVoyage : HMS_VoyageData;
	pxyPref,
	berthPref : HMS_BerthPreferenceVoyageData;
begin
	
	pxyHMSVoyage := _pxyVoyage.myHMSVoyageData;

	if pxyHMSVoyage = null then
		create pxyHMSVoyage transient;
		_pxyVoyage.setHMSVoyageData(pxyHMSVoyage);
		pxyHMSVoyage.setMyHarbour(_passport.myTerminal.myHarbour);
	endif;
	
	pxyHMSVoyage.setPxyFromVessel(_vessel, _passport.myTerminal);
	
	tmpCategory	:= app.myRoot.allVesselCategories.first;
	tmpTidalClass	:= app.myRoot.allTidalClasses.first;
	
	pxyHMSVoyage.setPxyFromTestData(tmpCategory, tmpCategory, tmpTidalClass, tmpTidalClass,
					'AKL', 'POE', _berth);
	pxyHMSVoyage.setProxyDefaultVoyageMovements(null, null, _passport);					

/*
	//Set arrival/departure DT and berth
	self.tblArrivalDepart.setObjectFromTable(pxyHMSVoyage, 'setObjectFromTableSpecial', false);
	//Set dimensions/distances
	self.tblDimensions.setObjectFromTable(pxyHMSVoyage, 'setObjectFromTableSpecial', false);
	//Set harbour deatils
	self.tblHarbourDetail.setObjectFromTable(pxyHMSVoyage, 'setObjectFromTableSpecial', false);	
*/
/*
	//Set Berth Preferences
	pxyHMSVoyage.allBerthPreferencesArray.clear();	
	numRows := self.tblHMSBerthData.rows;
	numFix := self.tblHMSBerthData.fixedRows;
	
	foreach row in numFix to numRows do
		berthPref := self.tblHMSBerthData.accessRow(row).itemObject.HMS_BerthPreferenceVoyageData;
		if berthPref &lt;&gt; null then
			if (not berthPref.isTransient) 
			and berthPref.myVoyageData &lt;&gt; pxyHMSVoyage then
				//This can happen when changing HMS Voyage to Cellular voyage
				pxyPref := berthPref.cloneMySelf(true);
				self.allProxies.add(pxyPref);
				pxyHMSVoyage.allBerthPreferencesArray.add(pxyPref);
			elseif (not pxyHMSVoyage.allBerthPreferencesArray.includes(berthPref)) then
				pxyHMSVoyage.allBerthPreferencesArray.add(berthPref);
			endif;
		endif;
	endforeach;
*/				
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xmlLogScalingData" id="bbd0950a-c925-4e60-86c6-2518a0d0044f">
        <updating/>
        <source>xmlLogScalingData(_numBatches : Integer; _terminal : CM_Terminal; _userCode : String;
		_allLogBOLsUnmatched : CM_BOLExtLogInByTypeNumDTDict input) : String updating;
// ---------------------------------------------------------------------------
// Created:     07 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	logDetailPxy	: CM_LogScalingDtl;
	bolExt			: CM_BOLExtLogIn;
	tmpStr,
	batchStr,
	xml		: String;
	logScaleHdrPxy	: CM_LogScalingHdr;
	rtnValue	: Boolean;
	tmpBOL			: CM_BOL;
	msgId,
	idx,
	cnt,
	startId,
	numLogs			: Integer;
	tmpBatch,
	rtDeviceId,
	logId			: String;
	minSED,
	maxSED			: Decimal[6,2];
	tmpRTDevice		: CM_RadioTelemetryDevice;
	tmpProd			: CM_TestDataProductCode;
	tmpBOLNum,
	tmpOperatorCode,
	tmpNumStr		: String;
	tmpNum			: Integer;
	tmpOperator		: CM_Operator;
	tmpTestLogBOL	: CM_TestDataLogBOL;

begin

	beginTransaction;
	self.createChildren();
	commitTransaction;

	app.writeLog('Preparing XML for ' &amp; _numBatches.String &amp; ' batches', LogINFO);
	
	while true do
		if self.getNextBOLAsBOLToMatch(tmpBOLNum, tmpOperator, numLogs) then
			app.writeLog('   adding Scaling Dtls for unmatched BOL ' &amp; tmpBOLNum, LogINFO);
			tmpOperatorCode := tmpOperator.code;

			if tmpBOLNum.pos(BOLInNumPrefix, 1) = 1 and
			   tmpBOLNum &lt;&gt; BOLInNumPrefix then
				// assume that this is a test docket so
				// get numeric part and update the next unmatched num
				tmpNumStr := tmpBOLNum[BOLInNumPrefix.length + 1 : end];
				if tmpNumStr &lt;&gt; null and tmpNumStr.isInteger then
					tmpNum := tmpNumStr.Integer + 1;
					app.writeLog('   setting nextBOLInNumUnmatched to ' &amp; tmpNum.String, LogINFO);
					self.setNextBOLInNumUnmatched(tmpNum);
				endif;
			endif;

		else
			app.writeLog('   adding Scaling Dtls ' &amp; tmpBOLNum, LogINFO);
			// get the next product just to get the operator
			tmpBOLNum := self.getNextBOLInNumUnmatched();
			tmpProd	:= self.getNextTestProduct();
			tmpOperatorCode := tmpProd.operatorCode;
			numLogs := 52;
			
			// need to add into local test dict
			tmpOperator := app.myRoot.allOperators[tmpOperatorCode];
			if tmpOperator &lt;&gt; null then
				beginTransaction;
				create tmpTestLogBOL persistent;
				tmpTestLogBOL.set(tmpBOLNum, numLogs, tmpOperator);
				self.allLogBolsAsScalingDtls.add(tmpTestLogBOL);
				commitTransaction;
			endif;
		endif;

		delete logScaleHdrPxy;
		create logScaleHdrPxy transient;

		logScaleHdrPxy.setProxy(tmpBOLNum, tmpOperatorCode, null, app.actualTimeServer, _terminal);

		startId := self.getLogIds(numLogs);
// use this to test what happens if get a duplicate log id

//startId := self.myLogId.lastNum - 52;

		foreach idx in 1 to numLogs do
			logId := 'TDX' &amp; (startId + idx - 1).String;
			minSED := 14;
			maxSED := 18;
			
			create logDetailPxy transient;
			logDetailPxy.setProxy(logId, 'OK', minSED, maxSED, logScaleHdrPxy, _userCode);
		endforeach;

		tmpStr := logScaleHdrPxy.xmlOutputForTestLoad();
		batchStr := batchStr &amp; tmpStr;
		
		cnt := cnt + 1;
		if cnt &gt;= _numBatches then
			break;
		endif;
	endwhile;
	
	tmpRTDevice := self.getNextRTDevice(_terminal);
	if tmpRTDevice &lt;&gt; null then
		msgId := tmpRTDevice.lastMessageId + 1;
		rtDeviceId := tmpRTDevice.id;
	endif;
	
	xml := 
		logScaleHdrPxy.formatAsXMLPrefix(XML_MSG) &amp;
		logScaleHdrPxy.formatAsXMLPrefix(XML_HDR) &amp;
		logScaleHdrPxy.formatAsXML(XML_MSGTYPE, CM_RemoteDataManager.SCLTRUCKRQ) &amp;
		logScaleHdrPxy.formatAsXML(XML_MSGID, msgId.String) &amp;
		logScaleHdrPxy.formatAsXML(XML_DEVICEID, rtDeviceId) &amp;
		logScaleHdrPxy.formatAsXML(XML_USERID, _userCode) &amp;
		logScaleHdrPxy.formatAsXML(XML_PSWD, null) &amp;
		logScaleHdrPxy.formatAsXML(XML_TERMINAL, _terminal.code) &amp;
		logScaleHdrPxy.formatAsXML(XML_VERSION, '2') &amp;
		logScaleHdrPxy.formatAsXML(XML_TIME, app.actualTimeServer.formatAsYYYYMMDDHHmmSS()) &amp;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		logScaleHdrPxy.formatAsXMLSuffix(XML_HDR) &amp;
		logScaleHdrPxy.formatAsXMLPrefix(XML_BDY) &amp;
		logScaleHdrPxy.formatAsXMLPrefix(XML_BATCHRQ) &amp;
		batchStr &amp;
		logScaleHdrPxy.formatAsXMLSuffix(XML_BATCHRQ) &amp;
		logScaleHdrPxy.formatAsXMLSuffix(XML_BDY) &amp;
		logScaleHdrPxy.formatAsXMLSuffix(XML_MSG);

	return xml;

epilog
	delete logScaleHdrPxy;
end;</source>
        <Parameter name="_numBatches" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_allLogBOLsUnmatched" type="CM_BOLExtLogInByTypeNumDTDict" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
