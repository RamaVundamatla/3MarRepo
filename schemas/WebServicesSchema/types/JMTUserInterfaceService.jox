    <JadeWebServicesMethod name="getWorkOrderCargo" id="f7db74ee-aa82-4e11-bc60-ad92c32c9c85">
        <source>getWorkOrderCargo(_request : WS_GetWorkOrderCargoRequest) : WS_TrackedItemQueryResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2018	jlger1	Initial creation 38947
13/02/2019	jlgdap1	TFS 43062 PEL1 Container Services - Changes in Web Portal
06/03/2019	jlgdap1	TFS 43535 PEL1 Container Services - Freight Forwarder access and visibility in WP
*/

vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	tiWorkOrderDetail,
	workOrderDetail  : CM_WorkOrderDtl;
	booking			: CM_BookingRef;
	releaseRequest : CM_BulkRelease;
	iter 			: Iterator;
	ti 				: CM_TrackedItem;
	proxyTI			: WS_TrackedItem;
	user			: CM_User;								// TFS 43535
	failedDAC		: CM_DataAccessController;				// TFS 43535
	cons			: CM_ConsigneeConsignor;				// TFS 43535
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	// Check security access to this message
	app.checkCurrentUserHasAccess(PmAdmCargoEnquiryView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if _request.workOrderDetailOid &lt;&gt; null then
		workOrderDetail:=app.myPassport.getObjectOfTypeFromOid(_request.workOrderDetailOid,CM_WorkOrderDtl).CM_WorkOrderDtl;
	endif;	
	
	user := app.getMyUser;										// TFS 43535
	if _request.workOrderType = WO_TASK_RECEIVE then
		//get the booking and 
		booking:=app.myPassport.getObjectOfTypeFromOid(_request.sourceOid,CM_BookingRef).CM_BookingRef;
		if booking = null then
			completedOK := true;
			return response;
		endif;
		iter:= booking.allTIs.createIterator;
		while iter.next(ti) do
			if not ti.isPreNote then
				continue;
			endif;
			
			// TFS 43535 Check data access - freight forwarder / consignee / consignor
			if not user.getUserIsFreightForwarder then
				if ti.consignee &lt;&gt; null then
					cons := app.myRoot.allConsigneeConsignors[ti.consignee];
					if cons &lt;&gt; null and not cons.canUserAccessSelf(user, failedDAC, app.myPassport) then
						continue;
					endif;
				endif;
				if ti.consignor &lt;&gt; null then
					cons := app.myRoot.allConsigneeConsignors[ti.consignor];
					if cons &lt;&gt; null and not cons.canUserAccessSelf(user, failedDAC, app.myPassport) then
						continue;
					endif;
				endif;
			endif;
			if ti.myFreightForwarder &lt;&gt; null then
				if not ti.myFreightForwarder.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
					app.writeLog("User " &amp; app.getMyUser.userName &amp; " CANNOT access " &amp; ti.id, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
					continue;
				endif;
				app.writeLog("User " &amp; app.getMyUser.userName &amp; " CAN access " &amp; ti.id, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			elseif app.getMyUser.getUserIsFreightForwarder then
				continue;
			endif;
			// TFS 43535 end
				
			tiWorkOrderDetail :=ti.getWorkOrderDetailOfType( WO_TASK_RECEIVE);
			if tiWorkOrderDetail &lt;&gt; null then			
				if workOrderDetail &lt;&gt; tiWorkOrderDetail  then
					//already on cargo receive for another work order
					continue;
				endif;			
			endif;
			
			create proxyTI transient;
			proxyTI.setProxyFromObject(ti);
			response.allTrackedItems.add(proxyTI);
		endwhile;
	elseif _request.workOrderType = WO_TASK_RELEASE then
		releaseRequest:=app.myPassport.getObjectOfTypeFromOid(_request.sourceOid,CM_BulkRelease).CM_BulkRelease;
		if releaseRequest = null then
			completedOK := true;
			return response;
		endif;
		iter:= releaseRequest.allTrackedItemsAssigned.createIterator;
		while iter.next(ti) do
			tiWorkOrderDetail :=ti.getWorkOrderDetailOfType( WO_TASK_RELEASE);
			if tiWorkOrderDetail &lt;&gt; null then			
				if workOrderDetail &lt;&gt; tiWorkOrderDetail  then
					//already on cargo receive for another work order
					app.writeLog("TI " &amp; ti.id &amp; " is already assigned to another work order detail", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
					continue;
				endif;			
			endif;
			// TFS 43062 Filter by customs clearance number if entered
			if _request.customsClearanceNumber &lt;&gt; null and _request.customsClearanceNumber &lt;&gt; ti.customsEntryNumber then
				app.writeLog("TI " &amp; ti.id &amp; " does not match customs clearance number " &amp; _request.customsClearanceNumber, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				continue;
			endif;
			// TFS 43062 end
			
			// TFS 43535 Check data access - freight forwarder / consignee / consignor
			if not user.getUserIsFreightForwarder then
				if ti.consignee &lt;&gt; null then
					cons := app.myRoot.allConsigneeConsignors[ti.consignee];
					if cons &lt;&gt; null and not cons.canUserAccessSelf(user, failedDAC, app.myPassport) then
						app.writeLog("User " &amp; app.getMyUser.userName &amp; " CANNOT access " &amp; ti.id &amp; " - Consignee", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
						continue;
					endif;
				endif;
				if ti.consignor &lt;&gt; null then
					cons := app.myRoot.allConsigneeConsignors[ti.consignor];
					if cons &lt;&gt; null and not cons.canUserAccessSelf(user, failedDAC, app.myPassport) then
						app.writeLog("User " &amp; app.getMyUser.userName &amp; " CANNOT access " &amp; ti.id &amp; " - Consignor", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
						continue;
					endif;
				endif;
			endif;
			if ti.myFreightForwarder &lt;&gt; null then
				if not ti.myFreightForwarder.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
					app.writeLog("User " &amp; app.getMyUser.userName &amp; " CANNOT access " &amp; ti.id &amp; " - Freight Forwarder", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
					continue;
				endif;
				app.writeLog("User " &amp; app.getMyUser.userName &amp; " CAN access " &amp; ti.id, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			elseif app.getMyUser.getUserIsFreightForwarder then
				app.writeLog("User " &amp; app.getMyUser.userName &amp; " CANNOT access " &amp; ti.id &amp; " - User is Freight Forwarder", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				continue;
			endif;
			// TFS 43535 end
				
			create proxyTI transient;
			proxyTI.setProxyFromObject(ti);
			response.allTrackedItems.add(proxyTI);
		endwhile;
	endif;
	
	completedOK :=true;
	return response;
epilog
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_GetWorkOrderCargoRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWorkOrderStatuses" id="3fbbbbf9-535c-4979-b24e-dd72bf47b252">
        <source>getWorkOrderStatuses() : WS_CodeResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520
12 Aug 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	response			 : WS_CodeResponse;
	completedOK			 : Boolean;
	proxyWorkOrderStatus : WS_Code;
begin
	
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;		
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_USERENTRY.String, 		app.getErrorString(WO_STATUS_USERENTRY_DESC));
	response.allCodes.add(proxyWorkOrderStatus);	
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_PENDING.String,			app.getErrorString(WO_STATUS_PENDING_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_APPROVED.String,		app.getErrorString(WO_STATUS_APPROVED_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_NOTAPPROVED.String,		app.getErrorString(WO_STATUS_NOTAPPROVED_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_PARTCOMPLETE.String,	app.getErrorString(WO_STATUS_PARTCOMPLETE_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_COMPLETE.String,		app.getErrorString(WO_STATUS_COMPLETE_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_PENDING_CANCEL.String,	app.getErrorString(WO_STATUS_PENDING_CANCEL_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_CANCELLED.String,		app.getErrorString(WO_STATUS_CANCELLED_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_PENDING_HOLD.String,	app.getErrorString(WO_STATUS_PENDING_HOLD_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_HELD.String,			app.getErrorString(WO_STATUS_HELD_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	//12.8.2018 cnwma1 TFS #39698
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_PENDING_FIN.String,		app.getErrorString(WO_STATUS_PENDING_FIN_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	//12.8.2018 cnwma1 TFS #39698
	create proxyWorkOrderStatus transient;
	proxyWorkOrderStatus.setProxyDetails(null,WO_STATUS_REJECTED_FIN.String,	app.getErrorString(WO_STATUS_REJECTED_FIN_DESC));
	response.allCodes.add(proxyWorkOrderStatus);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
