    <JadeMethod name="doCheckDroppedTI" id="dd551ee5-63e6-469d-b1f2-441b2e113109">
        <source>doCheckDroppedTI(_theTI: CM_TrackedItem): Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return _theTI = self.myDroppedTI;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="cc5750e8-eea2-4735-bc5d-62b8cb4897f8">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;
	selectedCargo : CM_TIArray;

begin

	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		create selectedCargo transient;
		self.myCurrentDrawingController.getAllSelectedTIs( selectedCargo );
		if not selectedCargo.isEmpty then
			selectedCargo.copy(realTiSet);
			ti  := realTiSet.first;
			self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
			return;
		endif;
		return;
	endif;

	inheritMethod(menuItem);

epilog

	delete realTiSet;
	delete selectedCargo;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doContextMenuBuild" id="ce38b641-e0af-49c7-9190-7ee41a25769d">
        <updating/>
        <source>doContextMenuBuild(cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
16 Dec 2008	cnwkpd1	PAR #18664 - Clean up leaked transients

*/

vars
	lTI					: CM_TrackedItem;
	gridController		: CM_GridController;
	anLC				: CM_LocationsController;
	aRestriction		: CM_Restriction;
	aTiDict				: CM_TIByIdDict;
	termArea			: CM_TerminalArea;
	locnString			: String;
	thePlanMove			: CM_FutureMove;
	theObj				: Object;
	theDrawController	: YRD_ContainerDrawingController;
	tiArray				: CM_TIArray;
	yaAllocation		: CM_YardAllocation;
	tableObject			: CM_Object;
	table				: Table;
	deckingForTA		: Boolean;
begin
	self.doTurnOffContextMenus();
	self.allMenuTransients.purge(); // PAR 18723
	
	if self.myCurrentDrawingController = null then
		return;
	endif;
	

	self.mnuGridSelectorClear.visible := true; //not self.myCurrentDrawingController.allSelectorTIs.isEmpty;

	anLC := self.myDrawingFrame.getObjectForPositionClass(CM_LocationsController,x, y).CM_GridController;
	if anLC.isKindOf(CM_GridController) then
		gridController := anLC.CM_GridController;
	endif;
	

					
	theObj := self.myDrawingFrame.getObjectForPosition(x, y);
	theDrawController := self.myCurrentDrawingController;

	if theObj = null then
		return;
	endif;
	
	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
		
		if gridController &lt;&gt; null then
			self.mnuGridSelectAreas.visible := true;
			self.mnuGridSelectAreas.userObject := gridController;
		endif;
		if theDrawController.displayMode = DISPLAY_MODE_ACTUAL then
			lTI := theDrawController.get40FooterFromBackEnd(y,anLC,REAL_MODE);
		elseif theDrawController.displayMode = DISPLAY_MODE_QUEUE then
			lTI := theDrawController.get40FooterFromBackEnd(y,anLC,QUEUE_MODE);
		elseif theDrawController.displayMode = DISPLAY_MODE_PLAN then
			lTI := theDrawController.get40FooterFromBackEnd(y,anLC,PLANNING_MODE);
		endif;
	elseif theObj.isKindOf(CM_Restriction) then
		aRestriction := theObj.CM_Restriction;
	elseif theObj.isKindOf(CM_TrackedItem) then
		lTI := theObj.CM_TrackedItem;
		self.mnuGridSelectAreas.visible := true;
		self.mnuGridSelectAreas.userObject := lTI;
	endif;

	if lTI &lt;&gt; null then
		self.mnuCargo.visible := true;
		// #######################
		self.doBuildMnuContainer(lTI);
		if global.isValidObject(self.mnuCargoAP.userObject) then
			delete self.mnuCargoAP.userObject;
		else
			self.mnuCargoAP.userObject := null;
		endif;
		create tiArray transient;
		self.allMenuTransients.add(tiArray); // PAR 18723
		
		//theDrawController.allSelectedObjects.copy(tiArray);
		theDrawController.getAllSelectedTis(tiArray);	// 20514 here as well
		
		self.mnuCargoMoveIt.userObject := tiArray;
		self.mnuCargoAP.userObject := tiArray;
		if theDrawController.allSelectedObjects.size &gt; 1 then
//			self.mnuCargo.visible := false;
			self.mnuGridBulkEdit.visible := true;
			create aTiDict transient;
			self.allMenuTransients.add(aTiDict); // PAR 18723
			theDrawController.getAllSelectedTis(aTiDict);	// 20514 fix needed here too
			self.mnuGridBulkEdit.userObject := aTiDict;
			
			self.mnuCargoUnplan.visible := false;
			self.mnuCargoUnqueue.visible := false;
			self.mnuGridBulkUnqueue.visible := true;
			self.mnuGridBulkUnqueue.userObject := aTiDict;
			
		endif;
			// #####################
			// PLANNING FROM SHIP?
			// #####################
//		self.myAssistant.buildMnuGridLoadPlan(self.mnuGridPlanLoad,lTI,gridController,self.myCurrentDrawingController);		
		
		if app.myMoveController &lt;&gt; null then

			if lTI &lt;&gt; null then
				if app.myMoveController.mySlotRequest &lt;&gt; null and app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
					// YES!
					if app.myMoveController.mySlotRequest.isLoad then
						if lTI &lt;&gt; null then
							app.myMoveController.setMyTrackedItem(lTI);
						endif;
						// if it is planned DLR discharge and a 40 they may have right clicked on the back end.
						// we must have the primary location of teh 40 so that the screen draws correctly
						if  lTI.isAttributeTrue(TI_Attrib_IsForty) then
							if lTI.isRehandle then
								thePlanMove := lTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
								if thePlanMove &lt;&gt; null then
									anLC := thePlanMove.CM_FutureMovePlanned.allLocationsControllers.first;
									if anLC &lt;&gt; null and anLC.isKindOf(CM_GridController) then
										gridController := anLC.CM_GridController;
									endif;
								endif;
							else
								// if a plain export load then we need the primary actual location
								anLC := lTI.myPrimaryActualLocation;
								if anLC &lt;&gt; null and anLC.isKindOf(CM_GridController) then
									gridController := anLC.CM_GridController;
								endif;
							endif;
						endif;									

						app.myMoveController.setMyOriginatingLocation(gridController);
						locnString := app.myMoveController.mySlotRequest.mySlotController.myVoyage.code &amp; " ";
						locnString := locnString &amp; app.myMoveController.mySlotRequest.mySlotController.getStowageId(lTI);


						if self.myCurrentDrawingController.allSelectedObjects.size &gt; 1 then
							self.mnuGridPlanLoad.userObject := self.myCurrentDrawingController;
							self.mnuGridPlanLoad.caption := "Plan Load Selected Cargo";
						else
							self.mnuGridPlanLoad.caption := "Plan Load To " &amp; locnString;
							self.mnuGridPlanLoad.userObject := gridController;
						endif;
						self.mnuGridPlanLoad.visible := true;
					endif;
				elseif app.myMoveController.myVoyageRequest &lt;&gt; null and app.myMoveController.myVoyageRequest.myJob &lt;&gt; null then
					// YES!
					if app.myMoveController.myVoyageRequest.isLoad then
						if lTI &lt;&gt; null then
							app.myMoveController.setMyTrackedItem(lTI);
						endif;
						// if it is planned DLR discharge and a 40 they may have right clicked on the back end.
						// we must have the primary location of teh 40 so that the screen draws correctly
						if  lTI.isAttributeTrue(TI_Attrib_IsForty) then
							if lTI.isRehandle then
								thePlanMove := lTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
								if thePlanMove &lt;&gt; null then
									anLC := thePlanMove.CM_FutureMovePlanned.allLocationsControllers.first;
									if anLC &lt;&gt; null and anLC.isKindOf(CM_GridController) then
										gridController := anLC.CM_GridController;
									endif;
								endif;
							else
								// if a plain export load then we need the primary actual location
								anLC := lTI.myPrimaryActualLocation;
								if anLC &lt;&gt; null and anLC.isKindOf(CM_GridController) then
									gridController := anLC.CM_GridController;
								endif;
							endif;
						endif;									

						app.myMoveController.setMyOriginatingLocation(gridController);
						locnString := app.myMoveController.myVoyageRequest.CM_RORORequest.myROROController.myVoyage.code &amp; " ";
						locnString := locnString &amp; app.myMoveController.myVoyageRequest.CM_RORORequest.myROROController.getStowageId(lTI);


						if self.myCurrentDrawingController.allSelectedObjects.size &gt; 1 then
							self.mnuGridPlanLoad.userObject := self.myCurrentDrawingController;
							self.mnuGridPlanLoad.caption := "Plan Load Selected Cargo";
						else
							self.mnuGridPlanLoad.caption := "Plan Load To " &amp; locnString;
							self.mnuGridPlanLoad.userObject := gridController;
						endif;
						self.mnuGridPlanLoad.visible := true;
					endif;				
				endif; // SLOT
			endif;
		endif;

	else
		// #####################
		// PLANNING FROM SHIP?
		// #####################
		if app.myMoveController &lt;&gt; null then
			// DISCHARGE
			if app.myDraggedTrackedItem &lt;&gt; null then
				thePlanMove := app.myDraggedTrackedItem.getFutureMoveOfType(PLANNING_MODE, TI_FutureMoveDLRDischarge);
				if thePlanMove = null then
					thePlanMove := app.myDraggedTrackedItem.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
				endif;
				if thePlanMove &lt;&gt; null then
					self.mnuGridPlanDischarge.userObject := null;
					self.mnuGridPlanDischarge.visible := false;
				else
					if app.myMoveController.mySlotRequest &lt;&gt; null and 
					   app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
						// YES!
						if app.myMoveController.mySlotRequest.isDischarge  then
							self.mnuGridPlanDischarge.caption := "Plan Discharge " &amp; app.myDraggedTrackedItem.id;
							self.mnuGridPlanDischarge.userObject := gridController;
							self.mnuGridPlanDischarge.visible := true;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;

	self.doHideSeperator();
	
epilog
	/*  // PAR 18723 see allMenuTransients
	delete aTiDict;				// PAR #18664
	delete tiArray;
	*/
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDFContextMenu" id="8bf22203-8466-4af7-9031-0712e48631d5">
        <updating/>
        <source>doDFContextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	showAll : Boolean;
begin
	self.doTurnOffContextMenus();
	showAll := true;
	self.mnuGridSeperator02.visible := showAll;
	self.doBuildMnuZoom(self.mnuZoomSub);
	self.doContextMenuBuild(cntrl,conwin, mouse,x,y);
	self.mnuZoomSub.visible := showAll;
	if self.myCurrentDrawingController &lt;&gt; null
	and self.myCurrentDrawingController.getOverlayFrame(false).visible then
		self.mnuZoomSub.visible := true;
		self.mnuGridSelector.visible := false;
	endif;
	self.mnuGridBigFont.visible := true;
	self.mnuGridSeperator01.visible := false;
	self.mnuGridAreaContext.visible := true;
	return self.showContextMenu(mnuGridAreaContext, cntrl, conwin, mouse, x, y);

end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDFDblClick" id="7e2bfb09-9f69-4a6f-abec-0baee1f18bc3">
        <updating/>
        <source>doDFDblClick(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - remove references to location restrictions, replace YRD_LocationMaintForm constants with YRDPadArea Constants
vars
	theTI			: CM_TrackedItem;
	theLabour 		: CM_LabourRestriction;
	gridController 	: CM_GridController;
	anLC 			: CM_LocationsController;
	theBS 			: CM_BlockStack;
	termArea 		: CM_TerminalArea;
	hghtExceedObj	: CMIF_YardHeightExceeded;
	theObj 			: Object;
begin
	theObj := self.myDrawingFrame.getObjectForPosition(self.origXPos.Integer, self.origYPos.Integer);

	if theObj = null then
		return;
	endif;
	
	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
		
	elseif theObj.isKindOf(CM_BlockStack) then
		theBS := theObj.CM_BlockStack;
		
	elseif theObj.isKindOf(CM_LabourRestriction) then
		theLabour 	:= theObj.CM_LabourRestriction;
		termArea 	:= theLabour.myTerminalArea;

	elseif theObj.isKindOf(CM_TrackedItem) then
		theTI := theObj.CM_TrackedItem;
		
	elseif theObj.isKindOf(CMIF_YardHeightExceeded) then	// PAR 21532 CCMS SFW 1025
		hghtExceedObj := theObj.CMIF_YardHeightExceeded;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	if theTI &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
	
	// ### SUB BLOCK STACK 
	elseif theBS &lt;&gt; null then
		self.myAssistant.showLocationEnquiryForm(theBS, self.myMasterMenuAction, false, false);

	// ### LABOUR RESTRICTION
	elseif theLabour  &lt;&gt; null then
		self.myAssistant.showRestrictionsForm(termArea,YRD_PadArea.AreaMode_Labour,theLabour,self.xmlFlipH,self.xmlFlipV, self.myMasterMenuAction);
	
	elseif hghtExceedObj &lt;&gt; null then	// PAR 21532 CCMS SFW 1025
		if self.myCurrentDrawingController &lt;&gt; null then
			self.myAssistant.showHeightExceededForm(hghtExceedObj, self.myCurrentDrawingController.getViewMode(), self.myMasterMenuAction);
		endif;
	else
		return;
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. Unknown DOUBLE CLICK");
	endif;
epilog
	app.mousePointer := MousePointer_Default;


end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDFDragDrop" id="5aac63f0-4ea5-460d-a886-ae3537ec67d1">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFDragDrop(frame: YRD_ContainerDrawingFrame input; win: Window input; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//7
// ---------------------------------------------------------------------------

vars

	theTIs : CM_TIArray;
begin
	self.myDroppedTI := null;
	if win &lt;&gt; null then
		if win.userObject &lt;&gt; null then
			if win.userObject.class.name = "SHP_LoadList" then
				app.raiseCMException1(INVALID_MOVE_REQUEST, 'Cannot drag drop from Load List form.', null, null);
				return;
			endif;
		endif;
	endif;
	if self.myCurrentDrawingController.displayMode = DISPLAY_MODE_PLAN and self.myCurrentDrawingController.moveMode = REAL_MODE then
		app.raiseCMException1(INVALID_MOVE_REQUEST, Cr &amp;  'Cannot drag drop in INSTANT mode whilst displaying PLANNED cargo.', null, null);
		return;
	
	endif;

	if win.isKindOf(CMUI_GridAreaForm) or 
	   win.isKindOf(CMUI_GridAreaFrame) or
	   win.isKindOf(CMUI_GridAreaForm2) or
	   win.isKindOf(CMUI_GridAreaDrawingFrame) then

		if self.myPreviousDrawingController &lt;&gt; null then
			create theTIs transient;
			self.myPreviousDrawingController.getAllSelectedTIs(theTIs);
			if  theTIs.size &gt; 1 then
				self.doGridAreaDragDropEventQdOS(theTIs,app.myDraggedTrackedItem);
				if theTIs.isEmpty then
					return;
				endif;
			endif;
		endif;

		self.doDropFromGridAreaForm(frame,win, x,y);
	endif;
	
	if win.isKindOf(YRD_RoadOperationsForm) or win.isKindOf(CM_DataTable) then 
		self.doDropFromGridAreaForm(frame,win, x,y); // they basically do the same. This one is more comprehensive
	endif;
	if app.myPassport.trxCompletedOK then
		app.isDragging := true;
	else
		app.isDragging := false;
	endif;
	
	if self.autoMask then
		if self.myCurrentDrawingController.autoMask then
			if not self.myCurrentDrawingController.allSelectorTIs.includes(self.myDroppedTI) then
				self.myCurrentDrawingController.allSelectorTIs.add(self.myDroppedTI);
			endif;
		endif;
	endif;
	
	frame.dragMode := DragMode_None;
epilog
	delete theTIs;
	frame.enableEvent("mouseMove",false);


end;</source>
        <Parameter name="frame" type="YRD_ContainerDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDFDragOver" id="440089c6-ebd6-4a75-92dd-3831e1cc42cd">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFDragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	maskTI 	 : CM_TrackedItem;
	targetTA : CM_TerminalArea;
	gridArea : YRD_GridArea;
	cdc : YRD_ContainerDrawingController;
begin

	// if entering the frame init the AM flag
	if state = Window.DragOver_Enter then
		if app.myMoveController &lt;&gt; null then
			app.myMoveController.isAutoMasked := false;
		endif;
	endif;


	if frame = null then
		return;
	endif;
	
	if self.frmInfoDrag.visible then
		self.frmInfoDrag.move(x,y,self.frmInfoDrag.width,self.frmInfoDrag.height);
	endif;

	if app.myMoveController = null then
		return;
	endif;
	
	self.setFocus();
	self.zOrder(1);
	self.windowState := WindowState_Normal;
	
	if frame &lt;&gt; null then
		cdc := frame.YRD_ContainerDrawingFrame.getDrawingController();
	endif;

	if self.myCurrentDrawingController &lt;&gt; cdc then
		self.setMyCurrentDrawingController(cdc, true);
		app.myMoveController.isAutoMasked := false;
	endif;
	
	if state = Window.DragOver_Enter 
	and self.autoMask 
	and (not app.myMoveController.isAutoMasked) then
		if self.myCurrentDrawingController.autoMask then
			// auto masking on, colour up pad area for masked TI
			app.myMoveController.isAutoMasked := true;
			
			maskTI := app.myMoveController.myTrackedItem;
			if maskTI = null then
				return;
			endif;
			if cdc.allGridObjects.isEmpty then
				return;
			endif;
	
			self.doGridAreaDragOverAutoMask(cdc, maskTI);
		endif;
	endif;	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDFMouseDown" id="57731426-85ac-43e9-806b-a97b0c992acd">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFMouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	db : YRD_ContainerGridAreaDockBar;
	anObject : Object;
begin
	self.origXPos := x;
	self.origYPos := y;
	frame.enableEvent("mouseMove",true);
	
	self.myDrawingFrame := frame.YRD_ContainerDrawingFrame;

	self.setMyCurrentDrawingController(frame.YRD_ContainerDrawingFrame.getDrawingController(), false);
	
			
	foreach anObject in self.allDockBars do
		db := anObject.YRD_ContainerGridAreaDockBar;
		db.myDrawingFrame.changeBackColor(self.defYardBackColUnselected);
	endforeach;
	frame.CMUI_GridAreaDrawingFrame.changeBackColor(self.defYardBackColSelected);
	frame.CMUI_GridAreaDrawingFrame.isDrawDeskTopRectangle := false;
	frame.CMUI_GridAreaDrawingFrame.isDrawAltSelectRectangle := false;
	frame.CMUI_GridAreaDrawingFrame.isDrawShiftSelectRectangle := false;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDFMouseMove" id="7a3fedd8-f802-4118-af3d-29f4398ecc1b">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFMouseMove(frame: CMUI_GridAreaDrawingFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/07/2009	consw1		PAR 20210 - Allow multiple containers to be selected for planning (wanted for rail)
// ---------------------------------------------------------------------------
// 07/11/2012	CNWCS5	PAR 30475 - REMOVE LOCATION RESTRICTIONS
vars

	theTI		: CM_TrackedItem;
	root : CM_Root;
	lPicture : Picture;
	theTIs : CM_TIArray;
	anLC : CM_LocationsController;
	thePlanMove : CM_FutureMove;
	theLabour : CM_LabourRestriction;
	gridController : CM_GridController;
	theBS : CM_BlockStack;
	termArea : CM_TerminalArea;
	theObj : Object;
	theDrawController : YRD_ContainerDrawingController;
begin
	theObj := self.myDrawingFrame.getObjectForPosition(self.origXPos.Integer, self.origYPos.Integer);
	theDrawController := self.myCurrentDrawingController;

	if theObj = null then
		return;
	endif;
	
	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
		
		theTI := theDrawController.get40FooterFromBackEnd(y,anLC,REAL_MODE);
		// important that this actually be the ti's primary location - validation in move code
		if theTI &lt;&gt; null then
			anLC := theTI.myPrimaryActualLocation;
		endif;
				
	elseif theObj.isKindOf(CM_BlockStack) then
		theBS := theObj.CM_BlockStack;
	
	elseif theObj.isKindOf(CM_LabourRestriction) then
		theLabour 	:= theObj.CM_LabourRestriction;
		termArea 	:= theLabour.myTerminalArea;
	
	elseif theObj.isKindOf(CM_TrackedItem) then
		theTI := theObj.CM_TrackedItem;
		if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
			anLC := theTI.myPrimaryActualLocation;
		elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
			anLC := theTI.myPrimaryPlannedLocation;
		elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
			anLC := theTI.myPrimaryQueuedLocation;
		endif;

	endif;

	if button = Window.MouseButton_Left 
	and frame.dragMode &lt;&gt; DragMode_Drag
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then

		create theTIs transient;
//		self.myCurrentDrawingController.allSelectedObjects.copy(theTIs);
		if self.myCurrentDrawingController.moveMode = PLANNING_MODE and theTI &lt;&gt; null then
			// Allow multiple containers to be selected for planning (wanted for rail)
			if self.myCurrentDrawingController.allSelectedObjects.size &gt; 1
			and self.myCurrentDrawingController.allSelectedObjects.includes(theTI) then
				self.myCurrentDrawingController.allSelectedObjects.copy(theTIs);
				theTIs.remove(theTI);
			endif;
		endif;
		/* PAR 21901
		if theTIs.isEmpty then
			if theTI &lt;&gt; null then
				self.myCurrentDrawingController.selectObject(theTI,frame,false);
				theTIs.add(theTI);
			endif;
		endif;
		*/
		//PAR 21901 if not theTIs.isEmpty then
		if theTI &lt;&gt; null then
			//PAR 21901 if  theTIs.isEmpty then
			//PAR 21901 	return;
			//PAR 21901 endif;
			
			self.moveModeForm := self.myCurrentDrawingController.moveMode;
			if self.moveModeForm =REAL_MODE then
				theTIs.clear;
			endif;
			app.myDraggedTrackedItem := theTI;
			self.setMoveControllerSource(theTI);

			app.myMoveController.setMyOriginatingLocation(anLC);
			// if it is planned DLR discharge and a 40 they may have right clicked on the back end.
			// we must have the primary location of teh 40 so that the screen draws correctly
			if theTI.isRehandle and theTI.isAttributeTrue(TI_Attrib_IsForty) then
				thePlanMove := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
				if thePlanMove &lt;&gt; null then
					anLC := thePlanMove.CM_FutureMovePlanned.allLocationsControllers.first;
					if anLC &lt;&gt; null and anLC.isKindOf(CM_GridController) then
						app.myMoveController.setMyOriginatingLocation(anLC);
					endif;
				endif;
			endif;									

		
			if not theTIs.isEmpty then
				app.myMoveController.setAllOtherTrackedItems(theTIs);
			endif;
			frame.dragMode := DragMode_Drag;
			root := app.myRoot;

			create lPicture transient;
			self.setPictureDragCursor(lPicture);
			if lPicture.picture &lt;&gt; null then
				frame.dragCursor := lPicture.picture;
			endif;
		endif;
	endif;
epilog
	delete lPicture;
	delete theTIs;


end;</source>
        <Parameter name="frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDFMouseUp" id="92a2c756-25b6-47c5-8353-a2d269a7d1d2">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 07/11/2012	CNWCS5	PAR 30475 - REMOVE LOCATION RESTRICTIONS

vars
	statMess : String;
	thePIC : CMIF_PopupInfoController;
	theSBS : CM_BlockStack;
	theLabRest : CM_LabourRestriction;
	theTermArea : CM_TerminalArea;
	theCMObject : CM_Object;
	theTI : CM_TrackedItem;
	theLabour : CM_LabourRestriction;
	gridController : CM_GridController;
	anLC : CM_LocationsController;
	theBS : CM_BlockStack;
//	aTiDict : CM_TIByIdDict;
//	aOK : Boolean;
	termArea : CM_TerminalArea;
	theObj : Object;
	theDrawController : YRD_ContainerDrawingController;
begin
	theObj := self.myDrawingFrame.getObjectForPosition(x.Integer, y.Integer);
	
	
	theDrawController := self.myCurrentDrawingController;

	if theObj = null then
		theDrawController.clearAllSelectedObjects();
		return;
	endif;
	
	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
	elseif theObj.isKindOf(CM_BlockStack) then
		theBS := theObj.CM_BlockStack;
	elseif theObj.isKindOf(CM_LabourRestriction) then
		theLabour 	:= theObj.CM_LabourRestriction;
		termArea 	:= theLabour.myTerminalArea;
		anLC 		:= theObj.CM_LabourRestriction.allLocationControllers.first;

	elseif theObj.isKindOf(CM_TrackedItem) then
		theTI := theObj.CM_TrackedItem;
		if theDrawController.displayMode = DISPLAY_MODE_ACTUAL then
			anLC := theTI.myPrimaryActualLocation;
		elseif theDrawController.displayMode = DISPLAY_MODE_QUEUE then
			anLC := theTI.myPrimaryQueuedLocation;
		elseif theDrawController.displayMode = DISPLAY_MODE_PLAN then
			anLC := theTI.myPrimaryPlannedLocation;
		endif;

	endif;
//###
//	if anLC &lt;&gt; null then
//		theDrawController.heightOfStack := anLC.CM_GridController.myGridRow.myGridArea.heightOfStack;
//	endif;

	if frame.CMUI_GridAreaDrawingFrame.longLeftClick 
	and self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
	and not app.isDragging then
		create thePIC transient;
		theTermArea := anLC.myTerminalArea;
		theSBS := theBS.CM_SubBlockStack;
		theLabRest := theLabour;
		if theTI &lt;&gt; null then
			theCMObject := theTI;
		elseif theSBS &lt;&gt; null then
			thePIC.showEnquiryButton := true;
			self.frmPopupInfo.userObject := theSBS;
			self.btnPopupEnq.bubbleHelp := app.getErrorString(CMUI_Enquire_On) &amp; theSBS.id;
			theCMObject := theSBS;
		elseif theLabRest &lt;&gt; null then
			thePIC.showEnquiryButton := true;
			self.frmPopupInfo.userObject := theLabRest;
			self.btnPopupEnq.bubbleHelp := app.getErrorString(CMUI_Enquire_On) &amp; theLabRest.id;
			theCMObject := theLabRest;
		endif;

		thePIC.setForCreate(theCMObject, self.myCurrentDrawingController.displayMode, self.frmPopupInfo,self.tblPopupInfo,self.frmToolBarPopup,
								self.frmPopupInfoPic1,self.picExtraInfoTI1,self.btnPopupEnq);
		self.showPopupInfoFrame(thePIC);
	elseif button &lt;&gt; Button.MouseButton_Right then	//do only for left btn - JC 26/01/04
		self.showExtraInfo(theObj);
		self.picCargo.picture := self.showCargoPicture(theTI);
	endif;

	frame.YRD_ContainerDrawingFrame.handleMouseUp(theObj,button,shift, x,y);
	self.saveX := x.Integer;
	self.saveY := y.Integer;

	self.frmStatusLine.myFrameCaption.caption := null;
	if theTI &lt;&gt; null then
		statMess := theTI.id;
	endif;
	
	statMess := statMess &amp; " Selected: " &amp; theDrawController.allSelectedObjects.size.String;
	self.frmStatusLine.myFrameCaption.caption := statMess;

epilog
	frame.enableEvent("mouseMove",false);
	app.isDragging := false;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDOLFDragOver" id="a57bbbb8-e26d-48d0-a97a-551b73fc9819">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDOLFDragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	maskTI 	 : CM_TrackedItem;
	targetTA : CM_TerminalArea;
	gridArea : YRD_GridArea;
	cdc : YRD_ContainerDrawingController;
begin

	// if entering the frame init the AM flag
	if state = Window.DragOver_Enter then
	endif;

	if frame = null then
		return;
	endif;
	
	self.setFocus();
	self.zOrder(1);
	self.windowState := WindowState_Normal;
	
	if frame &lt;&gt; null then
		cdc := frame.YRD_ContainerDrawingFrame.getDrawingController();
	endif;

	if self.myCurrentDrawingController &lt;&gt; cdc then
		self.setMyCurrentDrawingController(cdc, false);
	endif;


end;</source>
