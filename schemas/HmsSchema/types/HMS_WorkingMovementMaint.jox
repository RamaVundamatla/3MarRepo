    <JadeMethod name="displayCancelledMovement" id="78501429-abf4-4681-bb45-6440a130f00e">
        <source>displayCancelledMovement();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	cancelledMovement : CMIF_HMS_WorkingMovement;
	workingVoyage : CMIF_HMS_WorkingVoyage;

begin

	if self.aMySelectedMovement &lt;&gt; null then
		cancelledMovement := aMySelectedMovement.myCancelledMovement;
	endif;

	if cancelledMovement = null then
		return;
	endif;
	
	workingVoyage := cancelledMovement.getWorkingVoyageForCancelled();
	if workingVoyage = null then
		return;
	endif;

	self.myAssistant.HMS_Assistant.showWorkingMovementForm( cancelledMovement, workingVoyage, true, self.myMasterMenuAction, self.aMyViewController);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayMvmntPilotDetails" id="041b019d-f2d2-4d46-8a30-768bd25bf524">
        <updating/>
        <source>displayMvmntPilotDetails() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	movementPilotDetails : HMS_MovementPilotDetails;
begin
	self.tblPilotLaunch.rows := self.tblPilotLaunch.fixedRows;		
	if self.aMySelectedMovement = null then
		return;
	endif;
	foreach movementPilotDetails in self.aMySelectedMovement.allMovementPilotDetails do
		self.addMvmntPilotDetailsToTable(movementPilotDetails);		
	endforeach;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayResourceUsed" id="79d04131-d988-4503-92c0-cbeaa2530f05">
        <updating/>
        <source>displayResourceUsed()updating, protected;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
// 16 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	resourceUsed : CMIF_HMS_ResourceUsed;	
begin

	if (not self.shtResources.visible) then
		return;
	endif;	
	
	//purge all cloned control and reset control new index
	//self.aAllClonedControls.purge(); // TFS 44438 - now in calling methods
	//aNewIndex := 0; // TFS 44438
		
	if self.aMySelectedMovement = null then
		return;
	endif;
	
	self.tblResources.rows := self.tblResources.fixedRows;
	
	foreach resourceUsed in self.aMySelectedMovement.allWorkingResUsed do

		if resourceUsed.myResourceType &lt;&gt; null then
			if (not resourceUsed.myResourceType.isMarineService) then // CCMS 1350
				self.addResourceUsedToTable(resourceUsed);
			endif;
		endif;		
		
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doApply" id="e6131e1f-3d39-4186-a41a-9f5678aa3b17">
        <updating/>
        <source>doApply() updating, protected;
//--------------------------------------------------
// Created:	28 May 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
19 Mar 2008	cnwkpd1	PAR #16176 - Ensure dates validation is done regardless of which is the top sheet
16 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
28 Feb 2020	jlgdap1	TFS 48708 PNL Adding Movement Resource Error
*/

vars
  	validForDT: Boolean;
begin
	
	// 27/07/2010 cnwmh5 #23248 - Start
	// check to see that new date/time don't already occur
	if self.aMySelectedMovement.checkIfMovementAlreadyExists(self.aMyViewController, self.myTxtMoveOnDate.getDate(), 
			self.myTxtMoveOnTime.getTime(), self.aAddMode) then
		return;
	endif;
	// 27/07/2010 cnwmh5 #23248 - End
	
    // Check to see if user has changed meter marks and new posn is not OK  
    if self.aTxtBowMark_LostFocus_Not_OK = false then
   		// New marks OK - proceed with other updates
//    	if self.fldMovements.topSheet = self.shtGeneral then		// PAR #16176
    		self.checkAndUpdateMoveDT(validForDT,false,false);
    		if validForDT = false then
    			// New DT and clearances NOT OK
    			return;
    		endif;
//    	endif;

		if self.updateMovement() then
			self.loadEditMovement();
			self.aAllClonedControls.purge(); // TFS 44438
			aNewIndex := 0; // TFS 44438
			self.displayResourceUsed();
			//aNewIndex := 0; // TFS 44438						// TFS 48708
			aNewPilotIndex := 0; // TFS 44438					// TFS 48708
			self.displayMvmntPilotDetails(); // TFS 44438
		endif;
	else
		// New position not OK - let user enter new marks
		app.msgBox("Berth marks failed validation. Please select a new bow mark and try again.", self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);				
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="17ef6fb2-c346-41cc-8eb6-e31440e468d2">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if (not self.aHasSavedChanges) then
		self.doDeleteClones();
	endif;

	self.unloadForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="dd6b491d-d9bc-4547-ad21-c101a2905da8">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//--------------------------------------------------
// Created:	28 May 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
19 Mar 2008	cnwkpd1	PAR #16176 - Ensure dates validation is done regardless of which is the top sheet

*/

vars
  	validForDT : Boolean;
begin

	// 27/07/2010 cnwmh5 #23248 - Start
	// check to see that new date/time don't already occur
	if self.aMySelectedMovement.checkIfMovementAlreadyExists(self.aMyViewController, self.myTxtMoveOnDate.getDate(), 
			self.myTxtMoveOnTime.getTime(), self.aAddMode) then
		return;
	endif;
	// 27/07/2010 cnwmh5 #23248 - End
	
   // Check to see if user has changed meter marks and new posn is not OK  
    if self.aTxtBowMark_LostFocus_Not_OK = false then
   		// New marks OK - proceed with other updates
//    	if self.fldMovements.topSheet = self.shtGeneral then		// PAR #16176
    		self.checkAndUpdateMoveDT(validForDT, false, false);
    		if validForDT = false then
    			// New DT and clearances NOT OK
    			return;
    		endif;
 //   	endif;

		if self.updateMovement() then
			self.unloadForm;
		endif;
	else
		// New position not OK - let user enter new marks
		app.msgBox("Berth marks failed validation. Please select a new bow mark and try again.", self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);				
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCbxToBerthClick" id="dd6de407-b4d4-414f-9449-26dc5f9cdbcf">
        <updating/>
        <source>doCbxToBerthClick(_comboBox : ComboBox input) updating, protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 17 November 2004
//
//********************************************************************
// Changed On	By			Reason
// ----------	--------	------------------------------------------
// 05/02/2014	cnwdap1		PAR #33337 CCMS PTR 2214 Enable Marine Services sheet if seelcted berth has marine services
vars
	tmpBerth,
	defaultBth	: HMS_Berth;
begin
	if self.aMySelectedMovement = null then
		return;
	endif;
	
	defaultBth := aMySelectedMovement.myHarbour.defaultDepartBerth;
	tmpBerth := _comboBox.listObject.HMS_Berth;
  	// Check to see if the movement is a departure - if it is, the ship can only 
  	// depart to the default departure berth
  	if self.aMySelectedMovement.moveType = HMSMovementTypeDeparture
  	and defaultBth &lt;&gt; null
  	and tmpBerth &lt;&gt; defaultBth then
  		// Tell user that ship can only depart to the default departure berth
		app.msgBox(app.getErrorString(MSGBOX_DepartBerth) &amp; defaultBth.description, app.getErrorString(MSGBOX_DepartBerthTitle), MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon);
		// Set berth back to last valid berth
		_comboBox.listIndex := _comboBox.findObject(self.aMyLastValidBerth);
		return;
	endif;
	
	if tmpBerth = self.aMySelectedMovement.myBerth then
		return;
	endif;
	
 	self.setMeterMarksTo(null, true);
 	
 	// Recalc Tidal Window Details
	self.calcClosestTidalWindow();

	// Modified by Russell 07/04/99
	// -------------------------------------------------------------
	self.setPLaunchReqdStatus();
	// -------------------------------------------------------------
    self.reloadMarineServicesSheet();

	if not tmpBerth.noMarineServices then						// PAR #33337
		self.shtMarineService.enabled := true;					// PAR #33337
	else														// PAR #33337
		self.shtMarineService.enabled := false;					// PAR #33337
	endif;														// PAR #33337

end;</source>
        <access>protected</access>
        <Parameter name="_comboBox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteClones" id="1324f97e-3b23-4747-877e-a18aff76d861">
        <updating/>
        <source>doDeleteClones() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
// 17 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
 	clonedMovement : CMIF_HMS_WorkingMovement;
begin
	if (not global.isValidObject(self.aMySelectedVoyage)) then
		return;
	endif;
	if self.aMySelectedMovement.isCancelled then	//20 Nov 2018	NDL	TFS 42043
		// no extra clones created.
		return;
	endif;
	if self.aMode = self.Mode_Update then
		//Don't delete as updating clones
		return;
	endif;	
	if self.aMySelectedVoyage &lt;&gt; null then
		// Delete clonedVoyage, resources and movements
		foreach clonedMovement in self.aMySelectedVoyage.allClonedMovements do
			clonedMovement.allWorkingResUsed.purge;
			clonedMovement.allMovementPilotDetails.purge; // TFS 44438
		endforeach;
		self.aMySelectedVoyage.allClonedMovements.purge;
		delete self.aMySelectedVoyage;
 	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMvmntPilotDetailsDelete" id="a5057459-a2a5-4b28-a697-c055038b41fc">
        <source>doMvmntPilotDetailsDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	theRow : Integer;
begin
	self.tblPilotLaunch.findObjectInRow(self.mnuPilotLaunchDelete.userObject, theRow);
	if theRow &gt; self.tblPilotLaunch.fixedRows then
		if self.tblPilotLaunch.accessRow(theRow).enabled then
			//OK to delete row
			self.tblPilotLaunch.removeItemObject(self.mnuPilotLaunchDelete.userObject);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPilotAdd" id="62939d1a-f667-475c-aceb-357c36bce5e4">
        <updating/>
        <source>doPilotAdd() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	tmpPilot : HMS_Pilot;
	proxy : HMS_MovementPilotDetails;
begin
	if self.tblPilotLaunch.row &gt; self.tblPilotLaunch.fixedRows then
		if self.tblPilotLaunch.accessRow(self.tblPilotLaunch.row).enabled then
			tmpPilot := self.tblPilotLaunch.accessCell(self.tblPilotLaunch.row, self.tblPilotLaunch.getColumnByRowName(ETRow_MyPilot)).cellControl.CMUI_ComboBox.listObject.HMS_Pilot;
		endif;
	endif;
	
	if tmpPilot = null then // get first valid pilot for this terminal &amp; harbour
		foreach tmpPilot in app.myRoot.allPilots discreteLock where not tmpPilot.isNotAvailableForEntry
			and tmpPilot.myCurrentHarbour = self.myTerminal.myHarbour do
			break;
		endforeach;	
	endif;
	if tmpPilot = null then
		app.raiseCMException(Input_require_pilot_field, null, null);
		return;
	endif;
	create proxy transient;
	proxy.setProxy(tmpPilot, null, null, self.aMySelectedMovement);
	self.addMvmntPilotDetailsToTable(proxy);
	self.tblPilotLaunch.selected := false;
	self.tblPilotLaunch.row := self.tblPilotLaunch.rows;
	self.tblPilotLaunch.column := 1;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryRowColumnChange" id="a33bb343-db88-4338-bc81-e62d41a40657">
        <updating/>
        <source>doQueryRowColumnChange(table: Table input; newRow: Integer) updating, protected;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
// 16 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	theRow,
	cols,
	idx,
	col : Integer;
begin

	theRow := table.row;

	cols := table.columns;
	col := table.column+1;
	
	if col &gt; cols then
		//end of row
		foreach idx in theRow+1 to table.rows do
			if table.accessRow(idx).enabled then
				return;
			endif;
		endforeach;				
		if table.name = "tblPilotLaunch" then // TFS 44438
			self.doPilotAdd(); // TFS 44438
		else // TFS 44438
			self.doResourceAdd();
		endif; // TFS 44438
		return;
	endif;		
	
	while col &lt;= cols do
		if table.accessCell(theRow, col).enabled then
			break;
		endif;
		if col+1 &gt; cols then
			foreach idx in theRow+1 to table.rows do
				if table.accessRow(idx).enabled then
					return;
				endif;
			endforeach;		
			//end of row
			if table.name = "tblPilotLaunch" then // TFS 44438
				self.doPilotAdd(); // TFS 44438
			else // TFS 44438
				self.doResourceAdd();
			endif; // TFS 44438
			return;
		endif;
		col := col+1;			
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newRow" type="Integer"/>
    </JadeMethod>
