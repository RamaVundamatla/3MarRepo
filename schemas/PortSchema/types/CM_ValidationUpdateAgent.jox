    <JadeMethod name="valBookingRef" id="f8d7b2d1-d53b-4c5d-addf-0be5d296ea6c">
        <updating/>
        <source>valBookingRef(pProxyBookingRef : CM_BookingRef input; _passport : CM_Passport input; pUserObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	pProxyBookingRef.raiseExceptionIfNotProxy(method);
	pProxyBookingRef.validateForUpdate(_passport, pUserObject, null);	
	
	if pProxyBookingRef.allBookingRefItems.size = 0 then
		app.raiseCMException(Must_Add_Equipment,app.getErrorString(BookingRef),null);
	endif;
epilog
	
	
end;</source>
