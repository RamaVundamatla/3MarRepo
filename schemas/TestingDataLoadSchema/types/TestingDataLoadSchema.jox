		app.writeLog("Unable to find UM_Root instance.  Exiting...", LogINFO);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="extractJRWArchive" id="796b5408-7d7a-44fc-b082-c2f04939d5b3">
        <source>extractJRWArchive();
/*

Purpose:			Extract/Load the JWA file from Xmast prior to the current cut being loaded

Parameters:			

Return Value:		

Date				Who		Reason
02 December 2020	jlgmd1	Initial creation TFS 50459
25 January 2024		navmd1	TFS 62200 Remove 156 from infront of UNLExtractName as rwa is currently 152 after removing some old schemas

*/
constants
	JadeMasterPathArg		: String = "jademasterpath=";
	ExtractArg				: String = "extract=";
	LoadArg					: String = "load=";
	
	UNLExtractName			: String = "allJRW";
vars
	cmdArgs,
	jadeMasterPath			: String;
	extract,
	load					: Boolean;
	pos						: Integer;
	
	filePath,
	rwaName,
	rwaPrefix				: String;
	now						: TimeStamp;
	
	files					: FileFolder;
	file,
	rwaFile,
	unlFile					: FileNode;
	dest					: String;
	
	docSchema				: Schema;
	klass					: Class;
	hsa						: HugeStringArray;
	jrwDocObj				: Object;
	
	unlLine					: String;
	xUNLFile				: File;
	
	userExitCode			: Integer;
begin
	userExitCode := 63;		// In case something goes wrong, exit with a non-zero exit code, so TFS knows something went wrong
	
	app.initialize();
	app.changeLogLevel(LogTRACE);
	
	// Initialise JMT and CardSchema exception handling - do not pass anything back, because
	// we are a background application
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);
	
	// vvvvv Parse any arguments vvvvv
	if true then	// For code folding only ;)
		cmdArgs					:= process.getCommandLine();
		if process.sendMsg("_isBeingDebugged").Boolean then
			cmdArgs := 'JadeMasterPath="F:\Releases\862\Monthly\862090\JadeMaster\schemas" extract=true';
		endif;
		app.writeLog("Arguments: " &amp; cmdArgs, LogINFO);
		
		// ARG: JadeMasterPath
		pos						:= cmdArgs.toLower.pos(JadeMasterPathArg, 1);
		if pos &gt; 0 then
			pos := pos + JadeMasterPathArg.length;
			app.writeLog("Found '" &amp; JadeMasterPathArg &amp; "' at " &amp; pos.String, LogTRACE);
			if cmdArgs[pos:1] = '"' then
				pos := pos+1;
				jadeMasterPath	:= cmdArgs.scanUntil('"', pos);
			else
				jadeMasterPath	:= cmdArgs.scanUntil(' ', pos);
			endif;
		endif;
		
		// ARG: extract
		pos					:= cmdArgs.toLower.pos(ExtractArg, 1);
		if pos &gt; 0 then
			pos := pos + ExtractArg.length;
			app.writeLog("Found '" &amp; ExtractArg &amp; "' at " &amp; pos.String, LogTRACE);
			if cmdArgs[pos:1] = '"' then
				pos := pos+1;
				extract			:= cmdArgs.scanUntil('"', pos).asBooleanJMT();
			else
				extract			:= cmdArgs.scanUntil(' ', pos).asBooleanJMT();
			endif;
		endif;
		
		// ARG: load
		pos						:= cmdArgs.toLower.pos(LoadArg, 1);
		if pos &gt; 0 then
			pos := pos + LoadArg.length;
			app.writeLog("Found '" &amp; LoadArg &amp; "' at " &amp; pos.String, LogTRACE);
			if cmdArgs[pos:1] = '"' then
				pos := pos+1;
				load			:= cmdArgs.scanUntil('"', pos).asBooleanJMT();
			else
				load			:= cmdArgs.scanUntil(' ', pos).asBooleanJMT();
			endif;
		endif;
		
		if jadeMasterPath = null and not load then
			app.writeLog("'" &amp; JadeMasterPathArg &amp; "&lt;path&gt;' not specified. Nothing to do.", LogFATAL);
			return;
		endif;
		
		if not extract and not load then
			app.writeLog("Neither '" &amp; ExtractArg &amp; "true' or '" &amp; LoadArg &amp; "true'. Don't know what to do.", LogFATAL);
			return;
		endif;
	endif;
	// ^^^^^ Parse any arguments ^^^^^
	
	// ################ VARIABLES #######################
	
	filePath := app.getJadeInstallDir() &amp; "\";					//LOCAL directory - should already exist (include the trailing slash)
	rwaPrefix := "PreCutArchive_";
	rwaName := rwaPrefix &amp; now.fileNameFormat() &amp; ".rwa";
	app.writeLog("Auto-Generated RWA name: " &amp; rwaName, LogTRACE);
	
	// ################ VARIABLES #######################
	
	if extract then
		app.writeLog("Starting Extract...", LogINFO);
	
		docSchema := rootSchema.getSchema("JRWDocSchema");
		if docSchema = null then
			app.writeLog("JRWDocSchema doesn't exist, unable to extract RWA", LogFATAL);
			return;
		endif;
	
		klass := docSchema.getClass("JRWDocSchema");
		if klass = null then
			app.writeLog("Can't find JRWDocSchema - are we sure JRWDocSchema was loaded ?", LogFATAL);
			return;
		endif;
		create jrwDocObj as klass transient;
			
			
		// Find the RWA UNL file
		delete files;
		create files transient;
		files.usePresentationFileSystem := true;
		files.fileName := jadeMasterPath;
		files.mask := "*.unl";
		
		foreach file in files.files do
			app.writeLog("Comparing [" &amp; file.name &amp; "] against [" &amp; UNLExtractName &amp; "_*]", LogTRACE);
			if file.name.pos(UNLExtractName, 1) &gt; 0 then
				app.writeLog("Found! [" &amp; file.fileName &amp; "]", LogTRACE);
				unlFile := file;
				break;
			endif;
		endforeach;
		
		if unlFile = null then
			app.writeLog("Unable to locate " &amp; jadeMasterPath &amp; "\" &amp; UNLExtractName &amp; "_*", LogFATAL);
			return;
		endif;
		
		// We have to do a bit of a fudge here, and remove any Views from the list, as we only want to extract Reports!
		create xUNLFile transient;
		xUNLFile.usePresentationFileSystem := true;
		xUNLFile.fileName := unlFile.fileName[1:unlFile.fileName.length-4] &amp; "_Xmast.unl";
		xUNLFile.mode := File.Mode_Output;
		xUNLFile.kind := File.Kind_ANSI;
		
		while not unlFile.File.endOfFile do
			unlLine := unlFile.File.readLine();
			if unlLine[1:4].toLower = "view" then
				continue;
			endif;
			xUNLFile.writeLine(unlLine);
		endwhile;
		// Close the open files
		xUNLFile.close();
		unlFile.File.close();
		// And use the new one instead
		unlFile := xUNLFile;
		
		app.writeLog("Extracting Reports...", LogINFO);
		create hsa transient;
		hsa.add(unlFile.fileName);		// (In) UNL File Path
		hsa.add(filePath &amp; rwaName);	// (Out) RWA File Path
		hsa.add(true.String);			// Do Not Terminate App
		jrwDocObj.sendMsgWithParams("unloadAll", hsa );
		app.writeLog("Done. [" &amp; filePath &amp; rwaName &amp; " created]", LogINFO);
	
	endif;	// extract = true
	
	if load then
		app.writeLog("Starting RWA Load...", LogINFO);
		
		delete files;
		create files transient;
		files.fileName := filePath;
		files.usePresentationFileSystem := true;
		files.mask := "*.rwa";
		
		// Grab the first (latest) .rwa that matches in the c_bin
		rwaFile := null;
		foreach file in files.files reversed do
			app.writeLog("Comparing [" &amp; file.name &amp; "] against [" &amp; rwaPrefix &amp; "*]", LogTRACE);
			if file.name.pos(rwaPrefix, 1) &gt; 0 then
				app.writeLog("Found! [" &amp; file.fileName &amp; "]", LogTRACE);
				rwaFile := file;
				rwaName := file.name;	// Overwrite the 'new' name with the latest one on the client
				break;
			endif;
		endforeach;
		
		if rwaFile = null then
			app.writeLog("Unable to locate " &amp; filePath &amp; "\" &amp; rwaPrefix &amp; "*", LogFATAL);
			return;
		endif;
		
		app.writeLog("Copying " &amp; rwaFile.fileName &amp; " to server...", LogDEBUG);
		dest := app.cnGetServerMiscPath() &amp; "\" &amp; rwaName;
		app.copyFileEx(rwaFile.fileName, true, dest, false);
		app.writeLog("Successfully coppied file to " &amp; dest, LogDEBUG);
		
		app.writeLog("Loading " &amp; rwaName &amp; "...", LogINFO);
		if not app.runJadloadB(null, null, dest, null) then
			app.writeLog("Failed loading RWA file, check logs", LogFATAL);
			return;
		endif;
		
		app.writeLog("Deleting " &amp; rwaName &amp; " file from server", LogDEBUG);
		app.removeFile(dest, true);
		
		app.writeLog("Deleting " &amp; rwaName &amp; " from client", LogDEBUG);
		app.removeFile(rwaFile.fileName, false);
		
	endif;	// load = true

	userExitCode := 0;
	app.writeLog("Done", LogINFO);
epilog
	delete files;
	delete hsa;
	delete jrwDocObj;
	delete xUNLFile;
	
	app.finalize();
	
	beginTransaction;
	process.userExitCode := userExitCode;
	commitTransaction;
	
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractUpgradeScriptFromPortSchema" id="7a80d3d2-1c09-43a9-8e9c-c02da5e11a4f">
        <source>extractUpgradeScriptFromPortSchema();
/*

Purpose:		This will extract out specificPostStandard from the relevant PortSchema Class

Parameters:			

Return Value:		

Date		Who		Reason
19/04/2024	navmh5	Initial creation

*/

vars
	
	schema							: Schema;
	class							: Class;
	actualMethod					: Method;
	file							: File;	
	
	paramNames						: StringArray512;
	paramValues						: StringArray512;
	paramArray						: StringArray512;

	pos								: Integer;
	commandLineStr					: String;
	posEqual						: Integer;
	posEqual2						: Integer;
	tempStr							: String;
	posSpace						: Integer;
	timeToLeave						: Boolean;
	
	version							: String;
	versionRelease					: String;
	className						: String;
	fileName						: String;
	
begin

	app.initialize();
	
	commandLineStr := self.getThinClientCommandLine();
	write "commandLineStr: " &amp; commandLineStr;
	create paramArray transient;
	pos := commandLineStr.toLower().pos("endjade", 1);
	if pos &lt;&gt; 0 then
		commandLineStr := commandLineStr[pos + 7:end];
	endif;

	while (true) do
	
		// Get the 1st =
		posEqual := commandLineStr.pos("=", 1);
		if posEqual = 0 then
			break;
		endif;
		write commandLineStr &amp; Tab &amp; posEqual.String;
		
		// get the next =
		posEqual2 := commandLineStr.pos("=", posEqual + 1);
		write "posEqual2: " &amp; posEqual2.String;
		
		// work out what the string is
		if posEqual2 &gt; 0 then
			posSpace := commandLineStr.reversePosIndex(" ", posEqual2);
			tempStr := commandLineStr[1:posSpace].trimBlanks();
			commandLineStr := commandLineStr[posSpace:end].trimBlanks();
		else
			tempStr := commandLineStr;
			timeToLeave := true;
		endif;
						
		// get the parameters
		paramArray.clear();
		tempStr.getTokensForDelimiter("=", paramArray);
		write "paramArray: " &amp; paramArray[1] &amp; Tab &amp; paramArray[2];
		if paramArray[1] = "VersionRelease" then
			versionRelease := paramArray[2];
		elseif paramArray[1] = "Version" then
			version := paramArray[2];
		endif;	
		
		// break out as no more items on the line
		if timeToLeave then
			break;
		endif;
	
	endwhile;
	
	className := "PortSchema_" &amp; version;
	fileName := versionRelease &amp; "UpgradeScriptSource.txt";
	
	write "className: " &amp; className;
	write "fileName: " &amp; fileName;
	
	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		app.writeLog("Unable to find schema (PortSchema).  Exiting...", LogINFO);
		return;
	endif;
	
	class := schema.getClass(className);
	if class = null then
		app.writeLog("Unable to find class (" &amp; className &amp; ") in PortSchema.  Exiting...", LogINFO);
		return;
	endif;
	
	actualMethod := class.getMethod("specificPostStandard");
	if actualMethod = null then
		app.writeLog("Unable to find method (specificPostStandard) in class (" &amp; className &amp; ") in PortSchema&gt;  Exiting...", LogINFO);
		return;
	endif;
	
	create file transient;
	file.fileName := "c:\temp\" &amp; fileName;
	file.usePresentationFileSystem := true;
	file.mode := File.Mode_Output;
	
	write "file.fileName: " &amp; file.fileName;
	
	file.writeString(method.getSource());
	file.close();
	

epilog

	delete file;
	
	app.finalize();
	terminate;
	
end;</source>
    </JadeMethod>
