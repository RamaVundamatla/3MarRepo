    <JadeMethod name="autocollCancellationRequest_SI" id="41bd93b3-f638-4be7-b58d-992a43386784">
        <updating/>
        <source>autocollCancellationRequest_SI(_request : CMIF_SAPAutoCancelReq) : CMIF_SAPWSResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	realRequest		: SAP110_AutocollCancellationReq_DT;
	realResponse	: SAP110_AutocollCancellationRet_DT;
	response		: CMIF_SAPWSResponse;
	createdObjects	: ObjectSet;
	soapFault		: Boolean;
	
begin
	self.doSetupConsumerInstance(SAP110_HTTP_Port);
	
	create createdObjects transient;
	create realRequest transient;
	createdObjects.add(realRequest);
	
	_request.copyToRealWSObject(realRequest, createdObjects);
	
	realResponse := self.doSendWebServiceRequest(self.myWebServiceConsumer,
												 method.name,
												 realRequest,
												 soapFault).SAP110_AutocollCancellationRet_DT;
												 
	if realResponse &lt;&gt; null then
		create response transient;
		response.setFromRealWSObject(realResponse);
	elseif soapFault then
		create response transient;
		response.setValuesForSOAPFault();
	endif;
	
	return response;
	
epilog
	if createdObjects &lt;&gt; null then
		createdObjects.purge();
		delete createdObjects;
	endif;
	
end;</source>
        <Parameter name="_request" type="CMIF_SAPAutoCancelReq"/>
        <ReturnType type="CMIF_SAPWSResponse"/>
    </JadeMethod>
