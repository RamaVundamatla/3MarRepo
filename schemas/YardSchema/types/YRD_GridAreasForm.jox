    <JadeMethod name="setDisplayMode" id="0de07cc2-8cef-4533-becf-e52ab14ab45c">
        <updating/>
        <source>setDisplayMode(_mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
//	newMode,
//	theIndex : Integer;
	cdc			: YRD_ContainerDrawingController;
	anObj		: Object;
	
begin
	/* replace with code below
	if _mode = DISPLAY_MODE_ACTUAL then
	elseif _mode = DISPLAY_MODE_PLAN then
	elseif _mode = DISPLAY_MODE_QUEUE then
	else
		return;
	endif;
	*/
	if _mode &lt;&gt; DISPLAY_MODE_ACTUAL and _mode &lt;&gt; DISPLAY_MODE_PLAN and _mode &lt;&gt; DISPLAY_MODE_QUEUE then
		return;
	endif;
	
	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_ContainerDrawingController;
		cdc.setDisplayMode(_mode);
		cdc.drawSelf(true);
	endforeach;
	
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// summarise will only be enabled for display mode of actual or queued.
	self.btnSummariseAll.enabled	:= _mode = DISPLAY_MODE_ACTUAL or _mode = DISPLAY_MODE_QUEUE;
	self.frmStatusLine.displayMode	:= _mode;
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromSelectorPanel" id="c045cf72-f8d1-438a-9ca0-6b2957d5a295">
        <updating/>
        <source>setFromSelectorPanel( 	_enqController : CM_EnquiryController;
						_viewMode : Integer;
						_clearSelection : Boolean;
						_didCreateEnq : Boolean
						) updating;

/*

Purpose:			
		called by frmSelectorPane::clickBtnRun
Parameters:			

Return Value:		


Date		Who		Reason
28 July 2011	cnwndl1	Initial creation	Par 27890
12 Oct 2012		cnwer1 par 30571
*/

vars

	obj,enqObj : Object;
	ydc : YRD_ContainerDrawingController;

begin

	if _clearSelection then
	
		//colour up everything again.
		self.useSelector := false;
		foreach obj in self.allDrawingControllers do
			ydc := obj.YRD_ContainerDrawingController;
			ydc.allSelectorTIs.clear;
			ydc.drawSelf(true);	
		endforeach;
		
	else
	
		// colour up the selection from the selector panel enquiry
		self.useSelector := true;
		if _didCreateEnq then
			self.mySelectorEnquiryController := _enqController;
			self.deleteEnqSelector := true;
		endif;
		foreach obj in self.allDrawingControllers do
			ydc := obj.YRD_ContainerDrawingController;
			ydc.allSelectorTIs.clear;
			foreach enqObj in  _enqController.allObjects.CM_ObjectSet do
				if enqObj.isKindOf(CM_TrackedItem) then
					ydc.allSelectorTIs.add(enqObj.CM_TrackedItem);
				elseif enqObj.isKindOf(CM_TITransaction) then
					if enqObj.CM_TITransaction.myTrackedItem &lt;&gt; null then
						ydc.allSelectorTIs.add(enqObj.CM_TITransaction.myTrackedItem);
					endif;
				endif;
			endforeach;
			
			ydc.drawSelf(true);	
		endforeach;
		
		self.mnuGridSelectorClear.visible := true;
		
	endif;
	
	return;
	
	// not called because of the return above, just here to give a reference
	// so some clown doesn't delete the high level one.
	inheritMethod( _enqController, _viewMode, _clearSelection, _didCreateEnq );

epilog

end;</source>
        <Parameter name="_enqController" type="CM_EnquiryController"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_clearSelection" type="Boolean"/>
        <Parameter name="_didCreateEnq" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setInitialiseWithObject" id="a602cba8-3626-4305-887e-82ce0399a8c4">
        <updating/>
        <source>setInitialiseWithObject(anObject : CM_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
