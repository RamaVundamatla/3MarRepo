    <JadeMethod name="getDisplayStringForAttribute" id="afb6b957-e656-48f2-a330-4e7eb2b9247c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rowString : String;
begin
	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
			if self.custDocType &lt;&gt; null then
				rowString := " (" &amp; self.custDocType &amp; ") ";
			endif;
			return app.getErrorString(TransType_159) &amp; ": " &amp; self.stopDescription &amp; rowString &amp;  '. ' &amp; self.remarks;
		endif;
		
	elseif _attrName = ETRow_StopCancelled then
		return self.stopDescription &amp; '. ' &amp; self.remarks;
	
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="f4564368-9ff7-4e9b-a37c-8122dc730ef8">
        <source>getEnquiryRow(): String;
// --------------------------------------------------------------------------------
// Created:		04 June 2010 by cnwdad1
//
// Purpose:		Returns a display string of the receiver's detaikls.
//
// Parameters:	None
//
// Returns:		A display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowString: String;
begin
	// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
	if self.custDocType &lt;&gt; null then
		rowString := "(" &amp; self.custDocType &amp; ") ";
	endif;
	return inheritMethod() &amp; app.getErrorString(TransType_159) &amp; ": " &amp; self.stopDescription &amp; 
				rowString &amp; '. ' &amp; self.remarks;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="549ef317-512e-4b5a-a379-9cb610760ee1">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:= 	inheritMethod() &amp; Tab &amp;
					self.stopID.display &amp; Tab &amp;
					self.stopDescription;
	
	if self.myTrackedItem &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myTrackedItem.id;
	endif;
	
	if self.myStop = null then
		returnStr	:= returnStr &amp; Tab &amp; '************';
	else
		returnStr	:= returnStr &amp; Tab &amp; self.myStop.id.display;
	endif;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
