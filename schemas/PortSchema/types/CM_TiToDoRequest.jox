    <JadeMethod name="createWLE" id="f54254e7-4eb3-47d3-8182-b3923c46c60d">
        <source>createWLE();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
17 July 2009	cnwrd1	Initial creation
14/06/2022 		navcs2 	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
*/

vars

	wle	: CM_ToDoWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);				  	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="db314e56-30ff-4181-9a2f-5271ced1b581">
        <source>createWLEs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwrd1	Initial creation

*/

vars
	i,
	numReq,
	numTIs		:	Integer;
	aWLE		:	CM_ToDoWLE;
	theTI		: 	CM_TrackedItem;
	iter		: 	Iterator;
begin
	//------------
	//Create the appropriate WLEs
	// 1 for each ti on the job and extra up to totalRequested
	//------------
	
	numTIs := self.myJob.CM_ToDoJob.allTrackedItems.size;
	
	numReq := self.totalRequested;
	i := 1;		
	
	if numReq &lt; numTIs then
		numReq := numTIs;
	endif;
	
	iter := self.myJob.CM_ToDoJob.allTrackedItems.createIterator;

	// step through all real ti's on the job 
	//then continue untill we have all we need
	
	while iter.next(theTI) do
	// create WLE , create todotask on ti link that to the wle			
		create aWLE;
		aWLE.setForCreate(self.myJob, self);  //set the wle job and request
		aWLE.setMyTrackedItem( theTI); // set the tracked item
		aWLE.causeEvent(aWLE.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, aWLE);				  	
//		aWLE.createTiToDoTask(); // doing this in setMyTrackedItem now.
		i := i+1;	
	endwhile;
		
	while true do
		if i &gt; numReq then
			//If total requested = 0 then we always create 1
			break;
		endif;

		//create 'empty' WLE's will fill them later
		create aWLE;
		aWLE.setForCreate(self.myJob, self);
		aWLE.causeEvent(aWLE.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, aWLE);				  	
		i := i+1;		
	endwhile;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="80660a27-20a8-4b9d-9208-17881629afb9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwrd1	Initial creation

*/

vars

begin
	if _attrName = ETRow_IsoType then
		return null;
	elseif _attrName = ETRow_Id then	
		return null;		
	elseif _attrName = ETRow_CargoDetails then
		return null;		
	elseif _attrName = ETRow_Commodity then
		return null;	
	elseif _attrName = ETRow_IsoGroup then
		return null;			
	elseif _attrName = ETRow_DischargePort then //cnwrd1par 27017
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);				
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
