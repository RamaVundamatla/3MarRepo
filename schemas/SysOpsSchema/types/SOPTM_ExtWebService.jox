    <JadeMethod name="loadCmbEventType" id="bca468dc-2eb5-472e-8309-05a5eff118c2">
        <source>loadCmbEventType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Feb 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
*/

vars
	form : SOP_TableMaintForm;
	combo : CMUI_ComboBox;
	index : Integer;
	eventType : CM_EventType;
begin
	form := self.myForm;
	combo := form.cmbEventType;
	
	combo.clear();
	combo.sorted := true;
	
	index := combo.addItem(" ");	
	foreach eventType in app.myRoot.allEventTypesByCategory where eventType.category = CM_EventType.TRAIN_EVENT do
			index := combo.addItem(eventType.name);
			combo.itemObject[index] := eventType;
	endforeach;
epilog

end;</source>
        <text>TFS 40360</text>
    </JadeMethod>
    <JadeMethod name="loadCmbTerminal" id="89567a4b-2791-45ab-a256-23a548a18b11">
        <source>loadCmbTerminal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2021	navpw1	Initial creation TFS: 52268

*/

vars
	form 			: SOP_TableMaintForm;
	combo 			: CMUI_ComboBox;
	index 			: Integer;
	userTerminal 	: CM_UserTerminal;
begin
	form := self.myForm;
	combo := form.cmbTerminal;
	
	combo.clear();
	combo.sorted := true;
	
	foreach userTerminal in app.myPassport.myUser.allUserTerminals do
		index := combo.addItem(userTerminal.myTerminal.name);
		combo.itemObject[index] := userTerminal.myTerminal;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbVesselType" id="d360f417-7cf2-4bc1-9953-8f14489b8689">
        <source>loadCmbVesselType();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 05 Oct 2023
TFS#		: 60754
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	form 			: SOP_TableMaintForm;
	combo 			: CMUI_ComboBox;
	index 			: Integer;	
	vesselType		: HMS_VesselType;
begin
	form := self.myForm;
	combo := form.cmbVesselType;
	
	combo.clear();
	combo.sorted := true;
		
	foreach vesselType in app.myRoot.allVesselTypes do
		index := combo.addItem(vesselType.displayEntryListbox);
		combo.itemObject[index] := vesselType;
	endforeach; 
	combo.lostFocus(combo);
end;</source>
    </JadeMethod>
    <JadeMethod name="loadGrantTypeCombo" id="e0bed755-e94a-4bc6-87b7-c169f1eed636">
        <updating/>
        <source>loadGrantTypeCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2024	navsp1	Initial creation

*/

vars
	combo	: CMUI_ComboBox;
begin
	combo	:= self.myForm.cmbGrantType;
	combo.clear();
	combo.addItem( " " );
	combo.addItem(SOP_TableMaintForm.GT_ClientSecret);
	combo.addItem(SOP_TableMaintForm.GT_UserCode_Password);	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="464b9492-490a-4c07-8b4f-75ca1769410f">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// 13 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
// 17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
// 05/10/2023	jlika1	TFS 60754	POB | QShip 55715.070 - Default Vessel Type 
// 06 Aug 2024  navsp1  TFS ChangeRequest 63842: NSW | OnePort Integration Dev
vars
	theForm     : SOP_TableMaintForm;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;
	idx			: Integer;
	ewsType : CM_ExternalWebServiceType;
	ewsDef : CM_ExternalWebServiceDef;
begin
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	entTableDef := app.myController.getEntTableDef(ETDef_ExtWebService);
	theForm.btnAdvanced.visible := true;		// 4/12/18 MAP TFS42015
	theForm.btnAdvancedOnToolbar.visible := true;		 // ### TFS 51853 17NOV2021 NAVAB1
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
		if entTableRow.name = ETRow_Endpoints then					// TFS 57207
			theForm.tblInput1.disableRowByName(entTableRow.name);	// TFS 57207
		endif;														// TFS 57207
	endforeach;
	
	self.loadCmbEventType(); 		// TFS 40360
	self.loadCmbTerminal();			// ### TFS 52268 16Dec2021 NAVPW1
	self.loadCmbVesselType();
	self.loadGrantTypeCombo();											//TFS 63842
	
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		//epr TFS 45207 18/6/19
		CM_ExternalWebServiceDef@comboWebServiceType(theForm.cmbWebServiceType, self.myEWSAgent); // ### JIRA 33544 17DEC2024 NAVAB1
		self.changeViews(null);
	else
		// ### JIRA 33959 14FEB2025 NAVAB1
		ewsDef:= theForm.myCurrentObject.CM_ExternalWebServiceDef;
		ewsType := ewsDef.getWebServiceType();
		self.showThumbnail(theForm.myCurrentObject.CM_ExternalWebServiceDef);
		if ewsType &lt;&gt; null and not ewsType.canDo() then		//null check added - navsp1 11.Mar.25
			app.msgBox("This system is not licensed for external web service type '" &amp; ewsType.name &amp; "'.", "Please Note", MsgBox_OK_Only);
			
		endif;
		
		theForm.tblInput1.enableRowByName(ETRow_EventType); // TFS 40360
		
	endif;
	theForm.tblInput1.moveFirst();
    theForm.tblInput1.cnEcResizeContents;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="66311ae7-c5f5-4c69-a3a4-fef2d048d96c">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2018	jlgmp6	Initial creation	TFS42015
13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
05 Oct 2023	jlika1	TFS 60754	POB | QShip 55715.070 - Default Vessel Type 
*/

vars

begin
	self.loadCmbEventType(); // TFS 40360
	self.loadCmbTerminal();	// ### TFS 52268 16Dec2021 NAVPW1
	self.loadCmbVesselType();
	inheritMethod();
	
	self.myForm.btnAdvanced.visible := true;
	self.myForm.btnAdvancedOnToolbar.visible := true; // ### TFS 51853 17NOV2021 NAVAB1
	self.myForm.btnSubTerms.visible	:=	false;	 // ### TFS 51853 17NOV2021 NAVAB1
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setGrantTypeData" id="f23928b1-7ea4-4e33-849f-9af9ede7ff43">
        <source>setGrantTypeData(_type : String; _def : CM_APIEndpointServiceDef);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2024	navsp1	Initial creation

*/

vars

begin
	
	
	if self.myForm.mode = self.myForm.Mode_Add then 
		if _type = ExternalWebServiceAPIEndpoint then
			self.myForm.cmbGrantType.text	:= SOP_TableMaintForm.GT_ClientSecret;
		else
			self.myForm.cmbGrantType.text	:= " ";		
		endif;
		self.myForm.cmbGrantType.click(self.myForm.cmbGrantType);
		self.myForm.cmbGrantType.lostFocus(self.myForm.cmbGrantType);
	else
		if _def &lt;&gt; null and _def.isKindOf(CM_APIEndpointServiceDef) then
			if _def	&lt;&gt; null and _type = ExternalWebServiceAPIEndpoint then
				if _def.password &lt;&gt; null and _def.userCode &lt;&gt; null and _def.CM_APIEndpointServiceDef.clientSecret = null then
					self.myForm.cmbGrantType.text	:= SOP_TableMaintForm.GT_UserCode_Password;
				elseif _def.CM_APIEndpointServiceDef.clientSecret &lt;&gt; null and _def.password = null and _def.userCode = null then
					self.myForm.cmbGrantType.text	:= SOP_TableMaintForm.GT_ClientSecret;
				else
					self.myForm.cmbGrantType.text	:= " ";
				endif;
			else
				self.myForm.cmbGrantType.text	:= " ";
			endif;
			self.myForm.cmbGrantType.click(self.myForm.cmbGrantType);
			self.myForm.cmbGrantType.lostFocus(self.myForm.cmbGrantType);
		endif;
	endif;	

epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_def" type="CM_APIEndpointServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setMACS3Defaults" id="80951849-337f-42cc-900d-31e98fb1789f">
        <source>setMACS3Defaults() protected;
/*

Purpose:			Defaults new setups to some sensible values

Parameters:			

Return Value:		

Date			Who		Reason
15 March 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	entryTable	: CM_EntryTable;
	rowIdx		: Integer;
begin

	entryTable := self.myForm.tblInput1;

	// Defaults
	entryTable.setValueByName(ETRow_BaseEndpoint, CM_MACS3ConsumerAgent.DefEndpoint.String);
	entryTable.setValueByName(ETRow_TimeoutSeconds, 5.Integer);
	entryTable.setValueByName(ETRow_CreditWarning, 20.Integer);		// ??? How much is a credit worth ?

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="3c160516-610e-4b0b-9bbd-71946c6cba75">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	theForm		: SOP_TableMaintForm;
	tmpMenu		: MenuItem;
	def			: CM_ExternalWebServiceDef;
begin
	inheritMethod(conwin);
	theForm := self.myForm;
	
	theForm.mnuContext1.enabled := false;
	theForm.mnuContext1.visible := true;
	theForm.mnuContext1.caption := "Test Connection";

	if theForm.mode &lt;&gt; theForm.Mode_Add then
		def := theForm.myProxyObject.CM_ExternalWebServiceDef;
		if def = null then
			def := theForm.myCurrentObject.CM_ExternalWebServiceDef;
		endif;
		if def &lt;&gt; null then
			theForm.mnuContext1.enabled := true;
		endif;
	endif;
		
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false ); 	
	
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		tmpMenu.enabled:= false;
	endif;
	
epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="c16c96a3-b1d7-4021-badb-7b0753f8c743">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 04 Feb 2025 naviv1  JIRA-12173 : MTN - JSON CAM Protocol and APIConsumerAgent hard codes EUP as the customer
//
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ExtWebServiceTbl);
	theForm.txtBox01.passwordField := true;
	if app.isSpecial then	//04-Feb-2025 naviv1 #12173 - start
		theForm.tblData.showColumnByColName(ETRow_Customer);
	else
		theForm.tblData.hideColumnByColName(ETRow_Customer);
	endif;	//04-Feb-2025 naviv1 #12173 - end

	theForm.shtTblInput1.caption := 'External Web Service Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ExtWebService);
	theForm.shtTblInput1.visible := true;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="f8d0539c-feff-4562-901a-d2ef7e2c518f">
        <updating/>
        <source>showThumbnail(_extWebService : CM_ExternalWebServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
09 APr 2020	jlgdap1	TFS 49003 MTN API Inline Agent
21 Sep 2020  cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice Definition
22 Dec 2021 navpw1	Change Request 52268: 1StopVBS External Webservice Definition
04 Oct 2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
15 Dec 2022 navmp20 ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
6  Apr 2023 jlier1 TFS 56856
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
05 Oct 2023	jlika1	TFS 60754	POB | QShip 55715.070 - Default Vessel Type 
04 Feb 2025 naviv1  JIRA-12173 : MTN - JSON CAM Protocol and APIConsumerAgent hard codes EUP as the customer
09 September 2025	navnk30	JIRA 35707: 4 - YARA | Create a new web service definition to use to send out AG Gateway messages
*/

vars
	theForm      : SOP_TableMaintForm;
	entTableDef	 : EntTableDef;
	mapping      : CM_ExtWebServiceEventMapping; // TFS 40360
	idx          : Integer;
	vbsService	 : CM_1StopVBSWebServiceDef;		// TFS 52268
		// ### TFS 55215 10Mar2023 NAVPW1
						// ### TFS 55215 10Mar2023 NAVPW1
	qshipService : CM_QshipsWebServiceDef;
	index		 : Integer;
begin
 	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	entTableDef := app.myController.getEntTableDef(ETDef_ExtWebService);
	self.changeViews(_extWebService.getExternalWebServiceType); //jlier1 TFS 56856 6/4/23
	
	if _extWebService.isKindOf(CM_InaportnetWebService) then
		//epr TFS 45207 18/6/19
		idx:=theForm.cmbVersion.findString(1,_extWebService.versionString);
		if idx &gt; 0 then
			theForm.cmbVersion.setIndex(idx);
		endif;
	endif;
	
	if _extWebService.isKindOf(CM_KiwiRailCheckInWSDef) then // TFS 40360
		mapping := _extWebService.myEventMapping; // TFS 40360
		if mapping &lt;&gt; null then // TFS 40360
			theForm.cmbEventType.listIndex := theForm.cmbEventType.findObject(mapping.myEventType); // TFS 40360
		endif; // TFS 40360
	endif;
	
	theForm.tblInput1.setTableFromCM_Object(_extWebService,null);
	theForm.tblInput1.disableRowByName(ETRow_WebServiceType); 
	
	if _extWebService.password &lt;&gt; null then
		theForm.setEnteredPassword(_extWebService.password);
		theForm.tblInput1.setValueByName(ETRow_Password, '******');
	endif;

	if _extWebService.isKindOf(CM_APIEndpointServiceDef) then												//TFS 63842
		self.setGrantTypeData(ExternalWebServiceAPIEndpoint, _extWebService.CM_APIEndpointServiceDef);		//TFS 63842
		if app.isSpecial then	//04-Feb-2025 naviv1 #12173 - start
			theForm.tblInput1.showRowByName(ETRow_Customer,true);
		else
			theForm.tblInput1.hideRowByName(ETRow_Customer,true);
		endif;	//04-Feb-2025 naviv1 #12173 - end
	endif;																									//TFS 63842
	
	//26 Aug 2021	NDL	TFS 51632
	if _extWebService.isKindOf(CM_KiwiRailCheckInWSDef) then
		if _extWebService.CM_KiwiRailCheckInWSDef.messagePassword &lt;&gt; null then
			theForm.setEnteredPassword2(_extWebService.CM_KiwiRailCheckInWSDef.messagePassword);
			theForm.tblInput1.setValueByName(ETRow_MessagePassword, '******');
		endif;
	endif;

	// TFS 52268
	if _extWebService.isKindOf(CM_1StopVBSWebServiceDef) and _extWebService.CM_1StopVBSWebServiceDef.myTerminal &lt;&gt; null then
		vbsService := _extWebService.CM_1StopVBSWebServiceDef;
		if theForm.cmbTerminal.findObject(vbsService.myTerminal) = -1 then
			idx := theForm.cmbTerminal.addItem(vbsService.myTerminal.name);
			theForm.cmbTerminal.itemObject[idx] := vbsService.myTerminal;
		endif;
		theForm.cmbTerminal.text := theForm.myAssistant.displayEntryTerminal(vbsService.myTerminal);
		theForm.cmbTerminal.listObject := vbsService.myTerminal;
	endif;
	// TFS 52268 end
	
	//jlika1 TFS 60754 --&gt;
	if _extWebService.isKindOf(CM_QshipsWebServiceDef) and _extWebService.CM_QshipsWebServiceDef.myVesselType &lt;&gt; null then
		qshipService := _extWebService.CM_QshipsWebServiceDef;
		index := theForm.cmbVesselType.findObject(qshipService.myVesselType);
		if index = -1 then
			idx := theForm.cmbVesselType.addItem(qshipService.myVesselType.displayEntryListbox);
			theForm.cmbVesselType.itemObject[idx] := qshipService.myVesselType;
		endif;
		theForm.cmbVesselType.text := qshipService.myVesselType.displayEntryListbox;
		theForm.cmbVesselType.listObject := qshipService.myVesselType;
		theForm.cmbVesselType.listIndex := index;
		theForm.tblInput1.setValueByName(ETRow_VesselType, theForm.cmbVesselType.text);
	endif;
	//jlika1 TFS 60754 &lt;--
	
	if _extWebService.isKindOf(CM_AgGatewayServiceDef) then
		theForm.tblInput1.setValueByName(ETRow_IsForCams, true);
		theForm.tblInput1.disableRowByName(ETRow_IsForCams);
		theForm.cmbTerminal.text := theForm.myAssistant.displayEntryTerminal(_extWebService.CM_AgGatewayServiceDef.myTerminal);
		theForm.cmbTerminal.listObject := _extWebService.CM_AgGatewayServiceDef.myTerminal;
	endif;
		
	
epilog

end;</source>
        <Parameter name="_extWebService" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
</Class>
