    <JadeMethod name="getDisplayStringForAttribute" id="45ae0a81-7bb1-4391-882c-2e595047531f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2023 navmv20 CR 58215 Task 58217: UI - Invoice Process Email

*/

vars

begin
	if _attrName = ETRow_EmailOptions then
		if self.myEmailTemplate &lt;&gt; null then
			return self.myEmailTemplate.subject;
		else
			return app.getErrorString(Not_Set);
		endif;
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
