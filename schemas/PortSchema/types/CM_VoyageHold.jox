    <JadeMethod name="setFromVesselHold" id="04cb71fe-ccb4-44e7-afa9-8a52e39f8f03">
        <updating/>
        <source>setFromVesselHold(_vesselHold : CM_VesselHold) updating;
/*
------------------------------------------------------------------------
Created:			31 January 2003 by cnwdwq1
Purpose:			Updates the properties on a newly created hold from the vessel's hold (basically a defn)
Parameters:		See Method signature above. Special comment:
Returns:			nill
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	if _vesselHold = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_vesselHold', null, null);
	endif;
	//OK, set properties..
	self.ordinalHold := _vesselHold.ordinalHold;		
end;</source>
        <Parameter name="_vesselHold" type="CM_VesselHold"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="e16408a5-8f29-446c-aaaa-2330c0ce13af">
