	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveTI::yardInstruction.name, "CM_ReserveTI", "yardInstruction", "", _features);
	
	//all super class references	CM_ReserveDetail
	create xdbFeature transient; 		
	xdbFeature.setupAndBuildSet(CM_ReserveTI::getTrackedItems.name, "CM_ReserveTI", "getTrackedItems", "", _features);
	create xdbFeature transient; 		 
	xdbFeature.setupAndBuildSet(CM_ReserveTI::getTrackedItemsReleased.name, "CM_ReserveTI", "getTrackedItemsReleased", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveTI::getBOLNumber.name, "CM_ReserveTI", "getBOLNumber", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveTI::getBookingRefItem.name, "CM_ReserveTI", "getBookingRefItem", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveTI::getReserveHeader.name , "CM_ReserveTI", "getReserveHeader", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveTI::myReserveHeader.name , "CM_ReserveTI", "myReserveHeader", "", _features);
