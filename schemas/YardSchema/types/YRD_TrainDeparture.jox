    <JadeMethod name="setUnconfirmedWagons" id="9ad3500d-a59d-48f3-81d2-bea9a80c818b">
        <updating/>
        <source>setUnconfirmedWagons() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 August 2009	cnwndl1	Initial creation

*/

vars

	wagon : CM_Wagon;
	myRailArea : CM_Rail;
	myRailJSIORake : CM_RailJSInOutRake;
	startPosition : Integer;
	endPosition : Integer;
	clearAll : Boolean;
	obj : Object;
	allRailLines : CM_RailLineById;
	railLine : CM_RailLine;
	idx : Integer;
	
begin

	self.allUnconfirmedWagons.clear();

	if myDefaultTrain &lt;&gt; null then
		foreach wagon in myDefaultTrain.allWagonsByIdOutward do
			if wagon.confirmedOutwards then
				continue;
			endif;
			if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean then
				self.allUnconfirmedWagons.add(wagon);
			endif;
		endforeach;
		
	else
	
		myRailArea := self.cmbRailArea.listObject.CM_Rail;
		if myRailArea = null then
			return;
		else
			foreach obj in myRailArea.allRailJSInOut do
				if obj.isKindOf(CM_RailJSInOutRake) and obj.CM_RailJSInOutRake.inOut.outwards = Rail_JSIO_Type_Out then
					myRailJSIORake := obj.CM_RailJSInOutRake;
					break;
				endif;
			endforeach;
		endif;
		
		if myRailJSIORake = null then
			return;
		endif;
	
		startPosition := self.cmbRakePos1.text.Integer;
		endPosition := self.cmbRakePos2.text.Integer;
		clearAll := false;	
		create allRailLines transient;
		if self.cmbRailRake.listObject &lt;&gt; null then
			allRailLines.add(self.cmbRailRake.listObject.CM_RailLine);
		else
			clearAll := true;
			if myRailArea &lt;&gt; null then
				myRailArea.allRailLines.copy(allRailLines);
			endif;
		endif;
		
		foreach railLine in allRailLines do
			idx := 0;
			foreach wagon in railLine.allWagons do
				if wagon = null then
					continue;
				endif;
				idx := idx + 1;
				sharedLock(wagon);
				if (not wagon.confirmed) then
					continue;
				endif;
				
				if clearAll or idx &gt;= startPosition and idx &lt;= endPosition then
					if wagon.confirmedOutwards then
						continue;
					endif;
					if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean then
						self.allUnconfirmedWagons.add(wagon);
					endif;
				endif;
				if not clearAll and idx &gt; endPosition then
					break;
				endif;
			endforeach;
			
		endforeach;
			
	endif;
	
	chkConfirmOut.enabled := not self.allUnconfirmedWagons.isEmpty;
	if not chkConfirmOut.enabled then
		chkConfirmOut.value := false;
	endif;
	
epilog

	delete allRailLines;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a61e205e-6ce7-4974-a77e-d484486ff39e">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     05 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	inheritMethod();
	app.mousePointer := MousePointer_Default;
	self.handleMenusForModalDisplay();
	
	self.btnOk.caption := app.getErrorString(SAVE_THAT_LADY_YO);

	self.myAssistant.YRD_Assistant.comboBoxRailArea(self.cmbRailArea, self.myDefaultRail);
	self.cmbRailArea.lostFocus(self.cmbRailArea);
	
	self.myAssistant.comboBoxTrain(self.cmbTrains, self.myDefaultTrain, false, true, false);
	self.cmbTrains.setFocus();
	self.setRailEnabled();
	
	if self.cmbRailArea.listCount() = 1 then
		self.cmbRailArea.listIndex := 1;
	endif;
	self.cmbRailArea.lostFocus(self.cmbRailArea);
	
	self.showPrinterName();
	
	if not self.myTerminal.getConfig(UseOutwardRailConfirm).Boolean then
		self.chkConfirmOut.value := true;
	endif;
epilog

end;</source>
    </JadeMethod>
