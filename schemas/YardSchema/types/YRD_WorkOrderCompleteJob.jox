    <JadeMethod name="collapseOrExpandCargoGroups" id="55771202-301a-4ca7-978d-3c4463fc0ea8">
        <source>collapseOrExpandCargoGroups(_table :Table input ; _clickedRow :Integer ; _col :Integer );
/*

Purpose: Collpase or Expand the CargoGroup rows.If the TIs of the group are already loaded,rows are just made visible.If not ,rows are added to the table	

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
25 Nov 2024 navbs1 Bug MTN-33186: MTN - Performance of Data retrieval in work order operations screen has been affected by cargo grouping
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/
vars
	row,rowIdx			: Integer;
	ti, nextTi,
	selectedTI			: CM_TrackedItem;
	plus, minus, 
	currentState,
	newState,
	theDataLine			: String;
	bottomTableRow		: Integer;
	selectedRow,
	tmpTableRow			: JadeTableRow;
	tis					: CM_TISet;
	cargoGroupDetail 	:CM_CargoGroupDetail;
	form				: CM_BaseForm;
begin 
	if _table = null or not _table.visible then
		return;
	endif;
	
	if _clickedRow &lt;= _table.fixedRows then
		return;
	endif;
	
	if _col &gt; 1 then
		return;
	endif;
	
	plus 			:= J_key_Plus.Character;
	minus 			:= J_key_Hyphen.Character;
	
	bottomTableRow  := _table.rows;
	selectedRow 	:=_table.accessRow(_clickedRow);
	selectedTI		:= selectedRow.itemObject.CM_TrackedItem;
	
	if selectedTI &lt;&gt; null and not selectedTI.isCargoGroupItem then 
		return ;
	endif;
	
	//access first cell
	currentState := _table.accessCell(_clickedRow, _col).text[1:1];
	if currentState = plus then
		newState := minus;
		nextTi   := null;
		row      := _clickedRow;
		
		if row &lt;&gt; bottomTableRow then
			nextTi := _table.accessRow(row + 1).itemObject.CM_TrackedItem;
		endif;
		if nextTi = null or nextTi.isCargoGroupItem then //cargo items are not loaded yet
			
			create tis transient;
			cargoGroupDetail := self.allCargoGroupDetails.getAtKey(_table.name, selectedTI).CM_CargoGroupDetail;
			if cargoGroupDetail &lt;&gt; null then
				cargoGroupDetail.allAssignedTrackedItems.copy(tis);
			endif;
			
			form := self;
			_table.CM_DataTable.getDataAndDisplayRowsMultith(tis, true, form, false);
			//add the rows to the table 
			rowIdx := row+1;
			foreach ti in tis do
				theDataLine :=_table.CM_DataTable.getDisplayStringAttributeArray(ti.getOidAsString());
				_table.CM_DataTable.addItemObjectAt(ti, theDataLine, rowIdx);
				rowIdx := rowIdx+1;
			endforeach;
			//25.11.2024 navbs1 #33186 END
			
		else//set rows to visible 
			bottomTableRow := _table.rows;
			while row &lt; bottomTableRow do 
				row := row+1;
				tmpTableRow := _table.accessRow(row);
				ti := tmpTableRow.itemObject.CM_TrackedItem;
				if ti = null or ti.isCargoGroupItem then 
				break;
				endif;
				tmpTableRow.visible:=true;
			endwhile;
		
		endif;
				
	else
		//set rows visibility to false
		newState 		:= plus;
		bottomTableRow  := _table.rows;
		row				:= _clickedRow;
		while row &lt; bottomTableRow do 
			row			:= row+1;
			tmpTableRow := _table.accessRow(row);
			ti			:= tmpTableRow.itemObject.CM_TrackedItem;
			
			if ti = null or ti.isCargoGroupItem then 
				break;
			endif;
			tmpTableRow.visible:=false;
		endwhile;
	endif;
	
	_table.accessedCell.text[1:1] := newState;

epilog
	delete tis; 
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_clickedRow" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="completeChecks" id="6ee98498-378c-445d-b2b7-ba1468b6b53f">
        <source>completeChecks(_ti : CM_TrackedItem; _context : Integer; _effectiveDate : TimeStamp): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars

begin
	if not app.myPassport.warningsAcknowledged then
		self.showCargoCheckForm(_ti,_context,_effectiveDate);
	endif;
	
	if self.myTerminal.allCargoChecks[_context].allCargoCheckItems.isEmpty or _ti.cargoChecksCompleted.last then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_effectiveDate" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="a3713b6b-8114-49c2-87da-7a6fe2a49a90">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars

begin
	self.permissionView		:= PmAdmWOCompleteJobView;
	self.permissionMaint	:= PmAdmWOCompleteJobMaint;		//27.09.2024 navnk30 #66108 END
	self.helpFileName 		:= HelpFile_Yard;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayMonitorForBulkMove" id="5f348f09-8e2f-47f5-95b6-0e8b00455b7a">
        <updating/>
        <source>displayMonitorForBulkMove()updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
03 Dec 2024 navbs1  Bug MTN-33570: MTN - Ship WorkOrder Enhancements
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/
vars
	cmifMonitor			: CMIF_Monitor;
	tiSet				: CM_TISet;
begin
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	create tiSet transient;															//03.12.2024  navbs1  #33570
	self.getSelectedObjects(self.tblAvailCargo,tiSet);							 	//03.12.2024  navbs1  #33570
	cmifMonitor.partsInJob := tiSet.size;											//03.12.2024  navbs1  #33570
	cmifMonitor.myParent := self;
	cmifMonitor.callBackMethodName := 'updateProgressForBulkMove';
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, 'Bulk Cargo Move...', null);
	self.pbProgressBar.visible := true;
	self.lblModalMessage.visible := true;
	self.lblModalInfo.visible := true;
	self.updateProgressForBulkMove(cmifMonitor);
	self.frmModalDialog.refreshNow;
epilog
	delete tiSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnStartStopClick" id="31f52511-c89d-442c-8e0d-60002e1cfeae">
        <source>doBtnStartStopClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/03/2024	navkc1 CR62696 Task 62944: UI - Retrospective UI Stop Start Option
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
*/

vars
	form	: CMUI_StartStopJobActivity;
	job		: CM_Job;
	ti		: CM_TrackedItem;
begin
	
	job := self.myJob;
	
	if job = null then
		return;
	endif;
	
	create form transient;
	
	if form = null then
		return;
	endif;
	
	form.setMyJob(job);
	if job.isJobMatchingMode(TI_TRANSMODE_PACKING) then	//09.10.2024 navhl20 #12389
		ti := self.tblParent.allSelectedObjects.first.CM_TrackedItem;
		form.setMyTrackedItem(ti);
	endif;
	form.showModal();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCompleteShip" id="7971ca00-1440-4daf-9fdb-6b127a2998e9">
        <updating/>
        <source>doCompleteShip(_tiset : CM_TISet; _moveController : CMIF_MoveController io; _time,_count : Integer; _isCargoGrp : Boolean; _ti : CM_TrackedItem; _trackByWeight, _load : Boolean; _job : CM_Job) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	result,
	idx 			: Integer;
	ti				: CM_TrackedItem;
	cgInAvailTblSet,
	movedTiSet		: CM_TISet;	
begin
	create cgInAvailTblSet transient;
	create movedTiSet transient;
	while true do
		app.myTrxUA.trxMoveTrackedItemsMoveContext(_tiset,movedTiSet,_moveController,_time,_count,_isCargoGrp,_load,_job,app.myPassport);
		
		// ### TFS CR 64297 TASK 64359 30MAY2024 NAVAB1
		if app.myPassport.hadDeadlock = true then
			return;
		endif;
		
		if app.myPassport.trxCompletedOK then
			
			if not self.isBulkMode then
				if _ti.totalQuantity &gt; 0 then
					if self.tblAvailCargo.findObjectInRow(_ti,idx) then
						self.tblAvailCargo.setCellText(idx, 1, _ti.getAttributeStringForDefArray(self.tblAvailCargo.allTblDataEntRows));
					endif;
				else
					self.tblAvailCargo.removeItemObject(_ti);
					if self.isCargoGrouping then 
						cgInAvailTblSet.tryAddIfNotNull(_ti.myCargoGroup);								
						self.removeObjectFromCGDtlDict(self.tblAvailCargo,_ti);
					endif;
				endif;
			endif;
			
			foreach ti in movedTiSet do
				self.tblAvailCargo.removeItemObject(ti);
				if self.isCargoGrouping then
					cgInAvailTblSet.tryAddIfNotNull(ti.myCargoGroup);							
					self.removeObjectFromCGDtlDict(self.tblAvailCargo,ti);
				endif;
			endforeach;
			
			self.refreshCargoGroupDetail(self.tblAvailCargo,cgInAvailTblSet);					
			self.lblSelectedCount.caption := self.lblSelectedCaption &amp; Space &amp; '0';
			self.txtSelectCount.text := null;
			
			if not self.chkHideCompleted.value then
				self.loadTblCompleted();
			endif;
			
			if self.tblAvailCargo.rows = 1 then
				self.btnOk.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
				self.btnDoOperation.enabled := false;
			endif;

			self.setTblDataCount();
			break;
		else
			foreach ti in movedTiSet do
				self.tblAvailCargo.removeItemObject(ti);
				if self.isCargoGrouping then
					cgInAvailTblSet.tryAddIfNotNull(ti.myCargoGroup);
					self.removeObjectFromCGDtlDict(self.tblAvailCargo,ti);
				 endif;
			endforeach;
			
			self.refreshCargoGroupDetail(self.tblAvailCargo,cgInAvailTblSet);
			
			result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, 20);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				break;
			endif;
		endif;
	endwhile;
epilog
	delete cgInAvailTblSet;
	delete movedTiSet;
end;</source>
        <Parameter name="_tiset" type="CM_TISet"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="io"/>
        <Parameter name="_time" type="Integer"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_isCargoGrp" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_trackByWeight" type="Boolean"/>
        <Parameter name="_load" type="Boolean"/>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="doExpandAndCollapse" id="9a86655f-45ae-4a18-9383-8c7725e08be2">
        <source>doExpandAndCollapse(action : Integer ; _rowToExpand:Integer);
/*

Purpose: exand and collapses the cargoGroup rows.If _rowToExpand has some value ,only that row is expanded/collpased ,else all the rows are expanded/collpased.			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group

*/

vars

	currentState,plus, 
	minus,searchSymbol  : String;
	tbl					: CM_DataTable;
	row,endRow  		: Integer;
	selectedTI 			: CM_TrackedItem;
	selectedRow 		: JadeTableRow;
begin

	plus := J_key_Plus.Character;
	minus := J_key_Hyphen.Character;
	
	if action = self.Expand then 
		searchSymbol := plus;
	else
		searchSymbol := minus;
	endif;
	
	tbl := self.tblAvailCargo;
	row := tbl.fixedRows+1;
	endRow := tbl.rows;
	
	if _rowToExpand &lt;&gt; null then 
		row:= _rowToExpand;
	endif;

	while row &lt;= endRow do 
		selectedRow :=tbl.accessRow(row);
		selectedTI:= selectedRow.itemObject.CM_TrackedItem;
		if selectedTI = null or selectedTI.isCargoGroupItem then
			currentState := tbl.accessCell(row, 1).text[1:1];
			if currentState = searchSymbol then
				self.collapseOrExpandCargoGroups(tbl,row,1);
			endif;
		endif;

		endRow:=tbl.rows; //since number of rows might change after collapseOrExpandCargoGroups method
		if _rowToExpand &lt;&gt; null then
			//need to break this loop as only one rows needs to be expanded/collapsed
			endRow:= row; 
		endif;
		row := row+1;
	endwhile;



end;</source>
        <Parameter name="action" type="Integer"/>
        <Parameter name="_rowToExpand" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMakePalletStuffVisible" id="05685fe9-fe2f-42d6-9617-8a194138cf96">
        <source>doMakePalletStuffVisible(_type : CM_ResourceType);
/*
Purpose:			

Date		Who		Reason
14 March 2024	navab1	CR 62818 TASK 62821 
*/

vars

	ti : CM_TrackedItem;
	handlingType : CM_HandlingType;

begin

	self.frmPallet.visible := false;
	
