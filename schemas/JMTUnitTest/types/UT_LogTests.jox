    <JadeMethod name="logBolUpdate" id="27326cb2-6641-4c30-8ae0-66194178b9c0">
        <source>logBolUpdate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwrd1	Initial creation

*/

vars
	operator	: CM_Operator;
	pxyBolIn,
	bolIn		: 	CM_BOLIn;
	loadStateSet: Boolean;
	
begin
/*
	bolIn	:= self.getBOLIn( self.BOLInNumber_UpdateXML, self.OperatorCode );
	
	app.cmsBeginLoad(loadStateSet);
	pxyBolIn:= bolIn.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadStateSet);
	
	pxyBolIn.weightNetTonnes := pxyBolIn.weightNetTonnes * 2;	// weight change
	app.myTrxUA.trxUpdateBOL(pxyBolIn, false, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
*/


	operator	:= self.getOperator(OperatorCode);

					
	bolIn := self.updateBOLIn(RTDeviceId,	
					'ABC', //_activity, 		
					'ABC',//_backLoad,		
					self.BOLInNumber_UpdateXML, //_bolNoLookup,
					CarrierCode, //_carrierCode,		
					null, //_chhSupplier,		
					null,//_compartment,			
					'ABC',//_customer,		
					null, //_docketError,
					'driver',//_driverId,	
					null,//_pieceCountError,
					null,//_driversPieceCount,
					null,//_fellDate,			
					null,//_forest,			
					'gang',//_gang,							
					'10.000',//_grossWeight,	
					'false', //_isFSC,
					'false',//_isNightShift,		
					null,//_loaderNumber,
					operator.code,//_loadingContractor,
					'BCA',//_loggingContractor,
					operator.code,//_loggingOperation,
					operator.code,//_loggingOrg,
					'8.000',//_netWeight,
					////self.BOLInNumber_UpdateXML &amp;'X',//_number,
					self.BOLInNumber_UpdateXML,//_number,	// 13 Aug 2012 cnwjre1 remove the trailing 'X' to make it work - no idea why!!
					operator.code,//_operatorLookup,
					'ABC',//_opid,
					null,//_pickupPoint,
					'remarksupdate',//_remarks,
					null,//_stand,
					null,//_subSupplier,
					'2.000',//_tareWeight,
					null,//_trailerNumber,
					VehicleId,//_truckNumber,
					null,//_unloadPoint,
					VehicleId,//_vehicle,
					'WBR'//_weighBridge
						);

	self.assertNotNull(bolIn);
	
	//bolIn.inspectModal;
	
	
epilog
	
end;</source>
    </JadeMethod>
