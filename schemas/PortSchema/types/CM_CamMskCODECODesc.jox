    <JadeMethod name="checkEditForStatusChange" id="b8a00fb7-8f68-40af-940a-628077f3bace">
        <source>checkEditForStatusChange(_transaction:CM_TITransaction; _newStatus : String io) : Boolean;
//
// CCMS1517 cnwrs1 Jan 2007
// check for availablity grade change for MSK status message
//
vars
	trans,saveTrans:CM_TITransaction;
	field,oldValue,newValue:String;
	i:Integer;
	tmpTerminal	: CM_Terminal;
begin
	if not _transaction.isCamsEditType() then
		return false;
	endif;
	//we have an edit transaction see if it is intesteresting
	foreach i in 1 to _transaction.CM_Edit.fieldsValues.size do
		_transaction.CM_Edit.getFieldValues(i, field, oldValue, newValue);
		if field = CM_Container::availabilityGrade.name then
			tmpTerminal := _transaction.myTerminal;
			if newValue &lt;&gt; null and newValue &lt;&gt; oldValue then
				if newValue = '1' then
					_newStatus := 'DB';
					return true;
				elseif newValue = '0' then
					_newStatus := 'NONAV';
					return true;
				elseif oldValue = '1' or oldValue = '0' then
					_newStatus := 'AV';
					return true;
				endif;
			endif;
		endif;
	endforeach;
	return false;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_newStatus" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="contentsStatusToString" id="dbd5353a-5d79-47b9-bedf-5c1dd73b1c01">
        <source>contentsStatusToString(_contentsStatus: Integer; _activity: Integer; _type: Integer): String;
//
// CCMS1893 DCT Gdansk cnwrs1 Oct 2009
//
vars
	contentsString : String;
begin
	contentsString := inheritMethod(_contentsStatus, _activity, _type);
	if _activity = CODECO_PACK then//for CCMS 1475
		contentsString := "5";
	elseif _activity = CODECO_UNPACK then//CCMS1499 cnwrs1 nov 2006 
		contentsString := "4";
	endif;
	return contentsString;
end;
</source>
        <Parameter name="_contentsStatus" type="Integer"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
