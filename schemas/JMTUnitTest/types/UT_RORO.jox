<Class name="UT_RORO" id="a32e38bc-451b-4bac-a058-73f41df1691c">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="tROROBaplieMovinsRotated" id="715afedb-4b2e-4188-acdb-5b7bbd19bbc8">
        <source>tROROBaplieMovinsRotated();
// cnwrs1 30 mar 2010 - test for Ship Manifest check it adds a and deletes it. It uses voyage Consist to create the voyage
//	If this test fails check the Terminal, Gate, Booking Required setting and changed to say "Partial".
/* Changes

Date		Name	TFS#		Description
============================================================================
26 Nov 2012	cnwrs1	par 30738 
24 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	VoyageName = 'VOYSHIP29749';
	ShipName = 'JROSO';	//JROSO
	TestOperator = 'MSL';
	UserDefinedDeckPlan	= 'Unit Test Deck Plan';
	UserDefinedStowAdvice = 'Unit Test RORO Stow Advice';
	ContainerId1 = "OOTL0002914";
	ContainerId2 = "OOTL0002915";
	ContainerId3 = "OOTL0002916";
	ContainerId4 = "OOTL0002917";
	ContainerId5 = "OOTL0002918";
	ContainerId6 = "OOTL0002919";
	ContainerId7 = "OOTL0002920";
vars
	bSynchronous : Boolean;
	xmlBlock : String;
	clientRef : String;
//	clientRefDeckStowAdvice : String;
	messageType : String;
	ediText : String;
	tempStr : String;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
//	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	binaryMsg : Binary;
	ediFileType : CM_EDIFileType;
	ediControllerAgent : CM_EDIControllerAgent;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	clientRefNum : Integer;
	voyCountLoad : Integer;
	layoutCountLoad : Integer;
	layoutPointCountLoad : Integer;
	tiCountLoad : Integer;
	voyCountExtract : Integer;
	layoutCountExtract : Integer;
	layoutPointCountExtract : Integer;
	tiCountExtract : Integer;
	found : Boolean;
	ti : CM_TrackedItem;
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedDeckPlan);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedDeckPlan].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		//self.assertTrue(app.myPassport.trxCompletedOK());
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedDeckPlan).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedDeckPlan &amp; ' is missing');

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_ROROStowAdvice(UserDefinedStowAdvice);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedStowAdvice].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		//self.assertTrue(app.myPassport.trxCompletedOK());
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedStowAdvice).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedStowAdvice &amp; ' is missing');

	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
//	self.deleteVessel(ShipName);
//	vessel := self.getVessel(ShipName);
//	self.assertIsDeleted(vessel);

	operator := app.myRoot.allOperators[TestOperator];
	
	// now set up cleanly
//	vessel := self.addVesselConRORO(ShipName, operator);
//	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
/*	voyage	:= self.addVoyageWithGeneralCargoStruc(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													10 );*/
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);

	// make sure all of the objects are deleted and created correctly.
	found := false;
	clientRefNum := 0;
	while found = false do
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
		if ediFile &lt;&gt; null then
			beginTransaction;
			if ediFile.ediData = null then
				delete ediFile;
			else
				ediData := ediFile.ediData;
				delete ediData;
			endif;
			commitTransaction;
		else
			found := true;
		endif;
	endwhile;

	// make sure all of the objects are deleted and created correctly.
	//  now add the ship manifest via EDI
	ediControllerAgent.setTerminal(self.getTerminal);	// cnwrl1 24/05/2010 PAR 24276
	clientRefNum := 0;
	// setup the add ship manifest here
	ediText := //self.uRORODeckPlan(VoyageName, ShipName, TestOperator);
'V,,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
L,D3026,S,,Yes,1X3
L,D3038,S,,Yes,1X5
L,D3054,S,,Yes,2X3
C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D3026R,,,,'&amp;ContainerId1&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,14777,,,,,'&amp;VoyageName&amp;'
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D3055R,,,,'&amp;ContainerId2&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D3049R,,,,'&amp;ContainerId3&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D3034,,,,'&amp;ContainerId4&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,,,,,CONT,,,GENL,,,,,,,,,AUSYD,D3058,,,,'&amp;ContainerId5&amp;',1,2063,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName;
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedDeckPlan[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
/*	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg);
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg);
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg(ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1');
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);*/

	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedDeckPlan, UserDefinedDeckPlan&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);

	voyCountLoad := 0;
	layoutCountLoad := 0;
	layoutPointCountLoad := 0;
	tiCountLoad := 0;
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountLoad := voyCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountLoad := layoutCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountLoad := layoutPointCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountLoad := tiCountLoad + 1;
		endif;
	endforeach;
	clientRef := null;
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);

	// now add RORO Stow advice
	ediControllerAgent.setTerminal(self.getTerminal);	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add ship manifest here
	ediText := //self.uROROStowageAdvice(VoyageName, ShipName, TestOperator);
'V,,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
S,LOA,Book124,,ISO Container,GENL,NZPOE,USPOE,NZAKL,1.1,,ANNE1111110,,2200,,NZPOE,,,Remark 01,,D1010,,,'&amp;VoyageName&amp;',
S,LOA,Book125,,ISO Container,FZBF,NZPOE,USPOE,NZAKL,,,ANNE1111112,,2232,,NZPOE,,,Remark 01,,D1011,-20,,'&amp;VoyageName&amp;',14888
S,LOA,Book126,,ISO Container,GENL,NZPOE,USPOE,NZAKL,1.1,,ANNE1111111,,2200,,NZPOE,,,Remark 01,,D1012,,,'&amp;VoyageName&amp;',
L,D3097,S,,Yes,2X5
L,D3021,S,,Yes,2X3
L,D3054,S,,Yes,1X3
L,D1101G,S,,
P,D1101G,1,52.4,-1.7
P,D1101G,2,60.5,-1.7
P,D1101G,3,67.5,0.1
P,D1101G,4,68.2,9.9
P,D1101G,5,59,10.9
P,D1101G,6,52.4,5.7
P,D1101G,7,52.4,-1.7
S,LOA,Book126,,CANNON,GENL,NZPOE,USPOE,NZAKL,,,GCGC2277884,,,,NZPOE,,,Remarks 03,,D1101G,,,'&amp;VoyageName&amp;',21126
S,LOA,Book124,,ISO Container,GENL,,USPOE,NZAKL,1.1,,ANNE1111114,,4100,,NZPOE,,,Remark 01,,D1003,,,'&amp;VoyageName&amp;',
S,LOA,Book124,,ISO Container,GENL,,USPOE,NZAKL,1.1,,ANNE1111116,,4100,,NZPOE,,,Remark 01,,D1042,,,'&amp;VoyageName;
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedStowAdvice[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS.display, tempStr);

	ediText := //self.uROROStowageAdvice(VoyageName, ShipName, TestOperator);
'V,,'&amp;VoyageName&amp;','&amp;ShipName&amp;'
S,LOA,Book124,,ISO Container,GENL,NZPOE,USPOE,NZAKL,1.1,,ANNE1111110,,2200,,NZPOE,,,Remark 01,,D1010,,,'&amp;VoyageName&amp;',
S,LOA,Book125,,ISO Container,FZBF,NZPOE,USPOE,NZAKL,,,ANNE1111112,,2232,,NZPOE,,,Remark 01,,D1011,-20,,'&amp;VoyageName&amp;',14888
S,LOA,Book126,,ISO Container,GENL,NZPOE,USPOE,NZAKL,1.1,,ANNE1111111,,2200,,NZPOE,,,Remark 01,,D1012,,,'&amp;VoyageName&amp;',
L,D3097,S,,Yes,2X5
L,D3021,S,,Yes,2X3
L,D1101G,S,,
P,D1101G,1,52.4,-1.7
P,D1101G,2,60.5,-1.7
P,D1101G,3,67.5,0.1
P,D1101G,4,68.2,9.9
P,D1101G,5,59,10.9
P,D1101G,6,52.4,5.7
P,D1101G,7,52.4,-1.7
S,LOA,Book126,,CANNON,GENL,NZPOE,USPOE,NZAKL,,,GCGC2277884,,,,NZPOE,,,Remarks 03,,D1101G,,,'&amp;VoyageName&amp;',21126
S,LOA,Book124,,ISO Container,GENL,,USPOE,NZAKL,1.1,,ANNE1111114,,4100,,NZPOE,,,Remark 01,,D1003,,,'&amp;VoyageName&amp;',
S,LOA,Book124,,ISO Container,GENL,,USPOE,NZAKL,1.1,,ANNE1111116,,4100,,NZPOE,,,Remark 01,,D1042,,,'&amp;VoyageName;
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedStowAdvice[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);
	voyCountLoad := 0;
	layoutCountLoad := 0;
	layoutPointCountLoad := 0;
	tiCountLoad := 0;
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountLoad := voyCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountLoad := layoutCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountLoad := layoutPointCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDIStowAdviceTI) then
			tiCountLoad := tiCountLoad + 1;
		endif;
	endforeach;
	
	// now extract the details
	create ediDataParams transient;
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedStowAdvice];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckStowageAdvice(voyage, clientRef, voyage.myOperator, ediFileType);
		ediDataParams.operator := voyage.myOperator;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
	endif;
	voyCountExtract := 0;
	layoutCountExtract := 0;
	layoutPointCountExtract := 0;
	tiCountExtract := 0;
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountExtract := voyCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountExtract := layoutCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountExtract := layoutPointCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDIStowAdviceTI) then
			tiCountExtract := tiCountExtract + 1;
		endif;
	endforeach;
	self.assertEqual(voyCountExtract, voyCountLoad);
//	self.assertEqual(layoutCountExtract, layoutCountLoad);
	self.assertEqual(layoutPointCountExtract, layoutPointCountLoad);
//	self.assertEqual(tiCountExtract, tiCountLoad);
	
	ediControllerAgent.setTerminal(self.getTerminal);
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedDeckPlan];
	ediDataParams.operator := voyage.myOperator;
	//now extract the actual and proposed deck plan and compare them - they should be different
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, ACTUAL_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
		voyCountLoad := 0;
		layoutCountLoad := 0;
		layoutPointCountLoad := 0;
		tiCountLoad := 0;
		foreach ediTI in ediData.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
				voyCountLoad := voyCountLoad + 1;
			elseif ediTI.isKindOf(CM_EDILayoutTI) then
				layoutCountLoad := layoutCountLoad + 1;
			elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
				layoutPointCountLoad := layoutPointCountLoad + 1;
			elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
				tiCountLoad := tiCountLoad + 1;
			endif;
		endforeach;
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, PROPOSED_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
		voyCountExtract := 0;
		layoutCountExtract := 0;
		layoutPointCountExtract := 0;
		tiCountExtract := 0;
		foreach ediTI in ediData.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
				voyCountExtract := voyCountExtract + 1;
			elseif ediTI.isKindOf(CM_EDILayoutTI) then
				layoutCountExtract := layoutCountExtract + 1;
			elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
				layoutPointCountExtract := layoutPointCountExtract + 1;
			elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
				tiCountExtract := tiCountExtract + 1;
			endif;
		endforeach;
		self.assertEqual(voyCountExtract, voyCountLoad);
		self.assertEqual(layoutCountExtract, 1);	//1 rotations 2 rotated locations have Import the other has no cargo
		self.assertEqual(layoutPointCountExtract, layoutPointCountLoad);
		self.assertEqual(tiCountExtract, tiCountLoad-1);	// 1 import
	endif;
	
	// 11/09/2015 cnwrf2
	beginTransaction;
	foreach ti in voyage.allOnshipTIsByCargoTypeId discreteLock do
		if not ti.remarks.cnContains(self.createdByUnitTest(null)) then
			ti.setRemarks(self.createdByUnitTest(null), true);
		endif;
	endforeach;
	commitTransaction;
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tROROCheckDeck2And3" id="1ca4bf51-a66d-44c0-b9ef-b94eaf7731fb">
        <source>tROROCheckDeck2And3();

/*

Purpose:		Check that stuff is loaded to decks 2 &amp; 3 and not deck 1

Date			Who		Reason
28/05/2014		cnwmh5	Initial creation

*/
constants

	VoyageId					: String = "UTMDHVOY1Q";
	VesselId					: String = "ZERA";
	UserDefinedROROBaplie		: String = 'UT Messina RORO Baplie 2';

vars

	voyage						: CM_Voyage;
	ediControllerAgent 			: CM_EDIControllerAgent;
	ediFile 					: CM_EDIFile;
	ediData 					: CM_EDIData;
	pxyFileTypeUser 			: CM_EDIFileTypeUser;
	fileTypeUser 				: CM_EDIFileTypeUser;
	voyageDeck 					: CM_DeckVoyage;
	
	theTIs						: CM_TIArray;

	ediText						: String;
	xmlBlock 					: String;
	binaryMsg 					: Binary;
	bSynchronous 				: Boolean;
	messageType 				: String;
	idx							: Integer;
	clientRef					: String;
	errorStr					: String;
	tempStr						: String;
	
begin

	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(),
		0, false, true);
	self.assertNotNull(voyage);
	
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_ROROBaplie2(UserDefinedROROBaplie);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedROROBaplie].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedROROBaplie).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedROROBaplie &amp; ' is missing');

	ediText := self.xZERANBaplie(voyage);
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedROROBaplie[1 : fileTypeUser.name.maxLength];  // ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedROROBaplie, UserDefinedROROBaplie&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// Check that there is only stuff on deck 2 and 3
	create theTIs transient;
	voyageDeck := voyage.myROROStructure.allDecksByCode["1"];
	self.assertNotNull(voyageDeck);
	voyageDeck.getAllTrackedItems(REAL_MODE, theTIs);
	self.assertEqual(theTIs.size, 0);
	
	theTIs.clear();
	voyageDeck := voyage.myROROStructure.allDecksByCode["2"];
	self.assertNotNull(voyageDeck);
	voyageDeck.getAllTrackedItems(REAL_MODE, theTIs);
	self.assertNotEqual(theTIs.size, 0);
	
	theTIs.clear();
	voyageDeck := voyage.myROROStructure.allDecksByCode["3"];
	self.assertNotNull(voyageDeck);
	voyageDeck.getAllTrackedItems(REAL_MODE, theTIs);
	self.assertNotEqual(theTIs.size, 0);
	
	
epilog

	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete theTIs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRORODeckPlan" id="9ad3d3b6-4dbd-4fbc-bc6d-134eebf88924">
        <source>tRORODeckPlan();
//
// cnwrs1 30 mar 2010 - test for Ship Manifest check it adds a and deletes it. It uses voyage Consist to create the voyage
//
//	If this test fails check the Terminal, Gate, Booking Required setting and changed to say "Partial".
constants
	VoyageName = 'VOYSHIP29024';
	ShipName = 'SHIP29024';
	TestOperator = 'ANL';
	UserDefinedShipManifest	= 'Unit Test Deck Plan';
vars
	bSynchronous : Boolean;
	xmlBlock : String;
	clientRef : String;
	messageType : String;
	ediText : String;
	tempStr : String;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	binaryMsg : Binary;
	ediFileType : CM_EDIFileType;
	ediControllerAgent : CM_EDIControllerAgent;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	idx : Integer;
	voyCountLoad : Integer;
	layoutCountLoad : Integer;
	layoutPointCountLoad : Integer;
	tiCountLoad : Integer;
	voyCountExtract : Integer;
	layoutCountExtract : Integer;
	layoutPointCountExtract : Integer;
	tiCountExtract : Integer;
	clientRefNum : Integer;
	ti : CM_TrackedItem;
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedShipManifest);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');

	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(ShipName);
	vessel := self.getVessel(ShipName);
	self.assertIsDeleted(vessel);
	operator := app.myRoot.allOperators[TestOperator];
	
	// now set up cleanly
	vessel := self.addVesselLOLOholdsRORO(ShipName, operator);
	
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
/*	voyage	:= self.addVoyageWithGeneralCargoStruc(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													10 );*/
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);

//  now add the ship manifest via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add ship manifest here
	ediText := self.uRORODeckPlan(VoyageName, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];  // ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
/*	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg);
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg);
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg(ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1');
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);*/

	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);

	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountLoad := voyCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountLoad := layoutCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountLoad := layoutPointCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountLoad := tiCountLoad + 1;
		endif;
	endforeach;
	
	// noe extract the details
	create ediDataParams transient;
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedShipManifest];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, ACTUAL_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediDataParams.operator := voyage.myOperator;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
	endif;
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountExtract := voyCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountExtract := layoutCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountExtract := layoutPointCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountExtract := tiCountExtract + 1;
		endif;
	endforeach;
	self.assertEqual(voyCountExtract, voyCountLoad);
	self.assertEqual(layoutCountExtract, layoutCountLoad);
	self.assertEqual(layoutPointCountExtract, layoutPointCountLoad);
	self.assertEqual(tiCountExtract, tiCountLoad);
	
	// 10/09/2015  cnwmh5
	beginTransaction;
	foreach ti in voyage.allOnshipTIsByCargoTypeId discreteLock do
		if not ti.remarks.cnContains(self.createdByUnitTest(null)) then
			ti.setRemarks(self.createdByUnitTest(null), true);
		endif;
	endforeach;
	commitTransaction;
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
