/*
Purpose:			CCMS 1007 Allow for reefer details on booking and CM_TrackedItem, not just CM_Container

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
*/
vars
	str : String;

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	if self.requiresTemperature then
		_value := true;
		return;
	endif;

	if self.requiresPower then
		_value := true;
		return;
	endif;

	if self.isConnected then
		_value := true;
		return;
	endif;
epilog

end;</source>
