    <JadeMethod name="setupForm" id="cafa7034-08ec-42aa-ac63-845159fd3ec1">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     03 October 2003	cnwth2
//
// Purpose:     
// 09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up 
// 19 Sep 2023 navsaa30 Defect 60522: MTN - Release Request Audits - No longer automatically displaying
// ----------   ----------  --------------------------------------------------
vars

begin
	self.tblData.allTblDataSortColumns.add(ETRow_Type);
	self.tblData.allTblDataSortDescending.add(false);
	inheritMethod();

	self.tblThumb.autoSize := Table.AutoSize_Row;  // 09/01/2017 cnwma1 TFS #2712
	self.tblThumb.accessColumn(1).width:=120;
	
	//01 Feb 2021	NDL	TFS 50152
	if self.myAudittedObject &lt;&gt; null then
		self.btnAuditConfig.visible := false;
	endif;
	
	self.toolbarShowCaptions(self.frmToolbar.showCaptions);  //19.09.2023 navsaa30 #60522
	self.frmTableFilter.setCallbackMethod(CM_AuditViewForm::doFilterTable.name); //25/06/2024	navkc1 CR 64823 Task 64824
	self.frmTableFilter.setSkipControlFilter(true); //02/08/2024	navkc1 Defect 65489
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailHeadings" id="a40b04d0-b543-4925-be66-5014481d1749">
        <source>setupThumbnailHeadings(_auditType : Integer);
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
// ---------------------------------------------------------------------------
vars

begin

	if _auditType = AuditCreated then
		self.tblThumb.columns := 2;
		self.tblThumb.addItemAt("Property" &amp; Tab &amp; "Initial Value", 1);
	elseif _auditType = AuditDeleted then
		self.tblThumb.columns := 2;
		self.tblThumb.addItemAt("Property" &amp; Tab &amp; "Value At Deletion", 1);
	elseif _auditType = AuditUpdated then
		self.tblThumb.columns := 3;
		self.tblThumb.addItemAt("Property" &amp; Tab &amp; "Before" &amp; Tab &amp; "After", 1);
	elseif _auditType = AuditInformation then
		self.tblThumb.columns := 1;
	else
		self.tblThumb.columns := 2;
		self.tblThumb.addItemAt("Property" &amp; Tab &amp; "Audited Value", 1);
	endif;
	
	if self.tblThumb.columns &lt; 3 then
		if self.tblThumb.columns &gt; 1 then	// there is one column, when AuditObjectInformation
			self.tblThumb.columnWidth[2] := self.tblThumb.clientWidth - self.tblThumb.columnWidth[1];
			self.tblThumb.accessColumn(2).wordWrap := true;  // 09/01/2017 cnwma1 TFS #2712
		endif;
	else
		self.tblThumb.columnWidth[2] := (self.tblThumb.clientWidth - self.tblThumb.columnWidth[1]) div 2;
		self.tblThumb.columnWidth[3] := self.tblThumb.clientWidth - (self.tblThumb.columnWidth[1] + self.tblThumb.columnWidth[2]);
		self.tblThumb.accessColumn(2).wordWrap := true;  // 09/01/2017 cnwma1 TFS #2712
		self.tblThumb.accessColumn(3).wordWrap := true;  // 09/01/2017 cnwma1 TFS #2712
	endif;
	
	if _auditType = AuditInformation then
		self.tblThumb.rows := 0;
	else
		self.tblThumb.rows := 1;
	endif;
	
end;</source>
        <Parameter name="_auditType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="eb67418a-5817-4a03-a197-20d52dafbe2a">
        <updating/>
        <source>showThumbnailData(_obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 Aug 2023 navhl20 Defect 59936: MTN - Displaying only the first tracked item on the Audit Enquiry for the Vehicle Booking Time Slot
// 30 Jan 2023 navhl20 Bug 57592: MTN - WO - Audits for Work Order Delete is not registered correctly
// 09 Jan 2025 navnk30 JIRA 19801: MTN - Audits on Terminal Area Definitions
// ---------------------------------------------------------------------------
vars
	aud 	: CM_AuditObject;
	obj		: Object;
	oidDecStr,
	str 	: String;
	i 		: Integer;
	aoiChild, 
	aoi		: CM_AuditObjectImage; // djc, 17 Dec 2000
	apiChild,
	api		: CM_AuditPropertyImage; // djc, 17 Dec 2000
	auditChildSubjects : StringArray;
	row : Integer;
	isTerminalArea	: Boolean;
begin

	tblThumb.clear;
	
	aud := _obj.CM_AuditObject;
	
	setupThumbnailHeadings(aud.type);

	if aud &lt;&gt; null then
		if aud.type = AuditInformation then
			tblThumb.addItem(aud.CM_AuditObjectInformation.info);	// CCMS 1676. Feb 2009
		else
		
			if aud.hasExtraInfo then
				tblThumb.addItem(aud.CM_AuditObjectInformation.info);	// CCMS 1676. Feb 2009
				tblThumb.addItem('');	// add a blank line
			endif;
			
			aoi := aud.getAuditObjectImage();	
			//epr TFS 43546 22/2/19
			create auditChildSubjects transient;
			if aud.mySubject &lt;&gt; null then
				aud.mySubject.getAuditChildSubjects(auditChildSubjects);
			endif;
			
			if aud.myAuditConfig.className = CM_VehicleBookingTimeSlot.name							//23.8.2023 navhl20 #59936
			or aud.myAuditConfig.className = CM_WorkOrder.name then									//30.01.2023 navhl20 #57592
				self.getAuditChildSubjStr(aud,auditChildSubjects);
			endif;
			
			isTerminalArea := aud.myAuditConfig.className = CM_TerminalAreaMaster.name;			//09.01.2025 navnk30 JIRA 19801
			
			if aoi &lt;&gt; null  then		
				foreach api in aoi.allPropertyImages discreteLock do
					if auditChildSubjects.includes(api.name) then
						delete aoiChild;
						create aoiChild transient;
						if api.beforeValue = null  then
							aoiChild.initialise(null,aud.type, null, api.afterValue, null);
						else				
							aoiChild.initialise(null,aud.type, null, api.beforeValue, api.afterValue);				
						endif;
						
						//self.addThumbnailChildHeader(api.name);					//09.01.2025 navnk30 JIRA 19801
						if not isTerminalArea then								//09.01.2025 navnk30 JIRA 19801
							self.addThumbnailChildHeader(api.name);
						else
							oidDecStr := api.name[api.name.pos("/", 1) + 1 : api.name.length];
							obj := oidDecStr.asOid();
							if global.isValidObject(obj) then
								self.addThumbnailChildHeader(oidDecStr.asOid().CM_LocationsController.ident);
							else
								self.addThumbnailChildHeader(api.name);
							endif;
						endif;
						
						foreach apiChild in aoiChild.allPropertyImages discreteLock do
							if aud.type = AuditUpdated and api.beforeValue = null then
								//put str in after column
								str:=apiChild.name &amp;  Tab &amp; Tab &amp; apiChild.beforeValue;
							else
								str := apiChild.getDisplayString();
							endif;
							
							
							row := tblThumb.addItem(str);
							tblThumb.accessCell(row,1).alignment:=Table.Alignment_Right;
						endforeach;
						tblThumb.addItem(null);
					else	
						//02 Apr 2019	NDL	TFS 44140 - superuser gets to see the context if there is one.
						if api.name = CM_AuditObject.CallingFormContext then
							if not app.isSpecial then
								continue;
							endif;
						endif;
						
						str := api.getDisplayString();
						tblThumb.addItem(str);
					endif;
				endforeach;
			endif;
		endif;
	endif;

	if tblThumb.rows &gt; 1 then
		tblThumb.fixedRows := 1;
		tblThumb.fixedColumns := 1;
	endif;
	
	tblThumb.cnEcResizeContents();
	
epilog
	delete aoi;
	delete aoiChild;
	delete auditChildSubjects;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
