    <JadeMethod name="setCamsAttributes" id="86293244-47a5-445c-9b6a-3073b89aa833">
        <updating/>
        <source>setCamsAttributes(_camProtocol, _fileName, _statusName : String; _runDateTime : TimeStamp; _seqNum : Integer; _emailUniqueID : Integer) updating;
// -------------------------------------------
// Created 30 March 2004 by cnwdvb1
// -------------------------------------------
vars

	emailId : String;

begin

	if _emailUniqueID &lt;&gt; 0 then
		emailId := app.getErrorString1(Email_ID, _emailUniqueID.String);
	else
		emailId := app.getErrorString1(Email_ID, app.getErrorString(None_Sent));
	endif;
	if self.description = null then
		self.setDescription(app.getErrorString(MSG_CAMS_TaskFinalised) &amp; ' ' &amp; _camProtocol &amp; ': ' &amp; _fileName &amp; ': ' &amp; emailId);
	endif;
	self.emailUniqueID	:= emailId;
	self.camProtocol	:= _camProtocol;
	self.fileName		:= _fileName;
	self.statusName		:= _statusName;
	self.runDateTime	:= _runDateTime;
	self.seqNumber		:= _seqNum;


end;</source>
        <Parameter name="_camProtocol" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_statusName" type="String"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_seqNum" type="Integer"/>
        <Parameter name="_emailUniqueID" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="dcaba717-6ea6-459a-9d46-e6a4369527a8">
        <updating/>
        <source>setForCreate(_proxy: CM_ActivityHistoryCams) updating;
// -------------------------------------------
// Created 31 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_proxy);
	self.emailUniqueID	:= _proxy.emailUniqueID;
	self.camProtocol	:= _proxy.camProtocol;
	self.fileName		:= _proxy.fileName;
	self.runDateTime	:= _proxy.runDateTime;
	self.seqNumber		:= _proxy.seqNumber;
	self.statusName		:= _proxy.statusName;


end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistoryCams"/>
    </JadeMethod>
</Class>
