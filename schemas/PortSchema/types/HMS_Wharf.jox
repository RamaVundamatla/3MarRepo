    <JadeMethod name="causeHMSEvent" id="bf98c2e5-28e8-4369-ab81-ba4a3e8a40c3">
        <source>causeHMSEvent(_eventMode: Integer);

vars

begin
	if _eventMode = self.EventMode_Delete then
		self.causeEvent(RefreshView, false, self);
	elseif _eventMode = self.EventMode_Update then
		self.causeEvent(RefreshView, false, self);			
	else
		inheritMethod(_eventMode);
	endif;
end;</source>
        <Parameter name="_eventMode" type="Integer"/>
    </JadeMethod>
