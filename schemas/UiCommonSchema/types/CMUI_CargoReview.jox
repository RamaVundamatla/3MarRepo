    <JadeMethod name="setMycriteriaLineHolder" id="834b2e1c-9dd5-4694-9f2d-9b74b5ecb82b">
        <updating/>
        <source>setMycriteriaLineHolder(_newCriteria : CM_QueryCriteriaLineHolder) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries

*/

vars
	criteriaLine : CM_SelectorCriteriaLine;
	idx	: Integer;
begin
	self.myCriteriaLineHolder := _newCriteria;
	// Might wanna set the table
	self.tblCriteria.rows := 0;
	foreach criteriaLine in self.myCriteriaLineHolder.allCriteriaLines discreteLock do
		idx := self.tblCriteria.addItem(criteriaLine.getDescriptionString);
		self.tblCriteria.accessRow(idx).itemObject := criteriaLine;
		self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
	endforeach;
epilog

end;</source>
        <Parameter name="_newCriteria" type="CM_QueryCriteriaLineHolder"/>
    </JadeMethod>
    <JadeMethod name="setPropertyValueAndOperator" id="213556f0-6647-4beb-aa2a-e163f29b4fdb">
        <source>setPropertyValueAndOperator(_existingCriteriaLine : CM_SelectorCriteriaLine) : CM_SelectorCriteriaLine protected;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwth2
//
// Purpose:     _criteriaLine passed will be null if adding a new criteria line, else existing passed in will updated
//				If null passed in and criteria line with existing property exists, it will chuck.
//
//				Returns true if a new line was sucessfully added.
//
// ---------------------------------------------------------------------------
vars
	persistentProp,
	tmpProp			: CM_QueryProperty;
	persistentOp,
	tmpOp			: CM_QueryOperator;
	criteriaLine 	: CM_SelectorCriteriaLine;
	criteriaLineHolder : CM_QueryCriteriaLineHolder;
	tmpDateArray	: DateArray;
	tmpTimeArray : TimeArray;
	tmpIntArray		: IntegerArray;
	value			: Any;
	
begin
	
	criteriaLineHolder := self.myCriteriaLineHolder;
		
	persistentProp		:= self.cmbAttr.listObject.CM_QueryProperty;
	persistentOp 		:= self.cmbOperator.listObject.CM_QueryOperator;
	
	if persistentProp = null or persistentOp = null then
		app.msgBox(app.getErrorString(CMUI_Selector_MustSelAttr), app.getErrorString(InsufficientInput), MsgBox_Exclamation_Mark_Icon);
		return null;
	endif;
	
	tmpProp := persistentProp.cloneSelf(true);
	tmpOp := persistentOp.cloneSelf(true);
	
	// PAR #31155 If we have a measurement type selector option, set the measurement type on the query property	
	if txtArgumentFrom.visible and (not self.txtArgumentTo.visible) then
		value := txtArgumentFrom.text;
		value := tmpProp.translateToSearchValue(value);
		tmpOp.setSearchValue(value);
	elseif self.txtArgumentFrom.visible and self.txtArgumentTo.visible then
		create tmpIntArray transient;
		tmpIntArray.add(self.txtArgumentFrom.text.Integer);
		tmpIntArray.add(self.txtArgumentTo.text.Integer);
		tmpOp.setSearchValue(tmpIntArray);
	elseif cmbArgument.visible then
		value := cmbArgument.listObject;
		//if value = null or value.isKindOf (CM_Bay) then//changed by cnwyl1 for PAR12265 // not the best solution - took out by AER 31/07/08 
		if value = null then
			value := cmbArgument.text;
		endif;
		value := tmpProp.translateToSearchValue(value);

		if value.String = '** not initialised **' then
			value := null;
		endif;
		tmpOp.setSearchValue(value);

	elseif tblArgument.visible or self.frmArgument.visible then
		tmpProp.setValuesFromList(tblArgument, tmpOp);
		self.lblargList.caption := tmpOp.getSearchValueStr(tmpProp);
		
	elseif (self.txtFromDate.visible) and 
	       (not self.txtToDate.visible) then
		value := self.txtFromDate.getDate();
		tmpOp.setSearchValue(value.Date);

	elseif self.txtFromDate.visible and 
	       self.txtToDate.visible then
		create tmpDateArray transient;
		tmpDateArray.add(self.txtFromDate.getDate());
		tmpDateArray.add(self.txtToDate.getDate());
		tmpOp.setSearchValue(tmpDateArray);
	
	elseif (self.txtFromTime.visible) and 
	       (not self.txtToTime.visible) then
		value := self.txtFromTime.getTime();
		tmpOp.setSearchValue(value.Time);

	elseif self.txtFromTime.visible and 
	       self.txtToTime.visible then
		create tmpTimeArray transient;
		tmpTimeArray.add(self.txtFromTime.getTime());
		tmpTimeArray.add(self.txtToTime.getTime());
		tmpOp.setSearchValue(tmpTimeArray);
	endif;
	

	if _existingCriteriaLine &lt;&gt; null then
		criteriaLine := criteriaLineHolder.allCriteriaByPropertyName[tmpProp.propertyName, tmpProp.propertyClassName];
		if (criteriaLine &lt;&gt; null) and (criteriaLine &lt;&gt; _existingCriteriaLine) then
			//there is already a DIFFERENT line with that property, so winge
			app.msgBox(app.getErrorString(CMUI_Selector_DupCriteria), app.getErrorString(CMUI_Selector_Duplicate_Line), MsgBox_Exclamation_Mark_Icon);
			return null;
		else
			criteriaLine := _existingCriteriaLine;
		endif; 
	else
		if criteriaLineHolder.allCriteriaByPropertyName.includesKey(tmpProp.propertyName, tmpProp.propertyClassName) then
			app.msgBox(app.getErrorString(CMUI_Selector_DupCriteria), app.getErrorString(CMUI_Selector_Duplicate_Line), MsgBox_Exclamation_Mark_Icon);
			return null;
		else
			create criteriaLine transient;
		endif;
	endif;
	
	criteriaLine.set(tmpProp, tmpOp, false);
	return criteriaLine;

epilog
	if criteriaLine = null then
		delete tmpProp;
		delete tmpOp;
	endif;
	
	self.cmbAttr.setFocus();
	delete tmpDateArray;
	delete tmpIntArray;
	delete tmpTimeArray;

end;</source>
        <access>protected</access>
        <Parameter name="_existingCriteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="CM_SelectorCriteriaLine"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="0205182b-4de4-4a6d-953c-faaf95db84c3">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:	Stop and exception 	

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2022	jlier1	Initial creation

*/

vars
	jdo : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
begin
	if self.tblCargoGrouped.row &lt;= 1 then
		return;
	endif;
	jdo:=self.tblCargoGrouped.accessRow(self.tblCargoGrouped.row).itemObject.JadeDynamicObject;
	if jdo =null then
		return;
	endif;
	if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then
		self.displayCargoResults(value.CM_TIByCargoTypeIdDict);
	endif;

epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupAdditionalRowsAvailable" id="6bceba62-ce5d-48ff-aa13-0a7f1f1ed48a">
        <updating/>
        <source>setupAdditionalRowsAvailable() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2022	jlier1	Initial creation

*/

vars
	entDef 		: EntTableDef;
	entTableRow : EntTableRow;
begin
	entDef:=app.myController.getEntTableDef(ETDef_CGReviewAdditional);
	create self.allAdditionalRowsAvailable transient;
	foreach entTableRow in entDef.allEntTableRows discreteLock do
		if entTableRow.measurementType = null then
			self.allAdditionalRowsAvailable.add(entTableRow);
			if entTableRow.name.startsWith("pre") or entTableRow.name.startsWith("release") then
				self.allPerformanceRows.add(entTableRow);
			endif;
		else
			self.addMeasurementRow(entTableRow,self.allAdditionalRowsAvailable);
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupArgumentView" id="407035be-5dd6-4ec2-9f8a-a0360e18c781">
        <source>setupArgumentView(_qOperator : CM_QueryOperator) protected;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwth2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Reversed changes made for PAR #17569 to allow null values in combobox
					fields
10 May 2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
04 Oct 2019	jlgdi1	45802 View permission cannot do any update
*/

vars
	prop,
	tmpProp					: CM_QueryProperty;
	controlType				: Integer;
	currentCriteriaLine		: CM_SelectorCriteriaLine;
	criteriaLineHolder		: CM_QueryCriteriaLineHolder;
	enableArgumentChange	: Boolean;
	tbl						: CM_DataTable;
	dateBoxArray,
	textBoxArray,
	timeBoxArray			: ObjectArray;
begin
	tbl := self.tblCriteria;
	criteriaLineHolder := self.myCriteriaLineHolder;

	enableArgumentChange := true;
	
	if self.tblCriteria.accessedRow &lt;&gt; null then
		if self.tblCriteria.accessedRow.itemObject  &lt;&gt; null then
			currentCriteriaLine := tblCriteria.accessedRow.itemObject.CM_SelectorCriteriaLine;
		endif;
	endif;
	
	if currentCriteriaLine &lt;&gt; null then
		if currentCriteriaLine.isUnavailableAtRunTime  then
			enableArgumentChange :=false;
		endif;
	endif;
	
	self.btnUpdate.enabled := enableArgumentChange;
	self.txtFromDate.visible 	:= false;
	self.txtToDate.visible 		:= false;
	self.txtFromTime.visible 	:= false;
	self.txtToTime.visible 		:= false;
	self.lblAnd.visible 		:= false;
	self.txtArgumentFrom.visible 	:= false;
	self.txtArgumentTo.visible 	:= false;
	self.cmbArgument.visible 	:= false;
	self.tblArgument.visible 	:= false;
	self.frmArgument.visible 	:= false;	//05 Sep 2019	NDL	TFS 45891
	
	prop := cmbAttr.listObject.CM_QueryProperty;
	
	if prop = null or
	   _qOperator = null then
		return;
	endif;
	
	tmpProp := prop.cloneSelf(true);																		
	
	controlType := tmpProp.getControlTypeForOperator(_qOperator);
	
	if controlType = QueryControl_TextBox then
		tmpProp.setTextValues(self.txtArgumentFrom, criteriaLineHolder, _qOperator, app.myPassport);
		self.txtArgumentFrom.visible := true;
		self.txtArgumentFrom.enabled := enableArgumentChange;
		
	elseif controlType = QueryControl_ComboBox then
		tmpProp.setComboValues(cmbArgument, criteriaLineHolder, _qOperator, app.myPassport);
		
		self.cmbArgument.visible := true;
		self.cmbArgument.enabled := enableArgumentChange;
		
	elseif controlType = QueryControl_MultiSelect then	
		tmpProp.setListValues(tblArgument, criteriaLineHolder, _qOperator, app.myPassport);
		self.tblArgument.visible := true;
		self.tblArgument.enabled := enableArgumentChange;
		
		//05 Feb 2019	NDL	TFS 45891
		self.frmArgument.visible := true;
		self.frmArgument.enabled := enableArgumentChange;
		self.btnArgFind.enabled := enableArgumentChange;
		self.lblargList.caption := _qOperator.getSearchValueStr(tmpProp);
		
	elseif controlType = QueryControl_Date then
		tmpProp.setDateValues(self.txtFromDate, criteriaLineHolder, _qOperator, app.myPassport);
		self.txtFromDate.visible := true; //always use fromDate box for single date comparison
		self.txtFromDate.enabled := enableArgumentChange;
		
	elseif controlType = QueryControl_DateRange then
		create dateBoxArray transient;
		dateBoxArray.add(self.txtFromDate);
		dateBoxArray.add(self.txtToDate);
		if tmpProp.isKindOf(CM_QDateProperty) then
			tmpProp.CM_QDateProperty.setDateRangeValues(dateBoxArray, criteriaLineHolder, _qOperator, app.myPassport);
		else
			tmpProp.CM_QDateMethod.setDateRangeValues(dateBoxArray, criteriaLineHolder, _qOperator, app.myPassport);	
		endif;
		self.txtFromDate.visible := true;
		self.txtToDate.visible := true;
		self.lblAnd.visible := true;
		
		self.txtFromDate.enabled := enableArgumentChange;
		self.txtToDate.enabled := enableArgumentChange;
		
	elseif controlType = QueryControl_NumTextBoxRange then
		create textBoxArray transient;
		textBoxArray.add(self.txtArgumentFrom);
		textBoxArray.add(self.txtArgumentTo);
		if tmpProp.isKindOf(CM_QDateProperty) then
			tmpProp.CM_QDateProperty.setTextRangeValues(textBoxArray, criteriaLineHolder, _qOperator, app.myPassport);
		else
			tmpProp.CM_QDateMethod.setTextRangeValues(textBoxArray, criteriaLineHolder, _qOperator, app.myPassport);	
		endif;
		self.txtArgumentFrom.visible := true;
		self.txtArgumentTo.visible := true;
		self.lblAnd.visible := true;
		
		self.txtArgumentFrom.enabled := enableArgumentChange;
		self.txtArgumentTo.enabled := enableArgumentChange;
		
	elseif controlType = QueryControl_Time then
		tmpProp.setTimeValues(self.txtFromTime, criteriaLineHolder, _qOperator, app.myPassport);
		self.txtFromTime.visible := true; //always use fromTime box for single date comparison
		self.txtFromTime.enabled := enableArgumentChange;
	
	elseif controlType = QueryControl_TimeRange then
		create timeBoxArray transient;
		timeBoxArray.add(self.txtFromTime);
		timeBoxArray.add(self.txtToTime);
		tmpProp.CM_QTimeMethod.setTimeRangeValues(timeBoxArray, criteriaLineHolder, _qOperator, app.myPassport);
		self.txtFromTime.visible := true;
		self.txtToTime.visible := true;
		self.lblAnd.visible := true;
		
		self.txtFromTime.enabled := enableArgumentChange;
		self.txtToTime.enabled := enableArgumentChange;
	endif;

epilog
	delete dateBoxArray;
	delete textBoxArray;
	delete timeBoxArray;
	delete tmpProp;																								// PAR #31155
end;</source>
        <access>protected</access>
        <Parameter name="_qOperator" type="CM_QueryOperator"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0ed47f88-4e76-4864-9d24-20ccd4f24e38">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2022	jlier1	Initial creation
17/03/2023	navkc1	Bug 56487: EUP - Cannot send all the Search Results to a Report/Summary
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes
*/

vars
	
begin
	
	inheritMethod();
	
	self.btnDown.caption := 226.Character; 
	self.btnDown.fontName := "Wingdings";	
	self.btnUp.caption := 225.Character;	
	self.btnUp.fontName := "Wingdings";	
	self.tblCriteria.columns := 1;
	self.tblCriteria.rows := 0;
	self.loadAttrCombo();
	
	
	self.setupGroupingRowsAvailable();
	self.setupAdditionalRowsAvailable();
	
	self.tblCargo.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_LlHeadings ));
	
	self.tblCargoGrouped.selectMode:= Table.SelectMode_WholeRows;
	self.tblCargoGrouped.selectionType := CM_DataTable.SelectionType_Row;
	self.tblCargoGrouped.multiSelect := CM_DataTable.MultiSelect_Simple; // 17/03/2023	navkc1	#56487
	self.tblCargo.selectMode:= Table.SelectMode_WholeRows;
	self.tblCargo.selectionType := CM_DataTable.SelectionType_Row;
	self.tblCargo.multiSelect := CM_DataTable.MultiSelect_Simple; //19/07/2023 navmv20 CR 58239 Task 58241
	
	self.btnModalOpt2.width:=self.btnModalOpt2.width+ 20;
	
	self.getXMLSettingsForSetup();
	self.createDefaultCriteriaLines();
	/* Moved to ToolBar //02/10/2023	navkc1	CR 60423 Task 60764
	if not app.myCurrentUserCan(self.myTerminal,PmYardMoveMaint) then
		self.btnGroupMove2.visible:=false;
	endif;
	*/
	self.mnuCGSendSummary.visible:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	self.setCriteriaLabel();
	
	//02/10/2023	navkc1	CR 60423 Task 60763
	if app.myCurrentUserCan(self.myTerminal, PmCargoReviewCustDocSummary) then
		self.btnShowTblSummary.visible := true;
	endif;
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.showToolbarCaptions := false;
	
	self.doInitQueryFolder();
	self.initCustDocTable();
	
	self.frmTableFilterGroup.setupControl(self.tblCargoGrouped, null);		//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTableFilterCargo.setupControl(self.tblCargo, null);				//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTableFilterCustDoc.setupControl(self.tblCustomDocument, null);	//05/06/2024	navkc1 CR 63736 Task 63770
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupGroupingRowsAvailable" id="cf55b9c6-c367-4c6f-91f1-748be54d93f2">
        <updating/>
        <source>setupGroupingRowsAvailable() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2022	jlier1	Initial creation

*/

vars
	entDef 		: EntTableDef;
	entTableRow : EntTableRow;
begin
	entDef:=app.myController.getEntTableDef(ETDef_CGReviewGrouping);
	create self.allGroupingRowsAvailable transient;
	foreach entTableRow in entDef.allEntTableRows discreteLock do
		if entTableRow.measurementType = null then
			self.allGroupingRowsAvailable.add(entTableRow);
		else
			self.addMeasurementRow(entTableRow,self.allGroupingRowsAvailable);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showContextMenu" id="8fcd466c-121c-4a36-b501-6444ec5c73d6">
        <updating/>
        <source>showContextMenu(pMenuItem: MenuItem; cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jun 2022	jlier1	Initial creation
19 Jul 2023	navmv20	CR 58239 Task 58241: UI- Open COO Maint in Update mode
10 Sep 2025	navdap1	MTN-35615 ENS | Bulk Creation of Yard Allocations
*/

vars
	
begin
	self.mnuCGBulkEdit.visible:= app.myCurrentUserCan(self.myTerminal, PmAdmCargoEnquiryMaint); 
	self.mnuCreateRelReq.visible:=app.myCurrentUserCan(self.myTerminal, PmGteEmptyReleaseMaintAll);
	// ### JIRA 33499 06JAN2025 NAVAB1
	/*
	self.mnuOwnershipChange.visible:=app.myCurrentUserCan(self.myTerminal, PmInvOwnershipChangeMaintMaint);
	self.mnuOwnershipChangeTi.visible:=app.myCurrentUserCan(self.myTerminal, PmInvOwnershipChangeMaintMaint);
	*/
	if app.myRoot.canDo(Sub_OwnershipChange) then
		self.mnuOwnershipChange.visible := app.myCurrentUserCan(self.myTerminal, PmInvOwnershipChangeMaintMaint);
		self.mnuOwnershipChangeTi.visible := self.mnuOwnershipChange.visible;
	else
		self.mnuOwnershipChange.visible := false;
		self.mnuOwnershipChangeTi.visible := false;
	endif;
	
	// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	// ### JIRA 33499 06JAN2025 NAVAB1
	/*
	//02/10/2023	navkc1	CR 60423 Task 60763
	self.mnuCustDocsSummary.visible := app.myCurrentUserCan(self.myTerminal, PmCargoReviewCustDocSummary);
	self.mnuCustDocsTISummary.visible := app.myCurrentUserCan(self.myTerminal, PmCargoReviewCustDocSummary);
	self.mnuCustDocs.visible:=app.myCurrentUserCan(self.myTerminal, PmAdmCustDocMaintMaint);
	self.mnuCustDocsTI.visible:=app.myCurrentUserCan(self.myTerminal, PmAdmCustDocMaintMaint);
	self.mnuCustDocsCreateAdmin.visible := app.myCurrentUserCan(self.myTerminal, PmAdmCompanyCustDocMaint);
	self.mnuCustDocsTICreateAdmin.visible := app.myCurrentUserCan(self.myTerminal, PmAdmCompanyCustDocMaint);
	*/
	if app.myRoot.canDo(Sub_CustomDocuments) then
		self.mnuCustDocsSummary.visible := app.myCurrentUserCan(self.myTerminal, PmCargoReviewCustDocSummary);
		self.mnuCustDocsTISummary.visible := self.mnuCustDocsSummary.visible;
		self.mnuCustDocs.visible:=app.myCurrentUserCan(self.myTerminal, PmAdmCustDocMaintMaint);
		self.mnuCustDocsTI.visible:=self.mnuCustDocs.visible;
		self.mnuCustDocsCreateAdmin.visible := app.myCurrentUserCan(self.myTerminal, PmAdmCompanyCustDocMaint);
		self.mnuCustDocsTICreateAdmin.visible := self.mnuCustDocsCreateAdmin.visible;
	else
		self.mnuCustDocsSummary.visible := false;
		self.mnuCustDocsTISummary.visible := false;
		self.mnuCustDocs.visible:= false;
		self.mnuCustDocsTI.visible := false;
		self.mnuCustDocsCreateAdmin.visible := false;
		self.mnuCustDocsTICreateAdmin.visible := false;
	
	endif;
	
	// MTN-35615 show / hide Bulk YA menu items
	if app.getMyUser.canDo(self.myTerminal, PmAdmBulkYAMaint) then
		self.mnuBulkYAExports.visible := true;
		self.mnuBulkYAImports.visible := true;
	else
		self.mnuBulkYAExports.visible := false;
		self.mnuBulkYAImports.visible := false;
	endif;
	// MTN-35615 end
	
	return inheritMethod(pMenuItem, cntrl, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="pMenuItem" type="MenuItem"/>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblCargoGrouped_click" id="29062ea0-946f-4331-ac8c-1898aab74e53">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargoGrouped_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2022	jlier1	Initial creation
08/09/2023	navkc1	CR 60429 Task 60446: UI - Cargo Review UI Changes - FIlter and Totals
02/10/2023	navkc1	CR 60423 Task 60764: UI - Cargo Review Cust Doc Summary
01/11/2023	navkc1	Bug 61059: FR | 53715 - EUP - Customs - Cargo review screen enhancements
*/

vars
	jdo : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	cargoDict	: CM_TIByCargoTypeIdDict;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, jdo, invalid);
	
	//jlier1 TFS 54102 12/7/22
	if table.row &lt; 1 then
		return;
	endif;
	
	//02/10/2023	navkc1	CR 60423 Task 60764
	if self.tblCustomDocument.rows &gt; self.tblCustomDocument.fixedRows and
		not hasAcknowledgedClearCustDoc //01/11/2023	navkc1	Bug 61059
		then
		self.hasAcknowledgedClearCustDoc := true;//01/11/2023	navkc1	Bug 61059
		if app.msgBox("Do you want to clear the custom document table?", app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			self.tblCustomDocument.rows := self.tblCustomDocument.fixedRows;
		endif;
	endif;
	
	jdo:=table.accessRow(table.row).itemObject.JadeDynamicObject;
	if jdo =null then
		return;
	endif;
	
	//08/09/2023	navkc1	CR 60429 Task 60446
	/*if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then
		self.displayCargoResults(value.CM_TIByCargoTypeIdDict);
	endif;*/
	
	create cargoDict transient;
	
	foreach jdo in table.CM_DataTable.allSelectedObjects as JadeDynamicObject do
		//11/06/2024	navkc1 Bug 64543
		if invalid then
			continue;
		endif;
		
		if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then
			value.CM_TIByCargoTypeIdDict.copyNoDuplicates(cargoDict, false);
		endif;
	endforeach;
	
	self.displayCargoResults(cargoDict);
	
epilog
	delete cargoDict;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCargoGrouped_contextMenu" id="e34f504e-f65a-491d-9b2e-6fe770b20361">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargoGrouped_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2022	jlier1	Initial creation
05/07/2023 navmv20 CR 58410 Task 58414: UI - Cargo Review - Grouping Table
*/

vars

begin
	
	if table.CM_DataTable.allSelectedObjects.size &gt; 0 then
		//05/07/2023 navmv20 CR 58410 Task 58414 - start
		if app.isAllowedToInspect then
			self.mnuInspectJdo.visible := true;
		else
			self.mnuInspectJdo.visible := false;	
		endif;
		//05/07/2023 navmv20 CR 58410 Task 58414 - end
		return self.showContextMenu(self.mnuGroupContext,table,conwin,mouse,x,y);
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblCargoGrouped_dblClick" id="bc18d0f0-9b85-43d6-96b7-804e92533430">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargoGrouped_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2022	jlier1	Initial creation
11/03/2024	navcs2	MTN-34327 CUX | Cargo Review Screen - Weight sorting alphabetically
*/

vars

	jdo : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	tiArray : CM_TIArray;
	currentEntRow, entRow	: EntTableRow;	// 11/03/2024	navcs2	MTN-34327
begin
	//jlier1 TFS 54102 12/7/22
	if table.row &lt; 1 then
		return;
	endif;
	
	foreach entRow in self.allAdditionalRows do																// 11/03/2024	navcs2	MTN-34327
		if table.sortColumn[1] &lt;&gt; null then																	// 11/03/2024	navcs2	MTN-34327
			if entRow.getHeading(null, null, null) = table.accessCell(1,table.sortColumn[1]).text then		// 11/03/2024	navcs2	MTN-34327
				currentEntRow := entRow;																	// 11/03/2024	navcs2	MTN-34327
			endif;																							// 11/03/2024	navcs2	MTN-34327
		endif;																								// 11/03/2024	navcs2	MTN-34327
	endforeach;																								// 11/03/2024	navcs2	MTN-34327
	
	if currentEntRow = null then																			// 11/03/2024	navcs2	MTN-34327
		foreach entRow in self.allGroupingRows do															// 11/03/2024	navcs2	MTN-34327
		if table.sortColumn[1] &lt;&gt; null then																	// 11/03/2024	navcs2	MTN-34327
			if entRow.getHeading(null, null, null) = table.accessCell(1,table.sortColumn[1]).text then		// 11/03/2024	navcs2	MTN-34327
				currentEntRow := entRow;																	// 11/03/2024	navcs2	MTN-34327
			endif;																							// 11/03/2024	navcs2	MTN-34327
		endif;																								// 11/03/2024	navcs2	MTN-34327
		endforeach;																							// 11/03/2024	navcs2	MTN-34327
	endif;																									// 11/03/2024	navcs2	MTN-34327
	
	// ### TFS CR 60424 TASK 60549 19SEP2023 NAVAB1
	if table.row = table.fixedRows then
		if table.sortColumn[1] &gt; 0 then
			table.accessCell(1,table.sortColumn[1]).fontBold := false;
		endif;
		if currentEntRow &lt;&gt; null then																		// 11/03/2024	navcs2	MTN-34327
			table.CM_DataTable.resortTableByColumnEntRow(table.column, currentEntRow);						// 11/03/2024	navcs2	MTN-34327
		else																								// 11/03/2024	navcs2	MTN-34327
			table.CM_DataTable.resortTableByColumn(table.column);											// 11/03/2024	navcs2	MTN-34327
		endif;																								// 11/03/2024	navcs2	MTN-34327
		table.accessCell(1,table.column).fontBold := true;
		return;
	endif;

	jdo:=table.accessRow(table.row).itemObject.JadeDynamicObject;
	if jdo =null then
		return;
	endif;
	if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then
		
		create tiArray transient;
		value.CM_TIByCargoTypeIdDict.copy(tiArray);
		self.myAssistant.showCargoEnquiryForTIs(tiArray.first, tiArray,self.myMasterMenuAction, false);
		
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCargoGrouped_gotFocus" id="8291d42e-f846-423c-872a-a32390e7a279">
        <controlMethod name="CM_DataTable::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargoGrouped_gotFocus(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60764: UI - Cargo Review Cust Doc Summary

*/

vars

begin
	self.myCurrentTable := table;
	self.doDeselectOtherTables(table);
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCargo_click" id="3759f9f7-7459-4af3-86a7-82273be080fd">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_click(table: CM_DataTable input) updating;
/*
Purpose:			

Date		Who		Reason
21 August 2023	navab1	CR 59615 TASK 59620
08/09/2023	navkc1	CR 60429 Task 60446: UI - Cargo Review UI Changes - FIlter and Totals
02/10/2023	navkc1	CR 60423 Task 60764: UI - Cargo Review Cust Doc Summary
01/11/2023	navkc1	Bug 61059: FR | 53715 - EUP - Customs - Cargo review screen enhancements
*/

vars
	ti	: CM_TrackedItem;
	pendingQty,
	clearedQty,
	qty : Integer;
	pendingWeight,
	clearedWeight,
	weight,
	pendingVol,
	clearedVol,
	volume : Decimal[23,4];
begin	
	//02/10/2023	navkc1	CR 60423 Task 60764
	if self.tblCustomDocument.rows &gt; self.tblCustomDocument.fixedRows and
		not hasAcknowledgedClearCustDoc //01/11/2023	navkc1	Bug 61059
		then
		self.hasAcknowledgedClearCustDoc := true; //01/11/2023	navkc1	Bug 61059
		if app.msgBox("Do you want to clear the custom document table?", app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			self.tblCustomDocument.rows := self.tblCustomDocument.fixedRows;
		endif;
	endif;
	
	foreach ti in table.allSelectedObjects as CM_TrackedItem do
		qty += ti.totalQuantity;
		weight += ti.totalWeight;
		volume += ti.totalVolume;
		
		//06/03/2023	navkc1 CR 62396 Task 62398
		pendingQty += ti.getCustDocsPendingQuantity();
		clearedQty += ti.getCustDocsClearedQuantity();
		
		//06/03/2023	navkc1 CR 62396 Task 62398
		pendingVol += ti.getCustDocsPendingVolume();
		clearedVol += ti.getCustDocsClearedVolume();
		
		//06/03/2023	navkc1 CR 62396 Task 62398
		pendingWeight += ti.getCustDocsPendingWeight();
		clearedWeight += ti.getCustDocsClearedWeight();
	endforeach;
	
	self.displayStatusLine(qty, pendingQty, clearedQty, weight, pendingWeight, clearedWeight, volume, pendingVol, clearedVol);
	
	self.mnuInspectObject.userObject := ti;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCargo_contextMenu" id="7ff6006d-960a-47d7-aafc-0b569539de8a">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_contextMenu(table: CM_DataTable input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2022	jlier1	Initial creation
05/07/2023 navmv20 CR 58410 Task 58414: UI - Cargo Review - Grouping Table
*/

vars
	ti : CM_TrackedItem;
begin
	//08/09/2023	navkc1	CR 60429 Task 60447
	self.mnuCargoMerge.visible := false;
	self.mnuCargoSplit.visible := false;
	
	//05/07/2023 navmv20 CR 58410 Task 58414 - start
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;
	//05/07/2023 navmv20 CR 58410 Task 58414 - end
	
	//08/09/2023	navkc1	CR 60429 Task 60447
	if table.allSelectedObjects.size() = 1 then
		ti := table.allSelectedObjects.first().CM_TrackedItem;
		if ti.canMergeBreakBulk() and ti.isOnSite() then
			self.mnuCargoMerge.visible := true;
			self.mnuCargoMerge.userObject := ti;
		endif;
		
		if ti.canSplitTotalQuantity() and (ti.isOnSite() or ti.isOnShip()) then
			self.mnuCargoSplit.visible := true;
			self.mnuCargoSplit.userObject := ti;
		endif;
	endif;	
	
	return self.showContextMenu(self.mnuCargoContext,table,conwin,mouse,x,y);
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblCargo_dblClick" id="efa50e4b-d66d-4bd8-898d-7efd7ec43fca">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2022	jlier1	Initial creation
12 Nov 2024 navrv30 JIRA Bug MTN-13946: CUX | Cargo Review Screen Issues
*/

vars
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	theRow	: Integer;
begin	
	if table.accessedRow = null then
		return;
	endif;
	
	theRow := table.row;
	if theRow &lt;= 0 then
		return;
	endif;
	
	//12 Nov 2024 navrv30 JIRA Bug MTN-13946
	if theRow = 1 then	
		if table.sortColumn[1] &gt; 0 then
			table.accessCell(1,table.sortColumn[1]).fontBold := false;
		endif;
		table.CM_DataTable.resortTableByColumn(table.column);
		table.accessCell(1,table.column).fontBold := true;
	else 
		ti:=table.accessedRow.itemObject.CM_TrackedItem;
		if ti = null then
			return;
		endif;
		create tiArray transient;
		tiArray.add(ti);
		self.myAssistant.showCargoEnquiryForTIs(tiArray.first, tiArray,self.myMasterMenuAction, false);
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
