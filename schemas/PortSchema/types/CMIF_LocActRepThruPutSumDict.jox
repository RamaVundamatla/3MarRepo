<CollClass name="CMIF_LocActRepThruPutSumDict" id="70aab462-c981-43c4-a0f2-92917291556e">
    <loadFactor>66</loadFactor>
    <memberType name="CMIF_LocActRepThroughPutSum"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <MemberKey>
        <property name="CMIF_LocActRepThroughPutSum::yearMonth"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_LocActRepThroughPutSum::myOperator"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_LocActRepThroughPutSum::myCargoType"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_LocActRepThroughPutSum::typeString"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_LocActRepThroughPutSum::modeString"/>
    </MemberKey>
    <JadeMethod name="addLocationActivity" id="a6132461-02b7-4ea2-ae87-6c553d7cadbd">
        <lockReceiver/>
        <updating/>
        <source>addLocationActivity( _locAct : CMEVT_LocationActivity; _serviceDate : Date; _count : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	cmif : CMIF_LocActRepThroughPutSum;
	yearMonth : Integer;
	cargoType : CM_CargoType;
	operator : CM_Operator;

begin

	yearMonth := _serviceDate.year * 100 + _serviceDate.month; 
	operator := _locAct.getOperator;
	cargoType := _locAct.getCargoType;
	
	cmif := self.getAtKey( yearMonth, operator, cargoType, _locAct.directionType, _locAct.directionMode );
	if cmif = null then
		create cmif transient;
		cmif.setFromLocationActivity( _locAct, yearMonth, _count );
		self.add( cmif );
	else
		cmif.incrementCountWeight( _locAct, _count );
	endif;

epilog

end;</source>
        <Parameter name="_locAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_serviceDate" type="Date"/>
        <Parameter name="_count" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCalculateYTD" id="5fd95dae-10f7-4830-831f-26273b2b4290">
        <lockReceiver/>
        <updating/>
        <source>doCalculateYTD( _startOfYearDate : Date; _selectedMonth : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	selectedYearMonth : Integer;

	otherMonthDict : CMIF_LocActRepThruPutSumDict;
	selectedMonthDict : CMIF_LocActRepThruPutSumDict;
	
	iter : Iterator;
	
	tPutSum : CMIF_LocActRepThroughPutSum;
	currentTputSum : CMIF_LocActRepThroughPutSum;

begin

	selectedYearMonth := _startOfYearDate.year * 100 + _selectedMonth;

	//copy all summmary lines into one or other of the local dicts.
	create selectedMonthDict transient; //summaries for the selected month
	create otherMonthDict transient;	//the summaries for all other months
	
	iter := self.createIterator;
	while iter.next( tPutSum ) do
		if tPutSum.yearMonth = selectedYearMonth then
			selectedMonthDict.add( tPutSum );
		else
			otherMonthDict.add( tPutSum );
		endif;
	endwhile;
	delete iter;
	
	
	//for each of the other month summaries, we need to add their count and weight
	//values into the YTD figures of the corresponding summary for the current month.
	//(If there isn't a current summary we have to create it first)
	
	iter := otherMonthDict.createIterator;
	while iter.next( tPutSum ) do
		currentTputSum := selectedMonthDict.getAtKey( selectedYearMonth, tPutSum.myOperator, tPutSum.myCargoType, tPutSum.typeString, tPutSum.modeString );
		if currentTputSum = null then
			create currentTputSum transient;
			currentTputSum.setFromLocActRepThroughPutSum( tPutSum, selectedYearMonth );
			self.add( currentTputSum );
			selectedMonthDict.add( currentTputSum );
		endif;
		currentTputSum.incrementYTDCountWeight( tPutSum.weight, tPutSum.count );
	endwhile;
	delete iter;
	
	//for each of the selected month summaries, we need to add their own count and weight
	//values into the YTD figures.
	
	iter := selectedMonthDict.createIterator;
	while iter.next( tPutSum ) do
		tPutSum.incrementYTDCountWeight( tPutSum.weight, tPutSum.count );
	endwhile;
	delete iter;
	
	//And now we delete all of the summaries that are not for the selected month, because apparently our report writer experts don't know how to skip over this data.
	//And off course they will never need it!
	iter := otherMonthDict.createIterator;
	while iter.next( tPutSum ) do
		self.remove( tPutSum );
	endwhile;
	delete iter;
	otherMonthDict.purge();

epilog

	delete selectedMonthDict;
	delete otherMonthDict;
	delete iter;

end;</source>
        <Parameter name="_startOfYearDate" type="Date"/>
        <Parameter name="_selectedMonth" type="Integer"/>
    </JadeMethod>
</CollClass>
