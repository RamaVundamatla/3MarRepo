//
// --------------------------------------------------------------------------------
begin
	return "Release Request";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="aa1be475-629d-4179-95b3-12c0d4022551">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return _cmifAutoPlan.isRailReleaseReq_Match(_yaData);
	
	// actually this is ANY bulk release....


end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
