    <JadeMethod name="doSendHTTPRequest" id="d8000b0a-ae10-4bc8-a483-0139c8b5e271">
        <updating/>
        <source>doSendHTTPRequest(_url: String; _verb: String; _additionalHeaders: String; _putPostData: String; _resultCode: Integer output): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2022	navpw1	Initial creation TFS: 55215
02 July 	2024	navhn30 Bug 64876: CUX - Outbound API messages to EDBIC are sent with "CONTENT_TYPE" of "text/plain", but should be "application/json"
*/

begin
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending HTTP Request to EDBIC", LogINFO);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "url is '" &amp; _url &amp; "'", LogINFO);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Data is '" &amp; _putPostData &amp; "'", LogINFO);
	
	return inheritMethod(_url, _verb, _additionalHeaders, _putPostData, _resultCode);		// 02.07.24		navhn30 	TFS #64876
	
end;</source>
        <Parameter name="_url" type="String"/>
        <Parameter name="_verb" type="String"/>
        <Parameter name="_additionalHeaders" type="String"/>
        <Parameter name="_putPostData" type="String"/>
        <Parameter name="_resultCode" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAdditionalHeadersForHTTP" id="b9165264-c64e-4561-8d65-c27c013bcbb5">
        <source>getAdditionalHeadersForHTTP(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2024	navhn30	Initial creation

*/

vars
	header : String;
begin
	header := inheritMethod();
	header := header &amp; "Content-Type: application/json";
	return header;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sendRailReceivalToEDBIC" id="30ea2f3c-0926-4504-8cf9-c6bb7ad6ac71">
        <updating/>
        <source>sendRailReceivalToEDBIC(_activeCuxportExtDef : CM_CuxportServiceDef; _trackedItem : CM_TrackedItem; _terminal : CM_Terminal) : Boolean updating;
/*

Purpose:			User Story 57370.080 Send Export Cargo Details to EDBIC for Cargo Received via Rail

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022	navpw1	Initial creation TFS: 55215
11 Apr 2023	navdap1	TFS 57362 CUX CHanges to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
*/

vars
	extWebservice 			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	cargo					: CMIF_JsonCargoCUX;
	jsonPostData,
	methodType,
	endpointPath			: String;
	
begin
	//Each of these methods should first check for an active CM_CuxportServiceDef web service definition - if none found, just return.
	extWebservice := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_RailReceivalEDBIC );	// TFS 58722
	if extWebservice &lt;&gt; null and extWebservice.isEDBIC then									// TFS 58722
		activeCuxPortInterface := extWebservice.CM_CuxportServiceDef;						// TFS 58722
	endif;																					// TFS 58722
	
	if activeCuxPortInterface = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Rail Receival Cuxport Interface defined", LogDEBUG);
		app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Rail Receival Cuxport Interface defined");
		return false;																		// TFS 58722
	endif;
	
	create cargo transient;
	cargo.setFromTI(_trackedItem, true);
	
	cargo.deserializeJSON(jsonPostData);													// TFS 57362
	app.writeLog(method.qualifiedName &amp; Tab &amp; "jsonPostData is " &amp; jsonPostData, LogDEBUG);	// TFS 57362
	
	// TFS 57207 start
	activeCuxPortInterface.getEndpointMethodAndValue(ETRow_RailReceivalEDBIC, methodType, endpointPath);
	if methodType = null or endpointPath = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_RailReceivalEDBIC &amp; " messages", LogERROR);
		app.doRaiseAlert(activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_RailReceivalEDBIC &amp; " messages");
		return true;
	endif;
	// TFS 57207 end
	self.sendToEDBIC(method.qualifiedName, activeCuxPortInterface.baseEndpoint &amp; "/" &amp; endpointPath, methodType, jsonPostData, _terminal, activeCuxPortInterface);
	return true;
	
epilog
	delete cargo;
end;</source>
        <Parameter name="_activeCuxportExtDef" type="CM_CuxportServiceDef"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendRoadReceivalToEDBIC" id="5ed0b973-ed11-42b4-87bf-81c2a8e3a179">
        <updating/>
        <source>sendRoadReceivalToEDBIC(_activeCuxPortInterface : CM_CuxportServiceDef; _vehicleVisitRecord : CM_VehicleVisitRecord; _terminal : CM_Terminal) : Boolean updating;
/*

Purpose:			User Story 53730.020 - Send Cargo Details for Cargo Received at the Gate House

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022	navpw1	Initial creation TFS: 55215
03 Apr 2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
*/

vars
	extwebService			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	gteEntity				: CMGTE_Entity;
	cargoOnly				: CMIF_JsonCargoOnlyCUX;
	cargo					: CMIF_JsonCargoCUX;
	jsonPostData,
	methodType,
	endpointPath			: String;
	
begin
	extwebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_RoadReceivalEDBIC );	// TFS 58722
	if extwebService &lt;&gt; null and extwebService.isEDBIC then									// TFS 58722
		activeCuxPortInterface := extwebService.CM_CuxportServiceDef;						// TFS 58722
	endif;																					// TFS 58722
	
	if activeCuxPortInterface = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Road Receival Cuxport Interface defined", LogERROR);
		app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Road Receival Cuxport Interface defined");
		return false;
	endif;
	
	create cargoOnly transient;
	foreach gteEntity in _vehicleVisitRecord.allGateEntities do
		if not gteEntity.isRecievalByType and gteEntity.isReceipt then	//15.Mar.24 navsp1 TFS 62947
			create cargo transient;
			cargo.setFromGTEReceival(gteEntity.CMGTE_Receival);
			cargoOnly.cargo.add(cargo);
		endif;
	endforeach;
	// any data to send?
	if cargoOnly.cargo.isEmpty then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No receival cargo for visit " &amp; _vehicleVisitRecord.visitNumber &amp; " - no message sent", LogDEBUG);
		return true;
	endif;
	
	cargoOnly.deserializeJSON(jsonPostData);												// TFS 57362
	app.writeLog(method.qualifiedName &amp; Tab &amp; "jsonPostData is " &amp; jsonPostData, LogDEBUG);	// TFS 57362
	
	// TFS 57207 start
	activeCuxPortInterface.getEndpointMethodAndValue(ETRow_RoadReceivalEDBIC, methodType, endpointPath);
	if methodType = null or endpointPath = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_RoadReceivalEDBIC &amp; " messages", LogERROR);
		app.doRaiseAlert(activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_RoadReceivalEDBIC &amp; " messages");
		return true;
	endif;
	// TFS 57207 end
	self.sendToEDBIC(method.qualifiedName, activeCuxPortInterface.baseEndpoint &amp; "/" &amp; endpointPath, methodType, jsonPostData, _terminal, activeCuxPortInterface);
	return true;
	
epilog
	delete cargoOnly;
end;</source>
        <Parameter name="_activeCuxPortInterface" type="CM_CuxportServiceDef"/>
        <Parameter name="_vehicleVisitRecord" type="CM_VehicleVisitRecord"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendShipReceivalToEDBIC" id="f8ba88a5-b76f-4940-9677-eae371cbf623">
        <updating/>
