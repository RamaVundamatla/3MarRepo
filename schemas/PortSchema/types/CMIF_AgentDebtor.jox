<Class name="CMIF_AgentDebtor" id="456daa64-d213-4682-a026-80066a72acb6">
    <superclass name="CMIF_Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Par 33497 CCMS GLT 2342 quick create of consignee and cash-only debtor.
Used as input parameter to create and update trx methods.</text>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="agentCode" id="43b11af3-35cb-4f30-8fa3-91ee8e0c3b1e">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <text>Consignee/Consignor/freight forwarder code (5)
Customs agent code (10)</text>
    </PrimAttribute>
    <PrimAttribute name="agentDescription" id="01bdda18-d37d-40c1-9aaf-cab04d4a0cae">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Consignee/consignor/freight forwarder description (30)
Customs agent name (30)</text>
    </PrimAttribute>
    <PrimAttribute name="agentType" id="ef485908-2422-428b-9898-2d0a92eed3a8">
        <embedded/>
        <type name="Integer"/>
        <text>See Global constant category ConsigneeConsignorTypes
CONSIGNOR = 1, FREIGHT_FORWARDER = 2, CONSIGNEE = 3, CUSTOMS_AGENT = 4</text>
    </PrimAttribute>
    <PrimAttribute name="debtorAddress" id="76294351-c595-4489-be3d-a1804886fb3e">
