Date		Who		Reason
06 September 2018	jlger1	Initial creation

*/

vars

begin
	self.jtxtMessages.findAgain(1);
epilog	

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="7e837241-5d7d-4144-b034-7b975948ba5d">
        <updating/>
