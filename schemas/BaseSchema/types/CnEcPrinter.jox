    <DbClassMap file="baserep"/>
    <ImplicitInverseRef name="myFile" id="928716d8-8caa-49c2-92d2-4b59bee76e17">
        <embedded/>
        <type name="File"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="print" id="23b9717f-5bed-4b7c-b029-ab1fe5672340">
        <updating/>
        <source>print(pFrameObj:Frame input): Integer updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		If the reference to myFile is null, then output will be printed
//				normally, otherwse the output will be written to the disk file
//				in CSV format.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	DOUBLE_QUOTE	: String = J_key_DoubleQuote.Character.String;

vars
	fileRecord		: String;
	labelText		: String;
	controlObj		: Control;
	parentFormObj	: Form;
	controlIndex	: Integer;
	noOfControls	: Integer;
	isFirstControl	: Boolean;

begin
	if self.myFile = null or (not pFrameObj.isKindOf(CnEcPrintFrame)) then
		return inheritMethod(pFrameObj);
	else
		// Now write out the contents of the frame's label.

		fileRecord		:=	"";
		parentFormObj	:=	pFrameObj.parent.Form;
		isFirstControl	:=	true;
		noOfControls	:=	parentFormObj.controlCount;
		controlIndex	:=	1;

		foreach controlIndex in 1 to noOfControls do
			controlObj	:=	parentFormObj.controls(controlIndex);

			if	(controlObj.parent = pFrameObj)			and
				(controlObj.isKindOf(CnEcPrintFrame))	then

				labelText	:=	controlObj.CnEcPrintLabel.caption.trimBlanks;

				if (pFrameObj.CnEcPrintFrame.isHeader) then
					if (controlObj.CnEcPrintLabel.isColumnHeading) then
						if (isFirstControl) then
							fileRecord	:=	DOUBLE_QUOTE &amp; labelText &amp; DOUBLE_QUOTE;
						else
							fileRecord	:=	fileRecord &amp; "," &amp; DOUBLE_QUOTE &amp; labelText &amp; DOUBLE_QUOTE;
						endif;

						if (isFirstControl) then
							isFirstControl	:=	false;
						endif;
					endif;
				else
					if (isFirstControl) then
						fileRecord	:=	DOUBLE_QUOTE &amp; labelText &amp; DOUBLE_QUOTE;
					else
						fileRecord	:=	fileRecord &amp; "," &amp; DOUBLE_QUOTE &amp; labelText &amp; DOUBLE_QUOTE;
					endif;

					if (isFirstControl) then
						isFirstControl	:=	false;
					endif;
				endif;
			endif;
		endforeach;

		self.myFile.writeLine(fileRecord);
		return Print_Successful;
	endif;
end;</source>
        <Parameter name="pFrameObj" type="Frame" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFile" id="203f7ba6-177f-4017-80d9-60e2d96db3b6">
        <updating/>
        <source>setFile(pFileObj:File) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Sets a reference to a file to write output to.
//
// Parameters:	pFile - A reference to the output file object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myFile &lt;&gt; pFileObj then
		self.myFile	:=	pFileObj;
	endif;
end;</source>
        <Parameter name="pFileObj" type="File"/>
    </JadeMethod>
</Class>
