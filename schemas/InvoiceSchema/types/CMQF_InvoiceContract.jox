<Class name="CMQF_InvoiceContract">
    <JadeMethod name="setFilters" id="9aaf2759-fb32-48e1-913a-13e04b598f4f">
        <updating/>
        <source>setFilters(_obj : INV_ContractEnquiry) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results

*/

vars

begin

	
	//Contract Filter Attributes
	
	self.setMyBusinessUnit(_obj.myCurrentBank);													//14.10.2024 navlc30 #19508
	self.contractId := _obj.filterQueryContract;
	self.isPrimary := _obj.filterQueryPrimary;		
	self.isActive	:= _obj.filterQueryActive;
	self.description := _obj.filterQueryDescription;
	
	self.allDebtors.clear();
	_obj.allDebtors.copy(self.allDebtors);

	self.contractFromEndDate   := _obj.filterQueryContractFromEnd.Date;
	self.contractFromStartDate := _obj.filterQueryContractFromStart.Date;
	self.contractToEndDate 	   := _obj.filterQueryContractToEnd.Date;
	self.contractToStartDate   := _obj.filterQueryContractToStart.Date;

	
	
	//Details Filter Attributes
	
	self.allInvoiceLineTypes.clear();
	_obj.allInvoiceLineTypes.copy(self.allInvoiceLineTypes);	
	
	self.detailsFromEndDate    := _obj.filterQueryDetailFromEnd.Date;
	self.detailsFromStartDate  := _obj.filterQueryDetailFromStart.Date;
	self.detailsToEndDate      := _obj.filterQueryDetailToEnd.Date;
	self.detailsToStartDate    := _obj.filterQueryDetailToStart.Date;
	self.isVolBased			   := _obj.filterQueryDetailVolBasedOnly;
	
	
	//Rate Filter Attributes
	
	self.allRateServices.clear();
	_obj.allServices.copy(self.allRateServices);
	
	self.rateFromEndDate       := _obj.filterQueryRateFromEnd.Date;
	self.rateFromStartDate     := _obj.filterQueryRateFromStart.Date;
	self.rateToEndDate         := _obj.filterQueryRateToEnd.Date;
	self.rateToStartDate       := _obj.filterQueryRateToStart.Date;	
	self.rateAmountFrom		   := _obj.filterQueryRateAmountFrom;
	self.rateAmountTo		   := _obj.filterQueryRateAmountTo;
	
	
epilog

end;</source>
        <Parameter name="_obj" type="INV_ContractEnquiry"/>
    </JadeMethod>
</Class>
