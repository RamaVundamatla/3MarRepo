    <JadeMethod name="zGetFile" id="395c5b70-2908-4bc0-8fca-d861046367de">
        <source>zGetFile(_fileName : String; _usePresentationFileSystem : Boolean) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     18 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	f	: File;

begin

	self.allDetails.clear;

	create f transient;
	f.kind 		:= File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	f.fileName 	:= _fileName;
	f.mode 		:= File.Mode_Input;
	f.shareMode	:= File.Share_ReadWrite;
	f.usePresentationFileSystem := _usePresentationFileSystem;

	if (not f.isAvailable) then
		self.allDetails.add('File (' &amp; _fileName &amp; ') is not available');
		return false;
	endif;

	if (not f.tryOpen) then
		self.allDetails.add('File (' &amp; _fileName &amp; ') could not be opened');
		return false;
	endif;
	
	while (not f.endOfFile) do
		self.allDetails.add(f.readLine);
	endwhile;
	
	return true;
	
epilog
	if f &lt;&gt; null then
		f.close;
		delete f;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_usePresentationFileSystem" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zGetJomLogFileName" id="8ac11308-dda5-40c8-813d-e387ce7adf8f">
        <source>zGetJomLogFileName(_iniFileName : String; _useAppServer : Boolean) : String protected;
// ---------------------------------------------------------------------------
// Created:     18 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	logDir,
	logName		: String;
	lastChar	: Character;
	
begin

	if _useAppServer then
		logDir	:= app.getProfileStringAppServer(_iniFileName, 'JadeLog', 'LogDirectory', null);
		logName	:= app.getProfileStringAppServer(_iniFileName, 'JadeLog', 'LogFile', null);
	else
		logDir	:= app.getProfileString(_iniFileName, 'JadeLog', 'LogDirectory', null);
		logName	:= app.getProfileString(_iniFileName, 'JadeLog', 'LogFile', null);
	endif;
	
	// somehow need to determine which is last jom log file .... (par to plant asking if we can find)
	logName := 'jom_podbprod1.log';
	
	if logDir &lt;&gt; null then
		lastChar := logDir[logDir.length];
		if lastChar = '\' or lastChar = '\' then
			logDir := logDir[1:logDir.length-1];
		endif;
		logName := logDir &amp; '\' &amp; logName;
	endif;
	
	return logName;

end;</source>
        <access>protected</access>
        <Parameter name="_iniFileName" type="String"/>
        <Parameter name="_useAppServer" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
