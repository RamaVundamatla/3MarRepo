    <JadeMethod name="populateTable" id="3d303f37-9e8a-4046-afdb-c52a510934e4">
        <updating/>
        <source>populateTable(	terminals : CM_TerminalByCodeDict input; 
				allEWSActivities : CM_EWSActivityByDateTime) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2023	jlier1	Initial creation 56856
10/05/2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working
15/08/2024	navcs2	Bug 65588: EUP - EWS Monitor - No warning and progress bar
27/09/2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback
04 Nov 2024 navah1	Bug 33174: CUX - External Web Services Monitor Table Row Limits
27/09/2024	navcs2	ChangeRequest 66181 Start
05/11/2025 navcs2 MTN-35303 CUX - Slowness in External Web Services Monitor
*/

vars
	terminal 			: CM_Terminal;
	iter 				: Iterator;
	ewAct 				: CM_ExternalWebServiceActivity;
	theDataLine 		: String;
	idx 				: Integer;
	progress			: CMIF_Monitor;	
	numberOfTasks,
	numberDone				: Integer;				// 27/09/2024	navcs2	ChangeRequest 66181
	lastUpdate			: Decimal [20];
begin		
	app.mousePointer := MP_HOURGLASS;				// 15/08/2024	navcs2	Bug 65588

	self.tblData.fixedRows := 1;
	self.tblData.rows := 1;
	
	iter := allEWSActivities.createIterator;
	numberOfTasks := allEWSActivities.size;
	/*
	05/11/2025 navcs2 MTN-35303 CUX - Slowness in External Web Services Monitor  
	Removed for performance reasons, needed to search the data pre searching the data to get max number :D
	
	// 27/09/2024	navcs2	ChangeRequest 66181 Start
	foreach terminal in self.filterTerminals do
		iter.reset;
		allEWSActivities.startKeyGeq(terminal, self.filterInterfaceName, self.filterDateFrom, iter);
		firstEntry := true;
		index := 0;
		startIndex := 0;
		while iter.next(ewAct) do
			if firstEntry then
				startIndex := allEWSActivities.indexOf(ewAct);
				firstEntry := false;
			endif;
			iter.getCurrentKeys(terminalKey, filterNameKey, dateTimeKey);
			if terminalKey &lt;&gt; terminal or filterNameKey &lt;&gt; self.filterInterfaceName then
				index := allEWSActivities.indexOf(ewAct);
				break;
			endif;
			index := allEWSActivities.indexOf(ewAct);
		endwhile;
		numberOfTasks := numberOfTasks + (index - startIndex);
	endforeach;
	// 27/09/2024	navcs2	ChangeRequest 66181 End
	*/
	
	// // 15/08/2024	navcs2	Bug 65588 Start
	create progress transient;
	app.myPassport.setMyCMIFMonitor(progress);
	progress.myParent := self;
	if progress &lt;&gt; null then
		progress.numFound := numberOfTasks;
		progress.partsDone := 0;
		progress.partsInJob := numberOfTasks;
		progress.message := "Searching External Web Service Activites....";
		self.modalDialogShow(null, app.getErrorString(Cancel),null ,OK , app.getErrorString(CMUI_Retreiving_Data), progress.message);
	endif;
	// 15/08/2024	navcs2	Bug 65588 End
	
	/*
	05/11/2025 navcs2 MTN-35303 CUX - Slowness in External Web Services Monitor  
	Removed for performance reasons, needed to search the data pre searching the data to get max number :D	// 14/08/2024	navcs2	Bug 65590 Start
	
	if numberOfTasks &gt; 10000 then
		if app.msgBox(app.getErrorString(This_searc_over_10000_items_ta), 'Warning', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
	endif;
	// 14/08/2024	navcs2	Bug 65590 End
	*/
	
	lastUpdate := app.relativeMachineTime;		// 15/08/2024	navcs2	Bug 65588
	
	foreach terminal in terminals discreteLock do 
		iter.reset;
		allEWSActivities.startKeyGeq(terminal, self.filterInterfaceName, self.filterDateFrom, iter);
		while iter.next(ewAct) do
			if  self.filterInterfaceName &lt;&gt; null and ewAct.interfaceName &lt;&gt; self.filterInterfaceName then
				break;
			endif;
			if ewAct.created &gt; self.filterDateTo and self.filterDateTo &lt;&gt; null then
				break;
			endif;
			if ewAct.myTerminal &lt;&gt; terminal then
				break;
			endif;
			if not self.includeObjectEWS(ewAct) then
				continue;
			endif;
			
			theDataLine := ewAct.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			idx := self.tblData.addItemObject(ewAct, theDataLine); 
			
			if ewAct.isInvoiceParts then																							// 27/09/2024	navcs2	ChangeRequest 66181
				if ewAct.CM_EWSActivityInvoiceAPIParts.direction =  CM_EWSActivityInvoiceAPIParts.DIRECTION_RECEIVE then
					tblData.accessRow(idx).backColor := LightYellow;
				else
					tblData.accessRow(idx).backColor := LightBlue;
				endif;
			endif;
			
			//navra1 - MTN-35875- 5th Sep 2025-4 - start
			if ewAct.isAgGatewayEWSActivity() then																							// 27/09/2024	navcs2	ChangeRequest 66181
				if ewAct.CM_EWSActivityAgGateway.direction =  CM_EWSActivityAgGateway.DIRECTION_RECEIVE then
					tblData.accessRow(idx).backColor := LightYellow;
				else
					tblData.accessRow(idx).backColor := LightBlue;
				endif;
			endif;
			//navra1 - MTN-35875- 5th Sep 2025-4 - end
			
			// 15/08/2024	navcs2	Bug 65588 Start
			numberDone := numberDone + 1;
			if (app.relativeMachineTime - lastUpdate) &gt; 500 then
				if progress &lt;&gt; null then
					self.updateProgress(progress);
					if not progress.updateProgress(progress.message, numberOfTasks,numberDone) then
						return;
					endif;
				endif;
				lastUpdate := app.relativeMachineTime;
			endif;
			// 15/08/2024	navcs2	Bug 65588 End
			
			if idx &gt;= JadeTableRowLimit then
				app.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String),
					app.getErrorString(TableRowLimitReached), MsgBox_OK_Only + MsgBox_Information_Icon);
				//break;																				//04.11.2024 navah1 #33174
				self.lblQueryLinesValue.caption := (self.tblData.rows - self.tblData.fixedRows).String; //04.11.2024 navah1 #33174
				return;																					//04.11.2024 navah1 #33174
			endif;
			
		endwhile;
	endforeach;
	
	self.lblQueryLinesValue.caption := (self.tblData.rows - self.tblData.fixedRows).String;
epilog
	delete iter;
	delete progress;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := MP_DEFAULT;	

end;</source>
        <access>protected</access>
        <Parameter name="terminals" type="CM_TerminalByCodeDict" usage="input"/>
        <Parameter name="allEWSActivities" type="CM_EWSActivityByDateTime"/>
    </JadeMethod>
    <JadeMethod name="populateTable1Stop" id="2871f93f-f007-4883-bb3b-aedc0a765fe6">
        <updating/>
        <source>populateTable1Stop() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/02/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS
// 30/08/2022 	navma1		Bug 54684: MTN - Issues with External Monitor Screen if there are more than 32,000 record
// 03/4/2023	jlier1 		TFS 56856 - refactored to call one method to search - just set up the filtered attributes here
// 14/08/2024	navcs2		Bug 65590: EUP - EWS Monitor - Free text search not working
// 10/12/2024	navcs2		MTN-33549 MTN - External Web service monitor doesn't show 1-stop requests when no dates selected

vars
	table : CM_DataTable;
	ewsact : CM_ExternalWebServiceActivity;
	theDataLine : String;
	idx : Integer;
	fromTime, toTime : Time;
	terminals : CM_TerminalByCodeDict;
begin
	if self.mskTimeFrom.getTime().isValid then
		fromTime := self.mskTimeFrom.getTime();
	else
		fromTime.setTime(0,0,0,0);
	endif;
	
	if self.mskTimeTo.getTime().isValid then
		toTime := self.mskTimeTo.getTime();
	else
		toTime.setTime(23,59,59,999);
	endif;	

	if self.mskDateFrom.getDate().isValid then
		self.filterDateFrom.setDate(self.mskDateFrom.getDate());
		self.filterDateFrom.setTime(fromTime);
	endif;
	if self.mskDateTo.getDate().isValid then
		self.filterDateTo.setDate(self.mskDateTo.getDate());
		self.filterDateTo.setTime(toTime);
	endif;
	
	if self.cmbAction.listIndex &gt; 1 then
		self.filterAction := self.cmbAction.text[1:1];
	endif;
	
	if self.cmbType.listIndex &gt; 1 then
		self.filterType := self.cmbType.text;
	endif;
	
	create terminals transient;
	self.getTerminals(terminals);				// 26/05/2024	navcs2	ChangeRequest 59188
	self.filterText := self.txtSearchBox.text;	// 14/08/2024	navcs2	Bug 65590
	self.getProtocols();						// 26/05/2024	navcs2	ChangeRequest 59188
	self.getResponses(); 						// 26/05/2024	navcs2	ChangeRequest 59188
	self.getStatus(); 							// 26/05/2024	navcs2	ChangeRequest 59188
	
	self.filterClass:= CM_EWSActivity1Stop;
	
	self.populateTable(terminals,app.myRoot.allEWSActivities);
epilog
	delete terminals;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTableAPIENDPOINT" id="6051018a-4728-48c1-9c6f-a68074121498">
