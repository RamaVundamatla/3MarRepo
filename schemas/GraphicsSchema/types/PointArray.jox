			endif;
		endif;
		
		wasOut := true;
	endwhile;
	
	offset := 2;
	
	// Put into param's for output
	_x1 := bestPlace[1].x + offset;
	_y1 := bestPlace[1].y + offset;
	_x2 := bestPlace[2].x + offset;
	_y2 := bestPlace[2].y + offset;
	
epilog
	delete bestPlace;
end;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwmc5	Initial creation

*/

/*vars
	bestPlace 		: PointArray;
	frame 			: Frame;
	point			: Point;
	wasOut			: Boolean;
	offset, origY, 
	maxX, maxY, height : Integer;
	
begin
	wasOut := false;
	height := 30;
	create bestPlace transient;
	
	// Starting points (inside poly)
	foreach point in self do
		if bestPlace.isEmpty() then
			bestPlace.add(point);
			origY := point.y;
		elseif point.x &lt; bestPlace[1].x then
			bestPlace[1] := point;
		elseif point.x = bestPlace[1].x and point.y &lt; bestPlace[1].y then
			bestPlace[1] := point;
		endif;
		
		//Find the largest Y point
		if maxY = null then
			maxY := point.y;
		elseif maxY &lt; point.y then
			maxY := point.y;
		endif;
		
		//Find the largest X point
		if maxX = null then
			maxX := point.x;
		elseif maxX &lt; point.x then
			maxX := point.x;
		endif;
	endforeach;
	
	// Calculate other points...
	point.set((maxX/2).Integer, bestPlace[1].y + height);
	bestPlace.add(point);
	
	//Build opposites... only needed for check if inside polygon.
	point.set(bestPlace[1].x, bestPlace[2].y);
	bestPlace.add(point);
	point.set(bestPlace[2].x, bestPlace[1].y);
	bestPlace.add(point);
	
	// Find the best place...
	while self.intersectsPolygon(bestPlace) = false do
		bestPlace[1].setY(bestPlace[1].y + 2);
		bestPlace[2].setY(bestPlace[2].y + 2);
		bestPlace[3].setY(bestPlace[3].y + 2);
		bestPlace[4].setY(bestPlace[4].y + 2);
		
		if bestPlace[2].y &gt; maxY then
			height := height - 2;
			bestPlace[1].setY(origY);
			bestPlace[2].setY(origY + height);
			bestPlace[3].setY(origY + height);
			bestPlace[4].setY(origY);
			
			//bestPlace[1].setX((maxX/2).Integer - 10);
			//bestPlace[2].setX((maxX/2).Integer - 10);
			//maxX := maxX - 10;
		endif;
		
		wasOut := true;
	endwhile;
	
	offset := 2;
	
	// Put into param's for output
	_x1 := bestPlace[1].x + offset;
	_y1 := bestPlace[1].y + offset;
	_x2 := bestPlace[2].x + offset;
	_y2 := bestPlace[2].y + offset;	
epilog
	delete bestPlace;
end;*/</source>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="intersectsPolygon" id="34641b65-c9c8-49e8-a8be-80b046106b22">
        <source>intersectsPolygon( _polygonB : PointArray input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2012	cnwer1	Initial creation PAR 29079

*/

vars
	i : Integer;
	iter, iter2 : Iterator;
	a, b, 
	c, d,
	thisPoint ,
	polygonBPoint: Point;
	allInside : Boolean;
begin
	allInside:= false;
	// check if all points of polygon B are inside this polygon first 
	iter:=_polygonB.createIterator;
	i := 1;
	while iter.next(thisPoint) do
		if thisPoint.insidePolygon(self) then
			if i = 1 then
				allInside:=true;
			else
				allInside := allInside and true;
			endif;
		else
			if i = 1 then
				allInside:=false;
			else
				allInside := allInside and false;
			endif;
		endif;
		i:=i+1;
	endwhile;
	
	if allInside then
		return true;
	endif;
		
	
	delete iter;
	// iterate through all the edges checking if they intersect with the edge from they other polygon
	/*iter := self.createIterator;
	while iter.next(thisPoint) do
		if a = null then
			a := thisPoint;
			continue;
		endif;
		
		b := thisPoint;
		
		delete iter2;
		iter2 :=_polygonB.createIterator;
		while iter2.next(polygonBPoint) do
			if c  = null then
				c := polygonBPoint;
				continue;
			endif;
			
			d := polygonBPoint;
			
			if self.edgeIntersection(a,b,c,d) then
				return true;
			endif;
			c := polygonBPoint;
		endwhile;
				
		a := thisPoint;
	endwhile;
	
	return false;*/
epilog
	delete iter;
	delete iter2;
end;</source>
        <Parameter name="_polygonB" type="PointArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInIntersection" id="f395ea43-d011-4281-8059-0419dd7456ff">
        <source>isInIntersection(x, y, x0, y0, x1, y1 : Integer) : Boolean protected;
/*
 ------------------------------------------------------------------------
Created:			20 November 2002 by cnwdwq1
Purpose:			Determine if the line (0,y)-(x,y) intersects (x0,y0)-(x1,y1)
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	a  : Real;
	xi, b: Integer;
begin

	// test for intersection
	// NB the &lt;= and &gt;= are highly significant see the comment above.

	// y0 and y1 are either side of y
// AKB2005DEC changed this. Removed '='. If the polygon is a rectangle that is 'square' on the screen the equals was making this pick up polygons away from the actual X,Y
// WAS	if   ( ((y0 &gt;= y) and (y1 &lt; y) ) or ( (y1 &gt; y)  and (y0 &lt;= y) ) ) 
	if   ( ((y0 &gt; y) and (y1 &lt; y) ) or ( (y1 &gt; y)  and (y0 &lt; y) ) ) then
		// if an x value on (x0,y0) to (x1,y1) lies in the range x to 0.
		if ( (x0 &lt;= x) or (x1 &lt; x) ) then
			// find X intercept
			a := ((y-y0) ).Real / (y1-y0);

// PAR 27749 WAS JULY 2011 AKB			xi :=  ((a*(x1-x0) +0.5).Integer) +x0;
			b :=(a*(x1-x0)).roundedUp();
			xi :=  b +x0;
			if xi &lt;= x then
				return true;
			endif;
		endif;
	endif;
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="x0" type="Integer"/>
        <Parameter name="y0" type="Integer"/>
        <Parameter name="x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
