    <JadeMethod name="addRemoveTIImexStatus" id="4783e0af-ea9c-4595-b605-6c16a291f884">
        <source>addRemoveTIImexStatus(_addedTIs, _removedTIs : CM_TISet);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 20/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
vars
	ti : CM_TrackedItem;
	newImex, oldImex : Integer;
	newImexString, oldImexString : String;
	tiTrxDetails : String;
	wle : CM_WorkListEntry;								// TFS 3489

begin
	// 1. When cargo is added to a discharge job change the IMEX to IMPORT, plus an edit transaction
	// 	  (but not if the TI is a DLR or SOB)
	// 2. When cargo is added to a load job change the IMEX to EXPORT, plus an edit transaction
	//	  (but not if the TI is a DLR or SOB)
	// 3. When cargo is removed from a discharge job change the IMEX to ROB, plus an edit transaction
	// 4 .When cargo is removed from a load job leave the IMEX as EXPORT
	foreach ti in _addedTIs do
		if ti.isTranshipItem then // TFS 3561
			continue;
		endif;
	
		// 1. When cargo is added to a discharge job change the IMEX to IMPORT, plus an edit transaction
		//if self.isDischarge and ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_IMPORT then														// TFS 3489
		if self.isDischarge and ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_IMPORT and ti.getTransitStatus = TI_TransitStatusNull then			// TFS 3489
			oldImex := ti.getImExStatus;
			oldImexString := ti.getImExStatusString;
			ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
			newImex := ti.getImExStatus;
			newImexString := ti.getImExStatusString;
			tiTrxDetails := app.formatForEditTransaction(CM_TrackedItem::imexStatus.name, oldImexString, newImexString);
			app.createEditTransaction(ti, tiTrxDetails, null, app.myPassport);				//20.02.2024 navhl20 #62525
		// 2. When cargo is added to a load job change the IMEX to EXPORT, plus an edit transaction
		//elseif not self.isDischarge and ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_EXPORT then												// TFS 3489
		elseif not self.isDischarge and ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_EXPORT and ti.getTransitStatus = TI_TransitStatusNull then	// TFS 3489
			if ti.dischargePort = null then
				app.raiseCMException(Input_required_field_dishPort, null, null);
			endif;
			oldImex := ti.getImExStatus;
			oldImexString := ti.getImExStatusString;
			ti.setImExStatus(TI_IMEX_STATUS_EXPORT);
			newImex := ti.getImExStatus;
			newImexString := ti.getImExStatusString;
			tiTrxDetails := app.formatForEditTransaction(CM_TrackedItem::imexStatus.name, oldImexString, newImexString);
			app.createEditTransaction(ti, tiTrxDetails, null, app.myPassport);      		//20.02.2024 navhl20 #62525
		endif;
	endforeach;
	
	foreach ti in _removedTIs do
		// 3. When cargo is removed from a discharge job change the IMEX to ROB, plus an edit transaction
		if self.isDischarge and ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
			oldImex := ti.getImExStatus;
			oldImexString := ti.getImExStatusString;
			ti.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
			newImex := ti.getImExStatus;
			newImexString := ti.getImExStatusString;
			tiTrxDetails := app.formatForEditTransaction(CM_TrackedItem::imexStatus.name, oldImexString, newImexString);
			app.createEditTransaction(ti, tiTrxDetails, null, app.myPassport);				//20.02.2024 navhl20 #62525
		// 4 .When cargo is removed from a load job leave the IMEX as EXPORT
		elseif not self.isDischarge then
			// do nothing
		endif;
		// here we also need to unplan any future planned move that matches a wle that matches this voyage hold job	// TFS 3489
		foreach wle in ti.allWorklistEntries where wle.job = self do												// TFS 3489
			if ti.allPlannedFutureMoves.includes(wle.myFutureMove) then												// TFS 3489
				ti.undoMove(PLANNING_MODE, app.myPassport);															// TFS 3489
			endif;																									// TFS 3489
		endforeach;																									// TFS 3489
	endforeach;
epilog

end;</source>
        <Parameter name="_addedTIs" type="CM_TISet"/>
        <Parameter name="_removedTIs" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="canBeDirectRelease" id="39482957-a856-428a-a69d-b7a26e8b444f">
        <source>canBeDirectRelease() : Boolean;
/*

Purpose:				Determine if job can be used for direct release

Parameters:			

Return Value:			

Date					Who		Reason
03 September 2019		jlgzm1	Initial creation TFS 42879 Direct Delivery Between Voyage Operations and Road &amp; Rail

*/

vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="54b92f58-fa99-4246-a454-714c6f328922">
