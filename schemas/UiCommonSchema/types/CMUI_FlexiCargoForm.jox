    <JadeMethod name="doBuildDeliveryReasons" id="0d153ecf-aa98-42d0-a3da-95fd9a5ade0b">
        <source>doBuildDeliveryReasons(_combo : ComboBox input) protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2009	cnwjk3	Initial creation

*/

vars
	reason: CM_DeliveryReleaseReason;
begin
	_combo.clear();
	_combo.addItem('');
	_combo.addItem(DELSTR_IST);
	_combo.addItem(DELSTR_NIB);
	_combo.addItem(DELSTR_PEX);
	_combo.addItem(DELSTR_RPK);
	_combo.addItem(DELSTR_SNT);
	_combo.addItem(DELSTR_TSC);
	
	// Add user reasons PAR 21885
	foreach reason in app.myRoot.allDeliveryReasonselReasons do
		_combo.addItem(reason.description);
	endforeach;

epilog

end;</source>
