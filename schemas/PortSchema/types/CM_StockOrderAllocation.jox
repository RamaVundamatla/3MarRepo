    <JadeMethod name="setProxyForAllocation" id="105e22c6-467d-46c6-af98-f3589c443730">
        <updating/>
        <source>setProxyForAllocation(_allocQuantity : Real;
					  _allocTypeStr : String;
					  _locnController : CM_LocationsController;
					  _sohLocation : CM_SOHLocation) updating, protected;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.allocTypeString := _allocTypeStr;
	self.myLocationsController := _locnController;
	self.mySOHLocation := _sohLocation;
	
	if self.allocType = self.AllocType_Quantity then
		self.allocQuantity := _allocQuantity;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_allocQuantity" type="Real"/>
        <Parameter name="_allocTypeStr" type="String"/>
        <Parameter name="_locnController" type="CM_LocationsController"/>
        <Parameter name="_sohLocation" type="CM_SOHLocation"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="d1c45ad0-bd52-4d43-bfc1-2745f7c0d371">
        <source>validateForCreate();
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.allocQuantity = null and self.allocType = self.AllocType_Quantity then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Allocate Quantity', ETRow_Quantity, null);
		app.raiseCMException(Input_required_field_allocQuan, ETRow_Quantity, null); // cnwdb2	PAR 35364
	endif;
	self.validateForUpdate();
end;</source>
    </JadeMethod>
