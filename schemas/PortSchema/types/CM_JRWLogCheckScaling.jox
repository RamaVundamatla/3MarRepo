    <JadeMethod name="getFromDateLocalTZ" id="839fe72f-6803-4a0d-b82e-b67f20760f3f">
        <source>getFromDateLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
01 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
begin
	if self.fromDate.isValid() then
		ts.setDate(self.fromDate);
		ts.setTime("0:00:00".Time);
		return self.systemToLocalTime(ts).Date;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getToDateLocalTZ" id="87a1f0ef-46bb-4c19-9097-6bbe53ec6c07">
        <source>getToDateLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
01 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
begin
	if self.toDate.isValid() then
		ts.setDate(self.toDate);
		ts.setTime("23:59:59.999".Time);
		return self.systemToLocalTime(ts).Date;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="9b37f829-8a81-4b9a-8372-04ead66ee095">
        <source>noOutputReturned(): Boolean;
// ---------------------------------------------------------------------------
// Created:     04 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.allCheckScaleDetail.isEmpty()then
		return true;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
