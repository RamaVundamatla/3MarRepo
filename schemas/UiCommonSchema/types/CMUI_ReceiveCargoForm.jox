    <JadeMethod name="setupForMakeLCLForm" id="db5bb41c-c959-44df-a866-7618e002ee0e">
        <updating/>
        <source>setupForMakeLCLForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/12/2013	cnwndl1	Initial creation	Par 32854
01/09/2014	cnwdap1	PAR #34771 Add voyage to voyage combo if we end up not adding it automatically
7/09/2015	cnwjre1	36670 separate field visibity and population, only populate from setup so a change of cargo type etc doesn't reset entered BOL
13/03/2024	jlika1	TFS 59006 LCL Cargo Operator - Default Value
*/

vars

	location : CM_LocationsController;
	parentContainer : CM_TrackedItem;
	consignor : CM_ConsigneeConsignor;
	consignee : CM_ConsigneeConsignor;
	freightForward : CM_ConsigneeConsignor;
	carrier : CM_Carrier;
	hideDisabledFields : Boolean;
	
	imex	: CM_IMEXStatus;		//cnwmc5 - 19 Jan 2016 - PAR 37431

begin

	if self.myPackUnpackObject &lt;&gt; null then
		if self.myPackUnpackObject.isKindOf(CM_LocationsController) then
			location := self.myPackUnpackObject.CM_LocationsController;
		elseif self.myPackUnpackObject.isKindOf(CM_TrackedItem) then
			parentContainer := self.myPackUnpackObject.CM_TrackedItem;
		endif;
	endif;
	
	if parentContainer &lt;&gt; null then
	
		if self.inSetup then			// 36670 don't populate after setup to avoid losing entries such as BOL
			self.cmbTransportMode.setForText(app.transModeToString(parentContainer.receiptTransportMode));
		
			self.txtWagon.setValue(parentContainer.wagon);
	
			self.cmbWagonClass.setForObject(parentContainer.getMyNotifiedWagonClass);	//12 May 2014	NDL	Par 33615
		
			self.txtWagonTrain.setValue(parentContainer.getMyNotifiedTrainString);
		
			self.cmbVoyageCode.setObject(parentContainer.myVoyage);
			if self.cmbVoyageCode.listCount = 0 then																									// PAR #34771
				self.cmbVoyageCode.addItemObject(parentContainer.voyageCode &amp; " - " &amp; parentContainer.myVoyage.description, parentContainer.myVoyage);	// PAR #34771
			endif;																																		// PAR #34771
			self.doSelectVoyage();
			
			// Need to check first if exist other wise in the setObject Method when it amInitialised is true and it has a dirtyobject or cannot find the value in the collection then it will clear the collection 
			// which will set the amInitialised to false which will trigger for the combox to be populated by the roots.alloperator collection.
			if parentContainer.myVoyage &lt;&gt; null and parentContainer.myVoyage.isNullVoyage then
				self.cmbOperatorCode.setObject(parentContainer.myOperator);
			elseif parentContainer.myVoyage &lt;&gt; null and parentContainer.myVoyage.allOperators[parentContainer.operatorCode] &lt;&gt; null then
				self.cmbOperatorCode.setObject(parentContainer.myOperator);			
			endif;
		
			self.cmbDischargePort.setObjectFromCode(parentContainer.dischargePort);
		
			consignor := app.myRoot.allConsigneeConsignors.getAtKey(parentContainer.consignor);
			if consignor &lt;&gt; null then
				self.cmbConsignor.setForObject(consignor);
			endif;
		
			consignee := app.myRoot.allConsigneeConsignors.getAtKey(parentContainer.consignee);
			if consignee &lt;&gt; null then
				self.cmbConsignee.setForObject(consignee);
			endif;
		
			freightForward := app.myRoot.allConsigneeConsignors.getAtKey(parentContainer.freightForwarderCode);
			if freightForward &lt;&gt; null then
				self.cmbFreightFwdr.setForObject(freightForward);
			endif;
		
			self.cmbDestPort.setObjectFromCode(parentContainer.destinationPort);
			
			//cnwmc5 - 19 Jan 2016 - PAR 37431
			if self.cmbImexStatus.getObject = null 
			and parentContainer.getImExStatus() = TI_IMEX_STATUS_TRANSHIP then
				imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
				if imex &lt;&gt; null then
					self.cmbImexStatus.addItemObject(imex.description, imex);
				endif;
			endif;
			
			self.cmbImexStatus.setForObject(parentContainer.getImExStatusObject);
		
			carrier := parentContainer.getCarrierReceive;
			if carrier &lt;&gt; null then
				self.cmbCarrier.listCollection(app.myRoot.allCarriers, true, 0);
				self.cmbCarrier.setForObject(carrier);
			endif;
			if parentContainer.myReceivalBOL &lt;&gt; null then
				self.txtBOLNumber.CMUI_FieldTextBox.setValue(parentContainer.myReceivalBOL.number);
			else
				self.txtBOLNumber.CMUI_FieldTextBox.setValue(parentContainer.billOfLading);
			endif;
		endif;
	
		self.cmbTransportMode.enabled := false;
		self.txtWagon.enabled := false;
		self.tblTareWeight.enabled := true; // PAR 35740
		self.cmbWagonClass.enabled := false;	//12 May 2014	NDL	Par 33615
		self.txtWagonTrain.enabled := false;
		
		self.tblTareWeight.isHidden := hideDisabledFields;
		
		self.lstDischarge.enabled := false;
		self.lstDischarge.isHidden := hideDisabledFields;
		
		self.cmbTranship.enabled := false;
		self.cmbTranship.isHidden := hideDisabledFields;
		
		self.txtBOLNumber.enabled := true;
		self.txtBOLNumber.isHidden := false;
		
		self.txtBookingRef.isHidden := true;
		self.cmbBRItem.isHidden := true;
	
	else
		if self.inSetup then		// 36670
			if location &lt;&gt; null then
				self.txtLocation.setValue( location.getFullId );
			endif;
			self.cmbTransportMode.setForText(TI_TRANSMODE_NULL_STR);
		endif;
		
		if location &lt;&gt; null then
			self.txtLocation.enabled := false;
			self.txtLocation.isHidden := false;
		endif;
		self.txtBOLNumber.enabled := true;
		self.txtBOLNumber.isHidden := false;
		
	endif;
	
	self.cmbAttachments.enabled := false;
	self.chkHasAttachment.isHidden := true;
	self.chkDirDel.isHidden := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="daceccf5-c051-47ea-96ee-2ffb8386e264">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/07/2009	cnwdap1	Initial creation
28/10/2009	cnwdap1	PAR #20964 New parameter to loadSubCargoCommodityCombos
11/03/2010	cnwmh5	PAR 22546 - only call doIMEXStatusChanged if myTI/MyRealGTEEntity are null so
					doesn't set sub terminal to default if editing one of these items
15/05/2014	cnwdap1	PAR #34157 If we got an exception in setupForm, unload myself so Road Gate doesnt end up disabled
30/06/2014	cnwdap1	PAR #34483 CCMS DPH 2384 Ent defs for ship attachments to have BOL instead of booking
17/11/2016	cnwdap1	TFS 2842 STWR Hazardous Details Enhancements
06/04/2020  navhl20 TFS 52777 EUP - INT - Generic API: record-scan
20/05/2022 navtnr20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16/07/2022	navmd1	TFS 52777 Tidy up/review code
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
09/09/2022  navds20 TFS Bug 54615: CUX - Road Gate not retaining pre-noted HAZ info
09/01/2023  navds21 TFS Bug 55848: PNL - In Road Gate - Seal number does not show when pre-noted containers are entered
14 April 2023	navkc1	Initial creation CR 57036 Task 57590: UI - Cargo Enquiry Create New Cargo
10 Nov 2023 navrv30 Bug 61141: MTN - Prenote HS Code is not displayed in Road Gate
*/
vars
	newItem		: Boolean;
	str, newId			: String;
	gteClass	: Class;		// cnwjk3 PAR 22502 02/03/10
	success		: Boolean;		// PAR #34157
begin
	success := false;			// PAR #34157
	inheritMethod();
	self.inSetup := true;		// 36670 used in setupForMakeLCLForm
	
	//epr par 34945 23/10/14
	if self.numberOfColumns = 0 then
		self.setColumnsAndControlWidth(3,160);
	endif;
	if (self.isOnshipForm or self.isOnsiteForm) and self.myTI = null then // TFS 2318
		self.updateMode := Mode_Add;
	endif;
	
	self.cmbDischargePort.isDisabledPortCodeSelector := true;	// cnwjk3 PAR 22690 12/03/2010
	self.cmbDischargePort.isLeaveEmptyIfNoVoyage := true;		// cnwjk3 PAR 22690 12/03/2010
	self.cmbTranshipPort.isDisabledPortCodeSelector := true;	// cnwjk3 PAR 22690 12/03/2010
	self.cmbTranshipPort.isLeaveEmptyIfNoVoyage := true;		// cnwjk3 PAR 22690 12/03/2010
	
	self.loadCombos;
	
	self.cmbDischargePort.myAssistant := self.myAssistant;
	self.cmbTranshipPort.myAssistant := self.myAssistant;
	self.myAssistant.comboBoxSubTerminal(self.cmbSubTerminal.getEmbeddedControl.ComboBox, null, self.myTerminal);	
	self.doBuildCoolingTypes(self.cmbCoolingType.getEmbeddedControl.ComboBox);
	self.doBuildVoltageTypes(self.cmbVoltageType.getEmbeddedControl.ComboBox);
	self.setupOverDimensions();
	
	self.decideEntDefType(true);  //epr par 34945 20/10/14
	
	// first off, are we an "attachment" form?
	if self.isAttachmentForm() then
		if self.isFlexiGateForm then
			if self.isFullContainer then
				self.setupFormFull;
			elseif self.isEmptyContainer then
				self.setupFormEmpty;
			elseif self.isAnyCargo then			
				newItem := true;
			endif;
		endif;
		
		self.doDefaultAttachmentFormDetails();
		self.btnDelete.visible := true;
		if self.myIntFacePreNote &lt;&gt; null or self.myPxyGTEEntity &lt;&gt; null or self.myProxyTrackedItem &lt;&gt; null then
			self.btnDelete.enabled := true;
		else
			self.btnDelete.enabled := false;
		endif;
		self.alignButtons;
		
	elseif self.isFlexiGateForm then
		self.cmbCarrier.setForObject(self.myCurrentVehicleVisit.getCarrier());	//cnwmc5 - 22 Oct 2013 - PAR 32659
		if self.isFullContainer() then
			self.setupFormFull;
		elseif self.isEmptyContainer() then
			self.setupFormEmpty;
		elseif self.isAnyCargo() then
			newItem := true;
		endif;
		
	elseif self.isPreNoteForm then
		if self.updateMode = self.Mode_Add then
			newItem := true;
		endif;	
			
	elseif self.isRailPreNoteForm then
		// default IMEX status to Export
		cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);
		if self.myCargoType &lt;&gt; null and not self.myCargoType.id = TI_CargoType_Container then
			//self.initFieldsForEntDefName(ETDef_RailPreNoteCargo, true);
			//04 Mar 2014	NDL	Par 33596 - No longer needed
			//self.txtNumItems.setMyCaption(app.getErrorString(CM_Total_Quantity));	//19 Aug 2013	NDL	Par 32169
			self.setIsGeneralCargo();
		endif;
		if self.myCargoType &lt;&gt; null then
			self.loadSubCargoCommodityCombos(self.myCargoType, self.existingCargoType, cmbSubCargo, cmbCommodity);
			self.loadGeneratorAndTrailerCombos(self.myCargoType);
			self.doSetSubTerminal();
			self.initFieldsForEntDefName(ETDef_RailPreNoteCargo, true);   //20 may 2022 navtnr20 TFS 53204
		endif;
		// copied from preNote - ** does the general cargo processing need all of these options??
	elseif self.isOnshipForm then
		if self.updateMode = self.Mode_Add then	
			//04 Mar 2014	NDL	Par 33596 - No longer needed
			self.cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);
			self.cmbImexStatus.enabled := false;
			self.cmbVoyageCode.setObject(myVoyage);
			// populated dependent combos
			self.doSelectVoyage();
			self.cmbVoyageCode.enabled := self.myVoyage = null; //epr par 34945 20/10/14
			self.doVoyageCodeLostFocus(); //epr par 34945 20/10/14
			newItem := true;
			// TFS 3218
			if self.myTerminal.getConfig(AutoGenIDsForOnShip).Boolean then
				//newId := self.myTerminal.generateNextCargoId(false,true);    // 1 Sept 2022 navmv20 TFS 54610
				newId := self.myTerminal.generateNextCargoId(false,true,null); //1 Sept 2022 navmv20 TFS 54610
				self.txtCargoID.setValue(newId); 
			endif;			
		endif;
		
	elseif self.isMakeLCLForm then	//06 Dec 2013	NDL	Par 32854
		//self.initFieldsForEntDefName(ETDef_GeneralCargo, true);
		self.setupForMakeLCLForm();
		newItem := true;	
	elseif self.isOnsiteForm then	// TFS 2318
		self.cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);
		self.cmbImexStatus.enabled := false;
		self.cmbVoyageCode.setObject(myVoyage);
		// populated dependent combos
		self.doSelectVoyage();
		self.cmbVoyageCode.enabled := self.myVoyage = null; 
		self.doVoyageCodeLostFocus(); 
		
		//	14/04/2023	navkc1	CR 57036 Task 57590
		if self.myParentForm.isContainerEnqForm() then
			self.myAssistant.comboBoxVoyageCurrent(cmbVoyageCode, self.myVoyage, true, false, false, true, true, false, true, false, true);
			self.cmbImexStatus.enabled := true;
			self.cmbVoyageCode.enabled := true;
		endif;
		
		newItem := true;	
		
		// TFS 3218
		if self.myTerminal.getConfig(AutoGenIDsForOnShip).Boolean then
			//newId := self.myTerminal.generateNextCargoId(false,true);   // 1 Sept 2022 navmv20 TFS 54610 
			newId := self.myTerminal.generateNextCargoId(false,true,null); //1 Sept 2022 navmv20 TFS 54610
			self.txtCargoID.setValue(newId); 
		endif;
		
	endif;
	
	self.setNumItemsCaptionAndEnabled( null );	//04 Mar 2014	NDL	Par 33596
	
	if newItem or (self.isAttachmentForm() and self.updateMode = self.Mode_Add) then
		// not wanted for on-ship general cargo - keep the default type as is
//		if not self.isOnshipForm  then
		if not self.isGeneralCargo and not self.isOnshipForm then	// PAR 36449		
			self.setupNewItem();
		endif;
	endif;

	self.doSetCaption();

	if self.currentEntTableDef.isOneOf(ETDef_GeneralCargo, ETDef_AttachmentGeneral) then
		self.flexiCargoType := self.FLEXI_CARGO_GENERAL;
		self.doOpenCloseDimensionsSection();
	endif;

	if self.myBookingRefItem &lt;&gt; null then
		self.setFieldsFromBookingItem();
	elseif self.myTI &lt;&gt; null then
		
		if self.isFlexiGateForm then
			// cnwjk3 PAR 22502 01/03/10 - We now create proxy GTEs from tracked items to ensure that attachments
			// don't get lost, as the attachement code was designed with proxy GTEs in mind, not real Tracked Items.
		
			gteClass := self.myTI.getGTEClassToCreate();		// cnwjk3 PAR 22502 01/03/10
			create self.myPxyGTEEntity as gteClass transient;	// cnwjk3 PAR 22502 01/03/10
			self.myPxyGTEEntity.setPxyFromTI(self.myTI);		// cnwjk3 PAR 22502 01/03/10
			
			self.myPxyGTEEntity.clearAmountWhenForceUserEntry();//11 May 2016	NDL	TFS 1978
			
			self.setFieldsFromGTEEntity(self.myPxyGTEEntity);	// cnwjk3 PAR 22502 01/03/10
		else
			self.setFieldsFromItem(self.myTI);	
		endif;
		if self.myTI.myHSCode &lt;&gt; null then		        		//10 Nov 2023 navrv30 #61141
			self.cmbHSCode.setForObject(self.myTI.myHSCode);
		endif;
	elseif self.myRealGTEEntity &lt;&gt; null then
		self.setFieldsFromGTEEntity(self.myRealGTEEntity);
	elseif self.myRealGTEEntityToCopy &lt;&gt; null then
		self.setFieldsFromItem(self.myRealGTEEntityToCopy);
		self.txtCargoID.setValue(null);
	elseif self.myIntFacePreNote &lt;&gt; null then
		self.setFieldsFromCMIFPreNote(self.myIntFacePreNote);
	elseif self.myPxyGTEEntity &lt;&gt; null then
		self.setFieldsFromGTEEntity(self.myPxyGTEEntity);
	elseif self.myBOLDtl &lt;&gt; null then
		self.setFieldsFromBOLDetail();
	endif;

	self.doShowPicture();
	self.enableControls();	
	
	if not self.isVVRUpdatable() then
		//26 May 2011	NDL	Par 27585	- This allows newly added GTE Entities on VVRs for trucks in the yard to be maintained
		//                                until the bif save is done on teh Road Gate form.
		if not self.isAdditionalGTEEntityOnVVR() then
			self.enableAllControls(false);
		endif;
		self.btnCancel.enabled := true;
		
		
		if self.cmbAttachments.listCount() &gt; 0 then
			self.chkHasAttachment.enabled := true;
			self.cmbAttachments.enabled := true;
			self.cmbAttachments.listIndex := 1;
			self.btnAttachments.enabled := true;
		endif;
		self.grpAdditional.enabled := true;
		self.btnAdditionalDet.enabled := true;	
		self.lblAdditionalDet.enabled := true;
	endif;
	if self.myTI = null and self.myRealGTEEntity = null then			// 11/03/2010 cnwmh5 #22546
		self.doIMEXStatusChanged();	
	endif;																// 11/03/2010 cnwmh5 #22546
	
	self.doSetTemperatureLabels();	//04 Jan 2018	NDL	TFS 42766 - was being reset to default during IMEX status chg..
	
	// from 27727 Mar 2012 was app.myPassport.myTerminal &lt;- null
	if not self.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
		self.showTranshipControl(false);
	endif;
	
	self.doShowVehicleBookings();	//17 Apr 2013	NDL	Par 31393

	// 29287 Apr 2012 multi-select pre-notes in road gate, use passed-in selected pre-note ids and count
	if self.cargoIDs.size &gt; 0 then
		str := self.cargoIDs[1];
		if self.cargoIDs.size &gt; 1 then
			str := str &amp; "-" &amp; self.cargoIDs[self.cargoIDs.size];
		endif;
		self.txtCargoID.setValue(str[1:20]);
		//self.txtNumItems.setValue(self.cargoIDs.size); //cnwrd1 removed for par 33096 - quantity should not be derived from number of TI's 
	endif;

	self.btnAdditionalDet.enabled := self.txtCargoID.getString() &lt;&gt; null ;		// cnwjk3 PAR 23222 17/03/2010	
	self.btnAttachments.enabled := self.txtCargoID.getString() &lt;&gt; null ;		// cnwjk3 PAR 23222 17/03/2010								// cnwjk3 PAR 23222 17/03/2010
	//epr par 31845 29/10/13
	self.btnDamage.enabled := self.txtCargoID.getString() &lt;&gt; null ;	
	self.btnPhotos.enabled := self.txtCargoID.getString() &lt;&gt; null ;	
	self.btnHazards.enabled := self.txtCargoID.getString() &lt;&gt; null ;	// TFS 2842

	//start 09/09/2022 navds20 TFS 54615
	if self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then
		self.btnHazards.enabled := false;
	endif;
	//end 09/09/2022 navds20 TFS 54615
	
	if not app.getMyUser.canDo(self.myTerminal, PmAdmOpExpReleaseNumEdit) then //cnwrd1 par 29485 30.4.2012
		self.txtOpExRelNbr.visible := false;
	endif;
	
	if self.myDefaultLocation &lt;&gt; null then // TFS 3218
		self.txtLocation.setValue(self.myDefaultLocation.getFullId()); // TFS 3218
	endif;
	
	if self.myMainForm &lt;&gt; null then
		self.myMainForm.myAssistant.populateScanDataFields4Cargo(self.myCurrentVehicleVisit, self.cmbType.getEmbeddedControl().ComboBox,
			self.txtCargoID.getEmbeddedControl().TextBox, self.txtAlternativeId.getEmbeddedControl().TextBox, self.sealTypes, self.sealValues);		// TFS 52777
	endif;
		
	if self.sealValues.first &lt;&gt; null then		//09.01.2023 navds21 TFS 55848
		self.restoreSealControlValues();
	endif;										//09.01.2023 navds21 TFS 55848
	
	success := true;			// PAR #34157
epilog
	self.inSetup := false;		// 36670
	if not success then			// PAR #34157
		self.unloadForm();		// PAR #34157
	endif;						// PAR #34157
end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormEmpty" id="2dcb8823-4ba8-4022-9a5a-abe8cbe9d524">
        <updating/>
        <source>setupFormEmpty() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars

begin
	self.restoreIMEXStatus(self.cmbImexStatus, TI_IMEX_STATUS_STORAGE, true);
	self.doIMEXStatusChanged();	
	self.setCommodityToDefaultEmpty(self.cmbCommodity);
	self.setCargoTypeToISOContainer(self.cmbType);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupFormFull" id="dc41be89-4744-4122-a985-827c972c00d2">
        <updating/>
        <source>setupFormFull() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2009	cnwjk3	Initial creation
*/
vars

begin
	self.restoreIMEXStatus(self.cmbImexStatus, TI_IMEX_STATUS_EXPORT, true);
	self.doIMEXStatusChanged();	
	self.setCargoTypeToISOContainer(self.cmbType);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMeasurementControls" id="81ac12a5-9be1-4598-964b-898ac8596273">
        <source>setupMeasurementControls();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
21/06/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
*/
vars

begin
	inheritMethod();
	
	self.tblDensity.setup(Type_Density, self.backColor);
	self.tblDiameter.setup(Type_Length, self.backColor);
	
	self.tblHeight.setup(Type_Height, self.backColor);
	self.tblLength.setup(Type_Length, self.backColor);
	self.tblWidth.setup(Type_Width, self.backColor);
	
	self.tblOverFront.setup(Type_Length, self.backColor);
	self.tblOverHeight.setup(Type_Height, self.backColor);
	self.tblOverLeft.setup(Type_Width, self.backColor);
	self.tblOverRear.setup(Type_Length, self.backColor);
	self.tblOverRight.setup(Type_Width, self.backColor);
	
	self.tblNettWeight.setup(Type_Weight, self.backColor);
	
	self.tblRollingLength.setup(Type_Length, self.backColor);
	
	self.tblTareWeight.setup(Type_Weight, self.backColor);
	self.tblTotalWeight.setup(Type_Weight, self.backColor);
	self.tblWeight.setup(Type_Weight, self.backColor);
	
	self.tblVentilation.setup(Type_Displacement, self.backColor);
	
	self.tblTotalVolume.setup(Type_Volume, self.backColor);
	self.tblVolume.setup(Type_Volume, self.backColor);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupNewItem" id="a4a0d92e-ce91-4d15-bf2f-4face1774a1f">
        <updating/>
        <source>setupNewItem() updating, protected;
/*
Purpose:			Set Cargo type to Terminal default, if it's a container assume it's full

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2009	cnwdap1	Initial creation
*/
vars
	defaultCargo	: CM_CargoType;

begin
	
	defaultCargo := app.myRoot.allCargoTypesById[self.myTerminal.defaultCargoType];
	self.cmbType.setForObject(defaultCargo);
	self.onCargoTypeChange();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupOverDimensions" id="9af2adb1-cf94-4741-b503-2f1f63faedcd">
        <updating/>
        <source>setupOverDimensions() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwdap1	Initial creation

*/

vars

begin
	chkIsOverDim.value := false;
	chkIsOverDim_change(chkIsOverDim);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showCargoIds" id="b05b1ff1-eccd-4610-821f-fb535eccadff">
        <updating/>
        <source>showCargoIds() updating, protected;

vars
	str	: String;
	form : CMUI_EnterCargoIds;
begin
	create form;
	form.centreWindow;
	form.setMyTerminal(self.myTerminal);
	self.cargoIDs.copy(form.ids);
	form.myCargoType := self.cmbType.getObject.CM_CargoType;	// 09/03/2017 jlgmd1 TFS #37320
	
	form.showModal;
	
	if form.modalResult = ModalResultOK then
		self.cargoIDs.clear;
		foreach str in form.ids do
			self.cargoIDs.add(str);	
		endforeach;
		// 23917 check that an id has been entered
		if self.cargoIDs.size &gt; 0 then
			str := self.cargoIDs[1];
			if self.cargoIDs.size &gt; 1 then
				str := str &amp; "-" &amp; self.cargoIDs[self.cargoIDs.size];
			endif;
		endif;
		self.txtCargoID.setValue(str[1:20]);
	endif;
	
	self.txtCargoID.setFocus();		// 22/02/2013 cnwar2 #30861
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHideWeighButton" id="e198b65f-eaec-4eb5-91cd-45d817e5e81c">
        <source>showHideWeighButton();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	cargoType : CM_CargoType;
	product : CM_Product;
	weighBridge : CM_WeighBridgeObj;

begin

	self.btnWeigh.visible := false;
	self.chkWeightCert.visible := false;
	self.chkWeightCert.enabled := false;
	
		
	if self.isFlexiGateForm then
		if self.cargoIDs.size &gt; 1 then
			return;
		endif;
		if self.txtCargoID.getString.trimBlanks = null then
			return;
		endif;
		cargoType := self.cmbType.getObject.CM_CargoType;
		if cargoType = null then
			product := self.cmbProdType.getObject.CM_Product;
			if product &lt;&gt; null then
				cargoType := product.myCargoType;
			endif;
		endif;
		if cargoType = null then
			return;
		endif;
		
		//epr 24/3/16 vgm tfs changes so chk certifed always visible
		if not self.myTerminal.allWeighBridges.isEmpty then
			//self.btnWeigh.visible := true;
			//05 Jul 2019 NDL TFS 44965 - show the button only if there is a Weigh Bridge that is NOT a two readings one
			foreach weighBridge in self.myTerminal.allWeighBridges do
				if weighBridge.isTwoReadings then
					continue;
				endif;
				self.btnWeigh.visible := true;
				break;
			endforeach;
		endif;
		
		if not cargoType.canWeightBeCertified then
			return;
		endif;
		
		//epr TFS 2011 8/6/16
		if not self.chkIsWeightCertified.visible then
			self.chkWeightCert.visible := true;
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showTIMasterGenEditForm" id="583e3cce-e46b-490c-9705-f37852748a76">
        <updating/>
        <source>showTIMasterGenEditForm(_tiMasterGenerator : CM_TIMasterGenerator) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
Date		Who		Reason
22 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
*/

vars
	form : CM_BaseForm;
	tiMasterGenEdit : CM_TIMasterGenerator;
	index : Integer;
begin
	form := app.loadForm(CMUI_MasterGeneratorMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_MasterGeneratorMaintForm;
	if form = null then
		return;
	endif;
	tiMasterGenEdit := _tiMasterGenerator;
	index := self.cmbAttachments.findObject(tiMasterGenEdit);
	form.CMUI_MasterGeneratorMaintForm.setAttributes(tiMasterGenEdit, true);
	form.setParentForm(self);
	form.centreWindow;
	form.centreOverParent(0);
	form.show();
epilog

end;</source>
        <Parameter name="_tiMasterGenerator" type="CM_TIMasterGenerator"/>
    </JadeMethod>
    <JadeMethod name="showTranshipControl" id="0fd86a01-b4fa-46a1-8dab-4da456b8a852">
        <updating/>
        <source>showTranshipControl(_show : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/

vars
	ctrl : Control;
	show : Boolean;
begin
	show := _show;
	if not self.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
		show := false;
	endif;
	self.getControlForEntDefRow(self.cmbTranship.name, ctrl);
	ctrl.visible := show;

epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblDensity_hasLostFocus" id="71cc5f58-5c28-4188-876f-d4c5f7367364">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDensity_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2018	jlger1	Initial creation

*/

vars

begin
	//epr TFS 7756 20/2/18
	if not self.totalWeightVolumeChanged and self.hasPrenoteVolumeChanged() then
		self.totalWeightVolumeChanged:=true;
	endif;
	if self.existingCargoType &lt;&gt; null and self.existingCargoType.isBulkByVolume then
		self.calculateTotalWeight(self.tblTotalVolume);
	endif;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
