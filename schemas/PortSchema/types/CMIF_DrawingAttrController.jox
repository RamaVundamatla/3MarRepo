    <JadeMethod name="handleWeightRange" id="57a78d15-4607-49c9-a94f-806d6b170323">
        <source>handleWeightRange(_value: Real; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	convertedValue : Decimal[14,4];
	iter		: Iterator;
	theCode		: String;
	theColor	: Integer;
	matchedRange,
	tmpRange	: CM_WeightRange;
	theObject  :  Object;
	weightType :  CM_MeasurementType;
begin

	theCode		:= _value.String;
	theColor	:= NullColour;
	//value coming in is in kilos
	//epr par 33447 12/11/14
	weightType:=app.getDefaultMeasurementForType(Type_Weight);
	iter := self.myRoot.allWeightRanges.createIterator;
	self.myRoot.allWeightRanges.startKeyGeq(weightType,null,iter);
	while iter.next(tmpRange) do
		
		if tmpRange.myMeasurementType &lt;&gt; weightType then
			break;
		endif;
		
		if tmpRange.myMeasurementType.shortName &lt;&gt; "kg" then
			convertedValue:=app.convertMeasurementForStorage(weightType.shortName,tmpRange.upper);
		else
			convertedValue:=tmpRange.upper;
		endif;
		
		if _value &lt;= convertedValue  then
			matchedRange := tmpRange;
			break;
		endif;
		
	endwhile;
		
	if matchedRange &lt;&gt; null then
		theCode		:= _value.String;
		theColor	:= matchedRange.colour;
		theObject := matchedRange;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Real"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
