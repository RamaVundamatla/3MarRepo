    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Each attributePlan may have a collection of these objects on it.</text>
    <DbClassMap file="planning"/>
    <ExplicitInverseRef name="allLocationControllers" id="a472e11b-d465-4791-8527-2e358a07a401">
