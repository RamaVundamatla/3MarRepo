    <JadeMethod name="doSave" id="001df704-a46c-41ba-b012-d31527a3f6b7">
        <updating/>
        <source>doSave() updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 11/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes
// -----------------------------------------------------------------------------

vars
	cargoType : Integer;
	row : Integer;				// TFS 38501
	cargoIDs : String;			// TFS 38501
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin


	self.checkAndSaveCurrent();
	
	if self.cmbCargoType.listObject &lt;&gt; null then
		cargoType := self.cmbCargoType.listObject.CM_CargoType.id;
	endif;
	
	if self.isWorkOrderBooking or self.isWorkOrderRelease then								// TFS 38501
		foreach row in self.tblCargoIDs.fixedRows + 1 to self.tblCargoIDs.rows do	// TFS 38501
			if self.tblCargoIDs.accessRow(row).selected then						// TFS 38501
				if cargoIDs &lt;&gt; null then											// TFS 38501
					cargoIDs := cargoIDs &amp; ",";										// TFS 38501
				endif;																// TFS 38501
				cargoIDs := cargoIDs &amp; self.tblCargoIDs.accessCell(row, 1).text;	// TFS 38501
			endif;																	// TFS 38501
		endforeach;																	// TFS 38501
		self.myProxySource.setProxy( cargoType, cargoIDs );							// TFS 38501
	else																			// TFS 38501
		self.myProxySource.setProxy( cargoType, self.txtCargoIDs.text );
	endif;																			// TFS 38501
	
	//  For new source just validate - work order will save source info
	//  For existing work order save now
	
	if self.myProxySource.pxyGetRealObject() &lt;&gt; null then
	
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateWorkOrderTISource(self.myProxySource, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			self.displayCargoIDs();	
			return;
			
		endwhile;
	
	endif;

	self.allWORequestsToBeDeleted.purge();

	if self.myMainForm.isKindOf(YRD_TaskJobMaintForm) then 
		self.myMainForm.YRD_TaskJobMaintForm.refreshFromChildSourceForm();
	elseif self.myMainForm.isKindOf(YRD_TaskJobTasks) then
		self.myMainForm.YRD_TaskJobTasks.refreshFromChildSourceForm();	
	endif;
	
	self.modalResult := IDOK;
	self.unloadForm();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowBookingRefThumb" id="9b95e33e-1c13-4a11-97de-831d9803c6d0">
        <source>doShowBookingRefThumb();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/12/2009	cnwrd1	Initial creation
16/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
*/

vars
	obj : Object;
	entTableView		: EntTableView;
	entTableDef			: EntTableDef;
	
	defName,
	viewName			: String;
	terminal 			: CM_Terminal;	
	
	etRow 				: EntTableRow;				// TFS 38501
begin

	obj := self.cmbBookingRef.listObject;
	
	terminal := self.myTerminal;
	
	if obj = null then
		tblThumb.rows := 0;
		self.btnViewSource.enabled := false;
		return;
	endif;
	
	self.btnViewSource.enabled := true;
	

	if obj.isKindOf(CM_BookingRef) then							//+cnwml2 PAR20173 SFW CCMS 1091
		if global.isValidObject( obj.CM_BookingRef) then//added by cnwyl1 for par 12683
			defName := ETDef_BookRefThumb;
			entTableDef := app.myController.getEntTableDef(defName);
			if obj.CM_BookingRef.isMultiItemBookingRef then
				viewName := ETView_MultiBR;
			//	loadBookRefItems(_obj.CM_BookingRef, false, false);
				//tblBRItems.visible := true;
			elseif not terminal.getConfig(AllowMultiBookingRef).Boolean then
				viewName := ETView_BookRefNoMulti;
				//self.sptThumbEdit.hideRightControl(true);
				//tblBRItems.clearAllSelected;
				//tblBRItems.clear;
			else
				viewName := null;
				//self.sptThumbEdit.hideRightControl(true);
				//tblBRItems.clearAllSelected;
				//tblBRItems.clear;
			endif;
			self.setNavigatorHeading(app.getErrorString(BookingRef) &amp; ' (' &amp; obj.CM_BookingRef.bookingReference &amp; ')');
			tblThumb.rows := 0;
			self.showThumbnailForDefWithView(ETDef_BookRefThumb, viewName, obj.CM_BookingRef);
			
		//	if app.isDevelopmentSystem then
			if app.isSpecial() then
				tblThumb.addItem(obj.String);
			endif;
			
			// 28/05/2009 cnwar2 CCMS1040
			if obj.CM_BookingRef.isMultiItemBookingRef then
				//self.myAssistant.GTE_Assistant.mainExtraSplitterRatio(tblThumb, tblBRItems, sptThumbEdit);
				//self.sptMain.cnEcResizeContents();
			else
				// TFS 38501 ETRow_CutoffEarliestTS and ETRow_EarliestRecLatestTS no longer in ETDef_BookRefThumb definition
				etRow := entTableDef.getEntTableRow(ETRow_CutoffEarliestTS);
				if etRow &lt;&gt; null then
					self.tblThumb.hideRowFromHeading(etRow.getHeading(null, null, app.myCurrentLocale));
				endif;
				etRow := entTableDef.getEntTableRow(ETRow_EarliestRecLatestTS);
				if etRow &lt;&gt; null then
					self.tblThumb.hideRowFromHeading(etRow.getHeading(null, null, app.myCurrentLocale));
				endif;
				// TFS 38501 end
			endif;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowReleaseThumb" id="a3f60926-4b6d-49f9-9d52-252bcef4b37b">
        <source>doShowReleaseThumb();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwrd1	Initial creation

*/

vars
	entTableView		: EntTableView;
	entTableDef			: EntTableDef;
