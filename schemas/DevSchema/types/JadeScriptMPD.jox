    <JadeMethod name="mpdXLATFixDups" id="abf1b50b-44c5-4afc-acc9-4ea91fd845c8">
        <source>mpdXLATFixDups();
/*

Purpose:			Fix bung translations.
					eg. lblCargoSubType.caption on form (SHP_VoyageBulkCopy) was added by navdap1 on 31/05/2021 at 17:32:39 but there is no constant available in CNWDMAST.

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlgmd1	Initial creation

*/
constants
	FORM		: String = 'INV_CashModuleConfigForm';
	CONTROL 	: String = 'cmbProformaReportProf';
	PROPERTY	: String = 'bubbleHelp';
vars
	allBadXlats	: ObjectArray;
	xlatsByForm : DynaDictionary;
	iter		: Iterator;
	
	xlat		: XLAT_FormCaption;
	//xlat		: XLAT_TranslatableText;
	res			: Integer;
	now			: TimeStamp;
	
begin
	app.initialize();
	
	create allBadXlats transient;

	create xlatsByForm transient;
	xlatsByForm.setMembership(XLAT_FormCaption);
	xlatsByForm.addMemberKey(XLAT_FormCaption::vFormClass.name, true, true);
	xlatsByForm.addMemberKey(XLAT_FormCaption::vControlName.name, true, true);
	xlatsByForm.endKeys(true);
	iter := xlatsByForm.createIterator();
	
	write "XLAT_FormCaption size: " &amp; XLAT_FormCaption.instances.size.String;
	now := app.actualTime;
	write now.cnFormat_DDMMYY_hhmmsscc &amp; " Start XLAT collection object copy...";
	XLAT_FormCaption.instances.copy(xlatsByForm);
	now := app.actualTime;
	write now.cnFormat_DDMMYY_hhmmsscc &amp; " Finished";
	xlatsByForm.startKeyGeq(FORM, CONTROL, iter);
	
	while iter.next(xlat) do
		
		if xlat.vFormClass &lt;&gt; FORM then
			break;
		endif;
		
		write "Checking XLAT " &amp; self.getOidStringForObject(xlat) &amp; "...";
		
		// Chances are its just a case mismatch thats causing us grief!
		if xlat.vControlName.toLower = CONTROL.toLower and xlat.vControlProperty.toLower = PROPERTY.toLower then
			allBadXlats.add(xlat);
			continue;
		endif;
		
		break;
	endwhile;
	
	if allBadXlats.size = 0 then
		write "Error: No Translations found, nothing to do.";
		return;
	endif;
	
	if allBadXlats.size &lt; 2 then
		write "Error: Only 1 Translation found, nothing to do.";
		return;
	endif;
	
	allBadXlats.inspectModal;
	
	res := app.msgBox("Are you sure you want to delete these translations?", "Confirmation Required", MsgBox_Yes_No);
	if res = MsgBox_Return_No then
		write "Cancelled";
		return;
	endif;
	
	beginTransaction;
	allBadXlats.purge();
	commitTransaction;
	
	write "Translations successfully deleted";
	
epilog
	delete iter;
	delete allBadXlats;
end;</source>
    </JadeMethod>
</Class>
