    <JadeMethod name="updateFromToInTxt" id="9ab7d8c5-9c21-474e-a88f-c7d64ccc9ed3">
        <source>updateFromToInTxt(_newFrom, _newTo: Integer);
//----------------------------------------------------------------
//	Created:	20 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if _newFrom &gt; _newTo then
		return;
	endif;
	
	self.txtFromIn.text := _newFrom.String;
	self.txtToIn.text := _newTo.String;
	


