    <JadeMethod name="ignoreAutoTaskAction" id="15daa617-6206-4371-a0f1-08c2c1e9df0e">
        <source>ignoreAutoTaskAction(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2023	navma1 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
28 Sep 2023 navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
*/

vars
	wod : CM_WorkOrderDtl;
begin
	foreach wod in self.allWoDtls do
		if wod.isKindOf(CM_WodReceive) then
			if wod.CM_WodReceive.transport = TI_TRANSMODE_SHIP and wod.CM_WodReceive.allActionedTIs.size = 0 then
				return true;
			endif;
		elseif wod.isKindOf(CM_WodRelease) then
			if wod.CM_WodRelease.transport = TI_TRANSMODE_SHIP and wod.CM_WodRelease.allActionedTIs.size = 0 then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWorkOrderForExportReturn" id="c1cd624f-12f1-474c-85f8-750c09297e0a">
