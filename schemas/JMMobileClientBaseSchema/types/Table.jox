<GUIClass name="Table">
    <JadeMethod name="mbCanScroll" id="20c2ab42-0a7a-4441-948d-098d9b2ec924">
        <updating/>
        <source>mbCanScroll():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 February 2006 by cnwdad1
//
// Purpose:		Returns a booelan flag to indicate whether the receiver can scroll
//				(i.e. if there are rows that are not currently visible.
//
// Parameters:	None
//
// Returns:		True if the receiver can scroll, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowCount	: Integer;
	theRow		: Integer;
	theHeight	: Integer;
	
begin
	rowCount	:=	self.rows;
	
	foreach theRow in 1 to rowCount do
		theHeight := theHeight + self.accessRow(theRow).height;
	endforeach;

	return self.height &lt; theHeight;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbCanScrollOld" id="2462005f-9e38-4996-8e0b-d6edf5b26413">
        <source>mbCanScrollOld():Boolean;
// --------------------------------------------------------------------------------
// Created:		09 February 2006 by cnwdad1
//
// Purpose:		Returns a booelan flag to indicate whether the receiver can scroll
//				(i.e. if there are rows that are not currently visible.
//
// Parameters:	None
//
// Returns:		True if the receiver can scroll, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowCount	: Integer;
	rowsPerPage	: Integer;
	firstRow	: Integer;
	
begin
	rowCount	:=	self.rows;
	rowsPerPage	:=	(self.height div self.defaultRowHeight) - self.fixedRows;
	
	if rowCount &gt; rowsPerPage then
		return true;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbEnable" id="55e59511-6162-4ead-8814-7d48d714da81">
        <updating/>
        <source>mbEnable(_isEnabled:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		27 June 2006 by cnwdad1
//
// Purpose:		Enables/disables any user input of the receiver depending upon the
//				value of the parameter.
//
// Parameters:	_isEnabled - True if the receiver is to be disabled, otherwise false.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.userInputEnabled	:=	_isEnabled;
end;</source>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbScrollPage" id="497f7b38-11e1-4148-bd2a-41df95a7d80f">
        <updating/>
        <source>mbScrollPage(_isDown:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2006 by cnwdad1
//
// Purpose:		Scrolls the receiver one page, up or down.
//
// Parameters:	_isDown - True if the receiver is to be scrolled down, otherwise
//					scroll up.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowCount	: Integer;
	rowsPerPage	: Integer;
	firstRow	: Integer;
	
begin
	if _isDown then
	else
		if self.topRow = 1 then
			return;
		endif;
	endif;
	
	rowCount	:=	self.rows;
	rowsPerPage	:=	(self.height div self.defaultRowHeight) - 1;
	
	if _isDown then
		firstRow	:=	self.topRow + rowsPerPage;
		
		if firstRow &gt; rowCount then
			firstRow	:=	rowCount;
		elseif firstRow &lt; 1 then
			firstRow	:=	1;
		endif;
	else
		firstRow	:=	self.topRow - rowsPerPage;
		
		if firstRow &lt; 1 then
			firstRow	:=	1;
		endif;
	endif;
	
	if firstRow &lt;&gt; 0 then
		self.topRow	:=	firstRow;
	endif;
end;</source>
        <Parameter name="_isDown" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbSetFixedColors" id="18b67d1c-8380-470a-b46d-bcc4fb8d9a44">
        <updating/>
        <source>mbSetFixedColors(_backColor:Integer; _foreColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		17 July 2006 by cnwdad1
//
// Purpose:		Sets the foreground and background colors of the receiver's columns
//				and rows.
//
// Parameters:	_backColor - The fixed background color.
//				_foreColor - The fixed foreground color.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer		: Integer;
	colPointer		: Integer;
	lastRow			: Integer;
	lastColumn		: Integer;
	cellObj			: JadeTableCell;
	
begin
	lastRow		:=	self.fixedRows;
	lastColumn	:=	self.columns;
	
	foreach rowPointer in 1 to lastRow do
		foreach colPointer in 1 to lastColumn do
			cellObj	:=	self.accessCell(rowPointer, colPointer);
			cellObj.backColor	:=	_backColor;
			cellObj.foreColor	:=	_foreColor;
		endforeach;
	endforeach;
	
	lastRow		:=	self.rows;
	lastColumn	:=	self.fixedColumns;

	foreach colPointer in 1 to lastColumn do
		foreach rowPointer in 1 to lastRow do
			cellObj	:=	self.accessCell(rowPointer, colPointer);
			cellObj.backColor	:=	_backColor;
			cellObj.foreColor	:=	_foreColor;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_backColor" type="Integer"/>
        <Parameter name="_foreColor" type="Integer"/>
    </JadeMethod>
</GUIClass>
