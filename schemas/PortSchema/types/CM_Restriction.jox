<Class name="CM_Restriction" id="890a947b-5ed6-48da-86c2-23d4865d4e31">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>This describes a restriction imposed on a location controller (or a series of location controllers)
A restriction may be of a labour type, where a strict warning is issued for a move to the
defined area as a target, or for a yard style where certain areas may be restricted to certain criteria.</text>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="allAuditObjects" id="9d31c847-a02a-4fcd-9c32-e5f3ee976d7a">
        <kind>parent</kind>
