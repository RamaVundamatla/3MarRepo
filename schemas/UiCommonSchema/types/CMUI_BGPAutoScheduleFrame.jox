    <JadeMethod name="createTables" id="c71a8b5b-ef30-4cdf-a549-1e9e653e1343">
        <updating/>
        <source>createTables() protected, updating;

// cnwdvb1 17 December 2002 

vars

begin


	create self.tblT transient;
	create self.tblD transient;
	create self.tblM transient;
	create self.tblE transient;
	
	create self.tblStartTimes transient;
	create self.txtTimeCopy transient;
	create self.btnAdd transient;
	create self.btnRemove transient;
	
	self.form.addControl(self.tblT);
	self.form.addControl(self.tblD);
	self.form.addControl(self.tblM);
	self.form.addControl(self.tblE);
	self.form.addControl(self.tblStartTimes);
	self.form.addControl(self.txtTimeCopy);
	self.form.addControl(self.btnAdd);
	self.form.addControl(self.btnRemove);
		
	self.tblT.parent := self.frT;
	self.tblD.parent := self.frD;
	self.tblM.parent := self.frM;
	self.tblE.parent := self.frE;
	self.tblStartTimes.parent	:= self.frD;
	self.txtTimeCopy.parent		:= self.frD;		
	self.btnAdd.parent			:= self.frD;		
	self.btnRemove.parent		:= self.frD;		
		
	self.tblT.height	:= 144;
	self.tblT.top		:= 0;
	self.tblT.width		:= 207;	
	self.tblT.setDistanceFromRight(10);
	self.tblT.left				:= 10;
	self.tblT.stretchWidth		:= true;
	
	self.tblD.height	:= 144;
	self.tblD.top		:= 0;
	self.tblD.width		:= 207;
	self.tblD.setDistanceFromRight(10);
	self.tblD.left				:= 10;
	self.tblD.stretchWidth		:= true;	
	
	self.tblM.height	:= 144;
	self.tblM.top		:= 0;
	self.tblM.width		:= 207;	
	self.tblM.setDistanceFromRight(10);
	self.tblM.left				:= 10;
	self.tblM.stretchWidth		:= true;
	
	self.tblE.height	:= 144;
	self.tblE.top		:= 0;
	self.tblE.width		:= 207;	
	self.tblE.setDistanceFromRight(10);
	self.tblE.left				:= 10;
	self.tblE.stretchWidth		:= true;
	
	self.tblStartTimes.height	:= 90;
	self.tblStartTimes.left		:= 170;
	//self.tblStartTimes.top	:= 210;
	self.tblStartTimes.top		:= 230;
	self.tblStartTimes.width	:= 207;	
	self.tblStartTimes.setDistanceFromRight(10);
	self.tblStartTimes.stretchWidth := true;
		
	self.txtTimeCopy.height	:= 18;
	self.txtTimeCopy.left	:= 10;
	//self.txtTimeCopy.top	:= 210;
	self.txtTimeCopy.top	:= 230;
	self.txtTimeCopy.width	:= 90;	
	
	self.btnAdd.height	:= 18;
	self.btnAdd.left	:= 110;
	//self.btnAdd.top		:= 210;
	self.btnAdd.top		:= 230;
	self.btnAdd.width	:= 50;
	self.btnAdd.caption := '-&gt;';	
	self.btnAdd.setMyFrame(self);
	
	self.btnRemove.height	:= 18;
	self.btnRemove.left		:= 110;
	//self.btnRemove.top		:= 235;
	self.btnRemove.top		:= 255;
	self.btnRemove.width	:= 50;	
	self.btnRemove.caption 	:= '&lt;-';
	self.btnRemove.setMyFrame(self);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doButtonClick" id="404e7def-3864-4dc4-abaf-1ccdd49b4506">
        <source>doButtonClick(_btn : CMUI_BGPButton);

// cnwdvb1 17 December 2002 

vars

	timeStr : String;

begin

	if _btn = self.btnAdd then
		timeStr := self.txtTimeCopy.text;
		self.addTime(timeStr);
	elseif _btn = self.btnRemove then
		self.removeTime();
	endif;

end;</source>
        <Parameter name="_btn" type="CMUI_BGPButton"/>
    </JadeMethod>
    <JadeMethod name="doClear" id="2542283e-78e3-4bc2-89bc-c4f425ab70f5">
        <source>doClear() protected;

// cnwdvb1 15 January 2003 

/* Changes

Date		Name	TFS#	Description
============================================================================
16/04/2019	jlgka1	43863	Added Recurring Value and Recurring Unit to set as the default
							wehn adding new Monthly Schedule.
============================================================================*/
begin

	self.txtDateStartT.setDate(app.actualTimeServer.date);
	self.txtDateEndT.setDate(null/*app.actualTimeServer.date*/);	//Par 18304 Mar 2009
	self.txtDateStartD.setDate(app.actualTimeServer.date);
	self.txtDateEndD.setDate(null/*app.actualTimeServer.date*/);	//Par 18304 Mar 2009
	self.txtTimeStart.setTime(null);
	self.txtTimeStartT.setTime(null);
	self.txtTimeEnd.setTime(null);
	self.txtTimeCopy.setTime(null);
	
	self.tblM.setValueByName(ETRow_DayOfMonth, null);
	self.tblM.setValueByName(ETRow_StartTime, self.txtTimeStart.getTime());
	//jlgka1 TFS 43863 --&gt;
	self.tblM.setValueByName(ETRow_RecurNumber, 1);
	self.tblM.setValueByName(ETRow_RecurType, CM_AutoSchedule.RecurUnit_Monthly);
	//jlgka1 TFS 43863 &lt;--
	
	self.tblT.setValueByName(ETRow_StartDateT, self.txtDateStartT.getDate());
	self.tblT.setValueByName(ETRow_StartTimeT, self.txtTimeStartT.getTime());
	self.tblT.setValueByName(ETRow_EndDateT, self.txtDateEndT.getDate());
	self.tblT.setValueByName(ETRow_EndTime, self.txtTimeEnd.getTime());
	self.tblT.setValueByName(ETRow_RecurNumber, null);
	self.tblT.setValueByName(ETRow_RecurType, null);
	
	self.tblD.setValueByName(ETRow_StartDateD, self.txtDateStartD.getDate());
	self.tblD.setValueByName(ETRow_EndDateD, self.txtDateEndD.getDate());	
	self.tblD.setValueByName(ETRow_BgpMonday, null);
	self.tblD.setValueByName(ETRow_BgpTuesday, null);
	self.tblD.setValueByName(ETRow_BgpWednesday, null);
	self.tblD.setValueByName(ETRow_BgpThursday, null);
	self.tblD.setValueByName(ETRow_BgpFriday, null);
	self.tblD.setValueByName(ETRow_BgpSaturday, null);
	self.tblD.setValueByName(ETRow_BgpSunday, null);
	
	self.tblE.setValueByName(ETRow_BgpAutoEventType, null);
	self.tblStartTimes.rows := 1;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCombos" id="7478b169-fad1-4a45-8bed-25630b97cd3e">
        <source>doCombos() protected;

// cnwdvb1 16 December 2002 

vars

	count	: Integer;
	const	: Constant;
	
begin

	self.cmbTimeUnit.clear;
	
	self.cmbTimeUnit.addItem(CM_AutoSchedule.RecurUnit_Seconds);
	self.cmbTimeUnit.addItem(CM_AutoSchedule.RecurUnit_Minutes);
	self.cmbTimeUnit.addItem(CM_AutoSchedule.RecurUnit_Hours);
	self.cmbTimeUnit.addItem(CM_AutoSchedule.RecurUnit_Days);
	
	self.cmbMonthDates.clear;
	
//	self.cmbMonthDates.addItem('START');
	self.cmbMonthDates.addItem('END');
	
	foreach count in 1 to 31 do
		self.cmbMonthDates.addItem(count.String);
	endforeach;
	const := currentSchema.findGlobalConstantInBranch('EventDataVoyage');
	self.cmbEventType.addItemWithData(const.text.cnEcGetTagValueOfName('display'), EventDataVoyage);
	const := currentSchema.findGlobalConstantInBranch('EventDataInvoicing');
	self.cmbEventType.addItemWithData(const.text.cnEcGetTagValueOfName('display'), EventDataInvoicing);		// 9/3/18 MAP TFS37340
	const := currentSchema.findGlobalConstantInBranch('EventDataVVR');
	self.cmbEventType.addItemWithData(const.text.cnEcGetTagValueOfName('display'), EventDataVVR);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisableEnable" id="fd4d4378-f606-4075-8c4c-85ce035088da">
        <source>doDisableEnable(_enable : Boolean) protected;

// cnwdvb1 16 January 2003 

vars

begin

	self.tblD.userInputEnabled	:= _enable;
	self.tblT.userInputEnabled	:= _enable;
	self.tblM.userInputEnabled	:= _enable;
	self.tblE.userInputEnabled	:= _enable;	
	self.tblStartTimes.userInputEnabled := false;
	
	self.optD.enabled 			:= _enable;
	self.optT.enabled 			:= _enable;
	self.optM.enabled			:= _enable;
	self.optE.enabled			:= _enable;
	self.btnRemove.enabled 		:= _enable;
	self.btnAdd.enabled 		:= _enable;
	self.txtTimeCopy.enabled	:= _enable;
	
end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLostFocus" id="4eb2a62b-0f0b-4378-ae6e-e16a6f54eb92">
        <updating/>
        <source>doLostFocus(_control : Control) updating;

// cnwdvb1 18 December 2002 

vars
	control : Control;
begin

	if self.myTable = null then
		return;
	endif;
	control := _control;
	if _control.isKindOf(ComboBox) then
		self.myTable.setValueByControlName(_control.ComboBox.name, _control.ComboBox.text);
	elseif _control.isKindOf(CMUI_DateMaskBGP) then
		self.myTable.setValueByControlName(_control.CMUI_DateMaskBGP.name, control.CMUI_DateMaskBGP.getDate());
	elseif _control.isKindOf(CMUI_TimeMaskBGP) then
		self.myTable.setValueByControlName(_control.CMUI_TimeMaskBGP.name, control.CMUI_TimeMaskBGP.getTime());
	endif;

end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doOptionButtonClick" id="c67cd12a-8d87-4130-a07d-9387fb016bb5">
        <updating/>
        <source>doOptionButtonClick(_optionButton : CMUI_BGPOptionButton) updating;

// cnwdvb1 18 December 2002 

vars

begin

	if _optionButton = self.optT then
		self.cmbEventType.visible := false;
		self.frT.visible := true;
		self.frD.visible := false;
		self.frM.visible := false;
		self.frE.visible := false;
		self.myTable := self.tblT;
		self.loadForTime();
	elseif _optionButton = self.optD then
		self.cmbEventType.visible := false;
		self.frD.visible := true;
		self.frT.visible := false;
		self.frM.visible := false;
		self.frE.visible := false;
		self.myTable := self.tblD;
		self.loadForDay();
	elseif _optionButton = self.optM then
		self.cmbEventType.visible := false;
		self.frM.visible := true;
		self.frD.visible := false;
		self.frT.visible := false;
		self.frE.visible := false;
		self.myTable := self.tblM;
		self.loadForDate();
	elseif _optionButton = self.optE then
		self.frE.visible 	:= true;
		self.frM.visible	:= false;
		self.frD.visible	:= false;
		self.frT.visible	:= false;
		self.myTable		:= self.tblE;
		self.loadForEvent();
	endif;
	
	
end;</source>
        <Parameter name="_optionButton" type="CMUI_BGPOptionButton"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="a8d6a9d4-9d16-480b-89ab-3c870744e0d7">
        <source>doSave() : Boolean;

// cnwdvb1 14 January 2003 

vars

begin

	if self.myProxyAutoSchedule &lt;&gt; null then
		self.myProxyAutoSchedule.raiseExceptionIfNotTransient(method);
		if self.optT.value then
			self.setProxyForTime(self.myProxyAutoSchedule);
		elseif self.optD.value then
			self.setProxyForDay(self.myProxyAutoSchedule);
		elseif self.optM.value then
			self.setProxyForDate(self.myProxyAutoSchedule);
		else
			self.setProxyForEvent(self.myProxyAutoSchedule);
		endif;
		return true;
	endif;
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTables" id="f8c1440c-d799-469b-9035-17bb233454f8">
        <source>doTables() protected;

// cnwdvb1 31 January 2003 

vars

	entTableControl	: EntTableDef;
	def				: String;

begin

	def := ETDef_BgpAutoDay;
	self.tblStartTimes.setColumnHeadingsFromDef(ETDef_BgpAutoDailyTimes, true);
	self.tblStartTimes.selectionType := CM_BaseTable.SelectionType_Row;
	entTableControl := app.myController.getEntTableDef(def);
	self.tblD.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblD.optimiseHeadingColumn();
	self.tblD.cnEcResizeContents();
	
	def := ETDef_BgpAutoTime;
	entTableControl := app.myController.getEntTableDef(def);
	self.tblT.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblT.optimiseHeadingColumn();
	self.tblT.cnEcResizeContents();
	
	def := ETDef_BgpAutoMonth;
	entTableControl := app.myController.getEntTableDef(def);
	self.tblM.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblM.optimiseHeadingColumn();
	self.tblM.cnEcResizeContents();
	
	def := ETDef_BgpAutoEvent;
	entTableControl := app.myController.getEntTableDef(def);
	self.tblE.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblE.optimiseHeadingColumn();
	self.tblE.cnEcResizeContents();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadAutoSchedule" id="41fb34c8-8cf2-4eac-9b0b-3abd77c63d70">
        <updating/>
        <source>loadAutoSchedule(_auto : CM_AutoSchedule; _isEditTable : Boolean) updating;

// cnwdvb1 18 December 2002 

vars

	

begin

	self.myProxyAutoSchedule := _auto;
	self.doDisableEnable(_isEditTable);
	if self.myProxyAutoSchedule = null then
		return;
	endif;
	if _auto.selectionState = State_Day then
		self.optD.value := true;
		self.optD.click(optD);
	elseif _auto.selectionState = State_Date then
		self.optM.value := true;
		self.optM.click(optM);
	elseif _auto.selectionState = State_Time then
		self.optT.value := true;
		self.optT.click(optT);
	elseif _auto.selectionState = State_Event then
		self.optE.value := true;
		self.optE.click(optT);
	else
		self.optT.value := true;
		self.optT.click(optT);
		self.doClear();
		// Just load up blank new one.
	endif;

end;</source>
        <Parameter name="_auto" type="CM_AutoSchedule"/>
        <Parameter name="_isEditTable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadForDate" id="ba10cb74-0474-4d39-9deb-1feacf6dae1b">
        <source>loadForDate() protected;

// cnwdvb1 14 January 2003 

/* Changes

Date		Name	TFS#	Description
============================================================================
16/04/2019	jlgka1	43863	Add Recurring Value to show in the Table when the option is Monthly.
============================================================================*/
begin

	if self.tblM.userInputEnabled then
		self.optM.setFocus();
//		self.tblM.setFocus();
//		self.tblM.moveFirst();
	endif;
	self.tblM.setValueByName(ETRow_BgpAutoDescription, self.myProxyAutoSchedule.description);
	if self.myProxyAutoSchedule &lt;&gt; null and self.myProxyAutoSchedule.selectionState = State_Date then
		self.tblM.setValueByName(ETRow_DayOfMonth, self.myProxyAutoSchedule.dayOfMonth);
		self.txtTimeStart.setTime(self.myProxyAutoSchedule.allRunTimes.first.Time);
		self.tblM.setValueByName(ETRow_StartTime, self.txtTimeStart.getTime());		
		//jlgka1 TFS 43863 --&gt;
		self.tblM.setValueByName(ETRow_RecurNumber, self.myProxyAutoSchedule.recurValue);		
		self.cmbTimeUnit.listIndex := self.cmbTimeUnit.findStringExact(1, self.myProxyAutoSchedule.recurUnit);
		//jlgka1 TFS 43863 &lt;--
	else
		self.doClear();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadForDay" id="998572f9-7729-4ba0-ae6b-28d568daf9f0">
        <source>loadForDay() protected;

// cnwdvb1 14 January 2003 

vars

	value 		: Boolean;
	runTime		: Time;

begin

	if self.tblD.userInputEnabled then
		self.optD.setFocus();
//		self.tblD.setFocus();
//		self.tblD.moveFirst();
	endif;
	self.tblD.setValueByName(ETRow_BgpAutoDescription, self.myProxyAutoSchedule.description);
	if self.myProxyAutoSchedule &lt;&gt; null and self.myProxyAutoSchedule.selectionState = State_Day then 
		self.txtDateStartD.setDate(self.myProxyAutoSchedule.startScheduleTs.date);
		self.txtDateEndD.setDate(self.myProxyAutoSchedule.endScheduleTs.date);
		self.tblD.setValueByName(ETRow_StartDateD, self.txtDateStartD.getDate());
		self.tblD.setValueByName(ETRow_EndDateD, self.txtDateEndD.getDate());
			
		if self.myProxyAutoSchedule.allRunDays.size = 7 then
			value := self.myProxyAutoSchedule.allRunDays[1];
			self.tblD.setValueByName(ETRow_BgpMonday, value);
					
			value := self.myProxyAutoSchedule.allRunDays[2];
			self.tblD.setValueByName(ETRow_BgpTuesday, value);
					
			value := self.myProxyAutoSchedule.allRunDays[3];
			self.tblD.setValueByName(ETRow_BgpWednesday, value);
				
			value := self.myProxyAutoSchedule.allRunDays[4];
			self.tblD.setValueByName(ETRow_BgpThursday, value);
					
			value := self.myProxyAutoSchedule.allRunDays[5];
			self.tblD.setValueByName(ETRow_BgpFriday, value);
					
			value := self.myProxyAutoSchedule.allRunDays[6];
			self.tblD.setValueByName(ETRow_BgpSaturday, value);
					
			value := self.myProxyAutoSchedule.allRunDays[7];
			self.tblD.setValueByName(ETRow_BgpSunday, value);
					
			self.tblStartTimes.rows := 1;
			foreach runTime in self.myProxyAutoSchedule.allRunTimes do
				self.addTime(runTime.format('HH:mm:ss'));
			endforeach;
		endif;
		self.txtTimeCopy.setTime(null);
	else
		self.doClear();
	endif;
	
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadForEvent" id="988b9ac0-6cf4-4912-90d8-192b2478da4c">
        <source>loadForEvent() protected;
// -------------------------------------------
// Created 29 June 2004 by cnwdvb1
// -------------------------------------------
vars

	const		: Constant;
	i,	
	numItems	: Integer;	

begin
	
	if self.tblE.userInputEnabled then
