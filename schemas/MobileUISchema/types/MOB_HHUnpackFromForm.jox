    <JadeMethod name="doFindLocation" id="92fd5d3e-ff64-48f2-8d17-5000f4b89be4">
        <updating/>
        <source>doFindLocation() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	idString : String;
	tmpFoundLC: CM_LocationsController;
	tmpFoundHeight : Integer;
	errMess : String;

begin

	idString := txtLocation.text.trimBlanks.toUpper;
	if idString = null or idString = lblLocation.caption.toUpper then
		self.myDefaultLocation := null;
		return;
	endif;
	
	self.myTerminal.findLocationFromString(idString, true, tmpFoundLC, tmpFoundHeight);
	
	if tmpFoundLC = null then
		errMess := app.getErrorString1(Location_NotFound, "'" &amp; idString &amp; "'");
	else
		
		if not tmpFoundLC.isYardLocation then
			errMess := app.getErrorString(Location_must_yard);
		elseif tmpFoundLC.isVehicle then
			errMess := app.getErrorString(Location_Not_vehicle);
		elseif tmpFoundLC.isMachineController then	// Par 23284
			errMess := app.getErrorString(Location_must_yard);
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		self.txtLocation.setFocus();
		self.myDefaultLocation := null;
		return;
	endif;
	
	self.myDefaultLocation := tmpFoundLC;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindTrackedItem" id="74403374-7a78-4704-9ed1-d5f5d9992a1b">
        <updating/>
        <source>doFindTrackedItem():CM_TrackedItem updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Jul 2011	cnwndl1	Initial creation
30 Aug 2012	cnwkpd1	PAR #28731 - Transient leaks in JMT

*/

vars

	contId : String;
	ti : CM_TrackedItem;
	allTis : CM_TISet;

begin

	contId := txtContainerId.text.trimBlanks.toUpper;

	if contId = lblContainerId.caption.toUpper or contId = null then
		myUnpackContainer := null;
		return null;
	endif;
	
	create allTis transient;
	self.myTerminal.getTIsMatchingId( contId,  null, allTis, TI_STATE_NORMAL);
	
	if allTis.isEmpty then
		return null;
	endif;
	
	return allTis.first;

epilog
	delete allTis;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="445ba853-b620-465c-9ead-d9d7e7a05a0c">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.txtContainerId.setAndIncrementTabIndex( tabIndex );
		self.txtContainerId.visible := true;
	endif;
	self.txtContainerId.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
								
	if _initialSetup then
		self.txtContainerId.text := self.lblContainerId.caption;
	endif;
								
	top := self.txtContainerId.top + self.txtContainerId.height + self.resizedMargin;
	if _initialSetup then
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );


	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="1309ed67-f371-462c-966c-9e0f5b240d1b">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	mess : String;

begin

	self.myUnpackContainer := self.doFindTrackedItem();

	if self.myUnpackContainer = null then
		mess := "Container not found '" &amp; self.txtContainerId.text.toUpper.trimBlanks &amp; "'";
		self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
		self.txtContainerId.setFocus();
		return;
	endif;
	
	self.myMobileGenericAgent.setUnPackContainerDetails(	self.myUnpackContainer,	//_trackedItem : CM_TrackedItem;
															self.myDefaultLocation	//_location : CM_LocationsController
															);	
	self.gotoForm( MOB_HHUnpackContainerForm, false );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="470d6497-1bf5-448b-b68f-b4ead365db35">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin
	
	self.myMobileGenericAgent.clearAll();
	app.myMobileAgent.setMyProxy( null );
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControls" id="89c154bf-d224-4ea6-ba69-101a2ae5db4e">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin
	
	self.doResizeControls(true);
	
	self.txtLocation.text := self.lblLocation.caption;
	
	if self.myMobileGenericAgent.myUnpackTi &lt;&gt; null then
		self.myUnpackContainer := self.myMobileGenericAgent.myUnpackTi;
		self.txtContainerId.text := self.myUnpackContainer.id;
	endif;
	if self.myMobileGenericAgent.myUnpackDefaultLocation &lt;&gt; null then
		self.myDefaultLocation := self.myMobileGenericAgent.myUnpackDefaultLocation;
		self.txtLocation.text := self.myDefaultLocation.getFullId;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2bd52d72-3d2b-4ba3-9ca3-9dbc2a59284d">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3da27775-3607-488d-b422-771dc2187b18">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016638, locale);
	lblContainerId.translateCaption(Xlat_0016639, locale);
	lblLocation.translateCaption(Xlat_0016640, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtContainerId_gotFocus" id="e9e05b65-0335-4ef8-9115-b4e5c05c78e1">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtContainerId_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if txtContainerId.text.toUpper = lblContainerId.caption.toUpper then
		txtContainerId.selStart := 0;
		txtContainerId.selLength := lblContainerId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtContainerId_lostFocus" id="5f3ca9ba-180a-49fc-9403-b49c3c1fa1fe">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtContainerId_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if txtContainerId.text.trimBlanks = null then
		txtContainerId.text := lblContainerId.caption;
	endif;
	
	txtContainerId.selStart := 0;
	txtContainerId.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
