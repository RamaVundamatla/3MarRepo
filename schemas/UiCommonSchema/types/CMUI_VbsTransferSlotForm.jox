    <JadeMethod name="validateTransferSlotTime" id="64d48bd0-6247-47d3-a3b5-fba1daee5c81">
        <source>validateTransferSlotTime() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots
23 Jan 2023	navak20 Task 55835: EUP - VBS MTN - [8] - Transfer Slots - Validate Transferring slots to future
26 Apr 2023 navhl20	Bug 57318:[57669] MTN - Cannot transfer VBS Slot to next day
07 Aug 2023	navma1	FR | 53429 - VBS Slot transfer - Current date
*/

vars
	newStartTS	: TimeStamp;
	currentTS	: TimeStamp;
begin
	newStartTS.setDate(self.txtStartDate.getDate());
	newStartTS.setTime(self.txtStartTime.getTime());
	
	currentTS := self.systemToLocalTime(app.actualTimeServer);
	
	if newStartTS.date &lt; currentTS.date then							//07.08.2023 navma1 #53429				
		app.msgBox(app.getErrorString(Transfer_only_for_future), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
