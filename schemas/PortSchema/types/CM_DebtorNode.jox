    <JadeMethod name="pxyCreateUpdateProxy" id="228fc5e7-51e9-48a3-8ee9-2d1b16699118">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------
//	Created:	23 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxy	: CM_DebtorNode;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	pxy.myParentDebtorNode	:= self.myParentDebtorNode;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="reinstate" id="cfcdab65-802c-4b6c-8a86-b94067ff0473">
        <updating/>
        <source>reinstate(doSubDebtors: Boolean) updating;

vars
	subDebtorNode:   CM_DebtorNode;
begin
	if doSubDebtors then
		foreach subDebtorNode in self.allChildDebtorNodes do
			subDebtorNode.reinstate(doSubDebtors);
		endforeach;
	endif;

	self.isSuspended := false;

end;</source>
        <Parameter name="doSubDebtors" type="Boolean"/>
    </JadeMethod>
