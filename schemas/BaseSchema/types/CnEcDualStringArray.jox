    <JadeMethod name="clear" id="db5edcf3-0e18-47c4-b9bb-12e77f2460ca">
        <lockReceiver/>
        <updating/>
        <source>clear() updating, lockReceiver;
// -----------------------------------------------------------------------------
// Created:		10 October 2001 by cnwndl1
//
// Purpose:		Clears the receiver and its array property.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod();
	self.secondArray.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcAdd" id="343b5b04-7c02-4092-bf4f-edd0b73310b2">
        <lockReceiver/>
        <updating/>
        <source>cnEcAdd(pFirstValue:String; pSecondValue:String) updating;

begin
	self.add(pFirstValue);
	self.secondArray.add(pSecondValue);
end;</source>
        <Parameter name="pFirstValue" type="String"/>
        <Parameter name="pSecondValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcChange" id="3a3d8115-e266-426b-83e8-164bcca3b17c">
        <source>cnEcChange(pFirstValue:String; pSecondValue:String io; pPos:Integer);

begin
	if pPos &lt;= self.size() then
		self[pPos]				:=	pFirstValue;
		self.secondArray[pPos]	:=	pSecondValue;
	endif;
end;</source>
        <Parameter name="pFirstValue" type="String"/>
        <Parameter name="pSecondValue" type="String" usage="io"/>
        <Parameter name="pPos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGet" id="8b123757-cfe0-4096-8e58-828ebea881f0">
        <source>cnEcGet(pFirstValue:String io; pSecondValue:String io; pPos:Integer);

begin
	if pPos &lt;= self.size() then
		pFirstValue		:=	self[pPos];
		pSecondValue	:=	self.secondArray[pPos];
	endif;
end;</source>
        <Parameter name="pFirstValue" type="String" usage="io"/>
        <Parameter name="pSecondValue" type="String" usage="io"/>
        <Parameter name="pPos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsPrimitiveArray" id="bc834702-4bdf-49aa-8267-4db798de2039">
        <source>cnEcIsPrimitiveArray(): Boolean;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
