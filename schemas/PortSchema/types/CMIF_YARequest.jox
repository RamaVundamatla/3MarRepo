    <JadeMethod name="setMyAllocation" id="9352fb9d-13ff-474d-a352-96a14e9407d0">
        <updating/>
        <source>setMyAllocation( _terminal: CM_Terminal; _anAllocation : CM_YardAllocation) updating;

/*

Purpose:			
//cnwrd1 ccms 1303 14.11.2012
Parameters:			

Return Value:		


Date		Who		Reason
13 November 2012	cnwrd1	Initial creation

*/

vars
	obj : Object;
	anInteger : Integer;
	yaData : CM_YAData;
	yaCriteria : CM_YACriteria;
begin

	self.myAllocation := _anAllocation;
	self.myTerminal := _terminal;
	
	if self.myAllocation &lt;&gt; null then
	// I want to setup some defaults here from the allocation.
	
	
		yaCriteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_OperatorItem);
		
		if yaCriteria &lt;&gt; null then
			yaData := yaCriteria.myYAData;
			obj := yaData.CM_YADataObjects.allObjects.first;
			if obj &lt;&gt; null and obj.isKindOf(CM_Operator) then //should be
				self.operatorCode := obj.CM_Operator.code;
			endif;
		endif;
		
		
		yaCriteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_ISO);
		
		if yaCriteria &lt;&gt; null then
			yaData := yaCriteria.myYAData;
			obj := yaData.CM_YADataObjects.allObjects.first;
			if obj &lt;&gt; null and obj.isKindOf(CM_ISOType) then //should be
				self.isoType := obj.CM_ISOType.code;
			endif;
		endif;
		
		
		yaCriteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_ISOGroup);
		
		if yaCriteria &lt;&gt; null then
			yaData := yaCriteria.myYAData;
			obj := yaData.CM_YADataObjects.allObjects.first;
			if obj &lt;&gt; null and obj.isKindOf(CM_ISOTypeGroup) then //should be
				self.isoGroup := obj.CM_ISOTypeGroup.code;
			endif;
		endif;
		
				
		yaCriteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_CargoType);
		
		if yaCriteria &lt;&gt; null then
			yaData := yaCriteria.myYAData;
			obj := yaData.CM_YADataObjects.allObjects.first;
			if obj &lt;&gt; null and obj.isKindOf(CM_CargoType) then //should be
				self.myCargoType := obj.CM_CargoType;
				
			endif;
		endif;
	
	
					
		yaCriteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_Commodity);		
		if yaCriteria &lt;&gt; null then
			yaData := yaCriteria.myYAData;
			obj := yaData.CM_YADataObjects.allObjects.first;
			if obj &lt;&gt; null and obj.isKindOf(CM_Commodity) then //should be
				self.myCommodity := obj.CM_Commodity;
				
			endif;
		endif;
		
		yaCriteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_Consignee);		
		if yaCriteria &lt;&gt; null then
			yaData := yaCriteria.myYAData;
			obj := yaData.CM_YADataObjects.allObjects.first;
			if obj &lt;&gt; null and obj.isKindOf(CM_ConsigneeConsignor) then //should be
				self.consigneeCode := obj.CM_ConsigneeConsignor.code;
			endif;
		endif;
		
		yaCriteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_Clean);		
		if yaCriteria &lt;&gt; null then
			yaData := yaCriteria.myYAData;
			self.clean := yaData.CM_YADataBoolean.getDataValue().Boolean;
		endif;
		
		/*yaCriteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_ImexStatus);
		
		if yaCriteria &lt;&gt; null then
			yaData := yaCriteria.myYAData;
			yaData.CM_YADataInteger.allValues.copy(self.imexStatusArray);
		endif;
		*/
		if self.myAllocation.isKindOf(CM_VoyageAllocation) then
			self.voyageCode := self.myAllocation.CM_VoyageAllocation.myVoyage.code;
		endif;
		
		//07/10/2025	navkc1 JIRA 36148
		yaCriteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_CargoTypeCont);
		if yaCriteria &lt;&gt; null then
			yaData := yaCriteria.myYAData;
			obj := yaData.CM_YADataObjects.allObjects.first;
			if obj &lt;&gt; null and obj.isKindOf(CM_CargoType) then
				self.myCargoTypeForContents := obj.CM_CargoType;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_anAllocation" type="CM_YardAllocation"/>
    </JadeMethod>
</Class>
