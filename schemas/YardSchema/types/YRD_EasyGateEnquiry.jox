    <JadeMethod name="removeFromTable" id="c8ecc9c5-e33c-4851-ad1d-46963ec8e9f2">
        <source>removeFromTable( _obj : CM_Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars
	theDataLine : String;
	interTermMove	: CM_InterTerminalMove;
	theRow : Integer;
begin
	// somethings been deleted we need to find if we have it in the table and remove.
	
	if CM_InterTerminalMove.hasInstance(_obj) then
		interTermMove := _obj.CM_InterTerminalMove;
	else
		return;
	endif;

	

	self.tblData.findObjectInRow(interTermMove, theRow);

	if theRow &gt; 0 then
		self.tblData.removeDeletedObject(interTermMove);
	endif;


epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="returnCargoToTruck" id="a73a2f0a-6a55-44f0-86fd-b1ca35591977">
        <updating/>
        <source>returnCargoToTruck(_interTerminalMove : CM_InterTerminalMove io) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 February 2010	conkc1	Initial creation

*/
vars

	interTermVehicleJob : CM_InterTermVehicleJob;
	proxyMove           : CM_InterTerminalMove;
	result              : Integer;
	
begin

write method.qualifiedName;

	interTermVehicleJob := _interTerminalMove.myInterTermVehicleJob;
	if interTermVehicleJob = null then
		app.msgBox('Dev message - Inter Term Vehicle Job missing', app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	//reloading accidental unload
	proxyMove     := _interTerminalMove.pxyCreateUpdateProxy();
	proxyMove.setStatus( ITT_LOADED );
	proxyMove.setMyTargetLC( null );
	
	while true do
		app.myTrxUA.trxUpdateInterTerminalMove( proxyMove, app.myPassport ); 
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
	return true;
	
epilog
	delete proxyMove;
end;</source>
        <Parameter name="_interTerminalMove" type="CM_InterTerminalMove" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setButtonState" id="4b779615-e712-470d-8670-bb985cabf720">
        <updating/>
        <source>setButtonState() updating;
/*

Purpose:			Enable or disable the appropriate icons (buttons)

Parameters:			self.myCurrentInterTerminalMove

Return Value:		

Date				Who		Reason
25 February 2010	conkc1	Initial creation

*/
vars

begin

	self.btnLoadTruck.enabled   := true;
	self.btnReturnTruck.enabled := false;
	self.btnReturnYard.enabled  := false;
	self.btnUnloadTruck.enabled := false;
	
	if self.myCurrentInterTerminalMove = null then
		self.setButtonsForView(); // TFS 2734
		return;
	endif;

	if self.myCurrentInterTerminalMove.status = ITT_LOADING then
		if self.myCurrentInterTerminalMove.mySourceTerminal = self.myTerminal then
			self.btnReturnYard.enabled  := true;
		endif;
	elseif self.myCurrentInterTerminalMove.status = ITT_LOADED then
		if self.myCurrentInterTerminalMove.myTargetTerminal = self.myTerminal then
			self.btnUnloadTruck.enabled := true;		
		else
			self.btnReturnYard.enabled  := true;
		endif;
	elseif self.myCurrentInterTerminalMove.status = ITT_UNLOADING then
		if self.myCurrentInterTerminalMove.myTargetTerminal = self.myTerminal then
			self.btnUnloadTruck.enabled := true;
			self.btnReturnTruck.enabled := true;
		endif;
	elseif self.myCurrentInterTerminalMove.status = ITT_UNLOADED then

	endif;
	
	self.setButtonsForView(); // TFS 2734
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setButtonsForView" id="e0a78e59-b6a7-4832-a1f5-ca2ff28bd8d7">
        <source>setButtonsForView();
/*
Purpose:			
Date		Who		Reason
12 October 2016	cnwab1	Initial creation
*/

vars

begin
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnLoadTruck.enabled:= false;
		self.btnReturnTruck.enabled:= false;
		self.btnReturnYard.enabled:= false;
		self.btnUnloadTruck.enabled:= false;
		self.mnuLoadTruck.visible := false;
		self.mnuReturnTruck.visible := false;
		self.mnuReturnYard.visible := false;
		self.mnuUnloadTruck.visible := false;
		self.mnuLoadTruckEG.visible := false;
		self.mnuReturnTruckEG.visible := false;
		self.mnuReturnYardEG.visible := false;
		self.mnuUnloadTruckEG.visible := false;
		self.mnuDeleteLoadEG.visible := false;
		self.mnuCompleteEG.visible := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bbf39449-438e-440e-8591-b21eec070d9b">
