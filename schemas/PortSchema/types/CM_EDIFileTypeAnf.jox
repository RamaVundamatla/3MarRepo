    <JadeMethod name="create" id="633e992e-8200-43c7-9bda-e753a205e116">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name 	:= "ANF Container Prenotification";
	self.type	:= EDIFileType_Anf;
end;</source>
    </JadeMethod>
    <JadeMethod name="createEDIData" id="6141906e-5741-4d9b-8936-56baefb8d114">
        <source>createEDIData(_transient: Boolean): CM_EDIDataPrenote;
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	prenote	: CM_EDIDataPrenote;
begin

	if _transient then
		create prenote transient;
	else
		create prenote persistent;
	endif;

	return prenote;


end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_EDIDataPrenote"/>
    </JadeMethod>
    <JadeMethod name="extractFile" id="eca67614-aaad-4e63-8dd9-c7b209d7846b">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	16 Jan 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
constants
	HDR1 : String = "$$$HDR** ANF COY: ";
	HDR2 : String = "    FILE MADE AT: ";
	EOT : String = "$$$EOT**VAR /MULTI   DATA RECORDS =";
vars
	ediDataPrenote	: CM_EDIDataPrenote;
	ediTI			: CM_EDITrackedItem;
	xlOperator		: CM_Operator;
	voyageOid		: CM_Voyage;
	now				: TimeStamp;
	terminal		: CM_Terminal;
	strTime			: String;
	ediData			: CM_EDIData;
	foundMatch		: Boolean;
	str : String;
begin

	terminal := app.myPassport.myTerminal;
	ediData := _ediFile.ediData;
	
	strTime := now.time.format("HHmm") &amp; "/" &amp; now.date.format("ddMMyy") &amp; "/";
	
	if (not CM_EDIDataPrenote.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;
	
	ediDataPrenote := ediData.CM_EDIDataPrenote;

	if _recipient = null then
		xlOperator := app.myRoot.allOperators[ediDataPrenote.operatorCode];
	else
		xlOperator := _recipient;
	endif;
	
	if xlOperator = null and _recipient &lt;&gt; null then
		xlOperator := _recipient;
	endif;

	// Header
	str := str &amp; HDR1 &amp; terminal.name.padTrimTo(21) &amp; strTime &amp; strTime &amp; HDR2 &amp; strTime &amp; " X " &amp; xlOperator.getXlationForeignCode(terminal.getConfig(PortDestCode).String,XLATION_TYPE_PORT_BYOP, foundMatch).padBlanks(5) &amp; " " &amp; CrLf;


	//------------------------------------------
	// Now the TIs
	//------------------------------------------
	foreach ediTI in ediDataPrenote.allEDITrackedItems do
		str := str &amp; self.extractTI(ediTI.CM_EDIPrenoteTI, null, xlOperator);
	endforeach;

	_ediFile.setNumContainers(ediData.allEDITrackedItems.size);
	
	// Footer
	str := str &amp; EOT &amp; (_ediFile.containers).String.padLeftBlanks(5) &amp; " " &amp; CrLf;
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();
	
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractTI" id="d9085fc7-dc2d-4e02-94da-0d7497939b97">
        <updating/>
        <source>extractTI(_ediTI : CM_EDITrackedItem input; _number : Integer; _operator : CM_Operator) : String updating, protected;
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET

vars
	message		: String;
	anfTI		: CM_EDIPrenoteTI;
	xlOperator	: CM_Operator;
	str			: String;
	foundMatch	: Boolean;
begin
	xlOperator := _operator;
	
	if not CM_EDIPrenoteTI.hasInstance(_ediTI) then
		app.raiseCMWarning1(ERR_INVALID_VALUE, 'EDI file type', 'fileType', null, self);
		return str;
	endif;
	
	anfTI := _ediTI.CM_EDIPrenoteTI;
	
										//1:8	// cnwrl1 09/06/2010 PAR 24299 - what it was
	str := xlOperator.getXlationForeignCode(anfTI.getVoyageCode(), XLATION_TYPE_VOYAGETERMINAL, foundMatch).padTrimTo(8) &amp;										//1:8
								" " &amp;															//9:1	??
								anfTI.locationId.padTrimTo(6) &amp; 								//10:6	could be longer - print 6 for now
								"".padTrimTo(5) &amp; 												//16:5		??
								anfTI.id.padTrimTo(11) &amp;										//21:11
								"".padTrimTo(10) &amp;												//32:10	date ?	"9910270606"
								anfTI.loadPort.padTrimTo(3)		&amp;								//42:3
								anfTI.operatorCode.padTrimTo(3)	&amp; 								//45:3
								"".padTrimTo(4) &amp;												//48:4			"ANFW"
								xlOperator.getXlationForeignCode(anfTI.isoType, XLATION_TYPE_ISOTYPE_BYOP, foundMatch).padTrimTo(4) &amp; 									//52:4
								"".padTrimTo(7) &amp;												//56:7			"       "
								"".padTrimTo(6) &amp;												//63:6	date ?	"991027"
								"".padTrimTo(6) &amp;												//69:6  flags?	"NY1   "
								anfTI.commodityDescription.padTrimTo(12) &amp;						//75:12
								anfTI.weight.stringWithLeadingZeros(5)	&amp;						//87:5
								anfTI.dischargePort.padTrimTo(3)	&amp; 							//92:3
								anfTI.destinationPort.padTrimTo(3)	&amp; 							//95:3
								anfTI.bookingRef.padTrimTo(9) &amp;									//98:9  BRef?	"AKL146199"
								"".padTrimTo(3) &amp;												//107:3  flags?	"NNN"
								"".padTrimTo(9) &amp;												//110:9  ?? 	"00288311 "
								xlOperator.getXlationForeignCode(anfTI.commodity, XLATION_TYPE_COMMODITY_BYOP, foundMatch).padTrimTo(4)	&amp;								//119:4
								anfTI.getLength.padTrimTo(3) &amp;									//123:3
								anfTI.getWidth.padTrimTo(3) &amp;									//126:3		
								anfTI.getHeight.padTrimTo(3) &amp;									//129:3
								anfTI.getOutputTemp.padTrimTo(4) &amp;								//132:4
								"".padTrimTo(45)  												//136:end		??
								;
	return str;						

	/*
	there is a wierd field in here - not sure whether it's right or wrong but the temperature field will steal the right
	most position off the height field if it requires a - (negative) sign.  Doesn't sound right to me, but anyways... 
	there may be a short version of this format (131 char line length ?)
	*/
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="3d1c0a25-644b-41c8-9d01-46d8d81cc3b1">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010

// cnwdvb1 29 January 2003 

vars

begin
	_ediDataClass := CM_EDIDataPrenote;
	_dataType := EDIDataType_Prenote;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="fd49ac22-949b-4266-b1b0-32e43fbabdf2">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/12/2024	navkc1 JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return self.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
