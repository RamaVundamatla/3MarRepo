    <JadeMethod name="validateMe" id="81ced27e-cdd4-4d2f-b60b-df8bd55bcc85">
        <source>validateMe() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code), null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	self.isValidCode( self.code );
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Description), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Description), null, null); // cnwdb2	PAR 35364
		return;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
