	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;	

	if tmpStr = app.getErrorString(Inspected) then
		return LOG_ROW_INSPECTED;
	elseif tmpStr = app.getErrorString(NotInspected) then
		return LOG_ROW_NOTINSPECTED;
	endif;
	
	return 0;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedSapStatus" id="494a058e-648e-43de-8b54-d688811fe0c5">
        <source>getSelectedSapStatus() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Hosst (H2H) Monitoring
//
vars
	tmpStr : String;
	reportParam	: WS_ReportParameter;
	
begin
	reportParam := self.allWSReportParams.getAtKey(ETRow_SapStatus);
	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;
	if tmpStr = "1" then
		tmpStr := app.getErrorString(SAP_Hold);
	elseif tmpStr = "2" then
		tmpStr := app.getErrorString(Debit);
	elseif tmpStr = "3" then
		tmpStr := app.getErrorString(Cancelled);
	endif;
	app.writeLog(method.qualifiedName &amp; " tmpStr for SAP Status is " &amp; tmpStr, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	return tmpStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedSapTransaction" id="334f6c73-be46-4756-a6a8-41ec102dbd54">
        <source>getSelectedSapTransaction() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Hosst (H2H) Monitoring
//
vars
	tmpStr : String;
	reportParam	: WS_ReportParameter;
	
begin
	reportParam := self.allWSReportParams.getAtKey(ETRow_Transaction);
	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;	
	if tmpStr = "1" then
		tmpStr := "Vessel";
	elseif tmpStr = "2" then
		tmpStr := "Cargo";
	endif;
	app.writeLog(method.qualifiedName &amp; " tmpStr for SAP Transaction is " &amp; tmpStr, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	return tmpStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
