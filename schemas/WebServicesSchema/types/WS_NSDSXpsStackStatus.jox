    <JadeMethod name="setProxyObject" id="b2e155d3-b155-4e8a-89f2-bf4b770f26a3">
        <updating/>
        <source>setProxyObject(_any: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2022	navsp1	Initial creation TFS#53369

*/

vars
	helper 		: CMIF_XpsStackStatus;
	ewsOpsView 	: CM_EWSActivityOpsview;
begin
	inheritMethod(_any);
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView); 
	
	self.tableName					:= helper.tableName;
	self.gkey						:= helper.gkey;
	self.bin 						:= helper.bin;
	self.bin_name					:= helper.bin_name;
	self.pkey						:= helper.pkey;
	self.status_chars				:= helper.status_chars;
	self.reefer_limit				:= helper.reefer_limit;
	self.max_tier_limit				:= helper.max_tier_limit;
	self.is_temp_blocked			:= helper.is_temp_blocked;
	self.is_men_working				:= helper.is_men_working;
	self.is_active					:= helper.is_active;
	self.yard_id					:= helper.yard_id; // ### TFS 53369 28APR2022 NAVAB1
	self.derived_capacity			:= helper.derived_capacity; //navra1 - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022
	self.measurement_unit_type		:= helper.measurement_unit_type; //navra1 - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022
	self.derived_measure_unit		:= helper.derived_measure_unit; //navra1 - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022
	
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
