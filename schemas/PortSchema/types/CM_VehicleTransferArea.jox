    <JadeMethod name="ccms1061_assert" id="f4c47445-d799-4693-a809-60cd42412a4c">
        <source>ccms1061_assert(_condition :Boolean; _message :String)protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not _condition then
		app.raiseUnexpectedProgramError (self.class.name, method.name, _message);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_condition" type="Boolean"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="ccms1061_conversion_moveTIs" id="cb988b77-65c2-4c23-a55b-ebbeb820f0d1">
        <source>ccms1061_conversion_moveTIs(_lc, _newLC :CM_YardController);
// ---------------------------------------------------------------------------
// Created:     20 October 2009 by cnwcs5
// Purpose:     par 21404 - move tis
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti		:CM_TrackedItem;
	txt		:String;
	move	:CM_FutureMove;
	set		:CM_ObjectSet;
	obj		:Object;
begin
	while true do
//	foreach ti in _lc.allTrackedItems do	// par 21404
		ti := _lc.allTrackedItems.first;
		
		if ti = null then
			break;
		endif;
		
		if ti.myPrimaryActualLocation = _lc then
			ti.doForcedMove (_newLC, null, REAL_MODE, true, false, app.myPassport);
			
			txt	:= method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT &amp; Tab &amp; 'Forced move of ' &amp; ti.id &amp; ' to ' &amp;  _newLC.getFullId;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

			app.writeStatement( txt );
			app.writeLog( txt, LogINFO );
		endif;
//	endforeach;
	endwhile;
	
	// we need to copy ti's to a set to avoid "Cannot update array during iteration" error
	create set transient;
	
	foreach move in _lc.allPlannedFutureMoves do
		if not move.isKindOf (CM_FutureMovePlanned) then
			continue;
		endif;
		
		ti := move.CM_FutureMovePlanned.myTrackedItem;
		
		set.addNoDuplicates (ti, false);
	endforeach;
	
	foreach obj in set do
		ti := obj.CM_TrackedItem;
		
		ti.doForcedUnplan (app.myPassport);
		
		txt	:= method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT &amp; Tab &amp; 'Forced unplan of ' &amp; ti.id;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		app.writeStatement( txt );
		app.writeLog( txt, LogINFO );
	endforeach;
	
	set.clear;
	
	foreach move in _lc.allQueuedFutureMoves do
		if not move.isKindOf (CM_FutureMovePlanned) then
			continue;
		endif;
		
		ti := move.CM_FutureMovePlanned.myTrackedItem;
		
		set.addNoDuplicates (ti, false);
	endforeach;
	
	foreach obj in set do
		ti := obj.CM_TrackedItem;	
		
		ti.doForcedUnqueue (app.myPassport);
		
		txt	:= method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT &amp; Tab &amp; 'Forced unqueue of ' &amp; ti.id;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		app.writeStatement( txt );
		app.writeLog( txt, LogINFO );
	endforeach;	
epilog
	delete set;
end;</source>
        <Parameter name="_lc" type="CM_YardController"/>
        <Parameter name="_newLC" type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="createPostGate" id="d4de4366-c231-4e7d-bb5e-51a54bf31857">
        <updating/>
        <source>createPostGate() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 October 2006	cnwer1	Initial creation - PAR#12681

*/
vars
	postGateLC,aLCProxy: CM_BlockController;
begin
	exclusiveLock(self);
	if self.allPostGateControllers.size &gt; 0 then			
		return;
	else
		create aLCProxy transient;
		create postGateLC;
		aLCProxy.setProxy(self);
		postGateLC.setMyPostGateVTA(self);
		postGateLC.setForCreate(aLCProxy, self);	
	endif;

epilog
	if aLCProxy &lt;&gt; null then
		delete aLCProxy;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="createPreGate" id="d47ab944-e7bf-4978-8450-7792863e1b54">
        <updating/>
        <source>createPreGate() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 October 2006	cnwer1	Initial creation - PAR#12681

*/
vars
	preGateLC,aLCProxy: CM_BlockController;
begin
	exclusiveLock(self);
	if self.allPreGateControllers.size &gt; 0 then			
		return;
	else
		create aLCProxy transient;
		create preGateLC;
		aLCProxy.setProxy(self);
		preGateLC.setMyPreGateVTA(self);
		preGateLC.setForCreate(aLCProxy, self);	
	endif;

epilog
	if aLCProxy &lt;&gt; null then
		delete aLCProxy;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="38453d58-8641-41c9-a177-41cd29b0eb7d">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	subQueue : CM_Object;
begin
	foreach subQueue in self.allSubQueues do
			subQueue.erase(NORMAL_ERASE);
	endforeach;
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="083d56af-0f3a-464f-aaac-60de6dc8eabe">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwer1	Initial creation

*/

vars

begin
	if _attrName = ETRow_IsDualGate then
		return self.isDualGate.asStringJMT;
	elseif _attrName = ETRow_NumGateLanes then
		return self.numGateLanes.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGateLaneController" id="323595a4-9a71-4ade-9423-66b01688c1f7">
        <source>getGateLaneController(_id : String) : CM_GateLaneController;

vars

	controller : CM_GateLaneController;

begin

	foreach controller in self.allGateLaneControllers discreteLock do
		if controller.ident.toUpper() = _id.toUpper() then
			return controller;
		endif;
	endforeach;
	
	return null;
end;
</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_GateLaneController"/>
    </JadeMethod>
