<CollClass name="CM_BOLTrnsactByTypeDateDict" id="be8e8ab6-b0e3-421d-8738-4f803e85e159">
    <duplicatesAllowed/>
    <memberType name="CM_BOLTransaction"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transactbol"/>
    <MemberKey>
        <property name="CM_BOLTransaction::type"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_BOLTransaction::dateTime"/>
    </MemberKey>
    <JadeMethod name="geBolTransOfType" id="e4a5341e-dda6-45b5-994a-e8d6ae59bb0c">
        <source>geBolTransOfType( _int : Integer; _reverse : Boolean ):CM_BOLTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	iter : Iterator;
	bolTrx : CM_BOLTransaction;

begin

	if self.isEmpty then
		return null;
	endif;
	
	iter := self.createIterator;
	
	if _reverse then
		while iter.back( bolTrx ) do
			if bolTrx.type = _int then
				return bolTrx;
			endif;
		endwhile;
	else
		while iter.next( bolTrx ) do
			if bolTrx.type = _int then
				return bolTrx;
			endif;
		endwhile;
	endif;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_int" type="Integer"/>
        <Parameter name="_reverse" type="Boolean"/>
        <ReturnType type="CM_BOLTransaction"/>
    </JadeMethod>
</CollClass>
