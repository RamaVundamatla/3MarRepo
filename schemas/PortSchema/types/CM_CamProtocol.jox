        <source>getContainerCarrier_NAD_CF(_container :CM_Container):String;
// ---------------------------------------------------------------------------
// Created:     28 March 2011 by cnwcs5
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
// ---------------------------------------------------------------------------
vars
	value 		:String;
	foundMatch	:Boolean;
begin
	if self.useContainerOperator_In_NAD_CF then
		// translate the Party Identifier
		value	:= app.myRoot.getXlationForeignOperatorCode( null, _container.operatorCode.trimBlanks, foundMatch );
	else
		value 	:= self.camGroup.shippersCode;
	endif;
	
	return value;
epilog

end;</source>
