    <JadeMethod name="valYATemplate" id="dee002e9-608c-4dce-a328-5e894cc1b41a">
        <source>valYATemplate(_yATemplate:CM_YATemplate; _proxyYATemplate:CM_YATemplate);
begin
	self.raiseExceptionIfNull(_proxyYATemplate, "Yard Allocation Template Proxy");
	self.raiseExceptionIfNull(_yATemplate, "Yard Allocation Template Existing");
	_proxyYATemplate.raiseExceptionIfNotProxy(method);
	
	if _yATemplate.code = _proxyYATemplate.code then
		_proxyYATemplate.validateForUpdate();
	else
		_proxyYATemplate.validateForCreate();
	endif;
	
	_proxyYATemplate.validate();
end;</source>
