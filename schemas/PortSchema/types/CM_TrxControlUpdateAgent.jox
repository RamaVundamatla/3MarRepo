    <JadeMethod name="trxUpdateTINonTranship" id="2d5ec142-50f4-45d4-a6f3-de36abf24edc">
        <updating/>
        <source>trxUpdateTINonTranship(_pxyTIs : CM_TIArray input; _updateMode : Integer; _passport : CM_Passport input) updating;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 15/06/2010	cnwdap1		CCMS 1116 Tranship changes - use this method to make tranship non-tranship
vars
	pxyTI, realTI		: CM_TrackedItem;
	expectedEdition		: Integer;
	valUpdateCntrl		: CMIF_TIUpdateController;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _pxyTIs.isEmpty then
		app.raiseCMException1(ERR_NO_OBJECT, "Tracked Item", null, null);
	endif;
	
	valUpdateCntrl := app.createTIUpdateControl(_updateMode, null, null);

	app.setContinueCMExceptions(true); //cnwrd1 par 24856 6.7.2010
		
	foreach pxyTI in _pxyTIs do //cnwrd1 par 24856 6.7.2010
		pxyTI.raiseExceptionIfNotProxy(method);
		pxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	
		if realTI = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
			return;
		endif;
		
		// VALIDATION - shifted up here fopr bulk edit. cnwrd1 par 24856 6.7.2010
	
		//14/04/2009 cnwdz2 ccms1735
		if app.isSubTerminalsOn(pxyTI.myTerminal) then
			if pxyTI.mySubTerminal &lt;&gt; realTI.mySubTerminal then
				pxyTI.checkStopsToBePrevented(StopPreventSubTerminalEdit,null,true);
			endif;
		endif;
		
		// do the validation here
		app.myValUA.valTrackedItem(pxyTI, valUpdateCntrl, _passport);
		
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then //cnwrd1 par 24856 6.7.2010
		return;
	endif;
		
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	app.myUtilityUA.utlUpdateTINonTranship(_pxyTIs, _updateMode, _passport);

epilog
	delete valUpdateCntrl;								// 07/04/2014 cnwmh5 - Transient Leak
	self.finaliseActivityWithPassport(_passport);
end;
</source>
        <Parameter name="_pxyTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIPackComplete" id="08561087-5e57-4fdd-a18d-0ebd611cb392">
        <updating/>
        <source>trxUpdateTIPackComplete(_theProxyTI: CM_TrackedItem input; _packRequest : CM_BulkRelease; _retroDT : TimeStamp; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	29 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/02/2009	cnwdad1		PAR #18930. If any of the updating method calls caused
//							an exception, then we need to check for errors and
//							not continue if there are any, instead just return.
// 24/07/2009	consw1		PAR #20335 - SFW1075 To Do Task Scheduling
// 08/09/2016   cnwma1  TFS #2589:PAR38142 STWR - TFS2239 " Double assign to release" -fix not OK
// 11 Sep 2023 	navhl20 Bug 52191: MTN - Pack by Request not changing the status of the Release Request to Complete after packing
// 19 Mar 2024  navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
// 12 Jul 2024 	navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
// ---------------------------------------------------------------------------
vars
	theTransactionController	: CMIF_TITransactionController;
	txnControllerDict 			: CMIF_TITxnContrlrByTypeDTDict;
	realTI						: CM_TrackedItem;
	packRequest					: CM_BulkRelease;
	terminal					: CM_Terminal;
	resDtl						: CM_ReserveDetail;
	reason						: String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	realTI := _theProxyTI.pxyGetRealObject();

	terminal := realTI.getMyTerminal();
	if terminal &lt;&gt; null and terminal.getConfig(DisallowOperatorChange).Boolean and realTI.myOperator &lt;&gt; _theProxyTI.myOperator then		// 25/6/19 MAP TFS44563
		app.raiseCMException1(Paren_conta_opera_does_not_mat, realTI.operatorCode, null, null);
	endif;

	create theTransactionController transient;
	create txnControllerDict transient;
	
	_passport.useTITransactionDeferUpdate := true;	// 05 Jul 2017	NDL	TFS 5238	
	_passport.useTIDictDeferUpdate 		  := true;	// 05 Jul 2017	NDL	TFS 5238
	
	beginTransaction;
	
	if _packRequest &lt;&gt; null then	 //11.9.2023 navhl20 #52191
		//jlier1 TFS 65289 19/7/24
		_packRequest.validatePackComplete();								//12.07.2024 navhl20 #61368
	
		if _passport.hasErrors() then										//12.07.2024 navhl20 #61368
			return;
		endif;
	
		if _packRequest.isPackingType and _packRequest.releaseByType then
			if realTI &lt;&gt; null then
				if realTI.allReserveDetails.isEmpty then
					if app.isWebApp or app.isJMTUnitTest or _retroDT.isValid then			//Added this check for below code should work only from unittest and websetvice	//19.03.2024 navhl20 #62863
						foreach resDtl in _packRequest.allReserveDetails where resDtl.isKindOf(CM_ReserveSelection) do
							if realTI.testAgainstReserveSelection(resDtl.CM_ReserveSelection, reason, true, null ) then 
								//assign the container as a parent on the packing release.
								app.myUtilityUA.utlAddToReserveDetail( resDtl, realTI, app.myPassport );
								realTI.updateObjectEdition(realTI);
							endif;					
						endforeach;
					endif;
				endif;
			endif;
		endif;
	endif;

	//complete the WLE and Work Order detail
	app.myUtilityUA.utlUpdateTIPackComplete(_theProxyTI, realTI, _passport);

	if _passport.hasErrors() then
		_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
		return;
	endif;

	theTransactionController.myTrackedItem 		:= realTI;
	theTransactionController.myOtherTrackedItem := null;
	theTransactionController.noCharge 			:= false;
	theTransactionController.type 				:= TRANS_TYPE_PackComplete;
	if _retroDT.isValid then									//19.03.2024 navhl20 #62863
		theTransactionController.dateTime := _retroDT;
	endif;
	
	if _packRequest &lt;&gt; null then //08/09/2016 cnwma1 TFS #2589
		theTransactionController.myBulkRelease := _packRequest;
	endif;
	txnControllerDict.add(theTransactionController);

	if _passport.hasErrors() then
		_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
		return;
	endif;
	
	// to bypass the check of edition in realTI.setForUpdate
	app.myPassport.allowProgressiveUpdates := true;		//20.8.2024 navbs1 #65687
	
	//update the container 
	app.myUtilityUA.utlUpdateTrackedItem(_theProxyTI, null, TI_UPDMODE_NORMAL, txnControllerDict, null, null, _passport);//cnwrd1 28.8.09 par 20545
	
	// cnwdad1 19/02/2009 - PAR #18930.
	if _passport.hasErrors() then
		_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
		return;
	endif;
	
// cnwdad1 19/02/2009 - PAR #18930.
	if _passport.hasErrors() then
		_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
		return;
	endif;
	
	// Set any unpack complete stops cnwrs1 may 2007
	realTI.setStopsToBeApplied(StopApplyPackComplete, true, _passport); //par15193 cnwrs1 oct 2007
	
// cnwdad1 19/02/2009 - PAR #18930.
	if _passport.hasErrors() then
		_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
		return;
	endif;
	
	realTI.updateContentsStatus; //+ dh par 17655 31/7/2008
	
	//14 Dec 2015	NDL	Par 37288
	if _packRequest &lt;&gt; null then
	
		if _passport.hasErrors() then
			_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
			return;
		endif;
		packRequest := _packRequest;
		packRequest.doCompleteIfLastItem(); // updating method
	endif;
	
	_passport.doDeferredUpdates();	// 05 Jul 2017	NDL	TFS 5238
	
epilog
	delete theTransactionController;
	delete txnControllerDict;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_packRequest" type="CM_BulkRelease"/>
        <Parameter name="_retroDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIPriorWhousePacking" id="aede4ebf-795d-4eff-9886-88a3c48042f2">
        <updating/>
        <source>trxUpdateTIPriorWhousePacking(_pxyTI : CM_TrackedItem; _pxyRelease : CM_BulkRelease; _bookingItem : CM_BookingRefItem; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 03/06/2015	cnwdap1		PAR #36231 Change exception handlers to non-silent ones
// 01/10/2015	cnwdap1		PAR #36988 New bookingItem parameter
//
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	//on Exception do agtPassportSilentExHandler(exception, _passport);					// PAR #36231
	//on LockException do agtPassportSilentLockExHandler(exception, 10, _passport);		// PAR #36231
	on Exception do agtPassportExHandler(exception, _passport);							// PAR #36231
	on LockException do agtPassportLockExHandler(exception, _passport);					// PAR #36231
	
	app.setContinueCMExceptions(true);
	
	//app.myValUA.valTIPriorToWhousePacking(_pxyTI, _pxyRelease, _passport);				// PAR #36988
	app.myValUA.valTIPriorToWhousePacking(_pxyTI, _pxyRelease, _bookingItem, _passport);	// PAR #36988
	if _passport.hasErrors then
		return;
	endif;

	app.setContinueCMExceptions(false);

	beginTransaction;
	app.myUtilityUA.utlUpdateTIPriorWHousePacking(_pxyTI, _pxyRelease, _passport);
	
epilog	
	self.finaliseActivityWithPassport(_passport);

end;</source>
