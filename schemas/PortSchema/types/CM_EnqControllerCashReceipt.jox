    <JadeMethod name="doQuery" id="ac892365-c50c-4f25-864b-2e2f93b4cd7b">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	bankSet : ObjectSet;
	crit : CM_SelectorCriteriaLine;
	obj : Object;
	int : Integer;
	term : CM_Terminal;
	termSet : ObjectSet;
	userTermDict : CM_UserTerminalByTerminalDict;
	userTerm : CM_UserTerminal;
	bank : CM_Bank;
	bankCode : String;

begin

	self.reset();
	
	create termSet transient;
	create bankSet transient;

	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashReceipt::myTerminal.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myTerminal := crit.myQueryOperator.getSearchValue().CM_Terminal;
		endif;
	endif;
	if termSet.isEmpty then
		if self.myTerminal &lt;&gt; null then
			termSet.add(self.myTerminal);
		else
			userTermDict := app.myPassport.myUser.allUserTerminals;
			foreach userTerm in userTermDict do
				termSet.add(userTerm.getMyTerminal);
			endforeach;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashReceipt::getBankCode.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(bankSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			bankCode := crit.myQueryOperator.getSearchValue().String;
			if bankCode &lt;&gt; null and self.myTerminal &lt;&gt; null then
				self.myBank := self.myTerminal.companies.getAtKey(bankCode);
			endif;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashReceipt::getDebtor.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myDebtor := crit.myQueryOperator.getSearchValue().CM_Debtor;
		endif;
	endif;
	
	if self.myTerminal &lt;&gt; null and self.myDebtor &lt;&gt; null then
		self.myDebtorTerminal := self.myTerminal.allDebtorTerminals.getAtKey(self.myDebtor);
	endif;
		
	if self.myDebtorTerminal = null and self.myBank = null then
		if bankSet.isEmpty then
			foreach obj in termSet do
				term := obj.CM_Terminal;
				foreach bank in term.companies do
					bankSet.addNoDuplicates(bank,false);
				endforeach;
			endforeach;
		endif;
	endif;
	
	if self.myDebtorTerminal &lt;&gt; null then
		self.doSearch();
		
	
	elseif self.myBank &lt;&gt; null then
		self.doSearch();
		
	elseif not bankSet.isEmpty then
		foreach obj in bankSet do
			self.myBank := obj.CM_Bank;
			self.doSearch();
		endforeach;
	
	// 34364 handle multiple terminals
	elseif not termSet.isEmpty then
		foreach obj in termSet do
			self.myTerminal := obj.CM_Terminal;
			if self.myTerminal &lt;&gt; null and self.myDebtor &lt;&gt; null then
				self.myDebtorTerminal := self.myTerminal.allDebtorTerminals.getAtKey(self.myDebtor);
			endif;
			self.doSearch();
		endforeach;
	
	endif;
	
epilog

	delete bankSet;
	delete termSet;

end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="9fee6bdf-c290-4da2-962a-1c5bf5716430">
        <updating/>
        <source>doSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2014	cnwndl1	Initial creation	Par 34142
22 Jan 2019 cnwma1	Bug 42984: QNS - RE: Report - Revenues by Service Lines
*/

vars

	iter : Iterator;
	cashReceipt : CM_CashReceipt;
	breakOut : Boolean;
	passport : CM_Passport;
	startObject : Object;
	selectorCrLine : CM_SelectorCriteriaLine;
	qfromDate       : CM_QueryOperator;
	fromDate        : Date;
	toDate          : Date;

begin

	passport := app.myPassport;
	
	//18.01.2019 cnwma1	Bug 42984
	fromDate := null;
	toDate   := null;
	if self.myCriteriaLineHolder.allCriteriaByPropertyName.isNotEmpty then	
		selectorCrLine:= self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashReceipt::dateTime.name,CM_CashReceipt.name];
		if selectorCrLine &lt;&gt; null then
			
			if selectorCrLine.myQueryOperator &lt;&gt; null then
				qfromDate := selectorCrLine.myQueryOperator;
				if qfromDate.isKindOf(CM_QDateRange) then
					if qfromDate.CM_QDateRange.fromDate.isValid then
						fromDate :=qfromDate.CM_QDateRange.fromDate;
					endif;
					if qfromDate.CM_QDateRange.toDate.isValid then
						toDate :=qfromDate.CM_QDateRange.toDate +1;
					endif;
				endif;
			endif;
		endif;
	endif;
		
	if self.myDebtorTerminal &lt;&gt; null then
		iter := self.myDebtorTerminal.allCashReceipts.createIterator;
		while iter.next(cashReceipt) do
			if self.includesObject(cashReceipt, breakOut, passport) then
				self.addObjectToSet(cashReceipt);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
				
	elseif self.myBank &lt;&gt; null then
		//bank known.
		iter := self.myBank.allCashReceipts.createIterator;
		
		//18.01.2019 cnwma1 Bug 42984
		if fromDate.isValid then
			self.myBank.allCashReceipts.startKeyGeq(fromDate.TimeStamp,iter);
		endif;
		
		while iter.next(cashReceipt) do
			
			//18.01.2019 cnwma1	Bug 42984
			if toDate.isValid then               				
				if cashReceipt.dateTime &gt; toDate.TimeStamp then
					break;
				endif;
			endif;
			
			if self.myBank &lt;&gt; null then
				if cashReceipt.getBank &lt;&gt; self.myBank then
					continue;
				endif;
			endif;
			//18.01.2019 cnwma1	Bug 42984
			
			if self.includesObject(cashReceipt, breakOut, passport) then
				self.addObjectToSet(cashReceipt);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
		
	// 34364 multi-terminal
	elseif self.myTerminal &lt;&gt; null then
		iter := self.myTerminal.allCashReceipts.createIterator;
		//18.01.2019 cnwma1 Bug 42984
		if fromDate.isValid then
			self.myTerminal.allCashPayments.startKeyGeq(fromDate.TimeStamp,iter);
		endif;
		
		while iter.next(cashReceipt) do
			
			if toDate.isValid then               				//18.01.2019 cnwma1	Bug 42984
				if cashReceipt.dateTime &gt; toDate.TimeStamp then
					break;
				endif;
			endif;
			
			if self.includesObject(cashReceipt, breakOut, passport) then
				self.addObjectToSet(cashReceipt);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
	endif;

epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reset" id="51c05d1c-0e8c-4e3b-8221-e76e3878ef40">
        <updating/>
        <source>reset() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	inheritMethod();
	
	self.myTerminal := null;
	self.myBank := null;
	self.myDebtor := null;
	self.myDebtorTerminal := null;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="696635f1-3eb2-496f-b8e4-f4a033961ba8">
        <updating/>
        <source>setMyFilterClass() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	self.myFilterClass := CM_CashReceipt;

epilog

end;</source>
    </JadeMethod>
</Class>
