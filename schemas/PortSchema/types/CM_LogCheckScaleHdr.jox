    </JadeMethod>
    <JadeMethod name="getDateLocalTZ" id="8d87bb57-9ee2-4022-b9ce-bcd33adec1c7">
        <source>getDateLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
01 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.dateTime).Date;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
