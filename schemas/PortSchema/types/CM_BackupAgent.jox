    </JadeMethod>
    <JadeMethod name="purgeFolderJournalFiles" id="c826be3c-1504-46c5-ac5b-ebec3aebc92a">
        <source>purgeFolderJournalFiles(_msg: String) protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//16 Dec 2013	cnwrs1		Par 33216 - After JMT 822 upgrade neither JacBackup nor JMTBackup fail to purge expired journal files.
// ---------------------------------------------------------------------------
vars
	fileNode: FileNode;
	file: File;
	deleteDT : TimeStamp;
	msg : String;
begin
	deleteDT.setDate(deleteDT.date - app.myRoot.myBackup.purgeJournalDays);
	msg := ' Purging files from '&amp;self.myFolder.fileName&amp;' older than '&amp;deleteDT.String&amp;' '&amp;self.myFolder.files.size.String;
	self.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	foreach fileNode in self.myFolder.files where fileNode.isKindOf(File) do
		file := fileNode.File;
		if file.lastModified &lt; deleteDT then
			msg := ' Purging '&amp;_msg&amp;' ('&amp;file.name&amp;')';
			self.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			file.cnSetFileAttribute(FileNode.CN_FILE_ATTR_READONLY, false);
			if file.tryOpen then				//Access rights ?
				file.purge;
			else
				msg := ' Unable to access '&amp;_msg&amp;' ('&amp;file.name&amp;') - not purged';
				self.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="raiseAlert" id="0f74b9f8-a645-4f5f-bc27-5ea6074d2398">
        <source>raiseAlert(_shortMsg, _longMsg: String; _severity: Integer);
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	alert: CM_SystemAlert;
	msg : String;
begin
	msg := 'Backup Alert - '&amp;_shortMsg&amp;' ('&amp;_longMsg&amp;')';
	self.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	create alert transient;
	alert.details := _shortMsg;
	alert.setSeverity(_severity);
//	alert.addLogEntry(_shortMsg);
	alert.addLogEntry(_longMsg);
	alert.add;
	app.commitAlert();
end;</source>
        <Parameter name="_shortMsg" type="String"/>
        <Parameter name="_longMsg" type="String"/>
        <Parameter name="_severity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setLoggingLevel" id="232b90d2-5100-48d4-b208-bb7471a26c1c">
        <updating/>
        <source>setLoggingLevel(_level: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.loggingLevel := _level;
end;</source>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="writeLog" id="2b6f930d-b985-4d1a-8bb6-9f6e74ac2764">
        <source>writeLog(_msg: String; _messageLevel: Integer);
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.myBackup = null or 
	   app.myRoot.myBackup.debug then
		app.writeLog(_msg, LogINFO);
	else
		app.writeLog(_msg, _messageLevel);
	endif; 
end;</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_messageLevel" type="Integer"/>
    </JadeMethod>
</Class>
