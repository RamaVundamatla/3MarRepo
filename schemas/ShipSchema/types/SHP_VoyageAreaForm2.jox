	self.btnPen45.enabled			:= enabled; // PAR 18682
	self.btnPen30.enabled			:= enabled; // PAR 16415 CCMS 1029
	self.btnPen53.enabled			:= enabled; // PAR 16415 CCMS 1029
	self.btnPenHalfHeight.enabled	:= enabled;
