<Class name="CMIF_TMCTaskResourceTypeGroup" id="69f06aef-9aaa-4c94-a19e-5c9f6b9ef7c8">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myTransResourceServiceBroker" id="c08d856c-50e3-4730-9eb0-423e038c4c4b">
        <embedded/>
        <type name="CM_ServiceBroker"/>
    </ImplicitInverseRef>
    <JadeMethod name="getPicture" id="b970d188-4cd5-48f8-875c-18ff3791b55c">
        <source>getPicture(form: INV_TransactionMap): Picture;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picResUsages;

epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="81e31209-28e0-45ab-9afe-972d9e305dca">
