    <JadeMethod name="createBlameItem" id="8289e29e-d79b-4fa0-af11-3a49d31b5e4a">
        <source>createBlameItem(	_methClassString : String;
					_type : Type;
					_meth : Method;
					_isForBlame : Boolean
					): UM_BlameItem;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
31 December 2010	cnwndl1	Initial creation
15/04/2013			cnwmh5	Changed so that unit test methods now appear so when changes are done to a UT_DSL method
							then we can easily find what has been changed
27 Nov 2014			cnwkpd1	Change from Class to Type to include primitive type methods
*/

vars
	blameItem : UM_BlameItem;
	author : String;
	now : Date;
	lastModified : TimeStamp;
	schemaName : String;

begin
	lastModified := _meth.cnGetModifiedTimeStamp();
	
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	//if _isForBlame and lastModified.Date + DateThreshold &lt; now then
	if _isForBlame and lastModified.Date + app.findBlameForNoDays &lt; now then
		// creating items for blame and not a recent change, ignore it.
		return null;
	endif;
	
	if not _isForBlame then
		// we are ultimately going to create a UM_ClassMethod for this
		schemaName := _type.schema.name;
		if schemaName = "RootSchema" or schemaName = "CardSchema" or schemaName = "BaseSchema" then
			// we are not recording testing details for these
			return null;
		endif;
		//if schemaName = "JMTUnitTest" then										// 15/04/2013 cnwmh5 - Changed so unit test stuff now appears
		//	if _methClassString[1:2] = "UT" then
		//		// specific testing code as opposed to real JMT code. 
		//		return null;
		//	endif;
		//endif;
	endif;
	
	on Exception do localHandler( exception );
	
	author := _meth.cnGetModifierName();

	beginTransaction;
	create blameItem;

	blameItem.setDetails(	author,	//_author : String;
							_methClassString,	//_classMethod : String;
							lastModified,	//_lastModified : TimeStamp;
							self	//_myBlame : UM_Blame
							);
	commitTransaction;
	return blameItem;

epilog

end;</source>
        <Parameter name="_methClassString" type="String"/>
        <Parameter name="_type" type="Type"/>
        <Parameter name="_meth" type="Method"/>
        <Parameter name="_isForBlame" type="Boolean"/>
        <ReturnType type="UM_BlameItem"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0918ebf4-bb68-40a2-a478-701b41a77939">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2010	cnwndl1	Initial creation

*/

vars

	file : File;
	
begin

	self.endProfiling();
	
	create file transient;
	file.fileName := self.fileName;
	file.usePresentationFileSystem := false;
	
	if file.tryOpen then
		file.close;
		file.purge;
		file.allowCreate := true;
		file.fileName := self.fileName;
	endif;
	
epilog

	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doClassMethodCoverage" id="1520bd73-a3dc-422a-92b8-3e7be28e605a">
        <source>doClassMethodCoverage( methodsCalled : StringArray io; _testQualifiedname : String ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2011	cnwndl1	Initial creation

*/

vars

	file : File;
	returnValue : String;

begin

	self.endProfiling();
	
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := self.fileName;
	file.usePresentationFileSystem := false;

	if file.tryOpen then
	
		file.commit;
		self.processProfileFile(file,false);
		file.close;
		
		self.getClassMethodCoverage( methodsCalled, _testQualifiedname );
	
	else
	
		returnValue := "Failed to open Profiler File from " &amp; method.qualifiedName;
		
	endif;
	
	return returnValue;

epilog

	delete file;
	
end;</source>
        <Parameter name="methodsCalled" type="StringArray" usage="io"/>
        <Parameter name="_testQualifiedname" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="endProfiling" id="a82a59d9-3440-4bc8-bd8d-bbc999f01d58">
        <source>endProfiling();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2010	cnwndl1	Initial creation

*/

vars

	myProfiler : JadeProfiler;

begin

	myProfiler := process.profiler;

	if myProfiler.isProfiling then
		myProfiler.stop;
		myProfiler.report;
	endif;

epilog
	delete myProfiler;		//cnwmc5 13/09/2012 - transient leak issue
end;</source>
    </JadeMethod>
    <JadeMethod name="getClassMethodCoverage" id="eaf19df0-0629-4460-8b11-d9fdbfcebb5f">
        <source>getClassMethodCoverage( methodsCalled : StringArray io; _testQualifiedname : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2011	cnwndl1	Initial creation

*/

vars

	blameItem : UM_BlameItem;

begin

	foreach blameItem in self.allBlameItems do
		if _testQualifiedname &lt;&gt; null and _testQualifiedname = blameItem.classMethod then
			continue;
		endif;
		methodsCalled.add(blameItem.classMethod);
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="methodsCalled" type="StringArray" usage="io"/>
        <Parameter name="_testQualifiedname" type="String"/>
    </JadeMethod>
    <JadeMethod name="getPotentialBlameList" id="d1adde71-e6e3-412b-b774-cc093bf6e98e">
        <source>getPotentialBlameList():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2010	cnwndl1	Initial creation

*/

vars

	blameItem : UM_BlameItem;
	returnValue : String;

begin

	if self.allBlameItems.isEmpty then
		return null;
	endif;
	
	returnValue := "*** Potential Blame list ***" &amp; CrLf;
	
	foreach blameItem in self.allBlameItems do
		returnValue := returnValue &amp; blameItem.message &amp; CrLf;
	endforeach;
	
	returnValue := returnValue &amp; "******" &amp; CrLf;
	
	return returnValue;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="localHandler" id="2c8065a6-96e0-4e36-9377-eb2a9dc3c0c2">
        <source>localHandler( exc : Exception) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2010	cnwndl1	Initial creation

*/

vars

begin

	if exc.errorCode = 1090 then

		return Ex_Resume_Next;
	
	else
	
		return Ex_Pass_Back;
	
	endif;
	
epilog

end;</source>
        <Parameter name="exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="message" id="99920810-8374-4b11-854a-1cdae09a7934">
        <source>message():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2010	cnwndl1	Initial creation

*/

vars

	file : File;
	returnValue : String;

begin

	self.endProfiling();
	
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	file.fileName := self.fileName;
	file.usePresentationFileSystem := false;

	if file.tryOpen then
	
		file.commit;
		self.processProfileFile(file,true);
		file.close;
		
		returnValue := self.getPotentialBlameList();
	
	else
		returnValue := "Failed to open Profiler File from " &amp; method.qualifiedName;
	endif;
	
	return returnValue;

epilog

	delete file;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processProfileFile" id="fce51447-5eec-4c1f-86a4-bee10d0f8d56">
        <source>processProfileFile( file : File; _isForBlame : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
31 December 2010	cnwndl1	Initial creation
22/05/2012			cnwmh5	Change so that handles change to profile.log
27 Nov 2014			cnwkpd1	Allow for primitive types as well

*/

vars

	lineString : String;
	colonPosition : Integer;
	pos : Integer;
	firstAplhaPos : Integer;
	typeString : String;
	methodString : String;
	methClassString : String;
	aType : Type;
	meth : Method;
	schema : Schema;
	startPos : Integer;
	
begin

	schema := currentSchema;
	
	while not file.endOfFile do
		lineString := file.readLine();
		colonPosition := lineString.pos("::",1);
		if colonPosition &lt; 1 then
			// not a line with a method on it.
			continue;
		endif;
		
		// 22/05/2012 cnwmh5 - Change to handle new profile.log format
		colonPosition := colonPosition + 1;
		startPos := colonPosition;
		colonPosition := lineString.pos("::", colonPosition);
		if colonPosition &lt; 1 then
			// not a line with a method on it.
			continue;
		endif;
		
		firstAplhaPos := 0;
		typeString := null;
		methodString := null;
		aType := null;
		meth := null;
		foreach pos in startPos to colonPosition do       // 22/05/2012 cnwmh5 foreach pos in 1 to colonPosition do
			if lineString[pos].Character.isAlpha then
				firstAplhaPos := pos;
				break;
			endif;
		endforeach;
		
		if firstAplhaPos = 0 or firstAplhaPos &gt;= colonPosition then
			continue;
		endif;
		
		typeString :=  lineString[pos : colonPosition - pos].trimBlanks;
		methodString := lineString[colonPosition + 2 : end].trimBlanks;
		methClassString := lineString[pos : end].trimBlanks;
		
		if typeString = null or methodString = null then
			continue;
		endif;
		
		aType := schema.getClass(typeString);
		if aType &lt;&gt; null then
			meth := aType.Class.getMethodInHTree(methodString);
		else
			aType := schema.findName(typeString);
			if aType = null then
				continue;
			endif;
			meth := aType.getMethod(methodString);
		endif;

		if meth = null then
			continue;
		endif;
		
		self.createBlameItem( methClassString, aType, meth, _isForBlame);
						
	endwhile;

epilog

end;</source>
        <Parameter name="file" type="File"/>
        <Parameter name="_isForBlame" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="67e2a533-4869-4500-80b4-ea63471f39b9">
        <updating/>
        <source>setDetails( _testName : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2010	cnwndl1	Initial creation

*/

vars

	myProfiler : JadeProfiler;

begin

	self.testName := _testName;
	
	myProfiler := process.profiler;
	
	myProfiler.fileName := app.getJadeLogDir &amp; "\JUNIT_test_Profile.log";
	self.fileName := myProfiler.fileName;
	
	if myProfiler.isProfiling then
		myProfiler.reset;
		myProfiler.stop;
	endif;

	myProfiler.reportMethodSize := true;
	myProfiler.reportActualTime := false;
	myProfiler.reportCacheStatistics := false;
	myProfiler.reportLoadTime := false;
	myProfiler.reportTotalTime := false;
	myProfiler.reportStatistics := false;
	myProfiler.methodCount := 6000;
	
	myProfiler.start;

epilog

end;</source>
        <Parameter name="_testName" type="String"/>
    </JadeMethod>
</Class>
