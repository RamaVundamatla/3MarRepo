    <JadeMethod name="set" id="af335a52-47e2-44a8-a1ec-688db3d78de9">
        <updating/>
        <source>set(_termTypeDtl : CM_TerminologyTypeDtl;
		_termHdr : CM_TerminologyDef;
		_heading, _shortHeading : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _termHdr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminology Header proxy passed in was null');
		return;
	endif;
	
	self.myTerminologyTypeDtl := _termTypeDtl;
	self.myTerminologyDef := _termHdr;
	self.userHeading := _heading;
	self.userShortHeading := _shortHeading;
	
end;</source>
        <Parameter name="_termTypeDtl" type="CM_TerminologyTypeDtl"/>
        <Parameter name="_termHdr" type="CM_TerminologyDef"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_shortHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7961e5a1-1ce6-407e-806e-16bad7790179">
        <updating/>
        <source>setForUpdate(_pxyTermDtl : CM_TerminologyDtl; _realTermHdr : CM_TerminologyDef) updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.userHeading 			:= _pxyTermDtl.userHeading;
	self.myTerminologyDef 		:= _realTermHdr;
	self.myTerminologyTypeDtl 	:= _pxyTermDtl.myTerminologyTypeDtl;	

end;</source>
        <Parameter name="_pxyTermDtl" type="CM_TerminologyDtl"/>
        <Parameter name="_realTermHdr" type="CM_TerminologyDef"/>
    </JadeMethod>
