    <JadeMethod name="refreshBGPObject" id="453d2a61-3a1e-40db-82a7-0addd8723726">
        <updating/>
        <source>refreshBGPObject(_bgpObject : BGP_Object) protected, updating;

vars

	row,
	rows,
	fixed		: Integer;
	tableRow	: JadeTableRow;
	obj			: Object;
	found		: Boolean;
	bgpObject	: BGP_Object;

begin

	bgpObject := _bgpObject;
	on Exception do self.xHandler(exception, bgpObject);
	rows := self.tblDisplay.rows;
	fixed := self.tblDisplay.fixedRows;
	foreach row in fixed to rows do
		tableRow := self.tblDisplay.accessRow(row);
		obj := tableRow.itemObject;
		if obj = _bgpObject then
			self.tblDisplay.removeItem(row);
			self.addDisplayRow(_bgpObject.BGP_Object, not _bgpObject.isManager(), row);
			found := true;
			break;
		endif;
	endforeach;
	
	if self.selectedRow &gt; self.tblDisplay.fixedRows and self.selectedRow &lt;= self.tblDisplay.rows and self.selectedRow = row then
		self.selectObj(self.selectedRow, false);
	else
		self.doStartStopButtons();
	endif;
	if not found then
		self.doDisplay();
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_bgpObject" type="BGP_Object"/>
    </JadeMethod>
    <JadeMethod name="selectObj" id="9c4a711b-36b6-4732-9e7a-93a3779f77fe">
        <updating/>
        <source>selectObj(_row : Integer; _refresh : Boolean) protected, updating;

// cnwdvb1 29 October 2002
//09 Apr 2024   navbs1      Bug 62880: EUP - Invalid Table row Error at Background Application Screen 

vars

	obj	: Object;
	row	: JadeTableRow;
	bgp	: BGP_Object;
	
	etDef : EntTableDef;

begin

	row := self.tblDisplay.accessRow(_row);
	if row = null then
		return;
	endif;
	obj := row.itemObject;
	self.tblDisplay.row := _row;
			
	if obj &lt;&gt; null then
		self.selectedRow := _row;
		if row.selected = false then
			row.selected := true;
		endif;
		bgp := obj.BGP_Object;
		self.myBGPObject := bgp;
		self.doStartStopButtons();
		if bgp.isManager() then
			self.setNavigatorHeading(bgp.BGP_Manager.name);
			self.tblRequest.rows := 1;
		else
			if _refresh then
				self.refreshBGPObject(bgp);
				return;											  //09.04.2024 navbs1 #62880
			endif;
			
			self.btnFutureActorsDtls.visible := false;				//navra1 - TFS 60149/Task 64397 - 7th June 2024
			self.btnFutureActorsDtls.enabled := false;				//navra1 - TFS 60149/Task 64397 - 7th June 2024
			
			if bgp.isKindOf(BGP_FutureTimerController) then       //29/11/2016 cnwma1 TFS #2937
			//	self.tblRequest.setColumnHeadingsFromDef(ETDef_BgpFutureActors, false);
				//21 Dec 2017	NDL	TFS 8306
				etDef := app.myController.getEntTableDef(ETDef_BgpFutureActors);
				self.tblRequest.setColumnHeadingsFromDef(etDef.name, false);
				self.tblRequest.setMyEntTableDef(etDef);
				self.tblRequest.setTblDataEntRowsFromDef(etDef);
				
				//navra1 - TFS 60149/Task 64397 - 7th June 2024 - start
				self.btnFutureActorsDtls.visible := true;				
				if app.myCurrentUserCan(null, PmAdmBGPFutActorView) then
					self.btnFutureActorsDtls.enabled := true;
				endif;
				//navra1 - TFS 60149/Task 64397 - 7th June 2024 - end
				
				self.doLoadFutureActorsTable(bgp.BGP_Controller);
			else
				//self.tblRequest.setColumnHeadingsFromDef(ETDef_BgpClassRequests, false);
				//21 Dec 2017	NDL	TFS 8306
				etDef := app.myController.getEntTableDef(ETDef_BgpClassRequests);
				self.tblRequest.setColumnHeadingsFromDef(etDef.name, false);
				self.tblRequest.setMyEntTableDef(etDef);
				self.tblRequest.setTblDataEntRowsFromDef(etDef);
				
				self.doLoadRequestTable(bgp.BGP_Controller);
			endif;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_refresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectRequest" id="3eda8539-7cf8-4b62-8034-ce4f2258cf3d">
        <updating/>
        <source>selectRequest(_row : Integer; _isDoubleClick : Boolean) protected, updating;

// cnwdvb1 17 February 2003 
// Changed On	By			Reason
// ----------	--------	--------------------------------------------
// 09/04/2018	jlgdap1		TFS 37858 PEL1 Invoice Status Advancement
// 11/10/2018	jlgdap1		TFS 40202 PEL1 Estimation SAP Integration
vars

	row 	: JadeTableRow;
	obj		: Object;
begin
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	

	row := self.tblRequest.accessRow(_row);
	if row = null then
		return;
	endif;
	obj := row.itemObject;
	if obj &lt;&gt; null then
		 // TFS 2937 
		 //jlier1 TFS 57936 22/5/23
		if obj.isKindOf(CM_OfflineFutureActor) then		
			if app.isAllowedToInspect() then
				if _isDoubleClick then
					obj.inspectModal();
				endif;
			endif;
			return;
		endif;
	
		if _isDoubleClick then
			if app.isAllowedToInspect() then
				obj.inspect();
			else
				self.showDetail(obj.BGP_Request);
			endif;
		endif;
		self.mySelectedRequest := obj.BGP_Request;
		self.selectedRequestRow := _row;
		self.tblRequest.selectObject(obj, false);
//		if not row.selected then
//			row.selected := true;
//		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_isDoubleClick" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="ce42907e-cc2e-4b6e-83ce-2d6d06c209c7">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
