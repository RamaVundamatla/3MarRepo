// cnwdvb1 28 November 2002 

vars

begin

	return _bulk.userCode &amp; Tab &amp; self.systemToLocalTime(_bulk.dateTime).date.String;	// 13/7/16 cnwmp6 TFS 488 - Multi timezone support

end;</source>
