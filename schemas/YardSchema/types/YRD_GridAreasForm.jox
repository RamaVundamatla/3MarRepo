	endif;
	
/*
	if self.myDrawingFrame &lt;&gt; null then	
		dragSelectFrame := self.myDrawingFrame.myDragSelectFrame;
	endif;
	if dragSelectFrame &lt;&gt; null and dragSelectFrame.myContainerDrawingFrame &lt;&gt; null then	
		cdc := dragSelectFrame.myContainerDrawingFrame.getDrawingController();
	endif;
	
	if cdc &lt;&gt; null and cdc.isForOverview and not global.isValidObject(app.myMoveController) then	// cnwjk3 ccms 1018 01/02/10
		dragSelectFrame.drawDragFrame(x,y);
	else
		if dragSelectFrame.isControllKey  or dragSelectFrame.isShiftKey then
			dragSelectFrame.drawDragFrame(x,y);
		else
			dragSelectFrame.myContainerDrawingFrame.dragOver(dragSelectFrame.myContainerDrawingFrame, win, x, y, state);
		endif;
	endif;
	
	dragSelectFrame.dragOver(dragSelectFrame, win, x, y, state);
	*/	
end;</source>
