    <JadeMethod name="processTIs" id="2a3fa6bf-1e0e-4281-9890-7b9a055dda12">
        <updating/>
        <source>processTIs(_trackedItem : CM_TrackedItem; _type : Integer) updating;
// This method takes TI's from CMS and converts data to EDI TIs
// used to extract data from CMS


// need to shift this to CM_TrackedItem and subclasses  ::setEDITIFromSelf(), or something
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	realTI			: CM_TrackedItem;
	ediTrackedItem	: CM_EDITranshipTI;
	commodity		: CM_Commodity;
    slotController 	: CM_SlotController;
	tmpReeferInfo,    
    bayId, str, portCode 		: String;
	lVolume			: Real;
	tiLoc			: CM_LocationsController;
begin
	realTI := _trackedItem;
	if realTI = null then
		return;
	endif;
	
	if realTI.cargoType = TI_CargoType_LCL or	//don't process LCL individually
	realTI.myParent &lt;&gt; null then				//PAR7955	or any attached item
		return;
	endif;
		
	create ediTrackedItem persistent;
	ediTrackedItem.setForCreateNew(self);

	ediTrackedItem.setCargoType(realTI.cargoType);
	
	ediTrackedItem.setId(realTI.id);
	ediTrackedItem.setCommodity(realTI.commodity);
	
	ediTrackedItem.setDestinationPort(realTI.destinationPort);
	ediTrackedItem.setDischargePort(realTI.dischargePort);
	ediTrackedItem.setIsoType(realTI.getISOType);

	if realTI.isKindOf(CM_Container) then
		if realTI.CM_Container.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			ediTrackedItem.fullOrMT := "E";
		else
			ediTrackedItem.fullOrMT := "F";
		endif;

		ediTrackedItem.setTemperature(realTI.CM_Container.getTemperature);
		
		tmpReeferInfo := realTI.CM_Container.getReeferInfo();
	else
		//otherwise BBLK has temp of zero
		ediTrackedItem.setTemperature(NULL_TEMPERATURE);
	endif;
	
	// CCMS 1320 combine reefer info (cooling and voltage type) with remarks
	ediTrackedItem.setWeight(realTI.totalWeight);

	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1284 May 2012
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControllerFromEDITIs" id="5ad8d255-ec36-4dfd-a02b-a85f358c93a5">
        <source>setControllerFromEDITIs(_controller :CMIF_TranshipTIController input; _startEDITI : CM_EDITranshipTI io);
/*

Purpose: Sets up the CMIF to perform a (possibly) bulk update of the tranship items

Parameters:	 _controller: 	CMIF object we are loading
			_startEDITI:	Optional first 

Notes:
Called in Transaction State from TRX

Tranship file processing handles the TIs in clumps deteremined by destination port, old export voyage
and discharge port. TIs which have all these the same are in a clump. 
The EDI file may have different discharge ports per item (and this controller bulk updates fields in the item ) 
So when e.g. discharge port changes submit previous group of tracked items then continue to the next until
the discharge port changes again until we get to the end of file.

Date		Who		Reason
29/6/2006	cnwer1	Initial creation
27/11/2009  cnwml1	Par 21641 Tranship not updating stops
2/12/2009	cnwphb1	Par 21809 Add Export Voyage
22/3/2010	cnwrs1	Par 23163 Add processing via BOL number
29/7/2010	cnsdad1	Par 24319 Add Booking Reference
13/8/2010	cnwrl1	Par 25355 Add Destination Port
//14 Nov 2013	cnwrs1	Par32985 processing EDI tranships twice
02/05/2022	jlizm1	TFS 53083 GPHA revceival/release of tranship cargo
*/

vars
	trackedTI		: CM_EDITrackedItem;
	ediTranshipTI	: CM_EDITranshipTI;
	realTI			: CM_TrackedItem;
	oldDestPort		: CM_Port;
	newDestPort		: CM_Port;
	oldDischargePort: CM_Port;
	newDischargePort: CM_Port;
	oldExportVoyage : CM_Voyage;
	newExportVoyage	: CM_Voyage;
	iter			: Iterator;
	isMore			: Boolean;
	realBOL			: CM_BOL;
	bookingRef		: String;
	terminal		: CM_Terminal;
	interModal		: Boolean;
	
begin
	_controller.clear();
	
	terminal	:= self.getMyTerminal();
	
	iter := self.allEDITrackedItems.createIterator;
	if _startEDITI &lt;&gt;  null then
		iter.startAtObject(_startEDITI);
		oldDischargePort	:= _startEDITI.getRealDischargePort();
		oldDestPort			:= _startEDITI.getRealDestinationPort();
		interModal 			:= _startEDITI.interModal;
	endif;
	
	while iter.next(trackedTI) do	
		ediTranshipTI := trackedTI.CM_EDITranshipTI;
		realTI := ediTranshipTI.getRealTI( terminal );
		
		// If there isn't a real TI or a real BOL then ignore
		if realTI = null then
			if ediTranshipTI.id &lt;&gt; null then	//14 Nov 2013	cnwrs1	Par32985 dont try and find a bol if they specified a wrong ti.id
				continue;
			endif;
			realBOL := ediTranshipTI.getRealBOLIn( terminal );
			if realBOL = null then
				continue;
			endif;
		endif;	
		
		newDischargePort:= ediTranshipTI.getRealDischargePort();
		newDestPort		:= ediTranshipTI.getRealDestinationPort();
		newExportVoyage := self.getVoyage(ediTranshipTI.getExportVoyageCode);
		bookingRef		:= ediTranshipTI.bookingRef.trimBlanks();
		
		
		if (oldDischargePort &lt;&gt; null and oldDischargePort &lt;&gt; newDischargePort) or
		   (oldDestPort &lt;&gt; null and oldDestPort &lt;&gt; newDestPort) or
		   (oldExportVoyage &lt;&gt; null and oldExportVoyage &lt;&gt; newExportVoyage) then
			_startEDITI := ediTranshipTI;
			isMore := true;
			break;
		else
			if realTI &lt;&gt; null then
				if not _controller.allProcessedTrackedItems.includes(realTI) then	//14 Nov 2013	cnwrs1	Par32985 processing EDI tranships twice
					_controller.allTrackedItems.add(realTI);
					_controller.allProcessedTrackedItems.add(realTI);	//14 Nov 2013	cnwrs1	Par32985 processing EDI tranships twice
					
					if bookingRef &lt;&gt; null then
						_controller.doStoreTIBookingRef(realTI.id.trimBlanks(), bookingRef);
					endif;
				endif;
				realTI := null;
			else
				foreach realTI in realBOL.allTrackedItems do
					if not _controller.allProcessedTrackedItems.includes(realTI) then	//14 Nov 2013	cnwrs1	Par32985 processing EDI tranships twice
						_controller.allTrackedItems.add(realTI);
						_controller.allProcessedTrackedItems.add(realTI);	//14 Nov 2013	cnwrs1	Par32985 processing EDI tranships twice

						if bookingRef &lt;&gt; null then
							_controller.doStoreTIBookingRef(realTI.id.trimBlanks(), bookingRef);
						endif;
					endif;
				endforeach;
				realBOL := null;
			endif;
		endif;
		oldDischargePort	:= newDischargePort;
		oldDestPort			:= newDestPort;
		oldExportVoyage		:= newExportVoyage;
		interModal 			:= ediTranshipTI.interModal;	// TFS 53083
		
	endwhile;
	
	_controller.myExportVoyage		:= oldExportVoyage;
	_controller.myExportDisPort		:= oldDischargePort;
	_controller.myExportDestPort	:= oldDestPort;
	_controller.interModal			:= interModal;			// TFS 53083
	
	if not isMore then
		_startEDITI:= null;
	endif;
	
	// TFS 47222 jlgzm1 20/11/2019
	//_controller.removeStops := true;

epilog
	delete iter;
end;
</source>
        <Parameter name="_controller" type="CMIF_TranshipTIController" usage="input"/>
        <Parameter name="_startEDITI" type="CM_EDITranshipTI" usage="io"/>
    </JadeMethod>
