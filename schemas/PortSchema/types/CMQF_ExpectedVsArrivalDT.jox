begin
	if self.getMyVoyage &lt;&gt; null then
		self.filterForVoyage(_collection, _passport);
	else
		self.filterForTerminal(_collection, _passport);
	/*	foreach terminal in self.allTerminals do
			foreach ti in  terminal.allOnsiteTIsByCargoTypeId discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					if self.myVoyage &lt;&gt; null then
