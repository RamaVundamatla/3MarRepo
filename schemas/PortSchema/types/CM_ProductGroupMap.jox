    <JadeMethod name="validateInvLineDescUsedTranMap" id="a7e4a6d3-6663-4b2e-b893-cef34f903d59">
        <source>validateInvLineDescUsedTranMap(_invLineDesc : CM_InvoiceLineDesc) : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	map : CM_ProductMap;
begin

	foreach map in self.allProductMaps discreteLock do
		if map.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
