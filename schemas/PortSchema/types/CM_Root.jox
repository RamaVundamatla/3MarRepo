    <JadeMethod name="createVoyageJobTransferTypes" id="7f9fbe60-340c-4488-9ffc-3cfb6e89a195">
        <source>createVoyageJobTransferTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2022	navkc1	Initial creation	Bug 54130: CUX - 1090 Error in Job Operations with Ship Release
01 Aug	2022	navkc1	Bug 54362: MTN - 1025 UE when creating StarterDB
*/

vars
	root					: CM_Root;
	voyageJobTransferType	: CM_VoyageJobTransferType;
	
begin

	root	:= CM_Root.firstInstance();
	
	app.writeLog(method.qualifiedName &amp; " Creating 'System' Voyage Job Transfer Types", null);
	
	voyageJobTransferType := root.allVoyageJobTransferTypes.getAtKey(VESSEL_TYPE_RORO);
	if voyageJobTransferType = null then
		//beginTransaction;		 	// 01/08/2022	navkc1	#54362 - already in transaction state before calling this method, don't  need this
		create voyageJobTransferType persistent;
		voyageJobTransferType.setProxy( VESSEL_TYPE_RORO, VESSEL_TYPE_RORO_DESCR ,null);
		voyageJobTransferType.setIsSytem();
		//commitTransaction;		// 01/08/2022	navkc1	#54362 - not committing changes here, done in the calling method.
	endif;
	
	voyageJobTransferType := root.allVoyageJobTransferTypes.getAtKey(VESSEL_TYPE_LOLO);
	if voyageJobTransferType = null then
		//beginTransaction;			// 01/08/2022	navkc1	#54362 - already in transaction state before calling this method, don't  need this
		create voyageJobTransferType persistent;
		voyageJobTransferType.setProxy( VESSEL_TYPE_LOLO, VESSEL_TYPE_LOLO_DESCR ,null);
		voyageJobTransferType.setIsSytem();
		//commitTransaction;		// 01/08/2022	navkc1	#54362 - not committing changes here, done in the calling method.
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Created 'System' Voyage Job Transfer Types", LogINFO);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createWeightRanges" id="d2768161-ff5a-4b08-b86d-a68f072ec4cc">
        <source>createWeightRanges() protected;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------
// 01/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
