    <JadeMethod name="setProxyObject" id="83779b5f-c0fe-4478-9077-e9f108d50049">
        <updating/>
        <source>setProxyObject(_any : Any) updating;

/*
Date		Who		Reason
17 Mar 2022	navra1 	TFS53028 	
*/


vars
	helper 	: CMIF_RoadTruckTransactions;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName				:= helper.tableName;	
	self.gkey 					:= helper.gkey;
	self.category				:= helper.category;
	self.ctr_id 				:= helper.ctr_id;
	self.fcy_gkey 				:= helper.fcy_gkey;
	self.handled				:= helper.handled;	
	self.line_id				:= helper.line_id;
	self.nbr					:= helper.nbr;
	self.seq_within_facility	:= helper.seq_within_facility;
	self.stage_id				:= helper.stage_id;
	self.status					:= helper.status;
	self.sub_type				:= helper.sub_type;
	self.trkco_id 				:= helper.trkco_id;
	self.truck_visit_gkey		:= helper.truck_visit_gkey;

epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
