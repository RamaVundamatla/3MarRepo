    <JadeMethod name="trxAutoProcessExpiredToDoTask" id="f094d0ab-a49d-4fc0-9f15-b91a2740c9ab">
        <updating/>
        <source>trxAutoProcessExpiredToDoTask(_terminal:CM_Terminal input; _toDoTaskDesc : CM_ToDoTaskDesc; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	tiSet : CM_TISet;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	create tiSet transient;

	beginLoad;
	_terminal.getAllContainersForExpiredTask(tiSet, _toDoTaskDesc, _passport);
	endLoad;
	
	beginTransaction;
	
	// DVB moved this here so we get a completed transaction instead 
	// of an aborted one.
	if tiSet.isEmpty then
		return;
	endif;

	app.myUtilityUA.utlAutoProcessExpiredToDoTask(tiSet, _toDoTaskDesc, _passport);

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete tiSet;		// possible leaking transient	// cnwrl1 18/08/2010 PAR 24050
	self.finaliseActivityWithPassport(_passport);
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAutoResequenceOnPickup" id="92e7477d-5f4b-4e99-b89f-71c89b9743f9">
        <updating/>
        <source>trxAutoResequenceOnPickup(	_machine 		: CM_Machine;
							_rtQueueEntry : CM_RTQueueEntry input;
							_passport : CM_Passport input) updating;
/*

Purpose:		sets the setdown tasks target location to the best possible location
				and resequences any jobs that were meant to go to the new location to our tasks original target location

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwer1	Initial creation

*/

vars
	terminal : CM_Terminal;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	
	app.setContinueCMExceptions(false);
	
	beginTransaction;

	
	app.myUtilityUA.utlAutoResequenceOnPickup(_machine,_rtQueueEntry,_passport);
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxBreakBulkOverage" id="0b7f50b7-1b1f-4ea5-abea-69fc71aed228">
        <updating/>
        <source>trxBreakBulkOverage(_ti : CM_TrackedItem input;
					_context : String;
					_quantity : Integer;
					_totalWeight : Decimal;
					_cargoWeight : Decimal;
					_tareWeight : Decimal;
					_reason : String;
					_isShortlanded : Boolean; //29/03/2023	navkc1	CR# 56430 TASK 56435
					_isOverlanded : Boolean; 
					_autoZero : Boolean; //12/04/2023	navkc1	CR 56431 Task 56438
					_passport : CM_Passport input
					) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2013	cnwrd1	Initial creation
29/03/2023	navkc1	CR# 56430 Task 56435 Jade - Tracked Item Methods
12/04/2023	navkc1	CR 56431 Task 56438: UI - Cargo Enquiry
17/05/2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
25 Mar 2025	navhl20 Bug MTN-34322: EUP FR | 54014 - Unable to zero out weight and quantity for cargo attached to a job (Error 88606)
*/

begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate 		  := true;					//26.03.2025 navhl20 #34322				
	_passport.useTITransactionDeferUpdate := true;					//26.03.2025 navhl20 #34322	
	
	//22 Sep 2016	NDL	TFS 2537 
	app.myValUA.valBreakBulkOverage(_ti, _quantity, _totalWeight,false, _passport);

	
	if _passport.hasErrors then
		return;
	endif;
	
	beginTransaction;

	app.myUtilityUA.utlBreakBulkOverage(_ti, _quantity , _totalWeight, _cargoWeight, _tareWeight , _reason , _isShortlanded, _isOverlanded, _autoZero, _passport);

	if _passport.noErrors then										//26.03.2025 navhl20 #34322	
		_passport.doDeferredUpdates();	
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_context" type="String"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_cargoWeight" type="Decimal"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_isShortlanded" type="Boolean"/>
        <Parameter name="_isOverlanded" type="Boolean"/>
        <Parameter name="_autoZero" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCalcLocationStats" id="94f179e7-5000-420e-8985-fd4e4eab5131">
        <updating/>
        <source>trxCalcLocationStats(	_termAreaSet : CM_TerminalAreaSet;
						_yaBlockSet : CM_YABlockSet;
						_movementLogArray : ObjectArray io;
						_passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		06 November 2008 by cnwdad1
//
// Purpose:		Calculates Location Statistics for all relevant Terminal Areas and
//				Yard Allocations.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 09 June 2009	conkc1  	Added Deadlock exception handler and Deadlock priority
//
// --------------------------------------------------------------------------------
constants
	PersistentDeadlockPriority : Integer = -999;
vars
	allTerminalsSet	: CM_TerminalSet;
	allGridColSet,
	allGridRowSet	: CM_GridObjectSet;
	areaObj			: CM_TerminalArea;
	
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	on DeadlockException do agtPassportDeadlockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	// First, gather up all of the Terminals and Grid Areas that are affected.
	
	create allTerminalsSet transient;
	create allGridRowSet transient;
	create allGridColSet transient;
	
	foreach areaObj	in _termAreaSet do
		if not allTerminalsSet.includes(areaObj.myTerminal) then
			allTerminalsSet.add(areaObj.myTerminal);
		endif;
		
		if areaObj.isGridArea() then
			areaObj.CM_GridArea.allGridRows.copy(allGridRowSet);
			areaObj.CM_GridArea.allGridColumns.copy(allGridColSet);
		endif;
	endforeach;
	//
	//  Ensure that this process receives any deadlocks as the action will be replayed
	//  Note : CM_Passport :: finaliseTransaction resets this to zero after every transaction
	//
	process.setPersistentDeadlockPriority(PersistentDeadlockPriority);
	// Now do the transaction.	
	beginTransaction;
	
	app.myUtilityUA.utlCalcLocationStats(	allTerminalsSet,
											_termAreaSet,
											allGridRowSet,
											allGridColSet,
											_yaBlockSet,
											_movementLogArray,
											_passport);
	
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
	
	delete allTerminalsSet;
	delete allGridRowSet;
	delete allGridColSet;
end;</source>
        <Parameter name="_termAreaSet" type="CM_TerminalAreaSet"/>
        <Parameter name="_yaBlockSet" type="CM_YABlockSet"/>
        <Parameter name="_movementLogArray" type="ObjectArray" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCalcLocationStatsBackground" id="1f0f1735-43c9-4ef6-beea-b7fc44a65965">
        <updating/>
        <source>trxCalcLocationStatsBackground(_termAreaSet : CM_TerminalAreaSet;
							   _gridRowsSet,
							   _gridColumnSet: CM_GridObjectSet;
							   _yaBlockSet : CM_YABlockSet;
							   _movementLogArray : ObjectArray io;
							   _passport : CM_Passport input) updating;

/*

Purpose:			Calculates Location Statistics for all passed in Terminal Areas,
					Grid Rows and YA Blocks
					
Parameters:			Terminal Areas,
					Grid Rows,
					YA Blocks,
					Movent Logs to delete

Return Value:		None


Date		Who		Reason
07 Sep 2009	cnwkpd1	PAR #20586 - Performance enhancement by reducing number of Grid Rows to 
					recalculate

*/

constants
	PersistentDeadlockPriority : Integer = -999;
	
vars
	allTerminalsSet	: CM_TerminalSet;
	areaObj			: CM_TerminalArea;
	
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	on DeadlockException do agtPassportDeadlockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	// First, gather up all of the Terminals affected
	create allTerminalsSet transient;
	
	foreach areaObj	in _termAreaSet do
		allTerminalsSet.addNoDuplicates(areaObj.myTerminal, false);
	endforeach;
	//
	//  Ensure that this process receives any deadlocks as the action will be replayed
	//  Note : CM_Passport :: finaliseTransaction resets this to zero after every transaction
	//
	process.setPersistentDeadlockPriority(PersistentDeadlockPriority);
	
	// Now do the transaction.	
	beginTransaction;
	
	app.myUtilityUA.utlCalcLocationStats(	allTerminalsSet,
											_termAreaSet,
											_gridRowsSet,
											_gridColumnSet,
											_yaBlockSet,
											_movementLogArray,
											_passport);
	
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	
	delete allTerminalsSet;
	
end;</source>
        <Parameter name="_termAreaSet" type="CM_TerminalAreaSet"/>
        <Parameter name="_gridRowsSet" type="CM_GridObjectSet"/>
        <Parameter name="_gridColumnSet" type="CM_GridObjectSet"/>
        <Parameter name="_yaBlockSet" type="CM_YABlockSet"/>
        <Parameter name="_movementLogArray" type="ObjectArray" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCalcLocationStatsGridRow" id="777600bd-f497-4539-9c4f-fd7bb5d2e6bf">
        <updating/>
        <source>trxCalcLocationStatsGridRow(gridRowSet       : CM_GridObjectSet; 
                             _passport         : CM_Passport input) updating;
/*

Purpose:			Calculate Location Statistics for the given set of GridRows

Parameters:			Set of GridRows

Return Value:		

Date		Who		Reason
02 September 2008	conkc1	Initial creation
09 June 2009		conkc1  Added Deadlock exception handler and Deadlock priority

*/
constants
	PersistentDeadlockPriority : Integer = -999;
vars
	gridRow     : CM_GridRow;
	gridObject  : CM_GridObject;
begin
write class.name &amp; "::" &amp; method.name &amp; " is now redundant - use trxCalcLocationStats.";
return;
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	on DeadlockException do agtPassportDeadlockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	//
	//  Ensure that this process receives any deadlocks as the action will be replayed
	//  Note : CM_Passport :: finaliseTransaction resets this to zero after every transaction
	//
	process.setPersistentDeadlockPriority(PersistentDeadlockPriority);	
	beginTransaction;

	foreach gridObject in gridRowSet do
		gridRow := gridObject.CM_GridRow;
		exclusiveLock(gridRow);
		gridRow.buildLocationStatistics;
	endforeach;

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="gridRowSet" type="CM_GridObjectSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCalcLocationStatsYABlock" id="43550038-3100-4ed9-acd1-0f0b670239d8">
        <updating/>
        <source>trxCalcLocationStatsYABlock(yaBlockSet       : CM_YABlockSet; 
                            movementLogArray : ObjectArray io;
                           _passport         : CM_Passport input) updating;
/*

Purpose:			Calculate Location Statistics for the given set of YABlock

Parameters:			Set of Yard Allocation Blocks
					Array of CM_MovementLogs (can be null)

Return Value:		


Date		Who		Reason
22 August 2008	conkc1	Initial creation

*/
vars
	yardAllocationBlock	: CM_YABlock;
	
begin
write class.name &amp; "::" &amp; method.name &amp; " is now redundant - use trxCalcLocationStats.";
return;
//	process.profilerStart();

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	beginTransaction;

	foreach yardAllocationBlock in yaBlockSet do
		exclusiveLock(yardAllocationBlock);
		yardAllocationBlock.buildLocationStatistics();
	endforeach;
	//
	// Now purge the movementLogArray - this maybe empty
	//
	if movementLogArray &lt;&gt; null then
		movementLogArray.purge();
	endif;

	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="yaBlockSet" type="CM_YABlockSet"/>
        <Parameter name="movementLogArray" type="ObjectArray" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCancelAssignedTIDirector" id="0e80b78b-79d1-4299-8079-1dd7958280aa">
        <updating/>
        <source>trxCancelAssignedTIDirector(_rtQueueTask :  CM_RTQueueTask input;
							_machine : CM_Machine input;
							_passport : CM_Passport input) updating;
	
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 November 2011	cnwrd1	Initial creation

*/
vars
	ti : CM_TrackedItem;
	tiLocation : CM_LocationsController;
	job : CM_Job;
	updateMachineStatus : Boolean;
	rtEntry : CM_RTQueueEntry;
begin
 // Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport); //epr par 14718


	//app.myValRT.valCancelTask(_machine,_rtQueueTask);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	beginTransaction;

	if _rtQueueTask.isDirectorWithAssignedTI() then 
		app.myUtilityUA.utlCancelDirectorWithTITask(_rtQueueTask,_machine, _passport);
	else
		//shouldnt be here
	endif;
	if app.myPassport.hasErrors then
		return;
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCancelHMSMovement" id="ad689e7b-0bbc-4089-95bd-bdf54c276f4e">
        <updating/>
        <source>trxCancelHMSMovement(	_pxyCancelMovement : HMS_Movement;
						_woDtlForStatusChg : CM_WorkOrderVoyageDtl input;
						_woPermitToClear : CM_WodPermitRequest input;
						_pxyNewMovement : HMS_Movement input;
						_realNewMovement : HMS_Movement output;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlgndl1	Initial creation	TFS 42043
04 Dec 2018	NDL	TFS 42043 - More changes.

*/

vars

	woParent : CM_WorkOrderVoyage;
	newStatus : Integer;
	voyage : CM_Voyage;
	term : CM_Terminal;
	voyageStatus : CM_VoyageStatus;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _woDtlForStatusChg &lt;&gt; null then 
		woParent := _woDtlForStatusChg.getMyParent.CM_WorkOrderVoyage;
		if woParent &lt;&gt; null then
			voyage := woParent.getMyVoyageObject();
			if voyage &lt;&gt; null then
				term := voyage.getMyTerminal;
			endif;
		endif;
	endif;
	
	beginTransaction;
	
	//29 Nov 2018	NDL	TFS 42043
	if _woPermitToClear &lt;&gt; null then
		_woPermitToClear.setMyPermitWodVoyageDetail( null );
		if _passport.hasErrors then
			return;
		endif;
	endif;
	
	app.myUtilityUA.utlUpdateHMSMovement(_pxyCancelMovement, _passport);
	
	if not _passport.hasErrors and woParent &lt;&gt; null then
		woParent.setCancelledNoSAP();
	endif;
	
	if _pxyNewMovement &lt;&gt; null then	//11 Dec 2018	NDL	TFS 42043 - This week we don't do Shift movements, so may be null.
		if not _passport.hasErrors then
			app.myUtilityCA.utlCreateHMSMovement(_pxyNewMovement, _realNewMovement, true, _passport);
		endif;
	endif;
	
	if _passport.noErrors then
		if voyage &lt;&gt; null and term &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(voyage, term.getTerminalEvent(Voyage_Update_Event), voyage); 
		endif;
	endif; 

epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_pxyCancelMovement" type="HMS_Movement"/>
        <Parameter name="_woDtlForStatusChg" type="CM_WorkOrderVoyageDtl" usage="input"/>
        <Parameter name="_woPermitToClear" type="CM_WodPermitRequest" usage="input"/>
        <Parameter name="_pxyNewMovement" type="HMS_Movement" usage="input"/>
        <Parameter name="_realNewMovement" type="HMS_Movement" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
