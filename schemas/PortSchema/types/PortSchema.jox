    <JadeMethod name="getOSDescription" id="5cb72f02-cc5d-4bbc-afb2-64e25987d541">
        <source>getOSDescription():String;
// ---------------------------------------------------------------------------
// Created:     17 February 2010 by cnwcs5
// Purpose:     Get description of operating system (replaces existing method of same name)
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
    jdo : JadeDynamicObject;
begin
    create jdo transient;
	
    process.getOSDetails(jdo);
    
	return jdo.getAttributeValue("osVersionString").String;
epilog
    delete jdo;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOSDescription_old" id="28ed07a3-d6b4-4a29-b07c-19c192e003c4">
        <source>getOSDescription_old(_osPlatform : Integer; _osVersion : String; _osArchitecture : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     09 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	WindowsCE = 19;

vars

begin

	if _osPlatform.bitAnd(Node.OSWindows) &lt;&gt; 0 then
		// Operating system is Windows family (98, Me, 2000, or XP).
		if _osPlatform = Node.OSWindowsHome then
			// Version is one of Windows 95 or Windows 98.
			return	"Windows " &amp; _osVersion;
			
		elseif _osPlatform = Node.OSWindowsEnterprise then
			// Version is one of Windows 2003 Server, Windows 2000, or Windows XP.
            if _osVersion.Real &gt;= 5.2 then
                return 'Windows 2003';
            elseif _osVersion.Real &gt;= 5.1 then
                return 'Windows XP';
            elseif _osVersion.Real &gt;= 5.0 then
                return 'Windows 2000';
            else
                return 'Windows NT ' &amp; _osVersion;
            endif;
			
		elseif _osPlatform = Node.OSWindowsMobile then
			return "Windows Mobile " &amp; _osVersion;
			
		elseif _osPlatform = WindowsCE then
			return "Windows CE " &amp; _osVersion;
		endif;
		
	elseif _osPlatform.bitAnd(Node.OSUnix) &lt;&gt; 0 then
		// Operating system is unix (aix, linux, solaris, etc).
		if _osPlatform = Node.OSUnixAIX then  
			// Version is 4.3, for all releases of AIX 4.3.
			return	"IBM AIX " &amp; _osVersion;
			
		elseif _osPlatform = Node.OSUnixLinux then
           if _osArchitecture = Node.Architecture_32Little_Endian then
                return 'Intel Linux ' &amp; _osVersion;
            else
                return 'Linux ' &amp; _osVersion;
            endif;
		endif;
	endif;

	return	"Unknown platform: " &amp; _osPlatform.String &amp; " Version: " &amp; _osVersion;
epilog

end;</source>
        <Parameter name="_osPlatform" type="Integer"/>
        <Parameter name="_osVersion" type="String"/>
        <Parameter name="_osArchitecture" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjectForRequestTypeString" id="6257c1c7-5fb2-4a18-b570-ef1ff740bc90">
        <source>getObjectForRequestTypeString(_requestTypeDesc : String) : CM_Object;

/*

Purpose:			Get the object matching the passed in request type description

Parameters:			String description to match

Return Value:		Object the string represents, or null if none exists


Date		Who		Reason
22 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	tmpStopTable 	: CM_StopsTable;
	tmpStopTableDict : CM_StopsTableByIdDict;
	tmpToDoTask 	: CM_ToDoTaskDesc;
	tmpTaskDict 	: CM_ToDoTaskDescByCode;
	tmpRole 		: CM_SecurityRole;
	tmpTransType 	: CM_TransactionType;
	
begin
	// Only check those those that the security role has access to
	tmpRole := app.getMySecurityRole();
	if tmpRole = null then
		return null;
	endif;
	
	// First check transactions
	foreach tmpTransType in tmpRole.allTransactionTypesForEvents do
		if _requestTypeDesc = tmpTransType.description then
			return tmpTransType;
		endif;
	endforeach;		
	
	// Addition and removal of specific stops
	// Note: string format is used to determine whether request is for removing/clearing the stop
	// refer CMIF_EventRequestController::actionNotify();
	tmpStopTableDict := tmpRole.allStopsView;
	foreach tmpStopTable in tmpStopTableDict do
		if _requestTypeDesc = app.eventReqFormatActivityString(app.getErrorString(AddUpper), tmpStopTable.heading) or
		   _requestTypeDesc = app.eventReqFormatActivityString(app.getErrorString(ClearUpper), tmpStopTable.heading) then
			return tmpStopTable;
		endif;
	endforeach;	

	// Addition and removal of specific To Do Task
	// Note: string format is used to determine whether request is for removing/completing the task
	// refer CMIF_EventRequestController::actionNotify();	
	tmpTaskDict := tmpRole.allToDoTasksAddRemove;
	foreach tmpToDoTask in tmpTaskDict do
		if _requestTypeDesc = app.eventReqFormatActivityString(app.getErrorString(AddUpper), tmpToDoTask.description) or
		   _requestTypeDesc = app.eventReqFormatActivityString(app.getErrorString(ClearUpper), tmpToDoTask.description) then
			return tmpToDoTask;
		endif;
	endforeach;	

	// Didn't find a match, so return null
	return null;

	
epilog
	
end;</source>
        <Parameter name="_requestTypeDesc" type="String"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
