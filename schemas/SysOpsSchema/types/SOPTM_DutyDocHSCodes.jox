    <JadeMethod name="doSave" id="a01d0c45-308a-4783-9530-cd53b8832684">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars
	proxyDutyDocHSCode		: CM_DutyDocHSCode;
	theForm 				: SOP_TableMaintForm;
	
	lCode					: Integer64;
	lDescription			: String;
	lShortDesc				: String;
	lDutyType				: String;
	lDutyRate				: Decimal[5,2];
	lDutyExempt				: Boolean;
	lPriceCargo				: Boolean;
	lChemicalCargo			: Boolean;
	lNuclearCargo			: Boolean;
	
begin
	theForm := self.myForm; 
	
	lCode := theForm.tblInput1.getValueByName(ETRow_HsCode).Integer64;
	lDescription := theForm.tblInput1.getValueByName(ETRow_LongDescription).String;
	lShortDesc := theForm.tblInput1.getValueByName(ETRow_ShortDescription).String;
	lDutyType := theForm.tblInput1.getValueByName(ETRow_DutyType).String;
	lDutyRate := theForm.tblInput1.getValueByName(ETRow_DutyRate).Decimal;
	lDutyExempt := theForm.tblInput1.getValueByName(ETRow_DutyExempt).Boolean;
	lPriceCargo := theForm.tblInput1.getValueByName(ETRow_PriceCargo).Boolean;
	lChemicalCargo := theForm.tblInput1.getValueByName(ETRow_ChemicalCargo).Boolean;
	lNuclearCargo := theForm.tblInput1.getValueByName(ETRow_NuclearCargo).Boolean;
	

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DutyDocHSCode transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyDutyDocHSCode := theForm.myProxyObject.CM_DutyDocHSCode;
	proxyDutyDocHSCode.setProxy(lCode, lDescription, lShortDesc, lDutyType, lDutyRate, lDutyExempt, lPriceCargo, lChemicalCargo, lNuclearCargo);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateDutyDocHSCode(proxyDutyDocHSCode, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDutyDocHSCode(proxyDutyDocHSCode, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
