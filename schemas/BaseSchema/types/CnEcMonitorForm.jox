    <JadeMethod name="doShowMonitorMessage" id="2f6501ea-eb88-4a3c-8582-23829a2c8ef1">
        <source>doShowMonitorMessage(pMonitorMessage:String) protected;

constants
	TEXTBOX_SIZE_UPPER : Integer = 20000;
	TEXTBOX_SIZE_LOWER : Integer = 16000;

vars
	textboxLines		: Integer;
	firstVisibleLine	: Integer;
	textHeight			: Integer;
	visibleLines		: Integer;
	textboxObj			: TextBox;
	testData			: String;
	rowIndex			: Integer;
	rowCount			: Integer;
	isTextIncluded		: Boolean;
	isIncludesUsed		: Boolean;
	message				: String;
	callingAppName		: String;
	delimiterPos		: Integer;
	excludedApp			: String;
	includedApp			: String;

begin
	if aIsPaused then
		return;
	endif;

	delimiterPos	:=	pMonitorMessage.pos("|", 1);

	if delimiterPos = 0 then
		message	:=	pMonitorMessage;
	else
		if delimiterPos &gt; 1 then
			callingAppName	:=	pMonitorMessage[1:(delimiterPos - 1)];
		endif;

		message	:=	pMonitorMessage[(delimiterPos + 1):end];
	endif;

	excludedApp	:=	cmbExclude.text;
	includedApp	:=	cmbInclude.text;

	if excludedApp &lt;&gt; null and excludedApp = callingAppName then
		return;
	elseif includedApp &lt;&gt; null and includedApp &lt;&gt; callingAppName then
		return;
	endif;

	if message.length &gt; 10 then
		// Strip off time so can test data.
		testData			:=	message[10:message.length];
		isTextIncluded		:=	false;
		isIncludesUsed		:=	false;
		tblInclude.column	:=	1;
		rowCount			:=	tblInclude.rows;

		foreach rowIndex in 2 to rowCount do
			tblInclude.row	:=	rowIndex;

			if tblInclude.text.length &gt; 0 then
				isIncludesUsed	:=	true;

				if testData[1:tblInclude.text.length] = tblInclude.text then
					isTextIncluded	:=	true;
					break;
				endif;
			endif;

		endforeach;

		if isIncludesUsed and (not isTextIncluded) then
			return;
		endif;

		tblExclude.column	:=	1;
		rowCount			:=	tblExclude.rows;

		foreach rowIndex in 2 to rowCount do
			tblExclude.row	:=	rowIndex;

			if tblExclude.text.length &gt; 0 then
				if testData[1:tblExclude.text.length] = tblExclude.text then
					return;
				endif;
			endif;

		endforeach;
	endif;

	textboxObj	:=	txtMonitor;

	// Check on the current size of the textbox contents and truncate if necessary.
	if textboxObj.text.length &gt; TEXTBOX_SIZE_UPPER then
		textboxObj.text	:=	textboxObj.text[textboxObj.text.length - TEXTBOX_SIZE_LOWER:end];
	endif;

	textboxObj.text	:=	textboxObj.text &amp; CrLf &amp; message;

	// Scroll the textbox so the last line is at the bottom of the box.
	textboxLines	:=	textboxObj.lineCount;

	textHeight := 13; // Approx height in pixels of textbox text.

	// Calculate the client area height in text lines.
	visibleLines	:=	(textboxObj.clientHeight() / textHeight).Integer;

	// Set the scroll range to a few lines before the end of the text box
	// unless it's too much, like when there are no lines!
	firstVisibleLine	:=	textboxLines - visibleLines + 1;
	self.doMessageLog(pMonitorMessage);

	if firstVisibleLine &lt; 1 or firstVisibleLine &gt; textboxLines then 
		return;
	endif;

	textboxObj.scrollVertPos	:=	firstVisibleLine;
end;</source>
        <access>protected</access>
        <Parameter name="pMonitorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnvironmentName" id="eb35b314-c3c2-4d19-abb8-2f02ffd98341">
        <updating/>
        <source>getEnvironmentName():String updating, protected;
// --------------------------------------------------------------------------------
// Created:		25 May 2000 by cnwdad1
//
// Purpose:		Extract the Jade Utility environment name from the directory path.
//
// Parameters:	None
//
// Returns:		The name of the environment.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
 	directoryName	: String;
 	environmentName	: String;
 	startPos		: Integer;
 	folderObj		: FileFolder;

begin
	create folderObj transient;

	folderObj.fileName	:=	app.getJadeInstallDir();
	directoryName		:=	folderObj.cnEcFilePath();			// Get the base directory name.
	startPos			:=	directoryName.pos(":" &amp; global.cnEcGetFileSeparator(), 1) + 2;		// Get start position of directory name.
	environmentName		:=	directoryName[startPos:(directoryName.pos("\", startPos) - startPos)];	// Extract the directory name.

	return environmentName;
epilog
	delete folderObj;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLogFile" id="3c498bd0-cf5c-4c8e-b10b-f0c6f59b0f56">
        <updating/>
        <source>getLogFile() updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2000 by cnwdad1
//
// Purpose:		Set a refernce to a log file.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileOpenObj	: CMDFileOpen;
	fileName	: String;

begin
	create fileOpenObj;
	fileOpenObj.allowMultiSelect	:=	false;
	fileOpenObj.defaultExt			:=	".log";
	fileOpenObj.fileMustExist		:=	true;
//	fileOpenObj.filter				:=	"Log File (*.log)|*.log|Text (*.txt)|*.txt|All files (*.*)|*.*";
//	fileOpenObj.filterIndex		:=	1;
	fileOpenObj.cnEcSetFilters(true, 1, CNEC_FILE_FILTER_LOG, CNEC_FILE_FILTER_TEXT);

	if fileOpenObj.open = 0 then
		fileName	:=	fileOpenObj.fileName;

		create self.aMyLogFile transient;
		self.aMyLogFile.fileName	:=	fileName;
		self.aMyLogFile.cnEcOpenForLogging();
	endif;
epilog
	delete fileOpenObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
