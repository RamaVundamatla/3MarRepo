    <JadeMethod name="tblWLEMouseMoveEvent" id="618206e0-2dd8-441a-9dcc-859013e15b95">
        <updating/>
        <source>tblWLEMouseMoveEvent(_table: Table input; _button: Integer; _shift: Integer; _x: Real; _y: Real) updating;
/*

Purpose:			Handles mouse move events on the given table

Parameters:			

Return Value:		

Date			Who		Reason
17 July 2019	jlgzm1	Initial creation TFS 42872 JMT - Direct Release Between HOLD Voyages and Rail - All Cargo Types
10 Dec  2021    navma1	Bug 52539: SAL - Hold Planning Split Work - Delete Job
*/

vars
	sheet 	 : CMUI_Sheet;
	job   	 : CM_VoyageHoldJob;
	invalid	 : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, job, invalid); 					//10.12.21 navma1 #52539
		
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if self.tblAllocatedGang &lt;&gt; null and _table.name = self.tblAllocatedGang.name then
		sheet := self.fldData.topSheet.CMUI_Sheet;
		job   := sheet.userObject.CM_VoyageHoldJob;
	endif;
	
	if job = null then
		return;
	endif;
	
	job.fetchLatest();				//10.12.21 navma1 #52539
	
	if invalid then
		return;
	endif;
	
	if not job.isDischarge then
		return;
	endif;
	
	
	if self.myCurrentWLE = null then
		return;
	endif;
	
	// check drag/drop detected
	if _button &lt;&gt; Window.MouseButton_Left or (not app.dragDetected(_x, _y, self.origXPos, self.origYPos)) then
	   return;
	endif;
	self.origXPos := 0;
	self.origYPos := 0;	
   	
   	if (not self.myCurrentWLE.isReceipt) then
   		return;
   	endif;

	self.dragWorkListEntry(self.myCurrentWLE, _table);
	
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_shift" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="cd0d0fa0-a1ec-4ad0-b01c-48920a7b3308">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/02/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;

begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	/* TFS 3549 now handled by controls beign on a frame, code done in doResize
	self.lblVoyage.top := self.lblVoyage.top + heightDiff;
	self.cmbVoyage.top := self.cmbVoyage.top + heightDiff;
	self.lblWorkPoint.top := self.lblWorkPoint.top + heightDiff;
	self.cmbWorkPoint.top := self.cmbWorkPoint.top + heightDiff;
	self.lblShift.top := self.lblShift.top + heightDiff;
	self.cmbShifts.top := self.cmbShifts.top + heightDiff;
	self.lblJobId.top := self.lblJobId.top + heightDiff;
	self.txtJobId.top := self.txtJobId.top + heightDiff;
	self.btnCreateJob.top := self.btnCreateJob.top + heightDiff;
	self.btnRemoveJob.top := self.btnRemoveJob.top + heightDiff;
	self.lblShiftStartDate.top := self.lblShiftStartDate.top + heightDiff;
	self.txtShiftStartDate.top := self.txtShiftStartDate.top + heightDiff;
	self.txtShiftStartTime.top := self.txtShiftStartTime.top + heightDiff;
	self.lblJobRemarks.top := self.lblJobRemarks.top + heightDiff;
	self.txtJobRemarks.top := self.txtJobRemarks.top + heightDiff;
	self.lblShiftEndDate.top := self.lblShiftEndDate.top + heightDiff;
	self.txtShiftEndDate.top := self.txtShiftEndDate.top + heightDiff;
	self.txtShiftEndTime.top := self.txtShiftEndTime.top + heightDiff;
	self.lblShiftRemarks.top := self.lblShiftRemarks.top + heightDiff;
	self.txtShiftRemarks.top := self.txtShiftRemarks.top + heightDiff;
	self.fldData.top := self.fldData.top + heightDiff;
	// TFS 3549 controls missing
	self.chkDLR.top := self.chkDLR.top + heightDiff;
	self.chkSOB.top := self.chkSOB.top + heightDiff;
	self.cmbDischLoad.top := self.cmbDischLoad.top + heightDiff;
	self.cmbSubArea.top := self.cmbSubArea.top + heightDiff;
	self.lblDischLoad.top := self.lblDischLoad.top + heightDiff;
	self.lblSubArea.top := self.lblSubArea.top + heightDiff;
	self.doResize();
	*/
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="23992a26-e223-4d04-91f1-500f241a28c3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 October 2021 11:18:51.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021689, locale);
	btnAlloc.translateBubbleHelp(Xlat_0021930, locale);
	btnAlloc.translateCaption(Xlat_0021931, locale);
	btnCopyCargo.translateBubbleHelp(Xlat_0021801, locale);
