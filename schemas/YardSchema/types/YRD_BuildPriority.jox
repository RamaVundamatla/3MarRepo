        <source>showWithObject(pObj : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------

begin
	if pObj &lt;&gt; null and pObj.isKindOf(CM_Job) then
		self.initForm(pObj.CM_Job);
	else
		self.initForm(null);
	endif;
	
	self.show();
end;</source>
