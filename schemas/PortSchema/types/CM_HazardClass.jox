    <JadeMethod name="delete" id="11053ee0-8452-419a-978c-9216ff0025e7">
        <updating/>
        <source>delete() updating;
// cnwrs1 june 2006 was missing
// 
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 12/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
vars
	
begin

	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
	
	if global.isValidObject(self.myDrawingAttribute) then		// PAR #36206
		delete self.myDrawingAttribute;							// PAR #36206
	endif;														// PAR #36206
end;</source>
    </JadeMethod>
    <JadeMethod name="getAttachmentsAuditText" id="cff7d840-652b-452a-ad38-85d9b38ad324">
        <source>getAttachmentsAuditText() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/06/2015	cnwdap1		Initial creation PAR #63421 Hazardous Materials Handling
//
vars
	symbol : CM_Attachment;
	str : String;

begin
	foreach symbol in self.allSymbols where symbol.type = CM_Attachment.Type_Symbol do
		str := str &amp; symbol.description &amp; ',';
	endforeach;
	if str[str.length] = ',' then
		str := str[1:str.length-1];					
		return str;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="7f4bd68e-46be-4130-9cf7-df9755822263">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Jan 2006	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.description;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="374025b4-696b-4a83-88c3-7fde75a9a45f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Apr 2014	cnwdb2		PAR #33977  
// 12/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation for Hazard Class
// 15/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// ---------------------------------------------------------------------------

vars

begin

	if _attrName = ETRow_NotAvailableForEntry then
		return self.isNotAvailableForEntry.String;
		 	
	elseif _attrName = ETRow_DrawColour or														// PAR #36206
		_attrName = ETRow_DrawAttribute or														// PAR #36206
		_attrName = ETRow_Font or																// PAR #36206
		_attrName = ETRow_Character or															// PAR #36206
		_attrName = ETRow_CharacterNumber then													// PAR #36206
		if self.myDrawingAttribute &lt;&gt; null then													// PAR #36206
			return self.myDrawingAttribute.getDisplayStringForAttribute(_attrName, _short);		// PAR #36206
		else																					// PAR #36206
			return null;																		// PAR #36206
		endif;																					// PAR #36206
		
	elseif _attrName = ETRow_Symbols then														// PAR #36421
		return app.getErrorString(Dbl_Click_To_Add_Update);										// PAR #36421
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSymbols" id="0ac33181-7a2d-4ec3-baa1-5d31077291c9">
        <source>getSymbols(_symbols : ObjectArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	symbol : CM_Attachment;

begin
	foreach symbol in self.allSymbols do
		_symbols.add(symbol.CM_Symbol);
	endforeach;
epilog

end;</source>
        <Parameter name="_symbols" type="ObjectArray" usage="input"/>
    </JadeMethod>
