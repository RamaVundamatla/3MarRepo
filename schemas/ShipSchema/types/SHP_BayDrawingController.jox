// Created:     25 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_amPrinting, _printOutputSize, _separateODUD);

	self.setFontSizeForAttribute();
	
end;</source>
        <Parameter name="_amPrinting" type="Boolean"/>
        <Parameter name="_printOutputSize" type="Integer"/>
        <Parameter name="_separateODUD" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAttrPositions" id="2b12c842-89bd-4fc3-bd54-18da1026dc68">
        <updating/>
        <source>setAttrPositions(_displayMode : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin

	if _displayMode = ShpDisplayMode_Actual or
	   _displayMode = ShpDisplayMode_Proposed or
	   _displayMode = ShpDisplayMode_EDI then
		self.setAttrPositionsAct();
	elseif _displayMode = ShpDisplayMode_ColCodeDisch then
		self.setAttrPositionsColCodeDisch();
	elseif _displayMode = ShpDisplayMode_ColCodeLoad then
		self.setAttrPositionsColCodeLoad();
	elseif _displayMode = ShpDisplayMode_Defn then
		self.setAttrPositionsDefn();
	else
		// set as the default (for first time)
		self.setAttrPositionsAct();
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_displayMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAttrPositionsAct" id="11c94e67-0f88-4895-9e80-17f82314a17a">
        <updating/>
        <source>setAttrPositionsAct() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		works out the X and Y for the attribute 'icon'
// ---------------------------------------------------------------------------
vars
	yOffset,
	theX, theY		: Integer; 
	tmpY,
	tmpScaleFactor	: Real;
begin

	tmpScaleFactor := self.scaleFactor;

	if tmpScaleFactor = ScaleFactor_4 then
		yOffset := 3;			
	endif;
	
	theX := (self.columnWidth / 2).Integer + 2;
	theY := (self.rowHeight / 2).Integer - 5;
	
	if tmpScaleFactor &gt;= ScaleFactor_9 then
		tmpY := (self.rowHeight - 35).Integer + yOffset;

		self.attrX1 := 2;
		self.attrY1 := tmpY;
		self.attrX2 := 22;
		self.attrY2 := tmpY;
		self.attrX3 := 42;
		self.attrY3 := tmpY;
		self.attrX4 := 62;
		self.attrY4 := tmpY;
		
		self.attrMaxNum := 4;

	elseif tmpScaleFactor &gt;= ScaleFactor_6 then
		tmpY := (self.rowHeight - 24).Integer + yOffset;

		self.attrX1 := 2;
		self.attrY1 := tmpY;
		self.attrX2 := 20;
		self.attrY2 := tmpY;
		self.attrX3 := 38;
		self.attrY3 := tmpY;

		self.attrMaxNum := 3;

	elseif tmpScaleFactor &gt;= ScaleFactor_4 then
		tmpY := (self.rowHeight - 24).Integer + yOffset;

		self.attrX1 := 2;
		self.attrY1 := tmpY;
		self.attrX2 := 15;
		self.attrY2 := tmpY;
		self.attrX3 := 28;
		self.attrY3 := tmpY;

		self.attrMaxNum := 3;

	elseif tmpScaleFactor &gt;= ScaleFactor_3 then
		tmpY := (self.rowHeight - 15).Integer + yOffset;

		self.attrX1 := 2;
		self.attrY1 := tmpY;
		self.attrX2 := 15;
		self.attrY2 := tmpY;

		self.attrMaxNum := 2;

	else
		tmpY := ((rowHeight / 3) * 2).Integer - 4 + yOffset;

		self.attrX1 := 1;
		self.attrY1 := tmpY;
		self.attrX2 := theX.Integer;
		self.attrY2 := tmpY;

		self.attrMaxNum := 2;

	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAttrPositionsColCodeDisch" id="db1ba371-061f-410f-a611-e7a2b3d1ea21">
        <updating/>
        <source>setAttrPositionsColCodeDisch() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		works out the X and Y for the attribute 'icon'
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theX, theY, tmpX, tmpY : Real;
	theOffSet : Integer;
	tmpScaleFactor	: Real;
	
begin

	theOffSet := 8;

	tmpScaleFactor := self.scaleFactor;
	
	if tmpScaleFactor = 4 then
		theOffSet := 6;
	endif;

	if tmpScaleFactor = 3 then
		theY := (self.rowHeight / 2).Integer;
		self.attrX1 := 3;
		self.attrY1 := theY;
		self.attrX2 := (self.columnWidth / 2).Integer + 2;
		self.attrY2 := theY;
		
		self.attrMaxNum := 2;

	elseif tmpScaleFactor = 4 then
		theX := (self.columnWidth / 3).Integer;
		theY := ((self.rowHeight / 3) * 2).Integer - 4;
		self.attrX1 := 4;
		self.attrY1 := theY;
		self.attrX2 := theX;
		self.attrY2 := theY;
		self.attrX3 := theX * 2;
		self.attrY3 := theY;

		self.attrMaxNum := 3;
	elseif tmpScaleFactor = 2 or (self.printOutputStyle = PrintOutput_Medium) then
		theY := (self.rowHeight / 2).Integer - 1;

		self.attrX1 := 2;
		self.attrY1 := theY;
		self.attrX2 := (self.columnWidth / 2);
		self.attrY2 := theY;

		self.attrMaxNum := 2;

	else
		theX := (self.columnWidth / 3).Integer;
		theY := ((self.rowHeight / 3) * 2).Integer - theOffSet;
		self.attrX1 := 4;
		self.attrY1 := theY;
		self.attrX2 := theX;
		self.attrY2 := theY;
		self.attrX3 := theX * 2;
		self.attrY3 := theY;

		self.attrMaxNum := 3;

	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAttrPositionsColCodeLoad" id="8878e78f-5fa8-49e1-b844-a63b98ee55bb">
        <updating/>
        <source>setAttrPositionsColCodeLoad() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		works out the X and Y for the attribute 'icon'
// ---------------------------------------------------------------------------
vars
	theX, theY, tmpX, tmpY : Real;
	theOffSet : Integer;
	tmpScaleFactor	: Real;
begin

	tmpScaleFactor := self.scaleFactor;
	
	theOffSet := 2;
	if tmpScaleFactor = 4 then
		theOffSet := 7;
	endif;
	
	if tmpScaleFactor = ScaleFactor_3 then
		theX := (self.columnWidth / 2).Integer + 2;
		theY := (self.rowHeight / 2).Integer;
		self.attrX1 := 3;
		self.attrY1 := theY;
		self.attrX2 := theX;
		self.attrY2 := theY;
		
		self.attrMaxNum := 2;

	elseif tmpScaleFactor = ScaleFactor_2 then
		theX := (self.columnWidth / 2).Integer;
		theY := (self.rowHeight / 2).Integer - 1;

		self.attrX1 := 2;
		self.attrY1 := theY;
		self.attrX2 := theX;
		self.attrY2 := theY;

		self.attrMaxNum := 2;
	else
		theX := (self.columnWidth / 3).Integer;
		theY := ((self.rowHeight / 3) * 2).Integer - 4;
		self.attrX1 := 4;
		self.attrY1 := theY;
		self.attrX2 := theX;
		self.attrY2 := theY;
		self.attrX3 := theX * 2;
		self.attrY3 := theY;

		self.attrMaxNum := 3;
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAttrPositionsDefn" id="c5ac777e-d907-4fff-8bed-07b8f48be1cf">
        <updating/>
        <source>setAttrPositionsDefn() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		works out the X and Y for the attribute 'icon'
// ---------------------------------------------------------------------------
vars
	theX, theY		: Integer;
	theScale 		: Real;
	thePrintStyle	: Integer;
begin

	theScale := self.scaleFactor;
	theX := (self.columnWidth / 3).Integer + 2;
	theY := (self.rowHeight / 3).Integer - 2;
	
	if self.amPrinting then
		thePrintStyle := self.printOutputStyle;
		if thePrintStyle = self.PrintOutput_Small then
			self.attrX1 := 0;
			self.attrY1 := 0;

			self.attrMaxNum := 1;

		elseif self.printOutputStyle = self.PrintOutput_Medium then
			self.attrX1 := 2;
			self.attrY1 := 1;
			self.attrX2 := 10;
			self.attrY1 := 1;
			self.attrX3 := 2;
			self.attrY3 := 8;
			self.attrX4 := 10;
			self.attrY4 := 8;

			self.attrMaxNum := 4;

		else
			self.attrX1 := 2;			// 6/12/17 MAP TFS7494
			self.attrY1 := 1;
			self.attrX2 := (self.columnWidth * .45).Integer;
			self.attrY2 := 1;
			self.attrX3 := (self.columnWidth * .8).Integer;
			self.attrY3 := 1;
			self.attrX4 := 2;
			self.attrY4 := (self.rowHeight * .4).Integer;
			self.attrX5 := (self.columnWidth * .45).Integer;
			self.attrY5 := (self.rowHeight * .4).Integer;
			self.attrX6 := (self.columnWidth * .8).Integer;
			self.attrY6 := (self.rowHeight * .4).Integer;
			self.attrX7 := 2;
			self.attrY7 := (self.rowHeight * .65).Integer;
			self.attrX8 := (self.columnWidth * .45).Integer;
			self.attrY8 := (self.rowHeight * .65).Integer;
			self.attrX9 := (self.columnWidth * .8).Integer;
			self.attrY9 := (self.rowHeight * .65).Integer;

			self.attrMaxNum := 9;		// 6/12/17 MAP TFS7494
		endif;

	// not printing
	elseif theScale = ScaleFactor_1 then
		self.attrX1 := 2;
		self.attrY1 := 1;
		self.attrMaxNum := 1;

	elseif theScale = ScaleFactor_1_5 then
		self.attrX1 := 3;
		self.attrY1 := 1;
		self.attrMaxNum := 1;

	elseif theScale = ScaleFactor_2 then
		self.attrX1 := 3;
		self.attrY1 := 1;
		self.attrMaxNum := 1;
	else	
		self.attrX1 := 2;
		self.attrY1 := 0;

		self.attrX2 := theX;
		self.attrY2 := 0;

		self.attrX3 := theX + theX - 2;
		self.attrY3 := 0;

		self.attrX4 := 2;
		self.attrY4 := theY;

		self.attrX5 := theX;
		self.attrY5 := theY;

		self.attrX6 := theX + theX - 2;
		self.attrY6 := theY;

		self.attrX7 := 2;
		self.attrY7 := theY * 2;

		self.attrX8 := theX;
		self.attrY8 := theY * 2;

		self.attrX9 := theX + theX - 2;
		self.attrY9 := theY * 2;

		self.attrMaxNum := 9;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAttributeForSelectedDefn" id="fdbba107-7357-4e49-97dd-3ac83f37180d">
        <source>setAttributeForSelectedDefn(_attribute : String; _slotDefn : CM_SlotDefn input) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     02 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	aPoint : CMUI_GridPoint;
	matchingBayArea : CMUI_GridArea;
	aString : String;
	matchingPoint : SHP_BayPoint;
	 ls : Boolean;
	pxySD : CM_SlotDefn;
	theSlotController : CM_SlotController;
	pxySR,realSlotRequest : CM_SlotRequest;
	theCargoID : Integer;
	theCommodityCode, theDPortCode : String;
	trxUpdateOK,isVesselDefn,isBackEnd,
	is40  : Boolean;
	theMoveType : Integer;
begin

	if _slotDefn = null then
		app.raiseCMException1(MethodWithNullParam, 'slotDefn', null, null);
		return false;
	endif;

	if _slotDefn &lt;&gt; null then
		// update the actual slot defn
		// if the defn is transient it is a proxy already, and we are calling this from the vessel/voyage defn and not from the voyage work screen
		if _slotDefn.isTransient then
			pxySD := _slotDefn;
			isVesselDefn := true;
		else
			app.cmsBeginLoad(ls);
			pxySD := _slotDefn.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			isVesselDefn := false;
		endif;
		
		isBackEnd := _slotDefn.myBay.isAftBay;
		if _attribute = CM_SlotRequest.Attribute_Forty then
			// ### FORTY FOOT PEN
			// just set fortyFront as the setForUpdate will workout what to do with forty foot back and front on the definition
			is40 := (not pxySD.fortyFront);
			pxySD.setPxyFortyFront(is40);

		// ### 20 DOOR PEN
		elseif _attribute = CM_SlotRequest.Attribute_D20 then // PAR 18682 CCMS SFW 1055
			pxySD.setPxyDoors20Aft((not pxySD.doors20Aft));

		// ### 40 DOOR PEN
		elseif _attribute = CM_SlotRequest.Attribute_D40 then // PAR 18682 CCMS SFW 1055
			pxySD.setPxyDoors40Aft((not pxySD.doors40Aft));

		// ### 20 MOTOR PEN
		elseif _attribute = CM_SlotRequest.Attribute_M20 then // PAR 18682 CCMS SFW 1055
			pxySD.setPxyMotor20Aft((not pxySD.motor20Aft));

		// ### 40 MOTOR PEN
		elseif _attribute = CM_SlotRequest.Attribute_M40 then // PAR 18682 CCMS SFW 1055
			pxySD.setPxyMotor40Aft((not pxySD.motor40Aft));

		// ### MT ONLY PEN
		elseif _attribute = CM_SlotRequest.Attribute_Empty then // PAR 18682 CCMS SFW 1055
			pxySD.setPxyMTOnly((not pxySD.mtOnly));

		// ### POWER PEN
		elseif _attribute = CM_SlotRequest.Attribute_Power then // PAR 18682 CCMS SFW 1055
			pxySD.setPxyPower((not pxySD.power));

		// ### REEFER PEN
		elseif _attribute = CM_SlotRequest.Attribute_Reefer then // PAR 18682 CCMS SFW 1055
			pxySD.setPxyReefer((not pxySD.reefer));

		// ### WATERCOOLED PEN
		elseif _attribute = CM_SlotRequest.Attribute_Watercooled then // PAR 18682 CCMS SFW 1055
			pxySD.setPxyWatercooled((not pxySD.watercooled));

		// ### NOT AVAILABLE PEN
		elseif _attribute = CM_SlotRequest.Attribute_Unavailable then // PAR 18682 CCMS SFW 1055
			pxySD.setPxyUnavailable((not pxySD.unavailable));
		endif;
		
		app.myTrxUA.trxUpdateSlotDefn(pxySD, app.myPassport);
		
		if not isVesselDefn then // do not delete if calling from vessel defn
			delete pxySD;
		endif;
		trxUpdateOK := app.myPassport.trxCompletedOK;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	if not isVesselDefn then // do not delete if calling from vessel defn
		delete pxySD;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <access>protected</access>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_slotDefn" type="CM_SlotDefn" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBayHeight" id="fd3435f1-f381-499f-a062-2c5c10cddc14">
        <updating/>
