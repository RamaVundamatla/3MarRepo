    <JadeMethod name="assignValueSpecial" id="2173cbe2-a675-4b94-a8e6-785cdae988b1">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
//11 August 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
vars

begin
	if _propName = ETRow_AssignedCargoIds or _propName = CM_EDICargoGroupNotified::allPreAssignedCargoIds.name then
		self.CM_EDICargoGroupNotified.setAssignedCargoIdsFromString(_processedValue);
		return true;
	endif;
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxyCG" id="208f7133-4154-4770-b441-b3fd7061aaf1">
        <source>createProxyCG(  _pxyCgAssign : CM_CargoGroupAssignment input ):CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	pxyCargoGroup : CM_CargoGroup;
	cargoTypeObj : CM_CargoType;
	operatorObj : CM_Operator;
	trxOperCode : String;
	foundMatch : Boolean;

begin

	if self.cargoType &gt; 0 then
		cargoTypeObj := app.myRoot.getCargoTypeForID( self.cargoType );
	elseif self.cargoTypeDescr &lt;&gt; null then
		if self.cargoTypeDescr.isInteger then
			cargoTypeObj := app.myRoot.getCargoTypeForID( self.cargoTypeDescr.Integer );
		else
			cargoTypeObj := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
		endif;
	endif;
	if self.operatorCode &lt;&gt; null then
		operatorObj := app.myRoot.allOperators.getAtKey( self.operatorCode );
		if operatorObj = null then
			trxOperCode := app.myRoot.getXlationSystemCode( self.operatorCode, XLATION_TYPE_OPERATOR, foundMatch);
			if trxOperCode &lt;&gt; null then
				operatorObj := app.myRoot.allOperators.getAtKey( trxOperCode );
			endif;
		
		endif;
	endif;
	
/*	create pxyNotifyCargoGroup transient;
	pxyNotifyCargoGroup.setProxy(	self.id,	//_id : String;
									self.defaultLocation,	//_defaultLocation : String;
									self.remarks,	//_remarks : String;
									self.minWeight,	//_minWeight : Decimal;
									self.maxWeight,	//_maxWeight : Decimal;
									cargoTypeObj,	//_myCargoType : CM_CargoType;
									operatorObj,	//_myOperator : CM_Operator;
									self.allPreAssignedCargoIds,	//_allPreAssigned : StringArray;
									_pxyCgAssign	//_myCgAssign : CM_CargoGroupAssignment
									);
									
	return pxyNotifyCargoGroup; */
	
	//01 Oct 2018	NDL	TFS 39186
	pxyCargoGroup := _pxyCgAssign.createCargoGroupPxy(	self.id,	//_cargoGroupId : String;
														operatorObj,	//_oper : CM_Operator;
														cargoTypeObj,	//_cargoType : CM_CargoType;
														self.minWeight,	//_minWeight : Decimal;
														self.maxWeight,	//_maxWeight : Decimal;
														self.remarks,	//_remarks : String;
														self.defaultLocation,	//_defaultLocation : String;
														self.allPreAssignedCargoIds	//_allPreAssigned : StringArray
														);

	return pxyCargoGroup;
	
epilog

end;</source>
        <Parameter name="_pxyCgAssign" type="CM_CargoGroupAssignment" usage="input"/>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="204bad31-74b1-43af-a0c9-0d893fa50f1b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cType : CM_CargoType;
	str : String;
	retStr : String;
	
begin

	if _attrName = ETRow_CargoType then
		cType := app.myRoot.allCargoTypesById[self.cargoType];
		if cType = null then
			if self.cargoTypeDescr.isInteger then
				cType := app.myRoot.allCargoTypesById[self.cargoTypeDescr.Integer];
			else
				cType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
			endif;
		endif;
		if cType &lt;&gt; null then
			return cType.abbreviation;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_CargoTypeDescr then
		if self.cargoType &lt;&gt; null then
			cType := app.myRoot.allCargoTypesById[self.cargoType];
			if cType &lt;&gt; null then
				return cType.description;
			endif;
		elseif self.cargoTypeDescr &lt;&gt; null then
			if self.cargoTypeDescr.isInteger then
				cType := app.myRoot.allCargoTypesById[self.cargoTypeDescr.Integer];
			else
				cType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
			endif;
			if cType &lt;&gt; null then
				return cType.description;
			endif;
			return self.cargoTypeDescr;
		endif;
		return null;
		
	elseif _attrName = ETRow_AssignedCargoIds then
		foreach str in self.allPreAssignedCargoIds do
			if retStr &lt;&gt; null then
				retStr := retStr &amp; ",";
			endif;
			retStr := retStr &amp; str;
		endforeach;
		return retStr;
		
	elseif _attrName = ETRow_LocationId then
		return self.defaultLocation;
		
	elseif _attrName = ETRow_Remarks then	//21 Sep 2015	NDL	Par 36338
		return self.remarks;
		
	elseif _attrName = ETRow_AssignmentId then
		if self.myParent &lt;&gt; null then
			return self.myParent.id;
		endif;
		return null;
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
