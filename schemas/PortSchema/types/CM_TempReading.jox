    <JadeMethod name="getDisplayDetails" id="4f84ca2b-1708-4067-b59c-9a63ee68a418">
        <source>getDisplayDetails(_short: Boolean): String;

//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars

begin
	return self.systemToLocalTime(self.dateTime).String;
end;</source>
