    <JadeMethod name="getBOLVolumeForInvoice" id="6a3d00f2-e696-4dc5-8f4f-861e54750895">
        <source>getBOLVolumeForInvoice():Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	totalVolume	: Decimal[23,4];
	detail : CM_BOLDtl;

begin

	foreach detail in self.allBOLDtls do
		totalVolume := totalVolume + detail.volume;
