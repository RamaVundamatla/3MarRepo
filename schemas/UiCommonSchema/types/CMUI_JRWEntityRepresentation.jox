    </JadeMethod>
    <JadeMethod name="reportsOn" id="be77a10b-f301-405d-8676-02e4db809648">
        <source>reportsOn(_path : String) : Boolean;
// Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
// 16/11/2016 cnwrh7	TFS2934 Invoice Report and Line Report type error
vars
	result	: Boolean;
	pathLength	: Integer;
	queryPath	: String;
	featureColl	: MemberKeyDictionary;
	feature	: Object;
	invalidObject : Boolean;
	str : String;
begin
	on Exception do app.handleDeletedObject(exception, self.myJRDObject, invalidObject); 
	if _path = null then
		return false;
	endif;	
	if self.myJRDObject &lt;&gt; null then																										//-TFS2934
	//if self.myJRDObject &lt;&gt; null and app.isValidObject(self.myJRDObject) then					//+TFS2934
		str := self.myJRDObject.String;
		if invalidObject then
			return false;
		endif;
		pathLength := _path.length;
		featureColl := self.myJRDObject.getPropertyValue("allFeatures").MemberKeyDictionary;
		foreach feature in featureColl do
			queryPath := feature.getPropertyValue("queryPath").String;
			if queryPath.length &gt;= pathLength and
			   queryPath[1:pathLength] = _path then
				result := true;
				break;
			endif;
		endforeach;
	endif;

	return result;
end;
</source>
        <Parameter name="_path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
