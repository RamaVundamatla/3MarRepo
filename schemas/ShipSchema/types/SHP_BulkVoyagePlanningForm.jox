    <JadeMethod name="addToolbarControls" id="24588043-c24d-4b52-9dd4-54e1f452194e">
        <updating/>
        <source>addToolbarControls() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
// 19 May 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
//
vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	showCaptions := toolbar.showCaptions;

	toolbar.addButton(self.btnSelectVoyage, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnActual, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewImport, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewExport, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnViewOps, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewByWeight, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewByVolume, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnViewCargo, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewCommodity, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewShippingLine, CMUI_Toolbar.Control_Alignment_Left);	//19-may-2022 navtnr20 53204
	
	toolbar.addButton(self.btnViewConsignee, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewLoadPort, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewDischPort, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewISOGroup, CMUI_Toolbar.Control_Alignment_Left);
	if self.myTerminal.getConfig(ShipShowISOType).Boolean then
		self.btnViewISOGroup.bubbleHelp := "View by ISO Type";
	endif;
	toolbar.addButton(self.btnViewOperator, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewStatus, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewTemp, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewWeight, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnImportTasks, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCustomsEDI, CMUI_Toolbar.Control_Alignment_Left);
	if self.bAllowSummaryDefn then
		// always make this button visible but the enabling will depend on the display mode being used.
		toolbar.addButton(self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnCapacity,CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnFlipPS, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnClearSelected, CMUI_Toolbar.Control_Alignment_Left);

	//============================================================
	// Now setup the select voyage toolbar
	//============================================================
	toolbar := self.frmToolbarSelect;
	toolbar.showCaptions := showCaptions;
	
	toolbar.addButton(self.btnSelectVoyOK, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectVoyCan, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnActual_click" id="cf0ae9ac-9231-4c33-9fc8-171831826855">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnActual_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02 September 2015	cnwdap1		Initial creation PAR #
//
vars

begin
	if (not self.toolbarClickPreProcessing(VIEW_BAYVIEW)) then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	self.switchDisplayMode(ShpDisplayMode_Actual, true);
	
	tblGridAreaInfo.selectMode := Table.SelectMode_Default;

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCapacity_click" id="d5261933-8f02-409f-8af4-96948ee98416">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCapacity_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/09/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	self.myAssistant.SHP_Assistant.showKPIVoyageCapacityForm(self.myCurrentVoyage, self.myMasterMenuAction);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClearSelected_click" id="51a3fc0c-8258-4694-8596-080612007542">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClearSelected_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27 August 2015	cnwdap1		Initial creation PAR #
//
vars

begin
