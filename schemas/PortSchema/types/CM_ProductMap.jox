end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getImexServiceMap" id="cade92cb-b9e1-491f-b8a7-178e181bfea0">
        <source>getImexServiceMap(trackedItem : CM_TrackedItem) : CM_ImexServiceMap;

vars
	imexMap : CM_ImexServiceMap;

begin
	if trackedItem.isSOB then
		imexMap := self.allImExMaps[TI_TransitStatusSOB];
	elseif trackedItem.isRehandle then
		imexMap := self.allImExMaps[TI_TransitStatusDLR];
	else
		imexMap := self.allImExMaps[trackedItem.getImExStatus];
	endif;
	if imexMap = null then
		imexMap := self.allImExMaps[CM_ImexServiceMap.DEFAULT_IMEX_MAP];
	endif;

	return imexMap;

end;</source>
        <Parameter name="trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="CM_ImexServiceMap"/>
    </JadeMethod>
    <JadeMethod name="getImexServiceMapTran" id="e7ba1207-28d7-4a50-91f1-4ef7c2295e2d">
        <source>getImexServiceMapTran(_tran : CM_TITransaction) : CM_ImexServiceMap;
// ---------------------------------------------------------------------------
// Created:
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//Date			Who		Reason
//23 Oct 2024	navlw1 	JIRA-33107: Invoice Logging Use Levels
//25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
//
vars
	imex	: Integer;
	imexDesc	: String;
	imexMap : CM_ImexServiceMap;
	imexStatus	: CM_IMEXStatus;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if _tran.myTrackedItem &lt;&gt; null then
		if _tran.myTrackedItem.isSOB then
			imex := TI_TransitStatusSOB;
		elseif _tran.myTrackedItem.isRehandle then
			imex := TI_TransitStatusDLR;
		else
			imex := _tran.imExStatus;
		endif;
	else
		imex := _tran.imExStatus;
	endif;
	imexMap := self.allImExMaps[imex];
	if imexMap &lt;&gt; null and app.getLogger &lt;&gt; null then
		imexStatus := app.myRoot.allImexStatuses[imex];
		if imexStatus &lt;&gt; null then
			imexDesc := imexStatus.description;
		else
			imexDesc := "Unknown";
		endif;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("IMEX map found for " &amp; imexDesc, LogTRACE.String);
		endif;
	endif;
	if imexMap = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("IMEX map for DEFAULT", LogTRACE.String);
		endif;
		imexMap := self.allImExMaps[CM_ImexServiceMap.DEFAULT_IMEX_MAP];
	endif;

	return imexMap;

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <ReturnType type="CM_ImexServiceMap"/>
    </JadeMethod>
    <JadeMethod name="getPath" id="f568bf4a-9b5b-4e4e-b709-fb2db4df5548">
