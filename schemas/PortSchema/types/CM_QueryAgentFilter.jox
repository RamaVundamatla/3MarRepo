    <JadeMethod name="qryLocationActivity" id="fb0bab84-8bbb-4a35-9079-da038bf1fb12">
        <source>qryLocationActivity(_filter : CMQF_LocationActivity input; _passport : CM_Passport) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	jrwTrans : CM_JRWLocationActivity;
	numSelected : Integer;
	
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	jrwTrans := self.createJRWTransient(CM_JRWLocationActivity).CM_JRWLocationActivity;
	
	_filter.populateFromLocActivities( false );
	
	numSelected := _filter.allCMIFLocationThroughPutLines.size; 
	
	if not _filter.allCMIFLocationThroughPutLines.isEmpty then
		_filter.allCMIFLocationThroughPutLines.copy( jrwTrans.allThroughPutLines );
	endif;
	if not _filter.allCMIFLocationSummaryLines.isEmpty then
		_filter.allCMIFLocationSummaryLines.copy( jrwTrans.allThroughPutSummaryLines );
	endif;
	jrwTrans.reportingMonthYear := _filter.reportingMonth; 
	jrwTrans.startOfYearDate := _filter.startOfYearDate;
	jrwTrans.myCargoType := _filter.getMyCargoType.CM_CargoType;
	jrwTrans.myOperator := _filter.myOperator;
	
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_LocationActivity" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
