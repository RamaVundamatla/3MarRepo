    <JadeMethod name="getDisplayStringForAttribute" id="c7531869-a2ea-4746-b9ce-cf89b1874d51">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24/09/2012	cnwcs5	par 30390 - removed freightPayerCode, myTransferToTerminal, consignorVoyageCode, 
//									freightForwarderCode, voyageCode
// 02/08/2013	cnwcs5	  CCMS POL 2221 / par 32094(2)
// 22/01/2018   cnwma1    Bug 36725: Invalid Property errors in Satellite View
// 13/06/22 	jlier1	  TFS 53678
// 20/06/2022	navdap1	  TFS 53362 EUP Master Data interface customers between TOS and ERP
//19/07/2022	navtnr20  ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level		
//28 Oct 2022   navtnr20  ChangeRequest 54967: EUP - INB/OUT - Operational Instructions	
//16 Dec 2022   navsa20   BUG 55878: SNO - Error 4033 happens while trying to update a Release Request
// 21 Apr 2023  navhl20	  Bug 57694: MTN - WO - Release Request Summary details are missing
//11 May 2023	navhl20	  ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
//28 Aug 2023 	navhl20   ChangeRequest 55019: MTN - Show creation time/date for release requests
//27 Nov 2024	navhl20   CR MTN-33530: TPT - Road Gate Picker to Include Delivery Party
//18 Dec 2024 	navbs1	  Bug MTN-33650: CUX - Missing Additional Remarks pop up When Gated in Booking Item without reviewing cargo individually
//07 Jul 2025	naviv1	  MTN-35171 : MTN - Optimize Satellite View Screen to Handle Large Volumes of Failed Auto Plan Alerts Efficiently
//03 Nov 2025	jlizm1	  MTN 36255 Rotabox Assign Release To Vessel

vars
	iConsign	: CM_ConsigneeConsignor;
	request		: CM_Request;
begin
	// this set of ETRows are used in EDI Comparison
	if _attrName = ETRow_Ignore then
		return " ";
	elseif _attrName = ETRow_ReleaseRequestNumber or
		_attrName = ETRow_StatusBulkRelease or
		_attrName = ETRow_ConsignorCode or 
		_attrName = ETRow_VesselName or
		_attrName = ETRow_RemarksAdditional1 or	//29 Jan 2021	NDL	TFS 50723
		_attrName = ETRow_RemarksAdditional2 or	//29 Jan 2021	NDL	TFS 50723
		_attrName = ETRow_VoyageInward or
		_attrName = ETRow_PickerRelReqRemarks1 or			//18.12.2024 navbs1 #33650
		_attrName = ETRow_PickerRelReqRemarks2 then			//18.12.2024 navbs1 #33650
		return self.myReserveHeader.getDisplayStringForAttribute(_attrName, _short);
	endif;

	if _attrName = ETRow_DoISOGroupCheck or
	   _attrName = ETRow_DoISOGroupCheckStr or
	   _attrName = ETRow_IsoType or
	   _attrName = ETRow_Clean or
	   _attrName = ETRow_CleanString or
	   _attrName = ETRow_HeavyRated or
	   _attrName = ETRow_HeavyRatedString or 
	   _attrName = ETRow_Id or
	   _attrName = ETRow_PowerRequirements or
	   _attrName = ETRow_IsoTypeGroup or	// 24/11/2009 cnwar2 #21696
	   _attrName = ETRow_IdMask or
	   _attrName = ETRow_AllMTGrades or
	   //_attrName = ETRow_LineNumber or		//15-/07-2022 navtnr20 53974	//16.12.2022 navsa20 TFS 55878
		_attrName = ETRow_LineNumberHdr or  //16.12.2022 navsa20 TFS 55878 
	   _attrName = ETRow_CustomerReference or	//15-07-2022 navtnr20 53974
       _attrName = ETRow_PickerCargoRemarks1 or									//18.12.2024 navbs1 #33650
       _attrName = ETRow_PickerCargoRemarks2 or								//18.12.2024 navbs1 #33650
	   _attrName = ETRow_CargoTypeCodeForCntnt or
		_attrName = ETRow_CargoSubTypeCodeForCntnt then
		return null;//because they only apply to reserve details which should be handled in subclass
	// PAR 16242 from here
	elseif _attrName = ETRow_ReleaseNo then
		return self.getReleaseNumberDescr();
	
	elseif _attrName = ETRow_BillOfLading then
		return self.getBOLNumber;
		
	elseif _attrName = ETRow_Consignee then
		//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			iConsign := app.myRoot.allConsigneeConsignors[self.getConsigneeCode];
			if iConsign &lt;&gt; null then
				return iConsign.description;
			endif;
		endif;
		return self.getConsigneeCode();
	
	elseif _attrName = ETRow_QuantityRemaining then
		return self.getTotalOutstanding().asStringJMT(); //SFW1035
		
	elseif _attrName = ETRow_RequestsBeingActioned then
		request := self.getRequest();		//MTN-35171
		if self.myReserveHeader &lt;&gt; null and request &lt;&gt; null then		//SFW1035	//MTN-35171
			if self.myReserveHeader.allRequestsBeingActioned.includes(request) then	//MTN-35171
				return self.getTotalOutstandingDisplay; //epr par 34623 23/7/14
			endif;
		endif;
		return "0";

	//##### in the MT release requests form they can show the requests in the data table instead of the bulk release, so this switches it
	elseif _attrName = ETRow_ReleaseNo or
	 _attrName = ETRow_EstimatedRequiredDate or
	 _attrName = ETRow_CarrierCode or
	 _attrName = ETRow_LoadPort or
	 _attrName = ETRow_RequestDate or
	 _attrName = ETRow_Type or
	 _attrName = ETRow_AvailabilityGradeCode or
	 _attrName = ETRow_RailReference or	 
	 _attrName = ETRow_ReleaseByType or
	 _attrName = ETRow_PackLocation or
	 _attrName = ETRow_TotalPacked or
	 _attrName = ETRow_DeliveryReason or 
	 _attrName = ETRow_PackQuantity or
	 _attrName = ETRow_PackProduct or	 
	 _attrName = ETRow_VoyageArrival or
	 _attrName = ETRow_BookingConfirmation or
	 _attrName = ETRow_DeliveryReleaseNumber or
	 _attrName = ETRow_MyOperatorGroup or
	 _attrName = ETRow_MyOperator or
	 _attrName = ETRow_BusinessUnit or
	 _attrName = ETRow_DischargePort or
	 _attrName = ETRow_MyPinNo or
	 _attrName = ETRow_RequestsBeingActioned or
	 _attrName = ETRow_DeliveredToDate or
	 _attrName = ETRow_OperatorCode or
	 _attrName = ETRow_TrainAssignedID or 			// AKB2010FEB - 781 testing
	 _attrName = ETRow_Destination or 				// AKB2010FEB - 781 testing
	 _attrName = ETRow_MtRelease or					// 30/01/2012 cnwar2 #28957
	 _attrName = ETRow_MtReleaseStr or
	 _attrName = ETRow_ReleaseByType or				// 30/01/2012 cnwar2 #28957
	 _attrName = ETRow_ReleaseByTypeStr or			// 30/01/2012 cnwar2 #28957
	 _attrName = ETRow_NeedsReview or				// 30/01/2012 cnwar2 #28957
	 _attrName = ETRow_AllowCargoOnMultiRel or		// 30/01/2012 cnwar2 #28957
	 _attrName = ETRow_AllowCargoOnMultiRelStr or
	 _attrName = ETRow_AllowCargoMultiReleases or
	 _attrName = ETRow_FreightPayerCode or			// par 30390 Sept 2012
	 _attrName = ETRow_FreightForwarderCode or		// par 30390 Sept 2012
	 _attrName = ETRow_MyTransferToTerminal or		// par 30390 Sept 2012
	 _attrName = ETRow_VoyageCode or				// par 30390 Sept 2012
	 _attrName = ETRow_ConsignorVoyageCode or		// par 30390 Sept 2012
	 _attrName = ETRow_VehicleBookingSlots or	//25 Nov 2014	NDL	Par 35284
	 _attrName = ETRow_ExpiryDate or	//13 Feb 2017	NDL	TFS 3368
	 _attrName = ETRow_ExpiryTime or	//13 Feb 2017	NDL	TFS 3368
	 _attrName = ETRow_CanBeHiLoCube or   // 09/3/17 epr TFS 2606
	 _attrName = ETRow_DestinationPort or    // 22/01/2018   cnwma1 Bug 36725
	 _attrName = ETRow_PoolParty or          // 22/01/2018   cnwma1 Bug 36725
	 _attrName = ETRow_ExpiryTimeStamp      // 22/01/2018   cnwma1 Bug 36725
	 then
	 
		return self.myReserveHeader.getDisplayStringForAttribute(_attrName, _short);
	
	elseif _attrName = ETRow_CargoType or _attrName = ETRow_CargoTypeDescr then      //15.07.2024 navrv30 Bug 65073
		return self.getCargoTypeDescr();
	
	elseif _attrName = ETRow_QuantityRemaining then
		return null;
	
	elseif _attrName = ETRow_MyBookingRefItem then
		if self.myBookingRefItem = null then
			return null;
		else
			return self.myBookingRefItem.getShortDisplay();
		endif;

	elseif _attrName = ETRow_MyProduct then
		return self.getProductCode;
		
	elseif _attrName = ETRow_MySubTerminal then
		if self.myReserveHeader = null then
			return null;
		else
			if self.myReserveHeader.mySubTerminal = null then
				return null;
			else
				return self.myReserveHeader.mySubTerminal.code;
			endif;
		endif;
// cnwdad1 21/09/2009 - PAR #20708.
	elseif _attrName = ETRow_MyBookingRefStock then
		if self.myReserveHeader = null then
			return null;
		else
			if self.myReserveHeader.myBookingRefStock = null then
				return null;
			else
				return self.myReserveHeader.myBookingRefStock.bookingReference;
			endif;
		endif;
// cnwdad1 21/09/2009 - PAR #20708.
	elseif _attrName = ETRow_RequestedCountFromOps then
		if self.myReserveHeader = null then
			return null;
		else
			return self.myReserveHeader.numberWLECreated.asStringJMT();
		endif;
		
	//cnwjo3 par 24593
	elseif _attrName = ETRow_CustomsAgent then
		if self.myReserveHeader = null then
			return null;
		else
			return self.myReserveHeader.customsAgent;
		endif;
		
	//cnwjo3 par 24593	
	elseif _attrName = ETRow_CustomsAssistance or
		   _attrName = ETRow_CustomsAssistanceStr then
		if self.myReserveHeader = null then
			return null;
		else
			return self.myReserveHeader.customsAssistance.getYesNo();
		endif;
		
	//cnwjo3 par 24593	
	elseif _attrName = ETRow_InterTerminalRelease or
		   _attrName = ETRow_InterTerminalReleaseStr then
		if self.myReserveHeader = null then
			return null;
		else
			return self.myReserveHeader.isInterTerminalBulkRelease().asStringJMT();
		endif;		
		
	// 07/11/2011 cnwmh5 #28622
	elseif _attrName = ETRow_HiLowCube or
		   _attrName = ETRow_HiLowCubeStr then
		if self.myReserveHeader = null then
			return null;
		else
			return self.myReserveHeader.canBeHiLoCube.getYesNo();
		endif;
		
// TFS 2686	elseif _attrName = ETRow_RemoveStops or
// TFS 2686		   _attrName = ETRow_RemoveStopsStr then		// 08/10/2012 cnwar2 #30462
// TFS 2686		return self.getRemoveStops().getYesNo();
	elseif _attrName = ETRow_BlockEDIUpdates then	// 08/10/2012 cnwar2 #30462
		return self.myReserveHeader.blockEDIUpdates.getYesNo();
	elseif _attrName =ETRow_TotalQuantity then
		return self.totalRequested.asStringJMT;	
	elseif _attrName =ETRow_CargoSubType then					//21.4.2023 navhl20 #57694
		return self.getCargoSubType();
	elseif _attrName = ETRow_TotalRequested then //epr par 34406 25/6/14
		return self.getTotalRequestedDisplay;
	elseif _attrName = ETRow_StatusDesc then		// cnwmc5 - 19 Nov 2015 - PAR 37190
		return self.getStatusString();
	
	elseif _attrName = ETRow_SetStops then	//13 Sep 2016	NDL	TFS 2644 / 2001
		if self.myReserveDetailActions = null then
			return "-- Dbl Click to Add --";
		else
			return self.myReserveDetailActions.getStopsList(CrLf,false);	
		endif;
		
	elseif _attrName = ETRow_SetTasks then	//13 Sep 2016	NDL	TFS 2644 / 2001
		if self.myReserveDetailActions = null then
			return "-- Dbl Click to Add --";
		else
			return self.myReserveDetailActions.getTaskList(CrLf,false);	
		endif;
		
	elseif _attrName = ETRow_StopsToApply then	//16 Sep 2016	NDL	TFS 2644 / 2001
		if self.myReserveDetailActions = null then
			return null;
		else
			return self.myReserveDetailActions.getStopsList(CrLf,false);	
		endif;
		
	elseif _attrName = ETRow_TaskToApply then	//16 Sep 2016	NDL	TFS 2644 / 2001
		if self.myReserveDetailActions = null then
			return null;
		else
			return self.myReserveDetailActions.getTaskList(CrLf,false);	
		endif;
	
	elseif _attrName = ETRow_PickerType then	//15 Mar 2017	NDL	TFS 3758
		return 'Release';
		
	elseif _attrName = ETRow_Outstanding then	//15 Mar 2017	NDL	TFS 3758
		return self.getTotalOutstandingDisplay();
		
	elseif _attrName = ETRow_BeingActioned then	//15 Mar 2017	NDL	TFS 3758
		return self.getTotalActionedDisplay(null);
		
	elseif _attrName = ETRow_ItemId then	//15 Mar 2017	NDL	TFS 3758
		return self.myReserveHeader.code;
		
	elseif _attrName = ETRow_CargoId then	//15 Mar 2017	NDL	TFS 3758
		return null;
		
	elseif _attrName = ETRow_PickerDescription then	//15 Mar 2017	NDL	TFS 3758
		return self.getShortDescription();
		
	elseif _attrName = ETRow_Received or _attrName = ETRow_Prenoted then	//15 Mar 2017	NDL	TFS 3758
		return null;
		
	elseif _attrName = ETRow_Released then	//15 Mar 2017	NDL	TFS 3758
		return self.getTotalReleasedDisplay;
		
	elseif _attrName = ETRow_Operator then	//15 Mar 2017	NDL	TFS 3758
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
			return self.myReserveHeader.getOperatorDesc;			// TFS 53362
		else														// TFS 53362
			return self.myReserveHeader.getOperatorCode;
		endif;														// TFS 53362
		
	elseif _attrName = ETRow_Bol then	//15 Mar 2017	NDL	TFS 3758
		if self.myBOLIn &lt;&gt; null then
			return self.myBOLIn.number;
		endif;
		return null;
	elseif _attrName = ETRow_DeliveryParty then
		if self.myDeliveryParty &lt;&gt; null then
			return self.myDeliveryParty.code;
		endif;
		return null;
	elseif _attrName = ETRow_DeliveryAddress then
		if self.myDeliveryAddress &lt;&gt; null then
			return self.myDeliveryAddress.description;
		endif;
		return null;
	elseif _attrName = ETRow_DeliveryInstructions then
		return self.deliveryInstructions;
	elseif _attrName = ETRow_DeliveryFromDate then
		return self.deliveryFrom.date.asStringJMT;
	elseif _attrName = ETRow_DeliveryFromTime then
		return self.deliveryFrom.time.asStringJMT;
	elseif _attrName = ETRow_DeliveryToDate then
		return self.deliveryTo.date.asStringJMT;
	elseif _attrName = ETRow_DeliveryToTime then
		return self.deliveryTo.time.asStringJMT;
	elseif _attrName = ETRow_DefaultAnyAmount then
		return self.defaultAnyAmount.asStringJMT;
	elseif _attrName = ETRow_DeliveryAnyId then
		return self.defaultAnyId.asStringJMT;
	elseif _attrName = ETRow_ClientRef then
		return self.cargoMatchClientReference;
	elseif _attrName = ETRow_UndgCode then
		return self.cargoMatchUNDGcode;
	elseif _attrName = ETRow_OrderNumber then
		return self.cargoMatchOrderNumber;
	elseif _attrName = ETRow_PurchaseOrder then
		return self.cargoMatchPurchaseOrder;
	elseif _attrName = ETRow_ReceivedDate then
		return self.cargoMatchReceiveDate.date.asStringJMT;
	elseif _attrName = ETRow_ReceivedTime then
		return self.cargoMatchReceiveDate.time.asStringJMT;
	elseif _attrName = ETRow_ReleasedDT then
		return self.cargoMatchReleaseDate.date.asStringJMT;
	elseif _attrName = ETRow_ReleasedTime then
		return self.cargoMatchReleaseDate.time.asStringJMT;
	elseif _attrName = ETRow_Remark then
		return self.cargoMatchRemarks;
	elseif _attrName = ETRow_MyVessel then
		return self.cargoMatchVesselCode;
	// Start 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_InstructionInternal then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.internalInstructions.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionExternal then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.externalInstruction.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionCode then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionCode();
		endif;
		return null;
	elseif _attrName = ETRow_InstructionDesc then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionDesc();
		endif;
		return null;
	// End 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_PickerId then
		return null;
	elseif _attrName = ETRow_ExtraCriteria then				//11.5.2023 navhl20 #57402[57471]
		return null;
	elseif _attrName = ETRow_CreationDateTime then	
		return self.systemToLocalTime(self.createdTime).asStringJMT();		//29.8.2023 navhl20 #55019
	elseif _attrName = ETRow_LocnByOldestTransArrival then //15/02/2023	navkc1 CR 60078 Task 62448
		return self.locnByOldestTransportArrival.getYesNo();
	elseif _attrName = ETRow_DeliveryPartyName then							//27.11.2024 navhl20 #33530
		if self.myDeliveryParty &lt;&gt; null then
			return self.myDeliveryParty.name;
		endif;
		return null;
	endif;

	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
