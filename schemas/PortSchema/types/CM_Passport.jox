    <JadeMethod name="setMyTerminal" id="1f4db332-ef86-46ff-ba67-49e45b8317f2">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     05 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	

begin
	self.myTerminal := _terminal;
	if _terminal &lt;&gt; null then
		self.configDoIZeroFillSeqNum := not _terminal.getConfig(ShipRemoveLeadingZeros).Boolean;
	else
		self.configDoIZeroFillSeqNum := false;
	endif;
	
	if self.myStateChangeController &lt;&gt; null then  //jlier1 TFS 61676 14/12/23
		self.myStateChangeController.initializeMappings(self.myTerminal);
	endif;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setMyUser" id="3ab59b2a-0c25-4c21-b605-c80affa14c8f">
        <updating/>
        <source>setMyUser(_user : CM_User) updating;
// ---------------------------------------------------------------------------
// Created:     05 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	8 Aug 2022 	navhl20 	ChangeRequest 52513: MTN - Correctly Log User Codes in Log Files
//	24 Aug 2022	navmd1		TFS 54648 - Changed logfile created message to only be shown with the user is initially set
// ---------------------------------------------------------------------------
vars
	alertType 		: CM_SystemAlertType;
	eventType		: CM_EventType;
	userTerminal 	: CM_UserTerminal;
	terminal		: CM_Terminal;
	previousUser	: CM_User;
begin
	self.endNotificationForSubscriber(self);

	previousUser := self.myUser;
	self.myUser	:= _user;
	
	//Start 8.8.2022 navhl20 TFS 52513
	if previousUser = null and _user &lt;&gt; null then
		app.writeLog('Logfile created for user ' &amp; _user.code &amp; '.', LogINFO); 
	else
		if _user &lt;&gt; null then
			app.writeLog('Passport user changed to ' &amp; _user.code &amp; '.', LogTRACE);
		endif;
	endif;
	//End 8.8.2022 navhl20 TFS 52513
	
	if _user = null then
		self.myOrganisation	:= null;
		self.userCode := null;
	else
		self.userCode := _user.code;	
		self.myOrganisation	:= _user.myOrganisation;
		self.beginNotification(_user, EVENT_DAC_UPDATE, Response_Continuous, 0);
		
		if app.name = JMTerminal then
			foreach userTerminal in _user.allUserTerminals do
				terminal := userTerminal.myTerminal;
				//subscribe for system alerts types the user is interested in where the terminal in known
				foreach alertType in _user.allSystemAlertTypes do
					app.writeLog(_user.code &amp; " registering for alert " &amp; alertType.String &amp; " for terminal" &amp; terminal.code, null);
					self.beginNotification(terminal, alertType.type,Response_Continuous, 0);
				endforeach;
				//subscribe for event transactions of types the user is interested in where the terminal in known
				foreach eventType in _user.allEventTypes do
					app.writeLog(_user.code &amp; " registering for event type " &amp; eventType.name &amp; " for terminal" &amp; terminal.code, null);
					self.beginNotification(terminal, terminal.getTerminalEvent(EVENT_EVENT_TRANSACTION), Response_Continuous, 0);
				endforeach;
			endforeach;
			//subscribe for event transactions of types the user is interested in where the terminal is not known
			foreach eventType in _user.allEventTypes do
				app.writeLog(_user.code &amp; " registering for event type " &amp; eventType.name, null);
				self.beginNotification(eventType, EVENT_EVENT_TRANSACTION, Response_Continuous, 0);
			endforeach;
		endif;
	endif;
	
	self.setDataAccessControllers(_user);
	
end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setMyUserFromCode" id="6d14d729-f5c8-4bed-be24-c9e0d8195070">
