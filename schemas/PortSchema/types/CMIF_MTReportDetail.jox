<Class name="CMIF_MTReportDetail" id="3dcb6650-3afe-4001-b3ba-d857bc3dc7d9">
    <superclass name="CMIF_ReportExtraDetail"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="availabilityGrade" id="8341f2cd-0f39-4cda-935f-888fb6749b9f">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="isoCode" id="5e036906-93f1-41ff-8947-b3aa6f870861">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="operatorCode" id="3a42355b-f14d-4326-a6ef-ba4deacd2cb9">
        <length>7</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="requestCount" id="e21dbbba-2eac-4df3-b064-672ab7b4901e">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="matchesBR" id="b350facb-e836-48c2-b7c5-5bd8c50417b1">
        <source>matchesBR(_bulkRel: CM_BulkRelease; _requestsOutstanding: Integer output):Boolean;
//----------------------------------------------------------------
//	Created:	28 September 2004	by Jason Chapman  (cnwjc2)
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------
// 21/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
//----------------------------------------------------------------
vars
	matched : Boolean;
	reserveDetail : CM_ReserveDetail;
begin 
	
	if _bulkRel.status &lt;&gt; BR_ACTIVE then
		return false;
	endif;
	
	if _bulkRel.myOperator.code.trimBlanks &lt;&gt; self.operatorCode then
		return false;
	endif;
	
	foreach reserveDetail in _bulkRel.allReserveDetails do
		if reserveDetail.getISOTypeCode() = self.isoCode then
			matched := true;
			_requestsOutstanding := _requestsOutstanding + reserveDetail.getTotalOutstanding();
		endif;
	endforeach;
		
	return matched;
	
epilog

end;</source>
        <Parameter name="_bulkRel" type="CM_BulkRelease"/>
        <Parameter name="_requestsOutstanding" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
