    <JadeMethod name="getOutgoingVoyageStatus" id="ef7775ab-3315-4f21-86b8-cac470994e12">
        <source>getOutgoingVoyageStatus( _voyage: CM_Voyage ): CM_VoyageStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	currentStatus : Integer;
	voyStatus : CM_VoyageStatus;
	shiftStatuses : IntegerArray;
begin

	if _voyage &lt;&gt; null then
		currentStatus := _voyage.status;
	endif;
	create shiftStatuses transient;
	self.getShiftStatuses(shiftStatuses);
	if currentStatus = Voyage_Status_IAppPendIPN then
		voyStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IVoyageApproved );
	elseif shiftStatuses.includes( Voyage_Status_IShiftPendIPN) then
		voyStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IShiftAppIPN );
	endif;

	return voyStatus;

epilog
	delete shiftStatuses;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_VoyageStatus"/>
    </JadeMethod>
    <JadeMethod name="getShiftStatuses" id="95fbb5e8-2b3f-4192-89ea-dafd7848e4ec">
        <source>getShiftStatuses(_statuses : IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2018	jlger1	Initial creation

*/

vars
	pelindo1VoyProcess : CM_VoyageProcess;
	voyStatus,
	endStatus,
	startStatus : CM_VoyageStatus;
	iter : Iterator;
begin

	//Any with Priority less than the Priority of Voyage_Status_IVoyageArrived 
	endStatus 	:= app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IShiftPendIPN );
	startStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IShiftReqApp );
	if startStatus &lt;&gt; null then
		pelindo1VoyProcess := startStatus.myProcess;
		iter:=pelindo1VoyProcess.allStatuses.createIterator;
		pelindo1VoyProcess.allStatuses.startKeyGeq(startStatus.priority,iter);
		while iter.next(voyStatus) do
			_statuses.add(voyStatus.id);
			if voyStatus = endStatus then
				break;
			endif;
			
		endwhile;
		
	endif;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_statuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getValidCurrentStatuses" id="46915dea-e849-405a-a55a-b830ae2ae673">
        <source>getValidCurrentStatuses(_validStatuses: IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin
	_validStatuses.add( Voyage_Status_IAppPendIPN );
	self.getShiftStatuses(_validStatuses);
	//_validStatuses.add( Voyage_Status_IShiftPendIPN );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_validStatuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMessage" id="318965ec-ff61-4d59-9367-8d291eb9ac27">
        <source>processMessage( voyage : CM_Voyage io );
/*

Purpose:			

Parameters:		
"	This is the INAPORTNET Web Service allowing for the INAPORTNET Voyage Approval to be recorded in JMT.
"	Voyage must be able to be identified by PKK number.
"	Voyage must be at the "Approval Pending" status, otherwise the request will be rejected.
"	Update if everything is OK is to move the Voyage on to the "Voyage Approved" status.
	

Return Value:		

Date		Who		Reason
23/04/2018	jlgndl1	Initial creation	TFS 38135
14/02/2019	jlgdap1	TFS 43307 PEL1 INAP - SPOG message changes the berth
*/

vars

	shiftStatuses : IntegerArray;
	workOrderDtl : CM_WorkOrderVoyageDtl;
	movement 	 : HMS_VoyageMovement;
	arrivalMovement : HMS_VoyageMovement;			// TFS 43307
	arrivalBerth : HMS_Berth;						// TFS 43307
begin
	create shiftStatuses transient;
	self.getShiftStatuses(shiftStatuses);
	
	if shiftStatuses.includes(voyage.status) then
		//need to find last shift pending work order if one if there is one and approve work order
		workOrderDtl:=voyage.findWorkOrderDtlNotApproved(WO_TASK_SHIFTMOVEMENT);
		if workOrderDtl &lt;&gt; null then
			app.myTrxUA.trxUpdateWorkOrderPPK(workOrderDtl,null,true,app.myPassport);
			//epr TFS 43849 3/4/19
			movement:=workOrderDtl.CM_WodShiftMovement.myHMSVoyageMovement;
		endif;
		if movement = null then
			movement:=voyage.getLastMovementShift();
		endif;
	else
		movement:=voyage.getMovementArrival;
	endif;
	arrivalMovement := voyage.getMovementArrival;										// TFS 43307
	arrivalBerth := arrivalMovement.getMyBerth;											// TFS 43307
	app.writeLog(method.qualifiedName &amp; Space &amp; "arrivalMovement is " &amp; arrivalMovement.moveType &amp; Space &amp; arrivalMovement.occursOnDTNEW.asStringJMT &amp; ", arrivalBerth is " &amp; arrivalBerth.code, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	//epr TFS 40847 14/9/18
	app.myTrxUA.trxUpdateInaportnetSPOG(movement,self.nomorSpog,app.myPassport);
	self.doUpdateVoyageStatus(voyage);
	// TFS 43307 If the change of status above resulted in the arrival movement's 		// TFS 43307
	// berth changing, change it back again												// TFS 43307
	if arrivalMovement.getMyBerth &lt;&gt; arrivalBerth then									// TFS 43307
		app.myTrxUA.trxUpdateBerthSPOG(arrivalMovement, arrivalBerth, app.myPassport);	// TFS 43307
	endif;																				// TFS 43307
epilog

	delete shiftStatuses;

end;</source>
        <Parameter name="voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyageUpdate" id="cb0994f9-061e-46cb-88e6-19cfd482dfdf">
        <source>validateForVoyageUpdate( _voyage : CM_Voyage output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	term : CM_Terminal;

begin
	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	term := app.myPassport.myTerminal;
	
	_voyage := term.allVoyagesByExternalCode.getAtKey( self.nomorPkk);
	if _voyage = null then
		app.raiseCMException3(Value_field_not_resolve, self.nomorPkk, WS_EntrySPOGRequest::nomorPkk.name, app.getErrorString(Voyage), null, null);
		return false;
	endif;

	self.validateVoyageStatusForMsg( _voyage );

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMandFieldsPresent" id="973abc4f-1b53-4d6f-9d9d-721fd48a2314">
        <source>validateMandFieldsPresent():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	
	//1. self.user - Checked in superClass ::validareCredentials
	
	//2. self.password - Checked in superClass ::validareCredentials
	
	//3. Number of PKK (voyage notification), Mandatory
	if self.nomorPkk = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntrySPOGRequest::nomorPkk.name, null, null);
	endif;
	
	//4. Number of Ppkb (request for vessel service), Mandatory
	if self.nomorPpkb = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntrySPOGRequest::nomorPpkb.name, null, null);
	endif;
	
	//5. Number of SPK Pilot (work order), Mandatory
	if self.nomorSpk = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntrySPOGRequest::nomorSpk.name, null, null);
	endif;
	
	//6. Nomor SPOG (confirmation n from authority), Mandatory
	if self.nomorSpog = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntrySPOGRequest::nomorSpog.name, null, null);
	endif;
	
	//7 Port Code - Checked in superClass ::validareCredentials

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
