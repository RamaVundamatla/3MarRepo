    <JadeMethod name="getDisplay" id="0e0ca0e9-f347-4e6d-8549-9b739bdfddac">
        <source>getDisplay(dataObj : Object) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/08/2008	cnwdw1
12/07/2011  cnwmh5  27772 - Add operator
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
*/
vars
	operator	: CM_Operator;
begin
	
	operator :=  dataObj.CM_Product.myOperator ;
	
	if operator &lt;&gt; null then
		return dataObj.CM_Product.code &amp; " - " &amp; operator.code;
	else
		return dataObj.CM_Product.code;
	endif;

end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="08203eeb-3215-4592-a45d-82c98d5f9444">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	tmpTerminal		: CM_Terminal;
	tmpCargoType	: CM_CargoType;
	tmpCargoBOLType	: CM_CargoBOLType;
	product: CM_Product;
begin
	tmpTerminal := app.getMyTerminalDO_NOT_USE();
	if tmpTerminal = null then
		foreach tmpCargoType in app.myRoot.allCargoTypesById do
			foreach product in tmpCargoType.allProducts do
				//epr TFS 1846 19/4/16
				if product.isNotActive then
					continue;
				endif;
				//epr TFS 1822 28/4/16 
				objects[product.getYAIdentifier()] := product;
			endforeach;
		endforeach;
	else
		foreach tmpCargoBOLType in tmpTerminal.allCargoBOLTypes where
				tmpCargoBOLType.isCargoType() do
			foreach product in tmpCargoBOLType.CM_CargoType.allProducts do
				//epr TFS 1846 19/4/16
				if product.isNotActive then
					continue;
				endif;
				//epr TFS 1822 28/4/16 
				objects[product.getYAIdentifier()] := product;
			endforeach;
		endforeach;
	endif;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
