    <JadeMethod name="getDisplayFieldData" id="cb67752b-56f0-4abe-8b11-b639ec769cef">
        <updating/>
        <source>getDisplayFieldData(windowName:String; fieldName:String; fieldValue:String io) updating;
	// Given a WindowName, and FieldName, we retrieve the data from the field

vars
	_p1 : String;
	_p2 : String;

begin

	_p1 := windowName;
	_p2 := fieldName;


	_jadeActiveXInvokeio('GetDisplayFieldData', 1, '0.24,1.8,1.8,3.16392', _p1, _p2, fieldValue);

end;
</source>
        <Parameter name="windowName" type="String"/>
        <Parameter name="fieldName" type="String"/>
        <Parameter name="fieldValue" type="String" usage="io"/>
    </JadeMethod>
