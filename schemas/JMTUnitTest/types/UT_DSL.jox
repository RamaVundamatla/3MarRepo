    <JadeMethod name="updateCommodity" id="be1b2e9d-ee88-409a-b9b3-ccf06109188e">
        <source>updateCommodity(_commodity : CM_Commodity);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwmd1	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
05/08/2011	cnwmh5	Change to use UT_UnitTest's opts
25/03/2015	cnwdap1	PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
*/

vars
	proxyCommodity : CM_Commodity;
	passport : CM_Passport;
	maxTemp, minTemp : Decimal[12,2];
	reqsPackDetails, reqsPower : Boolean;
begin
	passport	:= app.myPassport;
	
	beginLoad;
	proxyCommodity	:= _commodity.pxyCreateUpdateProxy();
	endLoad;
	
	if self.opts.includesKey(ETRow_MaxTemp) then
		maxTemp	:= self.opts.int( ETRow_MaxTemp ).Decimal;
	else
		maxTemp := _commodity.maxTemp;
	endif;
	if self.opts.includesKey(ETRow_MinTemp) then
		minTemp	:= self.opts.int( ETRow_MinTemp ).Decimal;
	else
		minTemp := _commodity.minTemp;
	endif;
	
	reqsPackDetails := self.opts.bool( ETRow_RequiresPackInfo);
	reqsPower := self.opts.bool( ETRow_RequiresPower);
	
	proxyCommodity.setProxy(_commodity.code,
							_commodity.description,
							_commodity.shortDescription,
							_commodity.bayplanPrintAs,
							_commodity.hasTemp,
							reqsPower,
							reqsPackDetails,
							_commodity.isNotAvailableForEntry,
							_commodity.isEmpty,
							_commodity.colour,
							maxTemp,
							minTemp,
							_commodity.myCommodityGroup,
							_commodity.mySpecialStow,
							_commodity.isUsedForPacking,					// PAR #35895
							_commodity.allCargoTypes,
							_commodity.requiresWeighing	//05 Jul 2019	NDL	TF# 44965
							);
							
	app.myTrxUA.trxUpdateCommodity( proxyCommodity, passport );
	self.assertTrueMsg( passport.trxCompletedOK(), passport.getAllErrorsWarningsAsString() );
	
epilog

	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete proxyCommodity;

end;</source>
        <Parameter name="_commodity" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="updateCommodityGroup" id="a850e1d9-e5cc-45c7-9737-1592e9ebdde7">
        <source>updateCommodityGroup(_commodityGroup : CM_CommodityGroup);
/*

Purpose:		Update Commodity Group	

Date		Who		Reason
20/02/2014	cnwma1	Initial creation

*/

vars
	pxyCommodityGroup : CM_CommodityGroup;
	commDesc		  : String;
	commodities       : CM_CommodityByCodeDict;
	commoditySet	  : ObjectArray;

begin
	
	create commoditySet transient;
	create commodities transient;
	
	beginLoad;
	pxyCommodityGroup := _commodityGroup.pxyCreateUpdateProxy();
	endLoad;
	
	commDesc := _commodityGroup.description.asStringJMT();
	
	if self.opts.includesKey("ComDesc") then
		commDesc := self.opts.str("ComDesc");
		_commodityGroup.allCommodities.copy(commodities);
		commodities.add(app.myRoot.allCommodities["CHBF"]);

	endif;
	
	pxyCommodityGroup.setProxy(_commodityGroup.code,
							 commDesc,
							 5,
							 true,
							 50,
							 60,
							 commodities,
							 true,
							 true);
							 
	app.myTrxUA.trxUpdateCommodityGroup(pxyCommodityGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete pxyCommodityGroup;
	delete commoditySet;
	delete commodities;
	
end;</source>
        <Parameter name="_commodityGroup" type="CM_CommodityGroup"/>
    </JadeMethod>
    <JadeMethod name="updateConsigneeConsignor" id="de5c252a-db89-447b-975b-f770daec641c">
        <source>updateConsigneeConsignor(
	_consigneeConsignor	: CM_ConsigneeConsignor io);


/*
Date				Who		Reason
23 February 2010	cnwrl1	Initial creation as part of PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
05/08/2011			cnwmh5	Change to use UT_UnitTest's opts
19/08/2013			cnwjre1	Add address maintenance
25/03/2015			cnwdap1	PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
03 Aug 2017			cnwma1	TFS #5209:PEN - Release Request Stop
*/
	
vars
	address1	: String;
	address2	: String;
	address3	: String;
	postCode	: String;
	region		: String;
	countryCode	: String;
	addressDetailsEntered	: Boolean;
	consignGroup			: CM_ConsigneeConsignorGroup;
	debtor					: CM_Debtor;
	proxyConsigneeConsignor	: CM_ConsigneeConsignor;
	proxyAddress			: CM_Address;
	passport				: CM_Passport;

begin
	passport	:= app.myPassport;
	
	beginLoad;
	proxyConsigneeConsignor	:= _consigneeConsignor.pxyCreateUpdateProxy();
	endLoad;
	
	if self.opts.str( ETRow_ConsignGroupStr ) &lt;&gt; null then
		consignGroup	:= app.myRoot.allConsignGroups[ self.opts.str( ETRow_ConsignGroupStr ) ];
	elseif _consigneeConsignor.myConsignGroup &lt;&gt; null then
		consignGroup	:= _consigneeConsignor.myConsignGroup;
	endif;
	
	if self.opts.str( ETRow_DebtorStr ) &lt;&gt; null then
		debtor	:= app.myRoot.myRootCompany.debtors[ self.opts.str( ETRow_DebtorStr ) ];
	elseif _consigneeConsignor.debtor &lt;&gt; null then
		debtor	:= _consigneeConsignor.debtor;
	endif;
	
	// 31448 maintain address
	proxyAddress := proxyConsigneeConsignor.myAddress;
	if self.opts.str( ETRow_AddressLine1 ) &lt;&gt; null then
		address1 := self.opts.str( ETRow_AddressLine1 );
	elseif proxyAddress &lt;&gt; null then
		address1 := proxyAddress.addr1;
	endif;
	if self.opts.str( ETRow_AddressLine2 ) &lt;&gt; null then
		address2 := self.opts.str( ETRow_AddressLine2 );
	elseif proxyAddress &lt;&gt; null then
		address2 := proxyAddress.addr2;
	endif;
	if self.opts.str( ETRow_AddressLine3 ) &lt;&gt; null then
		address3 := self.opts.str( ETRow_AddressLine3 );
	elseif proxyAddress &lt;&gt; null then
		address3 := proxyAddress.addr3;
	endif;
	if self.opts.str( ETRow_AddressPostCode ) &lt;&gt; null then
		postCode := self.opts.str( ETRow_AddressPostCode );
	elseif proxyAddress &lt;&gt; null then
		postCode := proxyAddress.postCode;
	endif;
	if self.opts.str( ETRow_AddressRegion ) &lt;&gt; null then
		region := self.opts.str( ETRow_AddressRegion );
	elseif proxyAddress &lt;&gt; null then
		region := proxyAddress.region;
	endif;
	if self.opts.str( ETRow_AddressCountry ) &lt;&gt; null then
		countryCode := self.opts.str( ETRow_AddressCountry );
	elseif proxyAddress &lt;&gt; null then
		countryCode := proxyAddress.countryCode;
	endif;

	if address1 &lt;&gt; null or
	   address2 &lt;&gt; null or
	   address3 &lt;&gt; null or
	   postCode &lt;&gt; null or
	   region &lt;&gt; null or
	   countryCode &lt;&gt; null then
		addressDetailsEntered := true;
	endif;
	// don't create a CM_Address if not already one and no address details entered
	if proxyAddress = null and
	   addressDetailsEntered then
		create proxyAddress transient;
	endif;
	if proxyAddress &lt;&gt; null then
		proxyAddress.update(address1, address2, address3, postCode, region, countryCode);
	endif;
	
	proxyConsigneeConsignor.setMyAddress(proxyAddress);
	proxyConsigneeConsignor.setProxy(	_consigneeConsignor.code,
										_consigneeConsignor.description,
										self.opts.bool( ETRow_IsNotAvailableForEntry ),
										_consigneeConsignor.secureExportPartner,
										_consigneeConsignor.derogationNumber,
										_consigneeConsignor.emailAddress,
										_consigneeConsignor.colour,
										_consigneeConsignor.order,	// order is always zero!
										consignGroup,
										debtor,
										_consigneeConsignor.showOOWRemarks,
										_consigneeConsignor.isConsignee,
										_consigneeConsignor.isConsignor,
										_consigneeConsignor.isFreightFwdr,
										_consigneeConsignor.allPINNotifyEmailAddresses,
										null,	//cnwmc5 - 19/12/2012 - HAT 2198
										null,	//cnwmc5 - 19/12/2012 - HAT 2198
										false,		// PAR #35895
										false,
										false);// 2.8.2017 cnwma1 TFS #5209
	app.myTrxUA.trxUpdateConsigneeConsignor( proxyConsigneeConsignor, passport );
	self.assertTrueMsg( passport.trxCompletedOK(), passport.getAllErrorsWarningsAsString() );
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete proxyConsigneeConsignor;
	
end;
</source>
        <Parameter name="_consigneeConsignor" type="CM_ConsigneeConsignor" usage="io"/>
    </JadeMethod>
