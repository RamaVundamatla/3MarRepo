    <JadeMethod name="sendFaultEmail" id="61a2a7ef-e876-4925-89cf-03116b9cdad3">
        <source>sendFaultEmail();
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	message : String;
begin
	if app.myPassport.hasErrors then
		return;
	endif;
	//epr par 15680 21/1/2008
	// i don't want a problem with the email being sent to stop the fault being created
	app.setContinueCMExceptions(true);
	if self.myFaultType &lt;&gt; null then
		if self.myFaultType.emailRecipient = null then
			return;
		endif;
		message:="Fault reported by " &amp; self.myReportedByUser.userName &amp; " at " &amp; self.reportedTS.asStringJMT &amp; "."  &amp; CrLf
					&amp;  "Machine is "  &amp; self.myMachine.getDisplayDetails(false) &amp; "." &amp; CrLf  
					&amp;	"Fault Type is " &amp; self.myFaultType.description &amp; ".";
		if self.myFaultResponse &lt;&gt; null and self.myFaultResponse.myFaultQuestion &lt;&gt; null then
			message:= message &amp; CrLf &amp; "Fault Question was "  &amp; self.myFaultResponse.myFaultQuestion.description;
		endif;
		if self.additionalDetails &lt;&gt; null then
			message:=message &amp; CrLf &amp; "Additional Details are " &amp; self.additionalDetails;
		endif;
		app.myUtilityCA.utlCreateEmailSendRequest(	true,
													"Fault Email",
													self.myFaultType.emailRecipient,
													app.myRoot.getConfig(AutoSendersEmailAddress).String,
													self.myFaultType.emailRecipientCC,
													self.myFaultType.emailRecipientBCC,
													self.myFaultType.emailSubject,
													message, //message make something up
													null,
													null,
													null,
													null,
													null,
													null,
													app.myPassport);
														
														
	endif;
	
	
	// there has been errors or warnings from the email sending. We don't want the 
	// faults or responses to stop being created so clear the errors
	if app.myPassport.hasErrors then
		app.myPassport.clearErrorsWarnings;
	endif;
epilog
	app.setContinueCMExceptions(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="76664b97-63d6-40f8-abb7-5e70eb2e7bc1">
        <updating/>
        <source>setForCreate(	_pxyFault : CM_Fault;
				_terminal : CM_Terminal ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	
	self.setForUpdate(_pxyFault);
	self.myTerminal:=_terminal;
	self.sendFaultEmail;
epilog

end;</source>
        <Parameter name="_pxyFault" type="CM_Fault"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7b49036e-0e3f-4c4c-8188-bfee433a5bc7">
        <updating/>
        <source>setForUpdate(_pxyFault : CM_Fault) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	sendEmail : Boolean;
begin
	self.reportedTS:=_pxyFault.reportedTS;
	self.resolutionDetails:=_pxyFault.resolutionDetails;
	if self.additionalDetails &lt;&gt; _pxyFault.additionalDetails then
		self.additionalDetails:=_pxyFault.additionalDetails;
		sendEmail:=true;
	endif;
	self.myEnteredByUser:=_pxyFault.myEnteredByUser;
	self.myReportedByUser:=_pxyFault.myReportedByUser;
	self.myMachine:=_pxyFault.myMachine;
	self.myFaultType:=_pxyFault.myFaultType;
	self.myFaultStatus:=_pxyFault.myFaultStatus;
	
	if sendEmail then
		self.sendFaultEmail;
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyFault" type="CM_Fault"/>
    </JadeMethod>
    <JadeMethod name="setFromFaultResponse" id="15f366ce-fb2e-4cfd-805a-ab9ff1fcc90e">
        <updating/>
        <source>setFromFaultResponse(_faultResponse : CM_FaultResponse input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	self.myReportedByUser:=_faultResponse.myReportedByUser;
	self.myEnteredByUser:=_faultResponse.myReportedByUser;
	self.reportedTS:=_faultResponse.reportedTS;
	self.myFaultType:=_faultResponse.myFaultQuestion.myFaultType;
	self.myMachine:=_faultResponse.myMachine;
	self.myTerminal:=_faultResponse.myTerminal;
	self.myFaultStatus:=app.myRoot.getDefaultFaultStatus;
	self.myFaultResponse:=_faultResponse;
	
	
	//epr 15680 22/1/2008 send the note when the transaction commits
	self.causeEvent(myTerminal.getTerminalEvent(Event_Fault_Add),false,self);
	

	self.sendFaultEmail;
	
	
	
epilog

end;</source>
        <Parameter name="_faultResponse" type="CM_FaultResponse" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="53645aa1-ffdf-42a5-80b2-4abefeafc478">
        <updating/>
        <source>setProxy(	_reportedTS : TimeStamp;
			_reportedBy : CM_User;
			_enteredBy : CM_User;
			_machine : CM_Machine;
			_faultType : CM_FaultType;
			_faultStatus : CM_FaultStatus;
			_additionalDetails : String;
			_resolutionDetails : String;
			_faultResponse : CM_FaultResponse) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.reportedTS:=_reportedTS;
	self.myReportedByUser:=_reportedBy;
	self.myEnteredByUser:=_enteredBy;
	self.myFaultType:=_faultType;
	self.myFaultStatus:=_faultStatus;
	self.myMachine:=_machine;
	self.myFaultResponse:=_faultResponse;
	self.additionalDetails:=_additionalDetails;
	self.resolutionDetails:=_resolutionDetails;
	
	

epilog

end;</source>
        <Parameter name="_reportedTS" type="TimeStamp"/>
        <Parameter name="_reportedBy" type="CM_User"/>
        <Parameter name="_enteredBy" type="CM_User"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_faultType" type="CM_FaultType"/>
        <Parameter name="_faultStatus" type="CM_FaultStatus"/>
        <Parameter name="_additionalDetails" type="String"/>
        <Parameter name="_resolutionDetails" type="String"/>
        <Parameter name="_faultResponse" type="CM_FaultResponse"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="a9104cd3-8f86-4420-a080-998adc4f3fec">
        <source>validateForCreate();
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.validateForUpdate;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a6ec9843-c8e3-4de1-bddb-3adcf481d9c0">
        <source>validateForUpdate();
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myMachine = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'Machine',null,null);
		app.raiseCMException(Input_required_field_machine,null,null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.reportedTS = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Reported Date/Time', null, null);
		app.raiseCMException(Input_required_field_rptDteTme, null, null); // cnwdb2	PAR 35364


		return;
	endif;
	
	if not self.reportedTS.isValid then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Reported Date/Time',null,null);
		app.raiseCMException(Input_required_field_rptDteTme,null,null);
		return;
	endif;
	
	if self.myFaultType = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'Fault Type',null,null);
		app.raiseCMException(Input_required_field_faultType,null,null); // cnwdb2	PAR 35364


		return;
	endif;
	
	if self.myFaultStatus = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Fault Status', null,null);
		app.raiseCMException(Input_required_field_faultStat, null,null); // cnwdb2	PAR 35364


	endif;
	
	if self.myReportedByUser = null then
//		app.raiseCMException1(REQUIRED_FIELD,'Reported by User',null,null);
		app.raiseCMException(Input_required_field_rprtByUsr,null,null);
	endif;
	
	if self.myEnteredByUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'Entered by User',null,null);
		app.raiseCMException(Input_required_field_entByUser,null,null); // cnwdb2	PAR 35364
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
