    <JadeMethod name="maCargoAlloc" id="9bab017d-a452-48d9-abc1-d28b99ba0636">
        <source>maCargoAlloc();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2024		navma1	Initial creation

*/

vars
	trans 		  : CM_TranMapCargoAllocation;
	serviceBroker : CM_CargoAllocServiceBroker;
	lFile      		: File;
begin
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\"  &amp;"transMap.log";
    lFile.open;
	
	trans := "11958.3306".asOid.CM_TranMapCargoAllocation;
	
	if trans &lt;&gt; null then
		
		foreach serviceBroker in trans.allCargoAllocServiceBrokers do
			
			if serviceBroker.myChildQuantityMap = null then
				lFile.writeLine(serviceBroker.getOidString &amp; Tab &amp; serviceBroker.description);
			endif;
		endforeach;
	endif;
	
	lFile.close();
epilog
	delete lFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="maCheckActualTimeServer" id="b1c8273f-9961-41ea-b358-d155fe4101a0">
        <source>maCheckActualTimeServer();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2024		navma1	Initial creation

*/

vars
    oldWay : Boolean;
    dts,dte : Decimal[19];
    s,t,u,v : String;
    i,j,reps : Integer;
begin
    write CrLf &amp; "Starting...";
    reps := 10000;  // adjust this to get a run length of 1 to 10 seconds
    oldWay := false;
    dts := app.relativeMachineTime;
    foreach i in 1 to reps do
        if oldWay then
            s := app.actualTimeServer.String;
        else
            s := app.actualTimeAppServer.String;
        endif;
    endforeach;
    dte := app.relativeMachineTime;
    write "&lt;" &amp; s &amp; "&gt;" &amp; "&lt;" &amp; t &amp; "&gt;";  // to verify the functional results
    write ((dte-dts)/reps).roundedTo(6).String &amp; " ms/rep";
epilog
    write "Finished";
end;</source>
    </JadeMethod>
    <JadeMethod name="maCheckDuration" id="95d56b39-3915-4e2b-8844-c8f5949f5db9">
        <source>maCheckDuration();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2024		navma1	Initial creation

*/

vars
	t1,t2 		: TimeStamp;
	i1,i2       : Integer;
begin

	t1 := null;
	t2 := t2.addDays(-1);
	
	i1 := t1.cnSecondsDifference(t2);
	i2 := t1.getDifferenceInSeconds(t2).rounded;

	write i1.String;
	write i2.String;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="maCheckExtraData1" id="c8b7d94c-f66f-4acb-a7e4-2976cd745c11">
        <source>maCheckExtraData1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2022		navma1	Initial creation

*/

vars
	data : CM_EDIData;
	opr  : CM_Operator;
	xlationOperatorCode  : String;
	terminal : CM_Terminal;
	cargoTypeStr : String;
	lFile   	: File;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\MA\ediData- " &amp; app.actualTimeServer.getNumeralString() &amp; ".csv";
    lFile.open;
	
	
	/*
	lFile.writeLine("Terminal"  &amp; ","  &amp;  
					"DateTime"  &amp; ","  &amp;  
					"ClassName" &amp; ","  &amp;  
					"Oid" 		&amp; ","  &amp; 
					"Operator"  &amp; ","  &amp; 
					"CargoType");
	
	foreach terminal in CM_Terminal.instances discreteLock do 
		foreach data in terminal.myEdiConfig.ediDatas do
			if data.allExtraData.isEmpty then
				continue;
			endif;
			global.getExtraData(data.allExtraData, ETRow_XlateOperatorCode, xlationOperatorCode);
			global.getExtraData(data.allExtraData, ETRow_CargoTypes, 		cargoTypeStr);
			
			lFile.writeLine( terminal.code				  &amp; "," &amp; 
							data.createdTime.asStringJMT  &amp; ","  &amp; 
							data.getNiceClassName 		  &amp; ","  &amp; 
							data.getOidAsString			  &amp; "," &amp; 
							xlationOperatorCode 		  &amp; "," &amp; 
							cargoTypeStr);
		endforeach;
	endforeach;
	*/
	lFile.writeLine("Terminal"  &amp; ","  &amp;  
					"ediDatas"  &amp; ","  &amp;  
					"allEDIDataNotFullyProcessed" &amp; ","  &amp;  
					"allEDIDatasByDateStatus" 		&amp; ","  &amp; 
					"allEDIDatasByStatusDate"  &amp; ","  &amp; 
					"allEDIDatasByTypeNumber");
					
	foreach terminal in CM_Terminal.instances discreteLock do 
	
		
		lFile.writeLine( terminal.code				  		 		 						   &amp; "," &amp; 
						terminal.myEdiConfig.ediDatas.size.String  							  &amp; ","  &amp; 
						terminal.myEdiConfig.allEDIDataNotFullyProcessed.size.String 		  &amp; ","  &amp; 
						terminal.myEdiConfig.allEDIDatasByDateStatus.size.String			  &amp; ","  &amp; 
						terminal.myEdiConfig.allEDIDatasByStatusDate.size.String			  &amp; ","  &amp; 
						terminal.myEdiConfig.allEDIDatasByTypeNumber.size.String			  );

	endforeach;

	lFile.close;
epilog
	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="maCheckExtraData2" id="01dbd848-430f-46a6-b5a7-7708d2e3060a">
        <source>maCheckExtraData2();
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
18 November 2022		navma1	Initial creation

*/
vars
	data : CM_EDIData;
	opr  : CM_Operator;
	xlationOperatorCode  : String;
	terminal : CM_Terminal;
	cargoTypeStr : String;
	lFile   	: File;
	ediTI : CM_EDITrackedItem ;
	poNo ,
	serviceOrderNo,
	vehicle,
	salesOrderNo,
	destinationTerminal,
	transhipVesselName,
	voyageCode,
	alternativeId,
	clintRef,
	lISOTypeDesc,
	customAgent,
	billOfLading,
	tiCargoDesc,
	defaultId,
	commodity			: Any;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\MA\ediTIData- DMAST" &amp; app.actualTimeServer.getNumeralString() &amp; ".csv";
    lFile.open;
	lFile.writeLine("Terminal"  				&amp; ","  &amp;  
					"DateTime"  				&amp; ","  &amp;  
					"ClassName" 				&amp; ","  &amp;  
					"Oid" 						&amp; ","  &amp; 
					"PoNo"						&amp; ","  &amp; 
					"service OrderNo"			&amp; ","  &amp; 
					"vehicle"					&amp; ","  &amp;
					"salesOrderNo"				&amp; ","  &amp;
					"destinationTerminal"		&amp; ","  &amp;
					"transhipVesselName"		&amp; ","  &amp;
					"clintRef"					&amp; ","  &amp;
					"alternativeId"				&amp; ","  &amp;
					"lISOTypeDesc"				&amp; ","  &amp;
					"commodity"					&amp; ","  &amp; 
					"voyageCode"				&amp; ","  &amp; 
					"customAgent"				&amp; ","  &amp; 
					"billOfLading"				&amp; ","  &amp; 
					"tiCargoDesc"				&amp; ","  &amp; 
					"defaultId"				);
					
	foreach terminal in CM_Terminal.instances discreteLock do 
		foreach data in terminal.myEdiConfig.allEDIDatasByTypeNumber do
			foreach  ediTI in data.allEDITrackedItems discreteLock do
				if ediTI.getAllExtraData.isEmpty then
					continue;
				endif;
				
				global.getExtraData(ediTI.getAllExtraData,  CM_BOL::clientRef2.name, poNo);
				global.getExtraData(ediTI.getAllExtraData,  CM_BOL::clientRef1.name, serviceOrderNo);
				global.getExtraData(ediTI.getAllExtraData,  CM_BOL::vehicle.name, vehicle);
				global.getExtraData(ediTI.getAllExtraData,  ETRow_SalesOrderNbr, salesOrderNo);
				global.getExtraData(ediTI.getAllExtraData,  CM_EDIPackTI::destinationTerminal.name, destinationTerminal);
				global.getExtraData(ediTI.getAllExtraData,  CM_EDILoadListTI::transhipVesselName.name, transhipVesselName);
				global.getExtraData(ediTI.getAllExtraData,  ClientRef, clintRef);
				global.getExtraData(ediTI.getAllExtraData,  CM_EDIPrenoteTI::alternativeId.name, alternativeId);
				global.getExtraData(ediTI.getAllExtraData,  ETRow_IsoTypeDesc, lISOTypeDesc);
				global.getExtraData(ediTI.getAllExtraData,  ETRow_Commodity, commodity);
				global.getExtraData(ediTI.getAllExtraData,  ETRow_VoyageCode, voyageCode);
				global.getExtraData(ediTI.getAllExtraData,  CM_TrackedItem::myCustomsAgent.name, customAgent);
				global.getExtraData(ediTI.getAllExtraData,  CM_TrackedItem::billOfLading.name, billOfLading);
				global.getExtraData(ediTI.getAllExtraData,  CM_TrackedItem::description.name, tiCargoDesc);
				global.getExtraData(ediTI.getAllExtraData, "DefaultId", defaultId);
				
				
				lFile.writeLine( terminal.code				  &amp; "," &amp; 
								data.createdTime.asStringJMT  &amp; "," &amp; 
								data.getNiceClassName 		  &amp; "," &amp; 
								data.getOidAsString			  &amp; "," &amp; 
								poNo.String	  	  			  &amp; "," &amp;
								serviceOrderNo.String	  	  &amp; "," &amp;
								vehicle.String	  		 	  &amp; "," &amp;
								salesOrderNo.String	  		  &amp; "," &amp;
								destinationTerminal.String	  &amp; "," &amp;
								transhipVesselName.String	  &amp; "," &amp;
								clintRef.String	  	  		  &amp; "," &amp;
								alternativeId.String	  	  &amp; "," &amp;
								lISOTypeDesc.String		  	  &amp; "," &amp; 
								commodity.String		  	  &amp; "," &amp; 
								voyageCode.String 		   	  &amp; "," &amp; 
								customAgent.String 		   	  &amp; "," &amp; 
								billOfLading.String 		  &amp; "," &amp; 
								tiCargoDesc.String 			  &amp; "," &amp;
								defaultId.String
							);
				
			endforeach;
		endforeach;
	endforeach;


	lFile.close;
epilog
	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="maDurationFn" id="70046ba6-2f3f-4a31-9033-deb7c9342dd6">
        <source>maDurationFn();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2024		navma1	Initial creation

*/

vars
	from,toTs : TimeStamp;
	secondDiff    , 
	i,
	secondDiff2   : Integer;
begin

	// Integer Ranage -2,147,483,648 through 2,147,483,647   
	from := null;
	toTs.setDate('14/12/2024'.asDate);
	toTs.setTime('00:00:00.0'.Time);

	secondDiff := from.cnSecondsDifference(toTs);
	
	write  'secondDiff  := ' &amp;secondDiff.String;

end;</source>
    </JadeMethod>
    <JadeMethod name="maEncMethod" id="a843334c-8364-4c80-9a42-8649a46a72fb">
        <source>maEncMethod();

vars
	cls		 : Class;
	meth 	 : Method;
	methSet  : MethodSet;
	schema	 : Schema;
	clasCol  : ClassColl;
	src 	 : String;
	superClass : String;
begin

	//PortSchema
	schema  := rootSchema.getSchema('UiCommonSchema');
	
	create clasCol transient;
	
	clasCol := schema.getAllClasses(true);
	
	foreach cls in  clasCol do 
		if cls.schema.name ='CardSchema' then
			continue;
		endif;
		superClass := null ;
		superClass := cls.getSuperclass.name;
		
		if superClass = 'RootSchemaGlobal' or
			superClass = 'RootSchema' or
			superClass ='TcpIpConnection'  or 
			superClass ='CnInternet'  or  
			superClass ='CnTcpConnection' or 
			superClass ='CardSchema'    or 
			superClass ='FileNode'    or 
			superClass ='Type'    or 
			superClass ='Form'  or 
			superClass ='Window'		then
			continue;
		endif;
		
		if cls.name = 'Process' then
			continue;
		endif;
		
		if cls.name = 'CardSchema' then
			continue;
		endif;
		
		if cls.name = 'RootSchema' then
			continue;
		endif;
		
		if cls.name = 'JadeScript' then
			continue;
		endif;
		
		if cls.name = 'CnInternet' then
			continue;
		endif;
		
		delete methSet;
		create methSet  transient;
		
		
		cls.allMethods(methSet);
		
		foreach meth in methSet do
			src := "";
			
			src := meth.getSource;
			/*
			if meth.name ="getForm" then
				write src;
			endif;*/
			if   src.cnContains('begin')  then
				write   cls.name &amp; Tab &amp; meth.name  ;
			endif;

		endforeach;
	endforeach;
epilog
	delete methSet;
	delete clasCol;
end;</source>
    </JadeMethod>
    <JadeMethod name="maGetMapMethodForClass" id="bdf4375d-15b3-495d-935c-76cd4b9cc622">
        <source>maGetMapMethodForClass();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2025		navma1	Initial creation

*/

vars
	cls		 : Class;
	meth 	 : Method;
	methSet  : MethodSet;
	schema	 : Schema;
begin
	create methSet  transient;
	cls := Function;
	cls.allMethods(methSet);
	
	foreach meth in methSet do
		//if not meth.getSource().cnContains('*** Source not available ***') then
			write  meth.cnGetSourceLine(0) &amp; Tab &amp; meth.name  ;
		//endif;
		
	endforeach;
epilog
	delete methSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="maLnx" id="589e5f48-1102-49a8-a97e-0ae5c8c0efb5">
        <source>maLnx();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2025		navma1	Initial creation

*/

vars
	term 			: CM_Terminal;
	lFile      		: File;
	voyage			: CM_Voyage;
begin

	create lFile transient;
	lFile.fileName := "C:\temp\LNXVoyage.csv";
	lFile.open;
	
	lFile.writeLine('Terminal'    &amp; Tab&amp;
					'Voyage Code' &amp; Tab&amp;
					'ATA'		  &amp; Tab&amp; 
					'ATD' 		  &amp; Tab&amp;
					'Voyage Status' &amp; Tab&amp;
					'OnShip ' &amp; Tab&amp;
					'Onsite ' &amp; Tab&amp;
					'Prenote ' &amp; Tab&amp;
					'Offsite ' );
					
	foreach term in app.myRoot.allTerminals discreteLock do
		foreach voyage in term.allVoyagesByDepartDTCode discreteLock do
				lFile.writeLine(term.code &amp; Tab&amp;
				voyage.code &amp; Tab&amp;
				voyage.arrivedDT.shortCurrentLocaleFormat() &amp; Tab&amp;
				voyage.departedDT.shortCurrentLocaleFormat() &amp; Tab&amp;
				voyage.statusDescription &amp; Tab&amp;
				voyage.allOnshipTIsByCargoTypeId.size.String &amp; Tab&amp;
				voyage.allOnsiteTIsByCargoTypeId.size.String &amp; Tab&amp;
				voyage.allBulkReleases.size.String &amp; Tab&amp;
				voyage.allOffsiteTIsByCargoTypeId.size.String &amp; Tab&amp;
				voyage.allNotifiedTIsByCargoTypeId.size.String );			
		endforeach;
	endforeach;
	
epilog
	 lFile.close;
	 delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="maProfileGetTasks" id="eda2d71b-f46f-4bbf-ad42-c743c3aa1d3a">
        <source>maProfileGetTasks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2024		navma1	Initial creation

*/

vars
	machine 	: CM_Machine;
	str     	: String;
	allTasks 	: CM_RTQueueTaskArray; 
	prof     	: JadeProfiler;
	folder   	: String;
	machineCode : String;
	term		: CM_Terminal;
begin
	app.initialize();
	
	term := app.myRoot.allTerminals['MA'];
	
	foreach machine in term.machines do
		app.setMyTerminal(term);
	
		if machine = null then
			continue;
		endif;
		machineCode 		:= machine.code;
		folder 				:= global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   				:= process.profiler;	
		prof.methodCount	:= 30;
		prof.fileName 		:= folder&amp;"\MA" &amp; '\'  &amp; machineCode &amp;' ' &amp; app.actualTimeServer.getNumeralString() &amp; ".log";
		
		prof.clearMethodCache();
		prof.start;
			
		create allTasks transient;
		str := machine.getTasksAsJSON(allTasks);
		
		delete allTasks;
		if prof &lt;&gt; null then
			prof.report;
		endif;
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="maReleaeRequestCheck" id="53bc02d2-5857-43e6-89d1-72da1100908d">
        <source>maReleaeRequestCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2024		navma1	Initial creation

*/

vars
	term	 : CM_Terminal;
	rel		 : CM_BulkRelease;
	cnt		 : Integer;
begin
	term := app.myRoot.allTerminals['UT'];
	//foreach term in app.myRoot.allTerminals discreteLock do
		cnt := 0;
		foreach rel in term.allBulkReleasesByCodeDate discreteLock do 
			if  rel.allReserveDetails.isEmpty  then
				cnt := cnt +1;
				write rel.code;
			endif;
			
		endforeach;
		write term.code &amp; Tab &amp;  app.actualTimeServer.String   &amp;  '   cnt :=' &amp; cnt.String;
	//endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="maReleaeRequestDelete" id="7743c50a-69b1-4764-8cc4-7bdc750b700b">
        <source>maReleaeRequestDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2024		navma1	Initial creation

*/

vars
	term	 : CM_Terminal;
	rel		 : CM_BulkRelease;
	cnt		 : Integer;
begin
	term := app.myRoot.allTerminals['UT'];
	
	beginTransaction;
	
	foreach rel in term.allBulkReleasesByCodeDate discreteLock do 
		if rel.allReserveDetails.isEmpty then
			cnt := cnt +1;
			delete rel;
			if cnt = 10000 then
				commitTransaction;
				break;
			endif;
		endif;
		
	endforeach;
	
	write app.actualTimeServer.String   &amp;  '   cnt :=' &amp; cnt.String;
epilog

end;</source>
    </JadeMethod>
