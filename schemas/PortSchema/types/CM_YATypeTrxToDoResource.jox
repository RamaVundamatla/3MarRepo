<Class name="CM_YATypeTrxToDoResource" id="205d45fb-732f-450c-bb26-be7d93d56804">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="ca461ea7-a180-4446-8acb-cd4375921d00">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2024	jlier1	Initial creation 63834

*/

vars
	obj : Object;
	toDoTask : CM_ToDoTaskDesc;
	resource : Object;
begin
	
	if _allDependentObjs &lt;&gt; null 
	and _allDependentObjs.size &lt;&gt; 0 then
		foreach obj in _allDependentObjs do
			if obj.isKindOf(CM_TransactionType) then
				foreach toDoTask in obj.CM_TransactionType.allToDoTaskDesc do
					foreach resource in toDoTask.allResourceTypes do	
						if resource.isKindOf(CM_ResourceType) then
							_allCriteriaValues.tryAdd(resource);
						endif;
					endforeach;
				endforeach;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="1a0c5694-b0ee-4e56-b0d5-7c0fc49bb12b">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2024	jlier1	Initial creation 63834

*/

vars

begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);

epilog

end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDependentObjects" id="31679fa2-1603-4b1b-a353-7c54efd4f386">
        <source>getDependentObjects(_objs: CM_ObjectArray input; _value: Any; _type: CM_YACriteriaType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2024	jlier1	Initial creation 63834

*/

vars
	strArr			: StringArray;
	str				: String;
	obj				: Object;
	trxType 		: CM_TransactionType;
	todo 			: CM_ToDoTaskDesc;
begin
	
	create strArr transient;	
	_value.String.getTokensForDelimiter(',', strArr);
	
	if _type.isKindOf(CM_YATypeTransactionType) then
		
		foreach str in strArr do
			trxType:=app.myRoot.allTransactionTypesByDesc[str];
			if trxType &lt;&gt; null and trxType.hasToDoResourcesConfigured then	
				_objs.tryAdd(trxType);							
			endif;
		
		
		endforeach;
	endif;
epilog
	delete strArr;
end;</source>
        <Parameter name="_objs" type="CM_ObjectArray" usage="input"/>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_type" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="getDependentTypes" id="667cbc0d-b342-4d78-9d58-54c5fba46a5f">
