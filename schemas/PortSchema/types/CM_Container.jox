    <JadeMethod name="setStopsForExport" id="98ae45bc-5c30-40af-b79e-baecb30271db">
        <updating/>
        <source>setStopsForExport() updating;
//
// cnwrs1 May 2007 PAR13378 Stops
//
vars

begin
/*  // cnwrd1 par 22903 29.3.2010 removed  inapropriate to check this here,  term config not set no export stops are applied!
	if self.isEmpty or self.contentsStatus = TI_CONTENTS_STATUS_NULL then
		//Check to see if stop applies to Empties
		if (not self.myTerminal.getConfig(CedoAppliesToEmpties).Boolean) then
			//No stop required
			return;
		endif;
	endif;
	*/
	//Must apply to empties, carry on.
	inheritMethod();
end;
</source>
