    <JadeMethod name="extractNumber" id="5888e509-4942-4560-963f-f598c7aca743">
        <source>extractNumber(_value: String): Real;
//----------------------------------------------------------------
//	Created:	19 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	input		: String;
	strLen,
	int,
	numLen		: Integer;
	char		: String;	
begin
	
	input := _value;
	strLen := input.length;

	if strLen &lt; 1 then
		return null;
	endif;
	
	//find the first number in the string and return it
	foreach int in 1 to strLen do
		char := input[int:1];
		if char.isReal 
		or char = '-'
		or char = '+' then
			//test for bogus +/-
			if (not char.isReal)
			and (not input[int:2].isReal) then
				//we got a + or - but it's not in front of a number so...
				continue;
			endif;
			
			//found a number - return as many characters as possible while still being a number

			numLen := 1;
			while true do
				numLen  := numLen + 1;

				if (not input[int:numLen].isReal) then
					return input[int:numLen-1].Real;
				endif;
				if (int + numLen) &gt;= (strLen+1) then
					return input[int:numLen].Real;
				endif;
			endwhile;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="fullOrMTVerify" id="b2a06751-42af-468a-ba82-5694acb4b86a">
