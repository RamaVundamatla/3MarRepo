    <JadeMethod name="isReleaseByType" id="4e102a67-fd40-4389-8c4e-97c2a0e2c523">
        <source>isReleaseByType(_entTable : CM_EntryTable): Boolean;
//--------------------------------------------------------------
//Created: 17 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpRow		: Integer;
	entTable	: CM_EntryTable;
begin
	entTable := _entTable;
	tmpRow := entTable.getRow(ETRow_ReleaseByType);
	if tmpRow &gt; 0 then
		return entTable.getValue(tmpRow).Boolean;
	endif;
	return false;
	
end;</source>
        <Parameter name="_entTable" type="CM_EntryTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mainExtraCellInputReady" id="8cb02f88-5d9c-43d2-932e-3286a9cf6091">
        <updating/>
        <source>mainExtraCellInputReady(table: CM_EntryTable ;
						inputControl: Control input;
						cleft,
						ctop,
						cwidth,
						cheight,
						saveRowHeight : Real io;
						pGetControlMethod : String) updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------
// 15/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 20/05/2013	cnwdap1		PAR #31574 Allowable time off power editing
// ---------------------------------------------------------------------------
vars
	tbl				: CM_EntryTable;
	cmb				: ComboBox;
	voyageCombo		: ComboBox;
	lstTable		: CMUI_ListTable;
	tmpVoyage		: CM_Voyage;
	theText			: String;
	theControlName	: String;
	tmpOperator		: CM_Operator;
	imexStatusObj	: CM_IMEXStatus;
	imexStatus		: Integer;
	commodityObj	: CM_Commodity;
	commodCode		: String;
	terminalObj		: CM_Terminal;
	cargoTypeObj	: CM_CargoBOLType;
	subTerminaType	: Integer;
	isContainer		: Boolean;
	tmpCombo		: ComboBox;
	
begin
	theControlName 	:= inputControl.name;
	theText			:= table.text;

	// For comboboxes select the text
	if inputControl.isKindOf(ComboBox) then
		if inputControl.isKindOf(CMUI_ComboBox) then
			inputControl.CMUI_ComboBox.selectAllText();
		else
			self.selectAllComboText(inputControl.ComboBox);
		endif;
	endif;
	
	if theControlName = GTE_InOutForm::cmbHdlCntr1.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryHdlCntr1(cmb.listObject.CM_HandlingContractor1);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;

	elseif theControlName = GTE_InOutForm::cmbHdlCntr2.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryHdlCntr2(cmb.listObject.CM_HandlingContractor2);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
	elseif theControlName = GTE_InOutForm::cmbHdlSubCntr1.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryHdlSubCntr1(cmb.listObject.CM_HandlingSubContractor1);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;

	elseif theControlName = GTE_InOutForm::cmbISOType.name then
		cmb := inputControl.ComboBox;
		if theText &lt;&gt; null then
			if cmb.listObject &lt;&gt; null then
				if cmb.listObject.CM_ISOType.code &lt;&gt; theText then
					cmb.listObject := null;
				endif;
			endif;
			if cmb.listObject = null then
				cmb.listObject := app.myRoot.allISOTypes[theText];
				cmb.text := self.displayEntryISOType(cmb.listObject.CM_ISOType);
			endif;
		else
			cmb.listObject := null;
			cmb.text := null;
		endif;
	
/*	elseif theControlName = GTE_InOutForm::cmbBRItem.name then
		cmb := inputControl.ComboBox;
		if theText &lt;&gt; null then
			if cmb.listObject &lt;&gt; null then
				if cmb.listObject.CM_BookingRefItem.getShortDisplay &lt;&gt; theText then
					cmb.listObject := null;
				endif;
			endif;
			if cmb.listObject = null then
				br := 
				cmb.listObject := app.myRoot.[theText];
				cmb.text := self.displayEntryISOType(cmb.listObject.CM_ISOType);
			endif;
			
		else
			cmb.listObject := null;
			cmb.text := null;
		endif;*/
	elseif theControlName = GTE_InOutForm::cmbLogLength.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryLogLength(cmb.listObject.CM_LogLength);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
				
	elseif theControlName = GTE_InOutForm::cmbLogGrade.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryLogGrade(cmb.listObject.CM_LogGrade);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
		
	elseif theControlName = GTE_InOutForm::cmbLogType.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryLogType(cmb.listObject.CM_LogType);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
		
	elseif theControlName = GTE_InOutForm::cmbLogSpecies.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryLogSpecies(cmb.listObject.CM_LogSpecies);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;	
		
	elseif theControlName = GTE_InOutForm::cmbDocketError.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryLogDocketError(cmb.listObject.CM_DocketErrorType);//ccms 1110 			
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;	

	elseif theControlName = GTE_InOutForm::cmbMTGrade.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryMTGrade(cmb.listObject.CM_MTGrade);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;

	elseif theControlName = GTE_InOutForm::cmbOperator.name then
		cmb := inputControl.ComboBox;

		if theText &lt;&gt; null then
			if cmb.listObject &lt;&gt; null then
				if cmb.listObject.CM_Operator.code &lt;&gt; theText then
					cmb.listObject := null;
				endif;
			endif;
			if cmb.listObject = null then
				tmpOperator := app.myRoot.allOperators[theText];
				if tmpOperator &lt;&gt; null then
					 if cmb.findObject(tmpOperator) &gt; 0 then
						cmb.listObject := tmpOperator;
						cmb.text := self.displayEntryOperator(cmb.listObject.CM_Operator);
					endif;
				endif;
			endif;
		else
			cmb.listObject := null;
			cmb.text := null;
		endif;
	elseif theControlName = GTE_InOutForm::cmbScaler.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryUserForTerminal(cmb.listObject.CM_UserTerminal);
			//cmb.text := self.displayEntryUser(cmb.listObject.CM_User);//par 13954
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;								
	elseif theControlName = GTE_InOutForm::cmbSrcLocn.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntrySrcLocn(cmb.listObject.CM_SourceLocation);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;						
	elseif theControlName = GTE_InOutForm::cmbSrcSubLocn.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntrySrcSubLocn(cmb.listObject.CM_SourceSubLocation);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;						
	elseif theControlName = GTE_InOutForm::cmbSrcSubSubLocn.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntrySrcSubSubLocn(cmb.listObject.CM_SourceSubSubLocation);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
	elseif theControlName = GTE_InOutForm::cmbStockOrder.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryStockOrderHeader(cmb.listObject.CM_StockOrderHeader);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
	elseif theControlName = GTE_InOutForm::cmbSupplier.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryOperator(cmb.listObject.CM_Operator);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;									
	elseif theControlName = GTE_InOutForm::cmbLogLocation.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryLogLocation(cmb.listObject.CM_LogController);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
		
	elseif theControlName = GTE_InOutForm::cmbLogOperation.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
		//	cmb.text := self.displayEntryLogLocation(cmb.listObject.CM_LogController);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
	elseif theControlName = GTE_InOutForm::cmbRowArea.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryRowArea(self.myTerminal, cmb.listObject.CM_WarehouseRowController);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
	elseif theControlName = GTE_InOutForm::cmbTerminal.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryTerminal(cmb.listObject.CM_Terminal);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;								
						
	elseif theControlName = GTE_InOutForm::cmbTermArea.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryTerminalArea(self.myTerminal, cmb.listObject.CM_TerminalArea);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;								

	elseif theControlName = GTE_InOutForm::cmbTreatment.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryLogTreatment(cmb.listObject.CM_LogTreatment);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
								
	elseif theControlName = GTE_InOutForm::lstDischarge.name then
		tbl := table;
		self.listTableCellInputReady(tbl, cheight, saveRowHeight);

		lstTable	:= inputControl.CMUI_ListTable;
		voyageCombo	:= table.form.sendMsgWithParams(pGetControlMethod, 'cmbVoyage').ComboBox;
		tmpVoyage 	:= voyageCombo.listObject.CM_Voyage;
		self.listTableDischarge(lstTable, tmpVoyage, null);

	elseif theControlName = GTE_InOutForm::lstHazardList.name then
		tbl := table;
		self.listTableCellInputReady(tbl, cheight, saveRowHeight);
		//inputControl.CMUI_HazardsListTable.adjustColumns();
	elseif theControlName = GTE_InOutForm::lstMTGrade.name then
		tbl := table;
		self.listTableCellInputReady(tbl, cheight, saveRowHeight);

//	elseif theControlName = GTE_InOutForm.Cntrl_txtFellDate then
//		inputControl.GTE_DateBox2.text := table.text;

//	elseif theControlName = GTE_InOutForm::txtPackTime' then
//		if theText = null then
//			inputControl.CMUI_TimeEntry.time := NULL_TIME_STR.Time;
//		else
//			inputControl.CMUI_TimeEntry.time := theText.Time;
//		endif;

	elseif theControlName = GTE_InOutForm::txtQuantity.name then
		inputControl.TextBox.text := theText;
	elseif theControlName = GTE_InOutForm::txtDPCount.name then
		inputControl.TextBox.text := theText;
	elseif theControlName = GTE_PreNoteForm::lstStops.name then
		tbl :=table;
		self.listTableCellInputReady(tbl, cheight, saveRowHeight);
	elseif theControlName = GTE_PreNoteForm::lstToDo.name then
		tbl :=table;
		self.listTableCellInputReady(tbl, cheight, saveRowHeight);
	elseif theControlName = GTE_InOutForm::txtTimeOffPower.name then	// PAR #31574
		inputControl.TextBox.text := theText;							// PAR #31574
	//cnwmc5 - 2 April 2014 - CCMS 1127
	elseif theControlName = GTE_InOutForm::cmbLoggingOrg.name then
		cmb := inputControl.ComboBox;
		if cmb.listObject &lt;&gt; null then
			cmb.text := self.displayEntryLoggingOrg(cmb.listObject.CM_LoggingOrganisation);
		else
			if theText &lt;&gt; null then
				cmb.text := theText;
			endif;
		endif;
	endif;
	
	if inputControl.isKindOf(CMUI_MeasurementTable) then				// PAR #31155
		app.doMeasureTableCellInputReady(table, inputControl);			// PAR #31155
	endif;																// PAR #31155
end;</source>
        <Parameter name="table" type="CM_EntryTable"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
        <Parameter name="saveRowHeight" type="Real" usage="io"/>
        <Parameter name="pGetControlMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="mainExtraSetPowerReq" id="abe65238-8888-474b-b66d-2198c61766dc">
        <source>mainExtraSetPowerReq(pTblMain, pTblExtra : CM_EntryTable io; pNeedCOU, pNeedGenerator : Boolean);
// ---------------------------------------------------------------------------
// Created:     16 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pNeedCOU and pNeedGenerator then
		self.mainExtraSetValue(pTblMain, pTblExtra, ETRow_PowerRequirements, POWER_BOTH);
	elseif pNeedCOU then
		self.mainExtraSetValue(pTblMain, pTblExtra, ETRow_PowerRequirements, POWER_COU);
	elseif pNeedGenerator then
		self.mainExtraSetValue(pTblMain, pTblExtra, ETRow_PowerRequirements, POWER_GEN);
	else
		self.mainExtraSetValue(pTblMain, pTblExtra, ETRow_PowerRequirements, POWER_NONE);
	endif;

end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="io"/>
        <Parameter name="pNeedCOU" type="Boolean"/>
        <Parameter name="pNeedGenerator" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="receival_InitTblExtra" id="e4ed5292-e3d8-4ae8-be77-fae6b385042b">
        <source>receival_InitTblExtra(pTable : CM_EntryTable input; pIsBookingRef : Boolean);
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	row : Integer;
	
begin
//	self.comboBoxTempC(pTable, 'carriageTempC');
//	self.comboBoxTempF(pTable, 'carriageTempF');
	self.comboBoxCompany(pTable, ETRow_CompanyCode);
	if not pIsBookingRef then
		self.comboBoxCOUType(pTable, ETRow_CouType);
		self.comboBoxCoolingType(pTable, ETRow_CoolingType, null);
		self.comboBoxVoltageType(pTable, ETRow_VoltageType, null);		
//		self.comboBoxTempC(pTable, 'packTempC');
//		self.comboBoxTempF(pTable, 'packTempF');
		pTable.setValueByName(ETRow_PackDate, self.systemToLocalTime(app.actualTimeServer).date);// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support


		pTable.setValueByName(ETRow_AddAttachment, app.getErrorString(Dbl_Click_To_Add_Update));
		pTable.setValueByName(ETRow_PieceCountError,false);
		pTable.setValueByName(ETRow_TicketSequence, app.getErrorString(Dbl_Click_To_Add_Update));
//		pTable.setValueByName(ETRow_FellDate, app.actualTime.Date.format('d/M/yyy'));
		pTable.setValueByName(ETRow_FellDate, self.systemToLocalTime(app.actualTimeServer).date);// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		pTable.setValueByName(ETRow_Audit, true);
	endif;
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pIsBookingRef" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="receival_InitTblMain" id="e99f8abd-3258-482a-93d3-88374c0b3b7f">
        <source>receival_InitTblMain(pTable : CM_EntryTable input);
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow		: Integer;
	str			: String;
	exportDescr	: String;
		
begin
	
	pTable.setValueByName(ETRow_JasScaled, true);		
	pTable.setValueByName(ETRow_TicketedAll, true);		
	pTable.setValueByName(ETRow_PercentScaled, '100');						
	
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="receival_SaveCOU" id="a0964e4a-05d8-4123-8482-95893c3fc31b">
        <source>receival_SaveCOU(pIntFaceObject : CMIF_TIObject io; pIntFaceCOU : CMIF_InOutCOU io; pTblExtra : CM_EntryTable io; 
				 pCommon : CMIF_InOutCommon; pUserObject : Object);
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iso 	: String;
	typeStr : String;
	intFaceObj	: CMIF_TIObject;
	
begin


	if pIntFaceObject.hasCOU then

		pIntFaceCOU := pIntFaceObject.getCOU;

		if pIntFaceCOU = null then
			create pIntFaceCOU transient;
		endif;
		
		pIntFaceCOU.setUserDetails(pUserObject);
		if pCommon &lt;&gt; null then
			//AJA: If prenote, do not have a common object
			pIntFaceCOU.setMyInOutCommon(pCommon);
		endif;

		iso := pTblExtra.getValueByName(ETRow_CouISOType).String;
		typeStr := pTblExtra.getValueByName(ETRow_CouType).String;			
		pIntFaceCOU.set(pTblExtra.getValueByName(ETRow_CouId).String,iso,typeStr, self.myTerminal);

		// Always add in as if updated may have removed and readded (see below)
		pIntFaceCOU.setMasterItem(pIntFaceObject);
	else
/*
		if pIntFaceCOU &lt;&gt; null and pIntFaceObject.allSubItems.includes(pIntFaceCOU) then
			// remove from list so will not get passed through for validation/updating but
			// do not delete here as for a pre-note update the user may "add-in" again.
			pIntFaceCOU.setMasterItem(null);		// to remove from pIntFace.allSubItems
		endif;
*/
		
		// Remove COU from intFaceObject
		pIntFaceObject.removeCOU;
	endif;

end;</source>
        <Parameter name="pIntFaceObject" type="CMIF_TIObject" usage="io"/>
        <Parameter name="pIntFaceCOU" type="CMIF_InOutCOU" usage="io"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="io"/>
        <Parameter name="pCommon" type="CMIF_InOutCommon"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="receival_SaveData" id="080ddc85-d8ca-410b-ab90-09617fdc6838">
        <source>receival_SaveData(pIntFaceObject : CMIF_TIObject io; pTblMain, pTblExtra : CM_EntryTable input; 
		 pLstHazardList : CMUI_HazardsListTable; pLstDischarge : CMUI_ListTable; 
		 pLstStops : CMUI_ListTable; pLstToDo : CMUI_ListTable; //th2 CCMS 1452 - stops and toDo entry from pre-note screen
		 pCommon : CMIF_InOutCommon;  pUserObject : Object;
		 pTerminal : CM_Terminal; pTxtBRItem : GTE_TextBox);
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/11/2009	cnwdap1		CCMS MES 1017 Save/clear overdimension details
// ---------------------------------------------------------------------------
vars
	tmpReceival		: CMIF_Receival;
	obj				: Object;
	theRow			: Integer;
	tmpCargoType	: CM_CargoBOLType;
	tmpCombo		: ComboBox;
	tmpStr			: String;
	theStops        : IntegerArray;
	aStopTable		: CM_StopsTable;
	aStop           : CM_Stops;
	subTerminalObj	: CM_SubTerminal;
	tmpStop         : Boolean;
	tmpTI           : CM_TrackedItem;
	tmpStatus		: CM_IMEXStatus;
	tmpGrade		: CM_MTGrade;
	sheet			: GTE_Sheet;
	prodAttr		: CM_ProductAttr;
	product			: CM_Product;
	allStops		: CM_StopsByIdDict;

begin
	pIntFaceObject.myTerminal := self.myTerminal;
	
	pIntFaceObject.setUserDetails(pUserObject);
	pIntFaceObject.setMyInOutCommon(pCommon);

	pTblMain.setObjectFromTable(pIntFaceObject, GTE_InOutForm::saveEntTblSpecial.name, false);
	
	theRow := pTblMain.getRow(ETRow_CargoType);
	if theRow &lt;&gt; 0 then
		tmpCombo := pTblMain.accessCell(theRow, pTblMain.ColumnValue).cellControl.ComboBox;
		if tmpCombo &lt;&gt; null and tmpCombo.name = GTE_InOutForm::cmbTiType.name then
			tmpCargoType := tmpCombo.listObject.CM_CargoBOLType;
			if tmpCargoType &lt;&gt; null then
				if pIntFaceObject.isKindOf(CMIF_Receival) then
					pIntFaceObject.CMIF_Receival.cargoType := tmpCargoType.id;
				elseif pIntFaceObject.isKindOf(CMIF_ReleaseById) then
					pIntFaceObject.CMIF_ReleaseById.cargoType := tmpCargoType.id;
				elseif pIntFaceObject.isKindOf(CMIF_ReleaseByType)
				and CM_CargoType.hasInstance(tmpCargoType) then
					pIntFaceObject.CMIF_ReleaseByType.myCargoType := tmpCargoType.CM_CargoType;					
				endif;
			endif;
		endif;
	endif;
	
// cnwdad1 14/04/2009 - CCMS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		theRow := pTblMain.getRow(ETRow_MySubTerminal);
		if theRow &lt;&gt; null then
			tmpCombo	:=	pTblMain.accessCell(theRow, pTblMain.ColumnValue).cellControl.ComboBox;
			if tmpCombo &lt;&gt; null and tmpCombo.name = GTE_InOutForm::cmbSubTerminal.name then
				subTerminalObj	:=	tmpCombo.listObject.CM_SubTerminal;
				pIntFaceObject.mySubTerminal	:=	subTerminalObj;
			endif;
		endif;
	endif;
	
	// Handle the Discharge ports
	if pIntFaceObject.isKindOf(CMIF_Receival) then
	 
		if pTblExtra.isRowVisible(ETRow_AllDischargePorts) then
			self.saveListTablePorts(pLstDischarge, pIntFaceObject.CMIF_Receival.allDischargePorts);
		else
			pIntFaceObject.CMIF_Receival.allDischargePorts.clear;
		endif;
		
		theRow := pTblMain.getRow(ETRow_StatusString);
		if theRow &lt;&gt; 0 then
			tmpCombo := pTblMain.accessCell(theRow, pTblMain.ColumnValue).cellControl.ComboBox;
			if tmpCombo &lt;&gt; null and tmpCombo.name = GTE_InOutForm::cmbImexStatus.name then
				tmpStatus := tmpCombo.listObject.CM_IMEXStatus;
				pIntFaceObject.CMIF_Receival.imExStatus := tmpStatus;
			endif;
		endif;

		theRow := pTblExtra.getRow(ETRow_AvailabilityGradeCode);
		if theRow &lt;&gt; 0 then
			tmpCombo := pTblExtra.accessCell(theRow, pTblExtra.ColumnValue).cellControl.ComboBox;
			if tmpCombo &lt;&gt; null and tmpCombo.name = GTE_InOutForm::cmbAvGrade.name then
				tmpGrade := tmpCombo.CMUI_ComboBoxMTGrade.myObject.CM_MTGrade;
				if tmpGrade &lt;&gt; null then
					pIntFaceObject.CMIF_Receival.availabilityGrade := tmpGrade.code;
				endif;
			endif;
		endif;	
		if pTxtBRItem &lt;&gt; null then
			if pTxtBRItem.userObject &lt;&gt; null and pTxtBRItem.userObject.isKindOf(CM_BookingRefItem) then
				pIntFaceObject.CMIF_Receival.myBookingRefItem := pTxtBRItem.userObject.CM_BookingRefItem;
			else
				pIntFaceObject.CMIF_Receival.myBookingRefItem := null;
			endif;
		endif;
	endif;
	
	if pTblExtra &lt;&gt; null then
		pTblExtra.setObjectFromTable(pIntFaceObject, GTE_InOutForm::saveEntTblSpecial.name, false);
		
		//cnwrd1 20.11.08 CCMS JMT 1743/1764 
		theRow := pTblExtra.getRow(ETRow_ExportReleaseNumber);
		if theRow &lt;&gt; 0 then
			pIntFaceObject.CMIF_Receival.operatorExportReleaseNumber := pTblExtra.getValue(theRow).String;
		endif;
		
		if pIntFaceObject.isKindOf(CMIF_Receival) then
			//th2 CCMS 1452  -stops and todo tasks added from pre-note screen
			if pLstStops &lt;&gt; null then
				pIntFaceObject.CMIF_Receival.doSetStops := true;
				pIntFaceObject.CMIF_Receival.allStops.clear();
				foreach obj in pLstStops.allSelectedObjects do
					pIntFaceObject.CMIF_Receival.allStops.add(obj.CM_StopsTable.id);
				endforeach;
			endif;
			
			if pLstToDo &lt;&gt; null then
				pIntFaceObject.CMIF_Receival.doSetToDoTasks := true;
				pIntFaceObject.CMIF_Receival.allToDoTasks.clear();
				foreach obj in pLstToDo.allSelectedObjects do
					pIntFaceObject.CMIF_Receival.allToDoTasks.add(obj.CM_ToDoTaskDesc);
				endforeach;
			endif;
			
			// Handle the hazards
			if pTblExtra.isRowVisible(ETRow_AllTIHazards) then
				pLstHazardList.cloneAllSelectedObjects(pIntFaceObject.CMIF_Receival.allTIHazards); // adm 290610 Par 24552
			else
				pIntFaceObject.CMIF_Receival.allTIHazards.clear;
			endif;
			
			// 23/02/2010 cnwar2 #22457
			theRow := pTblExtra.getRow(ETRow_TrailerType);
			if theRow &lt;&gt; 0 
			and pTblExtra.isRowVisible(ETRow_TrailerType) then				
				tmpCombo := pTblExtra.accessCell(theRow, pTblExtra.ColumnValue).cellControl.ComboBox;
				if tmpCombo &lt;&gt; null and tmpCombo.name = GTE_InOutForm::cmbTrailerType.name then
					obj := tmpCombo.GTE_ComboBox.listObject;
					if obj &lt;&gt; null then
						pIntFaceObject.CMIF_Receival.trailerType := obj.CM_TILCType.code;
					endif;
				endif;
			endif;
			
			if tmpCargoType &lt;&gt; null
			and not tmpCargoType.isSystemCargoBOLType then

				//par 19029 cnwjo3, moved
				if pUserObject.isKindOf(GTE_Sheet) then
					sheet := pUserObject.GTE_Sheet;
					if pTblExtra.isRowVisible(ETRow_MyProduct) then
						pIntFaceObject.CMIF_Receival.myProduct := sheet.getControlByName('cmbProduct').CMUI_ComboProduct.listObject.CM_Product;
					endif;
				endif;					
			
				product := pIntFaceObject.CMIF_Receival.myProduct;
				
				if product = null then
					pIntFaceObject.CMIF_Receival.widthString	:= pTblExtra.getValueByNameIfVisible(ETRow_MyWidthString).String;
					pIntFaceObject.CMIF_Receival.lengthString	:= pTblExtra.getValueByNameIfVisible(ETRow_MyLengthString).String;
					pIntFaceObject.CMIF_Receival.heightString	:= pTblExtra.getValueByNameIfVisible(ETRow_MyHeightString).String;
					pIntFaceObject.CMIF_Receival.volume			:= pTblExtra.getValueByNameIfVisible(ETRow_MyVolume).Real;
					pIntFaceObject.CMIF_Receival.length			:= pTblExtra.getValueByNameIfVisible(ETRow_MyLength).Decimal; //02.2.09 cnwrd1 par #18821
					pIntFaceObject.CMIF_Receival.width			:= pTblExtra.getValueByNameIfVisible(ETRow_MyWidth).Decimal; //02.2.09 cnwrd1 par #18821
					pIntFaceObject.CMIF_Receival.height			:= pTblExtra.getValueByNameIfVisible(ETRow_MyHeight).Decimal; //02.2.09 cnwrd1 par #18821
					pIntFaceObject.CMIF_Receival.quantity		:= pTblExtra.getValueByNameIfVisible(ETRow_MyQuantity).Integer;
					pIntFaceObject.CMIF_Receival.density		:= pTblExtra.getValueByNameIfVisible(ETRow_MyDensity).Decimal; // ### TFS 52193 22Nov2021 NAVPW1
				else
					pIntFaceObject.CMIF_Receival.widthString	:= pTblExtra.getValueByNameIfVisible(ETRow_MyWidthString).String;
					pIntFaceObject.CMIF_Receival.lengthString	:= pTblExtra.getValueByNameIfVisible(ETRow_MyLengthString).String;
					pIntFaceObject.CMIF_Receival.heightString	:= pTblExtra.getValueByNameIfVisible(ETRow_MyHeightString).String;
					pIntFaceObject.CMIF_Receival.quantity		:= pTblExtra.getValueByNameIfVisible(ETRow_MyQuantity).Integer;
					pIntFaceObject.CMIF_Receival.density		:= pTblExtra.getValueByNameIfVisible(ETRow_MyDensity).Decimal; // ### TFS 52193 22Nov2021 NAVPW1
					
					prodAttr := product.getProdAttrFromName(ETRow_MyWidth);
					pIntFaceObject.CMIF_Receival.width := prodAttr.divideValue(pTblExtra.getValueByNameIfVisible(ETRow_MyWidth).Decimal).Decimal;
					prodAttr := product.getProdAttrFromName(ETRow_MyLength);
					pIntFaceObject.CMIF_Receival.length := prodAttr.divideValue(pTblExtra.getValueByNameIfVisible(ETRow_MyLength).Decimal).Decimal;
					prodAttr := product.getProdAttrFromName(ETRow_MyHeight);
					pIntFaceObject.CMIF_Receival.height := prodAttr.divideValue(pTblExtra.getValueByNameIfVisible(ETRow_MyHeight).Decimal).Decimal;
					
					prodAttr := product.getProdAttrFromName(ETRow_MyVolume);
					pIntFaceObject.CMIF_Receival.volume := prodAttr.divideValue(pTblExtra.getValueByNameIfVisible(ETRow_MyVolume).Decimal).Decimal;
					
					product.calculateVolume(	pIntFaceObject.CMIF_Receival.length,
												pIntFaceObject.CMIF_Receival.width,
												pIntFaceObject.CMIF_Receival.height);
				endif;
								
				if pTblExtra.isRowVisible(ETRow_MyWeight) then
					pIntFaceObject.CMIF_Receival.weightTotal := pTblExtra.getValueByName(ETRow_MyWeight).Decimal; //02.2.09 cnwrd1 par #18821 
				endif;
				
			endif;
		endif;
	endif;
	
	// CCMS 1017 Overdimension details
	if pIntFaceObject.isKindOf(CMIF_Receival) then
		if pTblExtra.getValueByName(ETRow_IsOverDimensions).Boolean then
			pIntFaceObject.CMIF_Receival.overHeight			:= pTblExtra.getValueByName(ETRow_OverHeight).Decimal;
			pIntFaceObject.CMIF_Receival.overLengthFront	:= pTblExtra.getValueByName(ETRow_OverLengthFront).Decimal;
			pIntFaceObject.CMIF_Receival.overLengthRear		:= pTblExtra.getValueByName(ETRow_OverLengthBack).Decimal;
			pIntFaceObject.CMIF_Receival.overWidthLeft		:= pTblExtra.getValueByName(ETRow_OverWidthLeft).Decimal;
			pIntFaceObject.CMIF_Receival.overWidthRight		:= pTblExtra.getValueByName(ETRow_OverWidthRight).Decimal;
		else
			// set over dimension details to null
			pIntFaceObject.CMIF_Receival.overHeight			:= null;
			pIntFaceObject.CMIF_Receival.overLengthFront	:= null;
			pIntFaceObject.CMIF_Receival.overLengthRear		:= null;
			pIntFaceObject.CMIF_Receival.overWidthLeft		:= null;
			pIntFaceObject.CMIF_Receival.overWidthRight		:= null;
		endif;
	endif;
		

	// ----------------------
	// Reset the temperature fields as if these are null (blank) we want to set to the
	// null temperature and NOT 0 (which setObjectFromTable will do above)
	// ----------------------
	if pIntFaceObject.isKindOf(CMIF_Receival) then
		self.setIntFaceObjectTemperature(pIntFaceObject, pTblMain, pTblExtra, ETRow_CarriageTempC, false);
		self.setIntFaceObjectTemperature(pIntFaceObject, pTblMain, pTblExtra, ETRow_CarriageTempF, true);
		self.setIntFaceObjectTemperature(pIntFaceObject, pTblMain, pTblExtra, ETRow_PackTempC, false);
		self.setIntFaceObjectTemperature(pIntFaceObject, pTblMain, pTblExtra, ETRow_PackTempF, true);
		self.setIntFaceObjectDecimal(pIntFaceObject, pTblMain, pTblExtra, ETRow_Humidity, NULL_HUMIDITY);
		self.setIntFaceObjectDecimal(pIntFaceObject, pTblMain, pTblExtra, ETRow_Ventilation, NULL_VENTILATION);
		self.setIntFaceObjectDecimal(pIntFaceObject, pTblMain, pTblExtra, ETRow_Oxygen, NULL_OXYGEN);
		self.setIntFaceObjectDecimal(pIntFaceObject, pTblMain, pTblExtra, ETRow_CarbonDioxide, NULL_CARBON_DIOXIDE);
		//cnwmc5 - 2 September 2014 - PAR 34847
		self.setIntFaceObjectDecimal(pIntFaceObject, pTblMain, pTblExtra, ETRow_AllowableTimeOffPower, NULL_ALLOWABLE_TIME_OFF_POWER);
	endif;

	// ----------------------
	// Set the default values
	// ----------------------
	tmpStr := self.mainExtraGetValue(pTblMain, pTblExtra, ETRow_IdTextBox).String;
	if pIntFaceObject.isKindOf(CMIF_Receival) then
		pIntFaceObject.CMIF_Receival.id := tmpStr;
	elseif pIntFaceObject.isKindOf(CMIF_ReleaseById) then
		pIntFaceObject.CMIF_ReleaseById.id := tmpStr;
	endif;

	// ----------------------
	// Set the default values
	// ----------------------
	if pIntFaceObject.isKindOf(CMIF_Receival) then
		tmpReceival := pIntFaceObject.CMIF_Receival;
		
		tmpReceival.receiptTransportMode := TI_TRANSMODE_ROAD;

		//----------------------------------------------------------------------------------------
		//Par 5625 22102003 Load port can be changed in Create New Cargo form in ship Ops (GTE_ShipPreNoteForm
		//					ETROW_LoadPort should only be visible in this form therefore will take the loadPort
		//					Otherwise set LoadPort according to terminal config (which will happen everwhere else in the system
		//					The LoadPort is set in CM_EntryTable::setObjectFromTable called from GTE_Assistant::Save_Receival
		//----------------------------------------------------------------------------------------------------
		if (not pTblExtra.isRowVisible(ETRow_LoadPort)) then
			tmpReceival.loadPort := pTerminal.getConfig(PortDestCode).String;
		endif;
		
		//Check for a nonWorked Voyage to allow imex to be set to export.
		//For Create New Cargo only
		if pTblExtra.isRowVisible(ETRow_IsNonWorked) then
			if tmpCombo.text = app.getErrorString(NonWorked) then
				tmpReceival.nonWorkedReleaseType := TransactionedMoveType;
			endif;
		endif;
		
		//epr par 19023 if we have a valid booking ref don't overwrite operator and voyage
		// 28/05/2009 cnwar2 #19695 - don't overwrite at all, these fields should be manually entered
		/*tmpBooking:=self.myTerminal.allBookingRefsByRef[tmpReceival.CMIF_Receival.bookingReference];
		if tmpReceival.operatorCode = null  and tmpBooking = null then
			tmpOp := pTerminal.getConfig(DefOperator).CM_Operator;
			if tmpOp &lt;&gt; null then
				tmpReceival.operatorCode := tmpOp.code;
			endif;
		endif;

		if tmpReceival.voyageCode = null  and tmpBooking = null then
			theVoyage := pTerminal.getConfig(DefVoyage).CM_Voyage;
			if theVoyage &lt;&gt; null then
				tmpReceival.voyageCode := theVoyage.code;
			endif;
		endif;*/

	endif;
	//FD Set Stops ccms 1088
	//----------------------
	if  pIntFaceObject.isKindOf(CMIF_ReleaseById) then
		create theStops transient;
		//The  Table contains part of the stops ,not full stop array.
		//That's why we need to prefill the theStops Array with the stops that the TI already have
		//Otherwise other stops on the TI will be wiped out.
		tmpTI := self.myTerminal.allOnsiteTIsByIdCargoType[pIntFaceObject.CMIF_ReleaseById.id, pIntFaceObject.CMIF_ReleaseById.cargoType];
		if tmpTI &lt;&gt; null then
//			foreach aStop in tmpTI.getAllStops() do		// cnwrl1 15/12/2009 PAR 21889 - what it was
			create allStops transient;
			tmpTI.getAllActiveStops( allStops );
			foreach aStop in allStops do
				theStops.add(aStop.id);
			endforeach;
			foreach aStopTable in app.myRoot.allStopsTable do
				tmpStop := pTblMain.getValueByName(aStopTable.getAttrName()).Boolean;
				if tmpStop then
					if theStops.includes(aStopTable.id) = false then
						theStops.add(aStopTable.id);
					endif;
				else
					if theStops.includes(aStopTable.id) = true then
						theStops.remove(aStopTable.id);
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
epilog
	delete theStops;
	delete allStops;
	
end;
</source>
        <Parameter name="pIntFaceObject" type="CMIF_TIObject" usage="io"/>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pLstHazardList" type="CMUI_HazardsListTable"/>
        <Parameter name="pLstDischarge" type="CMUI_ListTable"/>
        <Parameter name="pLstStops" type="CMUI_ListTable"/>
        <Parameter name="pLstToDo" type="CMUI_ListTable"/>
        <Parameter name="pCommon" type="CMIF_InOutCommon"/>
        <Parameter name="pUserObject" type="Object"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="pTxtBRItem" type="GTE_TextBox"/>
    </JadeMethod>
    <JadeMethod name="receival_ShowDocketRows" id="d5880de5-018c-4be2-8a82-274b174257c6">
        <updating/>
        <source>receival_ShowDocketRows(pDocketType:CM_BOLType; pMainTable,pExtraTable:CM_EntryTable input; pTerminal:CM_Terminal) updating;
//--------------------------------------------------------------
//Created: 17 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	row			: Integer;
	tmpStr,
	defName,
	viewName	: String;
	view		: EntTableView;
	def			: EntTableDef;
	entryTable	: CM_EntryTable;
begin

	def := pMainTable.myEntTableDef;
	pMainTable.setTerminologyRelevant(pDocketType, pTerminal);
	pMainTable.setRowNamesFromTerminology();
	
	defName := def.name;
	if defName = ETDef_InMain then
		// Currently dockets are only handled for receivals
		viewName := pDocketType.gateInOutMainTblReceiveView;
	elseif defName = ETDef_OutMain then
		viewName := pDocketType.gateInOutMainTblReleaseView;
	endif;

	//find the view for viewName
	view := def.allEntTableViews[viewName];

	if view &lt;&gt; null then
		pMainTable.showHideRowsByView(view, CM_EntryTable.ShowHideRows, false);
	else
		pMainTable.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;

	pMainTable.resetSize();	
			
	//Set the extra table (bottom right)
	
	def := pExtraTable.myEntTableDef;

	if def = null then
		pExtraTable.visible := false;
		return;
	endif;
	
	pExtraTable.setTerminologyRelevant(pDocketType, pTerminal);
	pExtraTable.setRowNamesFromTerminology();
	
	defName := def.name;
	if defName = ETDef_InExtra then
		//Set view based on BOL type
		if pDocketType.id = BOLType_GeneralDocket then
			viewName := 'InGeneralDocket';
		elseif pDocketType.id = BOLType_GeneralBillOfLading then
			viewName := 'InGeneralBillOfLading';
		elseif pDocketType.id = BOLType_Log then
			viewName := 'InLogDocket';
		else viewName := 'InLogDocket'; //default to log		
		endif;
//	elseif defName = ETDef_InBreakBulk then
//		viewName := 'InBreakBulk';
	elseif defName = 'OutEmptyExtra' then
		viewName := 'OutEmptyByType';
	elseif defName = ETDef_OutFullExtra then
		viewName := null;
	elseif defName = ETDef_OutExtra then
		if pDocketType.id = BOLType_Log then
			viewName := 'OutLogDocket';
		else
			//Still to do other types
			viewName := null;		
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown def name (' &amp; defName &amp; ')');
	endif;

	// first try and find a view for viewName
	view := def.allEntTableViews[viewName];
	
	if view &lt;&gt; null then
		pExtraTable.showHideRowsByView(view, CM_EntryTable.ShowHideRows, false);
	else
		pExtraTable.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;

end;</source>
        <Parameter name="pDocketType" type="CM_BOLType"/>
        <Parameter name="pMainTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pExtraTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="receival_ShowRows" id="903ba66d-fafd-477c-9f48-298c31318535">
        <source>receival_ShowRows(pCargoBOLType : CM_CargoBOLType; pISOType : CM_ISOType; 
				  pMainTable, pExtraTable : CM_EntryTable input;
				  pTerminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/09/2008	Simon Ward	CCMS1654 - Controlled Atmosphere improvements
// ---------------------------------------------------------------------------
vars
	extraUserInputEnabled : Boolean;
	row				: Integer;
	tmpStr,
	defName,
	viewName,
	imexName		: String;
	hasTemperature	: Boolean;
	view			: EntTableView;
	def				: EntTableDef;
	entryTable		: CM_EntryTable;
	tmpCommodity	: CM_Commodity;
begin
	if pCargoBOLType = null then //cnwrs1 May 2007 par14104 dont display any thing if the cargotype is null
		return;
	endif;
	extraUserInputEnabled := true;
	def := pMainTable.myEntTableDef;
	defName := def.name;
	if defName = ETDef_InMain then
		viewName := pCargoBOLType.gateInOutMainTblReceiveView;
		if viewName = null then
			viewName := 'Default';
		endif;
	elseif defName = ETDef_BookRefMain then
		viewName := null;
	elseif defName = ETDef_OutMain then
		if self.isReleaseByType(pMainTable) then
			viewName := 'OutByType';
		else
			viewName := pCargoBOLType.gateInOutMainTblReleaseView;		
			if viewName = null then
				viewName := 'Default';
			endif;
		endif;
	elseif defName = ETDef_BookRefHeader then
		if viewName = null then
			viewName := 'Default';
		endif;
	elseif defName = ETDef_OutFullMain then
		viewName := pCargoBOLType.gateInOutMainTblReleaseView;		
		if viewName = null then
			viewName := 'Default';
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown def name (' &amp; defName &amp; ')');
	endif;

	// first try and find a view for viewName
	view := def.allEntTableViews[viewName];
	if view &lt;&gt; null then
		pMainTable.showHideRowsByView(view, CM_EntryTable.ShowHideRows, false);
	else
		pMainTable.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;
	if (not self.myTerminal.getConfig(GateInAllowAutoComplete).Boolean) then
		pMainTable.hideRowByName(ETRow_YardLocationTxt, true);	
	endif;

// Par 10633 - related pars PAR 9704, 7807
//	*** bELOW code taken out as it was causing Iso type to be dispalyed as opposed to not!
	// PAR 9704 ISO type not applicable to all cargo/bol types
//	if CM_CargoType.hasInstance(pCargoBOLType) then
//		tmpCargoType := pCargoBOLType.CM_CargoType;
//		if tmpCargoType.allISOTypes.isEmpty then
//			pMainTable.hideRowByName(ETRow_IsoType, true);			
//		else
//			pMainTable.showRowByName(ETRow_IsoType, true);			
//		endif;	
//	else
//		pMainTable.hideRowByName(ETRow_IsoType, true);					
//	endif;
			
	pMainTable.resetSize();

	// Extra table
	def := null;
	defName := null;
	view := null;
	def := pExtraTable.myEntTableDef;

	if def = null then
		pExtraTable.visible := false;
		return;
	endif;

	defName := def.name;

	row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_StatusString, entryTable);
	if row &gt; 0 then
		imexName := entryTable.getValue(row).String;
	endif;
	if imexName = null then
		// Par 12988
		// Use constant rather than lookup as description can change.
		//imexName := app.getIMEXStringFromIMEXStatus(TI_IMEX_STATUS_EXPORT);
		imexName := 'Export';
	endif;


	if defName = ETDef_InExtra or defName = ETDef_BookRefExtra 
	or defName = ETDef_BookRefDetails then
		if pCargoBOLType &lt;&gt; null and pCargoBOLType.isSystemCargoBOLType then
			viewName := pCargoBOLType.gateInOutExtraTblReceiveView;
		elseif pCargoBOLType &lt;&gt; null and pCargoBOLType.isKindOf(CM_CargoType) 
		and pCargoBOLType.CM_CargoType.classNameToCreate = CM_TILC.name then
			viewName := 'InChassis';	// 01/06/2011 cnwar2 #27596 - use this view for user-defined trailer types
		else
			viewName := 'BBLKGeneric';
		endif;
		
		if viewName = null then
			viewName := 'Default';
		endif;
		 
		if pCargoBOLType &lt;&gt; null and pCargoBOLType.id = TI_CargoType_Container then
			hasTemperature := true;
		endif;
		
	elseif defName = ETDef_OutExtra or  defName = ETDef_OutFullExtra then
		if self.isReleaseByType(pMainTable) then
			viewName := 'bulkRelease'; // CCMS 1355
			extraUserInputEnabled := false;
		else
			viewName := pCargoBOLType.gateInOutExtraTblReleaseView;
			if viewName = null then
				viewName := 'Default';
			endif;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown def name (' &amp; defName &amp; ')');
	endif;

	// first try and find a view for viewName &amp; imexStatus
	view := def.allEntTableViews[viewName &amp; imexName];
	if view = null then
		// if not found then just look for a view on viewName
		view := def.allEntTableViews[viewName];
	endif;

	if view &lt;&gt; null then
		pExtraTable.showHideRowsByView(view, CM_EntryTable.ShowHideRows, false);

	else
		pExtraTable.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;

	// see if an Imex specific view has been defined
	if imexName &lt;&gt; null then
		view := def.allEntTableViews[imexName];
		if view &lt;&gt; null then
			pExtraTable.showHideRowsByView(view, CM_EntryTable.ShowRowsOnly, false);
		endif;
	endif;

	pExtraTable.resetSize();	

	//---------------------------
	//Container options
	//---------------------------
	if hasTemperature then
		tmpStr := mainExtraGetValue(pMainTable, pExtraTable, ETRow_OperatorCode).String;
		self.showHideTemperatureFields(pCargoBOLType.id, pISOType, tmpStr, pExtraTable, pTerminal);
		
		// isControlledAtmosphere: oxygen and carbon dioxyde
		row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_IsControlledAtmosphere, entryTable);
		if row &gt; 0 then 
//			if pExtraTable.accessRow(row).visible then
//				self.showHideCAFields(entryTable, entryTable.getValue(row).Boolean);
//			else
//				self.showHideCAFields(entryTable, false);
//			endif;
			self.showHideCAFields(entryTable, entryTable.getValue(row).Boolean, false );
		endif;
	endif;

	// determine of the height, width or length has been altered and
	// requires displaying
	row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_IsOverDimensions, entryTable);
	if row &gt; 0 and pCargoBOLType.isKindOf(CM_CargoType) then						// 13/09/2010 cnwmh5 #25727
		self.showHideDimensionFields(entryTable, entryTable.getValue(row).Boolean, pCargoBOLType.CM_CargoType);
	endif;

	row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_HasAttachments, entryTable);
	if row &gt; 0 then
		self.showHideAttachmentFields(entryTable, entryTable.getValue(row).Boolean);
	endif;
	
	row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_Commodity, entryTable);
	if row &gt; 0 then
		tmpCommodity := app.myRoot.allCommodities[entryTable.getValue(row).String];
		if tmpCommodity &lt;&gt; null then
			if tmpCommodity.code = pTerminal.getDefaultEmptyCommodity() then
				row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_Clean, entryTable);
				if row &gt; 0 then
					// show "Clean" for MT containers only
					entryTable.showRow(row);
				endif;
				//PAR 1087 AA 5/7/01: Show PTI field for empty reefers
				row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_Inspected, entryTable);
				if row &lt;&gt; 0 and pISOType &lt;&gt; null then
					if pISOType.isReefer then
						entryTable.showRow(row);
					endif;				
				endif;
			endif;
		endif;
	endif;

	row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_TransportMode, entryTable);
	if row &gt; 0 then
		tmpStr := entryTable.getValue(row).String;
		row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_Wagon, entryTable);
		if row &gt; 0 then
			self.showHideWagonField(entryTable, tmpStr);
		endif;
		//04 Nov 2009	NDL	Par 21519
		//tmpStr := entryTable.getValue(row).String;	// 27/08/2010 cnwar2 #25569 - was overwriting with Wagon value instead of Transport Mode
		row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_WagonTrain, entryTable);
		if row &gt; 0 then
			self.showHideWagonField(entryTable, tmpStr);
		endif;
	else
		// check if the wagon field is present and hide
		row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_Wagon, entryTable);
		if row &gt; 0 then
			entryTable.hideRow(row);
		endif;
		//04 Nov 2009	NDL	Par 21519
		row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable, ETRow_WagonTrain, entryTable);
		if row &gt; 0 then
			entryTable.hideRow(row);
		endif;
	endif;

	if pISOType &lt;&gt; null then
		row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable,ETRow_HasCoolingWaterConn, entryTable);
		if row &gt; 0 then
			if pISOType.isIntegral then
				entryTable.showRow(row);
			else
				entryTable.hideRow(row);
			endif;
		endif;
	endif;
	
	if not self.myTerminal.getConfig(WeighBridgeEnabled).Boolean then
		row := self.mainExtraGetTableAndRow(pMainTable, pExtraTable,ETRow_Weighbridge, entryTable);
		if row &gt; 0 then
			entryTable.hideRow(row);
		endif;
	endif;

	self.showHideCompanyField(pMainTable, pExtraTable);
	// CCMS 1415 hide this row as only want it in Pre-Note screen (will be un hidden in code there)
	pExtraTable.hideRowByName(ETRow_Carrier,false);
	pExtraTable.userInputEnabled := extraUserInputEnabled;

end;</source>
        <Parameter name="pCargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="pISOType" type="CM_ISOType"/>
        <Parameter name="pMainTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pExtraTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="receival_tblExtraDblClick" id="0d482d75-3a35-4280-847b-aa9a27d68e57">
        <updating/>
        <source>receival_tblExtraDblClick(pTable : CM_EntryTable input; 
						pAllAttachments : CMIF_InOutAttachmentArray; 
						pCargoType : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rowInTable	: Integer;
	pCaption,pHint : String;
begin
	rowInTable := pTable.CM_EntryTable.getRow(ETRow_AddAttachment);
	
	if pTable.row &gt;= rowInTable and rowInTable &gt; 0 then
		self.inputAttachments(pAllAttachments, 
							pTable, 
							rowInTable, 
							pCargoType,
							null);		//self.myOperator); par 15424 - myOperator reference was not being set correctly so would always be null
	endif;

	rowInTable := pTable.CM_EntryTable.getRow(ETRow_IdMask);
	
	if pTable.row = rowInTable and rowInTable &gt; 0 then
	    pHint := 'Enter the cargo IDs to mask with. Can be full or partial cargo or series ids (eg SUDU 20). To enter a negative (NOT), add a "!" before the mask, i.e. !SUDU20. Each id should be on a separate line.';
	    pCaption := 'Cargo ID Masking';
		self.showIdMaskWindow(pTable, rowInTable,pCaption,pHint);
	endif;
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAllAttachments" type="CMIF_InOutAttachmentArray"/>
        <Parameter name="pCargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="receival_tblMainExtraChange" id="7df1b0a3-dc2d-4df8-b27b-a100790ce617">
        <source>receival_tblMainExtraChange(pChangedTable, pTblMain, pTblExtra : CM_EntryTable io; 
							pCargoBOLType : CM_CargoBOLType; pISOType : CM_ISOType;
							pTerminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/09/2008	Simon Ward	CCMS1654 - Controlled Atmosphere improvements
// ---------------------------------------------------------------------------
vars
	tmpRow		: Integer;
	entRowTrans	: EntTableRowTransient;
	rowName		: String;
			
begin

	
	tmpRow := pChangedTable.row;
	
	entRowTrans := pChangedTable.accessRow(tmpRow).itemObject.EntTableRowTransient;
	if entRowTrans = null then
		return;
	endif;

	rowName := entRowTrans.name;
	
	if rowName = ETRow_StatusString then
		self.receival_ShowRows(pCargoBOLType, pISOType,  pTblMain, pTblExtra, pTerminal);
	elseif rowName = ETRow_IsOverDimensions then
		self.showHideDimensionFields(pTblExtra, pChangedTable.getValue(tmpRow).Boolean, pCargoBOLType.CM_CargoType);
	elseif rowName = ETRow_IsControlledAtmosphere then
		
		self.showHideCAFields(pTblExtra, pChangedTable.getValue(tmpRow).Boolean, true);
	elseif rowName = ETRow_HasCOU then	
		self.showHideCOUFields(pTblExtra, pChangedTable.getValue(tmpRow).Boolean);
	elseif rowName = ETRow_PieceCountError then
		self.showHideDriversPieceCount(pTblExtra, pChangedTable.getValue(tmpRow).Boolean); //ccms 1110 cnwas3
	elseif rowName = ETRow_HasAttachments then
		self.showHideAttachmentFields(pTblExtra, pChangedTable.getValue(tmpRow).Boolean);
	elseif rowName = ETRow_TransportMode then
		self.showHideWagonField(pTblExtra, pChangedTable.getValue(tmpRow).String);
	elseif rowName = ETRow_JasScaled then
		self.showHidePercentScaled(pTblExtra, pChangedTable.getValue(tmpRow).Boolean);

	endif;	

end;</source>
        <Parameter name="pChangedTable" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="io"/>
        <Parameter name="pCargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="pISOType" type="CM_ISOType"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="saveEntTblSpecial" id="d81a6c62-b13c-47ea-9b07-b7a15b3da6f7">
        <updating/>
        <source>saveEntTblSpecial(_attrName : String;
				_strValue : String;
				_obj : Object input;
				_tbl : CM_EntryTable input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 August 2003 by cnwrs2
//
// Purpose:     
//
// Changed On	By		Reason
// ----------	-------	------------------------------------------------------
// 08/04/2010	cnwdap1	PAR #23565 allow entry of freight forwarder for releases
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// ---------------------------------------------------------------------------
vars
	tmpConsignee	: CM_ConsigneeConsignor;
	tmpStr			: String;

begin
//process.debug;
	if _attrName = ETRow_ConsigneeCode then
		tmpStr := _strValue;
		
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
	// changed from - if self.consigneeConsignorCmbOrdDescr then - set on creation of assistant HJG 12/02/05
	// code changed as CMUI_ComboConsignors used that has consigneeConsignorCmbOrdDescr set on displaying entry
			tmpConsignee := app.myRoot.allConsigneeConsignorsForDescr[tmpStr];
			if tmpConsignee &lt;&gt; null then
				tmpStr := tmpConsignee.code;
			else
				tmpStr := null;
			endif;
		else
			// Assume that tmpStr is the code
		endif;

		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.consigneeCode := tmpStr;
		elseif _obj.isKindOf(CMIF_ReleaseById) then
			_obj.CMIF_ReleaseById.consigneeCode := tmpStr;
		elseif _obj.isKindOf(CMIF_ReleaseByType) then
	     	_obj.CMIF_ReleaseByType.consigneeCode := tmpStr;
		elseif _obj.isKindOf(CMIF_BulkRelease) then
			_obj.CMIF_BulkRelease.consigneeCode := tmpStr;
		elseif _obj.isKindOf(CMIF_BOLIn) then
			_obj.CMIF_BOLIn.consigneeCode := tmpStr;
		elseif _obj.isKindOf(CMIF_BOLOut) then
			_obj.CMIF_BOLOut.consigneeCode := tmpStr;	     	
		elseif _obj.isKindOf(GTEIF_ShipBOLIn) then // added 12/05 to handle general cargo peing created on a ship
			_obj.GTEIF_ShipBOLIn.consigneeCode := tmpStr;	     	
		
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Consignee Field not being saved');
		endif;
		return true;
	elseif _attrName = ETRow_ConsignorCode then
		tmpStr := _strValue;
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then
	// changed from - if self.consigneeConsignorCmbOrdDescr then - set on creation of assistant  HJG 12/02/05
	// code changed as CMUI_ComboConsignors used that has consigneeConsignorCmbOrdDescr set on displaying entry
			tmpConsignee := app.myRoot.allConsigneeConsignorsForDescr[tmpStr];
			if tmpConsignee &lt;&gt; null then
				tmpStr := tmpConsignee.code;
			else
				tmpStr := null;
			endif;
		else
			// Assume that tmpStr is the code
		endif;
		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.consignorCode := tmpStr;
		elseif _obj.isKindOf(CMIF_BOLOut) then
			_obj.CMIF_BOLOut.consignorCode := tmpStr;	     	
		elseif _obj.isKindOf(CMIF_BOLIn) then
			_obj.CMIF_BOLIn.consignorCode := tmpStr;
		elseif _obj.isKindOf(GTEIF_ShipBOLIn) then // added 12/05 to handle general cargo peing created on a ship
			_obj.GTEIF_ShipBOLIn.consigneeCode := tmpStr;	     	
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'ConsignorField not being saved');
		endif;
		return true;
	
	//21/11/2006 par#12903 Mohammad
	elseif _attrName = ETRow_FreightForwarderCode then
		tmpStr := _strValue;
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then
	// changed from - if self.consigneeConsignorCmbOrdDescr then - set on creation of assistant  HJG 12/02/05
	// code changed as CMUI_ComboConsignors used that has consigneeConsignorCmbOrdDescr set on displaying entry
			tmpConsignee := app.myRoot.allConsigneeConsignorsForDescr[tmpStr];
			if tmpConsignee &lt;&gt; null then
				tmpStr := tmpConsignee.code;
			else
				tmpStr := null;
			endif;
		else
			// Assume that tmpStr is the code
		endif;
		if _obj.isKindOf(CMIF_BulkRelease) then
			_obj.CMIF_BulkRelease.freightForwarderCode := tmpStr;
		elseif _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.freightForwarderCode := tmpStr;
		elseif _obj.isKindOf(CMIF_ReleaseById) then					// PAR #23565
			_obj.CMIF_ReleaseById.freightForwarderCode := tmpStr;	// PAR #23565
		elseif _obj.isKindOf(CMIF_ReleaseByType) then				// PAR #23565
	     	_obj.CMIF_ReleaseByType.freightForwarderCode := tmpStr;	// PAR #23565
		elseif _obj.isKindOf(CMIF_BOLOut) then
			_obj.CMIF_BOLOut.freightForwarderCode := tmpStr;	     	
		elseif _obj.isKindOf(CMIF_BOLIn) then
			_obj.CMIF_BOLIn.freightForwarderCode := tmpStr;
		elseif _obj.isKindOf(GTEIF_ShipBOLIn) then // added 12/05 to handle general cargo peing created on a ship
			_obj.GTEIF_ShipBOLIn.freightForwarderCode := tmpStr;	     	
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'FreightForwarderCode not being saved');
		endif;
		return true;
		
	elseif _attrName = ETRow_CustomExportEntryNumber then
		//row could be hidden, value could have been set at prenote stage so must be saved even tho user can't set
		tmpStr := _strValue;
		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.customExportEntryNumber := tmpStr;
		endif;
		return true;
	elseif _attrName = ETRow_CoolingType then
		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.coolingType := app.coolingTypeStringToENum(_strValue);
		endif;	
		return true;		
		
	elseif _attrName = ETRow_DestinationPort then

	elseif _attrName = ETRow_VoltageType then
		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.voltageType := app.voltageTypeStringToENum(_strValue);
		endif;		
		return true;
		
	elseif _attrName = ETRow_SealNum then	//03 Dec 2010	NDL	Par 26506
		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.setSealNum(_strValue);
		endif;		
		return true;
		
	elseif _attrName = ETRow_SealNumCustoms then	//03 Dec 2010	NDL	Par 26506
		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.setSealNumCustoms(_strValue);
		endif;		
		return true;
		
	elseif _attrName = ETRow_SealNumShippers then	//03 Dec 2010	NDL	Par 26506
		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.setSealNumShippers(_strValue);
		endif;		
		return true;
		
	elseif _attrName = ETRow_SealNumVent then	//03 Dec 2010	NDL	Par 26506
		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.setSealNumVent(_strValue);
		endif;		
		return true;
		
	elseif _attrName = ETRow_SealNumTerminalOperator then
		if _obj.isKindOf(CMIF_Receival) then
		//	_obj.CMIF_Receival.setSealNumVent(_strValue);
			_obj.CMIF_Receival.setSealNumTerminalOperator(_strValue);	//23 Oct 2019	NDL	TFS 47149
		endif;		
		return true;
	elseif _attrName = ETRow_SealNumUnknown then
		if _obj.isKindOf(CMIF_Receival) then
			_obj.CMIF_Receival.setSealNumUnknown(_strValue);
		endif;		
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="Object" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveFlexiGateEntity" id="b7f06e20-c1a3-434a-9a6c-b8e5014beaef">
        <source>saveFlexiGateEntity(_parentForm : CM_BaseForm input; _isUpdate: Boolean; _proxyEntity: Object input; _validationOnly : Boolean; warningsToIgnore : IntegerArray): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2009	cnwdap1	Initial creation

*/

vars

begin
	return _parentForm.saveGateEntity(_isUpdate, _proxyEntity, _validationOnly, warningsToIgnore);
epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm" usage="input"/>
        <Parameter name="_isUpdate" type="Boolean"/>
        <Parameter name="_proxyEntity" type="Object" usage="input"/>
        <Parameter name="_validationOnly" type="Boolean"/>
