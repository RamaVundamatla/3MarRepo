    <JadeMethod name="uRenameTrackedItems" id="25dcabfa-c6a7-4c14-a501-6c722aa0fdf1">
        <source>uRenameTrackedItems();
//01 October 2008	cnwdw1	
//
vars
	terminalAreaName: String;
	prefix: String;
	ta: CM_TerminalArea;
	ti: CM_TrackedItem;
	newId: String;
	location: CM_LocationsController;
begin
	terminalAreaName := "Enter Terminal Area";
	read terminalAreaName;
	ta := getTerminal.allTerminalAreas[terminalAreaName];
	prefix := "Enter new prefix";
	read prefix;
	terminate;
	if ta &lt;&gt; null then
		foreach location in ta.allLocationsControllers do
			foreach ti in location.allTrackedItems do
				beginTransaction;
					newId := prefix &amp; ti.id[prefix.length+1:end];
					ti.sendMsgWithParams(CM_TrackedItem::changeIdInternal.name, newId, false,ti.state, false,  app.myPassport); //cwnrd1 par 25075 ccms 1973 3.11.2010
				commitTransaction;
				self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			endforeach;
		endforeach;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="uResetLCOffset" id="3286f132-5e50-44a4-ab94-f33a61cb695c">
        <source>uResetLCOffset();
// ---------------------------------------------------------------------------
// Created:     17 July 2012 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	term : CM_Terminal;
	area : CM_TerminalArea;
	anLC : CM_LocationsController;
	move : CMIF_MoveController;
begin
	term := self.getTerminal();
	create move transient;
	move.setMoveMode(REAL_MODE);
	
	foreach area in term.allTerminalAreas discreteLock do
		if not area.isGridArea() then
			continue;
		endif;
		
		foreach anLC in area.allLocationsControllers discreteLock do
			beginTransaction;
			anLC.clearOffsetFlexi(move,null);
			commitTransaction;
		endforeach;
		
	endforeach;

epilog
	delete move;
end;</source>
    </JadeMethod>
    <JadeMethod name="uResetYardOffsets" id="0c84a1c3-9ff6-41de-bd04-9f0ad8b92262">
        <source>uResetYardOffsets();
/*
Purpose:			
Date		Who		Reason
04 April 2014	NAVAB1	Initial creation
*/

vars
	term : CM_Terminal;
	grid	: CM_GridArea;
	gridLC : CM_GridController;
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
begin
	term := self.getTerminal();
	
	foreach ta in term.allTerminalAreas where ta.isGridArea do
		grid := ta.CM_GridArea;
		foreach lc in grid.allLocationsControllers discreteLock do
		gridLC := lc.CM_GridController;
		
		if gridLC.offsetFlexi &gt; 0
		and gridLC.allTrackedItemOSBackEnds.isEmpty()
		and gridLC.allTrackedItemOSBackEndsPd.isEmpty()
		and gridLC.allTrackedItemOSBackEndsQd.isEmpty() then
			beginTransaction;
			gridLC.setPropertyValue("offsetFlexi",0);
			commitTransaction;
		endif;
 
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uSetInitialVersion" id="80c75f47-3515-418b-a378-888c7d11b2a4">
        <source>uSetInitialVersion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2012	cnwmc5	Initial creation SFW 1323

*/

vars
	initVer 	: String;
	checkVer	: String;
	
	initVerArr 	: StringArray;
begin
	if app.msgBox('Have you set enhanced forms to "ON" in your terminal first?', "WARNING", MsgBox_Yes_No) = MsgBox_Return_No then
		
	endif;
	
	initVer := "Initial Version";
	read initVer;
	
	create initVerArr transient;
	
	initVer.asStringArrayByDelimiter(initVerArr, ".");
	
	if initVerArr.size &lt;&gt; 3 then
		app.msgBox("Initial version cannot be set to '" &amp; initVer &amp; "', it must be in 'X.X.X' format", "Error!", MsgBox_OK_Only);
		return;
	endif;

	beginTransaction;
	app.myRoot.setInitialVersion(initVer);
	commitTransaction;
	
	if app.myRoot.initialVersion = "0.0.0" then
		return;
	endif;
	
	app.msgBox("Initial version is now set to: " &amp; app.myRoot.initialVersion &amp; CrLf &amp; "REMEMBER: Change this back to 0.0.0 for dmast", "", MsgBox_OK_Only);
	
	if app.msgBox("Check against a version?", "Check?", MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	
	checkVer := "Check Version";
	read checkVer;
	
	app.msgBox("Is deprecated? " &amp; app.myRoot.isDeprecated(checkVer).String, "Deprecated?", MsgBox_OK_Only);
epilog
	delete initVerArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="uSetUpForCargoIdConversion" id="3338e2b7-c856-4a33-b7d1-c42f4628aa81">
        <source>uSetUpForCargoIdConversion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2016	cnwndl1	Initial creation

*/

vars

begin

	self.doCargoIdConversionSetup(true,true);
	
	write "Raw data to scan";
	write "*MMEMC71XXGH031214*";  // VIN number wrapped in asterix(s)
	write "JTJHY00W6G421386011";	// VIN with added suffix
	write "I1C3CCCABXGN177954";	// VIN with 'I' prefix
	write "DUMMYLENGTHGTRTHAN20ABCDEFGHIJKL";  // greater than 20 characters, outside of the specific rules, should just truncate at 20 and 30 respectively
	write " ";
	write " ";
	write "In Unit test, should find created Ids of:";
	write "MMEMC71XXGH031214";
	write "JTJHY00W6G4213860";
	write "1C3CCCABXGN177954";
	write "DUMMYLENGTHGTRTHAN20";
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uTFS37377" id="acdf21ed-7686-4317-8b2b-c8187b3a81e6">
        <source>uTFS37377();
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
01/03/2018	jlgndl1	TFS 37377 		Initial creation Set up the raw data
									so we can replicate for performance testing
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
24/01/2019	jlgka1	41708			As a result of the changes in the CM_BulkRelease.setProxy
									we also need to add myBOLIn here.
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight																										
============================================================================*/

constants

	ReleaseIdStr 	 : String = "81752089/0";
	BaseCargoGroupId : String = "PB37377";
	BaseCargoId 	 : String = "ALU37377";
	BlockStackId1 	 : String = "37377";
	CargoTypeDesc 	 : String = "37377";
	VoyageCodeStr 	 : String = "****";

vars

	bulkRelease 		: CM_BulkRelease;
	resDet 				: CM_ReserveDetail;
	resSel 				: CM_ReserveSelection;
	resDetCount 		: Integer;
	cargoCount 			: Integer;
	pbIndex 			: Integer;
	cargoIndex 			: Integer;
	cargoId 			: String;
	cargoGroupId 		: String;
	bs1 				: CM_BlockStack;
	cargoType 			: CM_CargoType;
	pxyVoyage 			: CM_Voyage;
	pxyGlobalVoyage 	: CM_VoyageGlobal;
	voyage 				: CM_Voyage;
	oper 				: CM_Operator;
	allCargoToAssign 	: CM_TISet;
	ti 					: CM_TrackedItem;
	cargoGroup 			: CM_TrackedItem;
	allCargoGroups 		: CM_TISet;
	pxyReleaseRequest 	: CM_BulkRelease;
	pxyReleaseMatchCrit : CM_ReleaseByTypeCriteria;
	pxyCriteria 		: CM_YACriteria;
	pxyReserveSelection : CM_ReserveSelection;
	
begin

	resDetCount := 40; //How many reserve details to create on the bulk release
	cargoCount := 40; // how much cargo per reserve detail
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);

	//clean-up
	
	deleteReleaseRequest(ReleaseIdStr);
	
	foreach pbIndex in 1 to resDetCount do
		cargoGroupId := BaseCargoId &amp; pbIndex.padLeadingWith('0',2);
		foreach cargoIndex in 1 to cargoCount do
			cargoId := BaseCargoId &amp; pbIndex.padLeadingWith('0',2) &amp; cargoIndex.padLeadingWith('0',2);
			self.deleteTrackedItem(cargoId, false);
		endforeach;
		self.deleteCargoGroup(cargoGroupId);
	endforeach;
	
	self.deleteTerminalArea(BlockStackId1);
	self.deleteCargoType(CargoTypeDesc);
	
	self.deleteVoyage(VoyageCodeStr);
	
	//create base data
	
	self.opts.purge();
	cargoType := self.addCargoType(CargoTypeDesc, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CargoTypeDesc &amp; " not created during setup.");
	
	
	bs1 := self.addBlockStack(BlockStackId1, (resDetCount  * cargoCount) + 10, null);
	self.assertTrueMsg(bs1 &lt;&gt; null, BlockStackId1 &amp; " not created during setup.");
	

	//create a single ship release
	
	create pxyVoyage transient;	
	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(VoyageCodeStr, null, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	pxyVoyage.setProxyVoyage(	null,
								null,
								VoyageCodeStr,								
								null,
								self.createdByUnitTest(null),					
								"vessCode",
								"vessName",
								null,
								false, 
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								0,	//pxyVoyage.status,
								0,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null, 
								null,// BANK
								oper,
								null,
								null,
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,							
								null,
								0,
								false,									
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		
								false,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	
								null,
								null,
								pxyVoyage.isBarge, 			//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,   //03/06/2020 cnwma1 Tfs #49400
								false	// 31.Aug.2023 navsp1 TFS 57809
								);
								
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, null, null, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	create allCargoToAssign transient;
	create allCargoGroups transient;
	foreach pbIndex in 1 to resDetCount do
		allCargoToAssign.clear();
		cargoGroupId := BaseCargoId &amp; pbIndex.padLeadingWith('0',2);
		foreach cargoIndex in 1 to cargoCount do
			cargoId := BaseCargoId &amp; pbIndex.padLeadingWith('0',2) &amp; cargoIndex.padLeadingWith('0',2);
			ti := self.addCargoAtLocation(cargoId, cargoType, oper, bs1.myLocationsController);
			self.assertTrueMsg( ti &lt;&gt; null , " Cargo '" &amp; cargoId &amp; "' not created pre-test");
			allCargoToAssign.add(ti);
			beginTransaction;
			ti.setTotalWeightWithoutTrans(500);
			ti.setVoyageCode( voyage.code, app.myPassport );
			ti.setSubTerminal( self.getTerminal().allSubTerminals.first,null );
			commitTransaction;
		endforeach;
		cargoGroup := self.addCargoGroup( cargoGroupId, allCargoToAssign );
		self.assertTrueMsg( cargoGroup &lt;&gt; null , " Cargo Group '" &amp; cargoGroupId &amp; "' not created pre-test");
		allCargoGroups.add(cargoGroup);
	endforeach;
	
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(ReleaseIdStr,
								BR_TYPE_RAIL,	//BR_TYPE_SHIP,
								true,
								BR_ACTIVE,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,//consign voyage
								app.actualTimeServer(),		// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
								null, //today,		// cnwdad1 30/05/2007 - PAR #14132: Do not default required date to today.
								null,
								null,
								null,
								null, //door dir
								null,
								null,
								self.getTerminal().getDefaultPort,//load port
								null,//_destinationPort
								null,
								null,//freightForwarder
								null,
								self.getTerminal(),
								oper,
								null,
								voyage,//voyage
								null,
								true,
								null,null,null,
								self.getTerminal().allSubTerminals.first,
								self.getTerminal().allSubTerminals.first, // subterm target//cnwrd1 par 23219 17.3.2010
								null, 	//_assignedTrain : CM_Train
								false,
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								false, false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false, // par 29480 April 2012
								null, 	//CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	// jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
								
	foreach cargoGroup in allCargoGroups do
	
		create pxyReleaseMatchCrit transient;
		create pxyCriteria transient;
		pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
		pxyCriteria.setProxy(	CM_YATypeCargoGroup.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
								cargoGroup.id,	//pDataValue:Any;
								"Cargo Grou"	//pCode:String
								);
	
		create pxyReserveSelection transient;
		pxyReserveSelection.setMyHeader(pxyReleaseRequest);
		pxyReserveSelection.setPxyDefaults();
	
		pxyReserveSelection.setProxy(0, 
									cargoType,
									null,
									null,
									null,
									null,
									null,
									null,
									cargoCount,
									null, //avail grades
									null,//clean
									null, //iso check
									false, //heavy rated
									null, //mask ids
									0,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,				
									null,
									null,
									null,
									null,
									null,		 // 01/07/2015 cnwma1 PAR #36555
									null,
									false,
									null,
									null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
									null,	// ### TFS 53953 11July2022 NAVPW1
									null,null,  //12-07-2022 navtnr20 53974
									null, //28/06/2023 navmv20 CR 58410 Task 58411
									false,		// 6/12/2023 navcs2 ChangeRequest 57537
									false,	//19/02/2023	navkc1 CR 60078 Task 62450
									null,  //24/04/2025	navrv30	MTN 34319
									null);
		
			pxyReleaseMatchCrit.setProxyBaseData(pxyReserveSelection);
		

	endforeach;
	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, bulkRelease, null, app.myPassport);
	self.assertTrueMsg( bulkRelease &lt;&gt; null , " Bulk Release '" &amp; ReleaseIdStr &amp; "' not created pre-test");

epilog

	delete pxyVoyage;
	delete allCargoToAssign;
	delete allCargoGroups;
	delete pxyReleaseRequest;

end;</source>
    </JadeMethod>
