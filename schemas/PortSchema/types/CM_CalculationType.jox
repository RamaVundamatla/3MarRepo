    <JadeMethod name="setForCreate" id="46711489-6cbe-408a-8b12-d75282d57038">
        <updating/>
        <source>setForCreate(_pxyMe : CM_CalculationType) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	qtyHook,
	rateHook,
	remHook			: Integer;
	proxyLinkObj	: CM_HookLink;
	proxyQtyRange	: CM_QuantityRange;
	qtyRange		: CM_QuantityRange;
begin
	_pxyMe.booleanList.copy(self.booleanList);
	_pxyMe.integerRange1.copy(self.integerRange1);
	
	self.calculationType := _pxyMe.calculationType;
	self.code := _pxyMe.code;
	self.description := _pxyMe.description;
	self.hoursFree := _pxyMe.hoursFree;
	self.hoursMax := _pxyMe.hoursMax;
	self.hoursMin := _pxyMe.hoursMin;
	self.myCalendarType1 := _pxyMe.myCalendarType1; // PAR 30681
	self.myCalendarType2 := _pxyMe.myCalendarType2; // PAR 30681
	self.myMeasurementType := _pxyMe.myMeasurementType; // PAR 31615
	self.rateType := _pxyMe.rateType;	//22 Mar 2019	NDL	TFS 43687
	
	self.hoursBlock := _pxyMe.hoursBlock;
	self.amountMax := _pxyMe.amountMax;
	self.amountMin := _pxyMe.amountMin;
	self.isNotAvailableForEntry := _pxyMe.isNotAvailableForEntry;
	self.timeFrom := _pxyMe.timeFrom;
	self.timeTo := _pxyMe.timeTo;
	self.theCalcTypeUnit := _pxyMe.theCalcTypeUnit;
	self.isCargoCalcType := _pxyMe.isCargoCalcType;
	self.isEventCalcType := _pxyMe.isEventCalcType;
	self.isVoyageCalcType := _pxyMe.isVoyageCalcType;
	self.isWorkOrderType := _pxyMe.isWorkOrderType; // TFS 39198
	self.isBolCalcType := _pxyMe.isBolCalcType;	//30 Oct 2019	NDL	TFS 47100
	self.isInventoryType := _pxyMe.isInventoryType; // ### TFS 51219 25MAY2021 NAVAB1
	self.weightOptionToUse := _pxyMe.weightOptionToUse; //02/10/2025	navkc1 JIRA 36149
	
	self.myRoot := app.myRoot;
	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	// 34489 CCMS 1327 extended to HMS types
	if self.isVoyageCalcType then
		qtyHook := HookType_HMSInvoiceQuantity;
		rateHook := HookType_HMSInvoiceRate;
	else
		qtyHook := HookType_InvoiceQuantity;
		rateHook := HookType_InvoiceRate;
	endif;
	remHook := HookType_InvoiceRemarks;
	if _pxyMe.myHookCodeQuantity &lt;&gt; null then
		proxyLinkObj	:=	_pxyMe.getUserHookLink(qtyHook);
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		create self.myHookCodeQuantity persistent;
		self.myHookCodeQuantity.setForCreate(_pxyMe.myHookCodeQuantity);
	endif;
	if _pxyMe.myHookCodeRate &lt;&gt; null then
		proxyLinkObj	:=	_pxyMe.getUserHookLink(rateHook);
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		create self.myHookCodeRate persistent;
		self.myHookCodeRate.setForCreate(_pxyMe.myHookCodeRate);
	endif;
	if _pxyMe.myHookCodeRemarks &lt;&gt; null then		// 22/2/18 MAP TFS37124
		proxyLinkObj	:=	_pxyMe.getUserHookLink(remHook);
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		create self.myHookCodeRemarks persistent;
		self.myHookCodeRemarks.setForCreate(_pxyMe.myHookCodeRemarks);
	endif;
	//	CCMS SFW 1279 May 2012 Storage Escalating Charges
	foreach proxyQtyRange in _pxyMe.allQuantityRanges do
		create qtyRange persistent;
		qtyRange.setup(proxyQtyRange.formula, self, proxyQtyRange.daysIncrement, proxyQtyRange.percentage, proxyQtyRange.rangeStart, proxyQtyRange.rangeEnd,proxyQtyRange.rangeType);
	endforeach;
	
end;</source>
        <Parameter name="_pxyMe" type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="024f8d57-20e8-48b7-bbf4-a1637983c06f">
        <updating/>
        <source>setForUpdate(_pxyMe : CM_CalculationType) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	changeForRate	: Boolean;
	hasChanged		: Boolean;
	qtyHook,
	rateHook,
	remHook			: Integer;
	idx				: Integer;
	proxyLinkObj	: CM_HookLink;
	proxyQtyRange	: CM_QuantityRange;
	qr,
	qtyRange		: CM_QuantityRange;
	oa				: ObjectArray;
begin
	self.booleanList.clear;
	self.integerRange1.clear;

	_pxyMe.booleanList.copy(self.booleanList);
	_pxyMe.integerRange1.copy(self.integerRange1);
	
	if self.calculationType &lt;&gt; _pxyMe.calculationType or
	   self.amountMax &lt;&gt; _pxyMe.amountMax or
	   self.amountMin &lt;&gt; _pxyMe.amountMin then
		changeForRate := true;
	endif;
	
	self.calculationType := _pxyMe.calculationType;
	self.code := _pxyMe.code;
	self.description := _pxyMe.description;
	self.hoursFree := _pxyMe.hoursFree;
	self.hoursMax := _pxyMe.hoursMax;
	self.hoursMin := _pxyMe.hoursMin;
	self.hoursBlock := _pxyMe.hoursBlock;
	self.myCalendarType1 := _pxyMe.myCalendarType1; // PAR 30681
	self.myCalendarType2 := _pxyMe.myCalendarType2; // PAR 30681
	self.myMeasurementType := _pxyMe.myMeasurementType; // PAR 31615
	self.amountMax := _pxyMe.amountMax;
	self.amountMin := _pxyMe.amountMin;
	self.isNotAvailableForEntry := _pxyMe.isNotAvailableForEntry;
	self.timeFrom := _pxyMe.timeFrom;
	self.timeTo := _pxyMe.timeTo;
	self.theCalcTypeUnit := _pxyMe.theCalcTypeUnit;
	
	
	self.isCargoCalcType := _pxyMe.isCargoCalcType; // TFS 41817
	self.isEventCalcType := _pxyMe.isEventCalcType; // TFS 41817
	self.isVoyageCalcType := _pxyMe.isVoyageCalcType; // TFS 41817
	self.isWorkOrderType := _pxyMe.isWorkOrderType; // TFS 41817
	self.rateType := _pxyMe.rateType;	//22 Mar 2019	NDL	TFS 43687
	self.isBolCalcType := _pxyMe.isBolCalcType;	//30 Oct 2019	NDL	TFS 47100
	self.isInventoryType := _pxyMe.isInventoryType; // ### TFS 51219 25MAY2021 NAVAB1
	self.weightOptionToUse := _pxyMe.weightOptionToUse; //02/10/2025	navkc1 JIRA 36149
	
	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	// 34489 CCMS 1327 extended to HMS types
	if self.isVoyageCalcType then
		qtyHook := HookType_HMSInvoiceQuantity;
		rateHook := HookType_HMSInvoiceRate;
	else
		qtyHook := HookType_InvoiceQuantity;
		rateHook := HookType_InvoiceRate;
	endif;
	remHook := HookType_InvoiceRemarks;
	if _pxyMe.myHookCodeQuantity &lt;&gt; null then
		proxyLinkObj	:=	_pxyMe.getUserHookLink(qtyHook);
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		if self.myHookCodeQuantity = null then
			create self.myHookCodeQuantity persistent;
			self.myHookCodeQuantity.setForCreate(_pxyMe.myHookCodeQuantity);
		else
			self.myHookCodeQuantity.setForUpdate(_pxyMe.myHookCodeQuantity);
		endif;
	else
		delete self.myHookCodeQuantity;
	endif;
	if _pxyMe.myHookCodeRate &lt;&gt; null then
		proxyLinkObj	:=	_pxyMe.getUserHookLink(rateHook);
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		if self.myHookCodeRate = null then
			create self.myHookCodeRate persistent;
			self.myHookCodeRate.setForCreate(_pxyMe.myHookCodeRate);
		else
			self.myHookCodeRate.setForUpdate(_pxyMe.myHookCodeRate);
		endif;
	else
		delete self.myHookCodeRate;
	endif;
	if _pxyMe.myHookCodeRemarks &lt;&gt; null then		// 22/2/18 MAP TFS37124
		proxyLinkObj	:=	_pxyMe.getUserHookLink(remHook);
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		if self.myHookCodeRemarks = null then
			create self.myHookCodeRemarks persistent;
			self.myHookCodeRemarks.setForCreate(_pxyMe.myHookCodeRemarks);
		else
			self.myHookCodeRemarks.setForUpdate(_pxyMe.myHookCodeRemarks);
		endif;
	else
		delete self.myHookCodeRemarks;
	endif;

	// 1279 Storage Escalating Charges update
	create oa transient;
	foreach qr in self.allQuantityRanges do
		oa.add(qr);
	endforeach;
	idx := 0;
	hasChanged := false;
	if oa.size &lt;&gt; _pxyMe.allQuantityRanges.size then
		hasChanged := true;
	else
		foreach proxyQtyRange in _pxyMe.allQuantityRanges do
			idx := idx + 1;
			qr := null;
			if idx &lt;= oa.size then
				qr := oa[idx].CM_QuantityRange;
			endif;
			if qr = null then
				hasChanged := true;
				break;
			else
				if qr.rangeStart &lt;&gt; proxyQtyRange.rangeStart or
				   qr.rangeEnd &lt;&gt; proxyQtyRange.rangeEnd or
				   qr.daysIncrement &lt;&gt; proxyQtyRange.daysIncrement or
				   qr.rangeType  &lt;&gt; proxyQtyRange.rangeType then
					hasChanged := true;
					break;
				endif;
			endif;
		endforeach;
	endif;
	if hasChanged then
		self.allQuantityRanges.purge();
		foreach proxyQtyRange in _pxyMe.allQuantityRanges do
			create qtyRange persistent;
			qtyRange.setup(proxyQtyRange.formula, self, proxyQtyRange.daysIncrement, proxyQtyRange.percentage, proxyQtyRange.rangeStart, proxyQtyRange.rangeEnd,proxyQtyRange.rangeType);
		endforeach;
		if self.allQuantityRanges.size &gt; 0 then
			self.updateTranMaps();
		endif;
	endif;
	
	// CCMS 1264 May 2012 update charge rate (no longer dynamic) from change of HMS calc type details
	if self.isVoyageCalcType and
	   changeForRate then
		self.updateChargeRate();
	endif;

epilog
	delete oa;
end;</source>
        <Parameter name="_pxyMe" type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="setHoursBlock" id="f47179bb-8f9f-4a9f-9a42-2d0613cf0d34">
        <updating/>
        <source>setHoursBlock(_block, _free, _min, _max : Decimal) updating;
/*
Purpose:			
Date		Who		Reason
31 December 2014	cnwab1	Initial creation
*/

