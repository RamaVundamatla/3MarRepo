    <JadeMethod name="showUnpack" id="9ee32939-bcb5-4294-a2bc-77bc1f44be1b">
        <source>showUnpack(_unpackWLE : CM_WOUnpackWLE);
// -----------------------------------------------------------------------------
// Created:		24 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	frm : YRD_PackUnpack;
	ti : CM_TrackedItem;
	wodUnpack : CM_WodUnpack;
	
begin
	frm := app.loadForm(YRD_PackUnpack, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_PackUnpack;
	
	if frm = null then
		return;
	endif;

	ti := _unpackWLE.myTrackedItem;

	if ti &lt;&gt; null and ti.isKindOf(CM_Container) then
		frm.myTI := ti.CM_Container;
	endif;

	wodUnpack := _unpackWLE.getWorkOrderTIDtl();
	
	if wodUnpack &lt;&gt; null then
		frm.myInitialisationLC := wodUnpack.myUnpackToLocation;
	endif;
	
	frm.show();

	frm.frmQuery.visible := false;

epilog

end;</source>
