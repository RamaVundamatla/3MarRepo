    <JadeMethod name="btnClose_click" id="5d6d4c6e-0d12-455b-8334-8c39ab968a47">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		18 February 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="e4fd6728-d1c4-4bc1-bd34-2e108fb3972c">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		18 February 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	centreWindow();
	lblSchemaVersion.caption	:=	" " &amp; CNEC_BASESCHEMA_VERSION;
epilog
	app.mousePointer	:=	Idle;
end;</source>
