    <JadeMethod name="isFullyPlanned" id="0db54e7d-dfb2-4967-8496-d1f0857c22db">
        <source>isFullyPlanned(): Boolean;
//----------------------------------------------------------------
//	Created:	02 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	wle		: CM_WorkListEntry;
begin

	foreach wle in self.workListEntries discreteLock do
		if wle.myFutureMove = null and wle.status = WLE_UNACTIONED then
			return false;
		endif;
	endforeach;

	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
