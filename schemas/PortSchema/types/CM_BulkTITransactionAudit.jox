<Class name="CM_BulkTITransactionAudit" id="862c06f9-6040-430e-ac69-5f82586187f6">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="audit"/>
    <ExplicitInverseRef name="allTis" id="505c7d0c-bb0c-4c46-9c91-aaa380aa86a1">
        <transientToPersistentAllowed/>
        <type name="CM_TISet"/>
        <access>readonly</access>
        <Inverse name="CM_TrackedItem::allBulkTiTransactions"/>
    </ExplicitInverseRef>
    <PrimAttribute name="dateTime" id="6e2eb434-e1aa-42f0-a2bd-5a24862ce30c">
