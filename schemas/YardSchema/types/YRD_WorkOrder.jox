    <JadeMethod name="loadTabVoyageShiftMovement" id="d3902835-859b-4a81-9ff2-d61ba9ba1a57">
        <updating/>
        <source>loadTabVoyageShiftMovement() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
25 April 2022	navukv20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
26 Aug   2022	navcs2		Bug 54417: MTN - Work Order Maintenance - Invalid Shift Task Can Be Selected in Time Change Voyage Task
*/

vars
	workOrder : CM_WorkOrder;
begin
	if self.myPxyTask = null then
		return;
	endif;
	
	self.shtVoyageResources.visible	:= true;
	self.shtShift.visible	:= true;
	self.fldVoyage.topSheet  	:= self.shtShift;
	
	// Shift Movement tab
	if self.myTerminal.myHarbour &lt;&gt; null then
		self.cmbToBerth.listCollection(self.myTerminal.myHarbour.allBerths, true, 0);	
	endif;
	
	if self.myPxyTask &lt;&gt; null and self.myPxyTask.myParent &lt;&gt; null then
		workOrder := self.myPxyTask.myParent;
		if not workOrder.hasBeenApproved then
			workOrder := null;
		endif;
	endif;
	
	// 26/08/2022 navcs2 #54417
	//self.myAssistant.comboBoxVoyageWorkOrders(self.cmbWorkOrder, self.myVoyage, workOrder, null);
	
	buildCmbShiftMovemet();
epilog

end;</source>
