/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/
vars

begin
	self.setCaption(app.getErrorString(CMUI_Selector_GC) &amp; ' - ' &amp; self.getModeDescription(self.myQDef.mode));	

end;</source>
