    <JadeMethod name="doOK" id="fbd5ef51-4362-40fa-9ba2-d6e282372808">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	 // ### TFS CR 64297 TASK 64299 05JUNE024 NAVAB1 if self.doSave() then // adm 120710 Par 24929
	if self.doSaveDLRT() then // ### TFS CR 64297 TASK 64299 05JUNE024 NAVAB1
		inheritMethod();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintCargoList" id="b2934670-c9f5-4899-8d85-b3c766580c35">
        <source>doPrintCargoList(_cmifRakeRegion : CMIF_RakeRegion);
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------
// 18 Mar 2010	consw1		PAR #22886 - Leaking report transients
//----------------------------------------------------------------
vars
	qryReport 			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jrwFileName			: String;
	jrwTransient		: CM_JRWTrackedItems;
	ti					: CM_TrackedItem;
	tmpJadeReport,
	jadeReport			: JadeReport;
	tmpPrintData,
	pxyPrintData		: JadePrintData;
	//railLine			: CM_RailLine;
	wagon				: CM_Wagon;
	tiArray				: CM_TIArray;
	startIdx,endIdx		: Integer;
	localCMIF			: CMIF_RakeRegion;
	strProfile,
	rptCaption			: String;
	selectedProfiles	: StringArray;
	pxyCloned			: Boolean;
	termDict			: CM_TerminalByCodeDict;
	
begin

	localCMIF := _cmifRakeRegion;
	
	qryReport := app.myRoot.getQryReport("Rail Rake Info"); // #### DO NOT TRANSLATE
	
	if qryReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString1(Report_Not_Found, "Rail Rake Info") ); // #### DO NOT TRANSLATE
		
		//The default report to run from this button has not been set.' &amp; CrLf &amp;
		//			'Set the default Reefer Monitoring report in the terminal maintenence section' &amp; CrLf &amp;
		//			'of the system admin screen','Report not set', 0);
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWContainer).CM_JRWContainer;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(JRW_Transient_Failed));
		return;
	endif;
	
	create selectedProfiles transient;
	self.setSelectedProfiles(selectedProfiles);
	
	create tiArray transient;
	
	jrwTransient.allTrackedItems.clear();

	if localCMIF.myTrain = null then
		tiArray.clear();
		foreach wagon in localCMIF.allWagons do
			wagon.getAllTrackedItems(false, tiArray, true);	
		endforeach;
		//populate the JRW transient
		tiArray.copy(jrwTransient.allTrackedItems); 
	else
		//populate the JRW transient
		localCMIF.myTrain.allTIsReleased.copy(jrwTransient.allTrackedItems); 
		//rwTransient.allTrackedItems := localCMIF.myTrain.getAllTrackedItems(true);
	endif;
	
	if localCMIF.myRailArea = null then
		rptCaption := app.getErrorString(Train) &amp; " " &amp; localCMIF.myTrain.code; // PAR 21182
	elseif localCMIF.clearAll then
		rptCaption := app.getErrorString1(ClearAllRakes, localCMIF.myRailArea.id);
	else
		rptCaption := app.getErrorString4(ClearRakes, localCMIF.myRailArea.id, localCMIF.allRailLines.first.id, localCMIF.startPosition.String, localCMIF.endPosition.String);
	endif;
	
	jrwTransient.rptClearRakeHeading := rptCaption[1:50];
//	jrwTransient.allTerminals.add(self.myTerminal);
	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
			
	jrwManager := app.createReportWriterManager();
	
	create jadeReport transient;

	app.printer.printPreview := false;

	jrwFileName := qryReport.jrwReportName.first;
	jrwReport := jrwManager.getReport(jrwFileName);
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	jadeReport.description := jrwReport.name;
	
	//+ 25/05/2009, cnwmd1, CCMS 1067, Par 19710 - Report Heading changes
	jrwReport.setParameter("InwardOutward", "Outward"); // #### DO NOT TRANSLATE
	if localCMIF.myTrain &lt;&gt; null then
		jrwReport.setParameter("TrainName", localCMIF.myTrain.description); // #### DO NOT TRANSLATE
	endif;
	//+ 19/05/2009, cnwmd1, CCMS 1067, Par 19710 - end of changes
	
	
	foreach strProfile in selectedProfiles do
		jrwReport.setProfile(strProfile);
		
		app.printer.setReport(jadeReport);	// need to do for each
		
		jrwReport.run();
	
		if not pxyCloned then
			tmpJadeReport := jadeReport.cloneSelf(true);
			tmpJadeReport.description := qryReport.heading;
			pxyCloned := true;
		endif;
		foreach pxyPrintData in jadeReport.printArray do
			tmpPrintData := pxyPrintData.cloneSelf(true);
			tmpJadeReport.printArray.add(tmpPrintData);
		endforeach;
		jadeReport.printArray.purge;	//pages have been cloned on to tmpJadeReport

	endforeach;	
	if self.chkPrintPreview.value then
		app.printPreview(tmpJadeReport, true);
	else
		app.printer.printReport(tmpJadeReport);
	endif;
	

epilog
	delete selectedProfiles;
	delete jadeReport;
	//dont delete tmpJadeReport;
	delete tiArray;
	delete jrwManager;
	delete jrwReport;
	delete termDict;
end;</source>
        <Parameter name="_cmifRakeRegion" type="CMIF_RakeRegion"/>
    </JadeMethod>
    <JadeMethod name="doPrintManifest" id="0f669a59-5d59-4dd4-9212-4ee903604203">
        <source>doPrintManifest();
// ---------------------------------------------------------------------------
// Created:     07 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myDefaultTrain = null then
		return;
	endif;
	
	self.myAssistant.printTrainManifest(self.myDefaultTrain, false, self.chkPrintPreview.value);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="0a6e2014-012d-4eba-ab08-0c9ed59a7b08">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	cmifRakeRegion	: CMIF_RakeRegion;
	result			: Integer;
	stillToPrint	: Boolean;
	form : YRD_RailOperationsForm;
	msg : String;
	moveController : CMIF_WagonMoveController;
begin
	
	create cmifRakeRegion transient;
	
	self.setCMIF_RakeRegion(cmifRakeRegion);
	
	//25 Feb 2021	NDL	TFS 50837
	form := self.getMyParentNamed( YRD_RailOperationsForm.name ).YRD_RailOperationsForm;
	if form &lt;&gt; null and not form.validateRetrospectiveTS(null) then
		return false;
	endif;
	
	//26 Feb 2021 NDL	TFS 50837
	create moveController transient;
	moveController.autoSetEffectiveTimeStamp();
	if moveController.effectiveTimeStamp.isValid then
		cmifRakeRegion.setEffectiveTimeStampOverride( moveController.effectiveTimeStamp );
	endif;
	
	//31 Aug 2009	NDL	CCMS 1067
	if chkConfirmOut.value then
		if self.allUnconfirmedWagons.isEmpty then
			app.msgBox(app.getErrorString(No_Unconfirmed_wagons_selected), app.getErrorString(Wagon_confirmation) &amp; " - " &amp; app.getErrorString(Outwards), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	
		self.myAssistant.YRD_Assistant.doConfirmWagonsOutward( moveController, self.allUnconfirmedWagons, null );
		if not app.myPassport.noErrors then
			return false;
		endif;
	
	endif;
	
	app.mousePointer := Busy;

	while true do
		app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
		
		// ### TFS CR 64297 TASK 64391 31MAY2024 NAVAB1
		if app.myPassport.hadDeadlock = true then
			return false;
		endif;
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(CLEAR_RAKE_RAIL), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return false;
	endwhile;	
	
	// PAR 19710
	if self.chkPrintCargo.value then	
		self.doPrintCargoList(cmifRakeRegion);
	endif;
	if self.chkPrintManifest.value then	
		self.doPrintManifest();
	endif;
	
	return true;
epilog
	delete cmifRakeRegion;
	delete moveController;	//25 Feb 2021	NDL	TFS 50837
	app.mousePointer := Idle;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDLRT" id="c1cff742-812e-408e-b93d-a8bc129fef36">
        <updating/>
        <source>doSaveDLRT() : Boolean updating;
/*
Purpose:			

Date		Who		Reason
05 June 2024	navab1	CR 64297 TASK 64299
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone
*/

vars
	localCaption : String;
begin
	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	while true do
	
		
		//call the code that was originally in this method
		self.doSave();	// original code 
		
		//if we did NOT have a dead lock, just bail out.
		if app.myPassport.noTrxReplayAllowed() then	
			if app.myPassport.hadDeadlock then
				app.showErrorWarningDialog(app.getErrorString(Train), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); 
			endif;
			return app.myPassport.trxCompletedOK;
		endif;
		
		self.updateCaptionDeadlockRetry(localCaption);		
	endwhile;

	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818

	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
