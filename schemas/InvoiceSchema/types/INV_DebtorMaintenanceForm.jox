    <JadeMethod name="btnAddrSave_click" id="6d54772a-04dc-42ae-ba0b-6186211a7c88">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddrSave_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars

begin
	if self.doSaveDebtorAddress() then
		self.populateShtDebtorAddresses();
		self.clearCurrentAddress();
		self.enableDisableAddressDetails(false);
		btnAddrDelete.enabled := false;
		btnAddrSave.enabled   := false;
		btnAddrUpdate.enabled := false;
		btnAddrNew.enabled    := self.myDebtorNode.CM_Debtor.allAddressesByCode.size() &lt; 9;		// 9/8/19 MAP TFS45577
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAddrUpdate_click" id="428ae8c4-63e7-49ab-ab30-7df6a417c8a2">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddrUpdate_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars

	address : CM_Address;
	index : Integer;

begin
	
	
	index := self.tblAddrDetails.row;
	if index &gt; 1 then
		address := self.tblAddrDetails.accessRow(index).itemObject.CM_Address;
	endif;
	
	if address &lt;&gt; null then
		self.showCurrentAddress(address);
		self.enableDisableAddressDetails(true);
		btnAddrSave.enabled 	   := true;
		self.btnAddrUpdate.enabled := false;
		
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
