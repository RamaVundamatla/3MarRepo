    <JadeMethod name="selectRandomReader" id="c527ac31-09c5-4c0c-a2e5-d063a514dc7f">
        <source>selectRandomReader() protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	rnd			: Integer;
	seed		: Integer;
	time			: Time;
begin
	//seed := time.second * time.minute;
	rnd := app.random(self.lstReader.listCount-1) + 1;
	self.lstReader.enabled := false;
	self.lstReader.listIndex := rnd;
	self.lstReader.itemSelected[rnd] := true;
	//self.lstReader.selectedCount
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectRandomTag" id="93a87163-e354-4b24-86ab-afc3e90a34e0">
        <source>selectRandomTag() protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	rnd			: Integer;
	seed		: Integer;
	time			: Time;
begin
	seed := time.second * time.minute;
	rnd := app.random(self.lstTag.listCount -1) + 1;
	
	self.lstTag.listIndex := rnd;
	self.lstTag.itemSelected[rnd] := true;
end;


</source>
        <access>protected</access>
    </JadeMethod>
