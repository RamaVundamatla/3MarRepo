    <JadeMethod name="isLoadRequest" id="998fa063-ef3b-4370-ba4b-f03c24542e4d">
        <source>isLoadRequest() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2017	jlger1	Initial creation 5535

*/

vars

begin
	if self.doTruckLoad then
		return true;
	endif;
	if self.doTruckLoadComplete then
		return true;
	endif;
	if self.undoTruckLoad then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUnloadRequest" id="b25dbde5-bde2-4137-bed4-9200543e98e2">
        <source>isUnloadRequest() :Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2017	jlger1	Initial creation

*/

vars

begin
	if self.doTruckUnload then
		return true;
	endif;
	if self.doTruckUnloadComplete then
		return true;
	endif;
	if self.undoTruckUnload then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
