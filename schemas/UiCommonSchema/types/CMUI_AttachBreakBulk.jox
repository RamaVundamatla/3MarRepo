    <JadeMethod name="createPxyBreakBulk" id="b317c9af-72e4-4f55-a971-e1db86e2bf46">
        <updating/>
        <source>createPxyBreakBulk(_attachID : String input; 
					_cargoType : CM_CargoType) : CM_TrackedItem updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	proxyTI 		: CM_TrackedItem;
begin
	_attachID.toUpper();
	
	//-cnwml2 PAR21010
	/*if self.myTerminal.allOnsiteTIsByCargoTypeId[_cargoType.id, _attachID.trimBlanks] &lt;&gt; null then
		app.raiseCMException3(ERR_TI_ONSITE, _cargoType.description, _attachID, self.myTerminal.code, null, null);
		app.raiseCMException1(ERR_ADDING_TI, _attachID.trimBlanks, null, null);
		return null;
	endif;*/
	
	create proxyTI as _cargoType.myClassToCreate transient;
	proxyTI.setPxyFromDefaultTI(self.myTerminal,_cargoType.id,_attachID, null, null);
	
	return proxyTI;
end;</source>
        <access>protected</access>
        <Parameter name="_attachID" type="String" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="displayAttachments" id="485fdc43-6cc2-4e06-8b90-4c50aca12982">
        <source>displayAttachments();
// ---------------------------------------------------------------------------
// Created:     05 November 2002		cnwth2	
//
// Purpose:     If the form is re-opened in a single gate In session this method
//				willl display the original attachments
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmifAttach			: CMIF_InOutAttachment;
	idx					: Integer;
	table				: CM_DataTable;
	strLoc,
	strTerm				: String;
begin
	table := self.tblAll;
	
	foreach cmifAttach in self.aAllAttachments do
		if cmifAttach.myTerminalArea &lt;&gt; null then 
			strTerm := cmifAttach.myTerminalArea.id;
		endif;

		if cmifAttach.myLocationsController &lt;&gt; null then 
			strLoc := cmifAttach.myLocationsController.getID;
		endif;
		
		idx := table.addItem(cmifAttach.id &amp; Tab &amp;
							cmifAttach.operatorCode &amp; Tab &amp;
							cmifAttach.myCargoType.description &amp; Tab &amp;
							strTerm &amp; Tab &amp;
							strLoc);
		table.accessRow(idx).itemObject := cmifAttach;
	endforeach;
	
	self.updateItemCount();
end;</source>
    </JadeMethod>
    <JadeMethod name="displayMyCurrentItem" id="2d09779d-fc74-4e5a-9cab-0a8df6e6a03e">
        <updating/>
        <source>displayMyCurrentItem() updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002		cnwth2	
//			 
// ----------   ----------  --------------------------------------------------
// 12/12/2012	cnwcs5	par 30852 - trailer type combo changes
// 13/08/2013	cnwdap1	PAR #32123 Added Colour Picker
// 20/06/2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	attach				: CMIF_InOutAttachment;
	tableAll			: CM_DataTable;
	table				: CM_EntryTable;
	entDef				: EntTableDef;
	cargoType			: CM_CargoType;		// par 30852 Dec 2012
	trailerType			: CM_TILCType;		// par 30852 Dec 2012
	pro					: CM_Product;
	prodAttr			: CM_ProductAttr;
	taType				: CM_TerminalAreaType;
	tmpImEx				: CM_IMEXStatus;
	consign				: CM_ConsigneeConsignor;
	tmpCommodity		: CM_Commodity;
	tmpOp				: CM_Operator;
	str					: String;
	isoType 			: CM_ISOType;
	operator			: CM_Operator;		// TFS 53362
begin
	
	tableAll 	:= self.tblAll;
	table 		:= self.tblItem;
	
	table.clearHasChanged();
	
	entDef 		:= self.getAllAttributesDef;
	attach 		:= tableAll.accessRow(tableAll.row).itemObject.CMIF_InOutAttachment;
	
	if attach = null then
		return;
	endif;
	
	cargoType	:= attach.myCargoType;	// par 30852 Dec 2012
	pro 		:= attach.myProduct;
	
	if self.cmbCargoType.listObject &lt;&gt; cargoType then
		self.cmbCargoType.listObject := cargoType;
		
		self.doCmbCargoTypeClick();
	endif;
	
	if self.cmbProduct.listObject &lt;&gt; attach.myProduct then
		self.cmbProduct.listObject := attach.myProduct;
	endif;
	
	if attach.myTerminalArea &lt;&gt; null then 
		taType := app.myRoot.allTerminalAreaTypes[attach.myTerminalArea.type];
	endif;
	
	if self.cmbTAType.listObject &lt;&gt; taType then
		self.cmbTAType.listObject := taType;
		self.loadTerminalAreas(attach.myTerminalArea);
	endif;
	
	if self.cmbTerminalArea.listObject &lt;&gt; attach.myTerminalArea then
		self.cmbTerminalArea.listObject := attach.myTerminalArea;
	endif;
	
	self.getAvailableRowsForProduct();
	
	if self.cmbLC.listObject &lt;&gt; attach.myLocationsController then
		self.cmbLC.listObject := attach.myLocationsController;
	endif;
	
	consign := app.myRoot.allConsigneeConsignors[attach.consignee];
	
	if self.cmbConsignee.myObject &lt;&gt; consign then
		self.cmbConsignee.setObject(consign);
	endif;	
	
	consign := app.myRoot.allConsigneeConsignors[attach.consignor];
	
	if self.cmbConsignor.myObject &lt;&gt; consign then
		self.cmbConsignor.setObject(consign);
	endif;	
	
	isoType := app.myRoot.allISOTypes[attach.isoType];
	
	if self.cmbISOType.myObject &lt;&gt; isoType then
		self.cmbISOType.setObject(isoType);
	endif;

	tmpOp := app.myRoot.allOperators[attach.operatorCode];
	
	if self.cmbOperator.listObject &lt;&gt; tmpOp then
		self.cmbOperator.setObject(tmpOp);
	endif;	

	tmpCommodity := app.myRoot.allCommodities[attach.commodityCode];
	
	if self.cmbCommodity.myObject &lt;&gt; tmpCommodity then
		self.cmbCommodity.setObject(tmpCommodity);
	endif;
	
	if self.cmbGenType.myObject &lt;&gt; attach.myGeneratorType then
		self.cmbGenType.setObject(attach.myGeneratorType);
	endif;
	
	//17 Oct 2012	NDL	Par 30095
	if cargoType.isTrailer then
		trailerType := attach.myTrailerType;
		
		// this next line will force re-loading of combo
		self.cmbTrailerType.myCargoType := cargoType; 

		self.cmbTrailerType.setObject(trailerType);
	else
		self.cmbTrailerType.myCargoType  := null;
		self.cmbTrailerType.clear;
	endif;
	
	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	tmpImEx := app.myRoot.allImexStatuses[attach.imExStatus];

	if tmpImEx &lt;&gt; null and tmpImEx.code &lt;&gt; null and self.cmbImExStatus.listObject &lt;&gt; tmpImEx then
		self.cmbImExStatus.listObject := tmpImEx;
	endif;
	
	self.lstHazardList.setSelectedFromObject(attach);
	self.lstHazardList.lostFocus(self.lstHazardList);
	
	if attach.voyageCode &lt;&gt; null and 
		self.cmbVoyage.listObject &lt;&gt; null and 
		self.cmbVoyage.listObject.CM_Voyage.code &lt;&gt; attach.voyageCode then
		self.cmbVoyage.text := attach.voyageCode;
		self.doCmbVoyageClick();
	endif;
	
	self.cmbDestPort.setObjectFromCode (attach.destinationPortCode);
	self.cmbDisPort.setObjectFromCode (attach.dischargePortCode);

	self.cmbWidthCodes.text 	:= attach.widthString;
	self.cmbHeightCodes.text 	:= attach.heightString;
	self.cmbLengthCodes.text 	:= attach.lengthString;
	self.cmbTypeCodes.text 		:= attach.type;

	if attach.myTerminalArea &lt;&gt; null then 
		str := attach.myTerminalArea.id;
	endif;
	
	table.setValueByName(ETRow_CargoType, attach.myCargoType.description);
	
	if trailerType &lt;&gt; null then
		table.setValueByName(ETRow_MyTrailerType, trailerType.description);
	endif;
	
	table.setValueByName(ETRow_TerminalArea,str);
	
	str  := null; 
	
	if attach.myLocationsController &lt;&gt; null then 
		str := attach.myLocationsController.getID;
	endif;

	table.setValueByName(ETRow_Row, str);
	
	table.setValueByName(ETRow_Id, attach.id);
	table.setValueByName(ETRow_Description, attach.description);
	// TFS 53362 start
	if app.myRoot.getConfig(ComboByNameOperator).Boolean then
		operator := app.myRoot.allOperators[attach.operatorCode];
		if operator &lt;&gt; null then
			table.setValueByName(ETRow_Operator, operator.description);
		endif;
	else
		table.setValueByName(ETRow_Operator, attach.operatorCode);
	endif;
	// TFS 53362 end
	table.setValueByName(ETRow_Consignee, self.cmbConsignee.text);
	table.setValueByName(ETRow_Consignor, self.cmbConsignor.text);	
	
	table.setValueByName(ETRow_TotalWeight, attach.weight);						//+cnwml2 MSL CCMS 1017
	table.setValueByName(ETRow_Volume, attach.volume.asStringJMT());	// ** #25592 18/11/2010 fixed ITALIAN locale
	table.setValueByName(ETRow_Commodity, attach.commodityCode);
	table.setValueByName(ETRow_DestPort, attach.destinationPortCode);
	table.setValueByName(ETRow_DisPort, attach.dischargePortCode);
	table.setValueByName(ETRow_Voyage, attach.voyageCode);
	table.setValueByName(ETRow_ImexStatus, cmbImExStatus.text);
	
	table.setValueByName(ETRow_Mark, attach.mark);
	table.setValueByName(ETRow_BookingRef, attach.bookingRef);
	table.setValueByName(ETRow_Remarks, attach.remarks);
	
	table.setValueByName(ETRow_Quantity, attach.quantity.String);
	table.setValueByName(ETRow_AlternativeId, attach.alternativeId);
	table.setValueByName(ETRow_ClientRef, attach.clientRef);
	table.setValueByName(ETRow_Condition, attach.condition);
	table.setValueByName(ETRow_BillOfLading, attach.billOfLading);
	table.setValueByName(ETRow_HouseBOL, attach.houseBillOfLading);
	
	if app.isSubTerminalsOn(self.myTerminal) then
		if attach.mySubTerminal &lt;&gt; null then
			table.setValueByName(ETRow_MySubTerminal, attach.mySubTerminal.code);
		endif;
	endif;
	
	self.cmbHasRadio.text := app.myRoot.carHasRadioDisplay(attach.hasRadio);
	
	table.setValueByName(ETRow_HasRadio, self.cmbHasRadio.text);
	
	self.cmbCustomsAgent.listIndex := self.cmbCustomsAgent.findObject(attach.myCustomsAgent);
	
	table.setValueByName(ETRow_CustomsAgent, self.cmbCustomsAgent.text);
	table.setValueByName(ETRow_Colour, attach.colour);
	
	if self.myTerminal.getConfig(ValidateColour).Boolean then							// PAR #32123
		self.myAssistant.setColourDetails(attach.colourDesc, self.lstColour, null);		// PAR #32123
	else																				// PAR #32123
		table.setValueByName(ETRow_Colour, attach.colourDesc);							// PAR #32123
	endif;																				// PAR #32123
	
	if pro = null then
		self.setProdAttrCodeValue(ETRow_MyWidthString, null, self.cmbWidthCodes, false, attach.widthString);
		self.setProdAttrCodeValue(ETRow_MyHeightString, null, self.cmbHeightCodes, false, attach.heightString);
		self.setProdAttrCodeValue(ETRow_MyLengthString, null, self.cmbLengthCodes, false, attach.lengthString);
		self.setProdAttrCodeValue(ETRow_MyType, null, self.cmbTypeCodes, false, attach.type);
		return;	
	endif;

	self.setProdAttrCodeValue(ETRow_MyWidthString, pro.myWidthString, self.cmbWidthCodes, false, attach.widthString);
	self.setProdAttrCodeValue(ETRow_MyHeightString, pro.myHeightString, self.cmbHeightCodes, false, attach.heightString);
	self.setProdAttrCodeValue(ETRow_MyLengthString, pro.myLengthString, self.cmbLengthCodes, false, attach.lengthString);
	self.setProdAttrCodeValue(ETRow_MyType, pro.myType, self.cmbTypeCodes, false, attach.type);
	
	table.setValueByName(ETRow_Product, pro.code &amp; '   ' &amp; pro.description);
	
	prodAttr := pro.getProdAttrFromName(ETRow_MyWidth);
	
	table.setValueByName(ETRow_MyWidth, prodAttr.multiplyValue(attach.width).String);
	
	prodAttr := pro.getProdAttrFromName(ETRow_MyHeight);
	
	table.setValueByName(ETRow_MyHeight, prodAttr.multiplyValue(attach.height).String);
	
	prodAttr := pro.getProdAttrFromName(ETRow_MyLength);
	
	table.setValueByName(ETRow_MyLength, prodAttr.multiplyValue(attach.length).String);
	
	prodAttr := pro.getProdAttrFromName(ETRow_MyQuantity);
	
	table.setValueByName(ETRow_MyQuantity, prodAttr.multiplyValue(attach.quantity).String);
	
	prodAttr := pro.getProdAttrFromName(ETRow_MyVolume);
	
	table.setValueByName(ETRow_MyVolume, prodAttr.multiplyValue(attach.volume).String);
	
	prodAttr := pro.getProdAttrFromName(ETRow_MyDensity);
	
	table.setValueByName(ETRow_MyDensity, prodAttr.multiplyValue(attach.density).String);
	
	prodAttr := pro.getProdAttrFromName(ETRow_MyWeight);
	
	table.setValueByName(ETRow_MyWeight, prodAttr.multiplyValue(attach.weight).String);
	
	//jlier1 TFS 53515 30/5/22
	if app.isCargoGroupEnabled then
		table.setValueByName(ETRow_CargoGroupId,attach.cargoGroupID);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoGroupRowChange" id="7ccf1df8-73c9-4e95-bc77-37ecaf902f44">
        <source>doCargoGroupRowChange(table: CM_EntryTable input ) : CMUI_CargoGroupCreateForm;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2022	jlier1	Initial creation	Par 53515

*/

vars
	originalRowValue	: String;
	terminal : CM_Terminal;
	cargoGroupId : String;
	cargoGroup : CM_CargoGroup;
	msg : String;
	creatCargoGroup : CMUI_CargoGroupCreateFormModal;
	cargoGroupTypeCount : Integer;
	iter : Iterator;
	obj : Object;
begin

	terminal := self.myTerminal;
	if terminal = null then
		return null;
	endif;
	
	cargoGroupId := table.getValueByName(ETRow_CargoGroupId).String.trimBlanks.toUpper;
	
	if cargoGroupId = null then
		return null;
	endif;
	
	cargoGroup := terminal.getCargoGroupItem( cargoGroupId ).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id &lt;&gt; cargoGroupId then
		cargoGroup := null;
	endif;
	
	if cargoGroup = null then
		iter:=self.myTerminal.allCargoBOLTypes.createIterator;
		while iter.next(obj) do
			if not obj.isKindOf(CM_CargoType) then
				continue;
			endif;
			if obj.CM_CargoType.productType = ProductType_CargoGroup then
				cargoGroupTypeCount:=cargoGroupTypeCount+1;
			endif;
			if cargoGroupTypeCount &gt; 1 then
				break;
			endif;
		endwhile;
		if cargoGroupTypeCount = 1 then
			return null;
		endif;
	
		msg := app.getErrorString1(Cargo_group_not_found_want_cre,cargoGroupId);
		if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) = MsgBox_Return_Yes then
			originalRowValue := table.getOrigValueByName(ETRow_CargoGroupId).String;		// TFS 2417
			creatCargoGroup := app.loadForm(CMUI_CargoGroupCreateFormModal, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_CargoGroupCreateFormModal;
			creatCargoGroup.setCargoGroupId( cargoGroupId );
			
			if   creatCargoGroup.showModal() = IDOK then
				cargoGroup:= creatCargoGroup.userObject.CM_CargoGroup;
				if cargoGroup &lt;&gt; null then
			
					table.setOrigValueByName(ETRow_CargoGroupId, originalRowValue);	
				else
					table.setValueByName(ETRow_CargoGroupId,null);
				endif;
			else
				table.setValueByName(ETRow_CargoGroupId,null);
			endif;
		else
			table.setValueByName(ETRow_CargoGroupId,null);	
		endif;
	endif;

epilog
	delete iter;
	return creatCargoGroup;

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <ReturnType type="CMUI_CargoGroupCreateForm"/>
    </JadeMethod>
    <JadeMethod name="doCheckKeyDownSpecial" id="6cab6190-827a-4bac-b039-f2af00d1d319">
