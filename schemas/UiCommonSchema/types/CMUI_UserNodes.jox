    <JadeMethod name="handleLogLevelResp" id="af92e372-5065-4a9c-beb4-2c18a17ef640">
        <source>handleLogLevelResp( _process : Process; _logLevel : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 November 2019	jlgndl1	Initial creation	TFS 47053
18 September 2023	navmd1	TFS 60524 Implement Column Organiser

*/

vars

	rowIndex	: Integer;
	processObj	: Process;
	colIndex	: Integer;
	fixedRows	: Integer;

begin
	fixedRows := self.tblNodes.fixedRows + 1;
	if self.tblNodes.rows &lt; fixedRows then
		return;
	endif;
	
	colIndex := self.tblNodes.getColumnByRowName(ETRow_LogLevel);
	if colIndex &lt;= 0 then
		return;
	endif;

	foreach rowIndex in fixedRows to self.tblNodes.rows do
		processObj := self.tblNodes.accessRow( rowIndex ).itemObject.Process;
		if _process = processObj then
			self.tblNodes.accessCell( rowIndex, colIndex ).text := app.getLoggingLevelString( _logLevel );
			break;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_process" type="Process"/>
        <Parameter name="_logLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleProcessUserCodeUpdate" id="ad373597-deea-4f94-ae07-734ea6a569cd">
        <source>handleProcessUserCodeUpdate(_process : Process) protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2003 by cnwrs2
//
// Purpose:     
//
// Date			Who		Reason
// 18/09/2023	navmd1	TFS 60524 Implement Column Organiser
// ---------------------------------------------------------------------------
vars
	row				: Integer;
	visibleColumns	: EntTableRowArray;
	invalid			: Boolean;
begin

	if (not self.tblNodes.findObjectInRow(_process, row)) then
		return;
	endif;
	
	visibleColumns := self.tblNodes.allTblDataEntRows;
	
	on Exception do app.handleDeletedObject(exception, _process, invalid);
	self.tblNodes.accessCell(row, 1).text := _process.getAttributeStringForDefArray(visibleColumns);

end;</source>
        <access>protected</access>
        <Parameter name="_process" type="Process"/>
    </JadeMethod>
    <JadeMethod name="handleSysNote" id="a603ff11-d543-49f9-b264-2562b9a2085f">
        <updating/>
        <source>handleSysNote(_eventType: Integer; _theObject: Object) updating, protected;
// -------------------------------------------
// Created 06 October 2003 by cnwdvb1
// -------------------------------------------
vars
	row : JadeTableRow;
begin
	if _eventType = Object_Delete_Event then
		self.tblNodes.removeDeletedObject(_theObject);

	elseif _eventType = Object_Create_Event and _theObject.isKindOf(Process) then
		// Give process some time to log on and handle multiple events.
		if (not self.isTimerOn) then
			self.isTimerOn := true;
			self.beginTimer(2000, Timer_OneShot, null);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
    </JadeMethod>
