    <JadeMethod name="getTwinLiftString" id="f8c5e634-7ce3-4ee5-93ff-bfaa1ab5efed">
        <source>getTwinLiftString() : String;
// -------------------------------------------
// Created 05 September 2005 by cnwdvb1
