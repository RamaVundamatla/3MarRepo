    <JadeMethod name="btnField_contextMenu" id="1cb36a45-21c8-4464-beda-cb8d0fa2bf3c">
        <controlMethod name="Button::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnField_contextMenu(
	_btn	: Button input;
	_conwin	: Window input;
	_mouse	: Boolean;
	_x		: Integer;
	_y		: Integer ) : Boolean updating;
	
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/01/2009	cnwrl1		Changed to use common code. (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------
vars

begin
	// save off the button the menu belongs to in the userObject property for the menu
	self.mnuPopup2.userObject		:= _btn;
	self.mnuPopup2Delete.enabled	:= _btn.value;
	
	// now show the menu and terminate further processing
	return self.showContextMenu( self.mnuPopup2, _btn, _conwin, _mouse, _x, _y );
	
epilog
	
end;</source>
        <Parameter name="_btn" type="Button" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
