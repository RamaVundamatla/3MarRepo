    <JadeMethod name="clear" id="c0008e28-28ce-4429-b28c-b796f6190f60">
        <updating/>
        <source>clear() updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2003 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 06 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
begin
	self.endNotificationForSubscriber(self);

	self.allCommodityGroups.clear();
	self.allHazards.clear();
	self.allConsignees.clear();
	self.allContentsStatus.clear();
	self.allDischargePorts.clear();
	self.allISOTypeGroups.clear();
	self.allISOTypes.clear();
	self.allLoadPorts.clear();
	self.allOperators.clear();
	self.allProducts.clear();
	self.allUsedProducts.clear();
	self.allTempRanges.clear();
	self.allVoyages.clear();
	self.allWeightRanges.clear(); // (11836) 27/09/2006 cnwmo1 
	self.allDestinationPorts.clear; // 
	self.allStockBookRefs.clear();
	self.allExportBookRefs.clear();
	self.allReleases.clear();
	self.allCargoTypes.clear();
	self.allTrains.clear();
	self.allDwellRanges.clear();	//20 Jul 2011	NDL	Par 27890
	self.allShippingLines.clear(); 	//06-06-2022 navtnr20 53204
	
	delete self.myIterHazards;
	delete self.myIterCommodity; // ## PAR 9720
	delete self.myIterCommodityGroup; // ## PAR 9720
	delete self.myIterConsignee; // ## PAR 9720
	delete self.myIteratorYardAllocations; // ## PAR 9720
	delete self.myIterContentsStatus; // ## PAR 9720
	delete self.myIterDischargePort; // ## PAR 9720
	delete self.myIterISOType; // ## PAR 9720
	delete self.myIterISOTypeGroup; // ## PAR 9720
	delete self.myIterLoadPort; // ## PAR 9720
	delete self.myIterOperator; // ## PAR 9720
	delete self.myIterProduct;
	delete self.myIterUsedProduct;
	delete self.myIterTempRange; // ## PAR 9720
	delete self.myIterVoyage; // ## PAR 9720
	delete self.myIterWeightRange; // (11836) 27/09/2006 cnwmo1
	delete self.myIterStockBookRef;
	delete self.myIterExportBookRef;
	delete self.myIterRelease;
	delete self.myIterCargoTypes;
	delete self.myIterTrain;
	delete self.myIterDwellRange;	//20 Jul 2011	NDL	Par 27890
	delete self.myIterShippingLine;	//06-06-2022 navtnr20 53204

	self.myIterHazards	 		:=	self.allHazards.createIterator(); 
	self.myIterCommodity	 		:=	self.allCommodities.createIterator(); // ## PAR 9720
	self.myIterCommodityGroup 		:=	self.allCommodityGroups.createIterator(); // ## PAR 9720
	self.myIterConsignee 			:=	self.allConsignees.createIterator(); // ## PAR 9720
	self.myIterContentsStatus		:=	self.allContentsStatus.createIterator(); // ## PAR 9720
	self.myIterDischargePort		:=	self.allDischargePorts.createIterator(); // ## PAR 9720
	self.myIterISOType				:=	self.allISOTypes.createIterator(); // ## PAR 9720
	self.myIterISOTypeGroup			:=	self.allISOTypeGroups.createIterator(); // ## PAR 9720
	self.myIterLoadPort				:=	self.allLoadPorts.createIterator(); // ## PAR 9720
	self.myIterOperator				:=	self.allOperators.createIterator(); // ## PAR 9720
	self.myIterProduct				:=	self.allProducts.createIterator();
	self.myIterUsedProduct			:=	self.allUsedProducts.createIterator();
	self.myIterTempRange			:=	self.allTempRanges.createIterator(); // ## PAR 9720
	self.myIterVoyage				:=	self.allVoyages.createIterator(); // ## PAR 9720
	self.myIteratorYardAllocations	:=	self.allYardAllocations.createIterator(); // ## PAR 9720
	self.myIterWeightRange			:=	self.allWeightRanges.createIterator(); // (11836) 27/09/2006 cnwmo1
	self.myIterStockBookRef			:=  self.allStockBookRefs.createIterator();
	self.myIterExportBookRef		:=  self.allExportBookRefs.createIterator();
	self.myIterRelease				:=  self.allReleases.createIterator();
	self.myIterCargoTypes			:=  self.allCargoTypes.createIterator();
	self.myIterTrain				:=  self.allTrains.createIterator();
	self.myIterDwellRange			:=	self.allDwellRanges.createIterator();	//20 Jul 2011	NDL	Par 27890
	self.myIterShippingLine 		:= self.allShippingLines.createIterator(); 	//06-06-2022 navtnr20 53204
	
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="fb26f2c4-0ea3-4592-97ff-e4fc912d68f6">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2003 by cnwrs2
//
// Purpose:     
// 06 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
begin
	self.myIterHazards	 		:=	self.allHazards.createIterator();
	self.myIterCommodity	 		:=	self.allCommodities.createIterator();
	self.myIterCommodityGroup 		:=	self.allCommodityGroups.createIterator();
	self.myIterConsignee 			:=	self.allConsignees.createIterator();
	self.myIterContentsStatus		:=	self.allContentsStatus.createIterator();
	self.myIterDischargePort		:=	self.allDischargePorts.createIterator();
	self.myIterISOType				:=	self.allISOTypes.createIterator();
	self.myIterISOTypeGroup			:=	self.allISOTypeGroups.createIterator();
	self.myIterLoadPort				:=	self.allLoadPorts.createIterator();
	self.myIterOperator				:=	self.allOperators.createIterator();
	self.myIterProduct				:=	self.allProducts.createIterator();
	self.myIterUsedProduct			:=	self.allUsedProducts.createIterator();
	self.myIterTempRange			:=	self.allTempRanges.createIterator();
	self.myIterVoyage				:=	self.allVoyages.createIterator();
	self.myIteratorYardAllocations	:=	self.allYardAllocations.createIterator();
	self.myIterWeightRange			:=	self.allWeightRanges.createIterator();  // (11836) 27/09/2006 cnwmo1 
	self.myIterStockBookRef			:=  self.allStockBookRefs.createIterator();
	self.myIterExportBookRef		:=  self.allExportBookRefs.createIterator();
	self.myIterRelease				:=  self.allReleases.createIterator();
	self.myIterCargoTypes			:=  self.allCargoTypes.createIterator();
	self.myIterTrain				:=  self.allTrains.createIterator();
	self.myIterDwellRange			:=	self.allDwellRanges.createIterator();	//20 Jul 2011	NDL	Par 27890
	self.myIterShippingLine 		:= self.allShippingLines.createIterator(); 	//06-06-2022 navtnr20 53204
	
	self.myRoot 					:=	app.myRoot;
	
	self.yardStackColours.clear;
	if app.myRoot.coloursForTALevels.isEmpty then
		 app.myRoot.createTALevelColours();
	endif;
 	app.myRoot.coloursForTALevels.copy(self.yardStackColours);

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="052558ad-dd5d-4175-ba54-a30d9f4dcf26">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.endNotificationForSubscriber(self);

	delete self.myIterCommodity;
	delete self.myIterCommodityGroup;
	delete self.myIterConsignee;
	delete self.myIterContentsStatus;
	delete self.myIterDischargePort;
	delete self.myIterISOType;
	delete self.myIterISOTypeGroup;
	delete self.myIterLoadPort;
	delete self.myIterOperator;
	delete self.myIterTempRange;
	delete self.myIterVoyage;
	delete self.myIteratorYardAllocations;
	delete self.myIterUsedProduct;
	delete self.myIterProduct;
	delete self.myIterStockBookRef;
	delete self.myIterExportBookRef;
	delete self.myIterRelease;
	delete self.myIterCargoTypes;
	//epr par 18417 3/11/08
	delete self.myIterHazards;
	delete self.myIterWeightRange;
	delete self.myIterTrain;
	
	self.allStockBookRefs.purge();
	self.allExportBookRefs.purge();
	self.allReleases.purge();
	self.allCargoTypes.purge();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSendNoteOnAdd" id="fd9202c7-bdc4-4046-bdfd-8acf1c8ac7c6">
        <source>doSendNoteOnAdd(_mode : Integer; _obj : Object) protected;
// ---------------------------------------------------------------------------
// Created:     07 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _mode &lt;&gt; self.modeForNoteOnAdd then
		return;
	endif;
	
	self.causeEvent(EVENT_DrawingAttrControllerAdd, true, _obj);

end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="formatForXML" id="cb6dfd0a-f0a4-4aa1-b1f2-ce6516a8e734">
        <source>formatForXML(_key : Integer; _code : String; _colour : Integer;_object : Object) : String protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	return	'&lt;' &amp; GridXML_ColourDtl &amp; '&gt;' &amp;
			'&lt;' &amp; GridXML_ColourKey &amp; '&gt;' &amp; _key.String &amp; '&lt;/' &amp; GridXML_ColourKey &amp; '&gt;' &amp;
			'&lt;' &amp; GridXML_ColourCode &amp; '&gt;' &amp; _code &amp; '&lt;/' &amp; GridXML_ColourCode &amp; '&gt;' &amp;
			'&lt;' &amp; GridXML_Colour &amp; '&gt;' &amp; _colour.String &amp; '&lt;/' &amp; GridXML_Colour &amp; '&gt;' &amp;
			'&lt;' &amp; GridXML_Object &amp; '&gt;' &amp; self.getOidStringForObject(_object) &amp; '&lt;/' &amp; GridXML_Object &amp; '&gt;' &amp;
			'&lt;/' &amp; GridXML_ColourDtl &amp; '&gt;';

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="Integer"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionForMode" id="e8be83bb-53f8-413d-934a-8f066ffbab2f">
        <source>getCollectionForMode(_mode : Integer) : MemberKeyDictionary;
// ---------------------------------------------------------------------------
// Created:     08 January 2004 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 30/08/2017	jlgdap1		TFS 5840 Add Contents Status mode
// 06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	theViewMode	: Integer;
//	tmpCode		: String;
//	tmpObj		: Object;
//	theColour	: Integer;	
begin
	theViewMode := _mode;

	if theViewMode = VIEW_OPERATOR then
		return self.allOperators;

	elseif theViewMode = VIEW_PRODUCT then
		return self.allProducts;

	elseif theViewMode = VIEW_VOYAGE then
		return self.allVoyages;

	elseif theViewMode = VIEW_TRAIN then
		return self.allTrains;

	elseif theViewMode = VIEW_TEMPERATURE then
		return self.allTempRanges;

	elseif theViewMode = VIEW_COMMODITY then
		return self.allCommodityGroups;

	elseif theViewMode = VIEW_WEIGHT then
		return self.allWeightRanges; // (11836) 27/09/2006 cnwmo1 
			//return null;

	elseif theViewMode = VIEW_CONSIGNEE then
		return self.allConsignees;

	elseif theViewMode = VIEW_DISPORT then
		return self.allDischargePorts;

	elseif theViewMode = VIEW_LOADPORT then
		return self.allLoadPorts;
	elseif theViewMode = VIEW_DESTPORT then
		return self.allDestinationPorts; //par 13694
//	elseif theViewMode = VIEW_STATUS then
//		theString := "Status";

	elseif theViewMode = VIEW_ISOGROUP and self.shipShowISOType then // TFS 37556
		return self.allISOTypes; // TFS 37556
	elseif theViewMode = VIEW_ISOGROUP then
		return self.allISOTypeGroups;
	elseif theViewMode = VIEW_PRODUCT then
		return self.allUsedProducts;
		
//	elseif theViewMode = VIEW_JOB then
//		theString := "Job";		

	elseif theViewMode = VIEW_YARD_ALLOC then // #25222 29/07/2010
		return self.allYardAllocations;	// there are Voyage Allocations (CM_VoyageAlloaction) for a voyage
	
	//20 Jul 2011	NDL	Par 27890
	elseif theViewMode = VIEW_DWELL_DAYS then
		return self.allDwellRanges;	
	//29 Jul 2011	NDL	Par 27890
	elseif theViewMode = VIEW_MTGRADE then
		return self.allAvailGrades;	
	elseif theViewMode = VIEW_CARRIERIN then	// 9/6/17 MAP TFS4209
		return self.allCarriersIn;
	elseif theViewMode = VIEW_CARRIEROUT then	// 9/6/17 MAP TFS4209
		return self.allCarriersOut;
		
	elseif theViewMode = VIEW_STATUS then				// TFS 5840
		return self.allContentsStatus;					// TFS 5840
		
	elseif theViewMode = VIEW_SHIPPINGLINE then
		return self.allShippingLines;		//06-06-2022 navtnr20 53204
		
	endif;
	
	return null;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="MemberKeyDictionary"/>
    </JadeMethod>
    <JadeMethod name="getColourForCC" id="9a949585-6416-41e1-9f3b-f4aebb69c835">
        <source>getColourForCC(_mode : Integer; _sr : CM_SlotRequest) : Integer;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theViewMode	: Integer;
	tmpCode		: String;
	tmpObj		: Object;
	theColour	: Integer;	
	theVoyage : CM_Voyage;
	isoGrp : CM_ISOTypeGroup;
	isoType : CM_ISOType;
	commodity : CM_CommodityGroup;
begin

	theColour	:= NullColour;
	
	if _sr = null then
		return theColour;
	endif;

	theViewMode := _mode;
	if _sr.myBay &lt;&gt; null then
		theVoyage := _sr.myBay.myCellularVoyageStructure.myVoyage;
		
		if theVoyage = null then
			return theColour;
		endif;		
	else
		return theColour;
	endif;
	if theViewMode = VIEW_VOYAGE then
		self.handleVoyage(theVoyage.code, theVoyage, null, tmpCode, theColour, tmpObj);
	elseif theViewMode = VIEW_TEMPERATURE then
	elseif theViewMode = VIEW_COMMODITY then
		commodity := _sr.getAttrCommodityGroup(); // TFS 37556
		
		if commodity &lt;&gt; null then // TFS 37556
			self.handleCommodityGroup(commodity.code, tmpCode, theColour, tmpObj); // TFS 37556
		endif;



	elseif theViewMode = VIEW_WEIGHT then
	elseif theViewMode = VIEW_CONSIGNEE then
		self.handleConsignee(_sr.consigneeCode, tmpCode, theColour, tmpObj);
	elseif theViewMode = VIEW_DISPORT then
		self.handleDischargePort(_sr.dischargePort, tmpCode, theColour, tmpObj);

	elseif theViewMode = VIEW_LOADPORT then
	elseif theViewMode = VIEW_STATUS then
	elseif theViewMode = VIEW_ISOGROUP and self.shipShowISOType then // TFS 37556
		isoType := _sr.getAttrISOType();
		if isoType &lt;&gt; null then
			self.handleISOType(isoType.code, tmpCode, theColour, tmpObj);
		endif;
	elseif theViewMode = VIEW_ISOGROUP then // TFS 37556
		isoGrp := _sr.getAttrIsoGroup();
		if isoGrp &lt;&gt; null then
			self.handleISOTypeGroup(isoGrp.code, tmpCode, theColour, tmpObj);
		endif;
	endif;
	
	
// PAR 23426	if _sr.allAllocations.size() &gt; 0 then			//cnwas3 ccms 1028
//		theColour := _sr.allAllocations.first().CM_VoyageAllocation.color;		
//	endif;
	
	return theColour;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_sr" type="CM_SlotRequest"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColourForMode" id="1ce7d579-4cb8-4fa4-be98-f5f663b2cf2d">
        <updating/>
        <source>getColourForMode(_mode : Integer; _ti : CM_TrackedItem; _viewModeCode : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2004 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 12/10/2009	cnwmh5		PAR 21297 - Change so that where temperature is -273
//										it shows as white.
//	19/5/2022 navtnr20 		ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars

	theViewMode	: Integer;
	tmpCode		: String;
	tmpObj		: Object;
	theColour	: Integer;
	
begin

	theColour	:= NullColour;
	
	if _ti = null then
		return theColour;
	endif;

	theViewMode := _mode;

	if theViewMode = VIEW_OPERATOR then
		self.handleOperator(_ti.operatorCode, _ti.myOperator, _viewModeCode, tmpCode, theColour, tmpObj);

	elseif theViewMode = VIEW_HEIGHT then
		
	elseif theViewMode = VIEW_HAZ then
		if not _ti.allTIHazards.isEmpty then
			self.handleHazards(_ti.allTIHazards.first.code, tmpCode, theColour, tmpObj);
		else
			theColour := White;
		endif;
	elseif theViewMode = VIEW_DWELL then
		if _ti.isDaysSinceReceival(self.number1, true) then
			theColour := Red;
		else
			theColour := Blue;
		endif;
		
	//20 Jul 2011	NDL	Par 27890
	elseif theViewMode = VIEW_DWELL_DAYS then
		handleDwellDayRange( _ti, theColour );
	
	//29 Jul 2011	NDL	Par 27890
	elseif theViewMode = VIEW_MTGRADE then
		handleMTGrade( _ti, theColour );	
		
	elseif theViewMode = VIEW_IMEX then
		return app.myRoot.allImexStatuses[_ti.getImExStatus()].colour;
	elseif theViewMode = VIEW_VOYAGE then
		self.handleVoyage(_ti.voyageCode, _ti.myVoyage, _viewModeCode, tmpCode, theColour, tmpObj);
	elseif theViewMode = VIEW_TRAIN then
		self.handleTrain(_ti.myTrainAssigned, tmpCode, theColour, tmpObj);

	elseif theViewMode = VIEW_TEMPERATURE then
		if CM_Container.hasInstance(_ti) then
			// 12/10/2009 mhill #21297 - Start
			if _ti.CM_Container.getTemperature = -273 then
				theColour := White;
			else
				self.handleTempRange(_ti.CM_Container.getTemperature, tmpCode, theColour, tmpObj);
			endif;
			//self.handleTempRange(_ti.CM_Container.temperature, tmpCode, theColour, tmpObj);
			// 12/10/2009 mhill #21297 - End
		endif;

	elseif theViewMode = VIEW_COMMODITY then
		self.handleCommodityGroup(_ti.commodity, tmpCode, theColour, tmpObj);

	elseif theViewMode = VIEW_WEIGHT then
		self.handleWeightRange(_ti.totalWeight, tmpCode, theColour, tmpObj);

	elseif theViewMode = VIEW_CONSIGNEE then
		self.handleConsignee(_ti.consignee, tmpCode, theColour, tmpObj);

	elseif theViewMode = VIEW_DISPORT then
		self.handleDischargePort(_ti.dischargePort, tmpCode, theColour, tmpObj);

	elseif theViewMode = VIEW_LOADPORT then
		self.handleLoadPort(_ti.loadPort, tmpCode, theColour, tmpObj);
	elseif theViewMode = VIEW_DESTPORT then //epr 22/3/07 par 13964
	
		self.handleDestinationPort(_ti.destinationPort,tmpCode,theColour,tmpObj);
		
	elseif theViewMode = VIEW_STATUS then
		if CM_Container.hasInstance(_ti) then
			self.handleContentsStatus(_ti.CM_Container.contentsStatus, tmpCode, theColour, tmpObj);
		endif;

	elseif theViewMode = VIEW_ISOGROUP and self.shipShowISOType then
		self.handleISOType(_ti.getISOType, tmpCode, theColour, tmpObj);

	elseif theViewMode = VIEW_ISOGROUP then
		self.handleISOTypeGroup(_ti.getISOType, tmpCode, theColour, tmpObj);
	elseif theViewMode = VIEW_PRODUCT then
		if _ti.myProduct &lt;&gt; null then
			self.handleProduct(_ti.myProduct.code, _ti.myProduct, _viewModeCode, tmpCode, theColour, tmpObj);
		endif;

	elseif theViewMode = VIEW_BOOKREF_EXPORT then
		self.handleBookRefExport(_ti, tmpCode, _viewModeCode, theColour, tmpObj);
		
	elseif theViewMode = VIEW_RELEASE_REQUEST then
		if _ti.allBulkReleasesAssigned.first &lt;&gt; null then
			self.handleRelease(_ti.allBulkReleasesAssigned.first, _viewModeCode, tmpCode, theColour, tmpObj);
		endif;

	elseif theViewMode = VIEW_BOOKREF_STOCK then
		if _ti.myBookingRef &lt;&gt; null and _ti.myBookingRef.isStockBookingRef then
			self.handleBookRefStock(_ti.myBookingRef, tmpCode, _viewModeCode, theColour, tmpObj);
		endif;
	
	elseif theViewMode = VIEW_CARGO_TYPE then
		self.handleCargoType(_ti.myCargoType, tmpCode, _viewModeCode, theColour, tmpObj);

	elseif theViewMode = VIEW_CARRIERIN then		// 9/6/17 MAP TFS4209
		self.handleCarrierIn(_ti.carrier, tmpCode, theColour, tmpObj);
	elseif theViewMode = VIEW_CARRIEROUT then		// 9/6/17 MAP TFS4209
		self.handleCarrierOut(_ti.releaseCarrier, tmpCode, theColour, tmpObj);

	elseif theViewMode = VIEW_SHIPPINGLINE then		//19-may-2022 navtnr20 TFS 53204
		handleShippingLine(_ti.getShippingLineCode(), _ti.myShippingLine, _viewModeCode, tmpCode, theColour, tmpObj); //13/07/2022 navgm20 Tfs 53195
	endif;

	//epr par 26889 9/2/2011
	if theColour = NullColour then
		theColour:=White;
	endif;
	
	return theColour;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_viewModeCode" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleBookRefExport" id="facf6ad8-c062-448b-83c9-2b82f3c5a63a">
        <source>handleBookRefExport(trackedItem: CM_TrackedItem; _code : String output; _viewModeCode : String; _color :Integer output; _object : Object output) protected;
// If this tracked Item has a export booking reference then add the ref to the list for the legend frame
// Anything that is not a Stock Booking ref and has a bookingReference is treated as an Export
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	theObject : Object;
	bookingReference : String;
	viewObjectColour : CM_ViewObjectColour;
	
begin
	bookingReference := trackedItem.bookingReference;
	trimCode := bookingReference.trimBlanks;

	if trimCode = null or trackedItem.getStockBookingReference() &lt;&gt; null or
	   (_viewModeCode &lt;&gt; null and _viewModeCode &lt;&gt; trimCode) then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;

	theCode		:= null;
	theColor	:= NullColour;

	iter := self.myIterExportBookRef;
	self.allExportBookRefs.startKeyGeq(trimCode, 0, iter);
	self.allExportBookRefs.getIteratorKeys(codeKey, colorKey, iter);

	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		create viewObjectColour transient;
		viewObjectColour.code := bookingReference;
		viewObjectColour.colour := self.allExportBookRefs.size.colourSpread();
		viewObjectColour.myObject := trackedItem.myBookingRef;
		self.allExportBookRefs.add(viewObjectColour);
		theCode	:= viewObjectColour.code;
		theColor := viewObjectColour.colour;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;
end;</source>
        <access>protected</access>
        <Parameter name="trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_viewModeCode" type="String"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleBookRefStock" id="2fe61e98-dc42-457c-8a04-4c7e20dc2a3e">
