    <JadeMethod name="jhpAnalyseCompare" id="ecd3b2c5-7f6b-4aa4-b9a4-aec639cea40f">
        <updating/>
        <source>jhpAnalyseCompare(folder:String; filenum:Integer) updating;

vars
	aa:Analysis;
	s,statsfile1,statsfile2:String;
begin
	create aa;
	aa.inFile.fileName:=folder&amp;"\cn_tranlog_"&amp;filenum.String&amp;".csv";
	aa.inFile.usePresentationFileSystem:=true;
	statsfile1:=aa.analyseTranLog;
	delete aa;
	
	create aa;
	aa.inFile.fileName:=folder&amp;"\cn_tranlog_"&amp;(filenum+1).String&amp;".csv";
	aa.inFile.usePresentationFileSystem:=true;
	statsfile2:=aa.analyseTranLog;
	delete aa;/**/
	
	create aa;
	aa.compareStatsFiles(statsfile1, statsfile2);
epilog
	delete aa;
end;</source>
        <Parameter name="folder" type="String"/>
        <Parameter name="filenum" type="Integer"/>
    </JadeMethod>
