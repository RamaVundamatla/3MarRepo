    <JadeMethod name="getId" id="bec06e92-5a02-4b92-b82d-3baca94f34ea">
        <source>getId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars
	str			  : String;
	reserveDetail : CM_ReserveDetail;
	bulkRelease   : CM_BulkRelease;
	isoType		  : String;
	cargoType     : CM_CargoType;
	cargoGrp	  : String;
begin
	
	reserveDetail := self.myReserveDetail;
	
	if reserveDetail &lt;&gt; null then
		bulkRelease := reserveDetail.myReserveHeader;
		if bulkRelease &lt;&gt; null then
			str := bulkRelease.myOperator.code;
		endif;
		
		isoType := self.getISOType;
		
		if isoType &lt;&gt; null then
			return str &amp; Space &amp; isoType;
		endif;
		
		cargoType := self.getCargoType;
		
		if cargoType &lt;&gt; null then
			str :=  str &amp; Space &amp; cargoType.abbreviation;
		endif;
		cargoGrp := reserveDetail.getMyCargoGroupId();
		if cargoGrp &lt;&gt; null then
			str :=  str &amp; Space &amp; cargoGrp;
		endif;
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseNumber" id="3e24f4fe-e26b-49f3-93b6-72e9fe395715">
        <source>getReleaseNumber(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars
	wod				: CM_WorkOrderTIDtl;
	job 			: CM_Job;
	releaseRequest	: CM_BulkRelease;
begin
	if self.myReserveDetail &lt;&gt; null then
		return self.myReserveDetail.myReserveHeader.code;
	else
		job := self.myJob;
		if job &lt;&gt; null then
			wod := job.myWODtl;
			if wod &lt;&gt; null then
				releaseRequest := wod.CM_WodRelease.myReleaseRequest;
				if releaseRequest &lt;&gt; null then
					return releaseRequest.code;
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
