    <JadeMethod name="rel821_par31965" id="1015bab1-89cc-48bd-aca1-93e53f6c1856">
        <source>rel821_par31965();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	vessel : CM_Vessel;
	voyage : CM_Voyage;
	transAgent : CM_TranslationAgent;
	tmpArray : StringArray;

begin

	app.initialize();
	
	create transAgent transient;
	create tmpArray transient;
	
	tmpArray.add('Invalid_GC_structure');
	tmpArray.add('Voyage_GC_LocID_max');
	tmpArray.add('Must_enter_name');
	tmpArray.add('Loactio_already_defined_hold');
	tmpArray.add('Hold');
	tmpArray.add('Location_name');
	transAgent.trxLoadSpecificErrors(tmpArray);

	foreach vessel in CM_Vessel.instances do
		if vessel.myGeneralCargoVesselStructure &lt;&gt; null then
			vessel.myGeneralCargoVesselStructure.convertToUseHoldLocnDefns();
		endif;	
	endforeach;
	
	foreach voyage in CM_Voyage.instances do
		if voyage.myGeneralCargoVoyage &lt;&gt; null then
			voyage.myGeneralCargoVoyage.convertToPopulateLocnDefnNames();
		endif;	
	endforeach;
	
	return;
	
	write Invalid_GC_structure;
	write Voyage_GC_LocID_max;
	write Must_enter_name;
	write Loactio_already_defined_hold;
	write Hold;
	write Location_name;

epilog

	delete tmpArray;
	delete transAgent;

end;</source>
    </JadeMethod>
    <JadeMethod name="rel821_par31975" id="79cbf36b-f6ab-472d-bebb-3461d5c838e1">
        <source>rel821_par31975();
//
// Purpose:			Look for duplicate measurement type names and shortNames and 
//					attempt to do something with them
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/07/2013	cnwdap1		Initial creation PAR #31975
//
vars
	allMeasures		: DynaDictionary;
	measure 		: CM_MeasurementType;
	duplicates		: StringArray;
	lastShortName	: String;
	lastName		: String;
	name			: String;
	foundOne		: Boolean;
	newShortName	: String;
	newName			: String;
	obj				: Object;
	fixes			: Integer;

begin
	app.initialize();
	create duplicates transient;
	
	create allMeasures transient;
	allMeasures.setMembership(CM_MeasurementType);
	allMeasures.addMemberKey(CM_MeasurementType::shortName.name, false, true);
	allMeasures.endKeys(true);
	
	beginTransaction;
	foreach measure in app.myRoot.allMeasurementTypesByShortName do
		allMeasures.add(measure);
	endforeach;
	foreach obj in allMeasures do
		measure := obj.CM_MeasurementType;
		if measure.shortName.toUpper = lastShortName.toUpper then
			duplicates.add(measure.shortName);
			if not duplicates.includes(lastShortName) then
				duplicates.add(lastShortName);
			endif;
		else	
			// do something with the duplicates
			foundOne := false;
			fixes := null;
			foreach name in duplicates do
				measure := app.myRoot.allMeasurementTypesByShortName[name];
				if not measure.isDefault then
					foundOne := true;
					if measure.shortName.length &gt; 8 then
						newShortName := measure.shortName[1:8] &amp; "_" &amp; fixes.String;
					else
						newShortName := measure.shortName &amp; "_" &amp; fixes.String;
					endif;
					measure.setPropertyValue(CM_MeasurementType::shortName.name, newShortName);
					write "setting " &amp; measure.shortName &amp; " name to " &amp; newShortName;
					fixes := fixes + 1;
					if (fixes + 1) = duplicates.size then
						break;
					endif;
				endif;
			endforeach;
			duplicates.clear;
		endif;
		lastShortName := measure.shortName;
	endforeach;
	commitTransaction;
epilog
	delete duplicates;
	delete allMeasures;
end;</source>
    </JadeMethod>
