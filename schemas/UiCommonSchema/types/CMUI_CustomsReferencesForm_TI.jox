    <JadeMethod name="create" id="8689937d-bd50-44ad-a5c9-8ccb95da6128">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 November 2022	navpw1	Initial creation TFS: 55215
20 March 2024		navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

*/

begin
	self.permissionView 	:= PmAdmCargoEnquiryView;
	self.permissionMaint 	:= PmAdmCustomsRefsMaint;
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectedItem" id="439733c5-023a-41fb-9633-810bebc71d3c">
        <updating/>
        <source>displaySelectedItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable
08 April 2024	navlw1 	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode
*/

vars
	customsReference 	: CM_CustomsReference;
	readOnly			: Boolean;
begin
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	//navlw1 #63566
	if self.mode &lt;&gt; self.Mode_View then
		readOnly := true;
	endif;
	
	// get the selected customs reference
	customsReference := self.tblData.accessRow(self.tblData.row).itemObject.CM_CustomsReference;
	if customsReference = null then
		return;
	endif;
	
	self.txtRefType.text 			:= customsReference.referenceType;
	self.txtRefNum.text 			:= customsReference.referenceNumber;
	self.txtPosNum.text 			:= customsReference.positionNumber.asStringJMT;
	self.txtStatus.text				:= customsReference.status;
	self.txtObjectName.text			:= customsReference.objectName;
	self.txtCustomsControl.text 	:= customsReference.customsContol;
	self.txtRemPackages.text		:= customsReference.packagesRemaining.asStringJMT;
	self.txtTotPackages.text		:= customsReference.packagesTotal.asStringJMT;
	self.dtRententionPeriod.text 	:= customsReference.retentionPeriod.asStringJMT;
	
	self.setSelectedItem(customsReference);
	
	// enabled the buttons based on permission
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) or readOnly then
		self.btnRemove.enabled := false;
		self.btnUpdate.enabled := false;
		self.frmControls.enabled := false;
	else
		self.btnRemove.enabled := true;
		self.btnUpdate.enabled := true;
		self.frmControls.enabled := true;
	endif;
	
	// cannot change these fields unless we are creating a new customs reference
	if self.txtPosNum.text = '0' then
		self.txtPosNum.enabled := true;
	else
		self.txtPosNum.enabled := false;
	endif;
	if self.txtRefType.text &lt;&gt; null then
		self.txtRefType.enabled := false;
	endif;
	if self.txtRefNum.text &lt;&gt; null then
		self.txtRefNum.enabled := false;
	else
		self.txtRefNum.enabled := true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="2ee1e8c8-32f7-4119-ae5b-f3ccbaa28fdd">
        <updating/>
        <source>doCancel() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

