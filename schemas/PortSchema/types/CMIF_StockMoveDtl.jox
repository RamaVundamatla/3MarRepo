    <JadeMethod name="addStockMovement" id="c4b47a84-242d-4d55-9b0a-b85528c6af41">
        <updating/>
        <source>addStockMovement(_stkMove : CM_StockMovement) updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _stkMove.isInwards then
		self.qtyIn := self.qtyIn + _stkMove.adjustQuantity;
		self.volIn := self.volIn + _stkMove.adjustVolume;
		self.weightIn := self.weightIn + _stkMove.adjustWeightKgs;
		self.allStockMovementsIn.add(_stkMove);
	else
		self.qtyOut := self.qtyOut + (_stkMove.adjustQuantity * -1);
		self.volOut := self.volOut + (_stkMove.adjustVolume * -1);
		self.weightOut := self.weightOut + (_stkMove.adjustWeightKgs * -1);

		self.allStockMovementsOut.add(_stkMove);
	endif;
	
end;</source>
        <Parameter name="_stkMove" type="CM_StockMovement"/>
    </JadeMethod>
    <JadeMethod name="formatQty" id="cba0921e-c436-4ab2-bd57-409d8ccfda5d">
        <source>formatQty(_value : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _value = 0 then
		return null;
	endif;

	return _value.String;

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatVol" id="d414fe67-93b9-4e76-9d96-0488fc3421ea">
        <source>formatVol(_value : Decimal) : String;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _value = 0 then
		return null;
	endif;

	return _value.jasVolumeString;		// does to 3 decimal places

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatWeight" id="505fe62b-2c35-44ce-84c9-59c857b42d07">
        <source>formatWeight(_value : Decimal) : String;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _value = 0 then
		return null;
	endif;

	//return _value.String; // cnwrd1 par 20165 -- 1.7.09
	return _value.asStringWeightJMT();  // cnwrd1 par 20165 ++ 1.7.09

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStr" id="42370792-60c2-4629-8d2a-76f9c684b302">
        <source>getDisplayStr() : String;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return	self.formatQty(self.qtyIn) &amp; Tab &amp;
			self.formatQty(self.qtyOut) &amp; Tab &amp;
			self.formatQty(self.qtyNet) &amp; Tab &amp;
				
			self.formatVol(self.volIn) &amp; Tab &amp;
			self.formatVol(self.volOut) &amp; Tab &amp;
			self.formatVol(self.volNet) &amp; Tab &amp;
				
			self.formatWeight(self.weightIn) &amp; Tab &amp;
			self.formatWeight(self.weightOut) &amp; Tab &amp;
			self.formatWeight(self.weightNet);


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIsForStockMoveIn" id="d19d6aea-7ecd-4779-be84-b134f491fd67">
        <source>getTIsForStockMoveIn(_col : Collection input);
/* ---------------------------------------------------------------------------
Created:     26 June 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	stkMove	: CM_StockMovement;
	
begin
	foreach stkMove in self.allStockMovementsIn do
		stkMove.getTIs(_col);
	endforeach;
epilog

end;</source>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIsForStockMoveOut" id="c4a38220-b5be-4091-84bc-e56367a7fcc5">
        <source>getTIsForStockMoveOut(_col : Collection input);
/* ---------------------------------------------------------------------------
Created:     26 June 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	stkMove	: CM_StockMovement;
	
begin
	foreach stkMove in self.allStockMovementsOut do
		stkMove.getTIs(_col);
	endforeach;
epilog

end;</source>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="qtyNet" id="8ad9a199-9a97-48ef-933f-554d4f79d293">
        <methodInvocation>mapping</methodInvocation>
        <source>qtyNet(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.qtyIn - self.qtyOut;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
