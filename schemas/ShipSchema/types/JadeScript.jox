    <JadeMethod name="readFile" id="0908f9b8-0879-4473-ab61-3c55909981a4">
        <source>readFile();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theXMLCompressed	: Binary;
	theXML				: String;
	theXMLString		: String;
	fileXML				: CMDFileOpen;
	theXMLFile			: File;
	
begin
	create fileXML;
	fileXML.filter := "All Files (*.*)|*.*";
	
	if fileXML.open() = 0 then
		create theXMLFile;
		theXMLFile.fileName := fileXML.fileName;
		
		// use these if not compressed
//		theXMLFile.maxRecordSize := 750000;
//		theXML := theXMLFile.readLine();
		
		// use these if compressed
		theXMLFile.kind := File.Kind_Binary;
		theXMLCompressed := theXMLFile.readBinary(theXMLFile.fileLength());
// cnwdad1 25/02/2009 - PAR #18366.
//		theXML := theXMLCompressed.uncompressString();
		theXML := theXMLCompressed.uncompressToStringJMT();
		
		write theXML;
	else
		return;
	endif;
epilog
	if theXMLFile &lt;&gt; null then
		delete theXMLFile;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="testForm" id="c8a6b784-db8d-4595-b7ef-d3819514c491">
        <source>testForm();

vars
	form : SHP_SummaryReports;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	create form transient;
	form.tblEnt.columns := 5;
	form.show;
end;
</source>
    </JadeMethod>
