		theArea.editMode := false;	
		self.mySDF.drawSelf();
	endif;

	self.displayTermSubArea(self.myCurrentTermSubArea);

epilog
	delete self.myProxyTermSubArea;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
