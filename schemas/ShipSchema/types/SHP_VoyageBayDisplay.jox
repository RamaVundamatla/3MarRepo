Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	_value:=self.myProxyBay.CM_BayVoyage;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_BayVoyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setBay" id="e244a15d-b439-4dbb-a5b1-217a9e78736e">
        <updating/>
        <source>setBay(_bay: CM_BayVoyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	self.myBay:=_bay;
	self.myCellularVoyageStructure:=_bay.myCellularVoyageStructure;
epilog

end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
    </JadeMethod>
    <JadeMethod name="setFormPermissions" id="de126a8d-ebdf-4647-856c-cf6fd8845b72">
        <source>setFormPermissions(_form: CM_BaseForm io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	_form.setPropertyValue(CM_BaseForm::permissionView.name,PmVoyageBayDefView);
	_form.setPropertyValue(CM_BaseForm::permissionMaint.name,PmVoyageBayDefMaint);
	_form.setPropertyValue(CM_BaseForm::helpFileName.name,HelpFile_Voyage);

epilog

end;</source>
        <Parameter name="_form" type="CM_BaseForm" usage="io"/>
    </JadeMethod>
</Class>
