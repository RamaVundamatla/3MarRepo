    <JadeMethod name="setComboValues" id="1a40d3ef-754b-43ec-a0ec-3e98b08fa481">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN 

*/

vars
	carrier			: CM_Carrier;
	selectStr		: String;
	storeIdx		: Integer;
	idx				: Integer;
	selectedCarrier : CM_Carrier;
begin
	_combo.clear();	
	_combo.sorted := true;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;

	foreach carrier in app.myRoot.allSubCarriersRoad  do
	
		idx := _combo.addItem(carrier.code &amp;' - ' &amp; carrier.description.toUpper());
		_combo.itemObject[idx] := carrier;
					
		if carrier.code = selectStr then
			selectedCarrier := carrier;
		endif;		
	endforeach;
	
	storeIdx  := _combo.findObject(selectedCarrier);
	
	if storeIdx &gt; 0 and storeIdx &lt; _combo.listCount then
		_combo.listIndex := storeIdx;
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="1b8dcea7-eabe-433d-9f24-1c02c1674548">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN 

*/

vars
	carrier			: CM_Carrier;
	selectionValue	: Integer;
	idx				: Integer;
	array			: ObjectArray;
begin
	
	table.rows := table.fixedRows;
	table.sortColumn[1] := 2;
	table.sortAsc[1] := true;
	
	array := table.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach carrier in app.myRoot.allSubCarriersRoad  do	
	
		selectionValue := 0;
		if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(carrier.code) then
			selectionValue := 1;
			array.add(carrier);
		endif;
	
		idx := table.addItem(selectionValue.String &amp; Tab  &amp; carrier.code &amp; ' - ' &amp; carrier.description.toUpper());
		table.accessRow(idx).itemObject := carrier;
	endforeach;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="902a0514-b0f4-429c-9c9a-e6131bdb6792">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN 

*/

vars
	carrier		: CM_Carrier;
	str			: String;
	numRows		: Integer;
	idx			: Integer;
	strArray	: StringArray;

begin

	create strArray transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			carrier := table.accessRow(idx).itemObject.CM_Carrier;
			strArray.add(carrier.code);
		endif;
	endforeach;
	
	queryOperator.setSearchValue(strArray);

epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="d0d7ea70-353f-4179-b76d-7a99b3442b81">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN 

*/

vars

begin
	if _value.isKindOf(CM_Carrier) then
		if _value &lt;&gt; null then
			return _value.CM_Carrier.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="11f4155c-1e60-4cf1-a739-2b643e2f4a16">
        <source>translateToSearchValue(value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN 

*/

vars
	invalidObj 	: Boolean;
	carrier		: CM_Carrier;
	returnVal	: String;
	
begin
	if value &lt;&gt; null then
		if value.isKindOf(Collection) then			
			return value;
		endif;

		if value.isKindOf(CM_Carrier) then
			carrier := value.CM_Carrier;
		endif;
	endif;
	
	if carrier &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, carrier, invalidObj);
		
		returnVal := carrier.code;
	endif;
	
	return returnVal;
end;</source>
        <Parameter name="value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="7d8e3dfc-37f0-4174-bd95-7e2f0dca71d1">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN 

*/

vars
str, rtnVal : String;
	strArray : StringArray;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			rtnVal := rtnVal &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnVal := rtnVal[1:rtnVal.length-2];
		return rtnVal;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		return _value.String;
		
	endif;
	
	return inheritMethod(_value, _sending);
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
