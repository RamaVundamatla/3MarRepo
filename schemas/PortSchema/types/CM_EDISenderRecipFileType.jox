    <JadeMethod name="clear" id="9d973329-9c26-42e8-b8bd-751c6a92e42c">
        <updating/>
        <source>clear() updating;
//
//18 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars

begin
	self.allSenderRecipFileTypeHist.purge();
	self.fileDateTime := null;
	self.fileVersion := null;
	self.lastFileName := null;
	self.seqNumber := null;
end;
</source>
    </JadeMethod>
    <JadeMethod name="delete" id="9d2d8431-f528-4d65-8360-d9f0d0310d06">
        <updating/>
        <source>delete() updating;
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	
begin
	self.allSenderRecipFileTypeHist.purge();
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setFileDetails" id="83193a04-13aa-49b2-8b35-4760e28c9735">
        <updating/>
        <source>setFileDetails(_fileDateTime : TimeStamp; _lastFileName : String; _seqNumber : String; _fileVersion : String) updating;
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
// 15 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
vars

	begin
	self.fileDateTime := _fileDateTime;
	self.lastFileName := _lastFileName[1:60];
	self.seqNumber := _seqNumber;
	self.fileVersion := _fileVersion;
end;
</source>
        <Parameter name="_fileDateTime" type="TimeStamp"/>
        <Parameter name="_lastFileName" type="String"/>
        <Parameter name="_seqNumber" type="String"/>
        <Parameter name="_fileVersion" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2e4b8c5b-fef3-4dab-999c-6b24c6a42467">
        <updating/>
        <source>setForCreate(_ediSenderRecipFileType : CM_EDISenderRecipFileType; _ediData : CM_EDIData) updating;
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars

begin
	_ediSenderRecipFileType.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_ediSenderRecipFileType, _ediData);
	self.myTerminal := _ediSenderRecipFileType.myTerminal;
end;</source>
        <Parameter name="_ediSenderRecipFileType" type="CM_EDISenderRecipFileType"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="33898f12-6430-41f8-b2c2-9e2c4fae0724">
        <updating/>
        <source>setForUpdate(_ediSenderRecipFileType : CM_EDISenderRecipFileType; _ediData : CM_EDIData) updating;
//
//18 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	ediSenderRecipFileTypeHist : CM_EDISenderRecipFileTypeHist;
begin
	self.fileDateTime := _ediSenderRecipFileType.fileDateTime;
	self.fileType := _ediSenderRecipFileType.fileType;
	self.fileVersion := _ediSenderRecipFileType.fileVersion;
	self.lastFileName := _ediSenderRecipFileType.lastFileName;
	self.recipient := _ediSenderRecipFileType.recipient;
	self.sender := _ediSenderRecipFileType.sender;
	self.processInDateOrder := _ediSenderRecipFileType.processInDateOrder; 
	self.processInSeqOrder := _ediSenderRecipFileType.processInSeqOrder;
	self.seqNumber := _ediSenderRecipFileType.seqNumber;
	if not self.isTransient then
		create ediSenderRecipFileTypeHist;
		ediSenderRecipFileTypeHist.setFileDetails(self.fileDateTime, self.lastFileName, self.seqNumber, _ediSenderRecipFileType.fileVersion, _ediData);
		self.allSenderRecipFileTypeHist.add(ediSenderRecipFileTypeHist);
	endif;
end;
</source>
        <Parameter name="_ediSenderRecipFileType" type="CM_EDISenderRecipFileType"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
