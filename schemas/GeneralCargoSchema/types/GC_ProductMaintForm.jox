    <JadeMethod name="loadValidations" id="2d20cd65-d849-4123-a294-f60efabea79b">
        <source>loadValidations(_prodAttr : CM_ProductAttr);
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	valString		: String;
	
begin
	
	self.tblAttributes.accessCell(self.tblAttributes.row, 4).cellControl := self.cmbValidation;
	
	self.cmbValidation.clear();
	
	foreach valString in _prodAttr.allValidationTypes do
		self.cmbValidation.addItem(valString);
	endforeach;
	
	self.cmbValidation.text := _prodAttr.validationType;
	self.tblAttributes.setCellText(self.tblAttributes.row, self.tblAttributes.getColumnByRowName(ETRow_ValidationType), _prodAttr.validationType);


end;</source>
        <Parameter name="_prodAttr" type="CM_ProductAttr"/>
    </JadeMethod>
