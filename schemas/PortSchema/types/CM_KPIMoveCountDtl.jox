        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="updatePlannedFromVoyage" id="18ba3a46-ed06-4e35-9e46-c3c71c1e6e97">
        <updating/>
        <source>updatePlannedFromVoyage(_voyage : CM_Voyage; _stats : CMIF_VoyageStats) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2012	cnwdw1	Initial creation
*/
vars
	
begin	
	self.loadMoveCount := _stats.plannedLoad;
	self.dischargeMoveCount := _stats.plannedDischarge;
	self.moveCount := _stats.movesCompleted + _stats.movesIncomplete;
	
	//self.loadMoveCount := _voyage.getLoadMoveCount;
	//self.dischargeMoveCount := _voyage.getDischargeMoveCount;
	//self.moveCount := self.loadMoveCount + self.dischargeMoveCount;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_stats" type="CMIF_VoyageStats"/>
    </JadeMethod>
</Class>
