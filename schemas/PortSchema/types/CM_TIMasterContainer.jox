    <JadeMethod name="isStopValid" id="ab12122b-e6a8-43c0-8960-8b2d5408c93a">
        <source>isStopValid(_theStop: CM_StopsTable): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2008	cnwrd1	Initial creation
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/


vars
	cargoTypeObj	: CM_CargoType;
	criteria 		: CM_YACriteria;	//	20 Jul 2022	navsj20	TFS 53862
begin
	
	
	cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoType];

	// START 20 Jul 2022	navsj20	TFS 53862
	//return _theStop.allCargoTypesNew.includes(cargoTypeObj);			
	if _theStop.myStopCriteria &lt;&gt; null then  
		foreach criteria in _theStop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do	// END 27 Jul 2022	navsj20	TFS 53862
			return criteria.myYAData.CM_YADataObjects.allObjects.includes(cargoTypeObj);	
		endforeach;//27 Jul 2022	navsj20	TFS 53862
	endif;
	// END 20 Jul 2022	navsj20	TFS 53862
	
epilog

end;</source>
        <Parameter name="_theStop" type="CM_StopsTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToDoTaskValid" id="cffc0cc4-79c0-4c74-889e-357ec67d4642">
        <source>isToDoTaskValid(_toDoTaskDesc: CM_ToDoTaskDesc): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2008	cnwrd1	Initial creation

*/

vars
	cargoTypeObj	: CM_CargoType;
begin

	if not self.isToDoTaskValidForGenSet( _toDoTaskDesc ) then	//Par 18032. Jan 2009
		return false;
	endif;
	
	cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoType];

	return _toDoTaskDesc.allCargoTypes.includes(cargoTypeObj);

epilog

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToDoTaskValidForGenSet" id="c47147bc-6c48-49e6-85ac-04fdf0683cc2">
        <source>isToDoTaskValidForGenSet( _task : CM_ToDoTaskDesc ) : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	23 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cont : CM_Container;

begin

	if _task.trxTypeOnCompletion = TRANS_TYPE_DetachGenerator or _task.trxTypeOnCompletion = TRANS_TYPE_AttachGenerator then
	
		cont := self.getCurrentTi().CM_Container;
		
		if not cont.isReefer then
			return false;	// non-reefers cannot have gen set attached/detached
		endif;
		
		if _task.trxTypeOnCompletion = TRANS_TYPE_DetachGenerator then
			//if TIMaster says that a Detach Generator todo task needs to be auto set on receival, 
			//this should only be done if the ti has a generator specified.
			if not cont.hasGeneratorSetAttached() then
				return false;
			endif;
			
		else	// TRANS_TYPE_AttachGenerator
			//if TIMaster says that a Attach Generator todo task needs to be auto set on receival, 
			//this should only be done if the ti has no generator specified.
			if cont.hasGeneratorSetAttached() then
				return false;
			endif;
			
		endif;
	
	endif;

	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForProxyMasterContainer" id="566746f0-3f66-4cfc-92e1-384d43072eaf">
        <updating/>
        <source>setForProxyMasterContainer(	_id: String;
							_isCommunicating,
							_isHeavyLift : Boolean;
							_coolingType,
							//_voltageType,				// PAR #31155
							_voltageType : Integer;		// PAR #31155
							_tareWeight,
							_extHeight,
							_extLength,
							_extWidth,
							_intHeight,
							_intLength,
							_intWidth, 
							//_maxWeight : Integer;		// PAR #31155
							_maxWeight : Decimal;		// PAR #31155
							_volume : Real;
							_operator,
							_owner : CM_Operator;
							_isoType : CM_ISOType;
							_stopTables		: CM_StopsTableByIdDict;
							_toDoTaskDesc	: CM_ToDoTaskDescByCode ;
							_generatorMaster : CM_TIMaster) updating; //27.02.2018 cnwma1 ChangeRequest #36813

/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/08/2008	cnwrd1	Initial creation
12/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements - change parameter for measurements to Decimal
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars
	cargoId	: Integer;

begin

	self.setForProxyMaster( TI_CargoType_Container,
							_id,
							null,
							_tareWeight,
							_operator,
							_owner,
							_stopTables,
							_toDoTaskDesc,
							app.myRoot);

	self.extHeight := _extHeight;
	self.extWidth := _extWidth;
	self.extLength := _extLength;	
	self.intHeight := _intHeight;
	self.intWidth := _intWidth;
	self.intLength := _intLength;	
	self.maxKilos := _maxWeight;
	self.volume := _volume;
	self.isCommunicating := _isCommunicating;
	self.isHeavyLift := _isHeavyLift;
	self.coolingType := _coolingType;
	self.voltageType := _voltageType;	
	
	if _isoType &lt;&gt; null then
		self.isoType	:= _isoType.code;
	endif;
	
	if _generatorMaster &lt;&gt; null then   //27.02.2018 cnwma1 ChangeRequest #36813
		self.allTIMasterAttachees.add(_generatorMaster);
	endif;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isCommunicating" type="Boolean"/>
        <Parameter name="_isHeavyLift" type="Boolean"/>
        <Parameter name="_coolingType" type="Integer"/>
        <Parameter name="_voltageType" type="Integer"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_extHeight" type="Decimal"/>
        <Parameter name="_extLength" type="Decimal"/>
        <Parameter name="_extWidth" type="Decimal"/>
        <Parameter name="_intHeight" type="Decimal"/>
        <Parameter name="_intLength" type="Decimal"/>
        <Parameter name="_intWidth" type="Decimal"/>
        <Parameter name="_maxWeight" type="Decimal"/>
        <Parameter name="_volume" type="Real"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_owner" type="CM_Operator"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_stopTables" type="CM_StopsTableByIdDict"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDescByCode"/>
        <Parameter name="_generatorMaster" type="CM_TIMaster"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="460fb870-f3ce-4bd8-a2df-0402a269b612">
        <updating/>
        <source>setForUpdate(_proxyTiMaster: SelfType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	cnwrd1	Initial creation

*/
vars
	damageInstance,
	newDamageInstance: CM_DamageInstance;
begin
	inheritMethod(_proxyTiMaster);
	
	self.coolingType := _proxyTiMaster.coolingType;
	self.isCommunicating := _proxyTiMaster.isCommunicating;
	self.isHeavyLift := _proxyTiMaster.isHeavyLift;
	self.isoGroup := _proxyTiMaster.isoGroup;
	self.isoType := _proxyTiMaster.isoType;
	self.maxKilos := _proxyTiMaster.maxKilos;
	self.voltageType := _proxyTiMaster.voltageType;

	
	self.causeEvent(Event_TiMaster_Update, false, null);
epilog

end;</source>
        <Parameter name="_proxyTiMaster" type="SelfType"/>
    </JadeMethod>
