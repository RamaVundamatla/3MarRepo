/*
Date		Who		Reason
01 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars

begin
	self.setEntTableRowsForDBItem (_table.allTblDataEntRows, self.allEntTableRowsForDBItem);

	self.loadDataTable;
epilog

end;</source>
