    <JadeMethod name="setSealCheckProxy" id="59fbc85e-f4b7-4ab4-9711-7c4de3a09381">
        <updating/>
        <source>setSealCheckProxy(	_shipReceival : Integer;
					_shipRelease : Integer;
					_railReceival : Integer;
					_railRelease : Integer;
					_roadReceival : Integer;
					_roadRelease : Integer;
					_pack : Integer;
					_unpack : Integer;
					_sealWagonLoad : Integer;
					_sealWagonDischarge : Integer;
					_sealTruckLoad : Integer;
					_sealTruckDischarge : Integer
					) updating;
//25 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars

begin
	self.sealCheckRailReceival	:= _railReceival;
	self.sealCheckRailRelease	:= _railRelease;
	self.sealCheckRoadReceival	:= _roadReceival;
	self.sealCheckRoadRelease	:= _roadRelease;
	self.sealCheckShipReceival	:= _shipReceival;
	self.sealCheckShipRelease	:= _shipRelease;
	self.sealCheckPack := _pack;	//04 Jul 2011	NDL	Par 26476
	self.sealCheckUnpack := _unpack;	//04 Jul 2011	NDL	Par 26476
	self.sealCheckWagonLoad := _sealWagonLoad;	// 10 Mar 2015	NDL	Par 35828
	self.sealCheckWagonDischarge := _sealWagonDischarge;	// 10 Mar 2015	NDL	Par 35828
	self.sealCheckTruckLoad := _sealTruckLoad;	// 01 Aug 2023 jlizm1 TFS 59985
	self.sealCheckTruckDischarge := _sealTruckDischarge;	// 01 Aug 2023 jlizm1 TFS 59985
epilog

end;</source>
