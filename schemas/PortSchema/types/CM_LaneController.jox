*/

vars

	weighBridge : CM_WeighBridgeObj;
	invalidObj : Boolean;

begin

	weighBridge := self.getWeighBridge();
	on Exception do app.handleDeletedObject( exception, weighBridge, invalidObj );
	if weighBridge &lt;&gt; null then
		return weighBridge.name;
	endif;
	
	return null;

epilog

end;</source>
