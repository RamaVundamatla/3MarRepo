    <JadeMethod name="doApplyConfigColours" id="b5114542-e9f7-4cf2-b8c7-41b09dd1ead4">
        <updating/>
        <source>doApplyConfigColours( form : MOB_HandHeldForm io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwndl1	Initial creation

*/

vars

	rtConfig : CM_RTVehicleConfig;
	backColorGen	: Integer;
	foreColorGen	: Integer;
	backColorTable	: Integer;
	foreColorTable	: Integer;
	numControls		: Integer;
	controlIndex	: Integer;
	controlObj		: Control;
	rtScreenMode	: CM_RTScreenConfig;
	
begin
	
	if self.myMobileGenericAgent.myScreenConfig = null then
		rtConfig := app.myLogonAgent.myTerminal.getRTVehicleConfigForObject(null);
		if rtConfig &lt;&gt; null then
			self.myMobileGenericAgent.setMyScreenConfig ( rtConfig.myDayScreenConfig );
		endif;
	endif;
	
	rtScreenMode := self.myMobileGenericAgent.myScreenConfig;
	if rtScreenMode = null then
		return;
	endif;
	
	backColorGen	:=	rtScreenMode.screenBackColour;
	backColorTable	:=	rtScreenMode.tableBackColour;
	foreColorGen	:=	rtScreenMode.screenForeColour;
	foreColorTable	:=	rtScreenMode.tableForeColour;
	numControls		:=	form.controlCount();
	
	foreach controlIndex in 1 to numControls do
		controlObj	:=	form.controls(controlIndex);		
		
		if controlObj.isKindOf(Label)
		or controlObj.isKindOf(Sheet) 
		or	controlObj.isKindOf(Button) 
		or controlObj.isKindOf(GroupBox) 
		or  controlObj.isKindOf(OptionButton) 
		or 	controlObj.isKindOf(CheckBox)then
			controlObj.setBackForeColor(backColorGen, foreColorGen);
			
		elseif controlObj.isKindOf(Table) then
			if controlObj = form.tblF1Help then
				controlObj.setBackForeColor(backColorGen, foreColorGen);
			else
				controlObj.setBackForeColor(backColorTable, foreColorTable);
			endif;
		elseif controlObj.isKindOf(TextBox)or controlObj.isKindOf(ComboBox) then
			controlObj.borderStyle:=TextBox.BorderStyle_Single;
			controlObj.borderColorSingle:=controlObj.getSystemColor(Control.Color_3DFace);
			controlObj.foreColor:=foreColorGen;
			controlObj.backColor:=backColorTable;
		elseif controlObj.isKindOf(Folder) then
			controlObj.backColor:=backColorGen;
			controlObj.Folder.tabActiveColor := backColorGen;
			controlObj.Folder.tabInactiveColor := backColorGen;
			controlObj.foreColor:=foreColorGen;
		elseif controlObj.isKindOf(Frame) then
			controlObj.borderStyle:=TextBox.BorderStyle_Single;
			controlObj.borderColorSingle:=controlObj.getSystemColor(Control.Color_3DFace);
			controlObj.setBackForeColor(backColorGen, foreColorGen);
		endif;
		
	endforeach;		
	
	form.backColor := backColorGen;
	
	return;
epilog

end;</source>
        <Parameter name="form" type="MOB_HandHeldForm" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doEquipmentCheckTableClick" id="e42867b6-2f03-4d5f-88a1-bacacfd0c714">
        <updating/>
        <source>doEquipmentCheckTableClick(	_table : CM_MobEntryTable input; 
							_displayOnly : Boolean;
							_tickBtn, _crossBtn, _tickBtnDown, _crossBtnDown : MOB_Button;
							_otherObject : CM_Object
							) : Class updating;
/*
Purpose:			Sort out where table was clicked and open appropriate form to deal with cargo check item

Parameters:			_table - the table that was clicked
					_displayOnly - is this click event solely to update the table view (true) or do we need to navigate to a new form (false)

Return Value:		

Date		Who		Reason
08/02/2010	cnwdap1	Initial creation
05/03/2010	cnwdap1	PAR #22741 Display Seals form when we have no voyage, as well as when we do and the seals setting matches
25/03/2010	cnwdap1	PAR #23369 Handle showing Weight form
29/03/2010	cnwdap1	PAR #22741 Seals check handling aligned with setupCargoCheckTable method
15/07/2014	cnwdap1	PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
23/04/2015	cnwdap1	PAR #36094 CCMSSFW 1413 TFS 313 Cold Store Enhancements
*/
vars
	checkItem 	: CM_CargoCheckItem;
	jadeCell 	: JadeTableCell;
	selected	: Boolean;
	objToUpdate : CM_Object;

begin
	if _table.column &lt;= _table.fixedColumns or _table.row &lt;= _table.fixedRows then
		return null;
	endif;
	
	//11 Mar 2015	NDL	Par 35828
	objToUpdate := self.myMobileGenericAgent.myNextTiToAction;
	if _otherObject &lt;&gt; null then
		objToUpdate := _otherObject;
	endif;
	
	checkItem := _table.accessRow(_table.row).itemObject.CM_CargoCheckItem;
	if checkItem = null then
		return null;
	endif;
	
	// switch pictures on the Yes/No buttons
	if checkItem.required and _table.column.isOneOf(_table.ColumnValue, _table.ColumnValueExtra) then
		// switch to the opposite button picture i.e. down for up, or up for down
		jadeCell := _table.accessCell(_table.row, _table.column).cloneSelf(true);
		if jadeCell.selected and not _displayOnly then

	// don't reset picture by clicking the same button again, cos it looks like we unset the value when we didn't.
	/*		if _table.column = _table.ColumnValue then
				jadeCell.picture := _tickBtn.createPicture(false, false, 32);
			else
				jadeCell.picture := _crossBtn.createPicture(false, false, 32);
			endif;
			jadeCell.selected 	:= false; */

		else

			jadeCell.selected 	:= true;
			selected 			:= true;
			
			if _table.column = _table.ColumnValue then
				jadeCell.picture := _tickBtnDown.createPicture(false, false, 32);
				self.myMobileGenericAgent.updateEquipmentCheckSettings(objToUpdate, checkItem, "Y");
				_table.accessCell(_table.row, _table.ColumnValueExtra).picture := _crossBtn.createPicture(false, false, 32);
				_table.accessCell(_table.row, _table.ColumnValueExtra).selected := false;
				_table.accessCell(_table.row, _table.ColumnValue).selected := true;
			elseif _table.column = _table.ColumnValueExtra then
				jadeCell.picture := _crossBtnDown.createPicture(false, false, 32);
				self.myMobileGenericAgent.updateEquipmentCheckSettings(objToUpdate, checkItem, "N");
				_table.accessCell(_table.row, _table.ColumnValue).picture := _tickBtn.createPicture(false, false, 32);
				_table.accessCell(_table.row, _table.ColumnValue).selected := false;
				_table.accessCell(_table.row, _table.ColumnValueExtra).selected := true;
			endif;
			
		endif;
	elseif _table.accessCell(_table.row, _table.column).inputType = _table.InputType_CheckBox then
		if _table.accessedCell.text = "1" then
			self.myMobileGenericAgent.updateEquipmentCheckSettings(objToUpdate, checkItem, "Y");
			selected := true;
		else
			self.myMobileGenericAgent.updateEquipmentCheckSettings(objToUpdate, checkItem, " ");
		endif;
	elseif _table.column = _table.ColumnValue then
		// this must be a button, and we've just clicked it - set "selected"
		self.myMobileGenericAgent.updateEquipmentCheckSettings(objToUpdate, checkItem, "Y");	
		selected := true;
	endif;
		
	// if the click was in column 2, see if we need to display another form
	if not _displayOnly then
		if _table.column = _table.ColumnValue and selected then
		
			// Damage - display the damager form
			if checkItem.requiredExtraInfo = EXTRA_INFO_DAMAGE then
			
				//11 Mar 2015	NDL	Par 35828
				if _otherObject &lt;&gt; null and _otherObject.isKindOf(CM_Wagon) then
					return MOB_HHRailWagonDamage;
				endif;
				
				// display the cargo damage form
				if not app.myMobileAgent.allFoundTIs.includes(self.myMobileGenericAgent.myNextTiToAction) then
					app.myMobileAgent.allFoundTIs.add(self.myMobileGenericAgent.myNextTiToAction);
				endif;
				app.myMobileAgent.setMySelectedTI( self.myMobileGenericAgent.myNextTiToAction ); //29 Apr 2010	NDL	Par 23945
				app.myMobileAgent.setMyCargoCheckItem(checkItem);	//cnwas3 par24175
				return MOB_HHDamageForm;
			
			// Seals - display the seals form if required
			elseif checkItem.requiredExtraInfo = EXTRA_INFO_SEALS then
				if checkItem.myCargoCheck.context.isOneOf(WAGON_CHECK_CONTEXT_PLACE_IN, WAGON_CHECK_CONTEXT_PLACE_OUT) then
					app.myMobileAgent.setMyCargoCheckItem(checkItem);
					return MOB_HHCargoSealsCheckNew;
				endif;
				
				if not checkItem.myCargoCheck.context.isOneOf(CARGO_CHECK_CONTEXT_SHIP_LOAD, CARGO_CHECK_CONTEXT_SHIP_DISC) or self.myMobileGenericAgent.myVoyage.myTerminal.getConfig(IsShipLanderSealCheck).Boolean then
					if not app.myMobileAgent.allFoundTIs.includes(self.myMobileGenericAgent.myNextTiToAction) then
						app.myMobileAgent.allFoundTIs.add(self.myMobileGenericAgent.myNextTiToAction);
					endif;
					app.myMobileAgent.setMyCargoCheckItem(checkItem);//cnwas3 par24175 part2
					return MOB_HHCargoSealsCheckNew;
				endif;
				
			// Dimensions - display the correct dimensions form depending on wjether we have cargo/container
			elseif checkItem.requiredExtraInfo = EXTRA_INFO_DIMENSION then
				if not app.myMobileAgent.allFoundTIs.includes(self.myMobileGenericAgent.myNextTiToAction) then
					app.myMobileAgent.allFoundTIs.add(self.myMobileGenericAgent.myNextTiToAction);
				endif;
				// display the appropriate dimensions form
				if self.myMobileGenericAgent.myNextTiToAction.isContainer then
					// display container dimensions form
					self.myMobileGenericAgent.setStringField1(checkItem.myCargoCheck.context.String.padLeadingZeros(2) &amp; checkItem.getOidString);
					app.myMobileAgent.setMyCargoCheckItem(checkItem);//cnwas3 par24175
					return MOB_HHContainerOverDimForm;
			//	elseif self.myNextTiToAction.isBulkOrBreakBulkGeneric then
				else // 01 Sep 2010	NDL	Par 25571
					// display general cargo dimensions form
					self.myMobileGenericAgent.setStringField1(checkItem.myCargoCheck.context.String.padLeadingZeros(2) &amp; checkItem.getOidString);
					app.myMobileAgent.setMyCargoCheckItem(checkItem);//cnwas3 par24175
					return MOB_HHCargoOverDimForm;
				endif;
			
			elseif checkItem.requiredExtraInfo = EXTRA_INFO_PHOTO then
				app.myMobileAgent.setMyCargoCheckItem(checkItem);//cnwas3 par24175
				return MOB_CargoPhotoForm;
				
			// Hazards - create the to do task
			elseif checkItem.requiredExtraInfo = EXTRA_INFO_HAZARD_SYMBOLS then
//				self.doHazardsToDoTaskCreate(self.getTerminal);
			
			// PAR #23369 Weights form
			elseif checkItem.requiredExtraInfo = EXTRA_INFO_WEIGHT then
				if not app.myMobileAgent.allFoundTIs.includes(self.myMobileGenericAgent.myNextTiToAction) then
					app.myMobileAgent.allFoundTIs.add(self.myMobileGenericAgent.myNextTiToAction);
				endif;
				app.myMobileAgent.setMyCargoCheckItem(checkItem);//cnwas3 par24175
				return MOB_HandHeldWeightForm;
				
			elseif checkItem.requiredExtraInfo = EXTRA_INFO_SPECIAL_LIFT then	//31 May 2010	NDL	Par 23903
				if not app.myMobileAgent.allFoundTIs.includes(self.myMobileGenericAgent.myNextTiToAction) then
					app.myMobileAgent.allFoundTIs.add(self.myMobileGenericAgent.myNextTiToAction);
				endif;
				app.myMobileAgent.setMyCargoCheckItem(checkItem);
				return MOB_HandHeldSpecialLiftForm;
			
			// PAR #34568 Alternative Id form												// PAR #34568
			elseif checkItem.requiredExtraInfo = EXTRA_INFO_ALTERNATIVE_ID then				// PAR #34568
				if not app.myMobileAgent.allFoundTIs.includes(self.myMobileGenericAgent.myNextTiToAction) then	// PAR #34568
					app.myMobileAgent.allFoundTIs.add(self.myMobileGenericAgent.myNextTiToAction);				// PAR #34568
				endif;																		// PAR #34568
				app.myMobileAgent.setMyCargoCheckItem(checkItem);							// PAR #34568
				return MOB_HandHeldAlternativeIdForm;										// PAR #34568
				
			// PAR #36094 Temperature reading form											// PAR #36094
			elseif checkItem.requiredExtraInfo = EXTRA_INFO_TEMPERATURE then				// PAR #36094
				if not app.myMobileAgent.allFoundTIs.includes(self.myMobileGenericAgent.myNextTiToAction) then	// PAR #36094
					app.myMobileAgent.allFoundTIs.add(self.myMobileGenericAgent.myNextTiToAction);				// PAR #36094
				endif;																		// PAR #36094
				app.myMobileAgent.setMyCargoCheckItem(checkItem);							// PAR #36094
				return MOB_HandHeldTemperatureForm;											// PAR #36094
			
			endif;
		endif;
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_table" type="CM_MobEntryTable" usage="input"/>
        <Parameter name="_displayOnly" type="Boolean"/>
        <Parameter name="_tickBtn" type="MOB_Button"/>
        <Parameter name="_crossBtn" type="MOB_Button"/>
        <Parameter name="_tickBtnDown" type="MOB_Button"/>
        <Parameter name="_crossBtnDown" type="MOB_Button"/>
