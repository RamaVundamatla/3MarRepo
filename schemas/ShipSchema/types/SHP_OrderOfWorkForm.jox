    <JadeMethod name="doBtnUnloadClick" id="0e4a88d7-cb41-469e-9f0f-4154fd89f475">
        <updating/>
        <source>doBtnUnloadClick() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 01/11/2012	PJS			PAr #30631 
// 25/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------

vars
	theObject 	: Object;
	theJob, 
	theProxyJob : CM_VoyageJob;
	loadState 	: Boolean;
	theResult 	: Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	if self.tblData.allSelectedObjects.size = 0 then
		app.msgBox(app.getErrorString(Please_Select_Job_Unload),app.getErrorString(Job_Unload_Error), MsgBox_OK_Only);
		return;
	endif;
	self.mousePointer := Window.MousePointer_HourGlass;
		
	foreach theObject in self.tblData.allSelectedObjects do
		if theObject.isKindOf(CM_VoyageJob) then
			theJob := theObject.CM_VoyageJob;
			delete theProxyJob;
			
			app.cmsBeginLoad(loadState);
			theProxyJob := theJob.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
			
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateVoyageJobLoadUnload(theProxyJob, false, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
			
			//epr TFS 830 again all code handled by notes 21/3/17		
		endif;	
	endforeach;
	
	global.beep;
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	delete theProxyJob;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuFullPlan" id="ce80ab92-66aa-4ab7-8546-7d329d75bbe8">
        <source>doBuildMnuFullPlan(_menu : MenuItem);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:
//		
// 01 Nov 2012		PJS		PAR #30631
// ---------------------------------------------------------------------------
vars
	mnuChild,
	mnuMaster	: MenuItem;
	idx			: Integer;
	crane		: CM_Machine;
	jobSheet	: CM_VoyageJobSheet;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	if not _menu.visible then
		return;
	endif;
	if not app.myPassport.myUser.canDo(self.myTerminal,PmShipCanFullyPlan) then
		return;
	endif;
//	if not app.myRoot.canDo(PmAutoShipPlanning) then
/* // ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)
	if not app.myRoot.canDo(Mod_CargoShip) then	//07 Oct 2019	NDL	TFS 46169
		return;
	endif;
	*/
	
	mnuMaster := _menu;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;

	foreach idx in 1 to 10 do
		mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;
	idx := 0;

	// ### VOYAGE MENU
	idx := idx+1;
	mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(idx); // Clone menu
	endif;
	mnuChild.caption := app.getErrorString(VoyageCapitalV) &amp; " " &amp; self.myCurrentVoyage.code &amp; "...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.userObject := self.myCurrentVoyage;
	mnuChild.helpContextId := CMIF_ShipPlanningController.Mode_Voyage; //epr TFS 830 29/3/17 tiding up duplicate constants
	
	
	// ### EACH CRANE MENU
	foreach jobSheet in self.myCurrentVoyage.allJobSheets do
		crane := self.myTerminal.machines[jobSheet.crane.trimBlanks];
		
		if crane &lt;&gt; null  then
			idx := idx+1;
			mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
			if mnuChild = null then
				mnuChild := mnuMaster.loadSubMenu(idx); // Clone menu
			endif;
			mnuChild.caption := crane.getDisplayDetails(false) &amp; "...";
			mnuChild.visible := true;
			mnuChild.enabled := true;
			mnuChild.userObject := crane;
			mnuChild.helpContextId := CMIF_ShipPlanningController.Mode_Crane;
		endif;
	endforeach; 

	// ### SELECTED JOBS MENU
	idx := idx+1;
	mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(idx); // Clone menu
	endif;
	if _menu = self.mnuOOWFullPLan then
		mnuChild.caption := app.getErrorString(Selected_Jobs_CTRL_L);  //30631
	else
		mnuChild.caption := app.getErrorString(Selected_Jobs_Dots); //30631
	endif;
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.userObject := null;
	mnuChild.helpContextId := CMIF_ShipPlanningController.Mode_Job;
	
end;</source>
        <Parameter name="_menu" type="MenuItem"/>
    </JadeMethod>
