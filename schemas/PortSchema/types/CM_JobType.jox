    <JadeMethod name="setForCreate" id="6bc15047-f5e2-4fac-8210-3bc0b0cf4319">
        <updating/>
        <source>setForCreate(pProxyJobType:CM_JobType) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	pProxyJobType.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyJobType);
	
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pProxyJobType" type="CM_JobType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="87673ede-14fa-44c8-ae34-a296012e95f7">
        <updating/>
        <source>setForUpdate(pProxyJobType:CM_JobType) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.name := pProxyJobType.name.trimBlanks;
	self.isHatchType := pProxyJobType.isHatchType;
	self.colour	:= pProxyJobType.colour;
	self.estimatedTimeToCompleteMins := pProxyJobType.estimatedTimeToCompleteMins;

end;</source>
        <Parameter name="pProxyJobType" type="CM_JobType"/>
    </JadeMethod>
