    <JadeMethod name="create" id="11f1455d-c90e-48cb-a543-8fa728d4ce8f">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgab1	Initial creation

*/

vars

begin
	self.permissionView  := PmAdmInvStatusView;
