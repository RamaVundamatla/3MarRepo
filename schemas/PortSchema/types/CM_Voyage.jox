    <JadeMethod name="hasStructureOfType" id="3f47de50-44e2-4426-984f-26f3ef4e7ee5">
        <source>hasStructureOfType(_structureType : Integer) : Boolean;
//--------------------------------------------------
// Created:	31 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	aBay : CM_Bay;
begin
	
	if _structureType = LogStructure then
		return self.myLogVoyageStructure &lt;&gt; null;
	// PAR 28701 elseif _structureType = CellularStructure or
	// PAR 28701	   _structureType = CellularStructureRORO then	// PAR 21745 CCMS MES 1031
	elseif _structureType = CellularStructure then
		if self.myCellularVoyageStructure  = null then
			return false;
// PAR 33644 		elseif self.isNonPlannedVoyage then
// PAR 33644			return false;
		elseif  self.myCellularVoyageStructure.allBayVoyagesByOrdinal.isEmpty() then
			return false;
		else
			foreach aBay in self.myCellularVoyageStructure.allBayVoyagesByOrdinal do
				if not aBay.hasStructure() then
					return false;
				endif;
			endforeach;
			return true;
		endif;
	// PAR 28701
	elseif  _structureType = CellularStructureRORO then
		if self.myCellularVoyageStructure  = null and self.myROROStructure = null then
			return false;
		else
		
			// No RORO and no bays defined
			if  self.myROROStructure = null and (self.myCellularVoyageStructure &lt;&gt; null and self.myCellularVoyageStructure.allBayVoyagesByOrdinal.isEmpty() ) then
				return false;
			// No LOLO and no decks decks
			elseif  self.myCellularVoyageStructure = null and (self.myROROStructure &lt;&gt; null and self.myROROStructure.allDecks.isEmpty() ) then
				return false;
			// No bays or decks defined
			elseif  (self.myCellularVoyageStructure &lt;&gt; null and self.myCellularVoyageStructure.allBayVoyagesByOrdinal.isEmpty() ) 
			and (self.myROROStructure &lt;&gt; null and self.myROROStructure.allDecks.isEmpty() ) then
				return false;
			// No deck s defined and a bay has no cells or tiers
			elseif (self.myROROStructure &lt;&gt; null and self.myROROStructure.allDecks.isEmpty() ) then
				foreach aBay in self.myCellularVoyageStructure.allBayVoyagesByOrdinal do
					if not aBay.hasStructure() then
						return false;
					endif;
				endforeach;
			endif;
			
			return true;
		endif;
	elseif _structureType = GeneralCargoStructure then
		return self.myGeneralCargoVoyage &lt;&gt; null;
	elseif _structureType = StructureTypeNull then
		// check if this is an HMS only voyage
		return self.myLogVoyageStructure = null and self.myCellularVoyageStructure = null and self.myGeneralCargoVoyage = null;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_structureType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
