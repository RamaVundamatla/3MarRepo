<Class name="CM_HazTempRange" id="dd937fac-77c9-4d96-8a8d-a78e06279455">
    <superclass name="CM_TempRange"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myRootHaz" id="30da5c66-b7ed-4df8-9044-f0163fadf40f">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allHazTempRanges"/>
    </ExplicitInverseRef>
    <JadeMethod name="getDisplayDetails" id="62f5a99e-dfc2-4aec-9149-bc496713ac27">
        <source>getDisplayDetails(_short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars

begin
	return self.lower.asStringJMT &amp; Hyphen &amp; self.upper.asStringJMT;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesTemp" id="561531e6-78ba-4121-8f7d-b45ff0c2d755">
        <source>includesTemp(_temp : Real) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars

begin
	if self.lower &lt;= _temp and self.upper &gt;= _temp then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_temp" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c5e3d7b8-4cd2-45a2-88ef-694dea401eb4">
        <updating/>
        <source>setForCreate(_pxyHazTempRange: CM_HazTempRange) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/11/2016	cnwdap1		Initial creation TFS 2841 STWR Hazardous Details Enhancement
//
vars

begin
	_pxyHazTempRange.raiseExceptionIfNotTransient(method);
	
	setForUpdate(_pxyHazTempRange);
	self.myRootHaz := app.myRoot;

epilog

end;</source>
        <Parameter name="_pxyHazTempRange" type="CM_HazTempRange"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ae4240a2-efa5-416f-aeee-2023d17c8079">
        <source>validateForCreate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 07/11/2016	cnwdap1		Initial creation TFS 2841 STWR Hazardous Details Enhancements
//
vars

begin
	if app.myRoot.allHazTempRanges[value] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.value.String, null, null);
	endif;

	self.validateMe;
epilog

end;</source>
    </JadeMethod>
</Class>
