    <JadeMethod name="displayEntryVesselWO" id="07156ea1-f9b9-496b-ad1c-697ab9cc551f">
        <source>displayEntryVesselWO(_obj : CM_Vessel):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	failedDAC	: CM_DataAccessController;
begin
	if _obj = null then
		return null;
	endif;
	
	if (not _obj.canCreateVoyages) then
		return null;
	endif;

	if not _obj.canUserAccessSelf(null, failedDAC, app.myPassport) then
		return null;
	endif;
	
	return _obj.code &amp; Tab &amp; _obj.name;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Vessel"/>
        <ReturnType type="String"/>
    </JadeMethod>
