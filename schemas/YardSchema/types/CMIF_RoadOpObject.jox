    <JadeMethod name="removeDataTableObject" id="44a064d2-fe6a-478d-8d12-122f1d3a25ed">
        <source>removeDataTableObject(_obj : CM_Object input);
/*
Date		Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx
19/03/2010		cnwcs5	par 23193 - tracked item notifications
*/
vars
	rowIdx 	: Integer;
	invalid	: Boolean;			// par 23193
	ti		: CM_TrackedItem;	// par 23193
begin
	on Exception do app.handleDeletedObject (exception, _obj, invalid);	// par 23193
	
	if self.myDataTable.findObjectInRow(_obj, rowIdx) then
		self.myDataTable.removeItem(rowIdx);
	endif;
	
	if _obj.isKindOf (CM_YardWLE) then
		// if _obj has been deleted we will get an exception 
		ti := _obj.CM_YardWLE.myTrackedItem;
		
		if invalid then
			// looks like the WLE has been deleted.  the ti will stay in the collection
			// till a refresh is done
			return;
		endif;
		
		self.doNotableRemove (ti);
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeTIFromDataTable" id="34ccb0ec-e3e4-4c0c-b9e7-8c4ac94322a8">
        <source>removeTIFromDataTable(_vehicle: CM_Vehicle input) abstract, protected;
</source>
