<Class name="CMIF_TrxActionOverstow" id="202f531d-445c-40ad-8d1a-3609fb769781">
    <superclass name="CMIF_TrxPostAction"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myFromLocation" id="00ead489-39b9-4c40-bbe9-1a48c119ba5e">
        <embedded/>
        <type name="CM_LocationsController"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTI" id="37e5b7f8-663d-4586-aaf7-b274796a2f02">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myToLocation" id="fa6fc187-fa2f-4f2d-8c03-b33fc0505e12">
        <embedded/>
        <type name="CM_LocationsController"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="5c271117-3d6a-4494-b8b0-4b2c3310d3c3">
        <updating/>
        <source>action(_passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2025	jlier1	Initial creation 35636

*/

vars
	passport : CM_Passport;
begin
	passport:=_passport;
	passport.setWarningsIgnored( true);
	passport.setWarningsAcknowledged( true);
	app.myTrxUA.trxUpdateOverstows(self.myFromLocation,self.myToLocation,self.myTI, passport);

	//the abort trx in above transaction if it is successfull in doing the proforma leaves status as incomplete because no longer in trx state
	
	passport.clearErrorsWarnings;
	passport.initialiseTransaction;
	passport.finaliseTransaction(TRXStatus_Committed);

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createAction" id="c0f4053d-1edb-4a49-a79d-56c549485e5d">
        <options>4</options>
        <source>createAction(_fromLC, _toLC : CM_LocationsController; _ti : CM_TrackedItem; _passport : CM_Passport input) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2025	jlier1	Initial creation 35636

*/

vars
	trxPA : CMIF_TrxPostAction;
	trxOverstow : CMIF_TrxActionOverstow;
	isFromYard,isToYard : Boolean;
begin
	if (_fromLC = null and _ti = null) or not _passport.noErrors() then
		return;
	endif;
	
	if _fromLC &lt;&gt; null then
		isFromYard:=_fromLC.isKindOf(CM_GridController);
	endif;
	if _toLC &lt;&gt; null then
		isToYard:=_toLC.isKindOf(CM_GridController);
	endif;
	if not isFromYard and  not isToYard then
		//has to be moving from or to a yard grid location else does not matter we don't need to calcuate overstows
		return;
	endif;
	
	if _fromLC &lt;&gt; null or _ti &lt;&gt; null or _toLC &lt;&gt; null then
		foreach trxPA in _passport.allTrxPostActions where trxPA.isKindOf(CMIF_TrxActionOverstow) do
			if trxPA.CMIF_TrxActionOverstow.myFromLocation = _fromLC and
				trxPA.CMIF_TrxActionOverstow.myTI = _ti and
				trxPA.CMIF_TrxActionOverstow.myToLocation = _toLC then
				return;
			endif;
		endforeach;
		
		create trxOverstow transient;
		trxOverstow.myFromLocation := _fromLC;
		trxOverstow.myTI := _ti;
		trxOverstow.myToLocation := _toLC;
		
		_passport.addTrxPostAction(trxOverstow);
	
	endif;

epilog
	
end;</source>
        <Parameter name="_fromLC" type="CM_LocationsController"/>
        <Parameter name="_toLC" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
