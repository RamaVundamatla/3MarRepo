    <JadeMethod name="isRailLanderRequest" id="5d747233-f9fd-4e1d-8584-e32496f254f8">
        <source>isRailLanderRequest() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 5535
04 August 2017	jlger1	Initial creation

*/

vars
	
begin
	return (self.doDischargeToRail or
	self.doLoadToRail);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidRequest" id="96640090-c600-42ef-90e7-8a53764ec5eb">
        <source>isValidRequest() : Boolean;
/*

Date		Who		Reason
25 January 2017	cnwer1	Initial creation TFS 1487

*/

vars

begin
	return  (self.doLoad or 
	self.doSOB or 
	self.doDischargeToGround or 
	self.doDischargeToGroundInTransit or 
	self.doDischargeToMachine or
	self.doDischargeToYard or
	self.doDischargeToRail or
	self.doLoadToRail);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
