    <JadeMethod name="resetData_41671" id="f61bee71-3c13-4e21-a1b1-e65160721ef7">
        <source>resetData_41671();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/06/2021	navmh5	Initial creation

*/



vars

	terminal				: CM_Terminal;
	iMove					: CM_InterTerminalMove;
	iConfig					: CM_InterTerminalConfig;
	ti						: Object;
	bs						: CM_BlockStack;
	operator 				: CM_Operator;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	app.initialize();
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	app.myPassport.setMyTerminal(terminal);
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG41671A01");
	tisToDelete.add("JLG41671A02");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	operator := self.getOperator("MSC");
	self.assertNotNull(operator);
	
	self.opts.purge();
	opts.addAssoc(UTTI_VoyageCode, "MSCK000002");
	opts.addAssoc(UTTI_DischargePort, "NZLYT");
	
	bs := self.getTerminalArea("XXBS08").CM_BlockStack;
	self.assertNotNull(bs);
	
	ti := self.addContainerAtLocation("JLG41671A01", operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs);
	self.assertNotNull(ti);
	
	bs := self.getTerminalArea("XXBS09").CM_BlockStack;
	self.assertNotNull(bs);
	
	ti := self.addContainerAtLocation("JLG41671A02", operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs);
	self.assertNotNull(ti);
	

epilog

	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_41720" id="38f721bb-6aae-4fb3-a9bd-b287e21632fa">
        <source>resetData_41720();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2020	jlgmh5	Initial creation

*/

constants

	VoyageId					: String = "BISL41720A";
	VesselId					: String = "BISL41720";
	CraneId						: String = "POT";

vars

	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	operator					: CM_Operator;
	voyageDischJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	
	tisToDelete					: StringArray;
	slotsFrom					: CM_SlotControllerArray;
	
	arrivalTS					: TimeStamp;
	departureTS					: TimeStamp;

begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create tisToDelete transient;
	tisToDelete.add("JLG41720A01");
	tisToDelete.add("JLG41720A02");
	tisToDelete.add("JLG41720A03");
	
	self.deleteTIResetScript(tisToDelete, terminal);
	
	self.deleteVoyage(VoyageId);
	
	// set arrival and departure dates
	arrivalTS.setDate("05/11/2018".Date);
	arrivalTS.setTime("15:32:00".Time);
	departureTS := arrivalTS;
	departureTS.setDate("05/11/2050".Date);
	
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId[1:9], "MSL", "ANZ");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageId &amp; ") was not created.", LogINFO);
	endif;
	
	// add cargo on voyage
	operator := self.getOperator("MSL");
	self.assertNotNull(operator);
	
	
	ti := self.addContainerOnShip("JLG41720A01", operator, "2200", "GEN", null, voyage, "USJAX", "030684").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "6000");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG41720A02", operator, "4200", "GEN", null, voyage, "USJAX", "030686").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG41720A03", operator, "2200", "GEN", null, voyage, "USJAX", "050684").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "05", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 1, 2, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D40);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "05", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 1, 2, 1, slotsFrom);
	
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	self.assertNotNull(voyageDischJob);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
epilog

	app.myPassport.setWarningsIgnored(false);

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tisToDelete;
	delete slotsFrom;

end;

</source>
    </JadeMethod>
    <JadeMethod name="resetData_41750" id="a62674fc-0a46-4752-8434-102936c3ec1a">
        <source>resetData_41750();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2020	jlgmh5	Initial creation

*/

constants

	VoyageId					: String = "BISL41750A";
	VesselId					: String = "BISL41750";
	CraneId						: String = "POT";

vars

	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	operator					: CM_Operator;
	voyageDischJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	
	tisToDelete					: StringArray;
	slotsFrom					: CM_SlotControllerArray;
	
	arrivalTS					: TimeStamp;
	departureTS					: TimeStamp;

begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create tisToDelete transient;
	tisToDelete.add("JLG41750A01");
	tisToDelete.add("JLG41750A02");
	tisToDelete.add("JLG41750A03");
	
	self.deleteTIResetScript(tisToDelete, terminal);
	
	self.deleteVoyage(VoyageId);
	
	// set arrival and departure dates
	arrivalTS.setDate("05/11/2018".Date);
	arrivalTS.setTime("15:32:00".Time);
	departureTS := arrivalTS;
	departureTS.setDate("05/11/2050".Date);
	
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId[1:9], "MSL", "ANZ");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageId &amp; ") was not created.", LogINFO);
	endif;
	
	// add cargo on voyage
	operator := self.getOperator("MSL");
	self.assertNotNull(operator);
	
	
	ti := self.addContainerOnShip("JLG41750A01", operator, "2200", "GEN", null, voyage, "USJAX", "030584").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "6000");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG41750A02", operator, "4200", "GEN", null, voyage, "USJAX", "030586").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG41750A03", operator, "2200", "GEN", null, voyage, "USJAX", "050584").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 6, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "05", DeckOnDeck, 6, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 6, 2, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D40);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 6, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "05", DeckOnDeck, 6, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 6, 2, 1, slotsFrom);
	
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	self.assertNotNull(voyageDischJob);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
epilog

	app.myPassport.setWarningsIgnored(false);

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tisToDelete;
	delete slotsFrom;

end;

</source>
    </JadeMethod>
    <JadeMethod name="resetData_41886" id="01182d2d-2c1a-4a68-aea5-8f869d46297a">
        <source>resetData_41886();
/*

Purpose:	Reset 50282		

Date		Who		Reason
28/04/2021	navmh5	Initial creation

*/
vars
	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	voyage					: CM_Voyage;
	
	arrivalTS				: TimeStamp;
	departureTS				: TimeStamp;
	
begin
	//app.initialize();
	
	
	/*****************************************************
	 * Terminal - MTNQ
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT2"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);

	voyage := self.getVoyage("TESTB0000");
	if voyage &lt;&gt; null then
		self.deleteVoyage("TESTB0000");
	endif;
	
	voyage := self.getVoyage("TESTI0000");
	if voyage &lt;&gt; null then
		self.deleteVoyage("TESTI0000");
	endif;
	
	arrivalTS.setDate("20/02/2019".Date);
	arrivalTS.setTime("10:56".Time);
	departureTS.setDate("20/02/2050".Date);
	departureTS.setTime("10:56".Time);
	
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	
	voyage := self.addVoyageWithContainerStructur("TESTB0000", "TESTING", "MSK", "MSK");
	self.assertNotNull(voyage);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_42012" id="03775520-4fc9-41c7-90de-ea500bd80ede">
        <source>resetData_42012();
/*

Purpose:			

Parameters:			

Return Value:		

   Date		     Who		Reason
05 August 2021	navmp4	Initial creation

*/

constants

	VoyageId					: String = "BISL42012A";
	VesselId					: String = "BISL42012";
	CraneId						: String = "POT";

vars

	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	operator					: CM_Operator;
	voyageDischJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	
	tisToDelete					: StringArray;
	slotsFrom					: CM_SlotControllerArray;
	
	arrivalTS					: TimeStamp;
	departureTS					: TimeStamp;

begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create tisToDelete transient;
	tisToDelete.add("JLG42012A01");
	tisToDelete.add("JLG42012A02");
	tisToDelete.add("JLG42012A03");
	tisToDelete.add("JLG42012A04");
	tisToDelete.add("JLG42012A05");
	tisToDelete.add("JLG42012A06");
	tisToDelete.add("JLG42012A07");
	tisToDelete.add("JLG42012A08");
	tisToDelete.add("JLG42012A09");
	tisToDelete.add("JLG42012A10");
	
	self.deleteTIResetScript(tisToDelete, terminal);
	
	self.deleteVoyage(VoyageId);
	
	// set arrival and departure dates
	arrivalTS.setDate("05/11/2018".Date);
	arrivalTS.setTime("15:32:00".Time);
	departureTS := arrivalTS;
	departureTS.setDate("05/11/2050".Date);
	
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId[1:9], "MSL", "ANZ");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageId &amp; ") was not created.", LogINFO);
	endif;
	
	// add cargo on voyage
	operator := self.getOperator("MSL");
	self.assertNotNull(operator);
	
	
	ti := self.addContainerOnShip("JLG42012A01", operator, "2200", "GEN", null, voyage, "USJAX", "070686").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "6000");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG42012A02", operator, "2200", "GEN", null, voyage, "USJAX", "070486").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG42012A03", operator, "2200", "GEN", null, voyage, "USJAX", "070286").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG42012A04", operator, "2200", "GEN", null, voyage, "USJAX", "070186").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG42012A05", operator, "2200", "GEN", null, voyage, "USJAX", "090686").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG42012A06", operator, "2200", "GEN", null, voyage, "USJAX", "090486").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG42012A07", operator, "2200", "GEN", null, voyage, "USJAX", "090286").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG42012A08", operator, "2200", "GEN", null, voyage, "USJAX", "090186").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG42012A09", operator, "4200", "GEN", null, voyage, "USJAX", "070684").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	ti := self.addContainerOnShip("JLG42012A10", operator, "4200", "GEN", null, voyage, "USJAX", "070484").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "5500");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 1, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 2, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 3, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 4, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "09", DeckOnDeck, 1, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "09", DeckOnDeck, 2, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "09", DeckOnDeck, 3, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "09", DeckOnDeck, 4, 2, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 2, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D40);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 1, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 2, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 3, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 4, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "09", DeckOnDeck, 1, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "09", DeckOnDeck, 2, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "09", DeckOnDeck, 3, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "09", DeckOnDeck, 4, 2, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 2, 1, 1, slotsFrom);
	
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	self.assertNotNull(voyageDischJob);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
epilog
	app.myPassport.setWarningsIgnored(false);

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tisToDelete;
	delete slotsFrom;

end;


</source>
    </JadeMethod>
    <JadeMethod name="resetData_42018" id="9bd33f9f-fa2f-4897-8ee7-69cebb4d6609">
        <source>resetData_42018();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/05/2021	navmh5	Initial creation

*/


vars

	terminal				: CM_Terminal;
	ti						: Object;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	app.initialize();
	
		
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(terminal);
	
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG42018A01");
	tisToDelete.add("JLG42018A02");
	tisToDelete.add("JLG42018A03");
	tisToDelete.add("JLG42018A04");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;

epilog

	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_42357" id="b43bcf8f-2c7b-405b-91c4-850f84de7496">
        <source>resetData_42357();
/*

Purpose:			

Parameters:			

Return Value:		

   Date		     Who		Reason
05 August 2021	navmp4	Initial creation

*/

constants

	VoyageId					: String = "MESDAI200001";
	CraneId						: String = "CRN1";

vars
	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	voyageDischJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	
	slotsFrom					: CM_SlotControllerArray;
	
begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);

	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 1, 6, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 1, 6, 1, slotsFrom);
	
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	self.assertNotNull(voyageDischJob);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	delete slotsFrom;
end;

</source>
    </JadeMethod>
    <JadeMethod name="resetData_43587" id="2a55b19f-4502-4ca9-9194-65034bcdd262">
        <source>resetData_43587();

/*

Purpose:	Reset 43587		

Date		Who		Reason
05/03/2019	jlgmk4	Initial creation

*/
constants

	ReleaseRequestID		: String = "JLG43587ROAD001";
	VehicleID				: String = "43587";

vars

	terminal				: CM_Terminal;
	dsl						: UT_DSL;
	iMove					: CM_InterTerminalMove;
	iConfig					: CM_InterTerminalConfig;
	ti						: Object;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
	release					: CM_BulkRelease;			
	
begin

	
	app.initialize();
	
	create dsl transient;
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Terminal", terminal.code);
	
	// delete the vehicle
	//self.deleteVehicle(VehicleID);
	
	// delete the release request
	release := self.getTerminal.getBulkReleaseFromCode(ReleaseRequestID);
	if release &lt;&gt; null then
		dsl.deleteReleaseRequest(ReleaseRequestID);
	endif;
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG43587A01");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			dsl.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	
	/*foreach vvr in CM_VehicleVisitRecord.instances discreteLock where vvr.regNumber = "43587" and vvr.timeOut = null do
		break;
	endforeach;
	
	if vvr &lt;&gt; null then
		self.ignoreTrxWarnings(true); 
		app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;*/
	
	vehicle := self.getVehicle("43587");
	if vehicle = null then
		app.writeLog("Unable to find vehicle 43587", LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;
	
	
epilog

	delete dsl;
	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_43684" id="a055971e-28b6-4ec0-b82c-32b7e6fc5ffd">
        <source>resetData_43684();

/*

Purpose:	Reset 43587		

Date		Who		Reason
05/03/2019	jlgmk4	Initial creation

*/
constants

	ReleaseRequestID		: String = "43684RLS";


vars

	terminal				: CM_Terminal;
	dsl						: UT_DSL;
	ti						: Object;
	vvr 					: CM_VehicleVisitRecord;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	app.initialize();
	
	create dsl transient;
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Terminal", terminal.code);
	
	// delete the release request
	dsl.deleteReleaseRequest(ReleaseRequestID);
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG43684A01");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			dsl.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	foreach vvr in CM_VehicleVisitRecord.instances discreteLock where vvr.regNumber = "43684" and vvr.timeOut = null do
		break;
	endforeach;
	
	if vvr &lt;&gt; null then
		self.ignoreTrxWarnings(true); 
		app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

	delete dsl;
	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_43699" id="caa432a3-69ba-48d1-9a39-18b65cf74254">
        <source>resetData_43699();

/*

Purpose:			

Parameters:			

Return Value:		

   Date		     Who		Reason
14 April 2021	navmp4	Initial creation

*/

constants

	VoyageId					: String = "VOY43699";
	VesselCode				    : String = "MSCK";
	CraneId						: String = "CRN1";

vars
	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	ti							: CM_Container;
	operator					: CM_Operator;
	
	tisToDelete					: StringArray;
	
begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
		
	//DELETE THE VOYAGE
	self.deleteVoyage(VoyageId);
	
	// create the voyage
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselCode, "MSK", "AZL"); 
	self.assertNotNull(voyage);
	
	operator := app.myRoot.allOperators["MSK"];
	self.assertNotNull(operator);


	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
end;



</source>
    </JadeMethod>
