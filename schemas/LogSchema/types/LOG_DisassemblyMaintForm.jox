    <JadeMethod name="resetTopPositions" id="fd9d7460-71c1-4405-aad7-47b1a43a3b86">
        <updating/>
        <source>resetTopPositions() protected, updating;

vars

	theHeight	: Real;

begin
	theHeight				:= self.topMargin + 10;
	self.optDocket.top		:= theHeight;
	self.optLocation.top	:= theHeight;
	self.optLogId.top		:= theHeight;
	self.optSpecs.top		:= theHeight;
	self.tblSelection.top	:= self.optDocket.top + self.optDocket.height + 10;
	self.splitterFrame.top	:= self.tblSelection.top + self.tblSelection.height + 10;
//	self.splitterFrame.height := 70;
	self.txtDetails.height	:= self.splitterFrame.height;
	self.tblNewLogDetail.top:= self.splitterFrame.top + self.splitterFrame.height + 10;
	theHeight				:= self.tblNewLogDetail.top + self.tblNewLogDetail.height + 10;
	self.btnAdd.top			:= theHeight;
	self.btnRemove.top		:= theHeight;
	self.btnUpdate.top		:= theHeight;
	self.tblDisplayDetail.top	:= self.btnUpdate.top + self.btnUpdate.height + 10;
	self.tblActionData.top	:= self.tblDisplayDetail.top + self.tblDisplayDetail.height + 10;
	theHeight				:= self.tblActionData.top + self.tblActionData.height + 5;
	self.lblResidualH.top	:= self.btnAdd.top;
	self.lblResidual.top	:= self.btnAdd.top;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="residualLength" id="7baddf24-098b-4d95-85a9-04f5153f1352">
        <methodInvocation>mapping</methodInvocation>
        <source>residualLength(set: Boolean; _value: Decimal io) mapping;

vars

	newLog	: CMIF_LogRegrade;
	length	: Real;

begin

	if self.myLog = null or not global.isValidObject(self.myLog) then
		_value := 0;
		return;
	endif;
	if not set then
		foreach newLog in self.allNewLogs do
			length := length + newLog.length.Real;
		endforeach;
		_value := (self.myLog.logLength - length);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="residualVolume" id="2f9ab309-9d64-4d16-8e46-60853846a564">
        <methodInvocation>mapping</methodInvocation>
        <source>residualVolume(set: Boolean; _value: Decimal io) mapping;

vars
	newLog	: CMIF_LogRegrade;
	//volume	: Decimal[12,3];
	volume	: Decimal[12,4];//par13537 13657

begin
	if self.myLog = null or not global.isValidObject(self.myLog) then
		_value := 0;
		return;
	endif;
	if not set then
		foreach newLog in self.allNewLogs do
			volume := volume + newLog.jasVolume;
		endforeach;
		_value := (self.myLog.getMyTotalVolume - volume);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="selectNewLog" id="849e1fbe-f7f9-4b88-9170-483030d0e97e">
        <updating/>
        <source>selectNewLog(_row : Integer) protected, updating;



vars

	row 		: Integer;
	count		: Integer;
	docketDef	: CMIF_DocketLogDef;

	

begin

	// Select group of logs from  select data table.
	row := (_row - 1).max(1);
	if row &lt; self.tblDisplayDetail.rows then	
		self.tblDisplayDetail.accessRow(_row).selected := true;
		self.mySelectedNewLog := self.allNewLogs.at(row);
		self.loadNewLog();
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
