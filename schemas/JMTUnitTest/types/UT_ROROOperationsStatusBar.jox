	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 2);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="xPAR31367StatusBarStep5" id="8f46ae96-4c54-4ff4-adc4-94bdc60f2738">
        <updating/>
        <source>xPAR31367StatusBarStep5() updating;

/*

Purpose:		Colour code load slotsand check that status bar details are correct	

Date			Who		Reason
10/05/2013		cnwmh5	Initial creation

*/
constants

	ContainerPartialId					: String = 'UT31367';

vars

	port								: CM_Port;
	cargo								: CM_TrackedItem;
	realAlloc 							: CM_VoyageAllocation;
	
	roro20FTLCs 						: CM_LCArray;
	roro40FTLCs 						: CM_LCArray;
	altRoroLCs							: CM_LCArray;
	slotsToLoadCC						: StringArray;
	
	idx									: Integer;
	isoTypeStr 							: String;
	str									: String;
	cargoCount							: Integer;

begin

	app.writeLog("STEP 5", LogINFO);
	app.writeLog("Creating onsite containers.  Please wait...", LogINFO);
	
	// create the cargo in the bs for loading
	isoTypeStr := "U20G";
	cargoCount := 1;

	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	
	port := app.myRoot.allPorts["ITGOA"];
	self.assertNotNullMsg(port, "Null Port");
	
	foreach idx in 1 to 20 do
	
		self.cargoCountId := self.cargoCountId + 1;
	
		cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), isoTypeStr, "GENL", 
			TI_IMEX_STATUS_EXPORT, self.myBlockStack.myLocationsController, port, self.myVoyage);
		self.assertNotNull(cargo);
		self.deleteStops(cargo);
	
		if (isoTypeStr = "U20G" and cargoCount &lt;= 2) or (isoTypeStr = "U40G" and cargoCount &lt;= 3) then
			self.tisToPlanArray.add(cargo);
			cargoCount := cargoCount + 1;
		endif;	
	
		if idx = 10 then
			isoTypeStr := "U40G";
			cargoCount := 1;
		endif;
		
	endforeach;
	
	app.writeLog("Colour coding Load slots.  Please wait...", LogINFO);
	
	
	// Load Colour code the 20fts
	create altRoroLCs transient;
	altRoroLCs.clear();
	
	create roro20FTLCs transient;
	roro20FTLCs.clear();
	
	create slotsToLoadCC transient;
	slotsToLoadCC.add("D40181");
	slotsToLoadCC.add("D40131");
	
	foreach str in slotsToLoadCC do
		self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, str, roro20FTLCs, true, 1);
	endforeach;
	
	realAlloc := self.addVoyageAllocation(self.myVoyage, "ITGOA", "U20G", "", 1, false, false);	
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roro20FTLCs, altRoroLCs, 1);
	roro20FTLCs.copy(self.roroLCs);
	
	// setup load colour coding for 40' containers
	create roro40FTLCs transient;
	roro40FTLCs.clear();
	
	altRoroLCs.clear();
	
	slotsToLoadCC.clear();
	slotsToLoadCC.add("D40182");
	slotsToLoadCC.add("D40183");
	slotsToLoadCC.add("D40184");	
	
	foreach str in slotsToLoadCC do
		self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, str, roro40FTLCs, true, 1);
	endforeach;
	
	realAlloc := self.addVoyageAllocation(self.myVoyage, "ITGOA", "U40G", "", 1, false, false);	
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roro40FTLCs, altRoroLCs, 1);
	roro40FTLCs.copy(self.roroLCs);
		
	// check that the details of the status bar is correct
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013  | ");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeLoad, ShpDisplayModeSub_ExportsShow, method.qualifiedName, 1);

epilog

	
	delete roro20FTLCs;
	delete roro40FTLCs;
	delete altRoroLCs;
	delete slotsToLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="xPAR31367StatusBarStep6" id="b8fc30fc-d160-49af-8a9a-637b7b4c80dd">
        <updating/>
        <source>xPAR31367StatusBarStep6() updating;

/*

Purpose:		Create the load job and check that status bar details are correct	

Date			Who		Reason
13/05/2013		cnwmh5	Initial creation

*/
vars

	voyageJob							: CM_VoyageJob;

begin

	app.writeLog("STEP 6", LogINFO);
	app.writeLog("Creating Load job.  Please wait...", LogINFO);
	
	voyageJob := self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_31367Job1", self.roroLCs, false);
	assertTrue(voyageJob &lt;&gt; null);
	

	// check that the details of the status bar is correct
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013  |  Job: 202");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeLoad, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 1);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="xPAR31367StatusBarStep7" id="3b9fd6e1-18a9-4d73-8ef9-f56948c094cb">
        <updating/>
        <source>xPAR31367StatusBarStep7() updating;

/*

Purpose:		Plan 2 x 20 and 2 x 40 and check that status bar details are correct	

Date			Who		Reason
13/05/2013		cnwmh5	Initial creation

*/
vars

	realAlloc 							: CM_VoyageAllocation;
	lc									: CM_LocationsController;
	
	str									: String;

begin

	app.writeLog("STEP 7", LogINFO);
	app.writeLog("Planning 2 x 20 and 2 x 40.  Please wait...", LogINFO);
	
	// plan the containers 2 x 20 and 2 x 40
	self.locationArray.clear();
	self.locationArray.add("D40131");
	self.locationArray.add("D40181");
	self.locationArray.add("D40182");
	self.locationArray.add("D40183");
	
	self.roroLCs.clear();
	foreach str in self.locationArray do
		lc := self.myVoyage.getLocationByID(str);
		self.roroLCs.add(lc);
	endforeach;
	
	realAlloc := self.roroLCs.first.getRequest(true).getVoyageAllocations().first.CM_VoyageAllocation;
	self.planTIsRORO(self.tisToPlanArray, self.roroLCs, realAlloc.allRequests.first.CM_RORORequest);
	self.assertNoTrxErrorsOrWarnings();
	
	// check that the details of the status bar is correct - Planned 4 items
	app.writeLog("Checking Status Bar details are correct for 4 load planned items.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 2 x CONT ITGOA  U20G| 2 x CONT ITGOA  U40G | UT313670021, UT313670030, UT313670031, UT313670020 Job: 202");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeLoad, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 1);

	// check that the details of the discharge status bar is correct - SHOW EXPORTS
	app.writeLog("Checking Status Bar (SHOW) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018  | ");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013  | ");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsShow, method.qualifiedName, 2);
	
	// check that the details of the discharge status bar is correct - HIDE EXPORTS
	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004 Job: 200");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008 Job: 200");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012 Job: 201");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 3);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="xPAR31367StatusBarStep8" id="43d254c7-90e1-4b83-80b2-b46e4dd337ff">
        <updating/>
        <source>xPAR31367StatusBarStep8() updating;

/*

Purpose:		Plan 1 x 40 and check that status bar details are correct	

Date			Who		Reason
13/05/2013		cnwmh5	Initial creation

*/
vars

	realAlloc 							: CM_VoyageAllocation;
	lc									: CM_LocationsController;
	cargo								: CM_TrackedItem;
	
	str									: String;

begin

	app.writeLog("STEP 8", LogINFO);
