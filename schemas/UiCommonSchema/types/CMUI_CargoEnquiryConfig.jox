    <JadeMethod name="doDeleteTab" id="930ee7a8-7386-454e-b5d8-42b789c1cf90">
        <updating/>
        <source>doDeleteTab() updating, protected;

vars
	desc : String;
	row	: Integer;
begin
	if self.myUserConfigTab = null then
		return;
	endif;
	// can only delete if no attributes
	if self.myUserConfigTab.allAttributes.size &gt; 0 then
		return;
	endif;

	desc := self.myUserConfigTab.description;
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, desc), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_Yes then	
		delete self.myUserConfigTab;
		self.setChanged();
		row := self.tblTabs.row;
		if row &gt; self.tblTabs.fixedRows and 
		row &lt;= self.tblTabs.rows then
			self.tblTabs.removeItem(row);
			if row &gt; 1 then
				self.tblTabs.selectRow(row, true);
				self.doTblTabsSelect();		// select the next row
			endif;
			self.recolourTable(self.tblTabs);
		endif;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
