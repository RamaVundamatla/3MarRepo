    <JadeMethod name="click" id="1e1a3a78-c400-4963-b0eb-b77c263fcdb1">
        <updating/>
        <source>click(table:Table input) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowValues		: HugeStringArray;
	columnWidths	: IntegerArray;

begin
	inheritMethod(table);

	if (self.getRowObject() &lt;&gt; null) and (self.myDisplayPanel &lt;&gt; null) then
		create rowValues transient;
		create columnWidths transient;

		self.myDisplayPanel.displayPanel(self.getRowObject(), rowValues, columnWidths);
		self.myDisplayPanel.buildDisplayTable(rowValues, columnWidths);
	endif;

	self.myDisplayPanel.click(self.myDisplayPanel);
epilog
	if (rowValues &lt;&gt; null) then
		delete rowValues;
	endif;

	if (columnWidths &lt;&gt; null) then
		delete columnWidths;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="bef4baed-13aa-453f-b659-1e9a950e791b">
        <updating/>
        <source>dblClick(table: Table input) updating;

begin
	self.myDisplayPanel.dblClick(self.myDisplayPanel);
	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayEntry" id="ead3ff61-a0a7-42a7-a8f1-5ebd67f0d6e0">
        <updating/>
        <source>displayEntry(table:CnEcDesignTable input; obj:Any; columnHeading:String input):String updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if (self.myDisplayPanel &lt;&gt; null) then
		return self.myDisplayPanel.displayEntry(table, obj, columnHeading);
	else
		return inheritMethod(table, obj, columnHeading);
	endif;
end;</source>
        <Parameter name="table" type="CnEcDesignTable" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="columnHeading" type="String" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayPicture" id="c971d99e-8b0b-479e-b069-8baf46200156">
        <updating/>
        <source>displayPicture(table:CnEcDesignTable input; obj:Any; columnHeading:String input):Binary updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Purpose:		Extension to the standard JADE 'displayEntry' method for a listCollection.
//
// Parameters:	table (CnEcDesignTable) - That CnEcDesignTable control.
//				obj (Any) - The listCollection object for the current table row.
//				columnHeading (String) - The table column heading corresponding to the current listCollection object.
// Returns:		Binary - The binary (picture) value to be displayed for the listCollection enry.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if (self.myDisplayPanel &lt;&gt; null) then
		return self.myDisplayPanel.displayPicture(table, obj, columnHeading);
	else
		return inheritMethod(table, obj, columnHeading);
	endif;
end;</source>
        <Parameter name="table" type="CnEcDesignTable" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="columnHeading" type="String" usage="input"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="excludeObject" id="612c4d98-a374-47eb-9c26-9312b3efb955">
        <updating/>
        <source>excludeObject(obj:Object):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Purpose:		Extension to the standard JADE 'displayEntry' method for
//				a listCollection, only this method excludes the listCollection
//				entry from the display.
//
// Parameters:	obj (Any) - The listCollection object for the current table row.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if (self.myDisplayPanel &lt;&gt; null) then
		return self.myDisplayPanel.excludeObject(obj);
	else
		return inheritMethod(obj);
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="8e91a5d9-22d6-499a-bf5c-b0d323e3ada2">
        <updating/>
        <source>mouseMove(table:CnEcDataTable input; button:Integer; shift:Integer; x:Real; y:Real) updating;
// --------------------------------------------------------------------------------
// Created:		30 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	firstRowHeight	: Integer;
	otherRowHeight	: Integer;
 	helpRow			: Integer;
	currentRow		: Integer;

begin
	// If there is no data in the table then exit now

	if (table.rows &lt; 2) then 
		table.bubbleHelp	:=	null;
		return;
	endif; 

	firstRowHeight	:=	table.rowHeight[1];
	otherRowHeight	:=	table.rowHeight[2];

	// Save off the current row

	currentRow	:=	table.row;

	// Workout which row that we are in

	if (firstRowHeight &gt; y) then
		self.bubbleHelpRow	:=	0;
		table.bubbleHelp	:=	null;
		return;
	endif;

	helpRow	:=	(((y - firstRowHeight) / otherRowHeight) + table.topRow).Integer;

	if (helpRow &lt;&gt; self.bubbleHelpRow) then
		self.bubbleHelpRow	:=	helpRow;	

		if (helpRow &gt; table.rows) then 
			self.bubbleHelpRow	:=	0;
			table.bubbleHelp	:=	null;
			return;
		endif;

		// We can include some code here that will force a mouse move 
		// so as bubble help will be displayed for every row.... otherwise
		// it will only appear the once and there will be a need to move 
		// the mouse off the control and come back.

		table.row			:=	helpRow;
		table.bubbleHelp	:=	self.myDisplayPanel.displayBubbleHelp(table, table.getRowObject());
	endif;

	// Reset the current row back

	if (table.row &lt;&gt; currentRow) then
		table.row	:=	currentRow; 
	endif;
end;</source>
        <Parameter name="table" type="CnEcDataTable" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
