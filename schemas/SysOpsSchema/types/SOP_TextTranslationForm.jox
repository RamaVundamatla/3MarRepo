    <JadeMethod name="create" id="e648ee6e-b5a0-4dc5-a9de-f9e709da9e82">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
//--------------------------------------------------
// Created:	15 July 2005 By: RBarr
//
// Changed On   Changed By  PAR             Reason
// ----------   ----------  --------------  ----------------------------------
//  09/10/2009	cnwmh5		21251 		    Help file Added
// ---------------------------------------------------------------------------
//
vars

begin
	self.permissionView  := PmAdmTranslationView;
	self.permissionMaint := PmAdmTranslationMaint;
