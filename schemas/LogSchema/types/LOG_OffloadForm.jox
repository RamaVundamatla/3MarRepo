    <JadeMethod name="cmbVoyageGlobal_click" id="789e2b78-25b7-4601-9fcb-40369632cc62">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyageGlobal_click(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 07 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	voy				: CM_Voyage;
	globalVoy 		: CM_VoyageGlobal;
begin
	self.clearAll(false);
	if combobox.listObject = null then
		return;
	endif;
	
	globalVoy := combobox.listObject.CM_VoyageGlobal;
	self.tblSelection.setValueByControlName(combobox.name, globalVoy.code);
	self.loadSelectionCombos();
	self.cmbVoyOtherTerm.clear();
	
	if globalVoy &lt;&gt; null then

		foreach voy in globalVoy.allVoyages do
			if (not voy.archived) then
				//	29 Aug 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, don't show completed voyages
				if voy.isClosedStatus() then
					continue;
				endif;
				// need to add voyage arrival date after terminal name
				// if more than 1 visit to this terminal
				self.cmbVoyOtherTerm.addItemObject(voy.getComboBoxDisplayString (true), voy);
			endif;
		endforeach;
	endif;
	
	self.cmbVoyOtherTerm.lostFocus(self.cmbVoyOtherTerm);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbVoyageGlobal_displayEntry" id="b1357713-a8a3-4db8-89c0-4096192e49dd">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyageGlobal_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
//--------------------------------------------------------------
//Created: 07 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return obj.CM_VoyageGlobal.code &amp; '  ' &amp; obj.CM_VoyageGlobal.vesselName ;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbVoyageGlobal_lostFocus" id="4e3d538a-c8c0-46f5-8626-6668e7a38c8b">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyageGlobal_lostFocus(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 07 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	displayName : String;
begin
	if self.cmbVoyageGlobal.listObject &lt;&gt; null then
		displayName := self.cmbVoyageGlobal.listObject.CM_VoyageGlobal.code &amp; ' ' &amp; self.cmbVoyageGlobal.listObject.CM_VoyageGlobal.vesselName;
		self.tblSelection.setValueByControlName(combobox.name,displayName );
	endif;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
