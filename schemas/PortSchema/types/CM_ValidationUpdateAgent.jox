        <source>valTransferToBol(	_newBol : CM_BOL;
					_tis : CM_TIArray;
					_passport : CM_Passport input
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	if _newBol = null then
		app.raiseCMException( Input_required_field_bol, null, null);
	endif;
	if _tis = null or _tis.isEmpty then
		app.raiseCMException( Cargo_selected_transfer, null, null);
	endif;
	
epilog

end;</source>
