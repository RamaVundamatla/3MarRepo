    <JadeMethod name="getConvertedRate" id="2effe62e-8106-4fd1-a4ec-bb2be696abc8">
        <source>getConvertedRate(_exchangeRate : Decimal ) : Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Nov 2018	jlgma1	Bug 42218: PEL1 - International Tariff - Currency Conversion.
19 Mar 2021 cnwma1 ChangeRequest 50925: ASPA - New Total Column in Invoice Form
*/

vars
	convertedRate   : Real;
	remainder 	    : Real;
	truncatedRate   : Integer;  
	terminal 	    : CM_Terminal;
	roundDecimalOpt : Integer;
begin
	if self.myInvoiceLineType = null then
		convertedRate := self.rate;
	else
		if self.myInvoiceLineType.currencyConversionNotRequired then
			convertedRate := self.rate;
			
		else
			convertedRate := ( _exchangeRate * self.rate );
			
			if convertedRate &lt;&gt; 0 then
				truncatedRate := convertedRate.Integer;
				remainder := convertedRate - truncatedRate;
				terminal := self.myCashReceipt.getMyTerminal();
				if terminal &lt;&gt; null /*and terminal.getConfig(InvoiceRoundLineTotal).Boolean*/ then //19.03.2020 cnwma1 TFS #50925
				
					// ### JIRA 34909 16MAY2025 NAVAB1 - no rounding leave convertedRate as is
					if app.myPassport.context = Context_Pass_InvSplitMerge then	
						
					else
				
						roundDecimalOpt := terminal.getConfig(InvoiceRoundLineTotal).Integer;          //19.03.2020 cnwma1 TFS #50925
						
						if roundDecimalOpt &lt;&gt; CMIF_ConfigTerminal.InvLineRound_Value_NoRound then      //19.03.2020 cnwma1 TFS #50925
							//apply rounding
							if remainder &gt;= 0.5 then
								truncatedRate := truncatedRate + 1;
								convertedRate := truncatedRate;
							endif;
						endif;
					endif;
				endif;
				
				
			endif;
		endif;
		
	endif;
	return convertedRate;
epilog

end;</source>
        <Parameter name="_exchangeRate" type="Decimal"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="e1d7b17c-3f03-442b-9bc7-4cc84e324213">
