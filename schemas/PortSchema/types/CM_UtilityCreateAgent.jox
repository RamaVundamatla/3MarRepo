    <JadeMethod name="utlCreateInvoiceWeb" id="777d4227-2a8a-4206-a142-5f9108903093">
        <source>utlCreateInvoiceWeb(_proxyInvoice: CM_Invoice; _realInvoice: CM_Invoice output; _passport: CM_Passport input);
/*

Purpose:			
	
	Utl method to create the new persistent invoice and set its data from the proxy

Parameters:		

	_proxyInvoice 	: The proxy invoice to set the values for the real invoice
	_realInvoice	: The new real invoice to be set and created from the proxy invoice
	_passport		: The passport	

Return Value:		

	None

Date		Who		Reason
07/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/

vars
	description : String;
begin
	description := _proxyInvoice.narration;

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	_proxyInvoice.validateWebInvoice();

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _realInvoice persistent;
	_realInvoice.setForCreate(_proxyInvoice);
	_realInvoice.setForUpdateWeb(description, _proxyInvoice);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realInvoice);
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceCreate), false, _realInvoice);
	endif;
end;</source>
        <Parameter name="_proxyInvoice" type="CM_Invoice"/>
        <Parameter name="_realInvoice" type="CM_Invoice" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateJob" id="6962ec38-f532-4859-a154-14bb200891f8">
        <source>utlCreateJob(pProxyJob:CM_Job input; pNewJob:CM_Job output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lCMIF_Object	: CMIF_Object;
	lTIArray	: CM_TIArray;
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valJob(pProxyJob);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewJob as pProxyJob.class;
	pNewJob.setForCreate(pProxyJob, _passport.myTerminal);
	pNewJob.causeTerminalEvent(pNewJob.Event_Mode_Create);
end;</source>
        <Parameter name="pProxyJob" type="CM_Job" usage="input"/>
        <Parameter name="pNewJob" type="CM_Job" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateJobAndRequest" id="86bbbd38-7c74-4ddf-be41-5e70223d206e">
        <source>utlCreateJobAndRequest(pProxyJob:CM_Job input; 
						pNewJob:CM_Job output;
						pProxyRequest:CM_Request input; 
						pNewRequest:CM_Request output;
						_passport : CM_Passport input);
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valJob(pProxyJob);
	self.raiseExceptionIfNull(pProxyRequest, 'Request Proxy');
	
	pProxyRequest.validate(null);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewJob as pProxyJob.class;
	pNewJob.setForCreate(pProxyJob, _passport.myTerminal);
	
	pProxyRequest.setJob(pNewJob);	
	
	create pNewRequest as pProxyRequest.class persistent;
	pNewRequest.setForCreate(pProxyRequest);
	
	
	pNewJob.causeTerminalEvent(pNewJob.Event_Mode_Create);				

end;</source>
        <Parameter name="pProxyJob" type="CM_Job" usage="input"/>
        <Parameter name="pNewJob" type="CM_Job" usage="output"/>
        <Parameter name="pProxyRequest" type="CM_Request" usage="input"/>
        <Parameter name="pNewRequest" type="CM_Request" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
