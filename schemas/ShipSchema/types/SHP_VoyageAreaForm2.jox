    <JadeMethod name="doBtnPrintPrintClick" id="75b86afc-459e-4212-a101-41396efd9145">
        <updating/>
        <source>doBtnPrintPrintClick() updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 26/05/2015	cnwdap1		PAR #36269 Visual Stack Weights and Heights
// 12/02/2018	jlgns1		Bug 36889: SNO - Header in bay plan printing
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)

constants
	PAGELABELWIDTH = 250;	//300;

vars
	printFrame				: SHP_BayDrawingFrame;
	theReport 				: CMUI_ReportLine;
	percentDone 			: Decimal[3,0];
	tmpJadeReport  			: JadeReport;
	theScale 				: Real;
	largeTitle 				: String;
	noCargo 				: Boolean;
	tmpBayDrawingController	: SHP_BayDrawingController;
	tmpBay					: CM_BayVoyage;
	maxHeight,
	thePrintStyle			: Integer;
	tmpBayPage				: SHP_BayPage;
	baysFound				: Boolean;
	pass,
	passes,
	maxCells, 
	maxTiers				: Integer;
	onDeck,
	underDeck				: Boolean;
	overDeckHeight,
	underDeckHeight 		: Integer;	//Bug 36889
	removedBay 				: CM_BayVoyage;	//20 Jul 2020	NDL TFS 49795
	dummyBay 				: CM_BayVoyage;	//20 Jul 2020	NDL TFS 49795
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	// We clone the drawing controller as we use a different frame
	// to print on.
	tmpBayDrawingController := self.myBayDrawingController.getClone();
	tmpBayDrawingController.init(self.myCurrentVoyage, self.allSelectedHolds, self.myTerminal);		// PAR #36269
	//self.myBayDrawingController.allBays.copy(tmpBayDrawingController.allBays);					// PAR #36269
	self.myBayDrawingController.allBays.copyNoDuplicates(tmpBayDrawingController.allBays, false);	// PAR #36269
	
	//08 Feb 2018	NDL 	TFS 36914
	if self.chkPrintWorked.value then
		tmpBayDrawingController.setConfig( self.myBayDrawingController.myConfig );
		//tmpBayDrawingController.shipOtherSlotColor := self.myBayDrawingController.shipOtherSlotColor;
		tmpBayDrawingController.setDisplayMode( ShpDisplayMode_ColCodeLoad );
		if self.optPrintLoad.value then
			tmpBayDrawingController.printWorked := SHP_BayDrawingController.PrintWorkedLoad;
		elseif self.optPrintDischarge.value then
			tmpBayDrawingController.printWorked := SHP_BayDrawingController.PrintWorkedDischarge;
		elseif self.optPrintLoadAndDis.value then
			tmpBayDrawingController.printWorked := SHP_BayDrawingController.PrintWorkedBoth;
		endif;
		
		// TFS 37556
		tmpBayDrawingController.setViewMode(VIEW_DISPORT);
		if self.optPrintCommodityGroup.value then
			tmpBayDrawingController.setViewMode(VIEW_COMMODITY);
		endif;
	else
		tmpBayDrawingController.printWorked := 0;
	endif;

	printFrame := self.frmBayPrint;
	printFrame.borderStyle := BorderStyle_None;

	if self.optPrintSmall.value then
		thePrintStyle := CMUI_GridDrawingController.PrintOutput_Small;
		theScale := CMUI_GridDrawingController.ScaleFactor_PrintSmall;
	elseif self.optPrintMedium.value then
		thePrintStyle := CMUI_GridDrawingController.PrintOutput_Medium;
		theScale := CMUI_GridDrawingController.ScaleFactor_PrintMedium;
	else
		thePrintStyle := CMUI_GridDrawingController.PrintOutput_Large;
		theScale := CMUI_GridDrawingController.ScaleFactor_PrintLarge;
	endif;

	tmpBayDrawingController.showNoColours := self.chkPrintBW.value;
	tmpBayDrawingController.setAmPrinting(true, thePrintStyle, self.optODUDSeparate.value);
	
	//cnwrd swaped round //cnwrd1 par 22530 12.4.2010
	tmpBayDrawingController.setFontDefaults();
//	tmpBayDrawingController.setScale(theScale, true, true);  //overriding font in here due to super large bay plan
//	tmpBayDrawingController.setDrawingPositions();

	self.lblPrintProgress.caption := null;
	
	create theReport transient;
	self.myBayDrawingController.printWorked := tmpBayDrawingController.printWorked;	//09 Feb 2018	NDL	TFS 36914
	self.printInitHeader(theReport);
	self.myBayDrawingController.printWorked := 0;	//09 Feb 2018	NDL	TFS 36914

	app.printer.setMargins(Print_Landscape, 5, 5, 5, 5);
//	app.printer.setHeader(theReport.frHeader);
	app.printer.setHeader(null);
	app.printer.setFooter(null);
	app.printer.suppressDialog := true;
	app.printer.printPreview := false; // &lt;&lt;&lt; LEAVE THIS
	app.printer.documentType := Print_A4;

	maxHeight := app.printer.pageHeight();

	create tmpBayPage transient;
	tmpBayPage.init(tmpBayDrawingController);

	if thePrintStyle = CMUI_GridDrawingController.PrintOutput_Large then
		theReport.lblTitle02.drawFontBold := true;
		largeTitle :=  self.myCurrentVoyage.code.trimBlanks &amp; " - " &amp; 
					   self.myCurrentVoyage.vesselName.trimBlanks &amp; " BAY " ;
	else
		largeTitle := null;
	endif;

	create tmpJadeReport transient;
	tmpJadeReport.description := theReport.lblTitle02.caption[1:60];

	app.printer.setReport(tmpJadeReport);
	app.printer.drawWidth := 1;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. maxHeight " &amp; maxHeight.String);

// for testing
//printFrame.borderStyle := Frame.BorderStyle_Single;

	self.clearLegendAndAttributes(tmpBayDrawingController);		// 29/11/17 MAP TFS7494 clear the attributes set from displaying the form

	if thePrintStyle = CMUI_GridDrawingController.PrintOutput_Large and self.optODUDSeparate.value then		// 24/11/17 MAP TFS7494
		passes := 2;
	else
		passes := 1;
	endif;
	
	foreach tmpBay in tmpBayDrawingController.allBays do
		baysFound := true;
		foreach pass in 1 to passes do
			if passes = 1 then
				onDeck := true;
				underDeck := true;
			else
				if pass = 1 then
					onDeck := true;
					underDeck := false;
				else
					onDeck := false;
					underDeck := true;
				endif;
			endif;
			//	Bug 36889: SNO - Header in bay plan printing
			tmpBayDrawingController.setBayHeight(tmpBayDrawingController.getFrameHeightForBay(tmpBay,overDeckHeight,underDeckHeight));
			
			tmpBayDrawingController.setScale(theScale, onDeck, underDeck);  //overriding font in here due to super large bay plan
			tmpBayDrawingController.setDrawingPositions();

			if thePrintStyle = CMUI_GridDrawingController.PrintOutput_Large then
				// in large output only put one bay per page
				tmpBayPage.addBayToPage(tmpBay, printFrame, onDeck, underDeck, thePrintStyle, dummyBay);
			elseif tmpBayPage.addBayToPage(tmpBay, printFrame, onDeck, underDeck, thePrintStyle, removedBay) then
				// the bay can be printed on the page
				continue;
			endif;
			tmpBayDrawingController.allAttributeCodes.clear();		// 29/11/17 MAP TFS7494 rebuild these for each page
			// print out the page
			tmpBayPage.print(theReport, printFrame, largeTitle, onDeck, underDeck);
			// print the legend
			self.printLegend(tmpBayDrawingController, maxHeight, Print_Landscape);		
			
			if thePrintStyle = CMUI_GridDrawingController.PrintOutput_Large then
				noCargo := self.printCargoList(tmpBay, tmpBayDrawingController, tmpJadeReport);
				if noCargo then
					app.printer.newPage();
					self.clearLegendAndAttributes(tmpBayDrawingController);		// 29/11/17 MAP TFS7494 rebuild these for each page
				endif;
			else
				app.printer.newPage();
				self.clearLegendAndAttributes(tmpBayDrawingController);		// 29/11/17 MAP TFS7494 rebuild these for each page
			endif;
	
			// add the bay to the page
			tmpBayPage.clear();
			if (not thePrintStyle = CMUI_GridDrawingController.PrintOutput_Large) then
				if removedBay &lt;&gt; null then	//20 Jul 2020	NDL TFS 49795
					tmpBayPage.addBayToPage(removedBay, printFrame, onDeck, underDeck, thePrintStyle, dummyBay);
				endif;
				tmpBayPage.addBayToPage(tmpBay, printFrame, onDeck, underDeck, thePrintStyle, dummyBay);
			endif;
		endforeach;
	endforeach;
	if baysFound and (thePrintStyle &lt;&gt; CMUI_GridDrawingController.PrintOutput_Large) then
		// print the page
		tmpBayPage.print(theReport, printFrame, largeTitle, onDeck, underDeck);
		// print the legend
		self.printLegend(tmpBayDrawingController, maxHeight, Print_Landscape);		

		if thePrintStyle = CMUI_GridDrawingController.PrintOutput_Large then
			self.printCargoList(tmpBay, tmpBayDrawingController, tmpJadeReport);
		endif;
	endif;

//	self.lblPrintProgress.caption := "Printing 100%";
//	self.lblPrintProgress.refreshNow;

	self.lblPrintProgress.caption := null;
	app.printPreview(tmpJadeReport, true);
	
	if self.chkPrintSummary.value then
		self.printProfileSummaryReport();
	endif;

epilog
	// incase we crash with a printer error, reset
	app.printer.close();
	delete theReport;
	delete tmpBayDrawingController;
	delete tmpBayPage;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="57c1a67a-f4b2-4136-bc38-717e39533be5">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
13 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
15 July 2010		cnwdap1	PAR #25021 review use of isImport/isExport for tranships
*/
	
vars
	coll				: ObjectSet;
	cm_TrackedItem		: CM_TrackedItem;
	iter1				: Iterator;
	isVoyCC : Boolean;
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects (containers) to pass to the Summary Definition form.
	if self.myCurrentVoyage &lt;&gt; null then
		if self.displayMode = ShpDisplayMode_ColCodeLoad then
			// For the current voyage get the ONSITE tracked items.
			iter1	:= self.myCurrentVoyage.allNotifiedTIsByIdCargoType.createIterator;
			while iter1.next( cm_TrackedItem ) do 
				//if cm_TrackedItem.isExport then										// PAR #25021
				if cm_TrackedItem.isExport or cm_TrackedItem.isTranshipOutbound then	// PAR #25021
					coll.addNoDuplicates( cm_TrackedItem, false );
				endif;
			endwhile;
			
			iter1	:= self.myCurrentVoyage.allOnsiteTIsByIdCargoType.createIterator;
			while iter1.next( cm_TrackedItem ) do 
				//if cm_TrackedItem.isExport then										//PAR #25021
				if cm_TrackedItem.isExport or cm_TrackedItem.isTranshipOutbound then	//PAR #25021
					coll.addNoDuplicates( cm_TrackedItem, false );
				endif;
			endwhile; 
			isVoyCC := true;
		else
			// For the current voyage get the  ONSHIP tracked items.
			iter1	:= self.myCurrentVoyage.allOnshipTIsByIdCargoType.createIterator;
			while iter1.next( cm_TrackedItem ) do : cm_TrackedItem_loop
				coll.addNoDuplicates( cm_TrackedItem, false );
			endwhile cm_TrackedItem_loop;
			isVoyCC := false;
		endif;
	endif;
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, isVoyCC, true );
	
epilog
	delete coll;
	delete iter1;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarCRIB" id="74457034-6e92-4f15-af42-9e6da1e27761">
        <updating/>
        <source>doBtnToolBarCRIB() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
begin

	if self.displayMode = ShpDisplayMode_ColCodeLoad then
		self.updateSlotRequestAttribute(CM_SlotRequest.Attribute_Crib);
