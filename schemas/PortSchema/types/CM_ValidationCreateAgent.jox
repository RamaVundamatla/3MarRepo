    <JadeMethod name="valEDIData" id="cdb844ef-af4b-4685-bc33-209f69a1f08b">
        <source>valEDIData(_ediConfig: CM_EDIConfig; _fileName: String; _fileType : CM_EDIFileType);

//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	file	: File;
begin

	if _ediConfig = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'CM_EDIConfig', null, null);
		app.raiseCMException(Input_required_field_CM_EDICON, null, null); // cnwdb2	PAR 35364
	endif;
	
	self.raiseExceptionIfNull(_fileType, '_fileType');
	
	if (not app.myRoot.canDoEDIFileType(_fileType.type)) then
		app.raiseCMException1(NotLicensedToPerformAction, 'Extract EDI File Type ' &amp; _fileType.name, null, null);
		return;
	endif;

	if _fileType.isKindOf(CM_EDIFileTypeLoadListTI) then	// this is for development environment - to create Load List for making Load List Comparison
		return;
	endif;
	
	if _fileName = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'extract file name', null, null);
		app.raiseCMException(Input_required_field_extrctFle, null, null); // cnwdb2	PAR 35364
	else
		create file transient;
		file.kind := File.Kind_Unknown_Text;	// 26/2/16 cnwmp6 PAR 36286 unicode version
		file.fileName := _fileName;
		file.mode := File.Mode_Input;
		if file.isAvailable then
			app.raiseCMWarning3(ItemAlreadyExists, 'extract file', 'file', 'in existence.  OK to overwrite?',null, null,_fileType);
		endif;
		
	endif;
	
epilog
	delete file;	
end;</source>
        <Parameter name="_ediConfig" type="CM_EDIConfig"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
    </JadeMethod>
    <JadeMethod name="valEDIDataBOLOutLog" id="2991df35-94a3-4542-84ba-5359cdc0d0b7">
        <source>valEDIDataBOLOutLog(_pxyEDIDataBOLOutLog : CM_EDIDataBOLOutLog; _voyageGlobal : CM_VoyageGlobal; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyEDILog	: CM_EDIBOLOutLogTI;
	err			: CM_Error;
	str			: String;

begin
	self.raiseExceptionIfNull(_pxyEDIDataBOLOutLog, 'EDIDataBOLOutLog Proxy');
	_pxyEDIDataBOLOutLog.raiseExceptionIfNotTransient(method);

	_pxyEDIDataBOLOutLog.validateForCreate();

	foreach pxyEDILog in _pxyEDIDataBOLOutLog.allEDILogsByLotHatchPlace do
		app.myValCA.valEDIBOLOutLogTI(pxyEDILog, _voyageGlobal, _passport);
		if _passport.hasErrors then
			foreach err in _passport.allErrorWarnings do
				if str = null then
					str := err.text; 
				else
					str := str &amp; '; ' &amp; err.text;
				endif;
			endforeach;
			app.raiseCMException2(EDILogInvalid, pxyEDILog.id, ' unknown (' &amp; str &amp; ')', null, null);		
		endif;
	endforeach;
	
epilog
	
	
end;</source>
        <Parameter name="_pxyEDIDataBOLOutLog" type="CM_EDIDataBOLOutLog"/>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
