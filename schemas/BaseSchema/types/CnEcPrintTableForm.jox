    <JadeMethod name="nextTablePosition" id="f581d54c-d67a-49a4-97ae-b213a629876d">
        <updating/>
        <source>nextTablePosition(	pFrameObj:Frame input;
					pTableObj:Table input;
					pNextTopRow:Integer io; 
					pNextLeftColumn:Integer io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	Height_Correction	: Integer = 2;
	Width_Correction	: Integer = 2;
	
vars
	rowPointer			: Integer;
	colPointer			: Integer;
	rowHeight			: Integer;
	colWidth			: Integer;
	isGoToTop			: Boolean;
			
begin
	if (pNextTopRow = pTableObj.fixedRows + 1)
	and (pNextLeftColumn = pTableObj.fixedColumns + 1)
	then
		isGoToTop	:=	true;
	endif;

	colWidth	:=	self.aFixedColumnWidth;
	
	if pNextLeftColumn &gt; pTableObj.columns then
		colPointer	:=	pTableObj.fixedColumns + 1;
		isGoToTop	:=	true;
	else
		colPointer	:=	pNextLeftColumn;
	endif;

	pTableObj.leftColumn	:=	colPointer;
	
	while colPointer &lt;= pTableObj.columns and colWidth + pTableObj.columnWidth[colPointer] &lt;= self.aMaxTableWidth do
		if pTableObj.columnVisible[colPointer] then
			colWidth	:=	colWidth + pTableObj.columnWidth[colPointer];
		endif;
		
		colPointer	:=	colPointer + 1;
	endwhile;
	
	pNextLeftColumn	:=	colPointer;	
	pFrameObj.width	:=	colWidth + Width_Correction;

	if isGoToTop then
		rowHeight			:=	self.aFixedRowHeight;
		rowPointer			:=	pNextTopRow;
		pTableObj.topRow	:=	pNextTopRow;
		
		while rowPointer &lt;= pTableObj.rows and rowHeight + pTableObj.rowHeight[rowPointer] &lt;= self.aMaxTableHeight do
			rowHeight	:=	rowHeight + pTableObj.rowHeight[rowPointer];
			rowPointer	:=	rowPointer + 1;
		endwhile;
		
		pNextTopRow			:=	rowPointer;
		pFrameObj.height	:=	rowHeight + Height_Correction;
		pTableObj.height	:=	pFrameObj.height;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFrameObj" type="Frame" usage="input"/>
        <Parameter name="pTableObj" type="Table" usage="input"/>
        <Parameter name="pNextTopRow" type="Integer" usage="io"/>
        <Parameter name="pNextLeftColumn" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="printTable" id="32da28b9-c8aa-4329-806b-bf9cd97120c9">
        <updating/>
        <source>printTable(	pTableObj:Table input;
			pIsLandscape:Boolean; 
			pIsPreview:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	progressFormObj	: CnEcProgressForm;
	nextTopRow		: Integer;
	nextLeftColumn	: Integer;
	rowPointer		: Integer;
	colPointer		: Integer;
	fixedRows		: Integer;
	fixedCols		: Integer;
	printTableObj	: Table;
	
begin
	if pTableObj = null then
		return;
	endif;

	printTableObj	:=	tblPrint;
	
	if printTableObj.rows &lt;= printTableObj.fixedRows then
		return;
	endif;
	
	// Set up the progress dialog.
	create progressFormObj;
	progressFormObj.startProgress("Printing table contents...", 6);
	progressFormObj.show();
	
	foreach rowPointer in 1 to pTableObj.fixedRows do
		if (not pTableObj.accessRow(rowPointer).visible) then
			fixedRows	:=	fixedRows + 1;
		endif;		
	endforeach;
	
	progressFormObj.updateProgress(1);
	
	foreach colPointer in 1 to pTableObj.fixedColumns do
		if (not pTableObj.accessColumn(colPointer).visible) then
			fixedCols	:=	fixedCols + 1;
		endif;	
	endforeach;
	
	progressFormObj.updateProgress(2);
	
	// Copy the table
	self.copyTable(pTableObj, fixedRows, fixedCols);
	
	progressFormObj.updateProgress(3);

	// Now set topRow/leftColumn and height/width.
	self.setMaxTableHeight;
	self.setMaxTableWidth;
	self.setFixedRowHeight(printTableObj);
	self.setFixedColumnWidth(printTableObj);
	printTableObj.centreWindow();
	
	progressFormObj.updateProgress(4);
	
	if picLogo.picture = null then
		picLogo.visible		:=	false;
	else
		picLogo.borderStyle	:=	Picture.BorderStyle_None;
	endif;
	
	if picHeader.picture = null then
		picHeader.visible		:=	false;
	else
		picHeader.borderStyle	:=	Picture.BorderStyle_None;
	endif;
	
	nextTopRow		:=	printTableObj.fixedRows + 1;
	nextLeftColumn	:=	printTableObj.fixedColumns + 1;
	
	progressFormObj.updateProgress(5);
	
	while nextTopRow &lt;= printTableObj.rows or nextLeftColumn &lt;= printTableObj.columns do
		self.nextTablePosition(fraTable, printTableObj, nextTopRow, nextLeftColumn);
		app.printer.print(fraTable);
	endwhile;
	
	progressFormObj.updateProgress(6);
epilog
	delete progressFormObj;
end;</source>
        <Parameter name="pTableObj" type="Table" usage="input"/>
        <Parameter name="pIsLandscape" type="Boolean"/>
        <Parameter name="pIsPreview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printTableGeneric" id="e84ed5e4-d777-402e-a07e-f7fab4b4b2f4">
        <updating/>
        <source>printTableGeneric(	pHeaderObj:Frame;
					pTableObj:Frame input;
					pFooterObj:Frame;
					pTableInObj:Table input;
					pIsLandscape:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nextTopRow			: Integer;
	nextLeftColumn		: Integer;
	rowPointer			: Integer;
	colPointer			: Integer;
	rowCount			: Integer;
	colCount			: Integer;
	fixedRows			: Integer;
	fixedColumns		: Integer;
	fixedInvisibleRows	: Integer;
	fixedInvisibleCols	: Integer;
	
begin
	if tblPrint.rows = tblPrint.fixedRows then
		return;
	endif;
	
	rowCount	:=	pTableInObj.rows;
	colCount	:=	pTableInObj.columns;
	
	foreach rowPointer in 1 to pTableInObj.fixedRows do
		if (not pTableInObj.accessRow(rowPointer).visible) then
			fixedInvisibleRows	:=	fixedInvisibleRows + 1;
		endif;		
	endforeach;
	
	foreach colPointer in 1 to pTableInObj.fixedColumns do
		if (not pTableInObj.accessColumn(colPointer).visible) then
			fixedInvisibleCols	:=	fixedInvisibleCols + 1;
		endif;	
	endforeach;
	
	self.fraHeader	:=	pHeaderObj;
	self.fraTable	:=	pTableObj;
	self.fraFooter	:=	pFooterObj;
	
	rowCount	:=	pTableInObj.rows;
	colCount	:=	pTableInObj.columns;
	// now set topRow/leftColumn and height/width
	self.setMaxTableHeight;
	self.setMaxTableWidth;
	self.setFixedRowHeight(pTableInObj);
	self.setFixedColumnWidth(pTableInObj);
	
	nextTopRow		:=	(pTableInObj.fixedRows + 1);// - numInvisibleFixedRows;
	nextLeftColumn	:=	(pTableInObj.fixedColumns + 1);// - numInvisibleFixedCols;
	fixedRows		:=	pTableInObj.fixedRows;// - numInvisibleFixedRows;
	fixedColumns	:=	pTableInObj.fixedColumns;// - numInvisibleFixedCols;
	
	while nextTopRow &lt;= pTableInObj.rows or nextLeftColumn &lt;= pTableInObj.columns do
		self.getNextTablePos(pTableObj, pTableInObj, nextTopRow, nextLeftColumn, fixedRows, fixedColumns);
		app.printer.print(pTableObj);
	endwhile;
end;</source>
        <Parameter name="pHeaderObj" type="Frame"/>
        <Parameter name="pTableObj" type="Frame" usage="input"/>
        <Parameter name="pFooterObj" type="Frame"/>
        <Parameter name="pTableInObj" type="Table" usage="input"/>
        <Parameter name="pIsLandscape" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFixedColumnWidth" id="c37d3b3a-fbe8-4125-ac27-5ef09a51e9b9">
        <updating/>
        <source>setFixedColumnWidth(pTableObj:Table input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colPointer	:  Integer;
	
begin
	self.aFixedColumnWidth	:=	0;

	colPointer	:=	1;
	
	while colPointer &lt;= pTableObj.fixedColumns do
		if (not pTableObj.accessColumn(colPointer).visible) then
			colPointer	:=	colPointer + 1;
			continue;
		endif;
		
		self.aFixedColumnWidth	:=	self.aFixedColumnWidth + pTableObj.columnWidth[colPointer];
		colPointer				:=	colPointer + 1;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFixedRowHeight" id="333b7609-9b54-4b6f-89f8-b1a1e1ed8386">
        <updating/>
        <source>setFixedRowHeight(pTableObj:Table input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	:  Integer;
	
begin
	self.aFixedRowHeight := 0;

	rowPointer	:=	1;
	
	while rowPointer &lt;= pTableObj.fixedRows do
		if (not pTableObj.accessRow(rowPointer).visible) then
			rowPointer	:=	rowPointer + 1;
			continue;
		endif;
		
		self.aFixedRowHeight	:=	self.aFixedRowHeight + pTableObj.rowHeight[rowPointer];
		rowPointer				:=	rowPointer + 1;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHeaders" id="a59700d1-bdc0-4934-b4af-27e8bd845e60">
        <source>setHeaders(pHeading1:String; pHeading2:String);
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	StdHeaderFrmHeight	: Real = 55;
	
begin
	lblHeader1.caption	:=	pHeading1;
	
	if pHeading1 &lt;&gt; null then
		lblHeader1.visible	:=	true;
		lblHeader1.cnEcCenterOnParentHorizontal();
	endif;

	lblHeader2.caption	:=	pHeading2;
	
	if pHeading2 &lt;&gt; null then
		lblHeader2.visible	:=	true;
		lblHeader2.cnEcCenterOnParentHorizontal();
		fraHeader.height	:=	StdHeaderFrmHeight + lblHeader2.height;
	else
		fraHeader.height	:=	StdHeaderFrmHeight;
	endif;
end;</source>
        <Parameter name="pHeading1" type="String"/>
        <Parameter name="pHeading2" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMaxTableHeight" id="e426c389-11b2-476c-b87f-83321de0a1a7">
        <updating/>
        <source>setMaxTableHeight() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	Height_Correction	: Integer = 4;
	
vars
	headFrameObj	: Frame;
	footFrameObj	: Frame;
	
begin
	self.aMaxTableHeight	:=	app.printer.pageHeight();
	// Use "getPropertyValue" as this is a protected property in the printer class.
	headFrameObj	:=	app.printer.getPropertyValue(Printer::headerFrame.name).Frame;
	
	if headFrameObj &lt;&gt; null then
		self.aMaxTableHeight	:=	self.aMaxTableHeight - headFrameObj.height.Integer;
	endif;

	footFrameObj	:=	app.printer.getPropertyValue(Printer::footerFrame.name).Frame;
	
	if footFrameObj &lt;&gt; null then
		self.aMaxTableHeight	:=	self.aMaxTableHeight - footFrameObj.height.Integer;
	endif;

	self.aMaxTableHeight	:=	self.aMaxTableHeight - Height_Correction;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMaxTableWidth" id="2072d4c2-07d9-4e33-aff9-4a1e6f78b7e9">
        <updating/>
        <source>setMaxTableWidth() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	Width_Correction	: Integer = 4;
	
begin
	self.aMaxTableWidth	:=	app.printer.pageWidth();
	self.aMaxTableWidth	:=	self.aMaxTableWidth - Width_Correction;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setPictures" id="112362aa-4337-4664-a8b6-b0291e878964">
        <source>setPictures(pLogo:Binary; pHeader:Binary);
// --------------------------------------------------------------------------------
// Created:		21 April 2006 by cnwdad1
//
// Purpose:		Sets the pictures for a logo and header at the top of the page.
//
// Parameters:	pLogo - A picture of a product logo.
//				pHeader - A picture for a header image.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	picLogo.picture		:=	pLogo;
	picHeader.picture	:=	pHeader;
end;</source>
        <Parameter name="pLogo" type="Binary"/>
        <Parameter name="pHeader" type="Binary"/>
    </JadeMethod>
</GUIClass>
