    <JadeMethod name="saveShift" id="8712d6bd-eedd-4ad7-974e-84865c25f9f5">
        <updating/>
        <source>saveShift() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	shiftStd	: CM_ShiftEntity;
	errObj		: CM_Error;
	result		: Integer;
	tmpTerminal	: CM_Terminal;
begin
	tmpTerminal := self.myTerminal;
	
	if self.myProxyShift = null then
		if self.mode = MODE_ADD or self.mode = MODE_COPY then
			if self.optStandard.value then
				create self.myProxyShift as CM_ShiftStd transient;
			else
				create self.myProxyShift as CM_Shift transient;
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	if self.optStandard.value then
		self.setShiftStd(self.myProxyShift.CM_ShiftStd);
	else
		self.setShiftDay(self.myProxyShift.CM_Shift);
	endif;
	app.myPassport.setWarningsIgnored(false);
	
	while true do
		if self.mode = MODE_ADD or self.mode = MODE_COPY or self.mode = self.MODE_DELETE then // self.MODE_DELETEmeans create an actual CM_SHIFT, but ignore it.
			app.myTrxCA.trxCreateShift(self.myProxyShift, app.myPassport, self.myNewShift);
		else
			app.myTrxUA.trxUpdateShift(self.myProxyShift, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			
			return true;
		else
			result := app.showErrorWarningDialog('Worker Shifts', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

			errObj := app.myPassport.allErrorWarnings.first;
			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;	
	endwhile;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectObj" id="db2aa8e3-4b79-4e91-a097-978c6cdaba32">
        <updating/>
        <source>selectObj(_row : Integer; _refresh : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	obj	: Object;
	row	: JadeTableRow;
	shift : CM_ShiftStd;

begin

	row := self.tblShift.accessRow(_row);
	if row = null then
		return;
	endif;
	obj := row.itemObject;
	//obj := self.tblShift.accessRow(_row).itemObject.CM_Shift;
	self.tblShift.row := _row;
	if row.selected = false then
		row.selected := true;
	endif;
	self.myCurrentShift := obj.CM_ShiftEntity;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_refresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAddDialog" id="5645ce76-e581-4437-9b65-e3b8f886014e">
        <updating/>
        <source>setAddDialog() updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	seletedRow : Integer;
	shift : CM_ShiftStd;
begin
	if self.mode = MODE_ADD then
		self.cmbShiftType.listIndex := 1;
		self.timeStartTime.setTime(null);
		self.timeEndTime.setTime(null);
		self.txtCode.text := null;
		self.txtDesc.text := null;
		self.btnNext.caption := "Next";
		self.lblCaption.caption := "Add Standard Work Shift";
	elseif self.mode = MODE_EDIT or self.mode = MODE_COPY then
		if self.myCurrentShift = null then
			self.cmbShiftType.listIndex := 1;
		else
			self.cmbShiftType.listIndex := self.myCurrentShift.CM_ShiftStd.shiftDay;
		endif;
		self.timeStartTime.setTime(self.myCurrentShift.CM_ShiftStd.startTime.Time);
		self.timeEndTime.setTime(self.myCurrentShift.CM_ShiftStd.endTime.Time);
		self.txtCode.text := self.myCurrentShift.code;
		self.txtDesc.text := self.myCurrentShift.description;
		self.btnNext.caption := "Copy";
		
		if self.mode = MODE_EDIT then
			self.lblCaption.caption := "Edit Standard Work Shift";
		elseif self.mode = MODE_COPY then
			self.lblCaption.caption := "Copy Standard Work Shift";
		endif;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setAddDialogDay" id="3afe44c9-af82-46c1-8080-2adedeffdd97">
        <updating/>
        <source>setAddDialogDay() updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//15/04/20116 cnwns1 TFS 488 Multi Timezone
// ---------------------------------------------------------------------------

vars
	seletedRow : Integer;
	shift : CM_ShiftStd;
	localShiftStartTS : TimeStamp;
	localShiftEndTS : TimeStamp;
begin
	if self.mode = MODE_ADD then
		self.timeStartTimeDay.setTime(null);
		self.timeEndTimeDay.setTime(null);
		self.mskDateStart.setDate(null);
		self.mskDateEnd.setDate(null);
		self.txtCodeDay.text := null;
		self.txtDescDay.text := null;
//		self.btnNextDay.caption := "Next";
		self.lblCaptionDay.caption := "Add Work Shift";
	elseif self.mode = MODE_EDIT or self.mode = MODE_COPY then
		
		localShiftStartTS := self.myCurrentShift.CM_Shift.startDateTime;
		localShiftEndTS   := self.myCurrentShift.CM_Shift.endDateTime;
		
		self.mskDateStart.setDate(localShiftStartTS.date());
		self.timeStartTimeDay.setTime(localShiftStartTS.time());

		self.mskDateEnd.setDate(localShiftEndTS.date());
		self.timeEndTimeDay.setTime(localShiftEndTS.time());
		
		self.txtCodeDay.text := self.myCurrentShift.code;
		self.txtDescDay.text := self.myCurrentShift.description;
//		self.btnNextDay.caption := "Copy";
		if self.mode = MODE_EDIT then
			self.lblCaptionDay.caption := "Edit Work Shift";
		elseif self.mode = MODE_COPY then
			self.lblCaption.caption := "Copy Work Shift";
		endif;
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setFormMode" id="185703ec-1b9b-4699-a072-d0c3cd0ce7b8">
        <updating/>
        <source>setFormMode(_mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.mode := _mode;
	
	if _mode = self.MODE_VIEW then
		self.btnCancelBase.caption := '&amp;Close';
		self.tblShift.readOnly 			:= true;
		self.btnSaveBase.enabled 		:= false;
		self.btnDelete.enabled 			:= true;
		self.btnAdd.enabled 			:= true;
		self.btnEdit.enabled 			:= true;
		self.optByDate.enabled			:= true;
		self.optStandard.enabled		:= true;
		self.btnCancelBase.enabled		:= true;
		self.tblShift.enabled			:= true;
		self.btnRefresh.enabled			:= true;
	elseif _mode = self.MODE_ADD or _mode = self.MODE_EDIT or _mode = self.MODE_COPY then
		self.btnCancelBase.caption := '&amp;Cancel';
		self.tblShift.readOnly 			:= false;
		self.btnSaveBase.enabled 		:= true;
		self.btnDelete.enabled 			:= false;
		self.btnAdd.enabled 			:= false;
		self.btnEdit.enabled 			:= false;
		self.optByDate.enabled			:= false;
		self.optStandard.enabled		:= false;
		self.btnCancelBase.enabled		:= false;
		self.tblShift.enabled			:= false;
		self.btnRefresh.enabled			:= false;
	endif;
end;
</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setOptionFrame" id="2146740b-c0dd-456d-85c5-ba1e841eda6a">
        <updating/>
        <source>setOptionFrame() updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
