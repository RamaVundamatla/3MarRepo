    <JadeMethod name="getDisplayStringForAttribute" id="864a533c-be85-47fd-a76e-2be135bdc86d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 February 2004 By: cnwgd1
//--------------------------------------------------
//Changed: 16/05/2014 Reason: PAR#33977 cnwdb2
vars

begin
	if _attrName = ETRow_Description then
		return self.myWharf.description;
		
	elseif _attrName = ETRow_StartTime then
		return self.systemToLocalTime(startOfLockoutDT).time.String;	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif	_attrName = ETRow_EndTime then
		return self.systemToLocalTime(endOfLockoutDT).time.String;	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	
	elseif _attrName = ETRow_StartOfLockoutDT then
		return self.systemToLocalTime(startOfLockoutDT).date.asStringJMT;	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif	_attrName = ETRow_EndOfLockoutDT then
		return self.systemToLocalTime(endOfLockoutDT).date.asStringJMT;	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	else	
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="7c54bd4d-1ad0-4c42-aebc-b1c30a3b3099">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_WharfLockout;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myWharf := self.myWharf;
	proxy.myHarbour := self.myHarbour;
	proxy.myHarbourPermLockout := self.myHarbourPermLockout;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3b68d29f-37e8-4dea-b449-49f441c82732">
        <updating/>
        <source>setForUpdate(_pxyWharfLockout: HMS_WharfLockout; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyWharfLockout, _passport);
	
	self.endMarkOnWharf 		:= _pxyWharfLockout.endMarkOnWharf;
	self.endOfLockoutDT 		:= _pxyWharfLockout.endOfLockoutDT;
	self.myHarbour				:= _pxyWharfLockout.myHarbour;
	self.myHarbourPermLockout 	:= _pxyWharfLockout.myHarbourPermLockout;
	self.myWharf				:= _pxyWharfLockout.myWharf;
	self.code					:= self.myWharf.code.toUpper.trimBlanks;
	self.reason					:= _pxyWharfLockout.reason;
	self.startMarkOnWharf 		:= _pxyWharfLockout.startMarkOnWharf;
	self.startOfLockoutDT 		:= _pxyWharfLockout.startOfLockoutDT;

end;</source>
        <Parameter name="_pxyWharfLockout" type="HMS_WharfLockout"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="cb67af91-a684-4dd2-801c-2ac21cb56925">
        <updating/>
        <source>setProxy(_harbour : HMS_Harbour; _startDT, _endDT : TimeStamp)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myHarbour := _harbour;
	self.endOfLockoutDT := _endDT;
	self.startOfLockoutDT := _startDT;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_endDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="8d8fc88a-7f40-47a3-8c37-54d1ef9be653">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	02 March 2005 By: cnwgd1
//--------------------------------------------------

// 08/12/2014 cnwdb2 PAR 35364

vars

begin
	inheritMethod(_passport);
	if self.myHarbourPermLockout &lt;&gt; null then
	//	app.raiseCMWarning2(CONF_DELETE, 'PERMANENT lockout', self.reason, null, null, self.myHarbourPermLockout);
		app.raiseCMWarning1(Sure_want_delete35364h, self.reason, null, null, self.myHarbourPermLockout); //cnwdb2 PAR 35364

		
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="f5fbb90a-7342-43c0-9280-53e69942e1c5">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	tmpWharfLockout : HMS_WharfLockout;
begin
	inheritMethod(_passport);
	if self.endMarkOnWharf = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'End Mark On Wharf', ETRow_EndMarkOnWharf, null);
		app.raiseCMException(Input_required_field_endMrkWhf, ETRow_EndMarkOnWharf, null); // cnwdb2	PAR 35364
	endif;
	/*if self.startMarkOnWharf = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Start Mark On Wharf', ETRow_StartMarkOnWharf,  null);
	endif;*/
	if self.endOfLockoutDT = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'End Of Lockout DT', ETRow_EndOfLockoutDT,  null);
		app.raiseCMException(Input_required_field_endLockDT, ETRow_EndOfLockoutDT,  null); // cnwdb2	PAR 35364
	endif;
	if self.startOfLockoutDT = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Start Of Lockout DT', ETRow_StartOfLockoutDT,  null);
		app.raiseCMException(Input_required_field_srtLockDT, ETRow_StartOfLockoutDT,  null); // cnwdb2	PAR 35364
	endif;
	if self.reason = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Reason', ETRow_Reason,  null);
		app.raiseCMException(Input_required_field_reason, ETRow_Reason,  null); // cnwdb2	PAR 35364
	endif;			

	if self.myWharf = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Wharf', ETRow_MyWharf,  null);
		app.raiseCMException(Input_required_field_wharf, ETRow_MyWharf,  null); // cnwdb2	PAR 35364
	endif;
	if self.myHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbour,  null);
		app.raiseCMException(Input_required_field_harbour, ETRow_MyHarbour,  null); // cnwdb2	PAR 35364
	endif;	

	if self.startOfLockoutDT &gt; self.endOfLockoutDT then
		app.raiseCMException2(ERR_LOWER_GT_UPPER, 'Start Date', 'End Date', null, null);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	tmpWharfLockout := self.myWharf.allWLockoutsByBothDT.getAtKey(self.startOfLockoutDT, self.endOfLockoutDT, self.startMarkOnWharf, self.endMarkOnWharf);
	if tmpWharfLockout &lt;&gt; null then
		if self.isTransient and tmpWharfLockout &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'WharfLockout', self.startOfLockoutDT.shortCurrentLocaleFormat, ETRow_StartMeterage, null); //14.06.2022 navds20 53760
			// WharfLockout already exists for 1% : Wharflocko_already_exists
			app.raiseCMException1(Wharflocko_already_exists, self.startOfLockoutDT.shortCurrentLocaleFormat, ETRow_StartMeterage, null); //14.06.2022 navds20 53760
		endif;
	endif;
	
	self.myWharf.validateRangeForResource(self.startMarkOnWharf, self.endMarkOnWharf, 'Wharf lockout ' &amp; self.code, _passport);
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
