    <JadeMethod name="checkEndTime" id="9bce1d2f-f9ef-4fe2-822a-a3b34c1b97a1">
        <source>checkEndTime() : Boolean;

// cnwdvb1 20 December 2002 

vars

begin

	if self.runTs = null and self.isActive = Schedule_Is_Active then
		return false;
	endif;
	
	if self.endScheduleTs = null then
		return true;
	endif;
	
	if self.runTs &gt; self.endScheduleTs then
		return false;
	endif;
	
	if app.actualTimeServer &gt; self.endScheduleTs then
		return false;
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTimes" id="8526064b-16f9-40ff-995d-710614811e92">
        <source>checkTimes(_newTimeStamp : TimeStamp input; _actualTime : TimeStamp) : Boolean protected;

// cnwdvb1 19 December 2002 

vars

	theTime 		: Time;

begin

	foreach theTime in self.allRunTimes do
		_newTimeStamp.setTime(theTime);
		if _newTimeStamp &gt; _actualTime then
			return true;
		endif;
	endforeach;
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_newTimeStamp" type="TimeStamp" usage="input"/>
        <Parameter name="_actualTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
