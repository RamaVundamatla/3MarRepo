    <JadeMethod name="fixCustomerName" id="30bbb88f-cba1-40b2-9b75-6ab20b7780e8">
        <source>fixCustomerName();

/*

Purpose:			Change the customer name on all old patches from the old name to the new name

Parameters:			

Return Value:		


Date			Who		Reason
12 October 2018	jlgmd1	Initial creation TFS 38497

*/

constants
	//OldCustName: String = 'Milaha';
	//NewCustName: String = 'Qatar Navigation Port Services';
	OldCustName: String = 'Diversified Port Holdings';
	NewCustName: String = 'Patriot Ports';
	//OldCustName: String = 'Pelindo 1';
	//NewCustName: String = 'Pelindo';
vars
	patch : Patch;
	topic, str, custStr : String;
	idx : Integer;
begin
	//beginTransaction;
	foreach patch in Patch.instances do
		topic := patch.readme_parTopic;	// PAR-38732, Advised by : Milaha
		idx := 1;
		str := topic.scanUntil(":", idx) &amp; ":";
		custStr := topic[idx+2:end];
		if custStr = OldCustName then
			str := str &amp; " " &amp; NewCustName;
			
			write "Changing " &amp; topic &amp; " -&gt; " &amp; str;
			//patch.setPropertyValue('readme_parTopic', str);
		else
			//write "NOT Changing " &amp; topic;
		endif;
	endforeach;
	//commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="gdkUpgradeScripts772to782" id="8ede9566-0f75-4cc6-a6f4-ef230cf6f4e2">
        <source>gdkUpgradeScripts772to782(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2010	cnwmd1	Initial creation

*/
constants
	Output_Folder : String = "F:\SETUP\782\JARI\772to782WorkingDir\UpgradeScripts\";
	Base_Folder : String = 'F:\SETUP\';
	Base_773_Folder : String = '773';
	Base_781_Folder : String = '781';
	Base_782_Folder : String = '782';
	Hotfixes_Folder : String = 'Hotfixes';
	JadeMaster_Folder : String = 'JadeMaster';
	Schemas_Folder : String = 'Schemas';
	Install_File : String = 'JMTInstall.txt';
	Cmd_Schema : String = 'SCM';
	Cmd_RunJade : String = 'RUNJADE';
	Cmd_SchemaCheck : String = 'SCMCHK';
	PortSchema : String = 'PortSchema';
	Delimeter : String = ',';
vars
	basefolder, hotfixesFolder : FileFolder;
	fileNode, hotfixesNode, patchNode : FileNode;
	installFile, schemaFile, outputFile : File;
	cmdLine, release, hotfix, patch, par, portSchemaFileName, tmpStr : String;
	pos, numPatches, numScripts : Integer;
	ts : TimeStamp;
begin
	write 'Start...';
	tmpStr := ts.literalFormat;
	tmpStr.replaceChar(':', ' ');
	create outputFile transient;
	outputFile.fileName := Output_Folder &amp; tmpStr &amp; '.csv';
	outputFile.mode := File.Mode_Output;
	
	create basefolder transient;
	create hotfixesFolder transient;
	basefolder.usePresentationFileSystem := true;
	basefolder.fileName := Base_Folder;
	foreach fileNode in basefolder.files() do
		if fileNode.class = FileFolder and (fileNode.name = Base_773_Folder or fileNode.name = Base_781_Folder or fileNode.name = Base_782_Folder) then
			release := fileNode.name;
			hotfixesFolder.fileName := fileNode.fileName &amp; '\' &amp; Hotfixes_Folder;
			if not hotfixesFolder.isAvailable() then write 'Aborting - Hotfixes Folder not available'; return null; endif;
			foreach hotfixesNode in hotfixesFolder.files where hotfixesNode.class = FileFolder do
				hotfix := hotfixesNode.name[hotfixesNode.name.pos('_', 1) + 1 : end];
				foreach patchNode in hotfixesNode.FileFolder.files where patchNode.class = FileFolder and patchNode.name &lt;&gt; JadeMaster_Folder and patchNode.name[1:3] &lt;&gt; release do
					patch := patchNode.name[1:3];
					par := patchNode.name[8:end];
					numPatches := numPatches + 1;
					create installFile transient;
					installFile.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
					installFile.fileName := patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Install_File;
					installFile.mode := File.Mode_Input;
					installFile.open;
					while not installFile.endOfFile do
						cmdLine := installFile.readLine;
						if cmdLine[1:6] = Cmd_SchemaCheck then
							continue;
						elseif cmdLine[1:3] = Cmd_Schema then
							//pos := cmdLine.pos(release &amp; '_', 6); //pos sh'd be &gt; 0
							pos := cmdLine.pos('::', 1) + 2;
							tmpStr := cmdLine[pos : cmdLine.pos('::', pos) - pos];
							if tmpStr[1:10] = PortSchema then //appJadeScript will always be in portSchema file
								portSchemaFileName := tmpStr;
							endif;
						elseif cmdLine[1:7] = Cmd_RunJade then
							write 'JadeScript for release/patch ' &amp; release &amp; '/' &amp; patch &amp; '    ' &amp; patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder &amp; '\' &amp; portSchemaFileName &amp; '.scm';
							outputFile.writeLine(release &amp; Delimeter &amp; patch &amp; Delimeter &amp; par &amp; Delimeter &amp; hotfix &amp; Delimeter &amp; patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder &amp; '\' &amp; portSchemaFileName &amp; '.scm');
							numScripts := numScripts + 1;
							//schema := cmdLine[10:cmdLine.pos('::', 10) - 10];
							/*create schemaFile transient;
							//schemaFile.fileName := patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder &amp; '\' &amp; schema &amp; '_' &amp; release &amp; '_' &amp; patch &amp; '.scm';
							schemaFile.fileName := patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder &amp; '\' &amp; portSchemaFileName;
							schemaFile.mode := File.Mode_Input;
							schemaFile.open;
							
							schemaFile.close;
							delete schemaFile;
							*/
						endif;
					endwhile;
					installFile.close;
					delete installFile;
				endforeach;
			endforeach;
		endif;
	endforeach;
epilog
	return outputFile.fileName;
	delete basefolder;
	delete hotfixesFolder;
	outputFile.close;
	delete outputFile;
	write 'Number of Patches: ' &amp; numPatches.String;
	write 'Number of Scripts: ' &amp; numScripts.String;
	write 'Finish...';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUpgradeStats" id="30e1f9db-3085-4ee1-b891-25fbcf58ec3a">
        <source>getUpgradeStats();

/*

Purpose:			Output run times for each step in a JMT Upgrade
					This can be multiple releases eg 773, 781 &amp; 782.  Change the ReleasesToEvaluate constant. Seperate each release with a comma.
					Output is written to a directory as specified in the Output_Folder
					Filename contains the date and time

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2010	cnwmd1	Initial creation

*/
constants
	Output_Folder : String = "F:\SETUP\782\JARI\772to782WorkingDir\UpgradeScripts\";
	JAPInstallLog : String = "F:\KPD\logs from tracker 313527\JAPInstall.log";   //&lt;-- Change JAPInstall Log
	Base_Folder : String = 'F:\SETUP\';
	ReleasesToEvaluate : String = '773,781,782';   //&lt;-- Change Releases
	Hotfixes_Folder : String = 'Hotfixes';
	JadeMaster_Folder : String = 'JadeMaster';
	Schemas_Folder : String = 'Schemas';
	Install_File : String = 'JMTInstall.txt';
	//Cmd_MajorRel : String = 'JMT Major Release';
	//Cmd_ReportLoad : String = 'Report All load';
	//Cmd_RunJadeApp : String = 'Run Jade Application';
	//Cmd_ReturnValue : String = 'Return Value';
	Cmd_Step : String = 'Step(';
	Cmd_Scm_File : String = 'SCM file ';
	Cmd_Report_File : String = 'Report Definition ';
	Cmd_ReportView_File : String = 'Report View ';
	Delimeter : String = ',';
	Ext_SCM : String = '.scm';
	Ext_RWR : String = '.rwr';
	Ext_RWV : String = '.rwv';
vars
	basefolder, hotfixesFolder, schemaFolder : FileFolder;
	fileNode, hotfixesNode, patchNode, schemaNode : FileNode;
	japInstallLog, outputFile : File;
	cmdLine, release, hotfix, patch, par, element, tmpStr, startCmd, scmFile, ext : String;
	pos, pos2, numPatches, currStep, cmdStep : Integer;
	ts : TimeStamp;
	startTime, endTime : TimeStamp;
	strArr : StringArray;
begin
	write 'Start...';
	tmpStr := ts.literalFormat;
	tmpStr.replaceChar(':', ' ');
	create outputFile transient;
	outputFile.fileName := Output_Folder &amp; tmpStr &amp; '.csv';
	outputFile.mode := File.Mode_Output;
	
	create strArr transient;
	
write 'Phase 1: Assemble schema file info';
	create basefolder transient;
	basefolder.usePresentationFileSystem := true;
	basefolder.fileName := Base_Folder;
	create hotfixesFolder transient;
	create schemaFolder transient;
		
	foreach fileNode in basefolder.files() do
		if fileNode.class = FileFolder and (ReleasesToEvaluate.pos(fileNode.name, 1) &gt; 0) then
			release := fileNode.name;
			
			//Major Release (JadeMaster Folder)
			schemaFolder.fileName := fileNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder;
			foreach schemaNode in schemaFolder.files do //where schemaNode.name[schemaNode.name.length - 3:end].toLower = '.scm' do
				ext := schemaNode.name[schemaNode.name.length - 3:end].toLower;
				if ext = Ext_SCM or ext = Ext_RWR or ext = Ext_RWV then
					strArr.add(schemaNode.name &amp; Delimeter &amp; release &amp; Delimeter &amp; '' &amp; Delimeter &amp; '' &amp; Delimeter &amp; '');
				endif;
			endforeach;
			
			//Hotfixes
			hotfixesFolder.fileName := fileNode.fileName &amp; '\' &amp; Hotfixes_Folder;
			foreach hotfixesNode in hotfixesFolder.files where hotfixesNode.class = FileFolder do
				hotfix := hotfixesNode.name[hotfixesNode.name.pos('_', 1) + 1 : end];
				foreach patchNode in hotfixesNode.FileFolder.files where patchNode.class = FileFolder and patchNode.name &lt;&gt; JadeMaster_Folder and patchNode.name[1:3] &lt;&gt; release do
					patch := patchNode.name[1:3];
					par := patchNode.name[8:5];
					
					//Get Schema Node
					//Iterate thru each file where file is scm
					//Save to array
					
					schemaFolder.fileName := patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder;
					foreach schemaNode in schemaFolder.files do //where schemaNode.name[schemaNode.name.length - 3:end].toLower = '.scm' do
						ext := schemaNode.name[schemaNode.name.length - 3:end].toLower;
						if ext = Ext_SCM or ext = Ext_RWR or ext = Ext_RWV then
							strArr.add(schemaNode.name &amp; Delimeter &amp; release &amp; Delimeter &amp; hotfix &amp; Delimeter &amp; patch &amp; Delimeter &amp; par);
						endif;
					endforeach;
				endforeach;
			endforeach;
		endif;
	endforeach;

write 'Phase 2: Iterate thru each instruction in japInstall file, get schema info, output to csv file';
	create japInstallLog transient;
	
	//strArr.inspectModal;
	japInstallLog.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	japInstallLog.fileName := JAPInstallLog;
	japInstallLog.mode := File.Mode_Input;
	japInstallLog.open;
	startCmd := 'Initialize';
	cmdLine := japInstallLog.readLine; //Get first line - should be a timestamp
	startTime.setDate(cmdLine[5:10].Date);
	startTime.setTime(cmdLine[16:8].Time);
	endTime.setDate(startTime.date);
	release := null;
	hotfix := null;
	patch := null;
	par := null;	
	
	while not japInstallLog.endOfFile do
		cmdLine := japInstallLog.readLine;
		
		pos := cmdLine.pos(Cmd_Step, 1);
		if pos = 0 then
			continue;
		endif;
		pos := pos + Cmd_Step.length;
		pos2 := cmdLine.pos(')', pos + 1);
		cmdStep := cmdLine[pos : pos2 - pos].Integer;

		if cmdStep &lt;&gt; currStep then
			endTime.setTime(cmdLine[1:8].Time); 
			if startTime.time &gt; endTime.time then //handle if deploy goes after midnight - japInstall file only outputs time...
				endTime.setDate(startTime.date.addDays(1));
			endif;
			
			outputFile.writeLine(currStep.String &amp; Delimeter &amp; release &amp; Delimeter &amp; hotfix &amp; Delimeter &amp; patch &amp; Delimeter &amp; par &amp; Delimeter &amp; startTime.String &amp; Delimeter &amp; endTime.String &amp; Delimeter &amp; (startTime.cnEcDiff(endTime).Integer / 1000).String &amp; Delimeter &amp; startCmd); //elapsed time in seconds
			if endTime.date &gt; startTime.date then
				startTime.setDate(endTime.date);
			endif;
		
			startTime.setTime(cmdLine[1:8].Time);
			startCmd := cmdLine;
			currStep := cmdStep;
			
			release := null;
			hotfix := null;
			patch := null;
			par := null;
		endif;
		
		if cmdLine.reversePos(' found') &gt; 0 and (cmdLine.pos(Cmd_Scm_File, 1 ) &gt; 0 or cmdLine.pos(Cmd_Report_File, 1 ) &gt; 0 or cmdLine.pos(Cmd_ReportView_File, 1 ) &gt; 0) then 
			//Get current scm
			pos2 := cmdLine.reversePos(' found');
			pos := cmdLine.reversePos('\');
			pos := pos + 1;
			scmFile := cmdLine[pos : pos2 - pos].toLower;
			foreach element in strArr do
				if element.getCSVField(1).toLower = scmFile then
					release := element.getCSVField(2);
					hotfix := element.getCSVField(3);
					patch := element.getCSVField(4);
					par := element.getCSVField(5);
					break;
				endif;
			endforeach;
		endif;
	endwhile;
epilog
	delete basefolder;
	delete hotfixesFolder;
	delete schemaFolder;
	outputFile.close;
	delete outputFile;
	delete strArr;
	write 'Finished';
end;</source>
    </JadeMethod>
    <JadeMethod name="startPatch" id="43f7cfa0-309f-45c6-b349-571d98f9b890">
        <source>startPatch();
// created by cnwvu1 on 11/03/2007
vars
	rtH					: RootHotFixes;
//	rt	: RootPatch;
	p				: Patch;
	strReadme		: StringArray;
	listOfPars		: FileNodeArray;
	newPatchNo		: String;
	// Parameters from the Form
	findNewPatchNo	: Boolean;
	newPatchNo_forced	: String;
	
begin

//	Parameters from the Form
	findNewPatchNo	:= true;
	newPatchNo_forced	:= '123';

	app.appStartHotFixKarma();
	
	create strReadme transient;
	create listOfPars transient;
	
			write '';
			write '';
			write ' __________________ Creating PAR __________________';

	rtH	:= app.myRootHotFix;//RootHotFixes.firstInstance;
	p	:= Patch.firstInstance;
			
	if (rtH = null) or (rtH.dirSetupHotFixes = null) then
		if not rtH.initRootHotFixes( 'C:\Setup', '742' ) then
			return;
		endif;
	endif;

// ______________________ getting the new Patch number __________________________
	if not findNewPatchNo then
		newPatchNo := newPatchNo_forced;
	else
		if not rtH.getPatchNoForNewPar( newPatchNo, '751' ) then
			return;
		endif;
	endif;

	beginTransaction;
	p.setPatchNo( newPatchNo, app.myRootHotFix.releaseVersionNo);
//	self.resynchObject(p);
	
// ______________________ create all directories for the new Patch __________________________
	if not rtH.createDirsForHotFix( 1, newPatchNo &amp; rtH.DIR_PART_PAR &amp; p.parNo, '', newPatchNo, false, false ) then
		abortTransaction;
		return;
	endif;

// ______________________ creating all files for the new Patch _____________________________
	if not p.createFilesForPatch( newPatchNo, false, false, false ) then
		abortTransaction;
		write('');
		write(' Creation of the PAR has been failed...');
		write('');
		return;
	endif;
	
	commitTransaction;	
	
	write('');
	write(' The Patch ' &amp; p.patchNo &amp;'_'&amp; p.parNo &amp; ' has been created on a disk.');
	write('');
	
epilog
	delete strReadme;
	delete listOfPars;

end;
</source>
    </JadeMethod>
</Class>
