    <JadeMethod name="tblDataDisplayRow" id="01a3b52f-763b-4e5f-af3a-7ef1911e64eb">
        <source>tblDataDisplayRow(_eventRequest : CM_EventRequest);
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	backColour,
	idx : Integer;
	failedDAC  :CM_DataAccessController;
begin

	if not _eventRequest.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
		return;
	endif;
	
	if (not app.getMyUser.canUserAccessObj(_eventRequest.myOrganisation, CM_Organisation)) then
		return;
	endif;
	
	if self.myCMIFSearchEventRequest &lt;&gt; null then
		if (not _eventRequest.matchesSearchCriteria(self.myCMIFSearchEventRequest)) then
			return;
		endif;
	endif;
	
	
	str := _eventRequest.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	idx := self.tblData.addItemObject(_eventRequest, str);
	if idx mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;			
	self.tblData.accessRow(idx).backColor := backColour;
	
end;</source>
        <Parameter name="_eventRequest" type="CM_EventRequest"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="a1ba07fd-f400-482b-a088-143db5e3d02b">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.doBuildMnuTblObj();		
	
	self.popupMenu(self.mnuContextTbl, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="007a14b7-f0a0-4dd7-a76c-03052cee34d8">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
// Reimplemented on 11/05/2009 cnwdz2 par 19625
//--------------------------------------------------
vars
	theRow	: Integer;
begin
	theRow := table.row;
	
	if theRow &lt;= 0 then
		return;
	endif;
	
	if theRow = 1 then
		if self.mode = self.Mode_View then
			self.zTblDataResort();
		endif;
	else
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			return;
		endif;
		if self.myCurrentEventRequest &lt;&gt; null then
			self.showEventRequestModal(self.Mode_Update);
		else
			self.showEventRequestModal(self.Mode_Add);
		endif;
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_keyDown" id="53b3e24e-0cd7-47be-86a7-4400cca4c7d3">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	08 June 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if keyCode = J_key_Delete 
	and (not self.frmSearch.visible) then
		self.doDelete();
	endif;		
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="607a5af3-c3e2-4cdd-9fc4-68bc3f88a9ef">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_rowColumnChg(table: Table input) updating;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myCurrentEventRequest := table.accessRow(table.row).itemObject.CM_EventRequest;
	if app.isAllowedToInspect() then
		self.mnuInspect.visible := true;
		self.mnuInspect.userObject := self.myCurrentEventRequest;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d532a250-c04b-4455-9784-5533849073a9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007427, locale);
	btnCloseSearch.translateCaption(Xlat_0000390, locale);
	btnDelete.translateCaption(Xlat_0000394, locale);
	btnEdit.translateCaption(Xlat_0000395, locale);
	btnNew.translateCaption(Xlat_0000396, locale);
	btnPrint.translateCaption(Xlat_0000397, locale);
	btnReportOptions.translateBubbleHelp(Xlat_0000384, locale);
	btnReportOptions.translateCaption(Xlat_0000385, locale);
	btnResetSearch.translateCaption(Xlat_0000391, locale);
	btnSearch.translateCaption(Xlat_0000398, locale);
	btnSelectAll.translateBubbleHelp(Xlat_0000392, locale);
	btnSelectAll.translateCaption(Xlat_0000393, locale);
	btnShowSearch.translateCaption(Xlat_0000417, locale);
	mnuActivateRequest.translateCaption(Xlat_0018033, locale);
	mnuAddRequest.translateCaption(Xlat_0007428, locale);
	mnuAudits.translateCaption(Xlat_0019707, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0007429, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0007430, locale);
	mnuContextTbl.translateCaption(Xlat_0007431, locale);
	mnuDeleteRequest.translateCaption(Xlat_0007432, locale);
	mnuEditRequest.translateCaption(Xlat_0007433, locale);
	mnuInspect.translateCaption(Xlat_0007434, locale);
end;</source>
    </JadeMethod>
