        <source>trxDeleteDBPurgeVehicleVisits(_vehicle : CM_Vehicle; _ts : TimeStamp; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 24 August 2004 by cnwdvb1
// -------------------------------------------
// SPECIAL TRX FOR GARBAGE COLLECTION.
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX
	on LockException do app.alertLockExceptionHandler(exception);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityDA.utlDeleteVehicleHistory(_vehicle, _ts, _agent);
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
