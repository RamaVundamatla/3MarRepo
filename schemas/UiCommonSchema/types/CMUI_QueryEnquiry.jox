    <JadeMethod name="doTblDataMouseDown" id="240f0612-98ff-4b4f-80c6-8eb4ac422ffd">
        <updating/>
        <source>doTblDataMouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if y &lt;= table.defaultRowHeight then
		table.clearAllSelected();
	endif;

	self.origXPos := x;
	self.origYPos := y;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
