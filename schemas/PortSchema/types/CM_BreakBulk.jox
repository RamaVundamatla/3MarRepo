    <JadeMethod name="getDisplayStringForAttribute" id="8d007655-55de-4200-99fe-e7dbb21a0bce">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     18 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
04 Aug 2016 cnwma1	TFS 2430:Unexpected Program Error in UiCommonSchema : : msgBox
04 Oct 2023	navma1 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
01 Jul 2025	jlizm1	MTN 35067 Cargo Enquiry table check boxes should be yes/no instead
*/

begin
	if _attrName = ETRow_OffsiteCleaned or 								//04.10.2023 navma1 #59638
	   _attrName = ETRow_OffsitePreTrip then
		
		return null.String;
	elseif _attrName = ETRow_BOLOutNumber 	  or
			_attrName = ETRow_OutwardsDate    or
			_attrName = ETRow_DmyContainer    or
			_attrName = ETRow_DmyVoyage       or
			_attrName = ETRow_DmyVessel       then
		if self.myReleaseBOL &lt;&gt; null then
			return self.myReleaseBOL.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
		
	elseif _attrName = ETRow_BOLInNumber then
		if self.myReceivalBOL &lt;&gt; null then
			return self.myReceivalBOL.number;
		endif;
		return null;
	elseif _attrName = ETRow_HandlingType then
		
		return self.getHandlingTypeDisplay;	//06 Apr 2017	NDL	TFS 3414

	elseif _attrName = ETRow_InwardsDate then
		if self.myReceivalBOL &lt;&gt; null then
			return	self.systemToLocalTime(self.myReceivalBOL.dateTime).date.shortFormatJMT();
		else
			return null;
		endif;

	elseif _attrName = ETRow_Pieces then
		return self.quantity.String;
	elseif _attrName = ETRow_PreSlung then
		return app.getYesNo(self.preSlung);
	elseif _attrName = ETRow_PreSlungYesNo then
		return app.getYesNo(self.preSlung);
	elseif _attrName = ETRow_ReceivedDT then	
		return self.systemToLocalTime(self.receivedDT).shortCurrentLocaleFormat();
	elseif _attrName = ETRow_LineNo then
		return null;
	elseif _attrName = ETRow_MyLength then
		return self.length.asStringMeasurementJMT();
	elseif _attrName = ETRow_MyWidth then
		return self.width.asStringMeasurementJMT();
	elseif _attrName = ETRow_MyHeight then
		return self.height.asStringMeasurementJMT();
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
