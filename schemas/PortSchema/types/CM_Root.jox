    <JadeMethod name="getMasterTITypeString" id="f3bb903b-d368-4760-843d-9e149dca5e9b">
        <source>getMasterTITypeString(_cargoType : Integer; _subType : Integer; _theTIMASTER : CM_TIMaster) : String;
// ---------------------------------------------------------------------------
// Created:     22 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpISO : CM_ISOType;
begin
	if _cargoType = TI_CargoType_Container then
		if _theTIMASTER = null then
			return "item";
		else
			tmpISO := _theTIMASTER.CM_TIMasterContainer.getISOTypeObject();
			if tmpISO &lt;&gt; null and tmpISO.isFlat then
				return "flat-rack";
			endif;
		endif;
		return "container";
	elseif _subType = ProductType_Trailer then
		return "trailer";
	elseif _cargoType = TI_CargoType_Generator then
		return "generator";
	endif;

	return null;
	
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_subType" type="Integer"/>
        <Parameter name="_theTIMASTER" type="CM_TIMaster"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMovementPath" id="4c0af100-26cc-448a-b5cb-0a6b504df203">
        <source>getMovementPath(_from : HMS_HarbourRegion; _to : HMS_HarbourRegion; _checkBothDirections : Boolean) : HMS_MovementPath;
//-----------------------------------------------------------------------
//	Created:	17 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	movementPath : HMS_MovementPath;
begin

	movementPath := self.allHMSMovementPathsByFromTo[_from, _to];
	
	if movementPath = null and _checkBothDirections then
		movementPath := self.allHMSMovementPathsByFromTo[_to, _from];
	endif;
	
	return movementPath;

epilog

end;</source>
        <Parameter name="_from" type="HMS_HarbourRegion"/>
        <Parameter name="_to" type="HMS_HarbourRegion"/>
        <Parameter name="_checkBothDirections" type="Boolean"/>
        <ReturnType type="HMS_MovementPath"/>
    </JadeMethod>
    <JadeMethod name="getNavigatorItem" id="6a2547f3-5bc0-40cd-8ff4-d18b1101edbf">
        <source>getNavigatorItem(_permission :Integer):CM_MenuDtlNav;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	item	:CM_MenuDtl;
begin
	item := self.myMenuRoot.allMenuDtlsByPermValue[_permission];
	
	if item.isKindOf (CM_MenuDtlNav) then
