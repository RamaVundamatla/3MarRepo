    <JadeMethod name="getHarmonizedSystem" id="7f50a1e0-b0f0-4be4-a516-d4127f87ac06">
        <source>getHarmonizedSystem(_code : String) : CM_HarmonizedSystem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2023	jlier1	Initial creation 55788

*/

vars
	hsCodeLength : Integer;
begin
	if _code = null then
		return null;
	endif;
	
	hsCodeLength:=_code.trimBlanks.length;
	
	if hsCodeLength = 2 then
		return app.myRoot.allHSChapters[_code];
	elseif hsCodeLength = 4 then
		return app.myRoot.allHSHeadings[_code];
	elseif hsCodeLength = 6 then
		return app.myRoot.allHSCodes[_code];	
	elseif hsCodeLength &gt; 6 then
		return app.myRoot.allHSSubCodes[_code];	
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_HarmonizedSystem"/>
    </JadeMethod>
    <JadeMethod name="getImexCodeFromDesc" id="054352ee-eba3-44c2-9972-1ae43d937ca1">
        <source>getImexCodeFromDesc(_imexDescription : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2008	cnwer1	Initial creation
21 Sep  2015	cnwma1  PAR #36887 Pre-Note EDI not updating IMEX of Pre-noted cargo

*/

vars
	imexCode : CM_IMEXStatus;
begin
	foreach imexCode in self.allImexStatuses discreteLock do
		if imexCode.description.toUpper = _imexDescription.toUpper or imexCode.abbreviation.toUpper = _imexDescription.toUpper   then  //21/09/2015 cnwma1 PAR #36887
			return imexCode.code;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_imexDescription" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceCurrencySymbol" id="db525f01-8d87-4646-a637-7ee2554685fd">
