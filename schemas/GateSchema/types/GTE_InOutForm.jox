        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_gotFocus(combobox: GTE_ComboOperator input) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	voyageCombo	: GTE_ComboBox;
	tmpVoyage	: CM_Voyage;
	voyageCode	: String;
	pos			: Integer;
	operator    : CM_Operator;
	
begin

	voyageCombo := self.getTopSheetControl(Cntrl_cmbVoyage).GTE_ComboBox;
	if voyageCombo = null then
		return;
	endif;

	pos := 1;
	voyageCode := voyageCombo.text;
	if voyageCode &lt;&gt; null then
		// strip off the description
		voyageCode := voyageCode.scanUntil(Tab, pos).trimRight;
	endif;
	// need to reset list
	
	if combobox.currentVoyageCode = voyageCode then
		return;
	endif;
	
	tmpVoyage := self.myAssistant.getVoyageFromCombo(voyageCode);
//combobox.clear();
	combobox.resetCollectionForVoyage(tmpVoyage);

//	self.myAssistant.comboBoxOperator(combobox, combobox.listObject.CM_Operator, tmpVoyage);
//	combobox.selectAllText(); handled by combobox

end;</source>
        <Parameter name="combobox" type="GTE_ComboOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbOperator_lostFocus" id="6cb18c91-7621-4ed1-b521-027f68961756">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_lostFocus(combobox: GTE_ComboOperator input) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTable	: CM_EntryTable;
	row			: Integer;
	comboProduct : CMUI_ComboProduct;
begin

	self.setCellTextFromControl(combobox.mySheet, combobox, combobox.text);

	if combobox.mySheet &lt;&gt; null then
		self.setCargoTypeFields(combobox.mySheet);	//update temp fields eg C or F
		self.setAvailabilityGrades();
		//if combobox.mySheet.myMenuAction.code = NavObj_GTE_OutByType then
		if entTable &lt;&gt; null then
			if self.myAssistant.GTE_Assistant.isReleaseByType(entTable) then
				//Change the tab heading to reflect our choice
				combobox.mySheet.setSubHeading(combobox.text[1:4].removeTabCrLfs.trimBlanks);
			endif;
		endif;
		// now done in setCargoTypeFields(..)
		//self.myAssistant.GTE_Assistant.showHideCEDOField(combobox.mySheet.myTblExtra,1);// ### CCMS 1294 AKB2005JAN
		
		
		comboProduct := self.getTopSheetControl(GTE_InOutForm::cmbProduct.name).CMUI_ComboProduct;  //cnwjo3
		if comboProduct &lt;&gt; null then
			comboProduct.setCargoType(combobox.mySheet.getCargoType()); //cnwjo3
			comboProduct.setOperator(combobox.listObject.CM_Operator); //cnwjo3
			comboProduct.setObject(comboProduct.listObject.CM_Product); //cnwjo3
		endif;
		
	endif;
	
end;</source>
        <Parameter name="combobox" type="GTE_ComboOperator" usage="input"/>
    </JadeMethod>
