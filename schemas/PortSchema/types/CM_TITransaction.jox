    <JadeMethod name="getCountryOfDestination" id="f6f513dc-f29e-47bd-ab0b-c4b10293fa1a">
        <source>getCountryOfDestination() : CM_Country;
/*
	
Purpose:			
			1) Return destination port country
			2) If Destination port is null, return Discharge port country
			3) If still null, return null;

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria

*/

vars
	port		: CM_Port;
	country		: CM_Country;
begin
	port := self.getDestinationPortObject();
	
	if port = null then
		port := self.getDischargePortObject();
	endif;
	
	if port &lt;&gt; null then
		country := port.myCountry;
	endif;
	
	return country;
epilog

end;</source>
        <ReturnType type="CM_Country"/>
    </JadeMethod>
