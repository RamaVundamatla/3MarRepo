    <JadeMethod name="getDisplayString" id="f7c2487c-5d1d-409e-ac01-5d4fce407dd2">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Jun 2018	jlger1	Initial creation
29 Sep 2021  navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	displayString : String;
	typeDesc      : String;
begin
	
	typeDesc := self.getTypeDescription();							   //29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayString := typeDesc;
	else
		displayString := self.getLongDescription(typeDesc,null);		//29.09.2021 navma1 #51925
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDtlType" id="33b69bb3-a9e6-4cbd-83fe-1fa61ac73512">
        <source>getDtlType(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars

begin
	return WO_TASK_MARINEINITIAL;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="d02cd963-438b-4fb2-8aca-084ba0321506">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2018	jlgab1	Initial creation
30 Nov 2021 navma1	Bug 52482: SAL - Web Portal - Cargo Work Orders
*/

vars
	block  : CM_DataContainerBlock;
	wodres : CM_WodMarineServiceDetail;
	tmpTS  : TimeStamp;
begin
	inheritMethod(_dataContainer);
	
	if self.myBerth&lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(MOVEHEAD_BerthTo), DC_Label, 1, null);
		block.addNewItem(self.myBerth.description , DC_Data, 1, null);
	endif;
	
	// ### OCCURS ON
	tmpTS := self.systemToLocalTime(self.getOccursDT); // PEL UAT WP testing 30SEP18
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Occurs_datetime), DC_Label, 1, null);
	block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null);
	
	// TFS 40236
	// ### BOW MARK
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(MOVEHEAD_MarkBow), DC_Label, 1, null);
	block.addNewItem(self.bowMarkTo.asStringJMT() , DC_Data, 1, null);
	
	// ### DRAFT AFT
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Draft_aft), DC_Label, 1, null);
	block.addNewItem(self.draftAft.asStringJMT() , DC_Data, 1, null);
	
	// ### DRAFT FORWARD
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Draft_fore), DC_Label, 1, null);
	block.addNewItem(self.draftFwd.asStringJMT() , DC_Data, 1, null);
	
	// ### HAS RAMP
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Vessel_external_ramp), DC_Label, 1, null);
	block.addNewItem(self.hasRamp.getYesNo() , DC_Data, 1, null);
	
	// ### STARBOARD BERTHED
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Starboard_Berthed), DC_Label, 1, null);
	block.addNewItem(self.starboardBerthed.getYesNo() , DC_Data, 1, null);
	
	//20 Sep 2018	NDL	TFS 40810
	if self.myTowingVoyage &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Towing_voyage_code), DC_Label, 1, null);
		block.addNewItem(self.myTowingVoyage.code , DC_Data, 1, self.myTowingVoyage);                       //30.11.2021 navma1 #52482
	endif;

	
	foreach wodres in self.allMarineServiceDetails do
	
		wodres.getExtraInfo(_dataContainer);
	endforeach;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInvFromDateTime" id="0f40ab8f-d1ab-4e13-9332-186992a30afb">
        <source>getInvFromDateTime(): TimeStamp;
/*

Purpose:		TFS 39237	

					get the oldest time stamp from the possible collection of WODs
					if these WO are created on the web portal for Pelindo1 there will be only one wod

Return Value:		

Date		Who		Reason
25 June 2018	jlgab1	Initial creation

*/

vars
	msd : CM_WodMarineServiceDetail;
	fdt, msdfdt : TimeStamp;
	d : Date;
	found : Boolean;
begin
	d.setDate(31,12,3000);
	fdt.setDate(d);

	
	foreach msd in self.allMarineServiceDetails	discreteLock do
		msdfdt :=msd.getInvFromDateTime();
		
		if msdfdt.isValid() then
			if msdfdt &lt; fdt then
				fdt := msdfdt;
				found := true;
			endif;
		endif;
	endforeach;

	if found then
		return fdt;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
