    <JadeMethod name="populateTables" id="ca79fb9a-eba0-4aa0-b1df-c1c9897c1359">
        <updating/>
        <source>populateTables(_topSheetOnly : Boolean) updating, protected;
//-----------------------------------------
// Created: June 2004 By: cnwgd1
//-----------------------------------------
//Par 8461
vars
	topSheet : Sheet;
begin
	
	topSheet := self.fldBuild.topSheet;
	
	if (_topSheetOnly and topSheet = self.shtBuildType)
	or (not _topSheetOnly) then
		self.doSetDefaultType();
		if self.modeType = self.Mode_update then
			self.doSetJobType();
		endif;
	endif;
	
	if (_topSheetOnly and topSheet = self.shtBuildStatus)
	or (not _topSheetOnly) then
		self.doSetDefaultStatus();
		if self.modeStatus = self.Mode_update then
			self.doSetJobStatus();
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_topSheetOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="retrieveTIs" id="57b888d7-8752-4ec2-bc37-af81b9c7be1c">
        <updating/>
        <source>retrieveTIs() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jan 2011	cnwkpd1		PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars
	str	: String;
	iter	: Iterator;
	ti		: CM_TrackedItem;
	keyId	: String;
	keyType, idx	: Integer;
	lCargoType	: Integer;
	lCargoTypeObj	: CM_CargoBOLType;
//	tiArray : CM_TIArray;
	lVoyage : CM_Voyage;
	lOperator : CM_Operator;
	lStatus : Integer;
	lCOU, lGenerator, lForward : Boolean;
	lConsignee : String;
	term : CM_Terminal;
	theRow : Integer;
	loadStateSet : Boolean;
	selectedTIs : CM_TISet;
	row : Integer;
	numRows : Integer;
	numFound : Integer;
	tmpConsignors : CM_ConsignByCodeDict;
	tis : CM_TIArray;
	
begin
	mousePointer := MousePointer_HourGlass;	
	
	term := self.myTerminal;
	// ##########
	// Clear top Table
	self.tblRetrieved.rows := self.tblRetrieved.fixedRows;
	//self.clrOne.caption := self.tblStatus.getValueByName('stat

	// Hold set of already selected tracked items so that we can
	// exclude these from the retrieved items.
	create selectedTIs transient;
	foreach row in self.tblSelected.fixedRows + 1 to self.tblSelected.rows do
		ti := self.tblSelected.accessRow(row).itemObject.CM_TrackedItem;
		selectedTIs.add(ti);
	endforeach;	

	//#####################
	// Setup The Search Parameters
	lCargoTypeObj := self.cmbTiType.listObject.CM_CargoBOLType;
	if lCargoTypeObj &lt;&gt; null then
		lCargoType := lCargoTypeObj.id;
	else
		lCargoType := null;
	endif;

//	lVoyage := self.myAssistant.getVoyageFromCombo(self.cmbFiltVoyage1.text);		
	lVoyage := self.myAssistant.getVoyageFromCombo(self.cmbFiltVoyage.text);	
		
	lOperator := self.cmbFiltOperator.listObject.CM_Operator;

	lForward			:= tblStatus.getValueByName(ETRow_DoorsForward).Boolean;
	lCOU				:= tblStatus.getValueByName(ETRow_NeedCOU).Boolean;
	lGenerator			:= tblStatus.getValueByName(ETRow_NeedGenerator).Boolean;
	lConsignee			:= tblStatus.getValueByName(ETRow_FilterConsignee).String;
	
	// Must check as could be content status object
	if self.cmbImexStatus.listObject.isKindOf(CM_IMEXStatus) then
		lStatus := self.cmbImexStatus.listObject.CM_IMEXStatus.code;
	else
		// Must have selected the content status of Empty then
	endif;
	// ########
	// Retrieve TIs
	app.cmsBeginLoad(loadStateSet);
	tmpConsignors := app.myRoot.allConsigneeConsignors;
	create tis transient;
	
	numRows := term.allOnsiteTIsByCargoTypeId.size;	
	numFound := 0;

	self.progressStart(numRows, 'Return Data', 'Cancel', null,
						'Searching for data');

	iter := term.allOnsiteTIsByCargoTypeId.createIterator;
	
	// Only containers are required at this stage
	term.allOnsiteTIsByCargoTypeId.startKeyGeq(lCargoType, null, iter);
	
	while iter.next(ti) do
		self.updSearchProgress(numFound);
		if self.modalDialogReturnValue = ModalDialogReturn_Option1 then
			return;
		endif;
		if self.modalDialogReturnValue = ModalDialogReturn_Default then
			break;
		endif;
		// Do this to avoid touching the actual object
		term.allOnsiteTIsByCargoTypeId.getIteratorKeys(keyType, keyId, iter);
		
		if lCargoType &lt;&gt; null and keyType &lt;&gt; lCargoType then
			break;
		endif;
		if lVoyage &lt;&gt; null and ti.myVoyage &lt;&gt; null then
			if ti.myVoyage &lt;&gt; lVoyage then
				continue;
			endif;
		endif;
		
		if lConsignee &lt;&gt; null and ti.consignee &lt;&gt; null then
			if ti.consignee &lt;&gt; lConsignee then
				continue;
			endif;
		endif;
		
		if selectedTIs.includes(ti) then
			continue;
		endif;
		
		if ti.cargoType = TI_CargoType_Container then //ti.isKindOf(CM_Container) then
			if lCOU and not ti.CM_Container.hasCOU then
				continue;
			endif;
			if lGenerator and ti.CM_Container.generatorId = null then
				continue;
			endif;
		endif;
		
		if lOperator &lt;&gt; null and (not lOperator.isKindOf(CM_NullOperator)) then
			if ti.myOperator &lt;&gt; null then
				if ti.myOperator &lt;&gt; lOperator then
					continue;
				endif;
			endif;
		endif;

		if lStatus &lt;&gt; null then
			if ti.getImExStatus() &lt;&gt; lStatus then
				continue;
			endif;
		elseif ti.isFull then // no status selected then only show empties
			continue;
		endif;
		
		numFound := numFound + 1;
		tis.add(ti);
	endwhile;
		
	numRows := tis.size;	
	numFound := 0;

	self.progressStart(numRows, 'Cancel', null, null,
			'Loading data into table');
		
	foreach ti in tis do
		self.updLoadProgress;
		if self.modalDialogReturnValue = ModalDialogReturn_Default then
			break;
		endif;
		str := ti.getAttributeStringForDefArray(tblRetrieved.allTblDataEntRows);
		idx := self.tblRetrieved.addItem(str);
		self.tblRetrieved.accessRow(idx).itemObject := ti;
		self.tblRetrieved.accessCell(idx,2).itemObject := tmpConsignors[ti.consignor.trimBlanks];
	endforeach;

/*
if ti.myOperator &lt;&gt; null then
write ti.id &amp; " OP " &amp; ti.myOperator.code ;
endif;
write ti.id &amp;  "CargoType " &amp; ti.myCargoType.id.String &amp; " " &amp; ti.isFull.String &amp; " ti.imExStatus " &amp; ti.imExStatus.String;
if ti.isKindOf(CM_Container) then
write  ti.id &amp; " COU "  &amp; ti.CM_Container.hasCOU.String &amp; " GEN " &amp; (ti.CM_Container.generatorId = null).String;
endif;
*/

	// ############
	// DISPLAY RESULTS
	self.btnDelete.enabled := false;
	self.btnAdd.enabled := true;
	self.btnAll.enabled := true;

	//app.msgBox((self.tblRetrieved.rows - 1).String &amp; " Tracked Items found.","Retrieve",MsgBox_OK_Only);

epilog
	delete iter;		// PAR #26678
	delete tis;
	self.progressFinish;
	delete selectedTIs;
	app.cmsEndLoad(loadStateSet);
	mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="selectFirstRowOfTable" id="e79e8403-3087-4bcc-b8b3-194fbcd2fa0f">
        <source>selectFirstRowOfTable(table : CM_DataTable input) protected;

begin
	if table.rows &gt; self.tblRetrieved.fixedRows then
		table.row := self.tblRetrieved.fixedRows + 1;
		table.column := self.tblRetrieved.fixedColumns + 1;
		table.selectTheCurrentRow(table.row);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="504532cc-2fe7-4407-aeab-b494fb3bb002">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;
begin
	inheritMethod(_colorControl);

	tmpBackColor	:= self.backColor;
	
	self.shtBuildStatus.backColor	:= tmpBackColor;
	self.shtBuildType.backColor		:= tmpBackColor;
	
	self.setColorsForEntryTable(self.tblStatus);
	self.setColorsForEntryTable(self.tblType);
	
	self.setColorsForTable(self.tblRetrieved);
	self.setColorsForTable(self.tblSelected);
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setNavigator" id="e2c64e54-6976-4af8-b34a-0cec093a8d5f">
        <updating/>
        <source>setNavigator() updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	lNavString : String;

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if self.myCurrentJob &lt;&gt; null and self.myCurrentJob.isKindOf(CM_RailJob) then
		lNavString := self.myCurrentJob.CM_RailJob.requestNum &amp; " - Rail Release Request"; 
	else
		lNavString := self.caption;
	endif;			

	// Update the navigator
	self.setNavigatorHeading(lNavString); 

epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c09e911c-c24c-4f71-b4ce-69632e1497bb">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	//th2 02/01/07 CCMS 1408 - Build priority obsolete
	/*
	if not app.getMyTerminal.getConfig(RailUseBuildPriority).Boolean then
		app.msgBox("This terminal is not configured to use Rail Build Priority. You should use the 'Release Request' screen to maintain rail releases and assign them to rail lines etc.",'Build Priority not available.',MsgBox_Exclamation_Mark_Icon);
		self.unloadForm();
		return;
	endif;
	*/
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	

	if self.myCurrentJob = null then
		self.modeStatus := self.Mode_add;
		self.modeType := self.Mode_add;
	endif;

	self.initTables();
	
	// Display delete button off window so that the hot key still works,
	// but we don't see the button.  Note the hot key is the same
	// as that for the remove context menu option.
	self.btnDelete.visible := true;
	self.btnDelete.left := -200;
	
	self.setNavigator;
	
	self.fldBuild.useSheetBackColors := true;
	self.fldBuild.setDefaultSheetBackColors();
	self.fldBuild.initSheetBackColors();
	

	// sgp 3 June 2003 : moved to loadDatForFirstTime
//	self.buildComboCargoType();
//	self.buildComboISOType();
//	self.buildComboOperator();
//	self.buildComboReason();
//	self.buildComboStatus();
//	self.buildComboConsignor();
//	self.buildComboVoyage();
//	self.buildLstMTGrade();
/*
	self.tblStatus.clearHasChanged(false);
	self.tblType.clearHasChanged(false);

	self.txtRequestDate.visible := false;
	self.txtRequestDate2.visible := false;

	if self.modeStatus = self.Mode_update then
		self.doSetJobStatus();
	else
		self.doSetDefaultStatus();
	endif;
	
	if self.modeType = self.Mode_update then
		self.doSetJobType();
	else
		self.doSetDefaultType();
	endif;
*/	
	self.maxButton := false;
	//self.doResize();

	self.getXMLSettingsForSetup();
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideRowForStatus" id="8a172d61-c2fc-4610-b1af-fb1c0e59ea67">
        <source>showHideRowForStatus();
//--------------------------------------------------
// Created:	16 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpStatus : Integer;
begin
	if self.cmbImexStatus.listIndex = null then
		return;
	endif;
	
	tmpStatus := self.cmbImexStatus.itemData[self.cmbImexStatus.listIndex];
	
	if tmpStatus = TI_IMEX_STATUS_IMPORT then
		self.tblStatus.hideRowByName(ETRow_DeliveryReason, false);
	else
		self.tblStatus.showRowByName(ETRow_DeliveryReason, false);	
	endif;
	
end;</source>
    </JadeMethod>
