    <JadeMethod name="getViewButtonCaption" id="76066955-657e-4a20-a679-74a9e2643f63">
        <source>getViewButtonCaption() : String protected;

/*

Purpose:			Return the caption to display on the View button, dependant on current
					configuration options


Return Value:		None


Date		Who		Reason
13 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	rtnValue		: String;
	
begin
	if self.aShowNumberOfQueueEntries then
		rtnValue := self.Caption_View &amp; " (" &amp; self.aNumberOfAvailableQEntries.String &amp; ")";
	else
		rtnValue := self.Caption_View;
	endif;
	
	return rtnValue;
	
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVisibleEnquiryTable" id="7da73d8c-80be-48a4-afcf-0076e2374911">
        <source>getVisibleEnquiryTable() : Table protected;

/*

Purpose:			Get the currently visible Enquiry table


Return Value:		Visible table


Date		Who		Reason
05 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars

begin
	if self.tblEnquiry.visible then
		return self.tblEnquiry;
	elseif self.tblContSrchRes.visible then
		return self.tblContSrchRes;
	else
		return self.tblQueueEntries;
	endif;
	

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Table"/>
    </JadeMethod>
    <JadeMethod name="loadFormFromQueryDTO" id="e93cbbaf-fcb4-4230-90cc-e54b0a543191">
        <updating/>
        <source>loadFormFromQueryDTO( _obj : Object ) updating;
// --------------------------------------------------------------------------------
// Created:		21 April 2008 by cnwvu1
// --------------------------------------------------------------------------------
begin
	if _obj.isKindOf(DTO_QuerySetForRT) then
		self.querySetButtonsMenu(_obj.DTO_QuerySetForRT);
			
	elseif _obj.isKindOf(DTO_QueryDefinitionRT) then
		self.queryDefinitionShow(_obj.DTO_QueryDefinitionRT);
		
	elseif _obj.isKindOf(DTO_QueryResult) then
		self.queryDisplayResult(_obj.DTO_QueryResult);		
		
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadFormFromThinClientObj" id="487a7667-fc3a-48ee-b932-3b38fce84778">
        <updating/>
        <source>loadFormFromThinClientObj(_obj : MobileServerRTThin::DTO_EnquiryGradingTasks) updating;

/*

Date		Who		Reason
18 Jan 2006	cnwdvb1	Created
05 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
29 Sep 2009 cnwas3	PAR 20285
*/

vars
	tableObj			: MB_TableNamedCols;
	dtoTaskObj			: MobileServerRTThin::DTO_ToDoTask;
	dtoGradeObj			: MobileServerRTThin::DTO_Grade;
	toDoTaskObj			: MB_ToDoTask;
	gradeObj			: MB_Grade;
//	isScrollRequired	: Boolean;
	dtoContObj			: MobileServerRTThin::DTO_ContainerSearchInfo;
	dtoQueueEntry		: MobileServerRTThin::DTO_RTQueueEntry;
	rowAdded			: Integer;
	tableRow			: JadeTableRow;
	
begin
	// PAR #16010 - Rewrite to clear all up front, then deal with multiple possible 
	self.tableEnqInitialize();
	self.tableGradeInitialize();
	self.tableToDoInitialize();
	self.tableContainerSearchInit();
	self.tableQueueEntriesInitialize();
	self.lblSearchWarning.caption := null;
	
	// Container search results
	if not _obj.allContainerSearchResults.isEmpty then
	
		makeEnquiryTableVisible(self.tblContSrchRes);
		
		foreach dtoContObj in _obj.allContainerSearchResults do
			self.tblContSrchRes.addItemWithColor(dtoContObj.containerId &amp; Tab &amp; 
										dtoContObj.currentLocationID &amp; Tab &amp;
										dtoContObj.queuedLocationID);
		endforeach;
		
		// Need to display when there are more than the maximum found
		self.lblSearchWarning.caption := _obj.searchWarningMessage;	
	
	// Queued entries
	elseif not _obj.allQueueEntries.isEmpty then
	
		makeEnquiryTableVisible(self.tblQueueEntries);
		
		foreach dtoQueueEntry in _obj.allQueueEntries do
			rowAdded := self.tblQueueEntries.addItemWithColor(dtoQueueEntry.description &amp; Tab &amp; 
										dtoQueueEntry.currentLocationID &amp; Tab &amp;
										dtoQueueEntry.queuedLocationID);
			
			tableRow := self.tblQueueEntries.accessRow(rowAdded);
			tableRow.itemObject := dtoQueueEntry.myRealQueueEntry;
		endforeach;
		
		// Need to display when there are more than the maximum found
		self.lblSearchWarning.caption := _obj.searchWarningMessage;	
	
	// An enquiry on a single container or task
	else
	
		tableObj := tblEnquiry;
		makeEnquiryTableVisible(tableObj);
	
		if self.aQueueTaskType &lt;&gt; "Set-down" then //cnwas3 PAR 20285
			self.txtContainerID.text	:=	_obj.containerID;
		endif; //cnwas3 PAR 20285
		tableObj.addNamedRow(self.TableRow_TaskType, _obj.taskType);
		self.aQueueTaskType := _obj.taskType;
		
		if self.aQueueTaskType = TASK_DIRECTOR_DESC then
			tableObj.addNamedRow(self.TableRow_PickupFrom, _obj.currentLocationID);
			tableObj.addNamedRow(self.TableRow_SetdownTo, _obj.targetLocation);
			tableObj.addNamedRow(self.TableRow_Remarks, _obj.remarks);
		else
			tableObj.addNamedRow(self.TableRow_OperatorCode, _obj.operatorCode);
			tableObj.addNamedRow(self.TableRow_RecDateTime, _obj.receivedDateTime.shortCurrentLocaleFormat(false));
			
			/*			
			Date		Who		Reason			
			20 Aug 2008	cnwdz2	Par 17782 CCMS Otago 1722 - Thin Client RT Changes: The result is that Voyage and Commodity will be moved down and ISO Type and Remarks moved up the list.			
			*/					
			tableObj.addNamedRow(self.TableRow_CurrentLocID, _obj.currentLocationID);
			tableObj.addNamedRow(self.TableRow_QuedLocn,_obj.queuedLocationID); //epr 14/12/07 CCMS1626
			tableObj.addNamedRow(self.TableRow_Hazards, _obj.hazards);  //cnwjo3 par 24939
			tableObj.addNamedRow(self.TableRow_ISOType, _obj.isoType);
			tableObj.addNamedRow(self.TableRow_Remarks, _obj.remarks);
			tableObj.addNamedRow(self.TableRow_Commodity, _obj.commodity);
			tableObj.addNamedRow(self.TableRow_VoyageCode, _obj.voyageCode);
			tableObj.addNamedRow(self.TableRow_Weight, _obj.weight.String);
			tableObj.addNamedRow(self.TableRow_ImexStatus, _obj.imexStatusDesc);
			tableObj.addNamedRow(self.TableRow_DischargePort, _obj.dischargePort);
			tableObj.addNamedRow(self.TableRow_HasStops, _obj.hasStops.mbFormat("Yes", "No"));
			//tableObj.addNamedRow(self.TableRow_Hazards, _obj.hazards);			
			if _obj.isControlledAtmosphere then // when false - the row disappeares on the screen
				tableObj.addNamedRow(self.TableRow_ControlledAtmosphere, _obj.isControlledAtmosphere.mbFormat("Yes", ""));	//ccms1536
			endif;
		endif;
		
		if _obj.targetLocation &lt;&gt; null then
			self.txtNewLocation.text	:=	_obj.targetLocation;
		endif;
	
		foreach dtoTaskObj in _obj.allToDoTasks do
			create toDoTaskObj transient;
			toDoTaskObj.translateFromPackage(dtoTaskObj);
			
			self.tblDataToDo.addTask(toDoTaskObj);
		endforeach;
		
		foreach dtoGradeObj in _obj.allGrades do
			create gradeObj transient;
			gradeObj.translateFromPackage(dtoGradeObj);
			
			if dtoGradeObj.isCurrentGrade then
				self.lblCurrentGrade.caption := dtoGradeObj.description;
			endif;
			
			self.tblDataGrade.addGrade(gradeObj);
		endforeach;
		
		tblDataToDo.mbSetFixedColors(app.colorBackTables, app.colorForeTables);
		tblDataGrade.mbSetFixedColors(app.colorBackTables, app.colorForeTables);
		
	
	endif;
	
	self.setEnquiryScrollButtons();		// PAR #16010
	
//	isScrollRequired			:=	tblEnquiry.mbCanScroll();
//	self.btnPUEnquiry.visible	:=	isScrollRequired;
//	self.btnPDEnquiry.visible	:=	isScrollRequired;

	// 03/04/2008 cnwar2 #16377
	if aMachineLiftType = TANDEM_LIFT then
		self.txtContainerID2.text := _obj.overstowContainerID;
	endif;
		
end;</source>
        <Parameter name="_obj" type="MobileServerRTThin::DTO_EnquiryGradingTasks"/>
    </JadeMethod>
    <JadeMethod name="loadFormFromWebSrvObj" id="a0b090c3-7aeb-4405-a062-3eebaeaecb4a">
        <updating/>
        <source>loadFormFromWebSrvObj(_obj: WebSrv_DTO_EnquiryGradingTasks) updating;
/*

Date		Who		Reason
18 Jan 2006 cnwdvb1	Created
04 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	tableObj			: MB_TableNamedCols;
	toDoTask			: WebSrv_DTO_ToDoTask;
	grade				: WebSrv_DTO_Grade;
	toDoTaskObj			: MB_ToDoTask;
	gradeObj			: MB_Grade;
//	isScrollRequired	: Boolean;
	
begin
	tableObj	:=	tblEnquiry;
	self.tableEnqInitialize();
	
	self.txtContainerID.text	:=	_obj.containerID;
	tableObj.addNamedRow(self.TableRow_TaskType, _obj.taskType);
	self.aQueueTaskType := _obj.taskType;
	
	if self.aQueueTaskType = TASK_DIRECTOR_DESC then
		tableObj.addNamedRow(self.TableRow_PickupFrom, _obj.currentLocationID);
		tableObj.addNamedRow(self.TableRow_SetdownTo, _obj.targetLocation);
		tableObj.addNamedRow(self.TableRow_Remarks, _obj.remarks);
	else
		tableObj.addNamedRow(self.TableRow_OperatorCode, _obj.operatorCode);
		tableObj.addNamedRow(self.TableRow_RecDateTime, _obj.receivedDateTime.shortCurrentLocaleFormat(false));
		tableObj.addNamedRow(self.TableRow_Commodity, _obj.commodity);
		tableObj.addNamedRow(self.TableRow_VoyageCode, _obj.voyageCode);
		tableObj.addNamedRow(self.TableRow_CurrentLocID, _obj.currentLocationID);
	
		tableObj.addNamedRow(self.TableRow_Weight, _obj.weight.String);
		tableObj.addNamedRow(self.TableRow_ImexStatus, _obj.imexStatusDesc);
		tableObj.addNamedRow(self.TableRow_ISOType, _obj.isoType);
		tableObj.addNamedRow(self.TableRow_DischargePort, _obj.dischargePort);
		tableObj.addNamedRow(self.TableRow_HasStops, _obj.hasStops.mbFormat("Yes", "No"));
		tableObj.addNamedRow(self.TableRow_Hazards, _obj.hazards);
		tableObj.addNamedRow(self.TableRow_Remarks, _obj.remarks);
	endif;
	
	if _obj.targetLocation &lt;&gt; null then
		self.txtNewLocation.text	:=	_obj.targetLocation;
	endif;
	
	self.tableToDoInitialize();
	self.tableGradeInitialize();
	
	foreach toDoTask in _obj.allToDoTasks do
		create toDoTaskObj transient;
		toDoTaskObj.translateFromWebServices(toDoTask);
		self.tblDataToDo.addTask(toDoTaskObj);
	endforeach;
	
	foreach grade in _obj.allGrades do
		create gradeObj transient;
		gradeObj.translateFromWebServices(grade);
			
		if grade.isCurrentGrade then
			self.lblCurrentGrade.caption := grade.description;
		endif;
		
		self.tblDataGrade.addGrade(gradeObj);
	endforeach;
	
	tblDataToDo.mbSetFixedColors(app.colorBackTables, app.colorForeTables);
	tblDataGrade.mbSetFixedColors(app.colorBackTables, app.colorForeTables);
	
	self.setEnquiryScrollButtons;		// PAR #16010
	
//	isScrollRequired		:=	tblEnquiry.mbCanScroll();
//	self.btnPUEnquiry.visible	:=	isScrollRequired;
//	self.btnPDEnquiry.visible	:=	isScrollRequired;
end;</source>
        <Parameter name="_obj" type="WebSrv_DTO_EnquiryGradingTasks"/>
    </JadeMethod>
