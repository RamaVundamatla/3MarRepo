    <JadeMethod name="canCreateResources" id="10dba42a-4056-4f70-96e1-ba09804a6387">
        <source>canCreateResources(_voyageStatus: CM_VoyageStatus output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlgndl1	Initial creation	TFS 40127

*/

vars
	allTis : CM_TISet;
	voyage : CM_Voyage;
	voyageProcess : CM_VoyageProcess;
	voyageStatus : CM_VoyageStatus;

begin

	
	create allTis transient;
	self.myParent.getAllTIs(allTis);
	if allTis.size &gt; 0 then
		return false;
	endif;

	if self.myParent.taskStatus &lt; WO_STATUS_APPROVED then
		return false;
	endif;
	
	return true;

epilog
	delete allTis;
end;</source>
        <Parameter name="_voyageStatus" type="CM_VoyageStatus" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
