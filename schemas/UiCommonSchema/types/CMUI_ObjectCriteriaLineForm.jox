    <JadeMethod name="changeTerminal" id="c11718ca-de18-406a-866b-70b6885e5042">
        <updating/>
        <source>changeTerminal(pTerminal: CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2014	cnwndl1	Initial creation

*/

vars

begin
	self.myTerminal := pTerminal;
	
	if self.myAssistant &lt;&gt; null then
		self.myAssistant.setMyTerminal(pTerminal);		
	endif;
	
	if self.cmbTerminal.visible and self.cmbTerminal.findObject(pTerminal) &gt; 0 then
		if self.cmbTerminal.listObject.CM_Terminal &lt;&gt; pTerminal then
			self.cmbTerminal.listIndex := self.cmbTerminal.findObject(pTerminal);
		endif;
	endif;
		
	app.myPassport.setMyTerminal( pTerminal );
	
	self.setupForm;

epilog

end;</source>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="cmbMovePopulate" id="bfac00bd-02fc-492d-b4d0-772df69760c1">
        <source>cmbMovePopulate(_combo: CMUI_ComboBox input; _default: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2016	cnwmp6	Initial creation	TFS 2443

*/

vars
	idx: Integer;
begin
	_combo.sorted := false;
	idx := _combo.addItem(app.getErrorString(None));
	_combo.itemData[idx] := -1;
	idx := _combo.addItem(app.moveModeStatusEnumToString(PLANNING_MODE));
	_combo.itemData[idx] := PLANNING_MODE;
	idx := _combo.addItem(app.moveModeStatusEnumToString(QUEUE_MODE));
	_combo.itemData[idx] := QUEUE_MODE;
	if _default = -1 then
		_combo.setIndex(1);
	else
		_combo.setIndex(_combo.findStringExact(1, app.moveModeStatusEnumToString(_default)));
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_default" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cmbTerminalPopulate" id="06b276d9-f010-466d-aefc-6bde1eaa6c28">
        <source>cmbTerminalPopulate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2014	cnwndl1	Initial creation	Par 33439 / CCMS 2311

*/

vars

	index : Integer;
	userTerm : CM_UserTerminal;
	term : CM_Terminal;
	wagonMaster : CM_WagonMaster;

begin

	self.cmbTerminal.clear();
	foreach userTerm in app.getMyUser.allUserTerminals do
		term := userTerm.myTerminal;
		index := self.cmbTerminal.addItem( term.name );
		self.cmbTerminal.itemObject[index] := term;
		if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
			if contextObject &lt;&gt; null then
				wagonMaster := contextObject.CM_WagonMaster;
				if wagonMaster.getMyObjectMatchCriteriaFor( term ) &lt;&gt; null then
					self.cmbTerminal.itemEnabled[index] := false;  
				endif;
			endif;
		endif;
	endforeach;
	
	if self.myTerminal &lt;&gt; null then
		self.cmbTerminal.listIndex := self.cmbTerminal.findObject( self.myTerminal );
	endif;
	
	//15 May 2015	NDL	Par 36234
	if self.context = CM_ObjectMatchCriteria.VBSExclusionInt then
		self.cmbTerminal.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbTerminal_change" id="c9b7b6b2-813a-4b03-8023-79ae7f3e0963">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminal_change(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2014	cnwndl1	Initial creation	Par 33439

*/

vars

	term : CM_Terminal;

begin

	term := self.cmbTerminal.listObject.CM_Terminal;
	if term &lt;&gt; null and term &lt;&gt; self.myTerminal then
		self.changeTerminal(term);
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
