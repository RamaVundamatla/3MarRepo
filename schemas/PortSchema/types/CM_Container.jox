    <JadeMethod name="isoGroup" id="3d083630-129c-4082-8355-d4bb09a0f474">
        <methodInvocation>mapping</methodInvocation>
        <source>isoGroup(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     23 September 2003	cnwth2
//
// Purpose:     
// 31 Oct 2023	navma1 		ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1			 
// ----------   ----------  --------------------------------------------------
vars
	tmpISOType	: CM_ISOType;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		tmpISOType :=  app.myRoot.allISOTypes[self.isoType];						//31.10.2023 navma1 #60920

		if tmpISOType &lt;&gt; null and tmpISOType.myISOTypeGroup &lt;&gt; null then
			_value := tmpISOType.myISOTypeGroup.code;
		endif;
	endif;

end;</source>
