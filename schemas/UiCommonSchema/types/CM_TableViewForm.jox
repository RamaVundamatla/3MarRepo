    <JadeMethod name="doDeleteClonedMenuFromSource" id="26651f47-c991-458c-bf64-6e7fb059cc0f">
        <updating/>
        <source>doDeleteClonedMenuFromSource(_sourceMenu : MenuItem io) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2008	cnwer1	Initial creation 14456

*/

vars
	clonedMenuItem : MenuItem;
begin
	clonedMenuItem := _sourceMenu.description.asOid.MenuItem;
	if clonedMenuItem &lt;&gt; null then
		_sourceMenu.description:=null;
		delete clonedMenuItem;
		self.setClonedMenuCount(self.clonedMenuCount-1);
		
	endif;
epilog

end;</source>
