    <JadeMethod name="lockRect" id="d8750342-6a42-4efe-8eea-ef5b9d179ff3">
        <updating/>
        <source>lockRect(_value: Boolean) updating;
/*
Purpose: Lock/unlock the rect so that in cannot be moved or resized		

