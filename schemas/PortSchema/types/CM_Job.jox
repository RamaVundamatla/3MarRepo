vars
	wle		: CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do	//06.03.2025 navma1 #MTN-34179
		return wle;
	endforeach;
	return null;
epilog

end;</source>
