vars

begin
	inheritMethod(form);

	form.myCurrentMapProdGrp := self.myProductGroupMap;
	form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
	form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;

/*
	form.myCurrentMapProdGrp := self.myProductGroupMap;
	form.myCurrentMapTIService := self.myProductGroupMap.myCargoTypeMap;
	form.myCurrentMapTM := self.myProductGroupMap.myCargoTypeMap.transactionMap;

*/

	form.myTMCProdGrp := self;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
