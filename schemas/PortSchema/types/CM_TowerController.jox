    <JadeMethod name="canConvertToBlockStack" id="d51e51d3-11dd-4d3f-b9da-dd79aae436e5">
        <source>canConvertToBlockStack();
// ---------------------------------------------------------------------------
// Created:		September  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.numTIs &gt; 0  or self.numPlannedTIs &gt; 0  or self.numQueuedTIs &gt; 0  then
		app.raiseCMException(ERR_CONV_LC_HAS_TOWER, null, null);
	endif;
end;</source>
    </JadeMethod>
