    <JadeMethod name="getPerformanceColour" id="c155a555-f039-4cb6-b944-d2a9f055a7aa">
        <source>getPerformanceColour() : Integer;
/*

Purpose:			

Parameters:		NotSet	= '0'	= Not yet set in the real code. ( set in create )
				Simple	= '1'	= A standard simple attribute on the object that is being displayed, or a very simply method i.e. it returns
								  an attribute off a direct reference or does a very simple calculation.
				CollKey	= '2' 	= A key in one or more of the collections we use for the selector.
				Complex	= '3' 	= A value that is derived via a non trivial method. I.e. Has potential to cause perfomance issues when used excessively.

Return Value:		

Date		Who		Reason
02 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars

begin

	if self.performanceRating = Simple then
		return self.SimpleColour;
	elseif self.performanceRating = CollKey then
		return self.CollKeyColour;
	elseif self.performanceRating = Complex then
		return self.ComplexColour;
	endif; 

	return self.NotSetColour;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="08a48359-cd3b-4c9b-8f40-9d114c95c46c">
        <source>getQueryOperatorForYADataConv():Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	queryOper : CM_QueryOperator;
	class : Class;
	className : String;

begin
	// re-implemented so should never
	// really be used, but here as a backstop.
	if self.allAllowedOperators.size = 1 then
		return self.allAllowedOperators.first.class;
	endif;
	
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		className := class.name;
		if className.pos("Equals",1) &gt; 0 then
			return class;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
