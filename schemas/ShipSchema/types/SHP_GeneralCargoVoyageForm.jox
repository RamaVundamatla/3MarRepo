/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
17 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	
begin
	app.mousePointer	:= Busy;
