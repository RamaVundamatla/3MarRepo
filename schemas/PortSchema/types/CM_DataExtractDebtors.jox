    <DbClassMap file="userData"/>
    <JadeMethod name="extractFieldsBody" id="d22dd29e-0732-4833-9fba-7a301f5f928b">
        <source>extractFieldsBody(_terminal: CM_Terminal; _outputFile: File; _counter: Integer io; _breakOut : Boolean output)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars
    debtor      : CM_Debtor;
	rootCompany : CM_Bank;
begin
	rootCompany := CM_Root.firstInstance.myRootCompany;
	if rootCompany &lt;&gt; null then
		foreach debtor in rootCompany.debtors do
			self.extractFieldsFromObject(debtor, _outputFile, _counter, _breakOut);		
		endforeach;
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_outputFile" type="File"/>
        <Parameter name="_counter" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
