    <JadeMethod name="disabledAppearance" id="fd248628-a3df-4413-9220-dcd03abf0c53">
        <source>disabledAppearance() : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	10 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return self.myGridArea.YRD_WagonArea.disabledAppearance;

end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawBody" id="d4263180-0337-45ba-a18f-0ecc76c35a8b">
        <updating/>
        <source>drawBody(pFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		sgp 24 July 2003
// ---------------------------------------------------------------------------
vars
	pFrameHeight : Integer;
	lTotalCols : Integer;
	lWagonWidth : Integer;
	lControllerWidth : Integer;
	wellCount : Integer;
begin
	pFrameHeight	:= pFrame.height.Integer;
	pFrame.drawWidth	:= 1;
	self.cellHeight := self.y2 - self.y1;
	lControllerWidth := (self.x2 - self.x1).Integer;

	lTotalCols := self.myGridArea.allGridColumns.size;
	
	pFrame.backColor := self.getColFrameBack;//self.myGridArea.YRD_WagonArea.colourBack;
	pFrame.drawStyle := pFrame.DrawStyle_Solid;
	// draw the wagon body
	lWagonWidth := (lControllerWidth * lTotalCols).Integer;
	pFrame.drawFillStyle := pFrame.DrawFillStyle_Solid;
	pFrame.drawFillColor := self.getColFrameFill();//White;
	pFrame.foreColor := self.myGridArea.YRD_WagonArea.colourWagon;
	pFrame.drawFilledRectangle(self.x1, self.y1,self.x1 + lWagonWidth, self.y2, self.getColFrameBack);
	
	wellCount := self.myGridArea.YRD_WagonArea.myWagon.getNumberOfWells();	//10 Dec 2014	NDL	Par 35346
	if wellCount &gt; 1 then	//08 Dec 2014	NDL	Par 35345
		self.drawBodyWellsAndExtraWheels( pFrame, wellCount, self.x1, self.y1,self.x1 + lWagonWidth, self.y2 );
	endif;
	
	pFrame.autoRedraw := true;
	
end;</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBodyWellsAndExtraWheels" id="199248ec-aa0c-4442-9af5-4cd2591717d1">
        <source>drawBodyWellsAndExtraWheels(	pFrame: CMUI_GridAreaFrame input;
				pWellCount : Integer;
				_x1: Real; _y1: Real; _x2: Real; _y2: Real
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	length : Real;
	increment : Real;
	lineAtX : Real;
	wellIds : StringArray;
	wellId : String;
	index : Integer;
	fontSize : Real;
	fontBold : Boolean;
	font : String;
	align : Integer;
	maxTextHeight : Real;
	currentTextHeight : Real;
	currentFontSize : Real;
	zoom : Real;
	lWheelWidth, lWheelTop,leftWheelLeft, rightWheelLeft, lLabelLeft : Real;
	wagonWellArray : CM_WagonWellArray;
	well : CM_WellcarWellVisit;
	wellLengths : IntegerArray;
	baseIncrement : Real;
	wellcarVisit : CM_WellcarVisit;
	wheelCol : Integer;
	flipHorizontal : Boolean;
	wellIndex : Integer;
	
begin

	flipHorizontal := self.myGridArea.flipHorizontal;

	fontSize := pFrame.drawFontSize;
	fontBold := pFrame.drawFontBold;
	font := pFrame.drawFontName;
	align := pFrame.drawTextAlign;
	
	maxTextHeight := _y2 - _y1 - 2;
	
	pFrame.drawFontName := "Verdana";
	
	zoom := self.myGridArea.scaleXFactor;
	if zoom &lt; 1.25 then
		pFrame.drawFontSize := 5;
	elseif zoom &lt; 1.75 then
		pFrame.drawFontSize := 6;
	elseif zoom &lt; 2.1 then
		pFrame.drawFontSize := 8;
	elseif zoom &lt; 2.6 then
		pFrame.drawFontSize := 9;
	elseif zoom &lt; 3.1 then
		pFrame.drawFontSize := 11;
	elseif zoom &lt; 3.6 then
		pFrame.drawFontSize := 14;
	else
		pFrame.drawFontSize := 14;
	endif;
	
	pFrame.drawFontBold := false;
	pFrame.drawTextAlign := 0;

	create wellIds transient;
	create wellLengths transient;
	create wagonWellArray transient;
	
	wellcarVisit := self.myGridArea.YRD_WagonArea.myWagon.CM_WellcarVisit;
	wheelCol := self.getColWheel(wellcarVisit);
	
	// for draw of wagon wheels
	if zoom &gt;= 3 then
		pFrame.drawWidth := 2;	
	else
		pFrame.drawWidth := 1;
	endif;
	pFrame.drawFillStyle := pFrame.DrawFillStyle_Solid;
	pFrame.drawFillColor := Gray;//14671839;//YRD_WagonArea.DisabledGrey_Light;
	if self.myGridArea.YRD_WagonArea.isWagonSelected then
		pFrame.drawFillColor := wheelCol;
	endif;
	
	wellcarVisit.allWagonWellsArray.copy(wagonWellArray);
	foreach well in wagonWellArray do
		wellIds.add( well.id );
		wellLengths.add( well.allLocationsControllersArray.size );
	endforeach;

	length := _x2 - _x1;
	baseIncrement := length / wellcarVisit.allLocationsControllersArray.size;
	lineAtX := _x1;
	index := 0;

	lWheelTop := _y2 + 2;
	lWheelWidth := maxTextHeight;
		
	while index &lt; pWellCount do
	
		if flipHorizontal then
			wellIndex := pWellCount - index;
		endif;
		index := index + 1;
		if not flipHorizontal then
			wellIndex := index;
		endif;
		
		wellId := wellIds[wellIndex];
		increment := baseIncrement * wellLengths[wellIndex];
		lineAtX := lineAtX + increment;
		pFrame.drawLine(lineAtX, _y1, lineAtX, _y2, Black);	 // Well end lines on the body ( 40 ft line )
		pFrame.drawTextAt( wellId, lineAtX - (increment/2), _y1 - 2, Black  );  // Well ids on the body
		
		if index &lt; pWellCount then
			//draw extra wheels pre well end
			leftWheelLeft := lineAtX - ((lWheelWidth * 2 ) + 2 );
			rightWheelLeft := leftWheelLeft + lWheelWidth + 1;
			pFrame.drawEllipse2(leftWheelLeft, lWheelTop, leftWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
			pFrame.drawEllipse2(rightWheelLeft, lWheelTop, rightWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
			
			//draw bogie
			pFrame.drawLine( leftWheelLeft + (lWheelWidth / 2), lWheelTop, leftWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
			pFrame.drawLine( rightWheelLeft + (lWheelWidth / 2), lWheelTop, rightWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
			pFrame.drawLine( leftWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), rightWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
	
			//draw wheels at next well start
			leftWheelLeft := rightWheelLeft + lWheelWidth + 4;
			rightWheelLeft := leftWheelLeft + lWheelWidth + 1;
			pFrame.drawEllipse2(leftWheelLeft, lWheelTop, leftWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
			pFrame.drawEllipse2(rightWheelLeft, lWheelTop, rightWheelLeft + lWheelWidth, lWheelTop + lWheelWidth, wheelCol);
			
			//draw bogie
			pFrame.drawLine( leftWheelLeft + (lWheelWidth / 2), lWheelTop, leftWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
			pFrame.drawLine( rightWheelLeft + (lWheelWidth / 2), lWheelTop, rightWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
			pFrame.drawLine( leftWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), rightWheelLeft + (lWheelWidth / 2), lWheelTop + (lWheelWidth / 2), Black );
		endif;
		
	endwhile;

epilog

	delete wellIds;
	delete wagonWellArray;
	delete wellLengths;
	
	pFrame.drawFontSize := fontSize;
	pFrame.drawFontBold := fontBold;
	pFrame.drawFontName := font;
	pFrame.drawTextAlign := align;
	
end;
</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="pWellCount" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="6cdf6d40-a7e1-4230-8abb-507c64252665">
        <updating/>
        <source>drawSelf(pFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 12/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	lPicY, lPicX	,lPicY2, lPicX2, zoom		: Real;
	lControllerWidth, lC, lF : Integer;
	tmpPic : Picture;
	lChar : Character;
begin
	if self.disabledAppearance then
		return;
	endif;
	zoom := self.myGridArea.scaleXFactor;
	
	if zoom &lt;= 1 then
		return;
	endif;
	
	if self.myGridArea.isBoxcar then
		// Boxcar has no twist locks.
		return;
	endif;
	
	self.cellHeight := self.y2 - self.y1;
	lControllerWidth := (self.x2 - self.x1).Integer;

	lPicX := self.x1 + (lControllerWidth.Real * 0.25).Real;
	lPicX2 := lPicX + (lControllerWidth.Real * 0.50).Real;
	lPicY := self.y1 + (self.cellHeight * 0.25).Real;
	lPicY2 := lPicY + (self.cellHeight * 0.50).Real;

	lPicY := self.y1 + 1;
	
	if self.myLocationsController.CM_WagonController.isWellcarCont then	//11 Dec 2014	NDL	Par 35346
		//not drawing twist locks for Wellcar wagons.
		return;
		
	elseif self.myLocationsController.CM_WagonController.isSkeletonCarCont then	// TFS 2533
		return;
	
	elseif self.myLocationsController.CM_WagonController.twistlocksAreUp then
		lPicY := self.y1 - (self.cellHeight * 0.25).Real;
		lChar := 233.Character;
		lF := 8;
		if  zoom &lt; 2 then
			lF := 4;
		elseif  zoom = 2 then
			lF := 6;
		elseif  zoom &gt; 3 then
			lF := 10;
		endif;
		lC := DarkBlue;
	elseif self.myLocationsController.CM_WagonController.hasTwistlocks then
		return;

	elseif self.myLocationsController.CM_WagonController.isAvailable then
		return;
		
	else
		lChar := 251.Character;
		lPicY := lPicY - 2;
		lF := 12;
		if  zoom &lt; 2 then
			lF := 6;
		elseif  zoom = 2 then
			lF := 8;
		elseif  zoom &gt; 3 then
			lF := 16;
		endif;
		lC := Red;
	endif;
	pFrame.drawFontName := "WingDings";
	pFrame.drawFontSize := lF;
	pFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	pFrame.drawTextAt(lChar,lPicX,lPicY,lC);
end;</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getColFrameBack" id="5eab6b59-cb07-4112-9ca9-38530d76eb83">
        <source>getColFrameBack() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	10 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.disabledAppearance then
		return YRD_WagonArea.DisabledGrey_Dark;
	else
		return Black;
	endif;
	
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColFrameFill" id="1c2c96a2-74ae-4e13-b262-42ba44b1810b">
        <source>getColFrameFill() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	10 November 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications	
----------  ----------  --------------------------------------------------
*/
vars
	wagon			: CM_Wagon;
	col				: Integer;
begin
	if self.disabledAppearance then
		col := YRD_WagonArea.DisabledGrey_Light;
	else
		wagon := self.myGridArea.YRD_WagonArea.myWagon;
		if wagon &lt;&gt; null then
//			col := wagon.getCCAllocationColor;
			if wagon.isBoxcar then
				if wagon.confirmed then
					if wagon.myWagonClass.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicTransporter then // TFS 49523 TRANSPORTER
						col := CM_BoxcarVisit.TransporterDrawColour; // TFS 49523 
					elseif wagon.myWagonClass.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicBulk then // TFS 49523  BULK
						col := CM_BoxcarVisit.BulkcarDrawColour; // TFS 49523 
					else
						col := CM_BoxcarVisit.BoxcarDrawColour;
					endif;
				else
					col := YRD_WagonArea.DisabledGrey_Light;
				endif;
			endif;
		endif;
	endif;
	
	if col = null or col = NullColour then
		col := White;
	endif;

	return col;
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasTwistLocks" id="cbdcadb6-8477-454e-8608-f61e8b2376d7">
        <source>hasTwistLocks():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2020	jlgndl1	Initial creation	TFS 50164

*/

vars

begin

	if self.myGridArea.isBoxcar then
		return false;
	elseif self.myGridArea.isWellcar then
		return false;
	elseif self.myGridArea.isSkeletonCar then
		return false; 
	else
		return true;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControllerState" id="cbe883a5-162a-45a4-a5dd-69db5d046075">
        <updating/>
        <source>setControllerState(state : Integer) updating;
// ---------------------------------------------------------------------------
// Created:      31 July 2003 by cnwsgp1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/08/2009	consw1		PAR 20464 - Incorrect rail wagon twistlock altered
// ---------------------------------------------------------------------------
vars
	tmpController : CM_WagonController;
	lWagonPosition : CMIF_TIWagonPosition;
	lPicture : Binary;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin
	tmpController := self.myLocationsController.CM_WagonController;

	create lWagonPosition transient;
	//lWagonPosition.myTrackedItem := null;
	lWagonPosition.position := tmpController.myWagon.allLocationsControllersArray.indexOf(tmpController);
	
	if state = Twist_Locked then
		lWagonPosition.available := true;
		lWagonPosition.hasTwistLocks := true;
		lWagonPosition.twistLocksAreUp := false; 
		lPicture := self.myGridArea.YRD_WagonArea.pictureHasTLs;
	elseif state = Twist_Available then
		lWagonPosition.available := true;
		lWagonPosition.hasTwistLocks := false;
		lWagonPosition.twistLocksAreUp := false; 
		lPicture := self.myGridArea.YRD_WagonArea.pictureAvail;
	elseif state = Twist_NotAvailable then
		lWagonPosition.available := false;
		lWagonPosition.hasTwistLocks := false;
		lWagonPosition.twistLocksAreUp := false; 
		lPicture := self.myGridArea.YRD_WagonArea.pictureUnavail;
	elseif state = Twist_Up then
		lWagonPosition.available := true;
		lWagonPosition.hasTwistLocks := true;
		lWagonPosition.twistLocksAreUp := true; 
		lPicture := self.myGridArea.YRD_WagonArea.pictureTLsUp;
	else
		return;
	endif;

	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWagonController(tmpController.myWagon, lWagonPosition, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Wagon', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	self.picture := lPicture;
		
epilog
	delete lWagonPosition;
end;</source>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="017f040d-ae49-4736-8865-a3575b6ea999">
        <updating/>
        <source>setForCreate(pController : CM_WagonController; pWagonRow : YRD_WagonRow;
			 pWagonCol : YRD_WagonColumn; pGridArea : YRD_WagonArea) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin
	self.myLocationsController := pController;
	self.myGridColumn 	:= pWagonCol;
	self.myGridRow		:= pWagonRow;
	self.myGridArea 	:= pGridArea;
end;</source>
        <Parameter name="pController" type="CM_WagonController"/>
        <Parameter name="pWagonRow" type="YRD_WagonRow"/>
        <Parameter name="pWagonCol" type="YRD_WagonColumn"/>
        <Parameter name="pGridArea" type="YRD_WagonArea"/>
    </JadeMethod>
</Class>
