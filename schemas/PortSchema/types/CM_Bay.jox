    <JadeMethod name="importFromXMLDoc" id="195c99b0-fffd-43d5-8f67-a0929493a4dd">
        <updating/>
        <source>importFromXMLDoc(_jadeXMLElement: JadeXMLElement input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	allSlotsElement,
	slotElement 	 : JadeXMLElement;
	childNode 	  : JadeXMLNode;
	slot 	: CM_SlotDefn;
	cell	: CM_CellDefn;
	tier 	: CM_TierDefn;
	ordinalDeck,
	ordinalCell,
	ordinalTier : Integer;
begin
	inheritMethod(_jadeXMLElement);
	
	// should have most of the proxy done
	
	//because slots have a tier and cell element need to set here because was all tiers &amp; cells
	// were not created before the slots were
	allSlotsElement:= _jadeXMLElement.getElementByTagName(CM_Bay::allSlotsByOrdinal.name);
	if allSlotsElement &lt;&gt; null then // JLGAB1 11MAR20
		foreach childNode in allSlotsElement.childNodes do
			slotElement:=childNode.JadeXMLElement;
			ordinalDeck:=slotElement.getElementByTagName(CM_SlotDefn::ordinalDeck.name).textData.Integer;
			ordinalCell:=slotElement.getElementByTagName(CM_SlotDefn::ordinalCell.name).textData.Integer;
			ordinalTier:=slotElement.getElementByTagName(CM_SlotDefn::ordinalTier.name).textData.Integer;
			slot:=self.allSlotsByOrdinal[ordinalDeck,ordinalCell,ordinalTier];
			if slot = null then
				continue;
			endif;
			if slot.isOnDeck() then
				cell:=self.allCellsOnDeckByOrdinal[ordinalCell];
				tier:=self.allTiersOnDeck[ordinalTier];
			else
				cell:=self.allCellsUnderDeckByOrdinal[ordinalCell];
				tier:=self.allTiersUnderDeck[ordinalTier];
			endif;
			slot.setCellAndTierDefn(cell,tier);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="31e7d4af-167f-4640-9546-cce96050d2dd">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	childElement		: JadeXMLElement;
	allChildElements : JadeXMLElementArray;
	pxyCell 	: CM_CellDefn;
	pxyTier 	: CM_TierDefn;
	pxySlot		: CM_SlotDefnVessel;
	isOnDeck	: Boolean;
begin
	if _property = CM_Bay::allCellsOnDeck then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_CellDefn.name,allChildElements);
		foreach childElement in  allChildElements do
			create pxyCell transient;
			pxyCell.setMyBay(self,true);
			pxyCell.importFromXMLDoc(childElement);	
		endforeach;
	elseif _property = CM_Bay::allTiersOnDeck then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_TierDefn.name,allChildElements);
		foreach childElement in  allChildElements do
			create pxyTier transient;
			pxyTier.setMyBay(self,true);
			pxyTier.importFromXMLDoc(childElement);
		endforeach;
	elseif _property = CM_Bay::allCellsUnderDeck then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_CellDefn.name,allChildElements);
		foreach childElement in  allChildElements do
			create pxyCell transient;
			pxyCell.setMyBay(self,false);
			pxyCell.importFromXMLDoc(childElement);
		endforeach;
	elseif _property = CM_Bay::allTiersUnderDeck then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_TierDefn.name,allChildElements);
		foreach childElement in  allChildElements do
			create pxyTier transient;
			pxyTier.setMyBay(self,false);
			pxyTier.importFromXMLDoc(childElement);
		endforeach;
	elseif _property = CM_Bay::allSlotsByOrdinal then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_SlotDefnVessel.name,allChildElements);
		foreach childElement in  allChildElements do
			create pxySlot transient;
			isOnDeck := childElement.getElementByTagName(CM_SlotDefn::ordinalDeck.name).textData.Integer = DeckOnDeck;
			pxySlot.setMyBay(self,isOnDeck);
			pxySlot.importFromXMLDoc(childElement);
		endforeach;
	endif;
	
	inheritMethod(_property, _xmlElement);

epilog
	delete  allChildElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="internalCreateSlots" id="dac661e1-e1ca-4885-807e-0decfb7af940">
        <updating/>
        <source>internalCreateSlots(_onDeck : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 March 2002 by cnwdwq1
//
// Purpose:     Converted from C++ localCreateSlots function.
//              Primary assumption is that the internalCreateCellsTiers method has been called first, else will do nothing
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
// ---------------------------------------------------------------------------

vars
	ordinalDeck : Integer;
	isISO : Boolean;	
	onDeckBayDefn, underDeckBayDefn : CM_Bay;
	realSlotDefn, pxySlotDefn : CM_SlotDefn;
	cellId, tierId : String;
	cellColl : CM_CellDefnByOrdinalDict;
	cellDefn : CM_CellDefn;
	tierColl : CM_TierDefnByOrdinalDict;
	tierDefn : CM_TierDefn;
	ordinalSlot : Integer;
	onDeck,loadState,newCellTier:Boolean;
	dirController : CMIF_DirectionController;
begin
	
	exclusiveLock(self);
	
	create dirController transient; //CCMS 1045 AKB2004Jan
	dirController.setForCreate(); //CCMS 1045 AKB2004Jan
	//-------------------------------------------
	// Setup control properties
	//-------------------------------------------
	if _onDeck then //ON Deck
		ordinalDeck :=  DeckOnDeck;
		onDeckBayDefn := self;
		underDeckBayDefn := null;
		cellColl := self.allCellsOnDeckByOrdinal;
		tierColl := self.allTiersOnDeck;
		onDeck := true;
	else
		ordinalDeck :=  DeckUnderDeck;
		onDeckBayDefn := null;
		underDeckBayDefn := self;
		cellColl := self.allCellsUnderDeckByOrdinal;
		tierColl := self.allTiersUnderDeck;
		onDeck := false;
	endif;
	
	//---------------------
	//Create slotDefns, 1st a proxy to do the work, then set its properties..
	//---------------------
	if self.isKindOf(CM_BayVoyage) then
		create pxySlotDefn as CM_SlotDefnVoyage transient;
	else
		create pxySlotDefn as CM_SlotDefnVessel transient;
	endif;		
//write "AKB1 " &amp; self.id;
	foreach cellDefn in cellColl do
		foreach  tierDefn in tierColl do
			// check that the slots ordinals and label ids are in line, incase a tier/cell has been inserted
			if self.checkAndResetOrdinals(cellDefn,tierDefn,_onDeck)then
				break;
			endif;
		endforeach;
	endforeach;


	app.cmsBeginLoad(loadState);
	// NOTE these cells and tiers are REAL
	foreach cellDefn in cellColl do
		foreach  tierDefn in tierColl do

			// only create if the slot is empty
			if cellDefn.allSlotDefinitions[ordinalDeck,tierDefn.ordinal] &lt;&gt; null then
				continue;
			endif;
						
			//------------------------------------
			// Create and initialise the SlotDefn
			//------------------------------------
			cellId := cellDefn.id;
			tierId := tierDefn.id;
			
			pxySlotDefn.setProxy( cellDefn.ordinal, ordinalDeck, tierDefn.ordinal, 0, 0, 0, 0,0,
			                     true, false, false, false, false, false, false, false, false,false, false,false,
			                     cellId, tierId, false, false, false);
			
			
			create realSlotDefn as pxySlotDefn.class;

			realSlotDefn.setMyBay(self, onDeck);
			realSlotDefn.setForCreate(pxySlotDefn, app.myPassport);
			realSlotDefn.setCellAndTierDefn(cellDefn,tierDefn);
			  //CCMS 1045 AKB2004Jan
			realSlotDefn.setDefaultDoorDirections(dirController); // use the system default settings stored on this controller

			if realSlotDefn.isKindOf(CM_SlotDefnVoyage) then
				realSlotDefn.CM_SlotDefnVoyage.createSlotController(false);
			endif;
			
		endforeach;
	endforeach;
	
epilog	// 08/04/2011 cnwmh5 #27347
	
	app.cmsEndLoad(loadState);


	//Clean up
	delete dirController;
	delete pxySlotDefn;
end;</source>
        <access>protected</access>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAftBay" id="90df7fce-0cd5-49d5-946d-b78217f893bc">
        <source>isAftBay() : Boolean;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bayIdx : Integer;
begin
	bayIdx := 1;

	if self.myHold &lt;&gt; null then
		return self.myHold.allBays.indexOf(self) &gt; bayIdx;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
