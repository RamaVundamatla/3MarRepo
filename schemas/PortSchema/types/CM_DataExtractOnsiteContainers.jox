    <JadeMethod name="initDataExtractFields" id="ebbcbd3f-2728-499a-aba5-7a9304f48c65">
        <source>initDataExtractFields(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	#cnwdz2	 

*/	
vars

begin
	self.extractOrder.clear();
	
	self.initDataExtractFields_Damage(_fields);
	self.initDataExtractFields_Hazard(_fields);
	self.initDataExtractFields_Stop(_fields);
	self.initDataExtractFields_CustNum(_fields);
	
	self.initDataExtractFields_Default(_fields);
	self.initDataExtractFields_ContData(_fields);
	self.initDataExtractFields_General(_fields);
	self.initDataExtractFields_GenData(_fields);
	self.initDataExtractFields_Receive(_fields);
	self.initDataExtractFields_Reefer(_fields);
	self.initDataExtractFields_Release(_fields);
	self.initDataExtractFields_Ship(_fields);
	self.initDataExtractFields_Status(_fields);
	self.initDataExtractFields_Tranship(_fields);
epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initDataExtractFields_ContData" id="6766d920-4abb-4dd5-a02f-bbd6771af86f">
        <source>initDataExtractFields_ContData(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
*************
25 May 2011 cnwsh3 Reviewed description and possible value fields
**************
*/

vars
	fieldName		: String;
	
begin
	fieldName := "customExportStop";
	self.initDataExtractField(_fields, CM_Container.name, "customExportStop", fieldName, STRING, "Held", "If Yes, a stop Customd Export Stop is applied to the container", STRING, "Yes or null");

	//fieldName := "transferTerminalFrom";
	//self.initDataExtractField(_fields, CM_Container.name, "transferTerminalFrom", fieldName, STRING, "Source Terminal", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	//fieldName := "transferTerminalTo";
	//self.initDataExtractField(_fields, CM_Container.name, "transferTerminalTo", fieldName, STRING, "Target Terminal", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	fieldName := "timeInTransit";
	self.initDataExtractField(_fields, CM_Container.name, "timeInTransit", fieldName, STRING, "Number Of Days In Transit", "Number of hours since the release time/date", STRING, "A number in string format");

	//fieldName := "mySubTerminal";
	//self.initDataExtractField(_fields, CM_Container.name, "mySubTerminal", fieldName, STRING, "Sub-Terminal", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	//fieldName := "mark";
	//self.initDataExtractField(_fields, CM_Container.name, "mark", fieldName, STRING, "Mark", "", STRING, "**** fill in with possible values description ****");

	fieldName := "markNumber";
	self.initDataExtractField(_fields, CM_Container.name, "markNumber", fieldName, STRING, "Mark Number", "Mark number of container", STRING, "String value of up to 30 charaters in length");

	fieldName := "status";
	self.initDataExtractField(_fields, CM_Container.name, "status", fieldName, STRING, "Status", "The status of the contents of the container", STRING, "FCL, LCL, MT or no value at all");

	fieldName := "receivedDT";
	self.initDataExtractField(_fields, CM_Container.name, "receivedDT", fieldName, TIMESTAMP, "Received Date/Time", "Date Time the container was received", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	fieldName := "hasToDoTasks";
	self.initDataExtractField(_fields, CM_Container.name, "hasToDoTasks", fieldName, BOOLEAN, "To Do", "Has to do tasks", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "hasRemarks";
	self.initDataExtractField(_fields, CM_Container.name, "hasRemarks", fieldName, BOOLEAN, "Has Remarks", "Returns true if remarks exist on the container", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "damaged";
