    <JadeMethod name="isCMIFDataMatch" id="f8feeb03-012f-4ee5-b9ce-eeca7b1db14b">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2017	jlgma1	Initial creation

*/

vars

begin
		return _yaData.value = null or _cmifAutoPlan.isDirectDelivery_Match(_yaData);

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
