    <JadeMethod name="trxHandleGenCargo" id="b267234b-f954-4b73-a02c-e01c7f749d92">
        <updating/>
        <source>trxHandleGenCargo(_roadJob : CM_RoadJob io; _cmifs : CMIF_Array; 
		_passport : CM_Passport input; _errorId : String io) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2002 by cnwrs2
//
// Purpose:     
//
// ---------------------------------------------------------------------------
vars
	cmif 		: CMIF_Object;
	cmifItem	: CMIF_TIGenCargo;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	beginTransaction;

	foreach cmif in _cmifs do
		cmifItem := cmif.CMIF_TIGenCargo;
		
		if not cmifItem.save(_roadJob, _passport, _errorId) then
			break;
		endif;	
		if _passport.hasErrors then
			break;
		endif;
	endforeach;

	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="io"/>
        <Parameter name="_cmifs" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_errorId" type="String" usage="io"/>
    </JadeMethod>
