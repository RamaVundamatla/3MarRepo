    <JadeMethod name="doQueryVisitType" id="656ac266-8a03-47b3-bbe9-2f1249492ec6">
        <updating/>
        <source>doQueryVisitType(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
*/

vars
	table : Table;
	savedChargedEffTS : TimeStamp;
	bank : CM_Bank;
	str : String;
	mp : Integer;
	rate : CM_Rate;

begin
	table := self.tblData;

	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate(self.effectiveDate.TimeStamp);
	
	self.myCurrentVisitType := self.cmbVisitType.listObject.HMS_VisitType;
	bank := self.cmbBank.listObject.CM_Bank;
	self.myCurrentBank := bank;
	
	if self.myCurrentVisitType = null then
		app.msgBox("Please select a Visit Type", "Query Error", MsgBox_OK_Only);
		return false;
	endif;
	
	//07.06.2018 cnwma1 ChangeRequest #38953
	if self.myCurrentBank = null then
		app.msgBox("Please select a Business Unit", "Query Error", MsgBox_OK_Only);
		return false;
	endif;
	str := "Rate History - ";

	str := str &amp; self.myCurrentVisitType.description;

	self.setCaption(str &amp; " /" &amp; self.myCurrentService.name &amp; " " &amp; self.myCurrentBank.code);
	self.setNavigatorHeading(self.caption);

	mp := app.mousePointer;
	app.mousePointer := MP_HOURGLASS;
	self.setMyCurrentRateEntry(null);

	table.rows := 1;
	rate := self.myCurrentVisitType.allServiceRates[self.myCurrentService];
	self.loadRateHistoryVisitType(self.myCurrentVisitType, table, self.myCurrentService);
	
	return true;
	
epilog
	app.mousePointer := mp;
	app.setChargeRateEffectiveDate(savedChargedEffTS);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRateAuditPrint" id="0621c6ba-7312-480d-b5f8-0c38597ec531">
        <source>doRateAuditPrint();
// ---------------------------------------------------------------------------
// Created:		19 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	Invoice_Label_Width = 250;
	Before_Description_Spacing = 15;
	After_Description_Spacing = 8;
vars
	rptAudit:    INV_DetailedAuditReport; 
	tmpJadeReport  : JadeReport;
	theBank : CM_Bank;
	rdg	 : CM_RootDebtorGroup;
	dateFromLocal,
	dateToLocal	 : TimeStamp;
begin
	app.mousePointer := MP_HOURGLASS; // PAR 31662

	if self.chkoutputCSV.value then //cwnrd1 par 24021 18.8.2010
		self.doCSV();
		return;
	endif;

	theBank := app.myRoot.myRootCompany;
	rdg := theBank.getRootDebtorGroup();

	
	create tmpJadeReport transient;
	tmpJadeReport.description := "Audit Report";
	app.printer.setReport(tmpJadeReport);
	app.printer.setMargins(Print_Landscape,10,10,10,10);
	app.printer.suppressDialog := true;

	create rptAudit;
	rptAudit.myBank := self.myCurrentBank;
	rptAudit.myDebtor := self.cmbDebtorPrt.listObject.CM_DebtorNode;
	rptAudit.myService := self.cmbServicePrt.listObject.CM_Service;
	rptAudit.myDefaultDebtor := rdg;
	
	dateFromLocal.setDate(self.txtDateFrom.getDate());			// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	dateFromLocal.setTime(self.txtTimeFrom.getTime());			// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	dateToLocal.setDate(self.txtDateTo.getDate());				// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	dateToLocal.setTime(self.txtTimeTo.getTime());				// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	rptAudit.dateFrom := self.localToSystemTime(dateFromLocal);	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	rptAudit.dateTo := self.localToSystemTime(dateToLocal);		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	
	rptAudit.doPrint();
	app.printPreview(tmpJadeReport, true);
	
	
epilog
	app.printer.close;

	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
