    <JadeMethod name="pxyCreateUpdateProxy" id="a478d05a-7888-4765-8e2a-0b3a8fe8b59e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

vars
	pxyClass : CM_ExportImportClass;
	realProperty : CM_ExportImportProperty;
	pxyProperty : CM_ExportImportProperty;
	completedOK		: Boolean;
	
begin
	pxyClass := inheritMethod;
	
	foreach realProperty in self.allProperties do
		pxyProperty := realProperty.pxyCreateUpdateProxy;
		pxyClass.allProperties.add(pxyProperty);
	endforeach;
	
	completedOK := true;			
	return pxyClass;
	
epilog
	if not completedOK then			
		delete pxyClass;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setExportImportProperty" id="2bbe2837-d36b-4fa6-9ea3-2f734e7ab9dc">
        <updating/>
        <source>setExportImportProperty(
	_propName: String;
    _include: Boolean;
    _expand: Boolean;
    _displayName: String;
	_refClassName : String;
	_isAttribute : Boolean;
	_isReference : Boolean;
	_isCollection : Boolean)  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

vars
    exImProp: CM_ExportImportProperty;
    prop: Property;
begin
    
    prop := self.myClass.getRepPropertyInFullTree(_propName);
    if prop = null then
        app.raiseUnexpectedProgramError(class.name, method.name, 
            "Property not found: " &amp; _propName &amp; " in class " &amp; self.myClass.name);
        return;
    endif;
   
     create exImProp transient;  

    exImProp.setProxy(prop, _include, _expand, _displayName,_refClassName,_isAttribute,_isReference,_isCollection);
	
	self.allProperties.add(exImProp);
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_include" type="Boolean"/>
        <Parameter name="_expand" type="Boolean"/>
        <Parameter name="_displayName" type="String"/>
        <Parameter name="_refClassName" type="String"/>
        <Parameter name="_isAttribute" type="Boolean"/>
        <Parameter name="_isReference" type="Boolean"/>
        <Parameter name="_isCollection" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="19e0daba-3e83-4676-8037-0913d9c0b387">
        <updating/>
        <source>setForCreate(_proxyClass : CM_ExportImportClass) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

vars
	proxyProperty : CM_ExportImportProperty;
begin
	self.className := _proxyClass.className;
	self.displayName := _proxyClass.displayName;
	self.category := _proxyClass.category;
	self.myKeyName := _proxyClass.myKeyName;
	self.isExportable := _proxyClass.isExportable;
	self.loadMethodName := _proxyClass.loadMethodName;
	
	foreach proxyProperty in _proxyClass.allProperties do
		self.createProperty(proxyProperty);
	endforeach;
epilog

end;</source>
        <Parameter name="_proxyClass" type="CM_ExportImportClass"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="03ee5800-eadf-4569-98d9-11830561cbd5">
        <updating/>
        <source>setForUpdate(_proxyClass: CM_ExportImportClass) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

vars
	proxyProperty : CM_ExportImportProperty;
	realProperty : CM_ExportImportProperty;
	toDelete : CM_ExportImportPropertySet;
	expectedEdition : Integer;
	
begin
	self.updateObjectEdition (self);	
	
	self.className := _proxyClass.className;
	self.displayName := _proxyClass.displayName;
	self.isExportable := _proxyClass.isExportable;
	self.loadMethodName := _proxyClass.loadMethodName;
	self.myKeyName := _proxyClass.myKeyName;
	self.category := _proxyClass.category;
	
	create toDelete transient;
	exclusiveLock(self.allProperties);
	self.allProperties.copy(toDelete);
	
	// 1. Create new features, update existing ones
	foreach proxyProperty in _proxyClass.allProperties do
		proxyProperty.pxyGetRealObjectAndEdition(realProperty, expectedEdition);
		if realProperty = null then
			self.createProperty(proxyProperty);
		else
			toDelete.remove(realProperty);
			exclusiveLock(realProperty);
			if realProperty.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'exportImportProperty', null, null);
				return;
			endif;
			realProperty.setForUpdate(proxyProperty);
		endif;
	endforeach;
	
	// 2. Delete missing features
	foreach realProperty in toDelete do
		self.allProperties.remove(realProperty);
		delete realProperty;
	endforeach;
	
epilog
end;</source>
        <Parameter name="_proxyClass" type="CM_ExportImportClass"/>
    </JadeMethod>
