    <JadeMethod name="doBulkEdit" id="32a24886-8da7-49fc-81c4-9e38bf0a0e66">
        <source>doBulkEdit(_all : Boolean);
// ---------------------------------------------------------------------------
// Created:     12 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	objSet 		: ObjectSet;
	tiArray 	: ObjectArray;
	tbl 		: CM_DataTable;
	numRows, 
	row ,
	objSetSize	: Integer;
	obj 		: Object;
	ti 			: CM_TrackedItem;
	tiSet		: CM_TISet;

begin
	tbl := self.tblData;
	create objSet transient;
	tbl.getSelectedCellObjects(objSet);
	objSetSize := objSet.size;
	if objSetSize &lt; 1 then
		if _all then
			tbl.selectAllCells();
			tbl.getSelectedCellObjects(objSet);
		else
			return;
		endif;
	endif;
	create tiArray transient;
	foreach obj in objSet do
		tiSet := obj.CMIF_CommercialQueryEntity.getTISet();
		if tiSet &lt;&gt; null and tiSet.size  &gt; 0 then 
			foreach ti in tiSet do
				if ti.isKindOf(CM_TrackedItem) and not tiArray.includes(ti) then
					tiArray.add (ti);
				endif;
			endforeach;
		endif;
	endforeach;
	
	if tiArray.size &gt; 1 or tiArray.size = 1 then
		self.myAssistant.showCargoEnquiryForTIs(tiArray[1].CM_TrackedItem, tiArray, self.myMasterMenuAction, false);
	endif;
	self.tblData.deselectAll();
epilog
	delete tiArray;
	delete objSet;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExportCSV" id="d2873d63-1241-4bdf-884f-98791920f8e4">
        <updating/>
        <source>doExportCSV() updating;
// ---------------------------------------------------------------------------
// Created:     29 November 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTbl			: CM_DataTable;
	i, j,
	row,
	numRows,
	numCols			: Integer;
	lastHeading,
	txt,
	str				: String;
	outputRow	: Boolean;
begin
	// we want to repeat some fields here when outputting as csv.
	create tmpTbl transient;
	tmpTbl.visible := false;
	self.addControl(tmpTbl);
	
	numRows := self.tblData.rows;
	numCols := self.tblData.columns;
	
	tmpTbl.rows := 0;
	tmpTbl.columns := numCols;
	foreach i in 1 to numRows do
		str := null;
		lastHeading := null;
		outputRow := false;
		foreach j in 1 to numCols do
			if i &lt;= self.tblData.fixedRows then
				// outputting heading
				txt := self.tblData.accessCell(i, j).text;
				if txt &lt;&gt; null then
					lastHeading := txt;
					outputRow := true;
				else
					txt := lastHeading;
				endif;
			else
				// outputting data
				outputRow := true;
				txt := self.tblData.accessCell(i, j).text;
			endif;
			/*
			elseif j = 2 and i &gt; self.tblData.fixedRows then
				if txt = null then
					// skip to next row;
					str := null;
					break;
				endif;
			endif;
			*/
			if j = 1 then
				str := txt;
			else
				str := str &amp; Tab &amp; txt;
			endif;
		endforeach;
		if str &lt;&gt; null and outputRow then
			tmpTbl.addItem(str);
		endif;
	endforeach;
	tmpTbl.outputAsCSV('jmt.csv');
epilog
	delete tmpTbl;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuCompare" id="79e98cc7-0b57-4b97-88a8-09186ce62929">
        <updating/>
        <source>doMnuCompare(menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	numRows,
	numCols,
	i, j, sum			: Integer;
	obj					: Object;
	firstDTL, secondDTL : CMIF_CommercialQueryEntity;
	one,
	two,
	brk  				: Boolean;
	objSet 				: ObjectSet;
	tiFirstSet,
	tiSecondSet 		: CM_TISet;
	tiArray 			: ObjectArray;
	tbl					: CM_DataTable;
	row ,
	objSetSize,
	firstSetSize,
	secondSetSize 		: Integer;
	ti 					: CM_TrackedItem;
	str 				: String;
begin
	tbl := self.tblData;
	create objSet transient;
	numRows := tbl.rows;
	numCols := tbl.columns;
	one := false;
	two := false;
	foreach i in 1 to numRows where brk &lt;&gt; true do 
		foreach j in 1 to numCols where brk &lt;&gt; true do
			if tbl.accessCell(i,j).selected then
				obj := tbl.accessedCell.itemObject;
				if  one = false and obj &lt;&gt; null then
					firstDTL := obj.CMIF_CommercialQueryEntity;//CMIF_CommercialQueryDtl;
					tiFirstSet := obj.CMIF_CommercialQueryEntity.getTISet();
					firstSetSize := tiFirstSet.size;
					one := true;
				elseif two = false and obj &lt;&gt; null then
					secondDTL := obj.CMIF_CommercialQueryEntity;//CMIF_CommercialQueryDtl;
					tiSecondSet := obj.CMIF_CommercialQueryEntity.getTISet();
					secondSetSize := tiSecondSet.size;
					two := true; 
				endif;
				if one = true and two = true then 
					brk := true;
				endif;
			endif;
		endforeach;
	endforeach;
	if not one or not two then
		return;
	endif;
	i := 0;
	if firstSetSize &lt; secondSetSize then
		foreach ti in tiFirstSet do 
			if tiSecondSet.includes(ti) then
				i := i + 1;
				objSet.add(ti);
				str :=str  &amp; i.String &amp; ".  " &amp;ti.id &amp;"     "&amp; ti.String &amp; CrLf;
			endif;
		endforeach;
		app.writeStatement( str);
		sum := tiFirstSet.size + tiSecondSet.size;
		str := "Sum  TI's :"&amp; sum.String&amp; "  / Shared TI's : "&amp; i.String ;
		app.msgBox(str, " Compare Result", null);
	else
		foreach ti in tiSecondSet do 
			if tiFirstSet.includes(ti) then
				i := i + 1;
				objSet.add(ti);
				str :=str  &amp; i.String &amp; ".  " &amp;ti.id &amp;"     "&amp; ti.String &amp; CrLf;
			endif;
		endforeach;
		app.writeStatement( str);
		sum := tiFirstSet.size + tiSecondSet.size;
		str := "Sum  TI's :"&amp; sum.String&amp; "  / Shared TI's : "&amp; i.String ;
		app.msgBox(str, " Compare Result", null);
	endif;
epilog
	delete objSet;
end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="38b94e10-19b4-44eb-823b-421f19b0327c">
        <source>doMnuInspectObject();
// ---------------------------------------------------------------------------
// Created:     13 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tbl 		: CM_DataTable;
	objSet 		: ObjectSet;
	objSetSize 	: Integer;
begin
	tbl := self.tblData;
	create objSet transient;
	if self.tblData.row &gt; self.tblData.fixedRows then
		tbl.getSelectedCellObjects(objSet);
		objSetSize := objSet.size;
		if objSetSize &lt; 1 then
			return;
		endif;
		objSet.inspect;
	endif;
epilog
	delete objSet;
end;</source>
    </JadeMethod>
