    <JadeMethod name="cmbTiType_click" id="e8a84881-f874-4df7-bf04-faf58ff454ea">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTiType_click(combobox: GTE_ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16.06.2008	cnwrd1		Par 16959
// ---------------------------------------------------------------------------
vars

begin

	self.setCellTextFromControl(combobox.mySheet, combobox, combobox.text);

	// 16.06.2008 cnwrd1 par 16959 start
	if combobox.listObject = null then 				//terminal not configured for that cargo type ( via old pre-note + ?).
		self.setCargoTypeFields(combobox.mySheet); 	//update cargo type reference (to null, before excpetion)
		app.raiseCMException2(IncompatibleTypeForLocation, '', ". Terminal is not configured for that Cargo Type (" &amp; combobox.text &amp; ")" , null, null);		//warn user
	else
	// 16.06.2008 cnwrd1 par 16959 end
		//if there are no terminal area restrictions on the cargo type then allow all TAs
		//otherwise poopulate accordingly
		if combobox.listObject.CM_CargoBOLType.allTerminalAreas.size &lt;&gt; 0 then
		self.populateTAs(combobox.listObject.CM_CargoBOLType);
		endif;
	endif;

	self.setCargoTypeFields(combobox.mySheet);
	// now done in setCargoTypeFields(..)
	//self.myAssistant.GTE_Assistant.showHideCEDOField(combobox.mySheet.myTblExtra,1);// ### CCMS 1294 AKB2005JAN
	
	self.resize();
end;</source>
        <Parameter name="combobox" type="GTE_ComboBox" usage="input"/>
    </JadeMethod>
