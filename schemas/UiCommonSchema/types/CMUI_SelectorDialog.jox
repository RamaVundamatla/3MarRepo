    <JadeMethod name="moveCriteriaLine" id="5fac1880-bc55-4c37-9d31-0044480f690c">
        <updating/>
        <source>moveCriteriaLine( _up : Boolean ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/

vars
	criteriaLine : CM_SelectorCriteriaLine;
	rowIndex : Integer;

begin

	criteriaLine := self.tblCriteria.accessRow(self.tblCriteria.row).itemObject.CM_SelectorCriteriaLine;
	if criteriaLine = null or not self.tblCriteria.accessRow(self.tblCriteria.row).selected then
		return;
	endif;
	
	rowIndex := self.tblCriteria.row;
	self.tblCriteria.removeItem( self.tblCriteria.row );
	
	if _up then
		rowIndex := rowIndex - 1;
	else
		rowIndex := rowIndex + 1;
	endif;
	
	self.tblCriteria.addItemAt( criteriaLine.getDescriptionString, rowIndex );
	self.tblCriteria.accessRow( rowIndex ).itemObject := criteriaLine;
	
	self.tblCriteria.accessRow( rowIndex ).backColor := criteriaLine.getPerformanceColour;
	
	self.tblCriteria.accessRow( rowIndex ).selected := true;
	self.tblCriteria.row := rowIndex;	

epilog

	self.evaluateUpDown();

end;</source>
        <access>protected</access>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
