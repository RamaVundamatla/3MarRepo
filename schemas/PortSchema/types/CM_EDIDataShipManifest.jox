    <JadeMethod name="getMyVoyageObject" id="e5e0f8c0-ecc7-4464-bb00-302b4919cf7a">
        <source>getMyVoyageObject(): CM_Voyage;
// ---------------------------------------------------------------------------
//navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ediTI : CM_EDITrackedItem;
	iter : Iterator;
	voyage : CM_Voyage;
	terminal : CM_Terminal;																			//navra1 - MTN-33533 - 2nd Dec 2024
begin
	if self.allEDITrackedItems = null or self.allEDITrackedItems.size() = 0 then					//navra1 - MTN-33087 - 23rd Oct 2024
		return null;																				//navra1 - MTN-33087 - 23rd Oct 2024
	endif;																							//navra1 - MTN-33087 - 23rd Oct 2024
	
	iter := self.allEDITrackedItems.createIterator();
	
	while iter.next(ediTI) do
		if ediTI.isEDICargo() then
			//navra1 - MTN-33533 - 2nd Dec 2024 - end
			if not ediTI.isEDICargoOnShipTI() then	//it is cargoOnSite
				if ediTI.CM_EDICargoOnSiteTI.imexStatus = "TRANSHIP" then
					terminal := app.myPassport.myTerminal;
					
					if terminal = null then
						return null;
					endif;
	
					return terminal.lookupVoyage(ediTI.CM_EDICargoOnSiteTI.exportVoyageCode, null, false);
				endif;
			endif;
			//navra1 - MTN-33533 - 2nd Dec 2024 - end
			
			voyage := ediTI.getVoyage();
			
			if voyage &lt;&gt; null then
				return voyage;
			endif;
		endif;
	endwhile;	
	
	return null;									//navra1 - MTN-33087 - 23rd Oct 2024
	
epilog
	delete iter;									//navra1 - MTN-33087 - 23rd Oct 2024
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getRealCargoItem" id="cef4d497-03ec-4ae7-9013-477abc13f2b9">
        <source>getRealCargoItem(_ediTI: CM_EDICargoTI): CM_TrackedItem;
/*
Date		Who		Reason
20 Jun 2012	cnwcs5	Initial creation - par 29747
23 Aug 2023	navdap1	TFS 59721 EUP | Manifest Verify of Work Orders
06 Nov 2023 navsp1  TFS Defect 61067: EUP - New cargo group not created with same ID for a different operator
19 Aug 2024	navdap1	TFS 65649 POB | Changes for NSW caused different IFCSUM behaviour
31 Oct 2024 navsp1  MTN-33176 EUP - NTO-765 | Unable to add cargo group across voyages
*/
vars
	voyage		: CM_Voyage;
	terminal	: CM_Terminal;
	cargoType	: CM_CargoType;
	iter		: Iterator;			// TFS 59721
	cgDetail	: CM_CargoGroupDetail;	// TFS 59721
	realTI		: CM_TrackedItem;
	startObject,
	cgObj		: CM_CargoGroup;
begin

	terminal	:= self.getMyTerminal();
	voyage 		:= terminal.lookupVoyage(_ediTI.getVoyageCode(), null, false);
	
	if voyage = null then
		// Assume invalid voyage will be caught later in validation
		return null;
	endif;
		
	// PAR 32476 Allow for break bulk in different locations on ship
	cargoType := terminal.myRoot.allCargoTypesById[_ediTI.cargoType];
	if cargoType &lt;&gt; null and cargoType.isAllowDuplicates then
		realTI := self.getRealBreakBulkItem(_ediTI, cargoType, voyage.allOnshipTIsByCargoTypeId);
		if self.myTransportManifest &lt;&gt; null then																							//02.Nov.2023 navsp1 TFS 61067
			//if realTI &lt;&gt; null and (realTI.getMyCargoGroupId &lt;&gt; _ediTI.cargoGroupId or realTI.operatorCode &lt;&gt; _ediTI.operatorCode) then	//14.Nov.2023 navsp1 TFS 61127
			if realTI &lt;&gt; null and realTI.getMyCargoGroupId &lt;&gt; _ediTI.cargoGroupId then 													    //14.Nov.2023 navsp1 TFS 61127
				realTI := null;
			endif;
		endif;
		return realTI;
	endif;
	
	// TFS 59721 Cargo Groups aren't actually "on ship", so the voyage.allOnshipTIsByCargoTypeId collection
	// doesn't contain them. We need to use voyage.allOnshipTIsByCargoGroupId
	if cargoType &lt;&gt; null and cargoType.isCargoGroup then
		iter := voyage.allCargoGroupDetails.createIterator();
		while iter.next(cgDetail) do
			if cgDetail.myCargoGroup &lt;&gt; null and cgDetail.myCargoGroup.id = _ediTI.id  then
				/*//14.Nov.2023 navsp1 TFS 61127
				if self.myTransportManifest &lt;&gt; null then										 											//02.Nov.2023 navsp1 TFS 61067
					if cgDetail.myCargoGroup.operatorCode &lt;&gt; _ediTI.operatorCode then
						continue;
					endif;
				endif;*/
				return cgDetail.myCargoGroup;
			endif;
		endwhile;
		delete iter;
		
		//Try to find the cargo group from the terminal collection														//MTN-33176
		iter := terminal.allCargoGroupsByIdCargoType.createIterator;													//MTN-33176
		startObject := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq(_ediTI.id, _ediTI.cargoType).CM_CargoGroup;		//MTN-33176
		if startObject &lt;&gt; null then																						//MTN-33176
			iter.startAtObject( startObject );																			//MTN-33176			
			while iter.next(cgObj) do																					//MTN-33176
				if cgObj &lt;&gt; null then																					//MTN-33176
					if cgObj.id = _ediTI.id  then																		//MTN-33176
						if cgObj.operatorCode = _ediTI.operatorCode then												//MTN-33176
							return cgObj;																				//MTN-33176
						endif;																							//MTN-33176
					else																								//MTN-33176
						break;																							//MTN-33176
					endif;																								//MTN-33176					
				endif;																									//MTN-33176
			endwhile;																									//MTN-33176
		endif;																											//MTN-33176
		
		return null;
	endif;
	// TFS 59721 end
	
	//return voyage.allOnshipTIsByCargoTypeId[_ediTI.cargoType, _ediTI.id];
	
	//                                                                                                                                     //06.Nov.2023 navsp1 TFS 61067
	//Now the system can create duplicate cargo group IDs with different operators, so need to make sure selecting the right cargo.
	realTI := voyage.allOnshipTIsByCargoTypeId[_ediTI.cargoType, _ediTI.id];	
	if self.myTransportManifest &lt;&gt; null then
		//if realTI &lt;&gt; null and (realTI.getMyCargoGroupId &lt;&gt; _ediTI.cargoGroupId or realTI.operatorCode &lt;&gt; _ediTI.operatorCode) then //14.Nov.2023 navsp1 TFS 61127
		if realTI &lt;&gt; null and realTI.getMyCargoGroupId &lt;&gt; _ediTI.cargoGroupId then  												 //14.Nov.2023 navsp1 TFS 61127
			realTI := null;
		endif;	
	endif;
	
	//navra1 - CR 64618/Task 64656 - 10th July 2024 - start
	//for ISCSUM92B ship manifests, we want to be able to update cargo onsite/arriving onsite, if it already exists
	// TFS 65649 This is only for NSW - POB use EDIFileType_IFCSUMAUBNE94B but don't want to update already on site cargo items
	//if voyage.isAutomaticProcess then			//We will do it without any checks as agreed upon in TICKET 65666's comments
		if self.myEDIFile &lt;&gt; null then
			if self.myEDIFile.myEDIFileType &lt;&gt; null then
				if self.myEDIFile.myEDIFileType.type = EDIFileType_IFCSUMAUBNE94B then
					//only if it is a CM_EDICargoOnSiteTI then find some cargo that might be on site to modify,
					//otherwise it might replace(nullify) what you found on the ship
					if not _ediTI.isEDICargoOnShipTI() then																		//navra1 - BUG 65727 - 28th Aug 2024
						if terminal.getConfig(UpdOnSitCargoFromIFCSUM).Boolean then																//navra1 - BUG 65725 - 17th Sep 2024
							realTI := terminal.allOnsiteTIsByIdCargoType[_ediTI.id, _ediTI.cargoType];
							//return if you found something on site, so that it can be updated instead of trying to create a new one
							if realTI &lt;&gt; null then
								return realTI;
							endif;
						endif;																													//navra1 - BUG 65725 - 17th Sep 2024
					endif;																										//navra1 - BUG 65727 - 28th Aug 2024
				endif;	
			endif;
		endif;
	//endif;
	//navra1 - CR 64618/Task 64656 - 10th July 2024 - end
	
	return realTI;
	
epilog
	delete iter;		// TFS 59721
end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getRealCargoItemForModify" id="cf8f6df2-1f6f-4b12-890c-774a75e761af">
        <source>getRealCargoItemForModify(_ediTI: CM_EDICargoTI input): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwmc5	Initial creation	PAR 34197

*/

vars
	voyage		: CM_Voyage;
	terminal	: CM_Terminal;
	cargoType: CM_CargoType;
	ti : CM_TrackedItem;
begin
	
	terminal	:= self.getMyTerminal();
	voyage 		:= terminal.lookupVoyage(_ediTI.getVoyageCode(), null, false);
	
	if voyage = null then
		// Assume invalid voyage will be caught later in validation
		return null;
	endif;
		
	// PAR 32476 Allow for break bulk in different locations on ship
	cargoType := terminal.myRoot.allCargoTypesById[_ediTI.cargoType];
	if cargoType &lt;&gt; null and cargoType.isAllowDuplicates then
		return self.getRealBreakBulkItem(_ediTI, cargoType, voyage.allOnsiteTIsByCargoTypeId);
	endif;
	
	ti := voyage.allOnsiteTIsByCargoTypeId[_ediTI.cargoType, _ediTI.id];
	
	if ti &lt;&gt; null then
		_ediTI.site := TI_SITE_ONSITE;
	endif;
	
	return ti;
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getReceiptTransportMode" id="b06c6525-d40c-48dc-8c2e-053cc26562f4">
        <source>getReceiptTransportMode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars

begin
	return TI_TRANSMODE_SHIP_STR;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusFromEDITrackedItems" id="c699c999-ab6b-467c-99c9-b4ca0c22fb60">
        <source>getStatusFromEDITrackedItems(_verifyOnly : Boolean) : Integer;
//
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
//
vars
	ediTI : CM_EDITrackedItem;
	newStatus, oldStatus, total, skipped, 
	dbLoaded, verified, warnings, errors, 
	todo : Integer;
	isToBePartiallyLoaded : Boolean;
begin
	if not self.canGetStatusFromEDITrackedItem then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for invalid EDI data type");
		return null;
	endif;
	isToBePartiallyLoaded := self.canBePartiallyLoaded();	
	total		:= self.allEDITrackedItems.size;
	newStatus 	:= CM_EDIFile.EDI_STATUS_UNPROCESSED;
	
	if total &gt; 0 then
		// it is a shame we have to go through all the EDI TIs but 
		// generally (MSK) there is only 1 per file
		foreach ediTI in self.allEDITrackedItems discreteLock do
			if ediTI.isKindOf(CM_EDIBOLDtlTI) or
			   ediTI.isKindOf(CM_EDISealTI) or
			   ediTI.isKindOf(CM_EDILayoutTI) or
			   ediTI.isKindOf(CM_EDILayoutPointTI) or
			   ediTI.isKindOf(CM_EDILayoutTI) then
				total := total - 1;
				continue;
			endif;
			oldStatus := ediTI.status;
			
			if oldStatus = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED then
				todo := todo + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
				dbLoaded := dbLoaded + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
				// we are ignoring this one
				total := total - 1;
			
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
				skipped := skipped + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED then
				verified := verified + 1;
				
			elseif oldStatus = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
				warnings := warnings + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS or 
				oldStatus = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS then
			
				errors := errors + 1;				
			endif;
		endforeach;
	
		if todo = total then
			// nothing processed
			if todo &gt; 0 then
				newStatus := CM_EDIFile.EDI_STATUS_LOADED;
			else
				// probably ignored everything
				if _verifyOnly then
					newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
				else
					newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
				endif;
			endif;
		elseif dbLoaded = total then 
			// everything loaded
			if _verifyOnly then
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
			else
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
			endif;
		elseif dbLoaded &gt; 0 then
			// file is partially loaded
			if skipped + dbLoaded = total then
				// all either loaded or skipped
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X;
			else
				// some skipped, some loaded, some yet to be loaded
				if isToBePartiallyLoaded then
					newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
				else
					newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
				endif;
			endif;
		else	
			// nothing loaded
			if _verifyOnly then
				if skipped &gt; 0 then
					if skipped = total then
						// everything has been skipped
						newStatus := CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X;
					elseif skipped + verified = total then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
					elseif skipped + verified + warnings = total then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
					else
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
					endif;
				else
					// still some stuff that has not loaded
					if errors &gt; 0 then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
					elseif warnings &gt; 0 then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
					else
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
					endif;
				endif;
			else	//dbloaded
				if skipped &gt; 0 then
					if skipped = total then
						// everything has been skipped
						newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X;
//					elseif skipped + verified = total then
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
//					elseif skipped + verified + warnings = total then
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
					else
						if isToBePartiallyLoaded then
							newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
						else
							newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
						endif;
					endif;
				else
					// still some stuff that has not loaded
//					if errors &gt; 0 then
						if isToBePartiallyLoaded then
							newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
						else
							newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
						endif;
//					elseif warnings &gt; 0 then
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
//					else
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
//					endif;
				endif;
			endif;
		endif;
	endif;
	
	return newStatus;
epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVesselName" id="ec606a11-3f4e-45b4-8c09-f493c01f62ac">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.vesselName;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
