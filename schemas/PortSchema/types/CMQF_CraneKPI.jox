    <JadeMethod name="cloneReferences" id="ee48ddbf-7428-4c5c-872d-5cce37267312">
        <updating/>
        <source>cloneReferences(_obj: CMQF_CraneKPI; _transient: Boolean) updating;

vars

begin
	inheritMethod(_obj, _transient);
	
	self.allCranes.clear();
	_obj.allCranes.copy(self.allCranes);
end;
</source>
        <Parameter name="_obj" type="CMQF_CraneKPI"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="5d42008b-69b0-40b2-a819-6df684868041">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// Dec 2010	CCMS 1134 KPI reporting by crane (not voyage)
//  get all CM_KPIVoyageCraneShift instances for the given crane and date range

vars
	breakOut,
	invalidCrane : Boolean;
	terminal : CM_Terminal;
	theMachines : CM_MachineSet;
	machine : CM_Machine;
	crane	: CM_Crane;
	craneShift : CM_KPIVoyageCraneShift;
begin
	if self.startDate.isValid() then
		self.startTS.setDate(self.startDate);
		self.startTS.setTime(self.startTime);
	else
		self.startTS.setDate("01/01/0001".Date);
	endif;

	if self.endDate.isValid() then
		self.endTS.setDate(self.endDate);
		self.endTS.setTime(self.endTime);
	else
		self.endTS.setDate("01/01/9999".Date);
	endif;

	if self.startTS &gt; self.endTS then
		return;
	endif;

	create theMachines transient;

	on Exception do app.handleDeletedObject(exception, machine, invalidCrane);

	foreach terminal in self.allTerminals do : terminalLoop
		// getAllMachines clears the collection
		terminal.getAllMachines(theMachines, true); // cranes only
		foreach machine in theMachines do
			crane := machine.CM_Crane;
			if not self.allCranes.includes(crane) then
				continue;
			endif;
			foreach craneShift in crane.allVoyageKPICraneShifts discreteLock do
				if self.checkStatusIncludesObject(craneShift, app.myPassport, breakOut) then
					if breakOut then
						break terminalLoop;
					endif;
					_collection.add(craneShift);
				endif;
			endforeach;
		endforeach;
	endforeach;

epilog
	delete theMachines;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getCranesString" id="f9d11832-c58e-459e-8b62-3da60f3754a0">
        <source>getCranesString(_oid : String output) : String protected;

vars
	crane	: CM_Crane;
	machine	: CM_Machine;
	str		: String;
begin
	foreach machine in self.allCranes do
		crane := machine.CM_Crane;
		_oid := _oid &amp; crane.getOidAsString &amp; ', ';
		if str = null then
			str := crane.code;
		else
			str := str &amp; ', ' &amp; crane.code;
		endif;
	endforeach;
	if str = null then
		str := Any_String;
	endif;

	return str;
			
end;


</source>
        <access>protected</access>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="03b780b5-d8a6-4ffc-b1ad-21a62a829558">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;

vars
	oid     : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="200601e8-76f5-48ac-b571-6d256e7d2fa5">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;

vars

begin

	if _attrName = ETRow_Crane then
		return self.getCranesString(_oid);
	elseif _attrName = ETRow_StartTime then
		return self.startTime.shortFormatJMT();
	elseif _attrName = ETRow_EndTime then
		return self.endTime.shortFormatJMT();
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="8297442c-424b-44ad-872d-212d07c05476">
        <updating/>
        <source>includesObject(_obj: CM_Object; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;

vars
	craneShift : CM_KPIVoyageCraneShift;
begin
	self.numSearched := self.numSearched + 1;
	
	craneShift := _obj.CM_KPIVoyageCraneShift;
	if craneShift.shiftStartTS &gt;= self.startTS and
	  craneShift.shiftStartTS &lt;= self.endTS then
		self.numFound := self.numFound + 1;
		return true;
	endif;
	
	return false;
end;
</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
