    <JadeMethod name="initializeMe" id="c806803a-550f-4f3e-9570-8b761eccc2ca">
        <updating/>
        <source>initializeMe(_id:String; _cargoCount:Integer; _isDoorsBack:Boolean; _isEmpty:Boolean; _isForty:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		02 August 2006 by cnwdad1
//
// Purpose:		Initializes the receiver's settings.
//
// Parameters:	_id - The cargo ID.
//				_cargoCount - The unique "index" of the Cargo item.
//				_isDoorsBack - True if the doors are at the back.
//				_isEmpty - True if the load is empty.
//				_isForty - True if the load is a forty footer.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.cargoId		:=	_id;
	self.cargoCount		:=	_cargoCount;
	self.isDoorsBack	:=	_isDoorsBack;
	self.isEmpty		:=	_isEmpty;
	self.isForty		:=	_isForty;
	self.setCargoImage();
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoCount" type="Integer"/>
        <Parameter name="_isDoorsBack" type="Boolean"/>
        <Parameter name="_isEmpty" type="Boolean"/>
        <Parameter name="_isForty" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCargoImage" id="fb96f50c-ff62-47fd-9ab9-912a33006fd7">
        <updating/>
        <source>setCargoImage() updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 July 2006 by cnwdad1
//
// Purpose:		Sets the receiver's image based upon the configuration of the container.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isEmpty then
		if self.isForty then
			self.picture	:=	self.picEmpty40;
		else
			self.picture	:=	self.picEmpty;
		endif;
	else
		if self.isDoorsBack then
			if self.isForty then
				self.picture	:=	self.picDoorsBack40;
			else
				self.picture	:=	self.picDoorsBack;
			endif;
		else
			if self.isForty then
				self.picture	:=	self.picDoorsFront40;
			else
				self.picture	:=	self.picDoorsFront;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDoors" id="ac7875f4-4ce9-4489-91ff-b12807bc1f18">
        <updating/>
        <source>setDoors(_isDoorsBack:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Sets the receiver's flag to indicate whether the the doors are at
//				the back or the front of the container.  Also sets the the receiver's
//				image accordginly.
//
// Parameters:	_isDoorsBack - True if the doors are at the back.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isDoorsBack	:=	_isDoorsBack;
	self.setCargoImage();
end;</source>
        <Parameter name="_isDoorsBack" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsEmpty" id="853fc3e3-d42b-43e7-ae32-2ec1f59ca2e4">
        <updating/>
        <source>setIsEmpty(_isEmpty:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Sets the flag to indicate whether the receiver is empty.  Also sets
//				the receiver's image accordingly.
//
// Parameters:	_isEmpty - True if the load is empty.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isEmpty	:=	_isEmpty;
	self.setCargoImage();
end;</source>
        <Parameter name="_isEmpty" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsForty" id="08b36d87-38f4-4eb3-8aaa-199bd785abeb">
        <updating/>
        <source>setIsForty(_isForty:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		06 August 2006 by cnwdad1
//
// Purpose:		Sets the flag to indicate whether the receiver is a forty footer.  Also sets
//				the receiver's image accordingly.
//
// Parameters:	_isForty - True if the load is a forty footer.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isForty	:=	_isForty;
	self.setCargoImage();
end;</source>
        <Parameter name="_isForty" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="swapPlaceWith" id="0da0bd4b-8f2e-41e9-bf2b-4dc3b5051249">
        <updating/>
        <source>swapPlaceWith(_containerObj:CMUI_ContainerLoad input) updating;
// --------------------------------------------------------------------------------
// Created:		17 September 2006 by cnwdad1
//
// Purpose:		Switches places with the specified container, by changing the receiver's
//				settings to those of the parameter, and setting the parameter's settings
//				to the receiver's.
//
// Parameters:	_containerObj - A reference to the container to switch places with.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tmpCargoId		: String;
	tmpCargoCount	: Integer;
	tmpIsDoorsBack	: Boolean;
	tmpIsEmpty		: Boolean;
	tmpIsForty		: Boolean;
	
begin
	tmpCargoId			:=	self.cargoId;
	tmpCargoCount		:=	self.cargoCount;
	tmpIsDoorsBack		:=	self.isDoorsBack;
	tmpIsEmpty			:=	self.isEmpty;
	tmpIsForty			:=	self.isForty;
	
	self.initializeMe(_containerObj.cargoId, _containerObj.cargoCount, _containerObj.isDoorsBack, _containerObj.isEmpty, _containerObj.isForty);
	_containerObj.initializeMe(tmpCargoId, tmpCargoCount, tmpIsDoorsBack, tmpIsEmpty, tmpIsForty);
end;</source>
        <Parameter name="_containerObj" type="CMUI_ContainerLoad" usage="input"/>
    </JadeMethod>
