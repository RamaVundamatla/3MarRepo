    <JadeMethod name="setMyCurrentCG" id="bb76fcb7-26ce-44f8-9b63-d339aeb79030">
        <updating/>
        <source>setMyCurrentCG() protected, updating;
/*

Purpose:			Sets the myCurrentCargoGroup reference on the form

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 October 2022	navpw1	Initial creation TFS: 54565 (54384)
06 June 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
*/

vars
	cgId,
	cgCargoTypeId	: String;
	cargoGroup		: CM_CargoGroup;
	cgCargoType		: CM_CargoType;
	
begin
	cgId			:= self.tblCargoGroup.getValueByName(ETRow_CargoGroupId).String;
	cgCargoTypeId	:= self.tblCargoGroup.getValueByName(ETRow_CargoGroupType).String;
	cgCargoType		:= self.cmbCGType.listObject.CM_CargoType;
	
	if cgId = null or cgCargoTypeId = null then
		self.myCurrentCargoGroup := null;
		return;
	endif;
	
	//07/06/2023  navmv20 Bug 58090
	// so, there is tiId &lt;&gt; null and cargoTypeId &lt;&gt; null
	/*if self.myCurrentCargoGroup &lt;&gt; null then
		return;	// nothing changed, just return
	endif;*/
	
	self.myCurrentCargoGroup := null;
	
	cargoGroup := self.getMyCargoGroup(cgId, cgCargoType);
	
	if cargoGroup &lt;&gt; null then
		self.myCurrentCargoGroup := cargoGroup;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyCurrentTI" id="234991a5-2614-430e-bafb-b3ec821603ad">
        <updating/>
        <source>setMyCurrentTI() updating, protected;
/*

Purpose:			Sets the myCurrentTi reference on the form

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	cargoTypeId, subtype, comm,
	tiId			: String;
	ti				: CM_TrackedItem;
	cargoType		: CM_CargoType;
	cargoOperator	: CM_Operator;
	cargoLocation	: CM_LocationsController;
	cargoSubType : CM_Product;
	cargoComm : CM_Commodity;
begin
	tiId			:= self.tblCargo.getValueByName(ETRow_CargoId).String;
	cargoTypeId		:= self.tblCargo.getValueByName(ETRow_CargoType).String;
	cargoType		:= self.cmbCargoTypeInvP.listObject.CM_CargoType;
	
	// ### JIRA 33006 15OCT2024 NAVAB1
	subtype		:= self.tblCargo.getValueByName(ETRow_CargoSubType).String;
	comm		:= self.tblCargo.getValueByName(ETRow_CargoCommodity).String;
	cargoSubType := self.cmbCargoSubType.listObject.CM_Product;
	cargoComm := self.cmbCargoCommodity.listObject.CM_Commodity;
	cargoOperator	:= self.cmbCargoOper.listObject.CM_Operator;
	cargoLocation	:= self.cmbCargoLoc.listObject.CM_LocationsController;
	
	if tiId = null or cargoTypeId = null then
		self.myCurrentTI			:= null;
		self.myCurrentCargoType		:= null;
		// ### JIRA 33006 15OCT2024 NAVAB1
		self.myCurrentCargoSubType		:= null;
		self.myCurrentCargoCommodity		:= null;
		
		self.myCurrentTIOperator	:= null;
		self.myCurrentTILocation	:= null;
		self.tblCargo.setValueByName( ETRow_ReceivedDT, null );
		self.tblCargo.setValueByName( ETRow_ReleaseDT, null );
		return;
	endif;

	// so, there is tiId &lt;&gt; null and cargoTypeId &lt;&gt; null
	if self.myCurrentTI &lt;&gt; null 
	and self.myCurrentCargoType &lt;&gt; null
		// ### JIRA 33006 15OCT2024 NAVAB1
	and self.myCurrentCargoSubType &lt;&gt; null
	and self.myCurrentCargoCommodity &lt;&gt; null
	and self.myCurrentTI.id = tiId 
	and self.myCurrentCargoType.description = cargoTypeId
		// ### JIRA 33006 15OCT2024 NAVAB1
	and self.myCurrentCargoSubType.description = subtype
	and self.myCurrentCargoCommodity.description = comm
	and self.myCurrentTIOperator = cargoOperator
	and self.myCurrentTILocation = cargoLocation
	// ### JIRA 33006 15OCT2024 NAVAB1
//	and self.myCurrentCargoSubType = cargoSubType
//	and self.myCurrentCargoCommodity = cargoComm
	then
		return;	// nothing changed, just return
	endif;
	
	self.myCurrentTI		:= null;
	self.myCurrentCargoType	:= null;
	self.tblCargo.setValueByName(ETRow_ReceivedDT, null);
	self.tblCargo.setValueByName(ETRow_ReleaseDT, null);
	
	// ### JIRA 33006 15OCT2024 NAVAB1
	self.myCurrentCargoSubType := null;
	self.myCurrentCargoCommodity := null;

	ti := self.getMyTrackedItem(tiId, self.cmbCargoTypeInvP.listObject.CM_CargoType,cargoSubType,cargoComm, cargoOperator, cargoLocation);
	if ti &lt;&gt; null then
		self.myCurrentTI			:= ti;
		self.myCurrentCargoType		:= cargoType;
		self.myCurrentTIOperator	:= cargoOperator;
		self.myCurrentTILocation	:= cargoLocation;
	
		// ### JIRA 33006 15OCT2024 NAVAB1
		cargoSubType := ti.myProduct;
		self.myCurrentCargoSubType := cargoSubType;
		self.cmbCargoSubType.listObject := cargoSubType;
		self.tblCargo.setValueByControlName(self.cmbCargoSubType.name,self.cmbCargoSubType.text);
		self.myCurrentCargoSubType := cargoSubType;
		
		
		
		cargoComm := ti.getCommodityObject();
		self.myCurrentCargoCommodity := cargoComm;
		self.cmbCargoCommodity.listObject := cargoComm;
		self.tblCargo.setValueByControlName(self.cmbCargoCommodity.name,self.cmbCargoCommodity.text);

		
		//show dates on the form
		if ti.receivedDT &lt;&gt; null then
			self.tblCargo.setValueByName( ETRow_ReceivedDT, ti.receivedDT.asStringJMT() );
		endif;
		if ti.releasedDT &lt;&gt; null then
			self.tblCargo.setValueByName( ETRow_ReleaseDT, ti.releasedDT.asStringJMT() );
		endif;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
