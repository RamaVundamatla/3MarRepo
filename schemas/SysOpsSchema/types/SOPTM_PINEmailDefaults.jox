    <JadeMethod name="initShtMultiSelect" id="dedbbe25-3fbf-48a2-a520-65f002c9964b">
        <source>initShtMultiSelect();
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm	: SOP_TableMaintForm;
	
begin

	inheritMethod;
	theForm := self.myForm;	
	
	theForm.mulSelect1.setVisibleButtons(false,true,true);
	self.setupMultiSelect1("Email Fields",null,SOP_TableMaintForm::displayEntryEmailFields.name);	
	
	theForm.mulSelect1.multiSelect	:= ListBox.MultiSelect_Extended;
	theForm.mulSelect1.myAvailableListBox.sorted := false;
	theForm.mulSelect1.mySelectedListBox.sorted := false;
	
end;</source>
    </JadeMethod>
