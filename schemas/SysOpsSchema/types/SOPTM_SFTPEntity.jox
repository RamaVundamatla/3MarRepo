    <JadeMethod name="doSave" id="981a76a4-b967-470e-8e38-9a266409f50c">
        <updating/>
        <source>doSave(): Boolean updating;
//
// 19 Sep 2019	cnwrs1	TFS 46087 SFTP
//
vars
	errObj : CM_Error;
	ignoreWarnings : Boolean;
	rtnValue : Boolean;
	proxyFTPEntity : CM_SFTPEntity;
	lId : String;
//	lDestinationDirectory, lId, lPassword, lServerName, lSourceDirectory, lUserId : String;
//	lIsPassive : Boolean;
//	lUseProxy : Boolean;
//	lSingleFileCopy : Boolean;
//	lSaveUndeletedFilesList : Boolean;
//	lMode, lServerGMTBias, lServerType : Integer;
	lPassPhrase : String;
	lPrivateKey : String;
	lPublicKey : String;
	lPort : Integer;
	lTimeOut : Integer;
	theForm	: SOP_TableMaintForm;
	tbl : CM_EntryTable;
	msg : String;
begin
	theForm := self.myForm; 
	tbl := theForm.tblInput1;
//	lFTPEntity := theForm.tblInput1.getValueByName(ETDef_SFtpEntity).String.trimWhiteSpace;
	lId := theForm.tblInput1.getValueByName(ETRow_Id).String;
 	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_SFTPEntity transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyFTPEntity := theForm.myProxyObject.CM_SFTPEntity;
	tbl.setObjectFromTable(proxyFTPEntity, null, false);
/*25 Aug 2021	NDL	TFS 51632 
	//07 Jul 2017	NDL	TFS 5235
	if theForm.enteredPassword.length &gt; 30 then
		msg := app.getErrorString2( ERR_STRING_TO_LONG, app.getErrorString(Password), '30');
		app.msgBox("FTP " &amp; msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif; */
	proxyFTPEntity.setPassword(theForm.enteredPassword);
	proxyFTPEntity.setPassPhrase(theForm.enteredPassword2);	//06 Sep 2021	NDL	TFS 51165
/*	lPort := theForm.tblInput1.getValueByName(ETRow_Port).Integer;
	lTimeOut := theForm.tblInput1.getValueByName(ETRow_TimeOut).Integer;
	lPassPhrase := theForm.tblInput1.getValueByName(ETRow_PassPhrase).String;
	lPrivateKey := theForm.tblInput1.getValueByName(ETRow_PrivateKey).String;
	lPublicKey := theForm.tblInput1.getValueByName(ETRow_PublicKey).String;
	proxyFTPEntity.setProxy(proxyFTPEntity.destinationDirectory, proxyFTPEntity.id, proxyFTPEntity.password, proxyFTPEntity.serverName, proxyFTPEntity.sourceDirectory, proxyFTPEntity.userId, false, false, 0, 0, 0, lPort, lTimeOut, null, null, lPassPhrase, lPrivateKey, lPublicKey);*/
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateSFTPEntity(proxyFTPEntity, theForm.myCurrentObject.CM_FTPEntity, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateSFTPEntity(proxyFTPEntity, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, ' Invalid mode (' &amp; theForm.mode.String &amp; ')');
	endif;
	
	return app.myPassport.trxCompletedOK;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="2fb194ca-f012-4454-b22c-c4458445674a">
        <source>getCollection(): Collection;
//
// 19 Sep 2019	cnwrs1	TFS 46087 SFTP
//
vars
	ftpEntity : CM_FTPEntity;
begin
	foreach ftpEntity in app.myRoot.allFTPEntities do
		if ftpEntity.isSFTP and
		   not self.list.includes(ftpEntity) then
			self.list.add(ftpEntity);
		endif;
	endforeach;
epilog
	return self.list;
end;
</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
