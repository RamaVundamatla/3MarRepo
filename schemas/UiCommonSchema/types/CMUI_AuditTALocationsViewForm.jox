//
// ---------------------------------------------------------------------------
vars

begin
	self.frmSearch.top	:= self.frmToolbar.height;
	self.splMain.top	:= self.frmSearch.top + self.frmSearch.height;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveComments" id="d55b6d41-23bc-45a4-a104-b98089224b1d">
        <updating/>
        <source>doSaveComments() updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result			:Integer;
	coll			:ObjectArray;
	comment			:String;
	obj				:Object;
	gotException	:Boolean;
	table			:CM_DataTable;
	row, col		:Integer;
begin
	coll 	:= self.tblData.allSelectedObjects;
	comment	:= self.txtComment.text.trimBlanks;
	
	while true do
		app.myTrxUA.trxUpdateAuditTALocComments (coll, comment, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.mnuAddComments.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return;
	endwhile;
	
	self.commentsShowHideControls (false);
	
	// now make sure the comments are updated in the tables
	// only need to update comments column - not using notes as don't care
	// about changes other people have made (very unlikely)
	table 	:= self.tblData;
	
	self.doTblDataRowColChange (table);

	col		:= table.getColumnByRowName (ETRow_Comment);
	
	if col = null then
		// not displaying comments
		return;
	endif;
	
	foreach obj in coll do
		if table.findObjectInRow (obj, row) then
			table.setCellText (row, col, comment);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="75597ef7-1f5f-4a2a-a5ec-21a6743ba5c0">
        <source>doSelectAll();
// ---------------------------------------------------------------------------
// Created:     08 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.btnSelectAll.caption = app.getErrorString(SelectAll) then
		self.tblData.selectAll;
	else
		self.tblData.clearAllSelected;
	endif;

	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowSearcherClick" id="a531551f-ba92-4c54-aed7-b0eeae6171c8">
        <updating/>
        <source>doShowSearcherClick() updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if not self.usesQueryFrame then
		return;
	endif;
	
	inheritMethod();

	if self.frmQuery.visible then
		self.fldQuery.topSheet := self.shtQuery1;
		
		self.cmbTerminalArea.setFocus;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="7b05c0bb-a920-4f33-9bb5-269dcfcca302">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xLeft, yTop	:Real;
begin
	self.mnuAddComments.visible 		:= true;
	self.mnuSep1.visible				:= true;
	self.mnuColumnOrganiser2.visible	:= true;

	self.mnuAddComments.enabled	:= self.tblData.allSelectedObjects.size &gt; 0;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnComment.enabled:= false;
		self.mnuAddComments.enabled:= false;
	endif;
	
	// now actually  show the popup menu
	xLeft	:= x;
	yTop 	:= y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.mnuTablePopup, xLeft.Integer, yTop.Integer);
	
	return false;

epilog

end;</source>
