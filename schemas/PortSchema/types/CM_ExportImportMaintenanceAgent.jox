    <JadeMethod name="configureClassProperties" id="af3c222c-2937-4029-9050-a0117436c91d">
        <updating/>
        <source>configureClassProperties(_exportClass: CM_ExportImportClass io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars

begin
	if _exportClass.className = CM_Commodity.name then
        self.configureCommodity(_exportClass);
    elseif _exportClass.className = CM_CargoType.name then
        self.configureCargoType(_exportClass);
    elseif _exportClass.className = CM_CommodityGroup.name then
        self.configureCommodityGroup(_exportClass);
	elseif _exportClass.className = CM_Carrier.name then
        self.configureCarrier(_exportClass);
	elseif _exportClass.className = CM_Debtor.name then
        self.configureDebtor(_exportClass);
	elseif _exportClass.className = CM_EventType.name then
        self.configureEventType(_exportClass);
	elseif _exportClass.className = CM_TerminalAreaView.name then
		self.configureTerminalAreaView(_exportClass);
	elseif _exportClass.className = CM_TerminalAreaViewPosition.name then
        self.configureTerminalAreaViewPosition(_exportClass);
	elseif _exportClass.className = CM_Terminal.name then
		self.configureTerminal(_exportClass);
	elseif _exportClass.className = CM_TerminalArea.name then
		self.configureTerminalArea(_exportClass);
	elseif _exportClass.className = CM_TerminalAreaMaster.name then
		self.configureTerminalAreaMaster(_exportClass);
	elseif _exportClass.className = CM_BlockStack.name then
		self.configureBlockStack(_exportClass);
	elseif _exportClass.className = CM_ForkLiftStack.name then
		self.configureForkLiftStack(_exportClass);
	elseif _exportClass.className = CM_TerminalAreaType.name then
		self.configureTerminalAreaType(_exportClass);
	elseif _exportClass.className = CM_InterchangeArea.name then
		self.configureYardInterchangeArea(_exportClass);
	elseif _exportClass.className = CM_YardInterchangeArea.name then
		self.configureYardInterchangeArea(_exportClass);
	elseif _exportClass.className = CM_Machine.name then
		self.configureMachine(_exportClass);
	elseif _exportClass.className = CM_Product.name then
		self.configureProduct(_exportClass);
	elseif _exportClass.className = CM_GridRow.name then
		self.configureGridRow(_exportClass);
	elseif _exportClass.className = CM_GridColumn.name then
		self.configureGridColumn(_exportClass);
	elseif _exportClass.className = CM_TerminalAreaProductMinMax.name then
		self.configureTerminalAreaProductMinMax(_exportClass);
	elseif _exportClass.className = CM_DataAccessController.name then
		self.configureDataAccessController(_exportClass);
	elseif _exportClass.className = CM_GriddedTAStackHeight.name then
		self.configureGriddedTAStackHeights(_exportClass);
	elseif _exportClass.className = CM_YACriteria.name then
		self.configureYACriteria(_exportClass);
	elseif _exportClass.className = CM_YACriteriaPriority.name then
		self.configureYACriteriaPriority(_exportClass);
	elseif _exportClass.className = CM_YACriteriaType.name then
		self.configureYACriteriaType(_exportClass);
	elseif _exportClass.className = CM_YADataObjects.name then
		self.configureYADataObjects(_exportClass);
	endif;
epilog

end;</source>
        <Parameter name="_exportClass" type="CM_ExportImportClass" usage="io"/>
    </JadeMethod>
    <JadeMethod name="configureCommodity" id="d5a02e17-0bbf-48a6-8e63-70dbd9516ed1">
        <updating/>
        <source>configureCommodity(_exportClass: CM_ExportImportClass io) updating;
/*

Purpose:			
	* Configures CM_Commodity for export/import
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36793 - Use Case - System Admin - Commodities Export/Import

*/

vars
    builder: CM_ExportPropertyConfigBuilder;
begin
    create builder transient;
    
    builder.forClass(_exportClass)
        .property(CM_Commodity::code, "Commodity Code").asKey()
        .property(CM_Commodity::description, "Description")
        .property(CM_Commodity::requiresPower, "Requires Power")
        .property(CM_Commodity::hasTemp, "Has Temperature")
        .property(CM_Commodity::maxTemp, "Max Temperature")
        .property(CM_Commodity::minTemp, "Min Temperature")
        .property(CM_Commodity::myCommodityGroup, "Commodity Group")
        .property(CM_Commodity::allCargoTypes, "Cargo Types")
        .commit();
    
epilog
    delete builder;
end;</source>
        <Parameter name="_exportClass" type="CM_ExportImportClass" usage="io"/>
    </JadeMethod>
