    <JadeMethod name="hasOversizedBackendsByMode" id="4f76f5a7-9b41-4247-b86f-d98dd3eeb68b">
        <source>hasOversizedBackendsByMode(_mode : Integer; _stackPos : Integer; _tmpTIs : CM_TIArray input; _includeOnlyMode : Boolean) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		15 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	tmp : CM_TrackedItem;
	prevGC, prevPrevGC : CM_GridController;
	aFM : CM_FutureMove;
	fmSize, tiSize : Integer;
	fmTI : CM_TrackedItem;
	fms : CM_FutureMoveArray;
begin
	_tmpTIs.clear;

	// #### Get what we are actually looking at on screen
//	PAR 18682 if self.isOKForOverSizedCargo() then
		if _mode = DISPLAY_MODE_ACTUAL then
			self.getOversizedBackendsByModePrev(REAL_MODE, _tmpTIs,true);
			if not _includeOnlyMode then // PAR 19080
				self.getOversizedBackendsByModePrev(QUEUE_MODE, _tmpTIs,true);
				self.getOversizedBackendsByModePrev(PLANNING_MODE, _tmpTIs,true);
			endif;
		elseif _mode = DISPLAY_MODE_QUEUE then
			self.getOversizedBackendsByModePrev(QUEUE_MODE, _tmpTIs,true);
			if not _includeOnlyMode then// PAR 19080
				self.getOversizedBackendsByModePrev(REAL_MODE, _tmpTIs,true);
				self.getOversizedBackendsByModePrev(PLANNING_MODE, _tmpTIs,true);
			endif;
		elseif _mode = DISPLAY_MODE_PLAN then
			self.getOversizedBackendsByModePrev(PLANNING_MODE, _tmpTIs,true);
			if not _includeOnlyMode then// PAR 19080
				self.getOversizedBackendsByModePrev(REAL_MODE, _tmpTIs,true);
				self.getOversizedBackendsByModePrev(QUEUE_MODE, _tmpTIs,true);
			endif;
		endif;
/* PAR 18682	else
		if _mode = DISPLAY_MODE_ACTUAL then
			self.getFortyBackendsByMode(REAL_MODE, _tmpTIs);
			self.getFortyBackendsByMode(QUEUE_MODE, _tmpTIs);
			self.getFortyBackendsByMode(PLANNING_MODE, _tmpTIs);
		elseif _mode = DISPLAY_MODE_QUEUE then
			self.getFortyBackendsByMode(QUEUE_MODE, _tmpTIs);
			self.getFortyBackendsByMode(REAL_MODE, _tmpTIs);
			self.getFortyBackendsByMode(PLANNING_MODE, _tmpTIs);
		elseif _mode = DISPLAY_MODE_PLAN then
			self.getFortyBackendsByMode(PLANNING_MODE, _tmpTIs);
			self.getFortyBackendsByMode(REAL_MODE, _tmpTIs);
			self.getFortyBackendsByMode(QUEUE_MODE, _tmpTIs);
		endif;
		
	endif;
	*/

	if _tmpTIs.size &gt; 0 and _stackPos &lt;= _tmpTIs.size then
		return _tmpTIs[_stackPos];
	endif;
	
	return null;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_stackPos" type="Integer"/>
        <Parameter name="_tmpTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_includeOnlyMode" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="hasOversizedBackendsByModeOLD" id="65796bca-80e3-453d-92d6-114859135d2f">
        <source>hasOversizedBackendsByModeOLD(_mode : Integer; _stackPos : Integer; _tmpTIs : CM_TIArray input) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		15 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmp : CM_TrackedItem;
	prevGC, prevPrevGC : CM_GridController;
	aFM : CM_FutureMove;
	fmSize, tiSize : Integer;
	fmTI : CM_TrackedItem;
	fms : CM_FutureMoveArray;
begin

	// #### Get what we are actually looking at on screen
	if _mode = REAL_MODE then
		//tmp := inheritMethod(_mode,_stackPos,_tmpTIs);
		if tmp &lt;&gt; null then
			return tmp;
		endif;
	elseif (_mode = QUEUE_MODE or _mode = PLANNING_MODE) then
		prevGC := self.getPreviousControllerOfType(CM_GridController);
		if prevGC &lt;&gt; null then
			if _mode = QUEUE_MODE then
				fms := prevGC.allQueuedFutureMoves;
			else
				fms := prevGC.allPlannedFutureMoves;
			endif;
			foreach aFM in fms  discreteLock do
				fmTI := aFM.getTrackedItem();
				if fmTI &lt;&gt; null and fmTI.isOverSizedContainer() then
					_tmpTIs.add(fmTI);
				endif;
			endforeach;
			
			if _tmpTIs.size &gt; 0 and _stackPos &lt;= _tmpTIs.size then
				return _tmpTIs[_stackPos];
			endif;
			
		endif;
	endif;
	
	
	// ### If still null then check in the other modes to see is we are drawing something for a different mode.
	
	if _mode = REAL_MODE then
		prevGC := self.getPreviousControllerOfType(CM_GridController);
		if prevGC &lt;&gt; null then
	
			fmSize := prevGC.allQueuedFutureMoves.size;
			tiSize := self.allTrackedItemOSBackEnds.size;
		
			if _stackPos &gt; (fmSize + tiSize) then
				// still null
				if self.is53ft and self.offset53 = self.Offset53_6 then
					tiSize := prevGC.allTrackedItemOSBackEnds.size;
					prevPrevGC := prevGC.getPreviousControllerOfType(CM_GridController);
					fmSize := 0;
					if prevPrevGC &lt;&gt; null then
						fmSize := prevPrevGC.allQueuedFutureMoves.size;
					endif;
					if _stackPos &lt;= tiSize then
						tmp :=  prevGC.allTrackedItemOSBackEnds[_stackPos];
						if tmp &lt;&gt; null then
							return tmp;
						endif;
					endif;
					// still null check for overhanging backends of Qd 53s
					if tmp = null then
						if ((_stackPos - tiSize) &gt; 0) and (_stackPos - tiSize) &lt;= fmSize then
							aFM := prevPrevGC.allQueuedFutureMoves[_stackPos - tiSize];
							tmp := aFM.getTrackedItem();
							if tmp &lt;&gt; null then
								return tmp;
							endif;
						endif;
					endif;
				endif;
				return null;
			endif;
			if fmSize &gt; 0 and ( _stackPos &lt;= (fmSize + tiSize)) then
				aFM := prevGC.allQueuedFutureMoves[_stackPos - tiSize];
				tmp := aFM.getTrackedItem();
				if tmp &lt;&gt; null and tmp.isOverSizedContainer() then
					return tmp;
				endif;
			endif;
				
		endif;
	elseif _mode = QUEUE_MODE then
		prevGC := self.getPreviousControllerOfType(CM_GridController);
		if prevGC &lt;&gt; null then
	
			fmSize := prevGC.allQueuedFutureMoves.size;
			tiSize := self.allTrackedItemOSBackEnds.size;
		
			if _stackPos &lt;= self.allTrackedItemOSBackEnds.size then
				tmp := self.allTrackedItemOSBackEnds[_stackPos];
				if tmp &lt;&gt; null then
					return tmp;
				endif;
			endif;
		endif;
	endif;
	
	return null;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_stackPos" type="Integer"/>
        <Parameter name="_tmpTIs" type="CM_TIArray" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="hasOversizedFrontEndsByMode" id="596c1eda-b9e0-4a78-9a0c-aa2023f722e7">
        <source>hasOversizedFrontEndsByMode(_mode : Integer; _stackPos : Integer; _tmpTIs : CM_TIArray input) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		15 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	prevGC : CM_GridController;
	qFM : CM_FutureMoveQueued;
	fmSize, tiSize : Integer;
begin

	_tmpTIs.clear;
	if _mode = DISPLAY_MODE_ACTUAL then
		tmpTI := self.allTrackedItems.first();
		if tmpTI &lt;&gt; null then
			self.allTrackedItems.copy(_tmpTIs);
		endif;
		self.getOversizedFrontendsByMode(QUEUE_MODE,_tmpTIs);
		self.getOversizedFrontendsByMode(PLANNING_MODE,_tmpTIs);
	elseif _mode = DISPLAY_MODE_QUEUE then
		self.getOversizedFrontendsByMode(QUEUE_MODE,_tmpTIs);
		tmpTI := self.allTrackedItems.first();
		if tmpTI &lt;&gt; null then
			self.allTrackedItems.copy(_tmpTIs);
		endif;
		self.getOversizedFrontendsByMode(PLANNING_MODE,_tmpTIs);
	elseif _mode = DISPLAY_MODE_PLAN then
		self.getOversizedFrontendsByMode(PLANNING_MODE,_tmpTIs);
		tmpTI := self.allTrackedItems.first();
		if tmpTI &lt;&gt; null then
			self.allTrackedItems.copy(_tmpTIs);
		endif;
		self.getOversizedFrontendsByMode(QUEUE_MODE,_tmpTIs);
	endif;
	
	
	
	if _tmpTIs.size &gt; 0 and _stackPos &lt;= _tmpTIs.size then
		tmpTI :=  _tmpTIs[_stackPos];
		
		if tmpTI &lt;&gt; null then
			return self.allTrackedItems[1];
		endif;
	endif;

	return null;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_stackPos" type="Integer"/>
        <Parameter name="_tmpTIs" type="CM_TIArray" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="hasOversizedFrontEndsByModeOLD" id="01484486-61b1-4b1b-99d6-97550f02b974">
        <source>hasOversizedFrontEndsByModeOLD(_mode : Integer; _stackPos : Integer) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		15 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmp : CM_TrackedItem;
	prevGC : CM_GridController;
	qFM : CM_FutureMoveQueued;
	fmSize, tiSize : Integer;
begin
//	tmp := inheritMethod(_mode,_stackPos);
	
	if tmp &lt;&gt; null then
		return tmp;
	endif;
	fmSize := self.allQueuedFutureMoves.size;
	tiSize := self.allTrackedItems.size;
	
	
	if _stackPos &gt;  (fmSize + tiSize) then
		return null;
	endif;
	if _stackPos &lt;= (fmSize + tiSize) then
		qFM := self.allQueuedFutureMoves[_stackPos - tiSize].CM_FutureMoveQueued;
		tmp := qFM.myTrackedItem;
		if tmp &lt;&gt; null and (tmp.isAttributeTrue(TI_Attrib_IsForty) or tmp.isOverSizedContainer()) then 
			return tmp;
		endif;
	endif;

	return null;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_stackPos" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
