    <JadeMethod name="addToolbarControls" id="0687f9ea-753a-4a67-9fdd-b40461dc5fd3">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cmui_Toolbar		: CMUI_Toolbar;
	
begin
	cmui_Toolbar			:= self.frmToolbar;
	cmui_Toolbar.addButton( self.btnPrintTV, CMUI_Toolbar.Control_Alignment_Left );
	cmui_Toolbar.addButton( self.btnExtract, CMUI_Toolbar.Control_Alignment_Left );
	cmui_Toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
	
	cmui_Toolbar.addButton( self.btnShowDefn, CMUI_Toolbar.Control_Alignment_Left );
	cmui_Toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
	
	cmui_Toolbar.addButton( self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right );
	
	cmui_Toolbar.positionToolbarControls();
	cmui_Toolbar.visible	:= true;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
