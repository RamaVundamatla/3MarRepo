    <JadeMethod name="setControlVisible" id="74c89f7d-d88f-438a-8efc-64888d4a66e6">
        <updating/>
        <source>setControlVisible(_control :Control input; _visible :Boolean)updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myAgent.setControlVisible(_control, _visible);
	
	if not _visible then
		// have to assume it is the selected control
		self.mySelectedControl := null;
		self.clearGraphics;
	endif;
epilog

end;</source>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_visible" type="Boolean"/>
