    <JadeMethod name="btnEditCTA_click" id="bba211fb-a4dc-4450-81db-a2ba8f247f23">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEditCTA_click(btn: Button input) updating;
/*

Date		Who		Reason
08 November 2013	cnwer1	Initial creation PAR 32902

*/

vars
	cta 		: CM_CraneTransferArea;
begin	
	
	if self.myCurrentObject = null then
		return;
	endif;
	
	if not self.myCurrentObject.isKindOf(CM_VoyageCraneQueue) then
		return;
	endif;
	
	cta:= self.myCurrentObject.CM_VoyageCraneQueue.crane.transferArea;
	if cta = null then
		return;
	endif;
	self.myAssistant.showTerminalAreaDef(cta, self.myMasterMenuAction);

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
