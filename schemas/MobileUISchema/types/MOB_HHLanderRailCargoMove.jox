    <JadeMethod name="doComplete" id="10a89f54-ce85-4de9-a8ff-34e8684c36bd">
        <updating/>
        <source>doComplete():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278
*/

vars

	errMess : String;
	tmpFoundLC : CM_LocationsController;
	error : CM_Error;
	job : CM_Job;
	wle : CM_WorkListEntry;
	otherDDWle : CM_WorkListEntry;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	mustSelectWle : Boolean;
	checksSubCargo : CM_TrackedItem;
	moveController : CMIF_MoveController;
	result :Integer;
	
begin

	if self.myTrackedItem = null then
		errMess := app.getErrorString(No_Cargo_identified);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	if not self.findLocationToMoveTo( tmpFoundLC ) then
		return false;
	endif;

	if self.myTrackedItem.myPrimaryActualLocation = tmpFoundLC then
		errMess := app.getErrorString2(Cargo_already_located, self.myTrackedItem.id, self.txtLocation.text);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	if self.myTrackedItem.isBulkByQuantity and self.myTrackedItem.canSplitTotalQuantity then
		if self.txtQuantity.visible and self.txtQuantity.text.trimBlanks = null then	//27 May 2013	NDL	CCMS 2274
			errMess := app.getErrorString1(Quantity_Invalid, self.myTrackedItem.totalQuantity.String);
			self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
			return false;
		endif;
		quantity := self.txtQuantity.text.Integer;
		//02 Feb 2016	NDL	Par 37492
		if quantity &lt; self.myTrackedItem.totalQuantity then
			weight := self.myTrackedItem.totalWeight * ( quantity / self.myTrackedItem.totalQuantity );
		endif;
		
	elseif self.myTrackedItem.isBulkByWeight then
		weight := self.tblWeightVolume.getConvertedValue();
		if weight = 0 or weight &gt; self.myTrackedItem.totalWeight then
			errMess := app.getErrorString(Invalid_weight_entered);
			self.msgBox( errMess , app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
		endif;
		
	elseif self.myTrackedItem.isBulkByVolume then
		volume := self.tblWeightVolume.getConvertedValue();
		weight := volume * self.myTrackedItem.getDensity;
		if volume = 0 or volume &gt; self.myTrackedItem.totalVolume then
			errMess := app.getErrorString(Invalid_volume_entered);
			self.msgBox( errMess , app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
		endif;
		
	endif;
	
	// we have a location, should be good to go.
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
		
		if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_RAIL_REC, self.myTrackedItem, checksSubCargo) &lt;&gt; null then 
			self.btnTwo.click(self.btnTwo);			
			return false;
		endif;
		
		if tmpFoundLC.isVehicle and not self.myTrackedItem.directDelivery then	
			errMess := app.getErrorString1(Truck_Land_Not_Allowed, tmpFoundLC.getFullId );
			self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
				
		elseif tmpFoundLC.isVoyageController and not self.myTrackedItem.directDelivery then	
			errMess := app.getErrorString1(Not_land_directl_voyage, tmpFoundLC.getFullId );
			self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
				
		else
			// no machine involved, straight instant move.
			//wle := self.myTrackedItem.getWLEForRoadRailMove;
			self.getRailJobWLE( job, wle, false );
			
			if self.myTrackedItem.directDelivery then
				if not doCheckDirectDelsLoadedToOps( wle, otherDDWle ) then
					return false;
				endif;
				if wle.getTargetLocation = null and otherDDWle.getTargetLocation = tmpFoundLC then
					wle := otherDDWle;
				endif;
			endif;
			
			if not self.myMobileGenericAgent.moveTI( self.myTrackedItem, null, tmpFoundLC, wle, false, quantity, weight, null ) then
				return false;
			endif;
		
		endif;
		
		
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
	
		if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_RAIL_REL, self.myTrackedItem, checksSubCargo)  &lt;&gt; null then //28 May 2010	NDL	Par 23698
			self.btnTwo.click(self.btnTwo);			
			return false;
		endif;
							
		//wle := self.myTrackedItem.getWLEForRoadRailMove;
		mustSelectWle := self.tblWles.visible;
		//if not self.getRailJobWLE( job, wle, mustSelectWle ) then
		if not self.getRailJobWLE( job, wle, mustSelectWle ) and mustSelectWle then	//07 Mar 2014	NDL	Par 33656
			return false;
		endif;
		
		if self.myTrackedItem.directDelivery then
			if not doCheckDirectDelsLoadedToOps( wle, otherDDWle ) then
				return false;
			endif;
			if wle.getTargetLocation = null and otherDDWle.getTargetLocation = tmpFoundLC then
				wle := otherDDWle;
			endif;
		endif;
		
		//02 Feb 2016	NDL	Par 37492
		if wle &lt;&gt; null and wle.myTrackedItem = null then
			// This is a RAIL director task
			create moveController transient;
			moveController.setMyWorkListEntry(wle);
			moveController.setMyToPrimaryLocation(tmpFoundLC); 
			moveController.setMyTrackedItem(self.myTrackedItem);
			if quantity &lt;&gt; 0 then
				moveController.setQuantity(quantity);
			endif;
			if weight &lt;&gt; 0 then
				moveController.setWeight(weight);
			endif;
			
			while true do
				app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
				if not app.myPassport.trxCompletedOK then
					result := app.showErrorWarningDialog(app.getErrorString( Assign_release ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   result = IDOK then
						// there must have just been warnings that the user has acknowledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				break;
			endwhile;
			
			return result = IDOK;
			
		endif;
		
		if not self.myMobileGenericAgent.moveTI( self.myTrackedItem, null, tmpFoundLC, wle, false, quantity, weight, null ) then
			return false;
		endif;
		
	endif;
	
	self.myMobileGenericAgent.setSplitValues( 0, 0, null );
	return true;
	
epilog

	delete moveController;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="e643b479-bc83-41e9-83be-25fec97c9ec5">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation

*/

vars

	state : Integer;
	top : Real;
	stdWidth : Real;
	width : Real;
	halfWidth : Real;
	
	btnWidth : Real;
	btnLeft : Real;
	stdHeight : Real;
	tabIndex : Integer;
	tblHeight : Real;
	
	wagon : CM_Wagon;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	tabIndex := 4000;
	state := self.myMobileGenericAgent.checksState;
	
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	halfWidth := ( self.clientWidth/2 ) - self.resizedMargin - self.resizedMargin;
	
	top := self.resizedMargin;
	width := stdWidth - self.getSearchButtonSpace();
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( self.resizedMargin,
						 top,
						 width,
						 stdHeight );
						 
	width := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move( self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
						 top,
						 width,
						 stdHeight );

	
	top := top + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
		self.lblCargoType.visible := true;
	endif;
	self.lblCargoType.move( self.resizedMargin,
							 top,
							 halfWidth,
							 stdHeight ); 
	if _initialSetup then						 
		self.lblState.setAndIncrementTabIndex( tabIndex );
		self.lblState.visible := true;
	endif;
	self.lblState.move( self.resizedMargin + halfWidth + self.resizedMargin,
						 top,
						 halfWidth,
						 stdHeight );
						 
	//02 Aug 2013	NDL	Par 32156
	top := top + self.lblState.height;
	if _initialSetup then
		self.lblCargoDesc.visible := true;
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoDesc.move( self.resizedMargin,
							 top,
							 stdWidth,
							 stdHeight );
						 
	top := top + self.lblCargoDesc.height + self.resizedMargin;	
	if _initialSetup then
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );
	
	
	top := self.txtLocation.top + self.txtLocation.height + self.resizedMargin;
	if _initialSetup then
		self.lblQuantity.setAndIncrementTabIndex( tabIndex );
		self.lblQuantity.visible := false;
	endif;
	self.lblQuantity.move(	self.resizedMargin,
							top,
							halfWidth,
							stdHeight );
	
	if _initialSetup then
		self.txtQuantity.setAndIncrementTabIndex( tabIndex );
		self.txtQuantity.visible := false;
	endif;
	self.txtQuantity.move(	self.resizedMargin + halfWidth + self.resizedMargin,
							top,
							halfWidth,
							stdHeight );
	
	if _initialSetup then
		self.tblWeightVolume.setAndIncrementTabIndex( tabIndex );
		self.tblWeightVolume.visible := false;
	endif;
	self.tblWeightVolume.move(	self.resizedMargin + halfWidth + self.resizedMargin,
								top,
								halfWidth,
								stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
								);
								
	inheritMethod(_initialSetup);
							
	top := btnOne.top - ( btnOne.height * 2 ) - self.resizedMargin;
	btnLeft := btnThree.left;
	btnWidth := btnThree.width;
	if _initialSetup then
		self.btnAddCargo.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnAddCargo.move( 	btnLeft,
							top,
							btnWidth,
							stdHeight );
							
	top := self.txtQuantity.top + self.txtQuantity.height + self.resizedMargin;
	if self.btnAddCargo.visible then
		tblHeight := btnAddCargo.top - ( self.resizedMargin + top );
	else
		tblHeight := btnOne.top - ( self.resizedMargin + top );
	endif;
	
	self.tblWles.move(	self.resizedMargin,
						top,
						self.clientWidth - self.resizedMargin - self.resizedMargin,
						tblHeight );
						
	wagon :=  self.myMobileGenericAgent.myCurrentWagon;
	if state = self.myMobileGenericAgent.RailReceipt then
		self.btnThree.enabled := false;
		if wagon &lt;&gt; null and wagon.isSealed then
			self.btnThree.enabled := true;
		else
			self.btnThree.enabled := false;
		endif;
							 
	elseif state = self.myMobileGenericAgent.RailRelease then	
		if wagon &lt;&gt; null and wagon.hasSelectableSealTypes then
			self.btnThree.enabled := true;
		else
			self.btnThree.enabled := false;
		endif;
		
	endif;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="62e6c567-7671-4b1a-8774-c66749c0d2f1">
        <source>findLocationToMoveTo( tmpFoundLC : CM_LocationsController output ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	dataString : String;
	term : CM_Terminal;
	tmpFoundHeight : Integer;
	errMess : String;
	voyage : CM_Voyage;
	strs : StringArray;
	
begin

	
	if self.txtLocation.userObject &lt;&gt; null then
		tmpFoundLC := self.txtLocation.userObject.CM_LocationsController;
		return true;
	endif;

	// Find the location we are moving to.
	dataString := self.txtLocation.text.trimBlanks.toUpper;
	
	if dataString = null or dataString = lblLocation.caption.toUpper then
		errMess := app.getErrorString( No_Location_entered );
	else
	
		term := self.myMobileDataAgent.myTerminal;
		self.myTerminal.findLocationFromString(dataString, true, tmpFoundLC, tmpFoundHeight);
			
		if tmpFoundLC = null and self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
			voyage := self.myTrackedItem.myVoyage;
			create strs transient; 
			strs.add( dataString );
			if  voyage &lt;&gt; null then
				voyage.findLocation(strs, true, tmpFoundLC, tmpFoundHeight);
			endif;
			
		endif;
		
		if tmpFoundLC = null then
			errMess := errMess &amp; app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");
			
		else
			if self.myTrackedItem.directDelivery then
				// must be Road Rail or Ship
				if not tmpFoundLC.isVehicle and ( tmpFoundLC.isYardLocation or tmpFoundLC.isMachineController ) then
					errMess := app.getErrorString(Invalid_direct_delivery_loc);
				endif;
				
			elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
				if not tmpFoundLC.isYardLocation and not tmpFoundLC.isMachineController then
					errMess := app.getErrorString(Location_machine_yard);
				endif;
	
			elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
			//	if not tmpFoundLC.isKindOf(CM_WagonController) then
				if not tmpFoundLC.isWagon then	//27 May 2013	NDL	Part of Boxcar conversion
					errMess := app.getErrorString(Location_must_rail);
				//12 Sep 2013	NDL	Par 32452
				elseif tmpFoundLC.CM_WagonController.myWagon.myTrainOutwards &lt;&gt; self.myMobileGenericAgent.myCurrentWagon.myTrainOutwards then
					errMess := app.getErrorString(Load_locat_must_contr_selec_wa);
				endif;
		
			endif;
			
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		txtLocation.setFocus();
		return false;
	endif; 
	
	return true;
	
epilog

	delete strs;

end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getRailJobWLE" id="ad992bbf-fa5d-48a8-84d5-7b0ae252f510">
        <updating/>
        <source>getRailJobWLE( _job : CM_Job output; _wle : CM_WorkListEntry output; _forceSelection : Boolean ) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	row : Integer;
	msg : String;
	tmpWle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
	tmpFoundLC : CM_LocationsController;
	wc : CM_WagonController;
	resDetail : CM_ReserveDetail;
	reason :String;
	
begin

	ti := self.myTrackedItem;
	if ti = null then
		return false;
	endif;

	if ti.canMergeBreakBulk and  self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
	
		//Break bulk 'Releases' can have multiple WLEs and Jobs for a single 'cargo item'
		// A list of the available one has been displayed.
		// Need to make sure a wle is chosen.
		
		if self.tblWles.visible then
			// There are 2 or more contenders when the table is visible.
			
			if self.myWorkListEntry &lt;&gt; null and ti.allWorklistEntries.includes( self.myWorkListEntry ) then
				_wle := self.myWorkListEntry;
				
			else
				foreach row in 1 to self.tblWles.rows do
					if self.tblWles.accessRow( row ).selected then
						_wle := self.tblWles.accessRow( row ).itemObject.CM_WorkListEntry;
						if _wle &lt;&gt; null then
							if self.myWorkListEntry &lt;&gt; _wle then
								self.setMyTrackedItem( ti, _wle );
							endif;
							break;
						endif;
					endif;
				endforeach;
				
				if _forceSelection and _wle = null then
					msg := "Must select the associated move to be actioned";
					self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, false );
				endif;
			
			endif;
			
		else
			// Maximum of one available, we can choose it for them.
			if _wle = null then
				foreach tmpWle in ti.allWorklistEntries do
					if tmpWle.status = WLE_COMPLETED then
						continue;
					endif;
					if not tmpWle.isRail then
						continue;
					endif;
					if tmpWle.isReceipt then
						continue;
					endif;
					_wle := tmpWle;
					break;
				endforeach;
			endif;
		
		endif;
	
	
	else

		if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
			_job := ti.jobRailReceive;
		elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
			_job := ti.jobRailRelease;
		endif;
	
		
		if _job = null then
			return false;					
		endif;
		
		_wle := _job.getWLEForTI(self.myTrackedItem); // PAR 34417
	
	endif;
	
	//02 Feb 2016	NDL	Par 37492
	if _wle = null and self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
		//look for outward director tasks for our target wagon....
		tmpFoundLC := self.txtLocation.userObject.CM_LocationsController;
		if tmpFoundLC &lt;&gt; null then
			if tmpFoundLC.isKindOf(CM_WagonController) then
				wc := tmpFoundLC.CM_WagonController;
				foreach tmpWle in wc.allRailWLELoad do
					if tmpWle.status = WLE_COMPLETED then
						continue;
					endif;
					if not tmpWle.isRail then
						continue;
					endif;
					if tmpWle.isReceipt then
						continue;
					endif;
					if tmpWle.myRequest = null or not tmpWle.myRequest.isKindOf(CM_DeliveryRequest) then
						continue;
					endif;
					resDetail := tmpWle.myRequest.CM_DeliveryRequest.myReserveDetail;
					if resDetail = null or not resDetail.isKindOf(CM_ReserveSelection) then
						continue;
					endif;
					if not self.myTrackedItem.testAgainstReserveSelection( resDetail.CM_ReserveSelection, reason, true, null ) then
						continue;
					endif;
					_wle := tmpWle;
					_job := _wle.job;
					break;
				endforeach;
			endif;
		endif;
	endif;

	return (_wle &lt;&gt; null);
	
end;</source>
        <Parameter name="_job" type="CM_Job" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_forceSelection" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
