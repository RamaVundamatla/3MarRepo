<Class name="UT_HarbourAdmin" id="4b0a7604-3819-4103-a679-4bc7d50d5c4c">
    <superclass name="UT_SystemAdmin"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="tUpdateWharf" id="44da4003-9885-4950-93d8-8e66890a5ae9">
        <source>tUpdateWharf();
/*

Purpose:			

Date		Who		Reason
13 October 2015	cnwmk3	Initial creation

*/

vars
     term                   : CM_Terminal;
	 origHarbour            : HMS_Harbour;
	 wharf			        : HMS_Wharf;
     proxyWharf             : HMS_Wharf;
	 
	 desc                   : String;
begin
     term := self.getTerminal();
	 origHarbour := term.myHarbour;
     wharf := self.addWharf("UTWHARF01","Test Wharf", origHarbour, 100, 10);
	 self.assertNotNull(wharf);
	 
	 beginLoad;
	 proxyWharf := wharf.pxyCreateUpdateProxy();
	 delete proxyWharf.myHookCode;
	 endLoad;
	 
	 desc := "Wharf Updated";
	 proxyWharf.setPropertyValue("description", desc);
	 app.myTrxUA.trxUpdateWharf(proxyWharf, app.myPassport);
	 self.assertNoTrxErrorsOrWarnings();
	 self.assertEqual(wharf.description, desc);	
	 
epilog
	
     delete proxyWharf;
	 
end;</source>
    </JadeMethod>
</Class>
