<Class name="HMS_ConfirmActualMove" id="c8622789-1d28-4ea7-8180-444b5e763ff5">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <JadeMethod name="createPropertyChanges" id="c8324828-5f15-4556-afc6-080b5d120a1c">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	oldStr,
	newStr : String;
	tmpDT : TimeStamp;
	propertyChange : HMS_PropertyChange;
	fromPMovement : HMS_VoyageMovement;
	fromWMovement : CMIF_HMS_WorkingMovement;
begin

	// Status has changed from planned to actual
	
	inheritMethod(_cmifTrans);
	
	fromWMovement := _cmifTrans.myWorkingMovement;
	fromPMovement := _cmifTrans.myProxyHMSObject.HMS_VoyageMovement;

	if fromWMovement &lt;&gt; null then
		tmpDT := fromWMovement.occursOnDT;
	elseif fromPMovement &lt;&gt; null then
		tmpDT := fromPMovement.occursOnDTNEW;	
	else
		return;
	endif;
	
	create propertyChange;
	oldStr := "Planned DT: " &amp; self.myMovement.occursOnDTNEW.shortCurrentLocaleSystemUTC();	// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
	newStr := "Actual DT: " &amp; tmpDT.shortCurrentLocaleSystemUTC();
	//oldStr := "Planned DT: " &amp; self.myVoyageMovement.moveDTActual.Date.format('dd/MM/yy') &amp; ", " &amp; self.myVoyageMovement.moveDTPlanned.Time.currentLocaleFormatJMT();
	//newStr := "Actual DT: " &amp; fromMovement.moveDTActual.Date.format('dd/MM/yy') &amp; ", " &amp; fromMovement.moveDTActual.Time.currentLocaleFormatJMT();
  	propertyChange.set(self, "Movement ACTUAL time confirmed", oldStr, newStr);
end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="7f7ff9da-9da5-487e-8559-9a8fff1111a3">
        <updating/>
        <source>setTypeDetails() updating, protected;

vars

begin
 	// Set type and typeString
	type:=TRANS_TYPE_ConfirmActualMove;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="127d9c07-57f5-47bc-8e95-894f9fee3f0d">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myVoyageMovement = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Movement', 'Null', null, null);
		return false;
	endif;	

	if _transController.myWorkingMovement = null
	and _transController.myProxyHMSObject = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Movement', 'Null', null, null);
		return false;
	endif;
	
	return rtnValue;
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
