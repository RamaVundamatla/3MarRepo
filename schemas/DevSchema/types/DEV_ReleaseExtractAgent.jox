	_views.add("CM_AuditObjectView");		// 31/5/18 MAP TFS37718
	_views.add("SOHbyLocation");			// jlgmd1 28/01/2019 fix View "SOHbyLocation" is not defined for report "CM_WHSOHSummary" error
	_views.add("Log Locations");			// jlgmd1 31/01/2019 fix View "Log Locations" is not defined for report error
