    <JadeMethod name="validateForUpdate" id="04327336-c1d3-4a2a-be2f-09f2dd9e2448">
        <source>validateForUpdate();
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
*/

vars

begin
	inheritMethod();
	
	
	if self.newUnitsUsed = null then
		app.raiseCMException(Please_select_period, null, null);
	endif;
	
	if self.newFromDateTime.isValid
	and self.newToDateTime.isValid
	and self.newToDateTime &gt; self.newFromDateTime then
		app.raiseCMException(From_dates_times_wrong, null, null);
	
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
