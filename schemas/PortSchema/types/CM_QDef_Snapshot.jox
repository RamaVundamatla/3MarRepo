    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="4eadf493-7ef8-432f-905f-bb21df1eacce">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.className := CM_DynamicObject_Snapshot.name;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProperties" id="f194fef9-c19e-4ba0-bec1-eeae5180067e">
        <source>createProperties();
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/06/2010	cnwcs5		ccms 1156 / par 23706 - new date/time proeprty
// ---------------------------------------------------------------------------
vars
	prop	:CM_QueryProperty;
begin
	inheritMethod();	// terminal
	
	// run date/time - requires extenstion of CM_QueryProperty
	create prop as CM_QDateTimeMethod persistent;														// ccms 1156 / par 23706 26/07/2010
	prop.set('Run Date/Time', CM_DynamicObject_Snapshot::getRunDateTime.name, self.className);		// ccms 1156 / par 23706 26/07/2010
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(prop);																// ccms 1156 / par 23706 26/07/2010
	
	// run date
	create prop as CM_QDateMethod persistent;
	prop.set('Run Date', CM_DynamicObject_Snapshot::getRunDate.name, self.className);				// ccms 1156 / par 23706 26/07/2010
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(prop);
	
	// run time - requires extenstion of CM_QueryProperty

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isSnapshotType" id="4b0018a1-3446-4ef4-bfa5-49fb559e7868">
        <source>isSnapshotType():Boolean;
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
