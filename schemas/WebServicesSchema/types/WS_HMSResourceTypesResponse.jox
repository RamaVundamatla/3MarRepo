<Class name="WS_HMSResourceTypesResponse" id="87e59668-51c4-4d25-80a9-b8e58084784f">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allHMSResourceTypes" id="65bef37c-45e5-4e32-aa7e-ae840f4a75b2">
        <memberTypeInverse/>
        <type name="WS_HMSResourceTypeArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="createResourceTypesForStatus" id="4cf96e75-8cf5-4422-b5c4-41f8ed60bd2f">
        <source>createResourceTypesForStatus(	_voyStatus : CM_VoyageStatus;
								_berth : HMS_Berth);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2018	jlger1	Initial creation

*/

vars
	hmsResource : HMS_Resource;
	hmsResourceType : HMS_ResourceType;
	harbour 	: HMS_Harbour;
	wsResourceType : WS_HMSResourceType;
begin
	if  _voyStatus = null then
		return;
	endif;
	harbour:= app.myPassport.myTerminal.myHarbour;
	foreach hmsResource in _voyStatus.allHMSResourcesAllowed discreteLock do
			if hmsResource.myHarbour &lt;&gt; harbour then
				continue;
			endif;
			
			hmsResourceType:=hmsResource.myResourceType;
			if hmsResourceType = null or hmsResourceType.isNotAvailableForEntry or
				hmsResourceType.isMarineService then
				continue;
			endif;
			
			if not hmsResourceType.isQuantityRequired  and
				not hmsResourceType.isActionDateTimeRequired and
				not hmsResourceType.isFromToDateTimeRequired then
				continue;
			endif;
				
			
			create wsResourceType transient;
			wsResourceType.setProxyFromObject(hmsResourceType);
			wsResourceType.setResource(hmsResource); //epr TFS 39739 16/7/18
			self.allHMSResourceTypes.add(wsResourceType);
			
			if _berth &lt;&gt; null then
				wsResourceType.setDefaultTugHours(hmsResource,_berth);
			endif;
			
	endforeach;
epilog

end;</source>
        <Parameter name="_voyStatus" type="CM_VoyageStatus"/>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="createResourcesForEquip" id="c4834b07-2357-4f27-bf3e-ea6a583654ee">
        <source>createResourcesForEquip( _processHarbour : CM_ProcessHarbour );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	hmsResourceType : HMS_ResourceType;
	harbour : HMS_Harbour;
	wsResourceType : WS_HMSResourceType;

begin

	harbour := _processHarbour.myHarbour;
	if _processHarbour.allHMSResourceTypeForEquip.isEmpty then
		return;
	endif;
	
	foreach hmsResourceType in _processHarbour.allHMSResourceTypeForEquip discreteLock do
		if not hmsResourceType.isQuantityRequired  and
			not hmsResourceType.isActionDateTimeRequired and
			not hmsResourceType.isFromToDateTimeRequired then
			continue;
		endif;
		
		create wsResourceType transient;
		wsResourceType.setProxyFromObject(hmsResourceType);
		self.allHMSResourceTypes.add(wsResourceType);
		
	endforeach;

epilog

end;</source>
        <Parameter name="_processHarbour" type="CM_ProcessHarbour"/>
    </JadeMethod>
    <JadeMethod name="createResourcesForExt" id="d768db5e-e3d0-4d8b-b87c-482a65c9af68">
        <source>createResourcesForExt(_processHarbour : CM_ProcessHarbour);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2019	jlgndl1	Initial creation	TFS 43374

*/

vars
	hmsResource : HMS_Resource;
	harbour : HMS_Harbour;
	wsResourceType : WS_HMSResourceType;

begin
	harbour := _processHarbour.myHarbour;
	
	if _processHarbour.allHMSResourcesForExt.isEmpty then
		return;
	endif;
	
	foreach hmsResource in _processHarbour.allHMSResourcesForExt discreteLock do
		if hmsResource.myHarbour &lt;&gt; harbour then
			continue;
		endif;
		
		create wsResourceType transient;
		wsResourceType.setProxyFromObject(hmsResource.myResourceType);
		wsResourceType.setResource(hmsResource);
		self.allHMSResourceTypes.add(wsResourceType);
		
	endforeach;

epilog

end;</source>
        <Parameter name="_processHarbour" type="CM_ProcessHarbour"/>
    </JadeMethod>
    <JadeMethod name="createResourcesForShift" id="ee1f9ef6-ad69-4793-9f89-4af426bf0ddd">
        <source>createResourcesForShift(_processHarbour : CM_ProcessHarbour; _berth : HMS_Berth);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/08/2018	jlgdap1		Initial creation TFS 40488 PEL1 Resources for Shift Movements
//
vars
	hmsResource : HMS_Resource;
	harbour : HMS_Harbour;
	wsResourceType : WS_HMSResourceType;

begin
	harbour := _processHarbour.myHarbour;
	if _processHarbour.allHMSResourcesForShift.isEmpty then
		return;
	endif;
	
	foreach hmsResource in _processHarbour.allHMSResourcesForShift discreteLock do
		if hmsResource.myHarbour &lt;&gt; harbour then
			continue;
		endif;
		if not hmsResource.myResourceType.isQuantityRequired  and
			not hmsResource.myResourceType.isActionDateTimeRequired and
			not hmsResource.myResourceType.isFromToDateTimeRequired then
			continue;
		endif;
		
		create wsResourceType transient;
		wsResourceType.setProxyFromObject(hmsResource.myResourceType);
		wsResourceType.setResource(hmsResource);
		self.allHMSResourceTypes.add(wsResourceType);
		
		if _berth &lt;&gt; null then
			wsResourceType.setDefaultTugHours(hmsResource, _berth);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_processHarbour" type="CM_ProcessHarbour"/>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="delete" id="19f8dc63-0a5c-44f6-824f-8ee9c6fb0225">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2018	jlger1	Initial creation

*/

vars

begin
	self.allHMSResourceTypes.purge;
epilog

end;</source>
    </JadeMethod>
</Class>
