    <JadeMethod name="auditIdDisplay" id="c64bcaae-f4e8-496f-87c4-d29c72ff8281">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jan 2017	cnwma1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/
vars
	auditIdStr : String;
begin
	auditIdStr := self.auditId();
	
	if auditIdStr &lt;&gt; null then
		return 'Debtor Map'&amp; ' - ' &amp; auditIdStr;		//31.03.2025 navma1 #MTN-34387
