    <JadeMethod name="tblInfo_contextMenu" id="a6b44df1-300d-4adb-81e3-734fc4891997">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInfo_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	15 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
begin
	
	self.setMyCurrentControls(cntrl.CM_DataTable, false);
				
	self.mnuToggleExtraInfo.caption := app.getErrorString(Hide_Additional_Info);
	self.mnuToggleExtraInfo.userObject := self.myCurrentSplitter;

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.doBuildMnuInfoTable();

	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);

	return false;

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblInfo_dblClick" id="a818b983-e420-489e-a92b-797fe62d4cf4">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInfo_dblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	anObject : Object;
begin
	if table.row &gt; 0 and table.column &gt; 0 then
		anObject := table.accessCell(table.row,table.column).itemObject;
		if anObject &lt;&gt; null then
			anObject.inspect;
		endif;
	endif;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblWLEChange" id="f6b8a8a5-bdb2-4223-8397-14e172bcccc8">
        <updating/>
        <source>tblWLEChange(_table : CM_DataTable input; _newRow : Integer) updating;
//--------------------------------------------------------------
//Created: 20 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : CM_Object;
	rtCol : Integer;
begin

	if _newRow &lt;= _table.fixedRows then
		return;
	endif;
	
	self.myCurrentWLE := null;		
	self.myCurrentTrackedItem := null;
	obj := _table.accessRow(_newRow).itemObject.CM_Object;
	
	if not global.isValidObject(obj) then
		return;
	endif;
	
	if obj.isKindOf(CM_VoyageWLE) then
		self.myCurrentWLE := obj.CM_VoyageWLE;
	elseif obj.isKindOf(CM_TrackedItem) then
		self.myCurrentTrackedItem := obj.CM_TrackedItem;		
	endif;

	if self.myCurrentWLE &lt;&gt; null then
		self.myCurrentTrackedItem := self.myCurrentWLE.myTrackedItem;
		rtCol := _table.getColumnByRowName(ETRow_RadioTelemetry);						
		self.tblWLESetRowColour(_table, self.myCurrentWLE, _newRow, rtCol);
		
		self.setMyCurrentJob(self.myCurrentWLE.job.CM_VoyageJob); // TFS 3472
	endif;
	
	self.displayExtraInfoForObj(obj);
	self.setNavigator(obj);	
	self.setStatusBarCaption();
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWLEDragDropEvent" id="e8aff884-39c8-4338-8e63-af48da4593b2">
        <updating/>
        <source>tblWLEDragDropEvent(table: Table input; win: Window input; x: Real; y: Real) updating, protected;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if win.isKindOf(CMUI_GridAreaForm) or
	   win.isKindOf(CMUI_GridAreaFrame) or
	   win.isKindOf(CM_DataTable) then
		self.tblWLEReceiveDrop();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblWLEMouseMoveEvent" id="0d6d9036-2b8d-409b-b318-3b9c0df85530">
        <updating/>
        <source>tblWLEMouseMoveEvent(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	invalidObj : Boolean; // TFS 42872 jlgzm1 16/08/2019
begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;


	if self.myCurrentWLE = null and self.myCurrentTrackedItem = null then
		return;
	endif;
	
	// check drag/drop detected
	if button &lt;&gt; Window.MouseButton_Left or (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then
	   return;
	endif;
	self.origXPos := 0;
	self.origYPos := 0;	
   	
   	on Exception do app.handleDeletedObject(exception, self.myCurrentWLE, invalidObj); // TFS 42878 jlgzm1 30/08/2019
	// myCurrentWLE can become invalid after unplaning, can may not have been cleared
   	if (not self.myCurrentWLE.isReceipt) then
   		return;
   	endif;
	
	if invalidObj then 	// TFS 42878 
		return;			// TFS 42878 
	endif;
	
	// TFS 42872 jlgzm1 16/08/2019
	if self.myCurrentJob &lt;&gt; null and self.myCurrentJob.isVoyageHoldJob then
		// Voyage Hold Jobs should not be able to drag or drop
		return;
	endif;
	
	// check there is a trackedItem to move
	if self.myCurrentWLE &lt;&gt; null then
		theTI := self.myCurrentWLE.myTrackedItem;
	endif;
	
	if theTI = null then
		theTI := self.myCurrentTrackedItem;
	endif;
	
	if theTI = null then
		return;
	endif;

	app.myDraggedTrackedItem := theTI;
	self.dragTrackedItem(theTI, self.myCurrentWLE, table);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblWLEReceiveDrop" id="b86703ff-4768-4c68-bcb3-70e9b8a03e3b">
        <updating/>
        <source>tblWLEReceiveDrop() updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	if self.myCurrentWLE = null then
		return;
	endif;
	
	// TFS 42872 jlgzm1 16/08/2019
	if self.myCurrentJob &lt;&gt; null and self.myCurrentJob.isVoyageHoldJob then
		// Voyage Hold Jobs should not be able to drag or drop
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
				
	if self.myCurrentWLE.isReceipt then
		return;
	else //selected wle is a release
		self.assignTIToReleaseRequest(self.myCurrentWLE);
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblWLESaveSelected" id="3eeb4f37-eeaf-4fa8-b0a0-7ab98444efca">
        <updating/>
        <source>tblWLESaveSelected() protected, updating;
// ---------------------------------------------------------------------------
// Created: 05 September 2003 By: cnwgd1
// ---------------------------------------------------------------------------
begin
	//th2 added isValidObject - job maybe unloaded from operations while viewing
	if app.isValidObject(self.myCurrentTableWLE) and self.myCurrentTableWLE &lt;&gt; null then
		self.topRowTblWLE := self.myCurrentTableWLE.topRow;
	endif;
	self.selectedTableObject := self.myCurrentWLE;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblWLESetRowColour" id="cab9887c-ad84-4a6b-a66b-cdd8863c1060">
        <source>tblWLESetRowColour(_table : CM_DataTable input; pWLE : CM_WorkListEntry; _rowIdx, _rtCol : Integer);
//--------------------------------------------------------------
//Created: 17 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	isSelected,
	isReceipt 	: Boolean;
	foreColour,
	backColour 	: Integer;	
begin
	
	foreColour := Black;
	backColour := White;

	if pWLE = null then
		return;
	endif;

	if pWLE.job &lt;&gt; null and pWLE.job.jobType = BOLType_Log then
		foreColour := Black;
		if _rowIdx mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;
	else
		pWLE.getRowColour(foreColour, backColour);	
	endif;	

	_table.accessRow(_rowIdx).backColor := backColour;
	_table.accessRow(_rowIdx).foreColor := foreColour;				
	
	self.displayWLEsShowRT(_table, _rowIdx, _rtCol);
	
	if backColour = Red then
		_table.accessRow(_rowIdx).fontBold := true;	
	else		
		_table.accessRow(_rowIdx).fontBold := false;		
	endif;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="pWLE" type="CM_WorkListEntry"/>
        <Parameter name="_rowIdx" type="Integer"/>
        <Parameter name="_rtCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWLESetSelected" id="84ca4b75-d7e6-4593-8ca8-4921100885d9">
        <updating/>
        <source>tblWLESetSelected() updating;
//--------------------------------------------------------------
//Created: 05 September 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	newRow : Integer;
begin
	//th2 added 16/03/2007 - if notification from a job being deleted then could be currently selected
	if (not app.isValidObject(self.myCurrentTableWLE)) then
		self.myCurrentTableWLE := null;
	endif;
	
	if self.myCurrentTableWLE &lt;&gt; null then
		if self.myCurrentTableWLE.findObjectInRow(self.selectedTableObject, newRow) then
			self.tblWLEChange(self.myCurrentTableWLE, newRow);
			self.myCurrentTableWLE.selectTheCurrentRow(newRow);
			self.myCurrentTableWLE.row := newRow;
		endif;
		if self.topRowTblWLE &gt; 0
		and self.topRowTblWLE &lt;= self.myCurrentTableWLE.rows then
			self.myCurrentTableWLE.topRow := self.topRowTblWLE;
		endif;
	endif;
	
	
		
end;</source>
    </JadeMethod>
    <JadeMethod name="tblWLEUpdateJob" id="d2f31e6a-ed1a-4591-ac78-05601630ca6f">
        <updating/>
        <source>tblWLEUpdateJob(_obj : CM_Object; _mode : Integer)updating;
//--------------------------------------------------------------
//Created: 7 October 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rowIdx	: Integer;
	table	: CM_DataTable;
begin

	if _mode &lt;&gt; self.Mode_Delete and _mode &lt;&gt; self.Mode_Update then
		return;
	endif;
	
	//table := self.getWLETableForJob(_obj.CM_Job, rowIdx, true);
	table := self.getWLETableForJob(_obj.CM_Job);

	if table = null then
		return;
	endif;
	
	self.topRowTblWLE := table.topRow;
	
	if _mode = self.Mode_Delete or (not global.isValidObject(_obj)) then
		self.doRemoveTable(table);
		return;
	endif;

	if (not _obj.isKindOf(CM_VoyageJob)) then
		return;
	endif;
	
	if (not _obj.CM_VoyageJob.isLoadedToOperations) then
		self.doRemoveTable(table);
		return;
	endif;

	self.doRefreshTable(table);
	if self.topRowTblWLE &gt; 0 and global.isValidObject(table) then
		table.topRow := self.topRowTblWLE;
	endif;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWLEUpdateWle" id="10ac872f-3178-4d67-b1aa-46a361dda9bb">
        <updating/>
        <source>tblWLEUpdateWle(_wle : CM_WorkListEntry io; _mode : Integer; _breakOut : Boolean output; _checkStillHasWarnings : Boolean) : CM_DataTable updating;
//--------------------------------------------------------------
//Created: 31 January 2003 By: cnwgd1
//--------------------------------------------------------------
//Update:  07 Decemeber 2009 conkc1  PAR 21876
//24/03/2015 cnwma1 PAR #35900 System Error 4 in SHP_VoyageOperationsForm::tblWLEUpdateWle
//
vars
	col,
	rowIdx	: Integer;
	tableWLEWasOn,
	newTable			: CM_DataTable;
	job 				: CM_VoyageJob;
	invalidWLE 			: Boolean; 
begin

	if (not CM_VoyageWLE.hasInstance(_wle)) then
		return null;
	endif;

	if _mode = self.Mode_Delete or (not global.isValidObject(_wle)) then
		self.removeWLEForTable(_wle);
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception,_wle, invalidWLE);  //  24/03/2015 cnwma1  PAR #35900  

	job := _wle.job.CM_VoyageJob;
	
	if invalidWLE then 								   					  //  24/03/2015 cnwma1  PAR #35900  
		return null; 
	endif; 
	if job = null then
		return null;
	endif;
		
	if (not job.isLoadedToOperations) then
		return null;
	endif;
	
	if _mode = self.Mode_Update then
		// Get table that wle was on.
		tableWLEWasOn := self.getWLETableForWLE(_wle);
		// Get table wle should be on.
		newTable := self.getWLETableForJob(job);
		
		// Check to see if we have table wle is supposed to be on.
		if newTable &lt;&gt; null then
			// Are the tables the same?
			if newTable &lt;&gt; tableWLEWasOn then
				// We have to take wle of old table and add it to new table.
				app.writeStatement( 'Wrong table add/remove');
				
				self.removeWLEForTable(_wle);
				rowIdx := self.addWLEForTable(newTable, _wle);
			else
				// Just updating details so call update method.
				rowIdx := self.updateWLEForTable(tableWLEWasOn, _wle);
			endif;
		else
			// Remove wle from old table.
			self.removeWLEForTable(_wle);
		endif;
		
	elseif _mode = self.Mode_Add then
		// update could potentially have added wle already, check this before adding
		tableWLEWasOn := self.getWLETableForWLE(_wle);	// TFS 42872 jlgzm1 19/08/2019
		// Let sys notes know about this baby.
		newTable := self.getWLETableForJob(job);
		
		if newTable &lt;&gt; null and newTable &lt;&gt; tableWLEWasOn then	// TFS 42872
			rowIdx := self.addWLEForTable(newTable, _wle);

		endif;
	endif;

	if newTable &lt;&gt; null then
		if rowIdx &gt; newTable.fixedRows then
			newTable.accessRow(rowIdx).itemObject := _wle;	
			col := newTable.getColumnByRowName(ETRow_RadioTelemetry);							
			self.tblWLESetRowColour(newTable, _wle, rowIdx, col);
		endif;
	
		if _checkStillHasWarnings = true then
			self.updateWLEStillHasWarnings(newTable);	 // PAR7524 - AKB2004FEB added
		endif;
	endif;
	

	self.updateVoyageJob(job, VoyageJob_Update_Event, false);

	return newTable;
			
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_checkStillHasWarnings" type="Boolean"/>
        <ReturnType type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntries_contextMenu" id="897ee81a-80b3-4940-987a-324c68599b6a">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	----------	------------------------------------
// 17/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
// 23/06//2020  cnwma1      Bug 49384: PEN - Problem with splitting jobs
vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_VoyageWLE;
	voyage : CM_Voyage;
	user : CM_User;
begin
	
	self.setMyCurrentControls(cntrl.CM_DataTable, false);
	
	if self.myCurrentTableInfo &lt;&gt; null then
		if self.myCurrentTableInfo.visible then
			self.mnuToggleExtraInfo.caption := app.getErrorString(Hide_Additional_Info);
		else
			self.mnuToggleExtraInfo.caption := app.getErrorString(Show_Additional_Info);
		endif;		
	endif;
	self.mnuToggleExtraInfo.userObject := self.myCurrentSplitter;

	self.doBuildMnuCargo(self.myCurrentTrackedItem);
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	obj := 	cntrl.accessRow(cntrl.row).itemObject.CM_VoyageWLE;
	self.doBuildMnuTblObj(obj);
	
	user := app.getMyUser;
	if user.canDo(self.myTerminal, PmSealCheckType) then
		self.mnuRecSealCheck.visible := true;
		self.mnuRelSealCheck.visible := true;
		//+cnwml2 PAR23715 SFW CCMS1131
		voyage := self.myCurrentVoyage;
		if voyage &lt;&gt; null then
			self.mnuRecSCDefault.checked := voyage.sealCheckReceival =SEAL_CHECK_DEFAULT;
			self.mnuRecSCFull.checked := voyage.sealCheckReceival =SEAL_CHECK_FULL;
			self.mnuRecSCStrict.checked := voyage.sealCheckReceival =SEAL_CHECK_STRICT;
			self.mnuRecSCView.checked := voyage.sealCheckReceival =SEAL_CHECK_VIEW;
			self.mnuRecSCNone.checked := voyage.sealCheckReceival =SEAL_CHECK_NONE;
		
			self.mnuRelSCDefault.checked := voyage.sealCheckRelease=SEAL_CHECK_DEFAULT;
			self.mnuRelSCFull.checked := voyage.sealCheckRelease=SEAL_CHECK_FULL;
			self.mnuRelSCStrict.checked :=voyage.sealCheckRelease=SEAL_CHECK_STRICT;
			self.mnuRelSCView.checked := voyage.sealCheckRelease=SEAL_CHECK_VIEW;
			self.mnuRelSCNone.checked := voyage.sealCheckRelease=SEAL_CHECK_NONE;	
		else
			self.mnuRelSealCheck.visible := false;
			self.mnuRecSealCheck.visible := false;
		endif;
	else
		self.mnuRelSealCheck.visible := false;
		self.mnuRecSealCheck.visible := false;
	endif;
	
	self.doBuildMnuSeparators();
	
	
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuCargo.visible := true;
		self.mnuAutoplan.visible := false;
		self.mnuQueue.visible := false;
		self.mnuMoveIt.visible := false;
		self.mnuDoorDirections.visible := false;
		self.mnuDisconnectReefers.visible := false;
		self.mnuRemarks.visible := false;
		self.mnuSplitWork.visible := false;
		self.mnuTransferWork.visible := false;					// TFS 47144
		self.mnuSplitWork2.visible := false;
		self.mnuTransferWork2.visible := false;					// TFS 47144
		self.mnuRebuildJobStatus.visible := false;
		self.mnuRebuildWLESEQD.visible := false;
		self.mnuRebuildWLEStatus.visible := false;
		self.mnuRebuildWLEUnaction.visible := false;
		self.mnuShowVoyageJob.visible := false;
		self.mnuShowVoyDefinition.visible := false;
		self.mnuMove.visible := false;
		self.mnuMoveCargoFromJob.visible := false;
		self.mnuRelSealCheck.visible := false;
		self.mnuRecSealCheck.visible := false;
		self.mnuUnassignTI.visible := false;
		self.mnuCargoTaskAdd.visible := false;
		self.mnuCargoTaskComplete.visible := false;
		self.mnuCargoTaskRemarks.visible := false;
		self.mnuStops.visible := false;
		self.mnuReturnCargo.visible := false;
		self.mnuAssignToIntendedTBA.visible := false; // TFS 45590
	endif;	
	
	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);
	self.mnuColumnOrganiser.userObject := cntrl;

	//cnwjo3 CCMS 1178 par 23366
	if app.getMyUser.canDo(self.myTerminal,PmAdmMoveCargoFromJob) then
		self.mnuMoveCargoFromJob.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
	endif;
	
	//cnwjo3 ccms 1178 par 23366
	self.mnuSplitWork.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
	self.mnuTransferWork.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	// TFS 47144
	self.mnuMoveCargoFromJob.enabled := false;
	if self.myCurrentJob &lt;&gt; null then
		
		if self.myCurrentJob.isDischarge then
			self.mnuMoveCargoFromJob.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
		endif;
		if self.myCurrentJob.status = JOB_UNACTIONED then		// TFS 47144
			//self.mnuSplitWork.enabled := false;				// TFS 47144   //cnwma1 23.06.2020 #49384
			self.mnuTransferWork.enabled := true;				// TFS 47144
		else													// TFS 47144
			self.mnuSplitWork.enabled := true;					// TFS 47144
			self.mnuTransferWork.enabled := false;				// TFS 47144
		endif;													// TFS 47144
	endif;
	
	//02 Apr 2012	NDL	Par 29369
	self.mnuWPOpHrs.visible := voyage &lt;&gt; null;
	self.mnuWPOpHrs.userObject := voyage;

	
	return false;

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntries_dblClick" id="563ac8fb-258a-4b4a-81e6-a2b94ba1b5eb">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_dblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if table.row &gt; table.fixedRows then
		self.myAssistant.showCargoEnquiryForm(self.myCurrentTrackedItem, self.myMasterMenuAction, true, false);
	elseif table.row = table.fixedRows then
		self.resortTblWorkEntries(table.CM_DataTable);	
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntries_dragDrop" id="4db1c205-6804-4cb7-9184-91122fd047fa">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	self.tblWLEDragDropEvent(table, win, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntries_gotFocus" id="8e3b71b2-33c3-4086-87de-4a6dcfd2f56a">
        <controlMethod name="CM_DataTable::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_gotFocus(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/12/2019	jlgdap1		Initial creation TFS 47144 JMT Refactor OOW Job Split Transfer
//
vars

begin
	self.setMyCurrentControls(table.CM_DataTable, true);
	if self.myCurrentTableWLE &lt;&gt; null then			
		if myCurrentTableWLE.row &gt; myCurrentTableWLE.fixedRows then
			self.tblWLEChange(myCurrentTableWLE.CM_DataTable, table.row);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntries_keyPress" id="e23fee20-1b27-4e21-b299-732d709661e0">
        <controlMethod name="Table::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_keyPress(table: Table input; keyCode: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 oct 12	PJS			Par # 30438 - Voyage Rationalisation
// ---------------------------------------------------------------------------

vars

begin

	if keyCode = J_key_R then
	//	self.loadListJobsAll();
		handleListJobsLoad;
		self.doResize();
	endif;
end;</source>
