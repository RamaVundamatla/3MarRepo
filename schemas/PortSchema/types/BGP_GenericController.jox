<Class name="BGP_GenericController" id="fe5556bf-4d73-4bcc-a5b7-812695da066e">
    <superclass name="BGP_Controller"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;This generic controller provides the ability to process various system defined tasks. Each controller can be set up to listen for one or many task types.&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myTerminal" id="915ba3a7-6e78-44ec-96dd-58710cdd5a45">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <JadeMethod name="canRunOnSDSSecondaryDB" id="b08a942d-c6e2-4b3f-af60-80f5cbf4acf7">
        <source>canRunOnSDSSecondaryDB(): Boolean;
//
// 23 Jule 2011	cmwrs1		CCMS1150 - backup sds notification
//
vars

begin
	if self.isDBBackup() then
		return true;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFields" id="8762310d-7963-4840-9eda-ad9ee39e57eb">
        <source>getFields(_allFields: StringArray input);
// --------------------------------------------------------------------------------
// Created:		23 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_allFields);
	_allFields.add(ETRow_RequestClassName);
end;</source>
        <Parameter name="_allFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="335b656c-13e5-4aeb-b6fb-1093e83cd984">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2018	jlger1	Initial creation

*/

vars

begin
	return self.myTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="c4239627-22df-4883-8b6b-bfb4797e9fed">
        <updating/>
        <source>initApp() updating;
// -------------------------------------------
// Created 04 November 2003 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	msg : String;
begin
	inheritMethod();
	msg := 'Monitored Requests - ' &amp; self.displayString;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	if process.userInfo &lt;&gt; null then								
		app.setCnAppAlias(self.class.name &amp; "#" &amp; process.userInfo);	//epr TFS 36655 29/4/19
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="isDBBackup" id="772f3753-c4bb-4717-9994-7b7b5b8dc123">
        <source>isDBBackup(): Boolean;
//
// CCMS1150 cnwrs1 16 June 2011
//
vars

begin
	if self.allRequestClassesToProcess.size = 1 and
	   self.allRequestClassesToProcess.includes(BGP_BackupDB.name) then
		return true;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRunningSDSDisplay" id="6ff54758-7893-4ea3-b4d1-49d6f937ab09">
        <source>isRunningSDSDisplay(): String;
//
// CCMS1150 cnwrs1 04 July 2011
//
vars

begin
	if self.canRunOnSDSSecondaryDB then
		if isRunningSDS then
			return "Running";
		else
			return "Stopped";
		endif;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isSetup" id="b2779f00-ce8f-4b9a-b46f-d72b5e184d37">
        <methodInvocation>mapping</methodInvocation>
        <source>isSetup(set: Boolean; _value: Boolean io) mapping;

// cnwdvb1 28 July 2003 

vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.allRequestClassesToProcess.size &gt; 0 then
		inheritMethod(set, _value);
		return;
	endif;
	_value := false;
	

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="09170b58-8772-47c4-9ce6-c5a2a5690d3a">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

vars

begin
	
	self.name				:= 'Generic';
	self.schemaName			:= 'UiCommonSchema';
	self.isEditable			:= true;				
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="65405be6-69d5-42bf-9ba4-d47809e5f675">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);

// cnwdvb1 12 December 2002 
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal

vars

begin
	inheritMethod(_cmif);
	if self.myTerminal &lt;&gt; null then
		_cmif.myTerminal := self.myTerminal;
	endif;
	_cmif.allClasses.clear;
	self.allRequestClassesToProcess.copy(_cmif.allClasses);
end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fe6e7acd-6f67-4492-8afd-bd8e4dd8bbd9">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;

// cnwdvb1 12 December 2002 
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal

vars

begin
	inheritMethod(_cmif);
	self.myTerminal := _cmif.myTerminal;
	self.allRequestClassesToProcess.clear;
	_cmif.allClasses.copy(self.allRequestClassesToProcess);
	self.setDisplayStringFromRequests();
end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2d2c8c84-59aa-4de5-bdfe-c2be4b9d0dbb">
        <source>validateForUpdate();
// -------------------------------------------
// Created 26 October 2005 by cnwdvb1
// -------------------------------------------
// 28 May 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
// 10 Jun 2022		navsrk20 ChangeRequest 53760: MTN - DuplicateItem not Translatable
vars

	count : Integer;

begin
	inheritMethod();
		
	// Email Send
	if self.allRequestClassesToProcess.includes(BGP_EmailSendRequest.name) then
		count := app.isAppropriateBGPConfigured(BGP_EmailSendRequest.name, self);
		if count &gt; 0 then
			//app.raiseCMWarning2(DuplicateItem, 'An email Send controller', 'this system.' , null,null, self.myUser);	//10.06.2022 navsrk20 53760
			app.raiseCMWarning(Email_send_contr_alrea_exist_t,null ,null, self.myUser);									//10.06.2022 navsrk20 53760
		endif;
	endif;
	// Email Read
	if self.allRequestClassesToProcess.includes(BGP_EmailReadRequest.name) then
		count := app.isAppropriateBGPConfigured(BGP_EmailReadRequest.name, self);
		if count &gt; 0 then
			//app.raiseCMWarning2(DuplicateItem, 'An email Read controller', 'this system.' , null,null, self.myUser);  //10.06.2022 navds20 53760
			//Email_read_contr_alrea_exit_t : An email Read controller already exists for this system.
			app.raiseCMWarning(Email_read_contr_alrea_exit_t, null,null, self.myUser);  //10.06.2022 navds20 53760
		endif;
	endif;
	// Cams
	if self.allRequestClassesToProcess.includes(BGP_CamsRequest.name) then
		count := app.isAppropriateBGPConfigured(BGP_CamsRequest.name, self);
		if count &gt; 0 then
			//app.raiseCMWarning2(DuplicateItem, 'A Cams controller', 'this system.' , null,null, null); //10.06.2022 navds20 53760
			//Cams_contr_alrea_exist_this_sy : A Cams controller already exists for this system.
			app.raiseCMWarning(Cams_contr_alrea_exist_this_sy , null,null, null); //10.06.2022 navds20 53760
		endif;
	endif;
	// Edi
	if self.allRequestClassesToProcess.includes(BGP_EdiRequest.name) then
		count := app.isAppropriateBGPConfigured(BGP_EdiRequest.name, self);
		if count &gt; 0 then
			//app.raiseCMWarning2(DuplicateItem, 'An EDI controller', 'this system.' , null,null,null); //10.06.2022 navds20 53760
			//Contro_alread_exists_this_syst: An EDI controller already exists for this system.
			app.raiseCMWarning(Contro_alread_exists_this_syst , null,null,null); //10.06.2022 navds20 53760
		endif;
	endif;
	


end;</source>
    </JadeMethod>
</Class>
