<Class name="CMIF_KPITruckTurnaround" id="db83f0c2-6849-4408-bc62-2fd82c385f2a">
    <superclass name="CMIF_KPIController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventTrans"/>
    <ImplicitInverseRef name="myVehicleVisit" id="346823fd-0323-43ed-afb0-39c960badace">
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="addToKPI" id="537a85d7-15d4-46d0-a33e-e636b225dae1">
        <updating/>
        <source>addToKPI(_passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		28 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	term : CM_Terminal;
	kpiTrk : CM_KPITruckByCarrierDay;
	kpiDetail : CM_KPITruckDetail;
	details : CM_KPIByTypeCodeTS;
	today : TimeStamp;
	tm : Time;
	aTI : CM_TrackedItem;
	sumCode : String;
	
begin
//	app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. '  , true);
	
	if self.myTerminal = null then
		return;
	endif;
	if self.myVehicleVisit = null then
		return;
	endif;
// #############

	tm.setTime(0,0,0,0);
	today := self.myVehicleVisit.timeIn;
	today.setTime(tm);
	create details transient;

//	app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 2. '  , true);
	
	// KPI BY CARRIER
	kpiTrk := self.myTerminal.allKPIbyTypeCodeTS[KPI_Type_TruckCarrier,self.myVehicleVisit.vehicle.carrierCode,today].CM_KPITruckByCarrierDay;
	if kpiTrk = null then
		create kpiTrk;
		kpiTrk.setProxyKPI(self.myTerminal, self.myVehicleVisit.vehicle.carrierCode, today, KPI_Type_TruckCarrier,_passport.userCode);
	endif;
	kpiTrk.updateFromVisitRecord(self.myVehicleVisit);
	kpiTrk.updateCarrier(self.myVehicleVisit);
	
	// KPI BY CARGO
	if self.myVehicleVisit.allReceivedTrackedItems.isEmpty() 
	and self.myVehicleVisit.allReleasedTrackedItems.isEmpty() then
		// KPI TRUCK Detail with no cargo
		create kpiDetail;
		kpiDetail.setProxyKPI(self.myTerminal, null, self.myVehicleVisit.timeIn, KPI_Type_TruckDetail,_passport.userCode);
		kpiDetail.updateFromVisitRecord(self.myVehicleVisit);
		kpiDetail.setMyCarrier(kpiTrk);
	else
		self.addToKPICargo(self.myVehicleVisit.allReceivedTrackedItems, today, details, kpiTrk, _passport);
		self.addToKPICargo(self.myVehicleVisit.allReleasedTrackedItems, today, details, kpiTrk, _passport);
	endif;
epilog
	delete details;
	
	
	
	
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addToKPICargo" id="2cdddafe-11ba-4ba9-b1b3-3f22638db665">
        <source>addToKPICargo(_tis :  CM_TISet; _today : TimeStamp; _details : CM_KPIByTypeCodeTS input; _kpiTrk : CM_KPITruckByCarrierDay; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:		14 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	kpiCargo : CM_KPITruckByCargo;
	kpiDetail : CM_KPITruckDetail;
	aTI : CM_TrackedItem;
	imexCode, sumCode : String;
begin
	foreach aTI in _tis discreteLock do
		// KPI TRUCK Detail
		create kpiDetail;
		kpiDetail.setProxyKPI(self.myTerminal, null, self.myVehicleVisit.timeIn, KPI_Type_TruckDetail,_passport.userCode);
		kpiDetail.updateFromVisitRecord(self.myVehicleVisit);
		kpiDetail.addTI(aTI);
		kpiDetail.setMyCarrier(_kpiTrk);

	
		// By Cargo/Day KPI
		sumCode := aTI.getPlannerReportGroupDesc();
		imexCode := aTI.getImExStatusStringDesc(false);
		sumCode := imexCode &amp; " " &amp; sumCode;
		
		kpiCargo := self.myTerminal.allKPIbyTypeCodeTS[KPI_Type_TruckCargo,sumCode, _today].CM_KPITruckByCargo;
		if kpiCargo = null then
			create kpiCargo;
			kpiCargo.setProxyKPI(self.myTerminal, sumCode, _today, KPI_Type_TruckCargo,_passport.userCode);
		endif;
		kpiCargo.updateFromVisitRecord(self.myVehicleVisit);
		kpiCargo.addTI(aTI);
		kpiDetail.setMyCargo(kpiCargo);

	endforeach;

end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_today" type="TimeStamp"/>
        <Parameter name="_details" type="CM_KPIByTypeCodeTS" usage="input"/>
        <Parameter name="_kpiTrk" type="CM_KPITruckByCarrierDay"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="processKPI" id="2798762e-f8c2-4301-a187-d9e0c1da8344">
        <updating/>
        <source>processKPI() updating;
// ---------------------------------------------------------------------------
// Created:		28 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	term : CM_Terminal;
	kpiTrk : CM_KPITruckByCarrierDay;
	kpiDetail : CM_KPITruckDetail;
	details : CM_KPIByTypeCodeTS;
	today : TimeStamp;
	tm : Time;
	aTI : CM_TrackedItem;
	sumCode : String;
	
begin
	inheritMethod();
	
	if self.myTerminal = null then
		return;
	endif;
	if self.myVehicleVisit = null then
		return;
	endif;

//	app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; process.isInTransactionState.String , true);

	app.myTrxUA.trxUpdateKPITruck(self, app.myPassport); // new KPI is on controller - self.myUpdateKPI 
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControllerFromUserInfo" id="9b6c9271-bd52-43ce-9ff7-bd969c8cb7ee">
        <updating/>
        <source>setControllerFromUserInfo(_userInfo : String) updating;
// ---------------------------------------------------------------------------
// Created:		15 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Delimiter = "^";
vars
	sub : String;
	val, pos, idx, len  : Integer;
begin
//	app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; _userInfo, true);


	len := _userInfo.length();
	idx := 1;
	while true do
		pos := _userInfo.pos(Delimiter, idx);
		if pos = 0 then
			break;
		endif;
		sub := _userInfo[idx:pos - idx];
		val := val + 1;
		if val = 1 then
			self.myVehicleVisit :=  sub.asOid().CM_VehicleVisitRecord;
		endif;
		
		idx := pos + 1;
		if idx &gt; len then
			break;
		endif;
	endwhile;
	// don't forget the last item
	sub := _userInfo[idx:end];
	self.myTerminal := sub.asOid().CM_Terminal;

//	app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; self.myLocationSource.String &amp; "&lt;&gt;" &amp; self.myLocationTarget.String &amp; "&lt;&gt;" &amp; self.myTrackedItem.String &amp; "&lt;&gt;" &amp; self.numKPISource.String &amp;"&lt;&gt;" &amp; self.numKPITarget.String, true);

end;</source>
        <Parameter name="_userInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyVehicleVisit" id="96c18ced-1a08-4733-92e3-bd8dabd63db3">
        <updating/>
        <source>setMyVehicleVisit(_vvr: CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jan 2026	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around

*/

vars

begin
	self.myVehicleVisit := _vvr;
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
</Class>
