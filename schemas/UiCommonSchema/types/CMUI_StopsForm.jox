    <JadeMethod name="initStopsToAddTable" id="651562e3-04b2-40fc-b5fd-13ba379d84b5">
        <source>initStopsToAddTable( _table : CM_DataTable input ) protected;
// ---------------------------------------------------------------------------
// Created:     15 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
	col	:Integer;
begin
	_table.userInputEnabled	:= true;
	_table.selectMode		:= Table.SelectMode_None;
	_table.showFocus		:= false;
	
	col := _table.getColumnByRowName (ETRow_Add);
	
	if col &lt;&gt; 0 then
		_table.accessColumn (col).alignment	:= Table.Alignment_Center;
		_table.accessedColumn.widthPercent	:= 10;
	endif;
	
	col := _table.getColumnByRowName (ETRow_Update);
	
	if col &lt;&gt; 0 then
		_table.accessColumn (col).alignment	:= Table.Alignment_Center;
		_table.accessedColumn.widthPercent	:= 10;
	endif;
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initStopsToClearTable" id="8c015fea-a382-43ff-a4c4-3465c4817133">
        <source>initStopsToClearTable( _table : CM_DataTable input ) protected;
// ---------------------------------------------------------------------------
// Created:     15 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/09/2010	cnwrl1		PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
// ---------------------------------------------------------------------------
vars
	col	:Integer;
begin
	_table.userInputEnabled	:= true;
	_table.selectMode		:= Table.SelectMode_None;
	_table.showFocus		:= false;
	
	col := _table.getColumnByRowName (ETRow_Clear);
	
	if col &lt;&gt; 0 then
		_table.accessColumn (col).alignment	:= Table.Alignment_Center;
		_table.accessedColumn.widthPercent	:= 10;
	endif;
		
	col := _table.getColumnByRowName (ETRow_Cancel);
	
	if col &lt;&gt; 0 then
		_table.accessColumn (col).alignment	:= Table.Alignment_Center;
		_table.accessedColumn.widthPercent	:= 10;
	endif;
	
	// cnwrl1 21/09/2010 PAR 23697 - start of coding
	col := _table.getColumnByRowName (ETRow_Override);
	if col &lt;&gt; 0 then
		_table.accessColumn (col).alignment	:= Table.Alignment_Center;
		_table.accessedColumn.widthPercent	:= 10;
	endif;
	// cnwrl1 21/09/2010 PAR 23697 - end of coding
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
