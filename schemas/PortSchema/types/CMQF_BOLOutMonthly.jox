<Class name="CMQF_BOLOutMonthly" id="a2aa2e2a-1183-48e5-9e6a-67fcff60faba">
    <superclass name="CMQF_BOLOut"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="6429c2da-1fcd-4444-b3cd-8a32786e0e28">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars
	ext		: CM_BOLExtension;
	isoType	: CM_ISOType;
	bolColl : CM_BOLByTypeNumberDTDict;	
	bol		: CM_BOL;
	iter	: Iterator;
	op		: CM_Operator;
	opTerm	: CM_OperatorTerminal;
	terminal		: CM_Terminal;
	breakOut		: Boolean;
	ti				: CM_TrackedItem;
	failedDAC  :CM_DataAccessController;
begin
	op := self.myOperator;
	if op = null then
		return;
	endif;
	
	if not op.canUserAccessSelf(null, failedDAC,_passport) then
		return;
	endif;
	
	foreach terminal in self.allTerminals do : terminalLoop
		opTerm := op.getOperatorTerminal(terminal, false);
		if opTerm = null then
			continue terminalLoop;
		endif;
		
		bolColl := opTerm.allBOLByTypeNumber;
		delete iter;
		iter := bolColl.createIterator;
		bolColl.startKeyGeq(self.bolType, null, null, iter);
		
		while iter.next(bol) do	
			if self.bolType &lt;&gt; null and bol.bolType &lt;&gt; self.bolType then
				continue terminalLoop;
			endif;
			if not self.checkStatusIncludesObject(bol, _passport, breakOut) then
//			if (not self.includesObject(bol, _passport, breakOut)) then
				continue;
			endif;
		
			if CM_BOLOut.hasInstance(bol) then
				_collection.add(bol);
				self.numContainers := self.numContainers + 1;
				self.outwardsDockets := self.outwardsDockets + 1;
				self.outwardsTIs := self.outwardsTIs + bol.allTrackedItems.size;
				self.outwardsVolume := outwardsVolume + bol.getTotalTIVolume;
				self.outwardsWeight := outwardsWeight + bol.getTotalTIWeight();
				self.totalPackingCharge := self.totalPackingCharge + bol.CM_BOLOut.getContainerCharge;
				self.numOutwards := self.numOutwards + bol.allTrackedItems.size;
				ti := bol.CM_BOLOut.myMasterTI;
				
				if (not CM_Container.hasInstance(ti)) then
					continue;
				endif;
				
				if ti.CM_Container.is40 then
					num40ft := num40ft + 1;
				else
					num20ft := num20ft +1;
				endif;
				
			else
				self.numInwards := self.numInwards + bol.allTrackedItems.size;
				self.inwardsDockets := self.inwardsDockets + 1;
				self.inwardsTIs := inwardsTIs + bol.allTrackedItems.size;
				self.inwardsVolume := inwardsVolume + bol.getTotalTIVolume;
				self.inwardsWeight := inwardsWeight + bol.getTotalTIWeight;
			endif;
				
			if breakOut then
				return;
			endif;
		endwhile;
	endforeach;
	
	
epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
