    <JadeMethod name="rsShowForm" id="a52e5698-d315-446d-af66-cbe8f29a2fa5">
        <source>rsShowForm();
//
//08 August 2019	jlgrs1	Initial creation
//
vars
	form : CM_BaseForm;
	terminal : CM_Terminal;
begin
//	app.logMessage(method.qualifiedName);
	app.initialize;
	app.myPassport.setMyUserFromCode("SUPERUSER");
	terminal := CM_Root.firstInstance.allTerminals["UT"];
	app.myPassport.setMyTerminal(terminal); // NDL
	app.createMyController(CMUI_Controller);
	create form as CMUI_EDIForm transient;
	form.setMyTerminal(terminal);
	form.createMyAssistant(CMUI_Assistant);
	form.show;
//	app.msgBox("","",0);
epilog
//	delete form;
end;</source>
    </JadeMethod>
    <JadeMethod name="rsTFS3395" id="d132d371-4f68-40b0-8058-0b5580c9ee08">
        <source>rsTFS3395();

vars
	tmpAllAvailableObjs		: HMS_WharfArray;
	tmpAllSelectedObjs		: HMS_WharfArray;
	terminalObj			: CM_Terminal;
	wharfObj			: HMS_Wharf;
	failedDAC  :CM_DataAccessController;
	aAllSelectedWharves : HMS_WharfArray;
	aAllAvailableWharves : HMS_WharfArray;
	harbour : HMS_Harbour;
	str : String;
begin
	create tmpAllAvailableObjs transient;
	create tmpAllSelectedObjs transient;
	create aAllSelectedWharves transient;
	create aAllAvailableWharves transient;
	
	aAllSelectedWharves.copy(tmpAllSelectedObjs);
	aAllAvailableWharves.clear();
	aAllSelectedWharves.clear();

//	foreach terminalObj in self.myHarbour.allTerminalsByCode do		// PAR 16411
//		if terminalObj.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
	terminalObj := app.myRoot.allTerminals["T01"]; //.myTerminal;
	if terminalObj = null then
		str := "Terminal is invalid.";
		app.msgBox(str, null, 0);
	endif;
	harbour := app.myRoot.allHarbours["HMSAVON"];
	if harbour = null then
		str := "harbour is invalid.";
		app.msgBox(str, null, 0);
	endif;
	foreach wharfObj in terminalObj.allWharves do
		if not tmpAllAvailableObjs.includes(wharfObj) then
			tmpAllAvailableObjs.add(wharfObj);
		endif;
	endforeach;
//		endif;
//	endforeach;
	
	
	foreach wharfObj in harbour.allWharfDisplayOrderArray do
		// some wharfs (e.g. anchorage) may not be associated with
		// a terminal so add always add in.
		if wharfObj.allTerminals.isEmpty then
			aAllAvailableWharves.add(wharfObj);
			aAllSelectedWharves.add(wharfObj);
		endif;
		
		if tmpAllAvailableObjs.includes(wharfObj) then
			aAllAvailableWharves.add(wharfObj);
		endif;
		
		if tmpAllSelectedObjs.includes(wharfObj) then
			aAllSelectedWharves.add(wharfObj);
		endif;
	endforeach;
	
	if aAllSelectedWharves.isEmpty() then
		aAllAvailableWharves.copy(aAllSelectedWharves);
	endif;
	str := "aAllAvailableWharves ";
	foreach wharfObj in aAllAvailableWharves do
		str := str&amp;wharfObj.code&amp;', ';
	endforeach;
	str := str&amp;CrLf&amp;"aAllSelectedWharves ";
	foreach wharfObj in aAllSelectedWharves do
		str := str&amp;wharfObj.code&amp;', ';
	endforeach;
	app.msgBox(str, null, 0);
/*	self.msgSelectWharves.setAvailable(self.aAllAvailableWharves, true);
	self.msgSelectWharves.setSelected(self.aAllSelectedWharves);
	//epr par 16808 19/6/08
	self.myViewController.allWharves.clear;
	self.aAllSelectedWharves.copy(self.myViewController.allWharves);*/
epilog
	delete tmpAllAvailableObjs;
	delete tmpAllSelectedObjs;
	delete aAllSelectedWharves;
	delete aAllAvailableWharves;
end;
</source>
    </JadeMethod>
    <JadeMethod name="rsTFS3524" id="10d47537-da97-4158-b51e-59319648f004">
        <source>rsTFS3524();

vars
	_id : String;
	terminal : CM_Terminal;
	dict			: CM_MemberKeyDictionary;
	iter2			: Iterator;
	ediReleaseReqTI : CM_EDIReleaseRequestTI;
	idLength		: Integer;
	ediData			: CM_EDIData;
	_coll				: CM_ObjectSet;
	ediFileType	: CM_EDIFileType;
	voyage : CM_Voyage;
	_ediData :CM_EDIData;
	_voyage :CM_Voyage;
	_statusColl :IntegerArray;
	_ediFileTypeColl :CM_ObjectSet;
	_dateStart, _dateEnd :Date;
	str : String;
	chkExcludeDepart : Boolean;
 begin
	_id := "959085403";
	_dateStart := null;
	_dateEnd := null;
	idLength	:= _id.length();
	terminal := CM_Terminal.firstInstance;
	create _coll transient;
		dict := terminal.myEdiConfig.allEDIRelReqTiByRelNumStatus;
		iter2 := dict.createIterator;
		dict.startKeyGeq( _id, null, iter2 );
		
		while iter2.next( ediReleaseReqTI ) do
			
			if ediReleaseReqTI.releaseRequestNumber.toUpper[ 1 : idLength ] &lt;&gt; _id then
				break;
			endif;
			
			// make sure match other conditions selected.
			ediData	:= ediReleaseReqTI.myEDIData;
			str := str &amp; "Found edidata "&amp;ediData.String;
			// Because can easily already selected this EDIData check this first.
			if _coll.includes( ediData ) then
				continue;
			endif;
	_ediData := ediData;		
	if _voyage &lt;&gt; null and 
		not _ediData.isForVoyage(_voyage) then 
		str := str &amp; " return false Voyage";	// not for voyage we are interested in
	endif;
	
	if _statusColl &lt;&gt; null and 
		not _statusColl.isEmpty and
		not _statusColl.includes(_ediData.status) then // not great but need to check
		str := str &amp; "return false status ";	// filtering by status and not one of the selected statii
	endif;
	
	if _ediFileTypeColl &lt;&gt; null and not _ediFileTypeColl.isEmpty then
		ediFileType := _ediData.getEDIFileType;
		
		// cnwrl1 28/07/2010 PAR 24415 - start of replacement coding
		if ediFileType = null then
			// this can happen if the EDI User File Definition is deleted!
			str := str &amp; "return false fileType";
		endif;
		// Check the ediFileType is contained in the selected list
		if not _ediFileTypeColl.includes( ediFileType ) then 
			str := str &amp; "return false fileType Coll";
		endif;
		// cnwrl1 28/07/2010 PAR 24415 - end of coding
	endif;
	
	if chkExcludeDepart then
		voyage := terminal.lookupVoyage(_ediData.getVoyageCode,null,false);
		if voyage &lt;&gt; null and voyage.hasDeparted then
			str := str &amp; "return false departed voyage";
		endif;
	endif;
	
	if _dateStart &lt;&gt; null and
	   _ediData.processDate &lt; _dateStart then 
		str := str &amp; "return false dateStart";
	endif;
	
	if _dateEnd &lt;&gt; null and
	   _ediData.processDate &gt; _dateEnd then
		str := str &amp; "return false dateEnd";
	endif;
	
	str := str &amp; "return true doIncludeObject "&amp;_ediData.String;
//			if self.doIncludeObject( ediData, _voyage, _statusColl, _ediFileTypeColl, _dateStart, _dateEnd ) then
				_coll.add( ediData );
/*				size := size + 1;
				if size &gt; JadeTableRowLimit then
					// too many object to load into the table
					return;
				endif;
			endif;
			
			if self.doQuery_CheckCancel( count ) then
				return;	// user clicked cancel on the progress dialog
			endif;*/
		endwhile;
		app.msgBox(str, null, 0);
epilog
	delete _coll;
end;
</source>
    </JadeMethod>
    <JadeMethod name="rsTFS3524_2" id="ad08c300-57e1-4216-8888-ca4a0292dd41">
        <source>rsTFS3524_2();

vars
	_id : String;
	terminal : CM_Terminal;
	dict			: CM_MemberKeyDictionary;
	iter1			: Iterator;
	iter2			: Iterator;
	ediReleaseReqTI : CM_EDIReleaseRequestTI;
	idLength		: Integer;
	ediData			: CM_EDIData;
	_coll				: CM_ObjectSet;
	ediFileType	: CM_EDIFileType;
	voyage : CM_Voyage;
	_dataTypeColl		: IntegerArray;
	_ediData :CM_EDIData;
	_voyage :CM_Voyage;
	_statusColl :IntegerArray;
	_ediFileTypeColl :CM_ObjectSet;
	_dateStart, _dateEnd :Date;
	str : String;
	chkExcludeDepart : Boolean;
	ediTrackedItem : CM_EDITrackedItem;
	size : Integer;
	retCode : Boolean;
 begin
	_id := "959085403";
	_dateStart := null;
	_dateEnd := null;
	idLength	:= _id.length();
	terminal := CM_Terminal.firstInstance;
	create _coll transient;
	create _dataTypeColl transient;
	_dataTypeColl.add(EDIDataType_ReleaseRequest);
	dict		:= terminal.myEdiConfig.allEDITrackedItemsByIdStatus;
	iter1		:= dict.createIterator;
	dict.startKeyGeq( _id, null, iter1 );
	
	while iter1.next( ediTrackedItem ) do : edi_loop
		if ediTrackedItem.id.toUpper[ 1 : idLength ] &lt;&gt; _id then
			break edi_loop;
		endif;
		
		// make sure match other conditions selected.
		ediData	:= ediTrackedItem.myEDIData;
		// Because can easily already selected this EDIData check this first.
		if _coll.includes( ediData ) then
			continue edi_loop;
		endif;
		
		// check the Data Type for this EDITrackedItem
		if _dataTypeColl.isNotEmpty and not _dataTypeColl.includes( ediData.ediDataType ) then
			continue edi_loop;
		endif;
		// start doIncludeObject
		retCode := false;
		_ediData := ediData;		
		if _voyage &lt;&gt; null and 
			not _ediData.isForVoyage(_voyage) then 
			str := str &amp; " return false Voyage";	// not for voyage we are interested in
			retCode := true;
		endif;
		
		if _statusColl &lt;&gt; null and 
			not _statusColl.isEmpty and
			not _statusColl.includes(_ediData.status) then // not great but need to check
			str := str &amp; "return false status ";	// filtering by status and not one of the selected statii
			retCode := true;
		endif;
		
		if _ediFileTypeColl &lt;&gt; null and not _ediFileTypeColl.isEmpty then
			ediFileType := _ediData.getEDIFileType;
			
			// cnwrl1 28/07/2010 PAR 24415 - start of replacement coding
			if ediFileType = null then
				// this can happen if the EDI User File Definition is deleted!
				str := str &amp; "return false fileType";
			retCode := true;
			endif;
			// Check the ediFileType is contained in the selected list
			if not _ediFileTypeColl.includes( ediFileType ) then 
				str := str &amp; "return false fileType Coll";
			retCode := true;
			endif;
			// cnwrl1 28/07/2010 PAR 24415 - end of coding
		endif;
		
		if chkExcludeDepart then
			voyage := terminal.lookupVoyage(_ediData.getVoyageCode,null,false);
			if voyage &lt;&gt; null and voyage.hasDeparted then
				str := str &amp; "return false departed voyage";
			retCode := true;
			endif;
		endif;
		
		if _dateStart &lt;&gt; null and
		   _ediData.processDate &lt; _dateStart then 
			str := str &amp; "return false dateStart";
			retCode := true;
		endif;
		
		if _dateEnd &lt;&gt; null and
		   _ediData.processDate &gt; _dateEnd then
			str := str &amp; "return false dateEnd";
			retCode := true;
		endif;
		if not retCode then
			str := str &amp; "return true doIncludeObject "&amp;_ediData.String;
//		if self.doIncludeObject( ediData, _voyage, _statusColl, _ediFileTypeColl, _dateStart, _dateEnd ) then
			_coll.add( ediData );
			size := size + 1;
//			if size &gt; JadeTableRowLimit then
				// too many object to load into the table
//				return;
//			endif;
		endif;
		
//		if self.doQuery_CheckCancel( count ) then
//			return;	// user clicked cancel on the progress dialog
//		endif;
	endwhile edi_loop;
	if size &lt; 10 then
		app.msgBox(str, null, 0);
	else
		app.msgBox("large size of "&amp;size.String, null, 0);
	endif;
epilog
	delete _coll;
	delete iter1;
	delete iter2;
	delete _dataTypeColl;
end;
</source>
    </JadeMethod>
