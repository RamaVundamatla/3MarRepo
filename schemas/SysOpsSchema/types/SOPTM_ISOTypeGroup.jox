    <JadeMethod name="setControlsForAddEdit" id="e5fb76a4-fb86-4e1b-8366-cd741dc305bc">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;
	code	: String;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.shtMultiSelect1.visible := true;
	theForm.shtMultiSelect2.visible := true; //cnwrd1 par 30414 25.9.2012
	theForm.mulSelect1.userInputEnabled := true; 
	theForm.mulSelect2.userInputEnabled := true;//cnwrd1 par 30414 25.9.2012
	
	if process.isJLGAB1() then
		theForm.mulSelect1.top := 290;
		theForm.grpISOGroupQry.parent := theForm.shtMultiSelect1;
		theForm.grpISOGroupQry.visible := true;
		theForm.grpISOGroupQry.top := 0;
		theForm.grpISOGroupQry.left := 5;
		theForm.grpISOGroupQry.parentAspect := 1;
	endif;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
//		theForm.tblInput1.hideRowByName(ETRow_AllISOTypes,false);
		theForm.mulSelect1.setSelected(null);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.fldInput.initSheetBackColors();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_ISOTypeGroup);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
//		theForm.tblInput1.hideRowByName(ETRow_AllISOTypes,false);
	endif;
	self.enableMulSelect1Contents();
	self.enableMulSelect2Contents();//cnwrd1 par 30414 25.9.2012
	theForm.tblInput1.cnEcResizeContents;
	theForm.tblInput2.cnEcResizeContents;//cnwrd1 par 30414 25.9.2012
		
	/*code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	if code &lt;&gt; null then
		theForm.mulSelect2.removeItem(app.myRoot.allISOTypeGroups[code]);
	endif;*/
	
	//18 mar 2014	NDL	Par 33268
	if theForm.mode = theForm.Mode_Add then
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTareWeight,  0, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTotalWeight,  0, self.weightType );
	else
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTareWeight,  theForm.myProxyObject.CM_ISOTypeGroup.maxTareWeight, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTotalWeight,  theForm.myProxyObject.CM_ISOTypeGroup.maxTotalWeight, self.weightType );
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="4ad42cd9-4069-4433-92a7-6b3d62e30344">
        <updating/>
        <source>setCtrlsForView() updating;

vars

	theForm : SOP_TableMaintForm;

begin
	inheritMethod();  
  	theForm := self.myForm;
  	theForm.tblInput1.userInputEnabled := false;
//  theForm.tblInput1.showRowByName('allISOTypes',false);
  	theForm.tblInput1.cnEcResizeContents;
  	theForm.shtMultiSelect1.visible := true;
	theForm.shtMultiSelect2.visible := true; //cnwrd1 par 30414 25.9.2012
	
	if process.isJLGAB1() then
		theForm.mulSelect1.top := 0;
		theForm.grpISOGroupQry.visible := false;
		self.initShtMultiSelect();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="b8111247-fe71-4fd8-9d91-950a0060c515">
        <updating/>
        <source>setupThumbnailDetails()updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ISOTypeGroupTbl);
	//theForm.zAddColumn('ISO Type Group Id', 'code', Table.InputType_None, 30);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ISOTypeGroupMaint);
	theForm.shtTblInput1.visible := true;
		
	theForm.tblInput1.hideRowByName(ETRow_AllISOTypes,false);

	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);		
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="1f99709a-bafe-4a59-bdea-80c4b3f1de49">
        <updating/>
        <source>showThumbnail(pISOTypeGroup : CM_ISOTypeGroup) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2024	jlizm1	TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references

*/
vars

	theForm : SOP_TableMaintForm;
	list:String;	
	first:Boolean;
	isoType:CM_ISOType;	
	aCollection : CM_ISOTypeGroupByCodeDict ;
	
begin
  
  theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pISOTypeGroup.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pISOTypeGroup.description);
	theForm.tblInput1.setValueByName(ETRow_Colour,	pISOTypeGroup.colour);
	theForm.tblInput1.setValueByName(ETRow_ExternalReference1 ,	pISOTypeGroup.externalReference1);
	theForm.tblInput1.setValueByName(ETRow_ExternalReference2 ,	pISOTypeGroup.externalReference2);
	theForm.tblInput1.setValueByName(ETRow_ReportGroupOrder,	pISOTypeGroup.reportGroupOrder);
	theForm.tblInput1.setValueByName(ETRow_MaxTareWeight,	pISOTypeGroup.maxTareWeight);
	theForm.tblInput1.setValueByName(ETRow_MaxTotalWeight,	pISOTypeGroup.maxTotalWeight);
	
	//Moved to mulSelect1 sheet setSelected 01092003
/*	first := false;
	foreach isoType in pISOTypeGroup.allISOTypes do
		if (not first) then
			first := true;
			list := isoType.code.trimBlanks;
		else
			list := list &amp; ", " &amp; isoType.code.trimBlanks;
		endif;
	endforeach;
		theForm.tblInput1.setValueByName(ETRow_AllISOTypes, list);
*/
	theForm.mulSelect1.setSelected(pISOTypeGroup.allISOTypes);
	
	//cnwrd1 par 30414 25.9.2012 we dont want US in the list
	create aCollection transient;
	app.myRoot.allISOTypeGroups.copy ( aCollection);
	aCollection.removeIfPresent(aCollection[pISOTypeGroup.code]);
	theForm.mulSelect2.setAvailable(aCollection, true );
	theForm.mulSelect2.setSelected(pISOTypeGroup.allSubstitutingISOGroups ); 
	self.disableMulSelect1Contents();
	
	//18 Mar 2014	NDL	Par 33268
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTareWeight,  pISOTypeGroup.maxTareWeight, self.weightType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTotalWeight,  pISOTypeGroup.maxTotalWeight, self.weightType );
	
	
epilog
	delete aCollection;
end;</source>
        <Parameter name="pISOTypeGroup" type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="7348d77c-4339-4786-a7a2-ad4a62d9c5a0">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	isoTypeGroup:CM_ISOTypeGroup;
	cell		: JadeTableCell;
begin
	isoTypeGroup := _obj.CM_ISOTypeGroup;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := isoTypeGroup.colour;
		endif;
	endif;
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
