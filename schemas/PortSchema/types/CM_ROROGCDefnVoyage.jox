    <JadeMethod name="hasTIs" id="502c2261-0435-44d2-8032-fad24c8811fc">
        <source>hasTIs(_mode : Integer) : Boolean;
/*
Purpose:			
Date		Who		Reason
21 July 2011	cnwab1	Initial creation
*/

vars

begin
	
	if self.myGCController &lt;&gt; null then
		if _mode = REAL_MODE then
			if not self.myGCController.allTrackedItems.isEmpty() then
				return true;
			endif;
		// PAR 28919
		elseif _mode = PLANNING_MODE then
			return self.myGCController.hasTIsOfMode(PLANNING_MODE);
		elseif _mode = QUEUE_MODE then
			return self.myGCController.hasTIsOfMode(QUEUE_MODE);
		endif;
	endif;

	return false;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasUnactionedWLE" id="28055901-65f5-4a8c-b86b-89882290ea50">
        <source>hasUnactionedWLE(_isLoad: Boolean): Boolean;
/*
Purpose:			
Date				Who			Reason
AUGUST 2012		CNWAB1		Initial creation
*/

vars

begin
	if _isLoad then
		if self.myGCController.myRORORequestLoad &lt;&gt; null then
			if not self.myGCController.myRORORequestLoad.isComplete then
				return true;
			endif;
		endif;
	else
		if self.myGCController.myRORORequestDischarge &lt;&gt; null then
			if not self.myGCController.myRORORequestDischarge.isComplete then
				return true;
			endif;
		endif;
	endif;
	
	
	return false;

epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
