    <JadeMethod name="doMnuInvoicePostConfClick" id="ec7b2b3e-0432-4df9-9f03-1c99154dc435">
        <source>doMnuInvoicePostConfClick(menuItem: MenuItem input) protected;
/*

Purpose:	

	Method to send messages to TAS to confirm an invoice has been posted

Parameters:		

	The menu item clicked on

Return Value:	

	None

Date			Who		Reason
27 June 2023	navcs2	ChangeRequest 58433: [58454]: EUP | TAS Invoicing - Invoice Posting Confirmation Message

*/

vars
	invoice			: CM_Invoice;
	pxyRequest		: BGP_APIWSRequest;
	bgpRequest 		: BGP_ExternalWSRequest;
begin	
	invoice := self.myCurrentInvoice;
	
	if invoice &lt;&gt; null 
	// ### TFS BUG 63257 28MAR2024 NAVAB1 and (invoice.invoiceType.useForApiCn or invoice.invoiceType.useForApiInv) then
	and invoice.isTASCreditNote or invoice.isTASInvoice then // ### TFS BUG 63257 28MAR2024 NAVAB1
		create pxyRequest transient;
		pxyRequest.setDetails(null, invoice,null, self.myTerminal, BGP_APIWSRequest.Type_Invoice);
		app.myTrxCA.trxCreatePostInvoiceRequest(pxyRequest, bgpRequest, app.myPassport);
	else
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Message not sent, invoice is null", LogERROR);
		return;
	endif;
	
epilog
	delete pxyRequest;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
