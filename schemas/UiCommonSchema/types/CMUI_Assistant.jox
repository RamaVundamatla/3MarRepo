    <JadeMethod name="comboBoxBank" id="12253905-5292-41fa-80eb-86f5e81391c5">
        <source>comboBoxBank(_cmb:ComboBox input; _bank:CM_Bank);
//--------------------------------------------------------------
//Created: August 2002 By: cnwrs1
//--------------------------------------------------------------
vars

begin

	_cmb.listCollection(self.myTerminal.companies, false, 0);

	if _bank &lt;&gt; null and self.myTerminal.companies.includes(_bank) then
		_cmb.text := self.displayEntryBank(_bank);
