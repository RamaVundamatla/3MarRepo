	self.assertEqual(generatorType.description, updateDescription);
	
	//delete GeneratorType Object
	//self.deleteGeneratorType(generatorType);
	//self.assertNotNull(generatorType);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tHSCodes" id="5e5232e9-062e-4f23-9816-ba8016844dda">
        <source>tHSCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 January 2023		jlizm1	Initial creation TFS 56027 HS Code Tests

*/
constants
	SectionCode : String = "00";
	ChapterCode : String = "00";
	HeadingCode : String = "0000";
	HSCodeCode 	: String = "000000";
	SubCodeCode : String = "00000000";
	TaricCode	: String = "0000000000"; //26/02/2023	navkc1 CR 59577 Task 62410
	NewDesc		: String = "Updated Description";
	NewRemarks	: String = "Updated Remarks";
	
vars
	section,
	chapter,
	heading,
	code,
	subcode,
	taricCode,
	pxyHS		: CM_HarmonizedSystem;
	coll 		: CM_HarmonizedSystemSet;
	
begin
	// Clean up before starting test
	self.deleteHSCode(SectionCode, true); // should delete all child hs codes too
	
	// Create codes
	self.opts.purge();
	heading := self.addHSCode(HeadingCode, "UT Heading", "An HS Code chapter created by unit test", CM_HarmonizedSystem.HS_Heading, true);
	self.assertTrxErrorMsg(Related_obj_does_not_exist, "should have errord because no exisitng chapter");
	self.assertTrueMsg(heading = null, "Should not have succeeded in creating a heading");
	
	section := self.addHSCode(SectionCode, "UT Section", "An HS Code section created by unit test", CM_HarmonizedSystem.HS_Section, false);
	self.assertTrueMsg(section &lt;&gt; null, "Failed to create section - " &amp; app.myPassport.getErrorsAsString());
	
	self.opts.purge();
	self.opts.addAssoc("Parent", section);
	chapter := self.addHSCode(ChapterCode, "UT Chapter", "An HS Code chapter created by unit test", CM_HarmonizedSystem.HS_Chapter, true);
	self.assertTrueMsg(chapter &lt;&gt; null, "Failed to create chapter - " &amp; app.myPassport.getErrorsAsString());
	
	self.opts.purge();
	heading := self.addHSCode(HeadingCode, "UT Heading", "An HS Code heading created by unit test", CM_HarmonizedSystem.HS_Heading, true);
	self.assertTrueMsg(heading &lt;&gt; null, "Failed to create heading - " &amp; app.myPassport.getErrorsAsString());
	
	code := self.addHSCode(HSCodeCode, "UT Code", "An HS Code code created by unit test", CM_HarmonizedSystem.HS_Code, true);
	self.assertTrueMsg(code &lt;&gt; null, "Failed to create code - " &amp; app.myPassport.getErrorsAsString());
	
	subcode := self.addHSCode(SubCodeCode, "", "An HS Code subcode created by unit test", CM_HarmonizedSystem.HS_SubCode, true);
	self.assertTrueMsg(subcode = null, "should have failed to create subcode because no description");
	
	subcode := self.addHSCode(SubCodeCode, "UT Subcode", "An HS Code subcode created by unit test", CM_HarmonizedSystem.HS_SubCode, true);
	self.assertTrueMsg(subcode &lt;&gt; null, "Failed to create subcode - " &amp; app.myPassport.getErrorsAsString());
	
	//26/02/2023	navkc1 CR 59577 Task 62410
	taricCode := self.addHSCode(TaricCode, "", "An HS Code Taric Code created by unit test", CM_HarmonizedSystem.HS_Taric, true);
	self.assertTrueMsg(taricCode = null, "should have failed to create taric code because no description");
	
	//26/02/2023	navkc1 CR 59577 Task 62410
	self.opts.purge();
	self.opts.addAssoc("Parent", subcode);
	taricCode := self.addHSCode(TaricCode, "UT Taric Code", "An HS Code Taric Code created by unit test", CM_HarmonizedSystem.HS_Taric, true);
	self.assertTrueMsg(taricCode &lt;&gt; null, "Failed to create Taric code - " &amp; app.myPassport.getErrorsAsString());
	
	
	// Update codes
	beginLoad;
	pxyHS := section.pxyCreateUpdateProxy();
	endLoad;
	pxyHS.setProxy(section.id, NewDesc, false, false, NewRemarks);
	app.myTrxUA.trxUpdateHarmonizedSystem(pxyHS, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(section.description, NewDesc, "section description not updated");
	self.assertEqualMsg(section.remarks, NewRemarks, "section remarks not updated");
	delete pxyHS;
	
	beginLoad;
	pxyHS := chapter.pxyCreateUpdateProxy();
	endLoad;
	pxyHS.setProxy(chapter.id, NewDesc, false, false, NewRemarks);
	app.myTrxUA.trxUpdateHarmonizedSystem(pxyHS, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(chapter.description, NewDesc, "chapter description not updated");
	self.assertEqualMsg(chapter.remarks, NewRemarks, "chapter remarks not updated");
	delete pxyHS;
	
	beginLoad;
	pxyHS := heading.pxyCreateUpdateProxy();
	endLoad;
	pxyHS.setProxy(heading.id, NewDesc, false, false, NewRemarks);
	app.myTrxUA.trxUpdateHarmonizedSystem(pxyHS, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(heading.description, NewDesc, "heading description not updated");
	self.assertEqualMsg(heading.remarks, NewRemarks, "heading remarks not updated");
	delete pxyHS;
	
	beginLoad;
	pxyHS := code.pxyCreateUpdateProxy();
	endLoad;
	pxyHS.setProxy(code.id, NewDesc, false, false, NewRemarks);
	app.myTrxUA.trxUpdateHarmonizedSystem(pxyHS, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(code.description, NewDesc, "code description not updated");
	self.assertEqualMsg(code.remarks, NewRemarks, "code remarks not updated");
	delete pxyHS;
	
	beginLoad;
	pxyHS := subcode.pxyCreateUpdateProxy();
	endLoad;
	pxyHS.setProxy(subcode.id, NewDesc, false, false, NewRemarks);
	app.myTrxUA.trxUpdateHarmonizedSystem(pxyHS, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(subcode.description, NewDesc, "subcode description not updated");
	self.assertEqualMsg(subcode.remarks, NewRemarks, "subcode remarks not updated");
	delete pxyHS;
	
	beginLoad;
	pxyHS := subcode.pxyCreateUpdateProxy();
	endLoad;
	pxyHS.setProxy(subcode.id, "", false, false, NewRemarks);
	app.myTrxUA.trxUpdateHarmonizedSystem(pxyHS, app.myPassport);
	self.assertTrxErrorMsg(Input_required_field_Desc, "should have errord because no description");
	delete pxyHS;
	
	//26/02/2023	navkc1 CR 59577 Task 62410
	beginLoad;
	pxyHS := taricCode.pxyCreateUpdateProxy();
	endLoad;
	pxyHS.setProxy(taricCode.id, NewDesc, false, false, NewRemarks);
	app.myTrxUA.trxUpdateHarmonizedSystem(pxyHS, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(taricCode.description, NewDesc, "taricCode description not updated");
	self.assertEqualMsg(taricCode.remarks, NewRemarks, "taricCode remarks not updated");
	delete pxyHS;
	
	//26/02/2023	navkc1 CR 59577 Task 62410
	beginLoad;
	pxyHS := taricCode.pxyCreateUpdateProxy();
	endLoad;
	pxyHS.setProxy(taricCode.id, "", false, false, NewRemarks);
	app.myTrxUA.trxUpdateHarmonizedSystem(pxyHS, app.myPassport);
	self.assertTrxErrorMsg(Input_required_field_Desc, "should have errord because no description");
	delete pxyHS;
	
	// Activate/Deactivate code
	self.assertFalseMsg(subcode.isActive, "subcode should be inactive");
	create coll transient;
	beginLoad;
	pxyHS := subcode.pxyCreateUpdateProxy();
	endLoad;
	coll.add(pxyHS);
	app.myTrxUA.trxUpdateHarmonizedSysActivate(coll, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(subcode.isActive, "subcode should be active");
	
	app.myTrxUA.trxUpdateHarmonizedSysActivate(coll, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertFalseMsg(subcode.isActive, "subcode should be inactive again");
	
	// Delete codes
	
	//26/02/2023	navkc1 CR 59577 Task 62410
	self.assertNotNullMsg(taricCode, "taricCode");
	self.deleteHSCode(TaricCode, false);
	
	self.assertNotNullMsg(subcode, "subcode");
	self.deleteHSCode(SubCodeCode, false);
	
	self.assertNotNullMsg(code, "code");
	self.deleteHSCode(HSCodeCode, false);
	
	self.assertNotNullMsg(heading, "heading");
	self.deleteHSCode(HeadingCode, false);
	
	self.assertNotNullMsg(chapter, "chapter");
	self.deleteHSCode(ChapterCode, false);
	
	self.assertNotNullMsg(section, "section");
	self.deleteHSCode(SectionCode, true);
	
epilog
	delete pxyHS;
	delete coll;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tIMEXStatuses" id="83d3382a-4d84-4352-be2a-429ef5e3c958">
        <source>tIMEXStatuses();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53083 GPHA revceival/release of tranship cargo

*/

vars

	pxyImexStatus	: CM_IMEXStatus;
	realImexStatus	: CM_IMEXStatus;
	existingAllowIMTransitValue : Boolean;
	shouldReset		: Boolean;
	
begin
	
	realImexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
	
	self.assertNotNullMsg(realImexStatus, "Tranship IMEX Status object");
	
	//Store existing values to restore at end of test
	existingAllowIMTransitValue := realImexStatus.allowInterModalTransit;
	shouldReset := true;
	
	//---------------------------------------
	// Set setAllowInterModalTransit to false
	//---------------------------------------
	pxyImexStatus := app.createUpdateProxy(realImexStatus).CM_IMEXStatus;
	pxyImexStatus.setProxyForUpdate(realImexStatus.abbreviation, realImexStatus.description, realImexStatus.colour);
	pxyImexStatus.setAllowInterModalTransit(false);
	
	app.myTrxUA.trxUpdateCargoStatus(pxyImexStatus, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyImexStatus;
	
	realImexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
	self.assertTrueMsg(realImexStatus &lt;&gt; null, "Tranship IMEX Status object unable to be found after first update");
	self.assertTrueMsg(realImexStatus.allowInterModalTransit = false, "Tranship IMEX Status allowInterModalTransit not set to false");
	
	
	//---------------------------------------
	// Set setAllowInterModalTransit to true
	//---------------------------------------
	pxyImexStatus := app.createUpdateProxy(realImexStatus).CM_IMEXStatus;
	pxyImexStatus.setProxyForUpdate(realImexStatus.abbreviation, realImexStatus.description, realImexStatus.colour);
	pxyImexStatus.setAllowInterModalTransit(true);
	
	app.myTrxUA.trxUpdateCargoStatus(pxyImexStatus, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyImexStatus;
	
	realImexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
	self.assertTrueMsg(realImexStatus &lt;&gt; null, "Tranship IMEX Status object unable to be found after second update");
	self.assertTrueMsg(realImexStatus.allowInterModalTransit = true, "Tranship IMEX Status allowInterModalTransit not set to true");

	
epilog
	// reset to original values
	if shouldReset then
		realImexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
		if realImexStatus &lt;&gt; null then
			beginTransaction;
			realImexStatus.setPropertyValue("allowInterModalTransit", existingAllowIMTransitValue);
			commitTransaction;
		endif;
	endif;
	
	delete pxyImexStatus;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tISOType" id="bc4b0ca9-497f-4d72-9250-85ce174a07c9">
        <source>tISOType();

/*

Purpose:		Create / Update / Delete ISO Type

Date			Who		Reason
25/02/2014		cnwmh5	Initial creation
//02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
*/

vars

	isoType					: CM_ISOType;
	file					: File;
	
	description				: String;
	isoCode					: String;

begin

	isoCode := "MH20";

	isoType := self.addISOType(isoCode, "Michael's UT 20Ft ISO Type", app.myRoot.allCargoTypesById[TI_CargoType_Container], 
		true, false, false, false, false, false, false, false, false, false, false, true, false, false, false, false, true, 
		false, false, false, false, false, false, 2200);
	self.assertNotNull(isoType);
	
	// update iso type
	description := isoType.description;
	self.opts.purge();
	self.opts.addAssoc("Description", description  &amp; ' Changed');
	self.updateISOType(isoType);
	self.assertEqual(isoType.description, description  &amp; ' Changed');
	
	// import from file
	self.deleteISOType(isoCode);
	file := self.xISOTypeImportFile(isoCode);
	file.mode := File.Mode_Input;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.kind := File.Kind_Unknown_Text;
	
	app.myTrxCA.trxImportISOTypeFromFile(file, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	isoType := self.getISOType(isoCode);
	self.assertNotNull(isoType);

epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="tISOTypeGroup" id="c8e4810a-0383-4541-974b-6d37990b7577">
        <source>tISOTypeGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2014	cnwma1	Initial creation
//02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
*/
constants
	ISOTypeGroupCode	: String = "UTGR";
	ISOTypeDesc		: String = "Unit Test Iso Type Group";
	ISOType			: String = "FOUO";
vars
	isoTypeGroup 		: CM_ISOTypeGroup;
	isoTypeGroupDesc	: String;
	isoType				: CM_ISOType;
	isotypecoll			: CM_ISOTypeByCodeDict;
	isoTypeGroupSub		: CM_ISOTypeGroupByCodeDict;
begin

	// Create Iso Type
	isoType := self.addISOType(ISOType,
					"Unit Test Iso Type",app.myRoot.allCargoTypesById[TI_CargoType_Container], 
					true, false, false, false, false, false, false, false, false, false, false, true, false, false, false, false, true, 
					false, false, false, false, false, false, 2200);
	self.assertNotNull(isoType);

	create isotypecoll transient;
	isotypecoll.add(app.myRoot.allISOTypes[ISOType]);
	create isoTypeGroupSub transient;
	isoTypeGroupSub.add(app.myRoot.allISOTypeGroups["GEN2"]);
	//Create Iso Type Group
	isoTypeGroup := self.addISOGroup(ISOTypeGroupCode,ISOTypeDesc,isotypecoll,isoTypeGroupSub);
	self.assertNotNull(isoTypeGroup);
	
	// update ShippingLine
	isoTypeGroupDesc := isoTypeGroup.description &amp; "_UP_UT";
	self.opts.purge();
	self.opts.addAssoc("ISOTypeDesc", isoTypeGroupDesc);
	self.updateISOTypeGroup(isoTypeGroup);
	self.assertEqual(isoTypeGroup.description, isoTypeGroupDesc);
	
					
epilog
	delete isotypecoll;
	delete isoTypeGroupSub;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tImportUsers" id="fb2673d1-8e2d-41f0-9ce9-e9406f50aeb9">
        <source>tImportUsers();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2025	navlw1	Jira-35884: 34574.014 - Provide User Name and Single Sign On Matching ID import functionality
05 November 2025	navlw1	JIRA-36369: Add a new status “PENDING” for users and use this status for new imported users  
07 Novemeber 2025	navlw1	JIRA-36547:	Validation is not displaying and the system allows creating a new user without a 'System Security Role' value
*/
constants
User1 				= "UTUSER1";
User2 				= "UTUSER2";
User3 				= "UTUSER3";
User4Code 			= "UTUSER4";
User4Name 			= "UTUSER4";
SingleSignOnId		= "user3@mtn.navis.com";
SingleSignOnId4		= "user4@mtn.navis.com";
SSOUpdate			= "user4@mtn.navis.co.nz";
Organisation 		= "Navis NZ Ltd";
vars
	file					: File;
	user,
	pxyUser					: CM_User;
	singleSignOnMatchingId	: String;
	setState				: Boolean;
begin
	self.deleteUser(User1);
	self.deleteUser(User2);
	self.deleteUser(User3);
	
	self.addUser(User4Code,User4Name);
	user := app.myRoot.allUsers[User4Code];
	self.assertNotNullMsg(user, "Could not find user");
	
	// set the SSO after we created the pxy based of user 4
	app.cmsBeginLoad(setState);
	pxyUser := user.pxyCreateUpdateProxy;
	app.cmsEndLoad(setState);
	pxyUser.setSSOMatchingId(SingleSignOnId4); // this will set the SSO
	
	app.myTrxUA.trxUpdateUser(pxyUser, "password", app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	user := app.myRoot.allUsers[User4Code];
	self.assertNotNullMsg(user.ssoMatchingId, "SSO Matching Id not set");
	self.assertEqualMsg(user.ssoMatchingId, SingleSignOnId4, "User SSO Id should match");
	
	// TEST 1 create 3 users
	app.writeLog("Test 1 - Create 3 Users", LogINFO);
	file := self.xUserImportFile(Organisation, "System Root");
	file.mode := File.Mode_Input;
	file.kind := File.Kind_Unknown_Text;
	
	app.myTrxCA.trxImportUsersFromFile(file, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	user := app.myRoot.allUsers[User1];
	self.assertNotNullMsg(user, "Could not find user");
	app.writeLog(User1 &amp; " has been created", LogINFO);
	self.assertEqualMsg(user.code, User1, "User code should match");
	self.assertNotNullMsg(user.myOrganisation, "User Organistaion is null");
	self.assertEqualMsg(user.myOrganisation.name, Organisation, "User Organistaion should match");
	self.assertEqualMsg(user.status, PendingUser, "Status should be set as Pending User");
	self.assertEqualMsg(user.mySystemSecurityRole.name, "System Root", "System Security Role should match");
	
	user := app.myRoot.allUsers[User2];
	self.assertNotNullMsg(user, "Could not find user");
	app.writeLog(User2 &amp; " has been created", LogINFO);
	self.assertEqualMsg(user.code, User2, "User code should match");
	app.writeLog(User2 &amp; " Matches Code " &amp; user.code, LogINFO);
	self.assertNotNullMsg(user.myOrganisation, "User Organistaion is null");
	self.assertEqualMsg(user.myOrganisation.name, Organisation, "User Organistaion should match");
	self.assertEqualMsg(user.status, PendingUser, "Status should be set to Pending User");
	self.assertEqualMsg(user.mySystemSecurityRole.name, "System Root", "System Security Role should match");
	
	user := app.myRoot.allUsers[User3];
	self.assertNotNullMsg(user, "Could not find user");
	app.writeLog(User3 &amp; " has been created", LogINFO);
	self.assertEqualMsg(user.code, User3, "User code should match");
	app.writeLog(User3 &amp; " Matches Code " &amp; user.code, LogINFO);
	self.assertNotNullMsg(user.myOrganisation, "User Organistaion is null");
	self.assertEqualMsg(user.myOrganisation.name, Organisation, "User Organistaion should match");
	self.assertEqualMsg(user.status, PendingUser, "Status should be set to Pending User");
	self.assertEqualMsg(user.mySystemSecurityRole.name, "System Root", "System Security Role should match");
	
	// TEST 2 update user SSO Matching Id
	delete file;
	delete pxyUser;
	app.writeLog("Test 2 - Update User 3 with Single Sign on Matching Id", LogINFO);
	file := self.xImportUpdateUser();
	file.mode := File.Mode_Input;
	file.kind := File.Kind_Unknown_Text;
	
	app.myTrxCA.trxImportUsersFromFile(file, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	user := app.myRoot.allUsers[User3];
	self.assertNotNullMsg(user, "Could not find user");
	singleSignOnMatchingId := user.ssoMatchingId;
	self.assertNotNullMsg(singleSignOnMatchingId, "SSO Matching Id not set");
	self.assertEqualMsg(user.ssoMatchingId, SingleSignOnId.toLower(), "User SSO Id should match");
	self.assertEqualMsg(user.status, PendingUser, "Status should be set to Pending User");
	app.writeLog("User " &amp; User3 &amp; " should have SSO matching id set " &amp; singleSignOnMatchingId, LogINFO);
	
	// check that we have updated the user SSO matching Id correctly
	user := app.myRoot.allUsers[User4Code];
	self.assertNotNullMsg(user, "Could not find user");
	singleSignOnMatchingId := user.ssoMatchingId;
	self.assertNotNullMsg(singleSignOnMatchingId, "SSO Matching Id not set");
	self.assertEqualMsg(user.ssoMatchingId, SSOUpdate.toLower(), "User SSO Id should match");
	
	// TEST 3 No Organistation field set in the input file expect to have errors returned
	app.writeLog("Test 3 - No Organistation field set in the input file expect to have errors returned", LogINFO);
	delete file;
	self.deleteUser(User1);
	self.deleteUser(User2);
	self.deleteUser(User3);
	user := app.myRoot.allUsers[User1];
	self.assertNull(user);
	
	// pass in no organistation
	file := self.xUserImportFile("", "System Root");
	file.mode := File.Mode_Input;
	file.kind := File.Kind_Unknown_Text;
	
	app.myTrxCA.trxImportUsersFromFile(file, app.myPassport);
	self.assertTrxErrorMsg(Input_required_field_org,"");
	self.assertEqualMsg(app.myPassport.allErrors.size,2, "Should have two passport errors");
	app.writeLog("Expected error: User ID : " &amp; User3 &amp; " Code :89110. An input is required for the Organisation field.", LogINFO);
	
	// Start navlw1 JIRA-36547 07/11/25
	// TEST 4 No System Security Role not set in file
	app.writeLog("Test 4 - No System Security Role field set in the input file expect to have errors returned", LogINFO);
	delete file;
	self.deleteUser(User1);
	self.deleteUser(User2);
	self.deleteUser(User3);
	
	user := app.myRoot.allUsers[User1];
	self.assertNull(user);
	
	// pass in no System Security Role
	file := self.xUserImportFile(Organisation, "");
	file.mode := File.Mode_Input;
	file.kind := File.Kind_Unknown_Text;
	
	app.myTrxCA.trxImportUsersFromFile(file, app.myPassport);
	self.assertTrxErrorMsg(User_Security_Role_Not_Set,"");
	self.assertEqualMsg(app.myPassport.allErrors.size,1, "Should have one passport error");
	app.writeLog("Expected error: User ID : " &amp; User3 &amp; " Code :96966. System Security Role has not been set", LogINFO);
	// End navlw1 JIRA-36547 07/11/25
epilog
	delete pxyUser;
	delete file;
end;</source>
    </JadeMethod>
