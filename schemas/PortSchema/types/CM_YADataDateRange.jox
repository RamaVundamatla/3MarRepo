// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	return self.startDate.asStringJMT &amp; "|" &amp; self.endDate.asStringJMT;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
