    <JadeMethod name="doSendToReport" id="ac6916f5-ce8e-49af-8c02-0cea3824296e">
        <source>doSendToReport(_objArray : ObjectArray);
// after 8.3.2 financial reporting for invoice lines
vars
	jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	arrayCheck		: ObjectArray;
	pathList		: StringArray;
	obj				: Object;
	outputType		: Integer;
	filePath		: String;
begin
	if _objArray.isEmpty() then
		app.msgBox(app.getErrorString(NoInvoiceLinesForReport), app.getErrorString(NoInvoiceLinesForReport), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	create pathList transient;
	pathList.add("allInvoiceLines");
	//Get the report we want to send our invoice items to and find out whether we want a print preview.
	if app.getReportToSendItems(CM_InvoiceView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then
		//Have to ensure we don't have multiples so check this out here.
		create arrayCheck transient;
		foreach obj in _objArray do
			if arrayCheck.includes(obj) then
				continue;
			endif;
			
			arrayCheck.add(obj);
		endforeach;
		
		app.sendItemsToReport(CM_JRWInvoice, arrayCheck, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	delete arrayCheck;
	delete pathList;
end;</source>
        <Parameter name="_objArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doShowInvoice" id="626c9bc7-6d55-4590-920b-0d2d92f1b6a7">
        <source>doShowInvoice();
// show invoice from line, for toolbar button and context menu
vars
	theInv : CM_Invoice;
begin
	theInv := self.myCurrentInvoice;
	if theInv = null 
	and self.myCurrentInvoiceLine &lt;&gt; null then
		theInv := self.myCurrentInvoiceLine.invoice;
	endif;
	
	if theInv = null then
		app.msgBox("Please select an invoice line.","Invoice Warning",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.myAssistant.INV_Assistant.showInvoiceListForm(theInv, self.myMasterMenuAction, false);		

end;</source>
    </JadeMethod>
