    <JadeMethod name="tableHasDelays" id="e4dd6f78-a270-4934-a90f-48b6d25b9af8">
        <source>tableHasDelays(_table :Table input; _row, _col :Integer):Boolean;
/*
Date		Who		Reason
17 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	obj		:Object;
	result	:Boolean;
	kpi		:CM_KPIVoyageEntity;
	detail	:CM_KPIVoyageMoveDtl;
begin
	if _table &lt;&gt; self.myTable then
		// can't change table
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot change KPI table');
	endif;
	
	obj := _table.accessCell (_row, _col).itemObject;
	
	if obj &lt;&gt; null and  obj.isKindOf (CM_KPIVoyageEntity) then
		if not obj.CM_KPIVoyageEntity.allDelays.isEmpty then
			result := true;
		endif;
	elseif obj.isKindOf (CM_KPIVoyageMoveDtl) then
		kpi := obj.CM_KPIVoyageMoveDtl.myKPIVoyageEntity;
			
		result := kpi.allDelays.size &lt;&gt; 0;	
		
	elseif obj &lt;&gt; null and obj.isKindOf (Collection) and not obj.Collection.isEmpty then
		if obj.Collection.first.isKindOf (CM_Delay) then
			result := true;
		elseif obj.isKindOf (CM_KPIVoyageMoveDtlDict) then
			foreach detail in obj.CM_KPIVoyageMoveDtlDict do
				kpi := detail.myKPIVoyageEntity;
				
				if kpi.allDelays.size &lt;&gt; 0 then
					result := true;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
