    <JadeMethod name="sysNotify" id="eaeee233-1cc5-4331-81da-fec5dfceab33">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2011	cnwndl1	Initial creation	Par 28797

*/

constants

	MinimumTimerDelay	= 1000;
	
vars

	theTI : CM_TrackedItem;
	iter : Iterator;
	sumObject : CMIF_LoadListSummaryObject;
	rowIndex : Integer;
	obj : Object;
	randomNumber : Integer;
	
begin

	if eventType = Object_Delete_Event and theObject.isKindOf(CM_TrackedItem) then
	
		theTI := theObject.CM_TrackedItem;
		if self.allTIsSummaryUpdate.includes(theTI) then
			self.allTIsSummaryUpdate.remove(theTI);
		endif;
		
		self.tblData.removeItemObject(theTI);
		self.tblPlanned.removeItemObject(theTI);
		self.tblAll.removeItemObject(theTI);
		
		// this occurs if the 'All' table has not been displayed yet
		if self.tblAll.allTableObjects.includes(theTI) then
			self.removeInvalidObjectFromTblAll( theTI );
		endif;
	
		if self.mySummaryReport &lt;&gt; null then
			iter := self.mySummaryReport.allCMIFTransients.createIterator;
			while iter.next( sumObject ) do
				if sumObject.removeDeletedTi( theTI ) then
					if self.tblSummary.findObjectInRow(sumObject,rowIndex) then
						if rowIndex &gt; self.tblSummary.fixedRows and rowIndex &lt;= self.tblSummary.rows then
							self.tblSummary.setCellText( rowIndex, 1, sumObject.getReportTableDisplay );
						endif;
					endif;
				endif;
			endwhile; 
			delete iter;
			iter := self.mySummaryReport.allGroupedObjects.createIterator;
			while iter.next( sumObject ) do
				if sumObject.removeDeletedTi( theTI ) then
					if self.tblSummary.findObjectInRow(sumObject,rowIndex) then
						if rowIndex &gt; self.tblSummary.fixedRows and rowIndex &lt;= self.tblSummary.rows then
							self.tblSummary.setCellText( rowIndex, 1, sumObject.getReportTableDisplay );
						endif;
					endif;
				endif;
			endwhile; 
			delete iter;
		endif;
		
		//24 May 2012	NDL	Par 29001
		if not self.startedTimer then
			randomNumber := 0;
			randomNumber := app.random(10)  * 100;
			randomNumber := MinimumTimerDelay + randomNumber;
			self.beginTimer(randomNumber, Timer_OneShot, 1);
			self.startedTimer := true;
		endif;
		
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
