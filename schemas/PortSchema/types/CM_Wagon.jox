    <JadeMethod name="setForCreate" id="2f1924f3-2ecd-45a8-9afb-a429e5ab2529">
        <updating/>
        <source>setForCreate( _moveController : CMIF_WagonMoveController;  pProxyWagon:CM_Wagon input) updating; // ; lWagonPosition : CMIF_TIWagonPosition input
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
//	lLoc	: Integer;
//	lNewController, lPreviousController	: CM_WagonController;
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;
	
	self.myTerminal := pProxyWagon.myTerminal;
	
	self.setForUpdate( _moveController, pProxyWagon);
	
//	self.setMyWagonMaster(null);
	if self.myWagonMaster &lt;&gt; null  then
		self.myWagonMaster.copyDamageToNewWagon( _moveController, self);
	endif;

	self.createTransaction( effectiveDate, EVT_WagonCreate, null, null, null, true, null, null, null);
	// PAR 21740 self.causeEvent(self.myTerminal.getTerminalEvent(Wagon_Create_Event), false, self);
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(Wagon_Create_Event), self);		// PAR 21740 			

	if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then // ### TFS 51855 05JAN2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_WAGON, self); // ### TFS 51855 05JAN2022 NAVAB1
	endif;
end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="pProxyWagon" type="CM_Wagon" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fe12b688-1efe-45fe-aa62-1501d50cf371">
        <updating/>
        <source>setForUpdate( _moveController : CMIF_WagonMoveController; pProxyWagon:CM_Wagon input) updating; // ; pWagonContainer : CMIF_TIWagonPosition input
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 02/10/2020   cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
// 26/02/2021   cnwma1      Bug 50855: ASPA - Edit Departed Wagon gives Exception
// 25/07/2022	jlika1	TFS 54050 EUP  - Max Wagon Payload
// ---------------------------------------------------------------------------
vars
	resetWagonMaster : Boolean;
	pos : Integer;
	lc : CM_LocationsController;
	lPreviousController,lNewController : CM_WagonController;
	lLoc : Integer;
	oldId : String;
	newDamageInstance, damageInstance : CM_DamageInstance;
	wc : CM_WagonController;
	existingWagon : CM_Wagon;
	wagControl : CMIF_WagonMoveController;// PAR 26445
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837

	isUpdate : Boolean;
	allowWagonWeights : Boolean;
	invalidObject	  : Boolean;
begin
	isUpdate := pProxyWagon.pxyGetRealObject() &lt;&gt; null; // ### TFS 51855 06JAN2022 NAVAB1
	
	//jlier1 TFS 56772 21/3/22
	if self.getMyTerminal &lt;&gt; null then
		allowWagonWeights := self.getMyTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;
	endif;
	
	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	create wagControl transient;
	wagControl.autoSetEffectiveTimeStamp();
	if wagControl.effectiveTimeStamp.isValid then
		effectiveDate := wagControl.effectiveTimeStamp;
	elseif _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;
	

	//The user is allowed to change the wagon class.  If this happens we may need to add/delete location controllers 
	if pProxyWagon.myWagonClass &lt;&gt; null then
		// we don't want to ever set the wagon class to null.
		if self.myWagonClass &lt;&gt; null then
			// we are updating an existing wagon.
			if self.myWagonClass &lt;&gt; pProxyWagon.myWagonClass then
				// we are changing the wagon class.
				if self.myWagonClass.wagonType &lt;&gt;  pProxyWagon.myWagonClass.wagonType then
					app.raiseCMException2(Not_chang_from_wagon_class_typ, self.myWagonClass.getWagonTypeString,pProxyWagon.myWagonClass.getWagonTypeString, null, null);
				endif;
				
				self.setForUpdateWagonClass(pProxyWagon);	//02 Apr 2013	NDL	Par 31278 - code moved to separate method
				
			endif; 
		endif;
		self.myWagonClass := pProxyWagon.myWagonClass;
	endif;
	
	
	//14 Oct 2009	NDL	Par 20979
	//If there are no associated tracked items, the user is allowed to change the wagon id, if they do this,
	//we need to rename the loaction controllers.
	if not self.isTransient and not self.hasTrackedItems and self.id &lt;&gt; null and self.id &lt;&gt; pProxyWagon.id then
		foreach pos in 1 to self.myWagonClass.getLenInUnits do
			wc := self.allLocationsControllersArray[pos];
			wc.resetId(pProxyWagon.id &amp; self.myWagonClass.locationIds[pos].trimBlanks);
		endforeach;
		// 26.02.2021  cnwma1 #50855
		if self.getTerminal() &lt;&gt; null then
			self.causeEvent(self.getTerminal().getTerminalEvent(Wagon_Delete_Event),false,self);
		endif;
	endif; 
	

	if self.myTrainInwards &lt;&gt; null and pProxyWagon.myTrainInwards = null then
		self.createTransaction( effectiveDate, EVT_WagonRemove, self.myTrainInwards, null, null, true, null, null, null);
	endif;
	if self.myTrainOutwards &lt;&gt; null and pProxyWagon.myTrainOutwards = null then
		self.createTransaction( effectiveDate, EVT_WagonRemove, self.myTrainOutwards, null, null, false, null, null, null);
	endif;
	
	resetWagonMaster	 := self.id &lt;&gt; pProxyWagon.id; // 28 Jul 2009 - either the id has changed or we are creating a new one.
	oldId				 := self.id;
	self.id 			 := pProxyWagon.id;
	self.myCarrier 		 := pProxyWagon.myCarrier;

	if self.myCarrier = null then // PAR 21175 default to wagon class if the train does not have a carrier
		if self.myTrainInwards &lt;&gt; null then
			self.myCarrier := self.myTrainInwards.myCarrier; // this can be defaulted to the TERMINALS configd carrier
		endif;
		if self.myCarrier = null then 
			if self.myWagonMaster &lt;&gt; null then
				if self.myWagonMaster.myCarrier &lt;&gt; null then 
					on Exception do app.handleDeletedObject( exception, self.myWagonMaster.myCarrier, invalidObject);// No inverse need to check for invalidobject			
					if not invalidObject then
						self.myCarrier := self.myWagonMaster.myCarrier;
					endif;	
				endif;
			endif;
			if self.myCarrier = null then 
				if self.myWagonClass &lt;&gt; null then
					self.myCarrier := self.myWagonClass.myCarrier; // With Inverse no need to check for invalidobject
				endif;
			endif;
		endif;
	endif;
	
	self.myStevedoreReceive    := pProxyWagon.myStevedoreReceive;    //02.10.2020 cnwma1 TFS #50112
	self.myStevedoreRelease    := pProxyWagon.myStevedoreRelease;    //02.10.2020 cnwma1 TFS #50112
	self.remarks 			   := pProxyWagon.remarks;
	self.myDestinationTerminal := pProxyWagon.myDestinationTerminal; // TFS 2533
	
	if allowWagonWeights then
		self.maxCargoWeight		   := pProxyWagon.maxCargoWeight;
		self.tareWeight		   	   := pProxyWagon.tareWeight;
		if self.myWagonMaster &lt;&gt; null then
			self.myWagonMaster.setMaxCargoWeight(self.maxCargoWeight);
			self.myWagonMaster.setTareWeight(self.tareWeight);
		endif;
	endif;	

	if pProxyWagon.myTrainInwards = null then
		self.myTrainInwards := null;	// inverse automatically removes wagon from inwards train
	elseif self.myTrainInwards &lt;&gt; pProxyWagon.myTrainInwards then
	
		//25 Feb 2009	NDL Par 22469
		existingWagon := pProxyWagon.myTrainInwards.allWagonsByIdInward.getAtKey(pProxyWagon.id);
		if existingWagon &lt;&gt; null and existingWagon &lt;&gt; self then
			app.raiseCMException2(Wagon_with_alread_exists_train, self.id, pProxyWagon.myTrainInwards.getCodeDateString, null, null);
		endif;
		
		pProxyWagon.myTrainInwards.addWagon( _moveController, true, self, 0);
	endif;
	
	if pProxyWagon.myTrainOutwards = null then
		self.myTrainOutwards := null;	// inverse automatically removes wagon from outwards train
	elseif self.myTrainOutwards &lt;&gt; pProxyWagon.myTrainOutwards then
		
		//25 Feb 2009	NDL Par 22469
		existingWagon := pProxyWagon.myTrainOutwards.allWagonsByIdOutward.getAtKey(pProxyWagon.id);
		if existingWagon &lt;&gt; null and existingWagon &lt;&gt; self then
			app.raiseCMException2(Wagon_with_alread_exists_train, self.id, pProxyWagon.myTrainOutwards.getCodeDateString, null, null);
		endif;
		
		pProxyWagon.myTrainOutwards.addWagon( _moveController, false, self, 0);
		
		// PAR 26445 This wagon was inward on train A but is being edited to be outward on train B.
		 // 				Train B has a jobsheet of release jobs, the jobs need to be moved to the rail area job sheet so that they can be worked.
		if self.confirmed // INWARD
		and self.myRailLine &lt;&gt; null 
		and self.myTrainOutwards.myJobSheet &lt;&gt; null // train job sheet is only used for planning release jobs
		and not self.myTrainOutwards.myJobSheet.allJobsByOrder.isEmpty() then // still has release jobs
		 
			create wagControl transient; // PAR 26445
			wagControl.myTargetRailLine := self.myRailLine;
			wagControl.allWagons.add(self);
			wagControl.setEffectiveTimeStampOverride( effectiveDate );
			self.myTrainOutwards.moveOutwardJobsToRail(wagControl, app.myPassport);
		endif;
	endif;
	
	if resetWagonMaster then
		self.setMyWagonMaster(null,oldId);
	endif;
	
	if allowWagonWeights then
		if self.myWagonMaster &lt;&gt; null then
			if self.maxCargoWeight &lt;&gt; null then
				self.myWagonMaster.setMaxCargoWeight(self.maxCargoWeight);
			endif;
			
			if self.tareWeight &lt;&gt; null then
				self.myWagonMaster.setTareWeight(self.tareWeight);
			endif;
		endif; 
	endif;
	
	self.allDamageInstanceByPos.purge;
	foreach damageInstance in pProxyWagon.allDamageInstanceByPos do
		damageInstance.validateForUpdate();
		create newDamageInstance persistent;
		newDamageInstance.setForUpdateSubject(damageInstance,self);	
		if self.getExistingDamageTrx( damageInstance ) = null then	// 15 Jun 2011	NDL	Par 27543
			self.createTransaction( effectiveDate, EVT_WagonDamaged, newDamageInstance, null, null, true, null, null, null);
		endif;
	endforeach;
	
	self.setAllWagonSeals(pProxyWagon.allWagonSeals);	//10 Mar 2015	NDL	Par 35828

	//cnwjo3 par 22810.  If we have gotten this far then we know some kind of updating
	//has occurred on the wagon.  throw event for captuping on forms
	
	// 26.02.2021  cnwma1 #50855
	if self.getTerminal() &lt;&gt; null then   
		self.causeEvent(self.getTerminal().getTerminalEvent(Wagon_Update_Event), false, self);
	endif;
	
	if isUpdate
	and app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then // ### TFS 51855 05JAN2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_WAGON, self); // ### TFS 51855 05JAN2022 NAVAB1
	endif;
	
epilog
	delete wagControl;// PAR 26445
end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="pProxyWagon" type="CM_Wagon" usage="input"/>
    </JadeMethod>
