    <JadeMethod name="getReserveDetail" id="14719102-8658-4088-83a7-3317f8fccb96">
        <source>getReserveDetail() : CM_ReserveDetail;
/*
Purpose:	

Date		Who		Reason
27 December 2023	navab1	CR 58499 TASK 61455
*/

vars
	reserve : CM_ReserveDetail;
	wodtl : CM_WorkOrderDtl;
	wodrel : CM_WodRelease;
	req : CM_Request;
begin
	
	wodtl := self.getMyWorkOrderDtl();
	
	if wodtl &lt;&gt; null then
		if wodtl.isWodRelease then
			wodrel := wodtl.CM_WodRelease;
			reserve := wodrel.myReserveDetail.CM_ReserveSelection;
		endif;
	endif;

	if reserve = null then
		req := self.allRequests.first;
		if req &lt;&gt; null then
			reserve := req.myReserveDetail;
		endif;
	endif;
	
	return reserve;
	
epilog

end;</source>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="getRowColour" id="9f58004d-7b09-4b01-9cf1-27d2d2d7b865">
        <source>getRowColour(_foreColour : Integer output; _backColour : Integer output);
//--------------------------------------------------------------
//Created: 07 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	isRelease : Boolean;
begin
	_backColour := White;
	_foreColour := Black;
	
	isRelease := self.isRelease;
	if self.status = JOB_UNACTIONED then
		if isRelease then
			_foreColour := CM_Job.Colour_ReleaseUnactioned;
		else
			_foreColour := CM_Job.Colour_ReceiptUnactioned;		
		endif;
	elseif self.status = JOB_PART_COMPLETE then
		if isRelease then
			_foreColour := CM_Job.Colour_ReleasePartComplete;
		else
			_foreColour := CM_Job.Colour_ReceiptPartComplete;		
		endif;
	elseif self.status = JOB_COMPLETE then
		if isRelease then
			_backColour := CM_Job.Colour_ReleaseComplete;
		else
			_backColour := CM_Job.Colour_ReceiptComplete;		
		endif;
		_foreColour := White;			
	else
		_foreColour := White;			
		_backColour := Mauve;				
	endif;
			
					
end;</source>
        <Parameter name="_foreColour" type="Integer" usage="output"/>
        <Parameter name="_backColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getRowColourForWorkPoint" id="f5533580-ff06-422c-be34-74952fdf3ce0">
        <source>getRowColourForWorkPoint(isForUnallocatedTbl : Boolean):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
15 Sep 2023 navlc30 ChangeRequest 60211: EUP | Delivery Dispatch Colour Legend
25 Sep 2023 navhl20 Bug 60655: EUP | 53729 - Delivery Dispatch Screen - initial feedback
16 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
*/

vars
	vvr 	: CM_VehicleVisitRecord;
	time	: Integer;
	vehicle	: CM_Vehicle;
begin
	time := self.getMyTerminal().getConfig(GateElapsedTimeExceeded).Integer;
	
	if isForUnallocatedTbl then													//15.9.2023 navlc30 #60211
		if self.status = JOB_UNACTIONED then
			if self.dwellTime &gt; time then
				return LightRed;
			endif;
		else
			return White;
		endif;																	//15.9.2023 navlc30 #60211
	else 	
		if self.status = JOB_PART_COMPLETE then
			return LightYellow;
		elseif self.status = JOB_COMPLETE then
			return PaleGreen;
		elseif self.status = JOB_UNACTIONED then
			if self.isRoadJob then
				vvr := self.CM_RoadJob.myVehicleVisit;
				if vvr &lt;&gt; null then
					vehicle := self.CM_RoadJob.myVehicle;
					if vehicle &lt;&gt; null then
						if not vehicle.myPrimaryActualLocation.isInsideYard then			//16.10.2023 navhl20 #60863
							return LightBlue; 
						endif;
					endif;
				endif;
			endif;
			if self.dwellTime &gt; time then
				return LightRed;
			endif;
			return LightOrange;
		endif;
	endif;																		//15.9.2023 navlc30 #60211	
	return White;																//15.9.2023 navlc30 #60211
epilog

end;</source>
        <Parameter name="isForUnallocatedTbl" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
