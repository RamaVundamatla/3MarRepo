    <JadeMethod name="xCreateCustomsAction" id="da02ab20-5950-40f3-a05e-ff1d2399c359">
        <source>xCreateCustomsAction(_actionName : String; _actionKeyword, _actionKeyField, _actionType, _roleCode : String; _actionObject : CM_Object) : CM_EDIAction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2023	navpw1	Initial creation TFS: 61364 (61375)

*/

vars
	pxyCustomsAction,
	realCustomsAction	: CM_EDIAction;
	
begin
	create pxyCustomsAction transient;
	pxyCustomsAction.setProxy(_actionName, _actionKeyword, _actionKeyField, _actionType, _actionObject, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, _roleCode);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction, realCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction, "realCustomsAction");
	return realCustomsAction;
	
epilog
	delete pxyCustomsAction;
	
end;</source>
        <Parameter name="_actionName" type="String"/>
        <Parameter name="_actionKeyword" type="String"/>
        <Parameter name="_actionKeyField" type="String"/>
        <Parameter name="_actionType" type="String"/>
        <Parameter name="_roleCode" type="String"/>
        <Parameter name="_actionObject" type="CM_Object"/>
        <ReturnType type="CM_EDIAction"/>
    </JadeMethod>
    <JadeMethod name="xCreateHMSResourceType" id="6ef63931-e4b9-4cc8-bde7-3199f141bdbb">
        <source>xCreateHMSResourceType(_code 				: String;
				    _isQuantityRequired : Boolean;
					_quantityUnits		: String)  : HMS_ResourceType;
/*

Purpose:			
		Pending Require set proxy
Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	pxyHMSResourceType 			: HMS_ResourceType;
	resourceType				: HMS_ResourceType;
begin
	self.xDeleteResourceType(_code);
	
	create pxyHMSResourceType transient;
	pxyHMSResourceType.setProxy(app.myRoot);
	pxyHMSResourceType.setPropertyValue("code"					, _code);
	pxyHMSResourceType.setPropertyValue("description"			, _code);
	pxyHMSResourceType.setPropertyValue("isQuantityRequired"	, _isQuantityRequired);
	pxyHMSResourceType.setPropertyValue("quantityUnits"			, _quantityUnits);
	
	app.myTrxCA.trxCreateHMSResourceType(pxyHMSResourceType, resourceType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return resourceType;
epilog
	delete pxyHMSResourceType;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_isQuantityRequired" type="Boolean"/>
        <Parameter name="_quantityUnits" type="String"/>
        <ReturnType type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="xCreateHarbourResource" id="26d3509f-ad67-43ba-9190-67c9ba7e64f5">
        <source>xCreateHarbourResource(_harbour		 : HMS_Harbour;
					   _resourceType : HMS_ResourceType;
					   _wharf        : HMS_Wharf)		: HMS_Resource;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	pxyResource				: HMS_Resource;
	resource 				: HMS_Resource;
begin
	self.xDeleteHarbourResource(_resourceType.code, _harbour);

	create pxyResource transient;
	pxyResource.setProxy(_harbour, _wharf, null);
	
	pxyResource.setPropertyValue("code",		   _resourceType.code); 			
	pxyResource.setPropertyValue("description",    _resourceType.code);
	pxyResource.setPropertyValue("myResourceType", _resourceType);
	
	app.myTrxCA.trxCreateHMSResource(pxyResource, resource, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return resource;
	
epilog

	delete pxyResource;
	
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="xCreateInvoiceCalcType" id="e4a09547-36dc-43ef-819f-10c1e99c2a05">
        <source>xCreateInvoiceCalcType(_calculationType : Integer;
					   _code			: String;
					   _isCargo, 
					   _isVoyage,
					   _isEvent 		: Boolean) : CM_CalculationType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2022		navma1	Initial creation

*/
vars
	idx					: Integer;
	pxyCalculationType	: CM_CalculationType;
	newCalculationType	: CM_CalculationType;

begin

	self.xDeleteInvoiceCalcType(_code);
	
	create pxyCalculationType transient;
	
	pxyCalculationType.setProxy(null, 
								_calculationType,
								_code,
								_code,
								0,
								0,
								0,
								0,
								null,
								false,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,		
								null,
								_isCargo,
								_isVoyage,
								_isEvent, 
								false, 
								null, 
								null, 
								null, 
								0, 
								false, 
								false,
								0 //02/10/2025	navkc1 JIRA 36149
								);
	
	app.myTrxCA.trxCreateCalculationType(pxyCalculationType, newCalculationType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return newCalculationType;
epilog
	delete pxyCalculationType;
end;</source>
        <Parameter name="_calculationType" type="Integer"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_isCargo" type="Boolean"/>
        <Parameter name="_isVoyage" type="Boolean"/>
        <Parameter name="_isEvent" type="Boolean"/>
        <ReturnType type="CM_CalculationType"/>
