    <JadeMethod name="setupShtLocationDtls" id="39bce007-1028-44a8-8479-d4f4544cb0d4">
        <updating/>
        <source>setupShtLocationDtls() updating;
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	required 	: Integer;
	logAss 		: LOG_Assistant;
	species		: CM_LogSpecies;
	grade 		: CM_LogGrade;
	type 		: CM_LogType;
	treatment 	: CM_LogTreatment;
	length 		: CM_LogLength;
	
begin
	// 26/05/2010 cnwar2 #24188
	if self.cmbSpecies.myObject &lt;&gt; null then
		species := self.cmbSpecies.myObject.CM_LogSpecies;
	endif;
	if self.cmbGrade.myObject &lt;&gt; null then
		grade := self.cmbGrade.myObject.CM_LogGrade;
	endif;
	if self.cmbType.myObject &lt;&gt; null then
		type := self.cmbType.myObject.CM_LogType;
	endif;
	if self.cmbTreatment.myObject &lt;&gt; null then
		treatment := self.cmbTreatment.myObject.CM_LogTreatment;
	endif;
	if self.cmbLength.myObject &lt;&gt; null then
		length := self.cmbLength.myObject.CM_LogLength;
	endif;
	logAss := self.myAssistant.LOG_Assistant;
	logAss.comboBoxAssignedLocationsSpecs(	self.cmbLocations, self.filterVoyage, 
											species, grade, type, treatment, length, null);	
	
	required := self.tblHeaderDtls.getValueByName(ETRow_Quantity).Integer;
	self.txtRequired.text := required.String;
	self.txtSelected.text := self.selectedCount().String;
	self.cmbLocations.setFocus();
	if self.optLocnDtlsLocn.value then
		self.btnSelectAll.visible := false;
	else
		self.btnSelectAll.visible := true;	
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupShtNoNumbers" id="87e275a5-52a8-4e35-99da-b490af39aa01">
        <source>setupShtNoNumbers();
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.txtNoNumbers.text := self.tblHeaderDtls.getValueByName(ETRow_Quantity).String;
	self.tblNNData.setFocus();

	if self.filterVoyage &lt;&gt; null then
		self.getLocationsForNNData();
		self.showAllocRowsForNNData();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupShtOnBoard" id="d6e288df-8b6e-4e75-a50f-6f7a8418c81d">
        <source>setupShtOnBoard();
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cnt : Integer;
	str : String;
begin
	if self.filterVoyage = null then
		return;
	endif;
	cmbFilterLot.clear();
	cmbFilterLot.listCollection(self.filterVoyage.myLogVoyageStructure.allLogLots, false, null);	
	self.cmbFilterLot.setFocus();
	cnt := filterVoyage.myLogVoyageStructure.numHatches;
	cmbFilterHatch.clear();
	cmbFilterHatch.addItem(str);	
	while cnt &gt; 0 do
		str := cnt.String &amp; Tab;
		cmbFilterHatch.addItem(str);	
		cnt := cnt - 1;
	endwhile;
	self.showLogsOnBoard(null, null, null);
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="7f4a98c2-b75c-41ca-a2d8-e69493b0ba7f">
        <updating/>
        <source>setupTable(_theTable : Table input)updating;
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
	col : JadeTableColumn;
begin

	_theTable.columns := self.allTblDataEntRows.size;
	_theTable.fixedRows := 1;
	_theTable.userInputEnabled := true;
	_theTable.selectMode := Table.SelectMode_CurrentRow;
	_theTable.autoSize := Table.AutoSize_Column;
	_theTable.clearAllSelected();
	_theTable.clear;
	_theTable.rows := _theTable.fixedRows;
	
	self.displayTableDataRows();

	foreach idx in 1 to _theTable.columns do
		_theTable.accessCell(1, idx).text := allTblDataColHeadings[idx];
		col := _theTable.accessColumn(idx);
		if self.allTblDataColWidths.size &gt;= idx then	//PAR 9602 
			col.width := ((self.allTblDataColWidths[idx] / 100) * _theTable.width).rounded;
		endif;
	endforeach;

//	col := _theTable.accessColumn(allTblDataColHeadings.size);	
//	col.width := col.width + (_theTable.width - 1).Integer;	
	_theTable.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	_theTable.accessColumn(1).inputType := Table.InputType_CheckBox;
	_theTable.readOnly := false;	
	
	_theTable.accessColumn(4).alignment := Table.Alignment_Right_Middle;
	_theTable.accessColumn(5).alignment := Table.Alignment_Right_Middle;
	_theTable.accessColumn(6).alignment := Table.Alignment_Right_Middle;	
	
	if _theTable = tblNNData then					
		_theTable.accessColumn(7).alignment := Table.Alignment_Right_Middle;
	elseif _theTable = tblLocationDtls then
		_theTable.accessColumn(3).alignment := Table.Alignment_Right_Middle;
		//This is the dummy date column used for resorting table by date
		_theTable.accessColumn(_theTable.columns).visible := false;		
	endif;
	
	if optLocnDtlsLogs.value then
		_theTable.accessColumn(7).alignment := Table.Alignment_Right_Middle;	
	endif;
	


end;</source>
        <Parameter name="_theTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showAllocRowsForNNData" id="c2f6112a-c958-4a28-b282-2325851ab9bc">
        <source>showAllocRowsForNNData();
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	sohLocn : CM_SOHLocation;
	str : String;
	backColour, idx : Integer;
	loadStateSet : Boolean;
begin

	app.cmsBeginLoad(loadStateSet);

	foreach obj in tblNNData.myDynaDict do
		sohLocn := obj.CM_SOHLocation;
		str := sohLocn.getAttributeStringForDefArray(tblNNData.allTblDataEntRows);
		if self.tblNNData.rows mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;		
		idx := tblNNData.addItem(str);
		tblNNData.accessRow(idx).itemObject := sohLocn;
		tblNNData.accessedRow.backColor := backColour;
		tblNNData.accessCell(idx,1);
	endforeach;
	
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
