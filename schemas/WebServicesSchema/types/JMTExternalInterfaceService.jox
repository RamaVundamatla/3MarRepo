    <JadeWebServicesMethod name="cancelInvoiceSAP" id="addcf565-8170-4b36-8883-a747927e5828">
        <source>cancelInvoiceSAP(request : WS_CancelInvoiceRequest) : WS_SAPResponse webService;

/*

Purpose:			
	SAP request to change the status of an invoice to Cancelled
	WSDL 2.4: Invoice - Cancellation
Parameters:

Return Value:		


Date		Who		Reason
03 May 2018	jlgkpd1	TFS - Pelindo 1 SAP Integration
09 Jul 2018	jlgdap1	TFS 38641 PEL1 SAP Receive Document Cancellation
22 Aug 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
28 Aug 2018 cnwma1  Bug 40487: PEL1 - SAP Receive Document Cancellation
31 Oct 2018 cnwma1	ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice
28 Nov 2018 cnwma1  ChangeRequest 42118: PEL1 - Generate tax number and invoice date
*/

vars
	response		: WS_SAPResponse;
	completedOK		: Boolean;
	permission 		: Integer;
	invoice,
	pxyInvoice		: CM_Invoice;
	cmifStatus 		: CMIF_InvoiceStatus;
	pendingInv 		: CM_Invoice;
	newReserveStatus: Integer; 
	msg             : String;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Initialise the passport for the new transaction
	self.initialisePassportExternal();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check there is a request created (will be null if the input message is invalid)
	if request = null then
		app.raiseCMException(Parameter_Invalid, null, null);
	else
		// Validate the credentials passed in the request
		permission := PmWebCancelInvoiceSAP;
		request.validateCredentials( permission );
		
		// Populate known response attributes from the request
		response.populateFromRequest(request);
	endif;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation - must be able to find an invoice
	invoice := request.getInvoice(app.myPassport.myTerminal, request.invoiceID);
	if invoice = null then
		app.raiseCMException3(Value_field_not_resolve, request.invoiceID, WS_UpdateInvoiceRequest::invoiceID.name, app.getErrorString(Invoice), null, null);
	endif;
	
	// Check the user is allowed to change the invoice status to Void
	if invoice &lt;&gt; null then
		  // TFS 39618 PATCH 1 app.checkCurrentUserHasAccess(PmAdmInvoiceStatusVoid);
		if invoice.bank &lt;&gt; null then  // TFS 39618 PATCH 1 
			invoice.bank.checkCurrentUserHasAccess(CM_Invoice.INVOICE_VOID);  // TFS 39618 PATCH 1 
			if app.myPassport.hasErrors then  // TFS 39618 PATCH 1 
				invoice := null;
			endif;
		endif;
	endif;	
	
	// Got a valid invoice at the right status for a valid debtor who is a prepay debtor
	// Move the invoice to pending (the trx will validate whether the invoice is in the correct status)
	if invoice &lt;&gt; null then
		
		if invoice.status = CM_Invoice.INVOICE_POSTED or 
			(invoice.status = CM_Invoice.INVOICE_PENDING and invoice.paymentStatus =CM_Invoice.INVOICE_PAYMENT_NOTPAID) then
			
			create cmifStatus transient;		//08 Apr 2019	TFS 44245 - moved up.
			
			if invoice.status = CM_Invoice.INVOICE_POSTED then
				newReserveStatus := CM_Invoice.INVOICE_POSTED_REVERSE ;
			elseif invoice.status = CM_Invoice.INVOICE_PENDING then
				cmifStatus.requiresNewPaymentCode := true;	//08 Apr 2019	TFS 44245
				newReserveStatus := CM_Invoice.INVOICE_PENDING_REVERSE ;
				if app.myPassport.noErrors  then
					delete pxyInvoice;
					pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
					app.myTrxUA.trxUpdateInvoicePaymentStatus(pxyInvoice,CM_Invoice.INVOICE_PAYMENT_CANCEL,app.myPassport);
				endif;
			endif;
			
		//	create cmifStatus transient;
			cmifStatus.myInvoice := invoice;
			cmifStatus.narration := invoice.narration;
			cmifStatus.isZeroRatedTax := invoice.isZeroRatedTax;
			cmifStatus.doExport := false;
			cmifStatus.myTermsOfTrade := invoice.debtor.myTermsOfTrade;
			cmifStatus.purchaseOrderNumber := invoice.purchaseOrderNumber;
			cmifStatus.toDT.setDate( invoice.getEndDate );
			cmifStatus.debtorReference := invoice.debtorReference;
			
			// TFS 43820 JLGAB1 if 'invoice' is POSTED this will be PAID, if 'invoice' is PENDING this will be NOT PAID
			cmifStatus.paymentStatus := invoice.paymentStatus; 
			
			app.myTrxUA.trxInvoiceCopy(	cmifStatus,
										newReserveStatus,
										pendingInv,	
										app.myPassport
										);
			/*
			28.11.2018 cnwma1 ChangeRequest 42118
			Generate Tax
			*/
			if app.myPassport.noErrors then
				pendingInv.generateTax();
			endif;
		endif;
		
		if app.myPassport.hasErrors then
			msg :=  method.qualifiedName &amp; 
					' ' &amp; "SAP"        									   &amp;
					' ' &amp; "WSDL : "    &amp; BGP_SAPWSRequest.WSDL24 		   &amp;
					' ' &amp; "Invoice :"  &amp; invoice.exportCurrencyCode        &amp;
					' ' &amp; "ERRORS : "  &amp; app.myPassport.getErrorsAndWarningsAsString;
			app.writeLog(msg,LogINFO);
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	delete cmifStatus;
	delete pxyInvoice;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CancelInvoiceRequest"/>
        <ReturnType type="WS_SAPResponse"/>
    </JadeWebServicesMethod>
    <JadeMethod name="createActivityHistory" id="1f4f1e6e-d8bd-4982-801d-c67122e283f4">
        <source>createActivityHistory(_replyMessage: String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2018	jlgndl1	Initial creation	TFS 38135
13 Jun 2018	jlgkpd	TFS 39164 - rework to use Strings for performance and database space optimisation

*/

vars
	
	proxyActHistory : CM_ActivityHistoryExtInterface;
	description : String;
	errorDetail : String;
	interfaceName : String;	//30 Sep 2019	NDL	TFS 46758

begin
	

	//epr TFS 45207 19/6/19	
	if self.currentRequestIsInaportnet  then
		description:= "INAPORTNET webservice " &amp; self.getMethodName();
		if self.myVoyage &lt;&gt; null then
			description :=description &amp; " received for " &amp; self.myVoyage.voyageCodeExternal;
		endif;
		interfaceName := CM_ActivityHistoryExtInterface.INAPORTNETwebservice;	//30 Sep 2019	NDL	TFS 46758
	elseif self.currentRequestIsSAP then
		description:= "SAP webservice " &amp; self.getMethodName() &amp; " was received";
		interfaceName := CM_ActivityHistoryExtInterface.SAPwebservice;	//30 Sep 2019	NDL	TFS 46758
	else
		description:=  self.getMethodName() &amp; " was received";
		interfaceName := CM_ActivityHistoryExtInterface.EXTERNALwebservice;	//03 Oct 2019	NDL	TFS 46758
	endif;
	
	create proxyActHistory transient;
	proxyActHistory.setProxy(ActivityHistoryExtInterface, app.myPassport.myTerminal, false);
	proxyActHistory.setDescription(description);	
	proxyActHistory.setMessageData(self.rawIncomingMessage, _replyMessage);
	proxyActHistory.setRequestName(	self.getMethodName() );
	proxyActHistory.setMyVoyage(self.myVoyage);
	proxyActHistory.setInterfaceName( interfaceName );	//30 Sep 2019	NDL	TFS 46758
	
	app.myTrxCA.trxCreateActivityHistory(proxyActHistory, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		errorDetail := app.getErrorString(FailedToCreateActivityHist);
		app.remoteErrorWarningToAlert(errorDetail, null , app.myPassport.allErrors, null, false, false);
	endif;
	
epilog

	delete proxyActHistory;

end;</source>
        <access>protected</access>
        <Parameter name="_replyMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="createPreProcessActivity" id="e0e4453c-64b7-4d97-8480-b7d6f14fe194">
        <updating/>
        <source>createPreProcessActivity() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2018	jlger1	Initial creation more logging for inaport unit testing

*/

vars

	xmlHelper : CM_XmlHelperAgent;
	incomingSecureStr : String;
begin
	self.myVoyage:=null;
	self.rawIncomingMessage:=null;

	create xmlHelper transient;
	//epr TFS 45207 19/6/19
	self.rawIncomingMessage:=  xmlHelper.hidePasswordFieldsForLogging( self.incomingMessage );
	
epilog

	delete xmlHelper;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="currentRequestIsInaportnet" id="eb3f5993-94e0-42a5-ad76-83381571565d">
        <source>currentRequestIsInaportnet() : Boolean protected;
/*

Purpose:			Determine whether or not the currently processing Web Service request is an INAPORTNET one

Parameters:			None

Return Value:		True if the current request is from INAPORTNET

Date		Who		Reason
06 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	methodName		: String;
	
begin
	methodName := self.getMethodName();
	
	if methodName = JMTExternalInterfaceService::entryIjinGerak.name or
	   methodName = JMTExternalInterfaceService::entryPembatalanPKK.name or
	   methodName = JMTExternalInterfaceService::entryPerpanjanganMasaTambat.name or
	   methodName = JMTExternalInterfaceService::entryPindahKeluar.name or
	   methodName = JMTExternalInterfaceService::entryPKK.name or
	   methodName = JMTExternalInterfaceService::entryPPK.name or
	   methodName = JMTExternalInterfaceService::entryRKBM.name or
	   methodName = JMTExternalInterfaceService::entrySPB.name or
	   methodName = JMTExternalInterfaceService::entrySPOG.name then
		return true;
	endif;
	
	return false;
	   
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="currentRequestIsSAP" id="d74cedcc-0a73-47d2-a6d3-699ce71f659a">
        <source>currentRequestIsSAP() : Boolean protected;
/*

Purpose:			Determine whether or not the currently processing Web Service request is an SAP one

Parameters:			None

Return Value:		True if the current request is from SAP

Date		Who		Reason
06 Apr 2018	jlgkpd1	TFS - Pelindo 1 SAP Integration

*/

vars
	methodName		: String;
	
begin
	methodName := self.getMethodName();
	
	if methodName = JMTExternalInterfaceService::cancelInvoiceSAP.name or
	   methodName = JMTExternalInterfaceService::updateCustomerSAP.name or
	   methodName = JMTExternalInterfaceService::updateInvoiceSAP.name or
	   methodName = JMTExternalInterfaceService::updatePreInvoiceSAP.name then
		return true;
	endif;
	
	return false;
	   
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeWebServicesMethod name="entryIjinGerak" id="16df10c1-d7b8-4df9-a92b-9b6adbf9c638">
        <usesRPC>default</usesRPC>
        <updating/>
        <source>entryIjinGerak(req : WS_EntryIjinGerakRequest) : WS_EntryIjinGerakResponse webService, updating;

/*					CANCEL OR TIME CHANGE WORK ORDER

Purpose:			Template method for any new webService method on the JMTExternalInterfaceService provider.
					Use this code to ensure that all the correct framework requirements are met.
					Note that input parameter name should be changed to a name representative
					of the request class (but not exactly the same) because this then appears in the 
					generated WSDL as a meaningful name.
					
					Note: Please leave a meaningful Purpose description describing what the method does.
					From, either copy this purpose into the methods Text or run the JadeScript 'getPurposeForText'.
					The method Text will be provided in the external documentation to our customers (this also applies
					to attribute and class Text).
					
					The shipping Company / Agent fills in the request for changes to the service previously requested.

Parameters:

Return Value:		


Date		Who		Reason
04 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	response		: WS_EntryIjinGerakResponse;
	completedOK		: Boolean;
	permission 		: Integer;
	
	voyage			: CM_Voyage;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Initialise the passport for the new transaction
	self.initialisePassportExternal();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	// Check there is a request created (will be null if the input message is invalid)
	if req = null then
		app.raiseCMException(Parameter_Invalid, null, null);
	else
		// Validate the credentials passed in the request
		permission := PmWebEntryIjinGerak;		// Replace with appropriate permission
		req.validateCredentials( permission );
		
		// Populate known response attributes from the request
		response.populateFromRequest(req);
	endif;
	
		
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	self.myVoyage:=req.getVoyage();	
	// Perform validation, start populate response
	if not req.validateDetails()
	or not req.validateMandFieldsPresent()
	or not req.validateForVoyageUpdate( voyage )
	then
		completedOK := true;
		return response;
	endif; 
		
	req.processMessage(	voyage );
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="req" type="WS_EntryIjinGerakRequest"/>
        <ReturnType type="WS_EntryIjinGerakResponse"/>
