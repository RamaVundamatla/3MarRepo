    <JadeMethod name="clearThumbnailData" id="3122075f-509a-41ef-9d93-6c6e22e8cff2">
        <updating/>
        <source>clearThumbnailData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
