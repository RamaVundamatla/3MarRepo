    <JadeMethod name="setForCreate" id="355272ea-8354-4425-9bfe-e3b999447a81">
        <updating/>
        <source>setForCreate( _proxy : CM_QuickAccess ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin

	_proxy.raiseExceptionIfNotTransient(method);
	
	setForUpdate(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_QuickAccess"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d726032f-081b-420f-87bb-9175620635c0">
        <updating/>
        <source>setForUpdate( _proxy : CM_QuickAccess ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin

	self.allowsOption := _proxy.allowsOption;
	self.isForm := _proxy.isForm;
	self.helpDescription := _proxy.helpDescription.trimBlanks;
	self.permissionInteger := _proxy.permissionInteger;
	self.shortCode := _proxy.shortCode.trimBlanks.toUpper;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_QuickAccess"/>
    </JadeMethod>
