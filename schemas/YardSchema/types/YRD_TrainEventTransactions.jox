    <JadeMethod name="translateForm" id="897b46a2-83ce-42bc-a049-c46064248299">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 13:35:35.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022890, locale);
	btnDelete.translateBubbleHelp(Xlat_0013827, locale);
	btnDelete.translateCaption(Xlat_0013828, locale);
	btnEditEvent.translateBubbleHelp(Xlat_0013829, locale);
	btnEditEvent.translateCaption(Xlat_0013830, locale);
	btnExport.translateBubbleHelp(Xlat_0013831, locale);
	btnExport.translateCaption(Xlat_0013832, locale);
	btnInvoiceLine.translateBubbleHelp(Xlat_0013833, locale);
	btnInvoiceLine.translateCaption(Xlat_0013834, locale);
	btnNewEvent.translateBubbleHelp(Xlat_0013835, locale);
	btnNewEvent.translateCaption(Xlat_0013836, locale);
	btnPrint.translateCaption(Xlat_0013837, locale);
	lblCharge.translateCaption(Xlat_0013838, locale);
	lblDate.translateCaption(Xlat_0013839, locale);
	lblEventType.translateCaption(Xlat_0013840, locale);
	lblTime.translateCaption(Xlat_0013841, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0013842, locale);
	mnuContext.translateCaption(Xlat_0013843, locale);
	mnuInspectObject.translateCaption(Xlat_0013844, locale);
end;</source>
    </JadeMethod>
