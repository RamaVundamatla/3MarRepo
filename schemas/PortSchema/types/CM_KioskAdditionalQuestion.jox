    <JadeMethod name="persistCriteria" id="3434c459-1147-4f7b-b632-12ec676feca3">
        <updating/>
        <source>persistCriteria(_allTransientCriteriaObj : CMIF_Array; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	criteriaObj		: CM_YAKioskCriteria;
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	realCPObj		: CM_YACriteriaPriority;
	isCreateDone	: Boolean;
	isDeleteDone	: Boolean;
	isUpdateDone	: Boolean;
	term 			: CM_Terminal;

begin

	foreach criteriaObj in self.allCriteria reversed do
		criteriaObj.setPriorityValue(criteriaObj.priorityValue * -1);
	endforeach;
	
	isCreateDone	:= false;
	isDeleteDone	:= false;
	isUpdateDone	:= false;
	
	foreach cmifObject in _allTransientCriteriaObj do
		transientObj	:= cmifObject.CMIF_YACriteriaPriority;
		proxyObj		:= transientObj.myProxy;
		realCPObj		:= transientObj.myCriteriaPriority;
		proxyObj.CM_YAKioskCriteria.setMyAdditionalQuestion(self);
		
		// Do "New" first, because the "changed" flag can be set if a new Criteria
		// is changed after it is added, but before it is saved to the database
		if transientObj.isNew then
			app.myUtilityCA.utlCreateYACriteriaPriority(proxyObj, realCPObj, _passport);
			isCreateDone := true;
			
		elseif transientObj.isChanged then
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
			isUpdateDone := true;
			
		elseif transientObj.isDeleted then
			app.myUtilityDA.utlDeleteYACriteriaPriority(realCPObj, _passport);
			isDeleteDone := true;
			
		else
			// The Criteria/Priority has not been touched, however, we still need to update it,
			// because all priority values have been made negative as they all need to be 
			// resequenced for new or deleted Criteria
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
		endif;
	endforeach;
	
	self.recalculateCriteriaPriorities();
	
	self.validateCriteria();
	
	if isCreateDone or isUpdateDone or isDeleteDone then
		if self.myKiosk &lt;&gt; null then
			term := self.myKiosk.myTerminal;
		endif;
		if term &lt;&gt; null then
			self.causeEvent(term.getTerminalEvent(EVENT_YA_CP_UPDATE), false, process);
		endif;
	endif;

end;</source>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b8d9bc67-04a8-46cb-a45b-4b7446ddc0da">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 August 2023	jlier1	Initial creation 58511
25 August 2023	jlizm1	TFS 59551 Kiosk Additional Question

*/

vars
	proxy			: SelfType;
	completedOK		: Boolean;
	kioskTranslation ,
	pxyKioskTranslation : CM_KioskTranslation;
	criteria,
	pxyCriteria		: CM_YAKioskCriteria;
	
begin
	proxy :=  inheritMethod();
	
	foreach  kioskTranslation in self.allErrorMessages discreteLock do
		pxyKioskTranslation := kioskTranslation.pxyCreateUpdateProxy(); 
		proxy.allErrorMessages.add(pxyKioskTranslation);
	endforeach;
	
	foreach  kioskTranslation in self.allQuestions discreteLock do
		pxyKioskTranslation := kioskTranslation.pxyCreateUpdateProxy(); 
		proxy.allQuestions.add(pxyKioskTranslation);
	endforeach;
	
	completedOK := true;			
	return proxy;
	
epilog
	if not completedOK then			
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recalculateCriteriaPriorities" id="b06dcd4b-f78a-4257-a9fe-25f97f8cc864">
        <source>recalculateCriteriaPriorities();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	criteriaObj			: CM_YACriteria;
	allCriteriaSetObj	: CM_YACriteriaSet;
	priorityTotal		: Real;
	
begin
	create allCriteriaSetObj transient;
	self.allCriteria.copy(allCriteriaSetObj);
	priorityTotal	:= 0;
	
	foreach criteriaObj in allCriteriaSetObj do
		priorityTotal	:= priorityTotal + criteriaObj.calculatePriority();
	endforeach;
	
epilog
	delete allCriteriaSetObj;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="45cdc1a7-20cc-4172-ba06-cb05c1d6cf62">
        <updating/>
        <source>setForUpdate(_proxy: CM_KioskAdditionalQuestion) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2023	jlier1	Initial creation 58511

*/

vars

begin
	inheritMethod(_proxy);
	self.updateTranslations(self.allErrorMessages,_proxy.allErrorMessages);
	self.updateTranslations(self.allQuestions,_proxy.allQuestions);	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_KioskAdditionalQuestion"/>
    </JadeMethod>
