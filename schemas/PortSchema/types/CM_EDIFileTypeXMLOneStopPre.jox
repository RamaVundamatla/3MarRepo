    <JadeMethod name="processOverDims" id="0915e626-d77c-44cc-aca2-96305bed94fe">
        <source>processOverDims(	_xmlElementOD : JadeXMLElement;
					_ediFile: CM_EDIFile input;
					_ediPreNote : CM_EDIPrenoteTI input
					):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;

begin

	xmlSubElement := null;
	xmlSubElement := _xmlElementOD.getElementByTagName(self.TagTop);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null and str.isInteger then
			_ediPreNote.overHeight := str.Integer;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementOD.getElementByTagName(self.TagRight);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null and str.isInteger then
			_ediPreNote.overWidthRight := str.Integer;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementOD.getElementByTagName(self.TagLeft);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null and str.isInteger then
			_ediPreNote.overWidthLeft := str.Integer;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementOD.getElementByTagName(self.TagFront);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null and str.isInteger then
			_ediPreNote.overLengthFront := str.Integer;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementOD.getElementByTagName(self.TagBack);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null and str.isInteger then
			_ediPreNote.overLengthBack := str.Integer;
		endif;
		
	endif;
	
	return true;

epilog

end;</source>
