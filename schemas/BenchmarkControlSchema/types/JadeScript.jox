    <JadeMethod name="jhpBmkStats1" id="007861c8-2070-4589-bd1e-4e041dca710b">
        <source>jhpBmkStats1();

vars
	f,g:File; dateNode,runNode,fileNode:FileNode; ff,dateFolder,runFolder:FileFolder;
	i,j,pos:Integer; s,t,u,release,clientMachine:String;
begin
	create ff transient;
	ff.usePresentationFileSystem := false;
	ff.fileName := "t:\BenchMarkResults\StartStopTest";
	foreach dateNode in ff.files where dateNode.isKindOf(FileFolder) do
		dateFolder := dateNode.FileFolder;
		foreach runNode in dateFolder.files where runNode.isKindOf(FileFolder) do
			runFolder := runNode.FileFolder;
			
			runFolder.mask := "*PerfMonLog*.csv";
			foreach fileNode in runFolder.files where fileNode.isKindOf(File) and not fileNode.name.contains("_s25_") do
				s := fileNode.name;
				pos := 1;
				clientMachine := s.scanUntil("_", pos); pos := pos + 1;
				clientMachine := s.scanUntil("_", pos); pos := pos + 1;
				clientMachine := s.scanUntil("_", pos); pos := pos + 1;
			endforeach;
			
			runFolder.mask := "*.ini";
			foreach fileNode in runFolder.files where fileNode.isKindOf(File) do
				release := (fileNode.name.replace("base_","").replace("upg_","").replace("jsst","").replace(".ini",""))[3:4];
			endforeach;
			
			runFolder.mask := "*stats.csv";
			foreach fileNode in runFolder.files where fileNode.isKindOf(File) do
				f:=fileNode.File;
				while not f.endOfFile do
					s := f.readLine;
					if s.contains("Startup to Init Method") then
						write fileNode.name &amp; "," &amp; clientMachine &amp; "," &amp; release &amp; "," &amp; s;
						break;
					endif;
				endwhile;
			endforeach;
		endforeach;
	endforeach;
epilog
	delete ff;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpChangeMachine" id="bb814dfc-2092-4699-b97e-5467611c45e1">
        <source>jhpChangeMachine();

vars
	machine:Machine;
begin
	foreach machine in Machine.instances do
		if machine.hostName = "cnwchcs128" then
			beginTransaction;
			machine.hostName := "cnwchcs127";
			commitTransaction;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpCirc" id="f8532ba4-43c5-491c-9432-13e7546579cc">
        <source>jhpCirc();

vars
	m:Machine;
	f,g:File; fn:FileNode; ff:FileFolder;
	s,tok,miscPath:String; i,j:Integer;
begin
	write "starting";
	create f transient;
	create g transient;
	create ff transient;
	f.usePresentationFileSystem:=false;
	g.usePresentationFileSystem:=false;
	g.mode := File.Mode_Output;
	ff.usePresentationFileSystem:=false;
	miscPath := app.dbPath.replace("c_system", "c_misc");
	
	// check file dates
