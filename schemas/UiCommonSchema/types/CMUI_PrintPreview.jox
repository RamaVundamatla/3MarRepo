    <JadeMethod name="addToolbarControls" id="43d36924-ed35-4db0-9aad-9a8908091e1a">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
//	if app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmPDFBackground) then
		toolbar.addButton(self.btnEmail, CMUI_Toolbar.Control_Alignment_Left);
//	endif;
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintSelect, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnFirst, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrev, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNext, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnLast, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSpecific, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnReduce, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEnlarge, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFindNext, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFindPrev, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addFrame(self.frm_LblPgDetail, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

end;</source>
        <access>protected</access>
    </JadeMethod>
