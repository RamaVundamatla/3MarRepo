    <JadeMethod name="setProxyObject" id="b4d4197e-b445-4986-a97d-34f41eb88723">
        <updating/>
        <source>setProxyObject(_any: Any) updating;
/*

Purpose:			
	Mapping 
	MTN : 
	N4  : spatial_bins
Parameters:			

Return Value:		

Date		Who		Reason
08 April 2022	navsp1	Initial creation TFS#53369

*/

vars
	helper 		: CMIF_SpatialBins;
	ewsOpsView	: CM_EWSActivityOpsview;
begin
	inheritMethod(_any);
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView); 
	
	self.tableName					:= helper.tableName;
	self.gkey						:= helper.gkey;
	self.bin_level 					:= helper.bin_level;
	self.bin_subclass 				:= helper.bin_subclass;
	self.block_type_enum			:= helper.block_type_enum;
	self.internal_pos_name			:= helper.internal_pos_name;
	self.label_scheme_full_position := helper.label_scheme_full_position;
	self.life_cycle_state 			:= helper.life_cycle_state;
	self.parent_bin_gkey 			:= helper.parent_bin_gkey;
	self.yard_gkey 					:= helper.yard_gkey;
	self.z_index_last 				:= helper.z_index_last;
	self.heap_classification		:= helper.heap_classification;	//navra1 - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022 

epilog

end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setProxyObjectCOL" id="dfbba437-8b9e-42dc-b623-5b6028549abc">
        <updating/>
        <source>setProxyObjectCOL(_any: Any;_gKey:String) updating;

/*

Purpose:			
	Mapping 
	MTN : 
	N4  : spatial_bins
Parameters:			

Return Value:		

Date		Who		Reason
27 MAY 2022	navsp1	Initial creation TFS#53700

This is an exceptional method for the Block Stack
*/

vars
	helper 		: CMIF_SpatialBins;
	ewsOpsView	: CM_EWSActivityOpsview;
	nsdsObject	: WS_NSDSObject;
begin
	if _any = null then
		return;
	endif;
	

	self.sequenceNumber     := "";
	if _any.isKindOf(Object) then
		self.oid    			:= _any.Object.getOidString();
	endif;
	self.updateTimeStamp    := app.actualTimeServer().asEpochFormat();
	self.sequenceNumber     := app.actualTimeServer().asEpochFormat().String;
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivityCOL(_any, ewsOpsView,_gKey); 
	
	self.tableName					:= helper.tableName;
	self.gkey						:= helper.gkey;
	self.bin_level 					:= helper.bin_level;
	self.bin_subclass 				:= helper.bin_subclass;
	self.block_type_enum			:= helper.block_type_enum;
	self.internal_pos_name			:= helper.internal_pos_name;
	self.label_scheme_full_position := helper.label_scheme_full_position;
	self.life_cycle_state 			:= helper.life_cycle_state;
	self.parent_bin_gkey 			:= helper.parent_bin_gkey;
	self.yard_gkey 					:= helper.yard_gkey;
	self.z_index_last 				:= helper.z_index_last;

epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_gKey" type="String"/>
    </JadeMethod>
</Class>
