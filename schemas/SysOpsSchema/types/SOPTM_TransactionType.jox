    <JadeMethod name="canDoDelete" id="1ee4014e-4678-4e1b-87d9-6c1de393dbc5">
        <source>canDoDelete(): Boolean;
// ---------------------------------------------------------------------------
// Created:     10 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myForm.myCurrentObject.CM_TransactionType.isSystemTransType then
		app.msgBox(app.getErrorString1(Err_NoUpdDelForSysTransType, app.getErrorString(Delete)), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
