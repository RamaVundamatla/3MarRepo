    <JadeMethod name="isForShip" id="f1cabd95-1fd0-46c7-9add-407dbb257bbf">
        <source>isForShip() : Boolean;
// ---------------------------------------------------------------------------
// Created:     02 November 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	tranType	: Integer;
	
begin
	tranType	:=	self.trxType;
	
	return (tranType = TRANS_TYPE_REC_SHIP or tranType = TRANS_TYPE_REL_SHIP);


epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForSubTerminals" id="588d549b-a365-432e-ba4a-2120e9b7e7f5">
        <source>isForSubTerminals():Boolean;
// --------------------------------------------------------------------------------
// Created:		31 August 2009 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is for Sub-
//				Terminals.
//
// Parameters:	None
//
// Returns:		True if the receiver is for Sub-Terminals, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tranType	: Integer;
	
begin
	tranType	:=	self.trxType;
	
	if tranType = TRANS_TYPE_REC_ST_DEPOT_INT
	or tranType = TRANS_TYPE_REC_ST_DEPOT_RAIL
	or tranType = TRANS_TYPE_REC_ST_DEPOT_ROAD
	or tranType = TRANS_TYPE_REC_ST_DEPOT_SHIP
	or tranType = TRANS_TYPE_REC_ST_MARINE_INT
	or tranType = TRANS_TYPE_REC_ST_MARINE_RAIL
	or tranType = TRANS_TYPE_REC_ST_MARINE_ROAD
	or tranType = TRANS_TYPE_REC_ST_MARINE_SHIP
	or tranType = TRANS_TYPE_REC_ST_WHOUSE_INT
	or tranType = TRANS_TYPE_REC_ST_WHOUSE_RAIL
	or tranType = TRANS_TYPE_REC_ST_WHOUSE_ROAD
	or tranType = TRANS_TYPE_REC_ST_WHOUSE_SHIP
	or tranType = TRANS_TYPE_REL_ST_DEPOT_INT
	or tranType = TRANS_TYPE_REL_ST_DEPOT_RAIL
	or tranType = TRANS_TYPE_REL_ST_DEPOT_ROAD
	or tranType = TRANS_TYPE_REL_ST_DEPOT_SHIP
	or tranType = TRANS_TYPE_REL_ST_MARINE_INT
	or tranType = TRANS_TYPE_REL_ST_MARINE_RAIL
	or tranType = TRANS_TYPE_REL_ST_MARINE_ROAD
	or tranType = TRANS_TYPE_REL_ST_MARINE_SHIP
	or tranType = TRANS_TYPE_REL_ST_WHOUSE_INT
	or tranType = TRANS_TYPE_REL_ST_WHOUSE_RAIL
	or tranType = TRANS_TYPE_REL_ST_WHOUSE_ROAD
	or tranType = TRANS_TYPE_REL_ST_WHOUSE_SHIP
	or tranType = TRANS_TYPE_RECEIVE_ST_DEPOT
	or tranType = TRANS_TYPE_RECEIVE_ST_MARINE
	or tranType = TRANS_TYPE_RECEIVE_ST_WHOUSE
	or tranType = TRANS_TYPE_RELEASE_ST_DEPOT
	or tranType = TRANS_TYPE_RELEASE_ST_MARINE
	or tranType = TRANS_TYPE_RELEASE_ST_WHOUSE
	then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForWorkOrder" id="4c3a8ff6-81cf-45bb-975d-1fbdb66aa342">
