    <JadeMethod name="setControlsForGrade" id="f8b4205d-982f-4db8-a0c1-08d00f5eaee8">
        <updating/>
        <source>setControlsForGrade(_grade : CM_LogGrade; _type : CM_LogType;
					_treatment : CM_LogTreatment; _length : CM_LogLength) updating, protected;
// -----------------------------------------------------------------------------
// Created:		12 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
		
//	self.myAssistant.setLogType(tblMain, self.cmbLogType, _grade, _type);
//	self.myAssistant.setLogTreatment(tblMain, self.cmbTreatment, _grade, _treatment);	
//	self.myAssistant.setLogLength(tblMain, self.cmbLogLength, _grade, _length);
	
	self.cmbLogType.setObjectAndGrade(_type,_grade);
	self.cmbTreatment.setObjectAndGrade(_treatment,_grade);
	self.cmbLogLength.setObjectAndGrade(_length,_grade);
	
	self.tblMain.setValueByControlName(self.cmbLogType.name, self.cmbLogType.text);
	self.tblMain.setValueByControlName(self.cmbTreatment.name, self.cmbTreatment.text);
	self.tblMain.setValueByControlName(self.cmbLogLength.name, self.cmbLogLength.text);
	

end;</source>
