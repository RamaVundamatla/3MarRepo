    <JadeMethod name="cnEcGetDuplicate" id="e8a3c111-09ec-4b00-952c-c3986f27457a">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	celsius : Real;
	temp : CM_TemperatureConversion;

begin

	celsius := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "celsius" ).Real; 
	
	temp := app.myRoot.allTempsCelsius.getAtKey( celsius );

epilog

	return temp;
	
end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
