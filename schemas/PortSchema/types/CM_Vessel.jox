    <JadeMethod name="bridgeAfterBay" id="814f7a43-f6ec-4fb9-9920-4432d55a8e90">
        <source>bridgeAfterBay() : String;
//
// used by DSS
//
vars
	str : String;
begin
	str := null;
	if self.myCellularVesselStructure &lt;&gt; null then
		str := myCellularVesselStructure.bridgeAfterBay;
	endif;
	return str[1:9];
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
