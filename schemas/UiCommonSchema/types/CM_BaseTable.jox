    <JadeMethod name="getNumSelectedRows" id="5871ede5-ee1d-4c55-ab4a-3eaa4fa67236">
        <updating/>
        <source>getNumSelectedRows() : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2017	jlgab1	Initial creation

*/

vars
	idx, size, num : Integer;
begin
	size := self.rows;
	
	foreach idx in 1 to size do
		if self.accessRow(idx).selected then
			num := num + 1;
		endif;
	
	endforeach;
	return num;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowFromY" id="94d23eed-88dc-421c-8699-95b2ec9d7fdb">
        <updating/>
        <source>getRowFromY(y: Real): Integer updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yDist		: Real;
	intRow		: Integer;
	startRow	: Integer;
begin

	yDist := 0;
	foreach intRow in 1 to self.fixedRows do
		yDist := self.accessRow(intRow).height + yDist;
		if yDist &gt;= y then 
			return intRow;
		endif;
	endforeach;
	
	startRow := self.topRow;
	foreach intRow in startRow to self.rows do
		// ### TFS BUG 58853 17JUL2023 NAVAB1
		if self.accessRow(intRow).visible = false then
			continue;
		endif;

		yDist := self.accessRow(intRow).height + yDist;
		if yDist &gt;= y then 
			return intRow;
		endif;	
	endforeach;

	return 0;

end;</source>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCellObjects" id="f5f952ec-ee88-4bc2-9466-54da96aade63">
        <updating/>
        <source>getSelectedCellObjects(_objSet : Set input) updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2007 by cnwrs2
//
// Purpose:     OK for use on a small table, if gets implemented on a large
//				table then may have to look at doing similar for storing
//				allSelectedRows
// ---------------------------------------------------------------------------
vars
	numRows,
	numCols,
	i, j	: Integer;
	obj		: Object;
begin

	numRows := self.rows;
	numCols := self.columns;

	foreach i in 1 to numRows do
		foreach j in 1 to numCols do
			if self.accessCell(i,j).selected then
				obj := self.accessedCell.itemObject;
				if obj &lt;&gt; null then
					_objSet.add(obj);
				endif;
			endif;
		endforeach;
	endforeach;
				
end;</source>
        <Parameter name="_objSet" type="Set" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedRowAsString" id="41832f33-c3ff-45ff-a1f5-efedf93e6323">
        <updating/>
        <source>getSelectedRowAsString(_theRow : Integer) : String updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		Returns a delimited string so that a row in one table can be added to another table
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	theLine : String;
begin
	if _theRow &lt;= self.fixedRows then
		return null;
	endif;

	foreach idx in 1 to self.columns do
		theLine := theLine &amp; self.accessCell(_theRow,idx).text.trimBlanks &amp; Tab;
	endforeach;
	if theLine &lt;&gt; null then
		theLine := theLine[1:theLine.length - 1];
	endif;
	return theLine;
end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
