    <JadeMethod name="createValidateMoveResponse" id="66201cff-df6f-4bdc-8c09-80b1316a5f81">
        <source>createValidateMoveResponse(_message : CMIF_InterfaceMsgController input;
//						   _matches : Integer;			// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
						   _ti : CM_TrackedItem) protected;

/*

Purpose:			Create response for a successful incoming ValidateMove message

Parameters:			Incoming message controller, number of containers matching input container id
					and matching TI, if there is only 1

Return Value:		_message updated with response


Date		Who		Reason
22 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Change to hook code signature
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					No longer returns a Destination String

*/

vars
	field			: String;
	response		: CMIF_InterfaceResponse;
//	task			: CM_RTQueueTask;

begin
//	task := _message.getTask;
	
	// Create response object
	response := _message.createResponseLine();
	
	// Number of Matches
//	field := _matches.String;					// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	field := _message.numberOfMatches.display;
	response.allResponseFields.add(field);
	
	// Container Id
	field := null;
//	if _matches = 1 and _ti &lt;&gt; null then		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if _message.numberOfMatches = 1 and _ti &lt;&gt; null then
		field := _ti.id;
	endif;
	response.allResponseFields.add(field);
	
/*	PAR #18743 - Destination string removed

	// Destination String
	
	
	field := null;
	if _matches = 1 then
		field := self.myInterfaceDefinition.getLocationTranslationString(_message.functionName,
																		 task, 
																		 null,
																		 task.ultimateTargetLocation, 
																		 false);
	endif;
	response.allResponseFields.add(field);
*/

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doProcessGetDestination" id="31f972dd-00d1-46b9-aa93-d18da38ba036">
        <source>doProcessGetDestination(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming GetDestination message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
08 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Add in default response build
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
//	containerId,							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
//	containerId2	: String;				// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	passport		: CM_Passport;
	
begin
	passport := app.myPassport;
	
	// Validate number of parameters first
	_message.validateNumberOfParameters(3);

	// Validate and setup for machine
	_message.validateMachineAndMediator();
	
	// Get and validate 1st container number
//	containerId := _message.allInputFields[2];		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	_message.setContainerId( _message.allInputFields[2] );
//	if containerId = null then						// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if _message.containerId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ContainerID), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ContainerID), null, null); // cnwdb2	PAR 35364
	endif;

	// Get and validate 2nd container number
//	containerId2 := _message.allInputFields[3];		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	_message.setContainerId2( _message.allInputFields[3] );
	// If a second container Id is supplied, then must be a Twin Lift
//	if containerId2 &lt;&gt; null then					// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if _message.containerId2 &lt;&gt; null then
		_message.validateMachineIsTwinLift();
	endif;
	
	// Validate current task(s)
	_message.validateTasks(TASK_SETDOWN);

	// Validate container numbers
//	_message.validateContainers(containerId, containerId2);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	_message.validateContainers();
	
	// Update the last update timestamp
	app.myTrxRT.trxUpdateMediatorTimeStamp(_message.myMediator, null, passport);

	if passport.hasErrors() then
		return false;
	endif;

	// Create reply for successful GetDestination message
	self.createGetDestinationResponse(_message);
	
	// Got to here, then all OK
	return true;
	
epilog
	_message.createDefaultResponse(3);	// PAR #18526
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessInitialise" id="ce3cbb5c-5cc8-446c-9874-213dc8452091">
        <source>doProcessInitialise(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming Initialise message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
08 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Add in default response build

*/

vars
	user			: CM_User;
	userId			: String;

begin
	// Validate number of parameters first
	_message.validateNumberOfParameters(1);

	userId := _message.allInputFields[1].toUpper;
	
	// Process Initialise message
	user := app.myRoot.allUsers[userId];

	if user = null then
		app.raiseCMException(ERR_PASSWORD, null, null);
	endif;
	
	// Got to here, then all OK
	return true;
	
	
epilog
	_message.createDefaultResponse(0);
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessLogoff" id="2d14031f-3343-461d-8a2a-23002197841a">
        <source>doProcessLogoff(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming Logoff message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
27 Nov 2008	conjk3	PAR #18478 - Supress errors when logging off if already logged off
08 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Add in default response build

*/

vars
	mediator		: CM_RadioTelemetryMediator;
	passport		: CM_Passport;
	
begin
	passport := app.myPassport;
	
	// Validate number of parameters first
	_message.validateNumberOfParameters(1);

	// Validate and setup for machine
	_message.validateMachineAndMediator();

	// cnwjk3 PAR 18478 27/11/08
	// Process Logoff message
	mediator := _message.myMediator;
	
	if mediator &lt;&gt; null then
		// Validate current task - should not have one
		_message.validateTasks(TASK_UNKNOWN);

		app.myTrxRT.trxLogoffForInterface(mediator, null, passport);
	endif;
	
	if passport.hasErrors() then
		return false;
	endif;
	
	// Got to here, then all OK
	return true;
	
epilog
	_message.createDefaultResponse(0);		// PAR #18526
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessLogon" id="3591bf3f-960d-433b-8ce7-452c6f6f059f">
        <source>doProcessLogon(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming Logon message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Allow Logon message if already logged on with the same user
					Add in default response build
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
11 Mar 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
 8 Feb 2011 cnwer1  PAR 26908 - now passing in _machine to app.myRoot.concurrentAppSignonCheck
*/

vars
	machine			: CM_Machine;
//	machineId		: String;
	passport 		: CM_Passport;
	terminal		: CM_Terminal;
	user			: CM_User;
	userId			: String;
	errorCode		: Integer;
	msg				: String;
	exObj			: CM_Exception;
begin
	passport := app.myPassport;
	terminal := app.getMyTerminalDO_NOT_USE();

	// Validate number of parameters first
	_message.validateNumberOfParameters(2);
	
	// Validate machine
	_message.validateMachine();
	machine := _message.myMachine;
	
	// PAR #18526 - re-ordered code to validate User first to allow Logon when already logged on
	userId := _message.allInputFields[2].toUpper;
	user := app.myRoot.allUsers[userId];
	if user = null then
		app.raiseCMException(ERR_PASSWORD, null, null);
	endif;
	passport.setMyUser(user);

	// Allow duplicate logon messages if already logged on with the same User
	if machine.loggedOn and machine.user &lt;&gt; user then
		app.raiseCMException(ERR_MS_ALREADY_LOGGED_ON, null, null);
	endif;
	
	if not app.myRoot.concurrentAppSignonCheck(user, errorCode,machine,null, passport) then //+ cnwmd1 Par 22287
		msg := app.getErrorString(errorCode);
		app.myRoot.resolveMessagesWithExtraInfo(errorCode, msg);
		create exObj transient;
		exObj.set(errorCode, msg, false, null, null, null);
		raise exObj;
	endif;
		
	// Process Logon message
	app.myTrxRT.trxLogonForInterface(_message.myMachine, true, null, passport);
	if passport.hasErrors() then
		return false;
	endif;
	
	// Validate and setup for machine
	_message.validateMachineAndMediator();
	
	// Create reply for successful Logon  message
	self.createLogonResponse(_message);
	
	// Got to here, then all OK
	return true;
	
epilog
	_message.createDefaultResponse(3);		// PAR #18526, PAR #18743 (increased fields to 3)
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessNextJob" id="1279bfc5-67b7-4bd4-b6f0-bcf6c29aa89b">
        <source>doProcessNextJob(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming NextJob message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
28 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					If machine currently has a task assigned, then just return the details
					of that task, without an error
					Add in default response build
10 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
24 Feb 2009	cnwkpd1	PAR #18637 - Need to return an error here if we are in Set Down mode on
					the existing task, because this implies that the machine has gotten out of 
					step with the interface, and control will need to fix things up.
					
*/

vars
	passport		: CM_Passport;
	task			: CM_RTQueueTask;
	expectedType	: Integer;
	
begin
	passport := app.myPassport;

	// Validate number of parameters first
	_message.validateNumberOfParameters(1);

	// Validate and setup for machine
	_message.validateMachineAndMediator();

	// PAR #18526 - allow NextJob to continue if the machine already has a task
	task := _message.getTask();
	expectedType := TASK_UNKNOWN;
	
	
	if task = null then
		// Validate current task - should not have one
		_message.validateTasks(expectedType);
	
		// Request next task
		app.myTrxRT.trxRequestTask(_message.myMediator, null, passport);
	
	else
		// Anything other than a Set Down is OK - PAR #18637
		if task.taskType &lt;&gt; TASK_SETDOWN then
			expectedType := task.taskType;
		endif;
		
		//app.myTrxRT.trxRequestTwinTask(_message.myMediator,task, null, passport);
		// And validate the task either way, just in case the task has been allocated to another 
		// machine in the meantime
		_message.validateTasks(expectedType);
		
		
		
		// Update the last update timestamp
		app.myTrxRT.trxUpdateMediatorTimeStamp(_message.myMediator, null, passport);
	
	endif;
	
	if passport.hasErrors() then
		return false;
	endif;

	// Create reply for successful Next Job message
	self.createNextJobResponse(_message);
	
	// Got to here, then all OK
	return true;
	
epilog
	_message.createDefaultResponse(8);		// PAR #18526, PAR #18743 (changed no of fields)
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessPickup" id="86f3bc24-b93a-45c0-92a6-dd433ce9b26f">
        <source>doProcessPickup(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming Pickup message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
08 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Add in default response build
09 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
17/08/2009	cnwrl1	PAR 19668 - CCMS 1814 - Provide an audit trail of TCP message traffic
*/

vars
	acceptTask		: Boolean;
//	containerId,									// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
//	containerId2	: String;						// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	passport		: CM_Passport;
	task			: CM_RTQueueTask;
//	matches			: Integer;						// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	numberOfMatches	: Integer;						// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	ti,
	twinTI			: CM_TrackedItem;
	terminal		: CM_Terminal;
	
begin
	passport := app.myPassport;
	terminal := app.getMyTerminalDO_NOT_USE();
	
	// Validate number of parameters first
	_message.validateNumberOfParameters(3);

	// Validate and setup for machine
	_message.validateMachineAndMediator();

//	containerId := _message.allInputFields[2];		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	_message.setContainerId( _message.allInputFields[2] );
	
//	if containerId = null then						// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if _message.containerId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ContainerID), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ContainerID), null, null); // cnwdb2	PAR 35364
	endif;
	
//	containerId2 := _message.allInputFields[3];		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	_message.setContainerId2( _message.allInputFields[3] );

	// If a second container Id is supplied, then must be a Twin Lift
//	if containerId2 &lt;&gt; null then					// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if _message.containerId2 &lt;&gt; null then
		_message.validateMachineIsTwinLift();
	endif;
	
	// Need to determine what type of pickup this is
	task := _message.getTask();
	
	// If we have a task
	if task &lt;&gt; null then

		// If the task already has a ti assigned, then validate it is in the correct state,
		// and execute the pickup
		if task.ti &lt;&gt; null then
	
			// Validate current task
			_message.validateTasks(TASK_PICKUP);
		
//			_message.validateContainers(containerId, containerId2);		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
			_message.validateContainers();
			
			// Process Pickup message
			acceptTask := task.status = TASK_OFFERED;
						
			app.myTrxRT.trxPickupWithTask(_message.myMediator, null, acceptTask, null,null, passport);
			if not passport.trxCompletedOK then
				return false;
			endif;

		else
			// Should be a Director task, so we need to action this
			
			// Validate current tasks
			_message.validateTasks(TASK_DIRECTOR);
	
			// Action the Director task and pick it up
			acceptTask := task.status = TASK_OFFERED;
			/* cnwrl1 14/05/2009 PAR 19668 - CCMS 1814 - what it was
			app.myTrxRT.trxActionDirectorTask(containerId, 
											  containerId2,
											  _message.myMediator, 
											  acceptTask, 
											  true, 
											  passport);
			end of what it was - cnwrl1 14/05/2009 PAR 19668 - CCMS 1814 */
			app.myTrxRT.trxActionDirectorTask(	_message.containerId,
												_message.containerId2,
												_message.myMediator,
												acceptTask,
												true,
												null,
												null,
												null,
												passport );
			
			if not passport.trxCompletedOK then
				return false;
			endif;

		endif;
	
	else		// We don't have a task, so could be yard or crane pickup
	
		// First determine if we have unique container(s) (onsite plus onship)
//		ti := terminal.searchForOnsiteOrQueueOnshipTI(containerId, matches, TI_CargoType_Container);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		ti := terminal.searchForOnsiteOrQueueOnshipTI(_message.containerId, numberOfMatches, TI_CargoType_Container, true);
//		if matches &lt;&gt; 1 then							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		_message.setNumberOfMatches( numberOfMatches );
		if _message.numberOfMatches &lt;&gt; 1 then
			// Passed in Container Id is not unique
//			app.raiseCMException1(ERR_MULTIPLE_ITEMS, matches.String, null, null);		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
			app.raiseCMException1( ERR_MULTIPLE_ITEMS, _message.numberOfMatches.display, null, null );
			return false;
		endif;
		
		// If there's a second container ID passed in, then check that too
//		if containerId2 &lt;&gt; null then					// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		if _message.containerId2 &lt;&gt; null then
//			twinTI := terminal.searchForOnsiteOrQueueOnshipTI(containerId2, matches, TI_CargoType_Container);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
			twinTI := terminal.searchForOnsiteOrQueueOnshipTI(_message.containerId2, numberOfMatches, TI_CargoType_Container, true);
//			if matches &lt;&gt; 1 then						// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
			_message.setNumberOfMatches( numberOfMatches );
			if _message.numberOfMatches &lt;&gt; 1 then
				// Passed in Container Id is not unique
//				app.raiseCMException1(ERR_MULTIPLE_ITEMS, matches.String, null, null);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
				app.raiseCMException1( ERR_MULTIPLE_ITEMS, _message.numberOfMatches.display, null, null );
				return false;
			endif;
			
			// Also need to check both containers are in the "same place"
			if ti.isOnSite &lt;&gt; twinTI.isOnSite then
//				app.raiseCMException2(ERR_TWIN_LIFT_LOCATION_TIS, containerId, containerId2, null, null);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
				app.raiseCMException2(ERR_TWIN_LIFT_LOCATION_TIS, _message.containerId, _message.containerId2, null, null);
				return false;
			endif;
		endif;
		
		// Got to here, then container ids are OK, and they are either both on site, or both on ship

		// If the container(s) is/are onsite, then need to find tasks for them in my queue
		if ti.isOnSite then
			app.myTrxRT.trxActionYardPickup(ti, twinTI, _message.myMediator, true, null, passport);
			if not passport.trxCompletedOK then
				return false;
			endif;
		else
			// TI(s) must be on ship, so need to perform a crane pickup
			app.myTrxRT.trxActionCranePickup(ti, twinTI, _message.myMediator, true, true, null, passport);
			if not passport.trxCompletedOK then
				return false;
			endif;
		endif;
		
	endif;
	
	// Create reply for successful Pickup message
	self.createPickupResponse(_message);

	// Got to here, then all OK
	return true;	
	
epilog
	_message.createDefaultResponse(1);		// PAR #18526
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessReject" id="7558d57a-e818-4405-84b2-b4cc2d5d575e">
        <source>doProcessReject(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming Reject message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
04 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Allow reject with no current task - no error returned
					Add in default response build

*/

vars
	task	: CM_RTQueueTask;

begin
	// Validate number of parameters first
	_message.validateNumberOfParameters(1);

	// Validate and setup for machine
	_message.validateMachineAndMediator();

	// Validate current task
	task := _message.getTask;
	if task = null then
		// Do nothing
	elseif task.machine &lt;&gt; _message.myMachine then
		app.raiseCMException1(ERR_RT_PHASE_STARTUP, _message.functionName , null, null);
	elseif task.taskType = TASK_SETDOWN then
		app.raiseCMException1(ERR_RT_PHASE_SETDOWN, _message.functionName , null, null);
	endif;

	// Process Reject message
	app.myTrxRT.trxRejectTask(_message.myMediator, null, app.myPassport);
	
	// Got to here, then all OK
	return true;
	
epilog
	_message.createDefaultResponse(0);		// PAR #18526
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessSendFaultResponse" id="746151cf-b2f3-4ad9-a6bf-c1e00a32a194">
        <source>doProcessSendFaultResponse(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming SendFaultResponse message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
08 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Add in default response build

*/

vars
	driverResponse	: String;
	questionNo		: Integer;
//	uniqueID		: String;							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	mediator		: CM_RadioTelemetryMediator;
	
begin
	// Validate number of parameters first
	_message.validateNumberOfParameters(3);
	
	// Validate and setup for machine
	_message.validateMachineAndMediator();
	
	mediator := _message.myMediator;

	// Get parameters
//	uniqueID		:= _message.allInputFields[2];		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	_message.setUniqueId( _message.allInputFields[2] );
	
	driverResponse	:= _message.allInputFields[3].trimBlanks.toLower;
	driverResponse.firstCharToUpper;
	_message.setDriverResponse( driverResponse );		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	
	/* cnwrl1 14/05/2009 PAR 19668 - CCMS 1814 - what it was
	if uniqueID.isInteger then
		questionNo := uniqueID.Integer;
	endif;
	*/
	if _message.uniqueId.isInteger then
		questionNo := _message.uniqueId.Integer;
	endif;

	// Validate unique Id
	if questionNo &lt; 1 or questionNo &gt; _message.myMediator.allFaultResponses.size then
		app.raiseCMException(ERR_MACH_INVALIDQUESTIONID, null, null);
	endif;
	
	// Validate response
	if driverResponse &lt;&gt; AuditStringValue_Yes and driverResponse &lt;&gt; AuditStringValue_No then
		app.raiseCMException1(ERR_MACH_INVALIDFAULTRESP, driverResponse, null, null);
	endif;

	// Process SendFaultResponse message
	app.myTrxUA.trxUpdateMediatorResponseValue(mediator,		// _mediator : CM_RadioTelemetryMediator input;
											   questionNo,		// _index : Integer;
											   driverResponse,	// _response : String;
											   app.myPassport);
	
	// Got to here, then all OK
	return true;
	
epilog
	_message.createDefaultResponse(0);		// PAR #18526
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessSetDown" id="1e47b906-9e48-49c1-b192-1dbfe58ebdc9">
        <source>doProcessSetDown(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming SetDown message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
08 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Add in default response build
09 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
15 Jul 2011	NDL	Par 26414 - Actually use the twinlift trx!!

*/

vars

	setDownLocation	: String;
	primaryTask : CM_RTQueueTask;
	twinTask : CM_RTQueueTask;
	twinSetdownLocation : String;
	
begin
	// Validate number of parameters first
	_message.validateNumberOfParameters(3);
	
	// Validate and setup for machine
	_message.validateMachineAndMediator();

	// Get and validate 1st container number
	_message.setContainerId( _message.allInputFields[2] );
	if _message.containerId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ContainerID), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ContainerID), null, null); // cnwdb2	PAR 35364
	endif;
	
	// Get and validate 2nd container number
	_message.setContainerId2( _message.allInputFields[3] );
	if _message.containerId2 &lt;&gt; null then
		_message.validateMachineIsTwinLift();
	endif;
	
	// Validate current tasks
	_message.validateTasks(TASK_SETDOWN);
	
	// Validate container numbers
	_message.validateContainers();
	
	primaryTask :=  _message.getTask();
	twinTask := _message.getTwinTask();
	
	setDownLocation := primaryTask.ultimateTargetLocationId.trimRight();
	if twinTask &lt;&gt; null then
		twinSetdownLocation := twinTask.ultimateTargetLocationId.trimRight();
	endif;
	_message.setLocationDestination( setDownLocation );		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814

	// Process SetDown message	
//	app.myTrxRT.trxSetdownWithTask(_message.myMediator, setDownLocation, null, null, app.myPassport);
	
	app.myTrxRT.trxSetdownTaskTwin(	_message.myMachine,	//_machine : CM_Machine input;
									primaryTask,	//_rtTask,
									twinTask,	//_rtTwinTask: CM_RTQueueTask input;
									setDownLocation,	//_setDownLocation,
									twinSetdownLocation,	//_rtTwinSetdownLocation : String; 
									false,	//_overrideToInterchange : Boolean;
									app.myPassport	//_passport : CM_Passport input
									);
	
	
	// Got to here, then all OK
	return true;
	
epilog

	_message.createDefaultResponse(0);		// PAR #18526
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessSwap" id="a6ee03fd-3986-4738-aa8c-5b2f8dc07538">
        <source>doProcessSwap(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming Swap message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
//	containerId,										// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
//	containerId2	: String;							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	task,
	twinTask		: CM_RTQueueTask;
	
begin
	// Validate number of parameters first
	_message.validateNumberOfParameters(3);
	
	// Validate and setup for machine
	_message.validateMachineAndMediator();
	
	// Check machine is a twin lift
	_message.validateMachineIsTwinLift();
	
	// Get and validate 1st container number
//	containerId := _message.allInputFields[2];			// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	_message.setContainerId( _message.allInputFields[2] );
//	if containerId = null then							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if _message.containerId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ContainerID), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ContainerID), null, null); // cnwdb2	PAR 35364
	endif;
	
	// Get and validate 2nd container number (mandatory)
//	containerId2 := _message.allInputFields[3];			// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	_message.setContainerId2( _message.allInputFields[3] );
//	if containerId = null then							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if _message.containerId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ContainerID), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ContainerID), null, null); // cnwdb2	PAR 35364
	endif;
	
	// Validate current task(s)
	_message.validateTasks(TASK_SETDOWN);
	
	// Validate container numbers
//	_message.validateContainers(containerId, containerId2);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	_message.validateContainers();
	
	// Do the swap
	task := _message.getTask();
	twinTask := _message.getTwinTask();
	app.myTrxRT.trxSwapTargetLocations(_message.myMediator, task, twinTask, app.myPassport);
	
	// Got to here, then all OK
	return true;
	
epilog
	_message.createDefaultResponse(0);
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessValidateCraneQueue" id="75760d57-04d7-4eac-84b3-3dd1f742724f">
        <source>doProcessValidateCraneQueue(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 March 2011	cnwndl1	Initial creation	Par 27290

*/

vars

	passport		: CM_Passport;
	queue			: CM_RadioTelemetryQueue;
	crane 			: CM_Crane;
	craneId			: String;
	field			: String; 
	response		: CMIF_InterfaceResponse;

begin

	passport := app.myPassport;
	
	// Validate number of parameters first
	_message.validateNumberOfParameters(1);
	
	// Validate and setup for machine
	_message.validateMachineAndMediator();
	
	if _message.myMachine &lt;&gt; null then
	
		queue := _message.myMachine.myPrimaryQueue;
		
		if queue &lt;&gt; null then
			if queue.isCraneQueue then
				crane := queue.CM_VoyageCraneQueue.crane;
				if crane &lt;&gt; null then
					craneId := crane.id;
					_message.setCraneId( craneId );
					field := craneId;
				endif;
			else
				app.raiseCMException2(Voyag_crane_queue_contr_move_i, _message.myMachine.id, queue.id, null, null);
				return false;
			endif;
		endif;
	
	endif;
	
	response := _message.createResponseLine();
	response.allResponseFields.add(field);
	
	return true;

epilog

	_message.createDefaultResponse(1);

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessValidateDischarge" id="816b2834-4126-479a-881a-ecf25fe5651e">
        <source>doProcessValidateDischarge(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 March 2011	cnwndl1	Initial creation	Par 27290

*/

vars

	numberOfMatches	: Integer;							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	passport		: CM_Passport;
	task			: CM_RTQueueTask;
	ti				: CM_TrackedItem;
	
	sourceLocation	: CM_LocationsController;
	terminalArea	: CM_TerminalArea;
	
begin

	passport := app.myPassport;

	// Validate number of parameters first
	_message.validateNumberOfParameters(2);
	
	// Validate and setup for machine
	_message.validateMachineAndMediator();
	
	// Validate that there is no current task
	_message.validateTasks(TASK_UNKNOWN);

	// Get and validate container number
	_message.allInputFields[2] := _message.allInputFields[2].trimBlanks();  //cnwjo3 par 20483
	_message.setContainerId( _message.allInputFields[2] );
	_message.setPartialContainerId( _message.allInputFields[2] );	// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814

	if _message.containerId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ContainerID), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ContainerID), null, null); // cnwdb2	PAR 35364
	endif;
	
	ti := app.getMyTerminalDO_NOT_USE().searchForOnsiteOrQueueOnshipTI( _message.containerId, numberOfMatches, TI_CargoType_Container, false );
	
	// Update the last update timestamp
	app.myTrxRT.trxUpdateMediatorTimeStamp(_message.myMediator, null, app.myPassport);
		
	// Create reply for successful ValidateMove message
	_message.setNumberOfMatches( numberOfMatches );				// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if numberOfMatches = 1 and ti &lt;&gt; null then
	_message.setContainerId( ti.id );
	endif;
	self.createValidateMoveResponse( _message, ti );
	
	// Got to here, then all OK
	return true;
	
epilog
	_message.createDefaultResponse(2);		// PAR #18526
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessValidateMove" id="0c9a8aa1-0fd0-414a-a340-093e46109239">
        <source>doProcessValidateMove(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming ValidateMove message

Parameters:			Incoming message controller, structure validated and parsed

Return Value:		_message updated with appropriate return values


Date		Who		Reason
16 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
04 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Allow validateMove from "startup mode" to find a matching queue
					entry or perform a crane pickup
					Add in default response build
09 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					ValidateMove no longer does Pickup
					
*/

vars

	numberOfMatches	: Integer;							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	passport		: CM_Passport;
	task			: CM_RTQueueTask;
	ti				: CM_TrackedItem;
	
	allTerminalTis	: CM_TISet;
	allTermAreaTis	: CM_TISet;
	sourceLocation	: CM_LocationsController;
	locController	: CM_LocationsController;
	terminalArea	: CM_TerminalArea;
	iter			: Iterator;
	
begin

	passport := app.myPassport;

	// Validate number of parameters first
	_message.validateNumberOfParameters(2);
	
	// Validate and setup for machine
	_message.validateMachineAndMediator();

	// Get and validate container number
	_message.allInputFields[2] := _message.allInputFields[2].trimBlanks();  //cnwjo3 par 20483
	_message.setContainerId( _message.allInputFields[2] );
	_message.setPartialContainerId( _message.allInputFields[2] );	// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814

	if _message.containerId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ContainerID), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ContainerID), null, null); // cnwdb2	PAR 35364
	endif;
	
	// Have we got a task?
	task := _message.getTask();
	
	// If we have, then it must be a Director task, and we can process that
	if task &lt;&gt; null then
	
		// Validate current task
		_message.validateTasks(TASK_DIRECTOR);
	
		// Do container search
//		ti := app.getMyTerminalDO_NOT_USE().searchForOnsiteTI( _message.containerId, numberOfMatches, TI_CargoType_Container );


		//30 Mar 2011	NDL	Par 27290
		create allTerminalTis transient;
		// get a set of the tis in the terminal matching the id or part id submitted.
		app.getMyTerminalDO_NOT_USE().getTIsMatchingId( _message.containerId, TI_CargoType_Container, allTerminalTis, TI_STATE_NORMAL );
		
		numberOfMatches := allTerminalTis.size;
		
		if numberOfMatches = 1 then
			// there was only one found, so this is it.
			ti := allTerminalTis.first;
			
		elseif numberOfMatches &gt; 1 then
			// there is more than one, try checking for only those in the specified terminal area. (If we have a TA specified)
			sourceLocation := task.sourceLocation;
			if sourceLocation &lt;&gt; null then
				terminalArea := sourceLocation.myTerminalArea;
				if terminalArea &lt;&gt; null then
				
					//set up the TA sub set
					create allTermAreaTis transient;
					iter := allTerminalTis.createIterator;
					while iter.next( ti ) do
						locController := ti.myPrimaryActualLocation;
						if locController = null then
							continue;
						endif;
						if locController.myTerminalArea = terminalArea then
							allTermAreaTis.addNoDuplicates(ti, false);
						endif;
					endwhile;
					
					// if we have some in the terminal area, set the number of matches.
					if allTermAreaTis.size = 1 then
						numberOfMatches := 1;
						ti := allTermAreaTis.first;
					elseif not allTermAreaTis.isEmpty then
						numberOfMatches := allTermAreaTis.size;
					endif;
					
				endif;
			endif;
		endif;
		// end of 27290
		
	else
		// If we don't have a current task, then this is a "pickup" move
		// First determine if we have a unique container (onsite plus onship)
		ti := app.getMyTerminalDO_NOT_USE().searchForOnsiteOrQueueOnshipTI( _message.containerId, numberOfMatches, TI_CargoType_Container, true );
			
	endif;
	
	// Update the last update timestamp
	app.myTrxRT.trxUpdateMediatorTimeStamp(_message.myMediator, null, app.myPassport);
		
	// Create reply for successful ValidateMove message
	_message.setNumberOfMatches( numberOfMatches );				// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	if numberOfMatches = 1 and ti &lt;&gt; null then
	_message.setContainerId( ti.id );
	endif;
	self.createValidateMoveResponse( _message, ti );
	
	// Got to here, then all OK
	return true;
	
epilog
	_message.createDefaultResponse(2);		// PAR #18526
	delete allTerminalTis;
	delete allTermAreaTis;
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleCMException" id="0a1c3b5c-0618-4fc3-aca3-2d47b5c00f55">
        <source>handleCMException( _exc : CM_Exception ) : Integer;
// handleCMException(_exc : CM_Exception) : Integer protected;	// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814

/*

Purpose:			Handle CM_Exceptions during the processing of a TCP message request

Parameters:			CM_Exception object

Return Value:		Exception return code


Date		Who		Reason
11 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	if _exc.isWarning then
		app.myPassport.addWarningFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc.mySubject);
		if _exc.continuable then
			return Ex_Continue;
		else
			abortTransaction;
			abortTransientTransaction;
			return Ex_Resume_Next;
		endif;
	else
		// If the dump option is set, then do a dump for diagnostic purposes
		if self.dumpCMExceptions then
			app.doDumpStack(_exc);
		endif;
		
		abortTransaction;
		abortTransientTransaction;
		app.myPassport.addErrorFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc);
		return Ex_Resume_Next;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_exc" type="CM_Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleRequestException" id="8f6a4f0e-9635-41a2-a1b2-de9094fc1394">
        <updating/>
        <source>handleRequestException(_exc : Exception) : Integer updating, protected;

/*

Purpose:			Generic exception handler for processRequest.  Will catch and log every
					exception, and resume if possible to allow a response to be sent to the
					client.

Parameters:			Exception object

Return Value:		Standard exception return code


Date		Who		Reason
10 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	str				: String;
	
begin
	// First log details of exception for analysis
	str	:= "Exception " &amp; _exc.errorCode.String &amp; " (" &amp; _exc.text &amp; ")";
	if _exc.extendedErrorText &lt;&gt; null then
		str := str &amp; ", extendedErrorText=" &amp; _exc.extendedErrorText;
	endif;
	app.writeLog(str, LogERROR);	//26 Nov 2019	NDL	TFS 47053

	// And dump stack as well
	app.doDumpStack(_exc);

	// Unconditionally abort
	abortTransaction;
	abortTransientTransaction;

	// If the exception is resumable, then add an error to the current passport and 
	// resume in the processRequest method
	if _exc.resumable then
		app.myPassport.addErrorFull(_exc.errorCode,												// pErrorCode : Integer; 
									'Code :' &amp; _exc.errorCode.String &amp; '. ' &amp; _exc.text,		// pText, 
									null, 														// pField : String; 
									null,														// pObject : Object; 
									null);														// _exObj : Exception)
		
		app.writeLog(method.qualifiedName &amp; " finished, transaction aborted and locks released, return Ex_Resume_Next", LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return Ex_Resume_Next;
	endif;
	
	// If it is not resumable, the abort the current action
	app.writeLog(method.qualifiedName &amp; " finished, transaction aborted and locks released, return Ex_Abort_Action", LogERROR);	//26 Nov 2019	NDL	TFS 47053
	return Ex_Abort_Action;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleRequestLockException" id="0a7fb6ff-58bd-4f51-a1c0-dfd43c120a68">
        <source>handleRequestLockException(_exc : LockException io) : Integer protected;

/*

Purpose:			Handle lock exceptions encountered during the processing of a message

Parameters:			Lock Exception

Return Value:		Standard JADE exception return code


Date		Who		Reason
24 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars

begin
	// Just allow CardSchema lock exception to handle
	return app.cnGlobalLockExceptionHandler(_exc);
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="LockException" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseForNewRequest" id="f4f4c417-3bc9-4a3c-9309-af677d0965a2">
        <updating/>
        <source>initialiseForNewRequest() updating, protected;

/*

Purpose:			Perform any processing required to initialise Agent state at the start of
					a new request

Parameters:			None

Return Value:		None


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
17 Nov 2008	cnwkpd1	PAR #18377 - Ignore warnings in TCP interface

*/

vars
	passport		: CM_Passport;
	
begin
	passport := app.myPassport;
	passport.initialiseTransaction();
	
	// Default to warnings ignored - PAR #18377
	passport.setWarningsIgnored(true);
	
	// Default to automatic acceptance of warnings (interface does not have a dialog to manually acknowledge them)
	passport.warningsAcknowledged := true;
	
	// Set defaults as an anonymous user, because we don't know who the message is coming
	// from until it has been decoded
	passport.setMyUserFromCode( SUPERUSER_Str );
	
	// Unconditionally set terminal from interface definition
	app.setMyTerminal(self.myInterfaceDefinition.myTerminal);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processReqMessageDeadlockCheck" id="1b194a83-e0ba-4a12-aae6-fe6ce5c7923f">
        <source>processReqMessageDeadlockCheck(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2011	cnwndl1	Initial creation	Par 26304
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt

*/

vars

	success : Boolean;

begin

	// set up for dead lock replay 
	// -100 as prioirty is very low, means be sub servient if a deadlock occurs, let the other guy have it.
	// 2000 (milliseconds) = 2 seconds, how long to wait if we do get locked out
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		// call the updating portion where the dead lock could occur
		success := self.processRequestMessage(_message);
		
		if app.myPassport.hadDeadlock = false then
			//no dead lock, all is good carry on
			break;
		endif;
		
		app.writeLog(method.qualifiedName &amp; " Deadlock detected", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		
		if app.myPassport.silentDeadlockRetryCount &gt; app.myPassport.silentDeadlockLimit then
			// had enough attempts, call it a day.
			break;
		endif;

		app.writeLog(" Deadlock, sleep, retry in " &amp; app.myPassport.silentDeadlockSleepTime.String &amp; " ms", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

		//give the other guy a couple of seconds to finish his job before we try again
		process.sleep(app.myPassport.silentDeadlockSleepTime);
		app.myPassport.hadDeadlock := false;
		
		//unconditionally clear the message response array
		_message.clearResponsePreDeadlockRetry();
		
	endwhile;
	
	return success;

epilog

	// reset the process dead lock stuff to the default values again
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processRequestMessage" id="1be28086-f80b-47cc-9149-16794a2face1">
        <source>processRequestMessage(_message : CMIF_InterfaceMsgController input) : Boolean protected;

/*

Purpose:			Process the incoming message object, which has been created by the parsing
					of the raw input string

Parameters:			Incoming transient message controller

Return Value:		_message controller updated ready for building an output string for the client


Date		Who		Reason
15 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	functionName	: String;
	
begin
	// Call appropriate method based on operation name 
	functionName := _message.functionName;
	
	if functionName = TCP_FUNCTION_INITIALISE then
		return self.doProcessInitialise(_message);
	
	elseif functionName = TCP_FUNCTION_LOGON then
		return self.doProcessLogon(_message);
	
	elseif functionName = TCP_FUNCTION_LOGOFF then
		return self.doProcessLogoff(_message);
	
	elseif functionName = TCP_FUNCTION_SENDFAULTRESPONSE then
		return self.doProcessSendFaultResponse(_message);
	
	elseif functionName = TCP_FUNCTION_NEXTJOB then
		return self.doProcessNextJob(_message);
	
	elseif functionName = TCP_FUNCTION_REJECT then
		return self.doProcessReject(_message);
	
	elseif functionName = TCP_FUNCTION_PICKUP then
		return self.doProcessPickup(_message);
	
	elseif functionName = TCP_FUNCTION_VALIDATEMOVE then
		return self.doProcessValidateMove(_message);
	
	elseif functionName = TCP_FUNCTION_VALIDATEDISCHARGE then	//29 Mar 2011	NDL	Par 27290
		return self.doProcessValidateDischarge(_message);
	
	elseif functionName = TCP_FUNCTION_VALIDATECRANEQUE then	//29 Mar 2011	NDL	Par 27290
		return self.doProcessValidateCraneQueue(_message);
	
	elseif functionName = TCP_FUNCTION_GETDESTINATION then
		return self.doProcessGetDestination(_message);
	
	elseif functionName = TCP_FUNCTION_SETDOWN then
		return self.doProcessSetDown(_message);
	
	elseif functionName = TCP_FUNCTION_SWAP then			// PAR #18743
		return self.doProcessSwap(_message);

	else
		// Invalid function name
		app.raiseCMException1(ERR_TCP_INVALID_FUNCTION, functionName, null, null);
		return false;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processRequestString" id="9b46d982-3b95-492c-b796-d7909e6ee46d">
        <updating/>
        <source>processRequestString( _request : String ) : String updating;

/*

Purpose:			Process the input message passed in, and return the appropriate response

Parameters:			Input message string from client

Return Value:		String response to send back


Date		Who		Reason
05 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Add in lock exception handler for retries
18/05/2009	cnwrl1	PAR 19668 - CCMS 1814 - handle building of InterfaceHistory instances
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	message			: CMIF_InterfaceMsgController;
	outputString	: String;
	
begin
	// Arm local exception handlers to ensure we always return something
	on Exception do self.handleRequestException(exception);
	on LockException do self.handleRequestLockException(exception);
	on CM_Exception do self.handleCMException(exception);
	
	// Start by initialising state
	self.initialiseForNewRequest();
	
	// Create the message controller
	create message transient;
	message.setRequestTimeStamp( app.actualTimeServer );		// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	message.setMyInterfaceDefinition( self.myInterfaceDefinition );
	message.setupFromTCPAgent( self );			// PAR #18526
	message.setInputRequest( _request );
	
	// Validate overall message format - validate the input request and parse the message
	message.validateRequestFormat();
	
	// If OK, then process the request
	if app.myPassport.noErrors() then
		// Call the appropriate method to process the request
		//self.processRequestMessage( message );
		self.processReqMessageDeadlockCheck( message );	//18 Jan 2011	NDL	Par 26304 - extra deadlock protection
	endif;
	
	// Build the response string
	outputString	:= message.buildOutputResponseString;
	
	message.setResponseTimeStamp( app.actualTimeServer );	// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	message.buildAndCreateInterfaceHistory( self );				// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814
	
	// Send the reply
	return outputString;
	
epilog
	delete message;
	
end;</source>
        <Parameter name="_request" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyInterfaceDefinition" id="d907782f-f07f-4b1a-b788-696d04c6a5f0">
        <updating/>
        <source>setMyInterfaceDefinition(_interface : CM_TCPInterfaceDefinition) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	self.myInterfaceDefinition := _interface;
	
	
epilog

end;</source>
        <Parameter name="_interface" type="CM_TCPInterfaceDefinition"/>
    </JadeMethod>
    <JadeMethod name="setupFromTCPController" id="3b77c14e-aa80-4e7b-89e1-9025d746565f">
        <updating/>
        <source>setupFromTCPController(_controller : CM_TCPWorkerController) updating;

/*

Purpose:			Setup the receiver with any options from the owning controller

Parameters:			Owning controller object

Return Value:		None


Date		Who		Reason
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes

*/

vars

begin
	self.dumpCMExceptions := _controller.dumpCMExceptions;
	self.returnErrorCodes := _controller.returnErrorCodes;
	self.suppressWarnings := _controller.suppressWarnings;
	

epilog

end;</source>
        <Parameter name="_controller" type="CM_TCPWorkerController"/>
    </JadeMethod>
</Class>
