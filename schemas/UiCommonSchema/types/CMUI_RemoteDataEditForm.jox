    <JadeMethod name="addToolbarControls" id="2fe22008-7dc0-4ae0-9d56-2a4596b8f686">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBackT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnProcessT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	

end;</source>
        <access>protected</access>
    </JadeMethod>
