    <JadeMethod name="translateForm" id="6fdf7484-f2e3-46e0-ab7c-c79184aacfd2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 28 November 2024 13:44:55.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025851, locale);
	btnClose.translateCaption(Xlat_0025852, locale);
	btnFind.translateCaption(Xlat_0025853, locale);
	btnTrans.translateCaption(Xlat_0027003, locale);
	lblBusinessUnit.translateCaption(Xlat_0025854, locale);
	lblContractFromEnd.translateCaption(Xlat_0025855, locale);
	lblContractFromStart.translateCaption(Xlat_0025856, locale);
	lblContractId.translateCaption(Xlat_0025857, locale);
	lblDebtor.translateCaption(Xlat_0025858, locale);
	lblVessel.translateCaption(Xlat_0025859, locale);
	lblVoyage.translateCaption(Xlat_0025860, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025861, locale);
	mnuContextMenu.translateCaption(Xlat_0025862, locale);
	mnuInspectObject.translateCaption(Xlat_0025863, locale);
end;</source>
    </JadeMethod>
