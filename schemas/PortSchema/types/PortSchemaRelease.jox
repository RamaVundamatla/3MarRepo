    <JadeMethod name="rebuildMasterDataDumpObjs" id="c685ef4e-9808-43ad-ba89-a343a8c9ad26">
        <updating/>
        <source>rebuildMasterDataDumpObjs(_controller: CnEcReleaseController) updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 May 2004	cnwth2
//
// Purpose:     Rebuilds the root.allDataDumpClasses and associated features from the method text in 
//				CM_DataDumpMaintenanceAgent::maintainDataDumpClasses
//				This defines all possible dataDump classes and features and writes out all 
//				classes to the ini file of the environment for the change tracker to use.
//
//				(Users define which of these they wish to use from the data extract maintenance
//				screen under system ops (sysops schema))
//			 
// ----------   ----------  --------------------------------------------------
vars
	def : CM_DataDumpExtractDef;
	agent : CM_DataDumpMaintenanceAgent;
begin
	create agent transient;
	agent.maintainDataDumpClasses();
	agent.maintainDataDumpFeatureUpdate();	//PAR19114 DSS speed up cnwrs1 apr 2009
	agent.maintainDataDumpDefStoredProcs(); //par 32645 set flags to rebuild stored procs on next execution
	if not app.myPassport.trxCompletedOK then	
		app.writeLog('Maintain Extract Classes had errors ' &amp; CrLf  &amp; app.myPassport.getErrorsAsString, LogINFO);
		_controller.logEntry('There were errors building the master data dump classes and features - these have been logged');
	endif;
	
	_controller.logEntry('Rebuild of master data-dump classes and features successful');
epilog
	delete agent;
end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="removeInstOfOldClasses" id="a8f5e933-b268-4fd5-80b7-be80161b39c7">
        <source>removeInstOfOldClasses(_className : String) protected;
//
// Find and erase all instance of a class (the class does have to exist in this Schema)
//
vars
	classNames : StringArray;
	clsName	: String;
	cls	: Class;
	objects	: ObjectArray;
	obj	: Object;
begin
	create classNames transient;
	create objects transient;
	classNames.add(_className);
	foreach clsName in classNames do
		cls := currentSchema.getClass(clsName);
		if cls = null then
			app.writeLog( "Class " &amp; clsName &amp; " not found",0);
			continue;
		else
			app.writeLog( "Class " &amp; clsName &amp; " found.  Checking for instances.",0);
		endif;
		objects.clear;
		cls.allInstances(objects, 0, false);
		if objects.isEmpty then
			app.writeLog( Tab &amp; "No instances of " &amp; clsName &amp; " found.",0);
			continue;
		endif;
		app.writeLog( Tab &amp; clsName &amp; " has instances.  Attempting delete",0);
		foreach obj in objects do
			if CM_Object.hasInstance(obj) then
				beginTransaction;
				obj.CM_Object.erase(0);
				commitTransaction;
			endif;
		endforeach;
	endforeach;
epilog
	delete classNames;
	delete objects;
end;
</source>
        <access>protected</access>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
