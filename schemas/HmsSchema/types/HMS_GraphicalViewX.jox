    <JadeMethod name="setForReadOnlyView" id="c03b601c-f04d-43f0-91ac-c8944e9e30ac">
        <updating/>
        <source>setForReadOnlyView() updating, protected;

vars

begin
	// This method sets the main graphical view to readOnly
	self.isReadOnly := true;
	self.controlMoveStyle := Move_None;

	self.btnLock.value := true;
	self.btnLock.enabled := false;
	
	self.btnNSEWChanges.enabled := false;
	self.btnTimeChanges.enabled:= false;
	self.btnWharfChanges.enabled:=false;

	self.btnRoadStead.enabled := false;
	self.btnNewVoyage.enabled := false;
	self.btnSenarioVoyage.enabled := false;

	self.btnSaveBase.enabled:=false;
	self.btnRedo.enabled:=false;
	self.btnUndo.enabled:=false;

	self.mnuSetToPreferedMarks.visible:=false;
	self.mnuDeleteMovement.visible:=false;
	self.mnuDeleteVoyage.visible:=false;
	self.mnuAddMovement.visible := false;
	self.mnuMeterMarks.visible := false;
	self.mnuRemarks.visible := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMeterMarks" id="c9509800-3d62-47b3-84a6-207bbe5961fc">
        <updating/>
        <source>setMeterMarks(textbox: TextBox)updating, protected;
//--------------------------------------------------
// Created:	25 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	loa			: Decimal[6,2];
	bridgeToBow,
	tmpMark,
	bowMark,
	sternMark,
	bridgeMark	: Decimal[12,2];
	berth,
	berthForMarks	: HMS_Berth;
begin
	if self.myCurrentWorkingMovement = null then
		return;
	endif;
	if (not global.isValidObject(self.myCurrentWorkingMovement)) then
		self.setMyCurrentWorkingMovement(null);
		return;
	endif;	
	
	berth := self.cmbMyBerth.listObject.HMS_Berth;
	
	if berth = null then
		return;
	endif;
	
	bridgeToBow := self.myCurrentVoyageData.dist_BridgeToBow;
	loa := self.myCurrentVoyageData.dim_LengthOverall;

	if textbox = null then
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, self.vesselSideTo, bowMark, sternMark, bridgeMark, null, berthForMarks,true);
	elseif textbox = self.txtBowMarkTo then
		//bowMark := textbox.text.Decimal;
		bowMark := textbox.text.asDecimalJMT(); 	// 01 APR 2010	NDL	Par 23556
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, self.vesselSideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BowMark), berthForMarks,true);
	elseif textbox = self.txtSternMarkTo then
		//sternMark := textbox.text.Decimal;
		sternMark := textbox.text.asDecimalJMT(); 	// 01 APR 2010	NDL	Par 23556
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, self.vesselSideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_SternMark), berthForMarks,true);
	elseif textbox = self.txtBridgeMarkTo then
		//bridgeMark := textbox.text.Decimal;	
		bridgeMark := textbox.text.asDecimalJMT(); 	// 01 APR 2010	NDL	Par 23556	
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, self.vesselSideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BridgeMark), berthForMarks,true);
	else
		return;
	endif;

	self.tblMeterMarks.setValueByName(ETRow_BowMarkTo, bowMark.String);
	self.txtBowMarkTo.text := bowMark.String;
	self.tblMeterMarks.setValueByName(ETRow_SternMarkTo, sternMark.String);
	self.txtSternMarkTo.text := sternMark.String;	
	self.tblMeterMarks.setValueByName(ETRow_BridgeMarkTo, bridgeMark.String);
	self.txtBridgeMarkTo.text := bridgeMark.String;	

	if berthForMarks &lt;&gt; null then
		if berthForMarks &lt;&gt; berth then	
			self.cmbMyBerth.listIndex := self.cmbMyBerth.findObject(berthForMarks);
			self.tblMeterMarks.setValueByName(ETRow_MyBerth, self.cmbMyBerth.text);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="textbox" type="TextBox"/>
    </JadeMethod>
    <JadeMethod name="setMoveDirection" id="7a18d25d-104f-448b-8639-0d29be19d233">
        <updating/>
        <source>setMoveDirection() updating, protected;
/* ---------------------------------------------------------------------------
Created:	05 May 2009	by cnwvu1

Purpose:	Par 16281
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.myCurrentWorkingMovement = null then
		self.controlMoveStyle := Move_None;
		return;
	endif;
	
	// when movement is locked, we cannot move
	if self.myCurrentWorkingMovement.myWorkingVoyage.voyageStatus = HMS_VoyageIsLocked then
		self.controlMoveStyle := Move_None;
		return;
	endif;
		
	if self.btnNSEWChanges.value then
		self.controlMoveStyle := Move_NESW;	
	
	elseif self.btnWharfChanges.value then
		self.controlMoveStyle := Move_WE;	

	else //self.btnTimeChanges.value then
		self.controlMoveStyle := Move_NS;
		
	endif;

	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyCurrentWorkingMovement" id="b357b893-7e7f-4959-bc31-1211719fb2b6">
        <source>setMyCurrentWorkingMovement(_workingMovement : CMIF_HMS_WorkingMovement) protected;
// ---------------------------------------------------------------------------
// Created:     02 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myViewController &lt;&gt; null then
		// the following does a call back to self.setCurrentWorkMoveFromCntrler(..) to set local variable
		self.myViewController.setMySelectedMovement(_workingMovement);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="setResourceButtons" id="96fa1b0d-1938-488e-a0db-c997ba506512">
        <source>setResourceButtons() protected;

vars
	res : CMIF_HMS_ResourceUsed;
	int : Integer;
	size: Integer;
	cntrl:Control;
	rd	: HMS_ResourceType;
begin

	self.resetResourceButtons();
	// this method sets up the resource buttons for the currently selected movement.
	if global.isValidObject(myCurrentWorkingMovement) then
		size:= allResourceIdArray.size;
		foreach res in myCurrentWorkingMovement.allWorkingResUsed do
			if res.myResource &lt;&gt; null then
				rd := res.myResource.myResourceType;
			elseif res.myResourceType &lt;&gt; null then
				rd := res.myResourceType;
			else
				continue;
			endif;
			int := 1;
			while int &lt;= size do
				cntrl := self.btnResource.getControl(allResourceIdArray[int]);
				if cntrl.userObject = rd then
					cntrl.Button.value := false;
					break;
				endif;	
				int := int + 1;
			endwhile;		
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSelectedMovement" id="5ce3245f-6dde-4db9-8c81-c2859e699375">
        <updating/>
        <source>setSelectedMovement(_movement : CMIF_HMS_WorkingMovement; _scrollToSelected : Boolean) updating;

vars
	wharfCntrl 	: HMS_WharfDrawControl;
begin

	foreach wharfCntrl in self.allWharfDrawControlsVisible do
		wharfCntrl.showHideLabels(false, null, null);
	endforeach;

	if global.isValidObject(_movement) then	
		self.setMyCurrentWorkingMovement(_movement);
		self.colourSelectedSprite(_movement, _scrollToSelected);			
	else
		self.setMyCurrentWorkingMovement(null);
		self.colourSelectedSprite(null, _scrollToSelected);				
	endif;
		

end;</source>
        <Parameter name="_movement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_scrollToSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSystemDefinedColours" id="da42a791-c664-4d43-9800-554092921cc0">
        <updating/>
        <source>setSystemDefinedColours() updating, protected;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------
// 21/09/2023	navdap1		TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
vars
	userColour:		Integer;
begin

	// This method sets the user defined colours on main graphical view
	userColour := Red;

	// Set colours for Top RH labels (date/time/vessel name, berth, marks)
	if self.myHarbour &lt;&gt; null then
		userColour := self.myHarbour.timePositonLabelColour;
	endif;

    lblShowLoa.foreColor := userColour; 
    lblShowTime.foreColor := userColour;
    lblShowBerth.foreColor := userColour;
    lblShowBow.foreColor := userColour;
    lblShowStern.foreColor := userColour;
	lblShowBridge.foreColor := userColour;		    
	lblShowOrient.foreColor := userColour;			// TFS 59472

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="291529a4-11e4-420a-befd-51325876ba56">
        <source>setTableFromObjectSpecial(_theTable: CM_EntryTable input; _attrName: String; _row: Integer; _theObject: Object): Boolean;
//--------------------------------------------------
// Created:	25 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	dateTime : TimeStamp;
begin

	if _attrName = ETRow_OccursOnDate then
		return true;	
	elseif _attrName = ETRow_OccursOnTime then
		return true;
	elseif _attrName = ETRow_MyBerth then
		if CMIF_HMS_WorkingMovement.hasInstance(_theObject) then
			self.cmbMyBerth.listIndex := self.cmbMyBerth.findObject(_theObject.CMIF_HMS_WorkingMovement.myBerth);
			self.cmbMyBerth.lostFocus(self.cmbMyBerth);
		endif;
		return true;
	elseif _attrName = ETRow_BridgeMarkTo then
		if CMIF_HMS_WorkingMovement.hasInstance(_theObject) then
			self.txtBridgeMarkTo.text := _theObject.CMIF_HMS_WorkingMovement.getBridgeMarkTo().String;
			_theTable.setValueByName(ETRow_BridgeMarkTo, self.txtBridgeMarkTo.text);
		endif;
		return true;		
	elseif _attrName = ETRow_BowMarkTo then
		if CMIF_HMS_WorkingMovement.hasInstance(_theObject) then
			self.txtBowMarkTo.text := _theObject.CMIF_HMS_WorkingMovement.bowMarkTo.String;
			_theTable.setValueByName(ETRow_BowMarkTo, self.txtBowMarkTo.text);
		endif;
		return true;		
	elseif _attrName = ETRow_SternMarkTo then
		if CMIF_HMS_WorkingMovement.hasInstance(_theObject) then
			self.txtSternMarkTo.text := _theObject.CMIF_HMS_WorkingMovement.sternMarkTo.String;
			_theTable.setValueByName(ETRow_SternMarkTo, self.txtSternMarkTo.text);
		endif;
		return true;						
	/*elseif _attrName = ETRow_SideTo then
		if HMS_VoyageMovement.hasInstance(_theObject) then
			self.myAssistant.comboBoxHMSOrientation(self.tblMain, ETRow_SideTo, _theObject.HMS_VoyageMovement.sideTo);		
		endif;
		return true;*/
	endif;

	return false;
end;</source>
        <Parameter name="_theTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTerminalListForHarbour" id="2f87229f-b819-4767-8d06-f396fc2a5f0d">
        <updating/>
        <source>setTerminalListForHarbour()updating, protected;
//--------------------------------------------------
// Created:	22 November 2004 By: cnwgd1
//
// Changes:
//			1 Apr 08 - cnwrs2 - changes for PAR 16411 to only show 1 terminal
//--------------------------------------------------
vars
	allowedTerms,
	selectedTerms : CM_TerminalByCodeDict;
begin

	create allowedTerms transient;			// PAR-16411
	allowedTerms.add(self.myTerminal);		// PAR-16411
	
	if self.myHarbour &lt;&gt; null then
		if self.lstTerminal.allSelectedObjects.size &gt; 0 then
			create selectedTerms transient;
			self.lstTerminal.allSelectedObjects.copy(selectedTerms);
			//self.myAssistant.listTableTerminal(self.lstTerminal, true, true, self.myHarbour.allTerminalsByCode, selectedTerms);		
			self.myAssistant.listTableTerminal(self.lstTerminal, true, true, allowedTerms, selectedTerms);				// PAR-16411
		else
			//self.myAssistant.listTableTerminal(self.lstTerminal, true, true, self.myHarbour.allTerminalsByCode, self.myHarbour.allTerminalsByCode);
			self.myAssistant.listTableTerminal(self.lstTerminal, true, true, allowedTerms, allowedTerms);		// PAR-16411
		endif;
	endif;
	self.myAssistant.listTableLostFocus(self.tblSearch, self.saveRowHeight, self.lstTerminal, 'code', false);
	
	self.myViewController.setSelectedTerminals(self.lstTerminal.allSelectedObjects);
	
	// PAR 16411 - always hide option to select terminals as only allow user to see the 1 terminal
	//if (not app.myRoot.isMultiTerminal()) then
		//User only has access to one terminal so hide terminal filter
		self.tblSearch.hideRowByName(ETRow_FilterTerminal, true);
	//else
	//	self.tblSearch.showRowByName(ETRow_FilterTerminal, true);		
	//endif;				
	
epilog
	delete selectedTerms;	
	delete allowedTerms;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTotalWharfLabelWidth" id="b22a649f-8307-4b55-bb90-ed4c30f37983">
        <updating/>
        <source>setTotalWharfLabelWidth(_width : Real) updating, protected;
//--------------------------------------------------
// Created:	10 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	saveWidth : Real;
	tmpWharfCntrl : HMS_WharfDrawControl;
begin
	saveWidth := self.totalWharfLabelWidth;
	self.totalWharfLabelWidth := _width;

	if self.totalWharfLabelWidth = saveWidth then
		return;
	endif;

	// Width has changed so resize frames	
	self.resizeScrollingFrame();		

	foreach tmpWharfCntrl in self.allWharfDrawControlsVisible do
		tmpWharfCntrl.width := tmpWharfCntrl.myScrollableLabelFrame.width;
	endforeach;

				
end;</source>
        <access>protected</access>
        <Parameter name="_width" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d28b4ba5-81a5-43f5-92bc-b865c729b445">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 03 July 2003 By: cnwgd1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------------------
vars
	frameObj	: CMUI_ScrollableFrame;
	userObj		: CM_User;
	
begin
	inheritMethod();
	
	self.myHarbour := self.myTerminal.myHarbour;
	
// cnwdad1 27/06/2008 - PAR #17135.
	if self.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		self.unloadForm();
		return;
	endif;
	
	// Setup the scrolling MAIN frame
	frameObj		:=	self.frmScrollablMain;
	frameObj.setScrollingFrame(self.frmScrollingMain);
	frameObj.setBottomLabelMargin(self.Wharf_Label_Height);
	frameObj.labels	:=	self.ScrollBar_Vertical;
	frameObj.setVLabelDetails(Time_Label_Width, false);
	frameObj.setHLabelDetails(self.Wharf_Label_Height, false);
	
	// still do the following to get the bottom alignment set
	frameObj.setHLabelDetails(0, true);
	frameObj.zOrder(0);

	//		self.backColor := app.convertRGBToColor(149, 188, 253);
	frameObj.ignoreSkin	:=	true;
	if process.isJLGAB1() then // Draw like BWM
	frameObj.backColor	:= app.convertRGBToColor(254, 253, 254); // Draw like BWM
	
	else
	frameObj.backColor	:=	app.convertRGBToColor(149, 188, 253);
	endif;
	
	self.showToolbar	:=	true;
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	
	self.initViewController();

	// Modified by Russell 30/07/99
	// --------------------------------------
	// Set sensitivity for time/posn update to an update rate of 50ms
	self.timeIncrementSensitivity.setTime(0,0,0,50);
	// ---------------------------------------

	self.initZooms();
	
	create self.myDrawTimeLabel transient;
	if self.myDrawTimeLabel &lt;&gt; null then
		self.myDrawTimeLabel.setMyTerminal(self.myTerminal);	// 30/5/16 cnwmp6 TFS 488 - Multi timezone support
	endif;
	self.myDrawTimeLabel.initControl();
	
	self.lblContFore.backColor	:=	Green;
	self.doBtnShipPositionDetails(self.btnPosDetail);
	self.initRangeSelector();
	self.initMeterMarks();
	self.initMoveDirectionControls();
	self.initSelectWharvesGroupBox();
	self.initSelectWharvesCollection();
	
	// Lastly check to see if user has update rights to the main graphical view
	userObj	:=	app.getMyUser();
	
	if userObj &lt;&gt; null then
		if (not userObj.canDo(self.myTerminal, PmHMSGraphicalMaint)) then
			self.setForReadOnlyView();
		endif;
	
		if userObj.canDo(self.myTerminal, Mod_Invoicing) then
			self.mnuVoyageResourcesUsed.visible	:=	true;
		endif;
		
		if app.isDevelopmentSystem()
		or app.isSpecial()
		then
			//self.mnuBerthUsage.visible		:=	true;
			self.mnuVoyageStatistics.visible	:=	true;
			//self.btnBerthUsage.visible		:=	true;
			self.btnVoyageStat.visible			:=	true;
		else
			//self.btnBerthUsage.visible		:=	false;				
			self.btnVoyageStat.visible			:=	false;							
			//self.mnuBerthUsage.visible		:=	false;
			self.mnuVoyageStatistics.visible	:=	false;
		endif;
	else
		self.setForReadOnlyView();
	endif;
	
	self.moveModeForm := PLANNING_MODE;
	
	self.mnuShippingReport.caption := "&amp;" &amp; HMS_VesselReportInitiator.SHIPPING_REPORT_NAME &amp; "...";  //16988 cnwdz2
	self.mnuWorkOrdersReport.caption := "&amp;" &amp; HMS_VesselReportInitiator.WORK_ORDERS_REPORT_NAME &amp; "..."; //16988 cnwdz2
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupWharfControls" id="acc41d5a-fdc7-4c75-91d2-b7ed6de1c16f">
        <updating/>
        <source>setupWharfControls() updating, protected;
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
vars
	controlPointer		: Integer;
	labelWidth			: Real;
	wharfObj			: HMS_Wharf;
	drawControlObj		: HMS_WharfDrawControl;
	
begin
	self.allWharfDrawControlsVisible.clear();
	self.allWharfDrawControls.clear();	
	self.allBerthsInView.clear();
	self.totalWharfLabelWidth	:=	0;

	if self.myHarbour = null then
		return;
	endif;	

	// NOTE - do reversed here so that controls are displayed in
	// dock container correctly

	foreach wharfObj in self.myHarbour.allWharfDisplayOrderArray reversed do
		if (not wharfObj.isVisibleOnView) then
			continue;
		endif;
		
		if not self.isWharfDisplayed(wharfObj) then
			continue;
		endif;
			
		//create Wharf draw control
		controlPointer	:=	controlPointer + 1;
		drawControlObj	:=	self.dkbWharfDrawCntr.getControl(controlPointer).HMS_WharfDrawControl;
		
		if drawControlObj = null then		
			drawControlObj	:=	self.dkbWharfDrawCntr.loadControl(controlPointer).HMS_WharfDrawControl;
		endif;
		drawControlObj.myWharf	:=	wharfObj;
		self.addWharfDrawControl(drawControlObj);
		drawControlObj.initControl(wharfObj, self.wharfZoom, labelWidth);
		drawControlObj.width	:=	50;
				
		//add berths to view
		wharfObj.allBerths.copy(self.allBerthsInView);	
		self.beginNotification(wharfObj, RefreshView, Response_Continuous, 0);
		
	endforeach;
	
	self.cmbMyBerth.listCollection(self.allBerthsInView, false, 0);
	
	if self.mySeaViewForm &lt;&gt; null then
		self.mySeaViewForm.cmbMyBerth.listCollection(self.allBerthsInView, false, 0);
	endif;		
	
	self.setTotalWharfLabelWidth(labelWidth);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showAdditionalInfoForm" id="06dbf0d1-8f79-4104-9491-88dd2fa93851">
        <updating/>
        <source>showAdditionalInfoForm(_workingVoyage : CMIF_HMS_WorkingVoyage) updating, protected;
//--------------------------------------------------
// Created:	02 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	form : Form;
begin

	//PAR 11121
	if global.isValidObject(self.myAdditionalInfoForm) then
		self.myAdditionalInfoForm.setMyCurrentObject(_workingVoyage);
	else
		create self.myAdditionalInfoForm;
		//self.myAdditionalInfoForm := form.CMUI_AdditionalInfoNonMDI;
		self.myAdditionalInfoForm.setMyTerminal(self.myTerminal);
		self.myAdditionalInfoForm.createMyAssistant(HMS_Assistant);	
		self.myAdditionalInfoForm.showWithObjectMode(_workingVoyage, null);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="showAnchoredShips" id="089e5d41-d7b6-475c-8643-1128a8d549e8">
        <source>showAnchoredShips() protected;
//Method determines if any ships are currently in the anchorage and indicates
//this on the graphical view

vars
	tmpWharf : HMS_Wharf;
	now	:	TimeStamp;
	vesselName : String;
	numVessels : Integer;
	nextMove,
	move : CMIF_HMS_WorkingMovement;
begin
	//Only do this if view range spans the curent DT
	if self.myViewController.viewFinishDT &gt;= now 
		and self.myViewController.viewStartDT &lt;= now then

		foreach move in self.myViewController.allMovementsInViewByDT where move.moveType &lt;&gt; HMSMovementTypeDeparture do
			if (not move.isLogicalBerth()) then
				//also return true is berth or wharf is null
				continue;
			endif;
			tmpWharf := move.myBerth.myWharf;
			nextMove := move.getMovementNext();
			if nextMove = null then
				continue;
			endif;
			if move.occursOnDT &lt;= now and nextMove.occursOnDT &gt;= now then
				//anchor.visible := true;
				//lblAnch.visible := true;
				numVessels := numVessels + 1;
				vesselName := move.myWorkingVoyage.myHMSVoyageData.vesselName;
				if numVessels = 1 then
					//lblAnch.bubbleHelp := vesselName;
					self.btnRoadStead.bubbleHelp := vesselName;
				else
					//lblAnch.bubbleHelp := lblAnch.bubbleHelp &amp; ", " &amp; vesselName;
					self.btnRoadStead.bubbleHelp := self.btnRoadStead.bubbleHelp &amp; ", " &amp; vesselName;						
				endif;
			endif;
		endforeach;
        if numVessels = 1 then
			//lblAnch.caption := vesselName;
			self.btnRoadStead.caption := vesselName;			
		else
			//lblAnch.caption := numVessels.String &amp; " Ships";
			self.btnRoadStead.caption := numVessels.String &amp; " Ships";			
		endif;	
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showAuditEnquiry" id="0626401e-153f-44ff-8ace-5a8169c43a28">
        <source>showAuditEnquiry() protected;
//-----------------------------------------
// Created: August 2003 By: cnwgd1
//-----------------------------------------
vars
 	auditEnquiry:			HMS_AuditTrailEnquiry;
begin

 	auditEnquiry := app.loadForm(HMS_AuditTrailEnquiry, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).HMS_AuditTrailEnquiry;
	if auditEnquiry = null then
		return;
	endif;
	auditEnquiry.setMyTerminal(self.myTerminal);
 	auditEnquiry.show;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="b9e448a4-2ae3-4d65-85d6-32b043272c40">
        <source>showColourLegend() protected;
//--------------------------------------------------
// Created:	11 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
	
begin
	create colLegend;
	self.setNavigatorHeading(colLegend.caption);
	colLegend.centreWindow();
	
	colLegend.addLegendItem("Line at top of ship: Departure Movement Selected", White, Red, null, false);		
	colLegend.addLegendItem("Currently Selected Voyage", Black, MovementIsSelected, null, false);
	colLegend.addLegendItem("Line at bottom of ship: Arrival Movement Selected", White, Red, null, false);
	colLegend.addLegendItem("Actual time for movement", White, Blue, null, false);
	colLegend.addLegendItem("Voyage Locked", Black, White, null, false);
	colLegend.addLegendItem("Voyage changed but not yet saved", White, MovementNotYetSaved, null, false);
	colLegend.addLegendItem("Voyage changes saved", Black, MovementIsSaved, null, false);
	colLegend.addLegendItem("New Voyage not yet saved", Black, Mauve, null, false);
	colLegend.addLegendItem("New Voyage selected and not yet saved", Black, Yellow, null, false);
	colLegend.addLegendItem("Confidential Voyage", Black, VoyageConfidential, null, false);
	colLegend.addLegendItem("Voyage restricted (rejected) by Range Selector", White, DarkGray, null, false);
	colLegend.addLegendItem("Voyage Closed", Black, Gray, null, false);
	
	if self.myHarbour &lt;&gt; null then
		colLegend.addLegendItem("Midnight Line Colour", White, self.myHarbour.midnightLineColour, null, false);
	endif;

	colLegend.showModal();
epilog
	delete colLegend;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showExtraInfoForObject" id="dfddcf9e-5fa0-438a-98b9-5bd372741fbc">
        <updating/>
        <source>showExtraInfoForObject(_workingVoyage : CMIF_HMS_WorkingVoyage) updating, protected;
//--------------------------------------------------
// Created:	02 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	dataContainer : CM_DataContainer;
begin

	if _workingVoyage = null then
		return;
	endif;
	
	self.tblExtraInfo.clear();
	self.tblExtraInfo.rows := 0;
	self.tblExtraInfo.visible := true;	

	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	
	_workingVoyage.getExtraInfo(dataContainer);
	self.showExtraInformation(dataContainer, self.tblExtraInfo, true, true, 2, 1, 1, 1, 1);

	self.tblExtraInfo.accessColumn(1).width := 150;


epilog
	delete dataContainer;
end;</source>
        <access>protected</access>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="showHideMarksRemarks" id="d56f29ea-fa76-4089-9719-0db42390f2b4">
        <updating/>
        <source>showHideMarksRemarks(_editRemarks : Boolean; _planningDate : Date; _viewExtraInfo : Boolean )updating, protected;
//--------------------------------------------------
// Created:	24 May 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 20/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 04/02/2025 	navlw1		JIRA-33946: MTN | HMS Edit Movement Remarks Toolbar
vars
	vessel 		: String;
	height		: Real;
begin
	self.txtRemarks.text := null;
	self.tblMeterMarks.clearValues();
	self.txtRemarks.visible := false;
	self.tblMeterMarks.visible := false;
	self.txtPlanningHist.visible := false;
	self.tblExtraInfo.visible := false;		
	self.btnSaveExtra.enabled := false;
	self.btnCancel.enabled := false;	
	if (not self.isReadOnly) then	
		self.btnSaveBase.enabled := true;
	endif;
	self.btnCancelBase.enabled := true;
	self.btnSelectrSearch.enabled := true;

	//Clear selected fields of the table
	self.tblMeterMarks.clearAllSelected();								
			
	if self.frmMarksRemarks.visible then
		self.frmMarksRemarks.visible := false;
		return;
	endif;
			
	if _planningDate = null and self.myCurrentWorkingMovement = null then
		return;
	endif;
	
	if self.myCurrentVoyageData &lt;&gt; null then
		vessel := self.myCurrentVoyageData.vesselName;
	endif;
					
	if _editRemarks then
		//self.lblMeterMarks.caption := 'Movement Remarks: ' &amp; vessel;											// PAR #33337
		self.lblMeterMarks.caption := self.myCurrentWorkingMovement.moveType &amp; ' Movement Remarks: ' &amp; vessel;	// PAR #33337
		self.txtRemarks.visible := true;
		self.txtRemarks.text := self.myCurrentWorkingMovement.remarks;
		// set focus and move to the first row of table.
		height := self.txtRemarks.parent.height - self.lblMeterMarks.height - 20;
		self.txtRemarks.top := self.lblMeterMarks.height + 20; // navlw1 04/02/2025 #JIRA-33946
		self.txtRemarks.height := height;
		self.txtRemarks.setFocus();
		
	elseif _planningDate &lt;&gt; null then
		self.lblMeterMarks.caption := 'Planning Notes: ' &amp; _planningDate.shortFormatJMT();
		self.txtRemarks.visible := true;
		// set focus and move to the first row of table.
		self.displayPlanningNotes(_planningDate);
		
	elseif _viewExtraInfo then
		/*self.lblMeterMarks.caption := vessel;
		self.btnSaveExtra.enabled := false;
		self.showExtraInfoForObject(self.myCurrentWorkingMovement.myWorkingVoyage);*/
	else
		self.lblMeterMarks.caption := 'Meter Marks: ' &amp; vessel;
		self.tblMeterMarks.visible := true;
		if self.myCurrentWorkingMovement.moveType = HMSMovementTypeDeparture then
			self.tblMeterMarks.setTableFromObject(self.myCurrentWorkingMovement.getMovementPrevious(), 'setTableFromObjectSpecial');			
			self.tblMeterMarks.disableRowByName(ETRow_MyBerth);
		else
			self.tblMeterMarks.setTableFromObject(self.myCurrentWorkingMovement, 'setTableFromObjectSpecial');			
			self.tblMeterMarks.enableRowByName(ETRow_MyBerth);		
		endif;
		self.tblMeterMarks.cnEcResizeContents();
	endif;
	
	if (not _viewExtraInfo) then
		self.btnSaveBase.enabled := false;
		self.btnSelectrSearch.enabled := false;	
		self.btnSaveExtra.enabled := true;
	endif;
	self.btnCancelBase.enabled := false;	
	self.btnCancel.enabled := true;	
	
	if _viewExtraInfo then
		self.frmMarksRemarks.visible := false;	
	else
		self.frmMarksRemarks.visible := true;
		
		if _editRemarks or _planningDate &lt;&gt; null then
			// set focus and move text box
			self.txtRemarks.setFocus();
		elseif (not _viewExtraInfo) then
			// set focus and move to the first row of table.
			self.tblMeterMarks.setFocus();
			self.tblMeterMarks.moveFirst();						
		endif;
	endif;			
			
end;</source>
        <access>protected</access>
        <Parameter name="_editRemarks" type="Boolean"/>
        <Parameter name="_planningDate" type="Date"/>
        <Parameter name="_viewExtraInfo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideSelector" id="98b776a2-b6f4-439c-a4dd-64989abb889a">
        <updating/>
        <source>showHideSelector()updating, protected;
//--------------------------------------------------
// Created:	18 May 2004 By: cnwgd1
//--------------------------------------------------
// 07/06/2022 navvt20 TFS53757 - Search Range Functionality and Syncing
//--------------------------------------------------
vars

begin

	self.btnSelectrSearch.enabled := false;
	if (not self.isReadOnly) then	
		self.btnSaveBase.enabled := true;
	endif;
	
	if self.frmSearch.visible then
		self.frmSearch.visible := false;
		//navvt20 07/06/2022 TFS53757 - start
		self.myViewController.allWharves.clear;
		self.aAllSelectedWharves.copy(self.myViewController.allWharves);
		self.buildMap();
		self.refreshNow();
		//navvt20 07/06/2022 TFS53757 - end
	else
		self.doRangeSelectorResetDateTime(false);
		self.initSelectVessels(false);
		self.initSelectOperators(false);
		self.btnSelectrSearch.enabled := true;
		self.btnSaveBase.enabled := false;		
		self.frmSearch.visible := true;
		self.frmSearch.centreWindow();
		//We're showing the searcher and want move to the first row ready for new values.
		self.tblSearch.clearAllSelected;
		self.tblSearch.moveFirst();
		self.tblSearch.setFocus();
		
		//navvt20 07/06/2022 TFS53757 - start
		 self.msgSelectWharvesBox.setAvailable(self.aAllAvailableWharves, true);
	     self.msgSelectWharvesBox.setSelected(self.aAllSelectedWharves);
		//navvt20 07/06/2022 TFS53757 - end
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showMarksTimeForSelectedMove" id="50879fc0-07c1-47f0-be20-04d7aad93d6e">
        <updating/>
        <source>showMarksTimeForSelectedMove()updating, protected;
//--------------------------------------------------
// Created:	10 June 2004 By: cnwgd1
//--------------------------------------------------
vars
	cntrl : HMS_GraphicalDragPicture;
begin

	cntrl := self.myCurrentDragPicture; 
	if cntrl = null then
		return;
	endif;	

	// Update ship metrics and time scale
	cntrl.myCurrentWharfDrawControl.drawShipMetrics(cntrl);
	self.showTimeAndPositionForSelected(cntrl.myWorkingMovement);

	// adjust the pointers that are shown on the wharf and time control	
	self.myDrawTimeLabel.movePointer(true, cntrl.top, cntrl.top + cntrl.height);
	
																																																																											
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showMovementMaintForm" id="9e186967-97dc-4150-9170-6444fc4bef00">
        <source>showMovementMaintForm(_doEdit : Boolean)protected;
//--------------------------------------------------
// Created:	28 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.showWorkingMovementForm(self.myCurrentWorkingMovement, _doEdit);
end;</source>
