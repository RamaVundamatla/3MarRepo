    <JadeMethod name="updateStatus" id="ca1676ea-583b-4f60-a182-38a292962896">
        <updating/>
        <source>updateStatus(_newStatus : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin	
	if _newStatus &lt;&gt; self.status then
		self.status := _newStatus;
	endif;
epilog

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
