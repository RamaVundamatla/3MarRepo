    <JadeMethod name="finalizeTest" id="a15e59d0-7bcb-4680-9de0-40a6dc05ccd5">
        <updating/>
        <source>finalizeTest(_testRun : UM_TestRun; _test: Method; _ignore : Boolean; _blame : UM_Blame io) updating, protected;
//11 November 2008	cnwdw1	
//
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	testResult: UT_TestResult;
begin
	self.testFinishTime := app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.endNotificationForSubscriber(self);
	self.receivedNotes.clear();
	self.opts.purge();
	delete self.testProfile;
	if process.isInTransactionState then						// 09/01/2013 cnwmh5
		abortTransaction;
	endif;
	testResult := self.createUnitTestResult(_test, _testRun, _ignore, _blame, self.methods);
	self.sendNote(_test, testResult);
epilog
	if _blame &lt;&gt; null then
		self.deleteBlame( _blame );
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_testRun" type="UM_TestRun"/>
