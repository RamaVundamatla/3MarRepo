    <JadeMethod name="unitTestBeforeClass" id="94674d82-5e6d-46dc-ac83-3cd60ce38fba">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
//18 December 2008	cnwdw1	
//
// 10 Sep 2019	cnwrs1	TFS 46030
vars
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	inheritMethod;
	
	deleteVoyage("UTVBOOK1");
	deleteVoyage("UTVBOOK2");
	deleteVessel("UTBOAT");
	self.vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(self.vessel);
	self.voyage1 := addVoyageWithContainerStructur("UTVBOOK1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(self.voyage1);
	self.voyage2 := addVoyageWithContainerStructur("UTVBOOK2", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(self.voyage1);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
