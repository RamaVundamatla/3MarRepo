<Class name="WS_ReserveTI" id="686cee10-142a-4607-a4c8-4abecdf64d37">
    <superclass name="WS_ReserveDetail"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>These are for a "Release By ID" request.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="cargoID" id="629ee2ac-359d-4bb1-bb51-56f854d6966f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Used for creation. ID of the Tracked Item to add to the release.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="cargoType" id="c490909d-6a4d-4ec6-9750-2f9faeac7935">
        <embedded/>
        <type name="WS_CargoType"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="isReleased" id="c2f10862-49c8-4e84-9446-594a034e315d">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
        <text>Read only. Indicates if the Tracked Item has been released.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="myTrackedItem" id="9e99df5f-e5a6-4aba-91c7-b280b27d7a8e">
        <embedded/>
        <type name="WS_TrackedItem"/>
        <access>readonly</access>
        <text>Read only. A reference to the Tracked Item.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="totalQuantity" id="8e516233-2622-4d95-b5b6-2514f8a49946">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Total items requested.</text>
    </PrimAttribute>
    <PrimAttribute name="totalVolume" id="15f9857e-891e-414f-a030-32f7d57cdf9c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Total Volume for requested Bulk.</text>
    </PrimAttribute>
    <PrimAttribute name="totalWeight" id="851c5b5e-8bea-496e-a4b6-6e54a09e28fa">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Total Weight for requested Bulk.</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="10a39f92-de48-459f-a6f9-9bb34a746754">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2014	cnwmc5	Initial creation

*/

vars

begin
	delete self.cargoType;
	delete self.myTrackedItem;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="3f66aa44-ed04-406b-b8f9-2423f8c933de">
        <updating/>
        <source>setProxyFromObject(_reserveTI: CM_ReserveTI) updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
07 Nov 2014	cnwmc5				Initial creation
28 JUl 2019	jlgka1 	TFS 45287	JMT Handheld Apps - Pack by Request - Pack Container Jade
26/7/21		jlier1	52626		STW Release Staging 
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
20 Feb 2025 navma1	MTN-34072	TPT| Remove Cargo Once the Truck has been Completed via the Handheld
============================================================================*/

vars
	ti		: CM_TrackedItem;	
	measure	: CM_MeasurementType;
	volume 	: Decimal [22,10];
	cType	: CM_CargoType;

begin
	inheritMethod(_reserveTI);
	
	if not _reserveTI.hasTi() and _reserveTI.allTrackedItemsReleased.isNotEmpty then //23/06/2023	navkc1	CR 58406 Task 58408
		self.isReleased := true;
	endif;
	
	//cnwmc5 - 18 Dec 2014 - PAR 35320
	self.totalQuantity := _reserveTI.totalRequested;
	
	ti := _reserveTI.getTI();
	if ti &lt;&gt; null then
		
		cType := ti.myCargoType;
		
		create self.myTrackedItem transient;
		self.myTrackedItem.setProxyFromObject(ti);
		
		self.cargoID 	:= ti.id;
		
		if cType &lt;&gt; null then
			create self.cargoType transient;
			self.cargoType.setProxyFromObject(cType);
		endif;
		
		//cnwmc5 - 15 March 2015 - PAR 35864
		measure 		 := app.getDefaultMeasurementForType(Type_Weight);
		self.totalWeight := app.convertMeasurementForDisplay(measure.shortName, _reserveTI.weightRequested);
		
		if cType.isTrackByVolume then
			measure 		 := cType.myVolumeMeasurementType;
			if measure = null then
				measure := app.getDefaultMeasurementForType(Type_Volume);
			endif;
			volume 			 := _reserveTI.weightRequested / ti.getDensity;
			self.totalVolume := app.convertMeasurementForDisplay(measure.shortName, volume);
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_reserveTI" type="CM_ReserveTI"/>
    </JadeMethod>
    <JadeMethod name="setProxyRoadReserveSummary" id="68d93e24-9f35-4969-bca8-60e19e2b38fb">
        <updating/>
        <source>setProxyRoadReserveSummary(_reserveTI: CM_ReserveTI) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2025	navma1	MTN-34595 	DPH - Release Staging – Improve Performance of getRoadReleaseSummary() API

*/

vars
	ti		: CM_TrackedItem;	
begin
	inheritMethod(_reserveTI);
	
	if _reserveTI.allTrackedItemsReleased.isNotEmpty and not _reserveTI.hasTi() then 
		self.isReleased := true;
	endif;
	
	self.totalQuantity := _reserveTI.totalRequested;
	
	ti := _reserveTI.getTI();

	if ti &lt;&gt; null then
		self.cargoID := ti.id;
	endif;

epilog

end;</source>
        <Parameter name="_reserveTI" type="CM_ReserveTI"/>
    </JadeMethod>
</Class>
