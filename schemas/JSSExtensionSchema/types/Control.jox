    <JadeMethod name="jssCopyFontSettings" id="21fb713a-80ed-49a3-9825-dee37aeceeef">
        <updating/>
        <source>jssCopyFontSettings(pControl:Control) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Copy all of the font-related settings from the parameter control to
//				the receiver.
//
// Parameters:	pControl (Control) - The control from which to copy the font settings.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pControl.fontName = null then
		self.fontName 	:= app.fontName;
	else
		self.fontName	:= pControl.fontName;
	endif;

	self.fontBold 		:= pControl.fontBold;
	self.fontItalic 	:= pControl.fontItalic;
	self.fontSize		:= pControl.fontSize;
	self.fontStrikethru	:= pControl.fontStrikethru;
	self.fontUnderline	:= pControl.fontUnderline;
end;</source>
        <Parameter name="pControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="jssGetAccelerator" id="3412ba2f-e819-4832-9fc5-1f5550ddf9e0">
        <source>jssGetAccelerator():Character;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Return the character after the first "&amp;" in the receiver control's
//				caption.
//
// Parameters:	None
//
// Returns:		The accelerator character found, or null if there are none.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	AMPERSAND_CHAR	: Character = "&amp;";
	
vars
	captionValue	: String;
	captionLength	: Integer;
	ampersandPos	: Integer;

begin
	on Exception do global.jssXHandlerGetPropertyValue(exception);
	
	captionValue	:=	self.getPropertyValue("caption").String;
	
	if captionValue = null then
		return null;
	endif;
	
 	captionLength	:=	captionValue.length();
	ampersandPos	:=	captionValue.pos(AMPERSAND_CHAR, 1);
	
	if ampersandPos &gt; 0 and ampersandPos &lt; captionLength then
		return captionValue[(ampersandPos + 1):1].Character;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Character"/>
    </JadeMethod>
    <JadeMethod name="jssGetAllChildControls" id="52620669-7837-41b1-bd61-1ab6bba0128a">
        <source>jssGetAllChildControls(pAllChildControls: JSSControlArray io);
// --------------------------------------------------------------------------------
// Refer to the Window class abstraction for a description etc.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlIndex		: Integer;
	numberOfControls	: Integer;
	theParentForm		: Form;
	theFormControl		: Control;
	
begin
	theParentForm		:=	self.form;
	numberOfControls	:=	theParentForm.controlCount;
	
	foreach controlIndex in 1 to numberOfControls do
		theFormControl	:=	theParentForm.controls(controlIndex);
		
		if theFormControl.parent = self then
			pAllChildControls.add(theFormControl);
			theFormControl.jssGetAllChildControls(pAllChildControls);
		endif;
	endforeach;
end;</source>
        <Parameter name="pAllChildControls" type="JSSControlArray" usage="io"/>
    </JadeMethod>
