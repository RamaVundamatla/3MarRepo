    <JadeMethod name="getDisplayStringForAttribute" id="613bc697-224f-4bd5-8bd5-96b9a7d48fe9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	navtnr20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train
17 August 2022  navmv20    Bug 54563: MTN - Cargo Forecasts do not use Measurement Types Correctly
*/

vars
	str, type : String; //17 Aug 2022 navmv20 TFS 54563
begin
	if _attrName = ETRow_Commodity then
		if self.myCommodity = null then
			return null;
		else
			return self.myCommodity.description;
		endif;
		
	elseif _attrName = ETRow_CargoType then
		if self.myCargoType = null then 
			return null;
		else
			return self.myCargoType.description;
		endif;
		
	elseif _attrName = ETRow_Operator then
		if self.myOperator &lt;&gt; null then
			return self.myOperator.description;
		else
			return "";
		endif;
	elseif _attrName = ETRow_Mode then
		return self.mode;
	elseif _attrName = ETRow_Quantity then
		return self.totalQuantity.String;
	// START 17 Aug 2022 navmv20 TFS 54563	
	/*elseif _attrName = ETRow_Weight then
		return app.convertMeasurementForDisplay("MT", self.totalWeight).String;
	elseif _attrName = ETRow_WeightKg then
		return app.convertMeasurementForDisplay("kg", self.totalWeight).String;
	elseif _attrName = ETRow_WeightLbs then
		return app.convertMeasurementForDisplay("lbs", self.totalWeight).String;
	elseif _attrName = ETRow_WeightST then
		return app.convertMeasurementForDisplay("ST", self.totalWeight).String;
	elseif _attrName = ETRow_Volume then
		return self.totalVolume.String;*/
	// END 17 Aug 2022  navmv20 TFS 54563	
	
	// START 17 Aug 2022 navmv20 TFS 54563
	elseif _attrName.isMeasurementType() then 
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short); 
	// END 17 Aug 2022 navmv20 TFS 54563
	
	else
		return inheritMethod(_attrName, _short);
	endif;	

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="9468f0dc-06e8-4f09-ae81-3a19062b4354">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navmv20	Bug 54563: MTN - Cargo Forecasts do not use Measurement Types Correctly

*/

vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.totalWeight);
	elseif _attrName = ETRow_Volume then
		return app.convertMeasurementForDisplay(_measureType, self.totalVolume);
    endif;
    return null;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="16aaa868-e0d4-427c-9c04-fae0f85f4818">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			Creates an Update proxy and populates references

Parameters:			NONE

Return Value:		SelfType The proxy proxy to use for updating

Date		Who		Reason
08 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	pxy : SelfType;
	
begin
	pxy 				:= inheritMethod();
	pxy.myCargoType		:= self.myCargoType;
	pxy.myCommodity 	:= self.myCommodity;
	pxy.mode			:= self.mode;
	pxy.myOperator 		:= self.myOperator;
	pxy.myParent		:= self.myParent;
	return pxy;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3ad1901d-af62-49af-9049-20740e24ad94">
        <updating/>
        <source>setForCreate(_pxyCargoForecast: CM_CargoForecast) updating;
/*

Purpose:			Sets our real object, we are creating, to our proxy objects values

Parameters:			_pxyCargoForecast	CM_CargoForecast	The Proxy cargo forecast we need to set our object up from

Return Value:		NONE

Date		Who		Reason
04 April 2022	navpw1	Initial creation TFS: 53132

*/

begin
	//Attributes
	self.totalQuantity 	:= _pxyCargoForecast.totalQuantity;
	self.totalWeight 	:= _pxyCargoForecast.totalWeight;
	self.totalVolume 	:= _pxyCargoForecast.totalVolume;
	
	//References
	self.myCargoType	:= _pxyCargoForecast.myCargoType;
	self.myCommodity 	:= _pxyCargoForecast.myCommodity;
	self.mode 			:= _pxyCargoForecast.mode;
	self.myOperator 	:= _pxyCargoForecast.myOperator;
	self.myParent		:= _pxyCargoForecast.myParent;
	
end;</source>
        <Parameter name="_pxyCargoForecast" type="CM_CargoForecast"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1155e35a-088b-435b-ac16-f29021c50cef">
        <updating/>
        <source>setForUpdate(_pxyCargoForecast : CM_CargoForecast) updating;
/*

Purpose:			Sets the fields for our CM_CargoForecast

Parameters:			_pxyCargoForecast	CM_CargoForecast	The proxy CM_CargoForecast to update our real object from

Return Value:		NONE

Date		Who		Reason
04 April 2022	navpw1	Initial creation TFS: 53132

*/

begin
	//Attributes
	self.totalQuantity	:= _pxyCargoForecast.totalQuantity;
	self.totalWeight	:= _pxyCargoForecast.totalWeight;
	self.totalVolume 	:= _pxyCargoForecast.totalVolume;
	
	//References
	self.myCargoType	:= _pxyCargoForecast.myCargoType;
	self.myCommodity	:= _pxyCargoForecast.myCommodity;
	self.mode			:= _pxyCargoForecast.mode;
	self.myOperator		:= _pxyCargoForecast.myOperator;

end;</source>
        <Parameter name="_pxyCargoForecast" type="CM_CargoForecast"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreate" id="11da8751-ced1-4853-ad72-254a4cd9ee73">
        <updating/>
        <source>setProxyForCreate(_cargoType : CM_CargoType; _commodity : CM_Commodity; _mode : String; _operator : CM_Operator; _totalQuantity : Integer; _totalWeight, _totalVolume : Decimal; _parent : CM_Object) updating;
/*

Purpose:			Sets up Proxy instance so real object can be created from it

Parameters:			_cargoType		CM_CargoType	The cargo type for the cargo forecast
					_commodity		CM_Commodity	The commodity for the cargo forecast
					_mode			String			Can either be "Discharge" or "Load"
					_operator		CM_Operator		The operator for the cargo forecast
					_totalQuantity	Integer			The total quantity for the cargo forecast
					_totalWeight	Decimal			The total weight for the cargo forecast
					_totalVolume	Decimal			The total volume for the cargo forecast
					_parent			CM_Object		The parent object for the cargo forecast

Return Value:		NONE

Date		Who		Reason
07 April 2022	navpw1	Initial creation TFS: 53132

*/

begin
	//Attributes
	self.totalQuantity 	:= _totalQuantity;
	self.totalWeight	:= _totalWeight;
	self.totalVolume 	:= _totalVolume;
	
	//References
	if _commodity &lt;&gt; null and _cargoType = null and _commodity.allCargoTypes.size = 1 then
		//Set the cargo type if there is only 1 for the commodity
		self.myCargoType := _commodity.allCargoTypes.first;
	else
		self.myCargoType := _cargoType;
	endif;
	
	self.myCommodity	:= _commodity;
	self.mode			:= _mode;
	self.myOperator		:= _operator;
	self.myParent		:= _parent;
	
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_totalQuantity" type="Integer"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_totalVolume" type="Decimal"/>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setProxyForUpdate" id="f9b14f37-0b2f-46f3-9254-9726474e335e">
        <updating/>
        <source>setProxyForUpdate(_cargoType : CM_CargoType; _commodity : CM_Commodity; _mode : String; _operator : CM_Operator; _totalQuantity : Integer; _totalWeight, _totalVolume : Decimal; _parent : CM_Object) updating;
/*

Purpose:			Sets up Proxy instance so real object can be updated from it

Parameters:			_cargoType		CM_CargoType	The cargo type for the cargo forecast
					_commodity		CM_Commodity	The commodity for the cargo forecast
					_mode			String			Can either be "Discharge" or "Load"
					_operator		CM_Operator		The operator for the cargo forecast
					_totalQuantity	Integer			The total quantity for the cargo forecast
					_totalWeight	Decimal			The total weight for the cargo forecast
					_totalVolume	Decimal			The total volume for the cargo forecast
					_parent			CM_Object		The parent object for the cargo forecast

Date		Who		Reason
07 April 2022	navpw1	Initial creation TFS: 53132

*/

begin
	//Attributes
	self.totalQuantity 	:= _totalQuantity;
	self.totalWeight	:= _totalWeight;
	self.totalVolume 	:= _totalVolume;
	
	//References
	if _commodity &lt;&gt; null and _cargoType = null and _commodity.allCargoTypes.size = 1 then
		//Set the cargo type if there is only 1 for the commodity
		self.myCargoType := _commodity.allCargoTypes.first;
	else
		self.myCargoType := _cargoType;
	endif;
	
	self.myCommodity	:= _commodity;
	self.mode			:= _mode;
	self.myOperator		:= _operator;
	self.myParent		:= _parent;
	
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_totalQuantity" type="Integer"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_totalVolume" type="Decimal"/>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="87badff9-e5b4-40ae-8301-0d5514faee65">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			Whether or not we should audit a particular property

Parameters:			_rootClass	Class		Class the proeprty belongs to
					_property	Property	Property we are trying to audit

Return Value:		Boolean	Returns whether or not we should audit the property

Date		Who		Reason
05 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	propName	: String;
	
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName = "myChildQuantityMap" then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
