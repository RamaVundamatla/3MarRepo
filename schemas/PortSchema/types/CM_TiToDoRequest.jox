    <JadeMethod name="setTrackedItem" id="1f84b67a-0053-4bba-b0c3-d8710d17fdab">
        <updating/>
        <source>setTrackedItem( _theTI : CM_TrackedItem ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwrd1	Initial creation

*/

vars

begin
	self.myTrackedItem := _theTI;
	
	if self.myJob &lt;&gt; null then
	self.myJob.CM_ToDoJob.addTI( self.myTrackedItem , self);
	endif;

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
