    <JadeMethod name="addToolbarControls" id="78c35bd7-e144-43bf-ba54-39a3309aad1b">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	toolbar : CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnDeckSorting,CMUI_Toolbar.Control_Alignment_Left);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
