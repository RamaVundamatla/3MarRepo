        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	
// Changed:
// 27/06/2023	navcs2	ChangeRequest 58433: [58454]: EUP | TAS Invoicing - Invoice Posting Confirmation Message
// ---------------------------------------------------------------------------

vars
	
begin
	inheritMethod(table);
	//epr par 36958 29/9/15
	if table.row &gt; table.fixedRows then
		if self.tblData.accessRow(table.row).itemObject.isKindOf(CM_Invoice) then
			self.myCurrentInvoice := self.tblData.accessRow(table.row).itemObject.CM_Invoice;
		endif;
	endif;
	
	//epr par 37356 14/1/16
	if self.frmInvProperties.visible and self.currentView = ETView_InvListInvPropUpdate  then
		self.displayInvoice();
		self.resizeInvPropFrame();
	endif;

	self.setEnableObjects();
	
	self.enableDisablePostConf();			// 27/06/2023	navcs2	ChangeRequest 58433: [58454]
epilog

	self.mousePointer := Window.MousePointer_Default;
end;</source>
