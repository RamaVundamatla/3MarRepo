    <JadeMethod name="setLastModifiedTimeStamp" id="cf89b583-5f8e-4121-b07d-ab85e51b8f1b">
        <updating/>
        <source>setLastModifiedTimeStamp(_modifiedTimeStamp : LSModifiedTimeStamp) updating;
/*

Purpose:			Sets the last modified timestamp to the object passed through

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.modifiedBy			:= _modifiedTimeStamp.modifiedBy;
	self.modifiedVersion	:= _modifiedTimeStamp.modifiedVersion;
	self.patchVersion		:= _modifiedTimeStamp.patchVersion;
	self.modifiedTimeStamp	:= _modifiedTimeStamp.modifiedTimeStamp;

end;</source>
        <Parameter name="_modifiedTimeStamp" type="LSModifiedTimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setResolved" id="f7acb565-796e-4e6c-b7b0-4f5930e802f4">
        <updating/>
        <source>setResolved(_resolvedBy: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29 June 2023	navmd1	Initial creation

*/

vars
	beganTrx : Boolean;
begin
	if not process.isInTransactionState then
		beginTransaction;
		beganTrx := true;
	endif;
	
	self.resolvedBy := _resolvedBy[1:30];
	if _resolvedBy &lt;&gt; null then
		self.resolvedAt := app.actualTimeServer();
	else
		self.resolvedAt := null;
	endif;
	
	if beganTrx then
		commitTransaction;
	endif;
epilog
	// Attempt to continue if somethung goes wrong
	if beganTrx and process.isInTransactionState then
		abortTransaction;
	endif;
end;</source>
        <Parameter name="_resolvedBy" type="String"/>
    </JadeMethod>
</Class>
