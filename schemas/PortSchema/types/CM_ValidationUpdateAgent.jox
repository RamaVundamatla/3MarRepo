    <JadeMethod name="valTerminalConfig" id="155451dd-5a62-4b2a-8dbe-f4a83e3af2ef">
        <source>valTerminalConfig(realTerminal : CM_Terminal;_config:CMIF_ConfigTerminal);
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Purpose:     // Stub for any validation on terminal config
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 18/12/2013		cnwdap1			PAR #32849 CCMS PEN 2321 Security Gate
// 3/11/2019		jlgns1			TFS 3827 XLAT_FormCaptions need to be sorted out
// 05/11/2025		navlw1			JIRA-36268: MTN | Inward code were disappearing when enabled Allow Duplicate Voyage Inwards/External Codes
// ---------------------------------------------------------------------------

vars
	bank	: CM_Bank;
	rootSG : CM_ServiceGroup;
	servMem : CM_ServiceObject;
	service : CM_Service;
	yardArea: String;
	itemWidth: Integer;
begin
	//ccms 1058 12/5/09 
	if realTerminal.getConfig(ShipLinePortGroupsForInv).Boolean and not  _config.shipLinePortGroupsForInv then
		// 35872
		bank := realTerminal.getDefaultCompanyBank;
		if bank =  null then
			return;
		endif;
		rootSG := bank.getRootServiceGroup();
		//if any services have not default service schedule then raise exception
		foreach servMem in rootSG.groupMembers do
			if servMem = rootSG then
				continue;
			endif;
			if servMem.hasShippingLineRate(service) then
				app.raiseCMException1(Change_Use_ShipLine_Port_Group,service.name,null,null);
				break;
			endif;
		endforeach;
	endif;
	
	
	/* if they are trying to set Gate Auto Complete configs give an error stating they have to 
			unset these values
			
			GateInAutoComplete
			GateInAutoCompleteBkgrnd
			GateInAllowAutoComplete
			
		*/
	
	if realTerminal.getConfig(CashProcessingEnabled).Boolean then
	//cash enabled already set trying to turn on some of the gate stuff
		if _config.cashProcessingEnabled then		
			//epr 30723 5/12/12
			if _config.gateInAutoComplete then
				app.raiseCMException2(Not_enable_while_enabled,app.getFormCaptionsString(Xlat_0011555),app.getEntTableRowTranslation(ETRow_CashProcessingEnabled,ETGrp_ConfigGroup),null,null);
			endif;
			
			if	_config.gateInAutoCompleteBkgrnd then
				app.raiseCMException2(Not_enable_while_enabled,app.getEntTableRowTranslation(ETRow_GateInAutoCompleteBkgrnd,ETGrp_ConfigGroup),app.getEntTableRowTranslation(ETRow_CashProcessingEnabled,ETGrp_ConfigGroup),null,null);
			endif;
			
			if	_config.gateInAllowAutoComplete then
				app.raiseCMException2(Not_enable_while_enabled,app.getFormCaptionsString(Xlat_0011556),app.getEntTableRowTranslation(ETRow_CashProcessingEnabled,ETGrp_ConfigGroup),null,null);
			endif;
		endif;
	else 
		//enabling the cash processing
		if  _config.cashProcessingEnabled then	
			if _config.gateInAutoComplete then
				app.raiseCMException2(Not_enable_while_enabled,app.getEntTableRowTranslation(ETRow_CashProcessingEnabled,ETGrp_ConfigGroup),app.getFormCaptionsString(Xlat_0011555),null,null);
			endif;
			
			if	_config.gateInAutoCompleteBkgrnd then
				app.raiseCMException2(Not_enable_while_enabled,app.getEntTableRowTranslation(ETRow_CashProcessingEnabled,ETGrp_ConfigGroup),app.getEntTableRowTranslation(ETRow_GateInAutoCompleteBkgrnd,ETGrp_ConfigGroup),null,null);
			endif;
			
			if	_config.gateInAllowAutoComplete then
				app.raiseCMException2(Not_enable_while_enabled,app.getEntTableRowTranslation(ETRow_CashProcessingEnabled,ETGrp_ConfigGroup),app.getFormCaptionsString(Xlat_0011556),null,null);
			endif;
		
		endif;
	endif;
	
	// PAR #32849 Has Security Gate and Allow Auto Complete are mutually exclusive
	if _config.siteHasSecurityGate and _config.gateInAllowAutoComplete then
		app.raiseCMException2(Not_enable_while_enabled, app.getFormCaptionsString(Xlat_0011556), app.getFormCaptionsString(Xlat_0019390), null, null);
	endif;
	// PAR #32849 end
	
	yardArea := _config.defaultTBAYardLocation;			// 25/9/19 MAP TFS 45590
	if yardArea &lt;&gt; null and realTerminal.allTerminalAreas[yardArea] = null then
		app.raiseCMException1(ERR_INVALID_TA_ID, yardArea, null, null);
	endif;

	itemWidth := _config.roadGateReleaseItemWidth;		// 7/11/19 MAP TFS46955
	if (itemWidth &lt; 200 or itemWidth &gt;= 1000) and itemWidth &lt;&gt; 0 then
		app.raiseCMException(Road_gate_relea_cargo_relea_it, null, null);
	endif;
	
	// navlw1 JIRA-36268 05/11/2025
	if realTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean &lt;&gt; _config.allowDupVoyageInOutCodes then
		app.raiseCMWarning(Inwards_External_Codes_Changed,"Terminal Config",null,null);
	endif;

	_config.validateConfig();
epilog
	
end;</source>
        <Parameter name="realTerminal" type="CM_Terminal"/>
        <Parameter name="_config" type="CMIF_ConfigTerminal"/>
    </JadeMethod>
    <JadeMethod name="valTerminalStateObject" id="9bd0a9ca-239e-4620-b36c-1fed59084abf">
