    <JadeMethod name="validateForCreate" id="bb41f516-80e5-4b14-b473-b1b16e262833">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	23/11/2009	cnwcs5		ccms 1028 - summary mappings for ship planning
// ---------------------------------------------------------------------------
vars
	obj	:Object;
begin
	// name must have a value
	if self.name = null then
		app.raiseCMException (XLAT_Mapping_Error1, null, null);
	endif;
	
	// name cannot already be used
	if true = false then	// temp
		app.raiseCMException (XLAT_Mapping_Err2, null, null);
	endif;
	
	if self.getQueryProperty = null then
		app.raiseCMException1 (XTAB_InvalidPropertyName, self.propertyName, null, null);
	endif;
	
	// we expect the GUI to make sure the order is correct
	if order &lt;&gt; self.ORDER_MAPPING and
		order &lt;&gt; self.ORDER_MAPPING_VALUE then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid value for order');
	endif;
	
	// we expect the GUI to ensure otherValues is correct
	if self.otherValues &lt;&gt; self.OTHER_GROUPED and 
		self.otherValues &lt;&gt; self.OTHER_SEPERATE then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid value for other values');
	endif;
	
	if self.otherValues = self.OTHER_GROUPED then
		if self.otherHeading = null then
			app.raiseCMException (XLAT_Mapping_Error4, null, null);
		endif;
	endif;
	// there must be at least one mapping line
	if self.allMappingLines.isEmpty then
		app.raiseCMException (XLAT_Mapping_Error3, null, null);
	endif;
	
	foreach obj in self.allMappingLines do
		obj.CM_XTABMappingLine.validateForCreate;
	endforeach;
epilog

end;</source>
    </JadeMethod>
