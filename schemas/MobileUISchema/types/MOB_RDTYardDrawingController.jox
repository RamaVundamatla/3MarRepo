    <JadeMethod name="drawEverything" id="0b3fdb5a-7d37-4ef0-b075-013c75e04912">
        <updating/>
        <source>drawEverything() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars
	picture	: Picture;
begin
	self.hideLocationHighlight();
	self.clearGraphics();
	if self.isFancyGFX then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicGrayV;
		self.myDrawingFrame.drawPictureIn(
			picture.picture,
			0,
			0,
			self.myDrawingFrame.width,
			self.myDrawingFrame.height
		);
	endif;
	
	if self.isLandscape then
		self.drawAreaSubsetLandscape();
	else
		self.drawAreaSubsetPortrait();
	endif;
	self.drawGrid();
	self.drawGuides();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawFancyTI" id="7cd2ad42-22b4-4baa-b6ca-462bdec35d8a">
        <source>drawFancyTI(_x1, _y1, _x2, _y2 : Real; _ti : CM_TrackedItem; _frame : Frame) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwjk3	Initial creation

// Just for demo purposes


*/

vars
	picture			: Picture;
	opCode			: String;
begin
	opCode := _ti.operatorCode;
	if opCode = "ABOC" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicGreenV();
	elseif opCode = "DOUG" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicRedV();
	elseif opCode = "HLL" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicLightBlueV();
	elseif opCode = "TAT" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicOrangeV();
	elseif opCode = "CMS" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicBlueV();
	elseif opCode = "CSA" then
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicYellowV();
	else
		picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicPurpleV();
	endif;
	_frame.drawPictureIn(picture.picture, _x1, _y1, _x2, _y2);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_frame" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="drawGrid" id="a4e13cad-5556-4569-a65a-1b2509a6b352">
        <source>drawGrid() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
	hLineLen,
	vLineLen,
	gridWidth,
	gridHeight		: Real;
	numHLines,
	numVLines,
	count			: Integer;
begin
	if not self.showGrid then
		return;
	endif;
	
	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	numHLines := self.numGridRowsToDraw;
	numVLines := self.numGridColsToDraw;

	hLineLen := self.myDrawingFrame.width;
	vLineLen := self.myDrawingFrame.height;

	
	// Adjust number of lines
	if self.flipV  then
		if self.bottomGridRow = 1 and self.vScrollOffset &gt; 0 then
			numHLines := numHLines -1;
		endif;
	else
		if self.bottomGridRow = self.maxGridRow and self.vScrollOffset &gt; 0 then
			numHLines := numHLines -1;
		endif;
	endif;	
	if self.flipH  then
		if self.rightGridCol = 1 and self.hScrollOffset &gt; 0 then
			numVLines := numVLines -1;
		endif;
	else
		if self.rightGridCol = self.maxGridCol and self.hScrollOffset &gt; 0 then
			numVLines := numVLines -1;
		endif;
	endif;	
	
	// Draw horizontal lines 
	foreach count in 0 to numHLines do
		if self.flipV then
			self.myTIFrame.drawLine(0, self.myDrawingFrame.height - (self.bottomOffset - self.vScrollOffset + gridHeight * count), hLineLen, self.myDrawingFrame.height - (self.bottomOffset - self.vScrollOffset + gridHeight * count), Red); 
		else
			self.myTIFrame.drawLine(0, self.topOffset + self.vScrollOffset + gridHeight * count, hLineLen, self.topOffset + self.vScrollOffset + gridHeight * count, Red); 			
		endif;
	endforeach;

	// Draw vertical lines 
	foreach count in 0 to numVLines  do
		if self.flipH then
			self.myTIFrame.drawLine(self.myDrawingFrame.width - (self.rightOffset - self.hScrollOffset + gridWidth * count), 0, self.myDrawingFrame.width - (self.rightOffset - self.hScrollOffset + gridWidth * count), vLineLen, Red); 
		else
			self.myTIFrame.drawLine(self.leftOffset + self.hScrollOffset + gridWidth * count, 0, self.leftOffset + self.hScrollOffset + gridWidth * count, vLineLen, Red); 
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawGridOLD" id="f3c7090f-31bb-49e2-98f4-2cee8c4a8e3b">
        <source>drawGridOLD() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
	hLineLen,
	vLineLen,
	gridWidth,
	gridHeight		: Real;
	numHLines,
	numVLines,
	count			: Integer;
begin
	if not self.showGrid then
		return;
	endif;
	
	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	numHLines := self.numGridRowsToDraw;
	numVLines := self.numGridColsToDraw;

	
	hLineLen := numVLines * gridWidth + 1 + self.hScrollOffset;
	vLineLen := numHLines * gridHeight + 1 + self.vScrollOffset;

	// Adjust line lengths to cope with reaching end of cols/rows
	if self.flipV  then
		if self.bottomGridRow = 1 and self.vScrollOffset &gt; 0 then
			vLineLen := vLineLen - gridHeight;
		endif;
	else
		if self.bottomGridRow = self.maxGridRow and self.vScrollOffset &gt; 0 then
			vLineLen := vLineLen - gridHeight;
		endif;
	endif;
	if self.flipH  then
		if self.rightGridCol = 1 and self.hScrollOffset &gt; 0 then
			hLineLen := hLineLen - gridWidth;
		endif;
	else
		if self.rightGridCol = self.maxGridCol and self.hScrollOffset &gt; 0 then
			hLineLen := hLineLen - gridWidth;
		endif;
	endif;
	
	
	// Adjust number of lines
	if self.flipV  then
		if self.bottomGridRow = 1 and self.vScrollOffset &gt; 0 then
			numHLines := numHLines -1;
		endif;
	else
		if self.bottomGridRow = self.maxGridRow and self.vScrollOffset &gt; 0 then
			numHLines := numHLines -1;
		endif;
	endif;	
	if self.flipH  then
		if self.rightGridCol = 1 and self.hScrollOffset &gt; 0 then
			numVLines := numVLines -1;
		endif;
	else
		if self.rightGridCol = self.maxGridCol and self.hScrollOffset &gt; 0 then
			numVLines := numVLines -1;
		endif;
	endif;	

		
	self.debugCols( "-------- " &amp; method.name &amp; "------- " );
	
	// Draw horizontal lines 
	//foreach count in 0 to numRowsToDraw  do
	foreach count in 0 to numHLines do
		self.myTIFrame.drawLine(0, self.vScrollOffset + gridHeight * count, hLineLen, self.vScrollOffset + gridHeight * count, Red); 
	endforeach;

	// Draw vertical lines 
	//foreach count in 0 to numColsToDraw  do
	foreach count in 0 to numVLines  do
		//self.myGridFrame.drawLine(gridWidth * count, 0, gridWidth * count, vLineLen, Blue); 
		//self.myGridFrame.drawLine(self.hScrollOffset + gridWidth * count, 0, self.hScrollOffset + gridWidth * count, vLineLen, Blue); 
		self.myTIFrame.drawLine(self.hScrollOffset + gridWidth * count, 0, self.hScrollOffset + gridWidth * count, vLineLen, Red); 
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawGuides" id="9966ca44-6ceb-4142-b7dd-af069eceb09a">
        <source>drawGuides() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if not self.showGuideLines then
		return;
	endif;
	
	self.myTIFrame.drawLine(self.myDrawingFrame.clientWidth/2, 0, self.myDrawingFrame.clientWidth/2, self.myDrawingFrame.clientHeight, Blue);
	self.myTIFrame.drawLine(0, self.myDrawingFrame.clientHeight/2, self.myDrawingFrame.clientWidth, self.myDrawingFrame.clientHeight/2, Blue);
	self.myTIFrame.drawLine(self.leftOffset, 0, self.leftOffset, self.myDrawingFrame.clientHeight, Black);
	self.myTIFrame.drawLine(self.myDrawingFrame.clientWidth - self.rightOffset, 0, self.myDrawingFrame.clientWidth - self.rightOffset, self.myDrawingFrame.clientHeight, Black);
	self.myTIFrame.drawLine(0, self.topOffset, self.myDrawingFrame.clientWidth, self.topOffset, Black);
	self.myTIFrame.drawLine(0, self.myDrawingFrame.clientHeight - self.bottomOffset, self.myDrawingFrame.clientWidth, self.myDrawingFrame.clientHeight - self.bottomOffset, Black);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawLocation" id="c3dc9f6c-7077-47cb-8a34-1bc98bf9802b">
        <source>drawLocation( _x1, _y1, _gridWidth, _gridHeight : Real; _lcDraw : CMIF_RDTLocationDrawElement) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
	gx1, gy1,
	gx2, gy2	: Real;
begin	
	if _lcDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			gx1 := _x1 - _gridWidth;
			gy1 := _y1 - _gridHeight;
			gx2 := _x1;
			gy2 := _y1;
		else
			gx1 := _x1 - _gridWidth;
			gy1 := _y1;
			gx2 := _x1;
			gy2 := _y1 + _gridHeight;
		endif;
	else
		if self.flipV then
			gx1 := _x1;
			gy1 := _y1 - _gridHeight;
			gx2 := _x1 + _gridWidth;
			gy2 := _y1;
		else
			gx1 := _x1;
			gy1 := _y1;
			gx2 := _x1 + _gridWidth;
			gy2 := _y1 + _gridHeight;
		endif;
	endif;
	
	_lcDraw.draw(gx1, gy1, gx2, gy2, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV, self.drawMode);
	_lcDraw.gridPointsToElementPoints(gx1, gy1, gx2, gy2, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
	self.storeLCScreenPos(gx1, gy1, gx2, gy2, _lcDraw.myLocationsController);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_lcDraw" type="CMIF_RDTLocationDrawElement"/>
    </JadeMethod>
    <JadeMethod name="drawLocationID" id="78dc59ad-5b0d-4d69-a084-41f6cfa9133d">
        <source>drawLocationID( _lc : CM_GridController; _x1, _y1, _x2, _y2 : Real; _topTI : CM_TrackedItem; _frame : Frame input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	fontColour		: Integer;
	operator 		: CM_Operator;
	x1, y1,
	x2, y2,
	oldFontSize			: Real;
	oldDrawTextAlign 	: Integer;
begin
	if self.scaleFactor &lt; 1 then
		return;
	endif;	
	
	fontColour := Black;
	if _topTI &lt;&gt; null then
		operator := app.myRoot.allOperators[_topTI.operatorCode];
		if operator &lt;&gt; null then
			fontColour := operator.colour.getInverseColour();
		else
			fontColour := Black;
		endif;
	endif;
	
	oldFontSize := _frame.drawFontSize;
	oldDrawTextAlign := _frame.drawTextAlign;
	
	// Set font size
	if self.scaleFactor &lt;= 3 then
		_frame.drawFontSize := 2 * self.scaleFactor;
	else
		_frame.drawFontSize := 3 * self.scaleFactor;	
	endif;
	
	// Set font draw alignment
	_frame.drawTextAlign := Frame.DrawTextAlign_Right;
	
	// Form a rectangle to draw the text in
	x1 := _x1;
	y1 := _y2 - _frame.drawFontSize -12; //_frame.drawFontSize - 2;
	x2 := _x2 -4 ;
	y2 := _y2;
	//_frame.drawTextAt(_lc.getID(), x1, y1, Red);
	_frame.drawTextIn(_lc.getID(), x1, y1, x2, y2, fontColour);
	
	_frame.drawFontSize := oldFontSize;
	_frame.drawTextAlign := oldDrawTextAlign;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_topTI" type="CM_TrackedItem"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawLocationOLD" id="c1241405-7a9c-477d-b17b-b302f1222563">
        <source>drawLocationOLD( _x1, _y1, _gridWidth, _gridHeight : Real; _lcDraw : CMIF_RDTLocationDrawElement) protected;

/*

Purpose:			

Parameters:			

	_x1, _y1, _x2, _y2 - Grid rectangle

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
begin	
	if _lcDraw = null then 
		return;
	endif;
		
	if self.flipH then
		if self.flipV then
			//_lcDraw.draw(_x1 - _gridWidth, _y1 - _gridHeight, _x1, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
			self.storeLCScreenPos(_x1 - _gridWidth, _y1 - _gridHeight, _x1, _y1, _lcDraw.myLocationsController);
		else
			//_lcDraw.draw(_x1 - _gridWidth, _y1, _x1, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
			self.storeLCScreenPos(_x1 - _gridWidth, _y1, _x1, _y1 + _gridHeight, _lcDraw.myLocationsController);
		endif;
	else
		if self.flipV then
			//_lcDraw.draw(_x1, _y1 - _gridHeight, _x1 + _gridWidth, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);						
			self.storeLCScreenPos(_x1, _y1 - _gridHeight, _x1 + _gridWidth, _y1, _lcDraw.myLocationsController);
		else
			//_lcDraw.draw(_x1, _y1, _x1 + _gridWidth, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
			self.storeLCScreenPos(_x1, _y1, _x1 + _gridWidth, _y1 + _gridHeight, _lcDraw.myLocationsController);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
