    <JadeMethod name="isMatchWithString" id="ae26d81a-cd28-41d5-8d37-38a3978d6514">
        <source>isMatchWithString(_item: String; _fileValue: String; _match: String; _extraData: String output): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2015	cnwrd1	Initial creation

*/

vars

begin
    if self.item = _item then 
		if self.value = _fileValue then		
			//now check string match			
				_extraData := self.stopTable;
				return true;
			else
				return false;
			endif;
    endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_item" type="String"/>
        <Parameter name="_fileValue" type="String"/>
        <Parameter name="_match" type="String"/>
        <Parameter name="_extraData" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
