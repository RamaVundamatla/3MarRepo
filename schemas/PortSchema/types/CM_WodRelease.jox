    <JadeMethod name="getCustomEntryNumber" id="d0442dce-2eca-413e-87ca-b29ebec698b8">
        <source>getCustomEntryNumber(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	ti 		: CM_TrackedItem;
	cen		: String;
begin
	
	
	ti := self.getFirstTI();
	
	if ti &lt;&gt; null then
		cen := ti.customsEntryNumber;
	endif;
	
	if cen = null then
		cen := self.customsClearanceNumber;
	endif;
	
	return cen;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="85450a03-c6ba-42d1-a4d7-bf4da2c93170">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------------------------
07/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
01/04/2019 	JLGNS1		Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
29/09/2021  navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
06/03/2023 	navma1 		ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/
vars
	displayString : String;
	relReq 		  : CM_BulkRelease;
	typeDesc	  : String;
	code		  : String;
begin
	
	typeDesc := self.getTypeDescription();														//29.09.2021 navma1 #51925

	if _useShortDesc then
		displayString := typeDesc &amp;" Task #" &amp; self.getTaskSequenceNumber().String;				//06.03.2023 navma1 #56457:[56458]	
	else
		
		relReq := self.getMyReleaseRequest(); 													//Bug 44134
		
		if relReq &lt;&gt; null then																	//Bug 44134
		code := relReq.code;																	//Bug 44134
		endif;
		
		displayString :=  self.getLongDescription(typeDesc,code);								//29.09.2021 navma1 #51925
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
