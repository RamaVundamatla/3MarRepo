<Class name="CM_Symbol" id="33fbc29b-5b4f-45b5-8e5c-4720b45469c9">
    <superclass name="CM_Photo"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="userData"/>
    <ExplicitInverseRef name="myHazardClass" id="72fb7f45-0f16-40d6-ad9f-7fd88ca751bb">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_HazardClass"/>
        <access>readonly</access>
        <Inverse name="CM_HazardClass::allSymbols"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="ae4d0aab-1e33-4cd0-acea-ccb80fe126e4">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	if self.photoBytes = null then
		if self.isTransient() then
			create self.photoBytes transient;
		else
			create self.photoBytes persistent;
		endif;		
	endif;
	   
	if self.thumbnailBytes = null then
		if self.isTransient() then
			create self.thumbnailBytes transient;
		else
			create self.thumbnailBytes persistent;
		endif;
	endif;
	
	self.type := CM_Attachment.Type_Symbol;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="a515a3c4-69fc-4560-847c-f37cfecd3302">
        <updating/>
        <source>delete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	delete self.photoBytes;
	delete self.thumbnailBytes;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="bd99ffad-ac8b-40bb-8743-08273e638a1a">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	proxyObj : SelfType;
	completedOK : Boolean;

begin
	proxyObj := inheritMethod();
	proxyObj.myHazardClass := self.myHazardClass;
	completedOK := true;
	return proxyObj;
	
epilog
	if not completedOK then
		delete proxyObj;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="025d227c-16ba-43fd-9c4e-76b734868553">
        <updating/>
        <source>setForUpdate(_proxyObj: SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	inheritMethod(_proxyObj);
	self.myHazardClass := _proxyObj.myHazardClass;
epilog

end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMyParent" id="c53fb947-6f94-438c-8432-1a2511e472a9">
        <updating/>
        <source>setMyParent(_myParent: CM_Object) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	self.myHazardClass := _myParent.CM_HazardClass;

epilog

end;</source>
        <Parameter name="_myParent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="110a947f-9873-4dc6-9e6a-ae166181963f">
        <source>validateMe(_passport: CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
