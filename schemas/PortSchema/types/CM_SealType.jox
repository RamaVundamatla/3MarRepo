end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="99a3da73-acca-4fdc-a18c-f2bc6aa85b50">
        <source>pxyCreateUpdateProxy(): SelfType;
// CCMS 1131 PAR 23715 
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 23/03/2023	jlizm1		TFS 57098 EUP Seal numbers on trucks

vars
	sealType: SelfType;
	completedOK		: Boolean;
begin
	sealType :=	 inheritMethod();
	self.allCargoTypes.copy(sealType.allCargoTypes);
	self.allWagonClasses.copy(sealType.allWagonClasses);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return sealType;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete sealType;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="da079a49-1905-4407-955b-6192ac6d3c55">
        <updating/>
        <source>setForCreate(pProxySealType : CM_SealType) updating;
// CCMS 1131 PAR 23715 
vars
begin
	pProxySealType.raiseExceptionIfNotTransient(method);
	self.setForUpdate(pProxySealType);
	

end;</source>
        <Parameter name="pProxySealType" type="CM_SealType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6e9042b0-aa71-4400-ad91-bba54f0ac5b4">
        <updating/>
        <source>setForUpdate(pProxySealType : CM_SealType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
							CCMS 1131 PAR 23715
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/
vars
begin
	self.allCargoTypes.clear();
	pProxySealType.allCargoTypes.copy(self.allCargoTypes);
	self.allWagonClasses.clear();										//TFS 57098
	pProxySealType.allWagonClasses.copy(self.allWagonClasses);			//TFS 57098
	
	self.allowMultipleSealNums	:= pProxySealType.allowMultipleSealNums;
	self.description			:= pProxySealType.description;
	self.isInUse				:= pProxySealType.isInUse;
	self.myRoot 				:= app.myRoot;
	self.notAvailableForEntry	:= pProxySealType.notAvailableForEntry;
	self.sealType				:= pProxySealType.sealType;
	self.showSealOnCheck		:= pProxySealType.showSealOnCheck;
	self.savePreviousSeal		:= pProxySealType.savePreviousSeal;		//+cnwml2 PAR23715 SFW CCMS 1131
	self.useForTrucks			:= pProxySealType.useForTrucks;			//TFS 57098
	
epilog
end;</source>
        <Parameter name="pProxySealType" type="CM_SealType"/>
    </JadeMethod>
