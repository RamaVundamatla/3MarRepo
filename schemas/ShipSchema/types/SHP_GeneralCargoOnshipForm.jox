    <JadeMethod name="mnuOutTurnBOL_click" id="c7097b80-7e68-4f8e-b909-49c861603e70">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuOutTurnBOL_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2017	jlgndl1	Initial creation TFS 5701
24 Oct 2017		NDL		Rewrite for TFS 6940

*/

vars

	bolSet : CM_BOLSet;

begin

	if self.myCurrentBOL = null then
		return;
	endif;
	
	create bolSet transient;
	bolSet.add( self.myCurrentBOL );
	self.doOutturnEvent( bolSet );

epilog

	delete bolSet;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuOutTurnVoy_click" id="9954917c-49b9-4ae9-ac27-a33beba8272e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuOutTurnVoy_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2017	jlgndl1	Initial creation	TFS 6940

*/

vars

	bolSet : CM_BOLSet;

begin

	if self.myCurrentVoyage = null or self.myCurrentVoyage.allBOLInByTypeStatusNumDT.isEmpty then
		return;
	endif;
	
	create bolSet transient;
	self.myCurrentVoyage.allBOLInByTypeStatusNumDT.copy( bolSet );
	self.doOutturnEvent( bolSet );

epilog

	delete bolSet;

end;</source>
