    <JadeMethod name="initialiseFromDef" id="95761fc4-ff0b-4dd3-ad53-87beb80517d6">
        <updating/>
        <source>initialiseFromDef(_def : CM_ExternalWebServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15th July 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025

*/

vars

begin
	
	self.setMyExtWebServiceDef(_def);
	
	self.myRoot := app.myRoot;
	self.myExtWebserviceDef := _def;
	self.myTerminal := app.myPassport.myTerminal;
	self.createdUser := app.getMyUserCode();
	self.created := app.actualTimeServer();
epilog

end;</source>
        <Parameter name="_def" type="CM_ExternalWebServiceDef"/>
