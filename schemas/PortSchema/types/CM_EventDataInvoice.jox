<Class name="CM_EventDataInvoice" id="eb52fd35-61a8-4e5d-994c-bd8ce22f64f6">
    <superclass name="CM_EventData"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS CPL 2120 electronic invoicing for MSC</text>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myCompany" id="bc40f26d-86f7-4c30-87da-508c7d3511cf">
        <embedded/>
        <type name="CM_Bank"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myInvoice" id="04be00e5-6a15-467e-92a9-aad0f87d9ca8">
        <embedded/>
        <type name="CM_Invoice"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="cloneReferences" id="e961c598-7c5c-400a-ba37-fa0491f3d102">
        <updating/>
        <source>cloneReferences(_realEventData : CM_EventDataInvoice input) updating;

vars

begin

	_realEventData.myInvoice := self.myInvoice;
	_realEventData.myCompany := self.myCompany;
end;</source>
        <Parameter name="_realEventData" type="CM_EventDataInvoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEventDataDesc" id="e401aafb-21e0-4528-b802-d88eb62a9959">
        <source>getEventDataDesc(): String;

vars


begin

	if self.myInvoice = null then
		return null;
	endif;
	
	return 'Invoice - ' &amp; self.myInvoice.sequenceNum.String;
	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyEventDataInvoice" id="b8b09829-b959-4189-a19b-4d2fc21af767">
        <updating/>
        <source>setProxyEventDataInvoice(_invoice : CM_Invoice) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.type 		:= EventDataInvoicing;
	self.myCompany  := _invoice.bank;
	self.myInvoice	:= _invoice;
	
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
</Class>
