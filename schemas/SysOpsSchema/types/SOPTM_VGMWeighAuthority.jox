    <JadeMethod name="setupThumbnailDetails" id="303bc4e3-3743-4351-b7da-ea7eb5451866">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	form : SOP_TableMaintForm;
	weighAuth : CM_WeighAuthority;

begin
	form := self.myForm;
	form.useProxyObject := true;
	form.setTblDataEntRows(ETDef_WeighAuthorityMaint);

	form.shtTblInput1.caption := 'Details';
	form.initTblInput(form.tblInput1, ETDef_WeighAuthorityMaint);
