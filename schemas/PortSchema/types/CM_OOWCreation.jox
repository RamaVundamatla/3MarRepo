    <JadeMethod name="doJoint2040Jobs" id="781cb1d0-5d7f-4637-8fe1-6d645528f879">
        <source>doJoint2040Jobs(_isDisch : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		04 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	craneJnt2040 : Boolean;
	aCrane : CM_Crane;
	craneType : Integer;
begin
	aCrane := self.myCraneJobSheet.getMyCrane();
	
	if aCrane.isTwinLift then		//cnwmc5 - 28 July 2014 - PAR 34455
		craneType := JobTypePriority_Crane2;
	else
		craneType := JobTypePriority_Crane1;
	endif;
	
	craneJnt2040 := self.myVoyageStructure.getOOWSameJobFor2040(_isDisch,craneType);
	
	// so this is a T/L and it is configured for joint 20/40 jobs
	// lets check that the bay we are in can handle twin lifts
	if craneJnt2040 
	and (craneType = JobTypePriority_Crane2) then // TwinLift
		if self.ordinalDeck = DeckOnDeck then
			// this bay cannot handle T/L so lets see whether they have joint 20/40 for single lifts
			if not self.myBay.isTwinLiftOD then
				craneJnt2040 := self.myVoyageStructure.getOOWSameJobFor2040(_isDisch,JobTypePriority_Crane1);
			endif;
		else
			// this bay cannot handle T/L so lets see whether they have joint 20/40 for single lifts
			if not self.myBay.isTwinLiftUD then
				craneJnt2040 := self.myVoyageStructure.getOOWSameJobFor2040(_isDisch,JobTypePriority_Crane1);
			endif;
		endif;
	endif;
	
	return craneJnt2040;

end;</source>
        <Parameter name="_isDisch" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
