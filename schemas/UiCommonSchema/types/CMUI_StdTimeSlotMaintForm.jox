    <JadeMethod name="createProxiesForEdit" id="64ed264e-da84-4d92-b28e-31041dec8d21">
        <source>createProxiesForEdit(_row : Integer; _col : Integer) : CM_TimeSlotEntity protected;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	timeSlot : CM_TimeSlotEntity;
begin
	timeSlot := self.tblTimeSlot.accessCell(_row, _col).itemObject.CM_TimeSlotEntity;
	return app.createUpdateProxy(timeSlot).CM_TimeSlotEntity;
end;
</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="CM_TimeSlotEntity"/>
    </JadeMethod>
    <JadeMethod name="displayTimeSlots" id="7424deb0-55fb-47fa-928f-6a0043c9ae5f">
        <updating/>
        <source>displayTimeSlots(_currentRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	iter		: Iterator;
	timeSlot	: CM_TimeSlotEntity;
	idxCol,
	idxRow,
	day 		: Integer;
	
	dict		: Dictionary;

begin
	self.initTblTimeSlot();
	
	if self.formType = FORM_TYPE_STD then
		dict := self.myTerminal.allTimeSlotStd;
	else
		dict := self.myTerminal.allTimeSlotByDate;
	endif;
	
	iter := dict.createIterator();
	while iter.next(timeSlot) do
		if self.formType = FORM_TYPE_STD then
			if timeSlot.CM_TimeSlotStd.day = MONDAY then
				self.tblTimeSlot.rows := self.tblTimeSlot.rows + 1;
				idxRow := self.tblTimeSlot.rows;
				self.addDisplayTimeSlot(timeSlot, idxRow, timeSlot.CM_TimeSlotStd.day);
			endif;
			self.addDisplayTimeSlot(timeSlot, idxRow, timeSlot.CM_TimeSlotStd.day);
		else
			if timeSlot.CM_TimeSlot.date = self.selectedDate then
				self.tblTimeSlot.rows := self.tblTimeSlot.rows + 1;
				idxRow := self.tblTimeSlot.rows;
				self.addDisplayTimeSlot(timeSlot, idxRow, 2);
			endif;
		endif;
	endwhile;
	
	if _currentRow &lt;&gt; 0 then
		self.tblTimeSlot.row := _currentRow;
		self.tblTimeSlot.selectRow(_currentRow, true);
	endif;
epilog
	delete iter;
end;
</source>
        <Parameter name="_currentRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="62a69a39-8b85-43c4-93fe-3cbfa53c5100">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	if self.mode = MODE_VIEW then
		self.unloadForm;
	else
		setFormMode(MODE_VIEW);
		self.displayTimeSlots(0);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="0664bf88-daef-4057-99ec-b08d7316a747">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	timeStart,
	timeEnd		: Time;
	numOfSlot,
	timeInSlot,
	row,
	col			: Integer;
begin
	self.tblTimeSlot.sortAscending := false;		
	self.tblTimeSlot.resortTableByColumn(1);
	
	foreach row in 2 to self.tblTimeSlot.rows do
		timeStart := self.tblTimeSlot.accessCell(row, 1).text.Time;
		foreach col in 2 to self.tblTimeSlot.columns do
			numOfSlot := self.tblTimeSlot.accessCell(row, col).text.Integer;
			
			if not valEditSlots(timeStart, row, col) then
				return;
			endif;
			if self.formType = FORM_TYPE_STD then
				if not self.saveTimeSlot(col - 1, null, timeStart, numOfSlot, row, col) then
					return;
				endif;
			else
				if not self.saveTimeSlot(0, self.selectedDate, timeStart, numOfSlot, row, col) then
					return;
				endif;			
			endif;
		endforeach;
	endforeach;
	
	self.setFormMode(MODE_VIEW);
	self.displayTimeSlots(0);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnCancelClick" id="7ffd0f6a-7d69-4f9e-a634-c348250bbc19">
        <updating/>
        <source>doBtnCancelClick() updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	//self.frmCreateDlg.visible := false;
	self.setFormMode(MODE_VIEW);
	//self.clearProxyDetails();
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnSaveClick" id="d1ad395e-5ff3-48f9-8fd1-1627c292d1cd">
        <updating/>
        <source>doBtnSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars
	timeStart,
	timeEnd,
	tmpTime,
	timeIS		: Time;
	timeInSlots,
	numOfSlot,
	day,
	row,
	col			: Integer;
	
	dateFrom,
	dateTo		: Date;
	iter		: Iterator;
	timeSlot	: CM_TimeSlotEntity;

begin
// cnwdad1 17/06/2009 - PAR #19942.
//	timeStart := self.txtTimeStart.text.Time;
//	timeEnd := self.txtTimeEnd.text.Time;
//	timeInSlots := self.txtTimeInSlots.text.Integer;
//	numOfSlot := self.txtNumOfSlots.text.Integer;
//	dateFrom := self.dateMask.text.Date;
	timeStart := self.txtTimeStart.getTime();
	timeEnd := self.txtTimeEnd.getTime();
	timeInSlots := self.txtTimeInSlots.text.Integer;
	numOfSlot := self.txtNumOfSlots.text.Integer;
	dateFrom := self.dateMask.getDate();
	
	if not valBulkCreateSlots() then
		return;
	endif;
	
	if self.mode = MODE_CREATE then	
		if self.formType = FORM_TYPE_STD then
			day := 1;
			tmpTime := timeStart;
			while day &lt;= 7 do
				if tmpTime &lt; timeEnd then
					if not self.saveTimeSlot(day, null, tmpTime, numOfSlot, 0, 0) then
						return;
					endif;	
				else
					day := day + 1;
					tmpTime := timeStart;
					continue;
				endif;
				timeIS.setTime(0, timeInSlots, 0, 0);
				tmpTime := tmpTime + timeIS;
			endwhile;
		else
			tmpTime := timeStart;
			while tmpTime &lt; timeEnd do
				if not self.saveTimeSlot(0, self.selectedDate, tmpTime, numOfSlot, 0, 0) then
					return;
				endif;
				timeIS.setTime(0, timeInSlots, 0, 0);
				tmpTime := tmpTime + timeIS;
			endwhile;
		endif;
	endif;
		
	if self.mode = MODE_ADD then
		if self.formType = FORM_TYPE_STD then
			foreach col in 2 to 8 do
				if not self.saveTimeSlot(col - 1, null, timeStart, numOfSlot, 0, 0) then
					return;
				endif;
			endforeach;
		else
			if not self.saveTimeSlot(0, self.selectedDate, timeStart, numOfSlot, 0, 0) then
				return;
			endif;
		endif;
	endif;
	
	if self.mode = MODE_COPY and self.formType = FORM_TYPE_SPECIFIC then
		dateTo := self.selectedDate;
		iter := self.myTerminal.allTimeSlotByDate.createIterator();
		
		foreach row in 2 to self.tblTimeSlot.rows do
			doDelTimeSlot(row);
		endforeach;
		
		while iter.next(timeSlot) do
			if timeSlot.CM_TimeSlot.date = dateFrom then
				if not self.saveTimeSlot(0, dateTo, timeSlot.startTime, timeSlot.numOfSlot, row, col) then
					return;
				endif;
			endif;
		endwhile;
	endif;

	self.setFormMode(MODE_VIEW);

	
epilog
	delete iter;		// PAR #26678
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCopyTimeSlot" id="aebd0beb-423d-4c4c-8d50-efebc6b3a13f">
