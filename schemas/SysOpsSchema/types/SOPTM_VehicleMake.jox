    <JadeMethod name="doSave" id="776c27d7-ce17-449b-a334-29debb168161">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars
	proxyVehicleMake	: CM_VehicleMake;
	theForm 			: SOP_TableMaintForm;
	
	lMake				: String;
	
begin
	theForm := self.myForm; 
	
	lMake := theForm.tblInput1.getValueByName(ETRow_Make).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_VehicleMake transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyVehicleMake := theForm.myProxyObject.CM_VehicleMake;
	proxyVehicleMake.setProxy(lMake);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateVehicleMake(proxyVehicleMake, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateVehicleMake(proxyVehicleMake, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
