    <JadeMethod name="getGrayScale" id="51ac64dd-c585-4312-9c13-d24ae710d7d7">
        <source>getGrayScale(_idx : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		07 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 16415 CCMS 1029
//
// ---------------------------------------------------------------------------
vars
	rgb, idx : Integer;
begin
	rgb := 253;
	
	foreach idx in 1 to _idx do
		rgb := rgb - 14;
	endforeach;
	
	if rgb &lt; 0 then
		rgb := 0;
	endif;
	return app.convertRGBToColor(rgb,rgb,rgb);

end;</source>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
