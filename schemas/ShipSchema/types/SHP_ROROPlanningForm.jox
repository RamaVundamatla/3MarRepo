    <JadeMethod name="setMoveControllerSource" id="40dc2218-ff4f-458c-8174-705e6add6da5">
        <updating/>
        <source>setMoveControllerSource(_ti: CM_TrackedItem) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	theLSlotRequest,
	theDSlotRequest		: CM_RORORequest;
	theSlotController	: CM_VoyageROROController;
	theReturn 			: Integer;
	origLC				: CM_LocationsController;
	objects : CM_ObjectArray;
	obj : Object;
	theTI : CM_TrackedItem;
	moveController	: CMIF_MoveController;
	tmpTI : CM_TrackedItem;
	theWLE : CM_WorkListEntry;
	job : CM_Job;
begin

	tmpTI := _ti;
	
	create moveController transient;
	
	
	if app.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	endif;
	origLC := _ti.getPrimaryLocation(REAL_MODE);
	
	app.myMoveController := moveController;
	moveController.setMyTrackedItem(tmpTI);
	moveController.setMyOriginatingLocation(origLC);
	moveController.setMoveMode(self.moveModeForm);	
	moveController.isRehandleMove := tmpTI.isRehandle;
	moveController.myOriginatingForm := self;
//	moveController.transferType := VESSEL_TYPE_RORO; // TFS 4435

		

//	app.myMoveController.ignoreWeightValidation	:=	self.chkIgnoreWeightV.value;	

	if origLC = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController.myOriginatingLocation is null');
		return;
	endif;


	if self.moveModeForm = REAL_MODE then
		app.myMoveController.mySlotRequest := null;
		app.myMoveController.myVoyageRequest := null;
		return;
	endif;

	if (not origLC.isKindOf(CM_VoyageROROController))
	or (_ti.isTranshipExport() and self.moveModeForm = PLANNING_MODE) // should be an export replan. This has already been plan loaded and they can drag drop to a different slot
	then
		// ### if the orig location for this TI in this event on this form is not a slot controller 
		// then it must be that we are dragging an export TI 
		// that is planned to the ship and we want it planned elsewhere
		if _ti.myPrimaryActualLocation = origLC 
		or _ti.isTranshipExport()
		then
			if _ti.myPrimaryPlannedLocation &lt;&gt; null then
				if _ti.myPrimaryPlannedLocation.isKindOf(CM_VoyageROROController) then
					theSlotController := _ti.myPrimaryPlannedLocation.CM_VoyageROROController;
					theLSlotRequest := theSlotController.myRORORequestLoad;
				endif;
			endif;
		endif;
		if theLSlotRequest &lt;&gt; null then
			app.myMoveController.mySlotRequest := null;
			app.myMoveController.myVoyageRequest := theLSlotRequest;
		endif;

		return;
	endif;

	theSlotController := origLC.CM_VoyageROROController;
	
	// #### DISCHARGE
	if self.modeView = ShpDisplayMode_ColCodeDisch then
		theDSlotRequest := theSlotController.myRORORequestDischarge;
		if theDSlotRequest &lt;&gt; null then
			app.myMoveController.mySlotRequest := null;
			app.myMoveController.myVoyageRequest := theDSlotRequest;
		endif;

	// ##### LOAD
	else
		// it is possible to have discharge CC for a SOB AND load CC for an export, in the same slot.
		// the user is allowed to drag drop either, so if we have both we ask which one to use
		// only get the TI from the discharge CC if it is SOB, else get the ti for the load
		// if the TI is actaully here then we want the Discharge slot request, else we want the load
		// NOTE see baypoint getTI for the choosing of the TI
		if _ti.myPrimaryActualLocation = theSlotController then
			theLSlotRequest := theSlotController.myRORORequestDischarge;
		else
			theLSlotRequest := theSlotController.myRORORequestLoad;
		endif;
		// may have been erased so will be null move type
		if theLSlotRequest &lt;&gt; null then 
			app.myMoveController.mySlotRequest := null;
			app.myMoveController.myVoyageRequest := theLSlotRequest;
		endif;
	endif;
	
	if  app.myMoveController.myVoyageRequest &lt;&gt; null then
		theWLE := app.myMoveController.myVoyageRequest.getWLEForTI(_ti);
		app.myMoveController.setMyWorkListEntry(theWLE);
	endif;
	
	//12 Mar 2018	NDL	TFS 37444
	if app.myMoveController.myWorkListEntry &lt;&gt; null then
		job := app.myMoveController.myWorkListEntry.job;
	endif;
	app.myMoveController.setTransferTypeFromJob( job, VESSEL_TYPE_RORO );	//12 Mar 2018	NDL	TFS 37444
	
epilog
	delete objects;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMoveControllerTarget" id="3b30102f-b4b7-4be4-8f0a-c87403dbe2c3">
        <updating/>
        <source>setMoveControllerTarget(_req : CM_RORORequest) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars

	moveController	: CMIF_MoveController;
begin

	create moveController transient;
	
	delete app.myMoveController;
	app.myMoveController := moveController;
	moveController.setMyToPrimaryLocation(_req.myROROController);
	moveController.myVoyageRequest := _req;
	moveController.setMoveMode(PLANNING_MODE);	
	
	app.myDraggedTrackedItem := null; // PAR 28365 This is used by the DIscharge planning so should be nulled out during load planning
epilog

end;</source>
        <Parameter name="_req" type="CM_RORORequest"/>
    </JadeMethod>
