<Class name="CM_TrackedItemBRXref" id="df39976c-c2f3-4bda-9eef-c5944328badd">
    <superclass name="CM_XREFObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="crossref"/>
    <PrimAttribute name="bookingReference" id="b5772072-f230-412a-8799-71374b066e90">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myParent" id="21a9fcbf-2f0d-4050-bd07-b849bf4a4a07">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TerminalTIsByBR"/>
        <access>readonly</access>
        <Inverse name="CM_TerminalTIsByBR::allTIXrefsByTI"/>
        <Inverse name="CM_TerminalTIsByBR::allTIXrefsByBookingRef"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="11ad55c3-3980-43db-a9bd-22d656b8cc6b">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="setValuesForUpdate" id="8d8b2bcc-22e5-44dc-ac70-dbf8c929a07d">
        <updating/>
        <source>setValuesForUpdate(_parent : CM_TerminalTIsByBR;
				   _ti : CM_TrackedItem;
				   _bookingRef : String) : Boolean updating;

/*

Purpose:			Update the receiver with the passed in values

Parameters:			

Return Value:		True if any update occurred


Date		Who		Reason
27 Aug 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars
	updated			: Boolean;
	
begin
	if self.bookingReference &lt;&gt; _bookingRef then
		self.bookingReference := _bookingRef;
		updated := true;
	endif;
	if self.myTrackedItem &lt;&gt; _ti then
		self.myTrackedItem := _ti;
		updated := true;
	endif;
	if self.myParent &lt;&gt; _parent then
		self.myParent := _parent;
		updated := true;
	endif;
	
	return updated;
	

epilog

end;</source>
        <Parameter name="_parent" type="CM_TerminalTIsByBR"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_bookingRef" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
