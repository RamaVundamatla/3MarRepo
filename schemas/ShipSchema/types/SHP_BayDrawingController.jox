//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj);
	
	if CM_Voyage.hasInstance(_obj) then
		self.endNotification(_obj, self.noteVoyageAreaRefresh);
		self.endNotification(_obj, self.noteVoyageAreaUpdate);
