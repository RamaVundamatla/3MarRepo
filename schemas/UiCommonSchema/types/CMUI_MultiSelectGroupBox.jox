    <JadeMethod name="addItem" id="fa1ae420-ee93-448e-8d2c-6b5e94dc175b">
        <updating/>
        <source>addItem(_listBox : CM_MultiSelectListBox input; _theObject : Object) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars	
	idx		: Integer;
begin
	// add into the selected list box	
	idx := _listBox.addItem(self.displayEntry(_theObject));
	_listBox.itemObject[idx] := _theObject;
	
	return idx;
end;</source>
        <Parameter name="_listBox" type="CM_MultiSelectListBox" usage="input"/>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="availableHeading" id="8f4220dd-01d7-4ad9-a801-fc185b346bf0">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>availableHeading(set: Boolean; _value: String io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.availableHeading := _value;
		if self.myAvailableLbl &lt;&gt; null then
			self.myAvailableLbl.caption := _value;
			if _value = null then
				self.myAvailableLbl.visible := false;
			else
				self.myAvailableLbl.visible := true;
			endif;
		endif;
	else
		_value := self.availableHeading;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="buildSelf" id="b207af29-f168-488f-b054-4c9b49231176">
        <updating/>
        <source>buildSelf() updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Aug 2024	navnk30		Bug 65636: NSW - EDI Issues Configuration UI issues
// ---------------------------------------------------------------------------
vars

begin

	// NOTE: The order each control is created sets the tab ordering
	
	self.transparent := true;

	// Create the selected ListBox
	if self.mySelectedListBox = null then
		create self.mySelectedListBox transient;
		self.mySelectedListBox.parent := self;
		form.addControl(self.mySelectedListBox);

		if self.form.class &lt;&gt; CMUI_EDIEmailForm then	//22.08.2024 navnk30 #65636
			self.mySelectedListBox.sorted := true;
		endif;
		self.mySelectedListBox.multiSelect := self.multiSelect;
		
	endif;	
	
	// Create the Labels
	
	if self.myAvailableLbl = null then
		create self.myAvailableLbl transient;
		self.myAvailableLbl.parent := self;
		form.addControl(self.myAvailableLbl);

		self.myAvailableLbl.visible := false;
		self.myAvailableLbl.autoSize := true;
		self.myAvailableLbl.transparent := true;
		self.myAvailableLbl.wordWrap := true;
	endif;

	if self.mySelectedLbl = null then
		create self.mySelectedLbl transient;
		self.mySelectedLbl.parent := self;
		form.addControl(self.mySelectedLbl);

		self.mySelectedLbl.visible := false;
		self.mySelectedLbl.autoSize := true;
		self.mySelectedLbl.transparent := true;
		self.mySelectedLbl.wordWrap := true;
	endif;
	
		//cnwmc5 - 10/12/2012 - added this button
	if self.myBottomSelectedBtn = null then
		create self.myBottomSelectedBtn transient;
		self.myBottomSelectedBtn.parent := self;
		form.addControl(self.myBottomSelectedBtn);
		
		self.myBottomSelectedBtn.width := 20;
		self.myBottomSelectedBtn.caption := 44.Character; 
		self.myBottomSelectedBtn.fontName := "Wingdings 3";
		self.myBottomSelectedBtn.fontSize := 12;
		self.myBottomSelectedBtn.visible := false;
		//self.myBottomSelectedBtn
		
	endif;
	
	//cnwmc5 - 10/12/2012 - added this button
	if self.myTopSelectedBtn = null then
		create self.myTopSelectedBtn transient;
		self.myTopSelectedBtn.parent := self;
		form.addControl(self.myTopSelectedBtn);
		
		self.myTopSelectedBtn.width := 20;
		self.myTopSelectedBtn.caption := 43.Character; 
		self.myTopSelectedBtn.fontName := "Wingdings 3";
		self.myTopSelectedBtn.fontSize := 12;
		self.myTopSelectedBtn.visible := false;
		
	endif;

	if self.myDownSelectedBtn = null then
		create self.myDownSelectedBtn transient;
		self.myDownSelectedBtn.parent := self;
		form.addControl(self.myDownSelectedBtn);
		
		self.myDownSelectedBtn.width := 20;
		self.myDownSelectedBtn.caption := 226.Character; 
		self.myDownSelectedBtn.fontName := "Wingdings";
		self.myDownSelectedBtn.fontSize := 8;
		self.myDownSelectedBtn.visible := false;
		
	endif;		

	if self.myUpSelectedBtn = null then
		create self.myUpSelectedBtn transient;
		self.myUpSelectedBtn.parent := self;
		form.addControl(self.myUpSelectedBtn);
		
		self.myUpSelectedBtn.width := 20;
		self.myUpSelectedBtn.caption := 225.Character; 
		self.myUpSelectedBtn.fontName := "Wingdings";
		self.myUpSelectedBtn.fontSize := 8;
		self.myUpSelectedBtn.visible := false;
		
	endif;	

	if self.myRemoveAllBtn = null then
		create self.myRemoveAllBtn transient;
		self.myRemoveAllBtn.parent := self;
		form.addControl(self.myRemoveAllBtn);
		self.myRemoveAllBtn.width := 20;
		self.myRemoveAllBtn.caption := '&lt;&lt;'; 

		self.myRemoveAllBtn.fontSize := 8;
		//self.myRemoveAllBtn.visible := false;		//cnwmc5 - 7/12/2012
		
	endif;	

	if self.myAddAllBtn = null then
		create self.myAddAllBtn transient;
		self.myAddAllBtn.parent := self;
		form.addControl(self.myAddAllBtn);
		self.myAddAllBtn.width := 20;
		self.myAddAllBtn.caption := '&gt;&gt;'; 

		self.myAddAllBtn.fontSize := 8;
		//self.myAddAllBtn.visible := false;		//cnwmc5 - 7/12/2012
		
	endif;
	
	if self.myRemoveSelectedBtn = null then
		create self.myRemoveSelectedBtn transient;
		self.myRemoveSelectedBtn.parent := self;
		form.addControl(self.myRemoveSelectedBtn);

		self.myRemoveSelectedBtn.width := 20;
		self.myRemoveSelectedBtn.caption := '&lt;';
		
	endif;

	// Create the Buttons
	if self.myAddSelectedBtn = null then
		create self.myAddSelectedBtn transient;
		self.myAddSelectedBtn.parent := self;
		form.addControl(self.myAddSelectedBtn);
		
		self.myAddSelectedBtn.width := 20;
		self.myAddSelectedBtn.caption := '&gt;';
		
	endif;	

	// Create the avaialbe ListBoxe
	if self.myAvailableListBox = null then
		create self.myAvailableListBox transient;
		self.myAvailableListBox.parent := self;
		form.addControl(self.myAvailableListBox);
		
		self.myAvailableListBox.sorted := true;
		self.myAvailableListBox.multiSelect := self.multiSelect;
		
	endif;

	self.userInputEnabled := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="clearSelected" id="22ef12ee-40b6-4858-bf81-f4b1fb4e29af">
        <updating/>
        <source>clearSelected() updating;

// Created by cnwdvb1 on 15 September 2006

vars

	idx,
	numItems	: Integer;
	obj			: Object;
begin

	// first move any selected items back into the available listbox.
	numItems := self.mySelectedListBox.listCount;
	
	foreach idx in numItems to 1 step -1 do
		obj := self.mySelectedListBox.itemObject[idx];
		self.removeItem(idx, obj);
	endforeach;
	
	self.mySelectedListBox.clear;

end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="3c49c14c-e61c-477c-9569-1cfc4e5573b4">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/07/2013	cnwcs5		CCMS POL 2221 / par 32094
// ---------------------------------------------------------------------------
constants

vars

	allButtons : ObjectArray;
begin
	if (not self.isBuilt) or self.myAddSelectedBtn = null then
		return;
	endif;
	
	inheritMethod;
	
	//epr TFS 2227 3/8/16
	create allButtons transient; 
	allButtons.add(self.myAddSelectedBtn);
	allButtons.add(self.myRemoveSelectedBtn);
	allButtons.add(self.myAddAllBtn);
	allButtons.add(self.myRemoveAllBtn);
	allButtons.add(self.myUpSelectedBtn);
	allButtons.add(self.myDownSelectedBtn);
	allButtons.add(self.myTopSelectedBtn);
	allButtons.add(self.myBottomSelectedBtn);
	
	//epr refactored into method
	self.resizeMultiSelectLists(self.myAvailableListBox,self.mySelectedListBox,self.myAvailableLbl,self.mySelectedLbl,allButtons);
	
	
epilog
	delete allButtons;
end;</source>
    </JadeMethod>
