    <JadeMethod name="validateForUpdate" id="e6f68efb-82d5-4962-9bee-4c13c1ce2c2a">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.name = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'name', 'name', null);
		app.raiseCMException(Input_required_field_name, 'name', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'description', 'description', null);
		app.raiseCMException(Input_required_field_desc, 'description', null); // cnwdb2	PAR 35364
		return;
	endif;
	
epilog

end;
</source>
    </JadeMethod>
