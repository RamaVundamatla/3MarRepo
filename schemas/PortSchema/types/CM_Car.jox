    <JadeMethod name="getDisplayStringForAttribute" id="3cf0ec86-58df-458d-a918-6666d68dfba2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

// 16/03/2010	cnwcs5	par 22726 - new height, length, width ETRows
// 13/09/2013	cnwdap1	PAR #32215 new Car attributes
// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04/08/2016   cnwma1	TFS 2430:Unexpected Program Error in UiCommonSchema : : msgBox
// 29/08/2016   cnwma1  TFS #2607:PAR38173 STWO - Unable to edit cargo subtype
// 20/01/2020   cnwma1	Bug 48226: PNL - Pre-noting Reefers in the Web Portal - 8.6.1.080 PNL
// 31 Oct 2023	navma1  ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
// 01/07/2025	jlizm1	MTN 35067 Cargo Enquiry table check boxes should be yes/no instead
vars

begin
	if _attrName = ETRow_HasRadio then
		return app.myRoot.carHasRadioDisplay(self.hasRadio);
		
	elseif _attrName = ETRow_IsSelfPropelled then
		return self.selfPropelled.getYesNo;
		
	elseif _attrName = ETRow_IsSelfPropelledYesNo then
		return self.selfPropelled.getYesNo;
		
	elseif _attrName = ETRow_HeightCM then				// 16/03/2010 cnwcs5 par 22726
		return inheritMethod (ETRow_Height, _short);	// 16/03/2010 cnwcs5 par 22726
		
	elseif _attrName = ETRow_LengthCM then				// 16/03/2010 cnwcs5 par 22726
		return inheritMethod (ETRow_Length, _short);	// 16/03/2010 cnwcs5 par 22726
		
	elseif _attrName = ETRow_WidthCM then				// 16/03/2010 cnwcs5 par 22726
		return inheritMethod (ETRow_Width, _short);		// 16/03/2010 cnwcs5 par 22726
		
	elseif _attrName = ETRow_Make then					// PAR #32215
		return self.make;								// PAR #32215
	elseif _attrName = ETRow_Model then					// PAR #32215
		return self.model;								// PAR #32215
	elseif _attrName = ETRow_VehicleType then			// PAR #32215
		return self.carType;							// PAR #32215
	elseif _attrName = ETRow_Doors then					// PAR #32215
		return self.nbrDoors.zeroNotAllowed;			// PAR #32215          
	elseif _attrName = ETRow_NewVehicle then			// PAR #32215
		return self.isNew.getYesNo;						// PAR #32215
	elseif _attrName = ETRow_NewVehicleYesNo then
		return self.isNew.getYesNo;
	elseif _attrName = ETRow_DocsReceived then			// PAR #32215
		return self.systemToLocalTime(self.docsReceived).Date.asStringJMT;		// PAR #32215// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_DocsSent then				// PAR #32215
		return self.systemToLocalTime(self.docsSent).Date.asStringJMT;			// PAR #32215// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_DocsCleared then			// PAR #32215
		return self.systemToLocalTime(self.docsCleared).Date.asStringJMT;		// PAR #32215// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_DocsReturned then			// PAR #32215
		return self.systemToLocalTime(self.docsReturned).Date.asStringJMT;		// PAR #32215// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_Colour then				// PAR #32215
		return self.colour;								// PAR #32215
	elseif _attrName = ETRow_Year then					// PAR #32215
		return self.year.zeroNotAllowed;				// PAR #32215
	elseif _attrName = ETRow_TrackingNumber1 then
		return self.trackingNumber1;
	elseif _attrName = ETRow_TrackingNumber2 then
		return self.trackingNumber2;
	elseif _attrName = ETRow_MyCarProduct then  	//29/08/2016 cnwma1 TFS #2607 PAR #38173
		return  self.getCargoSubTypeCode();			//31.10.2023 navma1 #60920
	elseif _attrName = ETRow_Vin then				//21 Dec 2020	NDL	TFS 50341
		return self.vin;		
	elseif _attrName = ETRow_Registration then	//21 Dec 2020	NDL	TFS 50341
		return self.registration;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
