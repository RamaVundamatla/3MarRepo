epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBOLUpdate" id="56818ffd-322a-44eb-90da-1c5019fa8405">
        <methodInvocation>mapping</methodInvocation>
        <source>isBOLUpdate(set: Boolean; _value: Boolean io) mapping;
/* ---------------------------------------------------------------------------
Created:     07 March 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := (self.bolNumber &lt;&gt; null);
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
