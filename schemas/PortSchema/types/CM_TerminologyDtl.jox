    <JadeMethod name="processUserHeadings" id="717aaf99-40a9-4430-be40-c02ad2c5ea8d">
        <updating/>
        <source>processUserHeadings(_terminologyExpression : CM_TerminologyExpression) updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     Seek and replace
//			 
// ----------   ----------  --------------------------------------------------
vars
	newHeading,
	origHeading,
	searchFor,
	replaceWith			: String;
begin
	if _terminologyExpression = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'CM_TerminologyExpression passed in is null');
		return;
	endif;
	
	searchFor := _terminologyExpression.systemExpression;
	if searchFor = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'CM_TerminologyExpression.systemExpression is null');
		return;
	endif;
	
	replaceWith := _terminologyExpression.userExpression;
	if replaceWith = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'CM_TerminologyExpression.userExpression is null');
		return;
	endif;
	
	self.setUserHeading(searchFor, replaceWith);
	self.setUserShortHeading(searchFor, replaceWith);

end;</source>
        <Parameter name="_terminologyExpression" type="CM_TerminologyExpression"/>
    </JadeMethod>
    <JadeMethod name="resetUserHeading" id="181b93d9-783c-4f35-99d3-0de7a724f271">
        <updating/>
        <source>resetUserHeading() updating;
// ---------------------------------------------------------------------------
// Created:     17 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpDtl	: CM_TerminologyTypeDtl;
begin
	tmpDtl := self.myTerminologyTypeDtl;
	if tmpDtl &lt;&gt; null then
		self.userHeading := tmpDtl.systemEntRowHeading;
		self.userShortHeading := tmpDtl.systemEntRowShortHeading;
	else
		self.userHeading := null;
		self.userShortHeading := null;
	endif;

end;</source>
    </JadeMethod>
