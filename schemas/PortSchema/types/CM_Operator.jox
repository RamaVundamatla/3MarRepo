    </JadeMethod>
    <JadeMethod name="getOperatorTerminal" id="9d08205a-4cc0-4ed5-807f-e7ef6d78e376">
        <source>getOperatorTerminal(_terminal : CM_Terminal; _createIfNull : Boolean) : CM_OperatorTerminal;
// ---------------------------------------------------------------------------
// Created:     09 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	opTerm	: CM_OperatorTerminal;

begin

	if _terminal = null then
		return opTerm;
	endif;

	opTerm := self.allOperatorTerminals[_terminal];
	
	if opTerm = null and _createIfNull then
		// assume that if _createIfNull is passed in that the
		// system is in transaction state already
		if self.isTransient then			// cnwar2 par 19672
			create opTerm transient;
		else
			create opTerm persistent;
		endif;
		opTerm.init(self, _terminal);
	endif;
	
	return opTerm;
		

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_createIfNull" type="Boolean"/>
        <ReturnType type="CM_OperatorTerminal"/>
    </JadeMethod>
