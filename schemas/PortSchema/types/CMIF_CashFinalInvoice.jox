    <JadeMethod name="setBaseDetails" id="8f69ae91-66a7-4ca6-8981-1addf8ec1146">
        <updating/>
        <source>setBaseDetails(_cashInvoicePayment: CM_CashPayment; cmifSumm: CMIF_CashTrxSummary) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	inheritMethod(_cashInvoicePayment, cmifSumm);
	
	if _cashInvoicePayment.myTrackedItem &lt;&gt; null then
		self.cargoId :=  _cashInvoicePayment.myTrackedItem.id;
	endif;
	if _cashInvoicePayment.myCarrier &lt;&gt; null then
		self.carrier :=  _cashInvoicePayment.myCarrier.description;
	endif;
	if _cashInvoicePayment.myDriver &lt;&gt; null then
		self.driver :=  _cashInvoicePayment.myDriver.name;
	endif;
	if _cashInvoicePayment.myInvoice &lt;&gt; null then
		self.invoice :=  _cashInvoicePayment.myInvoice.getDisplayDetails(false).removeTabCrLfs().String[1:100];
		if self.invoice.length &gt; 50 then
			self.invoice :=  self.invoice[1:47] &amp; "...";
		endif;
	endif;
	if _cashInvoicePayment.myUser &lt;&gt; null then
		user := _cashInvoicePayment.myUser.code[1:30];
	endif;

epilog

end;</source>
        <Parameter name="_cashInvoicePayment" type="CM_CashPayment"/>
        <Parameter name="cmifSumm" type="CMIF_CashTrxSummary"/>
    </JadeMethod>
    <JadeMethod name="setLineValues" id="9cc31adb-0911-4253-b87a-f13f77702b83">
        <updating/>
        <source>setLineValues(_description : String; _quantity : Real; _total : Decimal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 February 2013	cnwjre1	Initial creation

*/

vars

begin
	self.lineDescription := _description;
	self.lineQuantity := _quantity;
	self.cashValue := _total;
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_quantity" type="Real"/>
        <Parameter name="_total" type="Decimal"/>
    </JadeMethod>
