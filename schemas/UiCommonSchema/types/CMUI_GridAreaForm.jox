    <JadeMethod name="loadDataForFirstTime" id="49bf0f7c-0f72-41b1-8fe8-dfba77e30939">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theMainFrame, theViewFrame : Frame;
begin

	inheritMethod();
	
	theMainFrame := self.frmPosition;
	theViewFrame := self.frmPositionView;
	theViewFrame.boundaryColor := Yellow;
	theViewFrame.boundaryWidth := 4;
	theMainFrame.boundaryWidth := 6;
	theMainFrame.boundaryColor := DarkBlue;
	theMainFrame.boundaryBrush := 0;
	theMainFrame.bevelInnerWidth := 0;
	theMainFrame.bevelOuterWidth := 0;
	theMainFrame.backColor := 16772829; //light Blue
	
	self.isSelectorCapable := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
