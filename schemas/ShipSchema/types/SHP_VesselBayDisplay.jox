    <JadeMethod name="createProxyBay" id="670d0607-3915-4599-bd74-b488a5aeb979">
        <updating/>
        <source>createProxyBay() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	pxyHold : CM_VesselHold;
begin
	inheritMethod;
	if self.myProxyBay = null then
		return;
	endif;

	beginLoad;
	pxyHold:=self.myBay.myHold.CM_VesselHold.pxyCreateUpdateProxy;
	pxyHold.setProxy(null,self.myBay.myHold.ordinalHold);
	self.myProxyBay.setMyHold(pxyHold);

epilog
	endLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayEntryShip" id="d3498669-8966-4926-ad5e-baccacfe1354">
        <updating/>
        <source>displayEntryShip(combobox: ComboBox input; _vesselStructure : CM_VesselStructure; lstIndex: Integer) :String updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

	tmpVessel : CM_Vessel;
begin
	if _vesselStructure = null then
		return null;
	endif;

	tmpVessel := _vesselStructure.myVessel;
	if tmpVessel = null then
		return null;
	endif;	
	
	if self.displayShipByName then
		return tmpVessel.name &amp;  " - (" &amp; tmpVessel.code &amp; ")" ;
	else
		return tmpVessel.code &amp; Tab &amp; tmpVessel.name;		
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_vesselStructure" type="CM_VesselStructure"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBaysCollection" id="735cf8e4-15ff-44c8-973f-4d876bc94b10">
        <source>getBaysCollection() : Collection;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myCellularVesselStructure &lt;&gt; null then
		return  self.myCellularVesselStructure.allBaysByLabel;
	
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
