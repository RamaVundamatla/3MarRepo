    <JadeMethod name="btn_SetDown_click" id="238404d6-a7bb-457b-8ec3-1573e36dba40">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btn_SetDown_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	objToDelete : CMIF_Object;
	selectedCMIFs : CMIF_Array;
begin
	//if doSave then
	//	doClearTable(false);
	//endif;
	//28/01/2010 cnwdz2 par22195
	create selectedCMIFs transient;
	if self.doSave() then
		self.tbl_Items.getAllSelectedObjects(selectedCMIFs);
		if selectedCMIFs.size() &gt; 0 then
			foreach objToDelete in selectedCMIFs do
				self.deleteObjectFromTable(objToDelete);
			endforeach;
		else
			self.doClearTable(false); //30/03/2010 cnwdz2 par22195
		endif;
	endif;
epilog
	delete selectedCMIFs;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
