    <JadeMethod name="getPickupTasks" id="d6cc8768-8c94-47d3-a2a6-a12ea63ddafb">
        <source>getPickupTasks(arbiter: CM_RTQueueArbiter input; _isOverstowMove	:	Boolean);
/*
	method that returns the work required to pick up a TI.
*/
vars
	task	: CM_RTQueueTask;
	theTargetLocation : CM_LocationsController;
begin
	create task;
	//parent will be set higher up.
	
	if arbiter.job.isKindOf(CM_YardInternalJob) then
		if arbiter.job.CM_YardInternalJob.isSwapJob then
			//SwapJob, use the Arbiter's locations, NOT the TI's ones (its still going to its original 
			//un-swapped location at this stage
			theTargetLocation := arbiter.targetLocation; 
		else
			theTargetLocation := arbiter.ti.getPrimaryLocation(QUEUE_MODE); 
			// Special case. Doing overstow tasks.
			if theTargetLocation = null then
				theTargetLocation := arbiter.targetLocation;
			endif;
		endif;
	else
		theTargetLocation := arbiter.ti.getPrimaryLocation(QUEUE_MODE); 
	endif;
	
	task.setDetails(	self,
						theTargetLocation,
						TASK_UNACTIONED,
						TASK_PICKUP,
						arbiter.ti);
	task.isOverstowTask := _isOverstowMove;

	arbiter.entry.addTask(task);
	//arbiter.addTask(task);
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_isOverstowMove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQueueTasks" id="acf3e153-9db0-47a7-8d70-2ed5c617c9e0">
        <source>getQueueTasks(arbiter: CM_RTQueueArbiter input; _isSource : Boolean);
//Returns the tasks required to do a unit of work. (move a TI)
//Called from the RTQueueArbiter.
vars

begin
	//Determine if the ti in the arbiter transient is here.
	


	if _isSource then
	
		//------------
		//Get the TI to provide its "pickup tasks"
		//------------
		
		self.getPickupTasks(arbiter, false);
	else
		//Target.
		//------------
		//Get the target to provide its "set-down tasks"
		//------------
		self.getSetdownTasks(arbiter, false);
	endif;
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSetdownTasks" id="a64768b1-7dbb-471b-8a07-43188b52ffa8">
        <source>getSetdownTasks(arbiter: CM_RTQueueArbiter input; isOverstowMove	:	Boolean);
/*
	method that returns the work required to set TI to the ground.
*/
vars
	task	: CM_RTQueueTask;
begin
	create task;
	//parent will be set higher up.
	
	task.setDetails(	arbiter.ti.getPrimaryLocation(REAL_MODE),
						self,
						TASK_UNACTIONED,
						TASK_SETDOWN,
						arbiter.ti);
	
	
	task.isOverstowTask := isOverstowMove;

	arbiter.entry.addTask(task);
	
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="isOverstowMove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getStateForNewCargo" id="84ce63a9-49ca-4ddf-9ac3-71401eb872d3">
        <source>getStateForNewCargo(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 September 2024	navcs2	ChangeRequest 65925: CUX | POST /cargo API: Create On-Site cargo on-board an on-site trailer or mafi.

*/

vars

begin
	return self.myTILC.state;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveFromToLC" id="4d17612d-f21c-46b7-abd7-b4f22de34ed5">
        <source>getTiTxnTypesForMoveFromToLC(_toController: CM_LocationsController; _intArray: IntegerArray input; _moveController: CMIF_MoveController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2020	jlgndl1	Initial creation	TFS 50422
15 Jul 2024 jlier1 TFS 65208  
*/

vars
	
begin
	inheritMethod(_toController, _intArray, _moveController);
	
	if self.myTerminal.roadProcessIsASPA then
		if _moveController &lt;&gt; null and _moveController.myAssociatedVVR &lt;&gt; null then
			if _toController &lt;&gt; null and _toController &lt;&gt; self then
				_intArray.add( TRANS_TYPE_TRAILER_DIS );
			elseif _toController = self then
				_intArray.add( TRANS_TYPE_TRAILER_LOAD );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_toController" type="CM_LocationsController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveFromToNULL" id="36cd458d-e201-42ad-bd5e-f959af636c96">
        <source>getTiTxnTypesForMoveFromToNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
/*

Date		Who		Reason
09 July 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars
	tmpTI : CM_TrackedItem;
begin
	inheritMethod(_moveController, _intArray);

	tmpTI := _moveController.myTrackedItem;

	app.addTiTxnSubTerminalRelease(tmpTI, TI_TRANSMODE_ROAD, _intArray);		// CCMS 1875.  	// PAR 20706 (swap order)

	if tmpTI.isAnInterTerminalRelease() then
		_intArray.add(TRANS_TYPE_REL_ROAD_INTER_TERM);
	else
		_intArray.add(TRANS_TYPE_REL_ROAD);
	endif;

	// TFS 42277 ALL CM_Release transaction create a storage transaction, so this is not needed. _intArray.add(TRANS_TYPE_STORAGE);
epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveToFromLC" id="643f2def-9386-4e6a-9f28-253e215394ed">
        <source>getTiTxnTypesForMoveToFromLC(_fromController: CM_LocationsController; _intArray: IntegerArray input; _moveController: CMIF_MoveController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Nov 2020	jlgndl1	Initial creation	TFS 50422
15 Jul 2024 jlier1 TFS 65208  
*/

vars

begin
	inheritMethod(_fromController, _intArray, _moveController);
	
	if self.myTerminal.roadProcessIsASPA then
		if _moveController &lt;&gt; null and _moveController.myAssociatedVVR &lt;&gt; null then
			if _fromController &lt;&gt; null and _fromController &lt;&gt; self then
				_intArray.add( TRANS_TYPE_TRAILER_LOAD );
			elseif _fromController = self then
				_intArray.add( TRANS_TYPE_TRAILER_DIS );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_fromController" type="CM_LocationsController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveToFromNULL" id="053ba665-a1e7-4c76-ac4e-aae72b9a964e">
        <source>getTiTxnTypesForMoveToFromNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2013	cnwer1	Initial creation CCMS SFW 1338

*/

vars
	tmpTI : CM_TrackedItem;
begin
	inheritMethod(_moveController, _intArray);
	tmpTI := _moveController.myTrackedItem;
	//jlier1 TFS 66300 7/10/24
	if self.myTILC &lt;&gt; null and self.myTILC.isOnShip then
		//created on a Trailer on ship
		return;
	endif;
	//Cargo comming into yard from Road
	if tmpTI.isAnInterTerminalReceival() then
		_intArray.add(TRANS_TYPE_REC_ROAD_INTER_TERM);
	else
		_intArray.add(TRANS_TYPE_REC_ROAD);
	endif;
	
	app.addTiTxnSubTerminalReceive(tmpTI, TI_TRANSMODE_ROAD, _intArray);		
epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVehicle" id="fdaef2a6-e4c2-4f89-b119-d9acf1b768d0">
        <source>getVehicle() : CM_Vehicle;
// ---------------------------------------------------------------------------
// Created:     22 September 2016 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// TFS 2699
// ---------------------------------------------------------------------------

vars
	parent : CM_Object;
begin
	parent := self.getParent();
	
	if parent.isKindOf(CM_VehicleController) then
		return parent.CM_VehicleController.vehicle;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="hasContainers" id="d73458e9-b9ed-494f-8122-fff932b2ac4e">
        <source>hasContainers(_checkPlanned,
				_checkQueued : Boolean) : Boolean;
/*

Date		Who		Reason
16 July 2014	cnwer1	Initial creation PAR par 34576 

*/

vars
	ti : CM_TrackedItem;
	fm : CM_FutureMove;
begin
	
	foreach ti in self.allTrackedItems do
		if not ti.isKindOf(CM_Cargo) then
			return true;
		endif;
	endforeach;
	
	if _checkPlanned then
		foreach fm in self.allPlannedFutureMoves do
			ti:=fm.getTrackedItem;
			if ti = null then
				continue;
			endif;
			if not ti.isKindOf(CM_Cargo) then
				return true;
			endif;
		endforeach;
	endif;
	if _checkQueued then
		foreach fm in self.allQueuedFutureMoves do
			ti:=fm.getTrackedItem;
			if ti = null then
				continue;
			endif;
			if not ti.isKindOf(CM_Cargo) then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_checkPlanned" type="Boolean"/>
        <Parameter name="_checkQueued" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMAFIController" id="3d242596-e8e4-430a-bfff-c9732d36ab61">
        <source>isMAFIController() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
20 February 2024		jlizm1	Initial creation TFS 62467 CUX Warning when setdown to MAFI heap

*/

vars

begin
	if self.myTILC = null then
		return false;
	endif;
	
	return self.myTILC.isMAFI;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
