    <JadeMethod name="trxUpdateTIConsigneeConsignor" id="74b98798-49ef-4ce3-987f-57a25800698a">
        <updating/>
        <source>trxUpdateTIConsigneeConsignor(pIncorrectCode, pCorrectCode : CM_ConsigneeConsignor; 
					_passport : CM_Passport input;
					pNumTIs : Integer output) updating;
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	tiSet		: CM_TISet;	
	ti			: CM_TrackedItem;
	iter		: Iterator;
	i			: Integer;
	term		: CM_Terminal;
	incorrectCode	: String;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportSilentExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 10, _passport);

	app.setContinueCMExceptions(true);
	
	app.myValUA.valTIConsigneeConsignor(pIncorrectCode, pCorrectCode);
	
	if _passport.hasErrors then
		return;
	endif;

	app.setContinueCMExceptions(false);

	incorrectCode := pIncorrectCode.code;

	create tiSet transient;
	//term := app.getMyTerminal;	cnwsb1 PAR 4846
	
	foreach term in app.myRoot.allTerminals do
		//foreach i in 0 to term.onsiteTrackedItems.size do
		//	if term.onsiteTrackedItems[i] = null then
		//		continue;
		//	endif;
			delete iter;		// PAR #26678
			iter := term.allOnsiteTIsByCargoTypeId.createIterator;
			while iter.next(ti) do
				if ti.consignee = incorrectCode or 
					ti.consignor = incorrectCode then
					tiSet.add(ti);
				endif;
				if (not _passport.noErrors) then
					break;
				endif;
			endwhile;
			if (not _passport.noErrors) then
				break;
			endif;
		//endforeach;
	endforeach;
	
	pNumTIs := tiSet.size;
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdateTIConsign(tiSet, pIncorrectCode, pCorrectCode, _passport);
	
epilog	
	self.finaliseActivityWithPassport(_passport);
	if tiSet &lt;&gt; null then
		delete tiSet;
	endif;			
	delete iter;

end;</source>
        <Parameter name="pIncorrectCode" type="CM_ConsigneeConsignor"/>
        <Parameter name="pCorrectCode" type="CM_ConsigneeConsignor"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pNumTIs" type="Integer" usage="output"/>
    </JadeMethod>
