    <JadeMethod name="vesselRequiresPilotForRule" id="74ec07c6-2a87-458b-a7af-21ea020451e7">
        <source>vesselRequiresPilotForRule( _vessel : CM_Vessel ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	vesselValue : Decimal [14,2];

begin

	if not self.isActive then
		return false;
	endif;
	
	if self.criteria = self.Criteria_Weight then
		vesselValue := _vessel.myHMSVesselData.dim_GrossRegTonnes;
	elseif self.criteria = self.Criteria_Length then
		vesselValue := _vessel.myHMSVesselData.dim_LengthOverall;
	elseif self.criteria = self.Criteria_Draft then
		if _vessel.myHMSVesselData.dim_DraftAft &gt; _vessel.myHMSVesselData.dim_DraftFore then
			vesselValue := _vessel.myHMSVesselData.dim_DraftAft;	
		else
			vesselValue := _vessel.myHMSVesselData.dim_DraftFore;
		endif;
	else
		return false;
	endif;

	if self.operator = self.Oper_Equals then
		if vesselValue = self.value then
			return true;
		endif;
	elseif self.operator = self.Oper_GEQ then
		if vesselValue &gt;= self.value then
			return true;
		endif;
	elseif self.operator = self.Oper_Greater_Than then
		if vesselValue &gt; self.value then
			return true;
		endif;
	elseif self.operator = self.Oper_LEQ then
		if vesselValue &lt;= self.value then
			return true;
		endif;
	elseif self.operator = self.Oper_Less_Than then
		if vesselValue &lt; self.value then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="voyageRequiresPilotForRule" id="98e71a3c-eca8-4377-b4a2-f19b81d145b9">
        <source>voyageRequiresPilotForRule( _voyage : CM_Voyage; _movement : HMS_VoyageMovement ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	voyageValue : Decimal [14,2];
	vessel: CM_Vessel;
	vesselData : HMS_VesselData;

begin

	if not self.isActive or _voyage = null then
		return false;
	endif;
	
	vessel := _voyage.getMyVessel; 
	if vessel &lt;&gt; null then
		vesselData := vessel.myHMSVesselData;
	endif;
	
	// get the value from the voyage (to test against the rules).  If its not populated, use the value from the vessel.
	if self.criteria = self.Criteria_Weight then
		if  _voyage.myHMSVoyageData &lt;&gt; null then
			voyageValue := _voyage.myHMSVoyageData.dim_GrossRegTonnes;
		endif;
		if voyageValue = 0 and vesselData &lt;&gt; null then
			voyageValue := vesselData.dim_GrossRegTonnes;
		endif;
	elseif self.criteria = self.Criteria_Length then
		if  _voyage.myHMSVoyageData &lt;&gt; null then
			voyageValue := _voyage.myHMSVoyageData.dim_LengthOverall;
		endif;
		if voyageValue = 0 and vesselData &lt;&gt; null then
			voyageValue := vesselData.dim_LengthOverall;
		endif;
	elseif self.criteria = self.Criteria_Draft then
		//16 Jan 2013	NDL	Par 30888 - draft can be changed on the movement
		if _movement &lt;&gt; null then
			if _movement.draftAft &gt; _movement.draftFwd then
				voyageValue := _movement.draftAft;	
			else
				voyageValue := _movement.draftFwd;
			endif;
		endif;
		if voyageValue = 0 and _voyage &lt;&gt; null then
			if  _voyage.myHMSVoyageData &lt;&gt; null then
				if _voyage.myHMSVoyageData.dim_DraftAft &gt; _voyage.myHMSVoyageData.dim_DraftFore then
					voyageValue := _voyage.myHMSVoyageData.dim_DraftAft;	
				else
					voyageValue := _voyage.myHMSVoyageData.dim_DraftFore;
				endif;
			endif;
		endif;
		if voyageValue = 0 and vesselData &lt;&gt; null then
			if vesselData.dim_DraftAft &gt; vesselData.dim_DraftFore then
				voyageValue := vesselData.dim_DraftAft;	
			else
				voyageValue := vesselData.dim_DraftFore;
			endif;
		endif;
	else
		// not a criteria we know about
		return false;
	endif;

	if self.operator = self.Oper_Equals then
		if voyageValue = self.value then
			return true;
		endif;
	elseif self.operator = self.Oper_GEQ then
		if voyageValue &gt;= self.value then
			return true;
		endif;
	elseif self.operator = self.Oper_Greater_Than then
		if voyageValue &gt; self.value then
			return true;
		endif;
	elseif self.operator = self.Oper_LEQ then
		if voyageValue &lt;= self.value then
			return true;
		endif;
	elseif self.operator = self.Oper_Less_Than then
		if voyageValue &lt; self.value then
			return true;
		endif;
	else
		//not an operator we know about
		return false;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
