    <JadeMethod name="doFindBooking" id="683ba937-0c17-4c79-af68-2d956b474e05">
        <updating/>
        <source>doFindBooking( _id : String; _isStock : Boolean ):CM_BookingRef updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2011	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	bookingRef : CM_BookingRef;
	iter : Iterator;
	allBookingRefs : ObjectArray;
	
	picker : MOB_HandHeldPickerForm;
	form : Form;

begin

	if _id = null
	or _id = self.lblContBookEnt.caption.toUpper
	or _id = self.lblStockBookEnt.caption.toUpper
	then
		return null;
	endif;

	term := self.myTerminal;
	bookingRef := term.allBookingRefsByStatusRef.getAtKey(BOOKING_REF_ACTIVE,_id);
	
	if bookingRef = null then
		return null;
	endif;
	
	iter := term.allBookingRefsByStatusRef.createIterator;
	iter.startAtObject(bookingRef);
	
	create allBookingRefs transient;
	
	while iter.next( bookingRef ) do

		if bookingRef.bookingReference &lt;&gt; _id then
			break;
		endif;
		if bookingRef.status &lt;&gt; BOOKING_REF_ACTIVE then
			break;
		endif;
		if bookingRef.isStockBookingRef &lt;&gt; _isStock then
			continue;
		endif;
		allBookingRefs.add( bookingRef );
	endwhile;
	
	// if we find dups need to present some sort of picker showing bookingref, operator and voyage.
	create picker transient;
	form := self;
	picker.setAllAvailable(	allBookingRefs,	//_selectedObjs : ObjectArray;
							allBookingRefs.first,	//_default : Object;
							"Booking",	//_objectTypeString : String;
							form,	//_form : Form
							MOB_HHPackForm::bookingDisplayLine.name	//_displayObjMethName : String
							);
	picker.showModal();
	return picker.mySelectedObject.CM_BookingRef;
	
epilog

	delete allBookingRefs;
	delete picker;
	delete iter;		// PAR #27874

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isStock" type="Boolean"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="doFindTrackedItem" id="a780312e-476a-4b10-a06b-1a710d6582a9">
        <source>doFindTrackedItem():CM_TrackedItem protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	id : String;
	ti : CM_TrackedItem;
	allTis : CM_TISet;

begin

	id := self.txtContainerId.text.trimBlanks.toUpper;
	if id = null then
		return null;
	endif;
	
	create allTis transient;
	self.myTerminal.getTIsMatchingId( id,  null, allTis, TI_STATE_NORMAL);
	
	if allTis.isEmpty then
		return null;
	endif;
	
	return allTis.first;

epilog

	delete allTis;

end;</source>
        <access>protected</access>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="02b377e2-5bcd-4e5f-b6b2-a1b6af71242b">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	tabIndex : Integer;
	transPackComplete : CM_TITransaction;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.lblStockBooking.setAndIncrementTabIndex( tabIndex );
		self.lblStockBooking.visible := true;
	endif;
	self.lblStockBooking.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
								
	top := self.lblStockBooking.top + self.lblStockBooking.height;
	if _initialSetup then
		self.txtCargoBooking.setAndIncrementTabIndex( tabIndex );
		self.txtCargoBooking.visible := true;
	endif;
	self.txtCargoBooking.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	self.txtCargoBooking.text := self.lblStockBookEnt.caption;
	
	top := self.txtCargoBooking.top + self.txtCargoBooking.height + self.resizedMargin;
	if _initialSetup then
		self.cmbCargoBookItem.setAndIncrementTabIndex( tabIndex );
		self.cmbCargoBookItem.visible := true;
	endif;
	self.cmbCargoBookItem.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
								
	top := self.cmbCargoBookItem.top + self.cmbCargoBookItem.height + ( self.resizedMargin * 2 );
	if _initialSetup then
		self.lblCargoBooking.setAndIncrementTabIndex( tabIndex );
		self.lblCargoBooking.visible := true;
	endif;
	self.lblCargoBooking.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
								
	top := self.lblCargoBooking.top + self.lblCargoBooking.height;
	if _initialSetup then
		self.txtContBooking.setAndIncrementTabIndex( tabIndex );
		self.txtContBooking.visible := true;
	endif;
	self.txtContBooking.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	if _initialSetup then
		self.txtContBooking.text := self.lblContBookEnt.caption;
		self.cmbContBooking.setAndIncrementTabIndex( tabIndex );
		self.cmbContBooking.visible := false;
	endif;
	self.cmbContBooking.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
								
	top := self.txtContBooking.top + self.txtContBooking.height + self.resizedMargin;
	if _initialSetup then
		self.cmbContBookItem.setAndIncrementTabIndex( tabIndex );
		self.cmbContBookItem.visible := true;
	endif;
	self.cmbContBookItem.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
								
	top := self.cmbContBookItem.top + self.cmbContBookItem.height + ( self.resizedMargin * 2 );
	if _initialSetup then
		self.lblContainerId.setAndIncrementTabIndex( tabIndex );
		self.lblContainerId.visible := true;
	endif;
	self.lblContainerId.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
								
	top := self.lblContainerId.top + self.lblContainerId.height;
	if _initialSetup then
		self.txtContainerId.setAndIncrementTabIndex( tabIndex );
		self.txtContainerId.visible := true;
	endif;
	self.txtContainerId.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	if _initialSetup then
		self.txtContainerId.text := lblContEnt.caption;
	endif;
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="58a6ffab-c3dd-4b9c-ac31-e6f94cc98312">
