    <JadeMethod name="doCmdSetTrxDelay" id="b9a799ee-3f4f-4e46-a5bc-9431f074d469">
        <updating/>
        <source>doCmdSetTrxDelay(target : Object) updating;

vars
	n, errNo : Integer;
	errTxt : String;
	
begin
	n := self.lastTrxDelaySetting;
	
	if app.readInteger("Enter the delay (in milliseconds) between driver transactions:",
		true, 0, 9999999, n)
	then
		self.lastTrxDelaySetting := n;
		
		on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
		
		if target = null then
			system.causeEvent(CmdEventNumber, true, CmdSetTrxDelay &amp; ':' &amp; n.String);
		else
			target.causeEvent(CmdEventNumber, true, CmdSetTrxDelay &amp; ':' &amp; n.String);
		endif;
	endif;
end;</source>
        <Parameter name="target" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doCmdStart" id="18849655-d06d-4e6e-afad-709587172ce0">
        <updating/>
        <source>doCmdStart(target : Object) updating;

vars
	d : DriverDescriptor;
	errNo : Integer;
	errTxt : String;
	
begin
	if self.allProcessDescsByProcess.size &lt; 1 then
		// there is nothing to start!
		//return;  // jhp 20080611
	endif;
	
	if target = null or target = system then
		d := self;
	elseif target.isKindOf(Node) then
		d := self.allNodeDescriptorsByNode[target.Node];
	elseif target.isKindOf(Process) then
		d := self.allProcessDescsByProcess[target.Process];
	else
		d := null;
	endif;

	if d = null then
		app.errorMsg("The receiver of this command is not recognised as a System, Node or Process." &amp;
			CrLf &amp; CrLf &amp; "Object: " &amp; getOidStringForObject(target) &amp; CrLf &amp; CrLf &amp;
			"The start command will not be sent.", false);
		return;
	endif;
		
	self.startClock;

	d.start;
	
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	if target = null then
		system.causeEvent(CmdEventNumber, true, CmdStart);
	else
		target.causeEvent(CmdEventNumber, true, CmdStart);
	endif;
end;</source>
        <Parameter name="target" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doCmdStop" id="c58ba512-1911-4728-80b0-0e1842bb6c8a">
        <updating/>
        <source>doCmdStop(target : Object) updating;

vars
	d : DriverDescriptor;
	errNo : Integer;
	errTxt : String;
	obj : Object;
	
begin
	if target = null then
		d := null;
	elseif target.isKindOf(Node) then
		d := self.allNodeDescriptorsByNode[target.Node];
	elseif target.isKindOf(Process) then
		d := self.allProcessDescsByProcess[target.Process];
	else
		d := null;
	endif;
	
	if d = null then
		// stop everything
		self.stop;
		obj := system;
	else
		d.stop;
		obj := target;
	endif;

	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	obj.causeEvent(CmdEventNumber, true, CmdStop);
end;</source>
        <Parameter name="target" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doCmdTerminate" id="257b03e9-284e-4e99-b6dc-dca2746f8e2b">
