<Class name="CM_ProformaAllocation" id="bdfffacb-72b6-40d5-a0a1-d48866667920">
    <superclass name="CM_YardAllocation"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="proForma"/>
    <ImplicitInverseRef name="myBank" id="5dec0820-917a-48ce-937f-743f2cf55255">
        <embedded/>
        <type name="CM_Bank"/>
