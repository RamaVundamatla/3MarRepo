    <JadeMethod name="trxUpdateEDITIStatusBulk" id="a45b0a5d-2e77-4f0b-8d38-86c738f1a691">
        <updating/>
        <source>trxUpdateEDITIStatusBulk(_coll :CM_EDITISet; _newStatus: Integer; _passport: CM_Passport input) updating;
/*
Date		Who		Reason
26 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars
	ediTI	:CM_EDITrackedItem;
begin
	//	do not initialize activity for this action
	app.setContinueCMExceptions(true);	
	
	beginTransaction;
	
	foreach ediTI in _coll do
		app.myUtilityUA.utlUpdateEDITIStatus(ediTI, _newStatus, _passport);
	endforeach;

	app.cmsCommitTransaction(null);
	
epilog
	//should have committed by now - must be a problem
	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;
	
end;</source>
        <Parameter name="_coll" type="CM_EDITISet"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
