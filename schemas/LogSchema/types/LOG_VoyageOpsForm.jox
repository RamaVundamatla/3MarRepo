    <JadeMethod name="tblSSSEDIData_contextMenu" id="3631dbad-38da-4f5a-8d36-ed401464ea2f">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSSSEDIData_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------------------
//Created: 19 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	x1 : Real;
	y1 : Real;

begin

	if self.tblSSSEDIData.row &lt;= self.tblSSSEDIData.fixedRows then
		return false;
	endif;
	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 1 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuSSSDeleteFile.visible := false;
		self.mnuSSSLoadFile.visible := false;
	endif;
	

	self.popupMenu(mnuLVOOptions, x1.Integer, y1.Integer);
	return false;                  // cancel further processing
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
