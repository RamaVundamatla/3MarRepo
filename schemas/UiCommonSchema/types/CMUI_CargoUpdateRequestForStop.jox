    <JadeMethod name="doChangeUpdateType" id="5799b29e-ddbc-4101-841f-33d31bbf281d">
        <updating/>
        <source>doChangeUpdateType() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation

*/

constants

	Spacing = 8;

vars

	updateType, cargoTypeIdx : Integer;
	controlTop : Real;
	cargoBOLType		: CM_CargoBOLType;
	cargoType	: CM_CargoType;
	loadCargpTypes : Boolean;
	locale : CM_Locale;													
	weighAuth : CM_WeighAuthority;	
	idx : Integer;
	buttonOffset : Real;
	
begin

	updateType := self.cmbUpdateType.listData;
	
	if updateType &lt; 1 then
		self.grpDetails.visible := false;
		self.grpEmail.visible := false;
		self.btnSave.visible := false;
	else
		self.grpDetails.visible := true;
		self.grpEmail.visible := true;
		self.btnSave.visible := true;
	endif;
			
	self.grpToDo.visible:= updateType = EventRequestTypeToDo;
	self.grpRemarks.visible:= updateType = EventRequestTypeRemarks;
	self.grpGrade.visible:= updateType = EventRequestTypeGrade;
	self.grpWeight.visible:= updateType = EventRequestTypeWeight;
	
	self.txtRef.case := TextBox.Case_None;
	controlTop := self.cmbUpdateType.top + self.cmbUpdateType.clientHeight + Spacing;
	self.txtCertName.visible:= updateType = EventRequestTypeWeight;			//Bug 38876
	self.txtAuthName.visible:= updateType = EventRequestTypeWeight;			//Bug 38876
	self.lblCertName.visible:= updateType = EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	self.lblRef.visible:= updateType = EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	self.txtRef.visible:= updateType &lt;&gt; EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	self.lblReference.visible:= updateType &lt;&gt; EventRequestTypeWeight;	//23 Aug 2017	NDL	TFS 5803
	
	locale := app.myCurrentLocale;											// TFS #1699
	if locale = null then													// TFS #1699
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);	// TFS #1699
	endif;																	// TFS #1699
	lblRef.translateCaption(Xlat_0019651, locale);		// TFS #1699
	
	if self.grpToDo.visible then
		self.grpToDo.top := controlTop;
		self.tblToDo.leftColumn := 1;
		controlTop := self.grpToDo.top + self.grpToDo.clientHeight + Spacing;
	endif;
	if self.grpRemarks.visible then
		self.grpRemarks.top := controlTop;
		controlTop := self.grpRemarks.top + self.grpRemarks.clientHeight + Spacing;
	endif;
	
	if self.grpGrade.visible then
		self.grpGrade.top := controlTop;
		controlTop := self.grpGrade.top + self.grpGrade.clientHeight + Spacing;
	endif;
	
	if self.grpWeight.visible then
		self.grpWeight.top := controlTop;
		controlTop := self.grpWeight.top + self.grpWeight.clientHeight + Spacing;
		self.txtRef.case := TextBox.Case_Upper; //epr TFS 2129
		self.lblRef.caption := app.getErrorString(Weight_certified_reference);		// TFS #1699

	endif;
	
	self.grpDetails.top := controlTop;
	controlTop := self.grpDetails.top + self.grpDetails.clientHeight + Spacing;
	
	self.grpEmail.top := controlTop;
	controlTop := self.grpEmail.top + self.grpEmail.clientHeight + Spacing;
	
	buttonOffset := self.height - self.btnCancel.top;
	
	self.height := controlTop + buttonOffset;
	self.minimumHeight := self.height.Integer;
	self.minimumWidth := 800;
	

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="e9f34c66-83b7-482b-9837-eea4e0f1ef68">
        <source>doSave(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	addresses : CM_StringArray;
	load : Boolean;
	cmifEventReq : CMIF_EventRequestController;
	currentRequestPxy : CM_EventRequestStops;

begin

	create addresses transient;
	self.getEmailAddresses(addresses);
	
	currentRequestPxy := self.myCurrentEventRequest;
	
	if self.grpToDo.visible then
		self.doSaveToDo(null,addresses,cmifEventReq,currentRequestPxy);
	elseif self.grpRemarks.visible then
		self.doSaveRemarks(null,addresses,cmifEventReq,currentRequestPxy);
	elseif self.grpGrade.visible then
		self.doSaveGrade(null,addresses,cmifEventReq,currentRequestPxy);
	elseif self.grpWeight.visible then
		self.doSaveWeightCertified(null,addresses,cmifEventReq,currentRequestPxy);
	else
		return false;
	endif;
	
	if  not app.myPassport.trxCompletedOK then
		app.showErrorWarningDialog('Stops Update Request', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		return false;
	endif;
	
	return true;

epilog

	delete addresses;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveGrade" id="cf503c5c-2345-44e9-9c69-84d9fc281324">
        <source>doSaveGrade(_cargoId: String; _addresses: CM_StringArray; _cmifEventReq: CMIF_EventRequestController input; _currentRequestPxy: CM_EventRequestStops) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	grade : CM_MTGrade;
	pxyRequestStops : CM_EventRequestStops;
	
begin

	grade := self.cmbGrade.listObject.CM_MTGrade;
	if grade = null then
		app.raiseCMException(Input_required_field_grade,null,null);
	endif;
	
	if _currentRequestPxy &lt;&gt; null then
		pxyRequestStops := _currentRequestPxy;
	else
		create pxyRequestStops as CM_EventRequestForStop transient;
	endif;
	
	pxyRequestStops.setProxyRequestStops(	EventRequestTypeGrade,
											_addresses,
											null,
											null,
											null,
											null,
											null,
											null,
											EventRequestPending,
											false,
											self.chkNotify.value,												
											null,
											false,
											null,
											null,
											null,
											pxyRequestStops.isEDI,
											null,
											grade,
											null,
											null,	//_custAgent : CM_CustomsAgent 
											null,	//_toDoRemarks		: String
											null,	//_tiBOL	
											null,	//_clearCustAgent		
											null,   
											null,   
											null); 
											
	if pxyRequestStops.CM_EventRequestForStop.myStopTableTemplate = null then
		pxyRequestStops.CM_EventRequestForStop.setMyStopTemplate( self.myProxyStopTableTemplate );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_cmifEventReq" type="CMIF_EventRequestController" usage="input"/>
        <Parameter name="_currentRequestPxy" type="CM_EventRequestStops"/>
    </JadeMethod>
    <JadeMethod name="doSaveRemarks" id="682168b8-4f8d-4837-895f-c7ca47952651">
        <source>doSaveRemarks(_cargoId: String; _addresses: CM_StringArray; _cmifEventReq: CMIF_EventRequestController input; _currentRequestPxy: CM_EventRequestStops) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	pxyRequestStops : CM_EventRequestStops;
	
begin

	if self.txtRemarks.text.trimBlanks = null then
		app.raiseCMException(Input_required_remarks,null,null);
	endif;
	
	if _currentRequestPxy &lt;&gt; null then
		pxyRequestStops := _currentRequestPxy;
	else
		create pxyRequestStops as CM_EventRequestForStop transient;
	endif;
	
	pxyRequestStops.setProxyRequestStops(	EventRequestTypeRemarks,
											_addresses,
											self.txtTrxRemarks.text,
											null,
											null,
											null,
											null,
											null,
											EventRequestPending,
											false,
											self.chkNotify.value,												
											null,
											false,
											null,
											null,
											null,
											pxyRequestStops.isEDI,
											null,
											null,
											self.txtRemarks.text.trimBlanks,
											null,	//_custAgent : CM_CustomsAgent 
											null,	//_toDoRemarks		: String
											null,	//_tiBOL	
											null,	//_clearCustAgent		
											null,   
											null,   
											null); 
											
	if pxyRequestStops.CM_EventRequestForStop.myStopTableTemplate = null then
		pxyRequestStops.CM_EventRequestForStop.setMyStopTemplate( self.myProxyStopTableTemplate );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
