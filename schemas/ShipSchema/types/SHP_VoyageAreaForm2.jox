    <JadeMethod name="doPlanningGetNextPointInSeq" id="00b6f67f-a12d-4e14-ab7a-aff3cee493d9">
        <updating/>
        <source>doPlanningGetNextPointInSeq(_theLocationController : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is fired off by a notification after a TI is planned to the yard
//				In here we must work out the next TI in sequence and then select that point as if the user had just done so
//				We only do this in planning mode and if there is only one point selected
// ---------------------------------------------------------------------------

vars
	theSlotController, 
	nextSlotController : CM_SlotController;
	theSlotRequest, 
	nextSlotRequest 	: CM_SlotRequest;
	theJob : CM_Job;
	theNextOne : Boolean;
	currentSeqNum, 
	nextSeqNum : Integer;
begin

	if self.workingMode &lt;&gt; WorkMode_Plan then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid working mode (' &amp; self.workingMode.String &amp; ')');
		return;
	endif;
	
	if (not _theLocationController.isKindOf(CM_SlotController)) then	
		return;
	endif;
	theSlotController := _theLocationController.CM_SlotController;

	if theSlotController.myBayVoyage.myCellularVoyageStructure.myVoyage &lt;&gt; self.myCurrentVoyage then
		return;
	endif;

	// this is the last point, de select and redraw		
	self.doClearAllSelectedPoints();
	self.myBayDrawingController.drawObject(null, theSlotController);

	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		theSlotRequest := theSlotController.mySlotRequestDischarge;

	elseif self.displayMode = ShpDisplayMode_ColCodeLoad then
		theSlotRequest := theSlotController.mySlotRequestLoad;
	else
		return;
	endif;	
	
	if theSlotRequest = null then
		return;
	endif;

	// We do not do the auto seq number thing for linked slot requests.  The reason 
	// is that when the discharge planning is complete a notification fires off this method. 
	// Lower down in this code the app.myMoveController is deleted and re created, however 
	// after the discharge planning is complete the code uses the same app.movecontroller 
	// and simple reverses the source and target location for the auto load.  You get an 
	// error  because the auto load future move controller has been deleted by this method 
	// from the notification

	// this has been erased - nulled
	if theSlotRequest.moveType = NULL_MOVETYPE then
		return;
	endif;
	if theSlotRequest.myJob = null  // PAR 8229
	or not global.isValidObject(theSlotRequest.myJob) then // PAR 8229
		delete app.myMoveController; // PAR 8229
		return; // PAR 8229
	endif; // PAR 8229
	
	nextSlotRequest := theSlotRequest.myJob.CM_VoyageJob.doPlanningGetNextPointInSeq(theSlotRequest);

	if nextSlotRequest = null then
		delete app.myMoveController;
		return;
	endif;
	
	theSlotController := nextSlotRequest.mySlotController;
	// we are doing planning of discharges for TIs, if there is no Ti then forget it!
	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		if theSlotController.allTrackedItems.isEmpty then
			return;
		endif;		
	endif;
	
	// have to send false for _redraw here as we do not know
	// what the frame is
	self.myBayDrawingController.selectObject(theSlotController, null, false); 
	self.myBayDrawingController.drawObject(null, theSlotController);
	self.doGridAreaMouseUpStatusLine(theSlotController);
	self.showExtraInfo(theSlotController);

	self.handleBayMouseDownEventPlan(self.myBayDrawingController, theSlotController,null);

end;</source>
        <Parameter name="_theLocationController" type="CM_LocationsController"/>
    </JadeMethod>
