    <JadeMethod name="setDirectExcessIfReqd" id="b4242a46-e53f-4316-a044-9bb725f7a9c7">
        <updating/>
        <source>setDirectExcessIfReqd(_prenote, _onsite : CM_TrackedItem; _voyageWLE : CM_VoyageWLE) updating;
//
// Purpose:			Check to see if this move is for more than the original planned amount
//					Planned amount will be on a prenote WLE, or if no prenote, on the onsite ti
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 	10/11/2021	navdap1		Initial creation TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
//
vars
	wleSet : CM_WLESet;
	prenoteWLE : CM_WorkListEntry;
	checkAmount : Integer;

begin
	if _prenote &lt;&gt; null then
		wleSet := _prenote.allWorklistEntries;
	elseif _onsite.wasPrenotified then
		wleSet := _onsite.allWorklistEntries;
	endif;
	if wleSet &lt;&gt; null then
		// can we find a prenoted wle for the same target location?
		foreach prenoteWLE in wleSet where prenoteWLE.status &lt;&gt; WLE_COMPLETED and prenoteWLE.locationTarget = _voyageWLE.locationTarget do 
			if _voyageWLE.subSeqNum &lt;&gt; null and _prenote = null then
				checkAmount := _voyageWLE.subSeqNum;
			else
				if _onsite.isBulkByQuantity then
					checkAmount := prenoteWLE.quantity;
				else
					checkAmount := prenoteWLE.weight.Integer;
				endif;
			endif;
			if _onsite.isBulkByQuantity and self.quantity &gt; checkAmount then
				self.directExcessQuantity := self.quantity - checkAmount;
			elseif (_onsite.isBulkByWeight or _onsite.isBulkByVolume) and self.weight &gt; checkAmount then
				self.directExcessWeight := self.weight - checkAmount;
			endif;
			break;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_prenote" type="CM_TrackedItem"/>
        <Parameter name="_onsite" type="CM_TrackedItem"/>
        <Parameter name="_voyageWLE" type="CM_VoyageWLE"/>
    </JadeMethod>
