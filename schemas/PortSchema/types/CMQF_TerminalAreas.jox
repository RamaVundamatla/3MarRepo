    <JadeMethod name="includesObject" id="19939701-ffca-4614-b52e-7d817169393e">
        <updating/>
        <source>includesObject(_obj: CM_Object; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	queryTA 			: CMQF_TerminalAreas;
begin
	queryTA := self;
	queryTA.numSearched := queryTA.numSearched + 1;
	
	self.numFound := self.numFound + 1;
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
