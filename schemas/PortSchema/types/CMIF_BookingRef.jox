    <JadeMethod name="checkForHazardOnBookingRefItem" id="f3d41e0f-0109-43e9-ba4c-57d329058792">
        <source>checkForHazardOnBookingRefItem(_tiHazard : CM_TIHazard; _bookingRefitem : CMIF_BookingRefItem output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2008	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	cmifBookingRefItem : CMIF_BookingRefItem;
begin
	
	iter:=self.allCMIF_BRItems.createIterator;
	while iter.next(cmifBookingRefItem) do
		if cmifBookingRefItem.allTIHazards[_tiHazard.code] &lt;&gt; null then
			_bookingRefitem:=cmifBookingRefItem;
			return true;
		endif;
	endwhile;
	
	return false;
epilog
	delete iter;
end;</source>
        <Parameter name="_tiHazard" type="CM_TIHazard"/>
        <Parameter name="_bookingRefitem" type="CMIF_BookingRefItem" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearInvalidBRefItems" id="6522380d-f284-4cd0-ab66-bcb0fd1e15f9">
        <source>clearInvalidBRefItems();

// dh 3/9/2008 - this method should nonly be used when aborting from a 'create' transaction.
//				It prevents invalid ORs on the myRealBookingRef and myRealBookingRefItem references when aborting a create.

vars
	cmifItem : CMIF_BookingRefItem;
begin
	
	foreach cmifItem in self.allCMIF_BRItems do
		cmifItem.setMyRealBookingRefItem(null);
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="createInterfaceItem" id="05fdb798-ecd2-42bd-8d23-4ef35af3cf1e">
        <source>createInterfaceItem(_brItem : CM_BookingRefItem; _ediBookRefTI : CM_EDIBookingRefTI): CMIF_BookingRefItem;
/*
	Created on 19 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmif_BRItem : CMIF_BookingRefItem;
begin
	create cmif_BRItem transient;
	
	if _brItem &lt;&gt; null then
		cmif_BRItem.setFromBookingRefItem(_brItem);
		
	elseif _ediBookRefTI &lt;&gt; null then
		cmif_BRItem.setFromEDI(_ediBookRefTI);
		
	endif;
	
	allCMIF_BRItems.add(cmif_BRItem);
	return cmif_BRItem;
end;</source>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <Parameter name="_ediBookRefTI" type="CM_EDIBookingRefTI"/>
        <ReturnType type="CMIF_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="createInterfaceItemFromEDIBook" id="4cf806f9-3278-4d0b-8fa6-4438618dea5c">
        <updating/>
        <source>createInterfaceItemFromEDIBook(_cmif_BookingRefItem : CMIF_BookingRefItem io; _ediBookingItemTI : CM_EDIBookingItemTI) updating;
///
// cnwrs1 par21718 Dec 2009
//
vars
//	cmif_BookingRefItem : CMIF_BookingRefItem; //cnwrs1 CCMS 1882 25 May 2010
	bookingRefSet		: CM_BookingRefSet;				// cnwrl1 16/04/2010 PAR 23624
	
begin
//	create cmif_BookingRefItem transient;
	
	if _ediBookingItemTI &lt;&gt; null then
		_cmif_BookingRefItem.setFromEDIBooking(_ediBookingItemTI);
	endif;
	
	self.allCMIF_BRItems.add(_cmif_BookingRefItem);
	//Create hazards to add to the CMIF_Booking also.
	self.setHazardsFromEDIBkingRefItems(_cmif_BookingRefItem.allTIHazards);  //PAR22880 - cnwsh3 Get Hazard info from EDI
	
	// cnwrl1 16/04/2010 PAR 23624 - start of coding
	if _ediBookingItemTI &lt;&gt; null then
		// this has to be done after the allCMIF_BRItems collection is populated above.
		create bookingRefSet transient;
		_ediBookingItemTI.addLinkedBookings(_cmif_BookingRefItem, bookingRefSet);
		_cmif_BookingRefItem.allLinkedExportBookingsRefs.clear;
		bookingRefSet.copy(_cmif_BookingRefItem.allLinkedExportBookingsRefs);
	endif;
	// cnwrl1 16/04/2010 PAR 23624 - end of coding
//	return cmif_BookingRefItem;
epilog
	delete bookingRefSet;							// cnwrl1 16/04/2010 PAR 23624
end;
</source>
        <Parameter name="_cmif_BookingRefItem" type="CMIF_BookingRefItem" usage="io"/>
        <Parameter name="_ediBookingItemTI" type="CM_EDIBookingItemTI"/>
    </JadeMethod>
    <JadeMethod name="createReleaseProxyFromEDI" id="8f799aa7-ad55-47a7-99d2-06f23fe6b8e0">
        <source>createReleaseProxyFromEDI(_ediTI : CM_EDIBookingRefTI; _terminalObj:CM_Terminal):CM_BulkRelease;
// --------------------------------------------------------------------------------
// Created:		15 April 2008 by cnwdad1
//
// Purpose:		Instantiates a proxy Bulk Release object, based upon the data provided
//				by the receiver, and returns a reference to the proxy object.
//
// Parameters:	_cmifBookRefObj - A reference to the CMIF Booking Reference object.
//				_terminalObj - A reference to the Terminal to which the Bulk Release belongs.
//
// Returns:		A reference to a proxy Bulk Release object, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 29/8/2008 	debby		moved this method from the editi object to here, so can reuse for non-edi situations
// --------------------------------------------------------------------------------


vars
	breleaseObj		: CM_BulkRelease;
	passportObj		: CM_Passport;
//	iteratorObj		: Iterator;
//	isFound			: Boolean;
	bookingOpCode	: String;
	releaseOpCode	: String;
//	dateTime        : TimeStamp;
begin
	if _ediTI.releaseRequestNumber = null then
		return null;
	else
		self.createRequestProxies(breleaseObj);
		if _ediTI &lt;&gt; null then
			breleaseObj.setFromEDIBookingRefTI(_ediTI);
		endif;
		return breleaseObj;
	endif;
end;
</source>
        <Parameter name="_ediTI" type="CM_EDIBookingRefTI"/>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="createReleaseProxyFromEDIBook" id="b3de82a3-1d4c-4fa3-b86d-ca55bbc31b65">
        <source>createReleaseProxyFromEDIBook(_releaseRequestNumber : String; _subTerminalCode : String; _cmifBookingRef : CMIF_BookingRef; _terminalObj:CM_Terminal) : CM_BulkRelease;
//
// Par21718 cnwrs1 dec 2009
//
vars
	breleaseObj	: CM_BulkRelease;
	passportObj	: CM_Passport;
	bookingOpCode : String;
	releaseOpCode : String;
begin
	if _releaseRequestNumber = null then
		return null;
	else
		self.createRequestProxies(breleaseObj);
		if _cmifBookingRef &lt;&gt; null then
			breleaseObj.setFromCMIFBookRef(_cmifBookingRef);
			breleaseObj.setCode(_releaseRequestNumber);
			breleaseObj.setSubTerminal(app.myRoot.allSubTerminals[_subTerminalCode]);
		endif;
		return breleaseObj;
	endif;
end;
</source>
        <Parameter name="_releaseRequestNumber" type="String"/>
        <Parameter name="_subTerminalCode" type="String"/>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef"/>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="createRequestProxies" id="433c6ed6-9360-4dcb-b8f0-8a492533ba83">
        <source>createRequestProxies(_breleaseObj:CM_BulkRelease io);
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 23/04/2012	cnwdap1		PAR #29475 CCMS PNL 2155 Create parent packing lines as well
// 25/09/2012	cnwcs5		par 30390 - change of signature for setParentPackingLineFromCMIF
vars
	refItemObj		: CMIF_BookingRefItem;
	reserveObj		: CM_ReserveDetail;
	packingParent	: CM_ReserveSelection;	// PAR #29475
	idx				: Integer;				// PAR #29475
	isoType			: String;				// PAR #29475
	nbr				: Integer;				// PAR #29475
begin
	if _breleaseObj = null then
		create _breleaseObj transient;
	endif;
	_breleaseObj.allReserveDetails.purge;
	foreach refItemObj in self.allCMIF_BRItems do
		
		create reserveObj as CM_ReserveSelection transient;
		reserveObj.setFrom_CMIF_BookingRefItem(refItemObj, _breleaseObj);
		_breleaseObj.allReserveDetails.add(reserveObj);
		refItemObj.setReserveDetail(reserveObj);
		
		
	endforeach;
	
	// PAR #29475 start
	foreach idx in 1 to self.containerTypes.size do
		isoType := self.containerTypes[idx];
		nbr 	:= self.containerNbrs[idx];
		if isoType = null then
			continue;
		endif;
		
		create packingParent transient;
		packingParent.setParentPackingLineFromCMIF(isoType, nbr);	// par 30390 Sept 2012
		_breleaseObj.allReserveDetails.add(packingParent);
	endforeach;
	// PAR #29475 end
end;
</source>
        <Parameter name="_breleaseObj" type="CM_BulkRelease" usage="io"/>
    </JadeMethod>
    <JadeMethod name="delete" id="43ac4bb6-32e6-4906-a0da-959df00fa181">
        <updating/>
        <source>delete() updating;
/*
	Created on 11 February 2008
	
	by Debby Hutchison
	
	Purpose:
	


Date		Who		Reason
10 Jul 2008	cnwkpd1	PAR #17486 - Rework tidy up of transients from GTE_BookingRefMultiForm

*/

vars

begin
	self.allCMIF_BRItems.purge();
	self.allTIHazards.purge;
	if app.isValidObject(self.myProxyBookingRef) then	// PAR #17486 - OK because it's transient
		delete self.myProxyBookingRef;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAllItemTIHazards" id="23b8d60f-7264-44f9-abe0-2a24122a2d0f">
        <source>getAllItemTIHazards(dict: CM_HazardByCodeDict io; cmifBrItem : CMIF_BookingRefItem; allTIHazards :ObjectArray );
//-----------------------------------------
//
// Created : by cnwaer1 04 September 2008
//-----------------------------------------
vars
	haz 	: Object;
	tiHaz	: CM_TIHazard;
	hazard : CM_Hazard;
	undgString : String;
	limitQ  : Boolean;
begin
// set the hazards from the Booking Ref Hazard List

	foreach haz in allTIHazards do
		if dict[haz.CM_Hazard.code] = null then
			dict.add(haz.CM_Hazard);
		endif;
	endforeach;
// set the Hazards from the booking Item that was opened for add/edit
	if cmifBrItem &lt;&gt; null then
		foreach hazard in cmifBrItem.allTIHazards do
			if dict[hazard.code] = null then
				dict.add(hazard);
			else
				tiHaz := dict[hazard.code].CM_TIHazard;
				if hazard.CM_TIHazard.getUndgCodesAsString(false) &lt;&gt; null //25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
				and not tiHaz.allUNDGCodes.includes(hazard.CM_TIHazard.getUndgCodesAsString(false)) then	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
					undgString:= tiHaz.allUNDGCodes.asCSV(false) &amp;','&amp; hazard.CM_TIHazard.allUNDGCodes.asCSV(false);
					tiHaz.setUNDGCodes(undgString);
				endif;
				limitQ := tiHaz.limitedQuantity and hazard.CM_TIHazard.limitedQuantity;
				tiHaz.setLimitedQuantity(limitQ);
			endif;
		endforeach;
	endif;
	
	
end;</source>
        <Parameter name="dict" type="CM_HazardByCodeDict" usage="io"/>
        <Parameter name="cmifBrItem" type="CMIF_BookingRefItem"/>
        <Parameter name="allTIHazards" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefItemForTI" id="98971028-4498-4835-9480-f929f0cafd95">
        <source>getBookingRefItemForTI( _ti : CM_TrackedItem ) : CMIF_BookingRefItem;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	cmifBRefItem : CMIF_BookingRefItem;
	realItem : CM_BookingRefItem;

begin

	if _ti = null then
		return null;
	endif;

	foreach cmifBRefItem in allCMIF_BRItems do
		realItem := cmifBRefItem.myRealBookingRefItem;
		if realItem &lt;&gt; null then
			if realItem.allTIs.includes(_ti) then
				return cmifBRefItem;
			endif;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CMIF_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="getCMIFBRItemWithISOType" id="35e855d0-1eb4-4c41-8839-5fb631c3ec54">
        <source>getCMIFBRItemWithISOType(_isoType : String) :CMIF_BookingRefItem;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwer1	Initial creation

*/

vars
	 cmifBRItem : CMIF_BookingRefItem;	
begin
	foreach cmifBRItem in self.allCMIF_BRItems do
		if cmifBRItem.isoType = _isoType then
			return  cmifBRItem;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_isoType" type="String"/>
        <ReturnType type="CMIF_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="getDiscrepValueFor" id="b4e1768d-7266-49ae-804f-a98cc5dbc378">
        <source>getDiscrepValueFor( _heading : String ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	name : String;
	bookingRef : CM_BookingRef;
	
begin

	if self.myProxyBookingRef = null then
		return null;
	endif;
	
	bookingRef := self.myProxyBookingRef;

	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	entTableRow := entTableDef.getEntTableRowByHeading(_heading);
	if entTableRow &lt;&gt; null then
		name := entTableRow.name;
	endif;
	
	if ( name = ETRow_CargoType
	or name = ETRow_Commodity
	or name = ETRow_Consignee
	or name = ETRow_Consignor
	or name = ETRow_Destination
	or name = ETRow_DischargePort
	or name = ETRow_Hazardous
	or name = ETRow_Humidity
	or name = ETRow_Ventilation
	or name = ETRow_Voyage
	) then
		return bookingRef.getDisplayStringForAttribute(name, false);
		
	elseif name = ETRow_CarriageTemperature then
		return bookingRef.getDisplayStringForAttribute(ETRow_Temperature, false);
			
	elseif name = ETRow_ContAtmosAndCurtainsIn then
		return bookingRef.getDisplayStringForAttribute(ETRow_CurtainsIn, false);

	elseif name = ETRow_ISOType then
		return bookingRef.getDisplayStringForAttribute(ETRow_IsoType, false);
		
	elseif name = ETRow_BookingRef or name = ETRow_BookingReference then
		return bookingRef.getDisplayStringForAttribute(ETRow_BookingRef, false);
	
	elseif name = ETRow_IsStock or name = ETRow_IsStockBookingReference then
		return bookingRef.getDisplayStringForAttribute(ETRow_IsStockBookingRef, false);
	
	elseif name = ETRow_Operator then
		return bookingRef.getDisplayStringForAttribute(ETRow_OperatorCode, false);
	
	else		//26 Mar 2010	NDL Par 23433
		return null;
	
	endif; 
	
	
epilog

end;</source>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIAction" id="05301e08-d39b-411b-9d61-dd55bc9f794c">
        <source>getEDIAction() : String;
/* ---------------------------------------------------------------------------
Created:	14 January 2009	by cnwvu1

Purpose:	Return possible EDI action:
				'BGM+126+232818800+1' - 1 means DELETE
				'BGM+126+232818800+5' - 5 means UDPATE
				'BGM+126+232818800+9' - 9 means ADD

   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	ediTI	: CM_EDIBookingRefTI;
begin
	if self.allEDIBookingRefTIs.size  = 0 then
		return self.action; //par21718 cnwrs1 Dec 2009
	endif;
	// actually, for multi booking ref all allEDIBookingRefTIs should have the same EDI action
	return self.allEDIBookingRefTIs.first.messageMode;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIVoyageAndOperator" id="d0772721-75fc-42bc-ac8d-be9ffd7fcca9">
        <source>getEDIVoyageAndOperator( _ediVoyCode, _ediOpCode : String output; _terminal : CM_Terminal );
/* ---------------------------------------------------------------------------
Created:	19 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	ediTI : CM_EDITrackedItem;	//cnwrs1 par 26800 14 Jan 2011
begin
//	_ediVoyCode	:=	self.allEDIBookingRefTIs.first.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	ediTI := self.allEDIBookingRefTIs.first;
	_ediVoyCode	:= ediTI.getVoyageCode();
	_ediOpCode	:= ediTI.getOperatorCode();	//cnwrs1 26800 14 jan 2011
	
	if _ediVoyCode &lt;&gt; null
	and _terminal.lookupVoyage(_ediVoyCode.String, null, false) = null
	then
		_ediVoyCode	:=	null;
	endif;
	
	if _ediOpCode &lt;&gt; null
	and app.myRoot.allOperators[_ediOpCode] = null
	then
		_ediOpCode	:=	null;
	endif;


end;</source>
        <Parameter name="_ediVoyCode" type="String" usage="output"/>
        <Parameter name="_ediOpCode" type="String" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getInterfaceItem" id="460f34ea-58c1-4cf2-ab7d-b6f0fddd276c">
        <source>getInterfaceItem(_brItem : CM_BookingRefItem):CMIF_BookingRefItem;
/*
	Created on 07 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	brItemInterface : CMIF_BookingRefItem;
	
begin
	brItemInterface := self.allCMIF_BRItems.getAtKey(_brItem);
	
	if brItemInterface = null then
		brItemInterface := self.createInterfaceItem(_brItem, null);
	endif;
	
	return brItemInterface;
end;</source>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <ReturnType type="CMIF_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="load" id="358ab532-96fe-4742-b24b-4eee44263e15">
        <source>load (bookingRef : CM_BookingRef);
/*
	Created on 14 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	brItem 		: CM_BookingRefItem;
	cmifBrItem 	: CMIF_BookingRefItem;
	cargoType 	: CM_CargoType;
	viewName 	: String;
begin
	self.allCMIF_BRItems.purge;
	foreach brItem in bookingRef.allBookingRefItems do		
		viewName := brItem.getViewName;
		cmifBrItem := createInterfaceItem(brItem, null);  // build it
		cmifBrItem.setViewName(viewName);
	endforeach;
end;</source>
        <Parameter name="bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="loadCMIFItemsFromEDILines" id="74528527-8b01-4837-8d34-73ee7a02450d">
        <source>loadCMIFItemsFromEDILines(_currentEDIBookingRefTI : CM_EDIBookingRefTI);
/*
	Created on 04 March 2008
	
	by Debby Hutchison
	
	Purpose: // creating a new Booking ref from the edi lines from a file
*/

vars
	ediBookingRefTI		: CM_EDIBookingRefTI;
	ediTI : CM_EDITrackedItem;	//cnwrs1 par 26800 14 Jan 2011
begin

	if _currentEDIBookingRefTI = null then	// Normal EDI loading mode (for example, User defined EDI Booking Ref)
		foreach ediTI in self.allEDIBookingRefTIs do
			if ediTI.isKindOf(CM_EDIBookingRefTI) then
				ediBookingRefTI := ediTI.CM_EDIBookingRefTI;	//cnwrs1 par 26800 14 Jan 2011
				self.createInterfaceItem(null, ediBookingRefTI);
			endif;
		endforeach;
		
	else	// EDI action loading mode
		self.createInterfaceItem(null, _currentEDIBookingRefTI);	//Par18495 Jan 2009
		
	endif;
	
end;</source>
        <Parameter name="_currentEDIBookingRefTI" type="CM_EDIBookingRefTI"/>
    </JadeMethod>
    <JadeMethod name="matchEDIBookingRefItem" id="c986391a-c7c9-4844-83b6-4113cd6dc79f">
        <source>matchEDIBookingRefItem(_cmifItem : CMIF_BookingRefItem io; _allMatchedBRItems : CM_BookingRefItemDict io);
//
//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
//02 May 2019	jlgzm1		TFS 43425 SNO Append new bookings rather than replace
//
vars
	brItem : CM_BookingRefItem;
begin
	if self.myRealBookingRef = null then
		return;
	endif;
	if self.myRealBookingRef.isSequenced() then //cnwrs1 CCMS 1882 25 May 2010
		foreach brItem in self.myRealBookingRef.allBookingRefItems do
			if brItem.sequence = _cmifItem.sequence then
			/*if brItem.sequence = _cmifItem.sequence and 
				 brItem.myBookingReference.bookingReference = _cmifItem.myCMIF_BookingRef.myProxyBookingRef.bookingReference then*/
				_cmifItem.setMyRealBookingRefItem(brItem);
			endif;
		endforeach;
	else
		// first pass - try for an exactMatch
		foreach brItem in self.myRealBookingRef.allBookingRefItems do
			if _allMatchedBRItems.includes(brItem) then
				if self.appendBookings then									// TFS 43425
					//doesnt matter that we've already matched with it		// TFS 43425
					if _cmifItem.matchesRealBRItem(brItem, true) then		// TFS 43425
						_cmifItem.setMyRealBookingRefItem(brItem);			// TFS 43425
						break;												// TFS 43425
					endif;													// TFS 43425
				endif;														// TFS 43425
				continue;
			endif;
			
			// this is an exact match (parameter is 'true')
			if _cmifItem.matchesRealBRItem(brItem, true) then
				_cmifItem.setMyRealBookingRefItem(brItem);
				_allMatchedBRItems.add(brItem);
				break;
			endif;
		endforeach;
		
		// second try - if the real item has been changed by the user, a close match sill do
		foreach brItem in self.myRealBookingRef.allBookingRefItems do
			if not brItem.isDataChanged then // can only do a less exact match if user has changed it.
				continue;
			endif;
			
			if _allMatchedBRItems.includes(brItem) then // already matched
				continue;
			endif;
			// this is a less exact match (parameter is 'false')
			if _cmifItem.matchesRealBRItem(brItem, false) then
				_cmifItem.setMyRealBookingRefItem(brItem);
				_allMatchedBRItems.add(brItem);
				break;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_cmifItem" type="CMIF_BookingRefItem" usage="io"/>
        <Parameter name="_allMatchedBRItems" type="CM_BookingRefItemDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="matchEDIBookingRefItems" id="2421ff76-c6f3-496b-95b7-b08404b67fae">
        <source>matchEDIBookingRefItems(_allMatchedBRItems : CM_BookingRefItemDict io);
/*
	Created on 05 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/
//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
vars
	cmifItem 			: CMIF_BookingRefItem;
	brItem 				: CM_BookingRefItem;
begin
	if self.myRealBookingRef = null then
		return;
	endif;
	
	if self.myRealBookingRef.isSequenced() then //cnwrs1 CCMS 1882 25 May 2010
		foreach cmifItem in self.allCMIF_BRItems do
			foreach brItem in self.myRealBookingRef.allBookingRefItems do
				if brItem.sequence = cmifItem.sequence then
					cmifItem.setMyRealBookingRefItem(brItem);
				endif;
			endforeach;
		endforeach;
	else
		// first pass - try for an exactMatch
		foreach cmifItem in self.allCMIF_BRItems do
			foreach brItem in self.myRealBookingRef.allBookingRefItems do
				if _allMatchedBRItems.includes(brItem) then
					continue;
				endif;
				
				// this is an exact match (parameter is 'true')
				if cmifItem.matchesRealBRItem(brItem, true) then
					cmifItem.setMyRealBookingRefItem(brItem);
					_allMatchedBRItems.add(brItem);
				endif;
			endforeach;
		endforeach;
		
		// second try - if the real item has been changed by the user, a close match sill do
		foreach cmifItem in self.allCMIF_BRItems do
			if cmifItem.myRealBookingRefItem &lt;&gt; null then // already matched
				continue;
			endif;
			
			foreach brItem in self.myRealBookingRef.allBookingRefItems do
				if not brItem.isDataChanged then // can only do a less exact match if user has changed it.
					continue;
				endif;
				
				if _allMatchedBRItems.includes(brItem) then // already matched
					continue;
				endif;
				// this is a less exact match (parameter is 'false')
				if cmifItem.matchesRealBRItem(brItem, false) then
					cmifItem.setMyRealBookingRefItem(brItem);
					_allMatchedBRItems.add(brItem);
				endif;
			endforeach;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_allMatchedBRItems" type="CM_BookingRefItemDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processCMIFItemsFromEDIBooking" id="19e1cfaf-5056-4731-a67a-7576c50336b1">
        <updating/>
        <source>processCMIFItemsFromEDIBooking(_ediBookingItemTI : CM_EDIBookingItemTI; _allMatchedBRItems : CM_BookingRefItemDict io) :CMIF_BookingRefItem updating;
//
// par21718 cnwrs1 dec 2009
//
// 14/07/2011	cnwcs5	par 26557 - change to return cmif_BookingRefItem
//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
vars

	cmif_BookingRefItem : CMIF_BookingRefItem; //cnwrs1 CCMS 1882 25 May 2010
begin
	create cmif_BookingRefItem transient;

	self.createInterfaceItemFromEDIBook(cmif_BookingRefItem, _ediBookingItemTI);
	
	// and attempt to match each detail with a br item on the real object
	if self.myRealBookingRef &lt;&gt; null then
		self.matchEDIBookingRefItem(cmif_BookingRefItem, _allMatchedBRItems);	//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
	endif;

	return cmif_BookingRefItem;
end;</source>
        <Parameter name="_ediBookingItemTI" type="CM_EDIBookingItemTI"/>
        <Parameter name="_allMatchedBRItems" type="CM_BookingRefItemDict" usage="io"/>
        <ReturnType type="CMIF_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="processCMIFItemsFromEDILines" id="9a617dfc-0bd4-4ce7-b43c-c03a55ae42a7">
        <source>processCMIFItemsFromEDILines(_currentEDIBookingRefTI : CM_EDIBookingRefTI; _allMatchedBRItems : CM_BookingRefItemDict io);
/* ---------------------------------------------------------------------------
Created:	29 January 2009	by cnwvu1

Purpose:	

Parameters:	_currentEDIBookingRefTI = null	for EDI normal loading mode
			_currentEDIBookingRefTI &lt;&gt; null	for EDI Action loading mode
   
------------------------------------------------------------------------------*/
//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
vars

begin

	self.loadCMIFItemsFromEDILines(_currentEDIBookingRefTI);
	
	// and attempt to match each detail with a br item on the real object
	if self.myRealBookingRef &lt;&gt; null then
		self.matchEDIBookingRefItems(_allMatchedBRItems);	//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
	endif;
end;</source>
        <Parameter name="_currentEDIBookingRefTI" type="CM_EDIBookingRefTI"/>
        <Parameter name="_allMatchedBRItems" type="CM_BookingRefItemDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processCMIFItemsFromEDIWithSeq" id="306f95c9-ca38-485d-8792-3db197df9a10">
        <updating/>
        <source>processCMIFItemsFromEDIWithSeq(_ediBookingItemTI : CM_EDIBookingItemTI; _realBookingRef : CM_BookingRef; _singleMatch : Boolean; _allMatchedBRItems : CM_BookingRefItemDict io):CMIF_BookingRefItem updating;
//
// cnwrs1 CCMS 1882 25 May 2010
//
// we have received a booking item with a sequence. This means we have to process the booking refs by sequence.
// In the normal case we would delete all the booking items and only add/update those in the file.
// In this case they will be specifying the booking items by sequence so we have to create proxies for all
// the booking items and update/process those that are specified

// this is called for each ediBookingItemTI but returns a CMIFBookingRefItem but the CMIF_BookingRef (self) must contain all bookingrefs either from  _ediBookingItemTI or existing in the bookingref.allBRItems

// 14/07/2011	cnwcs5	par 26557 - change to return CMIF_BookingRefItem
// 02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
// 22 Oct 2013  cnwah9 par 32559 - removed disfunctioning update which created new items.
// 03 Jun 2015  cnwrs1	PAR #36289 Amended Coparn not loading changes
// 22 Sep 2016	cnwrh7	PAR#38207 (TFS2676) Booking update file has applied a booking item change to the wrong booking
vars
	realBookingItem : CM_BookingRefItem;
	cmifBookingItem,
	result			: CMIF_BookingRefItem;
	found 			: Boolean;
	isNew 			: Boolean;
	ediData : CM_EDIData;
	ediTI : CM_EDITrackedItem;
	found2 : Boolean;
begin
//write class.name&amp;'::'&amp;method.name&amp;' booking='&amp;_ediBookingItemTI.id&amp;' seq='&amp;_ediBookingItemTI.sequence;
	// look at all the booking items on the real booking ref and create proxies for them
	foreach cmifBookingItem in self.allCMIF_BRItems do
		if _ediBookingItemTI.sequence = cmifBookingItem.sequence  then
			// have already created a CMIF for this booking item
			found := true;
			break;
		endif;
	endforeach;
	if found = true then
		return cmifBookingItem;
	endif;
	ediData := _ediBookingItemTI.myEDIData;
	// look at all the booking items on the real booking ref and create proxies for them
	if _realBookingRef &lt;&gt; null then
		isNew := true  ;
		foreach realBookingItem in _realBookingRef.allBookingRefItems do
			if realBookingItem.sequence = _ediBookingItemTI.sequence then
				// update to an existing item 
					//cnwah9 Par 32559 START - Added condition to not create duplicate CMIF ITEMS.
//				if self.allCMIF_BRItems.size = _realBookingRef.allBookingRefItems.size then
//					isNew := false;
//				else
					//cnwah9 Par 32559 STOP
				create cmifBookingItem transient; 
				self.createInterfaceItemFromEDIBook(cmifBookingItem, _ediBookingItemTI);
				cmifBookingItem.setMyRealBookingRefItem(realBookingItem);
				result := cmifBookingItem;	
				isNew := false;
//					break;					// 26/05/2015 cnwma1 PAR #36289
//				endif;
			else
//				found := false;
				foreach ediTI in ediData.allEDITrackedItems do
					if ediTI.isKindOf(CM_EDIBookingItemTI) then
					//	if ediTI.CM_EDIBookingItemTI.sequence = realBookingItem.sequence then			//-cnwrh7	PAR#38207 22/09/16 
						if ediTI.CM_EDIBookingItemTI.sequence = realBookingItem.sequence and			//+cnwrh7 PAR#38207 22/09/16 Need to match booking number
							ediTI.id = realBookingItem.myBookingReference.bookingReference  then
//							found2 := true;
							found := false;
							foreach cmifBookingItem in self.allCMIF_BRItems do
								if ediTI.CM_EDIBookingItemTI.sequence = cmifBookingItem.sequence then
									found := true;
									break;
								endif;
							endforeach;//moving proxy out of loop
							if not found then //cnwrs1 CCMS 1882 25 May 2010
								create cmifBookingItem transient; 
								self.createInterfaceItemFromEDIBook(cmifBookingItem, ediTI.CM_EDIBookingItemTI);
								cmifBookingItem.setMyRealBookingRefItem(realBookingItem);
							endif;
						endif;
					endif;
				endforeach;
				found := false;
				foreach cmifBookingItem in self.allCMIF_BRItems do
					if realBookingItem.sequence = cmifBookingItem.sequence then
						found := true;
						break;
					endif;
				endforeach;//moving proxy out of loop
				if not found and not _singleMatch then //cnwrs1 CCMS 1882 25 May 2010
						// create proxy
					create cmifBookingItem transient;
					self.allCMIF_BRItems.add(cmifBookingItem); //cnwrs1 CCMS 1882 25 May 2010
					cmifBookingItem.setFromBookingRefItem(realBookingItem);
				endif;
			endif;
		endforeach;
			
		if isNew then
			found := false;
			foreach cmifBookingItem in self.allCMIF_BRItems do
				//if _ediBookingItemTI.sequence = cmifBookingItem.sequence then																										//-cnwrh7	PAR#38207 22/09/16
					if _ediBookingItemTI.sequence = cmifBookingItem.sequence and																										//+cnwrh7 PAR#38207 22/09/16 Need to match booking number
						_ediBookingItemTI.id =  cmifBookingItem.myCMIF_BookingRef.myProxyBookingRef.bookingReference then
					
					// have already created a CMIF for this booking item
					found := true;
					break;
				endif;
			endforeach;//moving proxy out of loop
			if not found then //cnwrs1 CCMS 1882 25 May 2010
				create cmifBookingItem transient;
				self.createInterfaceItemFromEDIBook(cmifBookingItem, _ediBookingItemTI);
				result := cmifBookingItem;	
			endif;
		endif;
	else
		create cmifBookingItem transient;
		self.createInterfaceItemFromEDIBook(cmifBookingItem, _ediBookingItemTI);
		result := cmifBookingItem;	
	endif;
	// and attempt to match each detail with a br item on the real object
	if self.myRealBookingRef &lt;&gt; null then
		self.matchEDIBookingRefItem(cmifBookingItem, _allMatchedBRItems);	//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
	endif;
	
	return result;
end;
</source>
        <Parameter name="_ediBookingItemTI" type="CM_EDIBookingItemTI"/>
        <Parameter name="_realBookingRef" type="CM_BookingRef"/>
        <Parameter name="_singleMatch" type="Boolean"/>
        <Parameter name="_allMatchedBRItems" type="CM_BookingRefItemDict" usage="io"/>
        <ReturnType type="CMIF_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setHazardsFromEDIBkingRefItems" id="417def4f-15cd-4e7f-ad53-22569dcda356">
        <updating/>
        <source>setHazardsFromEDIBkingRefItems(_hazards : CM_HazardByCodeDict) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		12 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 12/03/2010   cnwsh3		PAR22880
// Creates pxyHazards and adds them to allTIHazards and also
// copies them to the myPxyBookingRef.allTIHazards if the proxy exists.
//----------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
11/06/3015	cnwdap1	PAR #36421 	Changed signature for CM_TIHazard::setProxy
09/11/2016	cnwdap1	TFS 2842 	Hazardous Details Enhancements
27/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
============================================================================*/
vars
	obj 	 : Object;
	newHaz	 : CM_TIHazard;
	tiHaz	 : CM_TIHazard;
	hasProxy : Boolean;
begin
	if _hazards = null or _hazards.isEmpty then
		return;
	endif;
	
	hasProxy := self.myProxyBookingRef &lt;&gt; null;
	
	foreach obj in _hazards do
		if CM_TIHazard.hasInstance(obj) then
			tiHaz := obj.CM_TIHazard;			
			create newHaz transient;
			newHaz.setProxy(	tiHaz.code, 							// TFS 2842
								tiHaz.description, 						// TFS 2842
								tiHaz.allUNDGCodes.asCSV(false),		// TFS 2842
								null,									// TFS 2842
								tiHaz.limitedQuantity,					// TFS 2842
								tiHaz.packingGroup,						// TFS 2842
								tiHaz.flashpointTemperature,			// TFS 2842
								tiHaz.isMarinePollutant,				// TFS 2842
								tiHaz.acidsBases	);					// TFS 2842
			self.allTIHazards.add(newHaz);
			
			if hasProxy then
				if self.myProxyBookingRef.allTIHazards[newHaz.code] = null then
					self.myProxyBookingRef.allTIHazards.add(tiHaz);
				endif;
			endif;
		endif;
	endforeach;
	
epilog
end;</source>
        <Parameter name="_hazards" type="CM_HazardByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="setMyProxyBookingRef" id="a7a08f0b-a797-4567-84a8-25c31fa36422">
        <updating/>
        <source>setMyProxyBookingRef(_br : CM_BookingRef)updating;
/*
	Created on 11 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	myProxyBookingRef := _br;
end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setMyRealBookingRef" id="ecbd04cb-490a-47a5-8f9a-a4bca00de702">
        <updating/>
        <source>setMyRealBookingRef(br : CM_BookingRef) updating;
/*
	Created on 04 March 2008
	
