    <JadeMethod name="canBeReprocessedByBGP" id="62599733-6771-4bfa-933a-d7366207d02c">
        <source>canBeReprocessedByBGP(): Boolean;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
//18 Sep 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
*/
vars
	result		:Boolean;
	status		:Integer;
	purgeDate	:Date;
	createTS	:TimeStamp;
begin
	result := inheritMethod();
	
	if not result then
		status := self.status;
		
		if status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
			status = CM_EDIFile.EDI_STATUS_VERIFIED or 
	        status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			
			result := true;
		endif;
	endif;
			
	if result then
		// we may have passed the expiry for unprocessed files in which case we should not re-process it after all
		purgeDate 	:= self.getUnprocessedExpiryDate (EDIUnprocCusResExpiry);
		createTS 	:= self.createdTime;
			
		if createTS.date &lt; purgeDate then
			// we are expired - we don't want to re-process
			app.writeLog ('Cusres expired ' &amp; self.displayName &amp; ' created ' &amp; createTS.String &amp; ' purge date ' &amp; purgeDate.String, LogDEBUG);
			result := false;
		endif;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
