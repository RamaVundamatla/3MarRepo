    <JadeMethod name="assignValueSpecial" id="ee072975-f7ba-48ff-b751-1514ef5a9e3d">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	carrier : CM_Carrier;
	xlOperator : CM_Operator;
	operator : CM_Operator;
	strArray : StringArray;
	foundMatch : Boolean;
	operatorCode : String;
	carrierCode : String;
	str : String;
begin
/*	if _propName = ETRow_CargoTypes or 
	   _propName = CM_EDICarrierAccessCTTI::cargoTypes.name then
//	   _propName = CM_EDICarrierAccessCTTI::allCargoTypeIds.name then
		self.cargoTypes := _processedValue;
		if self.cargoTypes &lt;&gt; null then
			self.allCargoTypeIds.clear();
			strArray := _processedValue.getTokens();
			if strArray &lt;&gt; null and 
			   not strArray.isEmpty then
				foreach str in strArray do
					cargoType := app.myRoot.getCargoTypeForID(str.Integer);
					if cargoType = null then
						cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(str);
					endif;
					if cargoType &lt;&gt; null then 
						self.allCargoTypeIds.add(str.Integer);
					endif;
				endforeach;
	//			strArray.copy(self.allCargoTypeIds);
			endif;
		endif;
		return true;
*/
	if _propName = ETRow_OperatorCode then
		if self.myEDIData.operatorCode = null and 
		   _processedValue &lt;&gt; null then
			self.myEDIData.operatorCode := _processedValue;
			operator := app.myRoot.allOperators[_processedValue];
			if operator = null then
				operatorCode := app.myRoot.getXlationSystemOperatorCode(null, _processedValue, foundMatch);
				if not foundMatch then
					operatorCode := app.myRoot.getXlationSystemOperatorCode(_xlationOperator, _processedValue, foundMatch);
				endif;
				operator := app.myRoot.allOperators[operatorCode];
			endif;
			if operator &lt;&gt; null then
				self.myEDIData.setOperator(operator);
			endif;
		endif;
		return true;
/*	elseif _propName = ETRow_CarrierCodes then
		self.carrierCodes := _processedValue;
		if self.carrierCodes &lt;&gt; null then
			xlOperator := self.myEDIData.getXlationOperator();
			self.allCarrierCodes.clear();
			strArray := _processedValue.getTokens();
			if strArray &lt;&gt; null and 
			   not strArray.isEmpty then
				foreach str in strArray do
//					if xlOperator &lt;&gt; null then
//						carrierCode := xlOperator.getXlationSystemCode(str, XLATION_TYPE_CARRIER_BYOP, foundMatch);
//					else
//						carrierCode := str;
//					endif;
					carrier := self.getCarrier(xlOperator);
					if carrier &lt;&gt; null then 
						self.allCarrierCodes.add(carrier.code);
write class.name&amp;'::'&amp;method.name&amp;' '&amp;carrier.code;
					endif;
				endforeach;
			endif;
		endif;
		return true;*/
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
epilog
	delete strArray;
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="a49c3eba-7275-4488-af75-1e67bf92d89f">
        <source>canUserSet(_propName: String): Boolean;
//
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 12 Aug 2019	jlgpda1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars

begin
	if _propName = CM_EDITrackedItem::description.name or
	   _propName = CM_EDITrackedItem::fullOrMT.name or
	   _propName = CM_EDITrackedItem::id.name or
	   _propName = CM_EDITrackedItem::remarksAdditional1.name or
	   _propName = CM_EDITrackedItem::remarksAdditional2.name or
	   _propName = ETRow_OperatorCode then
		return false;
	elseif _propName = ETRow_CargoTypeDescr then
		return true;
		
	elseif _propName = ETRow_ISOType then				// TFS 45836
		return true;									// TFS 45836
	elseif _propName = ETRow_CargoType then				// TFS 45836
		return true;									// TFS 45836
	elseif _propName = ETRow_TrailerType then			// TFS 45836
		return true;									// TFS 45836
		
	else
		return inheritMethod(_propName);
	endif;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCarrier" id="91df2c69-b3eb-4ece-9424-9cf5b5be352d">
        <source>getCarrier(_xlationOperator : CM_Operator) : CM_Carrier;
//
// 15 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//
vars
	carrier : CM_Carrier;
	foundMatch : Boolean;
	carrierCode : String;
begin
	if _xlationOperator &lt;&gt; null then
		carrierCode := _xlationOperator.getXlationSystemCode(self.carrierCodes, XLATION_TYPE_CARRIER_BYOP, foundMatch);
	else
		carrierCode := self.carrierCodes;
	endif;
	carrier := app.myRoot.allCarriers[carrierCode];
	return carrier;
epilog

end;</source>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="getCarriers" id="8c077427-e161-4733-bf0e-a3534cc193e5">
        <updating/>
        <source>getCarriers(_xlationOperator : CM_Operator; _carriers : CM_CarrierSet io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
// 03 Feb 2025	navah1		Bug 33429: MTN - Carrier Access File doesn't work with spaces in the carrier code
vars
	carriers : StringArray;
	carrierStr, carrierCode : String;
	carrier : CM_Carrier;
	foundMatch : Boolean;
	//carrierCodeStr : String;                               // 03.02.2025 navah1 #33429

begin
	if self.carrierCodes = null then
		return;
	endif;
	
	create carriers transient;
	self.processCarrierString(self.carrierCodes,carriers);   // 03.02.2025 navah1 #33429
	/*														 // 03.02.2025 navah1 #33429
	carrierCodeStr := self.carrierCodes.replaceString(Comma, Space);
	carrierCodeStr := carrierCodeStr.replaceString("  ", Space);
	carrierCodeStr.getTokensForDelimiter(Space, carriers);
	*/
	foreach carrierStr in carriers do
		carrierStr := carrierStr.replaceString(self.Temp_Delimiter, Space);	 // 03.02.2025 navah1 #33429
		if _xlationOperator &lt;&gt; null then
			carrierCode := _xlationOperator.getXlationSystemCode(carrierStr, XLATION_TYPE_CARRIER_BYOP, foundMatch);
		else
			carrierCode := carrierStr;
		endif;
		carrier := app.myRoot.allCarriers[carrierCode];
		if carrier &lt;&gt; null then
			_carriers.add(carrier);
		endif;
	endforeach;
epilog
	delete carriers;
end;</source>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_carriers" type="CM_CarrierSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="1fea7ee2-71e5-4fb9-883f-2d2bb244aec0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
//	cargoType : CM_CargoType;
//	strReturn : String;
//	int : Integer;
begin
	if _attrName = ETRow_Action then
		return self.messageMode;
	elseif _attrName = ETRow_OperatorCode then
		return self.myEDIData.operatorCode;
/*	elseif _attrName = ETRow_AllCargoTypeIds then
		foreach int in self.allCargoTypeIds do
			cargoType := app.myRoot.getCargoTypeForID(int);
			if cargoType &lt;&gt; null then
				if strReturn = null then
					strReturn := cargoType.abbreviation;	
				else
					strReturn := strReturn&amp;" "&amp;cargoType.abbreviation;
				endif;
			endif;
		endforeach;
		return strReturn;*/
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
