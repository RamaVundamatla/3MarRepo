    <JadeMethod name="getLoadAllOverDim" id="d5b1e55e-d648-4b61-b0cf-984bfd2aac11">
        <source>getLoadAllOverDim() : Integer;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tot : Integer;
begin
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Load, 20, CM_KPIVoyageMoveDtl_Container::numOverdimension);
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Load, 30, CM_KPIVoyageMoveDtl_Container::numOverdimension);
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Load, 40, CM_KPIVoyageMoveDtl_Container::numOverdimension);
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Load, 45, CM_KPIVoyageMoveDtl_Container::numOverdimension);
	tot := tot + self.zGetTotalByMoveTypeLen(VoyageMoveType_Load, 53, CM_KPIVoyageMoveDtl_Container::numOverdimension);
	
	return tot;
epilog

end;

</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
