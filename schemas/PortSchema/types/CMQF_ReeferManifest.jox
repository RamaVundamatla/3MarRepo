<Class name="CMQF_ReeferManifest" id="de5f8b50-f873-43d4-abfa-d0f5e5c8c9b5">
    <superclass name="CMQF_Reefer"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
This is primarily a Maersk format report</text>
    <DbClassMap file="default"/>
    <JadeMethod name="filterObjects" id="04facac8-29ab-4eca-92df-742c22903ca6">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	06 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	ti			: CM_TrackedItem;
	breakOut	: Boolean;
begin
	//need a voyage
	if self.getMyVoyage &lt;&gt; null then
	
		//on the ship
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
		
		//Still on site
		foreach ti in self.getMyVoyage.allOnsiteTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
		
		// Notified
		foreach ti in self.getMyVoyage.allNotifiedTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;		
	endif;
		

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="e53642c4-9df6-4d96-94b7-f2af2afd28f3">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	06 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	isoType : CM_ISOType;
begin
	//changed by cnwyl1 for par15163
	if CM_Container.hasInstance(_ti) and 
	   _ti.CM_Container.monitorConnection and 
	   (_ti.isExport or _ti.isTranshipOutbound) and 				// PAR #21025
	   _ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE then
		isoType := _ti.CM_Container.getISOTypeObject;
		if isoType &lt;&gt; null then
			if isoType.isPowered and inheritMethod(_ti, _passport, _breakOut) then
				return true;
			endif;
		endif;
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
