    <JadeMethod name="getRowLoadoutDetails" id="fa303677-272b-4996-8bf0-3aca747f83f6">
        <source>getRowLoadoutDetails(_tiCargoType : Integer; _rowLoadoutDict : CMIF_RowLoadoutBySOHLocDict input);
// ---------------------------------------------------------------------------
// Created:     24 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars	
	tiDict				: CM_TIByCargoTypeIdDict;
	iter				: Iterator;
	ti					: CM_TrackedItem;
	log					: CM_Log;
	rowLoadout			: CMIF_RowLoadout;
begin
	
	tiDict := self.allOnshipTIsByCargoTypeId;
	iter := tiDict.createIterator;
	tiDict.startKeyGeq(_tiCargoType, null, iter);
	
	while iter.next(ti) do
		if ti.cargoType &lt;&gt; _tiCargoType then
			break;
		endif;
		log := ti.CM_Log;
		
		rowLoadout := _rowLoadoutDict[log.myLoadOutSOHLocation];
		
		if rowLoadout = null then
			create rowLoadout transient;
			rowLoadout.mySOHLocation := log.myLoadOutSOHLocation;
			_rowLoadoutDict.add(rowLoadout);
		endif;
		
		rowLoadout.quantity := rowLoadout.quantity + log.quantity;
		rowLoadout.volume 	:= rowLoadout.volume + ti.getMyTotalVolume;
		//rowLoadout.weight 	:= rowLoadout.weight + ti.weight;			//-cnwml2 MSL CCMS 1017
		rowLoadout.weight	:= rowLoadout.weight + ti.totalWeight;			//+cnwml2 MSL CCMS 1017
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_tiCargoType" type="Integer"/>
        <Parameter name="_rowLoadoutDict" type="CMIF_RowLoadoutBySOHLocDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSOHLevelsForDate" id="db8f85f9-ba98-40d6-be26-24eef1b60d6d">
        <source>getSOHLevelsForDate(_date : Date; 
					_closingLevel 	: Boolean; 
					_totQty			: Integer io;
					_totVol			: Decimal io;
					_totWeight 		: Decimal io);
//--------------------------------------------------------------
// Created: October 2002 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// R Barr 8/11/2006 Comalco -- Refactor to use common CM_SOHLocation::getSOHLevelsForDate, and remove unused iterator
//--------------------------------------------------------------
vars
	locnCntrl		: CM_LocationsController;
	sohLocation		: CM_SOHLocation;
	
begin
	foreach locnCntrl in self.allVoyageLocations do
		foreach sohLocation in locnCntrl.allProductLocations do
			sohLocation.getSOHLevelsForDate(_date, _closingLevel, _totQty, _totVol, _totWeight);
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="io"/>
        <Parameter name="_totVol" type="Decimal" usage="io"/>
        <Parameter name="_totWeight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSchedulePriority" id="bff5bc92-8fd6-41ff-b766-dc0eb5b27f29">
        <source>getSchedulePriority(_passedThroughStart, _highPointFound : Boolean io; _startVoyage : CM_Voyage) : Integer;
/*
Purpose:			Get voyage priority for scheduling purposes, based on whether this voyage
					passes through defined priority start and end points

Parameters:			

Return Value:		

Date		Who		Reason
15/03/2012	cnwdap1	Initial creation PAR #29265 CCMS RIO 2132 
15/06/2012	cnwdap1	PAR #29837 Prevent recursive calls from looping by telling the recursive method where we started from
					(new parameter to this method _startVoyage)
*/
vars
	movement 		: HMS_Movement;
	berth			: HMS_Berth;
	otherVoyage		: CM_Voyage;

begin
	if self.myHMSVoyageData = null then // AKB2015MAR  or self.isKindOf(CM_CellularVoyage) then
		return null;
	endif;
	
	foreach movement in self.myHMSVoyageData.allVoyageMovements discreteLock do
		if not HMS_VoyageMovement.hasInstance(movement) then
			continue;
		endif;
		berth := movement.HMS_VoyageMovement.getMyBerth;
		if berth = null then
			continue;
		endif;
		if berth.myHarbourRegion &lt;&gt; null then
			if berth.myHarbourRegion.isPriorityStartPoint then
				_passedThroughStart := true;
			endif;
			if berth.myHarbourRegion.isHighPriority then
				_highPointFound := true;
				if _passedThroughStart and _highPointFound then
					return 1;
				endif;
			endif;
		endif;
	endforeach;
	
	if _passedThroughStart and _highPointFound then
		return 1;
	endif;
	
	// we also need to check the other end of this voyage, if it's one that starts at Weipa and finishes at Gladstone
	if self.myVoyageGlobalArrival &lt;&gt; null then
		//foreach otherVoyage in self.myVoyageGlobalArrival.allVoyages discreteLock where otherVoyage &lt;&gt; self do	// PAR #29837
		foreach otherVoyage in self.myVoyageGlobalArrival.allVoyages discreteLock do								// PAR #29837
			if otherVoyage = self or otherVoyage = _startVoyage then												// PAR #29837
				continue;																							// PAR #29837
			endif;																									// PAR #29837
			//otherVoyage.getSchedulePriority(_passedThroughStart, _highPointFound);								// PAR #29837
			otherVoyage.getSchedulePriority(_passedThroughStart, _highPointFound, self);							// PAR #29837
			if _passedThroughStart and _highPointFound then
				return 1;
			endif;
		endforeach;
	endif;
	if self.myVoyageGlobalDeparture &lt;&gt; null and self.myVoyageGlobalDeparture &lt;&gt; self.myVoyageGlobalArrival then
		//foreach otherVoyage in self.myVoyageGlobalDeparture.allVoyages discreteLock where otherVoyage &lt;&gt; self do	// PAR #29837
		foreach otherVoyage in self.myVoyageGlobalDeparture.allVoyages discreteLock do								// PAR #29837
			if otherVoyage = self or otherVoyage = _startVoyage then												// PAR #29837
				continue;																							// PAR #29837
			endif;																									// PAR #29837
			//otherVoyage.getSchedulePriority(_passedThroughStart, _highPointFound);								// PAR #29837
			otherVoyage.getSchedulePriority(_passedThroughStart, _highPointFound, self);							// PAR #29837
			if _passedThroughStart and _highPointFound then
				return 1;
			endif;
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_passedThroughStart" type="Boolean" usage="io"/>
        <Parameter name="_highPointFound" type="Boolean" usage="io"/>
        <Parameter name="_startVoyage" type="CM_Voyage"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSealCheckTypeForContext" id="4f410856-abf0-480a-ba69-71ca12648ead">
        <source>getSealCheckTypeForContext( _context : Integer ): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation	Par 23715

*/

vars

	returnType : Integer;
	
begin

	if _context = CARGO_CHECK_CONTEXT_SHIP_LOAD then
		returnType := self.sealCheckRelease;
	elseif _context = CARGO_CHECK_CONTEXT_SHIP_DISC then
		returnType := self.sealCheckReceival;
	endif;
	
	return returnType;

epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getServiceDate" id="493137b1-0400-4942-9bff-b33330163e2f">
        <source>getServiceDate():TimeStamp;
/*

Purpose:			

VOYAGE - getServiceDate() should return: 
if isBarge = TRUE
	NULL if any voyages with that Voyage Group Code do not have a departure date
	otherwise the Latest Voyage Departure Date for a Voyage with a matching Voyage Group Code.
If isBarge = FALSE
	Voyage Departure Date/Time
	
	
Parameters:			

Return Value:		

Date		Who		Reason
13 May 2021	navndl1	Initial creation	TFS 51196

*/

vars

	iter : Iterator;
	startObject : CM_Voyage;
	voyage : CM_Voyage;
	latestDate : TimeStamp;

begin

	if self.isBarge and self.voyageGroupCode &lt;&gt; null then
		iter := self.myTerminal.allVoyagesByVoyageGroupCode.createIterator;
		startObject := self.myTerminal.allVoyagesByVoyageGroupCode.getAtKeyGeq( self.voyageGroupCode );
		if startObject = null or startObject.voyageGroupCode &lt;&gt; self.voyageGroupCode then
			return self.departedDT;
		endif;
		latestDate := null;
		iter.startAtObject( startObject );
		while iter.next( voyage ) do
			if voyage.voyageGroupCode &lt;&gt; self.voyageGroupCode then
				break;
			endif;
			if not voyage.departedDT.isValid then
				return null;
			endif;
			if not latestDate.isValid then
				latestDate := voyage.departedDT;
			elseif voyage.departedDT &gt; latestDate then
				latestDate := voyage.departedDT;
			endif;
		endwhile;
		return latestDate;
		
	else
		return self.departedDT;
		
	endif;

epilog

	delete iter;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getShiftDT" id="ff72d17e-7803-4191-98ee-70d69c7a373d">
        <source>getShiftDT() : TimeStamp;
/*
----------   ----------  --------------------------------------------------
Created:	03 August 2007 By cnwth2

Purpose:	Used in JRW - don't delete

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	hmsMovement			: HMS_Movement;
	hmsVoyageData			: HMS_VoyageData;
begin
	if self.myHMSVoyageData = null then
		return null;
	endif;
	hmsMovement := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeShift);
	
	if hmsMovement = null then
		return null;
	endif;
	
	return hmsMovement.arrivalTimeAtToRegion;

end;


</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getShiftDTLocalTZ" id="a16cf917-c940-4c70-be34-f03b82f6cd46">
        <source>getShiftDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	hmsMovement			: HMS_Movement;
	hmsVoyageData			: HMS_VoyageData;
begin
	if self.myHMSVoyageData = null then
		return null;
	endif;
