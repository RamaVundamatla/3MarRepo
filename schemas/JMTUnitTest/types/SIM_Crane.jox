<Class name="SIM_Crane" id="6151e11a-85ad-42c1-8eae-063622ec86a4">
    <superclass name="SIM_Machine"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="getCraneQueue" id="cc4ae194-aa52-4e17-be88-866a5b00a9e9">
        <source>getCraneQueue() : CM_RadioTelemetryQueue;

vars
	craneQueue : CM_RadioTelemetryQueue;
begin

	foreach craneQueue in self.myMachine.myPrimaryQueue.allSubQueuesById do
		if craneQueue.isCraneQueue and craneQueue.CM_VoyageCraneQueue.crane = self.myMachine then
			return craneQueue;
		endif;
	endforeach;	

epilog

end;</source>
        <ReturnType type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="getWork" id="0cedd0ca-5899-4c76-97cd-c7be0439f09f">
        <updating/>
        <source>getWork(): SIM_Task updating;

vars
	craneQueue: CM_VoyageCraneQueue;
	entry: CM_RTQueueEntry;
	task: CM_RTQueueTask;
	simTask: SIM_Task;
begin
	craneQueue := self.getCraneQueue.CM_VoyageCraneQueue;
	foreach entry in craneQueue.allEntries do
		task := entry.allTasks.first;
		if task.isPickUp and task.isShipLoadTask then
			task := entry.allTasks.last;
		endif;
		simTask := self.mySIMTerminal.getPickupTaskForCrane(task);
		if simTask = null then
			process.debug;
		endif;
		if not simTask.isCompleted then
			return simTask;
		endif;
	endforeach;
	
epilog

end;</source>
        <ReturnType type="SIM_Task"/>
    </JadeMethod>
    <JadeMethod name="isCrane" id="d3038df5-3bd9-4b5a-b28e-2eefc6a8dfca">
        <source>isCrane(): Boolean;

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
