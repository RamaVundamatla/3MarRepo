    <JadeMethod name="getMyVoyageObject" id="f0cfebb5-6262-480f-a788-120fd31164c1">
        <source>getMyVoyageObject(): CM_Voyage;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
// 03/09/2020   cnwma1      Bug 49996: ASPA - Voyage Group Code - Issues
//
vars

begin
	if self.myTransactionHMS &lt;&gt; null then
		return self.myTransactionHMS.myVoyage;
	endif;
	
	if self.myTransactionEvent &lt;&gt; null then
		return self.myTransactionEvent.getVoyage();
	endif;
	
	if self.myTransactionTI &lt;&gt; null then
		return self.myTransactionTI.getVoyage();
	endif;
	
	if self.myTransactionWO &lt;&gt; null then // TFS 42161
		return self.myTransactionWO.getMyVoyageObject(); // TFS 42161
	endif;
	
	if self.myTransactionBOL &lt;&gt; null then	//31 Oct 2019	NDL	TFS 47100
		return self.myTransactionBOL.getMyVoyage();
	endif;
	
	if self.invoice &lt;&gt; null and self.invoice.myVoyage &lt;&gt; null then    		  //03.09.2020 cnwma1 #49996
		return self.invoice.myVoyage;
	endif;
	
	if self.trackedItem &lt;&gt; null and self.trackedItem.myVoyage &lt;&gt; null then    //03.09.2020 cnwma1 #49996
		return self.trackedItem.myVoyage;
	endif;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getNarrationFromInvoiceLocale" id="046bce35-611b-4a7a-89d2-34f4596e3934">
        <source>getNarrationFromInvoiceLocale() : String;
/*

Purpose:			Gets the narration based on the invoice locale

Parameters:			NONE

Return Value:		String	Representing the narration translated from the invoice locale

Date		Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	locale 					: CM_Locale;
	lcid					: String;
	invoiceLineType 		: CM_InvoiceLineDesc;
	invoiceLineNarration 	: CM_InvoiceLineNarration;
	coll					: CM_InvoiceLineNarrationSet;
	
begin
	if self.invoiceLineDesc = null then
		return null;
		
	endif;
	
	if self.invoice = null then
		return null;
		
	endif;
	
	locale 			:= self.invoice.myLocale;
	invoiceLineType := self.invoiceLineDesc;
	
	if locale = null then
		return invoiceLineType.narration;
	endif;
	
	lcid := locale.localeId;
	
	coll := invoiceLineType.allInvoiceLineNarrations;
	
	foreach invoiceLineNarration in coll where invoiceLineNarration.myLocale.localeId = lcid do
		return invoiceLineNarration.narration; //Return the narration if we have one
	endforeach;
	
	return invoiceLineType.narration; //If we do not a find narration for the locale return the invoice line type narration.

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOverridden" id="f488e4d0-a795-4e73-a34c-be45e06542c7">
        <source>getOverridden():Boolean;
