    </JadeMethod>
    <JadeMethod name="querySetButtonsMenu" id="0d28c167-22a1-40ca-b0ba-7bd31394781e">
        <updating/>
        <source>querySetButtonsMenu(_dtoQuerySet : DTO_QuerySetForRT) protected, updating;
// --------------------------------------------------------------------------------
// Created:		28 April 2008 by cnwvu1
//
// Purpose:		Organize set of buttons for each Query Access Set:
//					if number of queries &lt;= 36 - we have 3 columns on the screen
//					if number of queries &lt;= 24 - we have 2 columns on the screen
//					if number of queries &lt;= 12 - we have 1 column on the screen
// --------------------------------------------------------------------------------

constants
	Gap		: Integer = 6;		// vertical gap between buttons
	GapCol	: Integer = 20;		// gap between columns in the screen
	
vars
	clonedButton,
	btn					: MB_RTButtonQuery;
	i, iTop,
	nQueries,
	top, height, gap, 
	left, leftMargin,
	frmWidth, btnWidth,
	tabIndex			: Integer;
	
begin
	self.queryDeleteButtonsMenu();
	
	// ---------------------------------------------------------------------
	//						creating new buttons
	// ---------------------------------------------------------------------
	nQueries := _dtoQuerySet.queriesDescriptionArray.size();
	
	if nQueries = 0 then
		return;
	endif;

	frmWidth := self.frmReportMenu.width.Integer;
	btnWidth :=  self.queryButtonsGetWidth(nQueries, _dtoQuerySet.queriesDescriptionArray, frmWidth, GapCol);
	self.btnQr_rpt1.width := btnWidth;
	
	// getting leftMargin for the buttons
	if nQueries &gt; 24 then		// nQueries &gt; 24, we have three columns of the buttons on the screen
		leftMargin := GapCol;	 
	elseif nQueries &lt;= 12 then	// nQueries &lt;= 12 - one column in the center of the screen
		leftMargin := (frmWidth div 2) - (btnWidth div 2);
	else						// 12 &lt; nQueries &lt;= 24 - we have two columns on the screen
		leftMargin := GapCol + ((frmWidth - 3 * GapCol) - (2 * btnWidth)) div 3;
	endif;
	
	top		:= btnQr_rpt1.top.Integer;
	height	:= btnQr_rpt1.height.Integer;
	left	:= leftMargin;
	iTop	:= 0;
	lblSelectReport.left := leftMargin;
	
	foreach i in 1 to nQueries do 
		iTop := iTop + 1;
		
		if i = 1 then
			self.btnQr_rpt1.visible	:= true;
			self.btnQr_rpt1.caption			:= _dtoQuerySet.queriesDescriptionArray[i];
			self.btnQr_rpt1.querySelectorOid:= _dtoQuerySet.queriesSelectorOidArray[i];
			self.btnQr_rpt1.left	:= left;
			self.btnQr_rpt1.myForm	:= self;
			tabIndex := self.btnQr_rpt1.tabIndex + 700;
		else
			clonedButton := self.btnQr_rpt1.cloneSelf( true );
			self.addControl( clonedButton );	//clonedButton.form	:= self;
			clonedButton.caption			:= _dtoQuerySet.queriesDescriptionArray[i];
			clonedButton.querySelectorOid	:= _dtoQuerySet.queriesSelectorOidArray[i];
			clonedButton.name	:= btnQr_rpt1.name.String[ 1 : btnQr_rpt1.name.length()-1 ] &amp; i.String;
			clonedButton.parent	:= btnQr_rpt1.parent;
			
			// getting left
			if i = 25 then	// this is when we have the third column
				left := self.frmReportMenu.width.Integer - leftMargin - btnWidth;
				iTop := 1;
			elseif i = 13 then	// this is when we have either two or three columns
				iTop := 1;
				if nQueries &gt; 24 then	// three columns, this is in the middle
					left := (frmWidth div 2) - (btnWidth div 2);
				elseif nQueries &gt; 12 then // this column is the second of two columns
					left := (frmWidth div 2) + (leftMargin div 2);
				endif;
			endif;
			
			clonedButton.top	:= top + (iTop-1)*(height+Gap);
			clonedButton.left:= left;
			clonedButton.myForm	:= self;
			tabIndex := tabIndex + 1;
			clonedButton.tabIndex := tabIndex;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_dtoQuerySet" type="MobileServerRTThin::DTO_QuerySetForRT"/>
    </JadeMethod>
    <JadeMethod name="recoverFromDisruptedState" id="4804ae55-728a-46c3-96b5-a51ae3b96a19">
        <updating/>
        <source>recoverFromDisruptedState() updating, protected;
// -------------------------------------------
// Created 16 January 2006 by cnwdvb1
// -------------------------------------------
vars
	errorString	: String;

begin
	self.aState := RadioTelemetryGuiAgent.LoggedOnReset;
	self.updateFromState();
	
	if app.msgBox('Device ' &amp; self.aDevice &amp; ' was left in an invalid state at ' &amp; self.aLastTs.shortCurrentLocaleFormat(false) &amp; '. Do you wish to return to this transaction?', 'Recover',  MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_Yes then
		if not app.myRTGuiAgent.recoverFromDisruptedState(self, self.aState, self.aResetState, errorString, self.aLastTs) then
			self.showMessage(errorString, true);
		endif;
	else
		if not app.myRTGuiAgent.resetMediator(self.aClientConnectionDetails, self.aState, self.aResetState, errorString, self.aLastTs) then
			self.showMessage(errorString, true);
		endif;
	endif;
	
	self.updateFromState();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="registerForNotes" id="d440ce25-894f-42bc-9be4-d3e162912781">
        <source>registerForNotes() protected;
// -------------------------------------------
// Created 24 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	self.beginNotification(app.myRTGuiAgent.myNotesObj, Event_Delete_Queue_Entry, Response_Continuous , null);
	self.beginNotification(app.myRTGuiAgent.myNotesObj, Event_Add_Queue_Entry, Response_Continuous , null);
	self.beginNotification(app.myRTGuiAgent.myNotesObj, EVENT_MACH_BROADCAST_MSG, Response_Continuous , null);
	self.beginNotification(app.myRTGuiAgent.myNotesObj, EVENT_MACHQUEUE_ALTERED, Response_Continuous , null);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetForm" id="e8b0d764-022e-4a45-b3c1-aac47ef154aa">
        <updating/>
        <source>resetForm() protected, updating;
/*

Date		Who		Reason
12 Jan 2006	cnwdvb1	Created 
05 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

begin
	self.aIsLoggedOn := true;

	self.tblEnquiry.rows			:=	self.tblEnquiry.fixedRows;
	self.txtNewLocation.text		:=	null;
	self.btnAccept.enabled			:=	true;
	self.btnAccept.caption			:=	self.getViewButtonCaption;		// PAR #16010
//	self.btnAccept.picture			:=	picView.picture;
	self.btnReject.enabled			:=	false;				// PAR #16010
	self.btnTasksUpdate.enabled		:=	self.aIsSaveRequired;
	self.btnGradesUpdate.enabled	:=	true;
	self.btnPickup.caption			:=	self.Caption_Move;
	self.btnPickup.picture			:=	picView.picture;
	self.btnPickup.enabled			:=	false;
	self.btnGradesUpdate.enabled	:=	false;
	self.btnChangePass.enabled 		:=	true;
	self.btnPreferences.enabled 	:=	true;
	self.btnChangeQueue.enabled		:=	true;		// PAR #16010
	self.btnInfo.enabled			:=	true;
	self.btnLogOff.enabled			:=	true;
	self.btnLogOffExit.enabled		:=	true;
	self.btnChangePass.enabled 		:=	true;
	self.btnPreferences.enabled 	:=	true;
	self.txtNewLocation.enabled		:=	false;
	self.txtContainerID.mbEnable(true);
	self.lblCurrentGrade.caption	:=	null;
	self.showLogonFrame(false);
		
	self.tableToDoInitialize();
	self.tableGradeInitialize();
	
	self.makeEnquiryTableVisible(tblEnquiry);

	self.tblContSrchRes.rows		:= self.tblContSrchRes.fixedRows;
	self.tblQueueEntries.rows		:= self.tblQueueEntries.fixedRows;
	self.lblSearchWarning.caption	:= null;
		
	self.queryResultTableReInitialize();
	self.showSheetReports();
	
	self.shtMoves.enabled	:=	true;
	self.shtMoves.setFocus();
	self.txtContainerID.setFocus();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAviOnOff" id="7113b8e2-5212-4be7-8e6a-0d66fba6ac90">
        <updating/>
        <source>setAviOnOff(_isOn : Boolean) updating, protected;

/*

Date		Who		Reason
09 Feb 2006	cnwdvb1	Created 
14 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
					Make flag invisible if displaying number of Queue entries
*/

vars

begin
	if not self.aShowNumberOfQueueEntries and _isOn then
		self.mulFlag.play();
		self.mulFlag.visible := true;
	else
		self.mulFlag.stop();
		self.mulFlag.visible := false;
	endif;
	
	

end;</source>
        <access>protected</access>
        <Parameter name="_isOn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setClientConnectionDetails" id="32307686-fae0-4471-b774-1292ac866183">
        <updating/>
        <source>setClientConnectionDetails() protected, updating;
// -------------------------------------------
// Created 20 January 2006 by cnwdvb1
// -------------------------------------------
vars
	iniFileName : String;

begin
	iniFileName 			:= app.getIniFileName();
	self.aTerminal			:= app.getProfileString(iniFileName, RadioTelemetryIniFileSection, Key_RTTerminal, null);
	self.aDevice			:= app.getProfileString(iniFileName, RadioTelemetryIniFileSection, Key_RTDevice, null);
	self.txtUserName.text	:= app.getProfileString(iniFileName, RadioTelemetryIniFileSection, Key_RTLastUser, null);
	
	if self.txtUserName.text.trimBlanks() = null then
		self.txtUserName.setFocus();
	else
		self.txtNewPassword.setFocus();
	endif;
	
	if self.aTerminal = null or self.aDevice = null then
		self.showMessage('Ini file [RadioTelemetry] section has not been configured correctly' &amp; CrLf &amp;
		'[RadioTelemetry]' &amp; CrLf &amp;
		'RTTerminal= ' &amp; CrLf &amp; 
		'RTDeviceID= ', true);
		self.aClientConnectionDetails := null;
		return;
	endif;

	self.aClientConnectionDetails	:= self.aDevice &amp; ':' &amp; self.aTerminal &amp; ':' &amp; app.computerName() &amp; ':1010';
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setContolsForTandemLift" id="b0bd3d09-6887-4da9-be40-3506efc97be2">
        <updating/>
        <source>setContolsForTandemLift() protected, updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 Mar 2008	cnwkpd1		PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
//							Rewrite to use relative positions, not absolutes						
// ---------------------------------------------------------------------------

constants
	InterControlSpace		= 12;
	
vars
	
begin
	//should thinking about a better way to show the text box and label.
	if self.aMachineLiftType = TANDEM_LIFT then
	
		self.txtContainerID2.visible 	:= true;
		self.lblContainerID2.visible 	:= true;
		
		// First container text box should be positioned below the second
		self.txtContainerID.top 		:= self.txtContainerID2.top + self.txtContainerID2.height + InterControlSpace;
		
	else
	
		self.txtContainerID2.visible 	:= false;
		self.lblContainerID2.visible 	:= false;

		// Move the first container text box up to the position where the second one is
		self.txtContainerID.top 		:= self.txtContainerID2.top;
	
	endif;
	
	// Align the label with the text box
	self.lblContainerID.top 			:= self.txtContainerID.top;
	
	// And then space the button and tables below it in the remaining space
	self.btnPUEnquiry.top 				:= self.txtContainerID.top + self.txtContainerID.height + InterControlSpace;
	
	self.tblEnquiry.top 				:= self.btnPUEnquiry.top + self.btnPUEnquiry.height + InterControlSpace;
	self.tblEnquiry.height 				:= self.btnPDEnquiry.top - self.tblEnquiry.top - InterControlSpace;
	
	// Container search and queue tables occupy the same space as the enquiry table
	self.tblContSrchRes.top 			:= self.tblEnquiry.top;
	self.tblContSrchRes.height 			:= self.tblEnquiry.height;
	
	self.tblQueueEntries.top 			:= self.tblEnquiry.top;
	self.tblQueueEntries.height 		:= self.tblEnquiry.height;

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEnquiryScrollButtons" id="1baab0ad-89c3-49f7-94e7-64e13ad607f1">
        <source>setEnquiryScrollButtons() protected;

/*

Purpose:			Set up the visibility of the Enquiry PU and PD buttons based on the 
					currently visible Enquiry table, and it's "scrollability"


Return Value:		None


Date		Who		Reason
05 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	canScroll		: Boolean;
	
begin
	canScroll := getVisibleEnquiryTable.mbCanScroll;
	self.btnPUEnquiry.visible := canScroll;
	self.btnPDEnquiry.visible := canScroll;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setModeQuery" id="759a118f-ebd4-4888-a67f-0f7f9435e19c">
        <updating/>
        <source>setModeQuery( _modeQuery : Integer ) updating, protected;
// -------------------------------------------
// Created	28 April 2008 by cnwvu1
// -------------------------------------------

vars

begin

	self.aModeQuery	:= _modeQuery;
	
	if _modeQuery = self.Mode_QueryList then
		self.frmReportMenu.visible	:= true;
		self.frmReportDtl.visible	:= false;
	
	elseif _modeQuery = self.Mode_QueryRun then
		self.frmReportMenu.visible	:= false;
		self.frmReportDtl.visible	:= true;

	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_modeQuery" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setOnHoldBtn" id="1ed42b6c-8bf8-4394-9452-bbd90325f700">
        <updating/>
        <source>setOnHoldBtn(_isOnHold	: Boolean) protected, updating;
// -------------------------------------------
// Created 02 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	if _isOnHold then
		self.btnOnHold.caption := self.Caption_ResetOnHold;
		self.aIsOnHold := true;
	else
		self.btnOnHold.caption := self.Caption_OnHold;
		self.aIsOnHold := false;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_isOnHold" type="Boolean"/>
    </JadeMethod>
