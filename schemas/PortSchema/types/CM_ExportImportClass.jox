end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="aacecd92-346c-48a6-8876-1052d9fd8b90">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36791 - JADE Core Framework - Export/Import Registry Foundation

*/

vars
	realClass : CM_ExportImportClass;
	testClass : CM_ExportImportClass;
	proxyProperty : CM_ExportImportProperty;
begin
	
	self.raiseExceptionIfNotTransient(method);
	
	if self.displayName = null then
		app.raiseCMException(Input_required_field_clasAlias, null, null); 
	endif;
	if self.className = null then
		app.raiseCMException(Input_required_field_className, null, null); 
	endif;
	
	if self.myClass = null then
		app.raiseCMException1(Err_InvalidClass, self.className, null, null);
	endif;
	
	realClass := self.pxyGetRealObject;
	if realClass = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, self.class.name, null, null);
	endif;	

	testClass := app.myRoot.allExportImportClasses[self.className];
	
	if testClass &lt;&gt; null and testClass &lt;&gt; realClass then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.className, null, null);
	endif;
	
	foreach proxyProperty in self.allProperties do
		proxyProperty.validateMe;
	endforeach;
	
end;</source>
    </JadeMethod>
</Class>
