<GUIClass name="MOB_LoadTruckForm" id="91ccda39-41ab-44d8-a341-ef46dedecbf8">
    <superclass name="MOB_OneEntryModalForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myRoadJob" id="66d10fbf-83e3-4418-a2dc-f5ea317746f0">
        <embedded/>
        <type name="CM_RoadJob"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doButtonLeftClick" id="6082b7dd-6d4c-4f14-b16d-092053284f6d">
