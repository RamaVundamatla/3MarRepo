        <source>canBeVerfied() : Boolean;
/*

Date		Who		Reason
14 September 2016	cnwer1	Initial creation TFS 2606

*/

vars
	status	:Integer;
begin
	status := self.status;
	
	return status = CM_EDIFile.EDI_STATUS_LOADED or
			status = CM_EDIFile.EDI_STATUS_LOCKERROR or					// cnwrs1 18 mar 2010 so you can still continue
			status = CM_EDIFile.EDI_STATUS_VERIFYING or					// cnwrs1 18 mar 2010 so you can still continue
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or
			status = CM_EDIFile.EDI_STATUS_VERIFIED or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or
			status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS or
			status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;	

epilog

end;</source>
