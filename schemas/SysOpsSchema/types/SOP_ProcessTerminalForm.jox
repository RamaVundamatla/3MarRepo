    <JadeMethod name="cmbTerminal_displayEntry" id="ac766b88-0800-4457-9c07-df8accd80581">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminal_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140

*/

vars

begin

	if obj = null then
		return null;
	endif;
	
	if obj.isKindOf( CM_Terminal ) then
		return obj.CM_Terminal.name;
	else
		return null;
	endif;

epilog

end;</source>
