    <JadeMethod name="setMyVoyageEvent" id="d8aeed84-8dc7-4d9c-a43d-1a78913f19ef">
        <updating/>
        <source>setMyVoyageEvent( _event : CMEVT_VoyageEvent ) updating;
/*

