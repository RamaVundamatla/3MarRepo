    <JadeMethod name="generateWarning" id="adb71ef5-4405-47dc-a462-f90417196f19">
        <source>generateWarning(_warning : String; _ti : CM_TrackedItem) : Boolean protected; //should be WARNING_CONSTANT off self
// ---------------------------------------------------------------------------
// Created:     20 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if not self.allWarnings.includes(_warning) then
		self.allWarnings.add(_warning);
	else
		return true;
	endif;
	
	if _warning = WARNING_OVER_WEIGHT then
		if not app.msgBox(app.getErrorString(TheAddedWeightOfItem) &amp; ' ' &amp; _ti.id &amp; ' puts the total weight of' &amp; CrLf &amp;
					app.getErrorString(ContainerLwrCase) &amp; ' ' &amp; self.myTI.id &amp; ' over the maximum weight' &amp; CrLf &amp;
					app.getErrorString(DoYouWantToContinue), app.getErrorString(PackWarning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			return false;
		else
			self.allWarnings.add(WARNING_OVER_WEIGHT);
			return true;
		endif;
		
	elseif _warning = WARNING_OVER_VOLUMEMAX then	// ** #25592 17/11/2010 when container volume greater then max volume for container.
		if not app.msgBox(app.getErrorString1(ContVolumeExceedsMaxVolume, self.myTI.id) &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue), app.getErrorString(PackWarning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			return false;
		else
			self.allWarnings.add(WARNING_OVER_VOLUMEMAX);
			return true;
		endif;
		
	elseif _warning = WARNING_OVER_VOLUME then
		if not app.msgBox( app.getErrorString2(CargoVolumeExceedsContVolume, _ti.id, self.myTI.id) &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue), app.getErrorString(PackWarning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			return false;
		else
			self.allWarnings.add(WARNING_OVER_VOLUME);
			return true;
		endif;
	
	elseif _warning = WARNING_DIFFERENT_OPERATOR then
		if not self.myTerminal.getConfig(OnPackConfirmOpOverride).Boolean then					//+cnwml2 PAR22531
			if not app.msgBox('The operator of item ' &amp; _ti.id &amp; ' - ' &amp; _ti.operatorCode &amp;  CrLf &amp;' is different from the container.'&amp; CrLf &amp; app.getErrorString(ContainerID) &amp; " " &amp; self.myTI.id &amp; ' - ' &amp; self.myTI.operatorCode &amp; CrLf &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue) ,
						app.getErrorString(DifferentOperator), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
				return false;
			else
				self.allWarnings.add(WARNING_DIFFERENT_OPERATOR);
				return true;
			endif;
		else
			return true;
		endif;
		
	elseif _warning = WARNING_DIFFERENT_DESTINATION then		//+cnwml2 PAR24740
		if not app.msgBox(app.getString(DestPortDifferent, _ti.id, self.myTI.id)&amp; CrLf &amp;
					app.getString(DestPortUpdate) &amp; CrLf &amp;
					app.getErrorString(DoYouWantToContinue), app.getErrorString(PackWarning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			return false;
		else
			self.allWarnings.add(WARNING_DIFFERENT_DESTINATION);
			return true;
		endif;

	elseif _warning = WARNING_NO_EXPORT_BOOKING then		//#26726 14/01/2011
		if not app.msgBox(	app.getString(ExporBookingRequiredWhenPackin, _ti.id)&amp; CrLf &amp;
							app.getErrorString(DoYouWantToContinue), app.getErrorString(PackWarning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			return false;
		else
			self.allWarnings.add(WARNING_NO_EXPORT_BOOKING);
			return true;
		endif;

	elseif self.isUsedForRepack then
		if self.allWarnings.includes(_warning) then
			self.allWarnings.remove(_warning);
		endif;
		if _warning = WARNING_DIFFERENT_ISOTYPE then
			if not app.msgBox(app.getErrorString(DifferentISOTypesSentence) &amp; CrLf &amp; _ti.id &amp; ' - (' &amp; _ti.CM_Container.isoTypeDesc &amp; ') is different to container ' &amp; self.myTI.id &amp; ' - (' &amp; self.myTI.isoTypeDesc &amp; '). ' &amp; CrLf &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue) ,
					app.getErrorString(DifferentISOTypes), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
				return false;
			else
				//self.allWarnings.add(WARNING_DIFFERENT_ISOTYPE);
				return true;
			endif;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_warning" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
