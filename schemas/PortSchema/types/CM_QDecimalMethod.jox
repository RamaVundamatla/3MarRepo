<Class name="CM_QDecimalMethod" id="82ead09a-1fb0-4a74-a5be-013324b5a76f">
    <superclass name="CM_QueryMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
