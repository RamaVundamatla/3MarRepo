        <access>protected</access>
        <ReturnType type="CM_FormConfigForm"/>
    </JadeMethod>
    <JadeMethod name="isChildControlOf" id="6caeb4ff-2ed5-4858-8819-5546080c6a09">
        <source>isChildControlOf(_control :Control; _parent :Control):Boolean protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
29 August 2008	concms1	Initial creation
*/

vars
	control	:Control;
begin
	control := _control;
	
	while control.parent &lt;&gt; null and control.parent.isKindOf (Control) do
		if control.parent = _parent then
			return true;
		endif;
		control := control.parent.Control;
	endwhile;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control"/>
        <Parameter name="_parent" type="Control"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlCaption" id="82341361-4d00-417c-98bd-b0754daae6da">
        <source>setControlCaption(_control :Control input; _caption :String);
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	config : CM_FormConfigItem;
begin
	if not self.allCustomisableControls.includes (_control) then
		app.raiseCMException ( ERR_INVALID_INDEX, 'invalid control', null);
	endif;
	
	config := self.getConfigItemForControl (_control);
	
	if _control.isKindOf (Label) then
		config.CM_FormConfigLabel.setCaption (_caption);
		
		_control.Label.caption := _caption;
	elseif _control.isKindOf (Button) then
		config.CM_FormConfigButton.setCaption (_caption);
		
		_control.Button.caption := _caption;
	endif;
epilog

end;</source>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setControlPosition" id="6d628dd4-e348-4f0b-a35b-e5860cca99f5">
        <source>setControlPosition(_control :Control input; _left, _top :Real; _move :Boolean);
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	config : CM_FormConfigItem;
begin 
	if not self.allCustomisableControls.includes (_control) then
		app.raiseCMException ( ERR_INVALID_INDEX, 'invalid control', null);
	endif;
	
	config := self.getConfigItemForControl (_control);
	
	config.CM_FormConfigControl.setPosition (_left, _top);
	
	if _move then
		_control.move (_left, _top, _control.width, _control.height);
	endif;
epilog

end;</source>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_left" type="Real"/>
        <Parameter name="_top" type="Real"/>
        <Parameter name="_move" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlProperties" id="0ed8b134-6302-4b0a-916e-8c727e9b9e22">
        <source>setControlProperties(_control: Control input; _item: CM_FormConfigItem) protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_control, _item);

	if _control.isKindOf (ComboBox) then
		_control.ComboBox.style := ComboBox.Style_Simple;
	endif;
	
	_control.userObject := _item;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_item" type="CM_FormConfigItem"/>
    </JadeMethod>
    <JadeMethod name="setControlVisible" id="7929fcfa-6e2a-4e93-a500-aba031df8c20">
        <source>setControlVisible(_control :Control input; _visible :Boolean);
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	config : CM_FormConfigItem;
begin
	if not self.allCustomisableControls.includes (_control) then
		app.raiseCMException ( ERR_INVALID_INDEX, 'invalid control', null);
	endif;
	
	config := self.getConfigItemForControl (_control);
	
	config.CM_FormConfigControl.setVisible (_visible);
	
	_control.visible := _visible;
epilog

end;</source>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFormDimensions" id="48df2c40-373f-4cc5-8f2e-cada23a2a675">
        <source>setFormDimensions(_form :CM_BaseForm input; _parent :Frame input; _proxy : CM_FormConfigForm) protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  _form	- design form 
//				_parent - frame on which form image is being built
//				_proxy	- 
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// set the size of the frame being used in design
	if _proxy.width &gt; 0 then
		_parent.width	:= _proxy.width;
	else
		_parent.width	:= self.myJadeForm.clientWidth;
	endif;
	
	if _proxy.height &gt; 0 then	
		_parent.height	:= _proxy.height;
	else
		_parent.height	:= self.myJadeForm.clientHeight;
	endif;
	
	// set size of the form being used for design based on the frame size
	_form.clientWidth 	:= _parent.width.Integer;
	_form.clientHeight	:= _parent.height.Integer;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
        <Parameter name="_parent" type="Frame" usage="input"/>
        <Parameter name="_proxy" type="CM_FormConfigForm"/>
    </JadeMethod>
    <JadeMethod name="setMyFormConfiguration" id="7e9e67e5-aa04-4da7-bf6b-bbb830aae2a9">
        <updating/>
        <source>setMyFormConfiguration(_config: CM_FormConfigForm) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_config);
	
	if self.myPxyFormConfiguration &lt;&gt; null then
		delete self.myPxyFormConfiguration;
	endif;

	self.myPxyFormConfiguration := _config.pxyCreateUpdateProxy;
epilog

end;</source>
        <Parameter name="_config" type="CM_FormConfigForm"/>
    </JadeMethod>
    <JadeMethod name="showForm" id="b74f0a64-f442-4558-a3a8-18a6723771d0">
        <updating/>
        <source>showForm(_form :CM_BaseForm input; _frame :Frame input)updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// first build the form based on the jade definition
	self.buildFormFromJadeDefinition (_form, _frame); 
	
	// now apply any customisation
	self.customiseForm (_form);
epilog

end;</source>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
    </JadeMethod>
</Class>
