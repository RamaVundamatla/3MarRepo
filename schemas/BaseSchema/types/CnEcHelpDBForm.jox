    <JadeMethod name="buildForms" id="aba10def-3175-4c8b-995c-c9d0097027ec">
        <updating/>
        <source>buildForms() updating;

vars
	allForms		: ObjectSet;
	start, finish	: Integer;
	dateBuilt		: TimeStamp;
begin
	self.setStatus("Building form lists...", true);
	txtLastBuildDate.text := dateBuilt.String;

	create allForms transient;

	lstForms_new.clear;
	lstForms_change.clear;

	self.getFormsInSchema(allForms);

	start := app.clock();
	aMyHelp.getChangedForms(allForms, aAllNewForms, aAllChangedForms);
	finish := app.clock();
//	write("Process time=" &amp; (finish - start).String);

	lstForms_new.listCollection(aAllNewForms, false, 0);
	lstForms_change.listCollection(aAllChangedForms, false, 0);

	lstForms_new.setFocus();
	self.setStatus("Form lists built", false);
end;</source>
    </JadeMethod>
