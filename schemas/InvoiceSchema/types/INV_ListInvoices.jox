    <JadeMethod name="doCmbFilterVoyage" id="ba049ea6-ea2f-44f7-bfa8-ff463605411b">
        <source>doCmbFilterVoyage(_combo : CMUI_ComboBox input; _archive : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Aug 2023	navpw1	Initial creation TFS: 59142 (59645)
11 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
*/

vars
	str					: String;
	aVoyage				: CM_Voyage;
	idx					: Integer;
	filterText			: String;
	index				: Integer;
	terminal			: CM_Terminal;
	allVoyagesArchived,
	allVoyagesByCode,
	allVoyages			: CM_VoyageByCodeArrivalDT;
	invalidVoyage		: Boolean;
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	_combo.sorted := true;
	terminal := self.myTerminal;
	create allVoyages transient;
	allVoyagesArchived := terminal.allVoyagesArchived;
	allVoyagesByCode := terminal.allVoyagesByCode;
	
	index := 1;
	
	//if _combo &lt;&gt; self.cmbVoyage then					//11.9.2023 navhl20 #59376
	if _combo &lt;&gt; self.cmbVoyage and 
	_combo.getCollection &lt;&gt; null and 
	not _combo.getCollection.includes(null) then		//11.9.2023 navhl20 #59376		
		idx := _combo.addItem(null);
		_combo.itemObject[idx] := null;
	endif;
	
	if _archive then
		allVoyagesArchived.copyNoDups(allVoyages);
	endif;
	
	allVoyagesByCode.copyNoDups(allVoyages);
	
	//Add items if they do not already exist
	foreach aVoyage in allVoyages discreteLock do
		if filterText = null and _combo.findString(-1, aVoyage.code) = -1 then
			idx := _combo.addItem(aVoyage.getDisplayDetails(false));
			_combo.itemObject[idx] := aVoyage;
		elseif aVoyage.code.pos(filterText, index) &gt; 0 and _combo.findString(-1, aVoyage.code) = -1 then
			idx := _combo.addItem(aVoyage.getDisplayDetails(false));
			_combo.itemObject[idx] := aVoyage;
		endif;
	endforeach;
	
	//Remove items if they no longer exist
	index := 1;
	on Exception do app.handleDeletedObject(exception, aVoyage, invalidVoyage);
	while index &lt; _combo.listCount do
		//write "Item: " &amp; index.String;
		aVoyage := _combo.itemObject[index].CM_Voyage;
		if aVoyage &lt;&gt; null then					//11.9.2023 navhl20 #59376
			aVoyage.edition;		
		endif;
		if not invalidVoyage then
			index += 1;
			continue;
		endif;
		
		_combo.removeItem(index);
		invalidVoyage := false;
		
		index += 1;
	endwhile;
	
	if not _archive then						//11.9.2023 navhl20 #59376
		foreach aVoyage in allVoyagesArchived do
			_combo.removeObject(aVoyage);
		endforeach;
	endif;
	
	on Exception do null;
	
epilog
	allVoyages.clear();
	delete allVoyages;
	
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_archive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCmbInvCategoryBuild" id="78e4d812-9b19-4f53-9779-9b3f0376f48c">
        <source>doCmbInvCategoryBuild(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Feb 2023	navmv20 TFS 56403 Task 56460: Jade - Selector Category collection
*/

vars

begin

	_combo.clear;
	_combo.sorted := false;
	
	_combo.addItem(app.getErrorString(Invoice_categories));
	self.cmbInvCategory.itemData[self.cmbInvCategory.newIndex] := InvoiceCategory_AllCategories;
	self.cmbInvCategory.listIndex := self.cmbInvCategory.newIndex;
	
	_combo.addItemWithData(app.getErrorString(Invoice), InvoiceCategory_Invoice);
	_combo.addItemWithData(app.getErrorString(Credit_note), InvoiceCategory_CreditNote);
	
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbInvoiceStatusBuild" id="da3b8b2d-338f-49c3-adef-6f44663a4c98">
        <source>doCmbInvoiceStatusBuild();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 29/03/2018	jlgdap1		TFS 37560 PEL1 Prepend Invoice Status
// 31/10/2018   cnwma1		ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice
vars
	invoiceProcess : CM_InvoiceProcess; // TFS 39618
	invoiceStatus : CM_InvoiceStatus;
begin
	self.cmbInvoiceStatus.clear;
	cmbInvoiceStatus.sorted := false;
	invoiceProcess := app.getInvoiceProcess(self.myTerminal, self.myCurrentInvoice); // TFS 39618
	
	self.cmbInvoiceStatus.addItem(app.getErrorString(CM_Any_Status));
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_ALL_STATUS;

	self.cmbInvoiceStatus.listIndex := self.cmbInvoiceStatus.newIndex;

	foreach invoiceStatus in invoiceProcess.allStatuses	discreteLock do
		self.cmbInvoiceStatus.addItem(invoiceStatus.description); 
		self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := invoiceStatus.id;

	endforeach;
	
	/*
	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_SUSPENSE)); //app.getErrorString(Suspense)); // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_SUSPENSE;
	
	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_OPEN)); //app.getErrorString(Open_GC)); // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_OPEN;
	
	
	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_PREPEND)); //app.getErrorString(Prepend));// TFS 37560 // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_PREPEND;		// TFS 37560
	
	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_DISPUTED)); //app.getErrorString(Disputed)); // TFS 37560 // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_DISPUTED;		// TFS 37560
	
	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_PENDING)); //app.getErrorString(Pending)); // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_PENDING;

	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_POSTED)); //app.getErrorString(Posted)); // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_POSTED;
	
	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_VOID)); //app.getErrorString(Void)); // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_VOID;
	
	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_POSTED_CREDIT)); //app.getErrorString(Posted_credit)); // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_POSTED_CREDIT;
	
	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_POSTED_REVERSE)); //app.getErrorString(Posted_returned)); // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_POSTED_REVERSE;

	self.cmbInvoiceStatus.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_PENDING_REVERSE)); //app.getErrorString(Pending_returned)); //31.10.2018 cnwma1 TFS #41703 // TFS 39618
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_PENDING_REVERSE; //31.10.2018 cnwma1 TFS #41703
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbInvoiceTypeBuild" id="c514d731-3138-467c-a769-4a8b5467da4f">
        <source>doCmbInvoiceTypeBuild(	_combo : CMUI_ComboBox input;
						_showNotEnterable : Boolean);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	invType:  CM_InvoiceDesc;
begin
	_combo.clear;
	_combo.sorted := true;

	// show 'not available for entry' invoice types for the enquiry combo
	//	but not for the new invoice combo
	foreach invType in self.myCurrentBank.invoiceTypes do
		if invType.isNotAvailableForEntry and
		   not _showNotEnterable then
			continue;
		endif;
		_combo.addItem(invType.description);
		_combo.itemObject[_combo.newIndex] := invType;
	endforeach;
	_combo.sorted := false;
	//epr par 36958 29/6/15
	if _showNotEnterable then
		_combo.addItemAt(app.getErrorString(CM_All_Types),1);
	endif;
	// from 37580 may be no types for the current BU
	if _combo.newIndex &gt; 0 then
		_combo.itemData[_combo.newIndex] := null;
		_combo.listIndex := _combo.newIndex;
	endif;

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_showNotEnterable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCmbSearchFor" id="bb7aa84c-f4ea-4389-9fba-c09ca2ffa145">
        <source>doCmbSearchFor(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number

*/


vars
	finIOClass 		 : CM_ExtFinanceIO;
	usesExtInvNumber : Boolean;
begin
	self.cmbSearchFor.clear();
	
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	usesExtInvNumber := finIOClass.usesExternalInvoiceNumber();
	
	self.cmbSearchFor.addItem(app.getErrorString(Invoice_invoice_number));
	self.cmbSearchFor.addItem(app.getErrorString(Invoice_line_number));
	if usesExtInvNumber then
		self.cmbSearchFor.addItem(app.getErrorString(Inv_ext_inv_number));
	endif;
	self.cmbSearchFor.addItem(app.getErrorString(Inv_external_number));
	
	self.cmbSearchFor.listIndex := 1;
	self.textSearch.dataType := TextBox.DataType_Numeric;
	self.textSearch.maxLength := 9;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbStatusInvPropBuild" id="5e155a5c-42c9-480d-983d-badf3dfe27a3">
        <source>doCmbStatusInvPropBuild() protected;
/* ---------------------------------------------------------------------------
Created:	12 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	invoiceProcess : CM_InvoiceProcess; // TFS 39618
	invoiceStatus : CM_InvoiceStatus;
begin

	self.cmbStatusInvProp.clear;
	cmbStatusInvProp.sorted := false;
	
	invoiceProcess := self.myCurrentBank.getMyInvoiceProcess; // TFS 39618 PATCH 1
	
	if invoiceProcess.isLinxProcess() then // TFS 39618 PATCH 1
		invoiceStatus := invoiceProcess.allStatuses[CM_Invoice.INVOICE_PENDING_APPROVAL]; // TFS 39618 PATCH 1
		self.cmbStatusInvProp.addItem(invoiceStatus.description); 
		self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.newIndex] := CM_Invoice.INVOICE_PENDING_APPROVAL; // TFS 39618 PATCH 1
	
		self.cmbStatusInvProp.listIndex := 1;
		self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name, invoiceStatus.description); // TFS 39618 PATCH 1
	
	else
//		invoiceProcess := app.getInvoiceProcess(self.myTerminal, self.myCurrentInvoice); // TFS 39618
		self.cmbStatusInvProp.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_PENDING)); //app.getErrorString(Pending)); // TFS 39618
		self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.newIndex] := CM_Invoice.INVOICE_PENDING;
	
		self.cmbStatusInvProp.listIndex := 1;
		
		self.cmbStatusInvProp.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_SUSPENSE)); //app.getErrorString(Suspense)); // TFS 39618
		self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.newIndex] := CM_Invoice.INVOICE_SUSPENSE;
	
		self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name, app.getErrorString(Pending));
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbTermsTradeBuild" id="0806f370-1e5b-40ed-b931-76e1fb678111">
        <source>doCmbTermsTradeBuild();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// ---------------------------------------------------------------------------

vars

	invTerm : CM_InvoiceTermsOfTrade;
begin
	self.cmbTermsTrade.clear;
	cmbTermsTrade.sorted := false;

	self.cmbTermsTrade.addItem("");
	self.cmbTermsTrade.itemData[self.cmbTermsTrade.newIndex] := null;

	self.cmbTermsTrade.listIndex := self.cmbTermsTrade.newIndex;

	foreach invTerm in app.myRoot.myRootCompany.allInvoiceTermsOfTrade do
		self.cmbTermsTrade.addItem(invTerm.description);
		self.cmbTermsTrade.itemObject[self.cmbTermsTrade.newIndex] := invTerm;
	endforeach;
	
	//22.07.2019 cnwma1 TFS #45577
	if self.myCurrentInvoice &lt;&gt; null then
		if self.myCurrentInvoice.debtor &lt;&gt; null then
			if self.myCurrentInvoice.debtor.myTermsOfTrade &lt;&gt; null then
			
				self.cmbTermsTrade.listObject := self.myCurrentInvoice.debtor.myTermsOfTrade;
				self.cmbTermsTrade.listIndex  := self.cmbTermsTrade.findObject(self.myCurrentInvoice.debtor.myTermsOfTrade);
			endif;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="80c60567-6ddc-4abb-94a9-f22111419222">
        <source>doCmbVoyageBuild(_combo : CMUI_ComboBox input; _archive : Boolean; _allOtherCombos : ObjectArray);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	str				: String;
	aVoyage 		: CM_Voyage;
	idx 			: Integer;
	otherCombo		: CMUI_ComboBox;
	doOtherCombo	: Boolean;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	doOtherCombo := _allOtherCombos &lt;&gt; null and _allOtherCombos.isNotEmpty(); //17/04/2024	navkc1 Bug 63717
	
	_combo.clear;
	_combo.sorted := true;
	
	// cnwrl1 29/04/2009 PAR 19286 - start of coding
	if _combo &lt;&gt; self.cmbVoyage then		// do not add an empty voyage entry as 1 must be picked or ********* for all
		idx := _combo.addItem(null);
		_combo.itemObject[idx] := null;
	endif;
	/* cnwrl1 29/04/2009 what it was
	idx := _combo.addItem(null);
	_combo.itemObject[idx] := null;
	*/
	
	//17/04/2024	navkc1 Bug 63717
	if doOtherCombo then
		foreach otherCombo in _allOtherCombos as CMUI_ComboBox do
			otherCombo.clear;
			otherCombo.sorted := true;
			
			if otherCombo &lt;&gt; self.cmbVoyage then
				idx := otherCombo.addItem(null);
				otherCombo.itemObject[idx] := null;
			endif;
		endforeach;
	endif;
	
	if _archive  then
		foreach aVoyage in self.myTerminal.allVoyagesArchived discreteLock do
			str := aVoyage.code.trimBlanks &amp; " - " &amp; aVoyage.description;
			if _combo.findString(-1, str) = -1 then
				idx := _combo.addItem(str);
				_combo.itemObject[idx] := aVoyage;
			endif;
			//17/04/2024	navkc1 Bug 63717
			if doOtherCombo then
				foreach otherCombo in _allOtherCombos as CMUI_ComboBox do
					idx := otherCombo.addItem(str);
					otherCombo.itemObject[idx] := aVoyage;
				endforeach;
			endif;
		endforeach;
	endif;

	foreach aVoyage in self.myTerminal.allVoyagesByCode discreteLock do
		idx := _combo.addItem(aVoyage.getDisplayDetails(false));
		_combo.itemObject[idx] := aVoyage;
		//17/04/2024	navkc1 Bug 63717
		if doOtherCombo then
			foreach otherCombo in _allOtherCombos as CMUI_ComboBox do
				idx := otherCombo.addItem(aVoyage.getDisplayDetails(false));
				otherCombo.itemObject[idx] := aVoyage;
			endforeach;
		endif;
	endforeach;
	

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_archive" type="Boolean"/>
        <Parameter name="_allOtherCombos" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doCreateCriteriaLine" id="366d7e5d-1afe-4139-a4fa-d0172067c281">
        <source>doCreateCriteriaLine(	_qDef : CM_QueryDefinition;
						_criteriaHolder : CM_QueryCriteriaLineHolder io;
						_propName : String;
						_qOperatorStr : String;
						_value : Any
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	criteriaLine : CM_SelectorCriteriaLine;

begin

	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(_criteriaHolder);

epilog

