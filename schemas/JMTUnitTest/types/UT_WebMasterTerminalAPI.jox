vars
	realTI				: CM_TrackedItem;
	terminal			: CM_Terminal;
	cargoId 			: String;
	incomingJsonString,
	terminalCode,
	loginJson			: String;
	expectFailure		: Boolean;
	isSubTerminalsOn	: Any;
	root				: CM_Root;
	params				: String;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	bs					: CM_TerminalArea;
	operatorCode		: String;
	operator			: CM_Operator;
	passport			: CM_Passport;
	cargoType			: CM_CargoType;
	cargoSubType		: CM_Product;
	prenote1, 
	prenote2, 
	prenote3, 
	prenote4,
	onsite, onship		: CM_TrackedItem;
	bookingRef1,
	bookingRef2,
	bookingRef3,
	bookingRef4,
	bookingRef5,
	bookingRef6			:CM_BookingRef;
	lc 					: CM_LocationsController;
	prenoteUniqBooking 	: Any;
	json 				: String;
begin
	
	isSubTerminalsOn := self.setTerminalConfig(IsSubTerminalsOn, false);
	prenoteUniqBooking := self.setTerminalConfig(PrenoteUniqBooking, true);
	
	cargoId := TestCargoId;
	self.deleteTrackedItem(cargoId, true);
	cargoId := TestCargoId1;
	self.deleteTrackedItem(cargoId, true);
	self.deleteBooking(UTBookingRef1);
	self.deleteBooking(UTBookingRef2);
	self.deleteBooking(UTBookingRef3);
	self.deleteBooking(UTBookingRef4);
	self.deleteBooking(UTBookingRef5);
	self.deleteBooking(UTBookingRef6);
	
	root := app.myRoot;
	passport := app.myPassport;
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	operator := root.allOperators[operatorCode];
	self.assertNotNullMsg(operator, "Operator for '" &amp; operatorCode &amp; "' not found");
	
	cargoType := root.getCargoTypeFromAbbrevOrDescr(TestCargoType);
	self.assertNotNullMsg(cargoType, "Cargo Type PAPER not found");
	cargoSubType := cargoType.allProducts[null, TestCargoSubType];
	self.assertNotNullMsg(cargoSubType, "Cargo Subtype ROLLS not found");
	
	// Set up - delete vessel, voyage, terminal area, prenotes, onsite cargo, onship cargo
	self.deleteVoyage(ThisVoyage);
	voyage := self.getVoyage(ThisVoyage);
	self.assertTrueMsg(voyage = null, "Voyage " &amp; ThisVoyage &amp; " not deleted");
	self.deleteVessel(ThisVessel);
	vessel := self.getVessel(ThisVessel);
	self.assertTrueMsg(vessel = null, "Vessel " &amp; ThisVessel &amp; " not deleted");
	self.deleteTerminalArea(ThisBlockStack);
	
	// Create Vessel / Voyage
	self.createVesselVoyage(ThisVoyage, ThisVessel, operator);
	voyage := self.getVoyage(ThisVoyage);
	self.assertNotNullMsg(voyage, "Voyage " &amp; ThisVoyage &amp; " not found");
	
	bookingRef1 := self.addBookingForContainer(UTBookingRef1,operator,voyage,"DEHAM","2200","GENL");
	bookingRef2 := self.addBookingForContainer(UTBookingRef2,operator,voyage,"DEHAM","2200","GENL");
	bookingRef3 := self.addBookingForContainer(UTBookingRef3,operator,voyage,"DEHAM","2200","GENL");
	
	self.opts.addAssociation("cargoSubType", cargoSubType);
	bookingRef4 := self.addBookingForGeneralCargo(UTBookingRef4,operator,voyage,"DEHAM",cargoType.id,2);
	bookingRef5 := self.addBookingForGeneralCargo(UTBookingRef5,operator,voyage,"DEHAM",cargoType.id,2);
	bookingRef6 := self.addBookingForGeneralCargo(UTBookingRef6,operator,voyage,"DEHAM",cargoType.id,2);
	
	loginJson := null;	// Use default (REST) operator
	
	//Creation of new tracked item
	// Create Prenote
	self.opts.purge;
	self.opts.addAssociation("CargoType", cargoType.id);
	self.opts.addAssociation("cargoSubType", cargoSubType);
	self.opts.addAssociation("BookingItem", bookingRef1.allBookingRefItems.first);
	prenote1 := self.addPrenoted(TestCargoId);
	self.opts.addAssociation("BookingItem", bookingRef2.allBookingRefItems.first);
	prenote2 := self.addPrenoted(TestCargoId);
	self.opts.addAssociation("BookingItem", bookingRef3.allBookingRefItems.first);
	prenote3 := self.addPrenoted(TestCargoId);
	
	self.opts.addAssociation("CargoType", cargoType.id);
	self.opts.addAssociation("cargoSubType", cargoSubType);
	self.opts.addAssociation("BookingItem", bookingRef4.allBookingRefItems.first);
	prenote4 := self.addPrenoted(TestCargoId1);
	self.opts.addAssociation("BookingItem", bookingRef5.allBookingRefItems.first);
	onsite := self.addPrenoted(TestCargoId1);
	self.opts.addAssociation("BookingItem", bookingRef6.allBookingRefItems.first);
	onship := self.addPrenoted(TestCargoId1);
	
	beginTransaction;
	prenote1.setMyVoyage(voyage, passport);
	prenote1.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	prenote1.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	prenote1.setPropertyValue(CM_TrackedItem::remarks.name, "Prenote Remarks");
	prenote1.setAlternativeId("UT63113-01");
	prenote1.setDestinationPort("NZAKA");
	prenote1.setWeightCargo(2000.0000);
	prenote1.setWeightTare(200.0000);
	prenote1.setTotalWeightWithoutTrans(2200.0000);
	prenote1.CM_BreakBulkGeneric.setGrammage(360.0000);
	prenote1.CM_BreakBulkGeneric.setGrade("FIRST");
	prenote1.CM_BreakBulkGeneric.setDiameter(1000.000);
	prenote1.CM_BreakBulkGeneric.setRollingLength(12345.0000);
	prenote1.setHeight(200.000);
	prenote1.setWidth(150.000);
	prenote1.setLength(5000.000);

	prenote2.setMyVoyage(voyage, passport);
	prenote2.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	prenote2.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	prenote2.setPropertyValue(CM_TrackedItem::remarks.name, "Prenote Remarks");
	prenote2.setAlternativeId("UT63113-02");
	prenote2.setDestinationPort("NZAKA");
	prenote2.setWeightCargo(2000.0000);
	prenote2.setWeightTare(200.0000);
	prenote2.setTotalWeightWithoutTrans(2200.0000);
	prenote2.CM_BreakBulkGeneric.setGrammage(360.0000);
	prenote2.CM_BreakBulkGeneric.setGrade("FIRST");
	prenote2.CM_BreakBulkGeneric.setDiameter(1000.000);
	prenote2.CM_BreakBulkGeneric.setRollingLength(12345.0000);
	prenote2.setHeight(200.000);
	prenote2.setWidth(150.000);
	prenote2.setLength(5000.000);
	
	prenote3.setMyVoyage(voyage, passport);
	prenote3.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	prenote3.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	prenote3.setPropertyValue(CM_TrackedItem::remarks.name, "Prenote Remarks");
	prenote3.setAlternativeId("UT63113-03");
	prenote3.setDestinationPort("NZAKA");
	prenote3.setWeightCargo(2000.0000);
	prenote3.setWeightTare(200.0000);
	prenote3.setTotalWeightWithoutTrans(2200.0000);
	prenote3.CM_BreakBulkGeneric.setGrammage(360.0000);
	prenote3.CM_BreakBulkGeneric.setGrade("FIRST");
	prenote3.CM_BreakBulkGeneric.setDiameter(1000.000);
	prenote3.CM_BreakBulkGeneric.setRollingLength(12345.0000);
	prenote3.setHeight(200.000);
	prenote3.setWidth(150.000);
	prenote3.setLength(5000.000);
	
	prenote4.setMyVoyage(voyage, passport);
	prenote4.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	prenote4.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	prenote4.setPropertyValue(CM_TrackedItem::remarks.name, "Prenote Remarks");
	prenote4.setAlternativeId("UT63113-04");
	prenote4.setDestinationPort("NZAKA");
	prenote4.setWeightCargo(2000.0000);
	prenote4.setWeightTare(200.0000);
	prenote4.setTotalWeightWithoutTrans(2200.0000);
	prenote4.setHeight(200.000);
	prenote4.setWidth(150.000);
	prenote4.setLength(5000.000);
	
	onsite.setMyVoyage(voyage, passport);
	onsite.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	onsite.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	onsite.setPropertyValue(CM_TrackedItem::remarks.name, "Prenote Remarks");
	onsite.setAlternativeId("UT63113-05");
	onsite.setDestinationPort("NZAKA");
	onsite.setWeightCargo(2000.0000);
	onsite.setWeightTare(200.0000);
	onsite.setTotalWeightWithoutTrans(2200.0000);
	onsite.setHeight(200.000);
	onsite.setWidth(150.000);
	onsite.setLength(5000.000);
	
	onship.setMyVoyage(voyage, passport);
	onship.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	onship.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	onship.setPropertyValue(CM_TrackedItem::remarks.name, "Prenote Remarks");
	onship.setAlternativeId("UT63113-05");
	onship.setDestinationPort("NZAKA");
	onship.setWeightCargo(2000.0000);
	onship.setWeightTare(200.0000);
	onship.setTotalWeightWithoutTrans(2200.0000);
	onship.setHeight(200.000);
	onship.setWidth(150.000);
	onship.setLength(5000.000);
	commitTransaction;
	
	self.assertEqualMsg(voyage.allNotifiedTIsByIdCargoType.size, 6, "Voyage has wrong number of prenotes");

	//updating a prenote when more than one prenote with the same ID exists (when the Prenote uniqueness by booking reference terminal config option is set) and the prenotes have different booking references
		
	//Scenario 1 - Not passing booking Id
	params := "/Cargo/" &amp; TestCargoId &amp; "/" &amp; cargoType.abbreviation &amp; "/" &amp; '3' &amp; "?MasterTerminalAPI";
	
	incomingJsonString := IncomingStringJSON;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :96691. There are multiple prenotes found for Cargo Id : " &amp; TestCargoId &amp; " and Cargo Type : " &amp; TestCargoType &amp; ", please provide booking Id to uniquely identify the cargo");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	
	//Scenario 2 - Passing Invalid booking Id
	//params := "/Cargo/" &amp; TestCargoId &amp; "/" &amp; TestCargoType &amp; "/" &amp; '3' &amp; "/" &amp; "TESTBOOKING?MasterTerminalAPI";
	params := "/Cargo/" &amp; TestCargoId &amp; "/" &amp; TestCargoType  &amp; "/" &amp; '3' &amp; "?MasterTerminalAPI&amp;bookingId=TESTBOOKING";
	
	incomingJsonString := IncomingStringJSON;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :82661. Item not found");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	
	//Scenario 3 - Passing valid booking Id
	params := "/Cargo/" &amp; TestCargoId &amp; "/" &amp; TestCargoType  &amp; "/" &amp; '3' &amp; "?MasterTerminalAPI&amp;bookingId=" &amp; UTBookingRef3;
	
	incomingJsonString := IncomingStringJSON;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	
	realTI := self.getPrenotedCargoByBookingId(TestCargoId,TestCargoType ,UTSuccessBookingRef);
	assertEqual(realTI.alternativeId.toUpper,UTSuccessUpdatedAlt.toUpper);
	
	bs := self.getTerminalArea(ThisBlockStack);
	self.assertTrueMsg(bs = null, "Terminal Area " &amp; ThisBlockStack &amp; " not deleted");
	bs := self.addBlockStack (ThisBlockStack, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; ThisBlockStack &amp; ' failed');
	beginTransaction;
	lc := self.getTerminal.lookupTerminalArea(ThisBlockStack).allLocationsControllers.first;
	onsite.moveToLocation(lc, null, null, null, REAL_MODE, true, false, false, false, false,  false, null, null, null, null,null,app.myPassport);
	commitTransaction;
	
	self.moveCargo(onship, null, voyage.allVoyageLocations.first(), app.myPassport);
	
	//updating a prenote when cargo with the same id and cargo type exists on site and on ship
	params := "/Cargo/" &amp; TestCargoId1 &amp; "/" &amp; TestCargoType  &amp; "/" &amp; '3' &amp; "?MasterTerminalAPI&amp;bookingId=" &amp; UTBookingRef4;
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		json := IncomingStringJSON1.replace("&lt;Priority&gt;", "P2");
	elseif app.isRunningInWMAST() then
		json := IncomingStringJSON1.replace("&lt;Priority&gt;", "CP2");
	endif;
	// end navlw1 #65030

	incomingJsonString := json;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	
	realTI := self.getPrenotedCargoByBookingId(TestCargoId1,TestCargoType ,UTSuccessBookingRef1);
	assertEqual(realTI.alternativeId.toUpper,UTSuccessUpdatedAlt1.toUpper);
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		assertEqual(realTI.myCustomerPriority.code,"P2");	//17.06.24	navhn30 TFS #64067
	elseif app.isRunningInWMAST() then 
		assertEqual(realTI.myCustomerPriority.code,"CP2");
	endif;
	assertEqual(realTI.shipmentNumber, "HN31");
	
	//updating an on ship cargo item when prenotes and cargo on site with the same id and cargo type exist
	params := "/Cargo/" &amp; TestCargoId1 &amp; "/" &amp; TestCargoType  &amp; "/" &amp; '5' &amp; "?MasterTerminalAPI";
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		json := IncomingStringJSON2.replace("&lt;Priority&gt;", "P1");
	elseif app.isRunningInWMAST() then 
		json := IncomingStringJSON2.replace("&lt;Priority&gt;", "CP1");
	endif;
	// end navlw1 #65030
	
	incomingJsonString := json;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	
	realTI := self.getOnshipCargo(TestCargoId1,TestCargoType);
	assertEqual(realTI.alternativeId.toUpper,UTSuccessUpdatedAlt1.toUpper);
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		assertEqual(realTI.myCustomerPriority.code,"P1");	//17.06.24	navhn30 TFS #64067
	elseif app.isRunningInWMAST() then 
		assertEqual(realTI.myCustomerPriority.code,"CP1");
	endif;
	// end navlw1 #65030
	assertEqual(realTI.shipmentNumber, "HN30");

	//Start - 22.04.2024 naviv1	#63619 - POST &amp; PUT / Cargo API - Prenotified Trailer Cargo with Onboarded cargo and customs references
	self.deleteCargo("TEST6361904","UTMAFI");
	self.deleteCargo("CH-63619-04","PAPER");
	incomingJsonString := PostJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("CH-63619-04");
	assertEqual(realTI.allCustomsReferences.size, 1);
	
	realTI := self.getTrackedItem("TEST6361904");
	assertEqual(realTI.allCustomsReferences.size, 1);
	assertEqual(realTI.alternativeId, "6361904-ALT");
	assertEqual(realTI.getImExStatus, TI_IMEX_STATUS_EXPORT);
	assertEqual(realTI.totalWeight, 5000.Decimal);
	assertEqual(realTI.bookingReference, "BK-63619-04");
	assertEqual(realTI.isPreNote, true);
	assertEqual(realTI.operatorCode, "UTOP");
	assertEqual(realTI.voyageCode,ThisVoyage);
	
	incomingJsonString := IncomingJsonString4;
	expectFailure := false;
	params := "/Cargo/TEST6361904/UTMAFI/3?MasterTerminalAPI&amp;bookingId=" &amp; UTRealBooking;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	
	realTI := self.getTrackedItem("CH-63619-04");
	assertEqual(realTI.allCustomsReferences.size, 2);
	realTI := self.getTrackedItem("TEST6361904");
	assertEqual(realTI.allCustomsReferences.size, 2);
	assertEqual(realTI.alternativeId.toUpper, "6361904-ALT-updated".toUpper);
	assertEqual(realTI.getImExStatus, TI_IMEX_STATUS_EXPORT);
	assertEqual(realTI.totalWeight, 5000.Decimal);
	assertEqual(realTI.bookingReference.toUpper, "BK-63619-04".toUpper);
	assertEqual(realTI.isPreNote, true);
	assertEqual(realTI.operatorCode.toUpper, "UTOP");
	assertEqual(realTI.voyageCode,ThisVoyage);
	//End - 22.04.2024 naviv1	#63619 - POST &amp; PUT / Cargo API - Prenotified Trailer Cargo with Onboarded cargo and customs references
	
	//17.06.24	navhn30 	TFS #64067		Start
	self.deleteBooking("1236"); // navlw1 #64910
	self.deleteCargo("TESTONSI01","REBAR");
	
	incomingJsonString := OnsiteCargoJson;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);

	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		json := UpdatedOnsiteCargoJson.replace("&lt;Priority&gt;", "P3");
	elseif app.isRunningInWMAST() then 
		json := UpdatedOnsiteCargoJson.replace("&lt;Priority&gt;", "CP3");
	endif;
	// end navlw1 #65030
	
	incomingJsonString := json;
	expectFailure := false;
	params := "/Cargo/TESTONSI01/REBAR/1?MasterTerminalAPI&amp;bookingId=1236";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	realTI := self.getTrackedItem("TESTONSI01");
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		assertEqual(realTI.myCustomerPriority.code,"P3");	//17.06.24	navhn30 TFS #64067
	elseif app.isRunningInWMAST() then  
		assertEqual(realTI.myCustomerPriority.code,"CP3");
	endif;
	// end navlw1 #65030
	
	assertEqual(realTI.shipmentNumber, "HN33");
	//17.06.24	navhn30 	TFS #64067		End

// 14.08.2024	navhn30	TFS #65220 	START

	self.deleteCargo("TEST01","UTMAFI");
	self.deleteCargo("CHILD01","PAPER");
	incomingJsonString := PostPrenoteJson;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("CHILD01");
	assertNotNull(realTI);
	
	realTI := self.getTrackedItem("TEST01");
	assertNotNull(realTI);
	
	params := "/Cargo/" &amp; "TEST01" &amp; "/" &amp; "UTMAFI"  &amp; "/" &amp; '3' &amp; "?MasterTerminalAPI";
	
	incomingJsonString := UpdatePrenoteJson;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	realTI := self.getTrackedItem("TEST01-C");
	assertNotNull(realTI);
	
	self.deleteCargo("TEST02","UTMAFI");
	self.deleteCargo("CHILD02","PAPER");
	incomingJsonString := PostOnshipJson;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);

	realTI := self.getTrackedItem("TEST02");
	assertNotNullMsg(realTI, "Parent not created");
	realTI := self.getTrackedItem("CHILD02");
	assertNotNullMsg(realTI, "child not created");
	
	params := "/Cargo/" &amp; "TEST02" &amp; "/" &amp; "UTMAFI"  &amp; "/" &amp; '5' &amp; "?MasterTerminalAPI";

	incomingJsonString := UpdateOnshipJson;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	realTI := self.getTrackedItem("TEST02-C");
	assertNotNull(realTI);
	
	self.deleteCargo("TEST03","UTMAFI");
	self.deleteCargo("CHILD03","PAPER");
	incomingJsonString := PostOnsiteJson;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);

	realTI := self.getTrackedItem("TEST03");
	assertNotNullMsg(realTI, "Parent not created");
	self.assertEqualMsg(realTI.CM_TILC.allLCs.first.allTrackedItems.size, 1, "MAFI has no onboard cargo");
	realTI := self.getTrackedItem("CHILD03");
	assertNotNullMsg(realTI, "child not created");
	
	params := "/Cargo/" &amp; "TEST03" &amp; "/" &amp; "UTMAFI"  &amp; "/" &amp; '1' &amp; "?MasterTerminalAPI";

	incomingJsonString := UpdateOnsiteJson;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	realTI := self.getTrackedItem("TEST03-C");
	assertNotNull(realTI);
	// Trying to update onBoard Cargo location with invalid locationId "XYZ"
	realTI := self.getTrackedItem("CHILD03");		// 17.09.2024	navhn30	 TFS #65980
	assertNotNull(realTI);
	self.assertEqual(realTI.locationId, "TEST03-C 1");
	// Trying to update parent Cargo location with invalid locationId "ABC"
	realTI := self.getTrackedItem("TEST02-C");		// 17.09.2024	navhn30	 TFS #65980
	assertNotNull(realTI);
	self.assertEqual(realTI.locationId, realTI.voyageCode);
// 14.08.2024	navhn30	TFS #65220 END

    //Create a cargo onsite                                                                     //JIRA-34865 - START &gt;&gt;&gt;&gt;
    self.deleteCargo("UTTI3486501","CONT");
    incomingJsonString := PostOnsiteJsonWithStops;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
    realTI := self.getTrackedItem("UTTI3486501");
    assertNotNull(realTI);
    
    //Update Cargo with CEDO stops
    params := "/Cargo/" &amp; "UTTI3486501" &amp; "/" &amp; "CONT"  &amp; "/" &amp; '1' &amp; "?MasterTerminalAPI";
    incomingJsonString := PutOnsiteJsonWithStops;
    expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	realTI := self.getTrackedItem("UTTI3486501");
	assertNotNull(realTI);
    
    //Clear STOPS / Expects failure 
    params := "/Cargo/" &amp; "UTTI3486501" &amp; "/" &amp; "CONT"  &amp; "/" &amp; '1' &amp; "?MasterTerminalAPI";
    incomingJsonString := PutOnsiteJsonWithStopsClear;
    expectFailure := true;
    self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :79989. Cannot clear Stop Customs Export (CEDO) for cargo item UTTI3486501 as it requires additional information before it can be cleared.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	realTI := self.getTrackedItem("UTTI3486501");
	assertNotNull(realTI);
    
    //Clear STOP with 'requiredInfo'
    params := "/Cargo/" &amp; "UTTI3486501" &amp; "/" &amp; "CONT"  &amp; "/" &amp; '1' &amp; "?MasterTerminalAPI";
    incomingJsonString := PutOnsiteJsonWithStopsClearWithReqInfo;
    expectFailure := false;
    self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString,params,expectFailure);
	realTI := self.getTrackedItem("UTTI3486501");
    assertEqualMsg(realTI.customExportEntryNumber, "**REQUIRED INFO MSG**", "Required info string mismatch");
	assertNotNull(realTI);                                                                      //JIRA-34865 - END &lt;&lt;&lt;&lt;
    
epilog
	self.setTerminalConfig(IsSubTerminalsOn, isSubTerminalsOn);
	self.setTerminalConfig(PrenoteUniqBooking, prenoteUniqBooking);
end;</source>
    </JadeMethod>
    <JadeMethod name="tPutCargoUpdate" id="3d5a17a1-d88e-4be9-9366-1d7d118f2c94">
        <source>tPutCargoUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jan 2024	naviv1	Initial creation - TFS-57211
01 Feb 2024	naviv1	Change Request-57211 - CUX - MTN-EDBIC - 070 &amp; 090 - PUT Cargo Update
11 Mar 2024 naviv1	Bug 62829 : CUX | PUT CargoUpdate Issue on Prenotified Cargos
*/
constants
	TestCargoId : String = "UTPCU57211";
	IncomingJsonString = '
	[{
    "cargoIdentifiers": {
      "id": "UTPCU57211",
      "cargoTypeId": "CONT",
      "state": 3,
      "alternativeId": "",
      "bookingId": "",
      "voyageId": "",
      "locationId": "",
      "operatorId": "",
      "consigneeId": "",
      "consignorId": ""
    },
    "updates": [
      {
        "op": "add",
        "field": "alternativeId",
        "value": "CARGOTEST04"
      },
	  {
        "op": "add",
        "field": "consigneeId",
        "value": "HYD"
      },
	  {
        "op": "replace",
        "field": "imexStatus",
        "value": "IMP"
      },
	   {
        "op": "add",
        "field": "weights.gross",
        "value": "2500"
      }
    ]
  }]';
vars
	realTI		: CM_TrackedItem;
	terminal			: CM_Terminal;
	cargoId 			: String;
	incomingJsonString,
	terminalCode,
	loginJson			: String;
	expectFailure		: Boolean;
	bs					: CM_BlockStack;
	isSubTerminalsOn	: Any;
begin
	
	isSubTerminalsOn := self.setTerminalConfig(IsSubTerminalsOn, false);
	cargoId := TestCargoId;
	self.deleteContainer(cargoId);
	self.deleteTrackedItem(cargoId, true);
	terminal := self.getTerminal();
	
	//Creation of new tracked item
	bs := self.addBlockStack("UT57211", 99, null);
	realTI := self.createTrackedItem(cargoId,TI_CargoType_Container, "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, bs.myLocationsController);
	self.assertNoTrxErrorsOrWarnings();
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("State", TI_STATE_NOTIFIED);
	self.updateTI(realTI);
	self.assertNoTrxErrorsOrWarnings();
		
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	incomingJsonString := IncomingJsonString;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoUpdate.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem(cargoId);
	assertEqual(realTI.alternativeId, "CARGOTEST04");
	assertEqual(realTI.consignee, "HYD");
	assertEqual(realTI.getImExStatus, TI_IMEX_STATUS_IMPORT);
	assertEqual(realTI.totalWeight, 2500.Decimal);
	assertEqual(realTI.state, TI_STATE_NOTIFIED);	//11.03.2024 naviv1 #62829
epilog
	self.setTerminalConfig(IsSubTerminalsOn, isSubTerminalsOn);
end;</source>
    </JadeMethod>
    <JadeMethod name="tPutInvoiceExternalReference" id="6a92bbdc-91a8-4264-9a19-ff74bdf08cdb">
        <source>tPutInvoiceExternalReference();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/01/2026	navkc1 JIRA MTN 36571 - ROS - 2 - External Reference updates in API

*/
constants
	INVTYPE			= "UT35590T";
	INVLINETYPE1	= "UT35590LT1";
	INVLINETYPE2	= "UT35590LT2";
	UTCALCT 		= 'ROTACALCT';
	UTSERVICE1		= 'UTROTASVC1';
	UTSERVICE2		= 'UTROTASVC2';
	
	NoErrorOutput = '{"allErrors":null,"allInfo":null,"allWarnings":null,"header":{"externalFinancialID":"UTAPIEXT","externalNumber":"UPDATED","externalReferences":[{"cargoSubType":"","cargoType":"","commodity":"","contractID":"","externalRef1":"UpdatedExt1","externalRef2":"UpdatedExt2","externalRef3":"UpdatedExt3","externalRef4":"","invoiceLineType":"UT35590LT1","numberOfLines":2,"rate":4.400000,"total":8.800000},{"cargoSubType":"","cargoType":"","commodity":"","contractID":"","externalRef1":"","externalRef2":"","externalRef3":"","externalRef4":"","invoiceLineType":"UT35590LT2","numberOfLines":2,"rate":5.500000,"total":11.000000},{"cargoSubType":"","cargoType":"","commodity":"","contractID":"1","externalRef1":"","externalRef2":"","externalRef3":"","externalRef4":"","invoiceLineType":"UT35590LT2","numberOfLines":2,"rate":5.500000,"total":11.000000}],"externalTaxNumber":"","numberOfLines":6,"total":30.800000},"invoiceID":"UTAPIEXT"}';
	ExpectedOutput = '{"allErrors":null,"allInfo":null,"allWarnings":null,"header":{"externalFinancialID":"UTAPIEXT","externalNumber":"UPDATED","externalReferences":[{"cargoSubType":"","cargoType":"","commodity":"","contractID":"","externalRef1":"UpdatedExt1","externalRef2":"UpdatedExt2","externalRef3":"UpdatedExt3","externalRef4":"","invoiceLineType":"UT35590LT1","numberOfLines":2,"rate":4.400000,"total":8.800000},{"cargoSubType":"","cargoType":"","commodity":"","contractID":"","externalRef1":"","externalRef2":"","externalRef3":"","externalRef4":"","invoiceLineType":"UT35590LT2","numberOfLines":2,"rate":5.500000,"total":11.000000},{"cargoSubType":"","cargoType":"","commodity":"","contractID":"1","externalRef1":"","externalRef2":"","externalRef3":"","externalRef4":"","invoiceLineType":"UT35590LT2","numberOfLines":2,"rate":5.500000,"total":11.000000}],"externalTaxNumber":"","numberOfLines":6,"total":30.800000},"invoiceID":"UTAPIEXT"}';
	
vars
	request,
	params,
	response		: String;
	expectErrors	: Boolean;
	
	cmifHeader 		: CMIF_InvoiceExternalRefHeader;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2	: CM_InvoiceLineDesc;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	inv				: CM_Invoice;
	invLine			: CM_InvoiceLine;
	invLineGrp1,
	invLineGrp2,
	invLineGrp3		: CM_InvoiceLineBySeqNumDict;
	calcType		: CM_CalculationType;
	term			: CM_Terminal;
	bank			: CM_Bank;
	now				: TimeStamp;
	
begin
	
	// Get Terminal
		term := self.getMyTerminal();
	
	// Get Bank
		bank := term.getDefaultCompanyBank();
	
	// Get Invoice Type
		self.deleteInvoiceType(INVTYPE);
		self.opts.purge();
		self.opts.addAssoc("AllowManEditExtRef", true);
		invType := self.createInvoiceType(INVTYPE, InvoiceTypeGeneral);
	
	// Get Debtor
		debtorNode := self.getRootDebtor().CM_DebtorNode;
		debtor := debtorNode.allChildDebtorNodes.first().CM_Debtor;
		self.assertNotNullMsg(debtor, "Failed to get a debtor");
	
	// Get Calculation Type
		self.deleteCalculationType(UTCALCT, NORMAL_ERASE);
		calcType := self.addCalculationType(INV_CALC_TYPE_QUANTITY, UTCALCT, UTCALCT, null, null, null, null, null, null, null, true, null, null, null, null, null, null);
	
	// Get INvoice Line Type 1
		self.createInvoiceLineAndRate(invType, UTSERVICE1, INVLINETYPE1, calcType.code, 'SDT1', 4.4);
		self.assertNoTrxErrorsOrWarnings();
		invLineType1 := self.getInvoiceLineType(INVLINETYPE1);
		self.assertNotNullMsg(invLineType1, "Failed to get Invoice Line Type 1");
	
	// Get INvoice Line Type 2
		self.createInvoiceLineAndRate(invType, UTSERVICE2, INVLINETYPE2, calcType.code, 'SDT1', 5.5);
		self.assertNoTrxErrorsOrWarnings();
		invLineType2 := self.getInvoiceLineType(INVLINETYPE2);
		self.assertNotNullMsg(invLineType2, "Failed to get Invoice Line Type2 ");
	
	// Create invoice
		inv := self.createManualInvoice(bank, debtor, null, invType, null);
	
	// Create Invoice Lines
		// Grouped 1 by
			// Invoice Line Type - invLineType1
			// Rate - 4.4
			// COntract ID - null
		create invLineGrp1 transient;
		invLine := self.createManualInvoiceLine(invLineType1, inv, 1, "1", now.date());
		invLineGrp1.add(invLine);
		invLine := self.createManualInvoiceLine(invLineType1, inv, 1, "1", now.date());
		invLineGrp1.add(invLine);
	
		// Grouped 2 by
			// Invoice Line Type - invLineType2
			// Rate - 5.5
			// COntract ID - null
		create invLineGrp2 transient;
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		invLineGrp2.add(invLine);
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		invLineGrp2.add(invLine);
	
	// Grouped 3 by
			// Invoice Line Type - invLineType2
			// Rate - 5.5
			// COntract ID - "1"
		create invLineGrp3 transient;
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		beginTransaction;
			invLine.setContractId("1");
		commitTransaction;
		invLineGrp3.add(invLine);
		invLine := self.createManualInvoiceLine(invLineType2, inv, 1, "1", now.date());
		beginTransaction;
			invLine.setContractId("1");
		commitTransaction;
		invLineGrp3.add(invLine);
	
	// Manually set Invoice External Financial ID so we can get it easily from API;
		beginTransaction;
			inv.setExternalFinancialId("UTAPIEXT");
		commitTransaction;
	
	// Send request
		request := '{"header":{"externalFinancialID":"UTAPIEXT","externalNumber":"UPDATED","externalReferences":[{"cargoSubType":"","cargoType":"","commodity":"","contractID":"","externalRef1":"UpdatedExt1","externalRef2":"UpdatedExt2","externalRef3":"UpdatedExt3","externalRef4":"","invoiceLineType":"UT35590LT1","numberOfLines":2,"rate":4.400000,"total":8.800000},{"cargoSubType":"","cargoType":"","commodity":"","contractID":"","externalRef1":"","externalRef2":"","externalRef3":"","externalRef4":"","invoiceLineType":"UT35590LT2","numberOfLines":2,"rate":5.500000,"total":11.000000},{"cargoSubType":"","cargoType":"","commodity":"","contractID":"1","externalRef1":"","externalRef2":"","externalRef3":"","externalRef4":"","invoiceLineType":"UT35590LT2","numberOfLines":2,"rate":5.500000,"total":11.000000}],"externalTaxNumber":"","numberOfLines":6,"total":30.800000},"invoiceID":"UTAPIEXT"}';
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutInvoiceExternalRef.name, request, params, response, expectErrors);
	
	// Check response;
		self.assertEqualMsg(response, NoErrorOutput, "putInvoiceExternalRef response is not as expected");
	
	// Send request to get the latest info
		params := '?MasterTerminalAPI&amp;invoiceID=UTAPIEXT&amp;businessUnitID=DFBU';
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetInvoiceExternalRef.name, request, params, response, expectErrors);
	
	// Check response, it should have the updated information
		self.assertEqualMsg(response, ExpectedOutput, "Response is not as expected");
	
epilog
	self.deleteService(UTSERVICE1);
	self.deleteService(UTSERVICE2);
	self.deleteInvoiceLineType(INVLINETYPE1, NORMAL_ERASE);
	self.deleteInvoiceLineType(INVLINETYPE2, NORMAL_ERASE);
	self.deleteInvoice(inv);
	self.deleteInvoiceType(INVTYPE);
	if invLineGrp1 &lt;&gt; null then
		invLineGrp1.purge();
		delete invLineGrp1;
	endif;
	
	if invLineGrp2 &lt;&gt; null then
		invLineGrp2.purge();
		delete invLineGrp2;
	endif;
	
	if invLineGrp3 &lt;&gt; null then
		invLineGrp3.purge();
		delete invLineGrp3;
	endif;
	
	delete cmifHeader;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPutProformaAmount" id="46cf1541-ce0d-4fa6-8a04-7e5ec1f4021c">
        <updating/>
        <source>tPutProformaAmount() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/
constants
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "CASHAPITI";
	TRANMAP = "CASHAPI";
vars
	response,
	queryParam,
	loginJson,
	voyCode,
	bolCode,
	cargoIDs,
	cen,
	agentId			: String;
	
	today,
	effectiveDate,
	shipReleaseDate : Date;
	
	queryRecNumber,
	receiptNumber	: String;
	totalAmount		: Decimal[23,6];
	
	expectFailure 	: Boolean;
	
	tm				: CM_TranMap;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	ti				: CM_TrackedItem;
	
	debtorType		: CM_DebtorType;
	
	customagent		: CM_CustomsAgent;
	
	terminal		: CM_Terminal;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	
	bank			: CM_Bank;
	
	proxyCriteria	: CM_YACriteria;
	proxyProCrit 	: CM_ProformaTransactionCriteria;
	realProCrit 	: CM_ProformaTransactionCriteria;
	itemCode 		: String;
	value 			: Any;
	criterias		: CMIF_Array;
	cmifCriteria 	: CMIF_YACriteriaPriority;
	selectedTrxTypes: CM_TransactionTypeByType;
	critType 		: CM_YACriteriaType;
	
	cashReceipt		: CM_CashReceipt;
	fileContext		: String;
	pxyTransService : CM_TransServiceBroker;
begin
	//return;
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; "UT" &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// Terminal
	terminal := self.getMyTerminal();
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT1", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Custom Agent is null");
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 6);
	self.setTerminalConfig(FinancialRateDPlaces, 6);
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	self.assertNotNullMsg(tm, "CASHAPI Transaction Map is null");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,All,UTCASHAPI';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Debtor type is null");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[30] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "voyage is null");
	
	// Create cargo
	ti := self.getTrackedItem(CARGOID &amp; today.asStringJMT());
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	ti := self.addCargoForVoyage(voyage, CARGOID &amp; today.asStringJMT());
	self.assertNotNullMsg(ti, "TI is null");
	self.editIMEXStatus(ti, TI_IMEX_STATUS_IMPORT, true);
	
	cen := "UTCEN";
	
	beginTransaction;
	ti.setCustomsEntryNumber(cen);
	ti.setCustomsAgent(customagent);
	commitTransaction;
	
	// Do API
	voyCode := voyage.code;
	today := app.actualTimeServer().date();
	effectiveDate := today.addDays(5);
	agentId := customagent.code;
	
	queryParam := "?MasterTerminalAPI&amp;voyageId="&amp;voyCode&amp;"&amp;bolId="&amp;bolCode&amp;"&amp;cargoIds="&amp;cargoIDs&amp;"&amp;effectiveDate="&amp;effectiveDate.asStringJMT()&amp;"&amp;shipReleaseDate="&amp;shipReleaseDate.asStringJMT()&amp;"&amp;customsEntryNumber="&amp;cen&amp;"&amp;agentID="&amp;agentId&amp;"&amp;totalAmount=12.551495";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaAmount.name, loginJson, queryParam, response, receiptNumber, expectFailure);
	
	// Verify response
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	self.assertTrueMsg(receiptNumber &lt;&gt; null, "No receipt number created");
	
	// Get Cash Receipt header
	queryParam := "?MasterTerminalAPI&amp;debtorID="&amp;debtor.code&amp;"&amp;fromDate="&amp;today.asStringJMT()&amp;"&amp;toDate="&amp;today.asStringJMT();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetProformaHeader.name, loginJson, queryParam, response, queryRecNumber, totalAmount, expectFailure);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	self.assertTrueMsg(queryRecNumber = receiptNumber, "Receipt number from Query does not match with the receipt generated");
	self.assertTrueMsg(totalAmount = 12.551495, "Receipt amount not equals to amount paid");
	
	// Get Cash Payment Details
	queryParam := "?MasterTerminalAPI&amp;debtorID="&amp;debtor.code&amp;"&amp;receiptNumber="&amp;receiptNumber;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetProformaDetails.name, loginJson, queryParam, response, totalAmount, expectFailure);
	self.assertTrueMsg(totalAmount = 12.551495, "Receipt amount not equals to amount paid");
	
epilog
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	
	cashReceipt := bank.allCashReceiptsById[receiptNumber];
	
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPutProformaForExternal" id="fd3ad3fe-f334-4093-b8c2-6584aeae9670">
        <updating/>
        <source>tPutProformaForExternal() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2024	navkc1 CR 64840 Task 64855: Jade - Cash API Unit Tests
13/02/2025	navkc1 JIRA Story MTN-33879: MTN | Cash API - Does Not Work With All Debtor Types
*/
constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "CASHAPITI";
	CARGOID2 = "CASHAPITI2";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";

vars
	cargoId,
	cargoId2,
	responseInString,
	loginJson,
	voyCode,
	agentId			: String;
	
	today,
	effectiveDate : Date;
	
	totalAmount		: Decimal[23,6];
	
	expectFailure 	: Boolean;
	
	tm				: CM_TranMap;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	ti,
	ti2				: CM_TrackedItem;
	
	debtorType		: CM_DebtorType;
	
	customagent		: CM_CustomsAgent;
	
	terminal		: CM_Terminal;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	
	bank			: CM_Bank;
	
	proxyCriteria	: CM_YACriteria;
	proxyProCrit 	: CM_ProformaTransactionCriteria;
	realProCrit 	: CM_ProformaTransactionCriteria;
	itemCode 		: String;
	value 			: Any;
	criterias		: CMIF_Array;
	cmifCriteria 	: CMIF_YACriteriaPriority;
	selectedTrxTypes: CM_TransactionTypeByType;
	critType 		: CM_YACriteriaType;
	
	fileContext		: String;
	pxyTransService : CM_TransServiceBroker;
	
	receiptNumber	: Integer;
	request			: String;
	isPaymentAllowed : Boolean;
	cashReceipt,
	cashReceipt2,
	cashReceiptForBoth	: CM_CashReceipt;
	offlineActor	: CM_OfflineFutureActor;
	cashPayment		: CM_CashPayment;
begin
	//return;
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; "UT" &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// Terminal
	terminal := self.getMyTerminal();
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Custom Agent is null");
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 6);
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	 // 25/07/2025	navkc1	JIRA MTN-35344
	if tm &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		tm := null;
	endif;
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	self.assertNotNullMsg(tm, "CASHAPI Transaction Map is null");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ?,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ?,(Default),,,**Any**,All,UTCASHAPI';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Debtor type is null");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[30] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "voyage is null");
	cargoId := CARGOID&amp;today.asStringJMT();
	cargoId2 := CARGOID2&amp;today.asStringJMT();
	
	// Create cargo 1
	ti := self.getTrackedItem(cargoId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Create cargo 2
	ti2 := self.getTrackedItem(cargoId2);
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 1
	ti := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti, "TI is null");
	self.editIMEXStatus(ti, TI_IMEX_STATUS_IMPORT, true);
	beginTransaction;
	ti.setCustomsAgent(customagent);
	ti.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	// Cargo 2
	ti2 := self.addCargoForVoyage(voyage, cargoId2);
	self.assertNotNullMsg(ti2, "TI2 is null");
	self.editIMEXStatus(ti2, TI_IMEX_STATUS_IMPORT, true);
	beginTransaction;
	ti2.setCustomsAgent(customagent);
	ti2.setCustomsEntryNumber(CEN2);
	commitTransaction;
	
	voyCode := voyage.code;
	today := app.actualTimeServer().date();
	effectiveDate := today.addDays(5);
	agentId := customagent.code;
	
	/*
	Scenario 1 - Missing Param - Should get error message
	*/	
	request := '{
						"bolCode" : "",
						"cargoID" : "",
						"customsAgentCode" : "",
						"customsEntryNumber" : "",
						"effectiveDate" : "",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for scenario 1
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);

	// Verify response Scenario 1 - Missing Param Should get error message
	//self.assertTrueMsg(responseInString.pos('\"customsEntryNumber\" cannot be null.', 1) &gt; 0, "custsomEntryNumber required fields error not found"); //13/02/2025	navkc1 JIRA Story MTN-33879
	self.assertTrueMsg(responseInString.pos('\"customsAgentCode\" cannot be null', 1) &gt; 0, "customsAgentCode required fields error not found");
	//self.assertTrueMsg(responseInString.pos('\"voyageCode\" and \"customsEntryNumber\" cannot be both null. Either \"voyageCode\" or \"customsEntryNumber\" must be entered.', 1) &gt; 0, "voyageCode and customsEntryNumber required fields error not found"); //13/02/2025	navkc1 JIRA Story MTN-33879
	self.assertTrueMsg(responseInString.pos('\"externalUserCode\" cannot be null', 1) &gt; 0, "externalUserCode required fields error not found");
	self.assertTrueMsg(responseInString.pos('\"effectiveDate\" cannot be null', 1) &gt; 0, "effectiveDate required fields error not found");
	
	/*
	Scenario 2 - Good scenario - Cargo ID entered, Voyage code not entered. Should still get the CargoID from onsite and allActiveVoyage collection.
	*/

	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for scenario 2
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	// Verify response Scenario 2 - Good scenario - Should get cash receipt and amount
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[receiptNumber];
	cashPayment := cashReceipt.allCashPayments.first();
	self.assertNotNullMsg(cashPayment, "Failed to get the cash payment");
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt.cashValue = 12.551495, "Total amount is not correct"); //27/06/2025 NAVKC1 JIRA 35258
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
	self.assertTrueMsg(responseInString.pos('"rate":'&amp;cashPayment.getPaymentRate().String, 1) &gt; 0, "Rate in the response must be the same as Cash Payment Invoice Line"); //27/06/2025 NAVKC1 JIRA 35258
	
	/*
	Scenario 3 - Different external user code
	*/
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER2&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// call API for scenario 3
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	// Verify response Scenario 3 - Different external user code - Should get error
	self.assertTrueMsg(responseInString.pos('errorCode":96771,"text":"Cash Receipt API validation failed. '&amp; cargoId&amp;' is being processed by '&amp;EXTUSER1&amp;'"',1) &gt; 0, "Shoud get error other user processed the cashreceipt");
	self.assertTrueMsg(not isPaymentAllowed, "isPaymentAllowed should be false");
	
	app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	
	/*
	Scenario 4 - Good scenario. Voyage and Cargo ID entered.
	*/
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId2&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN2&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER2&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : "'&amp;VOYCODE&amp;'"
					}';
	// call API for scenario 4
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	// Verify response Scenario 4 - Good scenario Voyage and Cargo ID entered.
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[receiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt.cashValue = 12.551495, "Total amount is not correct"); //27/06/2025 NAVKC1 JIRA 35258
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
	
	// Take Cargo 2 - Check BGP
	offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
	self.assertNotNullMsg(offlineActor, "BGP not created for the draft receipt");
	
	app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	
	
	/* //01/10/2024 navkc1 JIRA 19366  - adding more scenario
	Scenario 5 - 
				Cargo 1 in draft receipt 1
				Cargo 2 in draft receipt 2
				
				Now if call the API for both Cargo 1 and Cargo 2, MTN should delete both current draft receipt, and create one for both cargo. I.e Cargo 1 and Cargo 2 in draft receipt 1
	*/
	// Cargo 1
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : "'&amp;VOYCODE&amp;'"
					}';
	// call API to create draft receipt for cargo 1
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[receiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt for Cargo 1 should not be null");
	// Cargo 2
	beginTransaction;
	ti2.allCustomsEntryNumbers.clear();
	ti2.setCustomsEntryNumber(CEN);
	commitTransaction;
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId2&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : "'&amp;VOYCODE&amp;'"
					}';
	// call API to create draft receipt for cargo 2
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt2 := debtorTerminal.allCashReceipts[receiptNumber];
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, "Cash receipt for Cargo 2 should not be null");
	// Now Cargo 1 is in cash receipt 1, Cargo 2 is in cash receipt 2
	// Do a API call again for Cargo 1 and Cargo 2 in a single request
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;','&amp;cargoId2&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : "'&amp;VOYCODE&amp;'"
					}';
	// call API to create draft receipt for both cargo
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceiptForBoth := debtorTerminal.allCashReceipts[receiptNumber];
	self.assertTrueMsg((cashReceipt = null or not app.isValidObject(cashReceipt)), "Cash Receipt 1 should be null/invalid, MTN should have delete it");
	self.assertTrueMsg((cashReceipt2 = null or not app.isValidObject(cashReceipt2)), "Cash Receipt 2 should be null/invalid, MTN should have delete it");
	self.assertTrueMsg(cashReceiptForBoth &lt;&gt; null, "Cash receipt for both should not be null");
	self.assertTrueMsg(cashReceiptForBoth.cashValue = 25.10299, "Total amount of Cash Receipt for both is not correct"); //27/06/2025 NAVKC1 JIRA 35258
	
	app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	
	/*
	Scenario 6 - Missing Customs Param when Customs Agent is selected in the Cash Config - Should get error message
	*/	
	request := '{
						"bolCode" : "",
						"cargoID" : "",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for scenario 1
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);

	// Verify response Scenario 1 - Missing Param Should get error message
	self.assertTrueMsg(responseInString.pos('\"voyageCode\" and \"customsEntryNumber\" cannot be null. \"customsEntryNumber\" must be entered at least.', 1) &gt; 0, "voyageCode and customsEntryNumber required fields error not found"); //13/02/2025	navkc1 JIRA Story MTN-33879
	
	
epilog
	self.resetDefaultTranMap();
	app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport);  // 25/07/2025	navkc1	JIRA MTN-35344
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti, true);
	self.deleteTrackedItem(ti2, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	if cashReceipt2 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt2);
	endif;
	if cashReceiptForBoth &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceiptForBoth);
	endif;
	delete pxyTransService;

end;</source>
    </JadeMethod>
    <JadeMethod name="tPutProformaStatus" id="086f68e8-6563-4970-97e9-59dfb083fc8a">
        <updating/>
        <source>tPutProformaStatus() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2024	navkc1 CR 64840 Task 64855: Jade - Cash API Unit Tests
13/02/2025	navkc1 JIRA Story MTN-33879: MTN | Cash API - Does Not Work With All Debtor Types
*/
constants
	CEN = "UTCEN";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "CASHAPITI";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	EXTFINANCIALID = "EXTERNAL FINANCIAL ID";
	EXTRECEIPTNUMBER = "EXTERNAL RECEIPT NUMBER";
	EXTREF1 = "EXTREF1";
	EXTTRANSACTION = "EXTERNAL TRANSACTION";
	
vars
	cargoId,
	responseInString,
	loginJson,
	voyCode,
	agentId			: String;
	
	today,
	effectiveDate : Date;
	
	totalAmount		: Decimal[23,6];
	
	expectFailure 	: Boolean;
	
	tm				: CM_TranMap;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	ti				: CM_TrackedItem;
	
	debtorType		: CM_DebtorType;
	
	customagent		: CM_CustomsAgent;
	
	terminal		: CM_Terminal;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	
	bank			: CM_Bank;
	
	proxyCriteria	: CM_YACriteria;
	proxyProCrit 	: CM_ProformaTransactionCriteria;
	realProCrit 	: CM_ProformaTransactionCriteria;
	itemCode 		: String;
	value 			: Any;
	criterias		: CMIF_Array;
	cmifCriteria 	: CMIF_YACriteriaPriority;
	selectedTrxTypes: CM_TransactionTypeByType;
	critType 		: CM_YACriteriaType;
	
	fileContext		: String;
	pxyTransService : CM_TransServiceBroker;
	
	draftReceiptNumber,
	finalReceiptNumber	: Integer;
	request			: String;
	isPaymentAllowed : Boolean;
	cashReceipt : CM_CashReceipt;
	offlineActor	: CM_OfflineFutureActor;
begin
	//return;
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; "UT" &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// Terminal
	terminal := self.getMyTerminal();
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Custom Agent is null");
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 6);
	self.setTerminalConfig(FinancialRateDPlaces, 6);
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	// 25/07/2025	navkc1	JIRA MTN-35344
	if tm &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		tm := null;
	endif;
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	self.assertNotNullMsg(tm, "CASHAPI Transaction Map is null");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ?,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ?,(Default),,,**Any**,All,UTCASHAPI';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Debtor type is null");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[30] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "voyage is null");
	cargoId := CARGOID&amp;today.asStringJMT();
	
	// Create cargo 1
	ti := self.getTrackedItem(cargoId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 1
	ti := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti, "TI is null");
	self.editIMEXStatus(ti, TI_IMEX_STATUS_IMPORT, true);
	beginTransaction;
	ti.setCustomsAgent(customagent);
	ti.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	voyCode := voyage.code;
	today := app.actualTimeServer().date();
	effectiveDate := today.addDays(5);
	agentId := customagent.code;
		
	/*
	First, create a  draft receipt
	*/

	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialId" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for creating draft receipt
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, draftReceiptNumber, expectFailure, isPaymentAllowed);
	// Verify response - Make sure our draft receipt is good
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[draftReceiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt.cashValue = 12.551495, "Total amount is not correct");
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
	// Get the BGP - we need to make sure we have 1 now
	offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
	self.assertNotNullMsg(offlineActor, "BGP not created for the draft receipt");
	
	/*
	Scenario 1 - Bad scenario - Send it request without any information
	*/
	request := '{
					"customsAgentCode" : "",
					"customsEntryNumber" : "",
					"draftReceiptNumber" : "",
					"finalReceiptNumber" : "",
					"externalFinancialId" : "",
					"externalReceiptNumber" : "",
					"externalRef1" : "",
					"externalTransaction" : "",
					"externalUserCode" : "",
					"remarks" : "",
					"statusValue" : 0
				}
					';
	// call API for scenario 1
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 1 - should get errors for missing information
	self.assertTrueMsg(responseInString.pos('Code :96776. Cash Receipt Status Validation Failed. The status must be one of the following. Hold(22) Cancelled(23) Paid(24) Final(25).',1) &gt; 0, "Shoud get error for invalid status");
	self.assertTrueMsg(responseInString.pos('\"customsAgentCode\" cannot be null.',1) &gt; 0, "Shoud get error customsAgentCode cannot be null");
	self.assertTrueMsg(responseInString.pos('"\"draftReceiptNumber\" and \"finalReceiptNumber\"',1) &gt; 0, "Shoud get error for draft/final invoice number");
	self.assertTrueMsg(responseInString.pos('\"externalUserCode\" cannot be null',1) &gt; 0, "Shoud get error externalUserCode cannot be null");	
	self.assertNotNullMsg(offlineActor, "BGP should still be here, should't get deleted");
	
	/*
	Scenario 2 - Bad scenario Try updateing the status with different external user
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER2&amp;'",
					"remarks" : "",
					"statusValue" : 22
				}
					';
	// call API for scenario 2
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 2 - Different external user code - Should get error
	self.assertTrueMsg(responseInString.pos('"Code :96777. External user \"'&amp;EXTUSER2&amp;'\" cannot update receipt \"'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'\", external user \"'&amp;EXTUSER1&amp;'\" has initiated this receipt."',1) &gt; 0, "Shoud get error for mismatched externalUserCode");
	self.assertTrueMsg(cashReceipt.externalFinancialId = null, "externalFinancialID should not get upated");
	self.assertTrueMsg(cashReceipt.externalReceiptNumber = null, "externalReceiptNumber should not get upated");
	self.assertTrueMsg(cashReceipt.externalRef1 = null, "externalRef1 should not get upated");
	self.assertTrueMsg(cashReceipt.externalTransaction = null, "externalTransaction should not get upated");
	self.assertNotNullMsg(offlineActor, "BGP should still be here, should't get deleted");
	
	
	/*
	Scenario 3 - Bad scenario. Enter invalid statusValue (not in correct sequence).
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 24
				}
					';
	// call API for scenario 3
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 3 - Bad scenario, should get error invalid StatusVAlue
	self.assertTrueMsg(responseInString.pos('Code :96778. The cash receipt has status of \"Draft\", next valid status should be \"Hold/Expired/Cancelled\".', 1) &gt; 0, "Should get error next invalid next status value");
	self.assertNotNullMsg(offlineActor, "BGP should still be here, should't get deleted");
	
	
	/*
	Scenario 4 - Good scenario - update status (HOLD 22) and external fields
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 22
				}
					';
	// call API for scenario 4
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 4 - Good scenario, update status and external fields
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "Payment status should gets updated to be HOLD");
	self.assertTrueMsg(cashReceipt.externalFinancialId = EXTFINANCIALID, "externalFinancialId should be " &amp; EXTFINANCIALID &amp; ", not " &amp; cashReceipt.externalFinancialId);
	self.assertTrueMsg(cashReceipt.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt.externalRef1);
	self.assertTrueMsg(cashReceipt.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt.externalTransaction);
	self.assertTrueMsg(finalReceiptNumber = null, "Should not have a final receipt number here");
	self.assertTrueMsg(draftReceiptNumber = cashReceipt.sequenceNum, "Draft receipt sequence number should match the cash receipt sequence number");
	self.assertTrueMsg(draftReceiptNumber &gt;= DRAFTCASHRECEIPT_StartNumber, "Draft receipt number should start from this number in the global constant");
	offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
	self.assertNullMsg(offlineActor, "BGP should be gone as we have updated the payment status to be HOLD");
	
	/*
	Scenario 5 - Bad scenario - update status (FINAL 25) wrong sequence
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 25
				}
					';
	// call API for scenario 5
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 5 - Bad scenario, update status from HOLD to FINAL
	self.assertTrueMsg(responseInString.pos('"Code :96778. The cash receipt has status of \"Hold\", next valid status should be \"Paid/Cancelled\"."', 1) &gt; 0, "Should get error stating invalid next payment status.");
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "Payment status should stay at HOLD");
	self.assertTrueMsg(cashReceipt.externalFinancialId = EXTFINANCIALID, "externalFinancialId should be " &amp; EXTFINANCIALID &amp; ", not " &amp; cashReceipt.externalFinancialId);
	self.assertTrueMsg(cashReceipt.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt.externalRef1);
	self.assertTrueMsg(cashReceipt.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt.externalTransaction);
	offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
	self.assertNullMsg(offlineActor, "BGP should be gone as we have updated the payment status to be HOLD");
	
	/*
	Scenario 6 - Good scenario - update status (PAID 24)
	*/
	request := '{
					"customsAgentCode" : "'&amp;agentId&amp;'",
					"customsEntryNumber" : "'&amp;CEN&amp;'",
					"draftReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"finalReceiptNumber" : "'&amp;cashReceipt.sequenceNum.asStringJMT()&amp;'",
					"externalFinancialId" : "'&amp;EXTFINANCIALID&amp;'",
					"externalReceiptNumber" : "'&amp;EXTRECEIPTNUMBER&amp;'",
					"externalRef1" : "'&amp;EXTREF1&amp;'",
					"externalTransaction" : "'&amp;EXTTRANSACTION&amp;'",
					"externalUserCode" : "'&amp;EXTUSER1&amp;'",
					"remarks" : "",
					"statusValue" : 24
				}
					';
	// call API for scenario 6
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaStatus.name, request, responseInString, draftReceiptNumber, finalReceiptNumber);
	// Verify response Scenario 6 - Good scenario, update status to FINAL 25
	// YES, QT want to accept paymentStatus Paid 24, then set the paymentStatus to Final 25
	self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "Payment status should gets updated to be FINAL");
	self.assertTrueMsg(cashReceipt.externalFinancialId = EXTFINANCIALID, "externalFinancialId should be " &amp; EXTFINANCIALID &amp; ", not " &amp; cashReceipt.externalFinancialId);
	self.assertTrueMsg(cashReceipt.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt.externalRef1);
	self.assertTrueMsg(cashReceipt.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt.externalTransaction);
	self.assertTrueMsg(cashReceipt.sequenceNum &lt; DRAFTCASHRECEIPT_StartNumber, "Cash receipt sequence number should have proper number now, " &amp;"i.e. less than " &amp;DRAFTCASHRECEIPT_StartNumber.asStringJMT()&amp;", should not be " &amp; cashReceipt.sequenceNum.asStringJMT());
	self.assertTrueMsg(finalReceiptNumber &lt;&gt; null, "Final receipt number should not be null");
	self.assertTrueMsg(finalReceiptNumber = cashReceipt.sequenceNum, "Final receipt number should be the same as the cash receipt number");
	offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
	self.assertNullMsg(offlineActor, "BGP should be gone as we have updated the payment status to be HOLD");
	
epilog
	self.resetDefaultTranMap();
	app.myTrxDA.trxDeleteInvoiceTranMap(tm, app.myPassport); // 25/07/2025	navkc1	JIRA MTN-35344
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	delete pxyTransService;

end;</source>
