	app.writeLog(method.qualifiedName &amp; " Update Release Request Mark Number completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Release Request Mark Number completed") ;	
	endif;	
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
