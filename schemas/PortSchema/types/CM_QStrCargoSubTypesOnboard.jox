<Class name="CM_QStrCargoSubTypesOnboard" id="ad9c20fb-66d6-4de3-bf5a-f20bdb73d703">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="setComboValues" id="75cd6578-01a3-48c8-b1ab-f299a47c747a">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 May 2024
TFS#		: 63961
Function	:

*** Changes ***
Date			Name		TFS#		Description
05 Feb 2025		navcs2		MTN-33832 CUX | Selector queries based on Onboard fields - changes required
****************************************************/
vars
	crit			: CM_SelectorCriteriaLine;
	idx				: Integer;
	os				: ObjectSet;
	value			: Any;
	obj				: Object;
	cargoType		: CM_CargoType;
	product			: CM_Product;
	qrl				: CM_QStringLookup;
	terminal 		: CM_Terminal;
	current			: Any;
begin
	_combo.clear;
	
	current:=_queryOperator.getSearchValue();
	
	if _params = null then
		 terminal := app.myPassport.myTerminal;
		foreach cargoType in app.myRoot.allCargoTypesById do
		
			if terminal &lt;&gt; null then
				if not terminal.allCargoBOLTypes.includes(cargoType) then
					continue;
				endif;
			endif;
			
			foreach product in cargoType.allProducts do
				idx := _combo.addItem(cargoType.abbreviation &amp; " - " &amp; product.code);
				_combo.itemObject[idx] := product;
				// Select the chosen one
				if product.description = current.asString then
					_combo.listObject := product;
				endif;
			endforeach;
		endforeach;
		
		return;
	endif;	
	
	crit := _params.allCriteriaByPropertyName['getOnboardCargoTypes', CM_TITransaction.name];
	
	if crit = null then																				// 05 Feb 2025		navcs2		MTN-33832
		crit := _params.allCriteriaByPropertyName['getOnboardCargoTypes', CM_TILC.name];			// 05 Feb 2025		navcs2		MTN-33832
	endif;																							// 05 Feb 2025		navcs2		MTN-33832

	create os transient;
	
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(os);
		elseif	crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal or 
				crit.myQueryOperator.description = CM_QueryOperator.Operator_NotEqual then
			
			cargoType := app.myRoot.allCargoTypesByDescription[crit.myQueryOperator.getSearchValue().asString];	
			if cargoType = null then
				app.msgBox(app.getString(CouldNotFindCargoType), 'Warning', 0);
				return;
			endif;
			os.add(cargoType);
		endif;
		
	else
		app.msgBox(app.getString(SpecifyCargoType), 'Warning', 0);				//+cnwml2 PAR24397
		return;
	endif;
	
	foreach obj in os do
		cargoType := obj.CM_CargoType;
		foreach product  in cargoType.allProducts do
			idx := _combo.addItem(product.code);
			_combo.itemObject[idx] := product;
			
			if product.description = current.asString then
				_combo.listObject := product;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="c38e622b-7647-482a-a97f-50de57e809a8">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 May 2024
TFS#		: 63961
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	subCargo : CM_Product;
	criteriaLine : CM_SelectorCriteriaLine;
	cargoTypeColl : ObjectArray;
	cargoType : CM_CargoType;
	selectionValue : Integer;
	idx : Integer;
	terminal : CM_Terminal;
	typeParam : String;
	typeArray : StringArray; 	
begin
	_tbl.clear();
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2; 

	
	foreach criteriaLine in _params.allCriteriaLines do
		if criteriaLine.propName = "onboardCargoTypes" then
			if  criteriaLine.myQueryOperator.isKindOf(CM_QStringLookupIsOneOf) then
				foreach typeParam in criteriaLine.myQueryOperator.CM_QStringLookupIsOneOf.allSelectionValues do
					cargoType := app.myRoot.allCargoTypesByDescription[typeParam];	
				endforeach;
			else
				typeParam := criteriaLine.myQueryOperator.CM_QStringLookup.selectionValue;
				cargoType := app.myRoot.allCargoTypesByDescription[typeParam];	
			endif;
			break;
		endif;
	endforeach;
	
	if cargoType &lt;&gt; null then 
		foreach subCargo in cargoType.allProducts do
			selectionValue := 0;
			if _operator &lt;&gt; null then
				if _operator.CM_QStringLookupIsOneOf.allSelectionValues.includes(subCargo.description) then
					selectionValue := 1;
				endif;
			endif;
			idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; subCargo.code &amp; " - " &amp; subCargo.description);
			_tbl.accessRow(idx).itemObject := subCargo.CM_Product;
			_tbl.row := idx;
			_tbl.change(_tbl); 
		endforeach;
	else	 
	 terminal := app.myPassport.myTerminal;
		foreach cargoType in app.myRoot.allCargoTypesById do
		
			if terminal &lt;&gt; null then
				if not terminal.allCargoBOLTypes.includes(cargoType) then
					continue;
				endif;
			endif;
			
			foreach subCargo in cargoType.allProducts do
				selectionValue := 0;
				if _operator &lt;&gt; null then
					if _operator.CM_QStringLookupIsOneOf.allSelectionValues.includes(subCargo.description) then
						selectionValue := 1;
					endif;
				endif;
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; cargoType.abbreviation &amp; " - " &amp; subCargo.code &amp; " - " &amp; subCargo.description);
				_tbl.accessRow(idx).itemObject := subCargo.CM_Product;
				_tbl.row := idx;
				_tbl.change(_tbl); 
			endforeach;
		endforeach;
	endif;
	
	
	_tbl.sortColumn[1] := 2;
	_tbl.sortAsc[1] := true;
	_tbl.resort();
	
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="07ce5ef5-6c1b-4f02-9c83-f4ebbe4559c6">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 May 2024
TFS#		: 63961
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	cargoSubType	: CM_Product;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: StringArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			cargoSubType := _tbl.accessRow(idx).itemObject.CM_Product;
			ia.add(cargoSubType.description);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="572e6937-2836-4e0e-bdcf-dff80bbb17ac">
        <source>translateToDisplayValue(_value: Any): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 May 2024
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars

begin
	if _value &lt;&gt; null then
		return _value.String;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="0ddbfc83-9ce6-411c-9bdc-92f5c46fdc7f">
        <source>translateToSearchValue(_value: Any): Any;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 May 2024
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	returnVal : String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		endif;

		if _value.isKindOf(CM_Product) then
			returnVal := _value.CM_Product.code;
		endif;
	endif;
	
	return returnVal;

epilog

end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
