					&lt;AllLayoutPoint&gt;
						&lt;LayoutPoint&gt;
&lt;longPos&gt;85.10&lt;/longPos&gt;
&lt;transPos&gt;4.00&lt;/transPos&gt;
							&lt;pointOrder&gt;1&lt;/pointOrder&gt;
							&lt;cargoTypeDescr/&gt;
							&lt;description/&gt;
							&lt;fullOrMT/&gt;
							&lt;id/&gt;
							&lt;layoutId&gt;D4299O&lt;/layoutId&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
						&lt;/LayoutPoint&gt;
						&lt;LayoutPoint&gt;
&lt;longPos&gt;91.10&lt;/longPos&gt;
&lt;transPos&gt;4.00&lt;/transPos&gt;
							&lt;pointOrder&gt;2&lt;/pointOrder&gt;
							&lt;cargoTypeDescr/&gt;
							&lt;description/&gt;
