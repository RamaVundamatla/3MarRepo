    <JadeMethod name="doMnuTaskOverideHalt" id="67b18ae6-0637-4260-b0dc-5ceba68316c1">
        <updating/>
        <source>doMnuTaskOverideHalt() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars

	flags	:	Integer;
	lTask : CM_RTQueueTask;
	lReturn,loadState : Boolean;
	lOR : String;
	lProxyEntry, lRealEntry : CM_RTQueueEntry;
	orFlagCol : Integer;
	entRow		: EntTableRow;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	if not checkCurrentObjects then
		return;
	endif;
	
	lTask := self.myCurrentTask;

	app.cmsBeginLoad(loadState);
	lRealEntry :=  lTask.myEntry;
	lProxyEntry := lRealEntry.pxyCreateUpdateProxy;
	lProxyEntry.setProxyOverRideFlags(lRealEntry);
	app.cmsEndLoad(loadState);
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateQueueEntryFlag(lProxyEntry,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			lOR := lRealEntry.getOverRideFlag(); 
			self.tblQEntries.getEntRowColumnByRowName(ETRow_Or,orFlagCol);
			if 	orFlagCol &gt; null then
				self.tblQEntries.accessCell(self.tblQEntries.row, orFlagCol).text := lOR;
			endif;
			break;
		else
			theResult := app.showErrorWarningDialog('Override Halt', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
		
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	if lProxyEntry &lt;&gt; null then
		delete lProxyEntry;
	endif;
end;</source>
    </JadeMethod>
