    <JadeMethod name="getResourceForHarbourMovement" id="339249fa-72bb-4d6f-8f34-c8fdeba4a218">
        <source>getResourceForHarbourMovement(_harbour : HMS_Harbour; _movement : String) : HMS_Resource;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	realResource : HMS_Resource;
	resourceLineComp : HMS_ResourceForLineCompany;
begin		
	if _harbour = null then
		return null;
	endif;
	
	resourceLineComp := self.allResourceForLineCompany[_harbour, self];
	if resourceLineComp &lt;&gt; null then
		if _movement = HMSMovementTypeArrival then
			return resourceLineComp.myArrivalResource;
		elseif _movement = HMSMovementTypeDeparture then
			return resourceLineComp.myDepartResource;
		else
			return resourceLineComp.myShiftResource;
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_movement" type="String"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="57eca711-b1d5-4a85-b416-6fef5bfd502a">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
//
//----------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy	:	HMS_LineCompany;
	completedOK		: Boolean;
	
begin
	proxy := inheritMethod();	
	proxy.myRoot := self.myRoot;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="d4ce37c2-1e5c-4573-9961-a5a6a5635455">
        <updating/>
        <source>setForDelete(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	resourceForLineCompany	: HMS_ResourceForLineCompany;
begin
	inheritMethod(_passport);
	foreach resourceForLineCompany in self.allResourceForLineCompany do
		resourceForLineCompany.setForDelete(_passport);
		resourceForLineCompany.erase(NORMAL_ERASE);
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="deb911af-9c7b-4870-bc6f-b08777853809">
        <updating/>
        <source>setForUpdate(_pxyLineCompany : HMS_LineCompany ; _passport: CM_Passport input) updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
// 03-JUL-2014  cnwma1 CCMS SFW1328 -HMS Not Available For Entry 
//----------------------------------------------------------

vars
	resourceForLineCompany,
	tmpResourceForLineCompany : HMS_ResourceForLineCompany;
begin
	inheritMethod(_pxyLineCompany , _passport);
	
	self.code					:= _pxyLineCompany.code.toUpper.trimBlanks;
	self.description			:= _pxyLineCompany.description;
	self.isNotAvailableForEntry := _pxyLineCompany.isNotAvailableForEntry; //  cnwma1 3/7/2014   CCMS SFW 1328
	self.myRoot			:= _pxyLineCompany.myRoot;
	
	foreach tmpResourceForLineCompany in self.allResourceForLineCompany do
			tmpResourceForLineCompany.setForDelete(_passport);
	endforeach;
	
	self.allResourceForLineCompany.purge();
	
	foreach tmpResourceForLineCompany in _pxyLineCompany.allResourceForLineCompany do
		create resourceForLineCompany persistent;
		resourceForLineCompany.setLineCompany(self);
		resourceForLineCompany.setForUpdate(tmpResourceForLineCompany, _passport);
	endforeach;

epilog

end;</source>
        <Parameter name="_pxyLineCompany" type="HMS_LineCompany"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c9f0d80f-b2ca-46a7-b754-30cb695ef996">
        <updating/>
        <source>setProxy( _root : CM_Root)updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
//
//----------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot := _root;
epilog

end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a5a6d1f2-923b-4246-9cca-42013cb161ed">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
//
//----------------------------------------------------------

vars

begin
	inheritMethod(_passport);
	if (not self.allVoyageMovements.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.description, "Voyage Movement", null, null);
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="54188b3d-1736-4cae-84e5-37c4a67b5a83">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//----------------------------------------------------------

vars
	tmpLineCo	:	HMS_LineCompany;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description, null);
		app.raiseCMException(Input_required_field_desc, ETRow_Description, null);  // cnwdb2	PAR 35364
	endif;
	
	if self.myRoot = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Harbour Root', null, null);
		app.raiseCMException(Input_required_field_harbRoot, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	tmpLineCo := self.myRoot.allLineCompanies.getAtKey(self.code);
	if tmpLineCo &lt;&gt;  null then
		if self.isTransient and tmpLineCo &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Line Company', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Line Company already exists for %1 : Line_company_already_exists
			app.raiseCMException1(Line_company_already_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;
		
	 
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
