    <JadeMethod name="testIsControllerAvailSubBlock" id="0f7e037f-56d7-42ce-ac1d-4d8c339d05fb">
        <source>testIsControllerAvailSubBlock(pCheckLabour, pCheckLocation, pCheckSubBlock : Boolean): Boolean;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		This test for availability is used during convertion from grid area to a sub block stack
//				This is a different requirement from testIsControllerAvailable which is used during autoplanning and moving
//				The 2 methods ask different questions for different situations
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if pCheckLocation then
		if self.myLocationRestriction &lt;&gt; null then
			if self.myLocationRestriction.allVoyages &lt;&gt; null then
				app.raiseCMException(WARN_ROW_HAS_RESTS, null, null);
				return false;
			endif;
		endif;
	endif;
	if pCheckLabour then
		if self.allLabourRestrictions.size &gt; 0 then
			app.raiseCMException(ERR_LC_HAS_RESTS, null, null);
			return false;
		endif;
	endif;
	return true;
end;</source>
        <Parameter name="pCheckLabour" type="Boolean"/>
        <Parameter name="pCheckLocation" type="Boolean"/>
        <Parameter name="pCheckSubBlock" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
