    <JadeMethod name="set" id="c5ffb71b-e757-48d5-baa4-8480292f77a3">
        <updating/>
        <source>set(pId : String; pISOType : String; pCOUType : String; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.id				:= pId;
	self.isoType		:= pISOType;
	self.couTypeString	:= pCOUType;
	self.myTerminal		:= _terminal;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pISOType" type="String"/>
        <Parameter name="pCOUType" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
