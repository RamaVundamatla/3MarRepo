    <JadeMethod name="uGetLastUsedXLATException" id="6e927024-fecf-41c2-a10d-fdab8aafda0c">
        <source>uGetLastUsedXLATException();

/*

Purpose:		Get the XLAT_Exception code used	

Date			Who		Reason
20/09/2012		cnwmh5	Initial creation

*/

vars
	number : Integer;
	constant : Constant;
begin
	foreach constant in rootSchema.getSchema(PortSchemaName).getCategory("XLAT_Exceptions").getConstants discreteLock do
		number := number.max(constant.getPropertyValue("source").Integer);
	endforeach;
	app.writeStatement("Last Number used: " &amp; number.String);
end;
</source>
    </JadeMethod>
    <JadeMethod name="xStringContains" id="882c79b4-ae6d-48e8-b0a9-aeb3cebefd14">
        <source>xStringContains(_methodCode : String ; _objectName : String):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2017	cnwns1	Initial creation

*/

vars
methSource : String;
pos : Integer;
nextChar : Character;
begin
	if 	_methodCode = null then
		return false;
	endif;
	
	
					
	pos := _methodCode.pos(_objectName,1);
					
	if pos &gt; 0 then 
		nextChar := _methodCode[pos + _objectName.length : 1].Character;
		if nextChar = "".Character then	
			return false;
		elseif nextChar = "_".Character then 
			return false;
		elseif nextChar = ",".Character then 
			return true;
		elseif nextChar = ";".Character then 
			return true;
		elseif nextChar.isAlpha then
			return false ;
		elseif nextChar.isNumeric then
			return false;
		endif;
		
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_methodCode" type="String"/>
        <Parameter name="_objectName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
