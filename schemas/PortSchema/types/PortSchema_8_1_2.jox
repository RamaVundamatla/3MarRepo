    <JadeMethod name="convertAutoTaskEDITerminal" id="5e74351a-5106-4f0a-93b6-3c6a9a9e3f6b">
        <source>convertAutoTaskEDITerminal() protected;
/*
Date		Who		Reason
27 August 2012	cnwcs5	Initial creation - par 
*/
vars
	task	:CM_AutoTaskEDITerminal;
begin
	app.writeLog( method.qualifiedName &amp; 'Upgrading EDI BGP Task data from 8.1.1 to 8.1.2', LogINFO);
	
	beginTransaction;

	foreach task in CM_AutoTaskEDITerminal.instances do
		if not task.processEventRequestStops and 
			not task.processNewFiles and 
			not task.deleteOldData and
			task.allEDIDataTypes.isEmpty then
			//  if they have nothing set then set everything
			task.setPropertyValue (CM_AutoTaskEDITerminal::processEventRequestStops.name, true);
			task.setPropertyValue (CM_AutoTaskEDITerminal::processNewFiles.name, true);
			task.setPropertyValue (CM_AutoTaskEDITerminal::deleteOldData.name, true);
			
			task.allEDIDataTypes.add (EDIDataType_BookingMultiLine);
			task.allEDIDataTypes.add (EDIDataType_CustomStop);
			task.allEDIDataTypes.add (EDIDataType_OperatorStop);
			task.allEDIDataTypes.add (EDIDataType_ReleaseRequest);
			task.allEDIDataTypes.add (EDIDataType_Pack);
			task.allEDIDataTypes.add (EDIDataType_Prenote);
		endif;
	endforeach;
	
	commitTransaction;

	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of EDI BGP Task data from 8.1.1 to 8.1.2', LogINFO);	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="convertRateEntry" id="9a8a83e5-e541-4973-9520-773f43fc8464">
        <source>convertRateEntry() protected;
/*
Date		Who		Reason
28 Sep 2012	cnwjre1	Initial creation - par 29980 escalating storage charges
*/
vars
	entry	: CM_RateEntry;

begin
	app.writeLog( method.qualifiedName &amp; 'Upgrading Rate Entry data from 8.1.1 to 8.1.2', LogINFO);
	beginTransaction;
	
	foreach entry in CM_RateEntry.instances do
		// 'cost is amount' and 'rate is percentage' have been stored in extension objects
		// now we want to put them in real properties
		entry.convertExtensionObjectValue (Obj_Extn_costIsAmount, CM_RateEntry::costIsAmount);
		entry.convertExtensionObjectValue (Obj_Extn_rateIsPercentage, CM_RateEntry::rateIsPercentage);
	endforeach;

	commitTransaction;
	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of Rate Entry data from 8.1.1 to 8.1.2', LogINFO);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="convertTempCamsLoggingFields" id="a38755a0-ca13-4fb6-9a8c-ee62af60857d">
        <source>convertTempCamsLoggingFields() protected;
/*
Date		Who		Reason
15 Aug 2012	cnwcs5	Initial creation - par 30176
*/
vars
	request	:BGP_CamsRequest;
	history	:CM_CamTaskHistory;
begin
	app.writeLog( method.qualifiedName &amp; 'Upgrading BGP Request data from 8.1.1 to 8.1.2', LogINFO);
	beginTransaction;
	
	foreach request in BGP_CamsRequest.instances do
		// log excluded transaction has been stored in an extension object
		// now we want to put it in a real property
		request.convertExtensionObjectValue (Obj_Extn_logExcludedTrans, BGP_CamsRequest::logExcludedTransactions);
	endforeach;

	commitTransaction;
	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of BGP Request data from 8.1.1 to 8.1.2', LogINFO);
	
	app.writeLog( method.qualifiedName &amp; 'Upgrading Cam Task History data from 8.1.1 to 8.1.2', LogINFO);
	beginTransaction;
	
	foreach history in CM_CamTaskHistory.instances do
		// log excluded transaction has been stored in an extension object
		// now we want to put it in a real property
		history.convertExtensionObjectValue (Obj_Extn_logExcludedTrans, CM_CamTaskHistory::logExcludedTransactions);
	endforeach;

	commitTransaction;
	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of Cam Task History data from 8.1.1 to 8.1.2', LogINFO);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="moveCamSpecialFields" id="2577d749-3bf4-4ff0-bda1-ef024b553818">
        <source>moveCamSpecialFields() protected;
/*
Date		Who		Reason
25 Sep 2012	cnwcs5	Initial creation - par 30409
*/
vars
	protocol	:CM_CamProtocol;
begin
	// specialField 1 &amp; 2 were used for 2 different purposes so 
	// we are going to use specialField 5 &amp; 6 so each flag is used
	// for only one thing
	
	// INTRAC protocols will move includeNonPlannedVoyage(specialField1) value to noSNTOnPackTrans (specialField5)
	// INTRAC protocols will move includeNonWorkedVoyage(specialField2) value to noRCVOnUnPackTrans (specialField6)
	
	app.writeLog( method.qualifiedName &amp; 'Upgrading Cam Protocol Special Fields data from 8.1.1 to 8.1.2', LogINFO);
/*	AKB remove includeNonPlannedVoyage
	foreach protocol in CM_CamProtocol.instances do
		if protocol.protocolDesc = null or not protocol.protocolDesc.isKindOf (CM_CamPANDOINTRAC) then
			continue;
		endif;
		
		if not protocol.includeNonPlannedVoyage and not protocol.includeNonWorkedVoyage then
			continue;
		endif;
		
		beginTransaction;
		
		if protocol.includeNonPlannedVoyage then
			protocol.setPropertyValue (CM_CamProtocol::noSNTOnPackTrans.name, true);
			protocol.setPropertyValue (CM_CamProtocol::includeNonPlannedVoyage.name, false);
		endif;
		
		if protocol.includeNonWorkedVoyage then
			protocol.setPropertyValue (CM_CamProtocol::noRCVOnUnpackTrans.name, true);
			protocol.setPropertyValue (CM_CamProtocol::includeNonWorkedVoyage.name, false);
		endif;
		
		commitTransaction;
	endforeach;
	*/
	app.writeLog( method.qualifiedName &amp; 'Finished Upgrading Cam Protocol Special Fields data from 8.1.1 to 8.1.2', LogINFO);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetGraphicsConfig" id="bbe94799-f8c5-4bee-838b-0392922b2f74">
        <source>resetGraphicsConfig() protected;
/*

Purpose:			Reset any user graphics configurations that may have overridden the defaults to ensure 
					the new product branding is properly deployed


Date		Who		Reason
07 Sep 2012	cnwkpd1	PAR #30306 - New graphics and product branding

*/

vars

begin
	app.writeLog(method.qualifiedName &amp; 'Resetting Graphics Configuration settings', LogINFO);
	
	beginTransaction;
	// Main form background image - reset any user defined value so product version is used
	app.myRoot.setConfig(SystemBackgroundPic, null, true);
	commitTransaction;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="2fdd87a4-41fc-48da-954c-5cca02574d62">
        <updating/>
        <source>specificPostStandard(_controllerObj : CnEcReleaseController) updating;
/*
Purpose:			Specific Release upgrade for JMT 8.1.2

Parameters:			Release Controller

Return Value:		None

Date		Who		Reason
03 Aug 2012	cnwkpd1	8.1.2 Release
21 Aud 2012	cnwcs5	Convert object extension properties used for par 29601
*/

vars
	fileObj	: File;
	tempStr	: String;
	
begin
	create fileObj transient;
	fileObj.usePresentationFileSystem	:= false;
	//fileObj.kind						:= File.Kind_ANSI;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	fileObj.mode						:= File.Mode_Output;
	fileObj.fileName					:= app.myCnCntrl.logPath &amp; '\app_upgrade.log';
	if fileObj.isAvailable then
		fileObj.purge();
	endif;
	
	tempStr	:= 'Performing Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage( tempStr, _controllerObj, fileObj );
	
	inheritMethod(_controllerObj);
	
	// Add in specific release stuff here
	
	// CAMS Logging fields
	self.convertTempCamsLoggingFields;
	
	// EDI BGP Task data
	self.convertAutoTaskEDITerminal();

	// User-defined graphics config
	self.resetGraphicsConfig();
	
	// CAM Protocol special fields 1 &amp; 2
	self.moveCamSpecialFields;
	
	// Rate escalating storage fields
	self.convertRateEntry();
	
	//*************** this is the last thing that should happen
	tempStr	:= 'Finished Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage(tempStr, _controllerObj, fileObj);
	
	
epilog

end;
</source>
        <Parameter name="_controllerObj" type="CnEcReleaseController"/>
    </JadeMethod>
</Class>
