    <JadeMethod name="maFleet" id="61637ae7-5983-4356-8321-7178ee232416">
        <source>maFleet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2021		navma1	Initial creation

*/

vars
	lFile      		: File;
	master          : CM_TIMaster;
		tmpTI : CM_TrackedItem;
	tmpStr : String;
	tmpLC : CM_LocationsController;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\fleetData31821.csv";
	lFile.open;
	
	
	lFile.writeLine(
					"Oid"	        	&amp; "," &amp;
					"Id"   				&amp; "," &amp;
					"CargoType"  		&amp; "," &amp;
					"currentLocation" 	&amp; "," &amp; 
					"ownder"    		&amp; "," &amp; 
					"iso"               &amp; "," &amp; 
					"tareWT"            &amp; "," 
					);
					
	foreach master in app.myRoot.allTiMasters discreteLock do
		
		
		tmpTI := master.allTis.last;
		if tmpTI = null then
			tmpStr :=  "";
		endif;
		if tmpTI &lt;&gt; null then
			tmpLC := tmpTI.getPrimaryLocation(REAL_MODE);
			if tmpLC &lt;&gt; null then
				tmpStr := tmpLC.getFullId();
				if tmpTI.myTerminal &lt;&gt; null then
					tmpStr := tmpTI.myTerminal.code &amp; " " &amp; tmpStr;
				endif;
			else
				if tmpTI.state = TI_STATE_OFFSITE then
					tmpStr := app.stateEnumToString(TI_STATE_OFFSITE);
					if tmpTI.myTerminal &lt;&gt; null then
						tmpStr := tmpTI.myTerminal.code &amp; " " &amp; tmpStr;
					endif;
				else
						tmpStr :=  "";
				endif;
			endif;
		endif;
		lFile.writeLine(
						master.getOidAsString                 &amp; "," &amp;
						master.id			                  &amp; "," &amp;	
						master.getCargoTypeDesc				  &amp; "," &amp;	
						tmpStr          				      &amp; "," &amp;
						master.getOwnerString(true)	          &amp; "," &amp;
						master.getISOTypeString()             &amp; "," &amp;
						master.tWeight.asStringWeightJMT()
						);
	endforeach;
	  
epilog
  lFile.close;
  delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="maGL" id="b4c37fc7-ca4f-460b-9fc3-c7a6c33b360f">
        <source>maGL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgma1	Initial creation

*/

vars
	glExt :String;
	str, tempCopy : String;
	pos : Integer;
	fieldName : String;
	ww,x : String;
	i: Integer;
begin
	glExt := "4101010000.410101.10.10.16-A01.A99..10..1003...01.100302";
	ww := "WW";
			
			
	tempCopy := glExt &amp; '.' &amp; "*";	
	pos := 1;
	while true do
		str := tempCopy.scanUntil('.', pos);
		str := str.trimLeft;		
		if pos = 0 then 
			break; 
		endif;
		pos  := pos + 1;	
		i := i+1;
		x := "00"&amp; i.String;
		if x.length &gt;3  then
			//i = i.String[2:i.String.length];
			x := x[2 :x.length];
		endif;
		if str &lt;&gt; "*" then
			write ww &amp; x &amp;"-----" &amp; str;
			//write str;
		else
			break;
		endif;
	endwhile;
			

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="maGL2" id="4ea4a1ab-9a39-45ac-a489-fa473ee189e3">
        <source>maGL2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2018	jlgma1	Initial creation

*/


vars
	glExt :String;
	str, tempCopy : String;
	pos : Integer;
	fieldName : String;
	ww,x : String;
	i: Integer;
begin
	glExt := "4101010000.410101.10.10.16-A01.A99..10..1003...01.100302.A0104";

	str := glExt[glExt.length-4:glExt.length];
	write str;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="maHMSHookCode" id="6cfa5910-67ce-4c87-8c9f-be13c17841fb">
        <source>maHMSHookCode(_cmif : CMIF_CalcTypeQuantityHook) : Real;
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars

   newQty : Real;
   voyage : CM_Voyage;
   cutOff : CM_ReceivalCutoffVoyage;
   cutOffTerm : CM_ReceivalCutoffTermDef;
    cutoffDateTime  : TimeStamp;
    earlistDateTime : TimeStamp;
	cutoffDateTimePN  : TimeStamp; //04/03/2025	navkc1 JIRA Story MTN-34227
    earlistDateTimePN : TimeStamp; //04/03/2025	navkc1 JIRA Story MTN-34227

begin
    newQty := _cmif.origQty;
        if _cmif.myTransaction.isKindOf(HMS_Transaction) then
			if _cmif.myTransaction.HMS_Transaction.myHMSVoyageData &lt;&gt; null then
				if  _cmif.myTransaction.HMS_Transaction.myHMSVoyageData.myVoyage &lt;&gt; null then
                    voyage := _cmif.myTransaction.HMS_Transaction.myHMSVoyageData.myVoyage;                                                           
                    if not voyage.allReceivalCutoffs.isEmpty then    // This results in empty
                        cutOff :=  voyage.allReceivalCutoffs.first.CM_ReceivalCutoffVoyage;
                        if cutOff &lt;&gt; null then
							app.invLog("Found Overrided Cutoff for voyage :" &amp; voyage.code, LogINFO.String);
                            cutoffDateTime := cutOff.cutoffDateTime;		
							earlistDateTime := cutOff.earliestDateTime;
							cutoffDateTimePN := cutOff.cutoffDateTimePN;		//04/03/2025	navkc1 JIRA Story MTN-34227	
							earlistDateTimePN := cutOff.earliestDateTimePN;		//04/03/2025	navkc1 JIRA Story MTN-34227
                            app.invLog("CutOffDate =" &amp;cutoffDateTime.asStringJMT, LogINFO.String);
							app.invLog("earlistDateTime =" &amp;earlistDateTime.asStringJMT, LogINFO.String); 
							app.invLog("CutOffDatePN =" &amp;cutoffDateTimePN.asStringJMT, LogINFO.String);			//04/03/2025	navkc1 JIRA Story MTN-34227
							app.invLog("earlistDateTimePN =" &amp;earlistDateTimePN.asStringJMT, LogINFO.String); 	//04/03/2025	navkc1 JIRA Story MTN-34227
							
							
                        endif;
					else        
						app.invLog("There was no Overrided cutoffs for voyage :" &amp; voyage.code, LogINFO.String);
							if not voyage.myTerminal.allReceivalCutoffDefs.isEmpty then
								// Now Looking for the Terminal Cuttoffs 
								app.invLog("Found Default cutoffs for Terminal :" &amp; voyage.myTerminal.code, LogINFO.String);
								cutOffTerm := voyage.myTerminal.allReceivalCutoffDefs["TEST"];
								if cutOffTerm &lt;&gt; null then
									app.invLog("cutOffTerm Code =" &amp;cutOffTerm.code, LogINFO.String);
									app.invLog("cutOffTerm Default Cuttoff =" &amp;cutOffTerm.defaultCutoff.asStringJMT, LogINFO.String);
									app.invLog("cutOffTerm Default Earliest  =" &amp;cutOffTerm.defaultEarliestReceival.asStringJMT, LogINFO.String);
									app.invLog("cutOffDateTimePN =" &amp;cutOffTerm.defaultCutoffPN.asStringJMT, LogINFO.String); //04/03/2025	navkc1 JIRA Story MTN-34227
									app.invLog("earliestDateTimePN  =" &amp;cutOffTerm.defaultEarliestReceivalPN.asStringJMT, LogINFO.String); //04/03/2025	navkc1 JIRA Story MTN-34227
								else
									app.invLog("No Default Cutoff defined with Code TEST", LogINFO.String);
								endif;
							else
								app.invLog("No Default Cutoff defined for that terminal", LogINFO.String);
							endif;
					endif;
				else               
					app.invLog("_cmif.myTransaction.HMS_Transaction.myHMSVoyageData.myVoyage is Empty", LogINFO.String);
				endif;
			else
				app.invLog("_cmif.myTransaction.HMS_Transaction.myHMSVoyageData is Empty", LogINFO.String);
			endif;               
		endif;
    return newQty;

end;
</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
