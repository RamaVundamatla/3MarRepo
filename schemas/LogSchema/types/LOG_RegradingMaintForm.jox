	if _species &lt;&gt; null then
		self.allCodes.clear;
//		self.myAssistant.comboBoxGeneral(_cmbGrade, _species.allLogGrades);
		_cmbGrade.CMUI_ComboLogGrade.setObjectAndSpecies(null, _species);

	endif;

end;</source>
