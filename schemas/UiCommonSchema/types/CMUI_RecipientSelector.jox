        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	xmlStr	: String;
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblContacts.getXmlStrForColumns(true);
	
	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="gotoFirstOfChar" id="54796e07-49da-445f-86da-01c7021c0025">
        <source>gotoFirstOfChar( _char : Character ) protected;
// created by cnwvu1	29/01/2007
// purpose: when typing a letter, to organize going down to the first row having that letter.
vars
	entity		: CM_EmailEntity;
	rtnValue	: Boolean;
	char		: Character;

begin

	char := _char.toUpper();
	entity := self.findEmail(char, false);
	if entity &lt;&gt; null and entity.name[1:1] = char then
		rtnValue := true;
	else
		char := char.toLower();
		entity := self.findEmail(char, false);
		if entity &lt;&gt; null and entity.name[1:1] = char then
			rtnValue := true;
		endif;
	endif;

	if rtnValue then
		self.gotoRow(entity);
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_char" type="Character"/>
    </JadeMethod>
    <JadeMethod name="gotoRow" id="76ad1af1-47e7-451f-af2a-12999376bbea">
        <source>gotoRow(_entity	: CM_EmailEntity) protected;
// created by cnwvu1	29/01/2007

vars
	idx : Integer;

begin

	self.tblContacts.findObjectInRow(_entity, idx);
	if idx &gt; 0 and idx &lt;= self.tblContacts.rows then
		self.tblContacts.topRow := idx;
		 self.tblContacts.deselectAll;
		 self.tblContacts.selectRow( idx, true);
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_entity" type="CM_EmailEntity"/>
    </JadeMethod>
    <JadeMethod name="initTblAddAddress" id="8cbf3c08-dbc7-4797-b526-241ee6f3ad69">
        <updating/>
        <source>initTblAddAddress() updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	entDef			: EntTableDef;
begin
	entDef := app.myController.getEntTableDef(ETDef_EmailAddressMaint);
	
	self.tblAddAddress.setEntTableDef(entDef, null, 'entTableDefSetupWarning');
	self.tblAddAddress.hideRowByName(ETRow_Groups, false);
	self.tblAddAddress.hideRowByName(ETRow_CamsProtocols, false);
	self.tblAddAddress.adjustHeight(200);
	self.tblAddAddress.userInputEnabled := false;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblContacts" id="2af6be24-a480-48ee-93bb-8bd9a67ab035">
        <updating/>
        <source>initTblContacts() updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.tblContacts.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_EmailEntity));
	
	self.tblContacts.userInputEnabled := false;
	self.tblContacts.selectMode := Table.SelectMode_WholeRows;//SelectMode_CurrentRow;
	self.tblContacts.selectionType := CM_DataTable.SelectionType_Row;
	self.tblContacts.multiSelect := self.tblContacts.MultiSelect_Simple;
	self.setColorsForTable(self.tblContacts);

	self.tblContacts.setFocus();	
		
end;</source>
    </JadeMethod>
    <JadeMethod name="keyUp" id="f5677f6a-6952-41cc-8288-23e053641ba8">
        <controlMethod name="Form::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyUp(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if keyCode = J_key_Delete then
		self.addRemoveAddress();
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="a4f662d1-28df-431e-bea8-990ff2f2f233">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	25 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.loadTblContacts();
	self.showAddressesSelected();
	
end;



</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTblContacts" id="2a853897-85a3-490e-bab6-55da64a968a8">
        <source>loadTblContacts() protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.tblContacts.rows := self.tblContacts.fixedRows;
	if app.myPassport.myUser.canDo(self.myTerminal, PmAdmEmailSystem) then
		self.optViewUser.enabled := true;
		self.optViewSystem.enabled := true;
	else
		self.optViewUser.value := true;
		self.optViewUser.enabled := false;	
		self.optViewSystem.enabled := false;
	endif;
	
	if self.optViewUser.value then
		self.tblContacts.displayRowsForCollection(app.myPassport.myUser.allEmailsICanSee, self.colorRow1, self.colorRow2, app.myPassport);	
	else
		self.tblContacts.displayRowsForCollection(app.myRoot.allEmailEntities, self.colorRow1, self.colorRow2, app.myPassport);	
	endif;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
