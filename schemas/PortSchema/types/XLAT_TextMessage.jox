    <JadeMethod name="getDisplayStringForAttribute" id="660dbc57-5ae1-41d8-a6e5-cff03927d59d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2022	navkc1	Initial creation TFS #53916, new ETROW for Table Entities

*/

vars

begin
	
	if _attrName = ETRow_AllTableEntDefs then
		return null; //#53916, navkc1, "Text messages" and "Table Entities" use the same EntTableDefs. Hide the new ETROW in "Text messages".
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isErrorOrWarning" id="b877eeb8-9630-4795-b729-03974c9cc1cb">
        <methodInvocation>mapping</methodInvocation>
        <source>isErrorOrWarning(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     04 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		// get code here
		_value := (self.isError or self.isWarning);
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
</Class>
