    <JadeMethod name="initialise" id="0fac3f6d-06cc-4b7e-b19e-5cdbe29460ca">
        <updating/>
        <source>initialise(_workOrder : CM_WorkOrder; _ti : CM_TrackedItem) updating;
/*

Purpose:			// TFS 38524

Parameters:			

Return Value:		

Date			Who		Reason
13 March 2018	jlgab1	Initial creation
18 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
20 Feb 2025		navlw1	JIRA-33752: MTN | Cash Configuration Criteria Priority Issue
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	bank : CM_Bank;
	proformaCrit : CM_ProformaTransactionCriteria;
	canLogExtra : Boolean;								//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	
	if self.myWorkOrder &lt;&gt; null then // TFS 39236
		return;
	endif;
	
	if _workOrder= null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("** CANNOT Create pro forma invoice lines for WORK ORDER, voyage is null **", LogINFO.String);
		endif;
		return;
	endif;
	
	bank := _workOrder.getMyBank();

	self.allProformaCriteria.clear();
	self.myWorkOrder := _workOrder;
	self.myBank := bank;
	self.myDebtor := _workOrder.getMyDebtor();
	self.myTrackedItem :=  _ti;
	self.effectiveDate := self.releaseDate;
	
	if self.myTrackedItem&lt;&gt; null then
	
		// TFS 39349
		if self.myTrackedItem.myOperator&lt;&gt; null then
			if self.myTrackedItem.myOperator.debtor &lt;&gt; null then
				self.myDebtor := self.myTrackedItem.myOperator.debtor;
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("Setting pro forma debtor to the cargo's debtor - " &amp; self.myDebtor.name, LogINFO.String);
				endif;
			endif;
		endif;
	
		self.ignoreProformaForRoadRelease := true; // self.myTrackedItem.isExport;
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(" " &amp; self.myDebtor.name, LogINFO.String);
			app.invLog("** Create pro forma invoice lines for " &amp; self.myTrackedItem.cargoBOLTypeDescr &amp; " " &amp; self.myTrackedItem.id &amp; " **" &amp; self.myDebtor.name, LogINFO.String);
			app.invLog(" " &amp; self.myDebtor.name, LogINFO.String);
			app.invLog("Find the Estimated Charges" &amp; self.myDebtor.name, LogINFO.String);
		endif;
		if self.myBank &lt;&gt; null then
			if self.myBank.allProformaCriteria &lt;&gt; null and not self.myBank.allProformaCriteria.isEmpty then
				self.myBank.allProformaCriteria.copy( self.allProformaCriteria );
			else
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("Business unit has no pro forma criteria defined", LogINFO.String);
				endif;
			endif;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("No business unit so no pro forma criteria", LogINFO.String);
			endif;
		endif;
		
		self.selectedTrxCriteria := null;
		
		// START navlw1 #JIRA-33752 20/02/2025
		foreach proformaCrit in self.allProformaCriteria discreteLock, reversed do
			// This is CARGO so ignore VESSEL criteria
			if proformaCrit.type &lt;&gt; CM_ProformaTransactionCriteria.TypeCargo then // TFS 37839 
				continue;
			endif;
	
			if proformaCrit.matches( self.myTrackedItem ) then
				self.selectedTrxCriteria := proformaCrit;
				break;
			endif;
		endforeach;
		// END navlw1 #JIRA-33752 20/02/2025
		
		if self.selectedTrxCriteria = null then
			// TFS 36335
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("No matching pro forma criteria can be found for " &amp; self.myTrackedItem.id, LogINFO.String);
			endif;
		endif;	
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);
		app.invLog("** Create pro forma invoice lines for WORK ORDER " &amp; _workOrder.id &amp; " **", LogINFO.String);
		app.invLog(" ", LogINFO.String);
		app.invLog("Find the Estimated Charges", LogINFO.String);
	endif;
	if self.myWorkOrder = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No Work Order specified, cannot create work order proforma invoice lines.", LogINFO.String);
		endif;
		return;
	endif;
	
	if self.myBank = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No bank derived, cannot create work order proforma invoice lines.", LogINFO.String);
		endif;
		return;
	endif;
	
	if self.myDebtor = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No debtor derived, cannot create work order proforma invoice lines.", LogINFO.String);
		endif;
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="nullMyTrackedItem" id="711b8c6f-83fa-41d9-aff2-ea8babd4bea8">
