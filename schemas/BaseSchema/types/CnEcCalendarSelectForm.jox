<GUIClass name="CnEcCalendarSelectForm" id="dd685aa2-318c-4c32-be9a-4fc6ca24e9a5">
    <superclass name="CnEcDialogForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

