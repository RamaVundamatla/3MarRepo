//
vars

begin
	return ETRow_Grade;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="63e40a08-19b9-48c6-aed3-f0195308e86f">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	grade			: CM_MTGrade;
	codeDict		: CM_MTGradeByCodeDict;
begin
	_combo.clear();
	// CCMS 1235
	codeDict := app.myRoot.allAvailabilityGrades;
	
	// Par 10095
	_combo.sorted := false;
	foreach grade in codeDict do
		_combo.itemObject[_combo.addItem(grade.description)] := grade;
	endforeach;


	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.listObject := codeDict[_queryOperator.CM_QIntegerLookupEqual.searchValue];
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := codeDict[_queryOperator.CM_QIntegerLookupNotEqual.searchValue];
	endif;
	
	// Par 10095
	_combo.sorted := true;
	
	
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="e4c4c228-e911-459a-9ae0-e6dbff15ddf7">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	grade			: CM_MTGrade;
	codeDict		: CM_MTGradeByCodeDict;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
begin
	codeDict := app.myRoot.allAvailabilityGrades;
	
	_tbl.rows := _tbl.fixedRows;
	//doesn't know about CMUI_ListTable - so have to do this:
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach grade in codeDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.allSelectionValues.includes(grade.code) then
			selectionValue := 1;
			array.add(grade);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; grade.description);
		_tbl.accessRow(idx).itemObject := grade;
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="4c19a3d0-0552-42ef-baea-731855277a96">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	grade		: CM_MTGrade;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			grade := _tbl.accessRow(idx).itemObject.CM_MTGrade;
			ia.add(grade.code);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="d7192add-fb73-4dbf-84bc-ad8550895f03">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	grade			: CM_MTGrade;
	codeDict		: CM_MTGradeByCodeDict;
	tmpDescription	: String;
	
begin
	
	if _value.isKindOf( CM_MTGrade ) then
		return _value;
	endif;
	
	tmpDescription	:= _value.String.toUpper();
	codeDict := app.myRoot.allAvailabilityGrades;
	
	foreach grade in codeDict discreteLock do
		if tmpDescription = grade.description.toUpper() then
			return grade.code;
		endif;
	endforeach;
	
	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="4fda55cb-77fd-4fae-9c5e-b789b7047831">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tmpGrade			: CM_MTGrade;
begin
	tmpGrade := app.myRoot.allAvailabilityGrades[_value.Integer];
	
	if tmpGrade &lt;&gt; null then
		return tmpGrade.description.trimBlanks;
	endif;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="0d0f32c7-4732-4e2e-9bfb-308832e507a8">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_MTGrade;
	returnVal		: Integer;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;
		
		if _value.isKindOf(CM_MTGrade) then
			object := _value.CM_MTGrade;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="1f883e5c-eb68-4539-befd-60c72237961b">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	int : Integer;
	grade : CM_MTGrade;
	result : String;
	collStr, str : String;
	strArray : StringArray;
	coll : IntegerArray;
	object : CM_MTGrade;

begin
	if _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			grade := app.myRoot.allAvailabilityGrades[int];
			if grade &lt;&gt; null then
				result := result &amp; grade.code.String &amp; CNEC_COMMA &amp; Space;
			endif;
		endforeach;
		result := result[1:result.length-2];
		return result;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create coll transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				coll.add(str.Integer);
			endforeach;
			return coll;
		endif;
		
		if _value.String.isInteger then
			object := app.myRoot.allAvailabilityGrades[_value.Integer];
			if object &lt;&gt; null then
				return object.code;
			endif;
		endif;
		
	elseif _value.isKindOf(Integer) then
		object := app.myRoot.allAvailabilityGrades[_value.Integer];
		if object &lt;&gt; null then
			return object.code;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
