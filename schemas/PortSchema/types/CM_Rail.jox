    <JadeMethod name="addIncompleteWLE" id="282f4e3d-2452-4a35-9663-d27033e0dc7a">
        <updating/>
        <source>addIncompleteWLE(toLine	: String; wle : CM_WorkListEntry input) updating;
//Adds wle to forRake.
vars
	railLine : CM_RailLine;
begin
	if wle = null then
		app.raiseCMException1(ERR_NO_OBJECT, app.getErrorString(Work_list_entry_ref), null, null);
		return;
	endif;
	railLine := self.allRailLines[toLine];
	if railLine = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_WAGON_POSITION, null, null);
		return;
	endif;
	railLine.addIncompleteWLE(wle);
end;</source>
        <Parameter name="toLine" type="String"/>
        <Parameter name="wle" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addLabourRestriction" id="618a745c-e2d1-471e-bb0f-7c803f427bae">
        <updating/>
        <source>addLabourRestriction(restrict : CM_LabourRestriction io) updating;


begin

	exclusiveLock(self);
	exclusiveLock(restrict);

	if labourRestriction &lt;&gt; null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_LC_HAS_RESTS, null, null);
		return;
	endif;

	labourRestriction := restrict;

end;</source>
        <Parameter name="restrict" type="CM_LabourRestriction" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addRailLine" id="82de6d41-0e56-4fc1-a237-a7a14442752d">
        <source>addRailLine(line : CM_RailLine input; atPos : Integer);
/*
 ------------------------------------------------------------------------
Created:			18 December 2001 by cnwdwq1
Purpose:			Adds a rail line to the rail area.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	currPos : Integer;
begin
	if line = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Rail_line_ref), null, null);
		return;
	endif;
	if atPos = 0 then
		if self.allRailLinesByIndex.includes(line) then
			self.allRailLinesByIndex.remove(line);
		endif;
		self.allRailLinesByIndex.add(line);
	else
		//specific location.
		currPos := self.allRailLinesByIndex.indexOf(line);
		if currPos = 0 then
			self.allRailLinesByIndex.insert(atPos, line);
		else
			//In array.
			if atPos &lt;&gt; currPos then
				self.allRailLinesByIndex.remove(line);
				if currPos &lt; atPos then
					self.allRailLinesByIndex.insert(atPos, line);
				else
					self.allRailLinesByIndex.insert(atPos -1, line);
				endif;
			endif;
		endif;
	endif;


	if self.allRailLines.includes(line) then
		return;
	endif;


	self.allRailLines.add(line);


end;</source>
        <Parameter name="line" type="CM_RailLine" usage="input"/>
        <Parameter name="atPos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="containsIncompleteRailRelease" id="72341b39-7cba-40cc-a788-4930da580fe1">
        <source>containsIncompleteRailRelease(forRailLine	: String): Boolean;
//we check here to see if there is anything in the rake that is "incomplete"
vars
	railLine : CM_RailLine;
begin
	railLine := self.allRailLines[forRailLine];
	if railLine = null then 
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_WAGON_POSITION, null, null);
		return false;
	endif;
	return railLine.containsIncompleteRailRelease();
end;</source>
        <Parameter name="forRailLine" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTransferArea" id="b89e348b-99eb-409b-8e38-a0bf741df5ed">
        <updating/>
        <source>createTransferArea(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lProxyYTA	: CM_YardTransferArea;
	lRealYTA	: CM_TerminalAreaMaster;		
	controller : CMIF_TerminalArea;
	
begin
	create lProxyYTA transient;
	lProxyYTA.setProxy(self.id &amp; "TA", null, TA_TYPE_RAIL_TRANS, 0, 5, 5, false, app.getErrorString(Rail_line_transfer), 9999,true,null, self.myTerminal, false, false,false, false,false,null,null,false);

	app.myUtilityCA.utlCreateTerminalArea(lProxyYTA,lRealYTA, _passport);
	
	self.myTransferArea := lRealYTA.CM_YardTransferArea;

epilog

	delete lProxyYTA;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteIncompleteWLE" id="591b133d-f6ca-42a5-9cb9-f3da41cdd841">
        <updating/>
        <source>deleteIncompleteWLE(wle : CM_WorkListEntry) updating;
//Removes the WLE passed in from the "to" list on rail that stops the
//rake being cleared.
vars
	line : CM_RailLine;
begin
	if wle = null then
		return;
	endif;
	foreach line in self.allRailLines do
		line.removeIncompleteWLE(wle);	// If its not in this rake, it returns. Safe to use for all
	endforeach;
end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="erase" id="a4e3e3dd-f8a8-4a6e-b426-d0d7202d7003">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		By deleting this object the auto inverses should delete the CM_RailLines, CM_Wagons, CM_WagonControllers etc.
//				Note was "CM_Rail_erase" in "CMLOCN" C++	
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lRailJSIORailLine	: Object;

begin

	foreach lRailJSIORailLine in self.allRailJSInOut do
			delete lRailJSIORailLine;
	endforeach;

	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="16810e76-8929-4bcd-80cc-82f46596902d">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
/*
 ------------------------------------------------------------------------
Created:			06 July 2001 by cnwdwq1
Purpose:			!     
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------			--------------		-----------------------------------------
11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
---------------------------------------------------------------------------
*/
vars
	iter : Iterator;
	line : CM_RailLine;
	railLineId : String;
	found : Boolean;
	remainingStrs : StringArray;
	
begin
	//20 Feb 2014	NDL	Par 33550
	//inheritMethod(_strs, _noException, _foundLC, _foundHeight);
	_foundLC := null;	//20 Feb 2014	NDL	Par 33550
	_foundHeight := NULLINDEX;	//20 Feb 2014	NDL	Par 33550
	
	if _strs.size = 0 then
		return;
	endif;
	sharedLock(self);
	//-----------------------
	//Find the rail line id
	//----------------------
	iter := self.allRailLines.createIterator();
	while(iter.next(line)) do
		iter.getCurrentKeys(railLineId);  //MTN-35226
		if _strs[1][1: railLineId.length] = railLineId then
			found := true;
			break;
		endif;
	endwhile;
	if not found then
		return;
	endif;
	create remainingStrs transient;
	_strs.copy(remainingStrs);
	//Chop off the railLineId postion before we pass to the railLine to find the rest
	remainingStrs[1] := remainingStrs[1][railLineId.length + 1: end];
	//--------------------
	//We have the rail Line, ask it to retrieve the 'n'th thing that is there
	//--------------------
	line.findLocation(remainingStrs, _noException, _foundLC, _foundHeight);
epilog
	delete remainingStrs;
	unlock(self);
	delete iter;
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findOffsiteLocation" id="ed04c223-24bf-4a31-b7b8-caa512d85da9">
        <source>findOffsiteLocation(_strs: StringArray): Integer;
// 36460
//11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
vars
	iter : Iterator;
	line : CM_RailLine;
	railLineId : String;
	
begin
	if _strs.size = 0 then
		return 0;
	endif;
	sharedLock(self);
	//-----------------------
	// Find the rail line id, which is enough - the last part of the location id is the wagonm position which will no longer be valid
	//		with the cargo and wagon offsite.
	//----------------------
	iter := self.allRailLines.createIterator();
	while iter.next(line) do
		iter.getCurrentKeys(railLineId);  //MTN-35226
		if _strs[1][1: railLineId.length] = railLineId then
			return 1;
			//break;
		endif;
	endwhile;
	
	return 0;
epilog
	unlock(self);
	delete iter;
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
