    <JadeMethod name="btnAdd_click" id="66c1574f-ca47-4f5e-95ad-93f1373c61ab">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicenseForm	: LicenseDetailsForm;
	
begin
	app.mousePointer	:=	Busy;
	
	create theLicenseForm;
	theLicenseForm.setLicenseInfo(null);
	theLicenseForm.showModal();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="7dfd5aac-ad1e-454e-aa98-0dab115124ae">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="031801d7-9a92-40ed-879c-70b256265557">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicenseInfo	: LicenseInfo;
	theTable		: Table;
	
begin
	app.mousePointer	:=	Busy;
	
	theTable	:=	tblLicenses;
	
	if theTable.row &gt; theTable.fixedRows and theTable.row &lt;= theTable.rows then
		theLicenseInfo	:=	theTable.accessRow(theTable.row).itemObject.LicenseInfo;
		
		if theLicenseInfo = null then
			app.msgBox("Please select the License details to delete.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		else
			if app.myLicense.deleteLicenseKey(theLicenseInfo.customerName, theLicenseInfo.productCode, theLicenseInfo.licenseKey) then
				app.myTestData.deleteLicenseInfo(theLicenseInfo);
			endif;
		endif;
	else
		app.msgBox("Please select the License details to delete.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEdit_click" id="0a0161c9-f1d0-4ea9-85d8-97c52d4d99f0">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEdit_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicenseForm	: LicenseDetailsForm;
	theLicenseInfo	: LicenseInfo;
	theTable		: Table;
		
begin
	app.mousePointer	:=	Busy;
	
	theTable	:=	tblLicenses;
	
	if theTable.row &gt; theTable.fixedRows and theTable.row &lt;= theTable.rows then
		theLicenseInfo	:=	theTable.accessRow(theTable.row).itemObject.LicenseInfo;
	endif;
	
	if theLicenseInfo = null then
		app.msgBox("Please select the License details to edit.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	else
		create theLicenseForm;
		theLicenseForm.setLicenseInfo(theLicenseInfo);
		theLicenseForm.showModal();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="807cd23e-3ff2-4447-a115-aa636bf1a039">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable	: Table;
	
begin
	centreWindow();
	
	theTable			:=	tblLicenses;
	theTable.rows		:=	1;
	theTable.selectMode	:=	Table.SelectMode_CurrentRow;
	theTable.setCellText(1, 1, "Customer" &amp; Tab &amp; "Product Code" &amp; Tab &amp; "License Key");
	
	theTable.displayCollection(app.myTestData.allLicenseInfos, true, 0, null);
end;</source>
    </JadeMethod>
    <JadeMethod name="tblLicenses_dblClick" id="a993ed38-ddd9-4ee5-8061-59bfb36ecd6f">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLicenses_dblClick(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		28 March 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnEdit.click(btnEdit);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblLicenses_displayRow" id="be889450-abbb-4527-9d13-47d768b585ff">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLicenses_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.LicenseInfo.getDisplay();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
</GUIClass>
