        <updating/>
        <source>tblSelection_lostFocus(table: Table input) updating;

vars
	ctrl : Control;

begin

	ctrl := table.accessCell(table.row, table.column).cellControl;
	if ctrl &lt;&gt; null and not ctrl.isKindOf(ComboBox) then
		zStartSearch();
	endif;

