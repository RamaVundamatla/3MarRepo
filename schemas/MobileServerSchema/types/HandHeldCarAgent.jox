    <JadeMethod name="resetNotes" id="4c9cf7a3-f7d6-4378-822f-1c151db72f10">
        <source>resetNotes() protected;
// ---------------------------------------------------------------------------
// Created:		12 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	event : Integer;
	theTI : CM_TrackedItem;
begin

	event := self.myTerminal.getTerminalEvent(EVENT_TI_ALTID_UPDATE);

	inheritMethod();
	
	if self.myTerminal &lt;&gt; null then
		self.beginNotification(self.myTerminal, event ,Response_Continuous , null);	
	endif;

end;</source>
