    <JadeMethod name="populateDateCombos" id="b24ac063-0405-4e3a-821f-5f35899ff0c9">
        <source>populateDateCombos() protected;
// populate the voyage arrival and departure date option combos
// 34917 add more for Ghana
// 35991 add a null entry and sort
// 26/05/2023	navkc1	CR 58009 Task 58010: UI - Storage Config - Storage Configuration Receival
vars
	combo	: CMUI_ComboBox;
	isNew	: Boolean;
begin
	combo := self.cmbReceivalDates;
	// Are we creating new storage config?
	isNew := self.myStorageConfig = null;
	combo.sorted := true;
	//combo.itemData[combo.addItem(" ")] := -1; // 26/05/2023	navkc1	CR 58009 Task 58010 - Don't want blank option
	combo.itemData[combo.addItem(Voyage_Actual_Discharge_Str)] := Voyage_Actual_Discharge;
	combo.itemData[combo.addItem(Voyage_Pilot_On_Board_Str)] := Voyage_Pilot_On_Board;
	combo.itemData[combo.addItem(Voyage_Anchor_Down_Str)] := Voyage_Anchor_Down;
	combo.itemData[combo.addItem(Voyage_Arrival_Str)] := Voyage_Arrival;
	combo.itemData[combo.addItem(Voyage_Labour_On_Board_Str)] := Voyage_Labour_On_Board;
	combo.itemData[combo.addItem(Voyage_Ship_Exchange_Start_Str)] := Voyage_Ship_Exchange_Start;
	combo.itemData[combo.addItem(Voyage_Rec_Labour_Ashore_Str)] := Voyage_Rec_Labour_Ashore;
	combo.itemData[combo.addItem(Voyage_Rec_Ship_Exch_End_Str)] := Voyage_Rec_Ship_Exch_End;
	combo.itemData[combo.addItem(Voyage_General_Landing_Str)] := Voyage_General_Landing;	//15 Mar 2016	NDL	TFS 1407
	combo.itemData[combo.addItem(Voyage_Rec_First_Day_Avail_Str)] := Voyage_Rec_First_Day_Avail;	//14 Dec 2016	NDL	TFS 3119 / 3038
	// Default to the first option if creating new config
	if isNew then
		combo.listIndex := 1;
	endif;
	combo := self.cmbReleaseDates;
	combo.sorted := true;
	//combo.itemData[combo.addItem(" ")] := -1; // 26/05/2023	navkc1	CR 58009 Task 58010 - Don't want blank option
	combo.itemData[combo.addItem(Voyage_Actual_Load_Str)] := Voyage_Actual_Load;
	combo.itemData[combo.addItem(Voyage_Ship_Exchange_End_Str)] := Voyage_Ship_Exchange_End;
	combo.itemData[combo.addItem(Voyage_First_Day_Avail_Str)] := Voyage_First_Day_Avail;
	combo.itemData[combo.addItem(Voyage_Labour_Ashore_Str)] := Voyage_Labour_Ashore;
	combo.itemData[combo.addItem(Voyage_Departed_Str)] := Voyage_Departed;
	combo.itemData[combo.addItem(Voyage_Pilot_Return_Str)] := Voyage_Pilot_Return;
	combo.itemData[combo.addItem(Voyage_Rel_Ship_Exch_Start_Str)] := Voyage_Rel_Ship_Exch_Start;
	combo.itemData[combo.addItem(Voyage_Rel_Labour_Onboard_Str)] := Voyage_Rel_Labour_Onboard;
	// Default to the first option if creating new config
	if isNew then
		combo.listIndex := 1;
	endif;
	// TFS 4274	 GL date is not for exports so this would never have worked.
// TFS 4274	combo.itemData[combo.addItem(Voyage_General_Landing_Str)] := Voyage_General_Landing;	//15 Mar 2016	NDL	TFS 1407
	
	// 26/05/2023	navkc1	CR 58009 Task 58010
	// Truck Receival based on
	combo := self.cmbTruckReceival;
	combo.itemData[combo.addItem(Storage_RoadActualReceivalStr)] := Storage_RoadActualReceival;
	combo.itemData[combo.addItem(Storage_RoadActualUnloadStr)] := Storage_RoadActualUnload;
	// Default to the first option if creating new config
	if isNew then
		combo.listIndex := 1;
	endif;
	// 26/05/2023	navkc1	CR 58009 Task 58010
	// Wagon Receival based on
	combo := self.cmbWagonReceival;
	combo.itemData[combo.addItem(Storage_RailActualReceivalStr)] := Storage_RailActualReceival;
	combo.itemData[combo.addItem(Storage_RailActualUnloadStr)] := Storage_RailActualUnload;
	// Default to the first option if creating new config
	if isNew then
		combo.listIndex := 1;
	endif;
	// 26/05/2023	navkc1	CR 58009 Task 58010
	// Child Receival based on
	combo := self.cmbChildReceival;
	combo.itemData[combo.addItem(Storage_UnpackSameAsParentStr)] := Storage_UnpackSameAsParent;
	combo.itemData[combo.addItem(Storage_UnpackActualUnpackStr)] := Storage_UnpackActualUnpack;
	// Default to the first option if creating new config
	if isNew then
		combo.listIndex := 1;
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setComboIndex" id="a93dd988-6ee8-4449-ae3f-51c048c5d020">
        <source>setComboIndex(_combo : ComboBox input; _value : Integer) protected;

vars
	idx, tot	: Integer;
begin
	tot := _combo.listCount();
	foreach idx in 1 to tot do
		if _combo.itemData[idx] = _value then
			_combo.listIndex := idx;
			break;
		endif;
	endforeach;

end;
</source>
        <access>protected</access>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="256cc47a-156f-413a-834f-2bb7d92678c0">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Sep 2012	cnwer1	Initial creation CCMS MES 1035
10 Oct 2017	jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing
19 Sep 2019	jlgdi	45972 Increased the minimum height and width of the form to accommodate 2 new controls (MT Storage Group ST and Group EX)
*/

constants
	FORM_MIN_HEIGHT : Integer = 470;
	FORM_MIN_WIDTH : Integer = 800;
	
begin
	self.minimumHeight := FORM_MIN_HEIGHT;	//20 Sep 2017	NDL	TFS 7032
	self.minimumWidth := FORM_MIN_WIDTH;

	inheritMethod();

	self.initControls();
	
	self.loadStorageConfig();
	
	// TFS 2198 CNWAB1
	self.doPopulateButtons();						//+TFS7228

	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_STORAGECONFI_CREATE), Response_Continuous, null);				//+TFS7228
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_STORAGECONFI_DELETE), Response_Continuous, null);				//+TFS7228
end;</source>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="ebcece9a-c68b-423a-8604-7eef40b0b849">
        <updating/>
        <source>skipToAttribute(_attributeName: String; _shtName: String) updating;
/*

Purpose: Set the target sheet on top

Parameters:			

Return Value:		

Date		Who		TFS		Reason
19 Sep 2019	jlgdi1	45972	Initial creation
*/

vars
	index : Integer;
	control : Control;
	tmpSheet : CMUI_Sheet;
	
begin
	foreach index in 1 to self.controlCount do
		control := self.controls(index);
		if control.isKindOf( CMUI_Sheet ) then
			tmpSheet := control.CMUI_Sheet;
		else
			continue;
		endif;
		if tmpSheet.caption &lt;&gt; _shtName then
			continue;
		endif;
		control.showMySheet();
		control.setFocus();
		break;
	endforeach;
end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c30ff6ad-a967-4faf-8e81-16d508e1c116">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 May 2023 08:12:23.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022133, locale);
	btnApply.translateCaption(Xlat_0022134, locale);
	btnCancel.translateCaption(Xlat_0022135, locale);
	btnDetails.translateCaption(Xlat_0022136, locale);
	btnRemove.translateCaption(Xlat_0022137, locale);
	btnSave.translateCaption(Xlat_0022138, locale);
	btnViewAudits.translateCaption(Xlat_0022158, locale);
	chkInc1stDay.translateCaption(Xlat_0022139, locale);
	chkIncLastDay.translateCaption(Xlat_0022140, locale);
	chkMTStorage.translateCaption(Xlat_0023729, locale);
	chkMTStorageEX.translateCaption(Xlat_0023730, locale);
	lblAttributes.translateCaption(Xlat_0022141, locale);
	lblChildReceivalBased.translateCaption(Xlat_0026073, locale);
	lblCompulsory.translateCaption(Xlat_0022142, locale);
	lblCutoff.translateCaption(Xlat_0022143, locale);
	lblExplainCompl.translateCaption(Xlat_0022145, locale);
	lblExplainExclude.translateCaption(Xlat_0022146, locale);
	lblReceivalBased.translateCaption(Xlat_0022147, locale);
	lblReleaseBased.translateCaption(Xlat_0022148, locale);
	lblTrans.translateCaption(Xlat_0022149, locale);
	lblTruckReceivalBased.translateCaption(Xlat_0026074, locale);
	lblWagonReceivalBased.translateCaption(Xlat_0026075, locale);
	lblWorkingDays.translateCaption(Xlat_0022150, locale);
	mnuResetStorageDays.translateCaption(Xlat_0022151, locale);
	mnuTriggersContext.translateCaption(Xlat_0022152, locale);
	shtAttributes.translateCaption(Xlat_0022153, locale);
	shtCargoTypes.translateCaption(Xlat_0024626, locale);
	shtStorage.translateCaption(Xlat_0022154, locale);
	shtTrans.translateCaption(Xlat_0022155, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="3c59cbcf-d4bd-4421-a3cb-cb04f6742e86">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2017	jlgrh7	Initial creation TFS7228

*/

vars

begin
	if eventType = EVENT_STORAGECONFI_CREATE or
		eventType = EVENT_STORAGECONFI_DELETE then
		self.doPopulateButtons();
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
