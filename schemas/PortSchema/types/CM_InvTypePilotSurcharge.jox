    <JadeMethod name="setProxy" id="0cc54342-5790-4bb9-99b4-4fbdcb873e8f">
        <updating/>
        <source>setProxy(	_surcharges : CM_InvoiceTypeSurchargeExempt;
			_notReadyLineType : CM_InvoiceLineDesc;
			_tooSoonLineType : CM_InvoiceLineDesc	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharges
//
vars

begin
	self.myPilotSurchargeInvLineTypeVNR := _notReadyLineType;
	self.myPilotSurchargeInvLineTypeRTS := _tooSoonLineType;
	
	self.mySurchargesAndExemptions := _surcharges;
epilog

end;</source>
        <Parameter name="_surcharges" type="CM_InvoiceTypeSurchargeExempt"/>
