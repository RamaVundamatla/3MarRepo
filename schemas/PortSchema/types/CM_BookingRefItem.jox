        <source>getViewName():String;
/*
	Created on 14 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	viewName : String;
begin
	if myCargoType &lt;&gt; null and myCargoType.isSystemCargoBOLType then
		viewName := myCargoType.gateInOutExtraTblReceiveView;
		if viewName = null then
			viewName := 'Default';
		endif;
	else
		viewName := 'BBLKGeneric';
	endif; 
	return viewName;
end;</source>
