    <JadeMethod name="pxyCreateUpdateProxy" id="508ff59a-3050-45fb-a5f0-d30567ff0841">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe :=  inheritMethod();

	pxyMe.myResource := self.myResource;
	pxyMe.myTransMap := self.myTransMap;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a587ba70-9cdd-47ab-9d5c-8a0d43a3c6e1">
