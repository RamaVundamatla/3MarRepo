    <JadeMethod name="shouldAuditProperty" id="3671a760-1f44-40dc-93c0-5a8ec5e08929">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_DebtorMap::myChildQuantityMap.name or
		propName = CM_DebtorMap::myDebtorType.name or
		propName = CM_DebtorMap::myDebtorNode.name  or
		propName = CM_DebtorMap::myServiceBroker.name  
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
