    <JadeMethod name="configureForFeetAndInches" id="dc26669e-fe38-4dcc-b0c8-8298a0573cc7">
        <source>configureForFeetAndInches();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2013	cnwmc5	Initial creation	PAR 33074

*/
vars
	measureType : CM_MeasurementType;
begin
	if self.cmbMeasureType.listIndex &gt; -1 then
		measureType := self.cmbMeasureType.itemObject[self.cmbMeasureType.listIndex].CM_MeasurementType;
	endif;
	
	if measureType &lt;&gt; null then
		if measureType.isFeetAndInches then
			self.txtValue.visible := false;
			self.txtFeetAndInches.visible := true;
		else
			self.txtValue.visible := true;
			self.txtFeetAndInches.visible := false;
		endif;
	endif;

end;</source>
    </JadeMethod>
