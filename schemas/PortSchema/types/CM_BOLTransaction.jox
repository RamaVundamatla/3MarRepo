    <JadeMethod name="getDisplayID" id="f931df19-8c9c-4a64-ad73-5b3001708bd6">
        <source>getDisplayID(): String;
//
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
vars

begin
	if self.myBOL &lt;&gt; null then
		return self.myBOL.number;
	else
		return inheritMethod;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ca0391ff-b74c-4cc0-8147-114ed746e569">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Date		Who		Reason
29 January 2015	cnwer1	Initial creation PAR
08 June 2023 navmv20 CR 54345 Task 57116: Jade - Contract Id Work Order Enquiry
30 May  2025 navrv30 MTN 34789 MTN | Query by BOL option doesn't return results for BOL-generated invoices
*/

vars

	str, result : String;
	debtor	: CM_Debtor;
	voyage	: CM_Voyage;
	invLine : CM_InvoiceLine;
begin

	if _attrName = ETRow_SortKey  then
		return null;
	// ### JIRA 14794 04NOV2024 NAVAB1
	elseif _attrName = ETRow_InvoiceLines then
		foreach invLine in self.allInvoiceLines do
			if result = null then
				result := invLine.sequenceNum.String;
			else
				result := result &amp; ", " &amp; invLine.sequenceNum.String;
			endif;
		endforeach;
		return result;
	elseif _attrName = ETRow_RowKey  then
		return null;
	elseif _attrName = ETRow_Details  then  //30 May  2025 navrv30 MTN 34789
		return self.getDisplayID();	
	elseif _attrName = ETRow_Type  then
		return self.getTypeString;
	elseif _attrName = ETRow_TransactionType
		or  _attrName = ETRow_TypeString	//05 Nov 2019	NDL	TFS 47100
		then
		return self.getTypeString;
	elseif _attrName = ETRow_Date or
		   _attrName = ETRow_DateTime then
		return self.systemToLocalTime(self.dateTime).shortCurrentLocaleFormat;	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	// from CCMS 1262 Jan 2012 transaction enquiry and selector queries, used in transaction edit to show just the date part
	//  also reported as problem 29284 Mar 2012
	elseif _attrName = ETRow_Date2 then
		return self.systemToLocalTime(self.dateTime).date.shortFormatJMT();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_Charged  then
	//	return null;
		return app.getYesBlank( self.isCharged() );		//05 Nov 2019	NDL	TFS 47100
		
	elseif _attrName = ETRow_User
		or _attrName = ETRow_UserName		//05 Nov 2019	NDL	TFS 47100
		then
		return self.userId;
	elseif _attrName = ETRow_Created  then
		return self.systemToLocalTime(self.createdTime).shortCurrentLocaleFormat();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	
	elseif _attrName = ETRow_NoCharge then	//05 Nov 2019	NDL	TFS 47100
		return app.getYesBlank(self.noCharge);
		
	elseif _attrName = ETRow_MyHMSVoyageData then	//05 Nov 2019	NDL	TFS 47100	
		voyage := self.getMyVoyage();
		if voyage = null then	
			return null;
		else
			return voyage.code;
		endif;
		
	elseif _attrName = ETRow_Debtor then		//05 Nov 2019	NDL	TFS 47100	
		debtor := self.getDebtorForSelector();
		if debtor = null then
			return null;
		else
			return debtor.name;
		endif;
	
	//09 Dec 2019	NDL	TFS 47943
	elseif ( _attrName = ETRow_HouseBillOfLading
		or _attrName = ETRow_BillOfLading 
		or _attrName = ETRow_TransactionBOL
		) then
		if self.myBOL &lt;&gt; null then
			return self.myBOL.number;
		else
			return null;
		endif;
	endif;
	return inheritMethod(_attrName, _short); //08/06/2023 navmv20 CR 54345 Task 57116
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceNumber" id="c14b643f-83b8-4bb7-bb0b-f3da18e8165c">
        <source>getInvoiceNumber():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	invoiceLine		: CM_InvoiceLine;
begin
	invoiceLine := self.allInvoiceLines.first;
	if invoiceLine = null then
		return null;
	else
		return invoiceLine.invoice.sequenceNum.String;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyBank" id="14c9d495-374e-4896-9004-c4f024ed1ec3">
        <source>getMyBank():CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	bank : CM_Bank;
	term : CM_Terminal;

begin

	if self.myBOL &lt;&gt; null then
		bank := self.myBOL.getMyBank();
	endif;

	if bank = null then
		term := self.getMyTerminal;
		if term &lt;&gt; null then
			bank := term.getDefaultCompanyBank();
		endif;
	endif;
	
	return bank;

epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="bc73a69b-e535-411c-84ec-c5fc2223bda1">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	term : CM_Terminal;

begin

	if self.myTerminal &lt;&gt; null then
		return self.myTerminal;
	endif;

	if self.myBOL &lt;&gt; null then
		term := self.myBOL.getMyTerminal;
		if term &lt;&gt; null then
			return term;
		endif;
	endif;

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
