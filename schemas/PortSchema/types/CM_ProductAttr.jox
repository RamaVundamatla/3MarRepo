    <JadeMethod name="setForUpdate" id="db49fbc4-8dd5-4a63-8fa6-ac54672532df">
        <updating/>
        <source>setForUpdate(_pxyAttr : CM_ProductAttr) updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 14/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	
begin
	self.displayName 		:= _pxyAttr.displayName;
	//epr TFs 7756 16/2/18 if not included on cargo type don't set is viewable
	if _pxyAttr.myProduct.myCargoType &lt;&gt; null then
		if not _pxyAttr.myProduct.myCargoType.allAttributesOnProduct.includes(self.name) then
			self.isViewable :=false;
		else
			self.isViewable 		:= _pxyAttr.isViewable;
		endif;	
	else
		self.isViewable 		:= _pxyAttr.isViewable;
	endif;
	self.validationType 	:= _pxyAttr.validationType;
	
	self.myMeasurementType	:= _pxyAttr.myMeasurementType;			// PAR #31155
end;</source>
        <Parameter name="_pxyAttr" type="CM_ProductAttr"/>
    </JadeMethod>
    <JadeMethod name="setFromCopy" id="62e2a1c7-8c6a-4775-b53d-a753f40f829e">
        <updating/>
        <source>setFromCopy(_copy : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCode,
	loopCode		: CM_ProductAttributeCode;

begin

	foreach loopCode in _copy.allCodes do
		tmpCode := loopCode.cloneSelf(false);
		self.allCodes.add(tmpCode);
	endforeach;
	
	_copy.allValidationTypes.copy(self.allValidationTypes);

	if _copy.myCode &lt;&gt; null then
		self.myCode	:= _copy.myCode.cloneSelf(false);
	endif;
	self.myType	:= _copy.myType;
	
end;</source>
        <Parameter name="_copy" type="SelfType"/>
    </JadeMethod>
