    <JadeMethod name="utlUpdateShipDeckLayersForDefn" id="c89db02c-73fd-47eb-91b3-f6a4d1c2b33a">
        <updating/>
        <source>utlUpdateShipDeckLayersForDefn(_pxyLayers : ObjectArray; _realLayers: ObjectArray;  _passport : CM_Passport input) : Boolean updating;

vars
	aOK:Boolean;
	pxyLayer,realLayer,realLayerNew,tmpLayer : CM_ShipDeckLayer;
	theObjects:	ObjectSet;
	tmpObj : Object;
begin
	
	if _passport.noErrors then
		// check for deletes
		aOK := false;
		create theObjects transient;
		foreach tmpObj in _realLayers do
			realLayer := tmpObj.CM_ShipDeckLayer;
			// if the real has no linked proxy then it must die!
			if realLayer.pxyGetProxyObject = null then
				theObjects.add(realLayer);
			endif;
		endforeach;
		while not theObjects.isEmpty do
			realLayer := theObjects.first.CM_ShipDeckLayer;
			theObjects.remove(realLayer);
			app.myUtilityDA.utlDeleteShipDeckLayer(realLayer.CM_ShipDeckLayer,_passport);
			if not _passport.noErrors then
				break;
			endif;
		endwhile;
		delete theObjects;
		
		
		// #### Create and Update
		if _passport.noErrors then
			foreach tmpObj in _pxyLayers do
				pxyLayer := tmpObj.CM_ShipDeckLayer;
				if pxyLayer.pxyGetRealObject() &lt;&gt; null then
					self.utlUpdateShipDeckLayer(pxyLayer,_passport);
				else

					// if the real has no linked proxy then it must be born!
					app.myUtilityCA.utlCreateShipDeckLayer(pxyLayer,realLayerNew, _passport);
					app.myProxyManager.createProxyLink(realLayerNew, pxyLayer);
					
					aOK := true;
				endif;
				if not _passport.noErrors then
					break;
				endif;
			endforeach;
		endif;
		
	endif;
	
	return aOK;

epilog
	
end;</source>
        <Parameter name="_pxyLayers" type="ObjectArray"/>
        <Parameter name="_realLayers" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateShipDecksForDefn" id="e0966c11-ec8e-4044-806e-138d47a9cfed">
        <updating/>
        <source>utlUpdateShipDecksForDefn(_pxyDecks : ObjectArray; _realDecks: ObjectArray ;  _passport : CM_Passport input) : Boolean updating;

vars
	aOK:Boolean;
	pxyDeck,realDeck,realDeckNew,tmpDeck : CM_ShipDeck;
	theObjects:	ObjectSet;
	tmpObj : Object;
begin
	
	if _passport.noErrors then
		// check for deletes
		aOK := false;
		create theObjects transient;
		foreach tmpObj in _realDecks do
			realDeck := tmpObj.CM_ShipDeck;
			// if the real has no linked proxy then it must die!
			if realDeck.pxyGetProxyObject = null then
				theObjects.add(realDeck);
			endif;
		endforeach;
		while not theObjects.isEmpty do
			realDeck := theObjects.first.CM_ShipDeck;
			app.myUtilityDA.utlDeleteShipDeck(realDeck.CM_ShipDeck,_passport);
			if not _passport.noErrors then
				break;
			endif;
			theObjects.remove(realDeck);
		endwhile;
		delete theObjects;
		
		
		// #### Create and Update
		if _passport.noErrors then
			foreach tmpObj in _pxyDecks do
				pxyDeck := tmpObj.CM_ShipDeck;
				if pxyDeck.pxyGetRealObject() &lt;&gt; null then
					self.utlUpdateShipDeck(pxyDeck,_passport);
				else

					// if the real has no linked proxy then it must be born!
					app.myUtilityCA.utlCreateShipDeck(pxyDeck,realDeckNew, _passport);
					app.myProxyManager.createProxyLink(realDeckNew, pxyDeck);

					aOK := true;
				endif;
				if not _passport.noErrors then
					break;
				endif;
			endforeach;
		endif;
		
	endif;
	
	return aOK;

epilog
	
end;</source>
        <Parameter name="_pxyDecks" type="ObjectArray"/>
        <Parameter name="_realDecks" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateShipLineStat" id="fba70605-6119-448a-a8ca-2b14ef304341">
        <updating/>
        <source>utlUpdateShipLineStat(_pxyObject : CM_ShippingLineStatus; _passport : CM_Passport input) updating;
// ##### CR 59580 TASK 59586 NAVAB1 04AUG2023
vars
	realObject		: CM_ShippingLineStatus;
