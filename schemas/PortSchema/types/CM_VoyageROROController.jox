    <JadeMethod name="addSlotRequest" id="8c9d0723-87b7-4bf2-be18-0696f8e609e7">
        <updating/>
        <source>addSlotRequest(_isLoad : Boolean; _request : CM_RORORequest input) updating;
/*
Purpose:		Updates the slotRequest collection AND THE STATIC property.
							We use the static property to quickly get the current state of the the controller.	
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	otherSlotRequest :CM_RORORequest;
	otherLC : CM_VoyageROROController;
begin

	if _request.myROROController &lt;&gt; self and _request.myROROController &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'attempt to add RORO Request to (' &amp; self.String &amp;
					') when  RORO Request.myROROController = ' &amp; _request.myROROController.String);
		return;
	endif;

	if _isLoad then
		if self.allRequestsLoad.includes(_request) then
			return;
		endif;
		self.myDeck.addRequestToSortDict(_request);
		self.allRequestsLoad.add(_request);
		// TFS 41381 self.myRORORequestLoad := _request;
		
		
		_request.setMyLC(self); // PAR 28890
	else
		if self.allRequestsDischarge.includes(_request) then
			return;
		endif;
		self.allRequestsDischarge.add(_request);
		// TFS 41381 self.myRORORequestDischarge := _request;
	endif;


end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_request" type="CM_RORORequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="archive" id="26aada9c-2742-4554-9932-ccf8943399e6">
        <updating/>
        <source>archive(_controller: CMIF_ArchiveVoyage; _moveControl: CMIF_MoveController input; _tiArray: CM_TIArray input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2020 cnwma1 Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue
*/

vars
	tmpSlotRequest  : CM_RORORequest;
begin

	exclusiveLock(self);
	if _controller = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'controller', null, null);
		return;
	endif;
	if _passport = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'passport', null, null);
		return;
	endif;
	if _moveControl = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_moveControl', null, null);
		return;
	endif;	
	
	inheritMethod(_controller, _moveControl, _tiArray, _passport);
	//----------------------
	//Nuke the slot Requests (load/discharge)
	//------------------------
	
	if self.myRORORequestDischarge &lt;&gt; null then 
		self.myRORORequestDischarge.erase(NORMAL_ERASE);
		self.myRORORequestDischarge := null;
	endif;
	
	while true do
		tmpSlotRequest := self.allRequestsDischarge.last;
		if tmpSlotRequest = null then
			break;
		endif;
		tmpSlotRequest.erase(NORMAL_ERASE);			
	endwhile;

	if self.myRORORequestLoad &lt;&gt; null then 
		self.myRORORequestLoad.erase(NORMAL_ERASE);
		self.myRORORequestLoad := null;
	endif;
	
	while true do
		tmpSlotRequest := self.allRequestsLoad.last;
		if tmpSlotRequest = null then
			break;
		endif;
		tmpSlotRequest.erase(NORMAL_ERASE);			
	endwhile;
	
end;</source>
        <Parameter name="_controller" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createDefaultDischargeCC" id="46d28429-a584-4e89-bec2-66ff8dc2a8f0">
        <updating/>
        <source>createDefaultDischargeCC(_passport : CM_Passport input; _isManual : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
begin
	exclusiveLock(self);
	self.createDischargeCC(DISCHARGE_MOVETYPE, _isManual, _passport); // PAR 28319 pass in false as this is automatic not manual
epilog
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_isManual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDischargeCC" id="3418fb56-5315-48e4-9288-7f8e542e571d">
        <updating/>
        <source>createDischargeCC(_moveType : Integer; _isManual : Boolean; _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	ti					: CM_TrackedItem;
	pxySR				: CM_RORORequest;
	newRequest, fwdReq		: CM_RORORequest;
	aftSlotReq			: CM_RORORequest;
	tisToBeDischarged	: CM_TIArray;
	is40				: Boolean;
	dischargeReq		: CMIF_DischargeRequest;
	reqClass : Class;
	aftLC : CM_VoyageROROController;
	theVoyage : CM_Voyage;
	theTerminal : CM_Terminal;
begin

	theVoyage := self.myVoyage;
	theTerminal := theVoyage.myTerminal;

	exclusiveLock(self);
	//----------------------
	//Check whether it has a ti for discharge here
	//----------------------
	create tisToBeDischarged transient;
	foreach ti in self.allTrackedItems do
		if self &lt;&gt; ti.getPrimaryLocation(REAL_MODE) then
			continue;	//Not primary slot.
		endif;
		if not _isManual then
			if ti.isToBeDischargedHere() then
				tisToBeDischarged.add(ti);
				if is40 = false 
				and (ti.isAttributeTrue(TI_Attrib_IsForty) or	ti.isOverSizedContainer()) then // PAR 21746
					is40 := true;	//Set this so we can set the back end, it means there is at least 1 40, 30, 45, 53 in this slot
				endif;
			endif;
		else
			tisToBeDischarged.add(ti);
			if is40 = false 
			and (ti.isAttributeTrue(TI_Attrib_IsForty) or	ti.isOverSizedContainer()) then // PAR 21746
				is40 := true;	//Set this so we can set the back end, it means there is at least 1 40, 30, 45, 53 in this slot
			endif;
		
		endif;
	endforeach;
	//if self.allSlotRequestsDischarge.isEmpty then
	if (not tisToBeDischarged.isEmpty()) and (self.myRORORequestDischarge = null 
														or (self.myRORORequestDischarge &lt;&gt; null  and self.myRORORequestDischarge.isComplete) ) then // PAR 30373
		if _moveType = NULL_MOVETYPE then
			//If no discharge slot request, then dont bother doing anything
			return;
		endif;
		//----------------------
		//Create it.
		//----------------------
		reqClass := self.getRequestClass();
		create pxySR as reqClass transient;
		pxySR.setProxyForCreate(self, _moveType, false, self.getTotalQuantityActual()); // cargo type set later on
		app.myUtilityCA.utlCreateSlotRequestRORO(pxySR, newRequest, _passport);
		
		app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								self);
		
		//----------------------
		// use the TI to populate the request
		//----------------------
		//
		fwdReq := null;
		ti := tisToBeDischarged.first();
		if ti &lt;&gt; null and newRequest &lt;&gt; null then		// newRequest not created if fails validation
			fwdReq := newRequest;
			//create dischargeReq transient;
			delete pxySR;
			pxySR := newRequest.pxyCreateUpdateProxy();
			pxySR.setFromTI(ti);
			//tisToBeDischarged.copy(dischargeReq.allTrackedItems);
			app.myUtilityUA.utlUpdateSlotRequestDischRORO(pxySR, tisToBeDischarged, _passport);

			if is40 then
				aftLC := self.getAftLC();
				if aftLC &lt;&gt; null then
					delete pxySR;
					create pxySR as reqClass transient;
					pxySR.setProxyForCreate(aftLC, _moveType, false, 1); // cargo type set later on
					app.myUtilityCA.utlCreateSlotRequestRORO(pxySR, newRequest, _passport);
					//----------------------
					// use the TI to populate the request
					//----------------------
					//
					if newRequest &lt;&gt; null then		// newRequest not created if fails validation
						delete pxySR;
						pxySR := newRequest.pxyCreateUpdateProxy();
						pxySR.setFromTI(ti);
						app.myUtilityUA.utlUpdateSlotRequestDischRORO(pxySR, tisToBeDischarged, _passport);
						newRequest.setForwardSlotRequest(fwdReq);
					endif;			
				endif;
			endif;
			
		endif;
		
		
	endif;
	
		
	if _moveType = DISCHARGE_MOVETYPE then // PAR 29033 This code changes the TI to an IMPORT, if we are doing DLR/SOB we want them to stay as RoB
		foreach ti in tisToBeDischarged do
			if ti.getVoyageWLEUnactioned(false) &lt;&gt; null then 
				ti.statusEvent(DIS_CCODE_STATUS_EV, true, _passport);
			endif;
		endforeach;	
	endif;

epilog
	delete pxySR;
	delete dischargeReq;
	delete tisToBeDischarged;
end;</source>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_isManual" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createUpdateRORORequest" id="9e551211-2795-4237-812b-5b05eb74cd61">
        <updating/>
        <source>createUpdateRORORequest(_isLoad : Boolean; _voyAlloc : CM_VoyageAllocation; _numItems : Integer; _moveType : Integer; _fwdSlot : CM_VoyageROROController; _passport : CM_Passport input): CM_RORORequest updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation
21/11/11 - Added _fwdSlot - PAR 28585
*/

vars
	theLinkedRequest,
	pxyRequest,
	realRequest	: CM_RORORequest;
	tmpSlot,
	theLinkedSlot	: CM_VoyageROROController;
	theTI			: CM_TrackedItem;
	theMoveType		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,
	needAftRequest	: Boolean;
	
begin

	tmpVoyage := self.myVoyage;

	
	if _isLoad then
		realRequest := self.myRORORequestLoad;
	else
		realRequest := self.myRORORequestDischarge;
	endif;	

	// PAR 28479
	theMoveType := _moveType;
	
	if theMoveType = NULL_MOVETYPE then
		if _isLoad then
			theMoveType := LOAD_MOVETYPE;
		else
			theMoveType := DISCHARGE_MOVETYPE;
		endif;
	endif;
	
	if realRequest = null 
	or (realRequest &lt;&gt; null and realRequest.isComplete) // PAR 30985 REWORK JOB
	// PAR 30985 - we do not complete the backends, so if we are a backend we need to check if the fwd is complete
	or (realRequest &lt;&gt; null and realRequest.getAttrIsBackend() and realRequest.getFwdSlotReq()  &lt;&gt; null  and realRequest.getFwdSlotReq().isComplete) then 
	   
	   // PAR 30985 realRequest.myJob &lt;&gt; null and
	   // PAR 30985 realRequest.myJob.isJobComplete) then 
	   
		realRequest := null;
	   	isCreate := true;

		// we need to create a request
		create pxyRequest as self.getRequestClass() transient;
		pxyRequest.setProxyForCreateVA(self, theMoveType, _isLoad,_numItems,_voyAlloc);	// PAR 28479	- theMoveType
		
		if _fwdSlot &lt;&gt; null then
			if _isLoad then
				pxyRequest.setForwardSlotRequest(_fwdSlot.myRORORequestLoad); // PAR 28585
			else
				pxyRequest.setForwardSlotRequest(_fwdSlot.myRORORequestDischarge); // PAR 28585
			endif;
		endif;
		
		if _passport.hasErrors then
			// something went wrong in the above set
			return null;
		endif;
	else
		pxyRequest := realRequest.pxyCreateUpdateProxy();
		pxyRequest.setProxyForCreateVA(self, theMoveType, _isLoad,_numItems,_voyAlloc);		// PAR 28479 - theMoveType
	endif;


	if isCreate then
		app.myUtilityCA.utlCreateSlotRequestRORO(pxyRequest, realRequest, _passport);
	else
		app.myUtilityUA.utlUpdateSlotRequestRORO(pxyRequest, _passport, true);
	endif;
	
	
	return realRequest;

epilog
	delete pxyRequest;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_fwdSlot" type="CM_VoyageROROController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="eraseRequest" id="a3ea5928-449d-42e3-b7ec-ebff7e49d53a">
        <updating/>
        <source>eraseRequest(_request : CM_RORORequest input) updating;
/*
Purpose:	Erase the colour coding, at the same time clean up WLEs and any planned future moves		
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
18 Dec 2012	cnwrs1	Par 30923 handle already deleted request
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	theTI				: CM_TrackedItem;
	aDischarge			: Boolean;
	fortyBack			: Boolean;
	theWLE				: CM_WorkListEntry;
	theMoveController	: CMIF_MoveController;
	portHere,portTI : CM_Port;
	theTerm : CM_Terminal;
	theVoyage : CM_Voyage;
	invalidObject :Boolean;
begin

	if _request = null then
		// no work to do
		return;
	endif;

	theVoyage := self.myVoyage;
	theTerm := theVoyage.myTerminal;
	
	on Exception do app.handleDeletedObject(exception, _request, invalidObject);
	aDischarge := _request.isDischarge; // keep this here as it check the link that is about to be broken
	if invalidObject then
		return;
	endif;
//	fortyBack := _request.getAttrIsBackend();
	
	// if the job has been erased and this is a discharge DLR we must reset the transit status on the TI
	if _request.allWorkListEntries.isEmpty then
		if _request.isRehandle and aDischarge then
			theTI := _request.myROROController.allTrackedItems.first;
			if theTI &lt;&gt; null then
				if theTI.isRehandle then
					theTI.setTransitStatus(TI_TransitStatusNull, true, app.myPassport);
				endif;
			endif;
		endif;
	elseif not _request.isComplete then // PAR 32732 added 'not _request.isComplete'
		foreach theWLE in _request.allWorkListEntries do
			if theWLE.status = WLE_COMPLETED then // PAR 32732 
				continue; // PAR 32732 
			endif;
			theTI := theWLE.myTrackedItem;

			if theTI &lt;&gt; null then
				// unplan, unassign from WLE and JOB as necessary
				create theMoveController transient;
				theMoveController.setMyWorkListEntry(theWLE);
				theMoveController.isFullyUnplan := true;
				theMoveController.setMoveMode(PLANNING_MODE);
				theMoveController.setMyTrackedItem(theTI);
				theTI.setFMUnplanIndex(not aDischarge,theMoveController);
				app.myUtilityUA.utlUpdateWLEUnassignTI(theMoveController,app.myPassport);
				
				theTI.setTransitStatus(TI_TransitStatusNull, true, app.myPassport);
				
				// ### PAR 11028
				// The imex status will only be set to TRANSIT if the colour coding being erased is discharge and the container involved  is non POE and the container is an import.
				if aDischarge then
					/* PAR 29033
					portHere := theTerm.myRoot.allPorts[theTerm.getConfig(PortDestCode).String];
					portTI := theTerm.myRoot.allPorts[theTI.dischargePort];
					
					if (theTI.isImport or theTI.isTranshipInbound) and portTI &lt;&gt; portHere then		// PAR #25021
					*/
					if (theTI.isImport)  then // PAR 29033 consulted Kaustubh and he agreed that we should 'always' put the IMEX back to RoB
					// PAR 29635 or theTI.isTranshipInbound)
						theTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
					endif;
				endif;
			endif;
	
		endforeach;
	endif;	

	self.removeSlotRequest(_request);
	
	if _request.myJob &lt;&gt; null then
		_request.myJob.setRemarks(null);
	endif;
	_request.erase(NORMAL_ERASE);

	app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerm.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								self);		
	
	if not (aDischarge or fortyBack) then
		//currently only have a need for load deletes
		// PAR 32732 self.myVoyage.causeEvent(self.myVoyage.myTerminal.getTerminalEvent(Event_SlotRequest_Delete), false, _request);	//26 Nov 2012	NDL	Par 30754
		app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage,self.myVoyage.myTerminal.getTerminalEvent(Event_SlotRequest_Delete),_request);	// PAR 32732 - same note, just checking for duplicate notes
	endif;

epilog
	delete theMoveController;
end;</source>
        <Parameter name="_request" type="CM_RORORequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executeDisplayNotesForMove" id="168bad66-4f48-423f-b253-268875a7bc01">
        <source>executeDisplayNotesForMove(_controller : CMIF_MoveController);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	theVoyage : CM_Voyage;	
	theTerminal : CM_Terminal;
	theTI : CM_TrackedItem;
	layout : CM_DeckItemLayout;
begin

	theTerminal := self.myTerminal;
	theTI := _controller.myTrackedItem;
// PAR 30388	theVoyage := self.myDeck.myVoyageStructure.myVoyage;
	theVoyage := self.getMyVoyage();
	
	app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								self);

	if (not _controller.isUndoMove) and 
	   _controller.myOriginatingForm &lt;&gt; null and
	   (self = _controller.myToPrimaryLocation or
	   self = _controller.myOriginatingLocation) then
		_controller.myOriginatingForm.causeEvent(EVENT_PLANNING_GET_NEXT_IN_SEQ, false, self);
	endif;


	// CCMS 1368  update the load list with DLR LOAD that is still on ship

	if _controller.isDLRLoadWithOutDischarge then
		if _controller.isUndoMove then
					app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,
						theTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED),
						theTI);
		endif;

		if not _controller.isUndoMove then
			// this is used in the load list
			app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,
				theTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED),
				theTI);
		endif;
		
		// calling this event whether unplanning or not means that the TI is added to the load list as it arrives in the yard
		// this is used in the load list
		if theVoyage &lt;&gt; null then
			// PAR 33644 if theVoyage.isNonPlannedVoyage or theVoyage.isNonWorkedVoyage then
			if theVoyage.isHOLDSorSHIP() then
			
				app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,
					theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
					theVoyage);								
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="executePostUndoMove" id="e6c83cd9-8696-40d6-bd10-296d4a86ce0b">
        <updating/>
        <source>executePostUndoMove(control: CMIF_MoveController; _passport: CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	aDSlotRequest,aLSlotRequest : CM_RORORequest;
begin



	inheritMethod(control, _passport);
	// The sequenced boolean is used to say that the TI on the request has actually been planned, i.e. a planned future move.
	// so need to reset it
	if control.moveMode = PLANNING_MODE and control.isUndoMove then
		if control.myToPrimaryLocation = self then
			aLSlotRequest := self.myRORORequestLoad;
			if aLSlotRequest &lt;&gt; null then
				aLSlotRequest.setSequenced(false);
			endif;
		elseif control.myOriginatingLocation = self then
			aDSlotRequest := self.myRORORequestDischarge;
			if aDSlotRequest &lt;&gt; null then
				aDSlotRequest.setSequenced(false);
			endif;
		
		endif;
	endif;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
