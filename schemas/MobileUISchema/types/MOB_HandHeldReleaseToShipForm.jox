    <JadeMethod name="translateForm" id="24fc4932-cd03-424d-8613-e0c509154dae">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013126, locale);
	btnBack.translateCaption(Xlat_0013127, locale);
	btnOK.translateCaption(Xlat_0013128, locale);
	lblLiftType.translateCaption(Xlat_0013129, locale);
	lblSlotDetail.translateCaption(Xlat_0013130, locale);
	txtBay.translateCaption(Xlat_0013131, locale);
	txtJob.translateCaption(Xlat_0013132, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
