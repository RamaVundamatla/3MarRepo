	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput2.userInputEnabled := false;	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="68016894-8338-4939-b11a-ad0b273c08dc">
        <updating/>
        <source>setupThumbnailDetails() updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 July 2009
//
// Implemented version: 7.7.3

//----------------------------------------------------------------------
vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DamagePosition);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_DamagePosition);
	theForm.shtTblInput1.visible := true;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="ec8ac583-8b96-4375-b8dc-a2e7887b8ab8">
        <updating/>
        <source>showThumbnail(_damagePosition : CM_DamagePosition) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.tblInput1.setValueByName(ETRow_Code, _damagePosition.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _damagePosition.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, _damagePosition.isNotAvailableForEntry);
	
	theForm.mulSelect1.setSelected(_damagePosition.allActiveCargoTypes);
	theForm.mulSelect2.setSelected(_damagePosition.allMachineTypes);
epilog
end;</source>
        <Parameter name="_damagePosition" type="CM_DamagePosition"/>
    </JadeMethod>
</Class>
