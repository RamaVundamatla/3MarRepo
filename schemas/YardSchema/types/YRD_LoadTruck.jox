epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="dc451095-322d-4162-9408-beadb5498dd7">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	conkc1	Initial creation

*/

vars

begin

	if self.doSave = true then
		inheritMethod;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="28d75d40-689b-4574-8e15-34cc72ecc999">
        <updating/>
        <source>doSave() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2010	conkc1	Initial creation

*/
vars
	interTermVehicleJob : CM_InterTermVehicleJob;
	result              : Boolean;
begin
	result := self.doValidate;
	if result = false then
		return false;
	endif;
	
	interTermVehicleJob := doCheckForInterTermJob(true);
	
	if interTermVehicleJob = null then
		return false;
	endif;

	self.myInterTermVehicleJob := interTermVehicleJob;
	//
	// If they want to change Driver name do it - separate transaction - not a problem
	//
	if self.myInterTermVehicleJob.driverID &lt;&gt; self.myDriver then
		result := doUpdateInterTermVehicleJob(self.myInterTermVehicleJob, myDriver);
		if result = false then
			return result;
		endif;
	endif;
	
	result := self.doCreateLoad;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateInterTermVehicleJob" id="bcc99329-f9c9-4653-bb65-091ba5569797">
        <updating/>
        <source>doUpdateInterTermVehicleJob(_interTermVehicleJob : CM_InterTermVehicleJob; _driverID : String) : Boolean updating;
/*

Purpose:			Update Vehicle Job - to change driveID

Parameters:			

Return Value:		

Date				Who		Reason
26 February 2010	conkc1	Initial creation

*/
vars

	proxy        : CM_InterTermVehicleJob;
	result       : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	proxy := app.createUpdateProxy(_interTermVehicleJob).CM_InterTermVehicleJob;
	proxy.setDriverID(myDriver);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateInterTermVehicleJob(proxy, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getString(Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
	
epilog

	delete proxy;

end;</source>
        <Parameter name="_interTermVehicleJob" type="CM_InterTermVehicleJob"/>
        <Parameter name="_driverID" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidate" id="c667e66a-10c2-4fd6-a5c4-8617cf621971">
        <updating/>
        <source>doValidate() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2010	conkc1	Initial creation

*/
vars
	errorMess    : String;
	result       : Integer;
	itm          : CM_InterTerminalMove;
	interRelease : CM_InterTerminalBulkRelease;
	config       : CM_InterTerminalConfig;
	itj : CM_InterTermVehicleJob;
begin
	self.setupMySourceTerminal;
	if self.mySourceTerminal = null then
		app.msgBox( app.getErrorString(Select_Terminal), app.getErrorString(Error), MsgBox_OK_Only);
		self.cmbSourceTerm.setFocus();
		return false;
	endif;
	
	self.setupMyTargetTerminal;
	if self.myTargetTerminal = null then
		app.msgBox( app.getErrorString(Select_Terminal), app.getErrorString(Error), MsgBox_OK_Only);
		self.cmbTargetTerm.setFocus();
		return false;
	endif;
	
	self.setupMyVehicle;
	if self.myVehicle = null then
		app.msgBox( app.getErrorString(Err_Gate_VehicleId), app.getErrorString(Error), MsgBox_OK_Only);
		self.txtVehicle.setFocus();
		return false;
	endif;
	
	self.setupMyDriver;
	if self.myDriver = null then
		errorMess := app.getErrorString1(ERR_Driver_Name_Blank,null);
		app.msgBox( errorMess, app.getErrorString(Error), MsgBox_OK_Only);
		self.txtDriver.setFocus();
		return false;
	endif;
	
	self.setupMyCargoItem;
	if self.myCargo = null then
		app.msgBox(app.getErrorString(ERR_INVALID_TI_ID), app.getErrorString(Error), MsgBox_OK_Only);
		self.txtCargoID.setFocus;
		return false;
	endif;

	interRelease := self.myCargo.getInterTerminalBulkRelease();
	
	if interRelease &lt;&gt; null then
		config := interRelease.myInterTerminalConfig;
	else
		app.msgBox(app.getErrorString(No_Terms_Not_Interterm_Cargo), app.getErrorString(Error), MsgBox_OK_Only);
		self.txtCargoID.setFocus;
		return false;
	endif;
	
	//21 Nov 2014	NDL	Par 35093
	//ideally we would have a conditional collection on terminal of its 'it moves' that were not completed, i.e. still had an associated 'it job'
	// then we could look thru the collection of active 'it moves' related just to this terminal.
	foreach itj in app.myRoot.allInterTerminalVehicleJobs do
		foreach itm in itj.allInterTerminalMoves do
			if itm.mySourceTI = self.myCargo then
				app.msgBox("'" &amp; self.myCargo.id &amp; "'  " &amp; app.getErrorString(CargoItemAlreadyOnVehicle) &amp; " " &amp; itj.vehicleID, app.getErrorString(Error), MsgBox_OK_Only);
				self.txtCargoID.setFocus;
				return false;
			endif;
		endforeach;
	endforeach;
	//21 Nov 2014	NDL	Par 35093
	// down in the bowels, unconditionally creates container objects... 
	if not self.myCargo.isContainer then
		app.msgBox("Inter-Terminal transfer by Truck is designed for transfering containers only.", app.getErrorString(Error), MsgBox_OK_Only);
		self.txtCargoID.setFocus;
		return false;
	endif;
	

	self.myInterTermVehicleJob := self.doCheckForInterTermJob(false);
	
	if self.myInterTermVehicleJob &lt;&gt; null then
	//	incorporated above...
	//	foreach itm in self.myInterTermVehicleJob.allInterTerminalMoves do
	//		if itm.cargoID = self.myCargo.id then
	//			app.msgBox("'" &amp; self.myCargo.id &amp; "'  " &amp; app.getErrorString(CargoItemAlreadyOnVehicle), app.getErrorString(Error), MsgBox_OK_Only);
	//			self.txtCargoID.setFocus;
	//			return false;
	//		endif;
	//	endforeach;

		if self.myInterTermVehicleJob.driverID &lt;&gt; self.myDriver then 
			errorMess := app.getErrorString(ChangingDriverName);
			errorMess := errorMess.replaceString("%1", self.myDriver);
			errorMess := errorMess.replaceString("%2", self.myInterTermVehicleJob.driverID);
			result := app.msgBox(errorMess, app.getErrorString(Error), MsgBox_Yes_No_Cancel);
			if result = MsgBox_Return_Cancel then
				return false;
			elseif result = MsgBox_Return_Yes then
				return true;
			elseif result = MsgBox_Return_No then
				self.txtDriver.text := self.myInterTermVehicleJob.driverID;
				self.myDriver       := self.myInterTermVehicleJob.driverID;
				return true;
			endif;
		endif;
	endif;

	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="29bf407a-b89b-426e-87c9-25031905de48">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2010	conkc1	Initial creation

*/
constants

	ContainerTop  : Integer = 20;
	ContainerLeft : Integer = 2;
vars

begin
	inheritMethod;

	self.frmContainer.left    := ContainerLeft;
	self.frmContainer.top     := ContainerTop;
	self.clientWidth          := (self.frmContainer.width + (ContainerLeft * 2)).Integer;
	self.clientHeight         := (self.frmContainer.height + (ContainerTop * 2) + self.btnOk.height).Integer;
	self.centreWindow;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1b10a9c8-eb4e-4f93-8f19-7f3e8ab48d5b">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	conkc1	Initial creation

*/

vars

begin
	inheritMethod();
	self.myTerminal := app.myPassport.myTerminal;
	doLoadSourceTerminal;
	doLoadTargetTerminal;
	if self.myCurrentInterTerminalMove &lt;&gt; null then
	
		txtDriver.text := self.myCurrentInterTerminalMove.myInterTermVehicleJob.driverID;
		if self.myCurrentInterTerminalMove.myTargetVehicleVisit &lt;&gt; null then
			txtDriver.text := self.myCurrentInterTerminalMove.myTargetVehicleVisit.driverCode;
		endif;

		txtVehicle.text := self.myCurrentInterTerminalMove.mySourceVehicle.regNumber;
		txtState.text   := self.myCurrentInterTerminalMove.mySourceVehicle.state;
		
		self.cmbTargetTerm.listObject := self.myCurrentInterTerminalMove.myTargetTerminal;
	endif;
	
	self.cmbSourceTerm.setFocus;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMyCargoItem" id="113c6396-625a-45db-a4c9-6f57174d0f11">
        <updating/>
        <source>setupMyCargoItem() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	conkc1	Initial creation

*/

vars
	id : String;
begin

	id := self.txtCargoID.text.trimBlanks;
	self.myCargo := self.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(id, null);
	if self.myCargo.id &lt;&gt; id then
		self.myCargo := null;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMyDriver" id="525ae99a-9fed-4466-a6a4-5ae777fc472c">
