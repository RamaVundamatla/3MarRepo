<Class name="HMS_Berth">
    <JadeMethod name="importPLXMLReference" id="5fd82f5e-7393-49f4-9912-2104cf2138c1">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
//	if _name = HMS_Berth::myRoot.name then
//		return app.myRoot;
	if _name = HMS_Berth::myHarbour.name then
		return app.getMyHarbour();
	elseif _name = HMS_Berth::myHarbourRegion.name then
		return app.getMyHarbour().allRegions[_theCode];
	elseif _name = HMS_Berth::myWharf.name then
		return app.getMyHarbour().allWharves[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
