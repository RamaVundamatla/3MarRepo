	self.scrollToSelectedBerth(tmpBerth);

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPrintGraphicalView" id="fcef94b6-2d74-4710-a2d4-a1bc285052ca">
        <updating/>
        <source>doPrintGraphicalView() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Jul 2011	cnwer1	Initial creation CCMS MES 2109
22 Sep 2011	cnwer1	CCMS 1025 - addtional changes for orientation, option to Shrink to Fit page.
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars
	
	viewPort, mainFrame: CMUI_Frame;
	tmpJadeReport  : JadeReport;
	pageWidth,
	pageHeight, 
	lastBerthWidth ,
	pointerHeight,
	pointerWidth: Integer;
	timeBin,
	graphBin , 
	berthBin :Binary; 
	picTime,
	picGraph,
	picBerth: Picture;
	hmsDrawControl : HMS_WharfDrawControl;
	headerForm : CMUI_ReportLine;
	footerForm 	: CM_GenericTablePrint;
	now			: TimeStamp;
	printOptions	: HMS_GraphicalViewPrint;
	
begin
	
	if self.myHarbour = null then
		return;
	endif;
	
	//epr CCMS 1025 additional changes to allow users to change the orientation and paper size etc
	create printOptions transient;
	if printOptions.showModal = IDCANCEL then
		return;
	endif;
	
	self.picPrint.picture:=null;
	self.picPrint.width:=1;
	self.picPrint.height:=1;
	app.mousePointer := MousePointer_HourGlass;
	
	app.printer.close;
	create headerForm transient;
	create footerForm transient;
	
	if app.printer.documentType = null then
		app.printer.documentType := app.printer.getDefaultDocumentType;
	endif;

	if printOptions.optLandscape.value then
		app.printer.orientation:=Print_Landscape;
	else
		app.printer.orientation:=Print_Portrait;
	endif;
	app.printer.suppressDialog := true;
	
	headerForm.initReport;
	headerForm.initReportForOrientation();
	headerForm.lblTitle01.caption :=  app.getErrorString(Harbour)&amp;":";
	headerForm.lblTitle03.caption := self.myHarbour.code;
	headerForm.lblTitle02.caption:=app.getErrorString(Date_range)&amp;":";
	headerForm.lblTitle04.caption:=self.myDrawTimeLabel.lblTimePointer.caption;
	headerForm.lblPrintedBy.caption := null;
	headerForm.lblPrintedBylbl.caption := null;
	
	create tmpJadeReport transient;
	tmpJadeReport.description := self.caption;
	app.printer.setReport(tmpJadeReport);
	
	app.printer.setMargins(app.printer.orientation,5,5,5,5);
	app.printer.setHeader(headerForm.frHeader);
	
	now:=app.actualTimeServer;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	footerForm.frFooter.width := app.printer.pageWidth-20;
	footerForm.lblTheUser.caption := app.getMyUserCode;
	footerForm.lblTheDatePrinted.caption := self.systemToLocalTime(now).asStringJMT;	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	app.printer.setFooter(footerForm.frFooter);

	
	pageWidth:=app.printer.pageWidth;
	pageHeight :=app.printer.pageHeight -footerForm.frFooter.clientHeight -headerForm.frHeader.clientHeight;
	
	
	viewPort := self.frmPrint.cloneSelf(true);	
	self.addControl(viewPort);
	viewPort.backColor:=White;
	viewPort.transparent:=false;
	viewPort.borderStyle:=Control.BorderStyle_None;
	viewPort.visible := true;
	viewPort.autoRedraw := true;
	viewPort.left:=0;
	viewPort.top:=0;
	viewPort.width:=pageWidth;
	viewPort.height:=pageHeight;
	
	mainFrame:= self.frmPrint.cloneSelf(true);
	mainFrame.parent:=viewPort;
	mainFrame.left:=0;
	mainFrame.top:=0;
	self.addControl(mainFrame);
	mainFrame.transparent:=true;
	mainFrame.borderStyle:=Control.BorderStyle_None;
	mainFrame.visible := true;
	mainFrame.autoRedraw := true;
	
	timeBin:=self.frmScrollablMain.myVLabels.createPictureAsType(false,true,24,Window.PictureType_Jpeg);
	picTime:=self.picPrint.cloneSelf(true);
	self.addControl(picTime);
	picTime.stretch:=Picture.Stretch_ControlTo;
	picTime.parent:=mainFrame;
	picTime.useImage(timeBin);
	picTime.left:=0;
	picTime.top:=0;
	
	/*
		could not use the forms self.frmScrollingMain 
		
		got them by iterating throught self.allWharfDrawControlsVisible
		- whats drawn on in the ocean bit is HMS_WharfDrawControl.myScrollingFrame
		- whats drawn at the botton (the wharf and marks) is HMS_WharfDrawControl.myScrollableLabelFrame
	
	
	*/
	
	lastBerthWidth:=0;
	foreach hmsDrawControl in self.allWharfDrawControlsVisible discreteLock do
		graphBin:=hmsDrawControl.myScrollingFrame.createPictureAsType(false,true,24,Window.PictureType_Jpeg);
		picGraph:=self.picPrint.cloneSelf(true);
		self.addControl(picGraph);
		picGraph.stretch:=Picture.Stretch_ControlTo;
		picGraph.parent:=mainFrame;
		picGraph.useImage(graphBin);
		picGraph.left:=self.frmScrollablMain.myVLabels.width + lastBerthWidth;
		picGraph.top:=0;
	
		berthBin:=hmsDrawControl.myScrollableLabelFrame.createPictureAsType(false,true,24,Window.PictureType_Jpeg);
		picBerth:=self.picPrint.cloneSelf(true);
		self.addControl(picBerth);
		picBerth.stretch:=Picture.Stretch_ControlTo;
		picBerth.parent:=mainFrame;
		picBerth.useImage(berthBin);
		picBerth.left:=self.frmScrollablMain.myVLabels.width + lastBerthWidth;
		picBerth.top:=picGraph.height;
	
		lastBerthWidth:=lastBerthWidth + hmsDrawControl.myScrollingFrame.clientWidth;
	
	endforeach;
	
	mainFrame.height:=picGraph.height + picBerth.height;
	mainFrame.width:=self.frmScrollablMain.myVLabels.width + self.frmScrollingMain.width;
	
	if printOptions.optNormalSize.value then
		pointerHeight:=0;
		pointerWidth:=0;
		while true do
			mainFrame.left:=-pointerWidth;
			mainFrame.top:=-pointerHeight;
			viewPort.zOrder(1);
			app.printer.print(viewPort);
			pointerHeight:=pointerHeight+pageHeight;
			if pointerHeight  &gt; mainFrame.height then
				//goBack to top
				if pointerWidth + pageWidth &gt; mainFrame.width then
					break;
				endif;
				pointerHeight:=0;
				pointerWidth:=pointerWidth + pageWidth;
			endif;
		endwhile;
	elseif printOptions.optFitToPage.value then
		self.picPrint.stretch:=Picture.Stretch_ToControl;
		self.picPrint.width:=pageWidth;
		self.picPrint.height:=pageHeight;
		self.picPrint.useImage(mainFrame.createPictureAsType(false,true,24,Window.PictureType_Jpeg));
		app.printer.printActive(self.picPrint);
	endif;
			
	app.printPreview(tmpJadeReport, true);
	
	app.printer.close;
	
epilog

	delete viewPort;
	delete headerForm;
	delete footerForm;
	delete printOptions;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doProcessPlanningNote" id="117a62cb-9cac-40ee-b494-2032b3d4f4a7">
        <updating/>
        <source>doProcessPlanningNote( yClick : Integer) updating;
//-----------------------------------------------------------------------
//	Created:	02 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------
// 29/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 Correct calculation of date from click position
vars
	dateOfNote		: Date;
	timeOfNote		: TimeStamp;											// PAR #33337
begin

	//dateOfNote := self.myDrawTimeLabel.getDateFromClick (yClick).Date;	// PAR #33337
	self.getTimeForPosition(yClick, timeOfNote);							// PAR #33337
	dateOfNote := timeOfNote.Date;											// PAR #33337
	self.planningNoteDate := dateOfNote;
	self.showHideMarksRemarks(false, dateOfNote, false);
	
epilog

end;</source>
        <Parameter name="yClick" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRangeSelectorResetDateTime" id="c60812fe-5973-444f-a453-e5a9d28461e3">
        <updating/>
        <source>doRangeSelectorResetDateTime(_isDefault : Boolean) updating, protected;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//
// Changes:
//			1 Apr 08 - cnwrs2 - changes for PAR 16411 to only show 1 terminal
//	27/5/16	cnwmp6	TFS 488 - Multi timezone support
//-----------------------------------------
vars
	fromLocal,
	toLocal	: TimeStamp;
	allowedTerms	: CM_TerminalByCodeDict;		// PAR 16411
begin

	create allowedTerms transient;			// PAR-16411
	allowedTerms.add(self.myTerminal);		// PAR-16411

	// Reset the base times before re-loading the default ranges
	if _isDefault then
//		date := now.date;
//		time.setTime(0,0,0,0);
		fromLocal := self.systemToLocalTime(app.actualTimeServer());
		fromLocal.setTime("0:00:00".Time);
		if self.myHarbour &lt;&gt; null then			
			//self.myAssistant.listTableTerminal(self.lstTerminal, true, true, self.myHarbour.allTerminalsByCode, self.myHarbour.allTerminalsByCode);
			self.myAssistant.listTableTerminal(self.lstTerminal, true, true, allowedTerms, allowedTerms);
		else
			//self.myAssistant.listTableTerminal(self.lstTerminal, true, true, app.myRoot.allTerminals, self.myViewController.allTerminalsSelectedForView);
			self.myAssistant.listTableTerminal(self.lstTerminal, true, true, allowedTerms, self.myViewController.allTerminalsSelectedForView);
		endif;
		self.myAssistant.listTableLostFocus(self.tblSearch, self.saveRowHeight, self.lstTerminal, 'code', false);				

//		date := now.date.cnEcAddDays(7);
		toLocal.setDate(fromLocal.Date + 7);
		toLocal.setTime("0:00:00".Time);

	else
//		date := self.myViewController.viewStartDT.date;
//		time := self.myViewController.viewStartDT.time;
		fromLocal := self.systemToLocalTime(self.myViewController.viewStartDT);
		if self.myHarbour &lt;&gt; null then				
			///self.myAssistant.listTableTerminal(self.lstTerminal, true, true, self.myHarbour.allTerminalsByCode, self.myViewController.allTerminalsSelectedForView);
			self.myAssistant.listTableTerminal(self.lstTerminal, true, true, allowedTerms, self.myViewController.allTerminalsSelectedForView);
		else
			//self.myAssistant.listTableTerminal(self.lstTerminal, true, true, app.myRoot.allTerminals, self.myViewController.allTerminalsSelectedForView);
			self.myAssistant.listTableTerminal(self.lstTerminal, true, true, allowedTerms, self.myViewController.allTerminalsSelectedForView);
		endif;
		self.myAssistant.listTableLostFocus(self.tblSearch, self.saveRowHeight, self.lstTerminal, 'code', false);					

//		date := self.myViewController.viewFinishDT.date;
//		time := self.myViewController.viewFinishDT.time;
		toLocal := self.systemToLocalTime(self.myViewController.viewFinishDT);
	endif;
	
	// set the defaults for the report from date time
	self.tblSearch.setValueByName(ETRow_FromDate, fromLocal.Date.shortFormatJMT());
	self.tblSearch.setValueByName(ETRow_FromTime, fromLocal.Time.shortFormatJMT());

	self.tblSearch.setValueByName(ETRow_ToDate, toLocal.Date.shortFormatJMT());
	self.tblSearch.setValueByName(ETRow_ToTime, toLocal.Time.shortFormatJMT());

epilog
	delete allowedTerms;
end;</source>
        <access>protected</access>
        <Parameter name="_isDefault" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRangeSelectorSave" id="d8818796-c993-4ec5-a0ee-c8c7b8b8e171">
        <updating/>
        <source>doRangeSelectorSave(_cancelRangeStatus : Boolean)updating, protected;
//--------------------------------------------------
// Created:	18 May 2004 By: cnwgd1
//--------------------------------------------------
/* Changes 

Date		Name	TFS#		Description
============================================================================
19/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
//  8 june 2022 navvt20 TFS53757 - Search Range Functionality for Wharves
//============================================================================
vars
	newStartDT,
	newEndDT		: TimeStamp;
	cmifMonitor		: CMIF_Monitor;
	i : String;
begin
	if self.lstTerminal.allSelectedObjects.isEmpty then
	//	app.raiseCMException1(REQUIRED_FIELD, "Terminal", null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); //cnwdb2 PAR 35364
		
		return;
	endif;
	
	//epr par 15528 20/12/07 rebuilding the vessels every notification caused performance issues
	// here update the selected vessels and operators
	
	self.allSelectedVessels.clear;
	self.msgVessels.getSelected(self.allSelectedVessels);
		
	self.allSelectedOperators.clear;
	self.msgOperators.getSelected(self.allSelectedOperators);
	
	// START navvt20 8 june 2022 TFS 53757
	self.aAllSelectedWharves.clear;
	self.msgSelectWharvesBox.getSelected(self.aAllSelectedWharves);
	
	
	if self.aAllSelectedWharves.isEmpty() then
		app.msgBox(app.getString(Must_Select_At_Least, app.getString(Wharf)), app.getString(Wharf), MsgBox_OK_Only);
		return;
	endif;
	
	// END navvt20 8 june 2022 TFS 53757
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null,'Cancel' , null, null, 'Changing Date Range',  'Please Wait....');
	self.pbProgressBar.visible := true;

//	newStartDT.setDate(self.tblSearch.getValueByName(ETRow_FromDate).Date);
	newStartDT.setDate(self.tblSearch.getValueAsDate(ETRow_FromDate));
	
	newStartDT.setTime(self.tblSearch.getValueByName(ETRow_FromTime).Time);
//	newEndDT.setDate(self.tblSearch.getValueByName(ETRow_ToDate).Date);
	newEndDT.setDate(self.tblSearch.getValueAsDate(ETRow_ToDate));
	newEndDT.setTime(self.tblSearch.getValueByName(ETRow_ToTime).Time);
	
	//Check we have a valid date range and if so, make the change.
	if self.myViewController.changeViewRange(self.localToSystemTime(newStartDT), self.localToSystemTime(newEndDT), self.lstTerminal.allSelectedObjects) then
		showHideSelector();		// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	//jlgka1 TFS 45620 --&gt;	
	// refresh the waiting costs form if it is open -- R Barr 27/10/2006 Comalco
	//self.showVesselWaitingCosts(true);
	//jlgka1 TFS 45620 &lt;--
	endif;
epilog
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.doResize();
end;</source>
        <access>protected</access>
        <Parameter name="_cancelRangeStatus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="6e4f2af5-53ef-4b5a-a663-e0fa8c7f4bb7">
        <updating/>
        <source>doRefresh() updating, protected;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 11 August 2003
//
//	Renamed method. Previously ::doUserInitiatedRefresh
//-----------------------------------------------------------------------
vars
	msgBoxType:	Integer;
	msgString:	String;
	userChoice:	Integer;
	
begin
	
 	// This method is called when the user presses the F5 key on the 
 	// graphical view. If there are any changes in the stack the user can
 	// agree to the discard or save of these before the view is refreshed. 
	inheritMethod();

 	if (not self.myViewController.allChanges.isEmpty) then 
 		// Changes in stack - discard y/n
 		msgBoxType := MsgBox_Yes_No_Cancel+MsgBox_Question_Mark_Icon;
		msgString := app.getErrorString(MSGBOX_UnsavedChanges); 
		userChoice := app.msgBox(msgString, app.getErrorString(MSGBOX_UnsavedChangesTitle), msgBoxType);
		
		if userChoice = MsgBox_Return_Yes then
			// return yes - save changes, then refresh view
			self.doSave();
		endif;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	// Refreshview now	
	self.myViewController.doRefreshView(false);
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="d35cacc7-dca5-43f2-95cc-94e2d3117d6b">
        <updating/>
        <source>doResize()updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
//  6 June 2022 navvt20 TFS53757 - Increasing Height of Form
vars
	tmpTop,
	tmpHeight : Real;
	tmpWharfCntrl : HMS_WharfDrawControl;
begin

	inheritMethod();
	
	tmpTop := self.frmToolbar.clientHeight;

	self.frmVslPosDetail.move(0, tmpTop, self.clientWidth, frmVslPosDetail.clientHeight);
	tmpTop := tmpTop + self.frmVslPosDetail.clientHeight;	
	self.frmScrollablMain.top := tmpTop;
	
	tmpHeight := self.myDrawTimeLabel.myLabelFrame.height + self.Wharf_Label_Height;
	
	
	//cnwjo3, par 21212.  Moved up here so Days are redrawn when the form is shrunken.
	if self.isFirstActivateComplete then
		self.doTimeRefresh();
	endif;

	if tmpHeight &lt; self.frmScrollablMain.clientHeight then
		/*   cnwjo3, par 21212.
		// need to stretch time scale as now have more room available
		if self.isFirstActivateComplete then
			self.doTimeRefresh();
		endif;*/
		
		//tmpHeight := self.myDrawTimeLabel.myLabelFrame.height + self.Wharf_Label_Height;		// 25/03/2008 cnwar2 #16218
		if self.frmScrollablMain.hasHScroll() then
			tmpHeight := self.frmScrollablMain.clientHeight - self.frmScrollablMain.ScrollBarWidth;
		else
			tmpHeight := self.frmScrollablMain.clientHeight;
		endif;
		//tmpHeight:=self.myDrawTimeLabel.scaleHeight;
		self.frmScrollablMain.resizeScrollingFrame(self.totalWharfLabelWidth, tmpHeight);

	else
		self.frmScrollablMain.repositionScrollBars();

		if self.frmScrollablMain.hasHScroll() then
			tmpHeight := self.frmScrollablMain.clientHeight - self.frmScrollablMain.ScrollBarWidth;
		else
			tmpHeight := self.frmScrollablMain.clientHeight;
		endif;
		
		//tmpHeight:=self.myDrawTimeLabel.scaleHeight;
		self.frmScrollablMain.resizeScrollingFrame(self.totalWharfLabelWidth, tmpHeight);

		foreach tmpWharfCntrl in self.allWharfDrawControls do
			tmpWharfCntrl.myScrollableFrame.repositionAfterResize();
		endforeach;	

	endif;
	// START navvt20 6 June 2022 53757
	self.fldSearch.height:=250;
	self.frmSearch.height:=300;
	// END navvt20 6 June 2022 53757
	self.fldSearch.top := self.frmSearchToolbar.height; // TFS 50421
			
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="563324e0-e127-4bb9-8874-d06aa77c3d4a">
        <updating/>
        <source>doSave() : Boolean updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22 Mar 2024	jlika1	TFS 55410 PNL-Voyage Actual Arrival Date Time Changed - Add a Warning Message when this happens
============================================================================*/
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin	
	if self.isReadOnly then
		app.msgBox(app.getErrorString1(VB_SECMOVE,"Harbour Management Graphical View"), "Security",MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);	
		return false;
	endif;

	// PAR 10455 clear the selected movement
	self.setSelectedMovement(null, false);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateHMSWorkingVoyages(self.myViewController, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('Voyage Update', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSavePosRemarks" id="7e20b2bd-ec6c-48c9-97b7-82cf4e68f219">
        <updating/>
        <source>doSavePosRemarks()updating, protected;
//--------------------------------------------------
// Created:	24 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	remarks 			: String;
	pict 				: HMS_GraphicalDragPicture;
	pxyMovement 		: HMS_VoyageMovement;
	pxyPlanningNote,
	realPlanningNote	: HMS_PlanningNote;
begin
	if self.txtPlanningHist.visible then
		// always creating a new planning note
		create pxyPlanningNote transient;
		pxyPlanningNote.setProxy (self.myHarbour, app.getMyUser, self.planningNoteDate, txtRemarks.text);
		app.myTrxCA.trxCreateHMSPlanningNote(pxyPlanningNote, realPlanningNote, app.myPassport);
		self.showHideMarksRemarks(true, null, false);
		
	elseif self.txtRemarks.visible then
		if self.myCurrentWorkingMovement &lt;&gt; null then
			// update the remarks
			remarks := self.txtRemarks.text;
			if remarks &lt;&gt; self.myCurrentWorkingMovement.remarks then
				if self.myCurrentWorkingMovement.myPersistentMovement &lt;&gt; null then
					// There is an actual movement which will be updated directly so create a proxy
					pxyMovement := app.createUpdateProxy(self.myCurrentWorkingMovement.myPersistentMovement).HMS_VoyageMovement;
				endif;
				
				//update scenario movement
				self.myCurrentWorkingMovement.remarks := remarks;
				
				if pxyMovement &lt;&gt; null then
					//Update actual movement
					app.myTrxUA.trxUpdateHMSMovementRemarks(pxyMovement, remarks, app.myPassport);
				endif;
			endif;
		endif;
		self.showHideMarksRemarks(true, null, false);

	elseif self.tblMeterMarks.visible then
		//Update the meter marks
		pict := self.myCurrentDragPicture;
		
		//if self.updateMovementToController(pict, pict.myWorkingMovement, true, false, self.cmbMyBerth.listObject.HMS_Berth, self.txtBowMarkTo.text.Decimal, self.txtSternMarkTo.text.Decimal) then
		if self.updateMovementToController(pict, pict.myWorkingMovement, true, false, self.cmbMyBerth.listObject.HMS_Berth, self.txtBowMarkTo.text.asDecimalJMT(), self.txtSternMarkTo.text.asDecimalJMT()) then 	// 01 APR 2010	NDL	Par 23556
			self.showSelectedPosDetails();
			self.showHideMarksRemarks(true, null, false);
		endif;
	else
		return;
	endif;
epilog
	delete pxyMovement;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetToPreferedMarks" id="0ae985a1-9295-43af-bf3d-40313154e98d">
        <updating/>
        <source>doSetToPreferedMarks() updating, protected;
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
vars
	workingMovement 	: CMIF_HMS_WorkingMovement;
	dragPic 			: HMS_GraphicalDragPicture;
	leftPos				: Real;
	bowOnLeft			: Boolean;
	dispLeftToRight		: Boolean;
  	editMovementChange	: CMIF_HMS_MovementEdit;
	
begin
	dragPic := self.myCurrentDragPicture;

	if dragPic = null then
		return;
	endif;

	workingMovement	:= dragPic.myWorkingMovement;
	
	if workingMovement = null then
		return;
	endif;
	
	workingMovement.setToPreferredBerthMarks();

	// reposition the sprite
	if (not dragPic.myCurrentWharfDrawControl.calculateSpriteLeftPosition(	workingMovement,
																			leftPos,
																			dispLeftToRight,
																			bowOnLeft)) then
		return;
	endif;
	
	dragPic.left := leftPos;
	dragPic.bowOnLeft := bowOnLeft;

	// move pointers
	self.myDrawTimeLabel.movePointer(true, dragPic.top, dragPic.top + dragPic.height);
	dragPic.myCurrentWharfDrawControl.showHideLabels(true, dragPic.left, dragPic.left + dragPic.width);

	// do the update to the controller - this will check and validate the shift to the preferred berth for the sprite
	if (not self.updateMovementToController(dragPic, dragPic.myWorkingMovement, false, true, null, null, null)) then
		dragPic.myCurrentWharfDrawControl.backoutSpriteChanges(dragPic);
		return;
	else
		dragPic := null;
	endif;
epilog
	// Notify controller that the movement has finished being edited
	self.myViewController.set_AddEditMovementActiveState(false);
	
	if dragPic &lt;&gt; null then
		dragPic.isDragging := false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTimeRefresh" id="3093ee8d-6c5d-45de-8798-d38ffbc4a964">
        <updating/>
        <source>doTimeRefresh()updating, protected;
//--------------------------------------------------
// Created:	19 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myDrawTimeLabel.drawMe();

	// clear all ships
	/*Don't null out selected movement, it is used to reselect the sprite in self.rebuildShips() below.
	self.setMyCurrentWorkingMovement(null);*/
	
	// redraw the Midnight and Berth lines on detail area
	self.rebuildScaleWharf();

	// rebuild the view
	self.rebuildShips();
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTimeZoom" id="b8462e0f-79bb-4b67-8ad2-12110e194237">
        <updating/>
        <source>doTimeZoom(menuItem: MenuItem input) updating, protected;
//--------------------------------------------------
// Created:	12 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	x, y : Real;
	startDT	: TimeStamp;
	finishDT: TimeStamp;
begin
	startDT := self.myViewController.viewStartDT;
	finishDT := self.myViewController.viewFinishDT;
	
	if not self.canDateRangeFitToScreen(startDT, finishDT, menuItem.helpKeyword.Integer) then 
		app.msgBox(app.getErrorString(MSGBOX_TimeZoomTooLarge), 'Time Zoom Scale Too High', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	self.frmScrollablMain.getPositionAsPercentage(self.origXPos.Integer, self.origYPos.Integer, x, y);
	
	self.timeZoom := menuItem.helpKeyword.Integer;
	
	self.mnuTimeZoomFull.checked := false;
	self.mnuTimeZoomX2.checked := false;	
	self.mnuTimeZoomX3.checked := false;	
	self.mnuTimeZoomX4.checked := false;	
	self.mnuTimeZoomX5.checked := false;	
	self.mnuTimeZoomX6.checked := false;	
	self.mnuTimeZoomX7.checked := false;	
	self.mnuTimeZoomX8.checked := false;
	menuItem.checked := true;
	
	self.myDrawTimeLabel.drawMe();
	
	// redraw the Midnight and Berth lines on detail area
	self.rebuildScaleWharf();

	// rebuild the view
	self.rebuildShips();
	
	self.showMarksTimeForSelectedMove();	

 	self.frmScrollablMain.scrollToFromPercentage(x, y);
	
	self.doResize();
																																																																												
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doWharfZoom" id="7be01674-e8fa-4c5c-9446-7eaba1eaaf61">
        <updating/>
        <source>doWharfZoom(menuItem: MenuItem input) updating, protected;
//-----------------------------------------
// Created: June 2004 By: cnwgd1
//-----------------------------------------
vars
	x, y : Real;  	
begin

	self.frmScrollablMain.getPositionAsPercentage(self.origXPos.Integer, self.origYPos.Integer, x, y);
	
	self.wharfZoom := menuItem.helpKeyword.Integer;
	
	mnuZoomX1.checked:=false;
	mnuZoomX2.checked:=false;
	mnuZoomX3.checked:=false;
	mnuZoomX4.checked:=false;
	mnuZoomX5.checked:=false;
	mnuZoomX6.checked:=false;
	mnuZoomX7.checked:=false;
	mnuZoomX8.checked:=false;

	menuItem.checked := true;

	if self.wharfZoom = self.lastSelectedWharfZoom then
		return;
	endif;

	// rebuild the meterage scale
	self.rebuildScaleWharf();

	// rebuild the view
	self.rebuildShips();	
		
	self.showMarksTimeForSelectedMove();	

	self.frmScrollablMain.scrollToFromPercentage(x, y);		

	self.doResize();

epilog
	self.lastSelectedWharfZoom := self.wharfZoom;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dragPictureContextMenu" id="38d15712-73c3-4e23-a9fd-c304c62fed28">
        <updating/>
        <source>dragPictureContextMenu(pict: HMS_GraphicalDragPicture input; x, y : Real) updating;
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 21/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 22/08/2022	navpw1		TFS: 54162 - SAL - ERROR : Voyage no./ Rotation - Changed automatic and assigned to another
vars
	voyageData: 		HMS_VoyageData;
	selectedRegion:		HMS_HarbourRegion;
	minuteOffset:		Integer;
	tmpMoveType,
	enterLeaveStatus:	String;
	tmpLeft, tmpTop : Real;
begin
	self.frmMarksRemarks.visible := false;
	if self.myCurrentWorkingMovement = null then
		return;
	endif;
	
	//Scenario voyage, actual CM_Voyage not created yet	
	voyageData := self.myCurrentWorkingMovement.myWorkingVoyage.myHMSVoyageData;
	// popup menu
	if voyageData.allBerthPreferencesByName.getAtKey(lblShowBerth.caption) &lt;&gt; null then
		mnuSetToPreferedMarks.enabled := true;
	else
		mnuSetToPreferedMarks.enabled := false;
	endif;
	
	// Modified by Russell 30/03/99
	// ------------------------------------------------
	/*if self.myCurrentWorkingMovement.isAgentDefault then
		// Agent is default customer for movement
		if myCurrentWorkingMovement.myShippingAgent &lt;&gt; null then
			// Agent is assigned to movement
			mnuAgentDetails.caption := $CustTypeAgent;
			mnuAgentDetails.enabled := true;
		elseif myCurrentWorkingMovement.myShippingLine &lt;&gt; null then
			// Agent is not assigned to movement, but shipping line is:
			mnuAgentDetails.caption := $CustTypeShipLine;
			mnuAgentDetails.enabled := true;
		else
			// Agent is not assigned to movement
			mnuAgentDetails.caption := $CustTypeAgent;
			mnuAgentDetails.enabled := false;
		endif;
	else
		// ShippingLine is default customer for movement
		if myCurrentWorkingMovement.myShippingLine &lt;&gt; null then
			// ShippingLine is assigned to movement
			mnuAgentDetails.caption := $CustTypeShipLine;
			mnuAgentDetails.enabled := true;
		elseif myCurrentWorkingMovement.myShippingAgent &lt;&gt; null then
			// ShippingLine is not assigned to movement, but agent is:
			mnuAgentDetails.caption := $CustTypeAgent;
			mnuAgentDetails.enabled := true;
		else
			// ShippingLine is not assigned to movement
			mnuAgentDetails.caption := $CustTypeShipLine;
			mnuAgentDetails.enabled := false;
		endif;
	endif;*/

	mnuContactDetails.caption := 'Contact Details...';
	if self.myCurrentWorkingMovement.myContact &lt;&gt; null then
		mnuContactDetails.enabled := true;
	else
		mnuContactDetails.enabled := false;
	endif;
	
	if voyageData.myVoyage = null then
		//This is a scenario voyage
		self.mnuVoyageDefin.visible := false;
		self.mnuVoyageDelays.visible := false;					// PAR #33337
		self.mnuDeleteVoyage.visible := false;					// ### TFS 54162 22Aug2022 NAVPW1
	else
		//This is an actual voyage
		self.mnuVoyageDefin.visible := true;
		self.mnuVoyageDelays.visible := true;					// PAR #33337
		self.mnuDeleteVoyage.visible := app.myCurrentUserCan(voyageData.myVoyage.myTerminal, PmShipVoyageEnquiryDel); // ### TFS 54162 22Aug2022 NAVPW1
	endif;
	
	tmpMoveType := self.myCurrentWorkingMovement.moveType;
	if tmpMoveType = HMSMovementTypeArrival then
		self.mnuEditMovement.caption := 'Edit Movement Arrival...';
	elseif tmpMoveType = HMSMovementTypeDeparture then
		self.mnuEditMovement.caption := 'Edit Movement Departure...';
	else
		self.mnuEditMovement.caption := 'Edit Movement Shift...';
	endif;
	
	self.mnuInspectVoyage.visible := app.isAllowedToInspect;
	self.mnuInspectMove.visible := app.isAllowedToInspect;
	
	tmpLeft := x;
	tmpTop := y;
	pict.windowToScreen(tmpLeft, tmpTop);
	self.screenToWindow(tmpLeft, tmpTop);
	
	self.popupMenu(mnuPopup, tmpLeft.Integer, tmpTop.Integer);
end;</source>
        <Parameter name="pict" type="HMS_GraphicalDragPicture" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCurrentDateRange" id="f4e3d9fa-7013-4bae-8c37-ed30642c85be">
        <source>getCurrentDateRange(_startTS:TimeStamp output; _finishTS:TimeStamp output);
// --------------------------------------------------------------------------------
// Created:		07 March 2007 by cnwdad1
//
// Purpose:		Fetches the current timestamp range of the Graphical View.
//
// Parameters:	_startTS - The start of the date/time range.
//				_finishTS - The finish of the date/time range.
//
// Returns:		The start/finish timestamps as output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_startTS	:=	self.myViewController.viewStartDT;
	_finishTS	:=	self.myViewController.viewFinishDT;
end;</source>
        <Parameter name="_startTS" type="TimeStamp" usage="output"/>
        <Parameter name="_finishTS" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getNewPicDrag" id="05c5ca4a-3a71-4e36-a575-673410d17330">
        <updating/>
        <source>getNewPicDrag(_wharfDrawControl : HMS_WharfDrawControl; 
			_workingMovement,
			_nextWorkingMovement : CMIF_HMS_WorkingMovement;
			_bowOnLeft : Boolean) : HMS_GraphicalDragPicture updating;
// ---------------------------------------------------------------------------
// Created:     28 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDragPic	: HMS_GraphicalDragPicture;
	
begin
	self.nextPicDragIndex := self.nextPicDragIndex + 1;
	tmpDragPic := self.picDrag.loadControl(self.nextPicDragIndex).HMS_GraphicalDragPicture;

	tmpDragPic.init(self, _wharfDrawControl, _workingMovement, _nextWorkingMovement, _bowOnLeft);
	
	return tmpDragPic;
end;</source>
        <Parameter name="_wharfDrawControl" type="HMS_WharfDrawControl"/>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_nextWorkingMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_bowOnLeft" type="Boolean"/>
        <ReturnType type="HMS_GraphicalDragPicture"/>
    </JadeMethod>
    <JadeMethod name="getNextWharfDrawControl" id="fc9e3e8e-3923-47c5-9b58-3f2121b3c66f">
        <source>getNextWharfDrawControl(_currentWhafDrawControl : HMS_WharfDrawControl) : HMS_WharfDrawControl;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
	tmpArray	: HMS_WharfDrawControlArray;
begin
	if _currentWhafDrawControl = null then
		return null;
	endif;
	tmpArray := self.allWharfDrawControlsVisible;
	idx := tmpArray.indexOf(_currentWhafDrawControl);
	if idx = 0 or
	   idx = tmpArray.size then
		return null;
	endif;
	
	return tmpArray[idx+1];

end;</source>
        <Parameter name="_currentWhafDrawControl" type="HMS_WharfDrawControl"/>
        <ReturnType type="HMS_WharfDrawControl"/>
    </JadeMethod>
    <JadeMethod name="getNoteForDate" id="3833acd2-b2fd-4224-8687-1401535f0e6a">
        <source>getNoteForDate( date : Date) : HMS_PlanningNote;
//-----------------------------------------------------------------------
//	Created:	02 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	return self.myHarbour.getNoteForDate(date);
epilog

end;</source>
        <Parameter name="date" type="Date"/>
        <ReturnType type="HMS_PlanningNote"/>
    </JadeMethod>
    <JadeMethod name="getPreviousWharfDrawControl" id="15d54d5d-a3ce-46ca-92e2-8eaec58daef8">
        <source>getPreviousWharfDrawControl(_currentWhafDrawControl : HMS_WharfDrawControl) : HMS_WharfDrawControl;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
	tmpArray	: HMS_WharfDrawControlArray;
begin
	if _currentWhafDrawControl = null then
		return null;
	endif;
	tmpArray := self.allWharfDrawControlsVisible;
	idx := tmpArray.indexOf(_currentWhafDrawControl);
	
	if idx &lt;= 1 then
		return null;
	endif;
	
	return tmpArray[idx-1];

end;</source>
        <Parameter name="_currentWhafDrawControl" type="HMS_WharfDrawControl"/>
        <ReturnType type="HMS_WharfDrawControl"/>
    </JadeMethod>
    <JadeMethod name="getSpritePositionForUpdate" id="ddc80747-c31a-44ab-baf5-624f212f51ae">
        <source>getSpritePositionForUpdate(_pict : HMS_GraphicalDragPicture input; _clonedMovement : CMIF_HMS_WorkingMovement input;
						   _berth : HMS_Berth output; _usePreferedMarks : Boolean) protected;
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------------------
// 05/11/2013	cnwdap1		PAR #32744 Change direction of the sprite if we're being dragged between
//							wharves that draw in different directions. Made _pict parameter input as well
// 29/09/2022 	navsj20		ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
// 21/03/2023	navdap1		TFS 56593 EUP - Show Bollard+Meters in all instances
// 05/09/2023	navdap1		TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial

vars
	meter1,
	meter2	: Decimal[12,2];
	displayLeftRight,
	onLeft  : Boolean;
	wharf : HMS_Wharf;
	oldWharf : HMS_Wharf;					// PAR #32744
	bowBollard, sternBollard, bridgeBollard : HMS_Resource;		// TFS 56593
	bowBMark, sternBMark, bridgeBMark : Decimal [12,2];			// TFS 56593	// TFS 59472
begin
	
	//AJA 1/8/00: If we wanted to move to preferred marks, then do a straight copy. Otherwise we
	//will end up a meter or two out due to pixel resolution
 	if _usePreferedMarks then
		_berth := _pict.myCurrentWharfDrawControl.getBerthByLeftPos(_pict.left);	 	 	
		return;
	endif;
	
	_pict.myCurrentWharfDrawControl.getBerthBowSternMarks(_pict.left, _pict.vesselLengthOverall, _berth, meter1, meter2);
	wharf := _pict.myCurrentWharfDrawControl.myWharf;
	oldWharf := _clonedMovement.myBerth.myWharf;						// PAR #32744
	if oldWharf &lt;&gt; wharf then											// PAR #32744
		if oldWharf.displayLeftToRight &lt;&gt; wharf.displayLeftToRight then	// PAR #32744
			_pict.bowOnLeft := not _pict.bowOnLeft;						// PAR #32744
		endif;															// PAR #32744
		if oldWharf.waterOnLeft &lt;&gt; wharf.waterOnLeft then				// PAR #32744
			_pict.bowOnLeft := not _pict.bowOnLeft;						// PAR #32744
		endif;															// PAR #32744
	endif;																// PAR #32744
	if controlMoveStyle=Move_NS or controlMoveStyle=Move_None then 
 		// Do not change posn if lock or NS movement only buttons are on
	else
		displayLeftRight := wharf.displayLeftToRight;
		onLeft := _pict.bowOnLeft;
		if onLeft and displayLeftRight then
					
			_clonedMovement.bowMarkTo  	:= meter1;
			_clonedMovement.sternMarkTo	:= meter2;
		elseif onLeft and (not displayLeftRight) then
		
			_clonedMovement.bowMarkTo  	:= meter2;
			_clonedMovement.sternMarkTo	:= meter1;
		elseif (not onLeft) and displayLeftRight then
		
			_clonedMovement.bowMarkTo  	:= meter2;
			_clonedMovement.sternMarkTo	:= meter1;
		elseif (not onLeft) and (not displayLeftRight) then
			
			_clonedMovement.bowMarkTo  	:= meter1;
			_clonedMovement.sternMarkTo	:= meter2;
		endif;
		// TFS 56593 start
		//_berth.getBollardForMark(_clonedMovement.bowMarkTo.Integer, bowBMark, bowBollard);			// TFS 59472
		//_berth.getBollardForMark(_clonedMovement.sternMarkTo.Integer, sternBMark, sternBollard);		// TFS 59472
		wharf.getBollardForMark(_clonedMovement.bowMarkTo.Integer, bowBMark, bowBollard);				// TFS 59472
		wharf.getBollardForMark(_clonedMovement.sternMarkTo.Integer, sternBMark, sternBollard);			// TFS 59472
		if _pict.myWorkingVoyage.myHMSVoyageData &lt;&gt; null then
			if _clonedMovement.sternMarkTo &gt; _clonedMovement.bowMarkTo then
				//_berth.getBollardForMark((_clonedMovement.bowMarkTo + _pict.myWorkingVoyage.myHMSVoyageData.dist_BridgeToBow).Integer, bridgeBMark, bridgeBollard);	// TFS 59472
				wharf.getBollardForMark((_clonedMovement.bowMarkTo + _pict.myWorkingVoyage.myHMSVoyageData.dist_BridgeToBow).Integer, bridgeBMark, bridgeBollard);		// TFS 59472
			else
				//_berth.getBollardForMark((_clonedMovement.bowMarkTo - _pict.myWorkingVoyage.myHMSVoyageData.dist_BridgeToBow).Integer, bridgeBMark, bridgeBollard);	// TFS 59472
				wharf.getBollardForMark((_clonedMovement.bowMarkTo - _pict.myWorkingVoyage.myHMSVoyageData.dist_BridgeToBow).Integer, bridgeBMark, bridgeBollard);		// TFS 59472
			endif;
		endif;
		_clonedMovement.bowToBollard := bowBMark;
		_clonedMovement.sternToBollard := sternBMark;
		_clonedMovement.bridgeToBollard := bridgeBMark;
		_clonedMovement.setMyBollards(bowBollard, sternBollard, bridgeBollard);
		// TFS 56593 end
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_pict" type="HMS_GraphicalDragPicture" usage="input"/>
        <Parameter name="_clonedMovement" type="CMIF_HMS_WorkingMovement" usage="input"/>
        <Parameter name="_berth" type="HMS_Berth" usage="output"/>
        <Parameter name="_usePreferedMarks" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTimeForPosition" id="16a3725a-bbee-4fff-b2da-f3a2d4698d82">
        <source>getTimeForPosition(_yPos : Real; _timeStamp : TimeStamp output) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     11 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 30/01/2014	cnwdap1		PAR #33337 CCMS PTR 214 HMS Enhancements - include scroled position when calculating date
vars
	yPosition		: Real;
	startTime		: TimeStamp;
	timeHeight		: Real;
	
begin
	// PAR #33337 - take account of the scrolled position of the graphical view when calculating yPosition					// PAR #33337
	//yPosition	:=	_yPos - self.frmToolbar.height - self.frmVslPosDetail.top + 2;											// PAR #33337
	yPosition	:=	_yPos - self.frmToolbar.height - self.frmVslPosDetail.top + 2 + self.frmScrollablMain.getVScrollValue;	// PAR #33337
	startTime	:=	self.myDrawTimeLabel.fromTimePeriod;
	timeHeight	:=	self.myDrawTimeLabel.scaleHeight;	// Current height of time label in pixels.
	
	if (yPosition &lt; 0) then
		// Control has moved off top of visible area.
		return false;
	elseif (yPosition &gt; timeHeight) then
		return false;
	endif;

	_timeStamp	:=	startTime.changeByXXMinutes(((timeHeight - yPosition) * self.minutesPerPixel).Integer);

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_yPos" type="Real"/>
        <Parameter name="_timeStamp" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTimeValuesForPosition" id="ee121732-0da1-43fc-b73b-a8a830e982ed">
        <source>getTimeValuesForPosition(_pict : HMS_GraphicalDragPicture; _moveInTS, _moveOutTS : TimeStamp output) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     11 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpFromTime	: TimeStamp;
	tmpMinsPerPixel,
	picMoveInPos,
	picMoveOutPos,	
	picHeight,
	timeHeight	: Real;

begin

	picHeight 		:= _pict.height;
	picMoveOutPos	:= _pict.top;
	picMoveInPos 	:= picMoveOutPos + picHeight;
	tmpMinsPerPixel	:= self.minutesPerPixel;
	
	tmpFromTime := self.myDrawTimeLabel.fromTimePeriod;

	timeHeight 	:= self.myDrawTimeLabel.scaleHeight;	// current height of time label in pixels
	
	if (picMoveOutPos + picHeight &lt; 0) then
		// control has moved off top of visible area
		return false;
	elseif (picMoveOutPos &gt; timeHeight) then
		return false;
	endif;

	_moveInTS := tmpFromTime.changeByXXMinutes(((timeHeight - picMoveInPos) * tmpMinsPerPixel).Integer);	
	_moveOutTS := _moveInTS.changeByXXMinutes((picHeight * tmpMinsPerPixel).Integer);

	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_pict" type="HMS_GraphicalDragPicture"/>
        <Parameter name="_moveInTS" type="TimeStamp" usage="output"/>
        <Parameter name="_moveOutTS" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getViewCaption" id="e93fd5e9-6f66-4808-ba45-8cf5a69b99bb">
        <source>getViewCaption():String;
//--------------------------------------------------
// Created:	14 February 2005 By: cnwgd1

/*

Date		Who		Reason
2 Apr 08	cnwrs2	Change to only show 1 terminal
20 Jun 2008	cnwkpd1	PAR #16991 - Add Harbour back in, in addition to Terminal
30/5/16		cnwmp6	TFS 488 - remove terminal, to be displayed by setCaption

*/
vars
	viewCaption		: String;
	
begin
	viewCaption := self.View_Caption;
/*	
	if self.myTerminal &lt;&gt; null then
		viewCaption := viewCaption &amp; ' ' &amp; self.myTerminal.code;
	endif;
*/	if self.myHarbour &lt;&gt; null then
		viewCaption := viewCaption &amp; ' ' &amp; self.myHarbour.code;
	endif;
	
	return viewCaption;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLForOtherTerminals" id="a578fa8e-f8e2-4c25-b310-09f55a27d0d3">
        <source>getXMLForOtherTerminals(_xmlSettings:String):String protected;
// --------------------------------------------------------------------------------
// Created:		06 October 2006 by cnwdad1
//
// Purpose:		Returns the XML of saved Wharf settings for all Terminals except for
//				the current Terminal - the Wharf settings for the current Terminal
//				will always be rebuilt by the calling method.
//
// Parameters:	_xmlSettings - The XML settings for the current User Window object.
//
// Returns:		The Terminal Wharf settings, in XML format.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj		: CM_Terminal;
	terminalOpen	: String;
	terminalClose	: String;
	workXml			: String;
	startPos		: Integer;
	endPos			: Integer;
	xmlLength		: Integer;
	terminalCode	: String;
	returnValue		: String;
	
begin
	terminalObj		:=	self.myTerminal;
	startPos		:=	1;
	terminalOpen	:=	"&lt;" &amp; self.XMLTag_Terminal &amp; "&gt;";
	terminalClose	:=	"&lt;/" &amp; self.XMLTag_Terminal &amp; "&gt;";
	
	while true do
		if startPos &gt; _xmlSettings.length() then
			break;
		endif;
		
		startPos	:=	_xmlSettings.pos(terminalOpen, startPos);
		
		if startPos = 0 then
			break;
		endif;
		
		endPos	:=	startPos + terminalOpen.length();
		endPos	:=	_xmlSettings.pos(terminalClose, endPos);
		
		if endPos = 0 then
			break;
		endif;
		
		xmlLength		:=	endPos - startPos + terminalClose.length();
		workXml			:=	_xmlSettings[startPos:xmlLength];
		terminalCode	:=	workXml.cnEcGetTagValueOfName(self.XMLTag_TerminalCode);
		
		// Now set the start pos for the next loop.  Do it here so that we're still at the
		// correct position if we have to "continue" to the next loop.
		startPos	:=	startPos + xmlLength;
		
		if terminalCode = terminalObj.code then
			continue;
		endif;
		
		if returnValue = null then
			returnValue	:=	workXml;
		else
			returnValue	:=	returnValue &amp; workXml;
		endif;
	endwhile;
	
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="_xmlSettings" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForExit" id="d88da42c-90a8-4456-925e-70da5b082f53">
        <updating/>
        <source>getXMLSettingsForExit(): String updating;
// --------------------------------------------------------------------------------
// Created:		04 October 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return inheritMethod();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="516ba6fa-96bc-48df-8133-15348b1b0cb8">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	04 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	xmlStr			: String;
	tmpStr			: String;
	startDT			: String;
	finishDT 		: String;
	wharfSettings	: String;
	entRow			: EntTableRow;
	wharfObj		: HMS_Wharf;
	userWindowObj	: CM_UserWindow;
	
begin
	xmlStr	:=	inheritMethod();
	
	if self.mnuSaveRange.checked then
		startDT		:=	self.myViewController.viewStartDT.asXMLFormat();
		finishDT	:=	self.myViewController.viewFinishDT.asXMLFormat();
	endif;

	// Time period.
	
	xmlStr	:=	xmlStr &amp; global.formatAsXML(self.XMLTag_StartDT, startDT)
				&amp; global.formatAsXML(self.XMLTag_FinishDT, finishDT)
				&amp; global.formatAsXML(self.XMLTag_PosMarks, self.btnPosDetail.value.String)
				&amp; global.formatAsXML(self.XMLTag_MoveDirection, self.controlMoveStyle.String)
				&amp; global.formatAsXML(self.XMLTag_TimeZoom, self.timeZoom.String)
				&amp; global.formatAsXML(self.XMLTag_WharfZoom, self.wharfZoom.String);
	
	// Tool tips stuff.
	
	foreach entRow in self.allToolTipsEntArray do
		tmpStr	:=	tmpStr &amp; global.formatAsXML(self.XMLTag_ToolTip, entRow.name);
	endforeach;
	
	xmlStr	:=	xmlStr &amp;
				global.formatAsXMLPrefix(self.XMLTag_AllToolTips &amp; ETDef_ToolTips) &amp;
				tmpStr &amp;
				global.formatAsXMLSuffix(self.XMLTag_AllToolTips &amp; ETDef_ToolTips);
	
	// Selected wharves.
	
	xmlStr	:=	xmlStr &amp; global.formatAsXMLPrefix(self.XMLTag_Wharves);

	userWindowObj	:=	app.getUserWindow(self.name, false);
	
	if userWindowObj &lt;&gt; null then
		wharfSettings	:=	self.getXMLForOtherTerminals(userWindowObj.xmlInfo);
		
		if wharfSettings &lt;&gt; null then
			xmlStr	:=	xmlStr &amp; wharfSettings;
		endif;
	endif;
	
	xmlStr	:=	xmlStr &amp;
				global.formatAsXMLPrefix(self.XMLTag_Terminal) &amp;
				global.formatAsXML(self.XMLTag_TerminalCode, self.myTerminal.code);
	
	foreach wharfObj in self.aAllSelectedWharves do
		xmlStr	:=	xmlStr &amp; global.formatAsXML(self.XMLTag_WharfCode, wharfObj.code);
	endforeach;
	
	xmlStr	:=	xmlStr &amp;
				global.formatAsXMLSuffix(self.XMLTag_Terminal) &amp;
				global.formatAsXMLSuffix(self.XMLTag_Wharves);
	
	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationRefreshView" id="b368f156-c54c-4d72-ae07-ffa5cdef2e41">
        <updating/>
        <source>handleNotificationRefreshView(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------
// Created:	07 January 2005 By: cnwgd1
// Changed
//	2 Apr 08	cnwrs2	Change to only show 1 terminal (PAR 16411)
//--------------------------------------------------
vars

begin

	if self.myTerminal.myHarbour = self.myHarbour then
		//harbour updated
		self.handleNotifications(eventType, self.myHarbour, null, self.myHarbour);
		return;
	endif;

	if self.myHarbour &lt;&gt; self.myTerminal.myHarbour then
		// PAR 16411 - as can only show 1 terminal if this is changed then need to close form.
		app.raiseCMException(Harbo_that_curre_termi_assoc_w, null, null);
		self.unloadForm();
	endif;
	
	/*
	if self.myHarbour &lt;&gt; self.myTerminal.myHarbour then
		self.myHarbour := self.myTerminal.myHarbour;
	else
		return;
	endif;
		
	//Harbour for terminal has changed
	self.myViewController.setMyHarbour();
	self.buildMap();
	self.buildEntireForegroundForXViews();
	*/
					
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="60f00356-59d4-4d56-8c90-8a8b919d4695">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: CM_Object; eventTag: Integer; userInfo: CM_Object) updating;
//--------------------------------------------------
// Created:	18 May 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
19 Mar 2008	cnwkpd1	PAR #16195 - Arm generic exception handler to deal with Update events followed by Delete
					events.
					Reworked handling of new vessels to add to either available or selected listbox 
					as appropriate.
					Reworked delete of a vessel to remove from listboxes and then rebuild selected collection
					from the listbox, to prevent error 4 exceptions in the includes call.
16 May 2012	cnwdap1	PAR #29427 New parameter for buildEntireForegroundForXViews method to prevent tidal summary form from being updated twice
*/

vars
	tmpObj			: HMS_Object;
	failedDAC		: CM_DataAccessController;
	tmpStr			: String;
	invalidObject	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);		// PAR #16195
	
	// cnwdad1 11/01/2007. If we're running the JMT application, then we want to ignore all objects
	// that have a Scenario Root.  If we're running the Scenario application, then we only want to
	// process objects who's Scenario Root object is the same as the one the application is running
	// for (each copy of the Scenario application can only views one scenario at a time).
	
	// PAR #16195 - exception handler will now deal with theObject being invalid
//	if global.isValidObject(theObject) then
	if eventType &lt;&gt; Object_Delete_Event and app.myRoot &lt;&gt; theObject.getMyRoot() then
		//app.writeLog("Graphical View notification rejected because the Object's root doesn't match the application's root.", LogAlways);
		//app.cnwdad1_write("Graphical View notification rejected because the Object's root doesn't match the application's root.");
		return;
	endif;
//	endif;


	if (not global.isValidObject(self.myCurrentWorkingMovement)) then
		self.setMyCurrentWorkingMovement(null);
	endif;

	if self.myViewController.viewStartDT &lt;&gt; self.myDrawTimeLabel.fromTimePeriod
	or self.myViewController.viewFinishDT &lt;&gt; self.myDrawTimeLabel.toTimePeriod
	then
		// PAR 10625 - unable to reproduce fault. Have added this check.
		self.myViewController.doRefreshView(true);
		app.writeLog(class.name &amp; ' ' &amp; method.name &amp; ' &gt;&gt; Time scale mismatch &lt;&lt;', LogINFO);
		return;
	
	elseif HMS_VoyageData.hasInstance(theObject) then
		// Do not inform user that their changes will be lost as per Phil
		self.myViewController.handleNotificationForHMSVoyage(eventType, theObject.HMS_VoyageData);
	
	elseif eventType = RefreshView
	or HMS_Harbour.hasInstance(theObject)
	then
		if self.myViewController.allChanges.size &gt; 0 then
			// Inform user that their changes will be lost
			if HMS_Object.hasInstance(userInfo) then
				tmpObj := userInfo.HMS_Object;
				tmpStr := tmpObj.getDisplayString();
			endif;
			
			app.msgBox(	app.getErrorString1(HMS_ChangesWillBeLost, tmpStr),
						app.getErrorString(MSGBOX_ChangesInvalid),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		endif;
		
		self.buildMap();
	
	// cnwdad1 18/07/2007 - PAR #14383: New vessels weren't being added to the selector's "available" list.
	elseif CM_Vessel.hasInstance(theObject) then
		//epr par 15528 20/12/07 rebuilding the vessels every notification caused performance issues
		// PAR #16195 - Handle deletes and updates differently - don't try to check access when this is a delete note
		if eventType = Object_Create_Event then
			if theObject.CM_Vessel.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
			
				// Add new vessel to selected list if we currently have all available vessels selected,
				// otherwise add it to the available list
				if self.msgVessels.myAvailableListBox.listCount() = 0 then
					self.msgVessels.addItem(self.msgVessels.mySelectedListBox, theObject);
					self.allSelectedVessels.add(theObject.CM_Vessel);		// 21/02/2008 cnwar2 #15658, #15846
				else
					self.msgVessels.addItem(self.msgVessels.myAvailableListBox, theObject);
				endif;				
				
			endif;
			
		elseif eventType = Object_Delete_Event then 		// and CM_Vessel.hasInstance(theObject) then - removed PAR #16195
		
			self.msgVessels.takeOutItem(self.msgVessels.myAvailableListBox, theObject);
			self.msgVessels.takeOutItem(self.msgVessels.mySelectedListBox, theObject);
			
			// PAR #16195 - rework to rebuild from the selected listbox, because we cant remove
			// a deleted object from a Dictionary
//			if self.allSelectedVessels.includes(theObject.CM_Vessel) then
//				self.allSelectedVessels.remove(theObject.CM_Vessel);
//			endif;
			self.allSelectedVessels.clear();
			self.msgVessels.getSelected(self.allSelectedVessels);

		endif;
		
	//09 Mar 2016	NDL	TFS 1627
	elseif HMS_PlanningNote.hasInstance(theObject) then
		if eventType = Object_Create_Event then
			self.buildMap();
		endif;
	else
		app.writeLog(class.name &amp; ' ' &amp; method.name &amp; ' &gt;&gt; Notification not handled &lt;&lt;', LogINFO);
		return;
	endif;
	
	//self.buildEntireForegroundForXViews();		// PAR #29427
	self.buildEntireForegroundForXViews(true);		// PAR #29427
	
	
epilog
		
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="CM_Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="42471c9b-cbbe-446c-bfe5-ad0f3ceffc2f">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//--------------------------------------------------
// Created:	04 May 2004 By: cnwgd1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------
vars
	terminalObj		: CM_Terminal;
	wharfObj		: HMS_Wharf;
	parserObj		: CnEcXmlParser;
	xmlObj			: CnEcXmlStructureInstance;
	xmlGroupObj		: CnEcXmlGroupInstance;
	xmlDocObj		: CnEcXmlGroupInstance;
	xmlFieldObj		: CnEcXmlStructureInstance;
	xmlTagObj		: CnEcXmlStructureInstance;
	tmpTime 		: TimeStamp;
	xmlDef			: String;
	strXmlInfo		: String;
	tmpEntRowName	: String;
	entRow 			: EntTableRow;
	rowArray		: EntTableRowArray;
	entTableDef 	: EntTableDef;
	pos				: Integer;
	
begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	
	strXmlInfo			:=	_userWindow.xmlInfo;
//process.debug();
	self.xmlStrStartDT	:=	strXmlInfo.cnEcGetTagValueOfName(XMLTag_StartDT);
	self.xmlStrFinishDT	:=	strXmlInfo.cnEcGetTagValueOfName(XMLTag_FinishDT);
	
	tmpTime	:=	self.xmlStrStartDT.asTimeStampFromXMLFormat();
	
	if tmpTime.isValid then
		self.mnuSaveRange.checked	:=	true;
	endif;
	
	self.xmlStrTimeZoom		:=	strXmlInfo.cnEcGetTagValueOfName(XMLTag_TimeZoom);
	self.xmlStrWharfZoom	:=	strXmlInfo.cnEcGetTagValueOfName(XMLTag_WharfZoom);
	
	if self.xmlStrTimeZoom &lt;&gt; null
	and self.xmlStrTimeZoom.Real &gt; 0
	and self.xmlStrTimeZoom.Real &lt;= self.Time_ZoomFull
	then
		self.timeZoom	:=	self.xmlStrTimeZoom.Real;
	endif;

	if self.xmlStrWharfZoom &lt;&gt; null
	and self.xmlStrWharfZoom.Real &gt; 0
	and self.xmlStrWharfZoom.Real &lt;= self.Wharf_Zoom1
	then
		self.wharfZoom	:=	self.xmlStrWharfZoom.Real;
	endif;

	self.controlMoveStyle	:=	strXmlInfo.cnEcGetTagValueOfName(XMLTag_MoveDirection).Integer;
	self.btnPosDetail.value	:=	strXmlInfo.cnEcGetTagValueOfName(XMLTag_PosMarks).Boolean;
	
	// ent rows used to decide what tool tips to show in bubble help.
	pos		:=	1;
	xmlDef	:=	strXmlInfo.cnEcGetNextTagValueOfName(XMLTag_AllToolTips &amp; ETDef_ToolTips, pos);
	
	if xmlDef = null then
		// no xml for def, no tool tips set up so default will be displayed.
		return;
	endif;

	entTableDef	:=	app.myController.getEntTableDef(ETDef_ToolTips);
	

	// Use the default view.
	rowArray		:=	entTableDef.allEntTableRows;

	
	pos	:=	1;
	
	while (pos &gt; 0) do
		tmpEntRowName	:=	xmlDef.cnEcGetNextTagValueOfName(XMLTag_ToolTip, pos);
		
		if tmpEntRowName &lt;&gt; null then
			foreach entRow in rowArray do
				if entRow.name = tmpEntRowName then
					// populate collection to be used when creating bubble help for
					self.allToolTipsEntArray.add(entRow);
					break;
				endif;
			endforeach;
		endif;
	endwhile;
	
	// Load any saved Wharves for the current Terminal.
	
	terminalObj		:=	self.myTerminal;
	self.aAllSelectedWharves.clear();
	create parserObj transient;
	create xmlObj as CnEcXmlGroupInstance transient;
	xmlDef		:=	strXmlInfo.cnEcGetTagValueOfName(self.XMLTag_Wharves);
	parserObj.parseToMsgStructure(xmlDef, xmlObj);
	xmlGroupObj	:=	xmlObj.CnEcXmlGroupInstance;
	
	foreach xmlFieldObj in xmlGroupObj.allFields do
		if xmlFieldObj.tagName = self.XMLTag_Terminal then
			xmlDocObj	:=	xmlFieldObj.CnEcXmlGroupInstance;
			
			foreach xmlTagObj in xmlDocObj.allFields do
				if xmlTagObj.tagName = self.XMLTag_TerminalCode then
					if xmlTagObj.tagData = terminalObj.code then
						// The rest of the tags in xmlDocObj should all be the Wharf codes.
						continue;
					else
						// Not for the current Terminal, so break and continue to scan xmlGroupObj.
						break;
					endif;
					
				elseif xmlTagObj.tagName = self.XMLTag_WharfCode then
					wharfObj	:=	terminalObj.allWharves[xmlTagObj.tagData];
					
					if wharfObj &lt;&gt; null then
						self.aAllSelectedWharves.add(wharfObj);
					endif;
				endif;
			endforeach;
		endif;
	endforeach;
	
	if self.aAllSelectedWharves.size = 0 then
		self.aAllSelectedWharves.add(terminalObj.allWharves.first);
	endif;
epilog
	delete parserObj;
	delete xmlObj;
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initMeterMarks" id="de95a970-7139-4788-81bd-7b8354510108">
        <updating/>
        <source>initMeterMarks()updating, protected;
//--------------------------------------------------
// Created:	18 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	frm					: CMUI_MoveableFrame;
	entTableDef			: EntTableDef;
	tbl					: CM_EntryTable;
	
begin
	frm := self.frmMarksRemarks;
	frm.backColor := self.backColor;

	tbl := self.tblMeterMarks;
	tbl.warningMethod := 'entTableWarning';
	tbl.top 	:= self.frmMarksToolbar.height;
	frm.cnEcResizeContents();
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_HMSMovementSelect];
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Entry table definition not found for meter mark table');
		return;
	endif;
	
	tbl.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.cmbMyBerth.style := ComboBox.Style_DropDownList;

	//Hide Data/Time as not implemented yet
	tbl.hideRowByName(ETRow_OccursOnDate, false);
	tbl.hideRowByName(ETRow_OccursOnTime, false);
	
	self.tblExtraInfo.selectMode := Table.SelectMode_None;
	self.tblExtraInfo.userInputEnabled := false;
	self.tblExtraInfo.wordWrap := true;			

	frm.centreWindow();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initMoveDirectionControls" id="423f8d05-01b9-4401-b5ad-91dec40d96df">
        <updating/>
        <source>initMoveDirectionControls()updating, protected;
//--------------------------------------------------
// Created:	27 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.controlMoveStyle = Move_NESW then
		self.doBtnWharfAndTimeChanges(true);
	elseif self.controlMoveStyle = Move_WE then
		self.doBtnWharfChangesOnly(true);
	elseif self.controlMoveStyle = Move_NS then
		self.doBtnTimeChangesOnly(true);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initRangeSelector" id="74f34d37-6cd6-412a-a8ec-cb531aeb8fb5">
        <updating/>
        <source>initRangeSelector()updating, protected;
//--------------------------------------------------
// Created:	18 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	frameObj		: CMUI_MoveableFrame;
	entTableDef		: EntTableDef;
	tableObj		: CM_EntryTable;
	folderObj		: CMUI_Folder;
	
begin
	frameObj				:=	self.frmSearch;
	frameObj.backColor		:=	self.backColor;
	frameObj.width			:=	500; //250;
	frameObj.height			:=	250;
	
	folderObj		:=	fldSearch;
	folderObj.move(0, (frmSearchToolbar.height + 20), (frameObj.width - 10), frameObj.height);
	
	tableObj				:=	self.tblSearch;
	tableObj.warningMethod	:=	'entTableWarning';
//	tableObj.top			:=	self.frmSearchToolbar.height;
//	tableObj.left			:=	0;
//	tableObj.stretchHeight	:=	true;
//	tableObj.stretchWidth	:=	true;
	tableObj.move(0, tableObj.top, shtRanges.width, (shtRanges.height - tableObj.top));
	msgOperators.move(0, 0, shtOperators.width, shtOperators.height - 50);
	msgVessels.move(0, 0, shtVessels.width, shtVessels.height - 50);
	frameObj.cnEcResizeContents();
	
	/*self.lblSearch.top := 5;
	self.lblSearch.left := 5;
	self.lblSearch.caption := 'Select the Terminal Areas to display';
	self.lblSearch.caption := 'Select the Terminal Area Types to display';*/

	entTableDef	:=	app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RangeSelector];
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Entry table definition not found for range selector table');
		return;
	endif;
	
	tableObj.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.doRangeSelectorResetDateTime(false);
	//epr par 15528 20/12/07 rebuilding the vessels every notification caused performance issues
	self.initSelectOperators(true);
	self.initSelectVessels(true);
	
	frmSearch.visible	:=	false;
	frmSearch.centreWindow();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initSelectOperators" id="89f27dc4-75a8-4a6a-b636-5a2f53d47907">
        <source>initSelectOperators(_default : Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		09 October 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	groupboxObj		: CMUI_MultiSelectGroupBox;
	operatorObj		: CM_Operator;
	userObj			: CM_User;
	failedDAC  :CM_DataAccessController;
	
begin
	groupboxObj								:=	self.msgOperators;
	groupboxObj.caption						:=	null;
	groupboxObj.distanceFromBottom			:=	5;
	groupboxObj.distanceFromRight 			:=	5;
	groupboxObj.lockBottom 					:=	false;
	groupboxObj.lockRight					:=	false;
	groupboxObj.stretchHeight 				:=	false;
	groupboxObj.stretchWidth 				:=	true;
	groupboxObj.multiSelect					:=	ListBox.MultiSelect_Extended;
	groupboxObj.formDisplayEntryMethodName	:=	HMS_GraphicalViewX::displaySelectOperator.name;
	groupboxObj.availableHeading			:=	app.getErrorString(Available_Operators);
	groupboxObj.selectedHeading				:=	app.getErrorString(Selected_Operators);
	groupboxObj.myBaseForm					:=	self;
	groupboxObj.mySelectedListBox.sorted	:=	false;
	groupboxObj.cnEcResizeContents();
	groupboxObj.readOnly					:=	false;
	
	userObj	:=	app.getMyUser();
	//epr par 15528 20/12/07 rebuilding the vessels every notification caused performance issues
	// we initialise the available on form load and when the search is reset
	if _default then
		self.allSelectedOperators.clear;
		foreach operatorObj in app.myRoot.allOperators do
			if operatorObj.canUserAccessSelf(userObj,failedDAC, app.myPassport) then
				self.allSelectedOperators.add(operatorObj);
			endif;
		endforeach;
		self.msgOperators.setAvailable(self.allSelectedOperators, true);
	endif;
	self.msgOperators.setSelected(self.allSelectedOperators);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_default" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initSelectVessels" id="14091927-4002-410f-a4fe-d018095b1a9c">
        <source>initSelectVessels(_isDefault : Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		09 October 2006 by cnwdad1
//
// Purpose:		Initializes the Vessel multi-select groupbox control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	groupboxObj		: CMUI_MultiSelectGroupBox;
	vesselObj		: CM_Vessel;
	passportObj		: CM_Passport;
	failedDAC  :CM_DataAccessController;
	
begin
	groupboxObj								:=	self.msgVessels;
	groupboxObj.caption						:=	null;
	groupboxObj.distanceFromBottom			:=	5;
	groupboxObj.distanceFromRight 			:=	5;
	groupboxObj.lockBottom 					:=	false;
	groupboxObj.lockRight					:=	false;
	groupboxObj.stretchHeight 				:=	false;
	groupboxObj.stretchWidth 				:=	true;
	groupboxObj.multiSelect					:=	ListBox.MultiSelect_Extended;
	groupboxObj.formDisplayEntryMethodName	:=	HMS_GraphicalViewX::displaySelectVessel.name;
	groupboxObj.availableHeading			:=	app.getErrorString(Available_vessels);
	groupboxObj.selectedHeading				:=	app.getErrorString(Selected_vessels);
	groupboxObj.myBaseForm					:=	self;
	groupboxObj.mySelectedListBox.sorted	:=	false;
	groupboxObj.cnEcResizeContents();
	groupboxObj.readOnly					:=	false;
	
	passportObj	:=	app.myPassport;
	//epr par 15528 20/12/07 rebuilding the vessels every notification caused performance issues
	// we initialise the available on form load and when the search is reset
	if _isDefault then
		self.allSelectedVessels.clear;
		foreach vesselObj in app.myRoot.allVessels do
			if vesselObj.canUserAccessSelf(null, failedDAC, passportObj) then
				self.allSelectedVessels.add(vesselObj);
			endif;
		endforeach;
		self.msgVessels.setAvailable(self.allSelectedVessels, true);
	endif;
	
	self.msgVessels.setSelected(self.allSelectedVessels);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_isDefault" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initSelectWharvesCollection" id="6d13f0e0-b43c-4697-8803-e411c1a26bae">
        <source>initSelectWharvesCollection() protected;
// --------------------------------------------------------------------------------
// Created:		02 October 2006 by cnwdad1
//
// Purpose:		Initializes the array of available wharves.  Wharves are only included
//				if the user has access to the wharf's Terminal.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
//	01 Apr 08	cnwrs2		PAR 16411 - change to restrict to only show 1 terminal
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
// 9 JUNE 2022 navvt20 TFS53757 - Initializing msgselectWharvesBox
vars
	tmpAllAvailableObjs		: HMS_WharfArray;
	tmpAllSelectedObjs		: HMS_WharfArray;
	terminalObj			: CM_Terminal;
	wharfObj			: HMS_Wharf;
	failedDAC  :CM_DataAccessController;
	
begin
	create tmpAllAvailableObjs transient;
	create tmpAllSelectedObjs transient;
	
	self.aAllSelectedWharves.copy(tmpAllSelectedObjs);
	self.aAllAvailableWharves.clear();
	self.aAllSelectedWharves.clear();

//	foreach terminalObj in self.myHarbour.allTerminalsByCode do		// PAR 16411
//		if terminalObj.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
	terminalObj := self.myTerminal;
	
	foreach wharfObj in terminalObj.allWharves do
		if not tmpAllAvailableObjs.includes(wharfObj) then
			tmpAllAvailableObjs.add(wharfObj);
		endif;
	endforeach;
//		endif;
//	endforeach;
	
	
	foreach wharfObj in self.myHarbour.allWharfDisplayOrderArray do
		// some wharfs (e.g. anchorage) may not be associated with
		// a terminal so add always add in.
		if wharfObj.allTerminals.isEmpty then
			self.aAllAvailableWharves.add(wharfObj);
			self.aAllSelectedWharves.add(wharfObj);
		endif;
		
		if tmpAllAvailableObjs.includes(wharfObj) then
			self.aAllAvailableWharves.add(wharfObj);
		endif;
		
		if tmpAllSelectedObjs.includes(wharfObj) then
			self.aAllSelectedWharves.add(wharfObj);
		endif;
	endforeach;
	
	if self.aAllSelectedWharves.isEmpty() then
		self.aAllAvailableWharves.copy(self.aAllSelectedWharves);
	endif;
	
	self.msgSelectWharves.setAvailable(self.aAllAvailableWharves, true);
	self.msgSelectWharves.setSelected(self.aAllSelectedWharves);
	
	//navvt20 07/06/2022 TFS-53757 -start
    self.msgSelectWharvesBox.setAvailable(self.aAllAvailableWharves, true);
	self.msgSelectWharvesBox.setSelected(self.aAllSelectedWharves);
	//navvt20 07/06/2022 TFS-53757 -end
	
	//epr par 16808 19/6/08
	self.myViewController.allWharves.clear;
	self.aAllSelectedWharves.copy(self.myViewController.allWharves);
epilog
	delete tmpAllAvailableObjs;
	delete tmpAllSelectedObjs;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initSelectWharvesGroupBox" id="fecbba4c-b9c1-4d98-8985-7e6455771ae9">
        <source>initSelectWharvesGroupBox() protected;
// --------------------------------------------------------------------------------
// Created:		02 October 2006 by cnwdad1
//
// Purpose:		Initializes the Wharf multi-select group box control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
//  07-06-2022 navvt20 TFS53757 - Intializing msgSelectWharvesBox
vars
	groupboxObj	: CMUI_MultiSelectGroupBox;
	groupboxObj1: CMUI_MultiSelectGroupBox; //navvt20 07-06-2022 TFS 53757
begin
	groupboxObj								:=	self.msgSelectWharves;
	groupboxObj.caption						:=	null;
	groupboxObj.distanceFromBottom			:=	5;
	groupboxObj.distanceFromRight 			:=	5;
	groupboxObj.lockBottom 					:=	false;
	groupboxObj.lockRight					:=	false;
	groupboxObj.stretchHeight 				:=	false;
	groupboxObj.stretchWidth 				:=	true;
	groupboxObj.multiSelect					:=	ListBox.MultiSelect_Extended;
	groupboxObj.formDisplayEntryMethodName	:=	HMS_GraphicalViewX::displaySelectWharves.name;
	groupboxObj.availableHeading			:=	app.getErrorString(Available_wharves);
	groupboxObj.selectedHeading				:=	app.getErrorString(Selected_wharves);
	groupboxObj.myBaseForm					:=	self;
	groupboxObj.mySelectedListBox.sorted	:=	false;
	groupboxObj.cnEcResizeContents();
	groupboxObj.readOnly					:=	false;
	
	//navvt20 07-06-2022 TFS 53757 - start
	groupboxObj1								:=	self.msgSelectWharvesBox;
	groupboxObj1.multiSelect					:=	ListBox.MultiSelect_Extended;
	groupboxObj1.formDisplayEntryMethodName	:=	HMS_GraphicalViewX::displaySelectWharves.name;
	groupboxObj1.availableHeading			:=	app.getErrorString(Available_wharves);
	groupboxObj1.selectedHeading				:=	app.getErrorString(Selected_wharves);
	groupboxObj1.myBaseForm					:=	self;
	groupboxObj1.mySelectedListBox.sorted	:=	false;
	groupboxObj1.cnEcResizeContents();
	groupboxObj1.readOnly					:=	false;
	//navvt20 07-06-2022 TFS 53757 - end
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initSnapBerthSubMenus" id="660690be-9506-4e49-8991-351b9cb44015">
        <source>initSnapBerthSubMenus() protected;
//--------------------------------------------------
// Created:	03 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	mnuChild,
	mnuMaster	: MenuItem;
	idx			: Integer;
	berth		: HMS_Berth;
begin
	
	mnuMaster := self.mnuSnapBerth;
	
	if mnuMaster.helpKeyword.isInteger then
		idx := mnuMaster.helpKeyword.Integer;
	endif;
	
	while idx &gt; 0 do
		mnuChild := mnuMaster.getMenuItem(idx);
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		idx := idx - 1;
	endwhile;
	
	idx := 0;
	
	foreach berth in self.allBerthsInView do
		idx := idx + 1;
		 // check if the menu is already cloned		
		mnuChild := mnuMaster.getMenuItem(idx);
		if mnuChild = null then
			// Clone menu
			mnuChild := mnuMaster.loadSubMenu(idx);
		endif;
		mnuChild.caption := berth.description;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.userObject := berth;
	endforeach;
	
	//Store away the number of sub menu items
	mnuMaster.helpKeyword := idx.String;	  

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initViewController" id="3022e43a-84d2-4653-8b55-d4e0d481b85e">
        <updating/>
        <source>initViewController()updating, protected;
//--------------------------------------------------------------
//Created: 03 July 2003 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
24/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	viewController	: HMS_CMIF_ViewController;
	scenarioFrom	: TimeStamp;
	scenarioTo		: TimeStamp;
	scenarioDiff	: Decimal[12, 0];
	xmlFrom			: TimeStamp;
	xmlTo			: TimeStamp;
	xmlDiff			: Decimal[12, 0];
	useFrom			: TimeStamp;
	useTo			: TimeStamp;
	
begin
	// Create view controller
	create viewController transient;

	// set ref to viewController
	self.myViewController := viewController;
	
	// Initialise controller	
	viewController.initialiseController(self.myTerminal, self.xmlStrStartDT.asTimeStampFromXMLFormat(), self.xmlStrFinishDT.asTimeStampFromXMLFormat());	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initZooms" id="3e757795-6ef3-49c4-ab6a-67b6737b460a">
        <updating/>
        <source>initZooms()updating, protected;
//--------------------------------------------------
// Created:	14 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	strZoom : String;
begin
	self.mnuTimeZoomFull.checked := false;
	self.mnuTimeZoomX2.checked := false;
	self.mnuTimeZoomX3.checked := false;		
	self.mnuTimeZoomX4.checked := false;	
	self.mnuTimeZoomX5.checked := false;	
	self.mnuTimeZoomX6.checked := false;	
	self.mnuTimeZoomX7.checked := false;	
	self.mnuTimeZoomX8.checked := false;	
	
	
	self.mnuTimeZoomFull.helpKeyword := Time_ZoomFull.String;	
	self.mnuTimeZoomX2.helpKeyword := Time_Zoom1.String;
	self.mnuTimeZoomX3.helpKeyword := Time_Zoom2.String;			
	self.mnuTimeZoomX4.helpKeyword := Time_Zoom3.String;	
	self.mnuTimeZoomX5.helpKeyword := Time_Zoom4.String;	
	self.mnuTimeZoomX6.helpKeyword := Time_Zoom5.String;	
	self.mnuTimeZoomX7.helpKeyword := Time_Zoom6.String;	
	self.mnuTimeZoomX8.helpKeyword := Time_Zoom7.String;

	strZoom := self.timeZoom.String;
		
	if strZoom = mnuTimeZoomFull.helpKeyword then
		self.mnuTimeZoomFull.checked := true;	
	elseif strZoom = self.mnuTimeZoomX2.helpKeyword then
		self.mnuTimeZoomX2.checked := true;		
	elseif strZoom = self.mnuTimeZoomX3.helpKeyword then
		self.mnuTimeZoomX3.checked := true;		
	elseif strZoom = self.mnuTimeZoomX4.helpKeyword then
		self.mnuTimeZoomX4.checked := true;		
	elseif strZoom = self.mnuTimeZoomX5.helpKeyword then
		self.mnuTimeZoomX5.checked := true;				
	elseif strZoom = self.mnuTimeZoomX6.helpKeyword then
		self.mnuTimeZoomX6.checked := true;		
	elseif strZoom = self.mnuTimeZoomX7.helpKeyword then
		self.mnuTimeZoomX7.checked := true;		
	elseif strZoom = self.mnuTimeZoomX8.helpKeyword then
		self.mnuTimeZoomX8.checked := true;										
	endif;	
	
	self.lastSelectedTimeZoom := self.timeZoom;
	
	self.mnuZoomX1.checked := false;
	self.mnuZoomX2.checked := false;	
	self.mnuZoomX3.checked := false;	
	self.mnuZoomX4.checked := false;	
	self.mnuZoomX5.checked := false;	
	self.mnuZoomX6.checked := false;	
	self.mnuZoomX7.checked := false;	
	self.mnuZoomX8.checked := false;
	
	self.mnuZoomX1.helpKeyword := Wharf_Zoom1.String;	
	self.mnuZoomX2.helpKeyword := Wharf_Zoom2.String;
	self.mnuZoomX3.helpKeyword := Wharf_Zoom3.String;			
	self.mnuZoomX4.helpKeyword := Wharf_Zoom4.String;	
	self.mnuZoomX5.helpKeyword := Wharf_Zoom5.String;	
	self.mnuZoomX6.helpKeyword := Wharf_Zoom6.String;	
	self.mnuZoomX7.helpKeyword := Wharf_Zoom7.String;	
	self.mnuZoomX8.helpKeyword := Wharf_Zoom8.String;
	
	strZoom := self.wharfZoom.String;
		
	if strZoom = mnuZoomX1.helpKeyword then
		self.mnuZoomX1.checked := true;	
	elseif strZoom = self.mnuZoomX2.helpKeyword then
		self.mnuZoomX2.checked := true;		
	elseif strZoom = self.mnuZoomX3.helpKeyword then
		self.mnuZoomX3.checked := true;		
	elseif strZoom = self.mnuZoomX4.helpKeyword then
		self.mnuZoomX4.checked := true;		
	elseif strZoom = self.mnuZoomX5.helpKeyword then
		self.mnuZoomX5.checked := true;				
	elseif strZoom = self.mnuZoomX6.helpKeyword then
		self.mnuZoomX6.checked := true;		
	elseif strZoom = self.mnuZoomX7.helpKeyword then
		self.mnuZoomX7.checked := true;		
	elseif strZoom = self.mnuZoomX8.helpKeyword then
		self.mnuZoomX8.checked := true;										
	endif;	

	self.lastSelectedWharfZoom := self.wharfZoom;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isVoyageDisplayed" id="7d3400b8-0116-40f9-9d25-4a39ede6f137">
        <source>isVoyageDisplayed(_workingVoyageObj:CMIF_HMS_WorkingVoyage):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		09 October 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Voyage should
//				be displayed.
//
// Parameters:	_workingVoyageObj - A reference to the Working Voyage to display.
//
// Returns:		True if the Voyage is to be displayed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	vesselObj		: CM_Vessel;
	operatorObj		: CM_Operator;
	
begin
	operatorObj	:=	_workingVoyageObj.getOperator();
	vesselObj	:=	_workingVoyageObj.getMyVessel();
	
	//epr par 15528 20/12/07 rebuilding the vessels every notification caused performance issues
	// use collection on form
	if operatorObj &lt;&gt; null then
		if self.allSelectedOperators[operatorObj.code] = null then
			app.writeLog ("Operator not rgitht " &amp; operatorObj.code, LogINFO);
			return false;
		endif;
	endif;
	
	if vesselObj &lt;&gt; null then
		if self.allSelectedVessels[vesselObj.code] = null then
			app.writeLog ("vessel not rgitht " &amp; vesselObj.code, LogINFO);
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_workingVoyageObj" type="CMIF_HMS_WorkingVoyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWharfDisplayed" id="3e894678-7e74-4eed-b8a0-2c42986e298e">
        <source>isWharfDisplayed(_wharfObj:HMS_Wharf):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		09 October 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Wharf should
//				be displayed.
//
// Parameters:	_wharfObj - A reference to the Wharf to display.
//
// Returns:		True if the Wharf is to be displayed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.aAllSelectedWharves.includes(_wharfObj) then
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_wharfObj" type="HMS_Wharf"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="b4ec9b40-9e2b-4f16-8b20-5d901c7e37b6">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	19 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F3 then
		self.btnSelectorShow.click(self.btnSelectorShow);
	elseif keyCode = J_key_Enter then
		if self.frmSearch.visible then
			self.doRangeSelectorSave(false);
		endif;
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
