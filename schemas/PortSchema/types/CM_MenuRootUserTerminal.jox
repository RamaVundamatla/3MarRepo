<Class name="CM_MenuRootUserTerminal" id="1480858b-7c2b-424f-adc9-6c7a8b17267a">
    <superclass name="CM_MenuRoot"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Nav Menu for each user</text>
    <DbClassMap file="cmenu"/>
    <ExplicitInverseRef name="myUser" id="dd697202-49dd-4f14-975b-23c391fb47ea">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_User"/>
        <access>readonly</access>
        <Inverse name="CM_User::allUserMenuRoots"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myUserTerminal" id="80eaf9c3-4582-4f54-9570-c350d786ac93">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_UserTerminal"/>
        <access>readonly</access>
        <Inverse name="CM_UserTerminal::myMenuRoot"/>
    </ExplicitInverseRef>
    <JadeMethod name="canDo" id="8d8ce625-3940-4f74-93e5-a7e42bf7b803">
        <source>canDo(_permValue: Integer; _rptId : String): Boolean;
// ---------------------------------------------------------------------------
// Created:     02 December 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ut	: CM_UserTerminal;

begin

	ut := self.myUserTerminal;

	if _rptId &lt;&gt; null then
		return ut.canDoReport(_rptId);
	endif;
	
	// deliberately go back to CM_User so does license check as well.
	return ut.myUser.canDo(ut.getMyTerminal, _permValue);
	

end;</source>
        <Parameter name="_permValue" type="Integer"/>
        <Parameter name="_rptId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneFromSource" id="16d83c71-67fc-4418-9b81-bb4ed8a8290a">
        <updating/>
        <source>cloneFromSource(_parent: CM_MenuEntity; _source: SelfType; _terminal: CM_Terminal; _targetMenuRoot: CM_MenuRoot input; _user: CM_User; _clearFirst: Boolean; _deleteSet: CM_MenuEntitySet input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/01/2019		jlgdap1		Initial creation TFS 41738 System Items icon missing in Navigator
//
vars

begin
	inheritMethod(_parent, _source, _terminal, _targetMenuRoot, _user, _clearFirst, _deleteSet);
	
	if _terminal &lt;&gt; null then
		// this is a terminal-level menu, turn off the icon
		if self.pictureStringButton &lt;&gt; null then
			self.pictureStringButton := null;
			self.pictureStringButtonDown := null;
			self.pictureStringIcon := null;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_parent" type="CM_MenuEntity"/>
        <Parameter name="_source" type="SelfType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_targetMenuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_clearFirst" type="Boolean"/>
        <Parameter name="_deleteSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExpandedDefault" id="d63d726c-c8ca-4cd7-9d9f-999b0a9a36f5">
        <source>getExpandedDefault(): Boolean;
// ---------------------------------------------------------------------------
// Created:     05 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHeading" id="a017a3b3-b91a-40c6-a5cc-593ad229ed3f">
        <source>getHeading(): String;

vars

	term : CM_Terminal;

begin
//	return self.myUserTerminal.getMyTerminal.name;
	term := self.myUserTerminal.getMyTerminal;
	return term.name &amp; "  (" &amp; term.code &amp; ")";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="5f9ffe09-cd10-452a-8278-cc242b5b709d">
        <source>getMyTerminal(): CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     19 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myUserTerminal &lt;&gt; null then
		return app.myRoot.getTerminalForScenario(self.myUserTerminal.getMyTerminal);
		//return self.myUserTerminal.myTerminal;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="myUser" id="0dd67eb0-7862-4fdd-a498-e506c0b2e3d8">
        <methodInvocation>mapping</methodInvocation>
        <source>myUser(set: Boolean; _value: CM_User io) mapping;
// ---------------------------------------------------------------------------
// Created:     09 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.myUserTerminal &lt;&gt; null then
			_value := self.myUserTerminal.myUser;
		endif;
	endif;



end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_User" usage="io"/>
    </JadeMethod>
</Class>
