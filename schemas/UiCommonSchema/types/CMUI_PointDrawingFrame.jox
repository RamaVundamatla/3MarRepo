    <JadeMethod name="delete" id="fb8f63b1-2cec-4c87-8d13-64bc18ff7b80">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	delete self.myRectangleRotator;
	delete self.myGraphicMover;
	delete self.myRectangleResize;
	delete self.myRectangleStretcher;

	self.doClearAllPointGraphics();
	
	if CM_LayoutGraphic.hasInstance(self.theGraphic)	and global.isValidObject(self.theGraphic) then
		if self.theGraphic.isTransient then
			delete theGraphic;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="detectDragPoint" id="49305144-0d8b-48b7-8742-9964a64fd4dd">
        <updating/>
        <source>detectDragPoint(x,y : Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		This is used in drawing mode to drag a point of a shape, to allow a resizing/reshaping of the shape.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	scale: Real;
	idx, xLess, xGreater, yLess, yGreater, pointX, pointY  : Integer;
	thePoint : Point;
	theObject : Object;
	thePointArray : PointArray;
	noPoint : Boolean;
	invalidObject : Boolean;
begin

	if self.mode = self.Mode_LineDrawing 
	or (self.mode = self.Mode_MultiSelect and (self.modeView &lt;&gt; ShpDisplayMode_ColCodeLoad and self.modeView &lt;&gt; ShpDisplayMode_Actual)) then // allow changes to load colour coding and Actual GC
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject); // 31053 If this kicks off the next statement is a continue anyway so have not added any extra coding
	

	scale := self.scaleFactor;
	if scale = 0 then
		scale := 1;
	endif;
	noPoint := true;
	self.dragPoint1 := null;
	self.dragPoint2 := null;
	self.dragPoint3 := null;
	self.dragPoint1Index := null;
	self.dragPoint2Index := null;
	self.dragPoint3Index := null;

	foreach theObject in self.allPointGraphics do : outerLoop
	
			// PAR 28013
		if not theObject.CM_DeckItemLayout.isResizeable() then
			continue;
		endif;
		thePointArray := theObject.CM_LayoutGraphic.pointsPolygon;
		idx := 0;
		foreach thePoint in thePointArray do : innerLoop
			idx := idx + 1;
			pointX := (thePoint.x * scale).Integer;
			pointY := (thePoint.y * scale).Integer;

			xLess := pointX - 3;
			xGreater := pointX + 3;
			yLess := pointY - 3;
			yGreater := pointY + 3;
			
			if x.Integer &gt;= xLess and x.Integer &lt;= xGreater
			and y.Integer &gt;= yLess and y.Integer &lt;= yGreater then
				// in this mode we only work on the 3rd point of our rectangle polygon
				// this is because in this mode the drag on the left mouse on the 3rd point resizes the rectangle
				if self.mode = self.Mode_PolyMove then
					if idx &lt;&gt; 3 then
						return;
					endif;
				endif;
				// PAR 27749
				if self.modeView = ShpDisplayMode_ColCodeLoad then
					if not theObject.CM_LayoutGraphic.isGCDefnLayout() then
						continue;
					endif;
				endif;
				self.mousePointer := Window.MousePointer_NWSE	;
				noPoint := false;
				
				// this is the object that we are working on so put it in the reference
				self.theGraphic := theObject.CM_LayoutGraphic;
				if idx = 1 then					
					self.dragPoint1Index := thePointArray.size - 1;
				else
					self.dragPoint1Index := idx - 1;
				endif;
				self.dragPoint2Index := idx;
				
				if idx = thePointArray.size then
					self.dragPoint3Index := 2;
				else
					self.dragPoint3Index := idx + 1; // + 2;
				endif;

				self.dragPoint1 := thePointArray[self.dragPoint1Index];
				self.dragPoint2 := thePointArray[self.dragPoint2Index];
				self.dragPoint3 := thePointArray[self.dragPoint3Index];
				if self.mode &lt;&gt; self.Mode_PolyMove then // PAR 27605
					self.mode := self.Mode_LineAlter; // PAR 27595
					
					// PAR 28920 - set the point to blue (selected)
					if self.isForPlanning() then
						self.doDrawSelectedPoint(self.dragPoint2, Blue, -1);
					endif;
				endif;
				
				break outerLoop;
			else
				self.mousePointer := Window.MousePointer_Arrow;
			endif;
		endforeach;
	endforeach;

	if noPoint then
		if not self.detectOverLine(x,y) then
			self.setModeFromParent();
		endif;
	endif;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="detectFirstPoint" id="da30ab0c-ce53-4238-aad2-7dc026759989">
        <updating/>
        <source>detectFirstPoint(x,y : Real) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		This is used whilst drawing. To detect the finishing of a shape
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	scale: Real;

	xLess, xGreater, yLess, yGreater, pointX, pointY : Integer;
begin
	if self.theGraphic = null then
		return false;
	endif;
	if self.theGraphic.locked then
		self.mousePointer := Window.MousePointer_Arrow;
		return false;
	endif;
	if self.mode = self.Mode_LineAlter then
		self.mousePointer := Window.MousePointer_Arrow;
		return false;
	endif;

	scale := self.scaleFactor;
	if scale = 0 then
		scale := 1;
	endif;

	pointX := (self.firstPoint.x * scale).Integer;
	pointY := (self.firstPoint.y * scale).Integer;


	/*
	xLess := self.firstPoint.x - 3;
	xGreater := self.firstPoint.x + 3;
	yLess := self.firstPoint.y - 3;
	yGreater := self.firstPoint.y + 3;
	*/
	xLess := pointX - 3;
	xGreater := pointX + 3;
	yLess := pointY - 3;
	yGreater := pointY + 3;

	if x.Integer &gt;= xLess and x.Integer &lt;= xGreater
	and y.Integer &gt;= yLess and y.Integer &lt;= yGreater then
		self.mousePointer := Window.MousePointer_Cross;
		return true;
	else
		self.mousePointer := Window.MousePointer_Arrow;
	endif;

	return false;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="detectIfInPolygon" id="7ea75e54-dafc-43f0-8aef-adf04a6e828c">
        <updating/>
        <source>detectIfInPolygon(x,y : Integer; _objectIndex : Integer output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	scale : Real;
	pointX, pointY : Integer;
	theObject : Object;
	deckItem : CM_DeckItem;
	thePointArray : PointArray;
	invalidObject : Boolean;
begin
	scale := self.scaleFactor;
	if scale = 0 then
		scale := 1;
	endif;

	_objectIndex := self.allPointGraphics.size;
	
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject); // 31053
	
	// AKB2011DEC - changed this to be reversed because lane positions are drawn in the same 
	//						layer as lane definitions and the smaller lane positions could not be selected
	foreach theObject in self.allPointGraphics reversed  do : outerLoop
		invalidObject := false; // 31053
		thePointArray := theObject.CM_LayoutGraphic.pointsPolygon;
		
		if invalidObject then // 31053
			continue;
		endif;
		
		if thePointArray.isPointInPolygon(x,y, scale) then


			self.theGraphic := theObject.CM_LayoutGraphic;
			return true;
		endif;

		_objectIndex := _objectIndex - 1;
	endforeach;
	
	_objectIndex := 0;

	return false;
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="_objectIndex" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="detectOverLine" id="83f71611-4261-44c7-ab7f-03c7af37f9ee">
        <updating/>
        <source>detectOverLine(x,y : Real) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     January 2011 ANDREW BISHOP
//
// Current;y ONLY detects over a horizontal or vertical line
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	scale: Real;
	idx, xLess, xGreater, yLess, yGreater, pointX, 
	oldMode, pointY, lastX, lastY, minY, maxY  : Integer;
	thePoint : Point;
	theObject : Object;
	thePointArray : PointArray;
	overLine : Boolean;
	invalidObject : Boolean;
begin
	if self.mode = self.Mode_LineDrawing then
		return false;
	endif;

	on Exception do app.handleDeletedObject(exception, theObject, invalidObject); // 31053 If this kicks off the next statement is a continue anyway so have not added any extra coding

	overLine := false;
	scale := self.scaleFactor;
	if scale = 0 then
		scale := 1;
	endif;

	self.mousePointer := Window.MousePointer_Arrow;
	if self.mode = 0 then
		self.mode := self.Mode_LineAlter;
	endif;
	
	self.dragPoint1 := null;
	self.dragPoint2 := null;
	self.dragPoint3 := null;
	self.dragPoint1Index := null;
	self.dragPoint2Index := null;
	self.dragPoint3Index := null;
//process.debug;	
	foreach theObject in self.allPointGraphics do : outerLoop
		thePointArray := theObject.CM_LayoutGraphic.pointsPolygon;
		// PAR 28013
		if not theObject.CM_DeckItemLayout.isResizeable() then

			continue;
		endif;
		idx := 0;
		foreach thePoint in thePointArray do : innerLoop
			idx := idx + 1;
			pointX := (thePoint.x * scale).Integer;
			pointY := (thePoint.y * scale).Integer;
			
			// DETECT A STRAIGHT VERTICAL LINE
			if lastX = pointX then
				if (y &gt;= lastY and y  &lt;= pointY) or (y &gt;= pointY and y  &lt;= lastY) then
					xLess := pointX - 3;
					xGreater := pointX + 3;
					yLess := pointY - 3;
					yGreater := pointY + 3;
					
					if x.Integer &gt;= xLess and x.Integer &lt;= xGreater then
						if self.mode = self.Mode_PolyMove then
							if idx &lt;&gt; 3 then
								return false;
							endif;
						endif;

						self.mousePointer := Window.MousePointer_WE;
						self.mode := self.Mode_LinePullLR;
						overLine := true;
						// this is the object that we are working on so put it in the reference
						self.theGraphic := theObject.CM_LayoutGraphic;
						if idx = 1 then					
							self.dragPoint1Index := thePointArray.size - 1;
						else
							self.dragPoint1Index := idx - 1;
						endif;
						self.dragPoint2Index := idx;
						
						if idx = thePointArray.size then
							self.dragPoint3Index := 2;
						else
							self.dragPoint3Index := idx + 1; // + 2;
						endif;
						self.dragPoint1 := thePointArray[self.dragPoint1Index];
						self.dragPoint2 := thePointArray[self.dragPoint2Index];
						self.dragPoint3 := thePointArray[self.dragPoint3Index];
						
						break outerLoop;
					else
						self.mousePointer := Window.MousePointer_Arrow;
					endif;
				endif;
			// DETECT A STRAIGHT HORIZONTAL LINE
			elseif lastY = pointY then
				if (x &gt;= lastX and x  &lt;= pointX) or (x &gt;= pointX and x  &lt;= lastX) then
					xLess := pointX - 3;
					xGreater := pointX + 3;
					yLess := pointY - 3;
					yGreater := pointY + 3;
					
					if y.Integer &gt;= yLess and y.Integer &lt;= yGreater then
						if self.mode = self.Mode_PolyMove then
							if idx &lt;&gt; 3 then
								return false;
							endif;
						endif;
						// PAR 27749
						if self.modeView = ShpDisplayMode_ColCodeLoad then
							if not theObject.CM_DeckItemLayout.isResizableUD() then
								continue;
							endif;
//							if not theObject.CM_LayoutGraphic.isGCDefnLayout() then
//								continue;
//							endif;
						elseif self.modeView = ShpDisplayMode_Actual then
							if not theObject.CM_DeckItemLayout.isResizableUD() then
								continue;
							endif;
						endif;
						self.mousePointer := Window.MousePointer_NS;
						self.mode := self.Mode_LinePullUD;
						overLine := true;

						// this is the object that we are working on so put it in the reference
						self.theGraphic := theObject.CM_LayoutGraphic;
						if idx = 1 then					
							self.dragPoint1Index := thePointArray.size - 1;
						else
							self.dragPoint1Index := idx - 1;
						endif;
						self.dragPoint2Index := idx;
						
						if idx = thePointArray.size then
							self.dragPoint3Index := 2;
						else
							self.dragPoint3Index := idx + 1; // + 2;
						endif;
						self.dragPoint1 := thePointArray[self.dragPoint1Index];
						self.dragPoint2 := thePointArray[self.dragPoint2Index];
						self.dragPoint3 := thePointArray[self.dragPoint3Index];
						
						break outerLoop;
					else
						self.mousePointer := Window.MousePointer_Arrow;
					endif;
				endif;
			endif;
			lastX := pointX;
			lastY := pointY;
		endforeach;
	endforeach;
	
	return overLine;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAddToArraysForProxy" id="e67e7e64-89a1-4076-ac14-66d1b41ce27a">
        <source>doAddToArraysForProxy(_pxyDeckItemLayout : CM_DeckItemLayout);
// ---------------------------------------------------------------------------
// Created:     April 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	// PAR 27510 only add once
	if self.allPointGraphics.includes(_pxyDeckItemLayout) then
		return;
	endif;
	
	self.allPointGraphics.add(_pxyDeckItemLayout);
	self.allLineColours.add(_pxyDeckItemLayout.drawLineColour);
	self.allLineStyles.add(_pxyDeckItemLayout.drawLineStyle);
	self.allFloodFill.add(true);
	self.allFillStyles.add(_pxyDeckItemLayout.drawFillStyle);
	self.allFillColours.add(_pxyDeckItemLayout.drawFillColour);
	self.allDrawWidths.add(_pxyDeckItemLayout.drawWidth);
	self.allTexts.add(_pxyDeckItemLayout.code);
epilog
	
end;</source>
        <Parameter name="_pxyDeckItemLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="doBtnClearClick" id="9e8ef0ce-d8b3-4383-bb28-bdfd76d21fe1">
        <updating/>
        <source>doBtnClearClick(_clear : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.clearGraphics();
	self.doClearDragPoints(); // PAR 28921
	/* PAR 28921
	self.dragPoint1 := null;
	self.dragPoint2 := null;
	self.dragPoint3 := null;
	self.dragPoint1Index := null;
	self.dragPoint2Index := null;
	
	self.dragPoint3Index := null;
	self.lastPoint.set(-1,-1);
	self.firstPoint.set(-1,-1);
	self.drawLastPoint.set(-1,-1);
	*/
	// do not delete this as it will be a transient copy that is attached to the tableviews copy of the terminal and that gets upset
//	if self.theGraphic &lt;&gt; null then
//		delete self.theGraphic;
//	endif;



	self.theGraphic := null;
	if _clear then
		self.doBtnClearClickArrays();
		/*
		self.doClearAllPointGraphics();
		self.allLineColours.clear();
		self.allLineStyles.clear();
		self.allFloodFill.clear();
		self.allFillStyles.clear();
		self.allFillColours.clear();
		self.allDrawWidths.clear();
		self.allTexts.clear();
*/
	endif;
end;</source>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnClearClickArrays" id="95306fc1-986b-40da-bbf4-9ac4d22c2cef">
        <source>doBtnClearClickArrays();
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars

begin
		self.doClearAllPointGraphics();
		self.allLineColours.clear();
		self.allLineStyles.clear();
		self.allFloodFill.clear();
		self.allFillStyles.clear();
		self.allFillColours.clear();
		self.allDrawWidths.clear();
		self.allTexts.clear();


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRefreshClick" id="021b57d3-6299-4098-8236-afd2b0098b82">
        <updating/>
        <source>doBtnRefreshClick() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	on Exception do self.handleNonExistantMethod(exception);

	self.clearGraphics();
	self.drawAllPolygons(null);
	if self.mySDF.myParentForm &lt;&gt; null then
		self.mySDF.myParentForm.sendMsg(CMUI_YardOverView::doDrawSpecialAfter.name);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUndoClick" id="89bab56e-2a8e-4fcb-9181-119b5c4c68d5">
        <updating/>
        <source>doBtnUndoClick() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		Undo the last lot of changes and put the pointPolygon back to how it was. Only 1 Undo
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	// PAR 27510
	if self.theGraphic &lt;&gt; null then
		self.theGraphic.pointsPolygon.clear();
		self.thePoints.copy(self.theGraphic.pointsPolygon);
	endif;
	self.clearGraphics();
	self.drawAllPolygons(null);
	self.drawLastPoint.set(-1,-1);
	self.lastPoint.set(-1,-1);

end;</source>
    </JadeMethod>
    <JadeMethod name="doClearAllPointGraphics" id="a9368b41-14f1-474b-b46a-77ddbaf33777">
        <source>doClearAllPointGraphics();
// ---------------------------------------------------------------------------
// Created:     31 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
begin
	foreach anObject in self.allPointGraphics do
		// These roro graphic objects are proxies that are used in a TRX to save the graphics
		if anObject.isKindOf(CM_ROROGraphic) then
			continue;
		endif;
		if anObject.isKindOf(CM_DeckItemLayout) then
			continue;
		endif;

		delete anObject;
	endforeach;
	
	self.allPointGraphics.clear();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClearDragPoints" id="7b1865ad-9dfe-494a-b9a6-892c934f1586">
        <updating/>
        <source>doClearDragPoints() updating;
/*
Purpose:			
Date				Who			Reason
JANUARY 2012		CNWAB1		Initial creation
*/

vars

begin

	self.dragPoint1 := null;
	self.dragPoint2 := null;
	self.dragPoint3 := null;
	self.dragPoint1Index := null;
	self.dragPoint2Index := null;
	
	self.dragPoint3Index := null;
	self.lastPoint.set(-1,-1);
	self.firstPoint.set(-1,-1);
	self.drawLastPoint.set(-1,-1);
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawKnob" id="ed192df0-9fad-40bd-9542-158e29a6c66f">
        <updating/>
        <source>doDrawKnob(_point : Point; _colour : Integer) updating;
/*
Purpose:			
Date		Who		Reason
25 June 2012	cnwab1	Initial creation
*/
constants
	KnobWidth = 3;
vars
	x1, y1, pointMarkerColour : Integer;
begin

	if _point = null then
		return;
	endif;
	
	x1 := _point.x;
	y1 := _point.y;
	

	pointMarkerColour := _colour;
	self.drawFillStyle := Frame.DrawFillStyle_Solid;
	self.drawFillColor := pointMarkerColour;
	self.drawFilledRectangle(x1 - KnobWidth,y1 - KnobWidth,x1 + KnobWidth,y1 + KnobWidth,pointMarkerColour);
	self.drawFillColor := pointMarkerColour;

epilog

end;</source>
        <Parameter name="_point" type="Point"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayer" id="9cbc539e-39f9-4acb-a26d-a6d38f703459">
        <updating/>
        <source>doDrawLayer(_layer : CM_ShipDeckLayer; _graphicToIgnore : CM_ROROGraphic) updating;

// ### PROTOTYPE



// ---------------------------------------------------------------------------
// Created:     January 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theRORODefn : CM_ROROStructure;
	roroGraphic : CM_ROROGraphic;
	aGraphic : CM_Graphic;
	theFrame : CMUI_PointDrawingFrame;
	theColour : Integer;
	graphArray : CM_GraphicArray;
	theDeck : CM_ShipDeck;
	
begin
	theFrame := self; 
	
	foreach aGraphic in _layer.allGraphics do
		roroGraphic := aGraphic.CM_ROROGraphic;
		theColour := roroGraphic.drawLineColour;
		if _graphicToIgnore = roroGraphic then
			continue;
		endif;
		//theFrame.doPointArrayAdd(roroGraphic.pointsPolygon,theColour, (roroGraphic.drawFillStyle &lt;&gt; Frame.DrawFillStyle_Transparent), roroGraphic.drawFillStyle, roroGraphic.drawWidth, roroGraphic.drawFillColor, true);
		theFrame.doPointArrayAddFromProxy(roroGraphic);
	endforeach;
	theFrame.drawAllPolygons(White);
	
end;</source>
        <Parameter name="_layer" type="CM_ShipDeckLayer"/>
        <Parameter name="_graphicToIgnore" type="CM_ROROGraphic"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayerLayout" id="a4594417-7f2c-4dd5-80ba-e360070c363b">
        <updating/>
        <source>doDrawLayerLayout(_layer : CM_DeckLayerLayout; _graphicToIgnore : CM_DeckItemLayout; _sdfDrawingFrame : CMUI_PointDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:     April 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// CCMS 1031 MES RORO
// ---------------------------------------------------------------------------

vars

	theRORODefn : CM_ROROVesselStructure;
	deckItemLayout : CM_DeckItemLayout;
	aGraphic : CM_Graphic;
	theFrame : CMUI_PointDrawingFrame;
	graphArray : CM_GraphicArray;
	theDeck : CM_DeckLayout;
	
begin
	
	theFrame := self; 
	foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
		// ### do not show the lane position definitions created by the planning screen
		if deckItemLayout.myDeckItem &lt;&gt; null and deckItemLayout.myDeckItem.isLocnLanePosition() then
			continue;
		endif;
		
		if self.mySDF = null then // back frame
			// If it is on the SDF's drawing frame then do not draw it on the back frame
			if _sdfDrawingFrame &lt;&gt; null then
				if _sdfDrawingFrame.allPointGraphics.includes(deckItemLayout) then
					continue;
				endif;
			endif;
		endif;
		if not deckItemLayout.isVisible then
			continue;
		endif;
		
		theFrame.doAddToArraysForProxy(deckItemLayout);
	endforeach;
	theFrame.drawAllPolygons(White);
end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_graphicToIgnore" type="CM_DeckItemLayout"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawQuickPolyArray" id="61c07169-da6a-49ac-b98f-22fde39cd0e9">
        <updating/>
        <source>doDrawQuickPolyArray(_startX, _startY : Integer; _numRows, _numCol : Integer; _horiz : Boolean; _polytype : Integer; _deckLayer : CM_DeckLayerLayout) updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/
constants
	LocnWidth = 60;
	LaneWidth = 500;
	LocnHeight = 60; // PAR 27513 make the default square so that it is obvious that no defaults are set
	LocnGap = 2;
	PillarWidth = 20;
	PillarHeight = 10;
vars
	allStateData : CM_StateDataDict;
	lPoint	: Point;
	pointsPolygon : PointArray;
	numGraphic, x1, y1, l1, t1, w1, h1, locnRow, locnCol, idx, fillStyle, fillColour: Integer;
	locnWidth, locnHeight,locnGap : Decimal[12,2];
	tmpLocn : CM_DeckItemLayout;
	tmpLocnDefn, prevLocnDefn : CM_ROROLocnDefn;
	tmpLaneDefn : CM_ROROLaneDefn;
	lblStr : String;
	theMode, theType : Integer;
	aVes : CM_Vessel;
	deck : CM_Deck;
begin
	// PAR 27493
	aVes := _deckLayer.getVessel();
	if aVes &lt;&gt; null then
		allStateData:= aVes.allStateData;
	endif;
	
	deck:=_deckLayer.myDeckLayout.myDeck;
// PAR 27513	if allStateData = null then
	if allStateData.size= 0 then
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	
	// ### CLEAR ALL DRAWINGS
	self.purgeDeckItems(); // delete any previous proxies created during quick draw
	self.doBtnClearClick(true);

	fillStyle :=  Frame.DrawFillStyle_Transparent;
	fillColour := Black;
	
	// ### SET DEFAULTS FOR EACH QUICK DRAW TYPE
	if _polytype = DeckItemLayoutType_Locn then
		lblStr := "AUTOLOCN";
		if _horiz then
			global.getExtraData(allStateData,RoRoLocationWidth,locnHeight);
			global.getExtraData(allStateData,RoRoLocationLength,locnWidth);
			global.getExtraData(allStateData,RoRoLocationGap,locnGap);
		else
			global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
			global.getExtraData(allStateData,RoRoLocationLength,locnHeight);
			global.getExtraData(allStateData,RoRoLocationGap,locnGap);
		endif;
		locnWidth := locnWidth * 10;
		locnHeight := locnHeight * 10;
		locnGap := locnGap * 10;
	elseif _polytype = DeckItemLayoutType_Lane then
		lblStr := "AUTOLANE";
		if _horiz then
			global.getExtraData(allStateData,RoRoLaneWidth,locnHeight);
			global.getExtraData(allStateData,RoRoLaneLength,locnWidth);
			global.getExtraData(allStateData,RoRoLaneGap,locnGap);
		else
			global.getExtraData(allStateData,RoRoLaneWidth,locnWidth);
			global.getExtraData(allStateData,RoRoLaneLength,locnHeight);
			global.getExtraData(allStateData,RoRoLaneGap,locnGap);
		endif;
		locnWidth := locnWidth * 10;
		locnHeight := locnHeight * 10;
		locnGap := locnGap * 10;

	elseif _polytype = DeckItemLayoutType_Pillar then
		lblStr := "Pillar";
		fillStyle :=  Frame.DrawFillStyle_Solid;
		if _horiz then
			locnWidth := PillarWidth;
			locnHeight := PillarHeight;
		else
			locnWidth := PillarHeight;
			locnHeight := PillarWidth;
	
		endif;
	elseif _polytype = DeckItemLayoutType_Power then
		lblStr := "Power";
		fillStyle :=  Frame.DrawFillStyle_Solid;
		fillColour := Yellow;
		
		if _horiz then
			locnWidth := PillarWidth;
			locnHeight := PillarHeight;
		else
			locnWidth := PillarHeight;
			locnHeight := PillarWidth;
	
		endif;

	endif;
	
	// DEFAULTS
	if locnWidth &lt;= 0 then
		locnWidth := LocnWidth;
	endif;
	if locnHeight &lt;= 0 then
		locnHeight := LocnHeight;
	endif;
	if locnGap &lt;= 0 then
		locnGap := LocnGap;
	endif;
	
	// ### CREATE THE REQUIRED NUMBER OF POLYGONS. NOTE THESE ARE NOT ATTACHED TO THE LAYER, THEY ARE ORPHANS. Attahced seperately.
	create pointsPolygon transient;
	y1 := (_startY / self.scaleFactor).Integer;
	
	foreach locnRow in 1 to _numRows do
		x1 := (_startX / self.scaleFactor).Integer;
		prevLocnDefn := null;
		foreach locnCol in 1 to _numCol do
			create tmpLocn transient;
			
			l1 := x1; t1 := y1; w1 := (l1 + locnWidth).Integer; h1 := (t1 + locnHeight).Integer;
			
			// ### SET POLYGON
			if _polytype = DeckItemLayoutType_Power then
				lPoint.set(x1 + 7,y1 + 1);
				pointsPolygon.add(lPoint);
				lPoint.set(x1 + 13,y1 + 7);
				pointsPolygon.add(lPoint);
				lPoint.set(x1 + 7,y1 + 13);
				pointsPolygon.add(lPoint);
				lPoint.set(x1 + 1,y1 + 7);
				pointsPolygon.add(lPoint);
				lPoint.set(x1 + 7,y1 + 1);
				pointsPolygon.add(lPoint);
			else
				tmpLocn.setDefaultOutline4(l1,t1, w1, h1,pointsPolygon);
			endif;
			
			// ### SET PROXY (ORPHANED)
			tmpLocn.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,lblStr ,_deckLayer, fillColour,fillStyle, 1, true, _polytype);
			if _polytype = DeckItemLayoutType_Locn then
				if deck.isKindOf(CM_DeckVessel) then
					create tmpLocnDefn as CM_ROROLocnDefnVessel transient;
				elseif deck.isKindOf(CM_DeckVoyage) then
					create tmpLocnDefn as CM_ROROLocnDefnVoyage transient;
				endif;
				tmpLocnDefn.setProxyForCreateDefaults(tmpLocn, prevLocnDefn, ROROLocn_AftForward);
				
			elseif _polytype = DeckItemLayoutType_Lane then
				if deck.isKindOf(CM_DeckVessel) then
					create tmpLaneDefn as CM_ROROLaneDefnVessel transient;
				elseif deck.isKindOf(CM_DeckVoyage) then
					create tmpLaneDefn as CM_ROROLaneDefnVoyage transient;
				endif;
				tmpLaneDefn.setProxyForCreateDefaults(tmpLocn,(locnGap / 10));
			endif;
			
			self.doAddToArraysForProxy(tmpLocn);
			prevLocnDefn := tmpLocnDefn;
			x1 := x1 + (locnWidth + locnGap).Integer;
				
		endforeach;
		y1 := y1 + (locnHeight + locnGap).Integer;
	endforeach;
	
	// DRAW ALL THe ORPHANED POLYS
	theMode := self.mode;
	self.mode := Mode_DisplayOnly;
	self.drawAllPolygons(White);
	self.mode := theMode;



epilog
	delete pointsPolygon;
end;</source>
        <Parameter name="_startX" type="Integer"/>
        <Parameter name="_startY" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCol" type="Integer"/>
        <Parameter name="_horiz" type="Boolean"/>
        <Parameter name="_polytype" type="Integer"/>
        <Parameter name="_deckLayer" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="doDrawQuickPolyArrayNEW" id="c901357a-499f-4a08-96fe-0e95fc00ad7c">
        <updating/>
        <source>doDrawQuickPolyArrayNEW(_startX, _startY : Integer; _numRows, _numCol : Integer; _horiz : Boolean; _polytype : Integer; _deckLayer : CM_DeckLayerLayout input) updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/
constants
	LocnWidth = 60;
	LaneWidth = 500;
	LocnHeight = 60; // PAR 27513 make the default square so that it is obvious that no defaults are set
	LocnGap = 2;
	PillarWidth = 20;
	PillarHeight = 10;
vars
	allStateData : CM_StateDataDict;
	lPoint	: Point;
	pointsPolygon : PointArray;
	numGraphic, x1, y1, l1, t1, w1, h1, locnRow, locnCol, idx, fillStyle, fillColour: Integer;
	locnWidth, locnHeight,locnGap : Decimal[12,2];
	tmpLocn : CM_DeckItemLayout;
	tmpLocnDefn, prevLocnDefn : CM_ROROLocnDefn;
	tmpLaneDefn : CM_ROROLaneDefn;
	lblStr : String;
	theMode : Integer;
	aVes : CM_Vessel;
	deck : CM_Deck;
	newDeckItems : ObjectArray;
	obj : Object;
begin
	// ### CLEAR ALL DRAWINGS
	self.purgeDeckItems(); // delete any previous proxies created during quick draw
	self.doBtnClearClick(true);

	create newDeckItems transient;
	_deckLayer.createPxyQuickDrawPolyArray(_startX, _startY, _numRows, _numCol, _horiz, _polytype, self.scaleFactor, newDeckItems);

	
	foreach obj in newDeckItems do
		self.doAddToArraysForProxy(obj.CM_DeckItemLayout);
	endforeach;
	// DRAW ALL THe ORPHANED POLYS
	theMode := self.mode;
	self.mode := Mode_DisplayOnly;
	self.drawAllPolygons(White);
	self.mode := theMode;



epilog
	delete pointsPolygon;
	delete newDeckItems;
end;</source>
        <Parameter name="_startX" type="Integer"/>
        <Parameter name="_startY" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCol" type="Integer"/>
        <Parameter name="_horiz" type="Boolean"/>
        <Parameter name="_polytype" type="Integer"/>
        <Parameter name="_deckLayer" type="CM_DeckLayerLayout" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDrawSelectedPoint" id="8a07dc47-2166-4d34-a482-af51fdbea15a">
        <updating/>
        <source>doDrawSelectedPoint(_point : Point; _colour : Integer; _button: Integer) updating;
/*
Purpose:			
Date		Who		Reason
25 June 2012	cnwab1	Initial creation
*/

vars

begin
	if self.theGraphic &lt;&gt; null and self.theGraphic.pointsPolygon.includes(_point) then
	
	
		if _point = null then
			self.doDrawKnob(self.dragLastPoint, _colour);
		else
			self.doDrawKnob(_point, _colour);
		
		endif;
	
		self.setCurrentPoint(_point);
	elseif self.dragLastPoint &lt;&gt; null then
		
		if _button &lt;&gt; Frame.MouseButton_Left then
			self.doDrawKnob(self.dragLastPoint, Red);
		endif;
		self.dragLastPoint := null;
	endif;	
epilog

end;</source>
        <Parameter name="_point" type="Point"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_button" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFrameAdjustGraphic" id="b532361f-99f1-49e0-ae56-821be480ceda">
        <updating/>
        <source>doFrameAdjustGraphic(_xAdjust, _yAdjust : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     11 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpGraphic : CM_LayoutGraphic;
	obj : Object;
begin
	on Exception do self.handleInvalidMethodCall(exception);

	// PAR 28787
	if self.mode = self.Mode_MultiSelect then
		foreach obj in self.allPointGraphics discreteLock do
		
			tmpGraphic := obj.CM_LayoutGraphic;
			tmpGraphic.adjustXY(_xAdjust, _yAdjust); // Adjust XY
			tmpGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
		endforeach;
	else

		tmpGraphic := self.allPointGraphics.first.CM_LayoutGraphic;
		if tmpGraphic = null then
			return;
		endif;
		
		tmpGraphic.adjustXY(_xAdjust, _yAdjust); // Adjust XY
	endif;
	self.doBtnRefreshClick(); // Re draw graphic
	
	tmpGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null); // PAR 28787
	
	if self.mySDF &lt;&gt; null then
		if self.mySDF.myParentForm &lt;&gt; null then
			self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawSaveGraphic",self.theGraphic);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_xAdjust" type="Integer"/>
        <Parameter name="_yAdjust" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseContextMenu" id="d3978d02-f858-4548-b21c-c05615da7484">
        <updating/>
        <source>doFrameMouseContextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpPoints : PointArray;
begin

	on Exception do self.handleInvalidMethodCall(exception);
	if self.dragging then
		return true;
	endif;
	if self.mode &lt;&gt; self.Mode_DisplayOnly  then
		if self.mySDF &lt;&gt; null then
			if self.mySDF.myParentForm &lt;&gt; null then
				self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawContextMenuEvent",cntrl,conwin, mouse, x, y);
				return true;
			endif;
		endif;
	endif;
	return true;
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseDbClick" id="b792291f-fede-4e77-bd90-99bf70ce9474">
        <updating/>
        <source>doFrameMouseDbClick(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpPoints : PointArray;
begin
	on Exception do self.handleInvalidMethodCall(exception);

	if self.mode = self.Mode_DisplayOnly then
		if self.mySDF &lt;&gt; null then
			if self.mySDF.myParentForm &lt;&gt; null then
				self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDbClickEvent",frame, self.firstPoint.x, self.firstPoint.y);
			endif;
		endif;
		return;
	endif;
epilog 
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseDown" id="37818851-9d5d-4d14-bed3-96d286c1f624">
        <updating/>
        <source>doFrameMouseDown(frame: Frame input; button: Integer; shift : Integer;x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpPoints : PointArray;
begin
	
	if button = Window.MouseButton_Right then
		if not shift.isAltKeyPressed() then
			self.doFrameMouseDownRight(frame,button,shift,x,y);
		endif;
	elseif button = Window.MouseButton_Left then
		self.doFrameMouseDownLeft(frame,button,shift,x,y);
	else
		return;
	endif;
epilog 
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseDownLeft" id="12157624-a361-4635-999d-991601e4ad09">
        <updating/>
        <source>doFrameMouseDownLeft(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpPoints : PointArray;
	theObjectIndex : Integer;
	aOK, allowDrag : Boolean;
	localY, localX : Integer;
	saveGraphic	: CM_LayoutGraphic;
begin
	
	
	on Exception do self.handleInvalidMethodCall(exception);
	if self.isForPlanning() then
		if self.mySDF &lt;&gt; null then
			if self.mySDF.myParentForm &lt;&gt; null then
				aOK := self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDownEvent",frame, button,shift, x, y).Boolean;
			endif;
		endif;
	endif;
	

	
	if self.mode = self.Mode_DisplayOnly then
		// FOR RORO if mySDF &lt;&gt; null it is the main drawing frame with 1 graphic on it.
		if self.mySDF &lt;&gt; null then
			if self.mySDF.myParentForm &lt;&gt; null then
			
				aOK := self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDownEvent",frame, button,shift, x, y).Boolean;
				if not aOK then
					// ### This is to allow the user to click on a different polygon in the same layer in the graphic (not the table)
					// ### This call on the main form will switch to the back frame that has all the other polygons on and then it will call this method on that frame
					// ### That will result in the doFrameDrawDetectOtherGraphic call being made.
					self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDownOther",frame, button,shift, x, y);
				endif;
			endif;
		// FOR RORO if mySDF = null it is the drawing frame for the current group of graphics (called a layer) with all the other graphics on it except the 1 being drawn.
		// In this case we are detecting if a different graphic has been clicked on and if so switching that graphic to be the current graphic being drawn.
		else
			if self.detectIfInPolygon(x.Integer,y.Integer,theObjectIndex)  then
				self.form.sendMsgWithParams("doFrameDrawDetectOtherGraphic",self.allPointGraphics[theObjectIndex], false);		//cnwmc5 - 26 Nov 2013 - PAR 32697

			endif;
		endif;
		return;
	elseif self.mode = self.Mode_Work then // RORO PLANNING SCREEN - ALL THE BACK GROUND LAYER FRAMES

		if self.mySDF &lt;&gt; null then
			if self.mySDF.myParentForm &lt;&gt; null then
			
				aOK := self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDownEvent",frame, button,shift, x, y).Boolean;
				if not aOK then
					// ### This is to allow the user to click on a different polygon in the same layer in the graphic (not the table)
					// ### This call on the main form will switch to the back frame that has all the other polygons on and then it will call this method on that frame
					// ### That will result in the doFrameDrawDetectOtherGraphic call being made
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; " " &amp; self.mySDF.name &amp; ' 19. Y: ' &amp; y.String&amp; " L:" &amp; self.left.String &amp; " T:" &amp; self.top.String);

					self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDownOther",frame, button,shift, x, y);
				endif;
			endif;
		// FOR RORO if mySDF = null it is the drawing frame for the current group of graphics (called a layer) with all the other graphics on it except the 1 being drawn.
		// In this case we are detecting if a different graphic has been clicked on and if so switching that graphic to be the current graphic being drawn.
		else
			// cnwmc5 - 28 June 2016 - TFS 2214
			localY := y.Integer;		//(y +5).Integer; // the plus 5 is because the mouse pointer hot spot is not on the end of the pointer icon
			localX := x.Integer;		//(x +2).Integer;// 
//		app.writeStatement( class.name &amp; '::' &amp; method.name &amp;  " " &amp; self.name &amp; ' 1. X: ' &amp; x.String); // &amp; ' Y: ' &amp; y.String  &amp; " L:" &amp; self.left.String &amp; " T:" &amp; self.top.String &amp; " " &amp; self.theGraphic.CM_DeckItemLayout.code);
			
//			if self.detectIfInPolygon(x.Integer,y.Integer,theObjectIndex)  then
			if self.detectIfInPolygon(localX,localY,theObjectIndex)  then
				self.form.sendMsgWithParams("doFrameDrawDetectOtherGraphic",self.allPointGraphics[theObjectIndex], false);		//cnwmc5 - 26 Nov 2013 - PAR 32697
			else

			self.form.sendMsgWithParams("doFrameDrawMouseDownOther",frame, button,shift, x, y);
			endif;
		endif;
		return;
	elseif self.mode &lt;&gt; self.Mode_LineDrawing then
		// we are drawing and have detected one of the points of our current polygon
		if self.mousePointer = Window.MousePointer_NWSE  then
			self.detectDragPoint(x,y) ; // PAR 28921 Are we still over a point? If had context menud and then move mouse away we do not want to drag the point.
		
			if self.theGraphic &lt;&gt; null then // PAR 27510
				if self.mode = self.Mode_PolyMove then
					delete self.myRectangleResize;
					create self.myRectangleResize;
					self.myRectangleResize.setup(x,y,self.theGraphic.pointsPolygon);
				endif;
				if self.mode = 0 then
					self.mode := self.Mode_LineAlter; 
				endif;
				self.dragging := true;
				self.dragButton := button;
				self.dragMode := Window.DragMode_Drag	;
				// ################################
				// ##### RESIZE
				self.dragCursor := self.picCursorResize;
				
	
				self.dragButton := button;
			endif;
			return;
		// ## OVER VERTICAL STRAIGHT LINE, STRETCHING
		elseif self.mode = self.Mode_LinePullLR then
			delete self.myRectangleStretcher;
			if self.theGraphic &lt;&gt; null then // PAR 27510
				create self.myRectangleStretcher;
				self.myRectangleStretcher.setup(x,y,self.theGraphic.pointsPolygon);
			endif;
			return;
		// ## OVER HORIZONTAL STRAIGHT LINE, STRETCHING
		elseif self.mode = self.Mode_LinePullUD then
			delete self.myRectangleStretcher;
			if self.theGraphic &lt;&gt; null then // PAR 27510
				create self.myRectangleStretcher;
				self.myRectangleStretcher.setup(x,y,self.theGraphic.pointsPolygon);
			endif;
			return;
		//##########################
		//### MOVE
		elseif self.detectIfInPolygon(x.Integer,y.Integer,theObjectIndex) and self.mode &lt;&gt; self.Mode_LineDrawing then

			if self.mode = 0 then
				self.mode := self.Mode_LineAlter; 
			endif;
	
			if self.theGraphic = null then
				app.msgBox("Graphic Null " &amp; self.class.name &amp; "::" &amp; method.name, "ERROR",MsgBox_OK_Only);
				return;
			endif;
				
			if self.mySDF &lt;&gt; null then
				if self.mySDF.myParentForm &lt;&gt; null then
					saveGraphic := self.theGraphic;		// 29794
					self.form.sendMsgWithParams("doFrameDrawDetectOtherGraphic", self.theGraphic, false);		//cnwmc5 - 26 Nov 2013 - PAR 32697
					///self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDown",frame, button,shift, x, y);
					self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDownEvent",frame, button,shift, x, y);	// found in 29794 checking
					if self.theGraphic = null then
						self.theGraphic := saveGraphic;	// 29794, is cleared from RORO doFrameDrawDetectOtherGraphic
					endif;
				endif;
			endif;
			
			if not self.theGraphic.CM_DeckItemLayout.isMoveable() then
				return;
			endif;
			// PAR 27749
			allowDrag := true;
			if self.mySDF &lt;&gt; null then
				if self.mySDF.myParentForm &lt;&gt; null then
					self.firstPoint.set(x.Integer,y.Integer); // these are used in the double click
					 allowDrag := self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawAllowDrag",frame, button,shift, x, y).Boolean;
				endif;
			endif;
			
			if not allowDrag then
				return;
			endif;
			
			self.dragging := true;
			self.dragButton := button;
			self.dragMode := Window.DragMode_Drag	;
			self.dragCursor := self.picCursorMove;
			create self.myGraphicMover transient;
			self.myGraphicMover.setup(x,y,self.theGraphic.pointsPolygon);
			
			if self.mySDF &lt;&gt; null then
				if self.mySDF.myParentForm &lt;&gt; null then
					self.firstPoint.set(x.Integer,y.Integer); // these are used in the double click
					self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawSetCurrentGraphic",frame, button,shift, x, y);
				endif;
			endif;
			return;
		else
			if self.mySDF &lt;&gt; null then
				if self.mySDF.myParentForm &lt;&gt; null then
					// ### This is to allow the user to click on a different polygon in the same layer in the graphic (not the table)
					// ### This call on the main form will switch to the back frame that has all the other polygons on and then it will call this method on that frame
					// ### That will result in the doFrameDrawDetectOtherGraphic call being made.
					self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDownOther",frame, button,shift, x, y);
				endif;
			endif;
		endif;
	elseif self.mode = self.Mode_LineDrawing then
		
		//####
		//#### NEW POLYGON, STARTING WITH NOTHING AND DRAWING LINES UNTIL WE JOIN TO FIRST POINT
		//####
		
		if self.lastPoint.x = -1 and self.mousePointer = Window.MousePointer_Arrow or self.mousePointer = 0 then
			self.dragging := false;
			self.mousePointer := Window.MousePointer_Arrow;
			
			// for now only 1 shape at a time
			if self.allPointGraphics.size &gt;= 1 then
				return;
			endif;
			
			self.firstPoint.set(x.Integer,y.Integer);
			self.lastPoint.set(x.Integer,y.Integer);

			// this is the object that we are working on so put it in the reference
			create self.theGraphic transient;
			self.drawLine(x,y,x,y,self.theGraphic.drawLineColour);
			self.allPointGraphics.add(self.theGraphic);
			self.theGraphic.pointsPolygon.add(self.firstPoint);
		else
			// finish drawing, we are drawing and have detected the first point of our current polygon
			if self.mousePointer = Window.MousePointer_Cross then
				self.dragging := false;
				self.dragMode := Window.DragMode_None;
				self.drawLine(self.lastPoint.x,self.lastPoint.y,self.drawLastPoint.x,self.drawLastPoint.y,self.mySDF.backColor);
				self.drawLine(self.lastPoint.x,self.lastPoint.y,self.firstPoint.x,self.firstPoint.y,Black);
				self.theGraphic.locked := true;
				self.theGraphic.pointsPolygon.add(self.firstPoint);
				
				self.theGraphic := null;
				self.lastPoint.set(-1,-1);
				self.firstPoint.set(-1,-1);
				self.mode := self.Mode_LineAlter; 
			// we are drawing. Set this point into the array and start a new line from this point
			elseif self.mousePointer = Window.MousePointer_Arrow then
				self.dragging := false;
				self.dragMode := Window.DragMode_None;
				
				// #######################
				// ### this can be removed in V6 of Jade.
				if self.theGraphic.pointsPolygon.size &gt;= 62 then	
					app.msgBox("There is a maximum of 64 points in any one polygon." &amp; Cr &amp; "This last point must finish the polygon." &amp; Cr
									&amp; "Auto finishing polygon....", "Maximum Polygon Points Reached",MsgBox_OK_Only + MsgBox_Information_Icon);

					self.drawLine(self.lastPoint.x,self.lastPoint.y,self.drawLastPoint.x,self.drawLastPoint.y,self.mySDF.backColor);
					self.drawLine(self.lastPoint.x,self.lastPoint.y,self.firstPoint.x,self.firstPoint.y,Black);
					self.theGraphic.locked := true;
					self.theGraphic.pointsPolygon.add(self.firstPoint);
					
					self.theGraphic := null;
					self.lastPoint.set(-1,-1);
					self.firstPoint.set(-1,-1);
					self.mode := self.Mode_LineAlter; 
					return;
				endif;
				self.drawLine(self.lastPoint.x,self.lastPoint.y,x,y,self.theGraphic.drawLineColour);
				self.lastPoint.set(x.Integer,y.Integer);
				self.theGraphic.pointsPolygon.add(self.lastPoint);
				
			endif;
		endif;
	endif;
epilog 
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseDownLeftCtrl" id="27cc2010-98be-4c50-8b9c-ab28bcd0f85e">
        <updating/>
        <source>doFrameMouseDownLeftCtrl(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			
Date		Who		Reason
20 July 2011	cnwab1	Initial creation
*/

vars

begin
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; self.mode.String);


	if self.mode = self.Mode_Work or self.mode = Mode_MultiSelect then // RORO PLANNING SCREEN
		self.firstPoint.set(x.Integer,y.Integer); 
		self.modeViewSub := 89;
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseDownRight" id="ca451045-f925-4391-9fe3-9b4f996b550b">
        <updating/>
        <source>doFrameMouseDownRight(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpPoints : PointArray;
	theObjectIndex, localY, localX : Integer;
	aOK : Boolean;
begin
	on Exception do self.handleInvalidMethodCall(exception);

	if self.mode = self.Mode_Work then // RORO PLANNING SCREEN

		if self.mySDF &lt;&gt; null then
			if self.mySDF.myParentForm &lt;&gt; null then
			
				aOK := self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDownEvent",frame, button,shift, x, y).Boolean;
				if not aOK then
					// ### This is to allow the user to click on a different polygon in the same layer in the graphic (not the table)
					// ### This call on the main form will switch to the back frame that has all the other polygons on and then it will call this method on that frame
					// ### That will result in the doFrameDrawDetectOtherGraphic call being made
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; " " &amp; self.mySDF.name &amp; ' 19. Y: ' &amp; y.String&amp; " L:" &amp; self.left.String &amp; " T:" &amp; self.top.String);
					self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseDownOther",frame, button,shift, x, y);
				endif;
			endif;
		// FOR RORO if mySDF = null it is the drawing frame for the current group of graphics (called a layer) with all the other graphics on it except the 1 being drawn.
		// In this case we are detecting if a different graphic has been clicked on and if so switching that graphic to be the current graphic being drawn.
		else
			localY := (y +5).Integer; // the plus 5 is because the mouse pointer hot spot is not on the end of the pointer icon
			localX := (x  +2).Integer;
			
//			if self.detectIfInPolygon(x.Integer,y.Integer,theObjectIndex)  then
			if self.detectIfInPolygon(localX,localY,theObjectIndex)  then
//		app.writeStatement( class.name &amp; '::' &amp; method.name &amp;  " " &amp; self.name &amp; ' 1. X: ' &amp; x.String &amp; ' Y: ' &amp; y.String  &amp; " L:" &amp; self.left.String &amp; " T:" &amp; self.top.String &amp; " " &amp; self.theGraphic.CM_DeckItemLayout.code);
				self.form.sendMsgWithParams("doFrameDrawDetectOtherGraphic",self.allPointGraphics[theObjectIndex], false);		//cnwmc5 - 26 Nov 2013 - PAR 32697
			endif;
		endif;
		return;	// ################################
	// ##### ROTATE
	elseif  self.mode = self.Mode_PolyMove then
		if self.detectIfInPolygon(x.Integer,y.Integer,theObjectIndex) then
			self.theGraphic := self.allPointGraphics[theObjectIndex].CM_LayoutGraphic;
		else
			return;
		endif;				
		if self.theGraphic = null then
			app.msgBox("Graphic Null " &amp; self.class.name &amp; "::" &amp; method.name, "ERROR",MsgBox_OK_Only);
			return;
		endif;
		delete self.myRectangleRotator;
		create self.myRectangleRotator transient;
		self.myRectangleRotator.setup(x,y,self.theGraphic.pointsPolygon);
		self.dragCursor := self.picCursorRotate;
		self.dragging := true;
		self.dragButton := Window.MouseButton_Right;
		self.dragMode := Window.DragMode_Drag	;
	endif;
	return;
epilog 
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseDragDrop" id="d3484e5d-9574-4a61-9356-94014aea3562">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doFrameMouseDragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
/*
Purpose:			
Date		Who		Reason
16 September 2011	cnwab1	Initial creation
*/

vars

begin
	on Exception do self.handleInvalidMethodCall(exception);

	if self.mySDF &lt;&gt; null then
		if self.mySDF.myParentForm &lt;&gt; null then
	
			self.mySDF.myParentForm.sendMsgWithParams("doFrameDragDropEvent",frame, win, x, y);
		endif;
	endif;	
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseDragOver" id="4d36025c-4a0f-4c6d-847c-ffee1820a499">
        <updating/>
        <source>doFrameMouseDragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aPoint,thePoint, fromPoint, toPoint : Point;
	idx, index1, index2 : Integer;
	theObject : Object;
	thePointArray2 : PointArray;
	scale, tmpX, tmpY,degree : Real;
	deckItemLayout : CM_DeckItemLayout;
begin
	on Exception do self.handleInvalidMethodCall(exception);

	if self.mode = self.Mode_DisplayOnly then
		return;
	endif;
	
	self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseMoveDisplay",frame, null,0, x, y); // PAR 28006

	scale := self.scaleFactor;
	if scale = 0 then
		scale := 1;
	endif;
	
	self.dataChanged := true;
	if self.dragButton = Window.MouseButton_Right then
		// ###########################
		// ## ROTATE
		if self.dragCursor = self.picCursorRotate then
			self.myRectangleRotator.doRotate(x,y);
			self.clearGraphics();
			if self.theGraphic &lt;&gt; null then // PAR 27510
				self.theGraphic.setPointsPolygon(self.myRectangleRotator.newPoints);
				self.drawAPolygon(self.theGraphic.pointsPolygon,false,self.theGraphic.drawLineColour, 1, self.theGraphic.drawLineColour, scale, null);
			endif;
		endif;
	elseif self.mode = self.Mode_LinePullLR then
		return;
	elseif self.mode = self.Mode_LinePullUD then
		return;
	elseif self.dragButton = Window.MouseButton_Left then
		if self.mySDF.myParentForm &lt;&gt; null then
			self.mySDF.myParentForm.sendMsgWithParams("doPointDrawingXY",x,y);
		endif;
		// ###########################
		// ## RESIZE
		if self.dragCursor = self.picCursorResize then
			if self.mode = self.Mode_PolyMove then
				// this version basically resizes a rectangle from the centre point
				self.myRectangleResize.doResize(x,y);
				// having done the resize re populate the drag points so that it draws correctly
				self.clearGraphics();
				if self.theGraphic &lt;&gt; null then // PAR 27510
					self.drawAPolygon(self.myRectangleResize.newPoints,false,self.theGraphic.drawLineColour, 1, self.theGraphic.drawLineColour, scale, null);
				endif;
			else
				// this version takes the 2nd of 3 points and allows the user pull the 'triangle' to any position
				if self.theGraphic &lt;&gt; null then
					self.clearGraphics();
					self.drawAllPolygons(self.theGraphic.drawLineColour);
					self.drawLine((self.dragPoint1.x * scale),(self.dragPoint1.y * scale),x,y,self.theGraphic.drawLineColour);// PAR 27595 add scale
					self.drawLine(x,y,(self.dragPoint3.x * scale),(self.dragPoint3.y * scale),self.theGraphic.drawLineColour);// PAR 27595 add scale
//					self.dragLastPoint.set(x.Integer,y.Integer);
				else
					self.dragging := false;
					self.dragCursor := null;
					self.dragMode := Frame.DragMode_None;
				endif;
			endif;
		// ###########################
		// ## MOVE
		elseif self.dragCursor = self.picCursorMove then
			if self.theGraphic &lt;&gt; null then // PAR 27515
				if not self.theGraphic.CM_DeckItemLayout.isMoveable() then
					return;
				endif;

				self.myGraphicMover.calculateOutline(x,y);
				self.clearGraphics();
				self.drawAPolygon(self.myGraphicMover.newPoints,false,self.theGraphic.drawLineColour, 1, theGraphic.drawLineColour, scale, null);
				if self.mySDF.myParentForm &lt;&gt; null then
					self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseMoveMove",frame, x, y);
				endif;
			endif;
		endif;
	endif;
epilog 
	self.drawMode := Window.DrawMode_Copy;
	delete thePointArray2;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseMove" id="565cb730-f505-4fcb-89cd-34e78184bb43">
        <updating/>
        <source>doFrameMouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theColour : Integer;
	scale: Real;
begin
	on Exception do self.handleInvalidMethodCall(exception);
	
	if self.mode = self.Mode_DisplayOnly then
		return;
	endif;	

	scale := self.scaleFactor;
	if scale = 0 then
		scale := 1;
	endif;
	
	if self.mySDF &lt;&gt; null then
		if self.mySDF.myParentForm &lt;&gt; null then
			self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseMoveDisplay",frame, button,shift, x, y);
		endif;
	endif;
	
	// PAR 28920 - Set the point to red (unselected)
	if self.isForPlanning() then
		self.doDrawSelectedPoint(null, Red, button);
	endif;

	if self.mode = self.Mode_LinePullLR then
		// myRectangleStretcher created on mouse down
		if self.myRectangleStretcher &lt;&gt; null and self.dragPoint1Index &gt; 0 then
			self.myRectangleStretcher.setupStretch(self.dragPoint1Index, self.dragPoint2Index, true, false);
			// this version basically resizes a rectangle from the centre point
			self.myRectangleStretcher.doStretch((x / scale).Integer,(y / scale).Integer);// PAR 27595 add scale
			// having done the resize re populate the drag points so that it draws correctly
			self.clearGraphics();
			if self.theGraphic &lt;&gt; null then // PAR 27510
				self.drawAPolygon(self.myRectangleStretcher.newPoints,false,self.theGraphic.drawLineColour, 1, self.theGraphic.drawLineColour, scale, null);
			endif;
		else
		// if myRectangleStretcher = null are we still over a line?
			// PAR 27515 self.detectOverLine(x,y); // this turns the line pull modes on and off
			self.detectDragPoint(x,y); // this turns the line pull modes on and off
			
		endif;
		return;
	elseif self.mode = self.Mode_LinePullUD then
		// myRectangleStretcher created on mouse down
		if self.myRectangleStretcher &lt;&gt; null and self.dragPoint1Index &gt; 0 then
			self.myRectangleStretcher.setupStretch(self.dragPoint1Index, self.dragPoint2Index, false, true);
			// this version basically resizes a rectangle from the centre point
			self.myRectangleStretcher.doStretch((x / scale).Integer,(y / scale).Integer);// PAR 27595 add scale
			// having done the resize re populate the drag points so that it draws correctly
			self.clearGraphics();
			if self.theGraphic &lt;&gt; null then // PAR 27510
				self.drawAPolygon(self.myRectangleStretcher.newPoints,false,self.theGraphic.drawLineColour, 1, self.theGraphic.drawLineColour, scale, null);
			endif;
		// if myRectangleStretcher = null are we still over a line?
		else
		// AKB AUG 2011 noticed that detectOverLine had been commented out above	self.detectOverLine(x,y);
			self.detectDragPoint(x,y); // this turns the line pull modes on and off
		endif;
		return;
	else 
		
		if not self.detectFirstPoint(x,y) then
			self.detectDragPoint(x,y);
		else
		
			return;
		endif;
	

		if self.mode = self.Mode_PolyMove then
			return;
		endif;
		if self.theGraphic = null then
			theColour := Black;
		else
			theColour := self.theGraphic.drawLineColour;
		endif;
		if self.lastPoint.x = -1 then
			if not self.isForPlanning() then
				self.drawLine(x,y,x,y,theColour);
			endif;
		else
			self.drawLine(self.lastPoint.x,self.lastPoint.y,self.drawLastPoint.x,self.drawLastPoint.y,self.mySDF.backColor);
			self.drawAllPolygons(theColour); // these were the linecolur
			self.drawLine(self.lastPoint.x,self.lastPoint.y,x,y,theColour);
			if self.mySDF.myParentForm &lt;&gt; null then
				self.mySDF.myParentForm.sendMsgWithParams("doPointDrawingXY",x,y);
			endif;
			self.drawLastPoint.set(x.Integer,y.Integer);
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseMoveLeftCtrl" id="7657e052-928b-4593-aaf4-f40430326980">
        <updating/>
        <source>doFrameMouseMoveLeftCtrl(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			
Date		Who		Reason
20 July 2011	cnwab1	Initial creation
*/
constants
	DragDist=3;
vars

begin


	if self.modeViewSub = 89 then
	/*
		if (x &gt; self.firstPoint.x + DragDist)
		or (x &lt; self.firstPoint.x - DragDist)
		or (y &lt; self.firstPoint.y + DragDist)
		or (y &gt; self.firstPoint.y - DragDist) then
			self.dragMode := Frame.DragMode_Drag;
		endif;
		*/
		
		self.clearGraphics();
		self.drawStyle := Frame.DrawStyle_Dot;
		self.drawRectangle(self.firstPoint.x, self.firstPoint.y, x, y, Black);
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseUp" id="a440e770-ca88-4415-8a7b-e69e83d97c7d">
        <updating/>
        <source>doFrameMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePoint : Point;
	abort : Boolean;
	newPoints : PointArray;
begin

	on Exception do self.handleInvalidMethodCall(exception);
	create newPoints transient;
	if self.mode = self.Mode_DisplayOnly then
		if self.mySDF &lt;&gt; null then
			if self.mySDF.myParentForm &lt;&gt; null then
				self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseUpEvent",frame, button,shift, x, y);
			endif;
		endif;
		return;
	elseif self.mode = self.Mode_LinePullLR then
		if self.myRectangleStretcher &lt;&gt; null then
			if self.theGraphic &lt;&gt; null then // PAR 27510
			
				self.theGraphic.setProxyPreUpdate(self.myRectangleStretcher.newPoints);

				if self.theGraphic.isTransient() then
					self.theGraphic.setPointsPolygon(self.myRectangleStretcher.newPoints); // CCMS 1031
					self.theGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
				else
					app.myTrxUA.trxUpdateROROGraphicPolygon(self.theGraphic.CM_DeckItemLayout, self.myRectangleStretcher.newPoints, app.myPassport);
				endif;
			endif;
			self.mode := Mode_LineAlter;
			delete self.myRectangleStretcher;
		endif;
		self.mousePointer := Window.MousePointer_Default;
	elseif self.mode = self.Mode_LinePullUD then
		if self.myRectangleStretcher &lt;&gt; null then
			if self.theGraphic &lt;&gt; null then // PAR 27510
				if self.theGraphic.isTransient() then
					self.theGraphic.setPointsPolygon(self.myRectangleStretcher.newPoints); // CCMS 1031
					self.theGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
				else
					app.myTrxUA.trxUpdateROROGraphicPolygon(self.theGraphic.CM_DeckItemLayout, self.myRectangleStretcher.newPoints, app.myPassport);
				endif;

			endif;
			self.mode := Mode_LineAlter;
			delete self.myRectangleStretcher;
		endif;
		self.mousePointer := Window.MousePointer_Default;
	else
		if not self.dragging then
			// PAR 29608
			if self.mySDF &lt;&gt; null then
				if self.mySDF.myParentForm &lt;&gt; null then
					self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseUpEvent",frame, button,shift, x, y);
				endif;
			endif;
			return;
		endif;
		self.dragging := false;
		// ##############
		// Make an UNDO copy
		self.thePoints.clear;
		if self.theGraphic &lt;&gt; null then
			self.theGraphic.pointsPolygon.copy(self.thePoints);
		endif;
	
		// #############################
		// ### ROTATING
		if button = Window.MouseButton_Right then
			if self.myRectangleRotator &lt;&gt; null then
				if self.theGraphic &lt;&gt; null then // PAR 27510
					if self.theGraphic.isTransient() then
						self.theGraphic.setPointsPolygon(self.myRectangleRotator.newPoints); // CCMS 1031
						self.theGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
					else
						app.myTrxUA.trxUpdateROROGraphicPolygon(self.theGraphic.CM_DeckItemLayout, self.myRectangleRotator.newPoints, app.myPassport);
					endif;
				endif;
				delete self.myRectangleRotator;
			endif;
		elseif button = Window.MouseButton_Left then
			if self.mode = self.Mode_LinePullLR then
				if self.theGraphic &lt;&gt; null then // PAR 27510
					if self.theGraphic.isTransient() then
						self.theGraphic.setPointsPolygon(self.myRectangleStretcher.newPoints); // CCMS 1031
						self.theGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
					else
						app.myTrxUA.trxUpdateROROGraphicPolygon(self.theGraphic.CM_DeckItemLayout, self.myRectangleStretcher.newPoints, app.myPassport);
					endif;

				endif;
				self.mode := Mode_LineAlter;
				self.mousePointer := Window.MousePointer_Default;
			elseif self.mode = self.Mode_LinePullUD then
				if self.theGraphic &lt;&gt; null then // PAR 27510
					if self.theGraphic.isTransient() then
						self.theGraphic.setPointsPolygon(self.myRectangleStretcher.newPoints); // CCMS 1031
						self.theGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
					else
						app.myTrxUA.trxUpdateROROGraphicPolygon(self.theGraphic.CM_DeckItemLayout, self.myRectangleStretcher.newPoints, app.myPassport);
					endif;

				endif;
				self.mode := Mode_LineAlter;
				self.mousePointer := Window.MousePointer_Default;
			// #############################
			// ### MOVING
			elseif self.dragCursor = self.picCursorMove then
				if not self.myGraphicMover.doDragDetected(x,y) then
					abort := true;
				elseif self.theGraphic &lt;&gt; null then // PAR 27515
					if self.theGraphic.isTransient() then
						self.theGraphic.setPointsPolygon(self.myGraphicMover.newPoints); // CCMS 1031
						self.theGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
					else
						app.myTrxUA.trxUpdateROROGraphicPolygon(self.theGraphic.CM_DeckItemLayout, self.myGraphicMover.newPoints, app.myPassport);
					endif;

					delete self.myGraphicMover;
				endif;
			// #############################
			// ### RESIZING
			elseif self.dragCursor = self.picCursorResize then
				if self.theGraphic = null then
					return;
				endif;
				if self.theGraphic.pointsPolygon.isEmpty then
					return;
				endif;
				// ### RESIZE
				if self.mode = self.Mode_PolyMove then
					if self.theGraphic.isTransient() then
						self.theGraphic.setPointsPolygon(self.myRectangleResize.newPoints); // CCMS 1031
						self.theGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
					else
						app.myTrxUA.trxUpdateROROGraphicPolygon(self.theGraphic.CM_DeckItemLayout, self.myRectangleResize.newPoints, app.myPassport);
					endif;
				// ### SINGLE POINT
				else
					// cnwjre1 from RORO testing Dec 2011, self.dragPoint2Index can be zero
					if self.dragPoint2Index &lt;&gt; 0 then
						thePoint.set((x / self.scaleFactor).Integer, (y / self.scaleFactor).Integer);// PAR 27595 add scale
						newPoints.clear;
						self.theGraphic.pointsPolygon.copy(newPoints);
						newPoints.atPut(self.dragPoint2Index, thePoint);
						// the last point and the first point are the same
						if self.dragPoint2Index = 1 then
							newPoints.atPut(self.theGraphic.pointsPolygon.size, thePoint);
						endif;
						if self.theGraphic.isTransient() then
							self.theGraphic.setPointsPolygon(newPoints); // CCMS 1031
							self.theGraphic.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
						else
							app.myTrxUA.trxUpdateROROGraphicPolygon(self.theGraphic.CM_DeckItemLayout, newPoints, app.myPassport);
						endif;
					endif;
				endif;
				self.setCurrentPoint(null); // PAR 28920
			endif;
		endif;
		self.dragCursor := null;
		if self.mySDF &lt;&gt; null then
			if self.mySDF.myParentForm &lt;&gt; null then

				self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawSaveGraphic",self.theGraphic);
			endif;
		endif;
		if not abort and not app.isDragging then
			self.doBtnRefreshClick();
		endif;
		app.isDragging := false;
	endif;
epilog
	delete newPoints;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseUpLeftCtrl" id="b1bc615d-fd4f-4c11-ae70-ad9ca303e000">
        <updating/>
        <source>doFrameMouseUpLeftCtrl(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			
Date		Who		Reason
20 July 2011	cnwab1	Initial creation
*/

vars

begin
	on Exception do self.handleInvalidMethodCall(exception);

	if self.isForPlanning then
		if self.modeViewSub = 89 then
			self.clearGraphics();
			self.lastPoint.set(x.Integer,y.Integer);
			if self.mySDF &lt;&gt; null then
				if self.mySDF.myParentForm &lt;&gt; null then
	
					self.mySDF.myParentForm.sendMsgWithParams("doFrameDrawMouseUpLftCtrlEvent",self, self.firstPoint, self.lastPoint);
				endif;
			endif;
			
			self.lastPoint.set(-1,-1);
			self.firstPoint.set(-1,-1);
			return;
		
		endif;
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doInsertNewPoint" id="0d26a70f-2b4c-4bb3-830e-53280a12fc81">
        <source>doInsertNewPoint(_thePoint : Point; _insertBefore : Boolean; _theGraphic : CM_LayoutGraphic input); // _thePointArray : PointArray) updating; // PAR 27773
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	thePointArray : PointArray;
	thePoint, theAdjoiningPoint, theNewPoint : Point;
	thePointIndex, theAdjoiningPointIndex : Integer;
	x1,x2,y1,y2,x3,y3 : Integer;
begin
/* PAR 27773 pass the point array in
	if self.theGraphic = null then
		app.msgBox("Please select a graphic","Select Point",MsgBox_OK_Only);
		return;
	endif;
	if self.theGraphic.pointsPolygon.isEmpty then
		app.msgBox("Please draw some points","Select Point",MsgBox_OK_Only);
		return;
	endif;
	*/
	

	thePointArray := _theGraphic.pointsPolygon;
	if thePointArray.isEmpty() then
		app.msgBox("Please draw some points","Select Point",MsgBox_OK_Only);
		return;
	endif;
	if _thePoint = null then
		app.msgBox("Please select a point","Select Point RORO",MsgBox_OK_Only);
		return;
	endif;
	
	_theGraphic.doInsertNewPoint(_thePoint,_insertBefore);
	/* PAR 27749
	thePointIndex := thePointArray.indexOf(_thePoint);
	
	if thePointIndex = 1 then
		theAdjoiningPointIndex := thePointArray.size;
	else
		if _insertBefore then
			theAdjoiningPointIndex := thePointIndex - 1;
		else
			theAdjoiningPointIndex := thePointIndex + 1;
		endif;
	endif;
	
	theAdjoiningPoint := thePointArray[theAdjoiningPointIndex];
	thePoint := thePointArray[thePointIndex];


	if _insertBefore then
		x1 := theAdjoiningPoint.x;
		y1 := theAdjoiningPoint.y;
		x2 := thePoint.x;
		y2 := thePoint.y;
		
		x3 := (((x2 - x1) / 2) + x1).Integer;
		y3 := (((y2 - y1) / 2) + y1).Integer;
		theNewPoint.set(x3,y3);
		thePointArray.insert(thePointIndex,theNewPoint);
	else
		x1 := thePoint.x;
		y1 := thePoint.y;
		x2 := theAdjoiningPoint.x;
		y2 := theAdjoiningPoint.y;
		
		x3 := (((x2 - x1) / 2) + x1).Integer;
		y3 := (((y2 - y1) / 2) + y1).Integer;
		theNewPoint.set(x3,y3);
		thePointArray.insert(theAdjoiningPointIndex,theNewPoint);
	endif;
	*/
end;</source>
        <Parameter name="_thePoint" type="Point"/>
        <Parameter name="_insertBefore" type="Boolean"/>
        <Parameter name="_theGraphic" type="CM_LayoutGraphic" usage="input"/>
    </JadeMethod>
