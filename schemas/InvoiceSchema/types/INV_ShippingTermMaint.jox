/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	pxy : CM_InvoiceContractShipTerm;
begin
	if not self.mode then
		self.createShippingTerm();
	else
		self.updateShipTerm();
	endif;
	if self.myShipTerm &lt;&gt; null  then
		self.btnAdd.enabled := true;
		self.btnRemove.enabled := true;
		self.btnUpdate.enabled := true;
		self.btnAudits.enabled := true;
	endif;
	
	//self.unloadForm();
epilog

end;</source>
