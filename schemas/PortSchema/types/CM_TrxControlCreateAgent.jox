    <JadeMethod name="trxCreateChildTrackedItem" id="c3ef450c-73d0-4b9a-a525-5fde0b9968a4">
        <updating/>
        <source>trxCreateChildTrackedItem(	_ti : CM_TrackedItem input;	
							_pxyChildTI : CM_TrackedItem input;
							_realChildTI : CM_TrackedItem output;
							_passport : CM_Passport input
							) updating;
/*
Date			Who		Reason
07 July 2011	cnwndl1	Initial creation	Par 26476
11 Dec 2012		cnwcs5	par 39855 / CCMS SFW 1294 - change order of collection lock to be subid order
*/

vars
	terminal 		: CM_Terminal;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	//th2 2/05/2007 JBL work - prevent deadlock. i.e. Make it this process that is the only one who gets to
	//upgrade to exclusive lock on the following collections (as we're about to implicitly read lock these in the 
	//validate further on)
	terminal := _pxyChildTI.myTerminal;
	
	self.exclusiveLock(_ti);

	self.exclusiveLock(terminal.allTITransactions);
	self.exclusiveLock(terminal.allTITransactionsByTypeDate);
	self.exclusiveLock(terminal.allTITransactionsByCamsTS);		// cnwdad1 23/08/2010 - CCMS 1093 (PAR #24065).
	
	self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeId);
	self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeIdRev);
	self.exclusiveLock(terminal.allOnsiteTIsByIdCargoType);
	self.exclusiveLock(terminal.allOnsiteTIsByIdCargoTypeRev);
									   
	// Start the transaction
	beginTransaction;

	app.myUtilityCA.utlCreateTrackedItem(_pxyChildTI, _realChildTI, _passport);
	
	if not _passport.noErrors then
		return;
	endif;
	
	_ti.attachChild( _realChildTI, _passport );
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_pxyChildTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realChildTI" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
