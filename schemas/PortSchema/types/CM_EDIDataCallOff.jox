    <JadeMethod name="loadDB" id="b9851a17-36b9-456a-8fe3-995250955f23">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/07/2023	navdap1		Initial creation TFS 58923 EUP Call Off EDI Data Load
// 09/10/2023	navdap1		TFS 58495 EUP | CallOff Processing - DB Load and Work Orders
// 18/10/2023	navdap1		Initial creation TFS 58926 EUP | Calloff Update - Replace/ Create Logic and DB Load
//27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//16 Jan 2024	jlirs1	TFS 59172 User Defined CallOff
//
vars
	existingEDIFile : CM_EDIFile;
	ediData : CM_EDIDataRequestMultiLine;
	callOffData : CM_EDIData;
	newStatus : Integer;
	ediErrors : CM_EDIErrorSet;
	errStr : String;				// TFS 58495
	
begin
	
	app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADING); //11.Mar.2024 navsp1 TFS 60793
	
	ediData := self.myRequestMultiLine;
	
	// TFS 58495 For SHIP CallOff, if a voyage hasn't been able to be found for this data yet, prevent DB Load
	if ediData = null or ediData.getVoyageCode() = null then
		if self.transportationMode.toUpper = BR_TYPE_SHIP_STR.toUpper then
			errStr := app.getErrorString(CallOff_No_Voyage_Not_DBLoad);
			newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
			app.myPassport.addErrorFull(CallOff_No_Voyage_Not_DBLoad, errStr, null, null, null);
			callOffData := self;
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(callOffData, newStatus);
			return;
		endif;
	endif;
	// TFS 58495 end
	
	if ediData &lt;&gt; null then
		ediData.loadDB(_mergeCargo, _passport);
		newStatus := ediData.status;
		ediErrors := ediData.allErrorWarnings;
	endif;
	
	if _passport.hasErrors then
		newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;		//16 Jan 2024	jlirs1	TFS 59172 User Defined CallOff
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, newStatus);
	endif;	

	if newStatus &lt;&gt; self.status then
		callOffData := self;
		app.myTrxUA.trxUpdateEDIDataErrorsStatus(callOffData, ediErrors, newStatus, app.myPassport);
	endif;
	
	// if there's an existing message that hasn't been DB Loaded, update its status to cancelled
	if self.manifestNumber &lt;&gt; null then		//27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		self.myEDIFile.myEDIFileType.findExistingEDIFile(self.manifestNumber, self.myEDIFile, existingEDIFile);
	endif;
	if not _passport.hasErrors and existingEDIFile &lt;&gt; null and not existingEDIFile.ediData.status.isOneOf(CM_EDIFile.EDI_STATUS_DBLOADED, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL) then
		//Update the existing EDI file
		app.myTrxUA.trxSetEDIDataStatus(existingEDIFile.ediData, CM_EDIFile.EDI_STATUS_CANCELLED);		
		app.writeLog(method.qualifiedName &amp; Tab &amp;"EDI file (" &amp; existingEDIFile.getOidString &amp; ") status has been updated to cancel", LogINFO);
	endif;

epilog
	// TFS 58926 update work order / release request status if necessary
	if _passport.hasErrorsOrWarnings then
		app.myTrxUA.trxUpdateWORelReqToPending(self.manifestNumber, _passport);
	endif;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3d9b3c2e-f09a-47f1-b0e6-fa664a0e1df8">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2023	navra1	Initial creation for TFS 59666 - EUP - CallOff fields not available in the column organiser

*/

vars
	pxy 		: CM_EDIDataCallOff;
	complete 	: Boolean;
	ediTi 		: CM_EDITrackedItem;
	reqHdrTi 	: CM_EDIRequestHeaderTI;
begin

	pxy := inheritMethod();
	pxy.myRequestMultiLine := app.createUpdateProxy(self.myRequestMultiLine).CM_EDIDataRequestMultiLine;

	foreach ediTi in self.myRequestMultiLine.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIRequestHeaderTI) then
			reqHdrTi := app.createUpdateProxy(ediTi).CM_EDIRequestHeaderTI;
			reqHdrTi.setMyEDIData(pxy.myRequestMultiLine);		
			break;
		endif;
	endforeach;
	
	complete := true;
	
	return pxy;	

epilog
	if complete &lt;&gt; true then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setEDITIProperty" id="fd0d29d8-5ab6-4bc5-aecd-f1892990b53c">
        <updating/>
        <source>setEDITIProperty(_name: String; _fullValue: Any; _ediFile: CM_EDIFile) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2023	jlirs1	Initial creation
16 Jan 2024	jlirs1	TFS 59172 User Defined CallOff
*/

vars
	ediFile : CM_EDIFile;
begin
	ediFile := _ediFile;
	if _name = ETRow_TransportStatus then
		ediFile.mode := _fullValue.String;
		self.statusString := _fullValue.String;
	elseif _name = ETRow_Guid then
		self.guid := _fullValue.String;
		ediFile.setGuid(_fullValue.String);
	elseif _name = ETRow_Sender then
		self.sender := _fullValue.String;
		ediFile.setFileSenderCode(_fullValue.String);
	elseif _name = ETRow_Receiver then
		self.receiver := _fullValue.String;
		ediFile.setFileRecipientCode(_fullValue.String);
	elseif _name = ETRow_ManifestType then
		self.type := _fullValue.String;
		ediFile.setEdiMessageType(_fullValue.String);
	elseif _name = ETRow_ManifestNumber then
		self.manifestNumber := _fullValue.String;
		ediFile.setEdiClientRef(_fullValue.String);
	elseif _name = ETRow_Vehicle then
		self.setVehicleNumber(_fullValue.String);
	elseif _name = ETRow_VbsNumberExternal then
		self.vehicleBookingSlotRemarks := _fullValue.String;
	elseif _name = ETRow_VbSlotType then
		self.vehicleBookingSlotType := _fullValue.String;
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_fullValue" type="Any"/>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="15ac76f2-4801-4540-bdb2-77078132d52e">
        <updating/>
        <source>setForUpdate(_proxySelf: CM_EDIDataCallOff) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Aug 2023	navra1	Initial creation for TFS 59666 - EUP - CallOff fields not available in the column organiser
30 Aug 2023	navdap1	TFS 60150 EUP | FR 53824 - Road Manifest IMPORT cargo
*/

vars
	ediTI : CM_EDITrackedItem;		// TFS 60150

begin
	inheritMethod(_proxySelf);
	self.setVehicleNumber(_proxySelf.getVehicleNumber());	
	self.transportReferenceCustomer := _proxySelf.transportReferenceCustomer;
	self.vehicleBookingSlotType := _proxySelf.vehicleBookingSlotType;
	
	// TFS 60150 start - update vehicle booking slot type on the request header as well
	if self.myRequestMultiLine &lt;&gt; null then
		foreach ediTI in self.myRequestMultiLine.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI.CM_EDIRequestHeaderTI.vbsSlotType := _proxySelf.vehicleBookingSlotType;
			endif;
		endforeach;
	endif;
	// TFS 60150 end
epilog

end;</source>
        <Parameter name="_proxySelf" type="CM_EDIDataCallOff"/>
    </JadeMethod>
    <JadeMethod name="setMyRequest" id="7145c94f-d81e-49f5-983e-49a78fe255e9">
        <updating/>
        <source>setMyRequest(_request : CM_EDIDataRequestMultiLine) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
