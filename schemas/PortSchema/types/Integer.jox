    <JadeMethod name="asWords" id="3c8f2ad8-bccf-4ba0-b753-984d7467cebd">
        <source>asWords():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2012	cnwndl1	Initial creation	Par 29968 - copied from JSMS

*/



vars

	header : Integer;
	footer : Integer;
	
begin

	if self &lt; 0 then return app.getErrorString(Num_Minus) &amp; " " &amp; self.abs.asWords;
	elseif self = 0 then return app.getErrorString(Num_Zero);
	elseif self = 1 then return app.getErrorString(Num_One);
	elseif self = 2 then return app.getErrorString(Num_Two);
	elseif self = 3 then return app.getErrorString(Num_Three);
	elseif self = 4 then return app.getErrorString(Num_Four);
	elseif self = 5 then return app.getErrorString(Num_Five);
	elseif self = 6 then return app.getErrorString(Num_Six);
	elseif self = 7 then return app.getErrorString(Num_Seven);
	elseif self = 8 then return app.getErrorString(Num_Eight);
	elseif self = 9 then return app.getErrorString(Num_Nine);
	elseif self = 10 then return app.getErrorString(Num_Ten);
	elseif self = 11 then return app.getErrorString(Num_Eleven);
	elseif self = 12 then return app.getErrorString(Num_Twelve);
	elseif self = 13 then return app.getErrorString(Num_Thirteen);
	elseif self = 14 then return app.getErrorString(Num_Fourteen);
	elseif self = 15 then return app.getErrorString(Num_Fifteen);
	elseif self = 16 then return app.getErrorString(Num_Sixteen);
	elseif self = 17 then return app.getErrorString(Num_Seventeen);
	elseif self = 18 then return app.getErrorString(Num_Eighteen);
	elseif self = 19 then return app.getErrorString(Num_Nineteen);
	elseif self = 20 then return app.getErrorString(Num_Twenty);
	elseif self = 30 then return app.getErrorString(Num_Thirty);
	elseif self = 40 then return app.getErrorString(Num_Forty);
	elseif self = 50 then return app.getErrorString(Num_Fifty);
	elseif self = 60 then return app.getErrorString(Num_Sixty);
	elseif self = 70 then return app.getErrorString(Num_Seventy);
	elseif self = 80 then return app.getErrorString(Num_Eighty);
	elseif self = 90 then return app.getErrorString(Num_Ninety);
	elseif self &lt; 100 then 
		header := (self div 10) * 10;
		footer := (self mod 10);
		return header.asWords &amp; app.getErrorString(Num_Sep) &amp; footer.asWords;
	elseif self &lt; 1000 then
		header := self div 100;
		footer := self mod 100;
		if footer = 0 then
			return header.asWords &amp;" " &amp; app.getErrorString(Num_Hundred);
		else
			return header.asWords &amp;" " &amp; app.getErrorString(Num_Hundred) &amp; " " &amp; app.getErrorString(Num_And) &amp; " " &amp; footer.asWords;
		endif;
	elseif self &lt; 1000000 then
		header := self div 1000;
		footer := self mod 1000;
		if footer = 0 then
			return header.asWords &amp;" " &amp; app.getErrorString(Num_Thousand);
		elseif footer &lt; 100 then
			return header.asWords &amp;" " &amp; app.getErrorString(Num_Thousand) &amp; " " &amp; app.getErrorString(Num_And) &amp; " " &amp; footer.asWords;
		else
			return header.asWords &amp;" " &amp; app.getErrorString(Num_Thousand) &amp; ", "&amp; footer.asWords;
		endif;
	elseif self &lt; 2147483647 then
		header := self div 1000000;
		footer := self mod 1000000;
		if footer = 0 then
			return header.asWords &amp;" " &amp; app.getErrorString(Num_Million);
		elseif footer &lt; 100 then
			return header.asWords &amp;" " &amp; app.getErrorString(Num_Million) &amp; " " &amp; app.getErrorString(Num_And) &amp; " "&amp; footer.asWords;
		else
			return header.asWords &amp;" " &amp; app.getErrorString(Num_Million) &amp; ", " &amp; footer.asWords;
		endif;
	else
		return app.getErrorString(Value) &amp; " &lt;" &amp; self.String &amp; "&gt;";
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asWords2" id="22aed9a0-136c-414e-a8d6-ea4de7ba7006">
        <source>asWords2():String;

// ---------------------------------------------------------------------------
// Created:     Sept 2013 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 32567 new method for QNPS
// ---------------------------------------------------------------------------
/*

Purpose:	This version of currency as words drops the 'and' between the numbers except for 'and 99 cents'.
				It also moves the 'Dollars' to the front of the words.
				It also removes all commas
*/

vars

	header : Integer;
	footer : Integer;
	
begin

	if self &lt; 0 then return app.getErrorString(Num_Minus) &amp; " " &amp; self.abs.asWords2();
	elseif self = 0 then return app.getErrorString(Num_Zero);
	elseif self = 1 then return app.getErrorString(Num_One);
	elseif self = 2 then return app.getErrorString(Num_Two);
	elseif self = 3 then return app.getErrorString(Num_Three);
	elseif self = 4 then return app.getErrorString(Num_Four);
	elseif self = 5 then return app.getErrorString(Num_Five);
	elseif self = 6 then return app.getErrorString(Num_Six);
	elseif self = 7 then return app.getErrorString(Num_Seven);
	elseif self = 8 then return app.getErrorString(Num_Eight);
	elseif self = 9 then return app.getErrorString(Num_Nine);
	elseif self = 10 then return app.getErrorString(Num_Ten);
	elseif self = 11 then return app.getErrorString(Num_Eleven);
	elseif self = 12 then return app.getErrorString(Num_Twelve);
	elseif self = 13 then return app.getErrorString(Num_Thirteen);
	elseif self = 14 then return app.getErrorString(Num_Fourteen);
	elseif self = 15 then return app.getErrorString(Num_Fifteen);
	elseif self = 16 then return app.getErrorString(Num_Sixteen);
	elseif self = 17 then return app.getErrorString(Num_Seventeen);
	elseif self = 18 then return app.getErrorString(Num_Eighteen);
	elseif self = 19 then return app.getErrorString(Num_Nineteen);
	elseif self = 20 then return app.getErrorString(Num_Twenty);
	elseif self = 30 then return app.getErrorString(Num_Thirty);
	elseif self = 40 then return app.getErrorString(Num_Forty);
	elseif self = 50 then return app.getErrorString(Num_Fifty);
	elseif self = 60 then return app.getErrorString(Num_Sixty);
	elseif self = 70 then return app.getErrorString(Num_Seventy);
	elseif self = 80 then return app.getErrorString(Num_Eighty);
	elseif self = 90 then return app.getErrorString(Num_Ninety);
	elseif self &lt; 100 then 
		header := (self div 10) * 10;
		footer := (self mod 10);
		return header.asWords2() &amp; app.getErrorString(Num_Sep) &amp; footer.asWords2();  
	elseif self &lt; 1000 then
		header := self div 100;
		footer := self mod 100;
		if footer = 0 then
			return header.asWords2() &amp;" " &amp; app.getErrorString(Num_Hundred);
		else
			return header.asWords2() &amp;" " &amp; app.getErrorString(Num_Hundred) &amp; " " &amp; footer.asWords2();
		endif;
	elseif self &lt; 1000000 then
		header := self div 1000;
		footer := self mod 1000;
		if footer = 0 then
			return header.asWords2() &amp;" " &amp; app.getErrorString(Num_Thousand);
		elseif footer &lt; 100 then
			return header.asWords2() &amp;" " &amp; app.getErrorString(Num_Thousand) &amp; " " &amp; footer.asWords2();
		else
			return header.asWords2() &amp;" " &amp; app.getErrorString(Num_Thousand) &amp; " " &amp; footer.asWords2();
		endif;
	elseif self &lt; 2147483647 then
		header := self div 1000000;
		footer := self mod 1000000;
		if footer = 0 then
			return header.asWords2() &amp; " " &amp; app.getErrorString(Num_Million);
		elseif footer &lt; 100 then
			return header.asWords2() &amp;" " &amp; app.getErrorString(Num_Million) &amp; " " &amp; footer.asWords2();
		else
			return header.asWords2() &amp;" " &amp; app.getErrorString(Num_Million) &amp; " " &amp; footer.asWords2();
		endif;
	else
		return app.getErrorString(Value) &amp; " &lt;" &amp; self.String &amp; "&gt;";
	endif;
	// app.getErrorString(Num_And)
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="changeColourByHSL" id="0118e26d-d382-4dae-b5d6-35321c3136e7">
        <source>changeColourByHSL(	_huePcent,
					_satPcent,
					_lumPCent : Real) : Integer;
/*

Purpose: input is the precent that you want the hue sat or lum changed
		i.e. if you want colour lighter then changee the lum by -0.1 (i.e. decrease it by 10 %)


Return Value:		


Date		Who		Reason
14 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	red,
	green,
	blue,
	newRed,
	newGreen,
	newBlue,
	newColour: Integer;
	hue,
	sat,
	lum,
	newSat,
	newHue,
	newLum: Real;
	lumPCent : Real;
begin
	//get the red green blue values of self
	self.cnEcGetRGBValues(red,green,blue);
	
	app.convertRGBtoHSL(red,green,blue,hue,sat,lum);
	
	newHue:=(hue/240) + _huePcent;
	if (newHue &gt; 1) then
		newHue := newHue -1;
    endif; 
	
	newSat:=(sat/240) + _satPcent;
	if (newSat &gt; 1) then
		newSat := newSat -1;
    endif; 


	lumPCent:=_lumPCent;
	// lum has to be in range of 45 - 195 anything less than 45 looks black anything &gt; 195 looks white
	// &gt; 0 its going lighter
	if _lumPCent &gt; 0 then
		//has to be taking into
		//if it is &gt; 195 change it the other way
		if (lumPCent * 240 + lum) &gt; 195 then
			lumPCent :=-lumPCent;
		endif;
	elseif  _lumPCent &gt; 0 then
		// going darker
		if (lumPCent * 240 + lum) &lt; 45 then
			lumPCent :=-lumPCent;
		endif;
	endif; 
	newLum:=(lum/240) + lumPCent;
	if (newLum &gt; 1) then
		newLum := newLum -1;
    endif; 
	app.convertHSLtoRGB((newHue*240).rounded,(newSat*240).rounded,(newLum * 240).rounded,newRed,newGreen,newBlue);
	
	newColour:=app.convertRGBToColor(newRed,newGreen,newBlue);
	return newColour;

epilog

end;</source>
        <Parameter name="_huePcent" type="Real"/>
        <Parameter name="_satPcent" type="Real"/>
        <Parameter name="_lumPCent" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="colourSpread" id="5b9d7c25-8907-489c-b45f-641223afb6fd">
        <source>colourSpread() : Integer;
// Return a colour that is spread over the full colour range based on the value of self
// The same colour will always be returned for a specific value
vars
	colourArray : IntegerArray;
begin
	create colourArray transient;
	colourArray.populateWithUniqueColours(self+1);
	return colourArray.last;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
