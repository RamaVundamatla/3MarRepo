    <JadeMethod name="tblResults_contextMenu" id="d8d19f47-48d8-42b4-a2e9-1c70729d5072">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2025	navbs1	Initial creation

*/

vars

begin
	if self.tblResults.selectedCount &gt; 0 then 
		self.showContextMenu__(mnuContextExtras, conwin, mouse, x, y);
		return true;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblResults_dblClick" id="e4d650b1-b1fe-47f0-9be3-0513e0c1d405">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_dblClick(table: Table input) updating;
/*
Purpose:			

Date		Who		Reason
30 October 2023	navab1	
*/

vars
	theSortType, tblCol : Integer;
begin
	if table.row &gt; table.fixedRows then
		return;
	endif;

	tblCol := table.column;
	
	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.sortColumn[1]	:= tblCol;    
	table.sortAsc[1]		:= not table.sortAsc[1];
	table.sortCased[1]	:= false;
	
	
	if tblCol= 4 or tblCol = 9 then
		theSortType :=  Table.SortType_Numeric;
	elseif tblCol= 5 then
		theSortType :=  Table.SortType_Date;
	elseif tblCol= 8 then
		theSortType :=  Table.SortType_Time;
	else
		theSortType := Table.SortType_Alpha;
	
	endif;
	
	table.sortType[1] := theSortType;
	
	if tblCol &lt;&gt; 8 then //Sort on Run Time column
		table.sortColumn[2]	:= 8;    
		table.sortAsc[2]	:= true;
		table.sortCased[2]	:= false;
		table.sortType[2]	:= Table.SortType_Time;
	endif;
	
	table.resort;

	table.accessCell(1,table.column).fontBold := true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblResults_keyDown" id="f6acd519-ed81-49a3-a88c-5ca499ee3904">
        <controlMethod name="CM_Table::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 August 2024		navmd1	Initial creation

*/

vars

begin
	// Lets try Jades way for once...
	if shift.bitAnd(2) &lt;&gt; 0 then	// Ctrl held
		if keyCode = J_key_F11 then
			table.accessRow(table.row).inspect;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblResults_rowColumnChg" id="a749d8dc-8b0f-45a9-bc1c-fe644ba19b7a">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_rowColumnChg(table: Table input) updating;

/*

Purpose:		Display / Clear the failure details

Date			Who		Reason
03/05/2012		cnwmh5	Initial creation

*/

vars

begin
	
	self.txtFailureDtls.text := null;
	if table.accessCell(table.row, 1).text.trimBlanks() = "FAIL" or process.isMPD then
		//self.txtFailureDtls.text := table.accessCell(table.row, self.tblResults.columns).text;
		// If the results contains any Tabs then the last cell will only end up with truncated results.
		// So, to display everything, lets just uncompress the details directly into the results text box
		if table.accessRow(table.row).itemObject &lt;&gt; null then
			self.txtFailureDtls.text := table.accessRow(table.row).itemObject.UM_UnitTestResult.details.uncompressToString().trimBlanks();
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
