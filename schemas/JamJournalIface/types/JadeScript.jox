<Class name="JadeScript">
    <JadeMethod name="doGenerateClassNumberFile" id="f93428e7-ed63-44d4-ac22-b388b5ed2ad4">
        <source>doGenerateClassNumberFile();

vars
	jaa		: JadeAuditAccess;
	schemas	: SchemaColl;
	schema	: Schema;
begin
	create jaa transient;
	create schemas transient;
	rootSchema.withAllSubschemas(schemas);
	foreach schema in schemas do
		jaa.generateClassNumberMapsFile(schema, 'c:\temp\ClassNumbers.txt');
	endforeach;
epilog
	delete schemas;
	delete jaa;
end;</source>
    </JadeMethod>
</Class>
