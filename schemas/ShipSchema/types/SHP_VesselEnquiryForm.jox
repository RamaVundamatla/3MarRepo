    <JadeMethod name="doBtnHoldDef" id="2d964131-bff5-498b-9849-e8f33781d9f9">
        <source>doBtnHoldDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	form : SHP_GCHoldLocationVessDefnForm;

begin

	if self.myCurrentVessel = null or self.myCurrentVessel.myGeneralCargoVesselStructure = null then
		return;
	endif;

	form := app.getForm(SHP_GCHoldLocationVessDefnForm.name).SHP_GCHoldLocationVessDefnForm;
	if form = null then
		form := app.loadForm(SHP_GCHoldLocationVessDefnForm, CMUI_Assistant, false, false, false, self.myTerminal, null).SHP_GCHoldLocationVessDefnForm;
	endif;
	if form &lt;&gt; null then
		form.setMyVessel( self.myCurrentVessel );
		form.setParentForm(self);
		form.showModal;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="2bddad01-1ddb-4230-8e18-74a80d2d3560">
        <updating/>
        <source>doDelete()updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	result			: Integer;
	msgStr			: String;
	selectedObj 	: CM_Object;
	objectArray		: CM_ObjectArrayActual;
	response		: Integer;
	
begin

	if self.tblData.allSelectedObjects.size &gt; 1 then
	   	msgStr := app.getErrorString2(ConfirmDelete, 'selected', 'vessels');
	elseif self.myCurrentVessel &lt;&gt; null then
		selectedObj := self.myCurrentVessel;
		msgStr := app.getErrorString2(ConfirmDelete, 'the selected', 'vessel ' &amp; self.myCurrentVessel.name);
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
		if selectedObj &lt;&gt; null then
		  	app.myTrxDA.trxDeleteCMObject(selectedObj, app.myPassport);
		else
			create objectArray transient;
			self.tblData.allSelectedObjects.copy(objectArray);
		  	app.myTrxDA.trxDeleteCMObjects(objectArray, app.myPassport);	
		endif;		  	  
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
		endif;
		break;
	endwhile;	

epilog
	delete objectArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doExport" id="36d81267-90af-44da-916c-9bc2a4f04c85">
        <source>doExport() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	fileXML : CMDFileSave;  // PAR #17167  11/08/2008 cnwdz2 Exporting a file to the disk should use save as dialogue.
	fileName : String;
begin
	on FileException do  app.fileExceptionHandler(exception);

	if self.myCurrentVessel = null then
		return;
	endif;
	create fileXML;
	fileXML.filter := "JMT Vessel Definition  (*.xml)|*.xml";
	fileXML.fileName := self.myCurrentVessel.code &amp; ".xml";
	if fileXML.open &lt;&gt; 0 then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	fileName:=fileXML.fileName;
	
	app.myTrxUA.trxExportAsXMLDoc(self.myCurrentVessel,fileXML.fileName,app.myPassport);

epilog
	
	delete fileXML;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="b16c90bc-6e53-45cc-939e-5ec878e0d0d8">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2022	navtnr20	Initial creation	TFS 53051

*/

vars
	filterText  : String;
	rowIdx,
	colIdx,
	start,rows  : Integer;
	cell 		: JadeTableCell;
	cellText    : String;
	tbl			: CM_DataTable;
begin
	/*//23/04/2024	navkc1 CR63736 Task 63770
	rows := 0;
	filterText := self.txtFilterBox.text.toUpper();
	tbl		   := self.tblData;
	
	if filterText = "" then
		self.clearFilter();
		return;
	else
		self.btnClearFilter.enabled := true;
	endif;

	start := tbl.fixedRows + 1;
	
	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
		
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.setSelectedVessel(null);
				tbl.accessedRow.visible := true;
				rows 					:= rows+1;
				continue rowLoop;
			endif;
		endforeach;
	
		tbl.accessedRow.visible := false;
	endforeach;
	*/
	
	//05/06/2024	navkc1 CR 63736 Task 63770
	rows := self.frmTableFilter.numOfRowVisible;
	
	self.statusLine.caption := rows.String &amp; ' rows found.';
	if rows = 0 then 
		self.setSelectedVessel(null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doImport" id="b21f3165-afdd-4168-9a44-dbfc551d06f4">
        <updating/>
        <source>doImport() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	pxyObj : CM_Object;
	deletePxy : Boolean;
	fileName : String;
	form : SHP_RORODeckImport;
begin
	app.mousePointer  := Window.MousePointer_HourGlass; 
	pxyObj:=app.importVesselDefnXMLCreateProxy(true,
												self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null,
												self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myROROVesselStructure &lt;&gt; null,
												fileName);
												
	app.mousePointer  := Window.MousePointer_Default;
	
	if pxyObj = null then
		return;
	endif;

	if pxyObj.isKindOf(CM_Vessel) then	
		self.myAssistant.SHP_Assistant.showVesselDefinitionForImport(pxyObj.CM_Vessel, self.myMasterMenuAction);
	elseif pxyObj.isKindOf(CM_CellularVesselStructure) then
		if self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null then
			self.myAssistant.SHP_Assistant.showLOLOBayImport(self.myCurrentVessel.myCellularVesselStructure,pxyObj,fileName);
		else
			deletePxy:=true;
		endif;
	elseif pxyObj.isKindOf(CM_ROROVesselStructure) or
			pxyObj.isKindOf(CM_DeckVessel) then
		if self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myROROVesselStructure &lt;&gt; null then
			self.myAssistant.SHP_Assistant.showRORODeckImport(self.myCurrentVessel.myROROVesselStructure,pxyObj,fileName);
		else
			deletePxy:=true;
		endif;
	endif;
epilog
	app.mousePointer  := Window.MousePointer_Default;
	if deletePxy then
		delete pxyObj;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
