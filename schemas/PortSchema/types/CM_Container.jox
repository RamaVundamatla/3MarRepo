    <JadeMethod name="validateISOType" id="54442625-e47d-43f8-bd05-cb25a8d7b8bd">
        <source>validateISOType(pControl: CMIF_TIUpdateController) protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/12/2011	cnwdap1		PAR #26619 Check if changing to a flat and overstowed
// 16/12/2014  cnwdb2	PAR 35364
// 27 Feb 2017	cnwrs1	TFS 3511 edit conatiner without ISOTYpe eg TBA ship planning containers causes 1090.
// 02 Dec 2019	jlgrs1	TFS 47414 error is existing 
// ---------------------------------------------------------------------------
vars
	commodity : CM_Commodity;
	realTI : CM_Container;					// PAR #26619
	realISO, proxyISO : CM_ISOType;			// PAR #26619
	topTI : CM_TrackedItem;					// PAR #26619
	planned, queued	: Boolean;				// PAR #26619
	mode : String;							// PAR #26619
	overstowID : String;					// PAR #26619
begin
	if self.isoType = null then  //cnwrd1 par 22764 we need an ISO type so validate it here.
		// ISO Type required.
	//	app.raiseCMException1(REQUIRED_FIELD, 'ISO Type', 'isoType', pControl.myUserObject); //6/11/2009 cnwdz2 20784
		app.raiseCMException(Input_required_field_IsoType, 'isoType', pControl.myUserObject); // cnwdb2	PAR 35364

		
	elseif self.isoType &lt;&gt; null then
		//4/11/2009 cnwdz2 par20724
		// par 11989 June 2006 cnwrs1
		//commodity := self.getCommodityObject();
		//if commodity &lt;&gt; null and
		 //  self.getCommodityObject().hasTemp and //check if commodity requires reefer the isotype must be reefer
		  // not self.getISOTypeObject().isReefer then
		//	app.raiseCMException1(ERR_REEF_COMMODITY, self.commodity &amp; " for " &amp; self.id,'commodity', pControl.myUserObject);
		//endif;
		self.validateGenSet(pControl);	//Par 18790, April 2009
		inheritMethod(pControl);
		
		// PAR #26619 check if we're changing to a flat or a platform
		realTI := pControl.myRealTrackedItem.CM_Container;
		if realTI = null or realTI.isoType = self.isoType then
			return;
		endif;
		
		realISO := app.myRoot.allISOTypes[realTI.isoType];
		proxyISO := app.myRoot.allISOTypes[self.isoType];
		if realISO &lt;&gt; null and
		   proxyISO = null then
			app.raiseCMException(Input_required_field_IsoType, 'isoType', pControl.myUserObject);
		endif;  
		if realISO &lt;&gt; null and
		   proxyISO &lt;&gt; null and
		   realISO.isFlat &lt;&gt; proxyISO.isFlat and
		   proxyISO.isFlat then
			// We've changed from an ISO type that is not a platform or a flat to an ISO type that is a platform or a flat
			// Are we overstowed, or going to be overstowed, by any other cargo?
			topTI := realTI.getPlannedQueuedActualTIOverMe();
			if topTI &lt;&gt; null then
				overstowID := topTI.id;
				if planned or queued then
					mode := "will be";
				else
					mode := "is";
				endif;
				// raise warning - I am overstowed, so can't really change me to be a flat
				app.raiseCMWarning3(Cargo_item_overs_canno_change, self.id, mode, topTI.id, "Container " &amp; self.id, null, self);
			endif;
		endif;
		// PAR #26619 end
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateId" id="80b2bb68-9ec8-4abb-8d47-492b956a635d">
        <source>validateId(pControl: CMIF_TIUpdateController) protected;
//13 Jan 2020 NDL	TFS 48256 - New Rule for containers, always check the check digit for a valid id when doing a normal update as well
vars
	theMode : Integer;
	tmpId	: String;
	idChanged : Boolean;
begin
	inheritMethod(pControl);

	tmpId := self.id;
	//Check to see if the id has changed in order to ascertain whether we need to validate it's id.
	if (pControl.myRealTrackedItem &lt;&gt; null) then
		if (tmpId &lt;&gt; pControl.myRealTrackedItem.id) then
			idChanged := true;
		endif;
	endif;
	
	theMode := pControl.mode;
	
	if (self.id.length &gt; ContainerID_Length) then
		app.raiseCMException2(ContainerIdToLong, id, ContainerID_Length.String, 'id', pControl.myUserObject);
		return;
	endif;
	
	//special code only activated in DEV environment, so we don't have to re-write all of the unit tests
	//that are currently using invalid container numbers.
	executeWhen JMTDevelopmentEnvironment;
	if theMode = TI_UPDMODE_NORMAL then
		return;
	endif;
	endExecuteWhen;

	// Need to validate the container number check digit.
	//Only for prenotes, edi, create and receive.
//	if (self.state = TI_STATE_EDI) or (self.state = TI_STATE_NOTIFIED) or (theMode = TI_UPDMODE_RECEIPT) or idChanged then
	if (self.state = TI_STATE_EDI) or (self.state = TI_STATE_NOTIFIED) or (theMode = TI_UPDMODE_RECEIPT) or idChanged or theMode = TI_UPDMODE_NORMAL then
	 	if (not app.checkDigitContainerId(id)) then
			app.raiseCMWarning2(ERR_CONTAINER_NO,  "Container Id", id, 'id', pControl.myUserObject, self);
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateMasterTI" id="8188d80f-4bf9-42d8-9154-f7fbb1583548">
        <updating/>
        <source>validateMasterTI(_master: CM_TIMaster; _passport: CM_Passport) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/09/2009	cnwjk3	sfw1035
21 May 2018	jlgrh7 TFS38723 Penn - Fleet File - ISO Container Maintenance 
*/
vars
	tiISOType,
	masterISOType : CM_ISOType;
	tiISOTypeDesc,
	masterISOTypeDesc : String;
	masterContainer : CM_TIMasterContainer;
begin
	if _master = null then 
		return;
	endif;

	inheritMethod(_master, _passport);
	
	masterContainer := _master.CM_TIMasterContainer;
	
	if self.isoType &lt;&gt; masterContainer.isoType then
		masterISOType := app.myRoot.allISOTypes[masterContainer.isoType];
		tiISOType := app.myRoot.allISOTypes[self.isoType];
		if masterISOType = null then
			masterISOTypeDesc := app.getErrorString(Null);	
		else
			masterISOTypeDesc := masterISOType.description;
		endif;
		
		if tiISOType = null then
			tiISOTypeDesc := app.getErrorString(Null);	
		else
			tiISOTypeDesc := tiISOType.description;
		endif;
		app.raiseCMWarning3(WARN_FLEETFILE_DISCREP,"ISO Type for " &amp; self.id, self.isoType &amp; " " &amp; tiISOTypeDesc &amp; " ", masterContainer.isoType &amp; " " &amp; masterISOTypeDesc&amp; " ","",null,self);	
	endif;
	
	if self.getCoolingType &lt;&gt; masterContainer.coolingType then
		app.raiseCMWarning3(WARN_FLEETFILE_DISCREP,"Cooling Type for " &amp; self.id, app.coolingTypeENumToString(self.getCoolingType, false), app.coolingTypeENumToString(masterContainer.coolingType, false),"",null,self);		
	endif;	
	
	if self.getVoltageType &lt;&gt; masterContainer.voltageType then
		app.raiseCMWarning3(WARN_FLEETFILE_DISCREP,"Voltage Type for " &amp; self.id, app.voltageTypeENumToString(self.getVoltageType, false), app.voltageTypeENumToString(masterContainer.voltageType, false),"",null,self);		
	endif;
	
	if masterContainer.maxKilos &gt;0 then															//+TFS38723
		if self.totalWeight &gt; masterContainer.maxKilos then
			//app.raiseCMWarning3(WARN_FLEETFILE_MAXWEIGHT, self.id, self.totalWeight.asStringWeightJMT(),masterContainer.maxKilos.asStringWeightJMT(),"",null,self);
			//09 Aug 2011	NDL	Par 27902
			app.raiseCMException3(WARN_FLEETFILE_MAXWEIGHT, self.id, self.totalWeight.asStringWeightJMT(),masterContainer.maxKilos.asStringWeightJMT(),"",self);			
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_master" type="CM_TIMaster"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateMoveFrom" id="9906c607-ab8c-4533-9bac-c0a00d35a0f2">
        <source>validateMoveFrom(control: CMIF_MoveController) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if control.isForcedMove then
		return;
	endif;

	if control.isUndoMove or control.isPostMoveCleanup then
		// PAR 17890
		if self.myPrimaryActualLocation.isKindOf(CM_MachineController) 
		and control.moveMode = QUEUE_MODE 
		and control.isUndoMove and not (self.isRotatableContainer and self.myPrimaryActualLocation.CM_MachineController.myMachine.isIMV) then //jlier1 TFS 8/10/25 36155 
			app.raiseCMException2(Canno_remov_queue_move_whils_c, self.id, self.myPrimaryActualLocation.CM_MachineController.myMachine.id, null, self);
		endif;

		return;
	endif;
	inheritMethod(control);
	if control.moveMode &lt;&gt; REAL_MODE and control.moveMode &lt;&gt; QUEUE_MODE then
		return;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
