    <JadeMethod name="canCreateWorkOrderWLE" id="c4497abe-b968-433a-b9cc-9053c1cbbe52">
        <source>canCreateWorkOrderWLE(_request : CM_Request; _wle : CM_WorkListEntry) : Boolean protected;
/*

Purpose:			Check whether we can create a new work order wle for this request or not

Parameters:			_request	CM_Request			The request to check
					_wle		CM_WorkListEntry	The Work List Entry to check

Return Value:		Boolean	Representing whether we can or cannot create as work order wle

Date				Who		Reason
06 September 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

vars
	reserveDetail : CM_ReserveDetail;
	
begin
	if not _request.isDeliveryRequest then
		return false; //This is not for a delivery request meaning this is not as release by type
		
	endif;
	
	if not _request.isAnyId and not _request.isAnyAmount then
		return false; //This is not for an Any ID Any Amount cargo release. Are both AnyId and AnyAmount required or do these have different functions
		
	endif;
	
	reserveDetail := _request.myReserveDetail;
	
	if reserveDetail = null then
		return false; //We need a reserve detail
		
	endif;
	
	if reserveDetail.allWodReleases.isEmpty then
		return false; //THis is not for a work order
		
	endif;
	
	if _wle.myWorkOrderWLE &lt;&gt; null then
		return false; //We do not need a new work order wle for this wle as it already has one
		
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
