    <JadeMethod name="create" id="06037422-550c-4865-8b44-9eb2021dbac3">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
