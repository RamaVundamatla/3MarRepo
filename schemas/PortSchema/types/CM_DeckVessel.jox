    <JadeMethod name="validateForXMLImport" id="7a9b3fba-4ebf-4b36-b13b-bc2f35093d42">
        <source>validateForXMLImport();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2013	cnwmc5	Initial creation

*/

vars
	allItems, allItemsCopy : CM_RORODeckItemLayoutArray;
	cms : DecimalArray;
	allCoveredCodes : StringArray;
	
	itemLayout : CM_DeckItemLayout;
	locn : CM_DeckItem;
	code : String;
	errorMsg : String;
begin
	create allItems transient;
	create allItemsCopy transient;
	create cms transient;
	create allCoveredCodes transient;
	
	foreach locn in self.allROROLocnDefnByCode do
		if locn.myLayout.type = ROROLayerType_Cargo or locn.myLayout.type = ROROLayerType_Lanes then
			cms.clear();
			locn.myLayout.myPolygonCMs.copy(cms);
			locn.myLayout.setPointsPolygonCMs(cms);
			allItems.add(locn.myLayout);
		endif;
	endforeach;
	
	foreach locn in self.allROROLaneDefnByCode do
		if locn.myLayout.type = ROROLayerType_Cargo or locn.myLayout.type = ROROLayerType_Lanes then
			cms.clear();
			locn.myLayout.myPolygonCMs.copy(cms);
			locn.myLayout.setPointsPolygonCMs(cms);
			allItems.add(locn.myLayout);
		endif;
	endforeach;
	
	allItems.copy(allItemsCopy);
	
	foreach itemLayout in allItemsCopy do
		allItems.remove(itemLayout);
		itemLayout.isCoveredOnXMLImport(allItems, allCoveredCodes);
	endforeach;
	
	foreach code in allCoveredCodes do
		errorMsg := errorMsg &amp; code &amp; ", ";
	endforeach;
	
	if errorMsg &lt;&gt; null then
		errorMsg := errorMsg[1:errorMsg.length-2];
		app.raiseCMException1(Covered_Locations,errorMsg,null,null);
	endif;
epilog
	delete allItems;
	delete allItemsCopy;
	delete cms;
	delete allCoveredCodes;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="de93cd2d-5f77-4f2d-bb51-673ea0d2011a">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	realSelf,dupDeck : CM_DeckVessel;
	roroStructure : CM_ROROVesselStructure;
begin
	inheritMethod(_passport);

	realSelf:=self.pxyGetRealObject;

	if realSelf &lt;&gt; null then
		roroStructure:=realSelf.getROROStructure();
		dupDeck:=roroStructure.allDecksByCode[self.code];
		if dupDeck &lt;&gt; null and dupDeck &lt;&gt; realSelf then
			app.raiseCMException1(Duplicate_code_must_unique,app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Deck),null,null);
			return;
		endif;	
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
