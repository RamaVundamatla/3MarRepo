    <JadeMethod name="deactivate" id="05952164-22bc-4367-8cdb-81dc1fbb33f0">
        <controlMethod name="Form::deactivate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>deactivate() updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	doShow : Boolean;
begin
	/*if not self.amActive then
		self.showHideCC(false);
	endif;
	self.endTimer( 1);*/
	
	//cnwjo3 par 25114
	doShow := (self.displayMode = ShpDisplayMode_ColCodeLoad or  self.displayMode = ShpDisplayMode_ColCodeDisch) and self.workingMode = self.WorkMode_None ; // PAR 23216 this is colour code mode only, not jobs, planning etc
	
	if app.activeForm.isKindOf(CMUI_VoyageAllocationsListForm) or app.activeForm.isKindOf(CMUI_VoyageAllocsLoadListForm) or app.activeForm.isKindOf(CMUI_YAMaintVoyForm) then
		self.amActive := true;
		//self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,doShow);//cnwas3 par26840a	
		self.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,doShow);//cnwas3 par 27769
		//self.showHideCC(doShow);
	else
		self.amActive := false;
		if self.myCurrentVoyage &lt;&gt; null then
			//self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);//cnwas3 par26840a	
			self.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);//cnwas3 par 27769
		endif;
		//self.showHideCC(false);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayHolds" id="bb5ec57f-ec89-4032-8fca-6c9d92da8f1b">
        <source>displayHolds(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     Callback method from msg
// ---------------------------------------------------------------------------
vars
	aBay : CM_Bay;
	aHold : CM_Hold;
	theString : String;
	first : Boolean;
begin
	if _theObject &lt;&gt; null then
		if self.selectMode = self.SelectModeHold then
			aHold := _theObject.CM_Hold;
			first := true;
			theString := "Hold " &amp; aHold.ordinalHold.String.padLeadingZeros(2) &amp; " - Bay " ;
			foreach aBay in aHold.allBays do
				if first then
					if (aBay.fortyFootBay and aBay.fortyFootOnly) // PAR 34678
					or (aBay.fortyFiveFootBay and aBay.fortyFiveFootOnly) then // PAR 34678
						theString := theString &amp; aBay.idBay40; // PAR 34678
					elseif aBay.bayType = BAY_TYPE_SINGLE then // PAR 34678
						theString := theString.trimBlanks &amp; " " &amp; aBay.id; // PAR 34678
					else
						theString := theString.trimBlanks &amp; "s " &amp; aBay.id;
					endif;
					first := false;
				else
					if (aBay.fortyFootBay and aBay.fortyFootOnly) // PAR 34678
					or (aBay.fortyFiveFootBay and aBay.fortyFiveFootOnly) then // PAR 34678
						
					else
						theString := theString &amp; ", " &amp; aBay.id;
					endif;
				endif;
			endforeach;
			return  theString;
		elseif self.selectMode = self.SelectModeMulti then
			aBay := _theObject.CM_Bay;
			theString := aBay.id;
			return  theString;
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
