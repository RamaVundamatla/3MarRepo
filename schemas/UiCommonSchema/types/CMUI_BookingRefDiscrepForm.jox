    <JadeMethod name="resetButtons" id="50b172fd-55dd-4898-a743-b28e8942127a">
        <updating/>
        <source>resetButtons() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/09/2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
27/10/2011	cnwdap1	PAR #28524 CMS POL 2096 add "Resolve discrepancies" button
*/
vars
	booking : CMEVT_BookingRefDiscrep;
begin

	if self.myCMEVT_BookingRefDiscrep &lt;&gt; null then
		self.setCaption( app.getErrorString(Booking_reference_discrepanc)  &amp; ": " &amp; self.myCMEVT_BookingRefDiscrep.getId );
	elseif not self.passedInTrackedItems.isEmpty then
		if self.passedInTrackedItems.size = 1 then
			self.setCaption( app.getErrorString(Booking_reference_discrepanc)  &amp; ": " &amp; app.getErrorString(Query_selection) &amp; " [" &amp; self.passedInTrackedItems.first.id &amp; "]");
		else
			self.setCaption( app.getErrorString(Booking_reference_discrepanc)  &amp; ": " &amp; app.getErrorString(Query_selection) );
		endif;
	elseif self.myCM_BookingRef &lt;&gt; null then
		self.setCaption( app.getErrorString(Booking_reference_discrepanc)  &amp; ": " &amp; app.getErrorString(Query_selection) &amp; " [" &amp; self.myCM_BookingRef.bookingReference &amp; "]");
	else
		self.setCaption( app.getErrorString(Booking_reference_discrepanc)  &amp; ": " &amp; app.getErrorString(Query_selection) );
	endif;
	
	booking := self.getBookingRefDiscrep();
	
	if booking &lt;&gt; null then
		btnEditBookRef.enabled :=  booking.myBookingRef &lt;&gt; null;
		btnEditRemarks.enabled := true;
		btnEditTI.enabled := booking.myTrackedItem &lt;&gt; null;
		btnResolve.enabled := booking.myBookingRef &lt;&gt; null and not self.tblData.allSelectedObjects.isEmpty;		// PAR #28524
	else
		btnEditBookRef.enabled := false;
		btnEditRemarks.enabled := false;
		btnEditTI.enabled := false;
		btnResolve.enabled := false;																			// PAR #28524
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditBookRef.enabled:= false;
		self.btnEditItem.enabled:= false;
		self.btnEditRemarks.enabled:= false;
		self.btnEditTI.enabled:= false;
		self.mnuEditBookingRef.enabled:= false;
		self.mnuEditRemarks.enabled:= false;
		self.mnuEditTI.enabled:= false;
		self.btnResolve.enabled:= false;
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="37140f30-fc9e-41dd-aada-086e549183dc">
        <updating/>
        <source>setBaseData(	_terminal : CM_Terminal;
				_bookingRefDiscrep : CMEVT_BookingRefDiscrep;
				_trackedItems : CM_TISet;
				_bookingRef : CM_BookingRef
				) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

begin

	self.myTerminal := _terminal;
	self.myCMEVT_BookingRefDiscrep := _bookingRefDiscrep;
	if _trackedItems &lt;&gt; null and not _trackedItems.isEmpty then
		_trackedItems.copy(self.passedInTrackedItems);
	endif;
	self.myCM_BookingRef := _bookingRef;
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_bookingRefDiscrep" type="CMEVT_BookingRefDiscrep"/>
        <Parameter name="_trackedItems" type="CM_TISet"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setupCmbStatus" id="ec78a618-8481-4a24-957a-060b87ab13cc">
        <source>setupCmbStatus();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwndl1	Initial creation

*/

vars

	pos : Integer;
	string : String;
	
begin

	cmbStatus.clear;
	
	cmbStatus.addItem(" ");
	foreach pos in 0 to 10 do
		string := app.stateEnumToString(pos);
		cmbStatus.addItem(string);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0b297d5e-a71b-491a-9679-ea5ad7c20209">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/08/2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
31/10/2011	cnwdap1	PAR #28524 CCMS POL 2096 Allow multi-select on the discrepancy table
*/
vars

begin

	self.usesQueryFrame := true;
	self.useTableInfo := false;
	self.useTableSorting := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.beginClassNotification(CMEVT_BookingRefDiscrep, false, Object_Create_Event, Response_Continuous, 1);
	self.beginClassNotification(CMEVT_BookingRefDiscrep, false, Object_Update_Event, Response_Continuous, 1);

	inheritMethod();
	
	if self.myTerminal &lt;&gt; null then
		self.cmbVoyage.listCollection(self.myTerminal.allVoyagesByCode, false, 0);
	endif;
	
	self.setupCmbStatus();
	
	self.frmQuery.width := 330;
	self.frmQuery.height := 300;
	
	self.initTheTableData(tblPrintVersion, ETDef_BookingRefPrint);
	
	//self.initTableData(ETDef_BookingRefDiscrep);
	self.initTheTableData(tblData, ETDef_BookingRefDiscrepDisplay);
	self.manipulateTblDataFixedRows();
	
	self.initQueryEntryTable();
	self.initQueryFrame();
	self.doResetSearch();
	self.initFilterDefaults();	//PAR 21523 Nov 2009
	
	if self.myCMEVT_BookingRefDiscrep &lt;&gt; null then
		self.frmQuery.visible := false;
		self.tblDataAddItem(self.myCMEVT_BookingRefDiscrep);
		self.resetButtons();
	elseif ( not self.passedInTrackedItems.isEmpty or self.myCM_BookingRef &lt;&gt; null ) then
		self.resetButtons();
		self.frmQuery.visible := true;
		self.doQuery();
		self.passedInTrackedItems.clear();
		self.myCM_BookingRef := null;
	else
		self.resetButtons();
	endif;
	
	// PAR #28524
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="02e04a9e-b9b1-453a-be2d-b2975da9d951">
        <source>showColourLegend();

