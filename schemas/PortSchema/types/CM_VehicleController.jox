    <JadeMethod name="setHazardLocations" id="dfeb00fb-2b22-4de9-a96d-7b3c93a08c20">
        <updating/>
        <source>setHazardLocations(_ti : CM_TrackedItem) updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	vertSpan,
	horzSpan,
	depthSpan			: Integer;
	notSameArea			: Boolean;
begin
	if _ti = null then
		return;
	endif;
	
	if self &lt;&gt; _ti.myPrimaryActualLocation then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self. does not equal the TIs primary actual location (' &amp; self.String &amp; ')');
		return;
	endif;
	
	_ti.getLargestHazardArea(self.getHazardSegregationRuleType(), vertSpan, horzSpan, depthSpan, notSameArea);
	if notSameArea then //all you can specify for on vehicle proximity - theres no allowance for vert/horz depth prox
		if (not self.allHazardousTIs.includes(_ti)) then
			self.allHazardousTIs.add(_ti);
		endif;		
	endif;
	

end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setHazardLocationsForMode" id="ecd48e77-4029-47b4-82f1-e51b11b99c33">
        <updating/>
        <source>setHazardLocationsForMode(_ti : CM_TrackedItem; _mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		April 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	vertSpan,
	horzSpan,
	depthSpan			: Integer;
	notSameArea			: Boolean;
	lc					: CM_LocationsController;
	tiCol : CM_TISet;
	tmpStr : String;
begin
	if _ti = null or (not _ti.isHazardous) then
		return;
	endif;
	
	if _mode = REAL_MODE then
		lc := _ti.myPrimaryActualLocation;
		tmpStr := "actual";
	elseif _mode = PLANNING_MODE then
		lc := _ti.myPrimaryPlannedLocation;
		tmpStr := "planned";
	elseif _mode = QUEUE_MODE then
		lc := _ti.myPrimaryQueuedLocation;
		tmpStr := "queued";
	endif;

	if self &lt;&gt; lc then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self. does not equal the TIs primary ' &amp; tmpStr &amp; ' location (' &amp; self.String &amp; ')');
		return;
	endif;
	
	
	_ti.getLargestHazardArea(self.getHazardSegregationRuleType(), vertSpan, horzSpan, depthSpan, notSameArea);
	
	if notSameArea then
		if _mode = REAL_MODE then
			if (not self.allHazardousTIs.includes(_ti)) then
				self.allHazardousTIs.add(_ti);
			endif;		
		elseif _mode = QUEUE_MODE then
			if (not self.allHazardousTIsQueued.includes(_ti)) then
				self.allHazardousTIsQueued.add(_ti);
			endif;		
		elseif _mode = PLANNING_MODE then
			if (not self.allHazardousTIsPlanned.includes(_ti)) then
				self.allHazardousTIsPlanned.add(_ti);
			endif;		
		endif;
	endif;
	
epilog

end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminalArea" id="6a84248c-7c18-47b8-87c6-6555fc7494f1">
