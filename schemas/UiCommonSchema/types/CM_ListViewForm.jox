    <JadeMethod name="zDoLstDataRefresh" id="79a40e99-d397-4e3e-b00c-72373bc3a98c">
        <updating/>
        <source>zDoLstDataRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

 	if self.needLstDataRefresh then
		self.needLstDataRefresh := false;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoNext" id="1297d488-4e9f-4874-87cf-b0c720874e37">
        <updating/>
        <source>zDoNext() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cont	: Boolean;
	idx		: Integer;
	theRow	: JadeTableRow;
	
begin

	if self.mode &lt;&gt; Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'You can only do a Next when adding');
		return false;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;

	

	if self.doSave() then
		self.zClearPlaceHolderObject(true);		// must be true to clear place holder from table before determing what
												// object to display below.
		self.zClearProxyDetails();
		self.clearErrorWarnings();
		
		if self.myCurrentObject &lt;&gt; null and
	   	   (self.lstData.findObject(self.myCurrentObject) &lt;= 0) then
			self.needLstDataRefresh := true;
		else
			// always force a redisplay (this should never happen).
			self.zLstDataSelectObject(null);
		endif;

		if self.needLstDataRefresh then
			self.zDoLstDataRefresh();
		endif;

		self.zSetControlsForNext();

		return true;
	else
		return false;
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDoPrintCurrent" id="fc2f9b0e-cae4-48d5-bb63-6f18538a5407">
        <updating/>
        <source>zDoPrintCurrent() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//AA 20/6/01: Protects against object being deleted from under us by a notification
	if not global.isValidObject(myCurrentObject) then
		myCurrentObject := null;
	endif;
	
	if self.myCurrentObject = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	self.doPrintCurrent();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoSave" id="942c15b8-5be8-4be2-bef1-429f6377df3f">
        <updating/>
        <source>zDoSave() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cont	: Boolean;
	idx		: Integer;
	theRow	: JadeTableRow;
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;

	self.addUpdateTransactionComplete := false;

	if self.doSave() then
		self.addUpdateTransactionComplete := true;
		self.zClearPlaceHolderObject(true);		// must be true to clear place holder from table before determing what
												// object to display below.
		self.zClearProxyDetails();
		self.zSetControlsForView();
		self.clearErrorWarnings();
		
		if self.mode = Mode_Add then
			if self.myCurrentObject &lt;&gt; null then
				self.zHandleObjectAdd();
			else
				// always force a redisplay (this should never happen).
				//par 13862 to move cursor to right position after adding a child 
				//self.zLstDataSelectObject(null);
			
			endif;

		elseif self.mode = Mode_Update then
			// redisplay any rows on the table that may have been updated
		endif;
	
		self.zShowThumbnailData(self.myCurrentObject);
	
		self.mode := Mode_View;
		
		return true;
	else
		return false;
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDoThumbnailContextMenu" id="b18033e6-d071-49b0-908e-b733ba42315f">
