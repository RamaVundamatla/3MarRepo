    <JadeMethod name="doOptDocketClick" id="ad1e992e-cc07-4fbd-8ea3-d1dee042bb33">
        <updating/>
        <source>doOptDocketClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tblDef			: EntTableDef;
begin

	self.selection := LOGDOCKET;
	self.clearSelectionDataTable();
	self.tblSelection.visible := true;
	self.tblSelectData.visible := true;
	self.txtDetails.visible := true;
	self.txtDetails.text := null;
	self.splitContainer.showLeftControl(50, true);
	
	// Par 10009 - need to be able to change terminology depending on cargo type is log or log docket
	self.tblActionData.setTerminologyRelevant(self.logDocketCargoType, self.myTerminal);
	self.tblActionData.setRowNamesFromTerminology();
	self.tblSelection.setTerminologyRelevant(self.logDocketCargoType, self.myTerminal);
	self.tblSelection.setRowNamesFromTerminology();
	self.tblSelectData.setTerminologyRelevant(self.logDocketCargoType, self.myTerminal);
	tblDef := app.myController.getEntTableDef(ETDef_SelectionTable);
	self.tblSelectData.setTblDataEntRowsFromDef(tblDef);
	self.tblSelectData.hideColumnByColName(ETRow_BgpPic);
	self.tblSelectData.hideColumnByColName(ETRow_Docket);//1/12/2008 cnwdz2 par18116
