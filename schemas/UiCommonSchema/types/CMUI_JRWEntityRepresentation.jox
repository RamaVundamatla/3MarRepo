<Class name="CMUI_JRWEntityRepresentation" id="2c8b1168-ab86-43ca-869d-3f9c6a0f1f1b">
    <superclass name="CMUI_Transient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Class exists purely as a transient representation of a real JRW report so
it can be quickly looked up in the CMUI_ReportBuilder screen by CMUI_ReportView (the transient
representation of a real JRW view). These representative objects are 
built in the initialization of this form and the refresh.</text>
    <DbClassMap file="cmtrans"/>
