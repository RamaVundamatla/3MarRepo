    <JadeMethod name="shouldAuditProperty" id="3b96a81f-2e8d-455f-b50a-9c163196ddb0">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/
vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_QuantityMap::myChildQuantityMap.name or
		propName = CM_QuantityMap::mappingType.name or
		propName = CM_QuantityMap::allQuantityRanges.name or
		propName = CM_QuantityMap::chargeZero.name  or
		propName = CM_QuantityMap::myCalculationType.name or 
		propName = CM_QuantityMap::mySnapShotQuantityType.name or  // 20/02/2017 cnwma1 TFS #2901
		propName = CM_QuantityMap::myFutureStorageMap.name      // 20/02/2017 cnwma1 TFS #2901
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="1161aefc-9ab8-4b11-a155-602ffce0227d">
        <source>validate();
/*
Purpose:			
Date		Who		Reason
25 March 2015	cnwab1	Initial creation
*/

vars
	qrm : CM_QuantityRangeMap;
begin
	if self.myCalculationType = null
	and self.mySnapShotQuantityType = null	//04 Feb 2019	NDL	TFS 43153
	then
		app.raiseCMException(Pleas_selec_calcu_type_deriv_q,null,null);
	endif;
	
	foreach qrm in self.allQuantityRanges discreteLock do
		qrm.validateMe();
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateInvLineDescUsedTranMap" id="34eb56fd-c0fb-45ca-89f7-34b8f8feb8fe">
        <source>validateInvLineDescUsedTranMap(_invLineDesc : CM_InvoiceLineDesc) : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	map : CM_QuantityRangeMap;
begin
	foreach map in self.allQuantityRanges discreteLock do
		if map.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
