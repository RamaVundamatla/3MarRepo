    </JadeMethod>
    <JadeMethod name="populateTableCams" id="30136d6b-8aac-4b91-adf7-9bad67d73c9a">
        <updating/>
        <source>populateTableCams() updating,protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/


vars
	fromTime, toTime 	: Time;
	protocol			: CM_CamProtocol;	
	protocolHist		: CM_CamTaskHistory;
	theDataLine 		: String;
	table				: CM_DataTable;
	progress			: CMIF_Monitor;	
	numberOfTasks,
	numberDone			: Integer;
	transientCamsHist	: CMIF_CamTaskHistory;
	match				: JadeRegexMatch;
	count				: Integer;
	lastUpdate			: Decimal [20];
	patternCompileException : Boolean;
	patternExceptionMessage : String;
	pattern : JadeRegexPattern;
begin
	on JadeRegexException do self.handleRegexException(exception,patternCompileException,patternExceptionMessage);

	create pattern transient;
	pattern.setAnchored(true).compile(self.txtSearch);
	if not pattern.isCompiled and self.txtSearch &lt;&gt; null then	
		app.raiseCMException1(Regex_pattern_error,patternExceptionMessage,null,null);
	endif;
	
	count := 0;
	app.mousePointer := MP_HOURGLASS;
	
	table 			:= self.tblData;
	table.clearAllSelected;		
	table.rows 		:= 1;
	table.column 	:= 1;
	
	if self.mskTimeStart.getTime().isValid then
		fromTime := self.mskTimeStart.getTime();
	else
		fromTime.setTime(0,0,0,0);
	endif;
	
	if self.mskTimeEnd.getTime().isValid then
		toTime := self.mskTimeEnd.getTime();
	else
		toTime.setTime(23,59,59,999);
	endif;	
	
	self.txtSearch := self.txtMessageSearch.text;
	self.regexSearch := self.chkRegex.value;
	
	self.filterDateFrom.setDate(self.mskDateStart.getDate());
	self.filterDateFrom.setTime(fromTime);
	self.filterDateTo.setDate(self.mskDateEnd.getDate());
	self.filterDateTo.setTime(toTime);

	self.getProtocols();
	self.getCamsStatus();
	
	numberOfTasks := self.getNumberOfTasks();
	
	if numberOfTasks &gt; self.MaxRows then
		if app.msgBox(app.getErrorString(This_searc_over_10000_items_ta), 'Warning', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			self.staStatusBar.caption := (0).String &amp; " rows found.";
			return;
		endif;
	endif;
	
	create progress transient;
	app.myPassport.setMyCMIFMonitor(progress);
	progress.myParent := self;
	if progress &lt;&gt; null then
		//progress.numFound := self.allFilterCamProtocols.size;
		progress.numFound := numberOfTasks;
		progress.message := "Searching Cams Protocols....";
		self.modalDialogShow(null, app.getErrorString(Cancel),null ,OK , app.getErrorString(CMUI_Retreiving_Data), progress.message);
	endif;
	
	lastUpdate := app.relativeMachineTime;
	foreach protocol in self.allFilterCamProtocols do 
		count := count +1;
		foreach protocolHist in protocol.taskHistoryByProtocolSeq reversed do
			if self.includeObjectCams(protocolHist) then
				if self.txtSearch &lt;&gt; null then
					if self.regexSearch then 
						create match transient;
						if not JadeRegex@findFirst(protocolHist.getRawDataString, self.txtSearch,true, false, match) then
							continue;
						endif;
					elseif not self.regexSearch and not protocolHist.stringInFileData(self.txtSearch) then
						continue;
					endif;
				endif;
				create transientCamsHist transient;
				if match &lt;&gt; null then
					transientCamsHist.setFoundString(match.value);
				else
					transientCamsHist.setFoundString(self.txtSearch);
				endif;
				transientCamsHist.setRealObj(protocolHist);
				theDataLine := transientCamsHist.getAttributeStringForDefArray(table.allTblDataEntRows);
				table.accessRow(table.addItem(theDataLine)).itemObject := protocolHist;
			endif;
			
			numberDone := numberDone + 1;
			if (app.relativeMachineTime - lastUpdate) &gt; 500 then
				if progress &lt;&gt; null then
					if not progress.updateProgress(progress.message, numberOfTasks, table.rows) then
						return;
					endif;
				endif;
				lastUpdate := app.relativeMachineTime;
			endif;
			delete match;
			delete transientCamsHist;
		endforeach;	
	endforeach;
	
	self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows);
	self.staStatusBar.caption := (tblData.rows - tblData.fixedRows).String &amp; " rows found.";	
	/*
	For use if we extend to use the EWS functionality like in the ExternalWebServices Monitor
	 
	create allEWSActivities transient;														
	
	if not self.allFilterCamProtocols.isEmpty then													
		foreach protocol in self.allFilterCamProtocols do											
			foreach eWSActivity in protocol.allEWSCamsActivities do							
				allEWSActivities.add(eWSActivity);											
			endforeach;																		
		endforeach;																			
	else
		allEWSActivities := app.myRoot.allEWSActivities;
	endif;
	*/
	
	//self.populateTable(allEWSActivities);
	
epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete progress;
	self.frmModalDialog.visible := false;
	delete match;
	app.mousePointer := MP_DEFAULT;	
	delete transientCamsHist;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupCamsProtocolsTbl" id="692066f7-dc68-4044-b79e-47188b017f33">
        <source>setupCamsProtocolsTbl();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars
	prot : CM_CamProtocol;
	idx : Integer;
	terminal : CM_Terminal;
begin	
	terminal := self.myTerminal;
	
	if terminal &lt;&gt; null then
		foreach prot in terminal.camProtocols discreteLock do
			if not self.tblCamsProtocols.findObject(prot, idx) then 
				self.tblCamsProtocols.addItemObject(Tab &amp; terminal.code &amp; " - " &amp; prot.code, prot);
			endif;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e3b6d030-2400-4fd4-95d8-b11037d31e51">
        <updating/>
