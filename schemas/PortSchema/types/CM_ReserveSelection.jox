    <JadeMethod name="getNonStagedAvailSTW" id="118c6bfa-9c0b-44f9-9c8a-297581b0b98b">
        <source>getNonStagedAvailSTW(_tiSet: CM_TISet input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626

*/

vars
	cargoType : CM_CargoType;
	iter : Iterator;
	startTi : CM_TrackedItem;
	ti : CM_TrackedItem;
	reason : String;
	opTerm : CM_OperatorTerminal;
	product : CM_Product;
	xtraReleaseCriteria : CM_ReleaseByTypeCriteria;
	criteria : CM_YACriteria;
	cargoId : String;
	cargoGroupId : String;
	cg : CM_CargoGroup;
	localDict : CM_TIByCargoTypeIdDict;
	skipAttributes : IntegerArray;	//11 Jan 2016	NDL	TFS 3189/2876
	terminal : CM_Terminal;
begin
	
	if _tiSet = null then
		return;
	endif;

	if self.myReserveHeader = null then
		return;
	endif;
	opTerm := self.myReserveHeader.myOperatorTerminal;
	if opTerm = null then
		return;
	endif;

	cargoType := self.getCargoType;
	if cargoType = null then
		return;
	endif;
	terminal:=self.getMyTerminal;
	
	product := self.getMyProduct;
	
	//OK see if we have any extra criteria that we can really use.
	xtraReleaseCriteria:= self.myReleaseCriteria;
	if xtraReleaseCriteria &lt;&gt; null then
		criteria := xtraReleaseCriteria.getCriteriaFor(YACriteriaType_ID);
		if criteria &lt;&gt; null then
			cargoId := criteria.getDisplayForYAMTableColumn;
		endif;
		criteria := xtraReleaseCriteria.getCriteriaFor(YACriteriaType_CargoGroup);
		if criteria &lt;&gt; null then
			cargoGroupId := criteria.getDisplayForYAMTableColumn;
		endif;
	endif;
	
	// Find / build the best collection of ti's to use and start an iterator
	if cargoGroupId &lt;&gt; null then
		cg := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq( cargoGroupId , null ).CM_CargoGroup;
		if cg &lt;&gt; null and cg.id = cargoGroupId then
			// we  have a cargo group to use, get a collection of the on-site cargo from it.
			create localDict transient;	
			iter := cg.allAssignedTrackedItems.createIterator;
			while iter.next(ti) do
				if not ti.isOnSite then
					continue;
				endif;
				if ti.isNotified or ti.myPrimaryActualLocation = null then
					continue;
				endif;
				localDict.add(ti);
			endwhile;
			delete iter;
			
			if not localDict.isEmpty then
				//there is some potential data, start an iterator
				iter := localDict.createIterator;
				startTi := localDict.getAtKeyGeq( cargoType.id, cargoId);
		
			endif;
			
		endif;
	
	else
		iter := opTerm.allOnsiteTIsByCargoTypeId.createIterator;
		startTi := opTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType.id, cargoId);
		
	endif;
		
	if startTi &lt;&gt; null and startTi.myCargoType = cargoType then
	
		//11 Jan 2016	NDL	TFS 3189/2876
		if self.myReserveHeader.isShipType then
			//testing against the reserve selection needs to ignore Voyage, Discharge Port and IMEX,
			//because these are unconditionally reset when assigned to the ship release during staging
			create skipAttributes transient;
			skipAttributes.add( YACriteriaType_Voyage );
			skipAttributes.add( YACriteriaType_DischargePort );
			skipAttributes.add( YACriteriaType_ImexStatus );
		endif;
		
		// ok we have an iterator and a tracked item to start from
		iter.startAtObject( startTi );
		while iter.next(ti) do
			if ti.myCargoType &lt;&gt; cargoType then	// check the cargo type.
				break;
			endif;
			if cargoId &lt;&gt; null then // if we found a cargo id in teh xtra criteria on the reserve selection check it
				if cargoId &lt;&gt; ti.id then
					break;
				endif;
			endif;
			if product &lt;&gt; null then	// if we found a product on the reserve selection, check it
				if ti.myProduct &lt;&gt; product then
					continue;
				endif;
			endif;
			if not ti.testAgainstReserveSelection( self, reason, true, skipAttributes ) then
				continue;
			endif;
			if not self.myReserveHeader.allowCargoOnMultipleReleases and not ti.allBulkReleasesAssigned.isEmpty then
				if ti.allBulkReleasesAssigned.size = 1 and ti.allBulkReleasesAssigned.first = self.myReserveHeader then
					//that's OK.
				else
					continue;
				endif;
			endif;
			if ti.isStagedFor( self.myReserveHeader ) then	//22 Mar 2016	NDL	
				continue;
			endif;
			if ti.isAvailableToStageFor(  self.myReserveHeader ) then
				_tiSet.addNoDuplicates( ti, false );
			endif;
		endwhile;
	endif;
	

epilog

	delete localDict;
	delete iter;
	delete skipAttributes;
end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getOtherProspectsForSTW" id="25bbab57-d23b-40f4-ab34-b7bb2a3325df">
        <source>getOtherProspectsForSTW(	_targetLocation : CM_LocationsController;
							_localTiSet : CM_TISet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2017	cnwndl1	Initial creation	TFS 4016
// 11 Jan 2018	cnwrs1	TFS 36603 STW fix locking issue
22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group
10 Jul 2024 navlc30 Bug 63707: EUP - 1090 Exception when clicking on the Pack button for the retrospective Pack jobs
19 Aug 2024 navhl20	ChangeRequest 65650: FR | 54177 - Retrospective Operations - Packing
21 Oct 2024 navhl20 Bug 23340: MTN - Performance issues and locks when completing the Retrospective Pack jobs
*/

vars

	bulkRelease : CM_BulkRelease;
	opTerm : CM_OperatorTerminal;
	ti : CM_TrackedItem;
	reason : String;
	iter : Iterator;
	cargoType : CM_CargoType;
	startObject : CM_TrackedItem;
	
	//19 Dec 2018	NDL	TFS 38083
	cargoGroup : CM_CargoGroup;
	localSearchDict : CM_TIByCargoTypeIdDict;
	cargoGroupId : String;
	cargoId : String;
	lc : CM_LocationsController;
begin

	bulkRelease := self.myReserveHeader;
	
	//19 Dec 2018	NDL	TFS 38083
	//cargoGroupId := self.getMyCargoGroupId;
	//if cargoGroupId &lt;&gt; null then
	cargoGroup := self.getMyCargoGroupObj(); //22/06/2023	navkc1	CR 57496 Task 58405
	if cargoGroup &lt;&gt; null then
		create localSearchDict transient;
		cargoGroup.allAssignedTrackedItems.copy( localSearchDict );
	endif;
	//endif;
	
	cargoId := self.getMyCriteriaCargoId;	//19 Dec 2018	NDL	TFS 38083
	cargoType := self.myCargoType;

	// get the prospective children - i.e. they are for the operator and match the release details
	opTerm := bulkRelease.myOperatorTerminal;
	if opTerm &lt;&gt; null then
		
		//19 Dec 2018	NDL	TFS 38083
		if localSearchDict &lt;&gt; null then
			iter := localSearchDict.createIterator;
			startObject := localSearchDict.getAtKeyGeq(cargoType.id, cargoId);
		else
			iter := opTerm.allOnsiteTIsByCargoTypeId.createIterator;
			startObject := opTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq(cargoType.id, cargoId);
		endif;
		
		if startObject &lt;&gt; null then
			cargoId := cargoId.toUpper;														//21.10.2024 navhl20 #23340
			iter.startAtObject(startObject);
			while iter.next(ti) do
				if ti.cargoType &lt;&gt; cargoType.id then
					break;
				endif;
				
				//19 Dec 2018	NDL	TFS 38083
				if cargoId &lt;&gt; null then
					if ti.id.toUpper &lt;&gt; cargoId then										//21.10.2024 navhl20 #23340
						break;
					endif;
				endif;
				
				lc := ti.myPrimaryActualLocation;											//21.10.2024 navhl20 #23340
				if lc = null then
					continue;
				endif;
				if bulkRelease.isPackingType then
					if ti.isContainer or ti.isChassis then
						//will be associated so as to be a parent not a child.
						continue;
					endif;
					if ti.isChild then
						//already packed
						continue;
					endif;
					/*
					//19.08.2024 navhl20 #65650
					if not ti.isAvailableForPackingChild() then				//10.07.2024 navlc30 #63707
						continue;
					endif;*/
				else
					
					if ti.isChild then
						continue;
					endif;
					
					if lc = _targetLocation then											//21.10.2024 navhl20 #23340
						continue;
					endif;
					if bulkRelease.isRoadType then  
						if lc.isVehicle then												//21.10.2024 navhl20 #23340
							continue;
						elseif lc.isTILCController then										//21.10.2024 navhl20 #23340
							continue;
						endif;
					elseif bulkRelease.isRailType then	//09 Jun 2020	NDL	TFS 49537 
						if lc.isWagon then													//21.10.2024 navhl20 #23340
							continue;
						endif;
					endif;
				endif;
				if not ti.testAgainstReserveSelection( self, reason, true, null ) then
					continue;
				endif;
				if ti.bulkReleaseAssignedCode &lt;&gt; null and ti.bulkReleaseAssignedCode &lt;&gt; bulkRelease.code then
				// don't want this one, as reserved for someone else
					continue;
				endif;
				_localTiSet.tryAdd( ti );		
			endwhile;
		endif;
	endif;

epilog
	delete iter;
	delete localSearchDict;
end;</source>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_localTiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProductCode" id="3ed6e550-d07f-4b52-a6c6-5fb7f17f9248">
        <source>getProductCode():String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
10 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars
	product : CM_Product;
begin
	
	product := self.myProduct;
	
	if product = null then
		return null;
	endif;
	
	return product.code;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductDescr" id="91efd2dc-edc1-48b9-ac2b-7ddf6e976813">
        <source>getProductDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	21 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	product : CM_Product;
