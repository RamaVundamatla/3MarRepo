<Class name="CM_ROROGeneralArea" id="505d26de-5ff7-4e1f-adb3-da66b9c5b99a">
    <superclass name="CM_DeckItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is referred to as "General Areas" on the user side</text>
    <DbClassMap file="vesselStructures"/>
    <PrimAttribute name="weight" id="fbaae2a3-4768-43b8-9ca3-d8a68e6d826e">
        <precision>12</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cloneMySelf" id="5fbabbcd-2de2-4637-b412-6def97ecb937">
        <source>cloneMySelf(_newDeck : CM_Deck; _copy : Boolean) : CM_ROROGeneralArea;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	deckItem : CM_DeckItem;
	newMe : SelfType;
begin
	newMe := self.cloneSelf(_copy);


	newMe.myDeck := _newDeck;
	
	if self.myLayout &lt;&gt; null then
		newMe.myLayout := self.myLayout.cloneMySelf(newMe, newMe.getLayer(), _copy);
	endif;
	
	return newMe;
epilog

end;</source>
        <Parameter name="_newDeck" type="CM_Deck"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_ROROGeneralArea"/>
    </JadeMethod>
    <JadeMethod name="delete" id="8fdfc40d-7ae6-40ce-8864-26a0b53aefc9">
        <updating/>
        <source>delete() updating;
/*
Date		    Who			Reason
17 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if self.isTransient then
		return;
	endif;
	
	if self.myDeck &lt;&gt; null then
		self.myDeck.causeEvent(EVENT_DECK_ITEM_DELETE,false,self);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="93b935cf-5460-4b62-ab20-5e44d9c4d480">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		    Who			Reason
16 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if _attrName = ETRow_IsMovable then
		return null;
	elseif _attrName = ETRow_Length then
		return null;
	elseif _attrName = ETRow_Width then
		return null;
	elseif _attrName = ETRow_MaxClearHeight  then
		return null;
	elseif _attrName = ETRow_MaxLoadAxel then
		return null;
	elseif _attrName= ETRow_MaxLoadM2 then
		return null;
	elseif _attrName = ETRow_MaxTotalWeight then
		return null;
	elseif _attrName = ETRow_TotalWeight then
		return self.weight.asStringJMT();
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
