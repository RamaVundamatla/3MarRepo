    <JadeMethod name="loadTabCargoRelease" id="e7f11870-7703-458a-b476-697e4c07b535">
        <updating/>
        <source>loadTabCargoRelease()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
26 Dec 2022 navdp20 ChangeRequest 56661:[56012] - Add Transport Mode to Receive and Release work orders
03 Feb 2023	navcs2	ChangeRequest 55440:[54990] EUP - Cargo Work Order Enhancements
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
20 Apr 2023 navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
05 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
09 Jun 2023 navhl20 ChangeRequest 57745: EUP - Delivery Dispatch – Allocation List - Road
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
19 Jul 2023 navhl20 Bug 59200: MTN - Release Rail Work order showing Prenote Button
01 Nov 2023 navhl20 Bug 61057: EUP - Invalid Property exception when selecting a Pack Task to the already existing Work Order
03 Feb 2025	navhl20 Bug MTN-33951: MTN | Release WO change transport mode is not showing anything in available cargo table
27 May 2025	navpw1	JIRA: MTN-34974 - Need to have the Change of Transport button enabled for Part Complete Work Orders
24 Sep 2025 navhl20 Defect MTN-36128: Error 4 exception on the cargo work order new screen when deleting the reserve detail from the release request
*/

vars
	cargoType		: CM_CargoType;
	wodReleaseTask	: CM_WodRelease;
	bulkRel			: CM_BulkRelease;
	obj				: Object;
begin
	if self.myPxyTask = null then
		return;
	endif;
	
	if self.hasVasSubscription and self.workOrderMode = self.MODE_ADD then
		self.cmbTransMode.enabled := true;
	endif;
	
	if app.myCurrentUserCan(self.myTerminal, PmGteEmptyReleaseMaintAll) then
		self.btnMaintainRelease.visible := true;
	endif;
	
	self.shtRelease.visible			:= true;
	self.shtToDoTasks.visible		:= true;
	self.btnCreateCargo.visible 	:= false;					//06.7.2023 navhl20 #58952			//19.7.2023 navhl20 #59200
	self.tblItems.visible			:= true;														//01.11.2023 navhl20 #61057
	
	self.grpReleaseItems.visible 	:= true;
	self.fldCargo.topSheet  		:= self.shtRelease;

	self.lblTransMode.visible 	   := true;
	self.cmbTransMode.visible 	   := true;
	self.lblTransMode.parent 	   := self.grpReleaseDetails;
	self.cmbTransMode.parent 	   := self.grpReleaseDetails;
	self.lblTransport.parent 	   := self.grpReleaseDetails;
	self.cmbTransport.parent 	   := self.grpReleaseDetails;
	self.tblItems.parent 		   := self.grpReleaseItems;   
	self.btnChangeTransport.parent := self.grpTaskDetails;									// ### TFS 59411 (61855) 22Dec2023 NAVPW1 - Had wrong parent
	
	self.lblReleaseRequest.parent 	   := self.grpReleaseDetails;							//18.4.2023 navhl20 #55442[57629]
	self.cmbReleaseRequest.parent 	   := self.grpReleaseDetails;							//18.4.2023 navhl20 #55442[57629]
	self.btnMaintainRelease.parent 	   := self.grpReleaseDetails;							//18.4.2023 navhl20 #55442[57629]
	self.lblReleaseRequest.top 	   	   := 137;												//18.4.2023 navhl20 #55442[57629]
	self.cmbReleaseRequest.top 	  	   := 137;												//18.4.2023 navhl20 #55442[57629]
	self.btnMaintainRelease.top 	   := 137;												//18.4.2023 navhl20 #55442[57629]
	
	self.lblCustomsClearanceNo.visible  := false;
	self.txtCustomsClearanceNo.visible  := false;
	
	if self.workOrderMode = self.MODE_UPDATE then													//3.2.2023 navhl20 #56631[56185]
		// ### TFS 59411 (61855) 22Dec2023 NAVPW1
		wodReleaseTask := self.myPxyTask.CM_WodRelease;
		self.btnChangeTransport.visible := self.hasVasSubscription;
		
		if wodReleaseTask.status = WO_STATUS_COMPLETE then
			self.btnChangeTransport.enabled := false;
		else
			self.btnChangeTransport.enabled := self.hasVasSubscription;
		endif;
		// ### TFS 59411 (61855) 22Dec2023 NAVPW1
		if wodReleaseTask.status &lt;&gt; WO_STATUS_ACTIONED and wodReleaseTask.status &lt;&gt; WO_STATUS_PARTCOMPLETE then	//03.02.2025 navhl20 #33951 // ### JIRA: MTN-34974 27May2025 NAVPW1
			bulkRel := wodReleaseTask.myReleaseRequest;
			if bulkRel &lt;&gt; null and bulkRel.releaseByType then
				self.btnChangeTransport.enabled := false;
			endif;
		endif;
	endif;

	obj := self.cmbReserveDetail.listObject;													//24.09.2025 navhl20 #36128
	if obj &lt;&gt; null then 																		//17.04.2023 navma1 #57324:[57325]								
		cargoType := obj.CM_ReserveSelection.myCargoType;
	endif;
	self.buildListToDoTasks(cargoType);
	
	/*Populate Task Details */
	//self.buildCmbRelease();
	self.buildOptBtnsRelease();
	self.buildCmbTransportMode();															//26.12.2022 navdp20 TFS 56661[56012]
	self.txtCustomsClearanceNo.text	:= self.myPxyTask.CM_WodRelease.customsClearanceNumber;
	self.maintainBtnAttachCargo();
	
	if self.isApproved then
		self.grpReleaseDetails.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabCargoTis" id="4b149430-b9e0-4bf1-b713-cf979d442d47">
        <source>loadTabCargoTis();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
09 Mar 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
30 Mar 2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement
17 Apr 2023 navhl20 ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
06 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
23 May 2024 navhl20 Bug 64258: MTN - Cargo work order takes significant time to click between tasks
04 Jun 2024 navlc30 Bug 64240: MTN - Cargo Work Order New Screen slow when many cargo items
24 Jul 2025 navhn30 MTN-35315: MTN | Pagination - Work Order Maintenance
*/

vars
	entTableDef : EntTableDef;
	tbl			: CM_DataTable;
	xmlStr		: String;
	tiSet		: CM_TISet;
	isShip		: Boolean;
	form 		: CM_BaseForm;	
begin
	if self.workOrderType &lt;&gt; WorkOrderMode_Cargo then
		return;
	endif;
	
	entTableDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);	
	tbl			:= self.tblSelectedCargo;
	
	xmlStr := self.enquiryTypeDef_Cargo;

	if xmlStr &lt;&gt; null then
		self.tblSelectedCargo.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		tbl.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	if self.myPxyTask = null then								//06.03.2023 navma1 #56457:[56458]
		self.updateCargoTabNumber();							//30.03.2023 navcs2	#55440:[54990]
		return;
	endif;
	
	self.btnCreateCargo.top 	  := self.tblSelectedCargo.height + self.tblSelectedCargo.top + 10;			//29.3.2023 navhl20	#55443[54991]
	
	tbl.setMyDataClass(CM_TrackedItem);
	tbl.fixedColumns    := 0;
	tbl.fixedRows 	    := 1;
	tbl.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	tbl.selectionType   := CM_DataTable.SelectionType_Row;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(tbl);
	
	create tiSet transient;																										//06.12.2023 navhl20 #58400[61617]	
	isShip := false;																											//06.12.2023 navhl20 #58400[61617]
	if self.myPxyTask.isKindOf(CM_WorkOrderTIDtl) and self.myPxyTask.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP then				//06.12.2023 navhl20 #58400[61617]
		isShip := true;
	endif;
	if isShip and self.myPxyTask.status &lt;&gt; WO_STATUS_COMPLETE then																//06.12.2023 navhl20 #58400[61617]
		self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.copyNoDuplicates(tiSet,false);
		self.myPxyTask.CM_WorkOrderTIDtl.allCompleteTIs.copyNoDuplicates(tiSet,false);
	elseif isShip and self.myPxyTask.status = WO_STATUS_COMPLETE then
		self.myPxyTask.CM_WorkOrderTIDtl.allCompleteTIs.copyNoDuplicates(tiSet,false);
	else	
		self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.copyNoDuplicates(tiSet,false);
	endif;
	
	if self.myPxyTask &lt;&gt; null  then															//13.03.2023 navma1 #56457:[56458]
		form := self;													//04.06.2024 navlc30 #64240																																																													
		//tbl.getDataAndDisplayRowsMultith(tiSet, true, form, true);
		tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, tiSet, true); //24.07.2025	navhn30  MTN-35315
	endif;
	
	if self.workOrderMode = self.MODE_ADD then												//23.05.2024 navhl20 #64258
		self.updateCargoTabNumber();														//08.02.2023 navma1 #56457:[56458]
	endif;
	self.maintainBtnAttachCargo();															//30.03.2023	navcs2  #55440:[54990]
	self.enableSelectCargoBtn();								//04.07.2023 navma1 #58952
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabCargoToDo" id="7bc0c5ea-b05e-4a25-b1c6-42df41c058bb">
        <updating/>
        <source>loadTabCargoToDo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
03 Aug 2022	navcs2	Bug 54402: MTN - Work Order Maintenance - The 'Selected Cargo Items' Is Not Shown Correctly in Voyage Work Order Creation Screen
7  Mar 2023	navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
17 Mar 2023	navcs2	ChangeRequest 56842:[56843]: EUP - VAS Task Priority
20 Mar 2023 navma1  Defect 57195: MTN - WO - Priority is showing some random number on the to do work orders on the yard operations form
29 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
06 Apr 2023 navhl20 ChangeRequest 57477:[57478] EUP - Moving No charge Option to be under Financial Tab
13 Oct 2023 navhl20 Bug 60868: EUP- Work Order New Form has  issues on Remarks Textbox and High Priority Checkbox
*/

vars
	wodtl :		CM_WodToDo;
begin
	if self.myPxyTask = null then
		return;
	endif;
	
	self.setTodoDetails(true);								//13.10.2023 navhl20 #60868
	//self.shtToDo.visible		:= true;					//7.3.2023 navhl20	#56614[56615]
	self.shtToDoTasks.visible	:= true;
	// 03/08/2022 navcs2 Bug 54402
	//self.fldCargo.topSheet  	:= self.shtToDo;			//7.3.2023 navhl20	#56614[56615]
	/*pending*/
	self.fldCargo.topSheet  	:= self.shtToDoTasks;
	//self.grpToDo.enabled		:= not self.isApproved;		//7.3.2023 navhl20	#56614[56615]
	self.mulToDoTasks.enabled	:= not self.isApproved;		//7.3.2023 navhl20	#56614[56615]
	
	// Move round some controls from the VAS work orders
	//self.chkPriority.parent		:= self.shtToDoTasks;		//17.03.2023	navcs2	#56842:[56843]			//13.10.2023 navhl20 #60868
	//self.lblToDoPriority.parent	:= self.shtToDoTasks;		//17.03.2023	navcs2	#56842:[56843]			//13.10.2023 navhl20 #60868
	//self.chkNoCharge.parent		:= self.shtToDoTasks;		//17.03.2023	navcs2	#56842:[56843]			//06.4.2023 navhl20	#57477[57478]
	//self.lblToDoNoCharge.parent	:= self.shtToDoTasks;		//17.03.2023	navcs2	#56842:[56843]			//06.4.2023 navhl20	#57477[57478]
	//self.txtToDoRemarks.parent	:= self.shtToDoTasks;		//17.03.2023	navcs2	#56842:[56843]			//13.10.2023 navhl20 #60868
	//self.lblToDoRemarks.parent	:= self.shtToDoTasks;		//17.03.2023	navcs2	#56842:[56843]			//13.10.2023 navhl20 #60868
	//self.txtToDoRemarks.parentAspect := 9;																	//13.10.2023 navhl20 #60868
	// Set values from the proxy
	wodtl := self.myPxyTask.CM_WodToDo;						//17.03.2023	navcs2	#56842:[56843]
	self.chkNoCharge.value 		:= wodtl.noCharge;			//17.03.2023	navcs2	#56842:[56843]
	self.txtToDoRemarks.text 	:= wodtl.remarks;			//17.03.2023	navcs2	#56842:[56843]
	if wodtl.priority = CM_WorkOrder.WO_Priority_High then	//17.03.2023	navcs2	#56842:[56843]	//20.03.2023 navma1 #57195
		self.chkPriority.value := true;						//17.03.2023	navcs2	#56842:[56843]
	else													//17.03.2023	navcs2	#56842:[56843]
		self.chkPriority.value := false;					//17.03.2023	navcs2	#56842:[56843]
	endif;													//17.03.2023	navcs2	#56842:[56843]
	self.txtInvContractId.text := wodtl.contractId;			//29.3.2023 navhl20 57301:[57303]

	if app.myPassport.isVASEnabled() then					//17.03.2023	navcs2	#56842:[56843]
		self.loadTabToDoSpecialRate();						//17.03.2023	navcs2	#56842:[56843]
		self.shtFinancial.parent	:= self.fldCargo;		//17.03.2023	navcs2	#56842:[56843]
		self.cmbDebtors.visible := false; // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
		self.lblDebtorFinance.visible := false; // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
		self.shtFinancial.visible	:= true;				//17.03.2023	navcs2	#56842:[56843]
	endif;													//17.03.2023	navcs2	#56842:[56843]
	
	//buildListToDoTasks();									//7.3.2023 navhl20	#56614[56615]
	//self.buildCmbToDo(myPxyTask.CM_WodToDo);				//7.3.2023 navhl20	#56614[56615]
	self.buildWOToDoList(myPxyTask.CM_WodToDo);				//7.3.2023 navhl20	#56614[56615]
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabCargoUnPack" id="6de80b4f-89ab-4d07-a43d-d4f4b7c985ef">
        <updating/>
        <source>loadTabCargoUnPack()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
21 MAr 2023 navma1  Defect 57205: MTN - WO - Unexpected Program error when adding cargo items to Unpack work order
20 Apr 2023 navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
*/

vars

begin
	if self.myPxyTask = null then
		return;
	endif;
	
	//self.myAssistant.combBoxTargetArea(self.cmbUnpkToLocal, null);	//21.03.2023 navma1 #57205
	self.myAssistant.combBoxUnPackLocation(self.cmbUnpkToLocal, null);  //21.03.2023 navma1 #57205
	
	self.shtUnPack.visible				:= true;
	self.shtToDoTasks.visible			:= true;
	self.fldCargo.topSheet  			:= self.shtUnPack;
	self.grpUnPackDetails.enabled		:= not self.isApproved;			//06.03.2023 navma1 #56457:[56458]
	
	buildCmbUnPack();
	buildListToDoTasks(null);											//17.04.2023 navma1 #57324:[57325]

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabToDoDetails" id="086c9e44-4b27-456d-95d7-708c64ee53a2">
        <source>loadTabToDoDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
15 Dec 2022	navcs2	 ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
02 Mar 2023	navtnr20 Task 56815: EUP - Work Order Contract Id
17 Mar 2023	navcs2	 ChangeRequest 56842:[56843]: EUP - VAS Task Priority
20 Mar 2023 navma1   Defect 57195: MTN - WO - Priority is showing some random number on the to do work orders on the yard operations form 
06 Apr 2023 navhl20  ChangeRequest 57477:[57478] EUP - Moving No charge Option to be under Financial Tab
*/

vars
	
begin
	
	self.buildListVasToDoTasks();
	
	if self.myPxyTask &lt;&gt; null then
		self.txtToDoRemarks.text 	 := self.myPxyTask.CM_WorkOrderToDoDtl.remarks;
		//self.chkNoCharge.value 		 := self.myPxyTask.CM_WorkOrderToDoDtl.noCharge;		//06.4.2023 navhl20	#57477[57478]
		self.txtInvContractId.text 	 := self.myPxyTask.CM_WorkOrderToDoDtl.contractId;  		//navtnr20 02-03-2023 56815
		if self.myPxyTask.CM_WorkOrderToDoDtl.priority = CM_WorkOrder.WO_Priority_High then		//17.03.2023	navcs2	#56842:[56843]  //20.03.2023 navma1 #57195
			self.chkPriority.value := true;														//17.03.2023	navcs2	#56842:[56843]
		else																					//17.03.2023	navcs2	#56842:[56843]
			self.chkPriority.value := false;													//17.03.2023	navcs2	#56842:[56843]
		endif;																					//17.03.2023	navcs2	#56842:[56843]
	endif;																						//17.03.2023	navcs2	#56842:[56843]
	
	if self.isApproved then				//20.03.2023 navma1 #57195
		//self.chkNoCharge.enabled 	  := false;													//06.4.2023 navhl20	#57477[57478]
		self.chkPriority.enabled 	  := false;
		if not self.workOrderMode = self.MODE_UPDATECOMPLETED then  //13/11/2024	navkc1 JIRA Story MTN-33012 Allow user to update in this mode
			self.txtInvContractId.enabled := false;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabToDoEntities" id="945828e2-099f-4fb5-99a2-35b96a3ddde7">
        <source>loadTabToDoEntities();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
20 Mar 2023 navma1  Defect 57195: MTN - WO - Priority is showing some random number on the to do work orders on the yard operations form 
*/

vars

begin
	if self.myPxyTask.isKindOf(CM_WodToDoNonOperational) then
		self.buildListVasNonOperational();
	elseif self.myPxyTask.isKindOf(CM_WodToDo) then
		//self.buildListVasCargoGroup();
	elseif self.myPxyTask.isKindOf(CM_WodToDoTrain) then
		self.buildListVasTrains();
	elseif self.myPxyTask.isKindOf(CM_WodToDoVBS) then
		self.buildListVasVBSlots();
	elseif self.myPxyTask.isKindOf(CM_WodToDoVehicleVisit) then
		self.buildListVasTrucks();
	elseif self.myPxyTask.isKindOf(CM_WodToDoWagon) then
		self.buildListVasWagons();
	elseif self.myPxyTask.isKindOf(CM_WodToDoVoyage) then
		self.buildListVasVoyages();
	elseif self.myPxyTask = null then
		self.clearMulToDoLists();
	endif;
	
	if self.isApproved then	//20.03.2023 navma1 #57195
		self.mulToDoEntity.enabled 			 := false;
		self.mulToDoSecondaryEntites.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabToDoSpecialRate" id="064ad370-ae63-4489-b5ca-93df7c5cdff8">
        <updating/>
        <source>loadTabToDoSpecialRate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
15 Dec 2022	navcs2	 ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
13 Mar 2023 navtnr20 Task 56815: EUP - Work Order Contract Id
20 Mar 2023 navma1  Defect 57195: MTN - WO - Priority is showing some random number on the to do work orders on the yard operations form 
06 Apr 2023 navhl20 ChangeRequest 57477:[57478] EUP - Moving No charge Option to be under Financial Tab
10 May 2023 navma1	Bug 57906: EUP - Financial Tab disappear after selecting VAS Task
*/

vars
	
begin
	self.shtFinancial.visible := true;														//10.05.2023 navma1 #57906
	/* // ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1
	self.buildCmbCalculationType();
	self.buildCmbChargeTo(self.cmbCalculationType.listObject.CM_CalculationType);
	self.formatSpecialRateTxtBox();
	*/
	if self.myPxyTask.isKindOf(CM_WorkOrderToDoDtl) then									//06.4.2023 navhl20	#57477[57478]
		self.chkNoCharge.value 	:= self.myPxyTask.CM_WorkOrderToDoDtl.noCharge;
	endif;
	
	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	if self.myPxyTask.isKindOf(CM_WodToDoNonOperational) then
		self.cmbDebtors.visible := false;
		self.lblDebtorFinance.visible := false;
	else
		self.cmbDebtors.visible := true;
		self.lblDebtorFinance.visible := true;
		if self.myPxyTask.isKindOf(CM_WorkOrderToDoDtl) then
			self.populateCmbDebtors(self.cmbDebtors, self.myPxyTask.CM_WorkOrderToDoDtl.myDebtor);
		endif;
	endif;
	
	if self.isApproved and																	//20.03.2023 navma1 #57195
		not self.workOrderMode = self.MODE_UPDATECOMPLETED then 							//13/11/2024	navkc1 JIRA Story MTN-33012 - Allow user to update in this mode
		 // ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1self.cmbCalculationType.enabled := false;
		 // ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1self.cmbChargeTo.enabled		:= false;
		 // ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1self.txtSpecialRate.enabled     := false;
		self.txtInvContractId.enabled	:= false;
		self.chkNoCharge.enabled		:= false;											//06.4.2023 navhl20	#57477[57478]
		self.cmbDebtors.enabled := false;  // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabVoyageBillAdjust" id="d491d474-d3d5-4ddb-be23-abdc84e7f73d">
        <updating/>
        <source>loadTabVoyageBillAdjust() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	
begin
	if self.myPxyTask = null then
		return;
	endif;
	
	self.shtBillingAdj.visible		:= true;
	buildCmbBillingAdj();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabVoyageCancelReq" id="86b67cc1-95cd-47ce-bb6b-7e7436b6c46f">
        <updating/>
        <source>loadTabVoyageCancelReq() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	cancelWorkOrder : CM_WorkOrder;
	idx : Integer;	
begin
	if self.myPxyTask = null then
		return;
	endif;
	
	self.shtHMSCancel.visible		:= true;
	buildCmbCancelReq();
	
	// Cancel HMS Request tab
	if self.myPxyTask &lt;&gt; null and self.myPxyTask.isKindOf(CM_WodHMSRequestCancel) then
		if self.myPxyTask.CM_WodHMSRequestCancel.myWorkOrderToCancel &lt;&gt; null then
			cancelWorkOrder := self.myPxyTask.CM_WodHMSRequestCancel.myWorkOrderToCancel;
		endif;
	endif;
	
	// 25/08/2022 navcs2 #54417
	self.myAssistant.comboBoxVoyageWorkOrders(self.cmbWorkOrderC, self.myVoyage, cancelWorkOrder, null); 
	
	if self.myWorkOrder &lt;&gt; null then
		idx := self.cmbWorkOrderC.findString(1, self.myWorkOrder.id);
		if idx &gt; 0 then
			self.cmbWorkOrderC.removeItem(idx);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabVoyageCargoReq" id="34f7197a-32c2-4015-905a-631d01b46699">
        <updating/>
        <source>loadTabVoyageCargoReq() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
09 Sep   2022	navcs2	Bug 54736: MTN - Work Orders - Discharge Port dropdown for Cargo Request is not showing based on the selected voyage
*/

vars
	voyage : CM_Voyage;	
	transferType : CM_VoyageJobTransferType;
	proxyTask : CM_WorkOrderDtl;
begin
	if self.myPxyTask = null then
		return;
	endif;
	
	self.shtVoyageResources.visible	:= true;
	self.shtCargoRequest.visible		:= true;
	self.fldVoyage.topSheet := self.shtCargoRequest;
	
	// Cargo Request tab
   	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType, null);
	self.cmbCargoType.removeObject(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	self.cmbCargoType.removeObject(app.myRoot.allCargoTypesById[TI_CargoType_COU]);
	self.cmbCargoType.removeObject(app.myRoot.allCargoTypesById[TI_CargoType_Generator]);
	self.cmbCargoType.removeObject(app.myRoot.allCargoTypesById[TI_CargoType_Tower]);
	self.myAssistant.comboBoxOperator(self.cmbOperator, null, myVoyage);
	self.myAssistant.comboBoxConsignor(self.cmbConsignee, null, CONSIGNEE);
	self.myAssistant.comboBoxConsignor(self.cmbConsignor, null, CONSIGNOR);
	self.myAssistant.comboBoxConsignor(self.cmbFreightFwdr, null, FREIGHT_FORWARDER);
	self.myAssistant.comboBoxIMEXStatus(self.cmbImexStatus, null);
	self.cmbDischargePort.myTerminal := self.myTerminal;
	self.cmbDischargePort.myAssistant := self.myAssistant;
	
	// 09 Sep 2022	 navcs2		Bug 54736
	proxyTask := self.myPxyTask;
	if myVoyage &lt;&gt; null and proxyTask.isKindOf(CM_WodCargoRequest) then	
		if self.myPxyTask.CM_WodCargoRequest.dischargePort &lt;&gt; null then
			self.cmbDischargePort.setObjectFromCodeAndVoyage (proxyTask.CM_WodCargoRequest.dischargePort, myVoyage);
		endif;
	endif;
	
	self.cmbLoadPort.myTerminal := self.myTerminal;
	self.cmbLoadPort.myAssistant:=self.myAssistant;
	self.cmbLoadPort.initialise(false);
	
	self.cmbWorkPoint.clear();
	self.myAssistant.comboBoxWorkPoint(self.cmbWorkPoint, self.myTerminal);
	
	
	self.cmbTransferType.clear();
	foreach transferType in app.myRoot.allVoyageJobTransferTypes do
		if transferType.id = 0 then
			continue;
		endif;
		self.cmbTransferType.itemObject[ self.cmbTransferType.addItem( transferType.description ) ] := transferType;
	endforeach;
	
	if self.myTerminal.myHarbour &lt;&gt; null then
		self.cmbBerthCR.listCollection(self.myTerminal.myHarbour.allBerths, true, 0);
	endif;
	
	if self.myVoyage &lt;&gt; null and self.myVoyage.myGeneralCargoVoyage &lt;&gt; null then
		self.cmbLocation.listCollection(self.myVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace, true, 0);
	endif;
	
	self.txtTotalVolume.setup(Type_Volume, self.backColor);
	self.txtTotalVolume.tabKey := J_key_Tab;
	self.txtTotalWeight.setup(Type_Weight, self.backColor);
	self.txtTotalWeight.tabKey := J_key_Tab;
	self.txtCargoWeight.setup(Type_Weight, self.backColor);
	self.txtCargoWeight.tabKey := J_key_Tab;
	self.txtTareWeight.setup(Type_Weight, self.backColor);
	self.txtTareWeight.tabKey := J_key_Tab;
	
	buildCmbCargoReq();
epilog

end;</source>
    </JadeMethod>
