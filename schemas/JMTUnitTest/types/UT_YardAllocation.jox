    <JadeMethod name="tYAforHazReef" id="3a7b420a-e9c8-42e8-a2f4-7a51058485b9">
        <source>tYAforHazReef();
/*

Purpose:			

Date		Who		Reason
10 March 2016	cnwmk3	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
vars
	bs1, bs2, bs3, bs4, bs5	: CM_BlockStack;
	ya1, ya2, ya3, ya4, ya5	: CM_YardAllocation;
	voy1, voy2				: CM_Voyage;
	lcArray1				: CM_LCArray;
	lcArray2				: CM_LCArray;
	lcArray3				: CM_LCArray;
	commodity 				: CM_Commodity;
	operator				: CM_Operator;
	gate					: CM_Gate;
	vvr						: CM_VehicleVisitRecord;
	ti						: CM_TrackedItem;
	packTS					: TimeStamp;
	tiSet					: CM_TISet;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	deleteVehicle("UT_TRK1");
	self.deleteYAPriorities();	
	disableAllYA(true);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString());
	// create terminal areas to use in yard allocations
	deleteTerminalArea("UTBS1");
	bs1 := addBlockStack("UTBS1", 5, null);
	deleteTerminalArea("UTBS2");
	bs2 := addBlockStack("UTBS2", 5, null);
	deleteTerminalArea("UTBS3");
	bs3 := addBlockStack("UTBS3", 5, null);
	deleteTerminalArea("UTBS4");
	bs4 := addBlockStack("UTBS4", 5, null);
	deleteTerminalArea("UTBS5");
	bs5 := addBlockStack("UTBS5", 5, null);
	
	// create voyage to use
	self.deleteVoyage("MESDI00002");
	voy1 := self.addVoyageWithContainerStructur("MESDI00002", "MESDIAM", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voy1);
	
	// Set up priorities for Hazardous, requires power and voyage
	self.addYAPriority(YACriteriaType_Hazardous, "1.1");
	assertEqual(self.getTerminal.allYAPriorities.size, 1);
	
	self.addYAPriority(YACriteriaType_RequiresPower, CM_YADataBoolean.VALUE_TRUE);
	assertEqual(self.getTerminal.allYAPriorities.size, 2);	
	
	self.addYAPriority(YACriteriaType_Voyage, voy1);
	assertEqual(self.getTerminal.allYAPriorities.size, 3);	
	
	// add YA for requires power
	self.deleteYA("UT01");
	ya1 := self.addYA1("UT01", YACriteriaType_RequiresPower, CM_YADataBoolean.VALUE_TRUE, bs1.myLocationsController);
	self.assertNotNull(ya1);
	
	// add YA for hazardous
	self.deleteYA("UT02");
	ya2 := self.addYA1("UT02", YACriteriaType_Hazardous, "1.1", bs2.myLocationsController);
	self.assertNotNull(ya2);
	
	// add YA for voyage and hazardous 
	create lcArray1 transient;
	bs3.allLocationsControllers.copy(lcArray1);
	self.deleteYA("UT03");
	ya3 := self.addYA("UT03", YACriteriaType_Voyage, voy1, YACriteriaType_Hazardous, "1.1", null, null, lcArray1, null);
	self.assertNotNull(ya3);
	
	// Add YA for Hazardous, requires power
	create lcArray2 transient;
	bs4.allLocationsControllers.copy(lcArray2);
	self.deleteYA("UT04");
	ya4 := self.addYA("UT04", YACriteriaType_Hazardous, "1.1", YACriteriaType_RequiresPower, CM_YADataBoolean.VALUE_TRUE, null, null, lcArray2, null);
	self.assertNotNull(ya4);
	
	// add YA for voy1, Hazardous, requires power
	create lcArray3 transient;
	bs5.allLocationsControllers.copy(lcArray3);
	self.deleteYA("UT05");
	ya5 := self.addYA("UT05", YACriteriaType_Voyage, voy1, YACriteriaType_Hazardous, "1.1", YACriteriaType_RequiresPower, CM_YADataBoolean.VALUE_TRUE, lcArray3,null);
	self.assertNotNull(ya5);
		
	
	//Set up commodity correctly so that a check on Exceeded Power off Time is done
	commodity := app.myRoot.allCommodities['APLD'].CM_Commodity;
	self.opts.addAssoc( ETRow_RequiresPackInfo, true );
	self.opts.addAssoc( ETRow_RequiresPower, true );
	self.updateCommodity( commodity );
	
	// Receive Reefer - should go to requires power
	deleteContainer("TEST0000001");
	packTS := testStartTime.addDays(-5);
	opts.addAssociation("PackDate", packTS.date.asStringJMT);
	opts.addAssociation("PackTime", packTS.time.asStringJMT);
	opts.addAssociation("AllowableTimeOffPower", 10);
	opts.addAssociation("PackTempC", 3);
	opts.addAssociation("CarriageTempC", 3);
	
	vvr := gateInContainer("UT_TRK1", "TEST0000001", "22R8", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, commodity.code, gate);
	self.assertNotNull(vvr);
	tiSet := vvr.getAllReceivedReleasedTIs();
	ti := tiSet.first;
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertEqual(ti.locationId, bs1.id);
	delete tiSet;
	
	//  Receive Haz cargo - should go to  Hazardous
	self.opts.purge();
	self.opts.addAssoc("Hazard", "1.1");
	self.opts.addAssoc("HazardDescription", "Explosives");
	self.deleteContainer("TEST0000002");
	vvr := gateInContainer("UT_TRK1", "TEST0000002", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "APPL", gate);
	tiSet := vvr.getAllReceivedReleasedTIs();
	ti := tiSet.first;
	self.assertTrueMsg(ti.isHazardous, "tiHaz is not hazardous");
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertEqual(ti.locationId, bs2.id);
	delete tiSet;
	
	//  Receive Haz cargo for voy1 - should go to voy1, Hazardous
	self.opts.purge();
	self.opts.addAssoc("Hazard", "1.1");
	self.opts.addAssoc("HazardDescription", "Explosives");
	self.opts.addAssoc("Voyage", voy1.code);
	self.deleteContainer("TEST0000003");
	vvr := gateInContainer("UT_TRK1", "TEST0000003", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "APPL", gate);
	tiSet := vvr.getAllReceivedReleasedTIs();
	ti := tiSet.first;
	self.assertTrueMsg(ti.isHazardous, "tiHaz is not hazardous");
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertEqual(ti.locationId, bs3.id);
	delete tiSet;
	
	// Receive Haz Reefer - should go to Hazardous requires power
	self.opts.purge();
	packTS := testStartTime.addDays(-5);
	opts.addAssociation("PackDate", packTS.date.asStringJMT);
	opts.addAssociation("PackTime", packTS.time.asStringJMT);
	opts.addAssociation("AllowableTimeOffPower", 10);
	opts.addAssociation("PackTempC", 3);
	opts.addAssociation("CarriageTempC", 3);
	self.opts.addAssoc("Hazard", "1.1");
	self.opts.addAssoc("HazardDescription", "Explosives");
	self.deleteContainer("TEST0000004");
	vvr := gateInContainer("UT_TRK1", "TEST0000004", "22R8", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, commodity.code, gate);
	tiSet := vvr.getAllReceivedReleasedTIs();
	ti := tiSet.first;
	self.assertTrueMsg(ti.isHazardous, "tiHaz is not hazardous");
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertEqual(ti.locationId, bs4.id);
	delete tiSet;
	
	// Receive Haz Reefer for voy1 - should go to voy1 Hazardous requires power
	self.opts.purge();
	packTS := testStartTime.addDays(-5);
	self.opts.addAssoc("Voyage", voy1.code);
	opts.addAssociation("PackDate", packTS.date.asStringJMT);
	opts.addAssociation("PackTime", packTS.time.asStringJMT);
	opts.addAssociation("AllowableTimeOffPower", 10);
	opts.addAssociation("PackTempC", 3);
	opts.addAssociation("CarriageTempC", 3);
	self.opts.addAssoc("Hazard", "1.1");
	self.opts.addAssoc("HazardDescription", "Explosives");
	self.deleteContainer("TEST0000005");
	vvr := gateInContainer("UT_TRK1", "TEST0000005", "22R8", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, commodity.code, gate);
	tiSet := vvr.getAllReceivedReleasedTIs();
	ti := tiSet.first;
	self.assertTrueMsg(ti.isHazardous, "tiHaz is not hazardous");
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertEqual(ti.locationId, bs5.id);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	disableAllYA(false);
	delete lcArray1;
	delete lcArray2;
	delete lcArray3;
	delete tiSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tYAforTranships" id="1e7cc417-71fc-4415-82f4-1acfb4d2ca26">
        <updating/>
        <source>tYAforTranships() updating;
/*

Purpose:	Testlink Test: 01-178 Yard Allocations for Tranships		

Date		Who		Reason
07 March 2016	cnwmk3	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
vars
	bs1, bs2				: CM_BlockStack;
	ya1, ya2				: CM_YardAllocation;
	ti1						: CM_TrackedItem;
	location				: CM_LocationsController;
	lcArray					: CM_LCArray;
	tiArray					: CM_TIArray;
	voy1, voy2				: CM_Voyage;
	controller				: CMIF_TranshipTIController;
	terminal				: CM_Terminal;
	yaConfig				: CM_YAConfig;
	ct 						: CM_YACriteriaType;
	pxyYAIMEXConfig			: CM_YAIMEXConfig;
	opCriteria				: CM_YACriteriaTypeArray;
	yaIMEXConfig			: CM_YAIMEXConfig;
	
	pxyYA					: CM_YardAllocation;
	proxyCriterias			: CMIF_Array;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteYAPriorities();	
	disableAllYA(true);
	
	// create terminal areas to use in yard allocations
	deleteTerminalArea("UTBS1");
	bs1 := addBlockStack("UTBS1", 1, null);
	deleteTerminalArea("UTBS2");
	bs2 := addBlockStack("UTBS2", 1, null);
	
	// create voyages to use
	self.deleteVoyage("MESDI00002");
	voy1 := self.addVoyageWithContainerStructur("MESDI00002", "MESDIAM", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voy1);
	
	self.deleteVoyage("MESDI00005");
	voy2 := self.addVoyageWithContainerStructur("MESDI00005", "MESDIAM", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voy2);
	
	// Set up priorities for new Yard Allocation options Voyage Inbound and Voyage Outbound.
	self.addYAPriority(YACriteriaType_VoyageInbound, "MESDI00002");
	assertEqual(self.getTerminal.allYAPriorities.size, 1);
	
	self.addYAPriority(YACriteriaType_VoyageOutbound, "MESDI00005");
	assertEqual(self.getTerminal.allYAPriorities.size, 2);	
	
	// On the Yard Allocation Config Form, edit the Criteria fields for IMEX = Tranship to include new option Voyage Inbound and Voyage Outbound.
	terminal := self.getTerminal();
	
	yaConfig := terminal.myYAConfig;
	self.assertNotNull(yaConfig);
	
	create opCriteria transient;
	ct := CM_YATypeVoyageInbound.firstInstance;
	opCriteria.add(ct);
	ct := CM_YATypeVoyageOutbound.firstInstance;
	opCriteria.add(ct);
	self.assertEqual(opCriteria.size, 2);
	
	foreach yaIMEXConfig in yaConfig.allYAIMEXConfigs do
		if(yaIMEXConfig.myIMEXStatus.code = TI_IMEX_STATUS_TRANSHIP) then
			pxyYAIMEXConfig := app.createUpdateProxy(yaIMEXConfig).CM_YAIMEXConfig;
			pxyYAIMEXConfig.setProxy(opCriteria, yaIMEXConfig.allGroupLabelCriteria, yaIMEXConfig.colour, yaIMEXConfig.allOpCriteria.first);
	
			app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAIMEXConfig, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endforeach;
	
	// create a container
	self.deleteContainer("TEST0000001");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNull(ti1);
	
	// now make the container a tranship
	create controller transient;
	controller.allTrackedItems.add(ti1);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKL'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['US123'];
	controller.myExportVoyage 		:= voy2;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	
	// create a yard allocation that does not match the Tranship port.
	self.deleteYA("UT01");
	ya2 := self.addYA1("UT01", YACriteriaType_TranshipToPort, app.myRoot.allPorts['US234'], bs2.myLocationsController);
	self.assertNotNull(ya2);
	
	// Allow others - Never
	create proxyCriterias transient;
	pxyYA := app.createUpdateProxy(ya2).CM_YardAllocation;
	
	pxyYA.setPropertyValue("allowOthersOption", YAOverlap_Never);
	app.myTrxUA.trxUpdateYardAllocation(pxyYA, proxyCriterias, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	// Attempt to move a TI into the Yard Allocation that does not match the Tranship to Port.  An error should be raised.
	self.expectTrxError(WARN_TI_NOTMATCH_ALLOCATION_AT);
	move(ti1, bs2);
	self.assertEqualMsg(ti1.locationId, null, "Did move to location when it should have failed");
	
	// Create a new Yard Allocation for IMEX Status Tranship, using one of Voyage Inbound or Voyage Outbound. Set the Tranship to Port Criteria to a valid Port.
	create lcArray transient;
	bs1.allLocationsControllers.copy(lcArray);
	self.deleteYA("UT");
	ya1 := self.addYA("UT", YACriteriaType_ImexStatus, app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP], YACriteriaType_VoyageInbound, voy1, YACriteriaType_TranshipToPort, app.myRoot.allPorts['US123'], lcArray,null);
	self.assertNotNull(ya1);
	
	// Attempt to move a TI into the YA that does match the Tranship Port.  No error should be raised..
	move(ti1, bs1);
	self.assertEqualMsg(ti1.locationId, bs1.id, "Did not move to correct location");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	disableAllYA(false);
	delete lcArray;
	delete controller;
	delete opCriteria;
	delete pxyYAIMEXConfig;
	delete proxyCriterias;
	delete pxyYA;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tYardDeliveryRequest" id="d3367d46-b0d1-403e-b517-5505f99076ca">
        <source>tYardDeliveryRequest();
// cnwndl1
/*

Purpose:			
		Provide some basic testing for CM_YardDeliveryRequest
Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
20/01/2011	cnwndl1	Par 26779 		Initial creation	
08/04/2011	cnwmh5	PAR #27347		Add cmsEndLoad or endLoad to epilog so that 
									if error occurs it will not leave it in 
									beginLoad state
03/10/2018	jlgka1	40698			Add "heavyRated" in method call 
									setProxyYardDelivery as a result of changes
									in that method.
3 Nov 2022 	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
============================================================================*/

vars

	allAvGrades 		: IntegerArray;
	theOperator 		: CM_Operator;
	theISOTypeCode 		: String;
	targetLocation 		: String;
	sourceLocation 		: CM_LocationsController;
	sourceTA 			: CM_TerminalArea;
	theTotalReq 		: Integer;
	addToRTQ 			: Boolean;
	isClean 			: Boolean;
	isoGroup			: String;
	theID 				: String;
	subTerminalObj 		: CM_SubTerminal;
	theRemarks 			: String;
	requiredBtDT 		: TimeStamp;
	targetSubTerminal 	: CM_SubTerminal;
	release 			: CM_BulkRelease;
	releaseItem 		: CM_ReserveDetail;
	rtQueue 			: CM_RadioTelemetryQueue;
	priority 			: Integer;
	bestPick 			: Boolean;
	theProxyJob 		: CM_YardInternalJob;
	theProxyRequest 	: CM_YardDeliveryRequest;
	theRealJob 			: CM_Job;
	theYDRequest 		: CM_YardDeliveryRequest;
	tiId 				: String;
	proxyTI 			: CM_TrackedItem;
	ti 					: CM_TrackedItem;
	blockStack1			: CM_BlockStack;
	blockStack2			: CM_BlockStack;
	term 				: CM_Terminal;
	today 				: Date;
	loadStateSet 		: Boolean;
	ya					: CM_YardAllocation;
begin

	term := self.getTerminal;
	
	disableAllYA(true);

	deleteTerminalArea("UTBS1");
	blockStack1 := addBlockStack("UTBS1", 1, null);
	assertNotNullMsg(blockStack1, "blockStack1");
	
	deleteTerminalArea("UTBS2");
	blockStack2 := addBlockStack("UTBS2", 20, null);
	assertNotNullMsg(blockStack2, "blockStack2");
	
	self.deleteYA("UTBS2YA");
//	create locations transient;
//	locations.add(blockStack2.allLocationsControllers.first);
	self.addYACatchAll("UTBS2YA", blockStack2);
	ya := term.allYardAllocatonsByCode["UTBS2YA"];
	
	

	create allAvGrades transient;
	allAvGrades.add(1);
							
//	theID := "601129615";
	priority := 3;
	theISOTypeCode := "2200";
	theOperator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).CM_Operator;
	theRemarks := null;
	targetLocation := "UTBS2";
	isClean := false;
	bestPick := true;
	isoGroup := "GEN2";
	theTotalReq := 1;
	subTerminalObj := self.getSubTerminal(null);													// 29/04/2014 cnwmh5
	sourceLocation := blockStack1.myLocationsController;
	sourceTA := blockStack1;		
	requiredBtDT.setDate(today);
	requiredBtDT.setTime("23:59:59".Time);
	targetSubTerminal := self.getSubTerminal(null);													// 29/04/2014 cnwmh5
	release := null;
	releaseItem := null;
	rtQueue := null;
	addToRTQ := true;
	
	tiId := "ZZ123456_1";
	self.deleteContainer(tiId);
	proxyTI := createContainer(	tiId,	//id: String;
								theISOTypeCode,	//_isoType: String;
								"MT",	//_commodity: String;
								theOperator,	//_operator: CM_Operator
								true
								);
	proxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_EXPORT);
	ti := self.addContainerFromProxy(proxyTI); 
	self.move(ti, blockStack1);
	assertTrue(ti.myTerminalArea.myTerminal = term);
							
	// test one - create a Yard Delivery move
	
	create theProxyJob transient;
	theProxyJob.setProxyYardDelivery(theID,term);
	theProxyJob.setPriority( priority );
	
	
	create theProxyRequest transient;
	theProxyRequest.setProxyYardDelivery(	theISOTypeCode,
											theOperator.code,
											theRemarks,
											targetLocation,
											app.getMyUserCode(),
											isClean,
											bestPick,
											isoGroup,
											theProxyJob,
											allAvGrades,
											theTotalReq,
											subTerminalObj,
											sourceLocation,
											sourceTA,		
											null, //source grid object ccms 2098
											requiredBtDT,
											targetSubTerminal,
											release,
											releaseItem,
											rtQueue,
											null,
											false,
											null,   //3.11.2022	navsks20 TFS 52721
											null);	//3.11.2022	navsks20 TFS 52721

				
	theProxyRequest.setMTCommodity();
	
	app.myTrxCA.trxCreateYardInternalDeliveryR(theProxyJob, theRealJob, theProxyRequest, theYDRequest, addToRTQ, app.myPassport);
	assertNotNullMsg(theRealJob, "Test one - The Persistant CM_YardInternalJob");
	assertNotNullMsg(theYDRequest, "Test one - The Persistant CM_YardDeliveryRequest");
	
	delete theProxyRequest;
	delete theProxyJob;
																							
	// test two - update a Yard Delivery move
	
	priority := 2;
	theProxyJob :=  app.createUpdateProxy(theRealJob).CM_YardInternalJob;
	
	app.cmsBeginLoad(loadStateSet);
	theProxyRequest := theYDRequest.pxyGetProxyObject;
	if theProxyRequest = null then		
		theProxyRequest := theYDRequest.pxyCreateUpdateProxy;
	endif;
	app.cmsEndLoad(loadStateSet);

	theProxyJob.setProxyYardDelivery(theID,term);
	theProxyJob.setPriority( priority );

	theProxyRequest.setProxyYardDelivery(	theISOTypeCode,
											theOperator.code,
											theRemarks,
											targetLocation,
											app.getMyUserCode(),
											isClean,
											bestPick,
											isoGroup,
											theProxyJob,
											allAvGrades,
											theTotalReq,
											subTerminalObj,
											sourceLocation,
											sourceTA,
											null, //source grid object ccms 2098
											requiredBtDT,
											targetSubTerminal,
											release,
											releaseItem,
											rtQueue,
											null,
											false,
											null,       //3.11.2022	navsks20 TFS 52721
											null);		//3.11.2022	navsks20 TFS 52721	
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateYardInternalDeliveryR(theProxyJob, theProxyRequest, addToRTQ, app.myPassport);
	
	self.assertEqualMsg(theRealJob.priority, 2, "Doesn't look like the Job prioirty got updated.");

epilog

	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	
	disableAllYA(false);

	delete allAvGrades;
	delete theProxyRequest;
	delete theProxyJob;
	
	self.deleteContainer(tiId);
	deleteTerminalArea("UTBS1");
	deleteTerminalArea("UTBS2");
	self.deleteJob(theRealJob);
	self.deleteYA("UTBS2YA");
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="uDisableAllYA" id="5766544e-30ac-4044-9369-5d7abb72628f">
        <source>uDisableAllYA();
//22 September 2009	cnwdw1	
//
vars
	ya: CM_YardAllocation;
	disable: Boolean;
begin
	disable := true;
	read disable;
	foreach ya in getTerminal.allYardAllocations do
		self.disableYA(ya, disable);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="xGACProcessCargo" id="d019bae5-59e1-4cf6-a91d-256071add921">
        <source>xGACProcessCargo(_location : CM_BlockStack; _imexStatus : Integer; _tiId, _truckId : String; _cargoType : CM_CargoType);

/*

Purpose:		Process Cargo for Generic Yard Allocation Check

Date			Who		Reason
27/03/2015		cnwmh5	Initial creation

*/

vars
		
	ti						: CM_TrackedItem;	
	vvr						: CM_VehicleVisitRecord;
		
begin

	self.opts.addAssoc("IMEX", _imexStatus);
	self.opts.addAssoc("Voyage", self.getTerminal().getNullVoyage().code);
	self.opts.addAssoc("DischargePort", "NZAKL");
	if _cargoType = null then
		vvr := self.gateInContainer(_truckId, _tiId, "2200", "UTOP", "GENL", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()));
	else
		vvr := self.gateInGC(_truckId, null, null, _tiId, _cargoType.description, self.getProfileSetting(UT_Profile.P_OPERATOR).asString,
			null, self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 45);
	endif;
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(_tiId);
	self.assertNotNull(ti);
	if ti.isKindOf(CM_Container) then
		self.assertEqualMsg(ti.myPrimaryQueuedLocation.getID(), _location.getID(), ti.id &amp; " is either not planned or is planned to the wrong location.  " &amp;
			"Planned to " &amp; ti.myPrimaryQueuedLocation.getID() &amp; " rather than " &amp; _location.getID());
		self.workVehicle(vvr);
	else
		ti := self.getTrackedItemByCargoType(_tiId, _cargoType.id);
		self.assertNotNull(ti);
		self.opts.removeAssoc("Voyage");
		self.opts.addAssoc("Voyage", self.getTerminal().getNullVoyage());
		self.updateTI(ti);
		if not ti.isQueued() then
			self.autoplanWLE(ti.allWorklistEntries.first);
		endif;
		self.moveVehicleToLane(vvr.vehicle, self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString), 1);
		self.moveVehicleToYard(vvr.vehicle);
		self.workVehicle(vvr);
		self.moveVehicleToLane(vvr.vehicle, self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString), 1);
	endif;
	
	
	self.roadExit(vvr);

epilog
	
end;</source>
        <Parameter name="_location" type="CM_BlockStack"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_truckId" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
</Class>
