    <JadeMethod name="intialTestSettings" id="587a2c9d-37c6-4c45-ac2f-8a3bd36b4d33">
        <source>intialTestSettings();
// -----------------------------------------------------------------------------
// Created:		18 September 2003 by cnwrs1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 28/07/2014	cnwmh5		Updated license keys
// 30/11/2017	jlgmd1		Automatically get the latest keys from dmast (if available)
// 10/06/2022	navmd1		Updated "default" license keys, so the starterDB on Azure can still initialize without access to Dmast
// -----------------------------------------------------------------------------

vars

begin
	self.txtCoyCode.text := "JMT";
	self.txtCoyName.text := "JadeMasterTerminal";
	self.txtClientName.text := "JADEMASTER";
	self.txtPassword1.text := "Pa55word_";
	self.txtPassword2.text := "Pa55word_";
	self.txtTermCode.text := "ONE";
	self.txtTermName.text := "Terminal One";
	self.txtUserName.text := "ADMIN";

	// Set *some* defaults in case Dmast can't be reached	
	self.txtLicName.text := "JADE Master Terminal";
	self.txtLicense.text := "610000002A000000192A60677E2A2A2A2A2A2A2A292A2A2AAAD6002AD534F6D5D5D5D5D5D569";
	
	self.txtEDILicName.text := "JADE Master Terminal (EDI)";
	self.txtEDILicense.text := "07000000FA000000CDFAB0B7AEA5BFBEB3FAFAFAE1FAFAFA1021DFFA050505F9FAFA06050505850405050505050505FA";
	
	self.txtSubLicName.text := "JADE Master Terminal";
	self.txtSubLicense.text := "920000003C000000363C3C3C083C6F697E6F3C3C3C3C3C3C3F3C3C3C5EC0163C3C3C3C3C3C3C3C3C3C000C0B090C0D0C0D0E0C0F0C0C0B0A0C0D0C0D0E0C0F0C0C0B0B0C0D0C0D0E0C0F0C0C0B040C0D0C0D0E0C0F0C";
	
	// ### JIRA 33543 16DEC2024 NAVAB1
	self.txtEWSLicName.text := "JADE Master Terminal";
	self.txtEWSLicense.text := "EC000000820000008C828282B182C7D5D18282828282828281828282AC68A7828582828282828282828282824282B2B2B3B0B1B3B0B0B2B1B2B2B2B0B0B1B3B0B0B2B4B2B2B2B1B0B1B3B0B0B2B7B2B3B2B1B0B1B3B0B0B2BBB2B3B2B6B0B1B3B0B0B2BBB2";

	// Now get the latest set of keys
	self.getClientSettings("JADE Master Terminal");
	
end;</source>
    </JadeMethod>
