    <JadeMethod name="drawRowsLandscape" id="34337c9e-8dde-4529-8824-1a96f69bdac7">
        <source>drawRowsLandscape(_y1 : Real; _gridWidth : Real; _gridHeight : Real; _row : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
	lcx1, lcy1,
	lcx2, lcy2,
	x1 				: Real;
	col 			: Integer;
	finishedCols 	: Boolean;
	lc 				: CM_LocationsController;
	tiDraw			: CMIF_RDTTIDrawElement;
	lcDraw			: CMIF_RDTLocationDrawElement;
	wagonDraw		: CMIF_RDTWagonPartDrawElement;
	trackDraw 		: CMIF_RDTTrackDrawElement;
	notEmpty 		: Boolean;
	theTI			: CM_TrackedItem;
	isGridArea 		: Boolean;
	key				: String;
begin
		isGridArea := self.isLocationInGriddedArea(self.myTargetLocation);
		// Note that I draw these in separate loops to avoid flicker issues, when drawing TIs that span more than one location
		
		// Draw the Locations
		if self.flipH then
			x1 := self.myDrawingFrame.clientWidth + self.xDrawOffset - self.rightOffset;	
		else
			x1 := self.xDrawOffset + self.leftOffset;
		endif;		
		
		if self.flipH then
			col := self.rightGridColDraw;
		else
			col := self.leftGridColDraw;
		endif;
		
		finishedCols := false;
		while not finishedCols do
			if self.drawMode = CMIF_RDTDrawElement.MODE_FACE and isGridArea then	
				lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, self.gridRowToStackHeight(_row, self.myGridArea));
			else
				lcDraw := self.myDisplayBuilder.getLocationDraw(_row, col);
			endif;
			
			if lcDraw &lt;&gt; null then 				
				lc := lcDraw.getLocationController();
			else
				lc := null;
			endif;
			
			// New wagon handling
			wagonDraw := self.myDisplayBuilder.getWagonPart(_row, col);
			if wagonDraw &lt;&gt; null then
				self.drawWagon(x1, _y1, _gridWidth, _gridHeight, wagonDraw); 		
			endif;
			//
			
			// New train track handling
			trackDraw := self.myDisplayBuilder.getTrack(_row, col);
			if trackDraw &lt;&gt; null then
				self.drawTrack(x1, _y1, _gridWidth, _gridHeight, trackDraw); 		
			endif;			
			//			
			
			if lcDraw &lt;&gt; null then 
				self.drawLocation(x1, _y1, _gridWidth, _gridHeight, lcDraw); 				
			endif;
			
			col := col + 1;
			if self.flipH then
				finishedCols := col &gt; self.leftGridColDraw;
			else
				finishedCols := col &gt; self.rightGridColDraw;
			endif;	
			
			// Move across
			if self.flipH then
				x1 := x1 - _gridWidth;
			else
				x1 := x1 + _gridWidth;
			endif;
						
		endwhile;

		// Draw the TIs
		if self.flipH then
			x1 := self.myDrawingFrame.width + self.xDrawOffset - self.rightOffset;	
		else
			x1 := self.xDrawOffset + self.leftOffset;
		endif;

		
		if self.flipH then
			col := self.rightGridColDraw;
		else
			col := self.leftGridColDraw;
		endif;
		
		finishedCols := false;
		while not finishedCols do
			
			if self.drawMode = CMIF_RDTDrawElement.MODE_FACE and isGridArea then
				//lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, self.maxGridRow - _row + 1);
				lcDraw := self.myDisplayBuilder.getLocationDrawWithHeight(_row, col, self.gridRowToStackHeight(_row, self.myGridArea));
			else
				lcDraw := self.myDisplayBuilder.getLocationDraw(_row, col);
			endif;

			if lcDraw &lt;&gt; null then 
				lc := lcDraw.getLocationController();
			else
				lc := null;
			endif;

			
			tiDraw := self.myDisplayBuilder.getTI(_row, col);
			if tiDraw &lt;&gt; null then
				theTI := tiDraw.getTI();
			else
				theTI := null;
			endif;
			
			if  tiDraw &lt;&gt; null then
				// Draw it
				self.drawTI(x1, _y1, _gridWidth, _gridHeight, tiDraw); 	
			endif;

			if lcDraw &lt;&gt; null then
				if self.flipH then
					lcx1 := x1 - _gridWidth;
					lcx2 := x1;
				else			
					lcx1 := x1;
					lcx2 := x1 + _gridWidth;
				endif;
				
				if self.flipV then
					lcy1 := _y1 - _gridHeight;
					lcy2 :=  _y1;
				else
					lcy1 := _y1;
					lcy2 :=  _y1 + _gridHeight;
				endif;
	
				
				lcDraw.gridPointsToElementPoints(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
		
				
				key := self.genHighlightedLCKey(lc, lcDraw.stackHeight);
				
				//if self.allHighlightLCsByID.includesKey(lc.getFullId()) then
				if self.allHighlightLCsByID.includesKey(key) then
					self.highlightLocation(lcx1, lcy1, lcx2, lcy2);
				endif;
	
	
				if lc = self.myTargetLocation then
					// Highlight the location
					if self.drawMode = CMIF_RDTDrawElement.MODE_FACE and isGridArea then
						// we only want to highlight the location at the height specified in the location string
						if self.gridRowToStackHeight(_row, self.myGridArea) = self.targetLocationHeight then
							self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2, theTI); 					
						endif;
					else
						self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2, theTI); 					
					endif;
				endif;

				lcDraw.drawLocationId(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.flipV, self.flipH, tiDraw, self.myTIFrame,self.drawMode);
			
			endif;
			
			col := col + 1;
			if self.flipH then
				finishedCols := col &gt; self.leftGridColDraw;
			else
				finishedCols := col &gt; self.rightGridColDraw;
			endif;	
			
			// Move across
			if self.flipH then
				x1 := x1 - _gridWidth;
			else
				x1 := x1 + _gridWidth;
			endif;
						
		endwhile;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawRowsLandscapeOLD" id="1d06b4b6-ea12-454e-a8ac-1a7b66e5d52d">
        <source>drawRowsLandscapeOLD(_y1 : Real; _gridWidth : Real; _gridHeight : Real; _row : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
	lcx1, lcy1,
	lcx2, lcy2,
	x1 				: Real;
	col 			: Integer;
	finishedCols 	: Boolean;
	lc 				: CM_GridController;
	tiDraw			: CMIF_RDTTIDrawElement;
	lcDraw			: CMIF_RDTLocationDrawElement;
	notEmpty 		: Boolean;
	theTI			: CM_TrackedItem;
begin
		// Note that I draw these in separate loops to avoid flicker issues, when drawing TIs that span more than one location
		
		// Draw the Locations
		if self.flipH then
			x1 := self.myDrawingFrame.width + self.xDrawOffset - self.rightOffset;	
		else
			x1 := self.xDrawOffset + self.leftOffset;
		endif;		
		
		if self.flipH then
			col := self.rightGridColDraw;
		else
			col := self.leftGridColDraw;
		endif;
		
		finishedCols := false;
		while not finishedCols do
			//lc := self.myDisplayBuilder.getLocationDraw(_row, col).CM_GridController;
			lcDraw := self.myDisplayBuilder.getLocationDraw(_row, col);
			lc := lcDraw.getLocationController().CM_GridController;
			
			if lc &lt;&gt; null then 
				// Draw the location
				if self.flipH then
					if self.flipV then
						//self.drawLocation(x1 - _gridWidth, _y1 - _gridHeight, x1, _y1, lc);				
						//lcDraw.draw(x1 - _gridWidth, _y1 - _gridHeight, x1, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
					else
						//self.drawLocation(x1 - _gridWidth, _y1, x1, _y1 + _gridHeight, lc);
						//lcDraw.draw(x1 - _gridWidth, _y1, x1, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
					endif;
				else
					if self.flipV then
						//self.drawLocation(x1, _y1 - _gridHeight, x1 + _gridWidth, _y1, lc);			
						//lcDraw.draw(x1, _y1 - _gridHeight, x1 + _gridWidth, _y1, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
					else
						//self.drawLocation(x1, _y1, x1 + _gridWidth, _y1 + _gridHeight, lc);			
						//lcDraw.draw(x1, _y1, x1 + _gridWidth, _y1 + _gridHeight, self.myDrawingFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
					endif;
				endif;
			endif;
			
			col := col + 1;
			if self.flipH then
				finishedCols := col &gt; self.leftGridColDraw;
			else
				finishedCols := col &gt; self.rightGridColDraw;
			endif;	
			
			// Move across
			if self.flipH then
				x1 := x1 - _gridWidth;
			else
				x1 := x1 + _gridWidth;
			endif;
						
		endwhile;

		// Draw the TIs
		if self.flipH then
			x1 := self.myDrawingFrame.width + self.xDrawOffset - self.rightOffset;	
		else
			x1 := self.xDrawOffset + self.leftOffset;
		endif;

		
		if self.flipH then
			col := self.rightGridColDraw;
		else
			col := self.leftGridColDraw;
		endif;
		
		finishedCols := false;
		while not finishedCols do
			//lc := self.myDisplayBuilder.getLocationDraw(_row, col).CM_GridController;
			lcDraw := self.myDisplayBuilder.getLocationDraw(_row, col);
			lc := lcDraw.getLocationController().CM_GridController;
			
			tiDraw := self.myDisplayBuilder.getTI(_row, col);
			if tiDraw &lt;&gt; null then
				theTI := tiDraw.getTI();
			else
				theTI := null;
			endif;

			//theTI := self.myDisplayBuilder.getTI(_row, col);
			
			if theTI &lt;&gt; null then
				// Draw it
				if self.flipH then
					if self.flipV then
						//self.drawTI(x1 - _gridWidth, _y1 - _gridHeight, x1, _y1, lc.getTopTI(REAL_MODE), lc, false); 
						//tiDraw.draw(x1 - _gridWidth, _y1 - _gridHeight, x1, _y1, self.myTIFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
					else
						//self.drawTI(x1 - _gridWidth, _y1, x1, _y1 + _gridHeight, lc.getTopTI(REAL_MODE), lc, false); 
						//tiDraw.draw(x1 - _gridWidth, _y1, x1, _y1 + _gridHeight, self.myTIFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
					endif;
				else
					if self.flipV then
						//self.drawTI(x1, _y1 - _gridHeight, x1 + _gridWidth, _y1, lc.getTopTI(REAL_MODE), lc, false); 
						//tiDraw.draw(x1, _y1 - _gridHeight, x1 + _gridWidth, _y1, self.myTIFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
					else
						//self.drawTI(x1, _y1, x1 + _gridWidth, _y1 + _gridHeight, lc.getTopTI(REAL_MODE), lc, false); 
						//tiDraw.draw(x1, _y1, x1 + _gridWidth, _y1 + _gridHeight, self.myTIFrame, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
					endif;
				endif;
			endif;

			if self.flipH then
				lcx1 := x1 - _gridWidth;
				lcx2 := x1;
			else			
				lcx1 := x1;
				lcx2 := x1 + _gridWidth;
			endif;
			
			if self.flipV then
				lcy1 := _y1 - _gridHeight;
				lcy2 :=  _y1;
			else
				lcy1 := _y1;
				lcy2 :=  _y1 + _gridHeight;
			endif;

			
			//self.gridPointsToLCPoints(lcx1, lcy1, lcx2, lcy2);
			lcDraw.gridPointsToElementPoints(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
	
			
			if self.allHighlightLCsByID.includesKey(lc.getFullId()) then
				self.highlightLocation(lcx1, lcy1, lcx2, lcy2);
			endif;


			if lc = self.myTargetLocation then
				// Highlight the location
				self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2, theTI); 					
			endif;
			
			 
			//self.drawLocationID(lc, lcx1, lcy1, lcx2, lcy2, theTI, self.myTIFrame);
			//lcDraw.drawLocationId(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.flipV, theTI, self.myTIFrame);
			
			col := col + 1;
			if self.flipH then
				finishedCols := col &gt; self.leftGridColDraw;
			else
				finishedCols := col &gt; self.rightGridColDraw;
			endif;	
			
			// Move across
			if self.flipH then
				x1 := x1 - _gridWidth;
			else
				x1 := x1 + _gridWidth;
			endif;
						
		endwhile;
		
epilog

end;</source>
