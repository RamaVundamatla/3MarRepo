    </JadeMethod>
    <JadeMethod name="doTblMasterEntryDblClick" id="1b81cd62-2d13-46eb-8676-3057f8e37ad1">
        <updating/>
        <source>doTblMasterEntryDblClick(_tbl: CM_EntryTable input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	row		: Integer;
begin
	row := _tbl.getRowByName(ETRow_ParentToPack);
	
	if _tbl.row &lt;&gt; row then
		return;
	endif;

	if (not CM_BOLOut.hasInstance(self.myCurrentMasterObject)) or
	   (not CM_TrackedItem.hasInstance(self.myCurrentMasterObject.CM_BOLOut.myMasterTI)) then
		return;
	endif;
	
	self.doEnquiryTI(self.myCurrentMasterObject.CM_BOLOut.myMasterTI);

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateDetailLine" id="8b82e11a-4d87-47c4-96ea-8add9d242237">
        <updating/>
        <source>doUpdateDetailLine() : Object updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numRows,
	row					: Integer;
	ti,
	existingTI			: CM_TrackedItem;
	bolOutLine,
	currentLine			: CMIF_BOLOutLine;
	tbl					: CM_DataTable;
	entDef				: EntTableDef;
begin
	tbl := self.tblDataDetail;
	entDef := tbl.myEntTableDef;
	currentLine := self.myCurrentDetailObject.CMIF_BOLOutLine;
	
	ti := self.cmbItem.listObject.CM_TrackedItem;
	if ti = null then
		app.msgBox('You must select an item to update the current ' &amp; self.getDataEntityDescription(false) &amp; ' first.', 
					app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return null;
	endif;
	
	numRows := tbl.rows;
	foreach row in tbl.fixedRows + 1 to numRows do
		bolOutLine := tbl.accessRow(row).itemObject.CMIF_BOLOutLine;
		if bolOutLine = currentLine then
			continue;
		endif;
		
		if bolOutLine.myTrackedItem = ti then
			app.msgBox('The selected item has already been added to this docket at line number ' &amp; (row - tbl.fixedRows).String, 
					app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
			return null;
		endif;	
	endforeach;
	
	currentLine.setFromTrackedItem(ti);
	
	tbl.setCellText(tbl.row, 1, self.getDataRowForDef(currentLine, entDef));
	self.doAssignLineNos();
	self.tblDetailEnt.setFocus();
	//self.tblDetailEnt.goToRowByName(ETRow_Id);
	self.cmbItem.setFocus();
	
	if (tbl.row + 1) &lt;= tbl.rows then
		tbl.accessRow(tbl.row).selected := false;
		tbl.row := tbl.row + 1;
		tbl.accessRow(tbl.row).selected := true;
		currentLine := tbl.accessedRow.itemObject.CMIF_BOLOutLine;
	endif;
	
	return currentLine;

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="18ee686a-1c27-4fee-bc72-46e18d3948da">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     07 May 2004	cnwth2
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	numRows,
	row				: Integer;
	tbl				: CM_DataTable;
	bolOut			: CM_BOLOut;
	breakOut		: Boolean;
	orderNo,
	docketNo		: String;
	entDef			: EntTableDef;
	stkOrd			: CM_StockOrderHeaderGeneric;

begin

	if eventType = Event_StockOrderHdr_Create then
		stkOrd := self.cmbStockOrder.listObject.CM_StockOrderHeaderGeneric;
		if stkOrd &lt;&gt; null then
			orderNo := stkOrd.orderNo;
		endif;
		self.myAssistant.comboBoxStockOrderGeneric(self.cmbStockOrder, self.myTerminal, null, null, null, orderNo);
		
	elseif eventType = Event_StockOrderHdr_Update then
		stkOrd := self.cmbStockOrder.listObject.CM_StockOrderHeaderGeneric;
		if stkOrd &lt;&gt; null then
			if self.mode &lt;&gt; self.Mode_View and
			   CM_StockOrderHeaderGeneric.hasInstance(userInfo.Object) and 
			   (stkOrd = userInfo.CM_StockOrderHeaderGeneric) then
				app.msgBox('Loadout screen: Another user has updated the stock order you currently have selected.' &amp; CrLf &amp;
							'The order lines must now be re-loaded.', 'Stock order updated', MsgBox_Exclamation_Mark_Icon);
				self.tblDataDetail.rows := self.tblDataDetail.fixedRows;
				
				self.doSelectStockOrder(stkOrd);
			endif;
			orderNo := stkOrd.orderNo;
		endif;
		self.myAssistant.comboBoxStockOrderGeneric(self.cmbStockOrder, self.myTerminal, null, null, null, orderNo);
				
	elseif eventType = Event_StockOrderHdr_Delete then
		orderNo := userInfo.String;
		if (not global.isValidObject(self.cmbStockOrder.listObject.CM_StockOrderHeaderGeneric)) then
			if self.mode &lt;&gt; self.Mode_View then
			   	app.msgBox('Loadout screen: Another user has just deleted stock order ' &amp; orderNo &amp; '.' &amp; CrLf &amp;
							'You will have re-select a defferent stock order, or cancel.', 'Stock order deleted...', MsgBox_Exclamation_Mark_Icon);
				self.tblDataDetail.rows := self.tblDataDetail.fixedRows;
			endif;
		endif;
		self.myAssistant.comboBoxStockOrderGeneric(self.cmbStockOrder, self.myTerminal, null, null, null, orderNo);
	endif;
	
	tbl := self.tblDataMaster;
	entDef := tbl.myEntTableDef;
	
	if eventType = Event_BOLOut_Create then
		if self.mode &lt;&gt; self.Mode_View then
			return;
		endif;
		
		if (not CM_BOLOut.hasInstance(userInfo.Object)) then
			return;
		endif;
		
		bolOut := userInfo.CM_BOLOut;
		if (not self.includesObject(bolOut)) then
			return;
		endif;

		self.addObjectToMasterTable(tbl, bolOut, null, null, breakOut);
		if bolOut = self.myCurrentMasterObject then
			tbl.selectObject(bolOut, true);
			self.zShowThumbnailData(bolOut);
		endif;
		
	elseif eventType = Event_BOLOut_Update then
		if (not CM_BOLOut.hasInstance(userInfo.Object)) then
			return;
		endif;
		
		bolOut := userInfo.CM_BOLOut;
		
		if bolOut = self.myCurrentMasterObject then
			if self.mode = self.Mode_Edit and (not self.isUpdateComplete) then
				if app.msgBox('Another user has updated the docket (' &amp; bolOut.number &amp; ') that you are currently editing.' &amp; CrLf &amp;
			 			'Do you want to refresh the updated info or cancel?','Docket updated by another user...', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
					self.zDoCancel();
				endif;
			endif;
			
			if tbl.accessRow(tbl.row).itemObject = bolOut then
				tbl.setCellText(tbl.row, 1, self.getDataRowForDef(bolOut, entDef));
			endif;
			
			self.zShowThumbnailData(bolOut);
			return;	
		endif;
		
		if (not self.includesObject(bolOut)) then
			return;
		endif;
		
		numRows := tbl.rows;
		foreach row in tbl.fixedRows + 1 to numRows do
			if tbl.accessRow(row).itemObject = bolOut then
				tbl.setCellText(row, 1, self.getDataRowForDef(bolOut, entDef));
				break;
			endif;
		endforeach;
			
	elseif eventType = Event_BOLOut_Delete then		
		docketNo := userInfo.String;
		if docketNo = null then
			return;
		endif;
		if not global.isValidObject(self.myCurrentMasterObject) then
			if self.mode = self.Mode_Edit then
				app.msgBox('Another user has deleted the docket (' &amp; docketNo &amp; ') that you are currently editing. This operation will be cancelled','Docket deleted', MsgBox_Exclamation_Mark_Icon);
				self.myCurrentMasterObject := null;
				self.zDoCancel();
			else
				//app.msgBox('Another user has deleted the docket (' &amp; docketNo &amp; ') that you are currently viewing. It will now be removed from the table','Docket deleted', MsgBox_Exclamation_Mark_Icon);
				self.myCurrentMasterObject := null;
				self.zClearThumbnailData();
			endif;		
		endif;
		
		numRows := tbl.rows;
		foreach row in tbl.fixedRows + 1 to numRows do
			if tbl.getCellText(row, 1) = docketNo then
				tbl.removeItem(row);
				break;
			endif;			 
		endforeach;
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
