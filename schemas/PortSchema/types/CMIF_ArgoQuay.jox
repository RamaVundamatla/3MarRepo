[facility_gkey] [bigint] 	   NOT NULL,</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="facility_gkey" id="24203b97-5ca9-434c-8f10-d1f33f40fe17">
        <embedded/>
        <type name="Integer64"/>
