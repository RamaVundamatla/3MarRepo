    <JadeMethod name="isRetrospective" id="44cdd381-410d-40f7-85aa-a7a025a97748">
        <source>isRetrospective(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release

*/

vars

begin
	if self.myVehicleVisitRecord &lt;&gt; null and self.myVehicleVisitRecord.retrospectiveDT.isValid then
		return true;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendSAP" id="a7df6852-5f4e-4f48-8642-59ea74b089d8">
        <source>sendSAP();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2019	jlgndl1	Initial creation	TFS 44248
11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration

*/

vars

	term : CM_Terminal;
	iter : Iterator;
	cashPayment : CM_CashPayment;
	inv : CM_Invoice;
	invLineSet : CM_InvoiceLineSet;
	invLine : CM_InvoiceLine;

begin
	/*
	
	No Longer using SAP 11/06/2025	navcs2	MTN-34987 MTN -  Disable SAP Integration
	
	term := self.myTerminal;
	if term = null then		// during deferred updating
		term := self.myTrackedItem.myTerminal;
	endif;
	
	if not term.isSapFinancialEnabled then
		return;
	endif;
	
	create invLineSet transient;
	
	//find all prepay non sent invoice lines and add to the sorted collection.
	iter := self.myTrackedItem.allCashPayments.createIterator;
	while iter.next( cashPayment ) do
		invLine := cashPayment.myInvoiceLine;
		if invLine = null or invLine.invoice = null then
			continue;
		endif;
		if invLine.invoice.paymentType &lt;&gt; PaymentType_PrePay then
			continue;
		endif;
		if invLine.externalTS05.date.isValid then
			continue;
		endif;
		//if inv.hasWSDL112BgpForLine( invLine ) then	//14 May 2019	NDL	TFS 44248
		if invLine.invoice.hasWSDL112BgpForLine( invLine ) then	//20 May 2019	NDL	TFS 44248
			continue;
		endif;
		
		//invLineSet.add( invLine ); //06/05/2025	navkc1 JIRA Bug MTN-34801
		invLineSet.tryAdd(invLine); //06/05/2025	navkc1 JIRA Bug MTN-34801
			
	endwhile;
	
	if not invLineSet.isEmpty then
		self.doGroupAndSendSAP( invLineSet );
	endif;
	*/
epilog

	delete invLineSet;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="d7c39b30-50f7-41b1-b775-94d9988dffc7">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2020	jlgndl1	Initial creation	TFS 49202
18 May 2022	navma1	ChangeRequest 53430: EUP - Sub Carrier registration in MTN
*/

vars

	truck 					: CM_Vehicle;
	originatingLocation		: CM_LocationsController;
	vvr						: CM_VehicleVisitRecord;
begin

	inheritMethod(_tiTransCntrl, _passport);
	
	self.setLastYardLocationFromMoveTrx();
	self.locationRoad := _tiTransCntrl.myTrackedItem.priorLocation;
	
	originatingLocation:= _tiTransCntrl.myOriginatingLocation;
	
	if originatingLocation &lt;&gt; null then
		if originatingLocation.isVehicle then
			truck := originatingLocation.CM_VehicleController.vehicle;
			if truck &lt;&gt; null then
				self.regNumber := truck.regNumber;
			endif;
		endif;
	endif;
	
	//21 Oct 2020	NDL	TFS 50113
	vvr := _tiTransCntrl.myVVR;									//18.5.2022 navma1 #53430
	if vvr &lt;&gt; null then
		self.myVehicleVisitRecord	:= vvr;						//18.5.2022 navma1 #53430
		self.trailerTypeCode        := vvr.getTrailerTypeCode( self );
	endif; 
	
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLastYardLocationFromMoveTrx" id="b47ca55c-fb76-4ebf-82e9-f131af3a187b">
        <updating/>
        <source>setLastYardLocationFromMoveTrx()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2020	jlgndl1	Initial creation	TFSD 49202

*/

vars

	trxDict : CM_TITransactionByTypeDateDict;
	trx : CM_TITransaction;
	lc : CM_LocationsController;
	ta : CM_TerminalArea;

begin

	create trxDict transient;
	
	self.myTrackedItem.allTransactions.getAllTransactionsOfClass( CM_Move, trxDict, false );
	self.myTrackedItem.allTransactions.getAllTransactionsOfClass( CM_Pickup, trxDict, false );
	
	foreach trx in trxDict discreteLock do
		if trx.CM_Move.mode &lt;&gt; REAL_MODE then
			continue;
		endif;
		lc := trx.CM_Move.getSourceLocationsController();
		if lc &lt;&gt; null and lc.isYardLocation then
			ta := trx.CM_Move.getSourceTA();
			if ta &lt;&gt; null and not ta.isTransferArea then
				self.locationYard := lc.getFullId;
				return;
			endif;
		endif;
	endforeach;

epilog

	delete trxDict;

end;</source>
    </JadeMethod>
