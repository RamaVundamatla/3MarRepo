    <JadeMethod name="displayExtraInfoForObj" id="a81ecea0-3946-4498-bc65-716b697b0ea1">
        <source>displayExtraInfoForObj(_obj : CM_Object);
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	dataContainer : CM_DataContainer;
begin

	self.tblInfo.clear();
	self.tblInfo.rows := 0;

	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
			
	if _obj &lt;&gt; null  then
		_obj.getExtraInfoRail(self.optDirInTB.value, dataContainer);
		_obj.getExtraInfo(dataContainer);
		self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 1, 1, 1);
		self.doResizeColumnWidths(self.tblInfo, true);
	endif;

	self.picCargo.picture := self.showCargoPicture(_obj);
	
epilog
	delete dataContainer;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
