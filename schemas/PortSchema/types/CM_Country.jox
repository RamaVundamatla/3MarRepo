    <JadeMethod name="displayForXlation" id="ce792244-424f-411b-8041-06cc3155bb2e">
        <source>displayForXlation(_codeFirst: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2022	jlier1	Initial creation 54846

*/

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
epilog

end;</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="a3cf208a-9e13-4222-9e28-862628e58f3d">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	port    : CM_Port;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach port in self.ports do
		if tmpStr = null then
			tmpStr := port.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; port.code;
		endif;
	endforeach;

	txt := txt &amp; 'Ports' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="5c7ea27f-4ae4-4b64-8750-5bfb5812c978">
        <source>getAuditTextForProperty(_property: Property): String;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 16 March 2007
//
//----------------------------------------------------------------------

vars
	propName,
	txt,
	tmpStr : String;
	port : CM_Port; 
begin
/*	propName := _property.name;
	txt := null;
	if propName = CM_Country::ports.name then
		foreach port in self.ports do
			if tmpStr = null then
				tmpStr := port.code;
			else
				tmpStr := tmpStr &amp; ', ' &amp; port.code;
			endif;
		endforeach;
		txt := txt &amp; 'Ports' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		
		return txt;
	endif;
	*/
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="762861f9-39af-457d-9911-67309762be98">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.description;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="985f04f4-1c94-4e89-a818-9bfcbf21c8be">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 April 2014 by cnwdb2

//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Apr 2014	cnwdb2		PAR #33977  
// 03/08/2023	navkc1		CR 59552   Task 59555: UI CustDocs - Country Region Maint
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_NotAvailableForEntry then
		return self.isNotAvailableForEntry.String;
	elseif _attrName = ETRow_MyCountryRegion then	//03/08/2023	navkc1	CR 59552   Task 59555
		if self.myCountryRegion &lt;&gt; null then
			return self.myCountryRegion.code;
		endif;
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
