    <JadeMethod name="mnuBookingRefDiscrep_click" id="edf13f99-e978-4941-a8ad-cefe36331e46">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuBookingRefDiscrep_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwndl1	Initial creation

*/

vars
	tiArray : CM_TISet;
	obj : Object;
begin
	create tiArray transient;
	if not self.tblData.allSelectedObjects.isEmpty then
		foreach obj in self.tblData.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) then
				tiArray.add(obj.CM_TrackedItem);
			endif;
		endforeach;
	elseif CM_TrackedItem.hasInstance(menuItem.userObject) then
		tiArray.add(menuItem.userObject.CM_TrackedItem);
	endif;
	self.doViewDiscrepancy( tiArray );
	
epilog

	delete tiArray;

end;</source>
