    <JadeMethod name="trxSetEDIAsActualBayPlan" id="9802adcd-b89b-4db2-bf16-cd2d1a7e95aa">
        <updating/>
        <source>trxSetEDIAsActualBayPlan(_voyage : CM_Voyage input; _ediBP : CM_VoyageEDIBayPlanController input; _clearDetails, _mergeRetainAllCargo, _mergeRetainEDICargo, _mergeRetainManCargo, _mergeRetainNoCargo, _mergePlanning :Boolean; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			27 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
July 2008	cnwrs1	Par 17595 additional parameters
20/05/2010	cnwcs5	Changed merge parameters to be usage constant
03/02/2018	jlgrs1	TFS 36963 - add tranlog timings
22/01/2021	jlgdap1	TFS 50553 PNL Handling of Nested Child Cargo in EQA Segment
------------------------------------------------------------------------
*/
vars
	tmpStr : String;
	tmpId : Integer;
	ediData : CM_EDIDataBayPlan;			// TFS 50553
begin
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	tmpStr := method.qualifiedName;
	app.writeLog(tmpStr&amp;' '&amp;_voyage.code, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	tmpId := self.cnStartTransaction(tmpStr[1:50]);
	// Long transaction so we want it to survive deadlock
	// Par 13004
	process.setPersistentDeadlockPriority(1);

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate 			:= true;
	
	app.myUtilityUA.utlSetEDIAsActualBayPlan(_voyage, _ediBP, _clearDetails, _mergeRetainAllCargo, _mergeRetainEDICargo, _mergeRetainManCargo, _mergeRetainNoCargo, _mergePlanning, _passport) ;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

	ediData := _ediBP.myEdiData.CM_EDIDataBayPlan;							// TFS 50553
	ediData.updateParentAndChildFlatRacks(_ediBP.myVoyage, _passport);		// TFS 50553
	
epilog
	if tmpId &lt;&gt; null then
		self.cnEndTransactionEx(tmpId);
	endif;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_ediBP" type="CM_VoyageEDIBayPlanController" usage="input"/>
        <Parameter name="_clearDetails" type="Boolean"/>
        <Parameter name="_mergeRetainAllCargo" type="Boolean"/>
        <Parameter name="_mergeRetainEDICargo" type="Boolean"/>
        <Parameter name="_mergeRetainManCargo" type="Boolean"/>
        <Parameter name="_mergeRetainNoCargo" type="Boolean"/>
        <Parameter name="_mergePlanning" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
