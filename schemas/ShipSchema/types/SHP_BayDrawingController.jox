    <JadeMethod name="redrawSlots" id="009a15be-2382-4423-9113-08903326b4cd">
        <source>redrawSlots();
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	tmpFrame	: SHP_BayDrawingFrame;
	st, et		: Integer;	
begin

	foreach tmpFrame in self.allBayDrawingFramesById do
		beginLoad;
		tmpFrame.redrawSelf();
		endLoad;
	endforeach;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="redrawWeightsForSlot" id="97050e29-1a06-4079-9922-b44917f33ca1">
        <updating/>
        <source>redrawWeightsForSlot(_slotController : CM_SlotController) updating;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/05/2015	cnwdap1		PAR #36269 TFS 331 Visual Display of Weight Data
vars
	frame	: SHP_BayDrawingFrame;
	tmpBay	: CM_BayVoyage;
	tmpOrdDeck,
	theX,
	theY,
	tmpWeight,tierOrd	: Integer;
	isOverweight	: Boolean;
	 maxX, maxY : Real;
	mode : Integer;
	weight20 : Integer;
	weightOthers : Integer;
	maxWeight : Integer;
	comment : String;
	cellDefn : CM_CellDefn;
	showWeights : Boolean;							// PAR #36269
	showHeights : Boolean;							// PAR #36269
	usedHeight,										// PAR #36269
	maxHeight,										// PAR #36269
	remHeight : Integer;							// PAR #36269
begin
	
	if _slotController = null or
	   (not self.hasWeights) then
		return;
	endif;

	tmpBay := _slotController.myBayVoyage;
	frame := self.getFrameForBay(tmpBay);
	
	if frame = null then
		return;
	endif;

	tmpOrdDeck := _slotController.ordinalDeck;

	self.setLabelFont(frame);
	
	//25 Jan 2011	NDL Par 26641
	if self.displayMode = ShpDisplayMode_Actual then	
		mode := ShpDisplayMode_Actual;
	else
		//proposed or colour code load or colour code discharge
		mode := ShpDisplayMode_Proposed;
	endif;

	cellDefn := _slotController.getCellDefn;
	if cellDefn &lt;&gt; null then
		cellDefn.getPileWeight(	weight20,	//_weight20s : Integer output;
								weightOthers,	//_weightOthers : Integer output;
								tmpWeight,	//_displayWeight : Integer output;
								maxWeight,	//_maxPileWeight : Integer output;
								mode,	//_mode : Integer;
								comment	//_makeUpComment : String output
								);
		isOverweight := tmpWeight &gt; maxWeight;
	endif;
	
	theX := frame.leftSideMargin + _slotController.mySlotDefnVoyage.myCellDefinition.getDrawingPosX(self.columnWidth);
	theX := theX + self.xAxisLabelOffset;
	
	showWeights := self.myTerminal.getConfig(ShowWeightsLOLOPlanning).Boolean;					// PAR #36269 
	showHeights := self.myTerminal.getConfig(ShowHeightsLOLOPlanning).Boolean;					// PAR #36269 
	
	if tmpOrdDeck = DeckOnDeck then
		if showWeights or showHeights then
			theY := self.yHatchPos - 45;
			if showWeights and showHeights then
				theY := theY - 30;
			endif;
		else
			theY := self.yHatchPos - 15;
		endif;
	else
		theY := self.yUnderDeckEndPos + 2;
		if showHeights and showWeights then
			theY := theY + 15;
		endif;
	endif;
	
	// blank out any existing figures
	frame.drawFillColor := frame.backColor;
	frame.drawFilledRectangle(theX, theY, theX + 20, theY + 12, frame.drawFillColor);
	if showWeights then
		frame.drawFilledRectangle(theX, theY+15, theX + 20, theY + 30, frame.drawFillColor);
		frame.drawFilledRectangle(theX, theY+30, theX + 20, theY + 45, frame.drawFillColor);
	endif;
	self.drawCellPileWeight(frame, tmpBay, tmpWeight, isOverweight, theX, theY);
	if showWeights then
		self.drawCellPileWeight(frame, tmpBay, (maxWeight-tmpWeight), isOverweight, theX, theY+15);
		self.drawCellPileWeight(frame, tmpBay, maxWeight, isOverweight, theX, theY+30);
	endif;
	// now heights
	if showHeights then
		if showWeights then
			theY := theY + 45;
		else
			theY := theY + 15;
		endif;
		frame.drawTextAlign := Frame.DrawTextAlign_Left;
		//epr par 37334 14/1/16 added the + 1 to stop the line being overdrawn between the weights and heights
		frame.drawFilledRectangle(theX, theY + 1, theX + 20, theY+15, frame.drawFillColor);
		frame.drawFilledRectangle(theX, theY+15, theX + 20, theY+30, frame.drawFillColor);
		frame.drawFilledRectangle(theX, theY+30, theX + 20, theY+45, frame.drawFillColor);
		// draw the new heights
		cellDefn := _slotController.getCellDefn;
		if cellDefn &lt;&gt; null then
			cellDefn.getPileHeights(mode,usedHeight, remHeight, maxHeight);
		endif;
		self.drawCellPileWeight(frame, tmpBay, usedHeight, (usedHeight &gt; maxHeight), theX, theY);
		self.drawCellPileWeight(frame, tmpBay, remHeight, (usedHeight &gt; maxHeight), theX, theY+15);
		self.drawCellPileWeight(frame, tmpBay, maxHeight, (usedHeight &gt; maxHeight), theX, theY+30);
	endif;

	// ============================================================
	// now handle the TIER weight
	// ============================================================
	
	if tmpOrdDeck = DeckOnDeck then
		frame.allObjectsOnDeck.getMaxXY(maxX, maxY);
		theX := maxX.Integer + 5;
		theY := frame.getOnDeckOffset(null, self) - self.rowHeight + self.yAxisLabelOffset;		//cnwmc5 - 25 Oct 2013 - PAR 32847
		theY := theY - (self.rowHeight * _slotController.ordinalTier) + self.rowHeight - 5;
		if showWeights then
			theY := theY - 5;
		endif;
	else
		frame.allObjectsUnderDeck.getMaxXY(maxX, maxY);
		theX := maxX.Integer + 5;
		theY := self.yUnderDeckPos + self.yAxisLabelOffset;

		tierOrd := ((tmpBay.allTiersUnderDeck.size - _slotController.ordinalTier) + 0.5).Integer ;
		theY := theY + (self.rowHeight * tierOrd) + 7;
	endif;
	
	// blank out any existing figures
	frame.drawFillColor := frame.backColor;
	frame.drawFilledRectangle(theX-2, theY, theX + 23, theY + 15, frame.drawFillColor);
	
	if showWeights then
		self.drawTierPileWeight(frame, tmpBay, tmpOrdDeck, _slotController.ordinalTier, theX, theY+3);
	else
		self.drawTierPileWeight(frame, tmpBay, tmpOrdDeck, _slotController.ordinalTier, theX, theY);
	endif;

epilog
	if frame &lt;&gt; null then
		self.setDefaultFont(frame);
	endif;

end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="selectBlockOfObjectsFromXYs" id="be30d9a9-cd14-45d2-8961-4329223a5324">
        <updating/>
        <source>selectBlockOfObjectsFromXYs( _class : Class; _x1,_y1,_x2,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	objs : ObjectArray ;
	startObj, anObj : Object;
	selectTI : Boolean;
	cdc : SHP_BayDrawingController;
	realX1,realX2,realY1,realY2 : Integer;
	frmX1,frmX2,frmY1,frmY2 : Integer;
	objX1,objX2,objY1,objY2 : Integer;

	tmpFrame : SHP_BayDrawingFrame;
begin
	create objs transient;

	cdc := self;

	realX1 := _x1;
	realY1 := _y1;
	realX2 := _x2;
	realY2 := _y2;

	if _x1 &gt; _x2 then
		realX1 := _x2;
		realX2 := _x1;
	endif;
	
	if _y1 &gt; _y2 then
		realY1 := _y2;
		realY2 := _y1;
	endif;
	
	foreach tmpFrame in self. allBayDrawingFramesById do

		frmX1 := tmpFrame.left.Integer;
		frmX2 := tmpFrame.clientWidth + tmpFrame.left.Integer;
		frmY1 := tmpFrame.top.Integer;
		frmY2 := tmpFrame.clientHeight + tmpFrame.top.Integer;
		
		// ### skip the frames that we are not interested in.
		if ((frmX1 &lt;= realX1 and frmX2 &gt;= realX1) or (frmX1 &gt;= realX1 and frmX2 &lt;= realX2) or (frmX1 &lt;= realX2 and frmX2 &gt;= realX2))
		and ((frmY1 &lt;= realY1 and frmY2 &gt;= realY1) or (frmY1 &gt;= realY1 and frmY2 &lt;= realY2) or (frmY1 &lt;= realY2 and frmY2 &gt;= realY2)) then

			objs.clear;
			
			objX1 := realX1 - frmX1;
			objX2 := realX2 - frmX1;
			objY1 := realY1 - frmY1;
			objY2 := realY2 - frmY1;
			tmpFrame.allObjectsOnDeck.findObjectsInDict(objX1,objY1,objX2,objY2, objs, _class,true,false);
			tmpFrame.allObjectsUnderDeck.findObjectsInDict(objX1,objY1,objX2,objY2, objs, _class,true,false);
	//objs.inspect;
			foreach anObj in objs do
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. selct " &amp; anObj.CM_SlotController.getFullId());
				self.selectObject(anObj,tmpFrame,true);	
			endforeach;
//cdc.inspect;	
		endif;
	endforeach;
	
		

	
//	_frame.reorderSelectedObjects(_x1,_y1,_x2,_y2, objs,1);	
epilog
	delete objs;


end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectObjectsForJob" id="ed60cbab-8dd5-4a6c-8809-e0e9cdfaafd6">
        <updating/>
        <source>selectObjectsForJob(_job : CM_VoyageJob; _inLoadMode, _clearFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHatchLidJob	: CM_VoyageHatchLidJob;
	tmpHatchLid		: CM_HatchLid;
	tmpRequest		: CM_Request;
	tmpSlotRequest	: CM_SlotRequest;
	tmpLC			: CM_LocationsController;
	tmpSlot			: CM_SlotController;
	tmpTI			: CM_TrackedItem;
//	tmpTISet		: CM_TISet;
	tmpBay			: CM_Bay;
	tmpFrame		: SHP_BayDrawingFrame;
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	beginLoad;

	if _clearFirst then
		self.clearAllSelectedObjects();
	endif;
	
	if _job.isKindOf(CM_VoyageHatchLidJob) then
		tmpHatchLidJob := _job.CM_VoyageHatchLidJob;
		foreach tmpHatchLid in tmpHatchLidJob.allHatchLids do
			// need to find frame object is on to redraw
			foreach tmpBay in tmpHatchLid.allBays do
				tmpFrame := self.allBayDrawingFramesById[tmpBay.id];
				if tmpFrame &lt;&gt; null then
					self.selectObject(tmpHatchLid, tmpFrame, true);
				endif;
			endforeach;
		endforeach;
	else
		foreach tmpRequest in _job.allRequests do
			if (not CM_SlotRequest.hasInstance(tmpRequest)) then
				continue;
			endif;
			tmpSlotRequest := tmpRequest.CM_SlotRequest;
			if _inLoadMode then
				if tmpSlotRequest.isDischarge then
					continue;
				endif;
			else
				if tmpSlotRequest.isLoad then
					continue;
				endif;
			endif;
			tmpSlot	:= tmpSlotRequest.mySlotController; 
			if tmpSlot = null then
				continue;
			endif;
			tmpFrame := self.allBayDrawingFramesById[tmpSlot.myBayVoyage.id];
			if tmpFrame &lt;&gt; null then
				self.selectObject(tmpSlot, tmpFrame, true);
			endif;
		endforeach;
	endif;

epilog
	endLoad;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_inLoadMode" type="Boolean"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectSlotsForJob" id="0b16a406-7030-4a6b-bbd6-119919521a1e">
        <updating/>
        <source>selectSlotsForJob(_origSlotController : CM_SlotController) updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRequest	: CM_Request;
	tmpJob		: CM_VoyageJob;
	tmpSlot		: CM_SlotController;
	inLoadMode	: Boolean;
	
begin

	if _origSlotController = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_origSlotController', null, null);
		return;
	endif;

	if self.workingMode &lt;&gt; SHP_VoyageAreaForm2.WorkMode_Job then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid working mode (' &amp; self.workingMode.String &amp; ')for selecting jobs');
		return;
	endif;

	if self.displayMode = ShpDisplayMode_ColCodeLoad then
		inLoadMode := true;
		tmpRequest := _origSlotController.mySlotRequestLoad;
	elseif self.displayMode = ShpDisplayMode_ColCodeDisch then
		tmpRequest := _origSlotController.mySlotRequestDischarge;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid display mode (' &amp; self.displayMode.String &amp; ')for selecting jobs');
		return;
	endif;
	
	if tmpRequest = null then
		// slot not marked up for discharge/load so
		// can just return
		return;
	endif;
	
	tmpJob := tmpRequest.myJob.CM_VoyageJob;
	
	if tmpJob = null then
		// request not yet associated with a job
		return;
	endif;
	
	self.selectObjectsForJob(tmpJob, inLoadMode, false);

end;</source>
        <Parameter name="_origSlotController" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="setAmPrinting" id="93dea579-ae5d-451d-8527-6bfa09e4c8e6">
        <updating/>
        <source>setAmPrinting(_amPrinting: Boolean; _printOutputSize: Integer; _separateODUD: Boolean) updating;
