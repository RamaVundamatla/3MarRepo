//	return self.myFutureMove.getPrimaryLocation();

	//16 Mar 2011	NDL	Par 27189
	on Exception do app.handleDeletedObject( exception, self.myFutureMove, invalidObject );
	locCont := self.myFutureMove.getPrimaryLocation();
	
	return locCont;

end;</source>
        <ReturnType type="CM_LocationsController"/>
