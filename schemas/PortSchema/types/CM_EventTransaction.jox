    <JadeMethod name="isValidForCamsProcess" id="7b6d02f4-4a3c-42b7-9205-3f875b97dc21">
        <source>isValidForCamsProcess(_startDateTime : TimeStamp; _daysToLookBack : Integer; _trDateTime : TimeStamp io) : Boolean;

/*

Purpose: When in "Looking back" mode (Set on Protocol Desc) we capture any transaction which has either the transaction time 
		 OR was created (i.e. entered into the system) after the start date time of the cams protocol run. Later we will filter out 
		 transactions that are after the end date for the cams protocol run.

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2009	cnwphb1	Initial creation
22 December 2010    cnwgb1	Comments
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
*/

vars

begin
	if _daysToLookBack = 0 then		
		// "Normal processing mode" ignores created time. 
		// This actually implicitly assumes the dateTime is after the start date time
		_trDateTime := self.camsTimeStamp; 
		return true;
	else
		// "Looking Back Mode"
		if self.dateTime &gt; _startDateTime then
			// The transaction time is after the start time so therefore process the transaction.
			_trDateTime := self.camsTimeStamp; 
			return true;
		else
			if self.createdTime &gt; _startDateTime then
				// The transaction was entered after the start time therefore process the transaction.
				_trDateTime := self.createdTime; 
				return true;
			else
				// Both the entry time and the transaction time are before the start time, so don't process the transaction.
				_trDateTime := self.camsTimeStamp; 
				return false;
			endif;
		endif;
	endif;
end;
</source>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_daysToLookBack" type="Integer"/>
        <Parameter name="_trDateTime" type="TimeStamp" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
