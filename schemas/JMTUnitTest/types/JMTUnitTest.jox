    <JadeMethod name="afterAutomatedRunChecks" id="7d41a954-1c9a-44a7-a19d-7c82fe4dec69">
        <updating/>
        <source>afterAutomatedRunChecks(commandLine : String) updating;

/*

Purpose:		This method runs most of the checking tests that are run after the automated tests are run.
				They were originally run in main (where everything is run from) but if a run has to be
				aborted then they don't get run.
				
				Reason for doing it this way is that adding new delete of UM_Blame and UM_BlameItem records
				if they exist after a run but need to flag them as existing so we can check to see why
				they were created and under the old way they would never get run.

Date			Who		Reason
13/06/2016		cnwmh5	Initial creation
08/05/2025		navhn30 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1
*/

vars

	file						: File;
	root						: UM_Root;
	testRunner 					: JMTTestController;
	verAdmin					: UT_Verification_Admin;
	association					: CM_Association;
	unitTestRun					: UM_UnitTestRun;
	
	paramNames					: StringArray;
	paramValues					: StringArray;
	userSummaryDict				: CM_AssociationDict;
	
	iter						: Iterator;

	miscDirectory				: String;
	runDateReversed				: String;
	index						: Integer;
	param						: String;
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	line						: String;
	posTab						: Integer;
	user						: String;
	summary						: String;
	
begin

	/*******************************************************************
	* Get the command line parameters
	*******************************************************************/
	create paramNames transient;
	create paramValues transient;
	self.parseCommandLine(commandLine, paramNames, paramValues);
	
	foreach index in 1 to paramNames.size do
		param := paramNames[index].toUpper;
		if param = "RUNDATE" then
			runDateReversed := paramValues[index];
		endif;
	endforeach;
	app.writeLog("runDate: " &amp; runDateReversed.String, LogINFO);
	
	/*******************************************************************
	* Get the file for the run
	*******************************************************************/
	create file transient;
	miscDirectory := app.cnGetServerMiscPath() &amp; "\AutomatedRunDetails";
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := miscDirectory &amp; "\unitTestRunTime" &amp; runDateReversed &amp; ".txt";
	file.usePresentationFileSystem := false;
	app.writeLog("file: " &amp; file.fileName, LogINFO);
	if not file.isAvailable() then
		app.writeLog("Unit Test Run Time file or Directory not found.  Aborting run...", LogINFO);
		return;
	endif;
	
	/*******************************************************************
	* Get Start and End times from the file.  
	* If no end time just use actual server app server
	*******************************************************************/
	startTS := null;
	endTS := null;
	while not file.endOfFile do
		line := file.readLine();
		if line = null then
			continue;
		endif;
		posTab := line.pos(Tab, 1);
		if startTS = null then
			startTS.setDate(line[1:posTab-1].Date);
			startTS.setTime(line[posTab+1:end].Time);
		elseif endTS = null then
			endTS.setDate(line[1:posTab-1].Date);
			endTS.setTime(line[posTab+1:end].Time);
			endTS := endTS.addHours(1);
		endif;
	endwhile;
	file.close();
	if endTS = null then
		endTS := app.actualTimeAppServer;
	endif;
	app.writeLog('startTS: ' &amp; startTS.date.format("dd/MM/yyyy") &amp; Tab &amp; startTS.time.String &amp; ' endTS: ' &amp; 
		endTS.date.format("dd/MM/yyyy") &amp; Tab &amp; endTS.time.String, LogINFO);
	
	/*******************************************************************
	* Get the run's run object
	*******************************************************************/
	root := UM_Root.firstInstance;
	if root = null then
		app.writeLog("No Root Object found.  Aborting run...", LogINFO);
		return;
	endif;
	
	foreach unitTestRun in root.allUnitTestRuns reversed, discreteLock do
		if unitTestRun.startTS.truncateToSecond() = startTS.truncateToSecond() then
			app.myUMTestRunONight := unitTestRun;
			break;
		endif;	
	endforeach;
	if app.myUMTestRunONight = null then
		app.writeLog("No Test Run Object found.  Aborting run...", LogINFO);
		return;
	endif;

	/*******************************************************************
	* create additional object so can run
	*******************************************************************/
	create testRunner transient;
	create userSummaryDict transient;
	create verAdmin transient;
	
	/*******************************************************************
	* checking methods to run
	*******************************************************************/
	
	// 02/12/2013 cnwmh5 - Check to see if there are any stack dumps created during the run
	userSummaryDict.clear();
	verAdmin.sendMsgWithIOParams('vCheckForStackDumps', startTS, endTS, userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Stack Dumps (" &amp; app.stackDumpCount.String &amp; ")", 2, testRunner,null,false);
	endwhile;
	
	// 05/12/2013 cnwmh5 - Check to see if any tests need immediate action
	userSummaryDict.clear();
	verAdmin.sendMsgWithIOParams('vCheckSelectedTestsHaveFailed', startTS, endTS, userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Immediate Attention", 2, testRunner,null,false);
	endwhile;
	
	// 05/12/2013 cnwmh5 - Alert ADMIN(s) to those failing for more that UM_Blame::DateThreshold (currently 10)
	userSummaryDict.clear();
	verAdmin.sendMsgWithIOParams('vReportFailingGTThreshold', userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Failing Require Attention", 2, testRunner,null,false);
	endwhile;
	
	userSummaryDict.clear();
	verAdmin.sendMsgWithIOParams('vCheckFutureQueuedMoves', userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Failing Require Attention", 2, testRunner,null,false);
	endwhile;
	
	// 16/07/2014 cnwmh5 - Alert ADMIN(s) that there are logical certify errors that need chasing up
	userSummaryDict.clear();
	verAdmin.sendMsgWithIOParams('vReportLogicalCertErrors', userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Logical Certify Failures Require Attention", 2, testRunner,null,false);
	endwhile;
	
	userSummaryDict.clear();
	verAdmin.sendMsgWithIOParams('vCheckDatFileSizesGTThreshold', userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), ".dat files GT than Threshold", 2, testRunner,null,false);
	endwhile;
	
	// 24/02/2015 cnwmh5 - Automate the translateForm method
	// 23/09/2015 cnwmh5 - Removed as part of developer process
	// 10/11/2015 cnwmh5 - New Version to only extract required constants
	if not app.isDevelopmentSystemMain() and not app.isUnicode then
		userSummaryDict.clear();
		verAdmin.sendMsgWithIOParams('vGenXLATFormMethod', userSummaryDict);
		line := userSummaryDict.str("CNWMH5");
		userSummaryDict.removeAssoc("CNWMH5");
		iter := userSummaryDict.createIterator();
		summary := "";
		while iter.next(association) do
			userSummaryDict.getIteratorKeys(user, iter);
//			write 'user: ' &amp; user &amp; Tab &amp; 'summary: ' &amp; association.asStringWithoutFailures();
			summary := summary &amp; CrLf &amp; user &amp; "@jadeworld.com" &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; //association.asString;	// 24/03/2011 cnwmh5
			self.emailReports(association.asString, "XLAT Form Constants Missing for " &amp; user, 0, testRunner,null,false);			//cnwmc5 - 12/10/2012
		endwhile;
		if line &lt;&gt; null then
			userSummaryDict.clear();
			userSummaryDict.addAssociation("CNWMH5", line);
			summary := "";
			iter.reset;
			while iter.next(association) do
				userSummaryDict.getIteratorKeys(user, iter);
//				write 'user: ' &amp; user &amp; Tab &amp; 'summary: ' &amp; association.asStringWithoutFailures();
				summary := summary &amp; CrLf &amp; user &amp; "@jadeworld.com" &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; //association.asString;	// 24/03/2011 cnwmh5
				self.emailReports(association.asString, "XLAT Form Constants Missing", 2, testRunner,null,false);			//cnwmc5 - 12/10/2012
			endwhile;
		endif;
	endif;	
	
	// 26/03/2015 cnwmh5 - Automate the Extract / Load for Report Constants
	if app.isDevelopmentSystemMain() then
		userSummaryDict.clear();
		verAdmin.sendMsgWithIOParams('vExtractLoadReportConstants', userSummaryDict);
		iter := userSummaryDict.createIterator();
		while iter.next(association) do
			userSummaryDict.getIteratorKeys(user, iter);
			self.emailReports(association.asStringWithoutFailures(), "Failed to Update Extract Load Report Contants", 2, testRunner,null,false);
		endwhile;
	endif;
	
	// 04/12/2013 - cnwmh5 - Get the transient leak details from the file created during the unit test run
	verAdmin.sendMsgWithParams('vGetRunTransientLeakDetails', startTS, endTS);
	
	// 13/06/2016 cnwmh5 - Check to UM_Blame and UM_BlameItem records
	userSummaryDict.clear();
		verAdmin.sendMsgWithIOParams('vCheckForBlameObjects', userSummaryDict);
		iter := userSummaryDict.createIterator();
		while iter.next(association) do
			userSummaryDict.getIteratorKeys(user, iter);
			self.emailReports(association.asStringWithoutFailures(), "Persistent Blame Objects Found", 2, testRunner,null,false);
		endwhile;
	
	// 02/08/2016 - cnwmk3 - send unit test run stats to accounts every month
	// 19/02/2020 - jlgmh5 - no longer required + hasn't run for a while
	////if app.isDevelopmentSystemMain() and not app.isUnicode then
	///	verAdmin.sendMsgWithParams('vUnitTestStatForLastMonth');
	///endif;
	
	// 10/08/2016 - cnwmk3 - check permissions on the new forms created
	if app.isDevelopmentSystemMain() or app.isUnicode() then
		userSummaryDict.clear();
		verAdmin.sendMsgWithIOParams('vTestPermissions', userSummaryDict);
		line := userSummaryDict.str("CNWMK3");
		userSummaryDict.removeAssoc("CNWMK3");
		iter := userSummaryDict.createIterator();
		summary := "";
		while iter.next(association) do
			userSummaryDict.getIteratorKeys(user, iter);
	//		write 'user: ' &amp; user &amp; Tab &amp; 'summary: ' &amp; association.asStringWithoutFailures();
			summary := summary &amp; CrLf &amp; user &amp; "@jadeworld.com" &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; 
			self.emailReports(association.asString, " Incorrect Permissions set up on Forms for " &amp; user, 0, testRunner,null,false);		
		endwhile;
		if line &lt;&gt; null then
			userSummaryDict.clear();
			userSummaryDict.addAssociation("CNWMK3", line);
			summary := "";
			iter.reset;
			while iter.next(association) do
				userSummaryDict.getIteratorKeys(user, iter);
	//			write 'user: ' &amp; user &amp; Tab &amp; 'summary: ' &amp; association.asStringWithoutFailures();
				summary := summary &amp; CrLf &amp; user &amp; "@jadeworld.com" &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; 
				self.emailReports(association.asString, " Incorrect Permissions set up on Forms ", 2, testRunner,null,false);
			endwhile;
		endif;
	endif;
	
	// 07/12/2017 jlgmh5 - Report any automated tests that have changed in the last day
	userSummaryDict.clear();
	verAdmin.sendMsgWithIOParams('vCheckForTestMethodChanges', userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Automated Test Changes", 2, testRunner,null,false);
	endwhile;
	
epilog

	delete paramNames;
	delete paramValues;
	delete testRunner;
	delete userSummaryDict;	
	delete verAdmin;
	delete iter;
	
	/// temporarily removed
	if file &lt;&gt; null and file.isAvailable() then
		file.purge();
	endif;
	delete file;
	
end;</source>
        <Parameter name="commandLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="checkAutoUnitTestIsRunning" id="eeb81a69-7065-4447-b79c-d4037533e5d4">
        <source>checkAutoUnitTestIsRunning();

/*

Purpose:		Checks if Unit Test Auto is running.  If not start it up	

Date			Who		Reason
01 April 2011	cnwmh5	Initial creation

*/
constants

	APPLICATION_NAME = 'JMTUnitTest_Auto';
	
vars

	theNodes 		: NodeDict;
	theProcesses	: ProcessDict; 
	aNode 			: Node;	
	aProcess 		: Process;
	invalidNode,
	invalidProcess	: Boolean;
	unitTestRunning	: Boolean;
	
begin
	
	theNodes := system.nodes.cloneSelf(true);			
	
	on Exception do app.handleDeletedObject(exception, aNode, invalidNode);
	on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);
	
	foreach aNode in theNodes do
	
		invalidNode := false;
		
		if not aNode.isServerNode then
			continue;
		endif;
		
		// Clone the nodes collection of processes
		delete theProcesses;
		theProcesses := aNode.processes.cloneSelf(true);
		
		// If we had an exception accessing the node, then skip it
		if invalidNode then
			continue;
		endif;
		
		foreach aProcess in theProcesses do
			if aProcess.persistentApp.name = APPLICATION_NAME then
				unitTestRunning := true;
				break;
			endif;
		endforeach;	

		if unitTestRunning then 
			break;
		endif;
			
	endforeach;
	
	// not running so lets start it up
	if not unitTestRunning then
		self.startUnitTestAutoRun();
	endif;
	
epilog

	terminate;

end;</source>
    </JadeMethod>
