    <JadeMethod name="addBulkRelease" id="8a268b9b-4925-409c-b8e6-33e9c16cf661">
        <updating/>
        <source>addBulkRelease(_bulkRelease : CM_BulkRelease; _pinNumber : String; _rd : CM_ReserveDetail) : CMIF_TIObject updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 August 2006 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
// ---------------------------------------------------------------------------
vars

	tmpReleaseByType		: CMIF_ReleaseByType;
	tmpReleaseByID			: CMIF_ReleaseById;	
	retValue				: CMIF_TIObject;	

begin

	if _rd = null then	//19 May 2020	NDL	TFS 49167
		create tmpReleaseByID transient;
		self.allTransients.add(tmpReleaseByID);
		tmpReleaseByID.setForAAAI( _bulkRelease );
		retValue := tmpReleaseByID;
		
	elseif CM_ReserveSelection.hasInstance(_rd) then
		create tmpReleaseByType transient;
		self.allTransients.add(tmpReleaseByType);
		tmpReleaseByType.setFromBulkRelease(_bulkRelease, _rd.CM_ReserveSelection);
		retValue := tmpReleaseByType;
		
	else
		create tmpReleaseByID transient;
		self.allTransients.add(tmpReleaseByID);
		tmpReleaseByID.setFromBulkRelease(_bulkRelease, _rd);
		retValue := tmpReleaseByID;
		
	endif;
	
	return retValue;
	
end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_pinNumber" type="String"/>
        <Parameter name="_rd" type="CM_ReserveDetail"/>
        <ReturnType type="CMIF_TIObject"/>
    </JadeMethod>
    <JadeMethod name="adjustContainerLayout" id="3b23a8a5-c1c0-47e2-b505-441d07f0b3f0">
        <source>adjustContainerLayout() protected;
// --------------------------------------------------------------------------------
// Created:		24 September 2006 by cnwdad1
//
// Purpose:		This method is a wrapper for the method which adjusts the container
//				and ID label layout depending upon how many containers there are
//				for receivals and releases.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	
begin
	
	self.adjustContainersAndLabels(	self.aMyProxyLoad.allReceivals,
									393,
									587,
									65,
									lblReceive1,
									picReceive1,
									lblReceive2,
									picReceive2,
									lblReceive3,
									picReceive3,
									lblReceive4,
									picReceive4);
									
	//19 May 2020	NDL	TFS 49167
	if self.isAAAI then
		self.adjustGeneralCargoLayout();
		
	else	
		self.adjustContainersAndLabels(	self.aMyProxyLoad.allReleases,
										393,
										587,
										241,
										lblRelease1,
										picRelease1,
										lblRelease2,
										picRelease2,
										lblRelease3,
										picRelease3,
										lblRelease4,
										picRelease4);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="adjustContainersAndLabels" id="e27bf418-de46-483a-9adf-63251f9342ec">
        <source>adjustContainersAndLabels(	_allProxyCargosObj:GTE_KioskProxyCargoArray;
							_containerLeft1:Integer;	// The default left position of Container 1.
							_containerLeft2:Integer;	// The default left position of Container 2.
							_labelTop:Integer;			// The default top position of Container 1's ID label.
							_labelObj1:CMUI_Label input;
							_containerObj1:CMUI_ContainerLoad input;
							_labelObj2:CMUI_Label input;
							_containerObj2:CMUI_ContainerLoad input;
							_labelObj3:CMUI_Label input;
							_containerObj3:CMUI_ContainerLoad input;
							_labelObj4:CMUI_Label input;
							_containerObj4:CMUI_ContainerLoad input) protected;
// --------------------------------------------------------------------------------
// Created:		27 September 2006 by cnwdad1
//
// Purpose:		Adjusts the container layout depending upon how many containers
//				there are.
//
// Parameters:	All of the container ID labels and container controls.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyCargoObj		: GTE_KioskProxyCargo;
	containerObj		: CMUI_ContainerLoad;
	labelObj			: CMUI_Label;
	cargoCount			: Integer;
	fortyCount			: Integer;
	cargoWidth1			: Integer;
	cargoWidth2			: Integer;
	cargoWidth3			: Integer;
	cargoWidth4			: Integer;
	
begin
	_labelObj1.visible		:=	false;
	_containerObj1.visible	:=	false;
	_labelObj2.visible		:=	false;
	_containerObj2.visible	:=	false;
	_labelObj3.visible		:=	false;
	_containerObj3.visible	:=	false;
	_labelObj4.visible		:=	false;
	_containerObj4.visible	:=	false;
	fortyCount				:=	_allProxyCargosObj.getFortyCount();
	cargoCount				:=	0;
	
	foreach proxyCargoObj in _allProxyCargosObj do
		cargoCount	:=	cargoCount + 1;
		
		if cargoCount = 1 then
			containerObj	:=	_containerObj1;
			labelObj		:=	_labelObj1;
		elseif cargoCount = 2 then
			containerObj	:=	_containerObj2;
			labelObj		:=	_labelObj2;
		elseif cargoCount = 3 then
			containerObj	:=	_containerObj3;
			labelObj		:=	_labelObj3;
		elseif cargoCount = 4 then
			containerObj	:=	_containerObj4;
			labelObj		:=	_labelObj4;
		else
			break;
		endif;
		
		labelObj.cnEcSet(proxyCargoObj.id());
		containerObj.initializeMe(	proxyCargoObj.id(),
									proxyCargoObj.count,
									proxyCargoObj.isDoorsBack,
									proxyCargoObj.isEmpty,
									proxyCargoObj.isForty);
	endforeach;
	
	if cargoCount &gt; 0 then
		_labelObj1.visible		:=	true;
		_containerObj1.visible	:=	true;
	endif;
	
	if cargoCount &gt; 1 then
		_labelObj2.visible		:=	true;
		_containerObj2.visible	:=	true;
	endif;
	
	if cargoCount &gt; 2 then
		_labelObj3.visible		:=	true;
		_containerObj3.visible	:=	true;
	endif;
	
	if cargoCount &gt; 3 then
		_labelObj4.visible		:=	true;
		_containerObj4.visible	:=	true;
	endif;
	
	if cargoCount &lt;= 2 and fortyCount = 0 then
		if cargoCount = 0 then
			_containerObj1.setIsEmpty(true);
			_containerObj2.setIsEmpty(true);
		endif;
		
		_containerObj1.stretch	:=	Picture.Stretch_ControlTo;
		_containerObj2.stretch	:=	Picture.Stretch_ControlTo;
		_containerObj1.left		:=	_containerLeft1;
		_containerObj2.left		:=	_containerLeft2;
		
		return;
	else
		_containerObj1.stretch	:=	Picture.Stretch_ToControl;
		_containerObj2.stretch	:=	Picture.Stretch_ToControl;
		_containerObj3.stretch	:=	Picture.Stretch_ToControl;
		_containerObj4.stretch	:=	Picture.Stretch_ToControl;
		_containerObj1.left		:=	_containerLeft1 - 10;
		
		cargoWidth1		:=	0;
		cargoWidth2		:=	0;
		cargoWidth3		:=	0;
		cargoWidth4		:=	0;
		
		_allProxyCargosObj.getWidths(cargoWidth1, cargoWidth2, cargoWidth3, cargoWidth4);
		
		if cargoWidth1 = 0 then
			_containerObj1.visible	:=	false;
		else
			_containerObj1.visible	:=	true;
			_containerObj1.width		:=	cargoWidth1;
		endif;
		
		if cargoWidth2 = 0 then
			_containerObj2.visible	:=	false;
		else
			_containerObj2.visible	:=	true;
			_containerObj2.move((_containerObj1.left + _containerObj1.width + 1), _containerObj1.top, cargoWidth2, _containerObj2.height);
		endif;
		
		if cargoWidth3 = 0 then
			_containerObj3.visible	:=	false;
		else
			_containerObj3.visible	:=	true;
			_containerObj3.move((_containerObj2.left + _containerObj2.width + 1), _containerObj2.top, cargoWidth3, _containerObj3.height);
		endif;
		
		if cargoWidth4 = 0 then
			_containerObj4.visible	:=	false;
		else
			_containerObj4.visible	:=	true;
			_containerObj4.move((_containerObj3.left + _containerObj3.width + 1), _containerObj3.top, cargoWidth4, _containerObj4.height);
		endif;
	endif;
	
	_labelObj1.move(_containerObj1.left, _labelTop, _containerObj1.width, _labelObj1.height);
	_labelObj2.move(_containerObj2.left, _labelTop, _containerObj2.width, _labelObj2.height);
	_labelObj3.move(_containerObj3.left, _labelTop, _containerObj3.width, _labelObj3.height);
	_labelObj4.move(_containerObj4.left, _labelTop, _containerObj4.width, _labelObj4.height);
end;</source>
        <access>protected</access>
        <Parameter name="_allProxyCargosObj" type="GTE_KioskProxyCargoArray"/>
        <Parameter name="_containerLeft1" type="Integer"/>
        <Parameter name="_containerLeft2" type="Integer"/>
        <Parameter name="_labelTop" type="Integer"/>
        <Parameter name="_labelObj1" type="CMUI_Label" usage="input"/>
        <Parameter name="_containerObj1" type="CMUI_ContainerLoad" usage="input"/>
        <Parameter name="_labelObj2" type="CMUI_Label" usage="input"/>
        <Parameter name="_containerObj2" type="CMUI_ContainerLoad" usage="input"/>
        <Parameter name="_labelObj3" type="CMUI_Label" usage="input"/>
        <Parameter name="_containerObj3" type="CMUI_ContainerLoad" usage="input"/>
        <Parameter name="_labelObj4" type="CMUI_Label" usage="input"/>
        <Parameter name="_containerObj4" type="CMUI_ContainerLoad" usage="input"/>
    </JadeMethod>
    <JadeMethod name="adjustGeneralCargoLayout" id="663e1f42-c7d1-4cca-b84b-0719736c90db">
        <source>adjustGeneralCargoLayout();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2020	jlgndl1	Initial creation	TFS 49167

*/

constants

	TRAY_WIDTH		: Integer = 399;
	
vars

	proxyCargoObj : GTE_KioskProxyCargo;
	releaseIdStrs : String;

begin

	if not self.isAAAI then
		return;
	endif;

	if self.aMyProxyLoad.allReleases.isEmpty then
		self.picRelease1.visible := false;
		self.lblRelease1.visible :=	false;
		
	else
		self.picRelease1.visible := true;
		foreach proxyCargoObj in self.aMyProxyLoad.allReleases do
			if releaseIdStrs &lt;&gt; null then
				releaseIdStrs := releaseIdStrs &amp; ", ";
			endif;
			releaseIdStrs := releaseIdStrs &amp; proxyCargoObj.id();
		endforeach;
		if self.aMyProxyLoad.allReleases.size &gt; 1 then
			releaseIdStrs := app.getErrorString(Cargo_from_follow_releases) &amp; " : " &amp; CrLf &amp; releaseIdStrs;
		else
			releaseIdStrs := app.getErrorString(Cargo_from_release) &amp; " : " &amp; releaseIdStrs;
		endif;
		
		
		self.lblRelease1.visible :=	true;
		self.lblRelease1.caption := releaseIdStrs;
		
		self.picRelease1.stretch :=	Picture.Stretch_ToControl;
		self.picRelease1.left := 380;
		self.picRelease1.width := 397;
		
		self.lblRelease1.transparent := false;
		self.lblRelease1.backColor := White;
		self.lblRelease1.move( self.picRelease1.left + 3,  self.picRelease1.top + 3, self.picRelease1.width - 6, self.picRelease1.height - 6);
		self.lblRelease1.wordWrap := true;
		
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="check1StopVBS" id="e6423ca8-774a-4dbf-97d7-226d3628e672">
        <source>check1StopVBS(_allBookingSlots : CMIF_1StopBookingDataArray input; _allErrors : CnEcArray input) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2022	navam1	Initial creation
//TFS 53107, AjitM, navam1
 01/03/2023	jlika1		TFS 56731 AAT - 1Stop VBS Booking Not Required to Drop Off Export Empty Containers
*/

vars

	pinNumber 		: String;
	cm_PinNo 		: CM_PinNo;
	release			: CM_BulkRelease;
	container		: CM_Container;
	item			: Object;
	request 		: CMIF_1StopBookingRequest;
	response 		: CMIF_1StopBookingResponse;
	containerId, 
	pin 			: String;
	idToMatch 		: String;
	voyage 			: CM_Voyage;
	
begin
	if not self.aMyTerminal.roadProcessIs1StopVBS or not self.aMyTerminal.is1STOPVBSConfigured then
		return true;
	endif;
	
	foreach pinNumber in self.aAllPinNumbers do
		
		cm_PinNo 	:= self.aMyTerminal.allPinNos[pinNumber];
		item		:= cm_PinNo.allItems.first;
		idToMatch 	:= null;
		voyage		:= null;
		containerId := null;
		
		if(item.isKindOf(CM_BulkRelease)) then
			release	:= item.CM_BulkRelease;
			//if(not release.isForMTs) then 		//jlika1 TFS 56731
				idToMatch := release.code;
				voyage := release.myVoyage;
			//endif;
		elseif (item.isKindOf(CM_Container)) then
			container := item.CM_Container;
			//if(not container.isEmpty) then		//jlika1 TFS 56731
				containerId := container.id;
				idToMatch := container.id;
				voyage := container.myVoyage;
			//endif;
		endif;
	
		if(idToMatch = null and containerId = null) then
			continue;
		endif;
		
		create request transient;
		
		if self.lblCarrier &lt;&gt; null then
			request.carrierCode := self.lblCarrier.caption;
		endif;
		
		//if self.lblRegoNo &lt;&gt; null then
			//request.truckReg := self.lblRegoNo.caption;
		//endif;
		
		request.containerId := containerId;
		
		if(containerId = null) then
			request.pinNumber := pinNumber;
		endif;
		
		//self.aMyTerminal.request1StopVBS(request,response); 		//jlika1 TFS 56731
		
		//if response.data.isEmpty then								//jlika1 TFS 56731
		if not self.aMyTerminal.request1StopVBS(request, response) then
			if container &lt;&gt; null and container.isNotified and voyage &lt;&gt; null and voyage.structureIncludesLOLO then
				if container.isEmpty and not self.aMyTerminal.getConfig(ReqVehicleBooking1Stop).Boolean then
					return true;
				else
					_allErrors.addString(app.getErrorString1(No_vehicle_booking_prenote, container.id));
					return false;
				endif;
			endif;
		
			if release &lt;&gt; null and release.releaseByType and release.fullRelease then
				_allErrors.addString(app.getErrorString1(No_vehicle_booking_release, release.code));
				return false;
			endif;
		endif;
		
		if response &lt;&gt; null then 
			response.data.copy(_allBookingSlots);
		endif;
		
		delete request;
		delete response;
	endforeach;
	
	return true;
		
epilog
	delete request;
	delete response;
end;</source>
        <access>protected</access>
        <Parameter name="_allBookingSlots" type="CMIF_1StopBookingDataArray" usage="input"/>
        <Parameter name="_allErrors" type="CnEcArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRoadJob" id="b36b8a91-10fd-4d54-b9ab-e47c5172610b">
        <source>createRoadJob( _allErrorsObj : CnEcArray input ) : Boolean protected;
// --------------------------------------------------------------------------------
// Created:		14 August 2006 by cnwdad1
//
// Purpose:		Creates a job to process the receival/release.
//
// Parameters:	_allErrorsObj - An array of error messages, if any occur.
//
// Returns:		True if the transaction succeeded, otherwise false, in which case the
//				array parameter will be populated with the error message(s).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 26/03/2007	cnwdad1		PAR #13673. Remarks weren't being retained, and temparature
//							fahrenheit was erroneously being being set to 32.0.
//
// 28/05/2007	cnwdad1		PAR #13284. When the TI object array was deleted, the
//							TI interface objects were being purged (which are created
//							when the proxy load/cargo object is created). If an
//							exception occurs, a re-try caused an error 4.  The array
//							(which is instantiated in this method) is still deleted,
//							but its TI interface objects are preserved on the proxy
//							cargo object (they are deleted by the proxy's destructor).
//
// 25/07/2007	cnwdad1		CCMS #1493 - Added cargo item weight, which may be amended
//							by the driver.
//
// 03/07/2008	cnwdad1		PAR #17219. See comments in epilog.
// 
// 27 Mar 2009	cnwkpd1		PAR #19242 - Need to reinstate the transient cleanup for
//							the CMIF_Receival and CMIF_ReleaseById objects created 
//							in this method, because when these are leaked, the proxy
//							tracked items attached to them can also be leaked,
//							causing subsequent error 75793
//
// 30/07/2009	cnwdad1		PAR #20391 - For a Bulk Release, the mySubTerminal reference
//							was not copied to the tiInterfaceObj.
//
// 02/11/2009	cnwdap1		CCMS MES 1017 Add new over dimension fields
//
// 10/04/2013	cnwdap1		PAR #31411 bring remaining time off power across to receivalObj
// 18/12/2014   cnwma1		PAR #35385 Query -On Power in Transit  enabled Kiosk access removes changes this
// 10/07/2017   cnwma1		TFS #4729:POL - Is Externally Monitored Issue and enhancements ##4690##
// 22 Jan 2018	jlgrs1	TFS 36627 - PENN - Request request code length too short
// 01/03/2023	jlika1		TFS 56731 AAT - 1Stop VBS Booking Not Required to Drop Off Export Empty Containers
// --------------------------------------------------------------------------------
vars
	proxyLoadObj		: GTE_KioskProxyLoad;
	proxyCargoObj		: GTE_KioskProxyCargo;
	allProxyCargosObj	: GTE_KioskProxyCargoArray;
	trackedItemObj		: CM_TrackedItem;
	childTIObj			: CM_TrackedItem;
	stopObj				: CM_Stops;
	tiArrayObj,
	tiDeleteArray		: CMIF_TIObjectArray;			// PAR #19242
	ioCommonObj			: CMIF_InOutCommon;
	tiInterfaceObj		: CMIF_TIObject;
	receivalObj			: CMIF_Receival;
	releaseObj			: CMIF_ReleaseById;
	couObj				: CMIF_InOutCOU;
	attachmentObj		: CMIF_InOutAttachment;
	roadTransArea		: String;	
	errorObj			: CM_Error;
	errorMsg			: String;
	portCode			: String;
	isContainer			: Boolean;
	hasError			: Boolean;
	allStops			: CM_StopsByIdDict;
	//children 			: CM_TISet;//PAR 22954
	allBookingSlots		: CMIF_1StopBookingDataArray ; //TFS 53107, AjitM, navam1
begin
	proxyLoadObj	:=	self.aMyProxyLoad;
	_allErrorsObj.purge();
	
	create allProxyCargosObj transient;
	//create children transient;//PAR 22954
	create tiArrayObj transient;
	create tiDeleteArray transient;		// PAR #19242
	
	proxyLoadObj.getAllCargo(allProxyCargosObj);
	
	// Set common attributes for the job.
	
	create ioCommonObj transient;
	ioCommonObj.myTerminal			:=	self.aMyTerminal;
	//tiArrayObj.add(ioCommonObj);
	ioCommonObj.autoComplete		:=	false;
	ioCommonObj.batNumber			:=	null;
	ioCommonObj.carrierCode			:=	proxyLoadObj.myCarrier.code;
	ioCommonObj.regNumber			:=	proxyLoadObj.regoNumber;
	roadTransArea					:=	self.aMyTerminal.getConfig(DefRoadOpsArea).String.trimRight(); // 1061
	ioCommonObj.roadTransAreaId		:=	roadTransArea;
	
	//cnwrd1 ccms 1862 par 27435 2.5.2011 - use the ini file gate here
	if app.kioskGate &lt;&gt; null then
		ioCommonObj.myGateEntry			:= app.kioskGate;	
	else
		ioCommonObj.myGateEntry			:= self.aMyTerminal.getDefaultGate_IN;	
	endif;

	//cnwrd1 par 28350 10.10.2011
	if ioCommonObj.myGateEntry.myDefaultInterchangeArea &lt;&gt; null then  
		ioCommonObj.roadTransAreaId	 := ioCommonObj.myGateEntry.myDefaultInterchangeArea.id;
	endif;
	
	// Process all of the tracked items - this must be done in the order in which they are
	// stored within the array.
	
	foreach proxyCargoObj in allProxyCargosObj do
		if proxyCargoObj.isBulkRelease() then
			tiInterfaceObj	:=	proxyCargoObj.myTIInterface;
// cnwdad1 30/07/2009 - PAR #20391.
			tiInterfaceObj.mySubTerminal	:=	proxyCargoObj.myCargoItem.CM_BulkRelease.mySubTerminal;
			tiInterfaceObj.setMyInOutCommon(ioCommonObj);
			tiArrayObj.add(tiInterfaceObj);
			
			proxyCargoObj.setDoorsDirection(null);	// #25789 13/10/2010
			
			continue;
		endif;
		
		trackedItemObj	:=	proxyCargoObj.myCargoItem.CM_TrackedItem;

		if trackedItemObj = null then
			_allErrorsObj.addString("Could not locate the Cargo Item (" &amp; proxyCargoObj.myCargoItem.String &amp; ").");
			return false;
		endif;
		
		isContainer		:=	trackedItemObj.isContainer();
		
		if trackedItemObj.site &lt;&gt; TI_SITE_ONSITE then
			// Receive a container.
			
			create receivalObj transient;
			tiArrayObj.add(receivalObj);
			tiDeleteArray.add(receivalObj);			// PAR #19242
							
			receivalObj.setMyPersistentTrackedItem(trackedItemObj);
			receivalObj.setMyInOutCommon(ioCommonObj);
			receivalObj.myTerminal				:=	self.aMyTerminal;
			receivalObj.mySubTerminal := trackedItemObj.mySubTerminal; //23/06/2009 cnwdz2	par20019
			//receivalObj.hasAttachments			:=	trackedItemObj.allChildren.size() &lt;&gt; 0;//PAR 22954
			receivalObj.hasAttachments			:=	trackedItemObj.hasChildren;
			receivalObj.isFromPrenote			:= 	true;	// 12/03/2010 cnwar2 #22900
			
			receivalObj.ignoreWarnings			:=	true;
			receivalObj.myTerminal				:=	self.aMyTerminal;

			foreach portCode in trackedItemObj.allDischargePorts do
				receivalObj.allDischargePorts.add(portCode);
			endforeach;

			proxyLoadObj.cloneHazardsForTI(receivalObj, trackedItemObj);
			receivalObj.bookingReference		:=	trackedItemObj.bookingReference;
			receivalObj.cargoType				:=	trackedItemObj.cargoType;
			
			if isContainer then
				receivalObj.availabilityGrade	:=	trackedItemObj.CM_Container.availabilityGrade;	// cnwdad1 11/01/2007 - PAR #13256.
				receivalObj.carriageTempC	:=	trackedItemObj.CM_Container.getTemperature;
				receivalObj.carriageTempF	:=	trackedItemObj.CM_Container.temperatureInFahrenheit;
				receivalObj.clean			:=	trackedItemObj.CM_Container.isClean;
				receivalObj.contentsStatus	:=	trackedItemObj.CM_Container.contentsStatus;
				receivalObj.hasCOU			:=	trackedItemObj.CM_Container.getCou &lt;&gt; null;
				receivalObj.isExternallyMonitored := trackedItemObj.CM_Container.getExternalMonitoring;   // 10.07.2017 cnwma1 TFS #4729 
				receivalObj.curtainsIn := trackedItemObj.CM_Container.getCurtainsIn;                       // 10.07.2017 cnwma1 TFS #4729 
				receivalObj.voltageType := trackedItemObj.CM_Container.getVoltageType;                     // 10.07.2017 cnwma1 TFS #4729 
			else
				receivalObj.carriageTempC	:=	0;
				receivalObj.carriageTempF	:=	0;
				receivalObj.clean			:=	false;
				receivalObj.contentsStatus	:=	0;
				receivalObj.hasCOU			:=	false;
			endif;
			
			receivalObj.commodity				:=	trackedItemObj.commodity;
			receivalObj.companyCode				:=	trackedItemObj.companyCode;
			receivalObj.consigneeCode			:=	trackedItemObj.consignee;
			receivalObj.consignorCode			:=	trackedItemObj.consignor;
			receivalObj.consignorVoyageCode		:=	trackedItemObj.consignorVoyageCode;
			receivalObj.freightForwarderCode	:=	trackedItemObj.freightForwarderCode;	//PAR 23771 15/04/2010
			receivalObj.customExportEntryNumber	:=	trackedItemObj.customExportEntryNumber;
			receivalObj.damaged					:=	trackedItemObj.damaged;
			receivalObj.description				:=	trackedItemObj.description;
			receivalObj.destinationPort			:=	trackedItemObj.destinationPort;
			receivalObj.dischargePort			:=	trackedItemObj.dischargePort;
			receivalObj.myTranshipToPort		:=	trackedItemObj.myTranshipToPort;
			receivalObj.weightCargo             :=  trackedItemObj.weightCargo;   // 10.07.2017 cnwma1 TFS #4729 
			proxyCargoObj.setDoorsDirection(receivalObj);	// #25789 13/10/2010
			
			receivalObj.eirNumber				:=	trackedItemObj.eirNumber;		
			//18 Nov 2010	NDL	Par 26355
			receivalObj.createSealsFromTi( trackedItemObj );
				
			
			if trackedItemObj.myCargoType &lt;&gt; null then        // 10.07.2017 cnwma1 TFS #4729 
				
				if trackedItemObj.myCargoType.useTareCargoWeight then
					receivalObj.weightTare := trackedItemObj.weightTare;
				endif;
				
			endif;
			if isContainer then
				receivalObj.hasCoolingWaterConnection	:=	trackedItemObj.CM_Container.getHasCoolingWaterConnection();
				receivalObj.coolingType					:=	trackedItemObj.CM_Container.getCoolingType;
				receivalObj.setHumidity( trackedItemObj.CM_Container.getHumidity );
				receivalObj.setCarbonDioxide( trackedItemObj.CM_Container.getCarbonDioxide );
				receivalObj.setOxygen( trackedItemObj.CM_Container.getOxygen );
				receivalObj.isoType						:=	trackedItemObj.CM_Container.isoType;
				receivalObj.offsiteCleaned				:=	trackedItemObj.CM_Container.offsiteCleaned;
				receivalObj.offsitePreTrip				:=	trackedItemObj.CM_Container.offsitePreTrip;
				
				
				if trackedItemObj.CM_Container.packedDT &lt;&gt; null   
				and trackedItemObj.CM_Container.getPackTempDetails &lt;&gt; null
				then
					receivalObj.packTempC	:=	trackedItemObj.CM_Container.getPackTempDetails.tempC;
					receivalObj.packTempF	:=	trackedItemObj.CM_Container.getPackTempDetails.tempF;
				else	// cnwdad1 26/03/2007 - PAR #13673.
					receivalObj.packTempC	:=	NULL_TEMPERATURE;
				endif;
				
				receivalObj.packTime			:=	trackedItemObj.CM_Container.packedDT.time;
				receivalObj.preTripped			:=	trackedItemObj.CM_Container.getPreTripDT &lt;&gt; null;
				receivalObj.reeferRemarks		:=	trackedItemObj.CM_Container.getReeferRemarks;
				
				if trackedItemObj.CM_Container.getOnPowerDuringTransit then									
					receivalObj.onPowerDuringTransit	:=	trackedItemObj.CM_Container.getOnPowerDuringTransit;
					receivalObj.transitOnPowerDate	:=	trackedItemObj.getTransitOnPowerDate;
					receivalObj.transitOnPowerTime	:=	trackedItemObj.getTransitOnPowerTime;
					receivalObj.transitOnPowerRemarks	:=	trackedItemObj.getTransitOnPowerRemarks;
				endif;			
				receivalObj.ventilation			:=	trackedItemObj.CM_Container.getVentilation; //cnwrs1 nov 2008 18451			
				
				// CCMS 1017 Add over dimension details
				receivalObj.overHeight			:=	trackedItemObj.CM_Container.overHeight;
				receivalObj.overLengthFront		:=	trackedItemObj.CM_Container.overLengthFront;
				receivalObj.overLengthRear		:=	trackedItemObj.CM_Container.overLengthRear;
				receivalObj.overWidthLeft		:=	trackedItemObj.CM_Container.overWidthLeft;
				receivalObj.overWidthRight		:=	trackedItemObj.CM_Container.overWidthRight;
			endif;
			
			receivalObj.height					:=	trackedItemObj.height;
			receivalObj.id						:=	trackedItemObj.id;
			receivalObj.imExStatus				:=	trackedItemObj.getImExStatusObject();
			receivalObj.inspected				:=	trackedItemObj.inspectDT &lt;&gt; null;
			receivalObj.length					:=	trackedItemObj.length;
			//Par 13169
			//receivalObj.loadPort				:=	self.aMyTerminal.code;
			receivalObj.loadPort				:=	self.aMyTerminal.getConfig(PortDestCode).String;
			receivalObj.mark					:=	trackedItemObj.mark;
			//receivalObj.myBusinessUnit IGNORED
			//receivalObj.nonWorkedReleaseType IGNORED
			receivalObj.operatorCode			:=	trackedItemObj.operatorCode;
			
			receivalObj.preSlung				:=	false;
			receivalObj.quantity				:=	trackedItemObj.quantity;
			receivalObj.receiptTransportMode	:=	TI_TRANSMODE_ROAD;
			// cnwdad1 26/03/2007 - PAR #13673: The remarks line was commented out, so I put it back.
			receivalObj.remarks				:=	trackedItemObj.remarks;
//			receivalObj.remarks					:=	entryForm.getPosition(trackedItemObj.id);
			receivalObj.statusString			:=	trackedItemObj.getStatusCode();
			receivalObj.voyageCode				:=	trackedItemObj.voyageCode;
// cnwdad1 25/07/2007 - CCMS #1493 - The criver can now amend the weight if neccessary.
//			receivalObj.weightTotal				:=	trackedItemObj.totalWeight;
			receivalObj.weightTotal				:=	proxyCargoObj.totalWeight;
			//epr vgm 15/6/16 tfs 2184
			receivalObj.isWeightCertified       :=  trackedItemObj.isWeightCertified;
			receivalObj.weightCertifiedName		:= trackedItemObj.weightCertifiedName;
			receivalObj.weightCertifiedReference:=trackedItemObj.weightCertifiedReference;
			
			receivalObj.wet						:=	false;
			receivalObj.width					:=	trackedItemObj.width;
			receivalObj.myProduct				:=	trackedItemObj.myProduct;
			receivalObj.volume					:=  trackedItemObj.getMyTotalVolume; //par 18522 cnwjo3
			
			// cnwrd1 OMAR/MAF pack details - par 27895 28.7.2011
			receivalObj.packDate := trackedItemObj.packDate;
			receivalObj.packTime := trackedItemObj.packTime;
			receivalObj.packTempC := trackedItemObj.packTempC.Real;   
			receivalObj.packTempF := trackedItemObj.packTempF.Real; 
			if trackedItemObj.myReeferProperties &lt;&gt; null then
				receivalObj.allowableTimeOffPower := trackedItemObj.myReeferProperties.allowableTimeOffPower;
				receivalObj.remainingTimeOffPower := trackedItemObj.myReeferProperties.remainingTimeOffPower;	// PAR #31411
			endif;
			
			// Create COU interface if the TI has a COU.
			
			if isContainer and trackedItemObj.CM_Container.getCou &lt;&gt; null then
				create couObj transient;
				couObj.setMasterItem(releaseObj);
				couObj.setMyInOutCommon(ioCommonObj);
				couObj.ignoreWarnings		:=	true;
				
				couObj.set(	trackedItemObj.CM_Container.getCou.id,
							trackedItemObj.CM_Container.getCou.isoType, 
							app.couTypeEnumToString(trackedItemObj.CM_Container.getCou.couType),
							self.aMyTerminal);
			endif;

			// Create the attachment interfaces.
			//trackedItemObj.getAllChildren(children);//PAR 22954
			//foreach childTIObj in children do
			foreach childTIObj in trackedItemObj.allChildren do
				create attachmentObj transient;
				attachmentObj.ignoreWarnings	:=	true;
				attachmentObj.myTerminal		:=	self.aMyTerminal;
				attachmentObj.setMasterItem(receivalObj);
				attachmentObj.setMyInOutCommon(ioCommonObj);
				attachmentObj.hasAttachments	:=	false;
				attachmentObj.hasCOU			:=	false;

				attachmentObj.set(	self.aMyTerminal,
									childTIObj.cargoType,
									childTIObj.id,
									childTIObj.getISOType(),
//									childTIObj.weight);					//-cnwml2 MSL CCMS 1017
									childTIObj.totalWeight);			//+cnwml2 MSL CCMS 1017
			endforeach;
			
		else
			// Release a container.
			
			create releaseObj transient;
			tiArrayObj.add(releaseObj);
			tiDeleteArray.add(receivalObj);			// PAR #19242
			
			releaseObj.setMyInOutCommon(ioCommonObj);
			releaseObj.myTerminal				:=	self.aMyTerminal;
			releaseObj.mySubTerminal := trackedItemObj.mySubTerminal; //23/06/2009 cnwdz2	par20019
			
			if isContainer then
				releaseObj.hasAttachments	:=	trackedItemObj.CM_Container.getGenerator &lt;&gt; null;
				releaseObj.hasCOU			:=	trackedItemObj.CM_Container.getCou &lt;&gt; null;
				releaseObj.needCOU			:=	trackedItemObj.CM_Container.getCou &lt;&gt; null;
				releaseObj.needGenerator	:=	trackedItemObj.CM_Container.getGenerator &lt;&gt; null;
			endif;
			
			releaseObj.ignoreWarnings			:=	true;
			releaseObj.id						:=	trackedItemObj.id;
			releaseObj.carrierRemarks			:=	trackedItemObj.carrierRemarks;
			releaseObj.consigneeCode			:=	trackedItemObj.consignee;
			releaseObj.consignorVoyageCode		:=	trackedItemObj.consignorVoyageCode;
			releaseObj.customEntryNumber		:=	trackedItemObj.customsEntryNumber;
			//releaseObj.customsDocsChecked		:=	trackedItemObj.getAllStops()[TI_Stop_OperatorDocs] = null;	// cnwrl1 14/12/2009 PAR 21889 - what it was
			releaseObj.customsDocsChecked		:=	trackedItemObj.isStopSet( TI_Stop_OperatorDocs );
			releaseObj.deliveryReason			:=	app.deliveryReasonEnumToString(trackedItemObj.deliveryReleaseReason);
			releaseObj.deliveryReleaseNumber	:=	trackedItemObj.deliveryRelease;
			
			releaseObj.freightForwarderCode	 := trackedItemObj.freightForwarderCode;	//04 Mar 2013	NDL	Par 31220
			
			proxyCargoObj.setDoorsDirection(releaseObj);	// #25789 13/10/2010
			
			releaseObj.eirNumber				:=	trackedItemObj.eirNumber;
			releaseObj.remarks				:=	trackedItemObj.remarks;
			releaseObj.removeStops				:=	false;
			releaseObj.cargoType				:=	trackedItemObj.cargoType;
			
			//foreach stopObj in trackedItemObj.getAllStops() do	// cnwrl1 15/12/2009 PAR 21889 - what it was
			create allStops transient;
			trackedItemObj.getAllActiveStops( allStops );
			foreach stopObj in allStops do
				releaseObj.allStopsArray.add(stopObj.id);
			endforeach;
			
			// Create COU interface if the TI has a COU.
			
			if isContainer and trackedItemObj.CM_Container.getCou &lt;&gt; null then
				create couObj;
				couObj.setMasterItem(releaseObj);
				couObj.setMyInOutCommon(ioCommonObj);
				couObj.ignoreWarnings	:=	true;
				
				couObj.set(	trackedItemObj.CM_Container.getCou.id,
							trackedItemObj.CM_Container.getCou.isoType, 
							app.couTypeEnumToString(trackedItemObj.CM_Container.getCou.couType),
							self.aMyTerminal);
			endif;

			// Create the attachment interfaces.
			//trackedItemObj.getAllChildren(children);//PAR 22954
			//foreach childTIObj in children do
			foreach childTIObj in trackedItemObj.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			
				create attachmentObj transient;
				attachmentObj.ignoreWarnings	:=	true;
				attachmentObj.myTerminal		:=	self.aMyTerminal;
				
				attachmentObj.setMasterItem(releaseObj);
				attachmentObj.setMyInOutCommon(ioCommonObj);
				attachmentObj.hasAttachments	:=	false;
				attachmentObj.hasCOU			:=	false;

				attachmentObj.set(	self.aMyTerminal,
								childTIObj.cargoType,
								childTIObj.id,
								childTIObj.getISOType(),
				//				childTIObj.weight);					//-cnwml2 MSL CCMS 1017
								childTIObj.totalWeight);			//+cnwml2 MSL CCMS 1017
			endforeach;
		endif;
	endforeach;
	
	create allBookingSlots transient; //TFS 53107, AjitM, navam1
	self.check1StopVBS(allBookingSlots, _allErrorsObj); //TFS 53107, AjitM, navam1
	
	//jlika1 TFS 56731 --&gt; 
	// We need to catch the error from check1StopVBS if there is any.
	if _allErrorsObj &lt;&gt; null and _allErrorsObj.size &gt; 0 then
		hasError := true;		
		return _allErrorsObj.isEmpty();
	endif;
	//jlika1 TFS 56731 &lt;-- 
	
	// Finally, call the Road In/Out transaction.
	
	//app.myPassport.setWarningsIgnored(true);								//cnwmc5 - 22 Jan 2015 - PAR 35518
	//app.myTrxCA.trxCreateInOutVehicle(ioCommonObj, app.myPassport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);							//TFS#53837 navsp1 17Aug2022
	app.myTrxCA.trxCreateInOut(ioCommonObj, tiArrayObj, app.myPassport, allBookingSlots); //TFS 53107, AjitM, navam1
	
	if app.myPassport.trxCompletedOK() then
		return true;
	else
		app.myPassport.dumpErrorWarnings();
		errorMsg	:=	null;
		
		foreach errorObj in app.myPassport.allErrors do
			if errorObj.text.trimBlanks() &lt;&gt; null then
				_allErrorsObj.addString(errorObj.text);
			endif;
		endforeach;
		
		hasError := true;
		
		return _allErrorsObj.isEmpty();
	endif;
	
	
epilog
	delete ioCommonObj;
	delete allProxyCargosObj;
	delete tiArrayObj;					// cnwdad1 03/07/2008 - PAR #17219.
	if tiDeleteArray &lt;&gt; null then		// PAR #19242
		tiDeleteArray.purge();
		delete tiDeleteArray;
	endif;
	delete allStops;

end;</source>
        <access>protected</access>
        <Parameter name="_allErrorsObj" type="CnEcArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBackspace" id="e3002d39-a08a-49c3-8f57-4a323ec08311">
        <source>doBackspace() protected;
// --------------------------------------------------------------------------------
// Created:		13 November 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtPinNo.setFocus();
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClear" id="4ea91198-9031-487a-a4b5-ab703eddd8e5">
        <updating/>
        <source>doClear() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 June 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	txtPinNo.cnEcSet(null);
	self.doEnableControls();
	txtPinNo.setFocus();	//PAR14211
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmWeight" id="2d8445cd-e416-415b-8ba9-9be6accd8c9e">
        <source>doConfirmWeight(_tiObj:CM_TrackedItem input; _totalWeight:Decimal io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		23 July 2007 by cnwdad1
//
// Purpose:		Displays a modal form where the driver can confirm the weight of the
//				container.
//
// Parameters:	_tiObj - A reference to the Tracked Item (Container) object.
//				_totalWeight - Returns the total weight of the container.
//
// Returns:		True if the weight was confirmed, otherwise false if the confirmation
//				was cancelled.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	confirmFormObj	: GTE_KioskWeightConfirmForm;
	updController	: CMIF_TIUpdateController;
	proxyObj		: CM_TrackedItem;
	weight			: Decimal[14,4];		// The container weight we currently know.
	confirmedWeight	: Decimal[14,4];		// The confirmed weight of the container.
	formResponse	: Integer;
	
begin
	create confirmFormObj transient;
	weight			:=	_totalWeight;
	confirmFormObj.setWeight(weight);
	formResponse	:=	confirmFormObj.showModal();
	if formResponse = self.CNEC_MODAL_UPDATE then
		confirmedWeight	:=	confirmFormObj.aWeight;
		updController	:=	app.createTIUpdateControl(TI_UPDMODE_RECEIPT, app.myPassport.userCode, null);
		updController.transactionType	:=	TRANS_TYPE_WEIGH;
		updController.newWeight			:=	confirmedWeight;
		//updController.machineId			:=	?
		
		proxyObj		:=	app.createUpdateProxy(_tiObj).CM_TrackedItem;
		proxyObj.setTotalWeight(confirmedWeight, updController, app.myPassport);
		
		// If the following validation fails, then an exception will be raised.
		//process.debug;
		proxyObj.validateWeightForKiosk(updController);
		
		if weight &lt;&gt; confirmedWeight then
			_totalWeight	:=	confirmedWeight;
		endif;
		
	elseif formResponse = self.CNEC_MODAL_CLOSE then
		return true;
		
	elseif formResponse = self.CNEC_MODAL_CANCEL then
		return false;
		
	endif;
	
	return true;
epilog
	delete updController;
	delete proxyObj;
end;</source>
        <access>protected</access>
        <Parameter name="_tiObj" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_totalWeight" type="Decimal" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDone" id="d30df09b-f532-4733-97a4-b46f014b1999">
        <updating/>
        <source>doDone() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 August 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	if self.updateForm(false) then
		self.doRestart();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEditLoad" id="9cc67eea-bb32-4733-a267-48d77a3e6aa1">
        <updating/>
        <source>doEditLoad(_loadNumber:Integer; _isRelease:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 September 2006 by cnwdad1
//
// Purpose:		Edits a cargo container that was clicked.
//
// Parameters:	_isFront - True if the container is at the front.
//				_isRelease - True if the container is a release (otherwise receival
//					is assumed).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/07/2007	cnwdad1		CCMS #1493 - Added cargo item weight, which may be amended
//							by the criver.
//
// --------------------------------------------------------------------------------
vars
	cargoId			: String;
	cargoCount		: Integer;
	cargoObj		: CM_Object;
	itemObj			: CM_Object;
	intFaceObj		: CMIF_TIObject;
	proxyCargoObj	: GTE_KioskProxyCargo;
	confirmFormObj	: GTE_KioskEntryConfirmForm;
	
begin
	if _isRelease then
		if self.isAAAI then	//19 May 2020	NDL	TFS 49167
			return;
		endif;
		if _loadNumber = 1 then
			cargoId		:=	picRelease1.cargoId;
			cargoCount	:=	picRelease1.cargoCount;
		elseif _loadNumber = 2 then
			cargoId		:=	picRelease2.cargoId;
			cargoCount	:=	picRelease2.cargoCount;
		elseif _loadNumber = 3 then
			cargoId		:=	picRelease3.cargoId;
			cargoCount	:=	picRelease3.cargoCount;
		elseif _loadNumber = 4 then
			cargoId		:=	picRelease4.cargoId;
			cargoCount	:=	picRelease4.cargoCount;
		endif;
	else
		if _loadNumber = 1 then
			cargoId		:=	picReceive1.cargoId;
			cargoCount	:=	picReceive1.cargoCount;
		elseif _loadNumber = 2 then
			cargoId		:=	picReceive2.cargoId;
			cargoCount	:=	picReceive2.cargoCount;
		elseif _loadNumber = 3 then
			cargoId		:=	picReceive3.cargoId;
			cargoCount	:=	picReceive3.cargoCount;
		elseif _loadNumber = 4 then
			cargoId		:=	picReceive4.cargoId;
			cargoCount	:=	picReceive4.cargoCount;
		endif;
	endif;
	
	proxyCargoObj	:=	self.aMyProxyLoad.getCargoForId(cargoId, cargoCount, _isRelease);
	cargoObj		:=	proxyCargoObj.myCargoItem;
	
	create confirmFormObj;
	confirmFormObj.setTerminalRef(self.aMyTerminal);
	confirmFormObj.setCargoItem(cargoObj, proxyCargoObj.totalWeight, proxyCargoObj.count, false);
	confirmFormObj.aMyProxyLoad	:=	self.aMyProxyLoad;
	
	if cargoObj.isKindOf(CM_BulkRelease) then
		confirmFormObj.setTIInterface(proxyCargoObj.myTIInterface);
	endif;
	
	if confirmFormObj.showModal() = self.CNEC_MODAL_UPDATE then
		self.adjustContainerLayout();
	else
		self.doClear();
		return;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_loadNumber" type="Integer"/>
        <Parameter name="_isRelease" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="2d770570-449a-48d0-a183-0a41e902a7f3">
        <updating/>
        <source>doEnableControls() updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 July 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
//	if txtPinNo.text.trimBlanks() = null then
//		btnClear.enabled	:=	false;
//	else
		btnClear.enabled	:=	true;
//	endif;
	
	if self.aMyProxyLoad &lt;&gt; null then
		if self.aMyProxyLoad.allReceivals.isEmpty()
		and self.aMyProxyLoad.allReleases.isEmpty()
		then
			btnDone.enabled	:=	false;
		else
			btnDone.enabled	:=	true;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEnter" id="1e53e3c0-f3b6-46b4-b250-da5a42280e5f">
        <updating/>
        <source>doEnter() updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 July 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/07/2007	cnwdad1		CCMS #1493 - Added cargo item weight, which may be amended
//							by the driver.
//
// --------------------------------------------------------------------------------
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	pinNumber		: String;
	pinNoObj		: CM_PinNo;
	itemObj			: CM_Object;
	proxyLoadObj	: GTE_KioskProxyLoad;
	tiObj			: CM_TrackedItem;
	itemCount		: Integer;
	isDefaultFront	: Boolean;
	totalWeight		: Decimal[14,4];
	confirmFormObj	: GTE_KioskEntryConfirmForm;
	intFaceObj		: CMIF_TIObject;
	errorMsg		: String;
	
	kioskPicker		: GTE_KioskContainerPicker;
	pickerRD		: CM_ReserveDetail;
	
	releasedCount,
	totalRemaining	: Integer;
	tmpObj			: Object;
	
	isContainers : Boolean;	//19 May 2020	NDL	TFS 49167
begin
	inheritMethod();
	
	if self.validateForm(false) then
		pinNumber	:=	txtPinNo.cnEcString();
		pinNoObj	:=	self.aMyTerminal.allPinNos[pinNumber];
		//31 March 2011	#cnwdz2	 par27146 start
		if pinNoObj.status = PIN_InProcess then
			app.msgBox(app.getErrorString(ERR_PIN_INPROCESS),app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		//31 March 2011	#cnwdz2	 par27146 end
		self.aMyProxyLoad.pinNumber	:=	pinNumber;
		
		proxyLoadObj	:=	self.aMyProxyLoad;
		itemCount		:=	0;
		
		foreach itemObj in pinNoObj.allItems discreteLock do //+ cnwmd1 Par 25448 added dicreteLock
	
			itemCount	:=	itemCount + 1;
			
			if itemCount = 1 then
				isDefaultFront	:=	true;
			else
				isDefaultFront	:=	false;
			endif;
			
			if not proxyLoadObj.isCargoAllowed(itemObj, errorMsg) then
				app.msgBox(errorMsg, app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
				return;
			endif;
			
			//pre-notes timber, etc
			if itemObj.isKindOf(CM_TrackedItem) then
				tiObj		:=	itemObj.CM_TrackedItem;
				totalWeight	:=	tiObj.totalWeight;
				
				if not self.validateTrackedItem(tiObj, pinNumber) then
					return;
				endif;
				
				if self.aIsKioskWeightUsed then			// Check the Terminal Kiosk Weight setting.
					if tiObj.state = TI_STATE_NOTIFIED then	// Only confirm weight for receivals.
						if not self.doConfirmWeight(tiObj, totalWeight) then
							return;
						endif;
					endif;
				endif;
				
				create confirmFormObj;
				confirmFormObj.setTerminalRef(self.aMyTerminal);
				confirmFormObj.setCargoItem(tiObj, totalWeight, 0, true);
				confirmFormObj.aMyProxyLoad	:=	proxyLoadObj;
				
				if confirmFormObj.showModal() = self.CNEC_MODAL_UPDATE then
					self.aAllPinNumbers.add(pinNumber);
					self.adjustContainerLayout();
					txtPinNo.cnEcSet(null);
				else
					self.doClear();
					return;
				endif;

			elseif itemObj.isKindOf(CM_BulkRelease) then
			
				//19 May 2020	NDL	TFS 49167
				isContainers := itemObj.CM_BulkRelease.allReserveDetails.first.getCargoType.isContainer;
				if not isContainers then
					if not self.aMyTerminal.getConfig( OneCargoTypeRelReqById ).Boolean then
						app.msgBox(	app.getErrorString1( This_cargo_that_not_suppo_curr, pinNumber ),
						app.getErrorString(Error),
						MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
						self.doRestart();
						return;
					endif;
					if self.aAllPinNumbers.includes( pinNumber ) then
						app.msgBox(	app.getErrorString1( Have_alrea_enter_this_again_th, pinNumber ),
						app.getErrorString(Error),
						MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
						self.doClear();
						return;
					endif;
					if itemCount = 1 then
						self.isAAAI := true;
					endif;
				endif;
		
				if not self.validateBulkRelease(itemObj.CM_BulkRelease, pinNumber) then
					return;
				endif;
				
				// CCMS 1503
				if proxyLoadObj.myCarrier.code &lt;&gt; itemObj.CM_BulkRelease.carrierId then
				 //ask driver if they wish to continue.
					if app.msgBox('The PIN entered is for Release Number ' &amp; itemObj.CM_BulkRelease.code 
								&amp; ' which is for Carrier ' &amp; itemObj.CM_BulkRelease.carrierId &amp; '.'
								&amp; CrLf &amp; CrLf &amp; 'Do you want to continue?', 
								'Attention', 
								MsgBox_Yes_No) = MsgBox_Return_No then
						continue;
					endif;
				endif;
				
				//19 May 2020	NDL	TFS 49167
				if isContainers = self.isAAAI then
					//they are tring to collect containers and general cargo this is not permitted.
					app.msgBox( app.getErrorString( Not_enter_relea_pins_gener_car ),
					app.getErrorString(Error),
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
					self.doClear();
					return;
				endif;
				
				if isContainers and needKioskPickerForm(itemObj.CM_BulkRelease) then
					create kioskPicker;
					kioskPicker.setMyPinEntryForm(self);
					kioskPicker.setMyBulkRelease(itemObj.CM_BulkRelease);
					if kioskPicker.showModal() = self.CNEC_MODAL_UPDATE then
						pickerRD := kioskPicker.getMyReserveDetail();
						delete kioskPicker;
					else
						delete kioskPicker;
						self.doClear();
						return;
					endif;
				else
					pickerRD := itemObj.CM_BulkRelease.allReserveDetails.first();
					//par 19564 cnwjo3
					//if self.aMyProxyLoad.allReleases.size &gt;= itemObj.CM_BulkRelease.quantityRemaining then
					
					//par 19611 cnwjo3.  For some reason the pin number on all items is last entered!
					//data corruption is happening somewhere, this will at least solve the issue
					releasedCount := self.aMyProxyLoad.allReleases.size;
					if self.isAAAI then	//20 May 2020	NDL	TFS 49167
						totalRemaining := itemObj.CM_BulkRelease.allTrackedItemsAssigned.size;
					else
						//totalRemaining := itemObj.CM_BulkRelease.quantityRemaining;	// ### TFS 57643 09May2023 NAVPW1 - Commented out
						totalRemaining := itemObj.CM_BulkRelease.getTotalOutstanding() - itemObj.CM_BulkRelease.getNumItemsBeingActioned();	// ### TFS 57643 09May2023 NAVPW1
					endif;
					foreach tmpObj in self.aMyProxyLoad.allReleases discreteLock do //+ cnwmd1 Par 25448 added dicreteLock
						if tmpObj.isKindOf(GTE_KioskProxyCargo) then
							if tmpObj.GTE_KioskProxyCargo.myCargoItem &lt;&gt; null then
								if tmpObj.GTE_KioskProxyCargo.myCargoItem.isKindOf(CM_BulkRelease) then
									if tmpObj.GTE_KioskProxyCargo.myCargoItem.CM_BulkRelease &lt;&gt; itemObj.CM_BulkRelease then
										releasedCount := releasedCount - 1;
									endif;
								endif;
							endif;
						endif;
					endforeach;
					
					if releasedCount &gt;= totalRemaining then
					
					//if itemObj.CM_BulkRelease.allRequestsBeingActioned.size &gt; 0 then
					
						//when there is only 1 item on Release Request and
						//it is has been gated in but not road exited
						app.msgBox('There are no more outstanding items for the requested release.',
							app.getErrorString(Error),
							MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
						self.doClear();
						return;
					endif;
				endif;
				
				//19 May 2020	NDL	TFS 49167
				if not isContainers then
					pickerRD := null;
				endif;
				
				intFaceObj	:=	self.addBulkRelease(itemObj.CM_BulkRelease, pinNoObj.pinNo, pickerRD);	// Creates a new transient interface object.
				
				create confirmFormObj;
				confirmFormObj.setTIInterface(intFaceObj);
				confirmFormObj.setTerminalRef(self.aMyTerminal);
				
				confirmFormObj.setCargoItem(itemObj, 0, 0, true);
				confirmFormObj.aMyProxyLoad	:=	proxyLoadObj;
				
				//19 May 2020	NDL	TFS 49167
				if not isContainers then
					confirmFormObj.isAAAI := true;
				endif;
				
				if confirmFormObj.showModal() = self.CNEC_MODAL_UPDATE then
					self.aAllPinNumbers.add(pinNumber);
					self.adjustContainerLayout();
					txtPinNo.cnEcSet(null);
				else
					self.doClear();
					return;
				endif;

			else
				app.msgBox(	"This pin (" &amp; pinNumber &amp; " ) is not valid for cargo - contact office.",
							app.getErrorString(Error),
							MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
				self.doRestart();
				return;
			endif;
		endforeach;
	endif;
epilog
	self.doEnableControls();
	txtPinNo.setFocus();	//PAR14211
	delete kioskPicker;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doKeyboardInput" id="b846724b-a2ab-4dcc-a238-6ad0d12c9960">
        <updating/>
        <source>doKeyboardInput(_input: String):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pinNo	: String;
	
begin
	if inheritMethod(_input) then
		return true;
	endif;
	
	pinNo	:=	txtPinNo.cnEcString() &amp; _input;
	
	if self.validateText(txtPinNo, pinNo) then
		txtPinNo.cnEcSet(pinNo);
	endif;
	
	self.doEnableControls();
end;</source>
        <access>protected</access>
        <Parameter name="_input" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRestart" id="aa874da7-6dd5-4fff-b3d3-5b87ad7d8469">
        <updating/>
        <source>doRestart() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 June 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startFormObj	: GTE_KioskStartForm;
	
begin
	inheritMethod();

	// Should never be any proxies left but due to some
	// crap code sometimes these are left.  Clear here
	// to ensure does not cause problems
	//if app.myProxyManager &lt;&gt; null then
	//	app.myProxyManager.clearAllProxies();
	//endif;
	
	self.allTransients.purge;

	create startFormObj;
	startFormObj.show();
	self.unloadMe(true);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="needKioskPickerForm" id="230e3d5c-b873-4020-9e0d-677bf32279b9">
        <source>needKioskPickerForm(_br : CM_BulkRelease) : Boolean protected;

vars
	firstIso : String;
	rs : CM_Object;
begin
	
	if _br.allReserveDetails.first().isKindOf(CM_ReserveTI) and
		_br.allReserveDetails.size &gt; 1 then
			return true;
	endif;
	
	if _br.allReserveDetails.first().isKindOf(CM_ReserveSelection) then
		if _br.allReserveDetails.size &gt; 1 then
			//previously we were throwing up the picker if the release had
			//mutliple release by types AND each had different iso types
			//this would cause alot of new code to be created if the user
			//created a release with 2 item lines but with the same type
			//since code would need to be written to identify which ReserveDetail
			//has been actioned.  No simplifying code so that if some user
			//wants to create a release with 2 items but with the same type
			//then driver will be prompted with 2 selections.
			
			/*firstIso := _br.allReserveDetails.first().CM_ReserveSelection.myISOType.code.String;
			foreach rs in _br.allReserveDetails do
				if firstIso.toUpper &lt;&gt; rs.CM_ReserveSelection.myISOType.code.String.toUpper then
					return true;
				endif;
			endforeach;*/
			return true;
		endif;
	endif;
	
	return false;
end;
</source>
        <access>protected</access>
        <Parameter name="_br" type="CM_BulkRelease"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
