    <JadeMethod name="setForCreate" id="f094b3b9-4a5c-405b-bd5e-f1966469eea3">
        <updating/>
        <source>setForCreate(_proxy : SelfType) updating;
/*
Purpose:			

Date		Who		Reason
26JUL2021	NAVAB1	TFS 50669
*/

vars

begin

	self.created := _proxy.created;
	self.createdUser := _proxy.createdUser;
	self.description := _proxy.description;
	self.myRoot	:= _proxy.myRoot;
	self.myTerminal	:= _proxy.myTerminal;
	self.interfaceName := _proxy.interfaceName;
	self.requestName := _proxy.requestName;
	self.status := _proxy.status;
	
	//self.myExtWebserviceDef := app.myRoot.getFirstActiveExtWebService(CM_OpsViewServiceDef).CM_OpsViewServiceDef;
	self.myExtWebserviceDef:=_proxy.myExtWebserviceDef; //jlier1 TFS 58839 6/7/23

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
