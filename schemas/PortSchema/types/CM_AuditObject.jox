epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDetailedBeforeAfter" id="808a9e3a-bc53-47f2-81bc-35165b7a97d2">
        <source>getDetailedBeforeAfter(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2018	jlgmp6	Initial creation	TFS37718

*/
constants
	OpenDelimiter: Character = "&lt;";
	CloseDelimiter: Character = "&gt;";
	Nothing: String = "nothing";
vars
	tagName,
	tagNames,
	oldValue,
	newValue,
	returnString: String;
	slash,
	tagStart: Integer;
	finished,
	nullOld,
	nullNew: Boolean;
begin
	tagNames := self.getAllTags(true);
	tagStart := 1;

	while not finished do
		slash := tagNames.pos(Forward_Slash, tagStart);
		if slash = 0 then
			tagName := tagNames[tagStart:End];
			finished := true;
		else
			tagName := tagNames[tagStart:slash - tagStart];
		endif;

		if self.getOldNewValueForTag(tagName, oldValue, newValue) then
			nullOld := false;
			nullNew := false;
			oldValue := oldValue.replaceString(Cr, "");
			oldValue := oldValue.replaceString(Lf, "");
			newValue := newValue.replaceString(Cr, "");
			newValue := newValue.replaceString(Lf, "");
			if oldValue = "null" or oldValue = null then
				oldValue := Nothing;
				nullOld := true;
			endif;
			if newValue = "null" or newValue = null then
				newValue := Nothing;
				nullNew := true;
			endif;
			if not(nullOld and nullNew) then
				if returnString &lt;&gt; null then
					returnString := returnString &amp; CrLf;
				endif;
				returnString := returnString &amp; tagName;
				if self.type = AuditCreated then
					returnString := returnString &amp; " initially set to ";
				elseif self.type = AuditUpdated then
					returnString := returnString &amp; " changed from ";
				elseif self.type = AuditDeleted then
					returnString := returnString &amp; " final setting ";
				endif;
				if not nullOld then
					returnString := returnString &amp; OpenDelimiter;
				endif;
				returnString := returnString &amp; oldValue;
				if not nullOld then
					returnString := returnString &amp; CloseDelimiter;
				endif;
				if self.type = AuditUpdated then
					returnString := returnString &amp; " to ";
					if not nullNew then
						returnString := returnString &amp; OpenDelimiter;
					endif;
					returnString := returnString &amp; newValue;
					if not nullNew then
						returnString := returnString &amp; CloseDelimiter;
					endif;
				endif;
			endif;
		endif;
		tagStart := slash + 1;
	endwhile;

	return returnString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetails" id="1c8ab636-85c0-4f5b-8345-69db4a560164">
        <source>getDetails(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2018	jlgmp6	Initial creation	TFS37718

*/

vars

begin

	return self.getDisplayStringForAttribute(ETRow_Details, false);

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="20b7f83a-6bd4-4080-bb30-92e192558d3e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// cnwrs1 june 2006
vars

begin
	if _attrName = ETRow_ObjectClass then	
		if self.myAuditConfig &lt;&gt; null then
			return self.myAuditConfig.getDescription();
		//06 May 2021	NDL	TFS 50906
		elseif self.mySubject &lt;&gt; null then
			return self.mySubject.class.name;
		else
			return null;
		endif;
	elseif _attrName = ETRow_SubjectIdString then	
		return self.getSubjectIdString();
	elseif _attrName = ETRow_Timestamp then
		return self.systemToLocalTime(self.timestamp).shortCurrentLocaleFormatSecs();	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_Details then
		return self.getAllTags(false);		// 22/5/18 MAP TFS37718
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
