    <JadeMethod name="rel20021_tfs54321" id="bf408a04-fc9f-42c0-b0c3-cc109f6ba3b6">
        <source>rel20021_tfs54321();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 July 2022	navmd1	Initial creation TFS 54321 include updatec constants

*/

vars
	agent 				: EntTableAgent;
	array 				: StringArray;
	
	translationAgent 	: CM_TranslationAgent;
begin
	app.initialize();

	create agent transient;
	create array transient;
	agent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	array.add("ETDef_GateLanesTable");
	array.add("ETDef_ScanReader");
	array.add("ETDef_WeighBridge");
	
	array.add("ETRow_Lane_scan_reader");
	array.add("ETRow_MyGateLane");
	array.add("ETRow_Name");
	array.add("ETRow_Code");
	array.add("ETRow_DeviceID");

	agent.trxUpdateFromConstant(array);
	
	array.purge();
	create translationAgent transient;
	
	array.add("Device_id");
	
	translationAgent.trxLoadSpecificErrors(array);
	return;

	write ETDef_GateLanesTable;
	write ETDef_ScanReader;
	write ETDef_WeighBridge;
	
	write ETRow_Lane_scan_reader;
	write ETRow_MyGateLane;
	write ETRow_Name;
	write ETRow_Code;
	write ETRow_DeviceID;
	
	write Device_id;
epilog
	delete agent;
	delete translationAgent;
	delete array;
end;
</source>
    </JadeMethod>
