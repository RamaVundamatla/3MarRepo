    <JadeMethod name="aaaRJSTest01" id="21cbafa2-7e24-47fa-8c64-48a0bb991cf7">
        <updating/>
        <source>aaaRJSTest01() updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	xmlStr,
	tmpStr,
	delimStr,
	theXMLTag	: String;
	pos,
	idx			: Integer;
	_theMode	: Integer;
	st,
	et,
	cnt			: Integer;
	sa			: StringArray;
	
begin

// init code
	_theMode := REAL_MODE;

	create sa transient;	
	xmlStr := '&lt;at&gt;Pic01&lt;/at&gt;&lt;at&gt;Pic02&lt;/at&gt;&lt;at&gt;Pic03&lt;/at&gt;&lt;at&gt;Pic04&lt;/at&gt;';
	delimStr := 'Pic01,Pic02,Pic03,Pic04';

sa.add('Pic01');
sa.add('Pic02');
sa.add('Pic03');
sa.add('Pic04');

// reset code
	self.bayActAttribute1 := null;
	self.bayActAttribute2 := null;
	self.bayActAttribute3 := null;
	self.bayActAttribute4 := null;
	self.bayActAttribute5 := null;
	self.bayActAttribute6 := null;

	self.bayProAttribute1 := null;
	self.bayProAttribute2 := null;
	self.bayProAttribute3 := null;
	self.bayProAttribute4 := null;
	self.bayProAttribute5 := null;
	self.bayProAttribute6 := null;


st := app.clock;
cnt := 0;
while cnt &lt; 200 do
	cnt := cnt + 1;

	///
	sa.clear;
	delimStr.getTokensForDelimiter(GridData_SubDelimiter, sa);
	
	self.bayActAttribute1 := sa[1];
	self.bayActAttribute2 := sa[2];
	self.bayActAttribute3 := sa[3];
	self.bayActAttribute4 := sa[4];
	/*
	idx := 0;
	foreach theXMLTag in sa do
		idx := idx + 1;
		if _theMode = REAL_MODE then
			if idx = 1 then
				self.bayActAttribute1 := theXMLTag;
			elseif idx = 2 then
				self.bayActAttribute2 := theXMLTag;
			elseif idx = 3 then
				self.bayActAttribute3 := theXMLTag;
			elseif idx = 4 then
				self.bayActAttribute4 := theXMLTag;
			elseif idx = 5 then
				self.bayActAttribute5 := theXMLTag;
			elseif idx = 6 then
				self.bayActAttribute6 := theXMLTag;
			else
				break;
			endif;
		elseif _theMode = PLANNING_MODE then
			if idx = 1 then
				self.bayProAttribute1 := theXMLTag;
			elseif idx = 2 then
				self.bayProAttribute2 := theXMLTag;
			elseif idx = 3 then
				self.bayProAttribute3 := theXMLTag;
			elseif idx = 4 then
				self.bayProAttribute4 := theXMLTag;
			elseif idx = 5 then
				self.bayProAttribute5 := theXMLTag;
			elseif idx = 6 then
				self.bayProAttribute6 := theXMLTag;
			else
				break;
			endif;
		endif;
	endforeach;
	*/

endwhile;
et := app.clock;
write 'ARR ' &amp; (et-st).asStringJMT; 

// reset code
	self.bayActAttribute1 := null;
	self.bayActAttribute2 := null;
	self.bayActAttribute3 := null;
	self.bayActAttribute4 := null;
	self.bayActAttribute5 := null;
	self.bayActAttribute6 := null;

	self.bayProAttribute1 := null;
	self.bayProAttribute2 := null;
	self.bayProAttribute3 := null;
	self.bayProAttribute4 := null;
	self.bayProAttribute5 := null;
	self.bayProAttribute6 := null;


// test 1
st := app.clock;
cnt := 0;
while cnt &lt; 200 do
	cnt := cnt + 1;
	
	////
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := xmlStr.cnEcGetNextTagValueOfName("at", pos);
		if theXMLTag &lt;&gt; null then
			if _theMode = REAL_MODE then
				if self.bayActAttribute1 = null then
					self.bayActAttribute1 := theXMLTag;
				elseif self.bayActAttribute2 = null then
					self.bayActAttribute2 := theXMLTag;
				elseif self.bayActAttribute3 = null then
					self.bayActAttribute3 := theXMLTag;
				elseif self.bayActAttribute4 = null then
					self.bayActAttribute4 := theXMLTag;
				elseif self.bayActAttribute5 = null then
					self.bayActAttribute5 := theXMLTag;
				elseif self.bayActAttribute6 = null then
					self.bayActAttribute6 := theXMLTag;
				else
					break;
				endif;
			elseif _theMode = PLANNING_MODE then
				if self.bayProAttribute1 = null then
					self.bayProAttribute1 := theXMLTag;
				elseif self.bayProAttribute2 = null then
					self.bayProAttribute2 := theXMLTag;
				elseif self.bayProAttribute3 = null then
					self.bayProAttribute3 := theXMLTag;
				elseif self.bayProAttribute4 = null then
					self.bayProAttribute4 := theXMLTag;
				elseif self.bayProAttribute5 = null then
					self.bayProAttribute5 := theXMLTag;
				elseif self.bayProAttribute6 = null then
					self.bayProAttribute6 := theXMLTag;
				else
					break;
				endif;
			endif;
		endif;
	endwhile;

endwhile;
et := app.clock;
app.writeStatement( 'XML ' &amp; (et-st).asStringJMT); 
	////


// test 2	


epilog
	delete sa;
end;</source>
    </JadeMethod>
    <JadeMethod name="amPrinting" id="7a42a8c2-ba95-4cda-900a-51918656ac33">
