    <JadeMethod name="translateForm" id="b845dc85-19af-48d4-8dcc-bc72d3b25354">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008163, locale);
	btnExportCSV_SU.translateCaption(Xlat_0013526, locale);
	btnExportCancel.translateCaption(Xlat_0005271, locale);
	btnExportDo.translateCaption(Xlat_0005272, locale);
	btnExportSelect.translateBubbleHelp(Xlat_0005273, locale);
	btnHazSet.translateBubbleHelp(Xlat_0005274, locale);
	btnHazSet.translateCaption(Xlat_0005275, locale);
	btnLocateTI.translateBubbleHelp(Xlat_0005276, locale);
	btnLocateTI.translateCaption(Xlat_0005277, locale);
	btnRefresh.translateBubbleHelp(Xlat_0020251, locale);
	btnRefresh.translateCaption(Xlat_0020252, locale);
	btnShowKPI.translateBubbleHelp(Xlat_0005278, locale);
	btnShowKPI.translateCaption(Xlat_0005279, locale);
	btnViewHaz.translateCaption(Xlat_0005280, locale);
	btnViewYAlloc.translateCaption(Xlat_0005281, locale);
	chkContents.translateCaption(Xlat_0005282, locale);
	chkHaz.translateCaption(Xlat_0005283, locale);
	chkISO.translateCaption(Xlat_0005284, locale);
	chkImex.translateCaption(Xlat_0005285, locale);
	chkSpace.translateCaption(Xlat_0005286, locale);
	chkYalloc.translateCaption(Xlat_0005287, locale);
	cmbKPITA.translateBubbleHelp(Xlat_0005288, locale);
	cmbTA.translateBubbleHelp(Xlat_0005289, locale);
	lblAreas.translateCaption(Xlat_0005290, locale);
	lblDateFrom.translateCaption(Xlat_0005291, locale);
	lblDateTo.translateCaption(Xlat_0005292, locale);
	mnuAutoPlan.translateCaption(Xlat_0016202, locale);
	mnuAutoPlanTest.translateCaption(Xlat_0016203, locale);
	mnuCloneItem.translateCaption(Xlat_0016204, locale);
	mnuLocalContext.translateCaption(Xlat_0016205, locale);
	shtHaz.translateCaption(Xlat_0005293, locale);
	shtQuery7.translateCaption(Xlat_0005294, locale);
	shtSpace.translateCaption(Xlat_0005295, locale);
	shtSpaceDtl.translateCaption(Xlat_0005296, locale);
	shtYA.translateCaption(Xlat_0005297, locale);
end;</source>
    </JadeMethod>
