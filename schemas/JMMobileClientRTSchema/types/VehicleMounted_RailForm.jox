    <JadeMethod name="beginTimerForRefresh" id="ac6deecc-4000-4ab5-91ba-212676d95f9e">
        <updating/>
        <source>beginTimerForRefresh() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if (not self.timerRefreshActive) then
		self.timerRefreshActive := true;
		self.beginTimer(60000, Timer_OneShot, Timer_Refresh);
	endif;

epilog

end;</source>
