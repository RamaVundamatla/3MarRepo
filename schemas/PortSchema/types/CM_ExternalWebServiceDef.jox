    <JadeMethod name="getDisplayStringForAttribute" id="4e0c418d-dac0-417b-b6cd-801d2e8cf3a6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// 11 Jun 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 15 Nov 2021	navmd1	TFS 49052 Refactor ExtWSDef attributes post JADE2020 src comparison
// 17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
//
vars
	endpoint : CM_Endpoint;		// TFS 57207

begin

	if _attrName = ETRow_Version then
		return self.versionString;	 //epr TFS 45207
	elseif _attrName = ETRow_Active then
		return self.active.getYes;
	elseif _attrName = ETRow_EventType then
		if self.myEventMapping &lt;&gt; null then
			return self.myEventMapping.myEventType.name;
		else
			return null;
		endif;
	elseif _attrName = ETRow_WebServiceType then //jlier1 TFS 56856 28/3/23
		return self.getExternalWebServiceType;
	
	elseif _attrName = ETRow_Endpoints then		// TFS 57207
		return self.getEndpointsAsString();		// TFS 57207
    elseif _attrName = ETRow_TerminalsLastSuccessDT then            //MTN-36362
        return self.getTerminalLastSuccDTAsString();                //MTN-36362
        
	endif;
	
	// TFS 57207
	if _attrName.isOneOf(ETRow_RailReceivalEDBIC, ETRow_RoadReceivalEDBIC, ETRow_ShipReceivalEDBIC, 
							ETRow_ShipReleaseEDBIC, ETRow_TrainDepartureEDBIC, ETRow_TruckArrivalEDBIC,
							ETRow_TruckDepartureEDBIC, ETRow_VoyageArrivalEDBIC, ETRow_VoyageDepartureEDBIC) then
		endpoint := self.allEndpoints[_attrName];
		if endpoint &lt;&gt; null then
			return endpoint.verb &amp; Space &amp; endpoint.endpoint;
		endif;
		
		return null;
	endif;
	// TFS 57207
	/*
		Unhelpfully here, the column organiser has columns for almost all the subclass attributes
		Which means, the default 'return inheritMethod' doesn't work.
		
		Doing it this way, means we only have to specify attributes that don't match their ETRow name
		in the respective getStringForAttribute methods.
	*/
	
	// Check to see if we have the property we're looking for
	if self.class.findProperty(_attrName) &lt;&gt; null then
		return inheritMethod(_attrName, _short);
	endif;
	
	// If not, then return blank
	return null;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEndpointMethodAndValue" id="04db82c1-ef1c-48ff-8452-ee5dbe3c77a4">
        <source>getEndpointMethodAndValue(_value: String; _methodType: String output; _endpointPath: String output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2023	navdap1		Initial creation TFS 57207 EUP - Refactor Inspection App API Message
//
vars
	endpoint : CM_Endpoint;

begin
	endpoint := self.allEndpoints[_value];
	if endpoint &lt;&gt; null then
		_methodType := endpoint.verb;
		_endpointPath := endpoint.endpoint;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <Parameter name="_methodType" type="String" usage="output"/>
        <Parameter name="_endpointPath" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getEndpointsAsString" id="aa67b598-d957-4a5c-872d-17f45937810f">
        <source>getEndpointsAsString() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17 Apr 2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
//
vars
	endpoint : CM_Endpoint;
	str : String;
	
begin
	foreach endpoint in self.allEndpoints do
		if str = null then
			str := endpoint.verb &amp; Space &amp; endpoint.endpoint;
		else
			str := str &amp; "; " &amp; endpoint.verb &amp; Space &amp; endpoint.endpoint;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEndpointsView" id="35a80584-40e4-484a-9cf5-8e818cfe19df">
        <source>getEndpointsView() : EntTableView;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2024	jlier1	Initial creation

*/

vars
	def : EntTableDef;
begin
	def := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_ExtWebService];
	if def = null then
		return null;
	endif;
	
	return def.allEntTableViews[ETView_EndPointEWSEndPoints]; // ### JIRA 33544 15JAN2025 NAVAB1
epilog

end;</source>
        <ReturnType type="EntTableView"/>
    </JadeMethod>
    <JadeMethod name="getExtWebServiceTerminals" id="ed2cbc43-3cf3-439e-b240-6472f775cd3f">
        <source>getExtWebServiceTerminals(_terminalSet : CM_TerminalSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

*/

vars
	term 			: CM_Terminal;
	allUserTerminals: CM_TerminalByCodeDict;
begin

	_terminalSet.clear();
	
	create allUserTerminals transient;
	app.getMyUser.getTerminals(allUserTerminals);
	
	foreach term in self.allTerminals do
		if allUserTerminals.includes(term) then
			_terminalSet.add(term);
		endif;
	endforeach;

epilog
	delete allUserTerminals;

end;</source>
        <Parameter name="_terminalSet" type="CM_TerminalSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExternalWebServiceType" id="65fb8a6e-9b6e-414c-9982-caf78557a704">
        <source>getExternalWebServiceType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
10 Oct 2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
05 Dec 2022	navdap1	TFS 55159 MTN - Export CAMS to JSON API Endpoint
13 Nov 2023 navra1 	TFS 54090 -  EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61386/Task - 61389)
*/

vars

begin
	if self.isKindOf(CM_AllotracServiceDef) then
		return ExternalWebServiceAllotrac;
	elseif self.isKindOf ( CM_CargoChainServiceDef) then
		return ExternalWebServiceCARGOCHAIN;
	elseif self.isKindOf ( CM_InaportnetWebService) then
		return ExternalWebServiceINAPORTNET;
	elseif self.isKindOf ( CM_KiwiRailCheckInWSDef) then
		return ExternalWebServiceKiwiRail;
	elseif self.isKindOf ( CM_NavisMACS3Service) then
		return ExternalWebServiceNavisMACS3;
	elseif self.isKindOf ( CM_OpsViewServiceDef) then
		return ExternalWebServiceOPSVIEW;
	elseif self.isKindOf ( CM_SAPWebService) then
		return ExternalWebServiceSAP;
	elseif self.isKindOf ( CM_QshipsWebServiceDef) then
		return ExternalWebServiceQships;
	elseif self.isKindOf( CM_1StopVBSWebServiceDef ) then
		return ExternalWebService1StopVBS;
	elseif self.isKindOf(CM_CuxportServiceDef) then			//TFS 55215
		return ExternalWebServiceEDBIC;						//TFS 55215
	elseif self.isKindOf(CM_APIEndpointServiceDef) then		// TFS 55159
		return ExternalWebServiceAPIEndpoint;				// TFS 55159
	elseif self.isKindOf(CM_InvoiceAPIServiceDef) then		//navra1 - TFS 54090(CR 61386/Task - 61389) - 13th Nov 2023
		return ExternalWebServiceInvoiceAPI;				//navra1 - TFS 54090(CR 61386/Task - 61389) - 13th Nov 2023
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumBGPControllerForTerminal" id="2aafcdf6-8a2e-4307-bf56-34b0189e6caa">
        <source>getNumBGPControllerForTerminal(_terminal : CM_Terminal) : Integer;
/*
Purpose:			

Date		Who		Reason
23 August 2021	navab1	TFS 50669
*/

vars
	bgp : BGP_ExternalWSController;
	idx : Integer;
begin
	
	foreach bgp in self.allExternalBGPControllers do
		if bgp.myTerminal = _terminal then
			idx := idx + 1;
		endif;
	endforeach;
	
	return idx;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
