    <JadeMethod name="getPrefixForEventType" id="1650a71d-3596-40a8-9941-a2577f2cc21d">
        <source>getPrefixForEventType(_eventType : Integer) : String protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if _eventType = EVENT_ACTCAP_DIAGNOSTIC then
		return 'DAIG:' &amp; Tab;
	elseif _eventType = EVENT_ACTCAP_SECURITY then
		return 'SECRTY:'&amp; Tab;
	elseif _eventType = EVENT_ACTCAP_ENTDEF then
		return 'ENTDEF:'&amp; Tab;
	elseif _eventType = EVENT_ACTCAP_CONFIG then
		return 'CONFIG:'&amp; Tab;
	elseif _eventType = EVENT_ACTCAP_MISC then
		return 'MISC:'&amp; Tab;
	
	else
		return 'UNKWN:'&amp; Tab;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleActivityNotification" id="a8ebfc89-4204-44f5-9e05-60ef1ea2e60c">
        <updating/>
        <source>handleActivityNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	file				: File;
	str					: String;
begin

	if eventType = EVENT_ACTCAP_PROFILE then
		self.logProfilerOutput('Profiler output - from ' &amp; userInfo.String &amp; ' :');
		create file transient;
		file.usePresentationFileSystem := false;
		file.fileName := userInfo.String;
		if (not file.isAvailable) then
			str := userInfo.String &amp; ' &gt;&gt; FILE NOT AVAILABLE';
		else
			file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
			file.openInput(userInfo.String);
			while (not file.endOfFile()) do
				str := str &amp; file.readLine &amp; CrLf;
			endwhile;
			file.purge();
		endif;
		self.logProfilerOutput(str);
		app.writeLog(str, LogINFO);
	else
		self.cachedOutput := self.cachedOutput &amp; CrLf &amp; self.getPrefixForEventType(eventType) &amp; userInfo.String;
	endif;


epilog
	delete file;
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleCountFormsReqCompletion" id="3fda8a85-54ac-44c8-afa7-ee8339d10aa7">
        <source>handleCountFormsReqCompletion(_formsCount : NR_CountForms) protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	str	: String;
	f	: File;
begin

	global.beep;
	
	create f transient;
	f.fileName := 'c:\temp\forms.csv';
	f.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	f.mode := File.Mode_Append;
	if _formsCount &lt;&gt; self.myNodeFormCountRequest then
		app.msgBox('Returned formsCount request &lt;&gt; my formsCount request ... processing anyway', 'Warning', MsgBox_OK_Only);
	endif;

	self.tblLogEntries.addItem('');
	f.writeLine('');
	self.tblLogEntries.addItem(_formsCount.appName);
	f.writeLine(_formsCount.appName);
	self.tblLogEntries.addItem(_formsCount.userName);
	f.writeLine(_formsCount.userName);
	self.tblLogEntries.addItem(_formsCount.currentDateTime.String);
	f.writeLine(_formsCount.currentDateTime.String);
	self.tblLogEntries.addItem('Number of Forms = ' &amp; _formsCount.allFormDetails.size.String);
	f.writeLine('Number of Forms = ' &amp; _formsCount.allFormDetails.size.String);
	foreach str in _formsCount.allFormDetails do
		f.writeLine(str);
		self.tblLogEntries.addItem(str);
	endforeach;

	beginTransaction;
	// remove invalid entries from the collection
	_formsCount.allProcesses.rebuild();
	commitTransaction;

	if (not _formsCount.allProcesses.isEmpty()) then
		self.myNodeFormCountRequest.reset();
		self.tblLogEntries.addItem('Now sending to process ' &amp; _formsCount.allProcesses.first.String);
		// still needs to be sent to other processes
		_formsCount.allProcesses.first.causeEvent(self.myNodeFormCountRequest.NR_NodeRequestActionEvent, true, self.myNodeFormCountRequest);
		return;
	endif;

	self.endNotificationForSubscriber(self);

	self.btnSend.visible := true;
	self.btnCancelRequest.visible := false;

epilog
	if f &lt;&gt; null then
		f.close;
	endif;
	delete f;
end;</source>
        <access>protected</access>
        <Parameter name="_formsCount" type="NR_CountForms"/>
    </JadeMethod>
    <JadeMethod name="handleFileRequestCompletion" id="5689a3a5-5160-4b45-a0ba-bb7c7aafef7f">
        <updating/>
        <source>handleFileRequestCompletion(_nodeFileRequest : NR_NodeFileRequest input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	fileNode	: NR_FileNode;
	toDir		: String;
	idx			: Integer;
	
begin

	self.endNotificationForSubscriber(self);
	
	global.beep;
	
	if _nodeFileRequest &lt;&gt; self.myNodeFileRequest then
		app.msgBox('Returned node file request &lt;&gt; my node file request ... processing anyway', 'Warning', MsgBox_OK_Only);
	endif;
	
	staMain.caption := 'Request complete - processing data locally';
	
	if _nodeFileRequest.listFiles then
		self.tblFilesList.rows := self.tblFilesList.fixedRows;
		self.tblFilesToGet.rows := self.tblFilesToGet.fixedRows;
		
		beginTransaction;
		self.allFileNodes.purge;
		commitTransaction;
		
		_nodeFileRequest.allFileNodesByModifiedDT.copy(self.allFileNodes);
		
		// now remove from request so fileNodes don't get deleted when next request is sent
		beginTransaction;
		_nodeFileRequest.allFileNodesByModifiedDT.clear;
		_nodeFileRequest.allFileNodesByBaseName.clear;
		commitTransaction;
		
		foreach fileNode in self.allFileNodes do
			self.addFileNodeToTable(fileNode, tblFilesList);
		endforeach;
	endif;

	toDir := txtSaveDir.text;

	if _nodeFileRequest.isVersionInfoToBeReturned then
		
		_nodeFileRequest.outputVersionInfo(toDir, self, 'setStatusCaption');
	endif;

	
	if _nodeFileRequest.isIniFileToBeReturned or _nodeFileRequest.getFiles then
		if toDir &lt;&gt; null then
			_nodeFileRequest.outputDetails(toDir, self, 'setStatusCaption');
		endif;
	endif;

	staMain.caption := 'Local processing complete.';

	btnSend.visible := true;
	btnCancelRequest.visible := false;

end;</source>
        <access>protected</access>
        <Parameter name="_nodeFileRequest" type="NR_NodeFileRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleTransChkReqCompletion" id="b3f71480-fe1d-49a5-8f9f-835e17b746f6">
        <updating/>
        <source>handleTransChkReqCompletion(_nodeTransChkRequest : NR_CountTransients) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	fileNode	: NR_FileNode;
	toDir		: String;
	idx			: Integer;
	tmpStr		: String;
	
begin

	self.endNotificationForSubscriber(self);
	
	global.beep;
	
	if _nodeTransChkRequest &lt;&gt; self.myCountTransientsRequest then
		app.msgBox('Returned transient check request &lt;&gt; my transient check request ... processing anyway', 'Warning', MsgBox_OK_Only);
	endif;
	
	self.lstFound.clear;
	foreach tmpStr in _nodeTransChkRequest.allClassNamesFound do
		if tmpStr &lt;&gt; null then
			self.lstFound.addItem(tmpStr);
		endif;
	endforeach;
	
	staMain.caption := 'Request complete';
	
	btnSend.visible := true;
	btnCancelRequest.visible := false;

end;</source>
        <access>protected</access>
        <Parameter name="_nodeTransChkRequest" type="NR_CountTransients"/>
    </JadeMethod>
