<Class name="EntTableTextBox" id="d51a1d38-4d8c-4bfa-8a17-2c53b498003b">
    <superclass name="EntTableCellControl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="entTable"/>
    <PrimAttribute name="case" id="becaf813-1309-4624-9fbf-5d326f5df13d">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="maxLength" id="9fb52b7a-163e-49fc-849b-c758aa145034">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="getMaxLength" id="cf2f6ddb-e839-409c-8d52-6603dc6ea5d2">
        <source>getMaxLength(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.maxLength;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseCellControl" id="17fb1bb9-62c3-4e76-bc6e-806b0eae653e">
        <source>initialiseCellControl(pCell : JadeTableCell input);
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txtBox	: TextBox;
	saveStr	: String;
begin

	pCell.inputType	:= Table.InputType_TextBox;

	if pCell.cellControl &lt;&gt; null and pCell.cellControl.isKindOf(TextBox) then
		txtBox := pCell.cellControl.TextBox;
		if (self.case = TextBox.Case_UpperFirst or
		   self.case = TextBox.Case_LowerFirst) and
		   txtBox.text.length &gt; 1 and
		   (not txtBox.text[1].isAlpha()) then
			// cannot set to be case as system will puke with a 14067 error so ?
			txtBox.case := TextBox.Case_None;
		else
			txtBox.case := self.case;
		endif;
	endif;
	
	pCell.maxLength	:= self.maxLength;

	inheritMethod(pCell);
	
end;</source>
        <Parameter name="pCell" type="JadeTableCell" usage="input"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="9438206e-f5f6-4a89-97cc-6f1f295f4ae7">
        <source>outputAsXML(): String;
// ---------------------------------------------------------------------------
// Created:     27 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.xmlPrefix &amp;
	       self.formatAsXML(XMLTag_Case, self.case.String) &amp;
	       self.formatAsXML(XMLTag_MaxLength, self.maxLength.String) &amp;
	       self.xmlSuffix;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="74593829-2375-4a3a-9e3c-91d4127abc25">
        <updating/>
        <source>setForCreate(pProxy: EntTableTextBox; pRow: EntTableRow) updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.case		:= pProxy.case;
	self.maxLength	:= pProxy.maxLength;

	inheritMethod(pProxy, pRow);

end;</source>
        <Parameter name="pProxy" type="EntTableTextBox"/>
        <Parameter name="pRow" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="setFromXMLElement" id="a1700701-d906-49b2-bfab-01e5e32ba4b1">
        <updating/>
        <source>setFromXMLElement(_xmlElement : JadeXMLElement; pRow : EntTableRow) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.case		:= _xmlElement.getTagValueOfName(XMLTag_Case).Integer;
	self.maxLength	:= _xmlElement.getTagValueOfName(XMLTag_MaxLength).Integer;

	return inheritMethod(_xmlElement, pRow);

end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <Parameter name="pRow" type="EntTableRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
