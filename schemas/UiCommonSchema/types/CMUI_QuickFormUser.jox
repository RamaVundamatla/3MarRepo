    <JadeMethod name="populateTblSystem" id="0d7f74c5-461b-41be-adc3-58aad184d093">
        <source>populateTblSystem( _term : CM_Terminal );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation
08 Apr 2025 	naviv1		MTN-34407 - MTN | Remove old Windows CE based Handheld and Vehicle apps from Quick Find
*/

vars

	heading : String;
	quickAccess : CM_QuickAccess;
	rowIndex : Integer;
	hideHHandVM : Boolean;
begin
	hideHHandVM := app.myRoot.getConfig(HideAccessHHandVMApps).Boolean; //JIRA-34407

	self.tblSystem.clear();
	self.tblSystem.columns := 2;
	self.tblSystem.fixedColumns := 0;
	self.tblSystem.rows := 1;
	self.tblSystem.fixedRows := 1;
	self.tblSystem.selectMode := Table.SelectMode_CurrentRow;
	
	heading := app.getErrorString(ShortCut) &amp; Tab &amp; app.getErrorString(CM_Description);
	self.tblSystem.setCellText(1,1,heading);
	
	foreach quickAccess in app.myRoot.allSystemQuickAccess do
		if hideHHandVM then	//JIRA-34407
			if quickAccess.permissionInteger = PmAdmHandHeldLogonAs or quickAccess.permissionInteger = PmAdmVehicleRTLogonAs then
				continue;
			endif;
		endif;
		if quickAccess.permissionInteger = PmGteVehSchView then
			if _term = null or not _term.isVehicleBookingEnabled then
				continue;
			endif;
		endif;
		rowIndex := self.tblSystem.addItem( quickAccess.shortCode &amp; Tab &amp; quickAccess.helpDescription );
		self.tblSystem.accessRow(rowIndex).itemObject := quickAccess;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="populateTblUser" id="b104a6f9-acc1-486c-adc6-7126355f3281">
        <updating/>
        <source>populateTblUser( _quickAccess : CM_QuickAccess ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
09 July 2014	cnwndl1		Initial creation
08 Apr 2025 	naviv1		MTN-34407 - MTN | Remove old Windows CE based Handheld and Vehicle apps from Quick Find
*/

vars

	heading : String;
	quickAccess : CM_QuickAccess;
	rowIndex : Integer;
	systemQuickAccess : CM_QuickAccess;
	userQuickAccess : CM_QuickAccess;
	selectUserRow : Integer;
	hideHHandVM : Boolean;
begin

	hideHHandVM := app.myRoot.getConfig(HideAccessHHandVMApps).Boolean;  //JIRA-34407
	
	self.tblUser.clear();
	self.tblUser.columns := 2;
	self.tblUser.fixedColumns := 0;
	self.tblUser.rows := 1;
	self.tblUser.fixedRows := 1;
	self.tblUser.selectMode := Table.SelectMode_CurrentRow;
	
	heading := app.getErrorString(ShortCut) &amp; Tab &amp; app.getErrorString(CM_Description);
	self.tblUser.setCellText(1,1,heading);
		
	if self.myUser = null then
		return;
	endif;
	
	if _quickAccess &lt;&gt; null then
		foreach rowIndex in 2 to self.tblSystem.rows do
			systemQuickAccess := self.tblSystem.accessRow(rowIndex).itemObject.CM_QuickAccess;
			if hideHHandVM then
				if systemQuickAccess.permissionInteger = PmAdmHandHeldLogonAs or systemQuickAccess.permissionInteger = PmAdmVehicleRTLogonAs then
					continue;
				endif;
			endif;
			if systemQuickAccess = _quickAccess then
				userQuickAccess := self.myUser.getQuickAccessByPermission(systemQuickAccess.permissionInteger);
				self.displayQuickAccess( systemQuickAccess );
				break;
			endif;
		endforeach;
	endif;
	
	foreach quickAccess in self.myUser.allUserQuickAccess do
		if hideHHandVM then		//JIRA-34407
			if quickAccess.permissionInteger = PmAdmHandHeldLogonAs or quickAccess.permissionInteger = PmAdmVehicleRTLogonAs then
				continue;
			endif;
		endif;
		rowIndex := self.tblUser.addItem( quickAccess.shortCode &amp; Tab &amp; quickAccess.helpDescription );
		self.tblUser.accessRow(rowIndex).itemObject := quickAccess;
		if userQuickAccess = quickAccess then
			selectUserRow := rowIndex;
			self.displayQuickAccess( userQuickAccess );
		endif;
	endforeach;
	
	self.tblUser.row := 1;
	
	if selectUserRow &gt; 1 then
		self.tblUser.accessRow(selectUserRow).selected := true;
		self.tblUser.row := selectUserRow;
		self.tblUser.topRow := selectUserRow;
	endif;
	
epilog

end;</source>
        <Parameter name="_quickAccess" type="CM_QuickAccess"/>
    </JadeMethod>
    <JadeMethod name="setUpForm" id="43e5c578-4ef5-437a-9e4f-d6d13509e609">
        <updating/>
        <source>setUpForm( _user : CM_User; _term : CM_Terminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation

*/

vars

	user : CM_User;
	index : Integer;

begin

	self.populateTblSystem( _term );
	
	if _user &lt;&gt; null then
		self.myUser := _user;
		foreach user in app.myRoot.allUsers do
			index := self.cmbUser.addItem( user.userName );
			self.cmbUser.itemObject[index] := user;
		endforeach;
		self.cmbUser.listIndex := self.cmbUser.findObject( _user );
		self.cmbUser.enabled := not self.cmbUser.listIndex &gt; 0;
		
		self.populateTblUser( null );
		
	endif;
	
	foreach index in 2 to self.tblSystem.rows do
		self.tblSystem.accessRow(index).selected := false;
	endforeach;
	
	self.btnDefault.enabled := self.tblUser.allSelectedObjects.size &gt; 0;

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="tblSystem_click" id="6a571640-ba33-4a19-9039-8ee2e8cb52a7">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSystem_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation

*/

vars

	quickAccess : CM_QuickAccess;

begin

	quickAccess := self.tblSystem.accessRow(self.tblSystem.row).itemObject.CM_QuickAccess;

	self.populateTblUser( quickAccess );
	
	if quickAccess = null then
		self.displayQuickAccess( null );
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblUser_click" id="1fe61a7b-d674-43d2-b1ed-518577126ff6">
        <controlMethod name="Table::click"/>
