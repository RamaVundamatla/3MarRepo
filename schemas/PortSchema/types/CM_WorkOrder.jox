    <JadeMethod name="hasPackTask" id="9a346fc6-cf31-43f7-99f4-9d57193e1333">
        <source>hasPackTask() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	found : Boolean;
	task : CM_WorkOrderDtl;
	type : Integer;
begin

	found := false;
	
	foreach task in self.allWoDtls discreteLock do 		//28.05.2024 navma1 #64224
		type := task.detailType ;
		if type = WO_TASK_PACK then
			found := true;
			break;
		endif;
	endforeach;
	
