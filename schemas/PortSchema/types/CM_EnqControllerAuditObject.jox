    <JadeMethod name="addObjectToTableAllClasses" id="ad62e542-db20-4969-a012-5e60573822dc">
        <updating/>
        <source>addObjectToTableAllClasses() updating, protected;
// TFS 8390
vars
	iter	: MergeIterator;
	tmpAO	: CM_AuditObject;
	fromDate,
	toDate	: TimeStamp;
	dict	: CM_AuditObjectDictByTimestamp;
	useDate	: Boolean;
	tmpAC	: CM_AuditConfig;

begin
	fromDate := self.fromDateTime;
	toDate := self.toDateTime;
	useDate := toDate.isValid();

	create iter transient;

	if self.myCMObject = null then	//16 Oct 2019	NDL	TFS 47013
		foreach tmpAC in app.myRoot.allAuditConfigs discreteLock do
			iter.addCollection(tmpAC.allAuditObjects);
		endforeach;
	
	else	//16 Oct 2019	NDL	TFS 47013 - If we've gone to the trouble of setting this, use it.
		iter.addCollection(self.myCMObject.CM_AuditConfig.allAuditObjects);
		
	endif;

	if fromDate.isValid() then
		iter.startKeyGeq(fromDate);
	endif;
	
	while iter.next(tmpAO) do
		if useDate and tmpAO.timestamp &gt; toDate then
			break;
		endif;
		if includeObject(tmpAO) then
			self.addObjectToSet(tmpAO);
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQuery" id="ce0c0a35-1a5e-42d8-88f1-2ebf17938ca5">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
// TFS 8390
// 03 Jul 2025	navhl20 Defect MTN-35231: Selector Query - Cargo Transaction Days Passed less than 0 is not returning any data
vars
	crit			: CM_SelectorCriteriaLine;
	userSet : CM_UserSet;
	auditConfigSet : CM_ObjectSet;
	str: String;
	sa: StringArray;
	searchVal: Any;
	now: TimeStamp;
	user : CM_User;	//16 Oct 
begin
	inheritMethod(_qDef);
	self.reset();
	
	now := app.actualTimeServer();
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['timestamp', _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateEquals) then
			self.fromDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.toDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.toDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateGreaterThan) then
			self.fromDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.toDateTime := now;
		elseif crit.myQueryOperator.isKindOf(CM_QDateLessThan) then
			self.toDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.toDateTime.setTime('23:59:59:999'.Time);
			self.fromDateTime := null;
		elseif crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.fromDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.toDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.toDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateDayEquals) then
			self.fromDateTime := now.addDays(-crit.myQueryOperator.getSearchValue().Integer);
			self.fromDateTime.setTime('00:00'.Time);
			self.toDateTime := self.fromDateTime;
			self.toDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateDayLessThan) then
			self.fromDateTime := now.addDays(-crit.myQueryOperator.getSearchValue().Integer);		//03.07.2025 navhl20 #35231
			self.fromDateTime.setTime('00:00'.Time);
			self.toDateTime := now;
		elseif crit.myQueryOperator.isKindOf(CM_QDateDayGreaterThan) then
			self.toDateTime := now.addDays(-crit.myQueryOperator.getSearchValue().Integer);
			self.toDateTime.setTime('23:59:59:999'.Time);
			self.fromDateTime := null;
		elseif crit.myQueryOperator.isKindOf(CM_QDateDayRange) then
			self.fromDateTime := now.addDays(-1 * crit.myQueryOperator.CM_QDateDayRange.getSearchToValue().Integer.max(crit.myQueryOperator.CM_QDateDayRange.getSearchFromValue().Integer));
			self.fromDateTime.setTime('00:00'.Time);
			self.toDateTime := now.addDays(-1 * crit.myQueryOperator.CM_QDateDayRange.getSearchToValue().Integer.min(crit.myQueryOperator.CM_QDateDayRange.getSearchFromValue().Integer));
			self.toDateTime.setTime('23:59:59:999'.Time);
		endif;
	endif;

	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['getTime', _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QTimeGreaterThan) and self.fromDateTime.isValid() then
			self.fromDateTime.setTime(crit.myQueryOperator.getSearchValue().Time);
		elseif crit.myQueryOperator.isKindOf(CM_QTimeLessThan) and self.toDateTime.isValid() then
			self.toDateTime.setTime(crit.myQueryOperator.getSearchValue().Time);
		elseif crit.myQueryOperator.isKindOf(CM_QTimeRange) then
			if self.fromDateTime.isValid() then
				self.fromDateTime.setTime(crit.myQueryOperator.CM_QTimeRange.getSearchValueFromTime().Time);
			endif;
			if self.toDateTime.isValid() then
				self.toDateTime.setTime(crit.myQueryOperator.CM_QTimeRange.getSearchValueToTime().Time);
			endif;
		endif;
	endif;
/*
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['type', _qDef.className];
	if crit &lt;&gt; null then
		self.type := crit.myQueryOperator.getSearchValue().Integer;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['userCode', _qDef.className];
	if crit &lt;&gt; null then
		searchVal := crit.myQueryOperator.getSearchValue();
		if searchVal.isKindOf(StringArray) then
			sa := searchVal.StringArray;
			foreach str in sa do
				self.allUsers.add(app.myRoot.allUsers[str]);
			endforeach;
		elseif searchVal.isKindOf(String) then
			str := searchVal.String;
			self.allUsers.add(app.myRoot.allUsers[str]);
		endif;
	endif;
*/

	//16 Oct 2019	NDL	TFS 47013 - Make use of the user(s) if they have been selected in any way.
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['userCode', _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QStringLookup) then		//equal to
			str := crit.myQueryOperator.getSearchValue().String;
			if str &lt;&gt; null then
				user := app.myRoot.allUsers.getAtKey( str );
				if user &lt;&gt; null then
					self.allUsers.add( user );
				endif;
			endif;
		elseif crit.myQueryOperator.isKindOf(CM_QStringIsOneOf) then		//isOneOf
			sa := crit.myQueryOperator.getSearchValue().StringArray;
			if sa &lt;&gt; null then
				foreach str in sa do
					user := null;
					user := app.myRoot.allUsers.getAtKey( str );
					if user &lt;&gt; null then
						self.allUsers.add( user );
					endif;
				endforeach;
			endif;
		elseif crit.myQueryOperator.isKindOf(CM_QStringLookupNotEqual) then	//not equal to
			//ignore this one, won't be any quicker than using all users and eliminating in teh wash-up of checking all criteria.
		endif;
	endif;
	
	create auditConfigSet transient;	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['myAuditConfig', _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(auditConfigSet);
		self.myCMObject := auditConfigSet.first().CM_Object;
	endif;

	doSearch();
	
epilog
	endLoad;
	delete userSet;
	delete auditConfigSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="6f0a6645-86a6-4344-b342-33a58d6e021e">
        <updating/>
        <source>doSearch() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 February 2018	jlgab1	Initial creation
16 Oct 2019	NDL	TFS 47013 - Performance changes.

*/

vars
	iter	: Iterator;
	tmpAO	: CM_AuditObject;
	fromDate,
	toDate	: TimeStamp;
	dict	: CM_AuditObjectDictByTimestamp;
	useDate	: Boolean;
	user	: CM_User;

begin
	


	if self.allUsers.isEmpty() then
		self.addObjectToTableAllClasses();
		return;
		
	else
		
		fromDate := self.fromDateTime;
		toDate := self.toDateTime;
		useDate := toDate.isValid();
	
		foreach user in self.allUsers do
	
			dict := user.allAuditObjectChangesByMe;
			iter := dict.createIterator();
			if fromDate.isValid() then
				dict.startKeyGeq(fromDate, iter);
			endif;
			while iter.next(tmpAO) do
				if useDate and tmpAO.timestamp &gt; toDate then
					break;
				endif;
				if includeObject(tmpAO) then
					self.addObjectToSet(tmpAO);
				endif;
			endwhile;
			delete iter;
			
		endforeach;
		
	endif;

epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="includeObject" id="f644e889-9513-478d-8063-e3dd7a9257aa">
        <updating/>
        <source>includeObject(_obj: CM_Object): Boolean updating;
// TFS 8390
vars
	aud	: CM_AuditObject;
	auditDate : TimeStamp;
begin
	aud := _obj.CM_AuditObject;

	//User filter is done in copyCollectionToDynaDict
/*
	if self.type &lt;&gt; AuditAny then		
		if aud.type &lt;&gt; self.type then
			return false;
		endif;
	endif;
*/	
	if self.myCMObject &lt;&gt; null and aud.myAuditConfig &lt;&gt; null then
		if aud.myAuditConfig.className &lt;&gt; self.myCMObject.CM_AuditConfig.className then
			return false;
		endif;
	endif;

	if self.myCriteriaLineHolder &lt;&gt; null then
		if (not _obj.qrySelector(self.myCriteriaLineHolder)) then
			return false;
		endif;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reset" id="a1225530-d28d-48ee-bbbb-e1a661b3d2a1">
        <updating/>
        <source>reset() updating;
// TFS 8390
vars

begin
	inheritMethod();
	
	self.myCMObject				:= null;
	self.allUsers.clear();
	self.type			:= null;
	self.fromDateTime := null;
	self.toDateTime := null;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="9bea85cf-93d9-4829-bc68-467a47008d6a">
        <updating/>
        <source>setMyFilterClass() updating;
// TFS 8390
vars

begin
	self.myFilterClass := CM_AuditObject;


end;</source>
    </JadeMethod>
</Class>
