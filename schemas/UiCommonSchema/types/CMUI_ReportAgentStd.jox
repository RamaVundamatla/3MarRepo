        <source>getSelectedWOType(_typeArray: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	strObj		: Object;
	status		: String;
	
begin
	if _typeArray = null then
		app.raiseCMException2( MethodWithNullParam, method.name, '_TypeArray', null, null );
		return;
	endif;
	_typeArray.clear();
	
	if not self.isRowIncluded( ETRow_WorkOrderType ) then
		return;
	endif;
	
	foreach strObj in self.myLstTblWOType.allSelectedObjects do : wo_loop
		status	:= strObj.CM_WorkOrderDetailType.description;
		if not _typeArray.includes(status) then
			_typeArray.add( status );
		endif;
	endforeach wo_loop;
epilog

end;</source>
        <Parameter name="_typeArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectorControlCloned" id="3f1163f3-ed2c-414d-94c4-a705db12fc43">
        <updating/>
        <source>getSelectorControlCloned(_controlArray 			: ObjectArray input;
					_criteriaLineHolder 	: CM_QueryCriteriaLineHolder;
					_qProp 					: CM_QueryProperty; 
					_qOp 					: CM_QueryOperator; 
					_controlType, 
					_rowCount 				: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2004	cnwth2
//
// Purpose:     For each selector line in the report runner's entry table we are going to have CLONE a 
//				a control. If a cloned control of the correct type already exists, we will use that, else
//				we create a new one (hence the attritubes af 'maxComboNum' etc.

//				The name of the control is always set to be the master control's name &amp; the currentRow.String
//				in this way we can call the entry table's setValueByControlName method the 
//				CM_EntryTable::handleCellFocus's call back method - CMUI_ReportRunner::selectorControlLostFocus
//			 
// ----------   ----------  --------------------------------------------------
//21/08/2018 	Jlgns1	Bug 39835: PKT - Error 1090 and Wrong Report Output
//19 Nov 2024 	navah1	Bug 19289: CUX - Case # 00572807 - Report Runner shows "No Data to Display"
vars
	clonedTextBox			: CMUI_TextBox;
	clonedDateBox			: CMUI_DateMask;
	clonedTimeBox			: CMUI_TimeMask;
	clonedCombo				: CMUI_ComboBox;
	clonedLstTable			: CMUI_ListTable;
begin
	if _qProp = null or _qOp = null then
		return;
	endif;
	
	if _controlType = QueryControl_TextBox then
		self.maxTextBoxNum := self.maxTextBoxNum + 1;
		clonedTextBox := self.myTxtArgument.getControl(self.maxTextBoxNum).CMUI_TextBox;
		if clonedTextBox = null then
			clonedTextBox := self.myTxtArgument.loadControl(self.maxTextBoxNum).CMUI_TextBox;
			clonedTextBox.setPropertyValue('name', clonedTextBox.name &amp; _rowCount.String);
		endif;
		
		_qProp.setTextValues(clonedTextBox, _criteriaLineHolder, _qOp, app.myPassport);
		_controlArray.add(clonedTextBox);
	
	elseif _controlType = QueryControl_ComboBox then
		self.maxComboNum := self.maxComboNum + 1;
		clonedCombo := self.myCmbArgument.getControl(self.maxComboNum);
		if clonedCombo = null then
			clonedCombo := self.myCmbArgument.loadControl(self.maxComboNum).CMUI_ComboBox;
			clonedCombo.setPropertyValue('name', clonedCombo.name &amp; _rowCount.String);
		endif;
	
		_qProp.setComboValues(clonedCombo, _criteriaLineHolder, _qOp, app.myPassport);
		_controlArray.add(clonedCombo);
	
	elseif _controlType = QueryControl_MultiSelect then
		self.maxLstTableNum := self.maxLstTableNum + 1;
		clonedLstTable := self.myLstTblArgument.getControl(self.maxLstTableNum);
		if clonedLstTable = null then
			clonedLstTable := self.myLstTblArgument.loadControl(self.maxLstTableNum).CMUI_ListTable;
			clonedLstTable.setPropertyValue('name', clonedLstTable.name &amp; _rowCount.String);
		endif;
		clonedLstTable.clearSelected(); //epr 27867 12/11/2012
		_qProp.setListValues(clonedLstTable, _criteriaLineHolder, _qOp, app.myPassport);
		//the above call could create transient objects in the list table so...
		self.addListTransientsToCleanup(clonedLstTable);
		
		_controlArray.add(clonedLstTable);
		
	elseif _controlType = QueryControl_Date then
		self.maxDateBoxNum := self.maxDateBoxNum + 1;
		clonedDateBox := self.myTxtArgumentFromDate.getControl(self.maxDateBoxNum);
		if clonedDateBox = null then
			clonedDateBox := self.myTxtArgumentFromDate.loadControl(self.maxDateBoxNum).CMUI_DateMask;
			clonedDateBox.setPropertyValue('name', clonedDateBox.name &amp; _rowCount.String);
		endif;
		
		_qProp.setDateValues(clonedDateBox, _criteriaLineHolder, _qOp, app.myPassport);
		_controlArray.add(clonedDateBox);
	
	elseif _controlType = QueryControl_DateRange then
		self.maxDateBoxNum := self.maxDateBoxNum + 1;
		clonedDateBox := self.myTxtArgumentFromDate.getControl(self.maxDateBoxNum);
		if clonedDateBox = null then
			clonedDateBox := self.myTxtArgumentFromDate.loadControl(self.maxDateBoxNum).CMUI_DateMask;
			clonedDateBox.setPropertyValue('name', clonedDateBox.name &amp; _rowCount.String);
		endif;
		
		_qProp.setDateValues(clonedDateBox, _criteriaLineHolder, _qOp, app.myPassport);
		_controlArray.add(clonedDateBox);
		
		self.maxDateBoxNum := self.maxDateBoxNum + 1;
		clonedDateBox := self.myTxtArgumentToDate.getControl(self.maxDateBoxNum);
		if clonedDateBox = null then
			clonedDateBox := self.myTxtArgumentToDate.loadControl(self.maxDateBoxNum).CMUI_DateMask;
			clonedDateBox.setPropertyValue('name', clonedDateBox.name &amp; _rowCount.String);
		endif;
		
		_qProp.setDateValues(clonedDateBox, _criteriaLineHolder, _qOp, app.myPassport);
		_controlArray.add(clonedDateBox);
	elseif _controlType = QueryControl_NumTextBoxRange then
		//par 18120.  Code added. cnwjo3
		self.maxTextBoxRange := self.maxTextBoxRange + 1;
		self.maxTextBoxNum	:= self.maxTextBoxNum + 1;									//19.11.2024 navah1 #19289
		clonedTextBox := self.myTxtArgument.getControl(self.maxTextBoxNum).CMUI_TextBox;
		if clonedTextBox = null then
			clonedTextBox := self.myTxtArgument.loadControl(self.maxTextBoxNum).CMUI_TextBox;
			clonedTextBox.setPropertyValue('name', clonedTextBox.name &amp; _rowCount.String);
		endif;
		
		_qProp.setTextValues(clonedTextBox, _criteriaLineHolder, _qOp, app.myPassport);
		_controlArray.add(clonedTextBox);
	//14 May 2012	NDL	Par 29532	
	elseif _controlType = QueryControl_Time then
		self.maxTimeBoxNum := self.maxTimeBoxNum + 1;
		clonedTimeBox := self.myTxtArgumentFromTime.getControl(self.maxTimeBoxNum);
		if clonedTimeBox = null then
			clonedTimeBox := self.myTxtArgumentFromTime.loadControl(self.maxTimeBoxNum).CMUI_TimeMask;
			clonedTimeBox.setPropertyValue('name', clonedTimeBox.name &amp; _rowCount.String);
		endif;
		
		_qProp.setTimeValues(clonedTimeBox, _criteriaLineHolder, _qOp, app.myPassport);	//Bug 39835
		_controlArray.add(clonedTimeBox);												//Bug 39835
	//14 May 2012	NDL	Par 29532	
	elseif _controlType = QueryControl_TimeRange then
		self.maxTimeBoxNum := self.maxTimeBoxNum + 1;
		clonedTimeBox := self.myTxtArgumentFromTime.getControl(self.maxTimeBoxNum);
		if clonedTimeBox = null then
			clonedTimeBox := self.myTxtArgumentFromTime.loadControl(self.maxTimeBoxNum).CMUI_TimeMask;
			clonedTimeBox.setPropertyValue('name', clonedTimeBox.name &amp; _rowCount.String);
		endif;
		
		_qProp.setTimeValues(clonedTimeBox, _criteriaLineHolder, _qOp, app.myPassport);
		_controlArray.add(clonedTimeBox);
		
		self.maxTimeBoxNum := self.maxTimeBoxNum + 1;
		clonedTimeBox := self.myTxtArgumentToTime.getControl(self.maxTimeBoxNum);
		if clonedTimeBox = null then
			clonedTimeBox := self.myTxtArgumentToTime.loadControl(self.maxTimeBoxNum).CMUI_TimeMask;		// 37001 was using maxDateBoxNum
			clonedTimeBox.setPropertyValue('name', clonedTimeBox.name &amp; _rowCount.String);
		endif;
		
		_qProp.setTimeValues(clonedTimeBox, _criteriaLineHolder, _qOp, app.myPassport);
		_controlArray.add(clonedTimeBox);
	endif;
	
	
end;</source>
        <Parameter name="_controlArray" type="ObjectArray" usage="input"/>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_qProp" type="CM_QueryProperty"/>
        <Parameter name="_qOp" type="CM_QueryOperator"/>
        <Parameter name="_controlType" type="Integer"/>
        <Parameter name="_rowCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTemplateDateComboControl" id="7ef2dc72-24c1-43f3-aeed-7c89e614f598">
        <source>getTemplateDateComboControl(_entRowName : String) : String;
// cnwrs1 aug 2005
// foreach date entrow find the date combo box 
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 06/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Expected arrival/depature date/time
// 16 March 2023 navhl20 	Defect 57144: Send to Report showing Error
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
vars
	controlName : String;
	control : Control;
begin
	
	if _entRowName = ETRow_ActArrivedDateFrom then	//30 Oct 2012	NDL	Par 30394
		controlName := self.myCmbProcDate.name;
	elseif _entRowName = ETRow_ActArrivedDateTo then	//30 Oct 2012	NDL	Par 30394
		controlName := self.myCmbPackByDate.name;
	elseif _entRowName = ETRow_ActDepartedDateFrom then	//29 Oct 2012	NDL	Par 30394
		controlName := self.myCmbBaseDate.name;
	elseif _entRowName = ETRow_ActDepartedDateTo then	//29 Oct 2012	NDL	Par 30394
		controlName := self.myCmbCloseDate.name;
	elseif _entRowName = ETRow_ArrivalsDateFrom then
		controlName := self.myCmbArriveDFrom.name;
	elseif _entRowName = ETRow_ArrivalsDateTo then
		controlName := self.myCmbArriveDTo.name;
	elseif _entRowName = ETRow_BaseDate then
		controlName := self.myCmbBaseDate.name;
	elseif _entRowName = ETRow_CloseDate then
		controlName :=  self.myCmbCloseDate.name;
	elseif _entRowName = ETRow_DepartedDateFrom then
		controlName := self.myCmbDepartDFrom.name;
	elseif _entRowName = ETRow_DepartedDateTo then
		controlName := self.myCmbDepartDTo.name;
	elseif _entRowName = ETRow_InPortDateFrom then
		controlName := self.myCmbInPortDFrom.name;
	elseif _entRowName = ETRow_InPortDateTo then
		controlName := self.myCmbInPortDTo.name;
	elseif _entRowName = ETRow_MatchDateStart then
		controlName := self.myCmbMatchStart.name;
	elseif _entRowName = ETRow_MatchDateEnd then
		controlName := self.myCmbMatchEnd.name;
	elseif _entRowName = ETRow_MovementDateFrom then
		controlName := self.myCmbArriveDFrom.name;
	elseif _entRowName = ETRow_MovementDateTo then
		controlName := self.myCmbArriveDTo.name;
	elseif _entRowName = ETRow_OnDate then
		controlName :=  self.myCmbOnDate.name; 	
	elseif _entRowName = ETRow_OpenDate then
		controlName := self.myCmbOpenDate.name;
	elseif _entRowName = ETRow_EndDate then
		controlName :=  self.myCmbCloseDate.name;
	elseif _entRowName = ETRow_StartDate then
		controlName := self.myCmbOpenDate.name;
	elseif _entRowName = ETRow_LastConnectDT then
		controlName :=  self.myCmbOnDate.name; 		
	elseif _entRowName = ETRow_PackByDate then
		controlName := self.myCmbPackByDate.name;
	elseif _entRowName = ETRow_DateFrom or _entRowName = ETRow_RequiredByDateFrom then		//16.8.2023 navhl20 #58568
		controlName := self.myCmbOpenDate.name;
	elseif _entRowName = ETRow_DateTo or _entRowName = ETRow_RequiredByDateTo then			//16.8.2023 navhl20 #58568
		controlName :=  self.myCmbCloseDate.name;
	elseif _entRowName = ETRow_DateTimeFrom then
		controlName := self.myCmbOpenDate.name;
	elseif _entRowName = ETRow_DateTimeTo then
		controlName :=  self.myCmbCloseDate.name;
	elseif _entRowName = ETRow_FromPackByDate then		// cnwdad1 16/11/2010 - PAR #25218.
		controlName := self.myCmbOpenDate.name;					// cnwdad1 16/11/2010 - PAR #25218.
	elseif _entRowName = ETRow_ToPackByDate then		// cnwdad1 16/11/2010 - PAR #25218.
		controlName :=  self.myCmbCloseDate.name;					// cnwdad1 16/11/2010 - PAR #25218.
		
	elseif _entRowName = ETRow_FromEstReqDate then	//30 Dec 2010	NDL	Par 26650		
		controlName := self.myCmbOpenDate.name;					
	elseif _entRowName = ETRow_ToEstReqDate then	//30 Dec 2010	NDL	Par 26650		
		controlName :=  self.myCmbCloseDate.name;	
		
	
	//par 18183
	
	elseif _entRowName = ETRow_FilterDateIn or _entRowName = ETRow_FilterFromDate then	//02 Jun 2021	NDL	TFS 51245
		controlName := self.myCmbOpenDate.name;
	elseif _entRowName = ETRow_FilterDateOut or _entRowName = ETRow_FilterToDate then	//02 Jun 2021	NDL	TFS 51245
		controlName :=  self.myCmbCloseDate.name;
	elseif _entRowName = ETRow_ProcessDate then	//16 Nov 2009	NDL	Par 21519
		controlName :=  self.myCmbProcDate.name; 	
	elseif _entRowName = ETRow_EffectiveDate then	///cnwrd1 par 23583 11.8.2010
		controlName :=  self.myCmbOnDate.name; 	
	elseif _entRowName = ETRow_ExpiryDateFrom then //cnwrd1 par 23583 11.8.2010
		controlName :=self.myCmbOpenDate.name;
	elseif _entRowName = ETRow_ExpiryDateTo then //cnwrd1 par 23583 11.8.2010
		controlName :=  self.myCmbCloseDate.name;
		
	elseif _entRowName = ETRow_FromDate then	//14 Aug 2012	NDL	Par 29968		
		controlName := self.myCmbOpenDate.name;					
	elseif _entRowName = ETRow_ToDate then	//14 Aug 2012	NDL	Par 29968		
		controlName := self.myCmbCloseDate.name;
	elseif _entRowName = ETRow_ReportDate then	
		controlName := self.myCmbBaseDate.name;
	elseif _entRowName = ETRow_SchedDepartedDateFrom then	//30 Oct 2012	NDL	Par 30394
		controlName := self.myCmbDepartDFrom.name;
	elseif _entRowName = ETRow_SchedDepartedDateTo then	//30 Oct 2012	NDL	Par 30394
		controlName := self.myCmbDepartDTo.name;
	
	elseif _entRowName = ETRow_ExpectedArrivalDateFrom then			// PAR #35826
		controlName := self.myCmbExpectedArrDFrom.name;				// PAR #35826
	elseif _entRowName = ETRow_ExpectedArrivalDateTo then			// PAR #35826
		controlName := self.myCmbExpectedArrDTo.name;				// PAR #35826
	elseif _entRowName = ETRow_ExpectedDepartDateFrom then			// PAR #35826
		controlName := self.myCmbExpectedDepDFrom.name;				// PAR #35826
	elseif _entRowName = ETRow_ExpectedDepartDateTo then			// PAR #35826
		controlName := self.myCmbExpectedDepDTo.name;				// PAR #35826
	
	elseif _entRowName = ETRow_DateToRun then	//14 Aug 2019	NDL	TFS 46131
		controlName := self.myCmbOpenDate.name;
//	elseif _entRowName = ETRow_DateYearStart then	//14 Aug 2019	NDL	TFS 46131
	elseif _entRowName = ETRow_DateYearStart or _entRowName = ETRow_StartOfYearDate then	//02 Jun 2021	NDL	TFS 51245
		controlName := self.myCmbBaseDate.name;
	elseif _entRowName = ETRow_DateFromWO then				//21.3.2023 navhl20 #57144
		controlName := self.myCmbOpenDate.name;
	elseif _entRowName = ETRow_DateToWO then				//21.3.2023 navhl20 #57144
		controlName :=  self.myCmbCloseDate.name;
	elseif _entRowName = ETRow_TimeFromWO then				//21.3.2023 navhl20 #57144
		controlName := self.myCmbOpenDate.name;
	elseif _entRowName = ETRow_TimeToWO then				//21.3.2023 navhl20 #57144
		controlName :=  self.myCmbCloseDate.name;			
	
	// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
	elseif _entRowName = ETRow_ContractFromStartDate then
		controlName := self.myCmbContractFromStartDate.name;
	elseif _entRowName = ETRow_ContractToStartDate then
		controlName := self.myCmbContractToStartDate.name;
	elseif _entRowName = ETRow_DetailFromStartDate then
		controlName := self.myCmbDetailFromStartDate.name;
	elseif _entRowName = ETRow_DetailToStartDate then
		controlName := self.myCmbDetailToStartDate.name;
	elseif _entRowName = ETRow_RateFromStartDate then
		controlName := self.myCmbRateEntryFromStartDate.name;
	elseif _entRowName = ETRow_RateToStartDate then
		controlName := self.myCmbRateEntryToStartDate.name;
	elseif _entRowName = ETRow_ContractFromEndDate then
		controlName := self.myCmbContractFromEndDate.name;
	elseif _entRowName = ETRow_ContractToEndDate then
		controlName := self.myCmbContractToEndDate.name;
	elseif _entRowName = ETRow_DetailFromEndDate then
		controlName := self.myCmbDetailFromEndDate.name;
	elseif _entRowName = ETRow_DetailToEndDate then
		controlName := self.myCmbDetailToEndDate.name;
	elseif _entRowName = ETRow_RateFromEndDate then
		controlName := self.myCmbRateEntryFromEndDate.name;
	elseif _entRowName = ETRow_RateToEndDate then
		controlName := self.myCmbRateEntryToEndDate.name;
	// 20/04/2023	navkc1	CR 55654 Task 55670 &lt;--

	else
		//write _entRowName;
	endif;
	
	return controlName;
	
end;</source>
        <Parameter name="_entRowName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeForFormatDescription" id="a2ce0396-075a-44f8-8fbf-6a9f200bb819">
        <source>getTypeForFormatDescription(_formatDescr : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _formatDescr = self.FORMAT_OPTION_CSV then
		return JadeReportWriterReport.CSV;
	elseif _formatDescr = self.FORMAT_OPTION_HTML then
		return JadeReportWriterReport.HTML;
	elseif _formatDescr = self.FORMAT_OPTION_RTF then
		return JadeReportWriterReport.RTF;
	elseif _formatDescr = self.FORMAT_OPTION_XML then
		return JadeReportWriterReport.XML;
	elseif _formatDescr = self.FORMAT_OPTION_TEXT then
		return JadeReportWriterReport.TEXT;		// 28128
	else
		return JadeReportWriterReport.PRINTER;
	endif;

end;</source>
        <Parameter name="_formatDescr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValueByName" id="5ec80398-6ef1-49a0-a0cb-67e3dbe299a2">
        <source>getValueByName(_rowName : String) : Any;
// ---------------------------------------------------------------------------
// Created:     07 January 2004	cnwth2
//
// Purpose:     
// 19 July 2018	jlgrh7 TFS #39280 LNX - Cannot select default value for ETA and ETD in Report Maintenance
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
// ----------   ----------  --------------------------------------------------
vars
	numRows,
	row					: Integer;
	tbl					: CM_BaseTable;
	entTableRow			: EntTableRow;
	cell			: JadeTableCell;
begin
	// for CMUI_ReportRunner
	if self.myEntryTable &lt;&gt; null then
		return self.myEntryTable.getValueByName(_rowName);
	endif;
	//for CMUI_ReportBuilder	
	if _rowName = ETRow_ArrivalsDateFrom then
		return self.txtArriveDFrom;
	elseif _rowName = ETRow_ArrivalsDateTo then
		return self.txtArriveDTo;
	elseif _rowName = ETRow_BaseDate then
		return self.txtBaseDate;
	elseif _rowName = ETRow_CloseDate then
		return self.txtCloseDate;
	elseif _rowName = ETRow_DepartedDateFrom then
		return self.txtDepartDFrom;
	elseif _rowName = ETRow_DepartedDateTo then
		return self.txtDepartDTo;
	elseif _rowName = ETRow_InPortDateFrom then
		return self.txtInPortDFrom;
	elseif _rowName = ETRow_InPortDateTo then
		return self.txtInPortDTo;
	elseif _rowName = ETRow_MatchDateStart then
		return self.txtMatchStart;
	elseif _rowName = ETRow_MatchDateEnd then
		return self.txtMatchEnd;
	elseif _rowName = ETRow_OnDate then
		return self.txtOnDate;
	elseif _rowName = ETRow_OpenDate then
		return self.txtOpenDate;
		
// cnwdad1 19/11/2010 - PAR #25218.
	elseif _rowName = ETRow_FromPackByDate then
		return self.txtOpenDate;
	elseif _rowName = ETRow_ToPackByDate then
		return self.txtCloseDate;
		
	//30 Dec 2010	NDL	Par 26650
	elseif _rowName = ETRow_FromEstReqDate then
		return self.txtOpenDate;
	elseif _rowName = ETRow_ToEstReqDate then
		return self.txtCloseDate;
		
	//14 Aug 2012	NDL	Par 29968
	elseif _rowName = ETRow_FromDate then
		return self.txtOpenDate;
	elseif _rowName = ETRow_ToDate then
		return self.txtCloseDate;
		
	//par 18183 cnwjo3
	elseif _rowName = ETRow_FilterDateIn then
		//return self.myCmbOpenDate.text;
		return self.txtOpenDate;	//28 Feb 2018	NDL	TFS 37304
	elseif _rowName = ETRow_FilterDateOut then
		//return self.myCmbCloseDate.text;
		return self.txtCloseDate;	//28 Feb 2018	NDL	TFS 37304
	elseif _rowName = ETRow_ReportDate then
		return self.txtBaseDate;
		
	elseif _rowName = ETRow_ExpectedArrivalDateFrom then					//+TFS39280
		return self.txtEstimatedArrivalDFrom;
	elseif _rowName = ETRow_ExpectedArrivalDateTo then
		return self.txtEstimatedArrivalDTo;
	elseif _rowName = ETRow_ExpectedDepartDateFrom then
		return self.txtEstimatedDepartDFrom;
	elseif _rowName = ETRow_ExpectedDepartDateTo then 
		return self.txtEstimatedDepartDTo;
		
	elseif _rowName = ETRow_DateToRun then	//14 Aug 2019	NDL	TFS 46131
		return self.txtOpenDate;
//	elseif _rowName = ETRow_DateYearStart then	//14 Aug 2019	NDL	TFS 46131
	elseif _rowName = ETRow_DateYearStart or _rowName = ETRow_StartOfYearDate then	//02 Jun 2021	NDL	TFS 51245
		return self.txtBaseDate;
	
	// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
	elseif _rowName = ETRow_ContractFromStartDate then
		return self.txtContractFromStartDate;
	elseif _rowName = ETRow_ContractToStartDate then
		return self.txtContractToStartDate;
	elseif _rowName = ETRow_DetailFromStartDate then
		return self.txtDetailFromStartDate;
	elseif _rowName = ETRow_DetailToStartDate then
		return self.txtDetailToStartDate;
	elseif _rowName = ETRow_RateFromStartDate then
		return self.txtRateEntryFromStartDate;
	elseif _rowName = ETRow_RateToStartDate then
		return self.txtRateEntryToStartDate;
		
	elseif _rowName = ETRow_ContractFromEndDate then
		return self.txtContractFromEndDate;
	elseif _rowName = ETRow_ContractToEndDate then
		return self.txtContractToEndDate;
	elseif _rowName = ETRow_DetailFromEndDate then
		return self.txtDetailFromEndDate;
	elseif _rowName = ETRow_DetailToEndDate then
		return self.txtDetailToEndDate;
	elseif _rowName = ETRow_RateFromEndDate then
		return self.txtRateEntryFromEndDate;
	elseif _rowName = ETRow_RateToEndDate then
		return self.txtRateEntryToEndDate;
	// 20/04/2023	navkc1	CR 55654 Task 55670 &lt;--
		
	endif;
	tbl := self.myBaseTable;
	if tbl = null then
		return null;
	endif;
	
	numRows := tbl.rows;
	foreach row in 1 to numRows do
		entTableRow := tbl.accessRow(row).itemObject.EntTableRow;
		if (entTableRow = null) or
		   (entTableRow.name &lt;&gt; _rowName) then
		   continue;
		endif;
// Par10732 check box defaults not being set on Report Builder		
		cell := tbl.accessCell(row, CMUI_ReportBuilder.Column_DefaultValue);
		if cell.inputType = tbl.InputType_CheckBox then 
			if cell.text.length &gt; 0 and cell.text[1] = '1' then
				return true;
			else
				return false;
			endif;
		endif;
		
		return tbl.getCellText(row, CMUI_ReportBuilder.Column_DefaultValue);
	endforeach;

	return null;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getValueByNameIfVisible" id="01d0130b-80fa-41a7-a595-d7147f104ef1">
        <source>getValueByNameIfVisible(_rowName : String) : Any;
// ---------------------------------------------------------------------------
// Created:     07 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	theValue : Any;

begin

	// Par 9142	
	//  DVB 22/10/04 
	if self.myEntryTable &lt;&gt; null then
		theValue := self.myEntryTable.getValueByNameIfVisible(_rowName);
		if theValue &lt;&gt; null then
			return theValue;
		endif;
	endif;

	if self.isRowIncluded(_rowName) then
		return self.getValueByName(_rowName);
	endif;

	return null;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getValueForTemplateDates" id="e2630c7e-88df-4807-aeb5-ec5b029768a8">
        <source>getValueForTemplateDates(_name: String): String;
// -------------------------------------------
// Created 23 September 2005 by cnwdvb1
// -------------------------------------------
vars

	cell 	: JadeTableCell;
	theRow	: Integer;

begin

/*		self.switchDateBoxComboBox(true, ETRow_BaseDate, self.cmbBaseDate);
		self.switchDateBoxComboBox(true, ETRow_CloseDate, self.cmbCloseDate);
		self.switchDateBoxComboBox(true, ETRow_MatchDateEnd, self.cmbMatchEnd);
		self.switchDateBoxComboBox(true, ETRow_MatchDateStart, self.cmbMatchStart);
		self.switchDateBoxComboBox(true, ETRow_OnDate, self.cmbOnDate);
		self.switchDateBoxComboBox(true, ETRow_OpenDate, self.cmbOpenDate);
		
		self.switchDateBoxComboBox(true, ETRow_StartDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(true, ETRow_EndDate, self.cmbCloseDate);
		
			// HMS
		self.switchDateBoxComboBox(true, ETRow_ArrivalsDateFrom, self.cmbArriveDFrom);
		self.switchDateBoxComboBox(true, ETRow_ArrivalsDateTo, self.cmbArriveDTo);
		self.switchDateBoxComboBox(true, ETRow_DepartedDateFrom, self.cmbDepartDFrom);
		self.switchDateBoxComboBox(true, ETRow_DepartedDateTo, self.cmbDepartDTo);
		self.switchDateBoxComboBox(true, ETRow_InPortDateFrom, self.cmbInPortDFrom);
		self.switchDateBoxComboBox(true, ETRow_InPortDateTo, self.cmbInPortDTo);*/
	
//	below populates from report runner		
	if 	self.myEntryTable &lt;&gt; null then 
		theRow := self.myEntryTable.getRow(_name);
		
		if theRow &lt;&gt; 0 then
			if self.myEntryTable.isValidRow(theRow)  then
				cell := self.myEntryTable.accessCell(theRow, CM_EntryTable.ColumnValue);
				if cell &lt;&gt; null then 
					return cell.text;
				endif;
			endif;
		endif;
		return inheritMethod(_name);
	endif;

//	below populates from report builder. report builder has myEntryTable set to null 
	if self.isRowIncluded(_name) then
		return self.getValueByName(_name).String;
	endif;

	return null;	
	
	// 
/*	if _name = ETRow_BaseDate then
		return self.myCmbBaseDate.text;
	elseif _name = ETRow_OpenDate then
		return self.myCmbOpenDate.text;
	elseif _name = ETRow_CloseDate then
		return self.myCmbCloseDate.text;
	elseif _name = ETRow_StartDate then
		write self.myCmbOpenDate.text;
		return self.myCmbOpenDate.text;
	elseif _name = ETRow_EndDate then
		return self.myCmbCloseDate.text;
	elseif _name = ETRow_MatchDateStart then
		return self.myCmbMatchStart.text;
	elseif _name = ETRow_MatchDateEnd then
		return self.myCmbMatchEnd.text;
	elseif _name = ETRow_LastConnectDT then
		return self.myCmbOnDate.text;
	elseif _name = ETRow_MovementDateFrom then
		return self.myCmbArriveDFrom.text;
	elseif _name = ETRow_MovementDateTo then
		return self.myCmbArriveDTo.text;
	elseif _name = ETRow_ArrivalsDateFrom then
		return self.myCmbArriveDFrom.text;
	elseif _name = ETRow_ArrivalsDateTo then
		return self.myCmbArriveDTo.text;
	elseif _name = ETRow_DepartedDateFrom then
		return self.myCmbDepartDFrom.text;
	elseif _name = ETRow_DepartedDateTo then
		return self.myCmbDepartDTo.text;
	elseif _name = ETRow_InPortDateFrom then
		return self.myCmbInPortDFrom.text;
	elseif _name = ETRow_InPortDateTo then
		return self.myCmbInPortDTo.text;
	elseif _name = ETRow_OnDate then
		return self.myCmbOnDate.text;
	endif;*/
	


end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getViewNameForSelectorMode" id="8ff940a8-93bd-45e2-a25b-878832998e1d">
        <source>getViewNameForSelectorMode(_mode : Integer) : String;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
// 34442 add the financial selectors
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
// 16 Aug 2023 	navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
vars

begin
	if _mode = CM_QueryDefinition.CargoTransaction_Query_Mode or
		_mode = CM_QueryDefinition.EventTransaction_Query_Mode or
		_mode = CM_QueryDefinition.HMSTransaction_Query_Mode then
		return CM_TransactionView;
	elseif _mode = CM_QueryDefinition.CashPayment_Query_Mode or
		_mode = CM_QueryDefinition.CashReceipt_Query_Mode or
		_mode = CM_QueryDefinition.Invoice_Query_Mode or
		_mode = CM_QueryDefinition.InvoiceLine_Query_Mode then
		return CM_InvoiceView;
	elseif _mode = CM_QueryDefinition.Audit_Query_Mode then		// 31/5/18 MAP TFS37718
		return CM_AuditObjectView;
	elseif _mode = CM_QueryDefinition.Contract_Query_Mode then // 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
		return CM_InvoiceContractView;
	elseif _mode = CM_QueryDefinition.WorkOder_Query_Mode then //16.8.2023 navhl20 #58568
		return CM_WorkOrderView;
	else
		return CM_TrackedItemView;
	endif;
end;
</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getViewNameForTypeDescription" id="be6f2ac1-b3bb-4666-8948-774753cabd0b">
        <source>getViewNameForTypeDescription(_descr : String) : String;
// ---------------------------------------------------------------------------
// Created:     19 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 01/11/2010	cnwcs5		par 23714/ccms 1132 - new report type (machine history)
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Reports
// 01/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 03/08/2022	navkc1		Bug 54342: PRP - VVR Report
// 16 Mar 2023 	navhl20 	Defect 57144: Send to Report showing Error
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
vars

begin
	if (_descr = CM_QryReport.ReportTypeDescr_External) then
		return null;//no default JRW view for external type
	endif;
		
	if (_descr = CM_QryReport.ReportTypeDescr_BookingRef) or		// Par 17601. July 2008
	   (_descr = CM_QryReport.ReportTypeDescr_CargoReport) or
	   (_descr = CM_QryReport.ReportTypeDescr_BR_Discrepancy) or	//07 Sep 2009	NDL CCMS 1609 Par 20521
	   (_descr = CM_QryReport.ReportTypeDescr_TrackedItem) or
	   (_descr = CM_QryReport.ReportTypeDescr_Selector) or 
	   (_descr = CM_QryReport.ReportTypeDescr_Train) or				// Par 19913
	   (_descr = CM_QryReport.ReportTypeDescr_Events) or
	   (_descr = CM_QryReport.ReportTypeDescr_LogSummary) or    //21 January 2010	#cnwdz2	 CCMS 1108 par22177 
	   (_descr = CM_QryReport.ReportTypeDescr_OrgAccess) or	// Feb 2013 CCMS HAT 2205
	   (_descr = CM_QryReport.ReportTypeDescr_GateReceipt) then	// 03/08/2022	navkc1	#54342
		return CM_TrackedItemView;
	
	elseif _descr = CM_QryReport.ReportTypeDescr_LogDocket then
		return Logs;
	
	elseif _descr = CM_QryReport.ReportTypeDescr_LogLocation then
		return 'Log Locations';
	
	elseif (_descr = CM_QryReport.ReportTypeDescr_LogProductLoc) or
	   (_descr = CM_QryReport.ReportTypeDescr_LogVoyRowSum) then
		return CM_LogProductLocation;
	
	elseif (_descr = CM_QryReport.ReportTypeDescr_LogTransaction) or
		 (_descr = CM_QryReport.ReportTypeDescr_TrxResource) or // 18 Jan 2010 NDL CCMS MES 1006
		 (_descr = CM_QryReport.ReportTypeDescr_TrxSealChecks) or // 30 Sep 2010 NDL Par 25608
		 (_descr = CM_QryReport.ReportTypeDescr_TransReport) or
		 (_descr = CM_QryReport.ReportTypeDescr_BOLTransaction) or    // 2/5/2016  cnwjre1  TFS 1904
		 (_descr = CM_QryReport.ReportTypeDescr_CargoChgs) or //28 Feb 2012	NDL	Par 29118
		 (_descr = CM_QryReport.ReportTypeDescr_EvtTrans) or // 06 Jan 2020 NDL	TFS 47780
		 (_descr = CM_QryReport.ReportTypeDescr_WOTrans)  		//16.3.2023 navhl20	#57144
		 
		 then
		return CM_TransactionView;
		
	elseif (_descr = CM_QryReport.ReportTypeDescr_LocActivity) or	//04 Jun 2021	NDL	TFS 51245
		 (_descr = CM_QryReport.ReportTypeDescr_LocInventory)	//04 Jun 2021	NDL	TFS 51245
		 then
		return CM_LocationActivityView;
		
	elseif _descr = CM_QryReport.ReportTypeDescr_LogCheckScale then
		return CM_LogCheckScaleView;
	elseif _descr = CM_QryReport.ReportTypeDescr_HMSVoyage or 
	   _descr = CM_QryReport.ReportTypeDescr_HMSMovements or
	   _descr = CM_QryReport.ReportTypeDescr_HMSMasters or	//01 May 2012	NDL	Par 29496
	   _descr = CM_QryReport.ReportTypeDescr_Vessels or	//01 May 2012	NDL	Par 29496
	   _descr = CM_QryReport.ReportTypeDescr_SpecialVoySumm or	//14 Aug 2019	NDL	TFS 46131
	   _descr = CM_QryReport.ReportTypeDescr_HMSGlobalVoy or
	   _descr = CM_QryReport.ReportTypeDescr_CraneKPI then		// Dec 2010 CCMS 1134
		return CM_VoyageView;
	elseif _descr = CM_QryReport.ReportTypeDescr_VehicleDetails or
		_descr = CM_QryReport.ReportTypeDescr_VehicleBooking  then
		return CM_VehicleVisitView;
	elseif _descr = CM_QryReport.ReportTypeDescr_DateSorter then //CCMS 1869 cnwjo3
		return CM_ReportDateSorterView;
	
	elseif _descr = CM_QryReport.ReportTypeDescr_Invoice or
		_descr = CM_QryReport.ReportTypeDescr_CashTrx or	//14 Aug 2012	NDL	Par 29968
		_descr = CM_QryReport.ReportTypeDescr_InvoiceRate or	//cnwrd1 par 23583 11.8.2010
		_descr = CM_QryReport.ReportTypeDescr_InvoiceLine or	// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
		_descr = CM_QryReport.ReportTypeDescr_CashReceipt or	// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
		_descr = CM_QryReport.ReportTypeDescr_CashCredit or		// 3/02/2016 cnwjre1	TFS 985 cash credits
		_descr = CM_QryReport.ReportTypeDescr_InvoiceProform // 18/8/15 cnwer1 CCMS 2368 
		then // SFW CCMS 1115 PAR23680 - cnwsh3. Invoice JRW Interface
		return CM_InvoiceView;
	
	elseif _descr = CM_QryReport.ReportTypeDescr_MachineHistory then	// 01/11/2010 cnwcs5 par 23714/ccms 1132
		return CM_MachineHistoryView;									// 01/11/2010 cnwcs5 par 23714/ccms 1132
		
	elseif _descr = CM_QryReport.ReportTypeDescr_BulkReleases then			// TFS 5558
		return CM_MTReportView;												// TFS 5558
		
	elseif _descr = CM_QryReport.ReportTypeDescr_Audit then					// TFS 37718
		return CM_AuditObjectView;											// TFS 37718

	elseif _descr = CM_QryReport.ReportTypeDescr_SAPActivity then		// TFS 44298
		return CM_ActivityHistoryView;									// TFS 44298
		
	elseif _descr = CM_QryReport.ReportTypeDescr_InvoiceContrct then // 20/04/2023	navkc1	CR 55654 Task 55670
		return CM_InvoiceContractView;
		
	elseif _descr = CM_QryReport.ReportTypeDescr_WorkOrder then 	//16.8.2023 navhl20 #58568
		return CM_WorkOrderView;
	endif;	
	
end;</source>
        <Parameter name="_descr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="fa4ad858-0cd0-44d2-b779-0318fd4731d5">
        <updating/>
        <source>init(_parentForm : CM_BaseForm) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2004	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 06/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Added expected arrival/departure date/time
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
vars

begin

	self.myParentForm := _parentForm;

	if CMUI_ReportRunner.hasInstance(_parentForm) then
		self.initFromReportRunner();
	elseif CMUI_ReportBuilder.hasInstance(_parentForm) then
		self.initFromReportBuilder();
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Parent form unhandled type or null');
		return;
	endif;

	//loadTemplateDateTypes
	self.doLoadTemplateDateTypes(self.myCmbBaseDate);
	self.doLoadTemplateDateTypes(self.myCmbCloseDate);
	self.doLoadTemplateDateTypes(self.myCmbPackByDate);
	self.doLoadTemplateDateTypes(self.myCmbMatchEnd);
	self.doLoadTemplateDateTypes(self.myCmbMatchStart);
	self.doLoadTemplateDateTypes(self.myCmbOnDate);
	self.doLoadTemplateDateTypes(self.myCmbOpenDate);
	
	// HMS 
	self.doLoadTemplateDateTypes(self.myCmbArriveDFrom);
	self.doLoadTemplateDateTypes(self.myCmbArriveDTo);

	self.doLoadTemplateDateTypes(self.myCmbDepartDFrom);
	self.doLoadTemplateDateTypes(self.myCmbDepartDTo);
	
	self.doLoadTemplateDateTypes(self.myCmbInPortDFrom);
	self.doLoadTemplateDateTypes(self.myCmbInPortDTo);
	
	self.doLoadTemplateDateTypes(self.myCmbProcDate);	//16 Nov 2009	NDL	Par 21519
	
	self.doLoadTemplateDateTypes(self.myCmbExpectedArrDFrom);		// PAR #35826
	self.doLoadTemplateDateTypes(self.myCmbExpectedArrDTo);			// PAR #35826
	self.doLoadTemplateDateTypes(self.myCmbExpectedDepDFrom);		// PAR #35826
	self.doLoadTemplateDateTypes(self.myCmbExpectedDepDTo);			// PAR #35826
	
	// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
	self.doLoadTemplateDateTypes(self.myCmbContractFromStartDate);
	self.doLoadTemplateDateTypes(self.myCmbContractToStartDate);
	self.doLoadTemplateDateTypes(self.myCmbDetailFromStartDate);
	self.doLoadTemplateDateTypes(self.myCmbDetailToStartDate);
	self.doLoadTemplateDateTypes(self.myCmbRateEntryFromStartDate);
	self.doLoadTemplateDateTypes(self.myCmbRateEntryToStartDate);
	
	self.doLoadTemplateDateTypes(self.myCmbContractFromEndDate);
	self.doLoadTemplateDateTypes(self.myCmbContractToEndDate);
	self.doLoadTemplateDateTypes(self.myCmbDetailFromEndDate);
	self.doLoadTemplateDateTypes(self.myCmbDetailToEndDate);
	self.doLoadTemplateDateTypes(self.myCmbRateEntryFromEndDate);
	self.doLoadTemplateDateTypes(self.myCmbRateEntryToEndDate);
	// 20/04/2023	navkc1	CR 55654 Task 55670 &lt;--
end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="initFromReportBuilder" id="8cc22dee-1381-4c48-ac3a-d797ec1f2649">
        <updating/>
        <source>initFromReportBuilder() updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 12/08/2008 	concms1		Par 17586 Add vessel parameter
// 27/05/2009	concms1		Par 19768 Add shipping line parameter
// 04/07/2010	cnwdap1		PAR #24519 Add Include Tranships parameter
// 10/09/2010	cnwcs5		par 23714/ccms 1132 - added machine, machine type, delay type group and delay type parameters
// 06/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 added expected arrival/departure date
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Report
// 12/02/2018	jlgdap1		TFS 37030 SSL Demurrage report
// 03/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 25/05/2022 	navhl20	 	TFS 53430  EUP - Sub Carrier registration in MTN
// 16 March 2023 navhl20 	Defect 57144: Send to Report showing Error
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 24 May 2023 	navhl20 	ChangeRequest 53902:[57781] EUP - VBS MTN - [6] - Selector Query and JRW
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
// 28 Aug 2023 	navhl20 	Bug 60056: FR | 53429 - VBS Selector issues
vars
	frm : CMUI_ReportBuilder;
begin
	frm := self.myParentForm.CMUI_ReportBuilder;
	
	self.isOptCurrentVoyageAllowed := true;
	
	self.myAssistant := frm.myAssistant;
	self.myBaseTable := frm.tblCriteria;
	self.myEntryTable := null;
	
	self.myLstTblAvaGrade		:= frm.lstTblAvaGrade;
	self.myLstCashDrs			:= frm.lstTblCashDrs;	// 14 Aug 2012	NDL	Par 29968
	self.myLstTblEventTypes		:= frm.lstTblEventTypes;
	self.myLstTblUsers			:= frm.lstTblUsers;
	self.myLstTblIMEX			:= frm.lstTblIMEX;
	self.myLstTblLogLot			:= frm.lstTblLogLot;
	self.myLstTblPackArea		:= frm.lstTblPackArea;
	self.myLstTblSiteState		:= frm.lstTblSiteState;
	self.myLstTblStop			:= frm.lstTblStop;
	self.myLstTblTransact		:= frm.lstTblTransact;
	self.myLstTblWOTransact		:= frm.lstTblWOTransact;		//16.3.2023 navhl20	#57144
	self.myLstTblWOStatus		:= frm.lstTblWOStatus;			//16.8.2023 navhl20 #58568
	self.myLstTblWOType			:= frm.lstTblWOType;			//16.8.2023 navhl20 #58568
	self.myLstTblTasks			:= frm.lstTblTasks;		// 20 Oct 20101	Par 23800
	self.myLstTblVoyageJob		:= frm.lstTblVoyageJob;
	self.myLstTblDelayType		:= frm.lstTblDelayType;// 03/12/2010	cnwsh3		CCMS1132/PAR23714 	Machine Productivity reporting
	self.myLstTblDelayTypeGroup := frm.lstTblDelayTypGp;// 03/12/2010	cnwsh3		CCMS1132/PAR23714 	Machine Productivity reporting
	
	self.baseDate := frm.tblCriteriaGetValueByName(ETRow_BaseDate).Date;
	self.onDate	:= frm.tblCriteriaGetValueByName(ETRow_OnDate).Date;
	self.openDate := frm.tblCriteriaGetValueByName(ETRow_OpenDate).Date;
	self.closeDate := frm.tblCriteriaGetValueByName(ETRow_CloseDate).Date;
	self.matchStart	:= frm.tblCriteriaGetValueByName(ETRow_BaseDate).Date;
	self.matchEnd := frm.tblCriteriaGetValueByName(ETRow_BaseDate).Date;
	
	self.includeTranships := frm.tblCriteriaGetValueByName(ETRow_IncludeTranships).Boolean;	// PAR #24519
	self.pieceCountError := frm.tblCriteriaGetValueByName(ETRow_PieceCountError).Boolean;  //#23894 24/05/2010
	
	self.startTime := frm.tblCriteriaGetValueByName(ETRow_StartTime).Time;
	self.endTime := frm.tblCriteriaGetValueByName(ETRow_EndTime).Time;
//	self.onTime	:= frm.tblCriteriaGetValueByName(ETRow_OnTime).Time;
	
	self.myCmbAgent 			:= frm.cmbAgent;		// 36778
	self.myCmbActualVoy 		:= frm.cmbActualVoy;
	self.myCmbAgeType			:= frm.cmbAgeType;
	self.myCmbAllocatedVoy		:= frm.cmbAllocatedVoy;
	self.myCmbBaseDate			:= frm.cmbBaseDate;
	self.myCmbBOLIn				:= frm.cmbBOLIn;
	self.myCmbBOLOut			:= frm.cmbBOLOut;
	self.myCmbBOLType			:= frm.cmbBOLType;
	self.myCmbCargoType			:= frm.cmbCargoType;
	self.myCmbCarrier			:= frm.cmbCarrier;
	self.myCmbSubCarrier		:= frm.cmbSubCarrier;			//25/05/2022 navhl20 TFS 53430
	self.myCmbCellularVoy		:= frm.cmbCellularVoy;
	self.myCmbCloseDate			:= frm.cmbCloseDate;
	self.myCmbConsignee			:= frm.cmbConsignee;
	self.myCmbConsignor			:= frm.cmbConsignor;
	self.myCmbCrane				:= frm.cmbCrane;
	self.myCmbChkScaled			:= frm.cmbChkScaled;
	//self.myCmbDelayType			:= frm.cmbDelayType;	// 10/09/2010 cnwcs5 par 23714/ccms 1132
	//self.myCmbDelayTypeGrp		:= frm.cmbDelayTypeGrp;	// 10/09/2010 cnwcs5 par 23714/ccms 1132
	self.myCmbDocketChk			:= frm.cmbDocketChk;
	self.myCmbDocketErrCode		:= frm.cmbDocketErrCode; //ccms 1110
	self.myCmbHatch				:= frm.cmbHatch;
	self.myCmbISOGroup			:= frm.cmbISOGroup;
	self.myCmbLoadedOption		:= frm.cmbLoadedOption;
	self.myCmbLoadPort			:= frm.cmbLoadPort;
	self.myCmbLoggingOrg		:= frm.cmbLoggingOrg;
	self.myCmbLogGrade			:= frm.cmbLogGrade;
	self.myCmbLogLength			:= frm.cmbLogLength;
	self.myCmbLogOperation		:= frm.cmbLogOperation;
	self.myCmbLogSpecies		:= frm.cmbLogSpecies;
	self.myCmbLogTreatment		:= frm.cmbLogTreatment;
	self.myCmbLogType			:= frm.cmbLogType;
	self.myCmbLot				:= frm.cmbLot;
	self.myCmbMachineType		:= frm.cmbMachineType;	// 10/09/2010 cnwcs5 par 23714/ccms 1132
	self.myCmbMachine			:= frm.cmbMachine;		// 10/09/2010 cnwcs5 par 23714/ccms 1132
	self.myCmbMasters			:= frm.cmbMasters;	//01 May 2012	NDL	Par 29496
	self.myCmbMatchEnd			:= frm.cmbMatchEnd;
	self.myCmbMatchStart		:= frm.cmbMatchStart;
	self.myCmbMode				:= frm.cmbMode;
	self.myCmbMonth				:= frm.cmbMonths; //03 Jun 2021	NDL	TFS 51245
	self.myCmbOnDate			:= frm.cmbOnDate;
	self.myCmbOpenDate			:= frm.cmbOpenDate;
	self.myCmbOperator			:= frm.cmbOperator;
	self.myCmbOperatorGroup		:= frm.cmbOperatorGroup;
	self.myCmbOrder1			:= frm.cmbOrder1;
	self.myCmbOrder2			:= frm.cmbOrder2;
	self.myCmbOrigScaler		:= frm.cmbOrigScaler;
	self.myCmbOrganisation		:= frm.cmbOrganisation;	// Feb 2013 CCMS HAT 2205
	self.myCmbPlace				:= frm.cmbPlace;
	self.myCmbPackByDate		:= frm.cmbPackByDate;
	self.myCmbPort				:= frm.cmbPort;
	self.myCmbTranshipPort		:= frm.cmbTranship;
	self.myCmbProduct			:= frm.cmbProduct;
	self.myCmbProfile			:= frm.cmbProfile;
	self.myCmbReleaseType		:= frm.cmbReleaseType;
	self.myCmbRowId				:= frm.cmbRowId;
	self.myCmbSrcLocation		:= frm.cmbSrcLocation;
	self.myCmbState				:= frm.cmbState;
	self.myCmbSubSrc			:= frm.cmbSubSrc;
	self.myCmbSubSubSrc			:= frm.cmbSubSubSrc;
	self.myCmbTAType			:= frm.cmbTAType;
	self.myCmbTerminalArea		:= frm.cmbTerminalArea;
	self.myCmbTrain 			:= frm.cmbTrain;			// Par 19913
	self.myCmbTxnType			:= frm.cmbTxnType;
	self.myCmbUser				:= frm.cmbUser;
	self.myCmbVessel			:= frm.cmbVessel;			// Par 17586
	self.myCmbVoyage			:= frm.cmbVoyage;			// 04 Sep 2009	NDL CCMS 1609 Par 20521
	self.myCmbVoyageJob			:= frm.cmbVoyageJob;
	self.myCmbBOLVoyage			:= frm.cmbBOLVoyage;
	self.myCmbGatePass			:= frm.cmbGatePass; 		//par 18183 cnwjo3
	self.myCmbSubTerminal		:= frm.cmbSubTerminal; 		//24/04/2009 cnwdz2 ccms1735
	self.myCmbShippingLine		:= frm.cmbShippingLine;		// par 19768
	self.myCmbRowInspected		:= frm.cmbRowInspected;		// 28/09/2009 cnwar2 CCMS1107/#20638
	self.myCmbRowFumigated		:= frm.cmbRowFumigated;		// 28/09/2009 cnwar2 CCMS1107/#20638
	self.myCmbProcDate 			:= frm.cmbProcDate;			//16 Nov 2009	NDL	Par 21519
	self.myCmbInvoiceStatus		:= frm.cmbInvoiceStatus; 	// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 21/04/2010
	self.myCmbCompany			:= frm.cmbCompany;			// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 21/04/2010
	self.myCmbInvoiceType		:= frm.cmbInvoiceType;		// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 21/04/2010
	self.myCmbDebtor			:= frm.cmbDebtor;			// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 21/04/2010
	self.myCmbInvoiceLineType	:= frm.cmbInvoiceLineTy;	// CCMS 2348 Financial reporting
	self.myCmbService 			:= frm.cmbService;			//cnwrd1 par 23583 11.8.2010
	self.myCmbServiceGroup 		:= frm.cmbServiceGroup; 	//cnwrd1 par 23583 11.8.2010
	self.myCmbBkingRefStatus	:= frm.cmbBookingStatus; 	// SFW CCMS 1063 PAR25404	cnwsh3 - Booking Reference filter additions. 16/08/2010
	self.myCmbReceiptMode		:= frm.cmbReceiptMode;		//11 Nov 2010	NDL	Par 26294
	self.myCmbSealType			:= frm.cmbSealType;			//11 Nov 2010	NDL	Par 26294
	self.myCmbSAPStatus			:= frm.cmbSAPStatus;		// TFS 44298
	self.myLstTblVBSStatus		:= frm.lstTblVBSStatus;		//24.5.2023 navhl20 #53902[57781]		//28.8.2023 navhl20 #60056
	self.myLstTblVBSTsType		:= frm.lstTblVBSTsType;		//28.8.2023 navhl20 #60056
	self.myCmbSAPTransaction	:= frm.cmbSAPTransaction;	// TFS 44298
	self.myCmbEvtFinish			:= frm.cmbEvtFinish;		//15 Aug 2019	NDL	TFS 46131
	self.myCmbEvtPlace			:= frm.cmbEvtPlace;			//15 Aug 2019	NDL	TFS 46131
	self.myCmbEvtPull			:= frm.cmbEvtPull;			//15 Aug 2019	NDL	TFS 46131
	self.myCmbEvtStart			:= frm.cmbEvtStart;			//15 Aug 2019	NDL	TFS 46131
	self.myLstTblUnloadEvts		:= frm.lstUnloadEvts;		//15 Aug 2019	NDL	TFS 46131
	self.myLstTblBarges 		:= frm.lstBarges;			//15 Aug 2019	NDL	TFS 46131
	self.myCmbWtMeasurement		:= frm.cmbWtMeasure;		//16 Aug 2019	NDL	TFS 46131
	self.myLstTblNonBarges 		:= frm.lstNonBarges;		//21 Aug 2019	NDL	TFS 46131
	
	// HMS stuff.
	
	// Arrive
	self.arriveDFrom := frm.tblCriteriaGetValueByName(ETRow_ArrivalsDateFrom).Date;
	self.arriveDTo := frm.tblCriteriaGetValueByName(ETRow_ArrivalsDateTo).Date;
	self.arriveTFrom := frm.tblCriteriaGetValueByName(ETRow_ArrivalsTimeFrom).Time;
	self.arriveTTo := frm.tblCriteriaGetValueByName(ETRow_ArrivalsTimeTo).Time;
	self.myCmbArriveDFrom := frm.cmbArriveDFrom;
	self.myCmbArriveDTo := frm.cmbArriveDTo;
	
	// Depart
	self.departDFrom := frm.tblCriteriaGetValueByName(ETRow_DepartedDateFrom).Date;
	self.departDTo := frm.tblCriteriaGetValueByName(ETRow_DepartedDateTo).Date;
	self.departTFrom := frm.tblCriteriaGetValueByName(ETRow_DepartedTimeFrom).Time;
	self.departTTo := frm.tblCriteriaGetValueByName(ETRow_DepartedTimeTo).Time;
	self.myCmbDepartDFrom := frm.cmbDepartDFrom;
	self.myCmbDepartDTo := frm.cmbDepartDTo;
	
	// In Port
	self.inPortDFrom := frm.tblCriteriaGetValueByName(ETRow_InPortDateFrom).Date;
	self.inPortDTo := frm.tblCriteriaGetValueByName(ETRow_InPortDateTo).Date;
	self.inPortTFrom := frm.tblCriteriaGetValueByName(ETRow_InPortTimeFrom).Time;
	self.inPortTTo := frm.tblCriteriaGetValueByName(ETRow_InPortTimeTo).Time;
	self.myCmbInPortDFrom := frm.cmbInPortDFrom;
	self.myCmbInPortDTo	:= frm.cmbInPortDTo;
	
	self.myCmbExpectedArrDFrom	:= frm.cmbExpArrDFrom;				// PAR #35826
	self.myCmbExpectedArrDTo	:= frm.cmbExpArrDTo;				// PAR #35826
	self.myCmbExpectedDepDFrom	:= frm.cmbExpDepDFrom;				// PAR #35826
	self.myCmbExpectedDepDTo	:= frm.cmbExpDepDTo;				// PAR #35826
	
	self.myCmbMTPoolParty := frm.cmbPoolParty;				// TFS 5558
	self.myCmbQuery := frm.cmbQuery;								// TFS 37030
	
	// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
	self.myCmbContractFromStartDate 	:= frm.cmbContractFromStartDate;
	self.myCmbContractToStartDate 	:= frm.cmbContractToStartDate;
	self.myCmbDetailFromStartDate 	:= frm.cmbDetailFromStartDate;
	self.myCmbDetailToStartDate 		:= frm.cmbDetailToStartDate;
	self.myCmbRateEntryFromStartDate := frm.cmbRateFromStartDate;
	self.myCmbRateEntryToStartDate 	:= frm.cmbRateToStartDate;
	
	self.myCmbContractFromEndDate 	:= frm.cmbContractFromEndDate;
	self.myCmbContractToEndDate 	:= frm.cmbContractToEndDate;
	self.myCmbDetailFromEndDate 	:= frm.cmbDetailFromEndDate;
	self.myCmbDetailToEndDate 		:= frm.cmbDetailToEndDate;
	self.myCmbRateEntryFromEndDate := frm.cmbRateFromEndDate;
	self.myCmbRateEntryToEndDate 	:= frm.cmbRateToEndDate;
	
	self.myCmbCalculationType 	:= frm.cmbCalType;
	self.myCmbInvoiceLineType 	:= frm.cmbInvoiceLineTy;
	self.myCmbService 			:= frm.cmbService;
	self.myCmbUnitMeasureCode 	:= frm.cmbUnitMeasureCode;
	// 20/04/2023	navkc1	CR 55654 Task 55670 --&lt;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFromReportRunner" id="44171e90-80ce-4c62-a5ce-e9f1eb401ec3">
        <updating/>
        <source>initFromReportRunner() updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 12/08/2008	concms1		Par 17586 Add vessel parameter
// 27/05/2009	concms1		Par 17968 add shipping line parameter
// 04/07/2010	cnwdap1		PAR #24519 Add Include Tranships parameter
// 10/09/2010	cnwcs5		par 23714/ccms 1132 - added machine, machine type, delay type group and delay type parameters
// 06/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 added expected arrival/departure date
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Report
// 12/02/2018	jlgdap1		TFS 37030 SSL Demurrage Report
// 03/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 25/05/2022 	navhl20	 	TFS 53430  EUP - Sub Carrier registration in MTN
// 16 March 2023 navhl20 	Defect 57144: Send to Report showing Error
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 24 May 2023  navhl20 	ChangeRequest 53902:[57781] EUP - VBS MTN - [6] - Selector Query and JRW
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
// 28 Aug 2023 	navhl20 	Bug 60056: FR | 53429 - VBS Selector issues
vars
	frm			: CMUI_ReportRunner;
begin	
	frm := self.myParentForm.CMUI_ReportRunner;

	self.myAssistant := frm.myAssistant;
	self.myEntryTable := frm.tblParameter;
	self.myBaseTable := null;
	
//	self.myTblTerminals				:= frm.tblTerminals;	//old control - self.myLstTblTerminals used below JC 16/03/2005
	self.myTxtArgument				:= frm.txtArgument;
	self.myCmbArgument				:= frm.cmbArgument;
	self.myLstTblArgument			:= frm.tblArgument;
	self.myTxtArgumentFromDate		:= frm.txtArgFromDate;	
	self.myTxtArgumentToDate		:= frm.txtArgToDate;
	self.myTxtArgumentFromTime		:= frm.txtArgFromTime;	//14 May 2012	NDL	Par 29532
	self.myTxtArgumentToTime		:= frm.txtArgToTime;	//14 May 2012	NDL	Par 29532
	
	self.myLstTblTerminals		:= frm.tblTerminals;
	self.myLstTblAvaGrade		:= frm.lstTblAvaGrade;
	self.myLstCashDrs			:= frm.lstTblCashDrs;	// 14 Aug 2012	NDL	Par 29968
	self.myLstTblEventTypes		:= frm.lstTblEventTypes;
	self.myLstTblUsers			:= frm.lstTblUsers;
	
	self.myLstTblIMEX			:= frm.lstTblIMEX;
	self.myLstTblLogLot			:= frm.lstTblLogLot;
	self.myLstTblPackArea		:= frm.lstTblPackArea;
	self.myLstTblSiteState		:= frm.lstTblSiteState;
	self.myLstTblStop			:= frm.lstTblStop;
	self.myLstTblTransact		:= frm.lstTblTransact;
	self.myLstTblWOTransact		:= frm.lstTblWOTransact;			//16.3.2023 navhl20	#57144
	self.myLstTblWOType			:= frm.lstTblWOType;				//16.8.2023 navhl20 #58568
	self.myLstTblWOStatus		:= frm.lstTblWOStatus;				//16.8.2023 navhl20 #58568
	self.myLstTblTasks			:= frm.lstTblTasks;	// 20 Oct 2010	NDL	Par 23800
	self.myLstTblVoyageJob		:= frm.lstTblVoyageJob;
	self.myLstTblDelayType		:= frm.lstTblDelayType; // 03/12/2010	cnwsh3		CCMS1132/PAR23714 	Machine Productivity reporting
	self.myLstTblDelayTypeGroup	:= frm.lstTblDelayTypGp; // 03/12/2010	cnwsh3		CCMS1132/PAR23714 	Machine Productivity reporting
	
	self.baseDate := frm.tblParameter.getValueByName(ETRow_BaseDate).Date;
	self.onDate	:= frm.tblParameter.getValueByName(ETRow_OnDate).Date;
	self.openDate := frm.tblParameter.getValueByName(ETRow_OpenDate).Date;
	self.closeDate := frm.tblParameter.getValueByName(ETRow_CloseDate).Date;
	self.matchStart := frm.tblParameter.getValueByName(ETRow_MatchDateStart).Date;
	self.matchEnd := frm.tblParameter.getValueByName(ETRow_MatchDateEnd).Date;
	
	self.includeTranships := frm.tblParameter.getValueByName(ETRow_IncludeTranships).Boolean;	// PAR #24519
	self.pieceCountError := frm.tblParameter.getValueByName(ETRow_PieceCountError).Boolean;  //#23894 24/05/2010
	
	self.startTime := frm.tblParameter.getValueByName(ETRow_StartTime).Time;
	self.endTime := frm.tblParameter.getValueByName(ETRow_EndTime).Time;
//	self.onTime	:= frm.tblParameter.getValueByName(ETRow_OnTime).Time;
	
	self.myCmbAgent				:= frm.cmbAgent;		// 36778
	self.myCmbActualVoy 		:= frm.cmbActualVoy;
	self.myCmbAgeType			:= frm.cmbAgeType;
	self.myCmbAllocatedVoy		:= frm.cmbAllocatedVoy;
	self.myCmbBaseDate			:= frm.cmbBaseDate;
	self.myCmbBOLIn				:= frm.cmbBOLIn;
	self.myCmbBOLOut			:= frm.cmbBOLOut;
	self.myCmbBOLType			:= frm.cmbBOLType;
	self.myCmbCargoType			:= frm.cmbCargoType;
	self.myCmbCarrier			:= frm.cmbCarrier;
	self.myCmbSubCarrier		:= frm.cmbSubCarrier;			//25/05/2022 navhl20 TFS 53430
	self.myCmbCellularVoy		:= frm.cmbCellularVoy;
	self.myCmbCloseDate			:= frm.cmbCloseDate;
	self.myCmbConsignee			:= frm.cmbConsignee;
	self.myCmbConsignor			:= frm.cmbConsignor;
	self.myCmbCrane				:= frm.cmbCrane;
	self.myCmbChkScaled			:= frm.cmbChkScaled;
	//self.myCmbDelayType			:= frm.cmbDelayType;	// 10/09/2010 cnwcs5 par 23714/ccms 1132 removed as a list control is now used.
	//self.myCmbDelayTypeGrp		:= frm.cmbDelayTypeGrp;	// 10/09/2010 cnwcs5 par 23714/ccms 1132 removed as a list control is now used.
	self.myCmbDocketChk			:= frm.cmbDocketChk;
	
	self.myCmbHatch				:= frm.cmbHatch;
	self.myCmbISOGroup			:= frm.cmbISOGroup;
	self.myCmbLoadedOption		:= frm.cmbLoadedOption;
	self.myCmbLoadPort			:= frm.cmbLoadPort;
	self.myCmbLoggingOrg		:= frm.cmbLoggingOrg;
	self.myCmbLogGrade			:= frm.cmbLogGrade;
	self.myCmbLogLength			:= frm.cmbLogLength;
	self.myCmbLogOperation		:= frm.cmbLogOperation;
	self.myCmbLogSpecies		:= frm.cmbLogSpecies;
	self.myCmbLogTreatment		:= frm.cmbLogTreatment;
	self.myCmbLogType			:= frm.cmbLogType;
	self.myCmbLot				:= frm.cmbLot;
	self.myCmbMachineType		:= frm.cmbMachineType;	// 10/09/2010 cnwcs5 par 23714/ccms 1132
	self.myCmbMachine			:= frm.cmbMachine;		// 10/09/2010 cnwcs5 par 23714/ccms 1132
	self.myCmbMasters			:= frm.cmbMasters;	//01 May 2012	NDL	Par 29496
	self.myCmbMatchEnd			:= frm.cmbMatchEnd;
	self.myCmbMatchStart		:= frm.cmbMatchStart;
	self.myCmbMode				:= frm.cmbMode;
	self.myCmbMonth				:= frm.cmbMonths; //03 Jun 2021	NDL	TFS 51245
	self.myCmbOnDate			:= frm.cmbOnDate;
	self.myCmbOpenDate			:= frm.cmbOpenDate;
	self.myCmbOperator			:= frm.cmbOperator;
	self.myCmbOperatorGroup		:= frm.cmbOperatorGroup;
	self.myCmbOrder1			:= frm.cmbOrder1;
	self.myCmbOrder2			:= frm.cmbOrder2;
	self.myCmbOrigScaler		:= frm.cmbOrigScaler;
	self.myCmbOrganisation		:= frm.cmbOrganisation;	// Feb 2013 CCMS HAT 2205
	self.myCmbPackByDate		:= frm.cmbPackByDate;
	self.myCmbPlace				:= frm.cmbPlace;
	self.myCmbPort				:= frm.cmbPort;
	self.myCmbTranshipPort		:= frm.cmbTranship;
	self.myCmbProduct			:= frm.cmbProduct;
	self.myCmbProfile			:= frm.cmbProfile;
	self.myCmbReceiptMode		:= frm.cmbReceiptMode;	//30 Sep 2010	NDL	Par 25608
	self.myCmbReleaseType		:= frm.cmbReleaseType;
	self.myCmbRowId				:= frm.cmbRowId;
	self.myCmbSealType			:= frm.cmbSealType;	//30 Sep 2010	NDL	Par 25608
	self.myCmbSrcLocation		:= frm.cmbSrcLocation;
	self.myCmbState				:= frm.cmbState;
	self.myCmbSubSrc			:= frm.cmbSubSrc;
	self.myCmbSubSubSrc			:= frm.cmbSubSubSrc;
	self.myCmbTAType			:= frm.cmbTAType;
	self.myCmbTerminalArea		:= frm.cmbTerminalArea;
	self.myCmbTrain				:= frm.cmbTrain;	// Par 19913
	self.myCmbTxnType			:= frm.cmbTxnType;
	self.myCmbUser				:= frm.cmbUser;
	self.myCmbVessel			:= frm.cmbVessel;	// Par 17586
	self.myCmbVoyage			:= frm.cmbVoyage;	// 04 Sep 2009	NDL CCMS 1609 Par 20521
	self.myCmbVoyageJob			:= frm.cmbVoyageJob;
	self.myCmbBOLVoyage			:= frm.cmbBOLVoyage;
	self.myCmbGatePass			:= frm.cmbGatePass; //par 18183 cnwjo3
	self.myCmbSubTerminal		:= frm.cmbSubTerminal;//24/04/2009 cnwdz2 ccms1735
	self.myCmbShippingLine		:= frm.cmbShippingLine;	// par 19768
	self.myCmbRowInspected		:= frm.cmbRowInspected;	// 28/09/2009 cnwar2 CCMS1107/#20638
	self.myCmbRowFumigated		:= frm.cmbRowFumigated;	// 28/09/2009 cnwar2 CCMS1107/#20638
//	self.paramDate			:= frm.tblParameter.getValueByName(ETRow_ParamDate).date;
//	self.paramTime			:= frm.txtParamTime;
	self.myPicParamPic			:= frm.picParamPic;
	self.myCmbProcDate 			:= frm.cmbProcDate;	//16 Nov 2009	NDL	Par 21519
	self.myCmbInvoiceStatus		:= frm.cmbInvoiceStatus; 	// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 21/04/2010
	self.myCmbCompany			:= frm.cmbCompany;			// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 21/04/2010
	self.myCmbInvoiceType		:= frm.cmbInvoiceType;		// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 21/04/2010
	self.myCmbDebtor			:= frm.cmbDebtor;			// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 21/04/2010
	self.myCmbInvoiceLineType	:= frm.cmbInvoiceLineTy;	// CCMS 2348 Financial reporting
	self.myCmbDocketErrCode		:= frm.cmbDocketErrCode;	//#24306 01/06/2010
	self.myCmbService 			:= frm.cmbService; //cnwrd1 par 23583 11.8.2010
	self.myCmbServiceGroup 		:= frm.cmbServiceGroup; //cnwrd1 par 23583 11.8.2010
	self.myCmbBkingRefStatus	:= frm.cmbBookingStatus; 	// SFW CCMMS1063 PAR25404 	cnwsh3 - Booking Reference reporting additional filters.
	self.myCmbSAPStatus			:= frm.cmbSAPStatus;		// TFS 44298
	self.myLstTblVBSStatus		:= frm.lstTblVBSStatus;		//24.5.2023 navhl20 #53902[57781]			//28.8.2023 navhl20 #60056
	self.myLstTblVBSTsType		:= frm.lstTblVBSTsType;		//28.8.2023 navhl20 #60056
	self.myCmbSAPTransaction	:= frm.cmbSAPTransaction;	// TFS 44298
	self.myCmbEvtFinish			:= frm.cmbEvtFinish;		//15 Aug 2019	NDL	TFS 46131
	self.myCmbEvtPlace			:= frm.cmbEvtPlace;			//15 Aug 2019	NDL	TFS 46131
	self.myCmbEvtPull			:= frm.cmbEvtPull;			//15 Aug 2019	NDL	TFS 46131
	self.myCmbEvtStart			:= frm.cmbEvtStart;			//15 Aug 2019	NDL	TFS 46131
	self.myLstTblUnloadEvts		:= frm.lstUnloadEvts;		//15 Aug 2019	NDL	TFS 46131
	self.myLstTblBarges 		:= frm.lstBarges;			//15 Aug 2019	NDL	TFS 46131
	self.myCmbWtMeasurement		:= frm.cmbWtMeasure;		//16 Aug 2019	NDL	TFS 46131
	self.myLstTblNonBarges 		:= frm.lstNonBarges;		//21 Aug 2019	NDL	TFS 46131
	
	
	// HMS stuff.
	
	// Arrive
	self.arriveDFrom := frm.tblParameter.getValueByName(ETRow_ArrivalsDateFrom).Date;
	self.arriveDTo := frm.tblParameter.getValueByName(ETRow_ArrivalsDateTo).Date;
	self.arriveTFrom := frm.tblParameter.getValueByName(ETRow_ArrivalsTimeFrom).Time;
	self.arriveTTo := frm.tblParameter.getValueByName(ETRow_ArrivalsTimeTo).Time;
	self.myCmbArriveDFrom := frm.cmbArriveDFrom;
	self.myCmbArriveDTo	:= frm.cmbArriveDTo;
	
	// Depart
	self.departDFrom := frm.tblParameter.getValueByName(ETRow_DepartedDateFrom).Date;
	self.departDTo := frm.tblParameter.getValueByName(ETRow_DepartedDateTo).Date;
	self.departTFrom := frm.tblParameter.getValueByName(ETRow_DepartedTimeFrom).Time;
	self.departTTo := frm.tblParameter.getValueByName(ETRow_DepartedTimeTo).Time;
	self.myCmbDepartDFrom := frm.cmbDepartDFrom;
	self.myCmbDepartDTo	:= frm.cmbDepartDTo;
	
	// In Port
	self.inPortDFrom := frm.tblParameter.getValueByName(ETRow_InPortDateFrom).Date;
	self.inPortDTo := frm.tblParameter.getValueByName(ETRow_InPortDateTo).Date;
	self.inPortTFrom := frm.tblParameter.getValueByName(ETRow_InPortTimeFrom).Time;
	self.inPortTTo := frm.tblParameter.getValueByName(ETRow_InPortTimeTo).Time;
	self.myCmbInPortDFrom := frm.cmbInPortDFrom;
	self.myCmbInPortDTo	:= frm.cmbInPortDTo;
	
	self.myCmbExpectedArrDFrom	:= frm.cmbExpArrDFrom;				// PAR #35826
	self.myCmbExpectedArrDTo	:= frm.cmbExpArrDTo;				// PAR #35826
	self.myCmbExpectedDepDFrom	:= frm.cmbExpDepDFrom;				// PAR #35826
	self.myCmbExpectedDepDTo	:= frm.cmbExpDepDTo;				// PAR #35826
	
	self.myCmbMTPoolParty		:= frm.cmbPoolParty;			// TFS 5558
	self.myCmbQuery 			:= frm.cmbQuery;				// TFS 37030
	
	// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
	self.myCmbContractFromStartDate 	:= frm.cmbContractFromStartDate;
	self.myCmbContractToStartDate 	:= frm.cmbContractToStartDate;
	self.myCmbDetailFromStartDate 	:= frm.cmbDetailFromStartDate;
	self.myCmbDetailToStartDate		:= frm.cmbDetailToStartDate;
	self.myCmbRateEntryFromStartDate	:= frm.cmbRateFromStartDate;
	self.myCmbRateEntryToStartDate 	:= frm.cmbRateToStartDate;
	
	self.myCmbContractFromEndDate 	:= frm.cmbContractFromEndDate;
	self.myCmbContractToEndDate 	:= frm.cmbContractToEndDate;
	self.myCmbDetailFromEndDate 	:= frm.cmbDetailFromEndDate;
	self.myCmbDetailToEndDate		:= frm.cmbDetailToEndDate;
	self.myCmbRateEntryFromEndDate	:= frm.cmbRateFromEndDate;
	self.myCmbRateEntryToEndDate 	:= frm.cmbRateToEndDate;
	
	self.myCmbCalculationType 	:= frm.cmbCalType;
	self.myCmbInvoiceLineType 	:= frm.cmbInvoiceLineTy;
	self.myCmbService 			:= frm.cmbService;
	self.myCmbUnitMeasureCode 	:= frm.cmbUnitMeasureCode;
	// 20/04/2023	navkc1	CR 55654 Task 55670 --&lt;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isRowIncluded" id="762768a7-8227-4ee2-9010-476fe83a7192">
        <source>isRowIncluded(_rowName : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     09 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars


begin

	if CM_QryReportUser.hasInstance(self.myQryReport)then
		return self.myQryReport.CM_QryReportUser.viewRows.includes(_rowName);
	else //its a system report - where criteria CANNOT be included but not visible,
		//so the visibility determinds the inclusion
		return self.isRowVisible(_rowName);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRowVisible" id="f20098fd-c8e3-42e5-a52d-bd1afffba26a">
        <source>isRowVisible(_rowName : String) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     06 January 2004	cnwth2
//
// Purpose:     This method is protected for a good reason  - to do with the logic
//				involved in setting criteria from the report runner - if you need to
//				unprotect this then you don't know what you are doing.
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myEntryTable &lt;&gt; null then
		return self.myEntryTable.isRowVisible(_rowName);
	else
		return true;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadParameterByName" id="d602af55-6f94-4569-ac80-e50c870d59e3">
        <updating/>
        <source>loadParameterByName(_defaultTemplate : CMQF_FilterReports; 
					_row : EntTableRow;
					_rowNameParameter : String;
					_defaultValueStr : String io) updating;
// ---------------------------------------------------------------------------
// Created:     06 January 2004	cnwth2
//
// Purpose:     connect
//			 
// ----------   ----------  --------------------------------------------------
// aug 2008		concms1		par 17586
// may 2009		concms1		par 19768 - new shipping line parameter
// 10/09/2010	cnwcs5		par 23714/ccms 1132 - new parameter types machine, machine type, delay type, delay type group
// 27/07/2017	cnwdap1		TFS 5557 Include Tranships criteria not saved to template
// 02/08/2017	cnwdap1		TFS 5558 SNO Empty Release Report
// 12/02/2018	jlgdap1		TFS 37030 SSL Demurrage Report
// 17/07/2018	jlgmd1		TFS 39407 SNO - Fixed Bulk Release criteria not saving on the tempalte
// 03/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 25/05/2022 	navhl20 	TFS 53430  EUP - Sub Carrier registration in MTN
//16 March 2023 navhl20 	Defect 57144: Send to Report showing Error
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 24 May 2023 	navhl20 	ChangeRequest 53902:[57781] EUP - VBS MTN - [6] - Selector Query and JRW
//11 Aug 2023 	navhl20 	ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions
// 17 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
// 28 Aug 2023 	navhl20 	Bug 60056: FR | 53429 - VBS Selector issues
// 24 Sep 2024  navah1      Bug 23334: MTN - Service not defaulted on Invoice Rate Report  
vars
	getCalculatedDate			: Boolean;
	rowName : String;
	term : CM_Terminal;
	processStartDate : Date;
	processEndDate : Date;
	reportRunner : CMUI_ReportRunner;
	rowNum : Integer;
begin
	if _row &lt;&gt; null then
		rowName:=_row.name;
	endif;
	
	if rowName = null then
		rowName := _rowNameParameter;
	endif;
	
// cnwdad1 22/11/2010 - PAR #25218 - Added check for "View" state as well.
	getCalculatedDate := not (self.state = self.STATE_TEMPLATE_SAVE or self.state = self.STATE_TEMPLATE_EDIT or self.state = self.STATE_TEMPLATE_VIEW);
	
	if _defaultTemplate &lt;&gt; null then
		_defaultValueStr := _defaultTemplate.getDisplayStringForAttribute(rowName, getCalculatedDate);
	endif;
	
	if rowName = ETRow_AgeType then
		self.doLoadAgeTypes(self.myCmbAgeType, _defaultValueStr);
	elseif rowName = ETRow_AvaGrade then	
		self.doLoadAvaGrade(self.myLstTblAvaGrade, _defaultTemplate);
		if _defaultValueStr = null then
			self.myLstTblAvaGrade.lostFocus(self.myLstTblAvaGrade);	// Rebuild the display string instead		// TFS 39407
		else
			self.setValueByName(ETRow_AvaGrade, _defaultValueStr);
		endif;
	elseif rowName = ETRow_PackArea then	
		self.doLoadPackArea(self.myLstTblPackArea, _defaultTemplate);
		self.setValueByName(ETRow_PackArea, _defaultValueStr);
	elseif rowName = ETRow_BlockLength then	
		self.setValueByName(rowName, _defaultValueStr);
	elseif rowName  = ETRow_Operator or
	   rowName  = ETRow_OperatorCode then
		self.doLoadOperators(self.myCmbOperator, _defaultValueStr);
	elseif rowName = ETRow_BolType then
		self.doLoadBOLTypes(self.myCmbBOLType, _defaultValueStr);
	elseif rowName = ETRow_CargoType then
		self.doLoadCargoTypes(self.myCmbCargoType, _defaultValueStr);
	elseif rowName = ETRow_CarrierCode or rowName = ETRow_CarrierFilter  or rowName = ETRow_MyCarrier then  //cnwma1 29/04/2015  PAR #36129
		self.doLoadCarriers(self.myCmbCarrier, _defaultValueStr);
	elseif rowName = ETRow_SubCarrierCode or rowName = ETRow_SubCarrierFilter or rowName = ETRow_MySubCarrier then  						//25/05/2022 navhl20 TFS 53430  
		self.doLoadSubCarriers(self.myCmbSubCarrier, _defaultValueStr);			//25/05/2022 navhl20 TFS 53430 
	elseif rowName = ETRow_CashDebtors then	//14 Aug 2012	NDL	Par 29968
		self.doLoadCashDebtors(self.myLstCashDrs, _defaultTemplate);
	elseif rowName = ETRow_IsConnected then
		self.setValueByName(ETRow_IsConnected, _defaultValueStr);
	elseif rowName = ETRow_DocketError then
		self.doLoadDocketErrorTypes(self.myCmbDocketErrCode, _defaultValueStr);			//ccms 1110 - par 22201 begin
	elseif rowName = ETRow_DriversPieceCount then
		self.setValueByName(ETRow_DriversPieceCount, _defaultValueStr);
	elseif rowName = ETRow_PieceCountError then
		self.setValueByName(ETRow_PieceCountError, _defaultValueStr);			//ccms 1110 - par 22201 end
	elseif rowName = ETRow_Consignee then
		self.doLoadConsign(self.myCmbConsignee, _defaultValueStr, false);		//+cnwml2 PAR25402
	elseif rowName = ETRow_Consignor then
		self.doLoadConsign(self.myCmbConsignor, _defaultValueStr, true);		//+cnwml2 PAR25402
	elseif rowName = ETRow_Agent then
		self.doLoadClearingAgent(self.myCmbAgent, _defaultValueStr);			// 36778
	elseif rowName = ETRow_CheckScaled then
		self.doLoadBooleanCombo(self.myCmbChkScaled, _defaultValueStr);
	elseif rowName = ETRow_Crane then											// Dec 2010 CCMS 1134
		self.doLoadCraneList(self.myLstTblUsers, _defaultTemplate);
		self.setValueByName(ETRow_Crane, _defaultValueStr);
	elseif rowName = ETRow_DelayType then										// 10/09/2010 cnwcs5 par 23714/ccms 1132
		self.doLoadDelayTypes (self.myLstTblDelayType, _defaultTemplate, _defaultValueStr);			// 10/09/2010 cnwcs5 par 23714/ccms 1132
	elseif rowName = ETRow_DelayTypeGroup then									// 10/09/2010 cnwcs5 par 23714/ccms 1132
		self.doLoadDelayTypeGroups (self.myLstTblDelayTypeGroup, _defaultTemplate, _defaultValueStr);	// 10/09/2010 cnwcs5 par 23714/ccms 1132
	elseif rowName = ETRow_DocketChecked then
		self.doLoadBooleanCombo(self.myCmbDocketChk, _defaultValueStr);		
	elseif rowName = ETRow_DischargePort then
		self.doLoadPorts(self.myCmbPort, ETRow_DischargePort, _defaultValueStr);
	elseif rowName = ETRow_MyTranshipToPort then
		self.doLoadPorts(self.myCmbTranshipPort, ETRow_MyTranshipToPort, _defaultValueStr);
	elseif rowName = ETRow_AllEventTypes then	
		self.doLoadEventTypes(self.myLstTblEventTypes, _defaultTemplate);
		self.setValueByName(ETRow_AllEventTypes, _defaultValueStr);
	elseif rowName = ETRow_IMEXStatuses then
		self.doLoadIMEXStatus(self.myLstTblIMEX, _defaultTemplate);
	elseif rowName = ETRow_IsoTypeGroup then
		self.doLoadISOGroups(self.myCmbISOGroup, ETRow_IsoTypeGroup, _defaultValueStr);
	elseif rowName = ETRow_LoadPort then
		self.doLoadPorts(self.myCmbLoadPort, ETRow_LoadPort, _defaultValueStr);
	elseif rowName = ETRow_LoadedOption then
		self.doLoadCmbLoadedOption(self.myCmbLoadedOption, _defaultValueStr);
	elseif rowName = ETRow_LoggingOrganisation then
		self.doLoadLoggingOrg(self.myCmbLoggingOrg, _defaultValueStr);
	elseif rowName = ETRow_LogSpecies or
	   rowName = ETRow_MyLogSpecies then
		self.doLoadLogSpecies(_defaultValueStr);
			
	elseif rowName = ETRow_LogGrade or
	   rowName = ETRow_MyLogGrade then
		self.doLoadLogGrades(_defaultValueStr);
		
	elseif rowName = ETRow_LogType or
	   rowName = ETRow_MyLogType then
		self.doLoadLogTypes(_defaultValueStr);
		
	elseif rowName = ETRow_LogTreatment or
	   rowName = ETRow_MyLogTreatment then
		self.doLoadLogTreatments(_defaultValueStr);

	elseif rowName = ETRow_LogLength or
	   rowName = ETRow_MyLogLength then
		self.doLoadLogLengths(_defaultValueStr);
	
	elseif rowName = ETRow_Lot then 
		// when new report loaded then this will clear combo. (in case has previoualy been populated)
		self.doLoadLotHatchPlace(null);
		
	elseif rowName = ETRow_LoggingOperation then
//		self.doLoadLoggingOperations(self.myCmbLogOperation, self.myCmbOperator.listObject.CM_Operator, _defaultValueStr);
		self.doLoadLoggingOperations2(self.myCmbLogOperation, _defaultValueStr);
	elseif rowName = ETRow_Machine then										// 10/09/2010 cnwcs5 par 23714/ccms 1132
		self.doLoadMachines (self.myCmbMachine, self.myCmbMachineType.listObject.CM_MachineType, _defaultValueStr);			// 10/09/2010 cnwcs5 par 23714/ccms 1132
	elseif rowName = ETRow_MachineType then									// 10/09/2010 cnwcs5 par 23714/ccms 1132
		self.doLoadMachineTypes (self.myCmbMachineType, _defaultValueStr);	// 10/09/2010 cnwcs5 par 23714/ccms 1132
	elseif rowName = ETRow_Master then										// 01 May 2012	NDL	Par 29496
		self.doLoadMasters (self.myCmbMasters, _defaultValueStr);	
	elseif rowName = ETRow_Mode then
		self.doLoadModeCombo(self.myCmbMode, _defaultValueStr);
	elseif rowName = ETRow_OperatorGroup then
		self.doLoadOperatorGroups(self.myCmbOperatorGroup, ETRow_OperatorGroup, _defaultValueStr);
	elseif rowName = ETRow_PrintMTSummaryRep then
		self.setValueByName(ETRow_PrintMTSummaryRep, _defaultValueStr.Integer);

	elseif rowName = ETRow_Product or
	   rowName = ETRow_ProductCode then
		self.doLoadProducts(self.myCmbProduct,
							self.myCmbCargoType.listObject.CM_CargoType,
							self.myCmbRowId.listObject.CM_LocationsController, 		
							_defaultValueStr);
							
	elseif rowName = ETRow_ReportProfile then
		self.doLoadProfiles(self.myCmbProfile, self.myQryReport, _defaultValueStr);
	elseif rowName = ETRow_ReleaseJob then
		self.doLoadVoyageJobs(self.myCmbVoyageJob, self.myCmbCellularVoy.listObject.CM_Voyage);
	elseif rowName = ETRow_SrcLocation then
		self.doLoadSourceLocation(self.myCmbOperator.listObject.CM_Operator, _defaultValueStr);
	elseif rowName = ETRow_SrcSubLocation then
		self.doLoadSourceSubLocation(_defaultValueStr);
	elseif rowName = ETRow_SrcSubSubLocation then	
		self.doLoadSourceSubSubLocation(_defaultValueStr);
	elseif rowName = ETRow_OrigScaler then
		self.doLoadScalers(self.myCmbOrigScaler, _defaultValueStr);
	elseif rowName = ETRow_ReleaseType then
		self.doLoadReleaseTypes(self.myCmbReleaseType, app.myPassport, _defaultValueStr);		// TFS 39407 Allow setting the default selected release type (if we still have permission)
	elseif rowName = ETRow_SaveToWorkList then
		self.setValueByName(ETRow_SaveToWorkList, '1');
	elseif rowName = ETRow_State  then
		self.doLoadPlanningState(self.myCmbState, _defaultValueStr);
	elseif rowName = ETRow_Stops then
		self.doLoadStopsTable(self.myLstTblStop, _defaultTemplate);
	elseif rowName = ETRow_SiteState then
		self.doLoadTIStates(self.myLstTblSiteState, _defaultTemplate);
	elseif rowName = ETRow_TransactionType then
		self.doLoadContainerTxnTypes(self.myLstTblTransact, _defaultTemplate);
	elseif rowName = ETRow_AllWOTransTypes then								//16.3.2023 navhl20	#57144
		self.doLoadWoTxnTypes(self.myLstTblWOTransact, _defaultTemplate);
	elseif rowName = ETRow_Tasks or rowName = ETRow_TskType then	//20 Oct 2010	NDL	Par 23800			//11.8.2023 navhl20 #59284[59664]
		self.doLoadToDoTaskDescs(self.myLstTblTasks, _defaultTemplate);
	elseif rowName = ETRow_TerminalAreaType then
		self.doLoadTATypes(self.myCmbTAType, _defaultValueStr);
	elseif rowName = ETRow_TerminalAreaId then
		self.doLoadTAsByTypeWithAny(self.myCmbTAType.listObject.CM_TerminalAreaType, _defaultValueStr);
	elseif rowName = ETRow_Train then							// Par 19913
		self.doLoadTrains(self.myCmbTrain, _defaultValueStr, _defaultTemplate.CMQF_FilterReports);	// Par 19913
	elseif rowName = ETRow_LogTxnType then
		self.doLoadLogTxnTypes(self.myCmbTxnType, _defaultValueStr);
	elseif rowName = ETRow_RowId then
		//PAR17151 cnwsh3  Structural changes for warehousing and general cargo
		//self.doLoadRowIds(self.myCmbRowId, self.myCmbTerminalArea.listObject.CM_TerminalArea, _defaultValueStr);
		self.doLoadRowsOrAreas(self.myCmbRowId, self.myCmbTerminalArea.listObject.CM_TerminalArea, _defaultValueStr);
	elseif rowName = ETRow_OrderedBy or rowName = ETRow_OrderedBy2 then
		self.doLoadVoySumOrderedBy(self.myCmbOrder1, self.myCmbOrder2);
	elseif rowName = ETRow_VoyageActual then
		self.doLoadGlobalVoyActual(self.myCmbActualVoy, _defaultValueStr);
		self.doLoadLotHatchPlace(self.myCmbActualVoy.listObject.CM_VoyageGlobal);
	//18/05/2009 cnwdz2 par19257 changed ETRow_Voyage to ETRow_VoyageAllocated
	elseif rowName = ETRow_VoyageAllocated then
		if _row &lt;&gt; null then			
			if 	_row.controlName = self.myCmbAllocatedVoy.name then
				self.doLoadGlobalVoyAllocated(self.myCmbAllocatedVoy, _defaultValueStr);			
			endif;
		endif;
	elseif rowName = ETRow_Voyage then
	// cnwdad1 05/09/2007 - PAR #14854.
		//PAR15961 The entrow can sometimes be null as in the case of Query Selector reports so we can't rely entirely on the entrow being there.  cnwsh3
		if _row &lt;&gt; null then
			//epr par 15661 25/1/2008 don't load combos which aren't used in the report criteria
			if _row.controlName = self.myCmbCellularVoy.name then	
				self.doLoadCellularVoyages(self.myCmbCellularVoy, _defaultTemplate, _defaultValueStr);
			elseif 	_row.controlName = self.myCmbAllocatedVoy.name then
				self.doLoadGlobalVoyAllocated(self.myCmbAllocatedVoy, _defaultValueStr);
			elseif _row.controlName = self.myCmbRowId.name then
				self.doLoadAllocatedRows(self.myCmbRowId, self.myCmbAllocatedVoy.listObject.CM_VoyageGlobal, _defaultValueStr);
			elseif _row.controlName = self.myCmbActualVoy.name then
				self.doLoadLotHatchPlace(self.myCmbActualVoy.listObject.CM_VoyageGlobal);
			elseif _row.controlName = self.myCmbVoyage.name then
				self.doLoadVoyages(self.myCmbVoyage, _defaultValueStr);
			elseif _row.controlName = self.myCmbBOLVoyage.name then
				self.doLoadVoyages(self.myCmbBOLVoyage, _defaultValueStr);
			endif;
		endif;
	elseif rowName = ETRow_Vessel then								// Par 17586
		self.doLoadVessels (self.myCmbVessel, _defaultValueStr);	// Par 17586

	elseif rowName = ETRow_AllUsers then	
		self.doLoadUserList(self.myLstTblUsers, _defaultTemplate);
		self.setValueByName(ETRow_AllUsers, _defaultValueStr);
	elseif rowName = ETRow_OrganisationUsers then				// par 31248 Mar 2013
		self.doLoadOrganisationUsers(self.myLstTblUsers, _defaultTemplate);
		self.setValueByName(ETRow_OrganisationUsers, _defaultValueStr);
		
	elseif rowName = ETRow_User or
	   rowName = ETRow_UserCode or
	   rowName = ETRow_ScalerCode or
	   rowName = ETRow_MachineOperator then	// 10/11/2010 cnwcs5 par 23714/ccms 1132
		self.doLoadUsers(self.myCmbUser, _defaultValueStr);
	elseif rowName = ETRow_ShowWeight then
		self.setValueByName(rowName, _defaultValueStr.Integer);
	elseif rowName = ETRow_VisitNumber then
		self.doLoadGatePasses(self.myCmbGatePass, _defaultValueStr);
	elseif rowName = ETRow_MySubTerminal then//24/04/2009 cnwdz2 ccms1735
		self.doLoadSubTerminals(self.myCmbSubTerminal, _defaultValueStr);
	elseif rowName = ETRow_ShippingLine then									// par 19768
		self.doLoadShippingLines(self.myCmbShippingLine, _defaultValueStr);		// par 17968
	elseif rowName = ETRow_IsLocationInspected then								// 28/09/2009 cnwar2 CCMS1107/#20638
		self.doLoadLogRowInspect(self.myCmbRowInspected, _defaultValueStr);		// 28/09/2009 cnwar2 CCMS1107/#20638
	elseif rowName = ETRow_IsLocationFumigated then								// 28/09/2009 cnwar2 CCMS1107/#20638
		self.doLoadLogRowFumigate(self.myCmbRowFumigated, _defaultValueStr);	// 28/09/2009 cnwar2 CCMS1107/#20638
	elseif rowName = ETRow_InvoiceStatus then
		// TFS 39618 PATCH 1  self.doLoadInvoiceStatus(self.myCmbInvoiceStatus, _defaultValueStr); 	// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
		self.doLoadInvoiceStatus(self.myCmbInvoiceStatus, _defaultValueStr, self.myCmbCompany.listObject.CM_Bank); 
	elseif rowName = ETRow_Company then
		self.doLoadCompanies(self.myCmbCompany, _defaultValueStr);
	elseif rowName = ETRow_InvoiceType then
		self.doLoadInvoiceType(self.myCmbInvoiceType, _defaultValueStr, self.myCmbCompany.listObject.CM_Bank);
	elseif rowName = ETRow_InvLineType then
		self.doLoadInvoiceLineType(self.myCmbInvoiceLineType, _defaultValueStr, self.myCmbCompany.listObject.CM_Bank);
	elseif rowName = ETRow_Debtor then
		self.doLoadDebtors(self.myCmbDebtor, _defaultValueStr);
	// PAR #24519 default Include Tranships to true
	elseif rowName = ETRow_IncludeTranships then
		//if _defaultTemplate.myQryReport.isKindOf(CM_QryReportSystem) then			// TFS 5557						// TFS 5558
		if _defaultTemplate &lt;&gt; null and _defaultTemplate.myQryReport.isKindOf(CM_QryReportSystem) then	// TFS 5557	// TFS 5558
			self.setValueByName(ETRow_IncludeTranships, '1');
		else																		// TFS 5557
			self.setValueByName(ETRow_IncludeTranships, _defaultValueStr);			// TFS 5557
		endif;																		// TFS 5557
	elseif rowName = ETRow_IncludeDeparted then
		self.setValueByName(ETRow_IncludeDeparted, _defaultValueStr);
	elseif rowName = ETRow_IncludeLQ then  //cnwjo3 par 24883
		//we are making the assumption that all terminals will have
		//the same setting.  this is an understandable assumption
		if self.allTerminals.size &gt; 0 then
			term := self.allTerminals.first();
		endif;
		
		if term = null then
			self.setValueByName(ETRow_IncludeLQ,true);
		else
			self.setValueByName(ETRow_IncludeLQ,term.includeLQasHazardous());
		endif;
	
	elseif rowName = ETRow_IncludeChildTransactions then	// 03 Aug 2010	NDL	Par 23056 - default to true;
		if _defaultValueStr &lt;&gt; null then
			self.setValueByName(ETRow_IncludeChildTransactions, _defaultValueStr);
		else
			self.setValueByName(ETRow_IncludeChildTransactions, '1');
		endif;
	elseif rowName = ETRow_BookingStatus then 			//16/08/2010 - cnwsh3 PAR25404 CCMS SFW1063 - add booking reporting filters
		self.doLoadBookingStatus(self.myCmbBkingRefStatus, _defaultValueStr);

	elseif rowName = ETRow_ReceiptTransportMode then 			//30 Sep 2010	NDL	Par 25608
		self.doLoadReceiptModes(self.myCmbReceiptMode, _defaultValueStr);
	elseif rowName = ETRow_SealType then 			//30 Sep 2010	NDL	Par 25608
		self.doLoadSealTypes(self.myCmbSealType, _defaultValueStr);
	elseif rowName = ETRow_UnMatchedOnly then	//30 Sep 2010	NDL	Par 25608
		self.setValueByName(ETRow_UnMatchedOnly, _defaultValueStr);
	elseif rowName = ETRow_Organisation then	// Feb 2013 CCMS HAT 2205
		self.doLoadOrganisations(self.myCmbOrganisation, _defaultValueStr);
		
	elseif rowName = ETRow_PoolParty then										// TFS 5558
		self.doLoadMTPoolParties(self.myCmbMTPoolParty, _defaultValueStr);		// TFS 5558
		
	elseif rowName = ETRow_SelectorQueryIds then						// TFS 37030
		self.doLoadQueries(self.myCmbQuery, _defaultValueStr);			// TFS 37030
		
	elseif rowName = ETRow_SapStatus then											// TFS 44298
		self.doLoadSAPStatus(self.myCmbSAPStatus, _defaultValueStr);				// TFS 44298
	
	elseif rowName = ETRow_VBSStatus then												//24.5.2023 navhl20 #53902[57781]			//28.8.2023 navhl20 #60056
		self.doLoadVBSStatus(self.myLstTblVBSStatus, _defaultTemplate);				//24.5.2023 navhl20 #53902[57781]
		self.setValueByName(rowName, self.myLstTblVBSStatus.getSelectedFromDisplay);
	
	elseif rowName = ETRow_Transaction then											// TFS 44298
		self.doLoadSAPTransactions(self.myCmbSAPTransaction, _defaultValueStr);		// TFS 44298
		
	elseif rowName = ETRow_MyEventStart then	//15 Aug 2019	NDL	TFS 46131
		self.doLoadVoyageEvent( self.myCmbEvtStart, _defaultValueStr );
	elseif rowName = ETRow_MyEventFinish then	//15 Aug 2019	NDL	TFS 46131
		self.doLoadVoyageEvent( self.myCmbEvtFinish, _defaultValueStr );
	elseif rowName = ETRow_MyEventPlaced then	//15 Aug 2019	NDL	TFS 46131
		self.doLoadVoyageEvent( self.myCmbEvtPlace, _defaultValueStr );
	elseif rowName = ETRow_MyEventPulled then	//15 Aug 2019	NDL	TFS 46131
		self.doLoadVoyageEvent( self.myCmbEvtPull, _defaultValueStr );	
	elseif rowName = ETRow_AllVoyageEvents then	//15 Aug 2019	NDL	TFS 46131
		self.doLoadAllVoyageEvent( self.myLstTblUnloadEvts, _defaultValueStr );
		self.setValueByName(rowName, self.myLstTblUnloadEvts.getSelectedFromDisplay);
	elseif rowName = ETRow_AllBargeVessels then	//15 Aug 2019	NDL	TFS 46131
		self.doLoadAllBargVessels( self.myLstTblBarges, _defaultValueStr );
		self.setValueByName(rowName, self.myLstTblBarges.getSelectedFromDisplay);
	elseif rowName = ETRow_WeightMeasureType then //16 Aug 2019	NDL	TFS 46131
		self.doLoadWtMeasureTypes( self.myCmbWtMeasurement, _defaultValueStr );
	elseif rowName = ETRow_DateToRun then //16 Aug 2019	NDL	TFS 46131
		self.setValueByName(rowName, _defaultValueStr);
		self.txtOpenDate := _defaultValueStr;
//	elseif rowName = ETRow_DateYearStart then //16 Aug 2019	NDL	TFS 46131
	elseif rowName = ETRow_DateYearStart or rowName = ETRow_StartOfYearDate then	//21 Jun 2021	NDL	TFS 51245
		self.setValueByName(rowName, _defaultValueStr);
		self.txtBaseDate := _defaultValueStr;
	elseif rowName = ETRow_AllNonBargeVessels then	//21 Aug 2019	NDL	TFS 46131
		self.doLoadAllNonBargVessels( self.myLstTblNonBarges, _defaultValueStr );
		self.setValueByName(rowName, self.myLstTblNonBarges.getSelectedFromDisplay);
	elseif rowName = ETRow_FilterTA then	//01 Jun 2021	NDL	TFS 51245
		self.doLoadTATypes( self.myCmbTerminalArea, _defaultValueStr );
		self.setValueByName(ETRow_FilterTA, self.myCmbTerminalArea.text);
	elseif rowName = ETRow_FilterCargoType then	//03 Jun 2021	NDL	TFS 51245
		self.doLoadCargoTypes(self.myCmbCargoType, _defaultValueStr);
		self.setValueByName(ETRow_FilterCargoType, self.myCmbCargoType.text);
	elseif rowName = ETRow_FilterOperator then	//03 Jun 2021	NDL	TFS 51245
		self.doLoadOperators( self.myCmbOperator, _defaultValueStr );
		self.setValueByName(ETRow_FilterOperator, self.myCmbOperator.text);
	elseif rowName = ETRow_Month then	//03 Jun 2021	NDL	TFS 51245
		self.doLoadMonths( self.myCmbMonth, _defaultValueStr );
	elseif rowName = ETRow_CalculationType then // 20/04/2023	navkc1	CR 55654 Task 55670
		self.doLoadCalculationType(self.myCmbCalculationType, _defaultValueStr);
	elseif rowName = ETRow_Service then // 20/04/2023	navkc1	CR 55654 Task 55670
		//self.doLoadServices(self.myCmbService, self.myCmbCompany.listObject.CM_Bank,null);
		self.doLoadServices(self.myCmbService, self.myCmbCompany.listObject.CM_Bank,self.myCmbServiceGroup.listObject.CM_ServiceGroup,_defaultValueStr); //18.09.2024 navah1 #23334
		self.setValueByName(ETRow_Service,_defaultValueStr);//24.09.2024 navah1 #23334
	elseif rowName = ETRow_ServiceGroup then
		self.doLoadServiceGroup( self.myCmbServiceGroup, self.myCmbCompany.listObject.CM_Bank,_defaultValueStr );	//18.09.2024 navah1 #23334
		self.setValueByName(ETRow_ServiceGroup,_defaultValueStr); 													//16.09.2024 navah1 #23334
	elseif rowName = ETRow_UnitOfMeasureCode then // 20/04/2023	navkc1	CR 55654 Task 55670
		self.doLoadUnitOfMeasure(self.myCmbUnitMeasureCode, _defaultValueStr);
	elseif rowName = ETRow_WorkOrderStatus then 	//16.8.2023 navhl20 #58568
		self.doLoadWOStatus(self.myLstTblWOStatus, _defaultTemplate);
		self.setValueByName(rowName, self.myLstTblWOStatus.getSelectedFromDisplay);
	elseif rowName = ETRow_WorkOrderType then 		//16.8.2023 navhl20 #58568
		self.doLoadWOType(self.myLstTblWOType, _defaultTemplate);
		self.setValueByName(rowName, self.myLstTblWOType.getSelectedFromDisplay);
	elseif rowName = ETRow_TsType then				//7.9.2023 navhl20 #60056
		self.doLoadVBSTsType(self.myLstTblVBSTsType, null);
		self.setValueByName(ETRow_TsType, self.myLstTblVBSTsType.getSelectedFromDisplay);
	else 
		self.setValueByName(rowName, _defaultValueStr);
	endif;	
	
end;</source>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
        <Parameter name="_row" type="EntTableRow"/>
        <Parameter name="_rowNameParameter" type="String"/>
        <Parameter name="_defaultValueStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateTemplateDateTypes" id="5cd7e52f-cd22-4981-982c-a1c4b43f0fe3">
        <options>4</options>
        <source>populateTemplateDateTypes(_combo : ComboBox input) typeMethod;
/*

Purpose:			Populates a combo box with all the template date types

Parameters:			_combo	ComboBox	Combo Box to populate

Return Value:		NONE

Date				Who		Reason
04 November 2025	navpw1	Initial creation JIRA: MTN-36160

*/

begin
	if _combo = null then
		return;
	endif;
	
	_combo.clear;
	_combo.sorted := false;
	_combo.addItem(null);
	_combo.addItem(RTPL_RunDateText);
	_combo.addItem(RTPL_RunDatePlusText);
	_combo.addItem(RTPL_RunDateMinusText);
	_combo.addItem(RTPL_RunMonthStartText);
	_combo.addItem(RTPL_RunMonthEndText);
	_combo.addItem(RTPL_RunMonthStartPlusText);
	_combo.addItem(RTPL_RunMonthStartMinusText);
	_combo.addItem(RTPL_RunMonthEndPlusText);
	_combo.addItem(RTPL_RunMonthEndMinusText);
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSelectorQueryFromTable" id="7eafe71e-36b3-402e-83a6-5a0686c8b91d">
        <updating/>
        <source>setSelectorQueryFromTable(_filterObject : CMQF_FilterReports input) updating;
// ---------------------------------------------------------------------------
// Created:     20 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	criteriaLine			: CM_SelectorCriteriaLine;
	criteriaLineHolder		: CM_QueryCriteriaLineHolder;
	qProp					: CM_QueryProperty;
	qOp						: CM_QueryOperator;
	row,
	controlType				: Integer;
	tbl						: CM_EntryTable;
	cellControl				: Control;
	value					: Any;
	dateArray				: DateArray;
	holderCount				: Integer;
	nameSuffix				: String;
	rangeArray				: IntegerArray;
	timeArray : TimeArray;
begin
	tbl := self.myEntryTable;
	_filterObject.allQueryCriteriaHolders.purge();
	holderCount := 0;
	foreach criteriaLineHolder in self.allCriteriaLineHolders do
		holderCount := holderCount+1;
		nameSuffix := holderCount.String;
		foreach criteriaLine in criteriaLineHolder.allCriteriaByPropertyName do
			if criteriaLine.isUnavailableAtRunTime then
				continue;
			endif;
			
			value := null;
			qProp := criteriaLine.myQueryProperty;
			qOp := criteriaLine.myQueryOperator;
			controlType := qProp.getControlTypeForOperator(qOp);
			//here we use the name suffix to differentiate between the 'OR' sheet rows with the same name
			row := tbl.getRowByName(qProp.propertyName &amp; nameSuffix);
			if row &lt;= tbl.fixedRows then
				//someone has updated the query elsewhere?
				continue;
			endif;
			
			cellControl := tbl.accessCell(row, tbl.ColumnValue).cellControl;
			
			if cellControl = null then
				continue;//this should never happen
			endif;
		
			if controlType = QueryControl_TextBox then 
//			or controlType = QueryControl_Date then
				value := cellControl.TextBox.text; //cast as TextBox as it may be a cnEcDatebox
				value := qProp.translateToSearchValue(value);
				qOp.setSearchValue(value);

			elseif controlType = QueryControl_Date then // PAR 11074
				value := cellControl.CMUI_DateMask.getDate;	//02 Dec 2013	NDL	Par 33082
				qOp.setSearchValue(value);
			//14 May 2012	NDL	Par 29532
			elseif controlType = QueryControl_Time then 
				value := cellControl.CMUI_TimeMask.text;
				value := qProp.translateToSearchValue(value);
				qOp.setSearchValue(value);
	
			elseif controlType = QueryControl_ComboBox then
				value := cellControl.CMUI_ComboBox.listObject;
				if value = null then
					value := cellControl.CMUI_ComboBox.text;
				endif;
			
				value := qProp.translateToSearchValue(value);
				qOp.setSearchValue(value);
				
			elseif controlType = QueryControl_MultiSelect then
				qProp.setValuesFromList(cellControl.CMUI_ListTable, qOp);
		
			elseif controlType = QueryControl_DateRange then
				delete dateArray;
				create dateArray transient;
				dateArray.add(cellControl.CMUI_DateMask.getDate);	//02 Dec 2013	NDL	Par 33082
				cellControl := tbl.accessCell(row + 1, tbl.ColumnValue).cellControl;
				dateArray.add(cellControl.CMUI_DateMask.getDate);	//02 Dec 2013	NDL	Par 33082
				qOp.setSearchValue(dateArray);
			
			//14 May 2012	NDL	Par 29532
			elseif controlType = QueryControl_TimeRange then	//23 Jun 2020	NDL	TFS 49221
				delete timeArray;
				create timeArray transient;
				timeArray.add(cellControl.CMUI_TimeMask.getTime);		
				cellControl := tbl.accessCell(row + 1, tbl.ColumnValue).cellControl;
				timeArray.add(cellControl.CMUI_TimeMask.getTime); 
				qOp.setSearchValue(timeArray);
				
			elseif controlType = QueryControl_NumTextBoxRange then
				//par 18120.  Code added. cnwjo3
				create rangeArray transient;
				self.getRangesFromString(cellControl.CMUI_TextBox.text,rangeArray);
				qOp.CM_QDateDayRange.setSearchValue(rangeArray);

			endif;
		endforeach;
	endforeach;
	
	//self.allCriteriaLineHolders.copy(_filterObject.allQueryCriteriaHolders);\
	// Par 12182 Make copies so we can delete holders in array automatically later.
	self.allCriteriaLineHolders.cloneContents(_filterObject.allQueryCriteriaHolders);
	
epilog
	delete dateArray;
	delete rangeArray;
	delete timeArray;
end;</source>
        <Parameter name="_filterObject" type="CMQF_FilterReports" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setState" id="70dbf457-b3f8-4f33-a601-5ea18758d4ea">
        <updating/>
        <source>setState(_newState: String) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpForm	: CM_BaseForm;
	
begin
	inheritMethod(_newState);
	
	tmpForm := self.myParentForm;
	if CMUI_ReportRunner.hasInstance(tmpForm) then
		tmpForm.CMUI_ReportRunner.setStateFromReportAgent(_newState);
	endif;

end;</source>
        <Parameter name="_newState" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTemplateComboObject" id="04786c11-9b33-44ac-bf6c-8cb421c6db6b">
        <source>setTemplateComboObject(_entRow : EntTableRow; _comboString : String);
// ---------------------------------------------------------------------------
// Created:     08 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	con			: Control;
	combo		: ComboBox;
	listCount,
	idx			: Integer;
	comboText	: String;
begin

	if _entRow.controlName = null or 
	   _comboString = null or
	   self.myParentForm = null then
		return;
	endif;
	
	con := self.myParentForm.getPropertyValue(_entRow.controlName).Control;
	
	if con = null or (not ComboBox.hasInstance(con)) then
		return;
	endif;

	combo := con.ComboBox;
	listCount := combo.listCount;
	foreach idx in 1 to listCount do
		comboText := combo.itemText[idx].trimBlanks;
		if comboText = _comboString then
			combo.listIndex := idx;
			combo.listObject := combo.itemObject[idx];
			combo.text := comboText;
			combo.click(con.ComboBox);
			break;		
		endif;
	endforeach;

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <Parameter name="_comboString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setValueByControlName" id="6ac43698-ceaf-43bc-a307-afb40c7bf17d">
        <source>setValueByControlName(_controlName : String; _value : Any) : Integer;
// ---------------------------------------------------------------------------
// Created:     08 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numRows,
	row					: Integer;
	tbl					: CM_BaseTable;
	entTableRow			: EntTableRow;
begin
	if self.myEntryTable &lt;&gt; null then
		return self.myEntryTable.setValueByControlName(_controlName, _value);
	endif;
	
	tbl := self.myBaseTable;
	if tbl = null then
		return null;
	endif;
	
	numRows := tbl.rows;
	foreach row in tbl.fixedRows + 1 to numRows do
		entTableRow := tbl.accessRow(row).itemObject.EntTableRow;
		
		if (entTableRow = null) or
		   (entTableRow.controlName &lt;&gt; _controlName) then
		   continue;
		endif;
		
		tbl.setCellText(row, CMUI_ReportBuilder.Column_DefaultValue, _value.String);
		break;
	endforeach;
	
	return row;

end;</source>
        <Parameter name="_controlName" type="String"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValueByName" id="9847d931-ad56-4bca-8683-becaf16ea11f">
        <source>setValueByName(_rowName : String; _value : Any) : Integer;
// ---------------------------------------------------------------------------
// Created:     06 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numRows,
	row					: Integer;
	tbl					: CM_BaseTable;
	entTableRow			: EntTableRow;
begin
	if self.myEntryTable &lt;&gt; null then
		return self.myEntryTable.setValueByName(_rowName, _value);
	endif;
	
	tbl := self.myBaseTable;
	if tbl = null then
		return null;
	endif;
	
	numRows := tbl.rows;
	foreach row in 1 to numRows do
		entTableRow := tbl.accessRow(row).itemObject.EntTableRow;
		if (entTableRow = null) or
		   (entTableRow.name &lt;&gt; _rowName) then
		   continue;
		endif;
		tbl.setCellText(row, CMUI_ReportBuilder.Column_DefaultValue, _value.String );
		break;
	endforeach;
	
	return row;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTableForSelectorReport" id="309d0fb4-6b1c-444a-89dc-907188f904b4">
        <updating/>
        <source>showTableForSelectorReport(_criteriaHolders : CM_QueryCriteriaHolderArray) updating;
//showTableForSelectorReport(_menuUserQuery : CM_MenuUserQuery) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2003	cnwth2
//
// Purpose:     Populates tblParameter with a row for each criteria line that
//				is available to be updated in the selector query associated with 
//				the current report.
//				Criteria not available for change at run time does not appear, but is still applied.
//			 	
//				An entRowTransient is created 'behind' each row - cell controls are cloned on the fly.
//				
// ----------   ----------  --------------------------------------------------
vars
	clonedCriteriaLine,
	persistentCriteriaLine		: CM_SelectorCriteriaLine;
	clonedCriteriaHolder,
	persistentCriteriaHolder	: CM_QueryCriteriaLineHolder;
	clonedOp					: CM_QueryOperator;
	clonedProp					: CM_QueryProperty;
	valueStr,
	headingStr					: String;
	tbl							: CM_EntryTable;
	cellControl					: Control;
	rowCount,
	controlType,
	idx							: Integer;
	entRowTrans					: EntTableRowTransient;
	firstTime					: Boolean;
	obj							: Object;
	controlArray				: ObjectArray;
	holderCount					: Integer;
	nameSuffix					: String;
begin
	if _criteriaHolders = null then
		return;
	endif;
	
	create controlArray transient;
	
	tbl := self.myEntryTable;
	self.allCriteriaLineHolders.purge();
	tbl.allEntRowTransients.purge();

	tbl.rows := tbl.fixedRows;
	self.maxTextBoxNum := 0;
	self.maxComboNum := 0;
	self.maxDateBoxNum := 0;
	self.maxLstTableNum := 0;
	self.maxTextBoxRange := 0;

	holderCount := 0;
	foreach persistentCriteriaHolder in _criteriaHolders do
		holderCount := holderCount+1;
		nameSuffix := holderCount.String;
		clonedCriteriaHolder := persistentCriteriaHolder.cloneSelf(true);
		self.allCriteriaLineHolders.add(clonedCriteriaHolder);
		foreach persistentCriteriaLine in persistentCriteriaHolder.allCriteriaLines do
			//this cloneSelf call has been re-implemented to clone off the queryProperty and
			//queryOperator objects - including cloning of all neccessary references etc.
			clonedCriteriaLine := persistentCriteriaLine.cloneSelf(true);
			clonedCriteriaLine.setMyCriteriaLineHolder(clonedCriteriaHolder);
			
			clonedProp := clonedCriteriaLine.myQueryProperty;
			clonedOp := clonedCriteriaLine.myQueryOperator;
			
			if clonedCriteriaLine.isUnavailableAtRunTime then
				//selector criteria still needs to be created and take effect when the query is executed
				//but the user will not see it
				continue;
			endif;
			
			rowCount := rowCount + 1;
			
			
			controlType := clonedProp.getControlTypeForOperator(clonedOp);
			controlArray.clear();
			self.getSelectorControlCloned(controlArray, persistentCriteriaHolder, clonedProp, clonedOp, controlType, rowCount);
			if controlArray.isEmpty then
				//this should never happen - rowCount is needed proir to adding a table row as it 
				//is used to set the cloned cell control name (see self.setSelectorControl
				rowCount := rowCount - 1;
				continue;
			endif;
			
			foreach obj in controlArray do
				cellControl := obj.Control;
				if controlType = QueryControl_DateRange then
					if (obj = controlArray.first) then
						headingStr := clonedProp.niceName &amp; ' ' &amp; clonedOp.description;
						valueStr := clonedOp.CM_QDateRange.fromDate.shortFormatJMT();
					else
						headingStr := 'and';
						valueStr := clonedOp.CM_QDateRange.toDate.shortFormatJMT();
					endif;
				elseif controlType = QueryControl_NumTextBoxRange and clonedOp.isKindOf(CM_QDateDayRange) then
					//par 18120.  Code added. cnwjo3
					//TextBox.text change since somewhere else it only sets the cellText
					//which does not keep the value
					headingStr := clonedProp.niceName &amp; ' ' &amp; clonedOp.description;
					cellControl.CMUI_TextBox.case := 0;
					valueStr := clonedOp.CM_QDateDayRange.fromNumDays.asStringJMT;
					valueStr := valueStr &amp; ' and ' &amp; clonedOp.CM_QDateDayRange.toNumDays.asStringJMT;
					cellControl.CMUI_TextBox.text := valueStr;
				//14 May 2012	NDL	Par 29532
				elseif controlType = QueryControl_TimeRange then
					if (obj = controlArray.first) then
						headingStr := clonedProp.niceName &amp; ' ' &amp; clonedOp.description;
						valueStr := clonedOp.CM_QTimeRange.fromTime.shortFormatJMT();
					else
						headingStr := 'and';
						valueStr := clonedOp.CM_QTimeRange.toTime.shortFormatJMT();
					endif;
				else
					headingStr := clonedProp.niceName &amp; ' ' &amp; clonedOp.description;
					valueStr := clonedOp.getSearchValueStr(clonedProp);
					
				endif;
				
				if CMUI_DateMask.hasInstance(cellControl) then
					cellControl.CMUI_DateMask.setDate(valueStr.asDateJMT); //epr par 32824 11/4/13
				endif;
				
				//14 may 2012	NDL	Par 29532
				if CMUI_TimeMask.hasInstance(cellControl) then
					cellControl.CMUI_TimeMask.setTime(valueStr.asTimeJMT);
				endif;
				
				create entRowTrans transient;
				tbl.allEntRowTransients.add(entRowTrans);

				//here we use the name suffix to differentiate between the 'OR' sheet rows with the same name
				entRowTrans.setBasicDetails(clonedProp.propertyName &amp; nameSuffix,
											headingStr,
											null,
											true,
											true);
				
				entRowTrans.setControlName(cellControl.name);
				entRowTrans.setLostFocusMethodName('selectorControlLostFocus');
				//short heading property used to store listbox property name
				entRowTrans.setShortHeading(clonedProp.getListBoxPropertyName());
			
				tbl.accessRow(tbl.addItem(headingStr &amp; Tab &amp; valueStr)).itemObject := entRowTrans;	
				tbl.accessedRow.cellControl := cellControl;
			endforeach;
		endforeach;
		
		if persistentCriteriaHolder &lt;&gt; _criteriaHolders.last then
			idx := tbl.addItem('--OR--' &amp; Tab &amp; '--------------');
			tbl.accessCell(idx, tbl.ColumnValue).inputType := tbl.InputType_None;
		endif;
	endforeach;	
	//add the report profile row
	create entRowTrans transient;
	tbl.allEntRowTransients.add(entRowTrans);
	headingStr := 'Report Profile';
	entRowTrans.setBasicDetails(ETRow_ReportProfile,
								headingStr,
								null,
								true,
								true);
	
	entRowTrans.setControlName(self.myCmbProfile.name);
	tbl.accessRow(tbl.addItem(headingStr)).itemObject := entRowTrans;
	entRowTrans.setLostFocusMethodName('selectorControlLostFocus');	
	tbl.accessedRow.cellControl := self.myCmbProfile;
	
epilog
	delete controlArray;				
end;</source>
        <Parameter name="_criteriaHolders" type="CM_QueryCriteriaHolderArray"/>
    </JadeMethod>
    <JadeMethod name="useCurrentDefaultVoyage" id="31e64c5e-4763-49cf-a03a-6d181695c58c">
        <source>useCurrentDefaultVoyage() : Boolean;
// ---------------------------------------------------------------------------
// Created:     08 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.isOptCurrentVoyageAllowed and
	   self.myCmbCellularVoy.text = OPT_DEFAULT_VOYAGE then
		return true;
	endif;
	return false;			
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
