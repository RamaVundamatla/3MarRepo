    <JadeMethod name="txtFilterBox_keyUp" id="93c6b490-8c93-4389-91bb-ba2ee9d06f34">
        <controlMethod name="TextBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFilterBox_keyUp(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

vars

	type,
	remaining		: Integer;

begin

	if self.getTimerStatus(self.Timer_TableData_Filter, type, remaining) then
		self.endTimer(self.Timer_TableData_Filter);
	endif;
	
	self.beginTimer(500, Timer_OneShot, self.Timer_TableData_Filter);

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
