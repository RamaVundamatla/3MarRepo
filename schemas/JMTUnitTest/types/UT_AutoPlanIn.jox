    <JadeMethod name="tTranshipDischargePort" id="b1d59a08-73e4-458a-9a96-c1d4865d0c8e">
        <updating/>
        <source>tTranshipDischargePort() updating;
// cnwndl1
//29 August 2008	cnwdw1	
// 10 Sep 2019	cnwrs1	TFS 46030
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1 : CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_GridArea;
	controller: CMIF_TranshipTIController;
	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	deleteVoyage("UTVOY1");
	deleteVessel("UTBOAT");
	vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage1 := addVoyageWithContainerStructur("UTVOY1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteContainer("TEST0000001");
	self.deleteContainer("TEST0000002");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	// now make it a tranship
	create controller transient;
	controller.allTrackedItems.add(ti1);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= voyage1;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; 	// TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);

	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_TranshipDischPt, app.myRoot.allPorts['NZAKL'], locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertEqualMsg(location, locations.first, "Did not autoplan to correct location");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_TranshipDischPt, app.myRoot.allPorts['NZAKA'], locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertEqualMsg(location, null, "Did autoplan to location when it should have failed");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete locations;
	delete controller;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVoyageObjectsCriteria" id="815dced1-1733-4402-8f70-0420baebfe7e">
        <source>tVoyageObjectsCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
// 10 Sep 2019	cnwrs1	TFS 46030
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	bs: CM_BlockStack;
	voyage1: CM_Voyage;
	voyage2: CM_Voyage;
	vessel: CM_Vessel; 
	voyages: ObjectSet;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	deleteTerminalArea("UTBS1");
	bs:= addBlockStack("UTBS1", 100, null);
	
	deleteVoyage("UTVOY1");
	deleteVoyage("UTXVOY2");
	deleteVessel("UTBOAT");
	vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage1 := addVoyageWithContainerStructur("UTVOY1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	voyage2 := addVoyageWithContainerStructur("UTXVOY2", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	self.deleteContainer("TEST0000001");
	self.opts.addAssoc("VoyageName", "UTVOY1");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertEqual(ti1.myVoyage, voyage1);
	self.deleteContainer("TEST0000002");
	self.opts.addAssoc("VoyageName", "UTXVOY2");
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertEqual(ti2.myVoyage, voyage2);
	
	// Create a YA to match pattern UTV*
	self.deleteYA("UT");
	create voyages transient;
	voyages.add(voyage1);
	voyages.add(voyage2);
	ya := self.addYA1("UT", YACriteriaType_Voyage, voyages, bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataObjects));

	// Test that a matching voyage succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a matching voyage succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete voyages;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVoyagePatternCriteria" id="622e548f-c8ac-46ab-9c7a-e1f037dc2dc1">
        <source>tVoyagePatternCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
// 10 Sep 2019	cnwrs1	TFS 46030
// 
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	bs: CM_BlockStack;
	voyage1: CM_Voyage;
	voyage2: CM_Voyage;
	vessel: CM_Vessel; 
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	deleteTerminalArea("UTBS1");
	bs:= addBlockStack("UTBS1", 100, null);
	
	deleteVoyage("UTVOY1");
	deleteVoyage("UTXVOY2");
	deleteVessel("UTBOAT");
	vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage1 := addVoyageWithContainerStructur("UTVOY1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	voyage2 := addVoyageWithContainerStructur("UTXVOY2", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	self.deleteContainer("TEST0000001");
	self.opts.addAssoc("VoyageName", "UTVOY1");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertEqual(ti1.myVoyage, voyage1);
	self.deleteContainer("TEST0000002");
	self.opts.addAssoc("VoyageName", "UTXVOY2");
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertEqual(ti2.myVoyage, voyage2);
	
	// Create a YA to match pattern UTV*
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_Voyage, "UTV*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataPattern));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertNull(location);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVoyageWildcardCriteria" id="e87641dd-4551-4d37-b5ed-b8f4ea95bece">
        <source>tVoyageWildcardCriteria();

/*

Purpose:		Autoplan using Wildcards

Date			Who		Reason
26/02/2014		cnwmh5	Initial creation

*/

constants

	VesselId						: String = "MESDIAM";
	Voyage1Id						: String = "UTMHV";
	Voyage2Id						: String = "UTMHV1";
	BlockStack1Id					: String = "UTMHV";
	YardAllocationId				: String = "UTWILD";
	TrackedItem1Id					: String = "UTMHWILD001";
	TrackedItem2Id					: String = "UTMHWILD002";
	
vars

	voyage1							: CM_Voyage;
	voyage2							: CM_Voyage;
	bs								: CM_BlockStack;
	ya								: CM_YardAllocation;
	ti1								: CM_TrackedItem;
	ti2								: CM_TrackedItem;
	slotVoyV						: CM_LocationsController;
	slotVoyV1						: CM_LocationsController;
	voyageJob						: CM_VoyageJob;
	tmpLoadCC						: CMIF_LoadColorCode;
	crane							: CM_Crane;
	
	slots							: CM_SlotControllerArray;
	strs							: StringArray;
	tiArray							: CM_TIArray;
	
	idx								: Integer;
	
begin

	self.disableAllYA(true);
	
	// delete / create voyages
	self.deleteVoyage(Voyage1Id);
	voyage1 := self.addVoyageWithConRORO(Voyage1Id, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, self.getProfileSetting(UT_Profile.P_TRADE).asString, 
		0, false, true);
	self.assertNotNull(voyage1);
	
	self.deleteVoyage(Voyage2Id);
	voyage2 := self.addVoyageWithConRORO(Voyage2Id, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, self.getProfileSetting(UT_Profile.P_TRADE).asString, 
		0, false, true);
	self.assertNotNull(voyage2);
	
	// delete / create bs
	bs := self.addBlockStack(BlockStack1Id, 10, null);
	self.assertNotNull(bs);
	
	// add yard allocation
	ya := self.addYA1(YardAllocationId, YACriteriaType_Voyage, "!UTMHV1", bs.allLocationsControllers.first);
	self.assertNotNull(ya);
	
	// create discharge cargo for, colour code
	create strs transient;
	strs.add("010282");
	voyage1.findLocation(strs, false, slotVoyV, idx);
	ti1 := self.addContainerAtLocnDisch(TrackedItem1Id, "2200", "GENL", TI_IMEX_STATUS_IMPORT, slotVoyV, 
		app.myRoot.allPorts["NZAKL"], voyage1);
	self.assertNotNull(ti1);
	
	create slots transient;
	slots.add(slotVoyV.CM_SlotController);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(voyage1, "CRN1", slots, true);
	self.assertNotNull(voyageJob);
	
	strs.clear();
	strs.add("010282");
	voyage2.findLocation(strs, false, slotVoyV1, idx);
	ti2 := self.addContainerAtLocnDisch(TrackedItem2Id, "2200", "GENL", TI_IMEX_STATUS_IMPORT, slotVoyV1, 
		app.myRoot.allPorts["NZPOE"], voyage2);
	self.assertNotNull(ti2);
	
	slots.clear();
	slots.add(slotVoyV1.CM_SlotController);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(voyage2, "CRN1", slots, true);
	self.assertNotNull(voyageJob);
	
	crane := self.getCrane("CRN1");
	self.assertNotNull(crane);
	
	self.autoplanDischargeItems(voyage1, bs, crane);
	
	self.opts.purge();
	self.opts.addAssoc("DontCheckHere", true);
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_NOTMATCH_ALLOCATION_AT);
	self.autoplanDischargeItems(voyage2, bs, crane);
	
epilog

	self.disableAllYA(false);

	delete strs;
	delete slots;
	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tYAPriorityLookup" id="13e6a2dc-b76a-4260-a5c5-6a676547e4b7">
        <source>tYAPriorityLookup();
// cnwndl1
//23 July 2010	cnwdw1	
// Test that Autoplanning looks at all the YA when the AutoPlanUsePriorityLookup setting is false
vars
	bs1, bs2: CM_BlockStack;
	ya1, ya2: CM_YardAllocation;
	ti1: CM_TrackedItem;
	location: CM_LocationsController;
begin
	self.deleteYAPriorities();	
	disableAllYA(true);
	
	deleteTerminalArea("UTBS1");
	bs1 := addBlockStack("UTBS1", 1, null);
	deleteTerminalArea("UTBS2");
	bs2 := addBlockStack("UTBS2", 1, null);

	self.addYAPriority(YACriteriaType_Hazardous, "1.1");
	assertEqual(self.getTerminal.allYAPriorities.size, 1);
	
	self.deleteYA("UTHAZ");
	ya1 := self.addYA1("UTHAZ", YACriteriaType_Hazardous, "1.1, 1.2", bs1.myLocationsController);
	assertEqual(ya1.priorityValue, 1.0);
	
	self.deleteYA("UT");
	ya2 := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, bs2.myLocationsController);
	assertEqual(ya2.priorityValue, 0.0);
		
	self.deleteContainer("TEST0000001");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	addTIHazard(ti1, "1.2", false);

	setTerminalConfig(AutoPlanUsePriorityLookup, false);
	// The container will match UTHAZ ya, and plan to bs1
	location := app.autoPlanTiYA(self.getTerminal, null, ti1);
	assertEqual(location, bs1.myLocationsController); 	

	setTerminalConfig(AutoPlanUsePriorityLookup, true);
	// The container will match UT ya, and plan to bs2, because the ti gets a priority value
	// of 0, as the hazard value of 1.2 is not a priority. 
	// As the priority of the UTHAZ ya is 1, it will not be found during autoplan
	location := app.autoPlanTiYA(self.getTerminal, null, ti1);
	assertEqual(location, bs2.myLocationsController); 	
	
epilog
	disableAllYA(false);
end;</source>
    </JadeMethod>
</Class>
