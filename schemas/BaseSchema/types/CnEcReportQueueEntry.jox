    <JadeMethod name="createParameterValue" id="0d593f42-b140-40f8-b2a2-9899c62e4386">
        <source>createParameterValue(	pReportParameter:CnEcReportParameter;
						pObjectValue:Object;
						pStringValue:String):CnEcReportParameterValue;
// --------------------------------------------------------------------------------
// Created:		27 July 2000 by cnwdad1
//
// Purpose:		Creates a parameter value object.
//
// Parameters:	pReportParameter - The owning parameter object.
//				pObjectValue - The object value.
//				pStringalue - The string value.
//
// Returns:		The new paremeter value object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theParameterValue	: CnEcReportParameterValue;

begin
	create theParameterValue;
	theParameterValue.initializeMe(self, pReportParameter, pObjectValue, pStringValue);
	return theParameterValue;
end;</source>
        <Parameter name="pReportParameter" type="CnEcReportParameter"/>
        <Parameter name="pObjectValue" type="Object"/>
        <Parameter name="pStringValue" type="String"/>
        <ReturnType type="CnEcReportParameterValue"/>
    </JadeMethod>
    <JadeMethod name="displayTab" id="57682f76-32a6-4be7-8609-89be34c4f448">
        <source>displayTab():String;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Returns a string for displaying the Queue Entry details in a
//				table control.
//
// Parameters:	None
//
// Returns:		The tab-delimited display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return	self.timeStamp.date.shortFormat.String &amp; ", " &amp; self.timeStamp.time.String &amp; Tab &amp;
			self.priority.String &amp; Tab &amp;
			self.printerName &amp; Tab &amp;
			self.copies.String &amp; Tab &amp;
			self.getPrintStatusMessage();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayTabP" id="839ce949-0c0e-4e86-9fd2-dd69c4b978c9">
        <source>displayTabP():String;
// --------------------------------------------------------------------------------
// Created:		01 August 2000 by cnwdad1
//
// Purpose:		Returns a string for displaying the Printer's Queue Entry details
//				in a table control.
//
// Parameters:	None
//
// Returns:		The tab-delimited display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return	self.timeStamp.date.shortFormat &amp; ", " &amp; self.timeStamp.time.String &amp; Tab &amp;
			self.priority.String &amp; Tab &amp;
			self.myReportDefinition.reportName &amp; Tab &amp;
			self.copies.String &amp; Tab &amp;
			self.getPrintStatusMessage();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayTabServer" id="12b45331-a7b2-4f19-a9ed-4e72e42e2e5c">
        <source>displayTabServer():String;
// --------------------------------------------------------------------------------
// Created:		10 August 2000 by cnwdad1
//
// Purpose:		Returns a string for displaying the Queue Entry details on a GUI
//				version of the Report Print Server table.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return	self.timeStamp.date.shortFormat.String &amp; ", " &amp; self.timeStamp.time.String &amp; Tab &amp;
			self.priority.String &amp; Tab &amp;
			self.myReportDefinition.reportName &amp; Tab &amp;
			self.printerName &amp; Tab &amp;
			self.copies.String &amp; Tab &amp;
			self.getPrintStatusMessage();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCastParameterValue" id="c60739f2-d59b-4478-bdb6-c7125763cfe3">
        <source>getCastParameterValue(pParameterType:String; pParameterValue:String):Any protected;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Casts the specified parameter value to the requested primitive type,
//				and returns the result.
//
// Parameters:	pParameterType - The desired primitive type.
//				pParameterValue - The parametr value to cast.
//
// Returns:		The cast parameter value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pParameterType = "Boolean" then
		return pParameterValue.Boolean;
		
	elseif pParameterType = "Date" then
		return pParameterValue.Date;
		
	elseif pParameterType = "Decimal" then
		return pParameterValue.Decimal;
		
	elseif pParameterType = "Integer" then
		return pParameterValue.Integer;
		
	elseif pParameterType = "Real" then
		return pParameterValue.Real;
		
	elseif pParameterType = "String" then
		return pParameterValue;
		
	elseif pParameterType = "Time" then
		return pParameterValue.Time;
		
	else
		return null;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pParameterType" type="String"/>
        <Parameter name="pParameterValue" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getParameterValue" id="32e44a6d-f13b-4941-ac2e-d7b94697340b">
        <source>getParameterValue(pParameterName:String; pAnyValue:Any output):Boolean;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Returns the parameter value for the specified report parameter name.
//
// Parameters:	pParameterName - The name of the parameter.
//				pAnyValue - The parameter value.
//
// Returns:		True if the parameter value was found, otherwise false.  The value
//				is returned in the output method parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	paramValue	: CnEcReportParameterValue;

begin
	foreach paramValue in self.allReportParameterValues
	where paramValue.myReportParameter.parameterName.toLower = pParameterName.toLower
	do
		if paramValue.myReportParameter.isPrimitiveType() then
			pAnyValue	:=	self.getCastParameterValue(paramValue.myReportParameter.parameterType, paramValue.stringValue);
		else
			pAnyValue	:=	paramValue.myObjectValue;
		endif;

		return true;
	endforeach;

	pAnyValue	:=	null;
	return false;
end;</source>
        <Parameter name="pParameterName" type="String"/>
        <Parameter name="pAnyValue" type="Any" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPrintStatusMessage" id="073b6c3a-d142-4d5f-9284-8a279854de94">
        <source>getPrintStatusMessage():String;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Returns a string for displaying the status of the print job.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (printStatus = CNEC_REPORT_PREVIEW) then
		return $CNEC_PREVIEWING;
	elseif (printStatus = CNEC_REPORT_PENDING) then
		return $CNEC_PENDING;
	elseif (printStatus = CNEC_REPORT_PRINTING) then
		return $CNEC_PRINTING;
	elseif (printStatus = CNEC_REPORT_PRINTED) then
		return $CNEC_PRINTED;
	elseif (printStatus = CNEC_REPORT_PAUSED) then
		return $CNEC_PAUSED;
	elseif (printStatus = CNEC_REPORT_CANCELLED) then
		return $CNEC_CANCELLED;
	elseif (printStatus = CNEC_REPORT_ERROR) then
		if (self.errorMessage = $CNEC_NO_DATA_TO_DISPLAY) then
			return $CNEC_NO_DATA;
		else
			return $CNEC_ERROR;
		endif;
	endif;

	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="a22f7852-c347-4dd5-a3f2-4166f581a938">
        <updating/>
        <source>initializeMe(pTimeStamp:TimeStamp;
			pPriority:Integer;
			pCopies:Integer;
			pDestination:String;
			pIsPrintToFile:Boolean;
			pPrintStatus:Integer;
			pPrinterName:String;
			pBaseRoot:CnEcBaseRoot;
			pReportDefinition:CnEcReportDefinition) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Initializes the receiver's property values.
//
// Parameters:	pTimeStamp - The timestamp of the queue entry.
//				pPriority - The priority of the print job.
//				pCopies - The number of copies to print.
//				pDestination - The name of the destination file (only applicable ir
//					the pIsPrintToFile flag is set).
//				pIsPrintToFile - If true, the output will be written to a disk file
//					in CSV format.
//				pPrintStatus - The current status of the report.
//				pPrinterName - The name of the destination printer (not required if
//					the pIsPrintToFile flag is set).
//				pBaseRoot - The BaseSchema root object.
//				pReportDefinition - A reference to the report definition object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// First, set any properties...

	self.copies				:=	pCopies;
	self.destination		:=	pDestination;
	self.isPrintToFile		:=	pIsPrintToFile;
	self.printStatus		:=	pPrintStatus;
	self.printerName		:=	pPrinterName;

	// Next, set any key properties...

	self.timeStamp			:=	pTimeStamp;
	self.priority			:=	pPriority;

	// Finally, set any references...

	self.myBaseRoot			:=	pBaseRoot;
	self.myReportDefinition	:=	pReportDefinition;
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <Parameter name="pPriority" type="Integer"/>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pDestination" type="String"/>
        <Parameter name="pIsPrintToFile" type="Boolean"/>
        <Parameter name="pPrintStatus" type="Integer"/>
        <Parameter name="pPrinterName" type="String"/>
        <Parameter name="pBaseRoot" type="CnEcBaseRoot"/>
        <Parameter name="pReportDefinition" type="CnEcReportDefinition"/>
    </JadeMethod>
    <JadeMethod name="updateErrorMessage" id="b9b22cf8-c923-4b83-b467-88b0a247cdbf">
        <updating/>
        <source>updateErrorMessage(pMessage:String) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Updates the receiver's error message.
//
// Parameters:	pMessageString - The error message.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.errorMessage &lt;&gt; pMessage then
		self.errorMessage	:=	pMessage;
	endif;
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="664e4b22-ac20-48ce-824a-cd2c4bb42d70">
        <updating/>
        <source>updateMe(	pTimeStamp:TimeStamp;
			pPriority:Integer;
			pCopies:Integer;
			pDestination:String;
			pIsPrintToFile:Boolean;
			pPrintStatus:Integer;
			pPrinterName:String;
			pReportDefinition:CnEcReportDefinition) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Updates the receiver's property values.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// First, set any properties...

	self.copies				:=	pCopies;
	self.destination		:=	pDestination;
	self.isPrintToFile		:=	pIsPrintToFile;
	self.printStatus		:=	pPrintStatus;
	self.printerName		:=	pPrinterName;

	// Next, set any key properties...

	self.timeStamp			:=	pTimeStamp;
	self.priority			:=	pPriority;

	// Finally, set any references...

	self.myReportDefinition	:=	pReportDefinition;
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <Parameter name="pPriority" type="Integer"/>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pDestination" type="String"/>
        <Parameter name="pIsPrintToFile" type="Boolean"/>
        <Parameter name="pPrintStatus" type="Integer"/>
        <Parameter name="pPrinterName" type="String"/>
        <Parameter name="pReportDefinition" type="CnEcReportDefinition"/>
    </JadeMethod>
    <JadeMethod name="updateParameterValues" id="9c09a122-bfe8-4171-bd28-bbda4f795924">
        <updating/>
        <source>updateParameterValues(pParameterValueArray:CnEcReportParameterValueArray) updating;
// --------------------------------------------------------------------------------
// Created:		28 July 2000 by cnwdad1
//
// Purpose:		Updates the receiver's parameter values with those in the specified
//				array.
//
// Parameters:	pParameterValueArray - An array of report parameter value objects.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parameterValue	: CnEcReportParameterValue;

begin
	self.allReportParameterValues.purge();

	foreach parameterValue in pParameterValueArray do
		self.createParameterValue(parameterValue.myReportParameter, parameterValue.myObjectValue, parameterValue.stringValue);
	endforeach;
end;</source>
        <Parameter name="pParameterValueArray" type="CnEcReportParameterValueArray"/>
    </JadeMethod>
    <JadeMethod name="updatePrintStatus" id="f7542701-4296-469e-975a-6df7ffb88509">
        <updating/>
        <source>updatePrintStatus(pStatus:Integer; pErrorMessage:String) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Update the print status and error message of the receiver.
//
// Parameters:	pStatus - The print status.
//				pErrorMessage - The error message.  Refer to the CnEcReports Global
//					Constant category for a list if valid inputs.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.printStatus &lt;&gt; pStatus then
		self.printStatus	:=	pStatus;
	endif;

	if self.errorMessage &lt;&gt; pErrorMessage then
		self.errorMessage	:=	pErrorMessage;
	endif;
end;</source>
        <Parameter name="pStatus" type="Integer"/>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
</Class>
