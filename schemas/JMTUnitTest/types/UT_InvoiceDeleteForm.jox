    </JadeMethod>
    <JadeMethod name="loadTerminals" id="6dc4f0c6-fa34-411f-a2cc-f460e613f9da">
        <source>loadTerminals();

/*

Purpose:		Load the terminal listbox

Date			Who		Reason
14/02/2014		cnwmh5	Initial creation

*/

vars

	root						: CM_Root;
	terminal					: CM_Terminal;
	
	index						: Integer;

begin

	root := CM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	foreach terminal in root.allTerminals do
		index := index + 1;
	//	self.lstTerminals.addItem(terminal.name);
		//self.lstTerminals.listObject[self.lstTerminals.listIndex] := terminal;
		self.lstTerminals.addObjectAt(terminal.code.padBlanks(4) &amp; " - " &amp; terminal.name, index, terminal, 1, false);
	endforeach;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2448182b-44ca-4d3b-ad19-4f6157bea5d1">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:		

Date			Who		Reason
14 February 2014	cnwmh5	Initial creation

*/

vars

begin

	self.loadTerminals();

	self.centreWindow();

epilog

end;</source>
    </JadeMethod>
