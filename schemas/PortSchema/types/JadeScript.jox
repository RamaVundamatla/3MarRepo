    <JadeMethod name="rel841_par36041" id="f1effd27-7cc5-4812-99f1-f9a4ea4b7512">
        <source>rel841_par36041();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/07/2015	cnwdap1		Initial creation PAR #36041 Tidy up chilledTIsOffPower arrays on CM_Terminal
//
vars
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	invalid, count : Integer;

begin
	beginTransaction;
	foreach terminal in CM_Terminal.instances do
		foreach ti in terminal.chilledTIsOffPower do
			if not app.isValidObject(ti) then
				terminal.chilledTIsOffPower.remove(ti);
				invalid := invalid + 1;
				continue;
			endif;
			if ti.isConnected then
				terminal.chilledTIsOffPower.remove(ti);
				count := count + 1;
			endif;
		endforeach;
	endforeach;
	commitTransaction;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="rel841_par36094" id="45185f35-2ea3-4a0e-a105-61385793c75b">
        <source>rel841_par36094();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars
	terminal : CM_Terminal;
	release : PortSchema_7_1_0;
	etArray : StringArray;
	etAgent	: EntTableAgent;

begin
	app.initialize;
	foreach terminal in app.myRoot.allTerminals do
		beginTransaction;
		terminal.createSystemEquipmentChecks();
		commitTransaction;
	endforeach;
	
	create release transient;
	release.createYATypesStandard();
	
	create etArray transient;
	create etAgent transient;
	etArray.add('ETRow_ExpiryDate');
	etArray.add('ETDef_ContainerFullReefer');
	etArray.add('ETDef_GeneralCargoReefer');
	etArray.add('ETDef_CargoEnqDefaultData');
	etArray.add('ETDef_ContainerData');
	etArray.add('ETDef_ReeferData');
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	etAgent.trxUpdateFromConstant(etArray);
	
	return;
	
	write CARGO_CHECK_CONTEXT_ROAD_REL;
	write CARGO_CHECK_ROADGATE_OUT_STRNG;
	write EXTRA_INFO_TEMPERATURE;
	write YACriteriaType_Temperature;
	write YA_CriteriaType_Max;
	write Obj_Extn_receivalTemperature;
	write ETRow_ExpiryDate;
	write ETDef_ContainerFullReefer;
	write ETDef_GeneralCargoReefer;
	write ETDef_CargoEnqDefaultData;
	write ETDef_ContainerData;
	write ETDef_ReeferData;
epilog
	delete release;
	delete etArray;
	delete etAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel841_par36103" id="6cff6902-2af7-438e-868b-3591746f2c4a">
