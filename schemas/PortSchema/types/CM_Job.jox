    </JadeMethod>
    <JadeMethod name="dwellTime" id="5296544a-fce7-4144-9af6-4b7702e5869e">
        <methodInvocation>mapping</methodInvocation>
        <source>dwellTime(set: Boolean; _value: Integer io) mapping;
//Returns the time in minutes between the creation of this
//job and now. Indicates how long a truck has been inside
//the terminal
vars
	aT	:	Time;
	isPos	:	Integer;
	numDays	:	Integer;
	mins : Integer;
begin
	if set then 
		app.raiseSetVirtualError(class.name, method.name);
		return; 
	endif;
	/*if self.status = JOB_COMPLETE then
		return;
	endif;*/
	aT := app.actualTimeServer.differenceAsTime(creationTime, isPos, numDays);
	_value := (numDays * 24 * 60) + (aT.hour * 60) + aT.minute + 1;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dwellTimeAsString" id="0abc45a0-a829-4cf8-8e3f-2f6d05ff70a0">
        <source>dwellTimeAsString() : String;
//Returns the milliseconds between the creation of this
//job and now. Indicates how long a truck has been inside
//the terminal
vars
begin


	// DVB changed this to 40 as there was an overflow problem.
	return app.actualTimeServer.cnEcDiff(creationTime).String.padLeadingZeros(40);
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
