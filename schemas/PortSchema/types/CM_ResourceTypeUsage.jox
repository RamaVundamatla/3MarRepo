    <JadeMethod name="getStatusString" id="03f389f3-9608-40b1-b441-3a11849977b2">
        <source>getStatusString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	str : String;

begin 
	
	if self.status = CM_InvoiceLine.STATUS_NORMAL then
		str := app.getString(Normal);
	elseif self.status = CM_InvoiceLine.STATUS_VOIDED then
		str := app.getString(Void);
	endif; 

	return str; 

epilog

end;</source>
        <ReturnType type="String"/>
