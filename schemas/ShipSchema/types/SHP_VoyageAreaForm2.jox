    <JadeMethod name="doMnuGridDeLinkClick" id="f41ac1eb-e81a-4ed5-a9a6-a384241cf27e">
        <updating/>
        <source>doMnuGridDeLinkClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	obj			: Object;
	tmpSlotController	: CM_SlotController;
	aLeftReq	: CM_SlotRequest;
	theLeftRequests: CM_SlotRequestArray;
	aRequest : CM_SlotRequest;
	theReturn : Integer;
	msgString : String;
	tmpSlots	: CM_SlotControllerArray;
	isDischarge	: Boolean;
	tmpDrawController	: SHP_BayDrawingController;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	tmpDrawController := self.myBayDrawingController;
	isDischarge := (self.displayMode = ShpDisplayMode_ColCodeDisch);

	create tmpSlots transient;

	foreach obj in tmpDrawController.allSelectedObjects do
		if (not obj.isKindOf(CM_SlotController)) then
			continue;
		endif;
		tmpSlotController := obj.CM_SlotController;
		
		// PAR 28968
		if tmpSlotController.isLinkedRequest(not isDischarge) then
			tmpSlots.add(tmpSlotController);
		endif;
	
	endforeach;

	if (not tmpSlots.isEmpty) then
		if tmpSlots.size = 1 then
			msgString := "this";
		else
			msgString := "these " &amp; tmpSlots.size.asStringJMT;
		endif;
		theReturn := app.msgBox("Are you sure that you want to de link " &amp; msgString  &amp; " linked request(s)?","Confirm De-Link", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_Yes then
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(tmpSlots, null, tmpDrawController.allObjectEditions, isDischarge, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Linking Requests', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;

		endif;
	endif;

epilog
	delete tmpSlots;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridFlipHClick" id="4fce8117-6ac2-44f2-a14d-0c946cca8804">
