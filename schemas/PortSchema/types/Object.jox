    <JadeMethod name="formatAsJSONValue" id="bca1851e-c8d7-4a81-8579-cae395bcc3d8">
        <source>formatAsJSONValue(pValue : Any) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jan 2013	cnwer1	Initial creation HAT 2189
7 Aug 2019 	jlger1	TFS 45963 - changed to use JadeJSON to format and make sure TimeStamp is returned in UTC format
19 Dec 2023 naviv1	Bug : TFS 61658 - MTN - Cuxport - Outbound Dates not formatted correctly
*/

vars
	jj : JadeJson;
	//tso : TimeStampOffset;	//19.12.2023 naviv1	#61568
begin
	create jj transient;
	
	if pValue.isKindOf(TimeStamp) then
		//tso.setFromLocalTimeStamp(pValue.TimeStamp,tso.getUTCBias);	//19.12.2023 naviv1	#61568
		//return jj.generateJson(tso,JadeJson.Format_Json_Newton);	//19.12.2023 naviv1	#61568
		jj.useISO8601 := true;	//19.12.2023 naviv1	#61568
		return jj.generateJson(pValue.TimeStamp.localToUTCTime,JadeJson.Format_Json_Newton);	//19.12.2023 naviv1	#61568
	endif;
	
	return jj.generateJson(pValue, JadeJson.Format_Json_Newton);
	
	

epilog
	delete jj;

end;</source>
        <Parameter name="pValue" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatAsXML" id="9e6fc25a-fc28-4891-8c46-ccd1f6b0b8e4">
        <source>formatAsXML(pTag, pValue : String) : String;
// ---------------------------------------------------------------------------
// Created:     27 December 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rtnStr	: String;
	
begin

	rtnStr := J_key_LessThan.Character &amp; pTag &amp; J_key_GreaterThan.Character &amp; 
			  pValue &amp; 
			  J_key_LessThan.Character &amp; J_key_Slash.Character &amp; pTag &amp; J_key_GreaterThan.Character &amp; CrLf;

	return rtnStr;
	
end;</source>
        <Parameter name="pTag" type="String"/>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
