    <JadeMethod name="runTest" id="e7a6c061-7a99-49b5-9867-9d029f40db40">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('rr002_VMRF_fldMain_click');
	sa.add('rr002v_VMRF_fldMain_click');
	sa.add('rr004_VMRF_tblJobs_click');
	sa.add('rr004v_VMRF_tblJobs_click');
	sa.add('rr006_VMRF_btnAccept_click');
	sa.add('rr006v_VMRF_btnAccept_click');
	sa.add('rr008_VMRF_btnMsgOK_click');
	sa.add('rr008v_VMRF_btnMsgOK_click');
	sa.add('rr010_VMRF_shtJobs_click');
	sa.add('rr010v_VMRF_shtJobs_click');
	sa.add('rr012_VMRF_fldMain_click');
	sa.add('rr012v_VMRF_fldMain_click');
	sa.add('rr014_VMRF_tblJobs_click');
	sa.add('rr014v_VMRF_tblJobs_click');
	sa.add('rr016_VMRF_btnAccept_click');
	sa.add('rr016v_VMRF_btnAccept_click');
	sa.add('rr018_VMRF_btnMsgOK_click');
	sa.add('rr018v_VMRF_btnMsgOK_click');
	sa.add('rr020_VMRF_btnLogoff_click');
	sa.add('rr024_HHLF_btnExit_click');
	sa.add('rr999_tidyUp');
	app.atcgSetMsgBoxReturn('Are you sure you want to log off?', 'Are you sure?', 1, 1);
	app.atcgSetMsgBoxReturn('Exiting will close this application. Are you sure you wish to exit?', 'Are you sure?', 4, 6);

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
