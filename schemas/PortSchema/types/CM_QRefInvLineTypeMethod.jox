    <JadeMethod name="setComboValues" id="aad72cd7-2cdd-4602-b8a2-ea3d7603d83b">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2014	cnwjre1	Initial creation

*/

vars

	terminal : CM_Terminal;
	termCrit			: CM_SelectorCriteriaLine;
	ut					: CM_UserTerminal;
	obj					: Object;
	os					: ObjectSet;
	bank : CM_Bank;
	invLineType	 : CM_InvoiceLineDesc;
	qrl : CM_QReferenceLookup;
begin
	_combo.clear();
	
	create os transient;
	// 34364 company and invoice types specific to terminal otherwise companies for terminals the user can see
	foreach termCrit in _params.allCriteriaLines do
		if termCrit.myQueryProperty.propertyName = 'myTerminal' or
		   termCrit.myQueryProperty.propertyName = 'getTerminal' then
			termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
			break;
		endif;
	endforeach;
	if os.isEmpty() then
		foreach ut in app.myPassport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;

	foreach obj in os do
		terminal := obj.CM_Terminal;
		foreach bank in terminal.companies discreteLock where bank.isBusinessUnit do
			foreach invLineType in bank.invoiceLineDescriptors discreteLock where not invLineType.isNotAvailableForEntry do
				_combo.itemObject[_combo.addItem( self.translateToDisplayValue(invLineType).String ) ] := invLineType;
			endforeach;
		endforeach;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) and
		   _combo.findObject(qrl.mySelectionValue) &gt; 0 then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;

epilog
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="74690dbd-d791-4cfa-ad86-29c7175e3ab5">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*
Purpose:		TFS 7821	
Date				Who			Reason
NOVEMBER 2017		CNWAB1		Initial creation
*/


vars

	selectionValue : Integer;
	terminal : CM_Terminal;
	bank : CM_Bank;
	idx : Integer;
	termCrit			: CM_SelectorCriteriaLine;
	ut					: CM_UserTerminal;
	obj					: Object;
	os					: ObjectSet;
	invLineType	 : CM_InvoiceLineDesc;
	qrl : CM_QReferenceLookup;
	
begin

	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2;
	
	create os transient;
	foreach termCrit in _params.allCriteriaLines do
		if termCrit.myQueryProperty.propertyName = 'myTerminal' or
		   termCrit.myQueryProperty.propertyName = 'getTerminal' then
			termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
			break;
		endif;
	endforeach;
	if os.isEmpty() then
		foreach ut in app.myPassport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;

	foreach obj in os do
		terminal := obj.CM_Terminal;
		foreach bank in terminal.companies discreteLock where bank.isBusinessUnit do
			foreach invLineType in bank.invoiceLineDescriptors discreteLock where not invLineType.isNotAvailableForEntry do
				selectionValue := 0;
				if _operator &lt;&gt; null and _operator.allSelectionValues.includes(invLineType) then
					selectionValue := 1;
				endif;
				idx := _tbl.addItem( selectionValue.String &amp; Tab &amp; self.translateToDisplayValue(invLineType).String );
				_tbl.accessRow(idx).itemObject := invLineType;
				_tbl.row := idx;
				_tbl.change(_tbl);
			endforeach;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="b4e2b12f-77b9-45d4-874d-2af39e27c4bc">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2014	cnwjre1	Initial creation

*/

vars

	invLineType : CM_InvoiceLineDesc;

begin
	if _value.isKindOf(CM_InvoiceLineDesc) then
		if _value &lt;&gt; null then
			invLineType := _value.CM_InvoiceLineDesc;
			return invLineType.narration &amp; "  [" &amp; invLineType.bank.code &amp; "/" &amp; invLineType.bank.terminal.code &amp; "]";
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="b10c7aa4-97b0-462c-9dbf-43f03fdb12fb">
        <source>translateToSearchValue(_value: Any): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2014	cnwjre1	Initial creation

*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_InvoiceLineDesc) then
			return _value.CM_InvoiceLineDesc;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
