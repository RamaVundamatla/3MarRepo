    <JadeMethod name="getBays" id="7378d894-d4ea-41ca-81b4-712857efd5c9">
        <source>getBays(_bayOne: CM_Bay output; _bayTwo: CM_Bay output);
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	ordinalFirst,
	ordinalLast : Integer;
	cellStructure : CM_CellularVoyageStructure;
begin
	inheritMethod(_bayOne, _bayTwo);
	if _bayOne = null then
		if self.allHatchLids.size = null then
			_bayOne:=self.myVoyage.lookupBayVoyage(self.bayId);
		else
			ordinalFirst:=self.allHatchLids.first.ordinalStartBay;
			ordinalLast:=self.allHatchLids.first.ordinalEndBay;
			if ordinalFirst = ordinalLast then
				ordinalLast:=null;
			endif;
			cellStructure:=self.myVoyage.myCellularVoyageStructure;
			if cellStructure &lt;&gt; null then
				//_bayOne
				_bayOne:=cellStructure.allBayVoyagesByOrdinal[ordinalFirst];
				if ordinalLast &lt;&gt; null then
					_bayTwo:=cellStructure.allBayVoyagesByOrdinal[ordinalLast];
				endif;
			endif;
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_bayOne" type="CM_Bay" usage="output"/>
        <Parameter name="_bayTwo" type="CM_Bay" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCompletedHatchJobTS" id="b26432d2-42b3-463a-abe6-167c3a817050">
        <source>getCompletedHatchJobTS(_jobs : CM_VoyageJobArray input) : TimeStamp;
/*

Purpose:			
TFS4796
Parameters:			

Return Value:		

Date		Who		Reason
12 July 2017	jlgrh7	Initial creation

*/

vars
	selfFound : Boolean;
	job : CM_VoyageJob;
	pJob : CM_VoyageJob;
	isLastJob : Boolean;
	
begin
	self.myJobSheet.getAllJobsForHold(_jobs, self.bayId);	//get jobs in the same Hold
	foreach job in _jobs do
		if job = self then
			selfFound := true;																	
			continue;
		endif;

		if selfFound then
			if job.hasJobStarted then
				return job.actualStartTs;
			endif;
		endif;

		endforeach;
	return null;
epilog
	
end;</source>
        <Parameter name="_jobs" type="CM_VoyageJobArray" usage="input"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5ebb212f-0868-4436-bba9-a5d61e8d3445">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	hatchLid : CM_HatchLid;
	hatchLidStr	: String;
	bay			: CM_Bay;
begin
	
	
	if _attrName = ETRow_TheHatchLids then
		bay	:=self.myVoyage.lookupBayVoyage(self.bayId);
		foreach hatchLid in self.allHatchLids do
			if hatchLidStr = null then
				hatchLidStr:=hatchLid.getDescription(bay);
			else
				hatchLidStr:=hatchLidStr &amp; CrLf &amp; hatchLid.getDescription(bay);
			endif;
		endforeach;
		return hatchLidStr;
	elseif _attrName = ETRow_BayId then
		return self.bayId;	
	else
	
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEstJobTimeForJobStats" id="46e71963-c14b-4aaa-b820-d16727ae2d24">
        <source>getEstJobTimeForJobStats(_crane: CM_Crane; _cmif_JobStats: CMIF_JobStats;_additionalMins : Integer): Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	jobAdditionalMins : Integer;
begin
	if self.myVoyage &lt;&gt; null then
		jobAdditionalMins:=_additionalMins;//self.myVoyage.myTerminal.getConfig(JobAdditionalTime).Integer;
	endif;
	return ((self.estimatedTimeToCompleteMins + jobAdditionalMins) * 60);


epilog

end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_cmif_JobStats" type="CMIF_JobStats"/>
        <Parameter name="_additionalMins" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEstJobTimeUsingCraneRates" id="e4a7df21-fb16-4db8-900f-0a358859724f">
        <source>getEstJobTimeUsingCraneRates(_crane: CM_Crane): Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	jobAdditionalMins : Integer;
begin
	if self.myVoyage &lt;&gt; null then
		jobAdditionalMins:=self.myVoyage.myTerminal.getConfig(JobAdditionalTime).Integer;
	endif;
	return self.estimatedTimeToCompleteMins + jobAdditionalMins;


epilog

end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
