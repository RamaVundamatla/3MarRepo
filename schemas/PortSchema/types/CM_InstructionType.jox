    <JadeMethod name="displayForXlation" id="b60e6eda-75cd-4210-8bfa-84e9cdbbe326">
        <source>displayForXlation(_codeFirst: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 June 2023		jlizm1	Initial creation TFS 58500 add EDI Xlation for Operational Instruction and trailer type

*/

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
	
epilog

end;</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
