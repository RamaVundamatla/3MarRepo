    <JadeMethod name="trxUpdInvStatusToReturned" id="60ec773d-7c81-499c-9b9a-0e1063fd1f6e">
        <updating/>
        <source>trxUpdInvStatusToReturned(	_creditCMIF : CMIF_InvoiceStatus input;
							_creditInv : CM_Invoice output;
							_pendingInv : CM_Invoice output;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

	returningInvoice : CM_Invoice;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	if _creditCMIF &lt;&gt; null then	
		returningInvoice := _creditCMIF.myInvoice;
	endif;
	if returningInvoice = null then
		app.raiseCMException(Invoice_selected,null,null);
		return;
	endif;
	
	if not returningInvoice.allCashPayments.isEmpty then
		app.raiseCMException(Not_return_invoic_that_paymen,null,null);
	endif;

	beginTransaction;
	
	// TFS 39618 PATCH 1 put code in UTIL so can do audits and notification
	app.myUtilityUA.utlUpdInvStatusToReturned(	_creditCMIF,_creditInv,_pendingInv,_passport );
	

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
