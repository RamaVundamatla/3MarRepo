    <JadeMethod name="doResize" id="57c485ee-a45e-4438-9e48-61550e617b9b">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	15 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	self.frmToolbarView.move(0, self.frmToolbar.top+self.frmToolbar.height, self.clientWidth, self.frmToolbarView.height);
	self.lbxVoyageTree.move(0, frmToolbarView.top+frmToolbarView.height, self.clientWidth, self.clientHeight - (frmToolbarView.top+frmToolbarView.height));

end;</source>
    </JadeMethod>
