	self.locked := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doLockLabour" id="73a6eeca-7e87-4dbb-a647-69ff99c8aa5f">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>doLockLabour(theLabour : CM_LabourRestriction) updating, serverExecution;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:	
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.isGap and (self.usage = LIGHT_TOWER_USE or self.usage = BUILDING_USE or self.availability = PAD_UNAVAILABLE) then
		self.locked := true;
		return;
	endif;
/*
	if self.allLabourRestrictions.size &lt;&gt; 0 then
		if self.allLabourRestrictions.includes(theLabour) then
			self.myGridArea.allSelectedPoints.add(self);
		endif;
	endif;
*/
	self.locked := false;

end;</source>
        <Parameter name="theLabour" type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="doLockSubBlock" id="33cef4ac-6313-42f9-9558-d89cf8f52454">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>doLockSubBlock(theSub : CM_BlockStack) updating, serverExecution;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.isGap and (self.usage = LIGHT_TOWER_USE or self.usage = BUILDING_USE or self.availability = PAD_UNAVAILABLE) then
		self.locked := true;
		return;
	endif;

	if self.mySubBlockStack &lt;&gt; null then
		if self.mySubBlockStack = theSub then
			self.locked := false;
			self.myGridArea.allSelectedPoints.add(self);
		else
			self.locked := true;
		endif;
	else
		self.locked := false;
	endif;

end;</source>
        <Parameter name="theSub" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="doSelectDoorDirectionRule" id="bbdd613d-6e3d-455a-9ba0-4bbd120929b0">
        <updating/>
        <source>doSelectDoorDirectionRule( _doorDirectionRule : CM_DoorDirectionRule; _theFrame : CMUI_GridAreaFrame input ) updating;
// ---------------------------------------------------------------------------
// Created:		06/09/2007	By cnwvu1
// ---------------------------------------------------------------------------
vars

begin

	if self.allDoorDirectionRules.size &lt;&gt; 0 then
		if self.allDoorDirectionRules.includes( _doorDirectionRule ) then
			self.myGridArea.allSelectedPoints.add(self);
			self.drawSelf(_theFrame);
		endif;
	endif;

end;
</source>
        <Parameter name="_doorDirectionRule" type="CM_DoorDirectionRule"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSelectHazards" id="f1966abb-ba45-4289-81ea-d75238c5ae70">
        <updating/>
        <source>doSelectHazards(_hazardDetails : CM_TerminalAreaHazDetails; _gridAreaFrame : CMUI_GridAreaFrame input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars

begin
	if self.allHazardDetails.size &lt;&gt; 0 then
		if self.allHazardDetails.includes(_hazardDetails) then
			self.myGridArea.allSelectedPoints.add(self);
			self.drawSelf(_gridAreaFrame);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_hazardDetails" type="CM_TerminalAreaHazDetails"/>
        <Parameter name="_gridAreaFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
