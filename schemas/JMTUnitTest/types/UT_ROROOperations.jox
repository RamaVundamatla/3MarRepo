        <source>moveCargoForVoyageJobExtra(_job: CM_Job);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2012	cnwmc5	Initial creation

*/

vars

begin
	self.moveCargoForVoyageJob(_job, QUEUE_MODE);
