<PrimType name="Any">
    <JadeMethod name="jssIsBetween" id="74033177-da6e-45c8-a8e9-17916557316a">
        <source>jssIsBetween(pLowCriteria:Any; pHighCriteria:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.jssIsGreaterThanOrEqual(pLowCriteria) and self.jssIsLessThanOrEqual(pHighCriteria));
end;</source>
        <Parameter name="pLowCriteria" type="Any"/>
        <Parameter name="pHighCriteria" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsGreaterThan" id="53f645be-df70-4d09-8c6e-7957e37b3999">
        <source>jssIsGreaterThan(pCriteria:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isKindOf(Binary) then
		return (self.Binary &gt; pCriteria.Binary);
	elseif self.isKindOf(Character) then
		return (self.Character &gt; pCriteria.Character);
	elseif self.isKindOf(Date) then
		return (self.Date &gt; pCriteria.Date);
	elseif self.isKindOf(Decimal) then
		return (self.Decimal &gt; pCriteria.Decimal);
	elseif self.isKindOf(Integer) then
		return (self.Integer &gt; pCriteria.Integer);
	elseif self.isKindOf(Real) then
		return (self.Real &gt; pCriteria.Real);
	elseif self.isKindOf(Time) then
		return (self.Time &gt; pCriteria.Time);
	elseif self.isKindOf(TimeStamp) then
		return (self.TimeStamp &gt; pCriteria.TimeStamp);
	else
		return (self.String &gt; pCriteria.String);
	endif;
end;</source>
        <Parameter name="pCriteria" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsGreaterThanOrEqual" id="9b624726-2647-4746-945c-27f1cc0239d9">
        <source>jssIsGreaterThanOrEqual(pCriteria:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isKindOf(Binary) then
		return (self.Binary &gt;= pCriteria.Binary);
	elseif self.isKindOf(Character) then
		return (self.Character &gt;= pCriteria.Character);
	elseif self.isKindOf(Date) then
		return (self.Date &gt;= pCriteria.Date);
	elseif self.isKindOf(Decimal) then
		return (self.Decimal &gt;= pCriteria.Decimal);
	elseif self.isKindOf(Integer) then
		return (self.Integer &gt;= pCriteria.Integer);
	elseif self.isKindOf(Real) then
		return (self.Real &gt;= pCriteria.Real);
	elseif self.isKindOf(Time) then
		return (self.Time &gt;= pCriteria.Time);
	elseif self.isKindOf(TimeStamp) then
		return (self.TimeStamp &gt;= pCriteria.TimeStamp);
	else
		return (self.String &gt;= pCriteria.String);
	endif;
end;</source>
        <Parameter name="pCriteria" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsLessThan" id="406f653b-09ca-4b57-a4f6-e03d9cb69dfe">
