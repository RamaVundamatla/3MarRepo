    <JadeMethod name="showInvoiceLineCollection" id="519e4a3d-41af-450d-8c41-76b77d9cf30c">
        <source>showInvoiceLineCollection(_lines : CM_InvoiceLineBySeqNumDict; _term : CM_Terminal; _masterMenuAction: CMUI_MenuAction);
/*
Purpose:			

Date		Who		Reason
02JUN2021	NAVAB1	TFS 51219
*/

vars
	formCls,
	assistCls	: Class;
	invoiceLineFrm : CM_BaseForm;
	subSys : CMUI_SubSystem;

begin

	subSys := app.myController.allSubSystems['InvoiceSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('INV_ListLines', formCls, assistCls);
	endif;

	if formCls = null then
		return;
	endif;
	
	if _term = null then
		return;
	endif;
	
	if _lines = null 
	or _lines.isEmpty then
		return;
	endif;

	invoiceLineFrm := app.loadForm(formCls, assistCls, false, false, false, _term, _masterMenuAction).CM_BaseForm;

	if invoiceLineFrm = null then
		return;
	endif;	
	
	invoiceLineFrm.showWithObjectMode(_lines, false);

end;</source>
        <Parameter name="_lines" type="CM_InvoiceLineBySeqNumDict"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showInvoiceLineForm" id="7c215c39-74eb-4ace-81a9-c06874569004">
        <source>showInvoiceLineForm(_object : Object; _masterMenuAction : CMUI_MenuAction);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	invoiceForm : Form;
	menuAction : CMUI_MenuAction;
begin

	if _object = null 
	or not (_object.isKindOf(CM_InvoiceLine) or _object.isKindOf(CM_Invoice) or _object.isKindOf(CM_CashPayment)) then
		return;
	endif;
	menuAction := app.myController.createMenuAction(PmAdmInvoicelinesView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null);
	if invoiceForm = null then
		return;
	endif;
	
	if _object.isKindOf(CM_Invoice) then
		invoiceForm.setPropertyValue("myCurrentInvoice", _object.CM_Invoice);
	elseif _object.isKindOf(CM_InvoiceLine) then
		invoiceForm.setPropertyValue("myCurrentInvoiceLine", _object.CM_InvoiceLine);
	elseif _object.isKindOf(CM_CashPayment) then
		invoiceForm.setPropertyValue("myCurrentCashPayment", _object.CM_CashPayment);
	endif;
	invoiceForm.show(); 

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
