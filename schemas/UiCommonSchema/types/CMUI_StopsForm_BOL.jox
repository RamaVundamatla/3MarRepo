    <JadeMethod name="loadStops" id="b3d31219-9416-4ea9-897a-0104000ecb51">
        <updating/>
        <source>loadStops(_bol :CM_BOL)updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table			: CM_DataTable;
	stopTable		: CM_StopsTable;
	passport		: CM_Passport;
	terminal		: CM_Terminal;
	user			: CM_User;
	viewColl, maintColl, 
	cancelColl		: CM_StopsTableByIdDict;
	row, col		: Integer;
	gotException	: Boolean;
	strDate			: String;
	clearanceExpiry	: Date;
begin
	on Exception do app.handleDeletedObject (exception, _bol, gotException);	
	
	// this next statement will cause an exception if _bol has been deleted
	self.expectedEdition := _bol.edition;
	
	if gotException then
		// display message and close form
		self.unloadFormWithMessage;
	endif;

	self.expectedStops	:= self.getStopsString ();	
	passport 			:= app.myPassport;
	user				:= passport.myUser;
	terminal			:= self.myTerminal;
	table				:= self.tblStopsAdd;
	
	table.rows := table.fixedRows;
	
	viewColl 	:= user.getStopsToViewForTerminal(terminal);
	maintColl 	:= user.getStopsToMaintForTerminal(terminal);
	cancelColl 	:= user.getStopsToCancelForTerminal(terminal);
	
	// load stops to be added first
	foreach stopTable in maintColl do
		if not stopTable.isAvailable then
			continue;
		endif;
		if not stopTable.isStopRelevantBOL (_bol) then
			// this stop not relevant for current bol
			continue;
		endif;
		
	//	if _bol.hasStopOfType( stopTable ) then
		if _bol.isStopSet( stopTable.id ) then
			// can't add it again
			continue;
		endif;
		
		strDate := null;
		
		if stopTable.allowClearanceExpiryDate then 
			// stop can have a future clearance expiry
			clearanceExpiry := _bol.getStopClearanceExpiry( stopTable.id );
			
			if clearanceExpiry &lt;&gt; null then
				// stop has a future clearance expiry
				strDate := clearanceExpiry.asStringJMT();
				row := table.addItemObject (stopTable, null.String);	// add this entry with blank details
				
				table.setCellValueByName (ETRow_Heading, row, stopTable.heading);
				table.setCellValueByName (ETRow_ClearanceExpiryDate, row, strDate);
				
				if not self.canUpdate then
					// over ride default of checkbox
					col := table.getColumnByRowName (ETRow_Add);
					
					if col &lt;&gt; null then
						table.accessCell (row, col).inputType 	:= Table.InputType_None;
						table.accessedCell.text					:= null;
					endif;
					
					col := table.getColumnByRowName (ETRow_Update);
					
					if col &lt;&gt; null then
						table.accessCell (row, col).inputType	:= Table.InputType_None;
						table.accessedCell.text					:= null;
					endif;
				endif;
				
				continue;
			endif;
		endif;
			
		row := table.addItemObject (stopTable, null.String); 
				
		table.setCellValueByName (ETRow_Heading, row, stopTable.heading);
		
		if not self.canUpdate then
			// over ride default of checkbox
			col := table.getColumnByRowName (ETRow_Add);
			
			if col &lt;&gt; null then
				table.accessCell (row, col).inputType 	:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
			
			col := table.getColumnByRowName (ETRow_Update);
		
			if col &lt;&gt; null then
				table.accessCell (row, col).inputType	:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
			
		endif;
	endforeach;
	// sort in heading order
	col := table.getColumnByRowName (ETRow_Heading);
	
	if col &lt;&gt; 0 then
		table.sortColumn [1]	:= col;
		table.resort;
	endif;
	
	// now load stops that can be cancelled/deleted
	table 		:= self.tblStopsClear;
	table.rows 	:= table.fixedRows;
	
	foreach stopTable in viewColl do
	//	if not _bol.hasStopOfType( stopTable ) then 
		if not _bol.isStopSet( stopTable.id ) then 
			// it's not set
			continue;
		endif;
		
		row := table.addItemObject (stopTable, null.String);
		
		table.setCellValueByName (ETRow_Heading, row, stopTable.heading);
		
		if stopTable.allowClearanceExpiryDate then
			clearanceExpiry	:= _bol.getStopClearanceExpiry( stopTable.id );
			
			if clearanceExpiry &lt;&gt; null then
				// stop has a clearance expiry date so show it
				strDate	:= clearanceExpiry.asStringJMT();
				table.setCellValueByName( ETRow_ClearanceExpiryDate, row, strDate );
			endif;
		endif;
		
		// check whether user has permission to maintain required infor for this stop
		col := table.getColumnByRowName (ETRow_Clear);
		
		if col &lt;&gt; 0 then
			if self.canUpdate and stopTable.userCanModify(terminal ) then
				table.accessCell (row, col).inputType		:= Table.InputType_CheckBox;
			else
				table.accessCell (row, col).inputType		:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
		endif;
	endforeach;	
	// sort in heading order
	col := table.getColumnByRowName (ETRow_Heading);
	
	if col &lt;&gt; 0 then
		table.sortColumn [1]	:= col	;
		table.resort;
	endif;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="setExpiryDateForRow" id="95afe9b1-f016-4ad2-b32a-7bf6c9b117e5">
        <source>setExpiryDateForRow(_table: CM_DataTable input; _row: Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2015	cnwndl1	Initial creation

*/

vars
	stopsTable	:CM_StopsTable;
	bol			:CM_BOL;
	date		:Date;
begin
	stopsTable	:= _table.accessRow (_row).itemObject.CM_StopsTable;
	bol			:= self.myBOL;
	date 		:= bol.getStopClearanceExpiry( stopsTable.id );
	
	if date &lt;&gt; null then
		_table.setCellValueByName (ETRow_ClearanceExpiryDate, _row, date.asStringJMT);
	else
		_table.setCellValueByName (ETRow_ClearanceExpiryDate, _row, null);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowForAdd" id="24312204-e094-4424-8983-a31a932e64b6">
        <source>setRowForAdd(_table :CM_DataTable input; _row :Integer) protected;
// ---------------------------------------------------------------------------
// Created:     14 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	value	: Boolean;
	col		: Integer;
	
begin
	value	:= _table.getCellValueByName (ETRow_Add, _row).Integer.Boolean;
	
	if value then
		// add and update are mutually exclusive
		col := _table.getColumnByRowName (ETRow_Update);
		
		if col &lt;&gt; null and
			_table.accessCell (_row, col).inputType = Table.InputType_CheckBox then
			_table.setCellValueByName (ETRow_Update, _row, null.String);
		endif;
		// can not change expiry date while adding
		col := _table.getColumnByRowName (ETRow_ClearanceExpiryDate);
		if col &lt;&gt; 0 then
			_table.accessCell (_row, col).inputType := Table.InputType_None;
		endif;
		// make sure expiry date is set to current value for stop
		self.setExpiryDateForRow (_table, _row);

	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowForClear" id="0635dafc-6aa0-40c4-a5ba-17b3dc217071">
        <source>setRowForClear(_table :CM_DataTable input; _row :Integer) protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	value		: Boolean;
	col			: Integer;
	stopsTable	: CM_StopsTable;
	
begin
	value 		:= _table.getCellValueByName( ETRow_Clear, _row ).Integer.Boolean;
	stopsTable	:= _table.accessRow( _row ).itemObject.CM_StopsTable;
	
	if value then
		// cancel, clear and override are mutually exclusive
		self.setTblClearCkboxesAndInputType( ETRow_Clear, _table, _row );
		
		// now set up the allowed data to be entered
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; null then
			if stopsTable.allowClearanceExpiryDate then
				// stop can have a future clearance expiry - so enable input for the cell
				_table.accessCell( _row, col ).inputType	:= Table.InputType_EditMask;
				_table.accessedCell.editMask				:= app.getDateEditMaskForShortFormat;
			else
				_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			endif;
		endif;
	else
		
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; null then
			_table.accessCell( _row, col ).inputType		:= CM_BaseTable.InputType_None;
		endif;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowForUpdate" id="e6a3db17-44ad-46d9-99d9-8b5237a76636">
        <source>setRowForUpdate( _table : CM_DataTable input; _row : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2015	cnwndl1	Initial creation

*/

vars
	value			: Boolean;
	date			: Date;
	col				: Integer;
	overrideStr		: String;						// cnwrl1 30/08/2010 PAR 23697
	overridenReason	: CM_StopOverridenReason;		// cnwrl1 30/08/2010 PAR 23697
	stopsTable		: CM_StopsTable;				// cnwrl1 03/09/2010 PAR 23697
	
begin
	value := _table.getCellValueByName( ETRow_Update, _row ).Integer.Boolean;
	
	if value then
		// add and update are mutually exclusive
		_table.setCellValueByName( ETRow_Add, _row, 0.String );
		
		// can change expiry date while updating
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; null then
			stopsTable	:= _table.accessRow( _row ).itemObject.CM_StopsTable;
			if stopsTable.allowClearanceExpiryDate then
				// stop can have a future clearance expiry - so enable input for the cell
				_table.accessCell( _row, col ).inputType	:= Table.InputType_EditMask;
				_table.accessedCell.editMask				:= app.getDateEditMaskForShortFormat;
			else
				_table.accessCell( _row, col ).cellControl	:= null;
				_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			endif;
		endif;
		
	else
		// can not change expiry date if not updating
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; null then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType		:= Table.InputType_None;
		endif;
		
		// make sure expiry date is set to current value for stop
		self.setExpiryDateForRow( _table, _row );
		
	endif;
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTblClearCkboxesAndInputType" id="a5cd0ded-d38d-47ef-b7bf-25da780254d1">
        <source>setTblClearCkboxesAndInputType(
	_checkboxStr	: String;
	_table			: CM_DataTable input;
	_row			: Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2015	cnwndl1	Initial creation

*/

vars
	col		: Integer;
	
begin
	if _checkboxStr = ETRow_Cancel then
		_table.setCellValueByName( ETRow_Clear, _row, null.String );
		
		col := _table.getColumnByRowName( ETRow_ClearanceExpiryDate );
		if col &lt;&gt; 0 then
			_table.accessCell( _row, col ).cellControl	:= null;
			_table.accessCell( _row, col ).inputType	:= Table.InputType_None;
			// clear any previously setup Expiry Date details
			_table.accessCell( _row, col ).text			:= null;
		endif;
		
	elseif _checkboxStr = ETRow_Clear then
		_table.setCellValueByName( ETRow_Cancel, _row, null.String );
		
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_checkboxStr" type="String"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="16e4eaec-d953-4510-a86a-4e1c13b0635d">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     15 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bol	:CM_BOLIn;
begin
	bol := self.myBOL;
	
	// make sure we have the selecetd TI in our coll
	self.allBOLs.addNoDuplicates (bol, false);

	inheritMethod();

	self.loadStops (bol);
	self.setCaption (bol.number);
	
	self.beginNotification (bol, Object_Update_Event, Response_Continuous, null);
	self.beginNotification (bol, Object_Delete_Event, Response_Continuous, null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8432cbab-9eb5-45e6-8d21-fe2979b73e55">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016219, locale);
end;</source>
    </JadeMethod>
</GUIClass>
