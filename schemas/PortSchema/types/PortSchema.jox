    <JadeMethod name="encryptPassword" id="673e5487-f9e2-438a-a0a9-e8185ec69212">
        <executionLocation>server</executionLocation>
        <source>encryptPassword(pUserCode:String; pPasswordStr : String; pIsNewEncryptionImplemented : Boolean) : Binary serverExecution;
// ---------------------------------------------------------------------------
// Created:		06 April 2001 by cnwdwq1
//
// Purpose:		New one-way encryption algorithm.
//
// Parameters:	pUserCode - The user-code of the person/process that is logging on.
//				pPasswordStr - The password of the person/process.
//				pIsNewEncryptionImplemented - use new method rather than old dll
//
// Returns:		The encrypted password in binary format.
//
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 14/11/2005	cnwdad1		Changed to use the new internal encryption method
//							rather than the old DLL library.
// ---------------------------------------------------------------------------
vars
	binPassword	: Binary[20];
	
begin
	
	return pPasswordStr.encrypt2(pUserCode.getEncryptionKey());
	
	/*
	// PAR 22678 - remove references to pswordhash.dll
	
	if pIsNewEncryptionImplemented then
		return pPasswordStr.encrypt2(pUserCode.getEncryptionKey());
	else
		return pPasswordStr.encrypt();
	endif;
	*/
end;</source>
        <Parameter name="pUserCode" type="String"/>
        <Parameter name="pPasswordStr" type="String"/>
        <Parameter name="pIsNewEncryptionImplemented" type="Boolean"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
