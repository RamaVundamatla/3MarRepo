<Class name="JSSTimeRange" id="04d85c06-7fa8-4512-bb39-bc4f59e2bae9">
    <superclass name="JSSValueRange"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
