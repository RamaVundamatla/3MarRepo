    <JadeMethod name="ediMakeActual" id="9b9f97d9-1dc1-4049-8c9f-27896a188d33">
        <source>ediMakeActual(_ediFile: CM_EDIFile);
//17 December 2008	cnwdw1	
//
vars
	voyage: CM_Voyage;
	ediDataBayPlan: CM_EDIData;
	void: Boolean;
	passportObj	: CM_Passport;
	clear			: Boolean;
	
begin
	ediDataBayPlan := _ediFile.ediData;
	voyage := self.getTerminal.lookupVoyage(ediDataBayPlan.getVoyageCode, null, false);
	passportObj	:=	app.myPassport;
	
	// 25/05/2016 cnwmh5
	if self.opts.includesKey("ClearDetails") then
		clear := true;
	endif;	
	
	app.myTrxUA.trxSetEDIAsActualBayPlan(voyage, ediDataBayPlan.myBayPlanController, clear, void, void, void, void, void, passportObj);
	
	if passportObj.trxCompletedOK() then
		app.myTrxUA.trxSetEDIDataStatus(ediDataBayPlan, CM_EDIFile.EDI_STATUS_MADE_ACTUAL);
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediMakeActualWithMerge" id="7e509de6-4d4e-4409-a7cf-bff9401c6722">
        <source>ediMakeActualWithMerge(_ediFile: CM_EDIFile);
// 20/05/2010	cnwcs5	Do make actual with cargo merge
//
vars
	voyage			: CM_Voyage;
	ediDataBayPlan	: CM_EDIDataBayPlan;
	passportObj		: CM_Passport;
begin
	ediDataBayPlan	:= _ediFile.ediData.CM_EDIDataBayPlan;
	voyage 			:= self.getTerminal.lookupVoyage(ediDataBayPlan.voyageCode, null, false);
	passportObj		:=	app.myPassport;
	
	app.myTrxUA.trxSetEDIAsActualBayPlan(voyage, ediDataBayPlan.myBayPlanController, false, true, false, false, false, false, passportObj);
	
	if passportObj.trxCompletedOK() then
		app.myTrxUA.trxSetEDIDataStatus(ediDataBayPlan, CM_EDIFile.EDI_STATUS_MADE_ACTUAL);
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediReLoadReTranslate" id="6522ffa4-231f-45a6-b182-516c0ac6a8cd">
        <source>ediReLoadReTranslate(_ediFile: CM_EDIFile);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
09 August 2011	cnwmh5	Initial creation
23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
*/

vars
	ediAgent: CM_EDIControllerAgent;
	ediData: CM_EDIData;
	ediFile	: CM_EDIFile;
	result : Boolean;
begin
	create ediAgent transient;
	ediAgent.setTerminal(self.getTerminal());
	ediData := _ediFile.ediData;
	ediFile := ediData.myEDIFile;
	ediAgent.reloadEDIFileForTerminal(ediFile, ediData, app.myPassport);	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete ediAgent;
end;</source>
