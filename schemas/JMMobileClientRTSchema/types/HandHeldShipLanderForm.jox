    <JadeMethod name="btnDamageCancel_click" id="cfc0c50e-aaa4-497b-865d-8777315d1990">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDamageCancel_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.tblDamage.init();

	if self.showingFowardContainer then
		self.doShowFrmFowardCont();
	elseif self.showingAftContainer then
		self.doShowFrmAftCont();
	else
		self.doShowFrmMain();
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
