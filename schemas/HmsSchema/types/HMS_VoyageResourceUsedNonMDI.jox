    <JadeMethod name="doMnuTIEdit" id="7b0373ea-a0de-44c9-add8-232cfc03c2df">
        <updating/>
        <source>doMnuTIEdit(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		17 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		PAR 10973.
//
// ---------------------------------------------------------------------------

vars
	aResUsed		: HMS_ResourceUsed;
	aMove			: HMS_VoyageMovement;
	workingMovement	: CMIF_HMS_WorkingMovement;	
	workingVoyage	: CMIF_HMS_WorkingVoyage;
	firstForm		: Form;
	
begin
	if menuItem.userObject.isKindOf(HMS_ResourceUsed) then
		aResUsed := menuItem.userObject.HMS_ResourceUsed;
		aMove := aResUsed.myVoyageMovement;
	else
		aMove := menuItem.userObject.HMS_VoyageMovement;
	
	endif;
	
	foreach self.myWorkingMovement in self.myViewController.allWorkingMovements do
		if self.myWorkingMovement.myWorkingVoyage.code = aMove.myHMSVoyageData.myVoyage.code then
			if self.myWorkingMovement.moveType = aMove.moveType then
				workingMovement := self.myWorkingMovement.myClone;
				workingVoyage := self.myWorkingMovement.myWorkingVoyage.myClone;
				break;
			endif;
		endif;
	endforeach;
	
//	if app.isVoyageCommodityPlanning then
//		firstForm	:=	app.getForm(HMS_WorkingMovementMaintComalc.name);
//	else
		firstForm	:=	app.getForm(HMS_WorkingMovementMaint.name);
//	endif;
	
	if firstForm &lt;&gt; null then
//		if app.isVoyageCommodityPlanning then
//			firstForm.setPropertyValue('aMode', HMS_WorkingMovementMaintComalc.Mode_Update);
//		else
			firstForm.setPropertyValue('aMode', HMS_WorkingMovementMaint.Mode_Update);
//		endif;
		
		firstForm.unloadForm();
	endif;
	
	if app.getMyUser.canDo(self.myTerminal, PmHMSMovementsMaint) then
		self.myAssistant.HMS_Assistant.showWorkingMovementForm(workingMovement, workingVoyage, (workingMovement &lt;&gt; null), self.myMasterMenuAction, self.myViewController);
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="d90b2ac8-cb37-4af0-ad03-c333181cac4e">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
