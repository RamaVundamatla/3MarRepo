    <JadeMethod name="pwRunSchemaCompare" id="8e0219f3-b651-4e6b-8d2a-c6322fb49192">
        <source>pwRunSchemaCompare();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2021	navpw1	Initial creation TFS: 52202

*/

constants
	SchemaFileName = "100DevSchema8621";
	SchemaFilePath = "\\cnwchcm24\cnwpod$\releases\862\Daily\JadeMaster\schemas";
	SchemaFileExtension = ".scm";
	
vars
	devSourceCompareAgent : DEV_SourceCompareAgent;
	
	
	fileNode				: FileNode;
	folder	: FileFolder;
	
begin
	app.initialize();
	app.changeLogLevel(LogDEBUG);
	
	create devSourceCompareAgent transient;
	
	/*
	**	Multiple File Processing
	*/
	
	create folder transient;
	folder.fileName := SchemaFilePath;
	folder.mask := "*.scm";
	
	if not folder.isAvailable() then
		devSourceCompareAgent.logMessage("Folder " &amp; folder.fileName &amp; " not found, exiting", LogFATAL);
		return;
	endif;
	
	foreach fileNode in folder.files do
		if (not fileNode.isKindOf(FileFolder)) then
			devSourceCompareAgent.doSchemaComparison(fileNode.fileName, fileNode.name.replace(".scm", ""), false, DEV_SourceCompareReport.ReportType_Manual);
		endif;
	endforeach;
	
	/*
	**	Single File Processing
	*/
	
	//devSourceCompareAgent.runComparison(SchemaFilePath, SchemaFileName, SchemaFileExtension);
	
	
	app.msgBox("Finished Processing", "Finished!!", MsgBox_OK_Only);
	
epilog
	delete devSourceCompareAgent;
	delete folder;
end;</source>
    </JadeMethod>
    <JadeMethod name="pwRunSourceCompare" id="74869b46-4e20-46c2-b356-a22562821f95">
        <source>pwRunSourceCompare();

/*

Purpose:			To test source comparison failures or manually run test

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2022	navpw1	Initial creation

*/

constants
	SchemaFilePathDMast = "F:\TeamStuff\PhillipWells\DailyExtracts"; //S11 Daily Extract path
	SchemaFilePathWMast = "\\cnwchcm24\cnwpod$\releases\20021\Daily\JadeMaster\schemas";

vars
	devSourceCompareAgent 	: Object;
	reportAgent				: Object;
	scm 					: Schema;
	cls 					: Class;
	
	fileNode				: FileNode;
	folder					: FileFolder;
	str, 
	concatanatedMessage,
	schemaFilePath			: String;
	logLevel				: Integer;
	
begin
	app.initialize();
	logLevel := app.logLevel; //Get original Log Level as we revert it back at the end of this method to stop garbage being printed
	
	//app.changeLogLevel(LogERROR);
	
	if app.myCnKarmaCntrl.environmentId.toUpper = "NAVDMAST" then //ToDO: Look for a better way to get envId
		schemaFilePath := SchemaFilePathWMast;
	else
		schemaFilePath := SchemaFilePathDMast;
	endif;
	
	scm := rootSchema.getSchema("DevSchema");
	if scm = null then
		app.log("DevSchema not found exiting...");
		return;
	endif;
	
	cls := scm.getClass("DEV_SourceCompareAgent");
	
	if cls = null then
		app.log("DEV_SourceCompareAgent not found exiting...");
		return;
	endif;

	create devSourceCompareAgent as cls transient;
	create folder transient;
	
	folder.fileName := schemaFilePath;
	folder.usePresentationFileSystem := true; //Use clients connection
	folder.mask := "*.scm";
	
	if not folder.isAvailable() then
		devSourceCompareAgent.sendMsgWithParams("logMessage", "Folder " &amp; folder.fileName &amp; " not found, exiting", LogFATAL);
		//self.assertFalse(true);
		write "ASSERT: FALSE";
		return;
	endif;
	
	foreach fileNode in folder.files do
		if (not fileNode.isKindOf(FileFolder)) then
			devSourceCompareAgent.sendMsgWithParams("doSchemaComparison", fileNode.fileName, fileNode.name.replace(".scm", ""), false);
			//break;
		endif;
	endforeach;
	
	devSourceCompareAgent.sendMsgWithParams("setReportAvailable");
	
	concatanatedMessage := devSourceCompareAgent.sendMsgWithParams("getReportOrd").asString();
	
	if concatanatedMessage.length &gt; 0 then
		devSourceCompareAgent.sendMsgWithParams("logMessage", concatanatedMessage, LogERROR);
	endif;
	
	//self.assertFalse(devSourceCompareAgent.getPropertyValue("errorsOccurred").Boolean);
	if devSourceCompareAgent.getPropertyValue("errorsOccurred").Boolean then
		write "ASSERT: FALSE";
	endif;
	//app.changeLogLevel(logLevel);
	
epilog
	delete devSourceCompareAgent;
	delete folder;

end;</source>
    </JadeMethod>
    <JadeMethod name="pwRunSourceCompare7Days" id="3460b676-926b-4c33-ba0b-ddc6e52f618b">
        <source>pwRunSourceCompare7Days();

/*

Purpose:			To test source comparison failures or manually run test

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2022	navpw1	Initial creation

*/

constants
	SchemaFilePathDMast = "F:\TeamStuff\PhillipWells\DailyExtracts"; //S11 Daily Extract path
	SchemaFilePathWMast = "\\cnwchcm24\cnwpod$\releases\20021\Daily\JadeMaster\schemas";
	
vars
	devSourceCompareAgent 	: Object;
	scm 					: Schema;
	cls 					: Class;
	
	fileNode				: FileNode;
	folder					: FileFolder;
	str, 
	concatanatedMessage,
	schemaFilePath			: String;
	logLevel				: Integer;
	
begin
	app.initialize();
	//logLevel := app.logLevel; //Get original Log Level as we revert it back at the end of this method to stop garbage being printed
	
	//app.changeLogLevel(LogERROR);
	
	if app.myCnKarmaCntrl.environmentId.toUpper = "NAVDMAST" then //ToDO: Look for a better way to get envId
		schemaFilePath := SchemaFilePathWMast;
	else
		schemaFilePath := SchemaFilePathDMast;
	endif;
	
	scm := rootSchema.getSchema("DevSchema");
	if scm = null then
		app.log("DevSchema not found exiting...");
		return;
	endif;
	
	cls := scm.getClass("DEV_SourceCompareAgent");
	
	if cls = null then
		app.log("DEV_SourceCompareAgent not found exiting...");
		return;
	endif;

	create devSourceCompareAgent as cls transient;
	create folder transient;
	
	folder.fileName := schemaFilePath;
	folder.usePresentationFileSystem := true; //Use clients connection
	folder.mask := "*.scm";
	
	if not folder.isAvailable() then
		devSourceCompareAgent.sendMsgWithParams("logMessage", "Folder " &amp; folder.fileName &amp; " not found, exiting", LogFATAL);
		//self.assertFalse(true);
		write "ASSERT: FALSE";
		return;
	endif;
	
	foreach fileNode in folder.files do
		if (not fileNode.isKindOf(FileFolder)) then
			devSourceCompareAgent.sendMsgWithParams("doGetRecentlyModified", fileNode.fileName, fileNode.name.replace(".scm", ""), false);
			//break;
		endif;
	endforeach;

	concatanatedMessage := devSourceCompareAgent.sendMsgWithParams("getReport").asString();
	
	if concatanatedMessage.length &gt; 0 then
		devSourceCompareAgent.sendMsgWithParams("logMessage", concatanatedMessage, LogERROR);
	endif;
	
	//self.assertFalse(devSourceCompareAgent.getPropertyValue("errorsOccurred").Boolean);
	if devSourceCompareAgent.getPropertyValue("errorsOccurred").Boolean then
		write "ASSERT: FALSE";
	endif;
		
	//app.changeLogLevel(logLevel);
	
epilog
	delete devSourceCompareAgent;
	delete folder;
end;</source>
    </JadeMethod>
    <JadeMethod name="pwSourceComparisonReportExample" id="469f9a70-e1f4-47cf-83dc-fa577b8701f4">
        <source>pwSourceComparisonReportExample();
/*

Purpose:			An Example of how to use the CM_SourceCompareReport database objects generated by the DEV_SourceCompareAgent

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	myReport 					: DEV_SourceCompareReport;
	devSchema 					: DEV_Schema;
	devGlobalConstantCategory 	: DEV_GlobalConstantCategory;
	devGlobalConstant 			: DEV_GlobalConstant;
	devClass 					: DEV_Class;
	devAttribute 				: DEV_Attribute;
	devConstant 				: DEV_ClassConstant;
	devReference 				: DEV_Reference;
	devMethod 					: DEV_Method;
	
begin
	myReport := DEV_SourceCompareReport.lastInstance();
	
	write "Report Time: " &amp;  myReport.timeStamp.String;
	write "-------------------------------------------------------------------------------------------";
	write "";
	
	write "Missing Global Constant Categories:";
	foreach devSchema in myReport.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Missing do
			write devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp; " - " &amp; devGlobalConstantCategory.modifiedBy &amp;  " | " &amp; devGlobalConstantCategory.modifiedTimeStamp.String;
		endforeach;
	endforeach;
	write "";
		
	write "Missing Global Constants:";
	foreach devSchema in myReport.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devGlobalConstant in devGlobalConstantCategory.allConstants where devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Missing do
				write devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp;  "::" &amp; devGlobalConstant.name &amp; " - " &amp; devGlobalConstant.modifiedBy &amp;  " | " &amp; devGlobalConstant.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
		
	write "Differing Global Constants:";
	foreach devSchema in myReport.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devGlobalConstant in devGlobalConstantCategory.allConstants where devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Different do
				write devSchema.name &amp; "::" &amp; devGlobalConstantCategory.name &amp;  "::" &amp; devGlobalConstant.name &amp; " - " &amp; devGlobalConstant.modifiedBy &amp;  " | " &amp; devGlobalConstant.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
	
	write "Missing Classes:";
	foreach devSchema in myReport.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Missing do
			write devSchema.name &amp; "::" &amp; devClass.name &amp; " - " &amp; devClass.modifiedBy &amp;  " | " &amp; devClass.modifiedTimeStamp.String;
		endforeach;
	endforeach;
	write "";
	
	write "Missing Methods:";
	foreach devSchema in myReport.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devMethod in devClass.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Missing do
				write devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devMethod.name &amp; " - " &amp; devMethod.modifiedBy &amp;  " | " &amp; devMethod.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
	
	write "Different Methods:";
	foreach devSchema in myReport.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devMethod in devClass.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Different do
				write devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devMethod.name &amp; " - " &amp; devMethod.modifiedBy &amp;  " | " &amp; devMethod.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
	
	write "Missing Attributes:";
	foreach devSchema in myReport.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devAttribute in devClass.allAttributes where devAttribute.reason = DEV_SourceCompareReportAgent.Object_Missing do
				write devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devAttribute.name &amp; " - " &amp; devAttribute.modifiedBy &amp;  " | " &amp; devAttribute.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
	
	//Issue with Differing Attributes - Check Comparison might have false positives
	write "Differing Attributes:";
	foreach devSchema in myReport.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devAttribute in devClass.allAttributes where devAttribute.reason = DEV_SourceCompareReportAgent.Object_Different do
				write devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devAttribute.name &amp; " - " &amp; devAttribute.modifiedBy &amp;  " | " &amp; devAttribute.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
	
	write "Missing Constants:";
	foreach devSchema in myReport.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devConstant in devClass.allConstants where devConstant.reason = DEV_SourceCompareReportAgent.Object_Missing do
				write devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devConstant.name &amp; " - " &amp; devConstant.modifiedBy &amp;  " | " &amp; devConstant.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
	
	write "Differing Constants:";
	foreach devSchema in myReport.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devConstant in devClass.allConstants where devConstant.reason = DEV_SourceCompareReportAgent.Object_Different do
				write devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devConstant.name &amp; " - " &amp; devConstant.modifiedBy &amp;  " | " &amp; devConstant.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
	
	write "Missing References:";
	foreach devSchema in myReport.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferences where devReference.reason = DEV_SourceCompareReportAgent.Object_Missing do
				write devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devReference.name &amp; " - " &amp; devReference.modifiedBy &amp;  " | " &amp; devReference.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
	
	write "Differing References:";
	foreach devSchema in myReport.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferences where devReference.reason = DEV_SourceCompareReportAgent.Object_Different do
				write devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devReference.name &amp; " - " &amp; devReference.modifiedBy &amp;  " | " &amp; devReference.modifiedTimeStamp.String;
			endforeach;
		endforeach;
	endforeach;
	write "";
	
	write "End of Report";
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="qNSUpdatePaymentDesc" id="051f061e-dc7f-4237-ad00-cee40214b9c2">
        <source>qNSUpdatePaymentDesc();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2019	jlgma1	Initial creation

*/
vars

	cashPayment 	  : CM_CashPayment;
	paymentOidArr     : StringArray;
	paymentOids	 	  : String;
	invoiceLineDesc   : CM_InvoiceLineDesc;
	invDescStr,
	servStr,
	oid				  : String;
	bank     		  : CM_Bank;
	term	 		  : CM_Terminal;
	service  		  : CM_ServiceObject;
begin
	
	/*
	This script will be used to  update the CM_CashPayment.proDesc with the InvoiceLineDesc.narration
	*/
	term := app.myRoot.allTerminals["CT1"]; 
	bank := term.companies["CT1"];
	
	servStr := "Documentation charges";
//	servStr := "Generator Hire per Hour";
	//servStr := "Port Storage Revenue";
//	servStr := "C- 40' Container de-stuffing and re-stuffing for inspection";
	//servStr := "Reefer Monitoring and power supply";

	paymentOids :="11834.4590031,11834.4629613,11834.4644407";
	
	
	if servStr &lt;&gt; null then
		service := bank.serviceObjects.getAtKeyGeq(servStr);
		if service &lt;&gt; null then
			invoiceLineDesc := service.CM_Service.invoiceLineDescriptions.first.CM_InvoiceLineDesc;
		endif;
	endif;
	
	
	create paymentOidArr transient;
	paymentOids.asStringArrayByDelimiter(paymentOidArr,',');
	
	if invoiceLineDesc &lt;&gt; null then
		foreach  oid in paymentOidArr do
			cashPayment := oid.asOid.CM_CashPayment;
			if cashPayment &lt;&gt; null then
				if cashPayment.proformaDesc &lt;&gt; invoiceLineDesc.narration then
					//Update 
					beginTransaction;
					cashPayment.setPropertyValue("proformaDesc",invoiceLineDesc.narration);
					commitTransaction;
					
				endif;
			endif;
		endforeach;
	endif;
	/*
	beginTransaction;
	cp := "".asOid.CM_CashPayment;

	cp.setPropertyValue("proformaDesc","");
	commitTransaction;
	*/
	
	
	write paymentOidArr.size;
epilog
	delete paymentOidArr;

end;</source>
    </JadeMethod>
    <JadeMethod name="qNsCashV2" id="c64f12fe-8530-4091-9c45-81716a823563">
        <source>qNsCashV2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2019	jlgma1	Initial creation

*/

vars
	lFile      		: File;
	bank 			: CM_Bank;
	term 			: CM_Terminal;
	dateFrom,
	dateTo,
	now				: TimeStamp;
	cashPayment		: CM_CashPayment;
	cr              : CM_CashReceipt;
	proDesc,
	servName,
	searchName,
	servOid,
	invlineName,
	invLineOid		: String;
	service         : CM_ServiceObject;
	invoiceLineDesc : CM_InvoiceLineDesc;
begin
	term := app.myRoot.allTerminals["CT1"]; 
	bank := term.companies["CT1"];
	
	dateFrom.setDate("01/01/2018".Date);
	dateFrom.setTime('00:00:00:000'.Time);
	
	dateTo.setDate("31/01/2018".Date);
	dateTo.setTime('23:59:59:999'.Time);
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\QnsData\Oid\PaymentOid" &amp; term.code &amp;"-" &amp;bank.code &amp;"Jan1801.csv";
    lFile.open;
	lFile.writeLine(
					"Inv Oid"       &amp; "," &amp;
					"CashRec Oid"   &amp; "," &amp;
					"Payment Oid"   &amp; "," &amp;
					"InvSeq" 		&amp; "," &amp; 
					"Created"       &amp; "," &amp;
					"Type"    		&amp; "," &amp; 
					"CashRecSeq"    &amp; "," &amp;
					"Line Desc"     &amp; "," &amp;
					"Total"         &amp; "," &amp;
					"Serv Oid"      &amp; "," &amp;
					"Service"       &amp; ", "&amp;
					"InvLineOid"    &amp; "," &amp;
					"InvLine Desc"  &amp; ","
					);
					
	foreach cr in bank.allCashReceipts do 
		if cr.createdTime &lt;  dateFrom   then
			continue;
		endif;
		
		if cr.createdTime &gt; dateTo then
			continue;
		endif;
		
		foreach cashPayment   in cr.allCashPayments discreteLock  do
				
				if not cashPayment.manual then
					continue;
				endif;
				
				if not cashPayment.getServiceName = null then
					continue;
				endif;
				searchName      := null;
				proDesc  		:= null;
				service  		:= null;
				servOid  		:= null;
				servName 		:= null;
				invoiceLineDesc := null;
				invLineOid 		:= null;
				invlineName     := null;
				
				if cashPayment.proformaDesc.toUpper.cnContains("DOC FEE")	or 
				   cashPayment.proformaDesc.toUpper.cnContains("BAYAN FEES")	or  
				   cashPayment.proformaDesc.toUpper.cnContains("DEC")	or 
				   cashPayment.proformaDesc.toUpper.cnContains("DO")	or 
				   cashPayment.proformaDesc.toUpper.cnContains("DOCU")	or 
				   (cashPayment.proformaDesc[1:3].toUpper="5SI" and cashPayment.cashValue= 20) or 
				   cashPayment.proformaDesc.toUpper.cnContains("DOC") 		then
				   
						searchName := "Documentation charges";
						service := bank.serviceObjects.getAtKeyGeq(searchName);
						
					
				elseif cashPayment.proformaDesc.toUpper.cnContains("GEN SET")   or 
					   cashPayment.proformaDesc.toUpper.cnContains("GENERATOR") or
					   cashPayment.proformaDesc.toUpper.cnContains("GEN") or 
					   cashPayment.proformaDesc.toUpper.cnContains("RG")        then
					   
						searchName := "Generator Hire per Hour";
				elseif cashPayment.proformaDesc.toUpper.cnContains("XRY + RAMBA")   then 
				
					servName := "C- 40' Container de-stuffing and re-stuffing for inspection";
				elseif cashPayment.proformaDesc.toUpper.cnContains("SHORT")   then 
					
					service := null;
				elseif cashPayment.proformaDesc.toUpper.cnContains("STORAGE")   then 
					
					searchName := "Port Storage Revenue";
				else
				
					service := null;
				endif;
				
				if searchName &lt;&gt; null then
					service := bank.serviceObjects.getAtKeyGeq(searchName);
					if service &lt;&gt; null then
						servOid  := service.getOidAsString;
						servName := service.name;
						invoiceLineDesc := service.CM_Service.invoiceLineDescriptions.first.CM_InvoiceLineDesc;
					endif;
					
					if invoiceLineDesc &lt;&gt; null then
						invlineName := invoiceLineDesc.narration;
						invLineOid  := invoiceLineDesc.getOidAsString;
					endif;
				endif;
				
				lFile.writeLine(
							cr.myCashInvoice.getOidAsString                 &amp; "," &amp;
							cr.getOidAsString                               &amp; "," &amp;
							cashPayment.getOidAsString                      &amp; "," &amp;
							cr.myCashInvoice.sequenceNum.String				&amp; "," &amp;
							cr.myCashInvoice.createdTime.asStringJMT     	&amp; "," &amp;
							cr.myCashInvoice.invoiceType.description		&amp; "," &amp;
							cashPayment.getExternalInvoiceNumber      		&amp; "," &amp;
							cashPayment.proformaDesc.cnRemoveChars(",")   	&amp; "," &amp;
							cashPayment.cashValue.String    				&amp; "," &amp;
							servOid                                         &amp; "," &amp;
							servName                                        &amp; "," &amp;
							invLineOid                                      &amp; "," &amp;
							invlineName                                      &amp; "," 
							
						);
						cashPayment := null ;
		endforeach;
		
	endforeach;
  lFile.close;
epilog

	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="qNsCashV3" id="9477006e-7d02-4a29-85de-810428b42760">
        <source>qNsCashV3();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2019	jlgma1	Initial creation

*/


vars
	lFile      		: File;
	bank 			: CM_Bank;
	term 			: CM_Terminal;
	dateFrom,
	dateTo			: TimeStamp;
	cashPayment		: CM_CashPayment;

	servName,
	searchName,
	servOid,
	invlineName,
	invLineOid		: String;
	service         : CM_ServiceObject;
	invoiceLineDesc : CM_InvoiceLineDesc;
	iter			: Iterator;
	cashInv         : CM_Invoice;
	cashRec         : CM_CashReceipt;
	now             : TimeStamp;
begin
	term := app.myRoot.allTerminals["CT1"]; 
	bank := term.companies["CT1"];
	now  := app.actualTimeAppServer;

	
	create lFile transient;
	lFile.fileName := "C:\TEMP\QnsData\Oid\Payments" &amp; term.code &amp;'.'&amp;bank.code &amp; 
						now.Date.year.String  &amp;
						now.Date.month.padLeadingWith("0",2) &amp;
						now.Date.day.padLeadingWith("0",2)   &amp;
						now.Time.hour.padLeadingWith("0",2)  &amp;
						now.Time.minute.padLeadingWith("0",2)&amp;
						".csv";
    lFile.open;
	lFile.writeLine(
					"Term "         		&amp; "," &amp;
					"Bank"          		&amp; "," &amp;
					"Payment Date"    		&amp; "," &amp;
 					"Receipt No"    		&amp; "," &amp;
					"Debtor "       		&amp; "," &amp;
					"Invoice Type"			&amp; "," &amp; 
					"Invoice No"    		&amp; "," &amp;
					"Payment Desc"  		&amp; "," &amp;
					"Payment Amount"		&amp; "," &amp;
					"Service"       		&amp; "," &amp;
					"Invoice Line Type" 	&amp; "," &amp;
					"Receipt Oid"   		&amp; "," &amp;
					"Invoice Oid"   		&amp; "," &amp;
					"Payment Oid" 		    &amp; "," &amp; 
					"Service Oid"     		&amp; "," &amp;
					"Invvoice Line Type Oid" 
				
					);
					

	dateFrom.setDate("01/01/2018".Date);
	dateFrom.setTime('00:00:00:000'.Time);
	
	dateTo.setDate("31/01/2018".Date);
	dateTo.setTime('23:59:59:999'.Time);
	
	iter:=term.allCashPayments.createIterator;
	term.allCashPayments.startKeyGeq(dateFrom,iter);
	
	while iter.next(cashPayment) do
	
	
		if cashPayment.dateTime &lt;  dateFrom   then
			continue;
		endif;
			
			if cashPayment.getBank &lt;&gt; bank then
				continue;
			endif;
			if cashPayment.dateTime &gt; dateTo then
				break;
			endif;
	
			if not cashPayment.manual then
				continue;
			endif;
			
			if not cashPayment.getServiceName = null then
				continue;
			endif;
			
			
			cashInv         := null;
			cashRec         := null;
			service  		:= null;
			searchName      := null;
			servName 		:= null;
			invoiceLineDesc := null;
			invLineOid 		:= null;
			servOid  		:= null;
			invlineName     := null;
			
			/*Mapping */
			if cashPayment.proformaDesc &lt;&gt; null then
				if cashPayment.proformaDesc.toUpper.cnContains("DOC FEE")		or 
				   cashPayment.proformaDesc.toUpper.cnContains("BAYAN FEES")	or  
				   cashPayment.proformaDesc.toUpper.cnContains("BAYAN")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("DEC")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("DO")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("DOCU")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("DOC")          or
				   cashPayment.proformaDesc.toUpper.cnContains("DCO")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("BAYAN FEE ONLY")or 
				   (cashPayment.proformaDesc[1:3].toUpper="5SE" and cashPayment.cashValue= 20) or 
				   (cashPayment.proformaDesc[1:3].toUpper="5SI" and cashPayment.cashValue= 20) or 
				   (cashPayment.proformaDesc[1:3].toUpper="5SR" and cashPayment.cashValue= 20) then
				   
						searchName := "Documentation charges";
					
				elseif cashPayment.proformaDesc.toUpper.cnContains("GEN SET")   or 
					   cashPayment.proformaDesc.toUpper.cnContains("GENERATOR") or
					   cashPayment.proformaDesc.toUpper.cnContains("GEN") 		or 
					   cashPayment.proformaDesc.toUpper.cnContains("RG")        then
					   
						searchName := "Generator Hire per Hour";
				elseif cashPayment.proformaDesc.toUpper.cnContains("XRY + RAMBA")   then 
				
						searchName := "C- 40' Container de-stuffing and re-stuffing for inspection";
				elseif cashPayment.proformaDesc.toUpper.cnContains("SHORT")   then 
					
						searchName := null;
				elseif cashPayment.proformaDesc.toUpper.cnContains("STORAGE")   then 
					
					searchName := "Port Storage Revenue";
				else
				
					searchName := null;
				endif;
			endif;
			
			if searchName &lt;&gt; null then
				service := bank.serviceObjects.getAtKeyGeq(searchName);
				if service &lt;&gt; null then
					servOid  := '-' &amp; service.getOidAsString &amp;'-';
					servName := service.name;
					invoiceLineDesc := service.CM_Service.invoiceLineDescriptions.first.CM_InvoiceLineDesc;
				endif;
				
				if invoiceLineDesc &lt;&gt; null then
					invlineName := invoiceLineDesc.narration;
					invLineOid  :=  '-' &amp;invoiceLineDesc.getOidAsString &amp;'-';
					if cashPayment.proformaDesc &lt;&gt; invoiceLineDesc.narration then
						
						/*
						//Update 
						beginTransaction;
						cashPayment.setPropertyValue("proformaDesc",invoiceLineDesc.narration);
						commitTransaction;
						*/
					endif;
				endif;
			endif;
			
			cashRec := cashPayment.myCashReceipt;
			if cashRec &lt;&gt; null then
			
				cashInv := cashPayment.myCashReceipt.myCashInvoice;
			
			endif;
			
			lFile.writeLine(
					cashPayment.getTerminal.code                &amp; "," &amp;
					cashPayment.getBankCode                    	&amp; "," &amp;
					cashPayment.createdTime.asStringJMT     	&amp; "," &amp;
					cashRec.externalInvoiceNumber				&amp; "," &amp;
					cashPayment.getDebtor.name 					&amp; "," &amp;                               	
					cashInv.invoiceType.description 			&amp; "," &amp;
					cashInv.sequenceNum.String					&amp; "," &amp;
					cashPayment.proformaDesc.cnRemoveChars(",") &amp; "," &amp;
					cashPayment.cashValue.String                &amp; "," &amp;
					servName                                    &amp; "," &amp;
					invlineName                                	&amp; "," &amp;
					'-'&amp; cashRec.getOidString     &amp;'-'          &amp; "," &amp;
					'-'&amp; cashInv.getOidString     &amp;'-' 	        &amp; "," &amp;
					'-'&amp; cashPayment.getOidString &amp;'-'          &amp; "," &amp;
					servOid										&amp; "," &amp;
					invLineOid                                      				 	
					);
					
			
	endwhile;
	
  lFile.close;
epilog

	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="qNsCashV4" id="e13e0309-4ed1-4ba3-8268-bd4a5c2caf15">
        <source>qNsCashV4();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2019	jlgma1	Initial creation

*/

vars
	lFile      		: File;
	bank 			: CM_Bank;
	term 			: CM_Terminal;
	dateFrom,
	dateTo			: TimeStamp;
	cashPayment		: CM_CashPayment;

	servName,
	searchName,
	servOid,
	invlineName,
	invLineOid		: String;
	service         : CM_ServiceObject;
	invoiceLineDesc : CM_InvoiceLineDesc;
	iter			: Iterator;
	cashInv         : CM_Invoice;
	cashRec         : CM_CashReceipt;
	now             : TimeStamp;
	lineQty             : Real;
	proQty          : Real;
begin
	term := app.myRoot.allTerminals["CT1"]; 
	bank := term.companies["CT1"];
	now  := app.actualTimeAppServer;

	
	create lFile transient;
	lFile.fileName := "C:\TEMP\QnsData\Oid\PaymentsService" &amp; term.code &amp;'.'&amp;bank.code &amp; 
						now.Date.year.String  &amp;
						now.Date.month.padLeadingWith("0",2) &amp;
						now.Date.day.padLeadingWith("0",2)   &amp;
						now.Time.hour.padLeadingWith("0",2)  &amp;
						now.Time.minute.padLeadingWith("0",2)&amp;
						".csv";
    lFile.open;
	lFile.writeLine(
					"Term "         		&amp; "," &amp;
					"Bank"          		&amp; "," &amp;
					"Payment Date"    		&amp; "," &amp;
 					"Receipt No"    		&amp; "," &amp;
					"Debtor "       		&amp; "," &amp;
					"Invoice Type"			&amp; "," &amp; 
					"Invoice No"    		&amp; "," &amp;
					"Payment Desc"  		&amp; "," &amp;
					"Payment Amount"		&amp; "," &amp;
					"Service"       		&amp; "," &amp;
					"Invoice Line Type" 	&amp; "," &amp;
					"Receipt Oid"   		&amp; "," &amp;
					"Invoice Oid"   		&amp; "," &amp;
					"Payment Oid" 		    &amp; "," &amp; 
					"Service Oid"     		&amp; "," &amp;
					"Invvoice Line Type Oid"&amp; "," &amp;
					"Get Service Name"      &amp; "," &amp;
					"Get Serviice Group"    &amp; "," &amp;
					"Get GL Code"           &amp; "," &amp;
					"InvLine Qty"      		&amp; "," &amp;      
					"Proforma Qty"
					);
					

	dateFrom.setDate("01/01/2018".Date);
	dateFrom.setTime('00:00:00:000'.Time);
	
	dateTo.setDate("31/01/2018".Date);
	dateTo.setTime('23:59:59:999'.Time);
	
	iter:=term.allCashPayments.createIterator;
	term.allCashPayments.startKeyGeq(dateFrom,iter);
	
	while iter.next(cashPayment) do
	
	
				
			if cashPayment.getBank &lt;&gt; bank then
				continue;
			endif;
			if cashPayment.myCashReceipt.dateTime &gt; dateTo then
				break;
			endif;
		/*
			if not cashPayment.manual then
				continue;
			endif;
			*/
			/*
			if not cashPayment.getServiceName = null then
				continue;
			endif;
			*/
			
			cashInv         := null;
			cashRec         := null;
			service  		:= null;
			searchName      := null;
			servName 		:= null;
			invoiceLineDesc := null;
			invLineOid 		:= null;
			servOid  		:= null;
			invlineName     := null;
			lineQty         := null;
			proQty          := null;
			
			/*Mapping */
			/*
			if cashPayment.proformaDesc &lt;&gt; null then
				if cashPayment.proformaDesc.toUpper.cnContains("DOC FEE")		or 
				   cashPayment.proformaDesc.toUpper.cnContains("BAYAN FEES")	or  
				   cashPayment.proformaDesc.toUpper.cnContains("BAYAN")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("DEC")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("DO")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("DOCU")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("DOC")          or
				   cashPayment.proformaDesc.toUpper.cnContains("DCO")			or 
				   cashPayment.proformaDesc.toUpper.cnContains("BAYAN FEE ONLY")or 
				   (cashPayment.proformaDesc[1:3].toUpper="5SE" and cashPayment.cashValue= 20) or 
				   (cashPayment.proformaDesc[1:3].toUpper="5SI" and cashPayment.cashValue= 20) or 
				   (cashPayment.proformaDesc[1:3].toUpper="5SR" and cashPayment.cashValue= 20) then
				   
						searchName := "Documentation charges";
					
				elseif cashPayment.proformaDesc.toUpper.cnContains("GEN SET")   or 
					   cashPayment.proformaDesc.toUpper.cnContains("GENERATOR") or
					   cashPayment.proformaDesc.toUpper.cnContains("GEN") 		or 
					   cashPayment.proformaDesc.toUpper.cnContains("RG")        then
					   
						searchName := "Generator Hire per Hour";
				elseif cashPayment.proformaDesc.toUpper.cnContains("XRY + RAMBA")   then 
				
						searchName := "C- 40' Container de-stuffing and re-stuffing for inspection";
				elseif cashPayment.proformaDesc.toUpper.cnContains("SHORT")   then 
					
						searchName := null;
				elseif cashPayment.proformaDesc.toUpper.cnContains("STORAGE")   then 
					
					searchName := "Port Storage Revenue";
				else
				
					searchName := null;
				endif;
			endif;
			
			if searchName &lt;&gt; null then
				service := bank.serviceObjects.getAtKeyGeq(searchName);
				if service &lt;&gt; null then
					servOid  := '-' &amp; service.getOidAsString &amp;'-';
					servName := service.name;
					invoiceLineDesc := service.CM_Service.invoiceLineDescriptions.first.CM_InvoiceLineDesc;
				endif;
				
				if invoiceLineDesc &lt;&gt; null then
					invlineName := invoiceLineDesc.narration;
					invLineOid  :=  '-' &amp;invoiceLineDesc.getOidAsString &amp;'-';
					
				endif;
			endif;
			*/
			cashRec := cashPayment.myCashReceipt;
			if cashRec &lt;&gt; null then
				cashInv := cashPayment.myCashReceipt.myCashInvoice;
			endif;
			
			
			if cashPayment.myInvoiceLine &lt;&gt; null then
				lineQty := cashPayment.myInvoiceLine.quantity;
			endif;
			
			if cashPayment.myProformaDetail &lt;&gt; null then
				proQty := cashPayment.myProformaDetail.quantity;
			endif;
			
			lFile.writeLine(
					cashPayment.getTerminal.code                &amp; "," &amp;
					cashPayment.getBankCode                    	&amp; "," &amp;
					cashPayment.dateTime.asStringJMT     	&amp; "," &amp;
					cashRec.externalInvoiceNumber				&amp; "," &amp;
					cashPayment.getDebtor.name 					&amp; "," &amp;                               	
					cashInv.invoiceType.description 			&amp; "," &amp;
					cashInv.sequenceNum.String					&amp; "," &amp;
					cashPayment.proformaDesc.cnRemoveChars(",") &amp; "," &amp;
					cashPayment.cashValue.String                &amp; "," &amp;
					servName                                    &amp; "," &amp;
					invlineName                                	&amp; "," &amp;
					'-'&amp; cashRec.getOidString     &amp;'-'          &amp; "," &amp;
					'-'&amp; cashInv.getOidString     &amp;'-' 		    &amp; "," &amp;
					'-'&amp; cashPayment.getOidString &amp;'-'          &amp; "," &amp;
					servOid										&amp; "," &amp;
					invLineOid                                  &amp; "," &amp;
  				 	cashPayment.getServiceName                  &amp; "," &amp;
					cashPayment.getServiceGroupName             &amp; "," &amp;
					cashPayment.getServiceGLCode                &amp; "," &amp;
					lineQty.String                              &amp; "," &amp;
					proQty.String
					);
							
	endwhile;
	
  lFile.close;
epilog

	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="qns2" id="a930701e-fa50-45ad-8a33-d6de9ef2ad0e">
        <source>qns2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2019	jlgma1	Initial creation

*/

vars
cmif 			: CMIF_SAPWSRequest;
	estimationID    : String;
	invLine			: CM_InvoiceLine;
	strArr          : StringArray;
	estID           : String;
	invoice         : CM_Invoice;
	term 			: CM_Terminal;
	bank 			: CM_Bank;
	lFile      		: File;
	cashPayment		: CM_CashPayment;
	cnt :           Integer;
	dict		: CM_InvoiceByToDTStatusDict;
	iter 		: Iterator;
	dateFrom,
	dateTo,
	now			: TimeStamp;
	obj			: Object;
		inv			: CM_Invoice;
begin
	term := app.myRoot.allTerminals["CASH"]; 
	bank := term.companies["MILA"];
	create lFile transient;
	lFile.fileName := "C:\TEMP\InvData" &amp; term.code &amp;".csv";
    lFile.open;
	lFile.writeLine(
					"Inv Seq" 		&amp; "," &amp; 
					"Created"       &amp; "," &amp;
					"Type"    		&amp; "," &amp; 
					"Debtor"  		&amp; "," &amp;
					"Line Seq"	    &amp; "," &amp;
					"Line Desc"     &amp; "," &amp;
					"Total"         &amp; "," &amp;
					"Cargo"       
					);
					
	dateFrom.setDate("01/01/2018".Date);
	dateFrom.setTime('00:00:00:000'.Time);
	
	
	dateTo.setDate("31/12/2019".Date);
	dateTo.setTime('23:59:59:999'.Time);
	
	dict := bank.allInvoicesByToDate;
	iter := dict.createIterator();
	dict.startKeyGeq(term, bank, dateFrom, null, null, iter);
	
	while iter.next(obj) do
		inv := obj.CM_Invoice;
		
		if inv.toDT.date &gt; dateTo.date then
			break;
		endif;
		/*
		if not inv.invoiceType.description ="Cash" then
			continue;
		endif;
		*/
		if inv.allCashPayments.isEmpty then
			continue;
		endif;
		
		foreach cashPayment   in inv.allCashPayments discreteLock  where cashPayment.myInvoiceLine = null do
								
			if not cashPayment.manual then
				continue;
			endif;
		
			lFile.writeLine(
						inv.sequenceNum.String		&amp; "," &amp;
						inv.createdTime.asStringJMT     	&amp; "," &amp;
						inv.invoiceType.description	&amp; "," &amp;
						invoice.getDebtor.name        			  &amp; "," &amp;
						cashPayment.getExternalInvoiceNumber      &amp; "," &amp;
						cashPayment.proformaDesc.cnRemoveChars(",")    	&amp; "," &amp;
						cashPayment.cashValue.String    &amp; "," &amp;
						cashPayment.getCargoDetails.cnRemoveChars(",")
					);
		endforeach;
		
	endwhile;
	
	  lFile.close;
epilog

	delete lFile;
		delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="qnsCash" id="d67e256b-1dfe-4ebd-b26c-412e1d605ab6">
        <source>qnsCash();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2017	jlgma1	Initial creation

*/

vars
	ts : TimeStamp;
	date: Date;
	time :Time;
	cp : CM_CashPayment;
	cr : CM_CashReceipt;
	i : Integer;
begin
	date := "01/09/2017".Date;
	time := "00:00:00.000".Time;
	ts.setDate(date);
	ts.setTime(time);
	foreach cr in CM_CashReceipt.instances where cr.dateTime &gt; ts do
		
		i := i+1;
	endforeach;
	
	app.msgBox("Total Cash Payment :"&amp; i.String,"",0);

	/*
	foreach cp in CM_CashPayment.instances where cp.dateTime &gt; ts do
		
		i := i+1;
	endforeach;
	
	app.msgBox("Total Cash Payment :"&amp; i.String,"",0);
	*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="qnsCashFind" id="97e7d063-ff54-4e69-8041-96bfd2f58300">
        <source>qnsCashFind();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2017	jlgma1	Initial creation

*/

vars
	cr ,prevCR: CM_CashReceipt;
	strCash,prevCash : String;
	ts : TimeStamp;
	lFile : File;
	date : Date;
	time : Time;
	diff : Integer;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\QNS\QQ1.csv";
	lFile.open;
	
	date := "01/01/2017".Date;
	time := "00:00:00.000".Time;
	ts.setDate(date);
	ts.setTime(time);
	
	foreach cr in CM_CashReceipt.instances reversed   do
		strCash := null;
		if cr.dateTime &lt;= ts then
			break;
		endif;
		
		if  cr.myTerminal.code &lt;&gt; "CT1" then
			continue;
		endif;
		
		strCash := cr.externalInvoiceNumber[9:6];
		
		prevCR := cr;
		if prevCR &lt;&gt; null then
			prevCash :=prevCR.externalInvoiceNumber[9:6];
			diff :=  strCash.Integer - prevCash.Integer;
		endif;
		
		
			write strCash;
			lFile.writeLine(cr.dateTime.String &amp;","&amp; cr.myTerminal.code  &amp;","&amp; cr.externalInvoiceNumber  &amp;","&amp;  strCash &amp;"," &amp; diff.String);
	
	endforeach;
		
	lFile.close;
	delete lFile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="qnsFixVoid" id="dfbb3237-2eb5-4dbe-b8b7-a589a3411fde">
        <source>qnsFixVoid();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2019	jlgma1	Initial creation

*/


vars

	cashPayment 	  : CM_CashPayment;
	paymentOidArr     : StringArray;
	paymentOids	 	  : String;
	invoiceLineDesc   : CM_InvoiceLineDesc;
	invDescStr,
	servStr,
	oid				  : String;
	bank     		  : CM_Bank;
	term	 		  : CM_Terminal;
	service  		  : CM_ServiceObject;
	profroma          : CM_ProformaDetails;
begin
	
	/*
	This script will be used to  update the CM_CashPayment.proDesc with the InvoiceLineDesc.narration
	*/
	term := app.myRoot.allTerminals["CT1"]; 
	bank := term.companies["CT1"];
	
	servStr := "Documentation charges";
	//servStr := "Generator Hire per Hour";
	//servStr := "Port Storage Revenue";
	//servStr := "C- 40' Container de-stuffing and re-stuffing for inspection";
	//servStr := "Reefer Monitoring and power supply";

	paymentOids :="11834.4590031,11834.4629613,11834.4644407";



	if servStr &lt;&gt; null then
		service := bank.serviceObjects.getAtKeyGeq(servStr);
		if service &lt;&gt; null then
			invoiceLineDesc := service.CM_Service.invoiceLineDescriptions.first.CM_InvoiceLineDesc;
		endif;
	endif;
	
	
	create paymentOidArr transient;
	paymentOids.asStringArrayByDelimiter(paymentOidArr,',');
	
	if invoiceLineDesc &lt;&gt; null then
		foreach  oid in paymentOidArr do
			cashPayment := oid.asOid.CM_CashPayment;
			if cashPayment &lt;&gt; null then
				if cashPayment.myProformaDetail &lt;&gt; null then
					if cashPayment.myProformaDetail.myInvoiceLineType &lt;&gt; null then
						if cashPayment.myProformaDetail.myInvoiceLineType.isVoid then
							profroma := cashPayment.myProformaDetail;
							beginTransaction;
							profroma.setPropertyValue("myInvoiceLineType",invoiceLineDesc);
							commitTransaction;
						endif;
					endif;
				else
					beginTransaction;
					cashPayment.setPropertyValue("proformaDesc",invoiceLineDesc.narration);
					commitTransaction;
				
				
				endif;
				
				/*
					//Update 
					beginTransaction;
					cashPayment.setPropertyValue("proformaDesc",invoiceLineDesc.narration);
					commitTransaction;
					*/
				
			endif;
		endforeach;
	endif;
	/*
	beginTransaction;
	cp := "".asOid.CM_CashPayment;

	cp.setPropertyValue("proformaDesc","");
	commitTransaction;
	*/
	
	
	write paymentOidArr.size;
epilog
	delete paymentOidArr;

end;</source>
    </JadeMethod>
    <JadeMethod name="rel851_tfs3042" id="3a8ad243-8590-4e31-bc6d-e0a4fcb2027c">
        <source>rel851_tfs3042();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/0/12017	cnwdap1		Initial creation TFS 3042 Empty Container Pool Management
//
vars
	debtorType : CM_DebtorType;

begin
	// create the new Debtor Type of "Empty Pool Party"
	beginTransaction;
	create debtorType;
	debtorType.setForCreateParam("SDT0", "Empty Pool Party");
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="releaseListClassesToDelete" id="fa54bec8-1ea3-4c3c-b53a-50a0d0e37b3c">
        <source>releaseListClassesToDelete();
// ---------------------------------------------------------------------------
// Created:     Jan 2005 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	count1,count2,i,j: Integer;
	startTime,finTime: TimeStamp;
	clss: Class;
	txt: String;
begin
	app.initialize();
	app.setSpecial('31/12/3000'.TimeStamp);
	startTime := app.actualTimeServer;							// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeStatement(app.actualTimeServer.String&amp;" start.");	// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach clss in currentSchema.allClasses do
		txt := clss.text.toLower.removeTabCrLfs;
		if txt.pos("remove after",1) &lt;&gt; null or 
		   txt.pos("delete after",1) &lt;&gt; null or
		   txt.pos("remove when",1) &lt;&gt; null or
		   txt.pos("delete when",1) &lt;&gt; null or
		   txt.pos("remove in",1) &lt;&gt; null or
		   txt.pos("delete in",1) &lt;&gt; null or
		   txt.pos("remove before",1) &lt;&gt; null or
		   txt.pos("delete before",1) &lt;&gt; null or
		   txt.pos("no longer used",1) &lt;&gt; null or
		   txt.pos("redundant",1) &lt;&gt; null or 
//		   txt.pos("remove",1) &lt;&gt; null or 
		   txt.pos("to be deleted", 1) &lt;&gt; null or
		   txt.pos("obsolete",1) &lt;&gt; null then 
			count2 := count2 + 1;
			app.writeStatement(clss.name&amp;' : '&amp;clss.numScriptRefs.String&amp;' : '&amp;clss.text.removeTabCrLfs);
//			if count2 &gt; 500 then
//				return;
//			endif;
		endif;
//		if count1 &gt; 100 then
//			return;
//		endif;
	endforeach;
	app.writeStatement(app.actualTimeServer.String&amp;" fin.");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
end;</source>
    </JadeMethod>
    <JadeMethod name="releaseListPropertiesToDelete" id="9bdeec4e-980a-40a1-8812-f6e9e8be9448">
        <source>releaseListPropertiesToDelete();
// ---------------------------------------------------------------------------
// Created:     Jan 2005 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	
	property:Property;
	count1,count2,i,j: Integer;
	startTime,finTime: TimeStamp;
	clss: Class;
	txt: String;
	pNDict: PropertyNDict;
begin
	app.initialize();
	app.setSpecial('31/12/3000'.TimeStamp);
	startTime := app.actualTimeServer;							// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeStatement( app.actualTimeServer.String&amp;" start.");	// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	create pNDict transient;
	foreach clss in currentSchema.allClasses do
		pNDict.clear;
		clss.getPropertiesOnlyInSuperclass(pNDict);
		count1 := count1 + 1;
		foreach property in clss.allProperties do
			if pNDict.includes(property) then
				continue;
			endif;
			txt := property.text.toLower.removeTabCrLfs;
			if txt.pos("remove after",1) &lt;&gt; null or 
			   txt.pos("delete after",1) &lt;&gt; null or
			   txt.pos("remove when",1) &lt;&gt; null or
			   txt.pos("delete when",1) &lt;&gt; null or
			   txt.pos("remove in",1) &lt;&gt; null or
			   txt.pos("delete in",1) &lt;&gt; null or
			   txt.pos("remove before",1) &lt;&gt; null or
			   txt.pos("delete before",1) &lt;&gt; null or
			   txt.pos("no longer used",1) &lt;&gt; null or
			   txt.pos("replaced with",1) &lt;&gt; null or 
			   txt.pos("redundant",1) &lt;&gt; null or 
			   txt.pos("to be deleted", 1) &lt;&gt; null or
			   txt.pos("obsolete",1) &lt;&gt; null then 
				count2 := count2 + 1;
				app.writeStatement( clss.name&amp;' : '&amp;property.name&amp;' : '&amp;property.numScriptRefs.String&amp;' : '&amp;property.text.removeTabCrLfs);
//				if count2 &gt; 500 then
//					return;
//				endif;
			endif;
		endforeach;
//		if count1 &gt; 100 then
//			return;
//		endif;
	endforeach;
