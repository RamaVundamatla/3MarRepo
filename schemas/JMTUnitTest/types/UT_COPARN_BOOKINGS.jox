    <JadeMethod name="tCoparnPILFTX" id="b44bf6ae-17c6-4ae0-8a06-813410ef0a79">
        <source>tCoparnPILFTX();
// cnwrs1
// cnwcs5 par 31942
// CCMS 2220
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
constants
	ShipName 	= "PIL2220a";
	VoyageName 	= "PIL2220VOY";
	BookingNo1 	= "PIL2220a";	
	BookingNo2 	= "PIL2220b";
	BookingNo3 	= "PIL2220C";
	PARTY		= 'PIL';
	SENDER1		= 'PILNZ';
	SENDER2		= 'PIL';
	REMARKS1	= 'REMARKS 1';
	REMARKS2	= 'REMARKS 2';
	REMARKS3	= 'REMARKS 3';
vars
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	ediFile 		: CM_EDIFile;
	booking 		: CM_BookingRef;
	bookingItem		: CM_BookingRefItem;
	text 			: String;
	tempStr 		: String;
	bookingItems 	: Integer;
	ediParty		: CM_EDIParty;
	rules			: CM_EDIPartyCoparnRules;
	code			: String;
	operator		: CM_Operator;
begin
	code 		:= self.getTerminal.code;
	operator	:= app.myRoot.allOperators ['PIL']; 
	
	self.assertNotNull (operator);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	
	self.deleteBooking(BookingNo1);
	self.deleteBooking(BookingNo2);
	
	vessel := self.addVesselCellular(ShipName, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, 'PIL', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg (voyage, "Add voyage failed");

	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, true);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;

	self.setTerminalConfig(EdiBookingCommodity, true); 

	text := "UNA:+.? '
UNB+UNOA:1+" &amp; SENDER1 &amp; "+NZWLGT01+20130415:0933+003780'
UNH+003780+COPARN:D:00B:UN'
BGM+104+" &amp; BookingNo1 &amp; "+9'
DTM+7:201304150933:203'
RFF+BN:" &amp; BookingNo1 &amp; "'
TDT+20+"&amp;VoyageName&amp;"+1+++++9323041:146:11:MOL WINTER'
RFF+VON:"&amp;VoyageName&amp;"'
LOC+9+NZNPE:139:6'
LOC+11+SGSIN:139:6'
NAD+CA+PIL'
NAD+OY++GARRA INTERNATIONAL LTD'
EQD+CN++25R1:102:5+1+2+5'
RFF+SQ:1'
EQN+1'
LOC+9+NZNPE:139:6'
LOC+11+SGSIN:139:6'
LOC+65+JOAQB:139:6'
TMP+2+-22.00:CEL'
RNG+5+CEL:-22.00:-22.00'
FTX+OSI+++" &amp; REMARKS1 &amp;"'
FTX+AAA+++FZBF MEATS,FROZEN'
UNT+21+003780'
UNH+003780+COPARN:D:00B:UN'
BGM+104+" &amp; BookingNo2 &amp; "+9'
DTM+7:201304150933:203'
RFF+BN:" &amp; BookingNo2 &amp; "'
RFF+AAY:" &amp; BookingNo2 &amp; "'
TDT+20+"&amp;VoyageName&amp;"+1+++++9323041:146:11:MOL WINTER'
RFF+VON:"&amp;VoyageName&amp;"'
LOC+9+NZNPE:139:6'
LOC+11+SGSIN:139:6'
NAD+CA+PIL'
NAD+OY++LAI EXPORTS'
EQD+CN++4530:102:5+1+2+5'
RFF+SQ:1'
EQN+2'
LOC+9+NZNPE:139:6'
LOC+11+SGSIN:139:6'
LOC+65+THBKK:139:6'
TMP+2+0.50:CEL'
RNG+5+CEL:0.00:0.00'
FTX+OSI+++M3/H  22.00'
FTX+AAA+++CHFT FRUITS, CHILLED (INCLUDING CIT'
UNT+22+003780'
UNH+003780+COPARN:D:00B:UN'
BGM+104+" &amp; BookingNo3 &amp; "+9'
DTM+7:201304150933:203'
RFF+BN:" &amp; BookingNo3 &amp; "'
TDT+20+"&amp;VoyageName&amp;"+1+++++9323041:146:11:MOL WINTER'
RFF+VON:"&amp;VoyageName&amp;"'
LOC+9+NZNPE:139:6'
LOC+11+SGSIN:139:6'
NAD+CA+PIL'
NAD+OY++AFFCO NEW ZEALAND LIMITED'
EQD+CN++2200:102:5+1+2+5'
RFF+SQ:1'
EQN+1'
LOC+9+NZNPE:139:6'
LOC+11+SGSIN:139:6'
LOC+65+THBKK:139:6'
FTX+OSI+++" &amp; REMARKS3 &amp;"'
FTX+AAA+++(520 PIECES) BULL HIDES WET SA'
UNT+18+003780'";

	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN-1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr );
	
	self.ediDBLoad(ediFile);
	
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
//	----------------------------------------	
	booking := self.getBooking(BookingNo1);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.remarks[1:REMARKS1.length], REMARKS1, 'booking 1 - remarks not set');
//	----------------------------------------	
	booking := self.getBooking(BookingNo2);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.getVentilation, '22'.Decimal, 'booking 2 - ventilation not set');
//	----------------------------------------	
	booking := self.getBooking(BookingNo3);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.remarks[1:REMARKS3.length], REMARKS3, 'booking 3 - remarks not set');
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="uPAR37277" id="80981866-8526-4617-a542-480942ee0a66">
        <source>uPAR37277();
// cnwrs1
// cnwcs5 par 31942
// CCMS 2220
//16 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
constants
	ForeignVoy	= "MCFOREIGN01";
	ShipName 	= "MOL2220a";
	VoyageName 	= "MOL2220VOY";
	BookingNo1 	= "MOL2220a";	
	BookingNo2 	= "MOL2220b";
	PARTY		= 'MOL';
	SENDER1		= 'MOLNZ';
	SENDER2		= 'MOL';

vars
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	ediFile 		: CM_EDIFile;
	booking 		: CM_BookingRef;
	bookingItem		: CM_BookingRefItem;
	text 			: String;
	tempStr 		: String;
	bookingItems 	: Integer;
	ediParty		: CM_EDIParty;
	rules			: CM_EDIPartyCoparnRules;
	code			: String;
	operator		: CM_Operator;
begin
	code 		:= self.getTerminal.code;
	operator	:= app.myRoot.allOperators ['MOL']; 
	
	self.assertNotNull (operator);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	
	self.deleteBooking(BookingNo1);
	self.deleteBooking(BookingNo2);
	
	self.opts.addAssoc(ETRow_LloydsNumber, "9323041");
	vessel := self.addVesselCellular(ShipName, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, 'MOL', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg (voyage, "Add voyage failed");

	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, true);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;

	self.createEDIXlation(ForeignVoy, VoyageName, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	text := "
UNA:+,? '
UNB+UNOA:1+" &amp; SENDER1 &amp; "+POWLG+130415:1049+5296'
UNH+8491+COPARN:D:95B:UN'
BGM+11+8491+9'
RFF+BN:"&amp;BookingNo1&amp;"'
TDT+20+"&amp;ForeignVoy&amp;"+1++MOL:172:166+++9323041:146'
RFF+VON:"&amp;VoyageName&amp;"'
LOC+8+INNSA:139:6'
LOC+9+NZWLG:139:6'
LOC+10+NZWLG:139:6'
LOC+11+SGSIN:139:6'
DTM+133:201304190530:203'
NAD+CA+MOL:172:20'
NAD+CZ++INTEGROW MARKETING LTD'
GID+1'
FTX+AAA+++APLA APPLES, FRESH/CHILLED'
SGP+17101073061L1'
EQD+CN+17101073061L1+4532:102:5++2+5'
EQN+1'
MEA+WT+G+KGM:31600.000'
TMP+2+0.000:CEL'
FTX+OSI++21+CBM/H'
CNT+16:1'
UNT+22+8491'
UNH+8492+COPARN:D:95B:UN'
BGM+11+8492+9'
RFF+BN:"&amp;BookingNo2&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++MOL:172:166+++9323041:146::MOL WINTER'
RFF+VON:"&amp;VoyageName&amp;"'
LOC+8+THLKR:139:6'
LOC+9+NZWLG:139:6'
LOC+10+NZWLG:139:6'
LOC+11+SGSIN:139:6'
DTM+133:201304190530:203'
NAD+CA+MOL:172:20'
NAD+CZ++INTEGROW MARKETING LTD'
GID+1'
FTX+AAA+++APLA APPLES, FRESH/CHILLED'
SGP+17101073077L1'
EQD+CN+17101073077L1+4532:102:5++2+5'
EQN+1'
MEA+WT+G+KGM:31600.000'
TMP+2+0.000:CEL'
FTX+OSI++22+MTQ'
CNT+16:1'
UNT+22+8492'
UNZ+2+5296'";

	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN-1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr );
	
	self.ediDBLoad(ediFile);
	
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	booking := self.getBooking(BookingNo1);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.getVentilation, '21'.Decimal, 'booking 1 - ventilation not set');
	
	booking := self.getBooking(BookingNo2);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.getVentilation, '22'.Decimal, 'booking 2 - ventilation not set');
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="zCoparnBookingVent" id="0f7b6268-09a7-47be-a81a-ba4771917154">
        <source>zCoparnBookingVent(_ftxSegment, _ruleValue :String):Decimal protected;
/*
Date		Who		Reason
09 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars
	ftxArray	:StringArray512;
	rule		:CM_EDIEDIFactRule;
begin
	create ftxArray transient;
	
	_ftxSegment.getTokensForDelimiter ('+', ftxArray);
		
	create rule transient;
	
	rule.setProxy (rule.Item_FTX_4_1, _ruleValue, rule.Function_FTX_4_1_BookingVent);
	
	return rule.getFTXBookingVentilation (ftxArray);
epilog
	delete rule;
	delete ftxArray;
end;</source>
        <access>protected</access>
        <Parameter name="_ftxSegment" type="String"/>
        <Parameter name="_ruleValue" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
</Class>
