	&lt;/allEDIFieldHookCodes&gt;
	&lt;/CM_EDIFieldMappingTypeCollections&gt;
	&lt;/CM_EDIFieldMappingType&gt;
	&lt;CM_EDIFieldMappingType&gt;
	&lt;CM_EDIFieldMappingTypeAttributes&gt;
	&lt;controlValue&gt;&lt;/controlValue&gt;
	&lt;ediDataType&gt;72&lt;/ediDataType&gt;
	&lt;/CM_EDIFieldMappingTypeAttributes&gt;
	&lt;CM_EDIFieldMappingTypeReferences&gt;
	&lt;/CM_EDIFieldMappingTypeReferences&gt;
	&lt;CM_EDIFieldMappingTypeCollections&gt;
	&lt;allEDIFieldMappings&gt;
	&lt;/allEDIFieldMappings&gt;
	&lt;allEDIFieldHookCodes&gt;
	&lt;/allEDIFieldHookCodes&gt;
	&lt;/CM_EDIFieldMappingTypeCollections&gt;
	&lt;/CM_EDIFieldMappingType&gt;
	&lt;/allEDIFieldMappingTypes&gt;
	&lt;/CM_EDIFileTypeUserCollections&gt;
	&lt;/CM_EDIFileTypeUser&gt;";

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tIFCSUM94BCommDefCargoType" id="87968db8-6184-48b4-8fc6-3b1fd1884621">
        <source>tIFCSUM94BCommDefCargoType();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 18 June 2019
TFS#		: 44416
Function	:

*** Changes ***
Date			Name		TFS#		Description
9/02/2025		navsck1		MTN-34057 	Unit test UT_EDI_CargoTypeSubTypeDef::tIFCSUM94BCommDefCargoType needs to be fixed
****************************************************/

constants
	ForeignOperatorCode1 : String = "KLIN";
	ForeignOperatorCode2 : String = "9HA2066";
	ForeignOperatorCode3 : String = "WLA";
	EDIPartyName 		 : String = "IFCSUM94B";
	VoyageNameOther 	 : String = "851";
	VoyageName1 		 : String = '66S';
	ForeignVoy 			 : String = 'CF704';
	BoatName 			 : String = 'IFCSUM';
	CommodityCode		 : String = "DEFC";
vars
	terminal			: CM_Terminal;
	oper1 				: CM_Operator;
	ediData 			: String;
	ediFile				: CM_EDIFile;
	ediParty 			: CM_EDIParty;
	mazdaConsign 		: CM_ConsigneeConsignor;
	mazdaMake 			: CM_VehicleMake;
	hondaConsign 		: CM_ConsigneeConsignor;
	hondaMake 			: CM_VehicleMake;
	isuzuConsign 		: CM_ConsigneeConsignor;
	isuzuMake 			: CM_VehicleMake;
	mclarenConsign 		: CM_ConsigneeConsignor;
	mclarenMake 		: CM_VehicleMake;
	bmwConsign 			: CM_ConsigneeConsignor;
	bmwMake 			: CM_VehicleMake;
	lrConsign 			: CM_ConsigneeConsignor;
	lrMake 				: CM_VehicleMake;
	carCargoType 		: CM_CargoType;
	vessel 				: CM_Vessel;
	voyage 				: CM_Voyage;
	port 				: CM_Port;
	klinOper 			: CM_Operator;
	wlaOper 			: CM_Operator;
	filesToDelete 		: CM_EDIFileSet;
	prevDefCommodity	: String;
	selectedCargoTypes	: ObjectArray;
	commodity		 	: CM_Commodity;
	trackedItem			: CM_TrackedItem;
//	bolIn : CM_BOLIn;
	prevUseCargoAndSubTypeAsDef : Boolean;	
	prevProcIFCSUMPortAuthority : Boolean;	
begin
	terminal := self.getTerminal;
	
	//Preserve previous config value
	prevUseCargoAndSubTypeAsDef := terminal.getConfig(UseCargoAndSubTypeAsDef).Boolean;
	prevProcIFCSUMPortAuthority := terminal.getConfig(ProcIFCSUMPortAuthority).Boolean;
	
	//Set Config to true
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, true);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, false);
	
	carCargoType := app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Car);
	
	//Preserve previous commodity value
	prevDefCommodity := carCargoType.defaultCommodityCode;
			
	//create commodity we don't need to delete commodity before re-creating as this is being deleted in the addCommodity method.
	create selectedCargoTypes transient;
	selectedCargoTypes.add(carCargoType);	
	commodity := self.addCommodity(CommodityCode, "UT Commodity Default Cargo Type", selectedCargoTypes);	
		
	beginTransaction;
	carCargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, CommodityCode);	
	commitTransaction;	
	
//	self.deleteBOL("KKLUJPN476644", bolIn); 
//	self.deleteBOL("KKLUJPN476642", bolIn);
//	self.deleteBOL("KKLUJPN476559", bolIn);
//	self.deleteBOL("KKLUJPN476547", bolIn);
//	self.deleteBOL("KKLUJPN476957", bolIn);
	
	create filesToDelete transient;
	
	self.deleteVoyage(VoyageNameOther);
	voyage := self.getVoyage(VoyageNameOther);
	self.assertIsDeleted(voyage);

	self.deleteVoyage( VoyageName1 );
	voyage	:= self.getVoyage( VoyageName1 );
	self.assertIsDeleted( voyage );
	
	self.deleteVessel( BoatName );
	vessel	:= self.getVessel( BoatName );
	self.assertIsDeleted( vessel );
	
	oper1 := app.myRoot.allOperators.getAtKey("UTOP");
	self.assertTrueMsg( oper1 &lt;&gt; null, "Operator of 'UTOP' not found during setup.");
	
	vessel := self.addVesselCellular(	BoatName, oper1 );
	self.assertNotNullMsg( vessel, 'Add vessel failed' );
	
	voyage := self.addVoyageWithContainerStructur(	VoyageName1,
													BoatName,
													oper1.code,
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	
	klinOper := app.myRoot.allOperators.getAtKey("KLIN");
	self.assertNotNullMsg( klinOper, 'KLIN operator not found in set up' );
	wlaOper := app.myRoot.allOperators.getAtKey("WLA");
	self.assertNotNullMsg( wlaOper, 'WLA operator not found in set up' );
	
	beginTransaction;
	if voyage &lt;&gt; null then
		port := app.myRoot.allPorts["AUADL"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		port := app.myRoot.allPorts["AUPKL"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		if not voyage.allOperators.includes(klinOper) then
			voyage.allOperators.add(klinOper);
		endif;
		if not voyage.allOperators.includes(wlaOper) then
			voyage.allOperators.add(wlaOper);
		endif;
	endif;
	commitTransaction;
			
	mazdaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00231");
	if mazdaConsign = null then
		mazdaConsign := self.addConsigneeConsignor("00231","MAZDA AUSTRALIA PTY",true,true,false);
	endif;
	mazdaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("MAZDA");
	self.assertTrueMsg( mazdaMake &lt;&gt; null, "Vehicle Make of 'MAZDA' not found during setup.");
	
	hondaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00172");
	if hondaConsign = null then
		hondaConsign := self.addConsigneeConsignor("00172","HONDA AUSTRALIA PTY",true,true,false);
	endif;
	hondaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("HONDA");
	self.assertTrueMsg( hondaMake &lt;&gt; null, "Vehicle Make of 'HONDA' not found during setup.");
	
	isuzuConsign := app.myRoot.allConsigneeConsignors.getAtKey("01636");
	if isuzuConsign = null then
		isuzuConsign := self.addConsigneeConsignor("01636","+ISUZU AUSTRALIA LTD",true,true,false);
	endif;
	isuzuMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("ISUZU");
	self.assertTrueMsg( isuzuMake &lt;&gt; null, "Vehicle Make of 'ISUZU' not found during setup.");
	
	mclarenConsign := app.myRoot.allConsigneeConsignors.getAtKey("MCL");
	if mclarenConsign = null then
		self.assertTrueMsg( mclarenMake &lt;&gt; null, "Vehicle Make of 'MCLAREN' not found during setup.");
	endif;
	mclarenMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("MCLAREN");
	self.assertTrueMsg( mclarenMake &lt;&gt; null, "Vehicle Make of 'MCLAREN' not found during setup.");
	
	bmwConsign := app.myRoot.allConsigneeConsignors.getAtKey("BMWAU");
	if bmwConsign = null then
		bmwConsign := self.addConsigneeConsignor("BMWAU","BMW AUSTRALIA LTD",true,true,false);
	endif;
	bmwMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("BMW");
	self.assertTrueMsg( bmwMake &lt;&gt; null, "Vehicle Make of 'BMW' not found during setup.");
	
	lrConsign := app.myRoot.allConsigneeConsignors.getAtKey("LRU");
	if lrConsign = null then
		lrConsign := self.addConsigneeConsignor("LRU","LAND ROVER EXPORTS LTD",true,true,false);
	endif;
	lrMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("LAND ROVER");
	self.assertTrueMsg( lrMake &lt;&gt; null, "Vehicle Make of 'LAND ROVER' not found during setup.");
	
	self.deleteEDIInwardXlation (ForeignOperatorCode1, XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation (ForeignOperatorCode2, XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation (ForeignOperatorCode3, XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIInwardXlation ('MCLAREN AUTOMOTIVE ASIA PTE LT', XLATION_TYPE_CONSIGNEE_BYOP, wlaOper, null);
	self.deleteEDIInwardXlation ('LAND ROVER EXPORTS LTD', XLATION_TYPE_CONSIGNEE_BYOP, wlaOper, null);
	self.deleteEDIInwardXlation ('BMW AUSTRALIA LTD', XLATION_TYPE_CONSIGNEE_BYOP, wlaOper, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, wlaOper, null);
	self.deleteEDIInwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, klinOper, null);
	self.deleteEDIInwardXlation(ForeignVoy, XLATION_TYPE_VOYAGETERMINAL, wlaOper, null);
	
	self.createEDIXlation(ForeignOperatorCode1,oper1.code, XLATION_TYPE_OPERATOR, false, null, null);
	self.createEDIXlation(ForeignOperatorCode2,wlaOper.code, XLATION_TYPE_OPERATOR, false, null, null);
	self.createEDIXlation(ForeignOperatorCode3,oper1.code, XLATION_TYPE_OPERATOR, false, null, null);
	self.createEDIXlation ('MCLAREN AUTOMOTIVE ASIA PTE LT', mclarenConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, wlaOper, null);
	self.createEDIXlation ('LAND ROVER EXPORTS LTD', lrConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, wlaOper, null);
	self.createEDIXlation ('BMW AUSTRALIA LTD', bmwConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, wlaOper, null);
	self.createEDIXlation(ForeignVoy, voyage.code, XLATION_TYPE_VOYAGETERMINAL, false, wlaOper, null);
	self.createEDIXlation(ForeignVoy, voyage.code, XLATION_TYPE_VOYAGETERMINAL, true, wlaOper, null);
	
	/*	//JIRA-
	//KLINES
	
	self.deleteEDIParty( EDIPartyName &amp; "_KLINE" );																			// 19/02/2025 navsck1	#MTN-34057
	ediParty := self.createEDIParty( EDIPartyName &amp; "_KLINE", method.qualifiedName &amp; " Unit Test", "KLINE", klinOper); 
	self.createEDIPartyIFCSUM49B( ediParty, mazdaConsign, carCargoType, mazdaMake, false, false, false, null );
	self.createEDIPartyIFCSUM49B( ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null );
	self.createEDIPartyIFCSUM49B( ediParty, isuzuConsign, carCargoType, isuzuMake, false, false, false, null ); 						
	
	ediData := self.zInputIFCSUM94B(3);	
	ediFile := self.ediVerifyErrors(ediData, "IFCSUM94B_KLINE", method.name&amp;"3", EDIFileType_Unknown);
	
	filesToDelete.add(ediFile);																								// 19/02/2025 navsck1	#MTN-34057
	
	//KLINES
	*/
	self.deleteEDIParty( EDIPartyName &amp; "_KLINE" );
	ediParty := self.createEDIParty( EDIPartyName &amp; "_KLINE", method.qualifiedName &amp; " Unit Test", "KLINE", klinOper); 
	self.createEDIPartyIFCSUM49B( ediParty, mazdaConsign, carCargoType, mazdaMake, false, false, false, null );
	self.createEDIPartyIFCSUM49B( ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null );
	self.createEDIPartyIFCSUM49B( ediParty, isuzuConsign, carCargoType, isuzuMake, false, false, false, null ); 						
	
	ediData := self.zInputIFCSUM94B(1);	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, "IFCSUM94B_KLINE", method.name&amp;"1", EDIFileType_Unknown, true, true, false, false, null);
	self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created. " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	filesToDelete.add(ediFile);
	
	trackedItem := voyage.allOnshipTIsByIdCargoType.getAtKey("KPA527610155245", TI_CargoType_Car);
	self.assertTrueMsg( trackedItem &lt;&gt; null, "Cargo '" &amp; "KPA527610155245" &amp; "' not created");
	
	//Test Commodity value	
	self.assertEqualMsg(trackedItem.commodity, CommodityCode, "Cargo ' " &amp; "KPA527610155245" &amp;  "' default commodity expecting '" &amp; CommodityCode &amp; "' Actual is incorrect '" &amp; trackedItem.commodity);
	
	//WLAs
	
	self.deleteEDIParty( EDIPartyName  &amp; "_WLA" );
	ediParty := self.createEDIParty( EDIPartyName  &amp; "_WLA", method.qualifiedName &amp; " Unit Test", "WLA", wlaOper); 
	self.createEDIPartyIFCSUM49B( ediParty, mclarenConsign, carCargoType, mclarenMake, true, false, false, null  );
	self.createEDIPartyIFCSUM49B( ediParty, bmwConsign, carCargoType, bmwMake, true, false, false, null  );
	self.createEDIPartyIFCSUM49B( ediParty, lrConsign, carCargoType, lrMake, true, false, false, null  );
	
	ediData := self.zInputIFCSUM94B(2);	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, "IFCSUM94B_WLA", method.name&amp;"2", EDIFileType_Unknown, true, true, false, false, null);
	self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created. " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	filesToDelete.add(ediFile);	
	
	trackedItem := voyage.allOnshipTIsByIdCargoType.getAtKey("MJH13CAD7HW002505", TI_CargoType_Car);
	self.assertTrueMsg( trackedItem &lt;&gt; null, "Cargo '" &amp; "MJH13CAD7HW002505" &amp; "' not created");
	
	//Test Commodity value	
	self.assertEqualMsg(trackedItem.commodity, CommodityCode, "Cargo ' " &amp; "MJH13CAD7HW002505" &amp;  "' default commodity expecting '" &amp; CommodityCode &amp; "' Actual is incorrect '" &amp; trackedItem.commodity);
		
epilog
	//Revert config to the orginal value
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, prevUseCargoAndSubTypeAsDef);	
	self.setTerminalConfig(ProcIFCSUMPortAuthority, prevProcIFCSUMPortAuthority);
	
	beginTransaction;
	carCargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, prevDefCommodity);
	commitTransaction;
		
	foreach ediFile in filesToDelete do
		if ediFile.ediData &lt;&gt; null then
//			app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
		endif;
	endforeach;

	delete filesToDelete;
	delete selectedCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPreNoteEDICommDefCargoSub" id="621c557f-672f-483d-a366-989855585320">
        <source>tPreNoteEDICommDefCargoSub();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 14 June 2019
TFS#		: 44416
Function	: Test Commodity Defaults from Cargo Sub Type.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	Cargo_Type  	: String = "UTNSCT";
	Cargo_SubType1 	: String = "UTNSCTP1";
	CargoId1 		: String = "UT44416CST1";	
	CargoId2 		: String = "UT44416CST2";	
	CommodityCode	: String = "DEFC";
	CommodityCode2	: String = "DEF2";
vars

	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	cargoType 				: CM_CargoType;
	pxyFileTypeUser 		: CM_EDIFileTypeUser;
	realFileTypeUser 		: CM_EDIFileTypeUser;
	ediUserDefinedXMLFormat : String;
	ediData 				: String;
	ediFile					: CM_EDIFile;	
	trackedItem 			: CM_TrackedItem;	
	filesToDelete 			: CM_EDIFileSet;		
	commodity		 		: CM_Commodity;
	commodityCargoSubType	: CM_Commodity;
	selectedCargoTypes		: ObjectArray;
	prevDefCommodity 		: String;
	prevDefCargoSubTypeCommo: String;
	cargoSubType			: CM_Product;
	
	prevUseCargoAndSubTypeAsDef : Boolean;	
begin
	terminal := self.getTerminal;
	
	//Preserve previous config value
	prevUseCargoAndSubTypeAsDef := terminal.getConfig(UseCargoAndSubTypeAsDef).Boolean;
	
	//Set Config to true
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, true);
	
	operator := app.myRoot.allOperators.getAtKey("UTOP");
	self.assertTrueMsg( operator &lt;&gt; null, "Operator of 'UTOP' not found during setup.");
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.assertTrueMsg( cargoType &lt;&gt; null, "Cargo Type of '" &amp; Cargo_Type &amp; "' not found during setup.");
	
	cargoSubType := cargoType.getProductFromCode(Cargo_SubType1);
	self.assertTrueMsg( cargoSubType &lt;&gt; null, "Cargo Sub Type of '" &amp; Cargo_SubType1 &amp; "' not found during setup.");
	
	//Preserve previous commodity value
	prevDefCommodity := cargoType.defaultCommodityCode;
	prevDefCargoSubTypeCommo := cargoSubType.defaultCommodityCode;
	
	//clean up from last run	
	self.deleteCargo(CargoId1, cargoType);	
	self.deleteCargo(CargoId2, cargoType);	
		
	//create commodity we don't need to delete commodity before re-creating as this is being deleted in the addCommodity method.
	create selectedCargoTypes transient;
	selectedCargoTypes.add(cargoType);	
	commodity := self.addCommodity(CommodityCode, "UT Commodity Default Cargo Type", selectedCargoTypes);	
	commodityCargoSubType := self.addCommodity(CommodityCode2, "UT Commodity Default Cargo Sub Type", selectedCargoTypes);
	
	beginTransaction;
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, CommodityCode);
	cargoSubType.setPropertyValue(CM_Product::defaultCommodityCode.name, CommodityCode2);
	commitTransaction;
	
	// delete any existing user defined setup for this one, and add it again.
	create pxyFileTypeUser transient;
	ediUserDefinedXMLFormat := self.setupUserDefFileFormat();	// the XML format for "Unit Test Prenote Cargo Type Defaults"
	pxyFileTypeUser.importMeXML(ediUserDefinedXMLFormat);
	realFileTypeUser := self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	self.assertTrueMsg( realFileTypeUser &lt;&gt; null, "User Defined Type '" &amp; self.UserDefFileFormat &amp; "' not created during setup.");
	delete pxyFileTypeUser;
	
	create filesToDelete transient;
	
	//First one, is to simply add a single pre-note with null commodity expected to get it from Cargo Typpe Defaults.
		// get the data to import
		self.opts.purge();	
		ediData := 
		"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,TotalQuantity" &amp; CrLf
		&amp; "A,"&amp;CargoId1&amp;","&amp;cargoType.description&amp;"," &amp; cargoSubType.description &amp; ",,25,Storage,,"&amp;operator.code&amp;",NZABY,,1" ;
		
		//Import the file.
		ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, self.UserDefFileFormat, method.name&amp;'1', EDIFileType_UserDefined, true, true, false, false, null);
		self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 1.");
		
		//Test if Cargo has been created
		trackedItem := terminal.allNotifiedTIsByCargoTypeId.getAtKey(cargoType.id,CargoId1);
		self.assertTrueMsg( trackedItem &lt;&gt; null, "Prenote '" &amp; CargoId1 &amp; "' not created - Test 2");
		
		//Test Commodity value			
		self.assertEqualMsg(trackedItem.commodity, CommodityCode2, "Prenote ' " &amp; CargoId1 &amp;  "' default commodity expecting '" &amp; CommodityCode2 &amp; "' Actual is incorrect '" &amp; trackedItem.commodity &amp; "' Test 3");
		
		filesToDelete.add(ediFile);
	
	//Second Test is for Empty default value in the Cargo Sub Type then it will need to get the defaults from the Cargo Type.
		beginTransaction;	
		cargoSubType.setPropertyValue(CM_Product::defaultCommodityCode.name, null);
		commitTransaction;
		
		ediData := 
		"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,TotalQuantity" &amp; CrLf
		&amp; "A,"&amp;CargoId2&amp;","&amp;cargoType.description&amp;"," &amp; cargoSubType.description &amp; ",,25,Storage,,"&amp;operator.code&amp;",NZABY,,1" ;
		
		//Import the file.
		ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, self.UserDefFileFormat, method.name&amp;'1', EDIFileType_UserDefined, true, true, false, false, null);
		self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 4.");
		
		//Test if Cargo has been created
		trackedItem := terminal.allNotifiedTIsByCargoTypeId.getAtKey(cargoType.id,CargoId2);
		self.assertTrueMsg( trackedItem &lt;&gt; null, "Prenote '" &amp; CargoId2 &amp; "' not created - Test 5");
		
		//Test Commodity value	
		self.assertEqualMsg(trackedItem.commodity, CommodityCode, "Prenote ' " &amp; CargoId2 &amp;  "' default commodity expecting '" &amp; CommodityCode &amp; "' Actual is incorrect '" &amp; trackedItem.commodity &amp; "' Test 6");
		
		filesToDelete.add(ediFile);
epilog
	//Revert config to the orginal value
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, prevUseCargoAndSubTypeAsDef);	
	
	beginTransaction;
	if cargoType &lt;&gt; null then
		cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, prevDefCommodity);
	endif;
	if cargoSubType &lt;&gt; null then
		cargoSubType.setPropertyValue(CM_Product::defaultCommodityCode.name, prevDefCargoSubTypeCommo);
	endif;
	commitTransaction;
	
	delete pxyFileTypeUser;
	
	//clean up the successfull ones from the EDI Operations Form.... ( cos these ones were from successfull tests )
	if filesToDelete &lt;&gt; null then
		foreach ediFile in filesToDelete do
			if ediFile.ediData &lt;&gt; null then
				app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
			endif;
		endforeach;
	endif;

	delete filesToDelete;
	delete selectedCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPreNoteEDICommDefCargoType" id="bc089565-72c5-4a3c-8389-831840d8ab96">
        <source>tPreNoteEDICommDefCargoType();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 14 June 2019
TFS#		: 44416
Function	: Test Commodity Defaults from Cargo Type.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	Cargo_Type  	: String = "UT_BB_GC";
	CargoId1 		: String = "UT44416R1";	
	CommodityCode	: String = "DEFC";
vars

	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	cargoType 				: CM_CargoType;
	pxyFileTypeUser 		: CM_EDIFileTypeUser;
	realFileTypeUser 		: CM_EDIFileTypeUser;
	ediUserDefinedXMLFormat : String;
	ediData 				: String;
	ediFile					: CM_EDIFile;	
	trackedItem 			: CM_TrackedItem;	
	filesToDelete 			: CM_EDIFileSet;		
	commodity		 		: CM_Commodity;
	selectedCargoTypes		: ObjectArray;
	prevDefCommodity 		: String;
	
	prevUseCargoAndSubTypeAsDef : Boolean;
begin
	terminal := self.getTerminal;
	
	//Preserve previous config value
	prevUseCargoAndSubTypeAsDef := terminal.getConfig(UseCargoAndSubTypeAsDef).Boolean;
	
	//Set Config to true
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, true);
	
	operator := app.myRoot.allOperators.getAtKey("UTOP");
	self.assertTrueMsg( operator &lt;&gt; null, "Operator of 'UTOP' not found during setup.");
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.assertTrueMsg( cargoType &lt;&gt; null, "Cargo Type of '" &amp; Cargo_Type &amp; "' not found during setup.");
	
	//Preserve previous commodity value
	prevDefCommodity := cargoType.defaultCommodityCode;
	
	//clean up from last run	
	self.deleteCargo(CargoId1, cargoType);	
		
	//create commodity we don't need to delete commodity before re-creating as this is being deleted in the addCommodity method.
	create selectedCargoTypes transient;
	selectedCargoTypes.add(cargoType);	
	commodity := self.addCommodity(CommodityCode, "UT Commodity Default", selectedCargoTypes);
	beginTransaction;
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, CommodityCode);
	commitTransaction;
	
	// delete any existing user defined setup for this one, and add it again.
	create pxyFileTypeUser transient;
	ediUserDefinedXMLFormat := self.setupUserDefFileFormat();	// the XML format for "Unit Test Prenote Cargo Type Defaults"
	pxyFileTypeUser.importMeXML(ediUserDefinedXMLFormat);
	realFileTypeUser := self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	self.assertTrueMsg( realFileTypeUser &lt;&gt; null, "User Defined Type '" &amp; self.UserDefFileFormat &amp; "' not created during setup.");
	delete pxyFileTypeUser;
	
	create filesToDelete transient;
	
	//First one, is to simply add a single pre-note with null commodity expected to get it from Cargo Typpe Defaults.
	// get the data to import
	self.opts.purge();	
	ediData := 
	"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,TotalQuantity" &amp; CrLf
	&amp; "A,"&amp;CargoId1&amp;","&amp;cargoType.description&amp;",,,25,Storage,,"&amp;operator.code&amp;",NZABY,,1" ;
	
	//Import the file.
	ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, self.UserDefFileFormat, method.name&amp;'1', EDIFileType_UserDefined, true, true, false, false, null);
	self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 1.");
	
	//Test if Cargo has been created
	trackedItem := terminal.allNotifiedTIsByCargoTypeId.getAtKey(cargoType.id,CargoId1);
	self.assertTrueMsg( trackedItem &lt;&gt; null, "Prenote '" &amp; CargoId1 &amp; "' not created - Test 2");
	
	//Test Commodity value	
	self.assertEqualMsg(trackedItem.commodity, CommodityCode, "Prenote ' " &amp; CargoId1 &amp;  "' default commodity is incorrect Test 3");
	
	filesToDelete.add(ediFile);
	
epilog
	//Revert config to the orginal value
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, prevUseCargoAndSubTypeAsDef);	
	
	beginTransaction;
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, prevDefCommodity);
	commitTransaction;
	
	delete pxyFileTypeUser;
	
	//clean up the successfull ones from the EDI Operations Form.... ( cos these ones were from successfull tests )
	foreach ediFile in filesToDelete do
		if ediFile.ediData &lt;&gt; null then
			app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
		endif;
	endforeach;

	delete filesToDelete;
	delete selectedCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPreNoteEDIMetricDefCargoSub" id="1e35ddea-7233-439e-870f-24694da6bc4a">
        <source>tPreNoteEDIMetricDefCargoSub();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 14 June 2019
TFS#		: 44416
Function	: This only test the Height default attribute as I am expecting all the other
			  measurement field will behave the same.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	Cargo_Type  		: String = "UTNSCT";
	Cargo_SubType1 		: String = "UTNSCTP1";
	CargoId1 			: String = "UT44416H3";	
	CargoId2 			: String = "UT44416H4";	
	CommodityCode		: String = "DEFC";
	DefaultHeight		: Integer = 150;
	DefaultProdHeight	: Decimal [14,4] = 100.00;
vars

	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	cargoType 				: CM_CargoType;
	cargoSubType			: CM_Product;
	productAttribute		: CM_ProductAttr;
	productAttrDeci			: CM_ProdAttrDecimal;
	pxyFileTypeUser 		: CM_EDIFileTypeUser;
	realFileTypeUser 		: CM_EDIFileTypeUser;
	ediUserDefinedXMLFormat : String;
	ediData 				: String;
	ediFile					: CM_EDIFile;	
	trackedItem 			: CM_TrackedItem;	
	filesToDelete 			: CM_EDIFileSet;		
	commodity		 		: CM_Commodity;
	selectedCargoTypes		: ObjectArray;
	prevDefCommodity 		: String;
	prevHeight				: Integer;
	prevHeightProd			: Decimal [14,4];	
	
	prevUseCargoAndSubTypeAsDef : Boolean;
begin
	terminal := self.getTerminal;
	
	//Preserve previous config value
	prevUseCargoAndSubTypeAsDef := terminal.getConfig(UseCargoAndSubTypeAsDef).Boolean;
	
	//Set Config to true
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, true);
	
	operator := app.myRoot.allOperators.getAtKey("UTOP");
	self.assertTrueMsg( operator &lt;&gt; null, "Operator of 'UTOP' not found during setup.");
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.assertTrueMsg( cargoType &lt;&gt; null, "Cargo Type of '" &amp; Cargo_Type &amp; "' not found during setup.");
	
	cargoSubType := cargoType.getProductFromCode(Cargo_SubType1);
	self.assertTrueMsg( cargoSubType &lt;&gt; null, "Cargo Sub Type of '" &amp; Cargo_SubType1 &amp; "' not found during setup.");
	
	//Preserve previous commodity value
	prevDefCommodity := cargoType.defaultCommodityCode;
	prevHeight		 := cargoType.defaultHeight;
	
	if cargoSubType &lt;&gt; null then		
		productAttribute := cargoSubType.getProdAttrFromName(ETRow_MyHeight);
		productAttrDeci  := productAttribute.CM_ProdAttrDecimal;
		prevHeightProd	 := cargoSubType.getHeightValue();
	endif;
	
	//clean up from last run	
	self.deleteCargo(CargoId1, cargoType);	
		
	//create commodity we don't need to delete commodity before re-creating as this is being deleted in the addCommodity method.
	create selectedCargoTypes transient;
	selectedCargoTypes.add(cargoType);	
	commodity := self.addCommodity(CommodityCode, "UT Commodity Default", selectedCargoTypes);
	beginTransaction;
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, CommodityCode);
	cargoType.setPropertyValue(CM_CargoType::defaultHeight.name, DefaultHeight);	
	commitTransaction;
	
	// delete any existing user defined setup for this one, and add it again.
	create pxyFileTypeUser transient;
	ediUserDefinedXMLFormat := self.setupUserMetricDefFileFormat();	// the XML format for "Unit Test Prenote Metric"
	pxyFileTypeUser.importMeXML(ediUserDefinedXMLFormat);
	realFileTypeUser := self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	self.assertTrueMsg( realFileTypeUser &lt;&gt; null, "User Defined Type '" &amp; self.UserDefineFileFormatM &amp; "' not created during setup.");
	delete pxyFileTypeUser;
	
	create filesToDelete transient;
	
	//First one, is to simply add a single pre-note with null height expected to get it from Cargo Type Defaults where the Sub Cargo Type default is null.
		// get the data to import
		self.opts.purge();	
		ediData := 
		"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,TotalQuantity,Height (cm)" &amp; CrLf
		&amp; "A,"&amp;CargoId1&amp;","&amp;cargoType.description &amp;"," &amp; cargoSubType.description &amp; ",,25,Storage,,"&amp;operator.code&amp;",NZABY,,1," ;
		
		//Import the file.
		ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, self.UserDefineFileFormatM, method.name&amp;'1', EDIFileType_UserDefined, true, true, false, false, null);
		self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 1.");
		
		//Test if Cargo has been created
		trackedItem := terminal.allNotifiedTIsByCargoTypeId.getAtKey(cargoType.id,CargoId1);
		self.assertTrueMsg( trackedItem &lt;&gt; null, "Prenote '" &amp; CargoId1 &amp; "' not created - Test 2");
		
		//Test Commodity value	
		self.assertEqualMsg(trackedItem.commodity, CommodityCode, "Prenote ' " &amp; CargoId1 &amp;  "' default commodity is incorrect Test 3");
		
		//Test Height value	
		self.assertEqualMsg(trackedItem.height.Integer, DefaultHeight, "Prenote ' " &amp; CargoId1 &amp;  "' default height expected '" &amp; DefaultHeight.asStringJMT &amp; "' actual is incorrect '" &amp; trackedItem.height.Integer.asStringJMT &amp; "' Test 4");
		
		filesToDelete.add(ediFile);
	
	//Second one, is to simply add a single pre-note with null height expected to get it from Sub Cargo Type Defaults.
		beginTransaction;
		if productAttrDeci &lt;&gt; null then		
			productAttrDeci.setPropertyValue(CM_ProdAttrDecimal::value.name, DefaultProdHeight);
		endif;
		commitTransaction;
		// get the data to import
		self.opts.purge();	
		ediData := 
		"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,TotalQuantity,Height (cm)" &amp; CrLf
		&amp; "A,"&amp;CargoId2&amp;","&amp;cargoType.description  &amp;"," &amp; cargoSubType.description &amp; ",,25,Storage,,"&amp;operator.code&amp;",NZABY,,1," ;
		
		//Import the file.
		ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, self.UserDefineFileFormatM, method.name&amp;'2', EDIFileType_UserDefined, true, true, false, false, null);
		self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 5.");
		
		//Test if Cargo has been created
		trackedItem := terminal.allNotifiedTIsByCargoTypeId.getAtKey(cargoType.id,CargoId2);
		self.assertTrueMsg( trackedItem &lt;&gt; null, "Prenote '" &amp; CargoId2 &amp; "' not created - Test 6");
		
		//Test Commodity value	
		self.assertEqualMsg(trackedItem.commodity, CommodityCode, "Prenote ' " &amp; CargoId2 &amp;  "' default commodity is incorrect Test 7");
		
		//Test Height value	
		self.assertEqualMsg(trackedItem.height, DefaultProdHeight, "Prenote ' " &amp; CargoId2 &amp;  "' default height expected '" &amp; DefaultProdHeight.asStringJMT &amp; "' actual is incorrect '" &amp; trackedItem.height.asStringJMT &amp; "' Test 8");
		
		filesToDelete.add(ediFile);
	
epilog
	//Revert config to the orginal value
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, prevUseCargoAndSubTypeAsDef);	
	
	beginTransaction;
	if cargoType &lt;&gt; null then
		cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, prevDefCommodity);
		cargoType.setPropertyValue(CM_CargoType::defaultHeight.name, prevHeight);
	endif;
	
	if productAttrDeci &lt;&gt; null then
		productAttrDeci.setPropertyValue(CM_ProdAttrDecimal::value.name, prevHeightProd);
	endif;
	
	commitTransaction;
	
	delete pxyFileTypeUser;
	
	//clean up the successfull ones from the EDI Operations Form.... ( cos these ones were from successfull tests )
	if filesToDelete &lt;&gt; null then
		foreach ediFile in filesToDelete do
			if ediFile.ediData &lt;&gt; null then
				app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
			endif;
		endforeach;
	endif;

	delete filesToDelete;
	delete selectedCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPreNoteEDIMetricDefCargoType" id="5a41797c-2e1c-469b-a5d6-1df7c5481419">
        <source>tPreNoteEDIMetricDefCargoType();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 14 June 2019
TFS#		: 44416
Function	: This only test the Height default attribute as I am expecting all the other
			  measurement field will behave the same.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	Cargo_Type  		: String = "UT_BB_GC";
	CargoId1 			: String = "UT44416H1";	
	CargoId2 			: String = "UT44416H2";	
	CommodityCode		: String = "DEFC";
	DefaultHeight		: Integer = 150;
	DefaultProdHeight	: Decimal [14,4] = 100.00;
vars

	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	cargoType 				: CM_CargoType;
	cargoSubType			: CM_Product;
	productAttribute		: CM_ProductAttr;
	productAttrDeci			: CM_ProdAttrDecimal;
	pxyFileTypeUser 		: CM_EDIFileTypeUser;
	realFileTypeUser 		: CM_EDIFileTypeUser;
	ediUserDefinedXMLFormat : String;
	ediData 				: String;
	ediFile					: CM_EDIFile;	
	trackedItem 			: CM_TrackedItem;	
	filesToDelete 			: CM_EDIFileSet;		
	commodity		 		: CM_Commodity;
	selectedCargoTypes		: ObjectArray;
	prevDefCommodity 		: String;
	prevHeight				: Integer;
	prevHeightProd			: Decimal [14,4];
	
	prevUseCargoAndSubTypeAsDef : Boolean;
begin
	self.setTerminalConfig(PrenoteUniqBooking, false);
	terminal := self.getTerminal;
	
	//Preserve previous config value
	prevUseCargoAndSubTypeAsDef := terminal.getConfig(UseCargoAndSubTypeAsDef).Boolean;
	
	//Set Config to true
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, true);
	
	operator := app.myRoot.allOperators.getAtKey("UTOP");
	self.assertTrueMsg( operator &lt;&gt; null, "Operator of 'UTOP' not found during setup.");
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.assertTrueMsg( cargoType &lt;&gt; null, "Cargo Type of '" &amp; Cargo_Type &amp; "' not found during setup.");
	
	//Preserve previous commodity value
	prevDefCommodity := cargoType.defaultCommodityCode;
	prevHeight		 := cargoType.defaultHeight;
	if cargoType.mySystemProductType &lt;&gt; null then
		cargoSubType	 := cargoType.mySystemProductType;		
		productAttribute := cargoSubType.getProdAttrFromName(ETRow_MyHeight);
		productAttrDeci  := productAttribute.CM_ProdAttrDecimal;
		prevHeightProd	 := cargoSubType.getHeightValue();
	endif;
	
	//clean up from last run	
	self.deleteCargo(CargoId1, cargoType);	
		
	//create commodity we don't need to delete commodity before re-creating as this is being deleted in the addCommodity method.
	create selectedCargoTypes transient;
	selectedCargoTypes.add(cargoType);	
	commodity := self.addCommodity(CommodityCode, "UT Commodity Default", selectedCargoTypes);
	beginTransaction;
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, CommodityCode);
	cargoType.setPropertyValue(CM_CargoType::defaultHeight.name, DefaultHeight);	
	commitTransaction;
	
	// delete any existing user defined setup for this one, and add it again.
	create pxyFileTypeUser transient;
	ediUserDefinedXMLFormat := self.setupUserMetricDefFileFormat();	// the XML format for "Unit Test Prenote Metric"
	pxyFileTypeUser.importMeXML(ediUserDefinedXMLFormat);
	realFileTypeUser := self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	self.assertTrueMsg( realFileTypeUser &lt;&gt; null, "User Defined Type '" &amp; self.UserDefineFileFormatM &amp; "' not created during setup.");
	delete pxyFileTypeUser;
	
	create filesToDelete transient;
	
	//First one, is to simply add a single pre-note with null height expected to get it from Cargo Type Defaults as mySystemProductType default is null.
		// get the data to import
		self.opts.purge();	
		ediData := 
		"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,TotalQuantity,Height (cm)" &amp; CrLf
		&amp; "A,"&amp;CargoId1&amp;","&amp;cargoType.description&amp;",,,25,Storage,,"&amp;operator.code&amp;",NZABY,,1," ;
		
		//Import the file.
		ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, self.UserDefineFileFormatM, method.name&amp;'1', EDIFileType_UserDefined, true, true, false, false, null);
		self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 1.");
		
		//Test if Cargo has been created
		trackedItem := terminal.allNotifiedTIsByCargoTypeId.getAtKey(cargoType.id,CargoId1);
		self.assertTrueMsg( trackedItem &lt;&gt; null, "Prenote '" &amp; CargoId1 &amp; "' not created - Test 2");
		
		//Test Commodity value	
		self.assertEqualMsg(trackedItem.commodity, CommodityCode, "Prenote ' " &amp; CargoId1 &amp;  "' default commodity is incorrect Test 3");
		
		//Test Height value	
		self.assertEqualMsg(trackedItem.height.Integer, DefaultHeight, "Prenote ' " &amp; CargoId1 &amp;  "' default height expected '" &amp; DefaultHeight.asStringJMT &amp; "' actual is incorrect '" &amp; trackedItem.height.Integer.asStringJMT &amp; "' Test 4");
		
		filesToDelete.add(ediFile);
	
	//Second one, is to simply add a single pre-note with null height expected to get it from mySystemProductType defaults
		beginTransaction;
		if productAttrDeci &lt;&gt; null then		
			productAttrDeci.setPropertyValue(CM_ProdAttrDecimal::value.name, DefaultProdHeight);
		endif;
		commitTransaction;
		// get the data to import
		self.opts.purge();	
		ediData := 
		"Action,ID,CargoType Descr,Cargo Subtype,Iso Type,Total Weight(kg),Imex Status,Voyage,Operator,Discharge Port,Destination,TotalQuantity,Height (cm)" &amp; CrLf
		&amp; "A,"&amp;CargoId2&amp;","&amp;cargoType.description&amp;",,,25,Storage,,"&amp;operator.code&amp;",NZABY,,1," ;
		
		//Import the file.
		ediFile := self.ediLoadVerifyDBLoadActualBasic(ediData, self.UserDefineFileFormatM, method.name&amp;'2', EDIFileType_UserDefined, true, true, false, false, null);
		self.assertTrueMsg( ediFile &lt;&gt; null, "EDI file not created - Test 5.");
		
		//Test if Cargo has been created
		trackedItem := terminal.allNotifiedTIsByCargoTypeId.getAtKey(cargoType.id,CargoId2);
		self.assertTrueMsg( trackedItem &lt;&gt; null, "Prenote '" &amp; CargoId2 &amp; "' not created - Test 6");
		
		//Test Commodity value	
		self.assertEqualMsg(trackedItem.commodity, CommodityCode, "Prenote ' " &amp; CargoId2 &amp;  "' default commodity is incorrect Test 7");
		
		//Test Height value	
		self.assertEqualMsg(trackedItem.height, DefaultProdHeight, "Prenote ' " &amp; CargoId2 &amp;  "' default height expected '" &amp; DefaultProdHeight.asStringJMT &amp; "' actual is incorrect '" &amp; trackedItem.height.asStringJMT &amp; "' Test 8");
		
		filesToDelete.add(ediFile);
	
epilog
	//Revert config to the orginal value
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, prevUseCargoAndSubTypeAsDef);	
	
	beginTransaction;
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, prevDefCommodity);
	cargoType.setPropertyValue(CM_CargoType::defaultHeight.name, prevHeight);
	
	if productAttrDeci &lt;&gt; null then
		productAttrDeci.setPropertyValue(CM_ProdAttrDecimal::value.name, prevHeightProd);
	endif;
	
	commitTransaction;
	
	delete pxyFileTypeUser;
	
	//clean up the successfull ones from the EDI Operations Form.... ( cos these ones were from successfull tests )
	foreach ediFile in filesToDelete do
		if ediFile.ediData &lt;&gt; null then
			app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
		endif;
	endforeach;

	delete filesToDelete;
	delete selectedCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tShipManifestCommDefCargoType" id="2ee3ea18-d09d-444d-a887-a7943d46236a">
        <source>tShipManifestCommDefCargoType();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 18 June 2019
TFS#		: 44416
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	UserDefineName 	: String = "JMTInternalShipManifest";
	ShipName		: String = "SHIPGEN";
	VoyageName		: String = "VOYSHIPGENXX";
	TestOperator 	: String = 'MSK';
	Cargo_Type		: String = "CONT";
	CommodityCode	: String = "DEFC";
vars
	vesselObj 		: CM_Vessel;
	voyageObj 		: CM_Voyage;
	ediFileObj 		: CM_EDIFile;
	ediDataObj 		: CM_EDIData;
	passportObj 	: CM_Passport;
	ediText 		: String;
	errorMsg 		: String;
	voyage 			: CM_Voyage;
	billOfLading	: CM_BOL;
	trackedItem		: CM_TrackedItem;	
	filesToDelete 	: CM_EDIFileSet;
	terminal		: CM_Terminal;
	
	prevUseCargoAndSubTypeAsDef : Boolean;
	prevDefCommodity 			: String;
	cargoType 					: CM_CargoType;
	selectedCargoTypes			: ObjectArray;
	commodity		 			: CM_Commodity;
begin
	
	terminal	:= self.getTerminal();
	passportObj	:= app.myPassport;
	
	//Preserve previous config value
	prevUseCargoAndSubTypeAsDef := terminal.getConfig(UseCargoAndSubTypeAsDef).Boolean;
	
	//Set Config to true
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, true);
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.assertTrueMsg( cargoType &lt;&gt; null, "Cargo Type of '" &amp; Cargo_Type &amp; "' not found during setup.");
	
	//Preserve previous commodity value
	prevDefCommodity := cargoType.defaultCommodityCode;
	
	//create commodity we don't need to delete commodity before re-creating as this is being deleted in the addCommodity method.
	create selectedCargoTypes transient;
	selectedCargoTypes.add(cargoType);	
	commodity := self.addCommodity(CommodityCode, "UT Commodity Default", selectedCargoTypes);
	beginTransaction;
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, CommodityCode);
	commitTransaction;
	
	self.deleteVoyage(VoyageName);
	voyageObj	:=	self.getVoyage(VoyageName);
	self.assertIsDeleted(voyageObj);
	
	self.deleteVessel(ShipName);
	vesselObj := self.getVessel(ShipName);
	self.assertIsDeleted(vesselObj);
	
	// now set up cleanly
	vesselObj := self.addVesselGeneralCargo(ShipName, self.getOperator(TestOperator), 10);
	self.assertNotNullMsg(vesselObj, 'Add vessel failed');

	voyageObj	:= self.addVoyageWithGeneralCargoStruc(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													10);
	self.assertNotNullMsg( voyageObj, 'Add voyage failed' );
	voyageObj := self.getVoyage(VoyageName);
	self.assertNotNull(voyageObj);
	
	create filesToDelete transient;
	
	ediText := self.zInputShipManifest(VoyageName);

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, UserDefineName, method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	
	self.assertNotNull(ediFileObj.ediData);		
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();

	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);

	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 54, "incorrect number of EDI trackedItems");
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	self.assertEqualMsg(voyage.allBOLInByTypeStatusNumDT.size, 4, "");
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 42, "");
	
	billOfLading := self.getBOL("BOLVOYSHIPGEN444161", 5003, "MSK");
	self.assertNotNull(billOfLading);
	self.assertEqualMsg(billOfLading.allBOLDtls.size, 1, "");
	self.assertEqualMsg(billOfLading.allTrackedItems.size, 0, "");
	
	billOfLading := self.getBOL("BOLVOYSHIPGEN44416", 5003, "MSK");
	self.assertNotNull(billOfLading);
	self.assertEqualMsg(billOfLading.allBOLDtls.size, 3, "");
	self.assertEqualMsg(billOfLading.allTrackedItems.size, 18, "");
	
	billOfLading := self.getBOL("BOLVOYSHIPGEN444162", 5003, "MSK");
	self.assertNotNull(billOfLading);
	self.assertEqualMsg(billOfLading.allBOLDtls.size, 1, "");
	self.assertEqualMsg(billOfLading.allTrackedItems.size, 8, "");
	
	billOfLading := self.getBOL("BOLVOYSHIPGEN444163", 5003, "MSK");
	self.assertNotNull(billOfLading);
	self.assertEqualMsg(billOfLading.allBOLDtls.size, 1, "");
	self.assertEqualMsg(billOfLading.allTrackedItems.size, 16, "");
	
	trackedItem := voyage.allOnshipTIsByIdCargoType.getAtKey("KPAI8063793",1);
	self.assertNotNull(trackedItem);
	self.assertTrueMsg( trackedItem.clientRef = "12345", "clientRef should be '12345'");
	trackedItem := voyage.allOnshipTIsByIdCargoType.getAtKey("KPAH8063770",1);
	self.assertNotNull(trackedItem);
	self.assertEqualMsg(trackedItem.getSealNumShipper(), "SHSEAL1,SHSEAL2", "Incorrect Terminal Operator Seal");
	
	//Test Commodity value	
	self.assertEqualMsg(trackedItem.commodity, CommodityCode, "Prenote ' " &amp; "KPAI8063793" &amp;  "' default commodity is incorrect");
	
	filesToDelete.add(ediFileObj);
epilog
	//Revert config to the orginal value
	self.setTerminalConfig(UseCargoAndSubTypeAsDef, prevUseCargoAndSubTypeAsDef);	
	
	beginTransaction;
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, prevDefCommodity);
	commitTransaction;
	
	//clean up the successfull ones from the EDI Operations Form.... ( cos these ones were from successfull tests )
	foreach ediFileObj in filesToDelete do
		if ediFileObj.ediData &lt;&gt; null then
			app.myTrxDA.trxDeleteEDIData(ediFileObj.ediData, app.myPassport);
		endif;
	endforeach;

	delete filesToDelete;
	delete selectedCargoTypes;	
end;
</source>
    </JadeMethod>
