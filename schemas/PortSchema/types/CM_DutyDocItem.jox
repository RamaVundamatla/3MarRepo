    <JadeMethod name="delete" id="bab93b3d-2856-420d-aefa-924fdd192ac3">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if self.isTransient then
			return;
	endif;

	if self.myDutyDoc &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(self.myDutyDoc,self.myDutyDocTerminalRoot.myTerminal.getTerminalEvent(EVENT_DUTYDOCITEM_UPDATE),self);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDelivOrderExpiryDateLocalTZ" id="73f963f4-aa0b-40dd-8534-4ce530196672">
        <source>getDelivOrderExpiryDateLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	expiryTS : TimeStamp;
begin
	expiryTS.cnEcSetDateAndTime(self.deliveryOrderExpiryDate,TimeEndOfDay);
	
	return self.systemToLocalTime(expiryTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b300d6cb-ca32-4837-913c-ee3f03cd9291">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

	hsCodeObj : CM_DutyDocHSCode;
	
begin

	if _attrName = ETRow_Id then
		return self.cargoId;
	elseif _attrName = ETRow_Description then
		return self.cargoDetails;
	elseif _attrName = ETRow_Do then
		return self.deliveryOrder;
	elseif _attrName = ETRow_DoExp then
		return self.deliveryOrderExpiryDate.asStringJMT();
	elseif _attrName = ETRow_HsCodeDescription then
		hsCodeObj:= self.getMyHSCode;
		if hsCodeObj &lt;&gt; null then
			return hsCodeObj.longDescription;
		endif;
		return null;
	elseif _attrName = ETRow_LocalInsurance then
		return self.insurance.asStringJMT;
	elseif _attrName = ETRow_LocalFreight then
		return self.freight.asStringJMT;
	elseif _attrName = ETRow_NetValue then
		return self.getNetValue.asStringJMT;
	elseif  _attrName = ETRow_RateInPcent then
		return self.dutyRate.asStringJMT;
	elseif _attrName = ETRow_DutyExempt then
		return (self.exemptDutyCode &lt;&gt; null or self.exemptBenefit &lt;&gt; null or self.exemptSource &lt;&gt; null).Boolean.getYesNo();  // 34042
	elseif _attrName = ETRow_Packing then
		return self.getPackingTypeString();
	elseif _attrName = ETRow_VehicleMake then
		return null;
	elseif _attrName = ETRow_Colour then
		return null;
	elseif _attrName = ETRow_VccNo then
		return null;
	elseif _attrName = ETRow_VccDate then
		return null;
	elseif _attrName = ETRow_VehicleMake then
		return null;
	elseif _attrName = ETRow_VehicleModel then
		return null;
	elseif _attrName = ETRow_ChassisNo then
		return null;
	elseif _attrName = ETRow_EngineNo then
		return null;
	elseif _attrName = ETRow_NumberPlate then
		return null;
	elseif _attrName = ETRow_VehicleType then
			return null;
	else
		
		if self.class.findProperty(_attrName) &lt;&gt; null then
			return inheritMethod( _attrName, _short );
		else
			if self.myTrackedItem &lt;&gt; null then
				return self.myTrackedItem.getDisplayStringForAttribute( _attrName, _short );
			else
			
				return null;
			endif;
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyBOL" id="deeba7be-8b0f-4d04-97ac-6dd4803c45e5">
        <source>getMyBOL() : CM_BOL;
vars
	voyage: CM_Voyage;
begin
	voyage := self.getMyVoyage();
	if voyage = null or self.bol = null then
		return null;
	endif;
	
	return voyage.getBOL(self.bol);
end;
</source>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="getMyConsignee" id="e536f0e2-ebf8-49b3-8e3c-5f599cf0f455">
        <source>getMyConsignee() : CM_ConsigneeConsignor;
vars

begin
	
	if self.consignee = null then
		return null;
	endif;
	
	return app.myRoot.allConsigneeConsignors[self.consignee];
	
epilog

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getMyFreightForwarder" id="b8c61b65-9819-452f-95af-843d0778ff15">
        <source>getMyFreightForwarder() : CM_ConsigneeConsignor;
vars
	operator: CM_Operator;
begin
	operator := self.getMyOperator();
	if operator &lt;&gt; null then
		return operator.allFFsForBookRefUpdate.first;
	endif;
epilog

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getMyHSCode" id="803f87f5-2a15-4fed-ace6-4ac292aa8524">
        <source>getMyHSCode() : CM_DutyDocHSCode;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	
begin
	if self.hsCode &lt;&gt; null and self.hsCode.isInteger64 then
		 return app.myDutyDocRoot().allDutyDocHSCodes.getAtKey( self.hsCode.Integer64 );
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_DutyDocHSCode"/>
    </JadeMethod>
    <JadeMethod name="getMyOperator" id="bf04c5f2-c375-4448-9554-d715f218e0f1">
        <source>getMyOperator() : CM_Operator;
vars
	ti: CM_TrackedItem;
begin
	ti := self.getMyTrackedItem();
	if ti &lt;&gt; null then
		return ti.myOperator;
	endif;
epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="1c53a092-46ed-4224-a570-e661e9b29e29">
        <source>getMyTerminal():CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2012	cnwndl1	Initial creation

*/

vars

begin

	if self.myDutyDocTerminalRoot &lt;&gt; null then
		return self.myDutyDocTerminalRoot.myTerminal;
	endif;
	
	return null;

epilog

end;</source>
