    <JadeMethod name="folderObject" id="005f1879-b82a-47fc-87cc-6cb57c0ddecb">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>folderObject(set_:Boolean; value_:IDispatch io) updating, mapping;
	// Returns a reference to an Active Messaging folder object.

vars
	v : IDispatch;

begin
	if not set_ then
		_jadeActiveXProperty('FolderObject', '', set_, v);
		if v = null then
			value_ := null;
		else
			value_ := v.IDispatch._morph(IDispatch).IDispatch;
		endif;
	else
		_jadeActiveXProperty('FolderObject', '', set_, value_);
	endif;
end;
</source>
        <Parameter name="set_" type="Boolean"/>
        <Parameter name="value_" type="IDispatch" usage="io"/>
    </JadeMethod>
