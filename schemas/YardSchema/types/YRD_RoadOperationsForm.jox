    <JadeMethod name="mnuToggleMultiSelect_click" id="b46322e3-1b87-475b-bfaa-16d46000b703">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuToggleMultiSelect_click(menuItem: MenuItem input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
03 August 2006	cnwer1	Initial creation - PAR#xxxx
30/04/2010	cnwmh5	Add setting of all tables multiSelect value
*/
vars
	wleTable : CM_DataTable;
	multiSelectValue	: Integer;		// 
begin
	wleTable := self.mnuTableContext.userObject.CM_DataTable;
	
	if wleTable &lt;&gt; null and wleTable.multiSelect = CM_DataTable.MultiSelect_Simple then
		multiSelectValue := CM_DataTable.MultiSelect_None;
	else
		multiSelectValue := CM_DataTable.MultiSelect_Simple;		
	endif;
	
	menuItem.checked := not menuItem.checked;
	self.initAreaTablesMultiSelect(multiSelectValue);
	
	/*
	// 30/04/2010 cnwmh5 #23634 - replaced
	if wleTable.multiSelect = CM_DataTable.MultiSelect_Simple then
		wleTable.multiSelect := CM_DataTable.MultiSelect_None;
		menuItem.checked := false;	
	else
		wleTable.multiSelect := CM_DataTable.MultiSelect_Simple;		
		menuItem.checked := true;			
	endif;
	*/

epilog

end;</source>
