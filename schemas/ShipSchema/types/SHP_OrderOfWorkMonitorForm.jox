    <JadeMethod name="doBuildMnuFullPlan" id="52ab108b-4317-4169-bfe1-ec2e9ce07c84">
        <source>doBuildMnuFullPlan(_menu : MenuItem);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:
//		
// 01 Nov 2012		PJS		PAR #30631
// ---------------------------------------------------------------------------
vars
	mnuChild,
	mnuMaster	: MenuItem;
	idx			: Integer;
	crane		: CM_Machine;
	jobSheet	: CM_VoyageJobSheet;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	if not _menu.visible then
		return;
	endif;
	if not app.myPassport.myUser.canDo(self.myTerminal,PmShipCanFullyPlan) then
		return;
	endif;
	//if not app.myRoot.canDo(PmAutoShipPlanning) then
	/*// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)
	if not app.myRoot.canDo(Mod_CargoShip) then	//07 Oct 2019	NDl	TFS 46169
		return;
	endif;
	*/
	
	mnuMaster := _menu;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;

	foreach idx in 1 to 10 do
		mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;
	idx := 0;

	// ### VOYAGE MENU
	idx := idx+1;
	mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(idx); // Clone menu
	endif;
	mnuChild.caption := app.getErrorString(VoyageCapitalV) &amp; " " &amp; self.myCurrentVoyage.code &amp; "...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.userObject := self.myCurrentVoyage;
	mnuChild.helpContextId := CMIF_ShipPlanningController.Mode_Voyage;
	
	
	// ### EACH CRANE MENU
	foreach jobSheet in self.myCurrentVoyage.allJobSheets do
		crane := self.myTerminal.machines[jobSheet.crane.trimBlanks];
		
		if crane &lt;&gt; null  then
			idx := idx+1;
			mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
			if mnuChild = null then
				mnuChild := mnuMaster.loadSubMenu(idx); // Clone menu
			endif;
			mnuChild.caption := crane.getDisplayDetails(false) &amp; "...";
			mnuChild.visible := true;
			mnuChild.enabled := true;
			mnuChild.userObject := crane;
			mnuChild.helpContextId := CMIF_ShipPlanningController.Mode_Crane;
		endif;
	endforeach; 

	// ### SELECTED JOBS MENU
	idx := idx+1;
	mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(idx); // Clone menu
	endif;
	if _menu = self.mnuFullLoadPlan then
		mnuChild.caption := app.getErrorString(Selected_Jobs_CTRL_L);  //30631
	else
		mnuChild.caption := app.getErrorString(Selected_Jobs_Dots); //30631
	endif;
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.userObject := null;
	mnuChild.helpContextId := CMIF_ShipPlanningController.Mode_Job;
	
end;</source>
        <Parameter name="_menu" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="3f1077c5-2865-41f3-b284-64c711af4933">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars	
	theReturn : Integer;
	result : Integer;
	jobs : CM_VoyageJobSet;
begin
	if self.myCurrentJob = null then
		app.msgBox(app.getErrorString(Please_select_job_delete),app.getErrorString(Delete_Job), MsgBox_OK_Only);
		return;
	endif;
	
	theReturn := app.msgBox(app.getErrorString2(ConfirmDelete, app.getErrorString(The_selected_jobs), ''),app.getErrorString(Confirm_Job_Delete), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	if theReturn = MsgBox_Return_No then
		return;
	endif;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	//epr TFS 1925 29/4/16 removed code just call one trx and copies selected to a collection to avoid 1308 exception
	create jobs transient;
	self.getAllSelectedJobs(jobs,false);
	
	while true do
		app.myTrxDA.trxDeleteVoyageJobs(jobs, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;			
	
epilog
	delete jobs;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFullyLoadPlan" id="e70bdcb9-8eb3-4203-8e69-84e888e97f63">
        <source>doFullyLoadPlan(_menuItem : MenuItem);
/*

Date		Who		Reason
27 March 2017	cnwer1	Initial creation TFS

*/

vars
	voyage : CM_Voyage;
	jobs : CM_JobArray;
	aJS : CM_JobSheet;
	mode : Integer;
begin
	if _menuItem.helpContextId = null then
		return;
	endif;
	
	create jobs transient;
	mode:= _menuItem.helpContextId;
	
	if mode = CMIF_ShipPlanningController.Mode_Voyage then
		foreach aJS in self.myCurrentVoyage.allJobSheets discreteLock do
			aJS.getJobsForPlanning(jobs);
		endforeach;
		voyage:=self.myCurrentVoyage;
		aJS := null;
	elseif mode = CMIF_ShipPlanningController.Mode_Crane then
		aJS := self.myCurrentVoyage.allJobSheets[_menuItem.userObject.CM_Crane.id];
		aJS.getJobsForPlanning(jobs);
	elseif mode = CMIF_ShipPlanningController.Mode_Job then
		self.getAllSelectedJobs(jobs,true);
	else
		return;
	endif;
	
	self.myAssistant.showShipFullyPlanForm(voyage, jobs, aJS.CM_VoyageJobSheet, mode, self.myMasterMenuAction);
epilog
	
	delete jobs;

end;</source>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doFullyUnplan" id="8b71aa5a-849d-4eee-8d57-fc84a90a3bb1">
        <source>doFullyUnplan(_menuItem : MenuItem);
/*

Date		Who		Reason
27 March 2017	cnwer1	Initial creation TFS

*/

vars
	voyage : CM_Voyage;
	jobs : CM_VoyageJobSet;
	aJS : CM_JobSheet;
	mode : Integer;
	result : Integer;
begin
	if _menuItem.helpContextId = null then
		return;
	endif;
	
	
	create jobs transient;
	mode:= _menuItem.helpContextId;
	
	if mode = CMIF_ShipPlanningController.Mode_Voyage then
		foreach aJS in self.myCurrentVoyage.allJobSheets discreteLock do
			aJS.getJobsForPlanning(jobs);
		endforeach;
		voyage:=self.myCurrentVoyage;
		aJS := null;
	elseif mode = CMIF_ShipPlanningController.Mode_Crane then
		aJS := self.myCurrentVoyage.allJobSheets[_menuItem.userObject.CM_Crane.id];
		aJS.getJobsForPlanning(jobs);
	elseif mode = CMIF_ShipPlanningController.Mode_Job then
		self.getAllSelectedJobs(jobs,true);
	else
		return;
	endif;
	
	if jobs.isEmpty then
		return;
	endif;
	
	
	while true do
		app.myTrxUA.trxUpdateVoyageJobsUnplan(jobs, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(LoadPlanInfo_UnplanVoyageJobs), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
epilog
	delete jobs;
end;</source>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doLoadUnloadToOps" id="4f250427-1993-41b8-9aa5-8410ed1d5eef">
        <updating/>
        <source>doLoadUnloadToOps(_doOppositeOfJobValue, _loadToOps : Boolean ) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 1/11/2012	PJS			PAR #30631 - translation
// ---------------------------------------------------------------------------

vars
	theJob,
	theProxyJob : CM_VoyageJob;
	loadState,load2Ops : Boolean;
	result		: Integer;
	jobs : CM_VoyageJobArray;
begin

	if self.myCurrentJob = null then
		app.msgBox(app.getErrorString(Please_Select_Job_Operations),app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	self.mousePointer := Window.MousePointer_HourGlass;
	
	create jobs transient;// AKB2007JULY - DCT EXCEPTION
	self.getAllSelectedJobs(jobs,false);
		
	foreach theJob in jobs do
			
		if (theJob.CM_VoyageJob.jobType &lt;&gt; JOB_TYPE_LOAD) and (theJob.CM_VoyageJob.jobType &lt;&gt; JOB_TYPE_DISCHARGE)
			and (theJob.CM_VoyageJob.jobType &lt;&gt; JOB_TYPE_SOB) then
			continue;
		endif;
		
		if _doOppositeOfJobValue then
			load2Ops := not theJob.isLoadedToOperations;
		else
			load2Ops:=_loadToOps;
			if load2Ops and theJob.isLoadedToOperations then
				continue;
			endif;
			
			if not load2Ops and not theJob.isLoadedToOperations then
				continue;
			endif;
		endif;

		delete theProxyJob;
		
		app.cmsBeginLoad(loadState);
		theProxyJob := theJob.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);

		while true do 
			app.myTrxUA.trxUpdateVoyageJobLoadUnload(theProxyJob, load2Ops, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return;
		endwhile;
		
	endforeach;

	global.beep;
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	delete theProxyJob;
	delete jobs;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_doOppositeOfJobValue" type="Boolean"/>
        <Parameter name="_loadToOps" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuild" id="92fa8f5a-e627-4d67-be2f-4b1eb6fb85e8">
        <updating/>
        <source>doMnuContextBuild(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 17/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
// 23/06/2020   cnwma1		Bug 49384: PEN - Problem with splitting jobs
vars
	allVoyageJobs : CM_VoyageJobArray;		// TFS 47144
	job 		  : CM_VoyageJob;			// TFS 47144
	
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return true;
	endif;	
	if self.myCurrentJob = null then
		self.doMnuContextNullObject();
		return false;
	endif;
	self.mnuInspect.visible := app.isAllowedToInspect;	
	//cnwjo3 ccms 1178 par 23366
	self.mnuJobSplit.visible := true;
	// TFS 47144 start
	self.mnuJobTransfer.visible := true;
	self.mnuJobSplit.enabled    := true;
	self.mnuJobTransfer.enabled := true;
	create allVoyageJobs transient;
	self.getSelectedForTable(allVoyageJobs, self.myCurrentTable, false);
	
	/* 23/06/2020 cnwma1 #49384
	if allVoyageJobs.size = 1 then
		if allVoyageJobs.first.CM_VoyageJob.status = JOB_UNACTIONED then
			self.mnuJobSplit.enabled := false;
		else
			self.mnuJobTransfer.enabled := false;
		endif;
	else
		self.mnuJobSplit.enabled := false;
		foreach job in allVoyageJobs do
			if not job.status = JOB_UNACTIONED then
				self.mnuJobTransfer.enabled := false;
				break;
			endif;
		endforeach;
	endif;
	*/
	if allVoyageJobs.isEmpty  then                 //23/06/2020 cnwma1 #49384
		self.mnuJobTransfer.enabled := false;
	endif;
	// TFS 47144 end
	self.mnuJobMoveCargo.visible := false;
	if self.myCurrentJob &lt;&gt; null then
		if self.myCurrentJob.isDischarge and app.getMyUser.canDo(self.myTerminal,PmAdmMoveCargoFromJob) then
			self.mnuJobMoveCargo.visible := true;
		endif;
	endif;
	self.mnuJobCargoList.visible := true;
	
	self.mnuFullLoadPlan.visible := true;
	self.mnuFullLoadUnplan.visible := true;
	self.doBuildMnuFullPlan(self.mnuFullLoadPlan);
	self.doBuildMnuFullPlan(self.mnuFullLoadUnplan);
	
	self.mnuJobDelete.visible := true;
	self.mnuJobNew.visible := true;
	self.mnuJobUnloadOps.visible := self.myCurrentJob.isLoadedToOperations;
	self.mnuJobLoadToOps.visible := not self.myCurrentJob.isLoadedToOperations;

	if self.myCurrentJob.myJobSheet.allJobsByOrder.first = self.myCurrentJob then
		self.mnuJobMoveUp.visible := false;
		self.mnuJobMoveDown.visible := true;
	elseif self.myCurrentJob.myJobSheet.allJobsByOrder.last = self.myCurrentJob then
		self.mnuJobMoveDown.visible := false;
		self.mnuJobMoveUp.visible := true;
	else
		self.mnuJobMoveDown.visible := true;
		self.mnuJobMoveUp.visible := true;
	endif;

	self.mnuRemarks.visible:=true;
	self.mnuRenumber.visible:=true;
	//02 Apr 2012	NDL	Par 29369
	self.mnuCraneHours.visible := self.myCurrentVoyage &lt;&gt; null;
	
	self.mnuColumnOrganiser.visible:=true;
	
	return self.showContextMenu(self.mnuContext,cntrl,conwin,mouse,x, y);
epilog
	delete allVoyageJobs;				// TFS 47144
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuContextNullObject" id="4a5c52b7-a5f9-4acd-903f-d627cc384a8b">
        <source>doMnuContextNullObject();
//-----------------------------------------
// Created: December 2003 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	----------	---------------------------------
// 17/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
vars
begin
	self.mnuJobCargoList.visible := false;

	self.mnuJobDelete.visible := false;
	self.mnuJobDelete.userObject := null;
	self.mnuJobEdit.visible := false;
	self.mnuJobEdit.userObject := null;
	self.mnuJobNew.visible := false;

	self.mnuJobLoadToOps.visible := false;
	self.mnuJobUnloadOps.visible:=false;
	self.mnuJobSplit.visible:=false;
	self.mnuJobTransfer.visible := false;			// TFS 47144
	self.mnuJobMoveCargo.visible :=false;
	
	self.mnuJobMoveDown.visible := false;
	self.mnuJobMoveUp.visible := false;
	self.mnuRemarks.visible:=false;
	self.mnuRenumber.visible:=false;
	
	self.mnuCraneHours.visible := self.myCurrentVoyage &lt;&gt; null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveJob" id="dd924a31-298f-4cbe-bec6-49af4a28dd6d">
        <updating/>
        <source>doMoveJob(_moveIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//01 Nov 2012	PJS			PAR #30631 - Voyage Rationalisation
// ---------------------------------------------------------------------------

vars
	theVoyage			: CM_Voyage;
	theJob				: CM_VoyageJob;
	theVoyageJS			: CM_VoyageJobSheet;
	index	: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	theVoyage := self.myCurrentVoyage;
	if theVoyage = null then
		return;
	endif;
	
	if self.myCurrentJob = null then
		app.msgBox(app.getErrorString(Please_Select_Job_Move),app.getErrorString(Job_Move_Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	theJob := self.myCurrentJob;	
	
	theVoyageJS := self.myCurrentJob.myJobSheet.CM_VoyageJobSheet;
	
	if theVoyageJS = null then
		app.msgBox(app.getErrorString(Job_Sheet_Could_Not_Found) &amp; " " &amp; theVoyage.code &amp; "/" &amp; theJob.jobId ,app.getErrorString(Job_Move_Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.myCurrentTable.allSelectedObjects.size &gt; 1 then
		app.msgBox(app.getErrorString(Only_1_Moved_Time) ,app.getErrorString(Job_Move_Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	index := theVoyageJS.allJobsByOrder.indexOf(theJob);
	if index &gt; 0 then
		if index =1 and _moveIndex = -1 then
			return;
		endif;
		if index = theVoyageJS.allJobsByOrder.size and _moveIndex = 1 then
			return;
		endif;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxShiftJobInJobSheet(theJob, app.myPassport, (_moveIndex));
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
		
		//epr TFS 830 job move handled by notes 21/3/17		
	endif;

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_moveIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doOpenSplitCrane" id="a42c4af3-3e7d-4379-81c8-aca322e315c0">
        <source>doOpenSplitCrane();
/*

Date		Who		Reason
27/03/2017	cnwer1	Initial creation TFS 830
17/12/2019	jlgdap1	TFS 47144 JMT Refactor OOW Job Split Transfer - renamed from doOpenSplitOrTransferCrane
*/

vars

	allVoyageJobs : CM_JobArray;
	job 		 : CM_Job;
begin
	create allVoyageJobs transient;	
	self.getSelectedForTable(allVoyageJobs,self.myCurrentTable,false);
	
	if allVoyageJobs.size &gt; 1 then
	//can only bulk move jobs that are unactioned
		foreach job in allVoyageJobs do
			if job.status &lt;&gt; JOB_UNACTIONED then
				app.msgBox(app.getErrorString1(Bulk_transfer_not_unactioned,job.id), app.getErrorString(Error),MsgBox_OK_Only);
				return;
			endif;
		endforeach;
	endif;
	
	self.myAssistant.showSplitWorkCraneForm( self.myCurrentJob,null,allVoyageJobs);
	
epilog
	
	delete allVoyageJobs;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenTransferCrane" id="b80a0dde-4adb-4d09-afdf-be370af9f71b">
        <source>doOpenTransferCrane();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/12/2019	jlgdap1		Initial creation TFS 47144 JMT Refactor OOW Job Split Transfer
//
vars
	allVoyageJobs : CM_JobArray;
