    <JadeMethod name="positionQueryFrame" id="26139585-298f-45c9-adfa-5bf474bea884">
        <source>positionQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     06/08/2007 cnwvu1
// ---------------------------------------------------------------------------

vars

begin

	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	100;  // TFS 50421 was     50;
	//self.frmQuery.height	:=	320;
	self.frmQuery.height	:=	425; //355;	// 10/02/2009 cnwar2 CCMS1797 (PAR18881)
