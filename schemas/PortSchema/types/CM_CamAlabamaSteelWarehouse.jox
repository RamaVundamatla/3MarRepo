    <JadeMethod name="isEventTypeToBeProcessed" id="a003bef4-3a69-4421-95cf-eca36d0b1856">
        <source>isEventTypeToBeProcessed(_camProtocol: CM_CamProtocol; _trans: CM_EventTransaction): Boolean;

vars

begin
    return inheritMethod(_camProtocol, _trans);
    /*
	return (_trans.type = EVT_TrainDepart or
		    _trans.type = EVT_VoyageDeparture or
		    _trans.type = EVT_TruckDeparture);
    */
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trans" type="CM_EventTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTransactionToBeProcessed" id="17c3a0c7-1579-4b37-88bb-8bd1624b6931">
        <source>isTransactionToBeProcessed(_camProtocol: CM_CamProtocol; _trans: CM_TITransaction; _camAgent : CM_CamControllerAgent): Boolean;
//
//05 Feb 2015	cnwrs1	Par 35630 - reject ship receives not from  'AEP/AMNS' and 'AEP/OKS'
//23 Feb 2015	cnwrs1	Par 35738 - doesn't handle some test data
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//09 Nov 2016	cnwrs1	FTS 2924 1090 on voyage for tranship
//
vars
	voyage : CM_Voyage;
	theTI : CM_TrackedItem;
	result : Boolean;
	msg : String;
begin
	result := inheritMethod(_camProtocol, _trans, _camAgent);
	if result then
		if _trans.type = TRANS_TYPE_REC_SHIP then
			theTI := _trans.myTrackedItem;
			voyage := _trans.getMyVoyage();
			if voyage = null then
				voyage := theTI.myVoyage;
				if theTI.isTranshipItem then
					if theTI.myImportVoyage &lt;&gt; null then
						voyage := theTI.myImportVoyage;
					endif;
				endif;
			endif;
			if voyage.myVessel &lt;&gt; null then
				if voyage.myVessel.code = 'AEP/AMNS' or
				   voyage.myVessel.code = 'AEP/OKS' or
				   voyage.myVessel.code = 'UT_VES4AST' then
					result := true;
				else
					msg := "Transaction is for wrong Vessel";
					result := false;
				endif;
			else
				msg := "Transaction has no Voyage/Vessel";
				result := false;
			endif;
		endif;
	endif;
	if result = false then
		if _camAgent &lt;&gt; null and
			_camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_trans, msg);
		endif;
	endif;
	return result;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processBooking" id="15f936d6-78de-420b-8cf1-d5eddc321447">
        <source>processBooking(_booking : CM_BookingRef; _bookingNum : String; _xmlElement : JadeXMLElement io; _transMode : Character) protected;
//
///29 Dec 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//22 Jan 2015	cnwrs1	Par 35539/35540 - AST EDI Formatting 
//02 Feb 2015	cnwrs1	Par 35540 - AST get booking quanity and weight from booking item
//05 Feb 2015	cnwrs1	Par 35630 - AST fix the booking.getTotalQuantity and getTotalWeight
//27 Jun 2017   cnwgb1  TFS 4673 - AST Not including voyage and vessael for EtI
//
constants
	BargeMode =  'B';
vars
	element : JadeXMLElement;
	measureType : CM_MeasurementType;
	dimStr : String;
	quantity : Integer;
	weight : Decimal[14,4];
begin
	if _booking = null and
	   _bookingNum = null then 
		return;
	endif;
	if _booking &lt;&gt; null then
		//if _transMode = BargeMode then // 4673 cnwgb1 27.June.2017
        element := _xmlElement.addElement("vessel");
        element.addText(_booking.vesselName);	//vessel name
        element := _xmlElement.addElement("vessel_voyage");
        element.addText(_booking.voyageCode);	//voyage Code
		//endif; // 4673 cnwgb1 27.June.2017
		element := _xmlElement.addElement("booking_nbr");
		element.addText(_booking.bookingReference);	//booking number
		quantity := _booking.getTotalQuantity();
		if quantity &lt;&gt; 0 then
			element := _xmlElement.addElement("booking_units");
			element.addText(quantity.String);	//booking quantity
		endif;
		weight := _booking.getTotalWeight();
		if weight &gt; 0 then
			element := _xmlElement.addElement("booking_weight");
			measureType := app.getDefaultMeasurementForType(Type_Weight);
			if measureType = null then
				dimStr := weight.asStringWeightJMT;
			else
				dimStr := app.convertMeasurementForDisplay(measureType.shortName, weight);
			endif;
			element.addText(dimStr);	//booking total weight
		endif;
		element := _xmlElement.addElement("booking_status");
		element.addText("B");
	else
		element := _xmlElement.addElement("booking_nbr");
		element.addText(_bookingNum);	//booking number
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_bookingNum" type="String"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="io"/>
        <Parameter name="_transMode" type="Character"/>
    </JadeMethod>
    <JadeMethod name="processCoil" id="9ca1309f-1b19-4066-890f-c11a56f34496">
        <source>processCoil(_ti : CM_TrackedItem; _xmlElement : JadeXMLElement io; _isExport : Boolean) protected;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//22 Jan 2015	cnwrs1	Par 35539/35540 - AST EDI Formatting 
//26 Jan 2015	cnwrs1	Par 35564/35567 - AST no coIl Qty in coil
//03 Feb 2015	cnwrs1	Par 35540 - AST coIl Qty in coil for Exports
//
vars
	element : JadeXMLElement;
	measureType : CM_MeasurementType;
	dimStr : String;
	quantity : Integer;
begin
	if _ti = null then
		return;
	endif;
	element := _xmlElement.addElement("coil_nbr");
	element.addText(_ti.id);
//	element := _xmlElement.addElement("booking_nbr");
//	element.addText(_ti.bookingReference);	//booking number
	if _isExport then 
		element := _xmlElement.addElement("coil_qty");
		if _ti.quantity = 0 then
			quantity := 1;
		else
			quantity := _ti.quantity;
		endif;
		element.addText(quantity.String);
	endif;
	element := _xmlElement.addElement("coil_weight");
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType = null then
		dimStr := _ti.totalWeight.asStringWeightJMT;
	else
		dimStr := app.convertMeasurementForDisplay(measureType.shortName, _ti.totalWeight);
	endif;
	element.addText(dimStr);
end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="io"/>
        <Parameter name="_isExport" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="743cf96c-a78e-4edd-9c69-1a6a4425ce46">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
//
//11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//
//29 Dec 2014	cnwrs1	Par 35419 - add additional data
//22 Jan 2015	cnwrs1	Par 35539/35540 - AST EDI Formatting 
//26 Jan 2015	cnwrs1	par 35564/35566/35573 - units 1 uom Units coli qty removed / Stevedore carrier should be from vehicleVisitRecord / 1090 when trying to produce train remarks with no train 
//03 Feb 2015	cnwrs1	Par 35540 - AST coIl Qty in coil for Exports
//23 Feb 2015	cnwrs1	Par 35738 - doesn't handle some test data
//18 Sep 2017   cnwma1	TFS #6614 AST - Vehicle Visit Number for Service Order in Road Process
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.

constants
	BargeMode =  'B';
	RailMode = 'R';
	TruckMode = 'T';
	InputMode = 'I';
	OutputMode = 'O';
	ExportMode = 'E';
	ImportMode = 'I';
vars
	theTI : CM_TrackedItem;
	voyage: CM_Voyage;
	train : CM_Train;
	wagon : CM_Wagon;
    vehicleVisitRecord : CM_VehicleVisitRecord;
	bookingRef : CM_BookingRef;
	bolIn : CM_BOLIn;
	camMessage : CM_CamMessage;
	strMsg : String;
	xmlDoc : JadeXMLDocument;
	rootElement : JadeXMLElement;
	attrib : JadeXMLAttribute;
	element : JadeXMLElement;
	soElement : JadeXMLElement;
	cargoElement : JadeXMLElement;
	coilElement : JadeXMLElement;
	tiArray : CM_TIArray;
	tiInExArray : CM_TIArray;
	tiOutExArray : CM_TIArray;
	tiInImArray : CM_TIArray;
	tiOutImArray : CM_TIArray;
	tiSteveImArray : CM_TIArray;
	tiSteveExArray : CM_TIArray;
	posStart, posEnd : Integer;
	strID : String;
	orderNum : Integer;
	count : Integer;
	cargoType : Integer;
	subType : String;
	iter : Iterator;
	seq : Integer;
	transMode : Character;
	imExType : Character;
	serviceOrder : String;
	transType : String;
	isExport : Boolean;
	isImport : Boolean;
	isIn : Boolean;
	isOut : Boolean;
	isInOrOut : Boolean;	//if in and out then need seperate messages for each
	isImEx : Boolean;
	int : Integer;
	isInvalid : Boolean;
	isStevedoreTransfer : Boolean;
	put : Character;
	bookingNum : String;
	measureType : CM_MeasurementType;
	dimStr : String;
begin
	on Exception do app.handleDeletedObject(exception, theTI, isInvalid);
	on Exception do app.handleDeletedObject(exception, voyage, isInvalid);
	on Exception do app.handleDeletedObject(exception, train, isInvalid);
	on Exception do app.handleDeletedObject(exception, wagon, isInvalid);
	on Exception do app.handleDeletedObject(exception, vehicleVisitRecord, isInvalid);
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.type.asStringJMT);
	create tiInExArray transient;
	create tiInImArray transient;
	create tiOutExArray transient;
	create tiOutImArray transient;
	create tiSteveImArray transient;
	create tiSteveExArray transient;
	create tiArray transient;
	if _transaction.type = EVT_VoyageDeparture then
		voyage := _transaction.getVoyage();
		if voyage = null then
			return;
		endif;
		transMode := BargeMode;
		if voyage &lt;&gt; null then
			serviceOrder := voyage.externalRef;
		endif;
		if voyage.allOnshipTIsByCargoTypeId.size &lt;&gt; 0 then
			foreach theTI in voyage.allOnshipTIsByCargoTypeId do
				if theTI.isExport then
					isExport := true;
					tiOutExArray.add(theTI);
				endif;
				if theTI.isImport then
					isImport := true;
					tiOutImArray.add(theTI);
				endif;
			endforeach;
			isOut := true;
		endif;
		if voyage.allOnsiteTIsByCargoTypeId.size &lt;&gt; 0 then
			foreach theTI in voyage.allOnsiteTIsByCargoTypeId do
				if theTI.isExport then
					isExport := true;
					tiInExArray.add(theTI);
				endif;
				if theTI.isImport then
					isImport := true;
					tiInImArray.add(theTI);
				endif;
			endforeach;
			isIn := true;
		endif;
	elseif _transaction.type = EVT_TrainDepart then
		train := _transaction.CMEVT_TrainTransaction.myTrain;
		if train = null then
			return;
		endif;
		transMode := RailMode;
		if theTI &lt;&gt; null then
			serviceOrder := theTI.remarks;
		endif;
		if train.allTIsReleased.size &lt;&gt; 0 then
			foreach theTI in train.allTIsReleased do
				if theTI.isExport then
					isExport := true;
					tiOutExArray.add(theTI);
				endif;
				if theTI.isImport then
					isImport := true;
					tiOutImArray.add(theTI);
				endif;
			endforeach;
			isOut := true;
		endif;
		if train.allTIsReceived.size &lt;&gt; 0 then
			foreach theTI in train.allTIsReceived do
				if theTI.isExport then
					isExport := true;
					tiInExArray.add(theTI);
				endif;
				if theTI.isImport then
					isImport := true;
					tiInImArray.add(theTI);
				endif;
			endforeach;
			isIn := true;
		endif;
	elseif _transaction.type = EVT_WagonDeparted or
		_transaction.type = EVT_WagonConfirmed then
	//	if _transaction.type = EVT_WagonDeparted then
		train := _transaction.CMEVT_WagonTransaction.myTrain;
		wagon := _transaction.CMEVT_WagonTransaction.myWagon;
	//	elseif _transaction.type = EVT_WagonConfirmed then
	//		train := _transaction.CMEVT_WagonTransaction.myTrain;
	//		wagon := _transaction.CMEVT_WagonTransaction.myWagon;
	//	endif;
		if train = null and 
		   wagon = null then
			return;
		endif;
		transMode := RailMode;
		if theTI &lt;&gt; null then
			serviceOrder := theTI.remarks;
		endif;
		if wagon.allTIsReleased.size &lt;&gt; 0 then
			foreach theTI in wagon.allTIsReleased do
				if theTI.isExport then
					isExport := true;
					tiOutExArray.add(theTI);
				endif;
				if theTI.isImport then
					isImport := true;
					tiOutImArray.add(theTI);
				endif;
			endforeach;
			isOut := true;
		endif;
		if wagon.allTIsReceived.size &lt;&gt; 0 then
			foreach theTI in wagon.allTIsReceived do
				if theTI.isExport then
					isExport := true;
					tiInExArray.add(theTI);
				endif;
				if theTI.isImport then
					isImport := true;
					tiInImArray.add(theTI);
				endif;
			endforeach;
			isIn := true;
		endif;
	elseif _transaction.type = EVT_TruckDeparture then
		vehicleVisitRecord := _transaction.getVehicleVisit;	//inxmast it is _transaction.CMEVT_TruckDeparture.myVisit;
		if vehicleVisitRecord = null then
			return;
		endif;
		transMode := TruckMode;
		if self.specialStevedore(vehicleVisitRecord.carrierCode) then
			isStevedoreTransfer := true;
		endif;
		if theTI &lt;&gt; null then
			//serviceOrder := theTI.remarks;				  //cnwma1 18.9.2017 cnwma1 TFS #6614
			serviceOrder := vehicleVisitRecord.visitNumber;   //cnwma1 18.9.2017 cnwma1 TFS #6614
		endif;
		if vehicleVisitRecord.allReleasedTrackedItems.size &lt;&gt; 0 then
			foreach theTI in vehicleVisitRecord.allReleasedTrackedItems do
				if theTI.isExport then
					isExport := true;
					if isStevedoreTransfer then
						tiSteveExArray.add(theTI);
					else
						tiOutExArray.add(theTI);
					endif;
				endif;
				if theTI.isImport then
					isImport := true;
					if isStevedoreTransfer then
						tiSteveImArray.add(theTI);
					else
						tiOutImArray.add(theTI);
					endif;
				endif;
			endforeach;
			isOut := true;
		endif;
		if vehicleVisitRecord.allReceivedTrackedItems.size &lt;&gt; 0 then
			foreach theTI in vehicleVisitRecord.allReceivedTrackedItems do
				if theTI.isExport then
					isExport := true;
					if isStevedoreTransfer then
						tiSteveExArray.add(theTI);
					else
						tiInExArray.add(theTI);
					endif;
				endif;
				if theTI.isImport then
					isImport := true;
					if isStevedoreTransfer then
						tiSteveImArray.add(theTI);
					else
						tiInImArray.add(theTI);
					endif;
				endif;
			endforeach;
			isIn := true;
		endif;
	else
		return;
	endif;
	foreach int in 1 to 6 do
		tiArray.clear();
		if int = 1 then
			put := OutputMode;
			transType := ImportMode&amp;transMode&amp;OutputMode;
			tiOutImArray.copy(tiArray);
		elseif int = 2 then
			put := InputMode;
			transType := ImportMode&amp;transMode&amp;InputMode;
			tiInImArray.copy(tiArray);
		elseif int = 3 then
			put := OutputMode;
			transType := ExportMode&amp;transMode&amp;OutputMode;
			tiOutExArray.copy(tiArray);
		elseif int = 4 then
			put := InputMode;
			transType := ExportMode&amp;transMode&amp;InputMode;
			tiInExArray.copy(tiArray);
		elseif int = 5 then
			transType := ExportMode&amp;transMode&amp;"R";
			tiSteveExArray.copy(tiArray);
		elseif int = 6 then
			transType := ImportMode&amp;transMode&amp;"R";
			tiSteveImArray.copy(tiArray);
		endif;
		if tiArray.size = 0 then
			continue;
		endif;
		theTI := tiArray.first;
		bookingRef := theTI.myBookingRef;
		if bookingRef = null then
			bookingNum := theTI.bookingReference;
		endif;
		camMessage := self.getCamMessage(_camFile, null, null, CODECO_EDIT, _camProtocol.singleContainerPerBGM);
		create xmlDoc transient;
		xmlDoc.outputDeclaration := true;
		//encoding
		rootElement := xmlDoc.addElement("warehouse_activity");
		soElement := rootElement.addElement("service_order");
		element := soElement.addElement("service_order_nbr");
		element.addText(serviceOrder);
		element := soElement.addElement("trans_date");
		element.addText(_transaction.camsTimeStamp.date.userFormat($CNEC_ANSI_DATE_FORMAT));
		element := soElement.addElement("trans_time");
		element.addText(_transaction.camsTimeStamp.time.formatAsHHmmSS);
		element := soElement.addElement("trans_type");
		element.addText(transType);
		if isStevedoreTransfer then
		else
			element := soElement.addElement("stevedore");
			element.addText("AST");
			element := soElement.addElement("consignee");
			element.addText(theTI.consignee);
			element := soElement.addElement("destination");
			element.addText(theTI.destinationPort);
			element := soElement.addElement("pickup_nbr");
			element.addText(theTI.purchaseOrder);
			if transMode = RailMode then
				element := soElement.addElement("rail_carrier");
				if train &lt;&gt; null then
					element.addText(train.description);		//getCarrierDescr);	// Train carrier
				endif;
				if wagon &lt;&gt; null then
					element := soElement.addElement("rail_car_init");
					if train &lt;&gt; null then
						element.addText(train.code);	//wagon.getType);	// wagon type
					endif;
					element := soElement.addElement("rail_car_nbr");
					element.addText(wagon.id);	//Wagon Number
					element := soElement.addElement("rail_car_type");
					element.addText(wagon.getType());	//train.description.trimRight);	// Train Description
				endif;
				element := soElement.addElement("rail_car_permit");
				if train &lt;&gt; null then
					element.addText(train.remarks);	//);	// Train description
				endif;
			endif;
			if transMode = BargeMode then
				element := soElement.addElement("barge_carrier");
				element.addText(theTI.operatorCode);	// Voyage Operator par35419
				element := soElement.addElement("barge_nbr");
				element.addText(theTI.voyageCode);	// Voyage Code par35419
			endif;
			element := soElement.addElement("shipper");
			element.addText(theTI.operatorCode);	//myOperator.code);
			if transMode = TruckMode then
				if vehicleVisitRecord &lt;&gt; null then
					element := soElement.addElement("truck_carrier");
					element.addText(vehicleVisitRecord.carrierCode);	// Vehicle visit carrier
					element := soElement.addElement("truck_nbr");
					element.addText(vehicleVisitRecord.vehicle.regNumber);	// Vehicle visit reqnumber
				endif;
			endif;
		endif;
	
		cargoElement := soElement.addElement("cargo");
		if isStevedoreTransfer then
			if put = InputMode then
				element := cargoElement.addElement("from_stevedore");
				element.addText(theTI.carrier);
				if vehicleVisitRecord &lt;&gt; null then
					element := cargoElement.addElement("from_location");
					element.addText(vehicleVisitRecord.vehicle.regNumber);
				endif;
				element := cargoElement.addElement("to_stevedore");
				element.addText("AST");
			else
				element := cargoElement.addElement("from_stevedore");
				element.addText("AST");
				element := cargoElement.addElement("to_stevedore");
				element.addText(vehicleVisitRecord.carrierCode);
				if vehicleVisitRecord &lt;&gt; null then
					element := cargoElement.addElement("to_location");
					element.addText(vehicleVisitRecord.vehicle.regNumber);
				endif;
			endif;
			element := cargoElement.addElement("incoming_service_order");
			if voyage &lt;&gt; null then
				element.addText(voyage.externalRef);
			endif;
			element := cargoElement.addElement("incoming_vessel");
			element.addText(theTI.vesselName);	//vessel name par35419
			element := cargoElement.addElement("incoming_vessel_voyage");
			element.addText(theTI.voyageCode);	//voyage Code par35419
			element := cargoElement.addElement("incoming_bol_nbr");
			element.addText(theTI.billOfLading);	//bol
		else
			element := cargoElement.addElement("commodity");
			element.addText(theTI.cargoTypeDescr);	//commodity);
			element := cargoElement.addElement("cargo_marks");
			element.addText(theTI.mark);
			element := cargoElement.addElement("cargo_weight");
			measureType := app.getDefaultMeasurementForType(Type_Weight);
			if measureType = null then
				dimStr := theTI.totalWeight.asStringWeightJMT;
			else
				dimStr := app.convertMeasurementForDisplay(measureType.shortName, theTI.totalWeight);
			endif;
			element.addText(dimStr);
			element := cargoElement.addElement("location");
			element.addText(theTI.locationId);
			element := cargoElement.addElement("incoming_service_order");
			if voyage &lt;&gt; null then
				element.addText(voyage.externalRef);
			endif;
			if transMode = BargeMode then
//				element := cargoElement.addElement("incoming_vessel");
//				element.addText(theTI.vesselName);	//vessel name
//				element := cargoElement.addElement("incoming_vessel_voyage");
//				element.addText(theTI.voyageCode);	//voyage Code
//				element := cargoElement.addElement("import_bol_issuer_scac");
//				element.addText(null);	
//				element := cargoElement.addElement("import_bill_of_lading");
//				element.addText(null);	
				element := cargoElement.addElement("it_vessel");
				element.addText(null);	
				element := cargoElement.addElement("it_vessel_voyage");
				element.addText(null);	
				element := cargoElement.addElement("it_bill_of_lading");
				element.addText(null);	
				element := cargoElement.addElement("it_from_port");
				element.addText(null);	
				element := cargoElement.addElement("it_service_order_number");
				if voyage &lt;&gt; null then
					element.addText(voyage.externalRef);	//null);	
				endif;
			endif;
		endif;
		self.processBooking(bookingRef, bookingNum, cargoElement, transMode);
		coilElement := cargoElement.addElement("coil");
		foreach theTI in tiArray do
			self.processCoil(theTI, coilElement, isExport);
		endforeach;
		strMsg := xmlDoc.writeToString();
		strMsg := strMsg.replaceString('&lt;?xml version="1.0"?&gt;'&amp;CrLf, '');
		strMsg := strMsg.replaceString('&lt;warehouse_activity&gt;'&amp;CrLf, '');
		strMsg := strMsg.replaceString('&lt;/warehouse_activity&gt;', '');
//	strMsg := strMsg.replaceString(CrLf&amp;CrLf, CrLf);
//	strMsg := strMsg.replaceString(CrLf&amp;CrLf, CrLf);
		self.addMessage(camMessage.group3, strMsg );
	endforeach;
epilog
	delete iter;
	delete xmlDoc;
	delete tiInExArray;
	delete tiInImArray;
	delete tiOutExArray;
	delete tiOutImArray;
	delete tiSteveImArray;
	delete tiSteveExArray;
	delete tiArray;
end;
</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="c8dcfc5b-5a21-40be-9b29-ff3a31591bac">
        <updating/>
        <source>processTransaction(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
//
//11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//
//29 Dec 2014	cnwrs1	Par 35419 - add additional data
//09 Jan 2015	cnwrs1	Par 35490 - incorrectly get the voyage
//22 Jan 2015	cnwrs1	Par 35539/35540 - AST EDI Formatting 
//26 Jan 2015	cnwrs1	par 35564/35566/35573 - units 1 uom Units coli qty removed / Stevedore carrier should be from vehicleVisitRecord / 1090 when trying to produce train remarks with no train 
//02 Feb 2015	cnwrs1	Par 35540 - change booking to tranship export booking for Barge tranship Import  
//03 Feb 2015	cnwrs1	Par 35540 - AST coIl Qty in coil for Exports
//05 Feb 2015	cnwrs1	Par 35569 - AST truck out missing data.
//09 Feb 2015	cnwrs1	Par 35656	AST Barge in uses wrong voyage for serviceorder
//11 Feb 2015	cnwrs1	Par 35565 - Remove rail_car_permit
//18 Sep 2017   cnwma1	TFS #6614 AST - Vehicle Visit Number for Service Order in Road Process
//13 Aug 2019	NDL		TFS 45929 - Add back rail_car_permit

constants
	BargeMode =  'B';
	RailMode = 'R';
	TruckMode = 'T';
	InputMode = 'I';
	OutputMode = 'O';
	ExportMode = 'E';
	ImportMode = 'I';
vars
	theTI : CM_TrackedItem;
	camMessage : CM_CamMessage;
	bookingRef : CM_BookingRef;
	vehicleVisitRecord : CM_VehicleVisitRecord;
	train : CM_Train;
	wagon : CM_Wagon;
	voyage : CM_Voyage;
	strMsg : String;
	xmlDoc : JadeXMLDocument;
	rootElement : JadeXMLElement;
	element : JadeXMLElement;
	soElement : JadeXMLElement;
	cargoElement : JadeXMLElement;
	coilElement : JadeXMLElement;
//	bookingElement : JadeXMLElement;
	transMode : Character;
	transType : String;
	imExType : Character;
	put : Character;
	isStevedoreTransfer : Boolean;
	serviceOrder : String;
	bookingNum : String;
	measureType : CM_MeasurementType;
	dimStr : String;
	voyageCode : String;
	bargeVoyageCode : String;
	vvr				: CM_VehicleVisitRecord;
begin

	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);

	theTI := _transaction.myTrackedItem;
	bookingRef := theTI.myBookingRef;
	if bookingRef = null then
		bookingNum := theTI.bookingReference;
	endif;
	voyage := theTI.myVoyage;
	voyageCode := voyage.code;
	bargeVoyageCode := voyageCode;
//	if bookingRef &lt;&gt; null then
//		isBooking := true;
//	endif;
	if _transaction.type = TRANS_TYPE_REC_SHIP or
	   _transaction.type = TRANS_TYPE_REL_SHIP then
		transMode := BargeMode;
		if _transaction.type = TRANS_TYPE_REC_SHIP then
			put := InputMode;
		else
			put := OutputMode;
		endif;
		if voyage &lt;&gt; null then
			serviceOrder := voyage.externalRef;
		endif;
	endif;
	if _transaction.type = TRANS_TYPE_REC_RAIL or
	   _transaction.type = TRANS_TYPE_REL_RAIL then
		if _transaction.type = TRANS_TYPE_REC_RAIL then
			train := _transaction.CM_ReceiveRail.getMyTrain();
			if train &lt;&gt; null then
				wagon := _transaction.CM_ReceiveRail.getMyWagon();
			endif;
			put := InputMode;
		else
			train := _transaction.CM_ReleaseRail.getMyTrain();
			if train &lt;&gt; null then
				wagon := _transaction.CM_ReleaseRail.getMyWagon();
			endif;
			put := OutputMode;
		endif;
//		CM_ReleaseRail
		serviceOrder := theTI.remarks;
		transMode := RailMode;
	endif;
	if _transaction.type = TRANS_TYPE_REC_ROAD or
	   _transaction.type = TRANS_TYPE_REL_ROAD then
		vehicleVisitRecord := theTI.allVisitRecords.first.CM_VehicleVisitRecord;
		
		if vehicleVisitRecord &lt;&gt; null then
			transMode := TruckMode;
			if self.specialStevedore(vehicleVisitRecord.carrierCode) then
				isStevedoreTransfer := true;
			endif;
		endif;
		if _transaction.type = TRANS_TYPE_REC_ROAD then
			put := InputMode;
		else
			put := OutputMode;
		endif;
		
		//serviceOrder := theTI.remarks;					//cnwma1 18.9.2017 cnwma1 TFS #6614
		//cnwma1 18.9.2017 cnwma1 TFS #6614
		if _transaction.type = TRANS_TYPE_REC_ROAD then
			vvr := theTI.getVehicleVisitReceival();
			if vvr &lt;&gt; null then
				serviceOrder := vvr.visitNumber;
			endif;
		elseif _transaction.type = TRANS_TYPE_REL_ROAD then
			vvr := theTI.getVehicleVisitRelease();
			if vvr &lt;&gt; null then
				serviceOrder := vvr.visitNumber;
			endif;
		endif;
		
	endif;
	if _transaction.imExStatus = TI_IMEX_STATUS_EXPORT then
		imExType := ExportMode;
	else
		if transMode = BargeMode and
		   theTI.isTranshipItem then
			imExType := ExportMode;
		else
			imExType := ImportMode;
		endif;
	endif;
	if isStevedoreTransfer then
		transType := imExType&amp;transMode&amp;'R';
	else
		transType := imExType&amp;transMode&amp;put;
	endif;
	camMessage := self.getCamMessage(_camFile, null, null, CODECO_EDIT, _camProtocol.singleContainerPerBGM);
	
	if theTI.isTranshipItem and
	   imExType = ExportMode then
		voyage := theTI.myVoyageTranshipExport;
		if voyage &lt;&gt; null then
			voyageCode := voyage.code;
			if theTI.myImportVoyage &lt;&gt; null then
				bargeVoyageCode := theTI.myImportVoyage.code;
				serviceOrder := theTI.myImportVoyage.externalRef;
			endif;
			// TFS 2122 add null test
			if theTI.myTranshipDetail &lt;&gt; null then
				bookingNum := theTI.myTranshipDetail.exportBookingReference;
			endif;
			bookingRef := voyage.allBookingRefs[theTI.operatorCode, bookingNum];
		endif;
	endif;
	if theTI.isTranshipItem and
	   imExType = ImportMode then
		voyage := theTI.myVoyageTranshipImport;
		if voyage &lt;&gt; null then
			voyageCode := voyage.code;
			if theTI.myExportVoyage &lt;&gt; null then
				bargeVoyageCode := theTI.myExportVoyage.code;
				serviceOrder := theTI.myExportVoyage.externalRef;
			endif;
			// TFS 2122 add null test
			if theTI.myTranshipDetail &lt;&gt; null then
				bookingNum := theTI.myTranshipDetail.importBookingReference;
			endif;
			bookingRef := voyage.allBookingRefs[theTI.operatorCode, bookingNum];
		endif;
	endif;
	create xmlDoc transient;
	xmlDoc.outputDeclaration := true;
	//encoding
	rootElement := xmlDoc.addElement("warehouse_activity");
//	element := rootElement.addElement("transmission_number");
//	element.addText(self.transmissionNumber.String);
	soElement := rootElement.addElement("service_order");
	element := soElement.addElement("service_order_nbr");
	element.addText(serviceOrder);
	element := soElement.addElement("trans_date");
	element.addText(_transaction.camsTimeStamp.date.userFormat($CNEC_ANSI_DATE_FORMAT));
	element := soElement.addElement("trans_time");
	element.addText(_transaction.camsTimeStamp.time.formatAsHHmmSS);
	element := soElement.addElement("trans_type");
	element.addText(transType);
	if isStevedoreTransfer then
	else
		element := soElement.addElement("stevedore");
		element.addText("AST");
		element := soElement.addElement("consignee");
		element.addText(theTI.consignee);
		element := soElement.addElement("destination");
		element.addText(theTI.destinationPort);
		element := soElement.addElement("pickup_nbr");
		element.addText(theTI.purchaseOrder);
		if transMode = RailMode then
			element := soElement.addElement("rail_carrier");
			if train &lt;&gt; null then
				element.addText(train.description);	// Train carrier
				element := soElement.addElement("rail_car_init");
				element.addText(train.code);	// wagon type
			endif;
			if wagon &lt;&gt; null then
				element := soElement.addElement("rail_car_nbr");
				element.addText(wagon.id);	//Wagon Number
				element := soElement.addElement("rail_car_type");
				element.addText(wagon.getType());	// Train Description
			endif;
			element := soElement.addElement("rail_car_permit");
			if train &lt;&gt; null then
				element.addText(train.remarks);	// Train description
			endif;
		endif;
		if transMode = BargeMode then
			element := soElement.addElement("barge_carrier");
			element.addText(theTI.operatorCode);	// Voyage Operator par35419
			element := soElement.addElement("barge_nbr");
			element.addText(bargeVoyageCode);	// Voyage Code par35419
		endif;
		element := soElement.addElement("shipper");
		element.addText(theTI.operatorCode);
		if transMode = TruckMode then
			if vehicleVisitRecord &lt;&gt; null then
				element := soElement.addElement("truck_carrier");
				element.addText(vehicleVisitRecord.carrierCode);	// Vehicle visit carrier
				element := soElement.addElement("truck_nbr");
				element.addText(vehicleVisitRecord.vehicle.regNumber);	// Vehicle visit reqnumber
			endif;
		endif;
	endif;
	cargoElement := soElement.addElement("cargo");
	if isStevedoreTransfer then
		if put = InputMode then
			element := cargoElement.addElement("from_stevedore");
			element.addText(theTI.carrier);
			if vehicleVisitRecord &lt;&gt; null then
				element := cargoElement.addElement("from_location");
				element.addText(vehicleVisitRecord.vehicle.regNumber);
			endif;
			element := cargoElement.addElement("to_stevedore");
			element.addText("AST");
		else
			element := cargoElement.addElement("from_stevedore");
			element.addText("AST");
			element := cargoElement.addElement("to_stevedore");
			element.addText(vehicleVisitRecord.carrierCode);
			if vehicleVisitRecord &lt;&gt; null then
				element := cargoElement.addElement("to_location");
				element.addText(vehicleVisitRecord.vehicle.regNumber);
			endif;
		endif;
	else
		element := cargoElement.addElement("commodity");
		element.addText(theTI.cargoTypeDescr);
		element := cargoElement.addElement("cargo_marks");
		element.addText(theTI.mark);
		element := cargoElement.addElement("cargo_units");
		element.addText('1');
		element := cargoElement.addElement("cargo_uom");
		element.addText('CL');
		element := cargoElement.addElement("cargo_weight");
			measureType := app.getDefaultMeasurementForType(Type_Weight);
			if measureType = null then
				dimStr := theTI.totalWeight.asStringWeightJMT;
			else
				dimStr := app.convertMeasurementForDisplay(measureType.shortName, theTI.totalWeight);
			endif;
			element.addText(dimStr);
		element := cargoElement.addElement("location");
		element.addText(theTI.locationId);
		if put = OutputMode and
		   (transMode = TruckMode or
		    transMode = RailMode) then
			element := cargoElement.addElement("import_vessel");
			element.addText(theTI.vesselName);
			element := cargoElement.addElement("import_vessel_voyage");
			element.addText(theTI.voyageCode);
			element := cargoElement.addElement("import_bill_of_lading");
			element.addText(theTI.billOfLading);	//bol
		endif;
	endif;
	if voyage &lt;&gt; null and 
	   imExType &lt;&gt; ExportMode then
		element := cargoElement.addElement("incoming_service_order");
		element.addText(voyage.externalRef);
	endif;
	if isStevedoreTransfer then
		element := cargoElement.addElement("incoming_vessel");
		element.addText(theTI.vesselName);	//vessel name par35419
		element := cargoElement.addElement("incoming_vessel_voyage");
		element.addText(theTI.voyageCode);	//voyage Code par35419
		element := cargoElement.addElement("incoming_bol_nbr");
		element.addText(theTI.billOfLading);	//bol
		element := cargoElement.addElement("incoming_bol_issuer");
		element.addText(theTI.operatorCode);
	endif;
	if transMode = BargeMode and
	   imExType = ImportMode and
	   put = InputMode then
//		element := cargoElement.addElement("incoming_vessel");
//		element.addText(theTI.vesselName);	//vessel name par35419
//		element := cargoElement.addElement("incoming_vessel_voyage");
//		element.addText(theTI.voyageCode);	//voyage Code par35419
//		element := cargoElement.addElement("import_bol_issuer_scac");
//		element.addText(null);	
//		element := cargoElement.addElement("import_bill_of_lading");
//		element.addText(null);	
		element := cargoElement.addElement("it_vessel");
		element.addText(null);	
		element := cargoElement.addElement("it_vessel_voyage");
		element.addText(null);	
		element := cargoElement.addElement("it_bill_of_lading");
		element.addText(null);	
		element := cargoElement.addElement("it_from_port");
		element.addText(null);	
		element := cargoElement.addElement("it_service_order_number");
		if voyage &lt;&gt; null then
			element.addText(voyage.externalRef);
		endif;
	endif;
//	if isBooking then
//		bookingElement := cargoElement.addElement("booking");
	self.processBooking(bookingRef, bookingNum, cargoElement, transMode);
//	endif;
	coilElement := cargoElement.addElement("coil");
	self.processCoil(theTI, coilElement, (imExType = ExportMode));
	strMsg := xmlDoc.writeToString();
	strMsg := strMsg.replaceString('&lt;?xml version="1.0"?&gt;'&amp;CrLf, '');
	strMsg := strMsg.replaceString('&lt;warehouse_activity&gt;'&amp;CrLf, '');
	strMsg := strMsg.replaceString('&lt;/warehouse_activity&gt;', '');
	strMsg := strMsg.replaceString(CrLf&amp;CrLf, CrLf);
	strMsg := strMsg.replaceString(CrLf&amp;CrLf, CrLf);
	self.addMessage(camMessage.group3, strMsg);

epilog
	delete xmlDoc;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="specialFileName" id="8ca51e3d-4a9b-4c82-8bf8-403507ab8acd">
        <source>specialFileName(_camGroup: CM_CamGroup; _startDateTime: TimeStamp; _runDateTime: TimeStamp): String;
//
//16 Dec 2014	cnwrs1	Par 35419 - add additional data
//
vars

begin
	return "i_wa_"&amp;_runDateTime.date.longYearEDI()&amp;_runDateTime.time.formatAsHHMMSS()&amp;".xml";
end;</source>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="specialStevedore" id="53abe367-b2aa-4232-b25f-8b10b84328ee">
        <source>specialStevedore(_carrierCode : String) : Boolean;
//
///23 Dec 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//26 Jan 2015	cnwrs1	par 35564/35566/35573 - units 1 uom Units coli qty removed / Stevedore carrier should be from vehicleVisitRecord / 1090 when trying to produce train remarks with no train 
//
vars
	
begin
	if _carrierCode = "CSA" or
	   _carrierCode = "SEAONUS" or
	   _carrierCode = "GOLDEN" or
	   _carrierCode = "PREMIER" or
	   _carrierCode = "RICHARDSON" or
	   _carrierCode = "TRISTATE" then
		return true;
	else
		return false;
	endif;
end;
</source>
        <Parameter name="_carrierCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
