    <JadeMethod name="utlUpdateDisconnect" id="55c918d1-0239-4c1e-bb3e-9cabd80624f4">
        <updating/>
        <source>utlUpdateDisconnect(_theConnectParams : CMIF_ConnectParams input; _pxyTI: CM_TrackedItem; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		The proxy TI is stored in the connect Parameters
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/07/2017	cnwma1		TFS #4729:POL - Is Externally Monitored Issue and enhancements ##4690##
// ---------------------------------------------------------------------------
vars
	realTrackedItem, aProxyTI :CM_TrackedItem;
begin

	self.initialiseActivity();
	
	if _pxyTI = null then
		aProxyTI := _theConnectParams.myTrackedItem;
	else
		aProxyTI := _pxyTI;
	endif;
	
	self.raiseExceptionIfNull(aProxyTI, 'Disconnect TI Proxy');	
	//epr par 36103 23/4/15
	if aProxyTI.isTransient then
		aProxyTI.raiseExceptionIfNotProxy(method);
		app.setContinueCMExceptions(true);
		realTrackedItem:=aProxyTI.pxyGetRealObject();
	else
		realTrackedItem:=aProxyTI;
	endif;
	
	if realTrackedItem = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;

	app.myValUA.valDisconnect(realTrackedItem, _theConnectParams);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realTrackedItem);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackedItem, true);
	endif;
	if _passport.noErrors then
		_theConnectParams.myTrackedItem := realTrackedItem;
		
		_theConnectParams.myOtherTrackedItem := realTrackedItem.getOtherTrackedItem(_theConnectParams.action);
		_theConnectParams.locationsController := realTrackedItem.getPrimaryLocation(REAL_MODE);
		
		if _theConnectParams.editMode &lt;&gt; CM_ReeferMtn then // ### TFS 52375 11Nov2021 NAVPW1
			_theConnectParams.hasExternalMonitoring := realTrackedItem.getExternalMonitoring(); 	//10.7.2017 cnwma1 TFS #4729
		endif;
		
		realTrackedItem.setForDisconnect(_theConnectParams, _passport);
		// redraw the TI Graphics on screen
		if _passport.noErrors 
		and _theConnectParams.locationsController &lt;&gt; null then
			//refMon
			realTrackedItem.causeEvent(_theConnectParams.myTerminal.getTerminalEvent(TIEvent_Connect),false, realTrackedItem);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackedItem, false);
	endif;

end;</source>
        <Parameter name="_theConnectParams" type="CMIF_ConnectParams" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDocketError" id="b582803e-8267-4270-9806-bade0d7262fc">
        <source>utlUpdateDocketError(pxyDocketError : CM_DocketError; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwas3	Initial creation

*/

vars
	realDocketError:CM_DocketError;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pxyDocketError.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

