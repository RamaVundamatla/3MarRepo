    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="ddbf2bc0-de4a-416f-b781-140b28d64099">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input): Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
