			maxX := point.x;
		endif;
		pointArray.add(point);
	endforeach;
	
	create lcArray transient;
	//transform point array and create new order
	foreach point in pointArray do
		point.setX((maxX+1)-point.x);
		locnCell := _theRow.getLocnCellAtCoord(point);
		if locnCell &lt;&gt; null then
			lcArray.add(locnCell);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, "can't find locnCell at Coordinate " &amp; point.display);
		endif;
		
	endforeach;
	
	//apply
	self.allYALocationCellsOut.clear;
