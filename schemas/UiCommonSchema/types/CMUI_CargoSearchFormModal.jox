    <JadeMethod name="rowPostprocess" id="1e5a7c36-1837-439c-af6d-7efa830a1b72">
        <updating/>
        <source>rowPostprocess(_dataTable: CM_DataTable io; _idx: Integer; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2024	navra1	Initial creation for //navra1 - TFS 64266 - 28th May 2024

*/

vars
	ti : CM_TrackedItem;
begin
	if not _obj.isKindOf(CM_TrackedItem) then
		return false;
	endif;
	
	ti := _obj.CM_TrackedItem;
	
	if self.colorRow1 &lt;&gt; null and self.colorRow2 &lt;&gt; null then
		if _idx mod 2 = 0 then
			_dataTable.accessRow(_idx).backColor := self.colorRow1;
		else
			_dataTable.accessRow(_idx).backColor := self.colorRow2;			
		endif;	
	endif;
	
	if self.tblSelectedItems.doSearch(ti.id, self.tblResults.getColumnByHeading("id")) &lt;&gt; null then
		self.tblResults.removeItemObject(ti);
	endif;	
	
	return true;
	
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="io"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowPreprocess" id="e1904d4d-86a9-4c8e-8279-2e421a3725be">
        <updating/>
        <source>rowPreprocess(_dataTable: CM_DataTable; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2024	navra1	Initial creation for //navra1 - TFS 64266 - 28th May 2024

*/

vars
	ti:CM_TrackedItem;
	klass : Class;
	failedDAC : CM_DataAccessController;
begin	
	if _obj = null or _dataTable.myDataClass = null then
		return false;
	endif;
	
	klass := _dataTable.myDataClass;
	
	if not _obj.isKindOf(klass) then			//this is much faster than hasInstance
		return false;
	endif;		
	
	if not _obj.isKindOf(CM_TrackedItem) then	//it should be since this is cargo search form
		return false;
	endif;
	
	ti := _obj.CM_TrackedItem;
	
	if not self.includeForApprovedDetail(ti) then
		return false;
	endif;	
	
	if self.myBookingItem &lt;&gt; null and self.myBookingItem &lt;&gt; ti.myBookingRefItem then				//16.10.2023 navlc30 #58996
		return false;
	endif;
		
	if myParentForm &lt;&gt; null and self.myParentForm.name = "CMUI_VehicleBookingItemMaint" then		//18.10.2023 navlc30 #58996
		if ti.allVehicleBookingSlotItems.isNotEmpty() then												
			return false;
		endif;
	endif;
	
	if not _obj.CM_Object.canUserAccessSelf(null, failedDAC, app.myPassport) then
		return false;
	endif;
	
	return inheritMethod(_dataTable, _obj);	
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCMIFBlendingComponent" id="1a1f07b4-643e-4278-828e-9abf91d5e6eb">
        <updating/>
        <source>setCMIFBlendingComponent( _cmif : CMIF_BlendingComponent ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.myCMIF_BlendingComponent := _cmif;
	
	if not _cmif.allTis.isEmpty then
		_cmif.allTis.copy( self.allSelectedTrackedItems );
	endif;

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_BlendingComponent"/>
    </JadeMethod>
    <JadeMethod name="setProduct" id="d1199614-ca00-480b-a9e2-a67ce13a33da">
        <source>setProduct( _value : CM_Product );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	if _value &lt;&gt; null then
		self.cmbSubCargoTypes.setObject(_value);
		self.cmbType.enabled := false;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="870c1c1a-46a7-48e2-b093-9119a5cf88c7">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243
13 July 2023 navmv20 CR 58233 Task 58236: UI - Add Item
*/

vars

begin

	self.handleMenusForModalDisplay();
	self.mnuMainContext.visible := false;
	
	inheritMethod();
	

	//13/07/2023 navmv20 CR 58233 Task 58236 - start
	if self.myParentForm.isKindOf(CMUI_OwnershipChangeMaint) then
		self.cmbOperatorCode.enabled := false;
		self.cmbOperatorCode.setObject(self.myOperator);
	endif;
	//13/07/2023 navmv20 CR 58233 Task 58236 - end
	
	self.mnuEnquire.visible := false;// ###  BUG 59643 03AUG2023 NAVAB1
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="01cc0f8b-eb15-461d-937c-4bc1558416c9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 28 June 2021 11:47:35.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	//self.translateCaption(Xlat_0017262, locale);
end;</source>
    </JadeMethod>
</GUIClass>
