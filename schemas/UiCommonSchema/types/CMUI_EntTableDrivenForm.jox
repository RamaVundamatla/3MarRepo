    <JadeMethod name="translateForm" id="769b9609-5221-4f5d-8ffd-0049066e7b09">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017356, locale);
	btnCancel.translateCaption(Xlat_0011881, locale);
	btnDelete.translateCaption(Xlat_0011882, locale);
	btnNext.translateCaption(Xlat_0011883, locale);
	btnSave.translateCaption(Xlat_0011884, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="truncateDisplayString" id="322a77dd-4b09-4009-8445-17cc901c3d91">
        <source>truncateDisplayString(_text : String; _maxLen : Integer ) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2009	cnwjk3	Initial creation

*/

constants
	MaxLen = 30;
vars
	maxLen : Integer;
begin
	if _maxLen = -1 then 
		maxLen := MaxLen;
	else
		maxLen := _maxLen;
	endif;
	
	if _text.length &gt; maxLen then
		return _text[1:maxLen-1]&amp; '...';
	else
		return _text;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_text" type="String"/>
        <Parameter name="_maxLen" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</GUIClass>
