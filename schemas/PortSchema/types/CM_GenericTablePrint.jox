    <JadeMethod name="addRowToTable" id="6a9a1258-8387-4d33-a702-94e9cfbc017a">
        <source>addRowToTable(pStr : String);
// ---------------------------------------------------------------------------
// Created:     30 October 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	row:             Integer;
	column:          Integer;
	accessMode:      Integer;
	tmpStr		: String;

begin

	row := self.table.addItem(pStr);
	table.accessMode := Table.AccessMode_Cell;
	
	foreach column in 1 to table.columns do
		if (not self.table.columnVisible[column]) then
			self.table.columnWidth[column] := 0;
			continue;
		endif;
		
		tmpStr := self.table.accessCell(row, column).text;
		if row = 1 then
			self.table.columnWidth[column] := self.table.getTextExtent(tmpStr) + 4;
		else
			self.table.columnWidth[column] := self.table.columnWidth[column].max(self.table.getTextExtent(tmpStr) + 4);
		endif;
	endforeach;

end;</source>
        <Parameter name="pStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="copyTable" id="72e148bb-331a-4858-a3d8-0ec388c170d6">
        <updating/>
        <source>copyTable(tblIn: Table input; _numInvisibleFixedRows, _numInvisibleFixedCols : Integer) updating, protected;

// 25/10/2010	cnwcs5	par 25619 - fix exception when printing table with tabs and tble.topSheet &lt;&gt; table.sheet

vars
	tblSheet		: JadeTableSheet;
	cell			: JadeTableCell;
	tblColumn		: JadeTableColumn;	// 25/10/2010 cnwcs5 par25619
	iRow,
	iColumn,
	iAccessMode,
	row,
	column,
	colOffset,
	rowOffset,
	tmpTextExtent,
	magicNumber		: Integer;
	tmpFrame		: Frame;
	
// not used	i, j : Integer;
begin
	create tmpFrame transient;
	
	tblSheet 		:= tblIn.accessSheet(tblIn.topSheet);
	table.rows		:= tblSheet.rows;
	table.columns 	:= tblSheet.columns;
	
	table.accessSheet(1).marginBottom 	:= 1;
	table.accessSheet(1).marginTop 		:= 1;
	table.accessSheet(1).marginLeft 	:= 1;
	table.accessSheet(1).marginRight 	:= 2;
	
	table.fixedRows 	:= tblSheet.fixedRows - _numInvisibleFixedRows;
	table.fixedColumns 	:= tblSheet.fixedColumns - _numInvisibleFixedCols;
	table.alignment 	:= tblIn.alignment;
	
	iRow 				:= tblSheet.row;
	iColumn 			:= tblSheet.column;
	iAccessMode 		:= tblIn.accessMode;
	tblIn.accessMode 	:= Table.AccessMode_Cell;
	table.accessMode 	:= Table.AccessMode_Cell;
	
	row 		:= 1;
	column 		:= 1;
	rowOffset 	:= 0;
	
//	while row &lt;= tblIn.rows do : rowLoop  // changed as would cause an error if printing a sheet that had less rows than parent table
//		if not tblIn.rowVisible[row] then
	while row &lt;= tblSheet.rows do : rowLoop
		if not tblSheet.accessRow(row).visible then
			rowOffset 	:= rowOffset + 1;
			row 		:= row + 1;
			continue;
		endif;
	
		column := 1;
		colOffset := 0;
//		while column &lt;= tblIn.columns do : columnLoop  // changed as would cause an error if printing a sheet that had less columns than parent table
//			if not  tblIn.columnVisible[column] then
		while column &lt;= tblSheet.columns do : columnLoop
			tblColumn := tblSheet.accessColumn (column);	// +25/10/2010 cnwcs5 par25619
			//if not  tblSheet.accessColumn(column).visible then 25/10/2010 cnwcs5 par25619
			if not tblColumn.visible then					// +25/10/2010 cnwcs5 par25619
				colOffset 	:= colOffset + 1;
				column 		:= column + 1;
				continue;
			endif;
			
			table.row 		:= row - rowOffset;			//rowOffset should be the number of invisible rows encountered
			table.column 	:= column - colOffset;		//colOffset should be the number of invisible columns encountered
			tblSheet.row 	:= row;
			tblSheet.column := column;

			// Text
			cell 			:= tblSheet.accessCell(row, column);
			table.text 		:= cell.text;
			// Alignment
			table.alignment := cell.alignment;
			// Font
			table.fontBold 			:= cell.fontBold;
			table.fontItalic 		:= cell.fontItalic;
			table.fontName 			:= cell.fontName;
			table.fontSize 			:= cell.fontSize;
			table.fontStrikethru 	:= cell.fontStrikethru;
			table.fontUnderline 	:= cell.fontUnderline;
			// Colour
			if self.whiteBackground then
				table.foreColor := Black;
				table.backColor := White;
			else
				table.foreColor := cell.foreColor;
				table.backColor := cell.backColor;
			endif;
			// GridLines
			table.gridLines := tblSheet.gridLines;
			table.gridColor := tblSheet.gridColor;
			// Picture
			table.picture := cell.picture;

			// ### AKB2004OCT added this to print Yes/No for check boxes
			if ( cell.cellControl &lt;&gt; null and cell.cellControl.isKindOf(CheckBox)) or
				cell.inputType = Table.InputType_CheckBox then
				if cell.text.Integer = 0 then 
					table.text := "  No";
				else
					table.text := "  Yes";
				endif;
			endif;
			
			//29 Nov 2009	NDL	CCMS 1864	Par 21652
			if cell.mergeCells &lt;&gt; 0 then
				table.accessCell(table.row, table.column).mergeCells := cell.mergeCells;
			endif;
			
			//magicNumber := 15;	//was 4  - changed for unknown reason			Jul 04
			//magicNumber := 12;	//was 15 but columns are spilling over			Dec 04
			//magicNumber := 7;		//was 12 but columns are still spilling over	Jan 05
			magicNumber := 5;		//was 7 - saving space							Feb 06

			// done the following way as table.getTextExtent does not return the correct value
			tmpFrame.fontItalic := cell.fontItalic;
			tmpFrame.fontName 	:= cell.fontName;
			tmpFrame.fontSize 	:= cell.fontSize;
			tmpFrame.fontBold 	:= cell.fontBold;
			tmpTextExtent 		:= tmpFrame.getTextExtent(table.text) + magicNumber;
			
			//tmpTextExtent := table.getTextExtent(table.text) - 7;
			
			if row = 1 then
				// if tblIn.columnWidth[column] = 1 then														25/10/2010 cnwcs5 par25619
				if tblColumn.width = 1 then 																	// + 25/10/2010 cnwcs5 par25619
					//formatting - leave as is
					table.columnWidth[column-colOffset] := 1;
				elseif self.useOrigTableColumnWidths then
					// not used i := tblIn.columnWidth[column].max(tmpTextExtent);								25/10/2010 cnwcs5 par25619
					// - table.columnWidth[column-colOffset] := tblIn.columnWidth[column].max(tmpTextExtent);	25/10/2010 cnwcs5 par25619
					table.columnWidth[column-colOffset] := tblColumn.width.max(tmpTextExtent);					// +25/10/2010 cnwcs5 par25619
				else
					table.columnWidth[column-colOffset] := tmpTextExtent;
				endif;
			else
				//if tblIn.columnWidth[column] = 1 then															25/10/2010 cnwcs5 par25619
				if tblColumn.width = 1 then																		// +25/10/2010 cnwcs5 par25619
					//formatting - leave as is
					table.columnWidth[column-colOffset] := 1;
				else
					// not used j := table.columnWidth[column-colOffset].max(tmpTextExtent);					25/10/2010 cnwcs5 par25619
					table.columnWidth[column-colOffset] := table.columnWidth[column-colOffset].max(tmpTextExtent);
				endif;
			endif;
			column := column + 1;
		endwhile;
		table.rowHeight[row - rowOffset] 			:= tblSheet.accessRow(row).height;
		table.accessRow(row - rowOffset).itemObject := tblSheet.accessRow(row).itemObject;
		row := row + 1;
	endwhile;
	
	//remove empty cols/rows
	table.columns 	:= tblSheet.columns-colOffset;
	table.rows 		:= tblSheet.rows-rowOffset;
	
	tblIn.accessMode 	:= iAccessMode;
	tblSheet.column 	:= iColumn;
	tblSheet.row 		:= iRow;

epilog
	delete tmpFrame;
end;</source>
        <access>protected</access>
        <Parameter name="tblIn" type="Table" usage="input"/>
        <Parameter name="_numInvisibleFixedRows" type="Integer"/>
        <Parameter name="_numInvisibleFixedCols" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="5be4c956-33a3-4a64-a8bd-4aca6e532a48">
        <updating/>
