	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	create response transient;
	
	create mode transient;
	mode.id				:= TI_TRANSMODE_ROAD_STR;
	//mode.id				:= TI_TRANSMODE_ROAD;	
	mode.description	:= TI_TRANSMODE_ROAD_STR;
	response.allTransportModes.add(mode);
	
	create mode transient;
	mode.id				:= TI_TRANSMODE_RAIL_STR;
	//mode.id				:= TI_TRANSMODE_RAIL;
	mode.description	:= TI_TRANSMODE_RAIL_STR;
	response.allTransportModes.add(mode);
	
	//process.sleep(5000);
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getTransportModes</wsdlName>
        <ReturnType type="WS_TransportModeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getTransportModesForSearch" id="e4e914ee-a8f8-4122-bc03-7e9c59e6fff8">
        <usesRPC>default</usesRPC>
        <source>getTransportModesForSearch() : WS_TransportModeResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
