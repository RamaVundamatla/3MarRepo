    <JadeMethod name="doAddInvoiceLine" id="51af091e-7db2-4ae8-a36b-858d317ae294">
        <updating/>
        <source>doAddInvoiceLine(_invLine : CM_InvoiceLine; _doGrouping : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	ti 					: CM_TrackedItem;
	cargoTypeObj		: CM_CargoType;
	cargoSubTypeObj		: CM_Product;
	invLineDesc			: CM_InvoiceLineDesc;
	
begin
	if not self.allInvoiceLines.tryAdd(_invLine) then
		app.invLog(self.getNiceName() &amp; " failed to add invoice line to the collection, skipped", LogINFO.String);
		return;
	endif;
	
	/* ===============
	These are the keys
	==================
	*/
	if _doGrouping then
		// Rate
		if self.rate = null then
			self.rate := _invLine.getRate();
		elseif self.rate &lt;&gt; _invLine.getRate() then
			app.invLog(self.getNiceName() &amp; " Rate is different than the key, skipped", LogINFO.String);
			return;
		endif;
		
		// Contract ID
		if self.contractID = null then
			self.contractID := _invLine.contractId;
		elseif self.contractID &lt;&gt; _invLine.contractId then
			app.invLog(self.getNiceName() &amp; " Contract ID is different than the key, skipped", LogINFO.String);
			return;
		endif;
		
		// Invoice Line Type
		invLineDesc := _invLine.invoiceLineDesc;
		if invLineDesc = null then
			app.invLog(self.getNiceName() &amp; " Invoice Line Desc is null, skipped", LogINFO.String);
			return;
		else
			if self.invoiceLineType = null then
				self.invoiceLineType := invLineDesc.narration;
			elseif self.invoiceLineType &lt;&gt; invLineDesc.narration then
				app.invLog(self.getNiceName() &amp; " Invoice Line Type is different than the key, skipped", LogINFO.String);
				return;
			endif;
		endif;
	endif;
	
	// Total
	self.total += _invLine.lineTotal;
	
	// External Ref 1
	self.externalRef1.addStringToList(_invLine.externalRef1, ",");
	
	// External Ref 2
	self.externalRef2.addStringToList(_invLine.externalRef2, ",");
	
	// External Ref 3
	self.externalRef3.addStringToList(_invLine.externalRef3, ",");
	
	// External Ref 4
	self.externalRef4.addStringToList(_invLine.externalRef4, ",");
	
	// If we have a Tracked Item, populate these information
	ti := _invLine.getTrackedItem();
	if ti &lt;&gt; null then
		// Cargo Type
		cargoTypeObj := ti.myCargoType;
		if cargoTypeObj &lt;&gt; null then
			self.cargoType.addStringToList(cargoTypeObj.description, ",");
		endif;
		
		// Cargo Sub Type
		cargoSubTypeObj := ti.myProduct;
		if cargoSubTypeObj &lt;&gt; null then
			self.cargoSubType.addStringToList(cargoSubTypeObj.description, ",");
		endif;
		
		// Commodity
		self.commodity.addStringToList(ti.commodity, ",");
	endif;
	
	// Add 1 here
	self.numberOfLines += 1;
	
epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <Parameter name="_doGrouping" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e88ed594-426b-4fc9-acd7-dd9a20a0ca61">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars

begin
	if _attrName = ETRow_InvLineType then
		return self.invoiceLineType;
	elseif _attrName = ETRow_ContractID then
		return self.contractID;
	elseif _attrName = ETRow_Rate then
		return self.rate.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true);
	elseif _attrName = ETRow_Lines then
		return self.numberOfLines.String;
	elseif _attrName = ETRow_TotalAmount then
		return self.total.asStringJMTWithPrecision(2, true);
	elseif _attrName = ETRow_CargoTypeDescr then
		return self.cargoType;
	elseif _attrName = ETRow_CargoSubType then
		return self.cargoSubType;
	elseif _attrName = ETRow_Commodity then
		return self.commodity;
	elseif _attrName = ETRow_ExternalReference1 then
		return self.externalRef1;
	elseif _attrName = ETRow_ExternalReference2 then
		return self.externalRef2;
	elseif _attrName = ETRow_ExternalReference3 then
		return self.externalRef3;
	elseif _attrName = ETRow_ExternalReference4 then
		return self.externalRef4;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRateEntryDecimalPlaces" id="eaac4545-083e-463b-bd9b-1275c308cc4d">
        <source>getRateEntryDecimalPlaces() : Integer;
/*
Purpose:	

Date		Who		Reason
09 January 2026	navab1	JIRA 36262
*/

vars

	dpl 	: Integer;
	term	: CM_Terminal;
begin
	term := self.getMyTerminal();
	if term &lt;&gt; null then
		dpl := term.getConfig(FinancialRateDPlaces).Integer;
	else
		dpl := $CM_RateEntry.decimalPlaces;	
	endif;
	
	return dpl;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
