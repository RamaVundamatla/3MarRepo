    <JadeMethod name="setupForm" id="594a5be0-7a45-4c21-86e9-4f6c052c5921">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
// 06/12/2012	cnwcs5	par 30582 - use translatable caption
// 12/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
// 06/03/2014	cnwdap1	PAR #33638 Correct Tare Weight field
// 27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
// 15/05/2025	navcs2	MTN-34843  Development - Fleet file Form implementation
vars
	cargoType  	: CM_CargoType;
	assistant	: CMUI_Assistant;
begin

	inheritMethod();
	
	self.centreWindow();	//Par18122 Oct 2008

	self.toolbarStyle 	:= self.ToolbarStyle_None;
	self.showToolbar 	:= false;
	self.hasChanged  	:= false;
	assistant 			:= self.myAssistant;

	if self.isEdit then
		self.btnNext.visible 		:= false;
		self.txtID.enabled 			:= false;
		self.cmbTILCType.enabled 	:= false;
		// just load type for existing master - you can't change it anyway
		if self.myParentForm.CMUI_TIMasterForm.isMAFI then								// 15/05/2025	navcs2	MTN-34843
			assistant.comboBoxMafi( self.cmbTILCType, self.myTiMaster.myTILCType);		// 15/05/2025	navcs2	MTN-34843
			self.cmbFloorType.visible := true;											// 15/05/2025	navcs2	MTN-34843
			self.txtFloorType.visible := true;											// 15/05/2025	navcs2	MTN-34843
		else																			// 15/05/2025	navcs2	MTN-34843
			assistant.comboBoxTILCType( self.cmbTILCType, self.myTiMaster.myTILCType);	// 15/05/2025	navcs2	MTN-34843
			self.cmbFloorType.visible := false;											// 15/05/2025	navcs2	MTN-34843
			self.txtFloorType.visible := false;											// 15/05/2025	navcs2	MTN-34843
		endif;																			// 15/05/2025	navcs2	MTN-34843

	else
		self.btnNext.visible 		:= true;
		self.txtID.enabled 			:= true;
		self.cmbTILCType.enabled 	:= true;		
		self.btnOk.left 			:= self.btnOk.left -74; 
		if self.myParentForm.CMUI_TIMasterForm.isMAFI then					// 15/05/2025	navcs2	MTN-34843
			assistant.comboBoxMafi( self.cmbTILCType, null);				// 15/05/2025	navcs2	MTN-34843
			self.cmbFloorType.visible := true;								// 15/05/2025	navcs2	MTN-34843
			self.txtFloorType.visible := true;								// 15/05/2025	navcs2	MTN-34843
		else																// 15/05/2025	navcs2	MTN-34843
			assistant.comboBoxTILCType( self.cmbTILCType, null);			// 15/05/2025	navcs2	MTN-34843
			self.cmbFloorType.visible := false;								// 15/05/2025	navcs2	MTN-34843
			self.txtFloorType.visible := false;								// 15/05/2025	navcs2	MTN-34843
		endif;										
	endif;
	
	assistant.comboBoxOperator( self.cmbOperator, null, null );
	assistant.comboBoxOperator( self.cmbOwner, null, null );
	self.myAssistant.comboBoxGenerator(self.cmbGenerators,false,true); //27.02.2018 cnwma1 ChangeRequest #36813
	if self.myTiMaster &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[self.myTiMaster.cargoType];
		
	else	
		foreach cargoType in app.myRoot.allCargoTypesById do
			// from 31981 skip not-available-for-entry cargo types
			if cargoType.isNotAvailableForEntry then
				continue;
			endif;
			if cargoType.productType = ProductType_Trailer then			
				cargoType := cargoType ;
				break;
			endif;
		endforeach;
	endif;
	
	// PAR #31155 set up default weight measurement in caption
	//self.lblWeight.setCaptionForMeasurementType(Type_Weight);			// PAR #33638
	self.txtWeight.setup(Type_Weight, self.backColor);					// PAR #33638
	self.txtWeight.tabKey := J_key_Tab;									// PAR #33638
	
	assistant.listTableStopsTableSysUser( self.lstTblStops, cargoType, self.allStopsForUser, true);
	assistant.listTableToDoTasksSysUser( self.lstTblToDoTasks,cargoType, self.allToDoTasksForUser );	
	
	self.beginClassNotification(CM_TIMasterTILC, false, Any_System_Event, Response_Continuous, null); //cnwrd1 par #18127 23.1.09

	self.loadData();
	
	self.buildFloorTypeCombo();		// 15/05/2025	navcs2	MTN-34843
	
	self.btnDamage.visible := false;  // ### TFS 55313 08NOV2022 NAVAB1 - Recorded damage is not used anywhere
end;</source>
    </JadeMethod>
    <JadeMethod name="setupLocations" id="14918b0c-3d20-4bd7-9c25-8be9e63d54bc">
        <source>setupLocations(_terminal : CM_Terminal) protected;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	app.setMyTerminal(_terminal);



end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="93c4de8e-7e62-4ef2-9cd6-20c699bae8b8">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2009	cnwrd1	Initial creation
//cnwrd1 par #18127 23.1.09
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars

begin
		if eventType = Object_Update_Event and theObject = self.myTiMaster then
				app.msgBox('Trailer Maintanance Screen: Another user has updated the Trailer you currently have selected.' &amp; CrLf &amp;
							'The Trailer must now be re-loaded.', 'Trailer updated', MsgBox_Exclamation_Mark_Icon);
				self.loadData();
		elseif eventType = Object_Delete_Event and theObject = self.myTiMaster then
			app.msgBox('Another user has deleted the Trailer you are currently editing. The editing must now be cancelled','Trailer deleted by another user.',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.unloadForm();
		endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
