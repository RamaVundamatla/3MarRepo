    <JadeMethod name="setProxyContract" id="b095811c-7f51-46fe-b859-b14693b8f90b">
        <updating/>
        <source>setProxyContract(_criterias: CMIF_Array; _priority : Integer; _name, _desc : String; _contractDtl : CM_InvoiceContractDetails) updating;
/*
Purpose:			

Date		Who		Reason
07 December 2022	navab1	TFS CR 55623 TASK 55674
*/

vars

begin
	self.setProxy(_criterias, _priority);
	
	self.name := _name;
	self.description := _desc;
	
	self.myInvoiceContractDetail := _contractDtl;
	
epilog

end;</source>
        <Parameter name="_criterias" type="CMIF_Array"/>
