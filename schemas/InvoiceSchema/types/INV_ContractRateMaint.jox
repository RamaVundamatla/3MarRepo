    <JadeMethod name="populateContractDtl" id="b637aebf-93d9-4832-b6fd-e4804d9ed182">
        <updating/>
        <source>populateContractDtl()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details
14 Mar 2023 navmk20		Bug 57039: EUP - Contract Line Type Change Issue
*/
vars
	localTS : TimeStamp;
begin
	// ### TFS BUG 58796 26JUN2023 NAVAB1 start
	localTS := self.systemToLocalTime(self.myContractDetails.fromTS);
	self.mskContractFromStart.setDate(localTS.date);
	self.mskContractFromStartTime.setTime(localTS.time);
	localTS := self.systemToLocalTime(self.myContractDetails.toTS);
	self.mskContractFromEnd.setDate(localTS.date);
	self.mskContractFromEndTime.setTime(localTS.time);
	// ### TFS BUG 58796 26JUN2023 NAVAB1 end
	
	if self.myContractDetails.contractType = INV_CONTRACT_TYPE_VOLUME_BASED then
		self.chkVolume.value := true;
		//Start //15-03-2023 NAVTNR20 CR 55647 TASK 55696
		self.chkReceiveRail.value := self.myContractDetails.CM_InvoiceContractDtlsVolBased.accumulateForRailReceival;
		self.chkReceiveRoad.value := self.myContractDetails.CM_InvoiceContractDtlsVolBased.accumulateForRoadReceival;
		self.chkReceiveShip.value := self.myContractDetails.CM_InvoiceContractDtlsVolBased.accumulateForShipReceival;
		if self.myContractDetails.CM_InvoiceContractDtlsVolBased.accumulationType = INV_VOL_BASED_PERIOD then
			self.optAccPeriod.value := true;
		else
			self.optAccVoyage.value := true;
		endif;
		//End //15-03-2023 NAVTNR20 CR 55647 TASK 55696
	endif;

	self.cmbShippingTerm.listObject := self.myContractDetails.myShippingTerm;
	self.cmbInvoiceLine.listObject := self.myContractDetails.myInvoiceLineType;
	
	//31/01/2023	navkc1 Bug 61578 - Disable in UPDATE mode, enable in NEW/COPY mode
	if self.mode = self.MODE_UPDATE then
		self.cmbInvoiceLine.enabled := false; // 14.3.2023 navmk20 TFS 57039
	endif;
	
	self.cmbInvoiceLine_change(self.cmbInvoiceLine);
	self.cmbUnitOfMeasure.listObject := self.myContractDetails.myUnitOfMeasure;
	self.cmbCalculationTypes.listObject := self.myContractDetails.myCalculationType;
	//self.cmbService.listObject	 := self.myInvContractRateEntry.myInvoiceContractRate;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCriteriaLabel" id="9f643a71-cbc5-42c4-8423-8bbcaa767860">
        <source>setCriteriaLabel(_detail : CM_InvoiceContractDetails);
/*
Purpose:			

Date		Who		Reason
16 February 2023	navab1	TFS CR 56446 TASK 56447
*/

vars

begin
	if _detail &lt;&gt; null
	and _detail.myInvoiceContractCriteria &lt;&gt;  null then
		self.lblCriteria.caption := app.getErrorString(Priority) &amp;  " " &amp;  _detail.myInvoiceContractCriteria.priority.String &amp; " - " &amp; // ### TFS BUG 59915 20SEP2023 NAVAB1
					_detail.myInvoiceContractCriteria.getCriteriaSummary(",");	
	else
		self.lblCriteria.caption := "";
	endif;

epilog

end;</source>
        <Parameter name="_detail" type="CM_InvoiceContractDetails"/>
    </JadeMethod>
