    <JadeMethod name="getConfig_FileDirectory" id="1d7f60df-3fac-43b2-b606-40e04bf86a49">
        <source>getConfig_FileDirectory( _code : String) : Any;
/*
Purpose:		This method is to be used to get the Terminal Configuration "CAM File Directory" and
				"EDI File Directory" settings.
				The addition to the normal use of getConfig is that the directory path can contain %MISCDIR% (any case)
				which will be interpreted at run time to be the correct miscellaneous directory and substituted in the
				directory path instead of the string %MiscDir%.
				This method is NOT to use app.cnGetClientMiscPath until JadeCare Start PAR 579 is fixed.

Date		Who		Reason
27 May 2009	cnwrl1	Initial creation as part of PAR 19732 - Get the AutoFileDirectory
22 Nov 2012	cnwcs5	par 30618 - replace CM_Root::substituteDirectory with String method

*/
	
vars
	fileDirectory	: String;
begin
	fileDirectory	:= self.getStateData( ConfigGrp_System, _code ).String;
	fileDirectory 	:= fileDirectory.substituteDirectory;	// par 30618 Nov 2012
	
	return fileDirectory;
	
epilog
	
end;
</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getCurrentTrain" id="50ef96fe-0575-4fba-a6ab-35b761ceaca0">
        <source>getCurrentTrain() : CM_Train;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	train : CM_Train;
	now : TimeStamp;
begin

	now := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	foreach train in self.allTrainsOnTerminal discreteLock do
		
		if train.arrivalDT.date = now.date then // DQ confirmed that he only wants trains that have arrived, and so have an arrived date set on them that is today.  4th August 2009 AKB
			return train;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getCurrentWagonByID" id="c86c8c17-29f0-488b-9a7d-82e2aaa7444b">
        <source>getCurrentWagonByID(_code : String) : CM_Wagon;
// ---------------------------------------------------------------------------
// Created:     29 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
begin
	foreach wagon in self.allWagons discreteLock, reversed  where wagon.id = _code   do
		if wagon.id = _code then
			return wagon;
		endif;
	endforeach;

	return null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getCustomExportStops" id="a0dc74e3-8500-4f1e-8932-77b5fffa0b35">
        <source>getCustomExportStops(_stopTables : CM_StopsTableSet io);
//----------------------------------------------------------------
//	Created:	Dec 2006	cnwrs1 par 13095
//----------------------------------------------------------------
vars
	stopTable : CM_StopsTable;//ccms1824 cnwrs1 may 2009
begin
	foreach stopTable in app.myRoot.allAvailableStopsTables discreteLock do //cnwrs1 May 2007 Par 13378
		if stopTable.isCEDOStop(self) then
			_stopTables.add(stopTable);
		endif;
	endforeach;
end;</source>
        <Parameter name="_stopTables" type="CM_StopsTableSet" usage="io"/>
