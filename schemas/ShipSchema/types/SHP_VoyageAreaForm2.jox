    <JadeMethod name="doZoom" id="5a2d37fb-906e-41b5-9341-4463cf591156">
        <updating/>
        <source>doZoom(pFactor: Real) updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//
// Changed On   Changed By  PAR             Reason
// ----------   ----------  --------------  ----------------------------------
//  09/10/2009	cnwmh5		21297			Zoom menu is dynamically created so
//											the check isn't getting updated, add
//											code to go through the zoom menu items
//											and update accordingly.
// ---------------------------------------------------------------------------
//
vars
	menuIndex 	: Integer;		// 09/10/2009 mhill #21297
	menuItem	: MenuItem;		// 09/10/2009 mhill #21297
begin
	inheritMethod(pFactor);

	// 09/10/2009 mhill #21297 - Start
	menuIndex := 1;
	menuItem := self.mnuWorkDisplayZoom.getMenuItem(menuIndex);
	while menuItem &lt;&gt; null do
		if menuItem.helpKeyword = pFactor.String then
			menuItem.checked := true;
		else
			menuItem.checked := false;
		endif;
		menuIndex := menuIndex + 1;
		menuItem := self.mnuWorkDisplayZoom.getMenuItem(menuIndex);
	endwhile;
	// 09/10/2009 mhill #21297 - End
	
	self.frmScrollBackgrd.resizeDragFrame();
	self.layoutRedraw(false);
end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="68d23448-afcf-4d71-ad0f-30003bf3d934">
