//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setControlsForNext();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSetControlsForView" id="8b810b4e-c015-4fc1-8b90-dce9092172d4">
        <updating/>
        <source>zSetControlsForView() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	btnSaveBase.enabled		:= false;
	btnCancelBase.enabled	:= true;

	btnNewTV.enabled		:= self.allowAdd;
	btnNewChildTV.enabled	:= self.allowAddChild;
	btnDeleteTV.enabled		:= self.allowDelete;	
	btnEditTV.enabled		:= self.allowUpdate;
	btnPrintTV.enabled		:= self.allowPrint;		

	self.lstData.enabled	:= true;

	sptThumbEdit.hideRightControl(true);
	
	self.setControlsForView();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSetFormDefaults" id="68ed8225-c800-4497-a329-e2452b163047">
        <updating/>
        <source>zSetFormDefaults() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
	self.useProxyObject			:= true;
	self.allowAdd				:= true;
	self.allowAddChild			:= false;
	self.allowNext				:= false;
	self.allowDelete			:= true;
	self.allowUpdate			:= true;
	self.showDataOnStartup 		:= true; 	// populate the data table with data
	self.allowPrint  			:= true;

	self.mode := Mode_View;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zShowThumbnailData" id="e53ac002-bea4-456e-bd0d-87c7b99465e1">
        <updating/>
        <source>zShowThumbnailData(obj : Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if obj = null then
		self.myCurrentObject := null;
		self.clearThumbnailData();
	else
		if obj.isKindOf(CM_Object) then
			self.myCurrentObject := obj.CM_Object;
		endif;
		self.showThumbnailData(obj);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="zShowThumbnailDataExHandler" id="51883fae-1538-4dfc-a7d3-16086cdd869e">
        <updating/>
        <source>zShowThumbnailDataExHandler(exObj : Exception) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	
vars

begin
	if exObj.errorCode = 4 then
	
		app.msgBox('The object or one of its components has been deleted', 'Error', MsgBox_OK_Only);
		self.myCurrentObject := null;
		self.zLstDataShow();
		return Ex_Abort_Action;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTimerEvent" id="1b8e0acd-094a-45be-947a-469036bfed41">
        <updating/>
        <source>zTimerEvent(eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if eventTag = Timer_Refresh then
		self.timerRefreshActive := false;
		self.zDoLstDataRefresh();
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
