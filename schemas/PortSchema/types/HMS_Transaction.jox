    </JadeMethod>
    <JadeMethod name="getHMSTransForAuditEnquiry" id="69cb50d5-0a84-491d-92ed-759f7680fd6a">
        <source>getHMSTransForAuditEnquiry(_auditEnquirySearcher : CMIF_HMS_AuditEnquiry input; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	17 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpVessel : CM_Vessel;
begin
	if _auditEnquirySearcher = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, '_auditEnquirySearcher is null');
		return;
	endif;
	
	if (not _auditEnquirySearcher.allSelectedTransactionTypes.isEmpty) then	
		if (not _auditEnquirySearcher.allSelectedTransactionTypes.includes(self.type)) then
			return;
		endif;
	endif;
	
	if (not _auditEnquirySearcher.allSelectedUsers.isEmpty) then
		if (not _auditEnquirySearcher.allSelectedUsers.includesKey(self.userCode)) then
			return;
		endif;	
	endif;
	
	if (not _auditEnquirySearcher.allSelectedVessels.isEmpty) then
		if self.myHMSVoyageData &lt;&gt; null then
			tmpVessel := self.myHMSVoyageData.getMyVessel();
		elseif self.myMovement &lt;&gt; null then
			tmpVessel := self.myMovement.getMyVessel();
		endif;
		if tmpVessel = null then
			return;
		endif;
		if (not _auditEnquirySearcher.allSelectedVessels.includes(tmpVessel)) then
			return;
		endif;
	endif;		
	
	_auditEnquirySearcher.allFoundTransactions.add(self);

end;</source>
        <Parameter name="_auditEnquirySearcher" type="CMIF_HMS_AuditEnquiry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
