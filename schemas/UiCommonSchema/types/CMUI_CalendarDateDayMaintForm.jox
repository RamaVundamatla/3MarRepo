    <JadeMethod name="doClearGrpNewData" id="c68a5bda-59c5-4158-9040-55fbdb968e47">
        <source>doClearGrpNewData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

begin

	self.cmbCalendar.listIndex := -1;
	self.cmbCalendar.enabled := true;
	self.txtDate.setDate(self.selectedDate);
	self.txtDate.enabled := false;
	self.txtDescription.text := null;
	self.txtTimeFrom.setTime(null);
	self.txtTimeTo.setTime(null);
	self.txtTimeFrom.enabled := false;
	self.txtTimeTo.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="31351b4e-7867-43aa-a4a4-e02a630d768a">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 March 2011	cnwndl1	Initial creation

*/

vars

	selectedCal : CM_Calendar;
	calendar : CM_Calendar;
	pos : Integer;
	rebuild : Boolean;
	iterCal : Iterator;

begin

	if theObject.isKindOf( CM_Calendar ) then
	
		if eventType = Object_Delete_Event and self.cmbCalendar.findObject( theObject ) &gt; 0 then
			rebuild := true;
		elseif eventType = Object_Create_Event and self.cmbCalendar.findObject( theObject ) &lt; 1 then
			rebuild := true;
		else
			rebuild := false;
		endif;
	
		if rebuild then
		
			selectedCal := self.cmbCalendar.listObject.CM_Calendar;
			if theObject.CM_Calendar = selectedCal then
				selectedCal := null;
			endif;
		
			self.cmbCalendar.clear();
			if not self.allSelectedCalendars.isEmpty then
				iterCal := self.allSelectedCalendars.createIterator;
			elseif self.myTerminal &lt;&gt; null then
				iterCal := self.myTerminal.allCalendars.createIterator;
			else
				iterCal := app.myRoot.allCalendars.createIterator;
			endif;
			while iterCal.next( calendar ) do
				pos := self.cmbCalendar.addItem(calendar.description);
				self.cmbCalendar.itemObject[pos] := calendar;
			endwhile;
			
			if selectedCal &lt;&gt; null then
				self.cmbCalendar.listIndex := self.cmbCalendar.findObject( selectedCal );
			endif;
		
		endif;
		
	endif;

epilog

	delete iterCal;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNewClick" id="f35576fc-5092-4607-9a2a-c3d95a6e9a52">
        <source>doNewClick();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2010	cnwndl1	Initial creation

*/

vars

begin

	self.populateTblDayData();
	self.grpNewDate.enabled := true;
	self.splMain.enabled := false;
	self.txtTimeFrom.enabled := false;
	self.txtTimeTo.enabled := false;
	self.cmbCalendar.setFocus();
	self.btnNew.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveClick" id="f380ac67-332c-47ff-9d28-f55f3cd8e4cd">
        <source>doRemoveClick();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2010	cnwndl1	Initial creation

*/

vars

	calDate : CM_CalendarDate;
	msg : String;
	
begin

	calDate := self.tblDayData.allSelectedObjects.first.CM_CalendarDate;

	if calDate = null then
		return;
	endif;
	
	msg := app.getErrorString1(Lit_Confirm_Delete, app.getErrorString1(Calendar_entries, "1") );
	if app.msgBox( msg, app.getErrorString(Calendar), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	app.myTrxDA.trxDeleteCalendarDate(calDate, app.myPassport);
	
	self.populateTblDayData();
		
epilog

	self.doClearGrpNewData();
	self.showButtons();

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="043f1b78-f5a2-4143-8f6e-0396675e22bf">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

	vLeft : Real;
	vWidth : Real;
	vTop : Real;
	vHeight : Real;

begin

	vTop := 1;
	vLeft := 1;
	vWidth := self.width - 10;
	vHeight := self.clientHeight - 245;
	vHeight := self.clientHeight - self.grpNewDate.height - 30;

	self.grpDates.move(	vLeft,	//x : Real;
						vTop,	//y : Real;
						vWidth,	//width2 : Real;
						vHeight	//height2 : Real
						);
				
	vHeight := self.grpDates.height - 30;
	self.splMain.move(	self.splMain.left,	//x : Real;
						vTop,	//y : Real;
						self.splMain.width,	//width2 : Real;
						vHeight	//height2 : Real
						);
						
						
	vTop := self.grpDates.top + self.grpDates.height;
	vHeight := self.grpNewDate.height;
	
	self.grpNewDate.move(	vLeft,	//x : Real;
							vTop,	//y : Real;
							vWidth,	//width2 : Real;
							vHeight	//height2 : Real
							);
												
	vWidth := self.grpDates.width - 2;
	
	
	self.txtFilterSummary.left := vLeft;
	self.txtFilterSummary.width := vWidth;
	
	self.splMain.left := vLeft;
	self.splMain.width := vWidth;
	
	self.btnClose.top := self.grpNewDate.top + self.grpNewDate.height + 5;
	self.btnClose.left := self.btnCancel.left + self.grpNewDate.left + 2;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveClick" id="a7fbcbf6-214f-4d2e-9f11-7def46f57dfb">
        <source>doSaveClick();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2010	cnwndl1	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars

	calendarDate : CM_CalendarDate;
	calendarDateProxy : CM_CalendarDate;
	loadState : Boolean;
	date : Date;
	description : String;
	year : Integer;
	startTime : Time;
	endTime : Time;
	calendar : CM_Calendar;
	calendarYear : CM_CalendarYear;
	calendarYearProxy : CM_CalendarYear;
	theReturn : Integer;
	errString : String;

begin

	calendarDate := self.tblDayData.allSelectedObjects.last.CM_CalendarDate;
	
	if calendarDate = null then
		create calendarDateProxy transient;
	else
		calendarDateProxy := calendarDate.pxyGetProxyObject();
		if calendarDateProxy = null then
			app.cmsBeginLoad(loadState);
			calendarDateProxy := calendarDate.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
		endif;
	endif;
	
	calendar := cmbCalendar.listObject.CM_Calendar;
	if calendar = null then
	//	errString := app.getErrorString1(REQUIRED_FIELD, lblCalendar.caption);
		errString := app.getErrorString1(Input_required_field_Required, lblCalendar.caption); // cnwdb2	PAR 35364
		
		app.msgBox(errString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		cmbCalendar.setFocus();
		return;
	endif;
	
	date := txtDate.getDate;
	if not date.isValid then
//		errString := app.getErrorString1(REQUIRED_FIELD, lblDate.caption);
		errString := app.getErrorString1(Input_required_field_Required, lblDate.caption);// cnwdb2	PAR 35364

		app.msgBox(errString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		txtDate.setFocus();
		return;
	endif;
	
	description := txtDescription.text.trimBlanks;
	if description = null then
	//	errString := app.getErrorString1(REQUIRED_FIELD, lblDescription.caption);
		errString := app.getErrorString1(Input_required_field_Required, lblDescription.caption); // cnwdb2	PAR 35364

		app.msgBox(errString, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		txtDescription.setFocus();
		return;
	endif;
	
	startTime := self.txtTimeFrom.getTime;
	endTime := self.txtTimeTo.getTime;
	
	year := date.year;
	
	calendarYear := calendar.allCalendarYears.getAtKey(year);
	
	if calendarYear = null then
	
		// have to create a new calendar year first...
		create calendarYearProxy transient;
		calendarYearProxy.setProxy( year, calendar);
	
		while true do
			app.myTrxCA.trxCreateCalendarYear(calendarYearProxy, calendarYear, app.myPassport, false);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				delete calendarYearProxy;
				self.clearErrorWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog("Calendar", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
		
	endif;
	
	// set up the calendar and calendar year on the calendar date transient.
	calendarDateProxy.setProxy(	date,	//_date : Date;
								description,	//_description : String;
								calendar,	//_myCalendar : CM_Calendar;
								calendarYear,	//_myCalendarYear : CM_CalendarYear
								calendarDateProxy.dataSource	//_dataSource : Integer
								);
								
	calendarDateProxy.setStartEndTime( startTime, endTime );
	
	while true do
		if calendarDate = null then
			app.myTrxCA.trxCreateCalendarDate(calendarDateProxy, calendarDate, app.myPassport);
		else
			app.myTrxUA.trxUpdateCalendarDate(calendarDateProxy, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			delete calendarDateProxy;
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog("Calendar", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	calendar.causeEvent(EVENT_Calendar_Update, true, calendar);

	self.populateTblDayData();
	self.splMain.enabled := true;
	self.grpNewDate.enabled := false;
	self.btnNew.enabled := true;
	
	self.doClearGrpNewData();
	self.showButtons();
		
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
//	self.doClearGrpNewData();
//	self.showButtons();

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateClick" id="2514be78-1e2d-4301-a20b-3bad7e955a72">
        <source>doUpdateClick();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

	calendarDate : CM_CalendarDate;
	
begin

	calendarDate := self.tblDayData.allSelectedObjects.last.CM_CalendarDate;
	if calendarDate = null then
		self.doClearGrpNewData();
		self.grpNewDate.enabled := false;
		self.splMain.enabled := true;
		return;
	endif;
	
	self.grpNewDate.enabled := true;
	self.splMain.enabled := false;
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	self.btnNew.enabled := false;
	self.cmbCalendar.listIndex := self.cmbCalendar.findObject( calendarDate.myCalendar );
	self.cmbCalendar.enabled := false;
	self.txtDescription.text := calendarDate.description;
	self.txtTimeFrom.setTime(calendarDate.startTime);
	self.txtTimeTo.setTime(calendarDate.endTime);
	self.txtTimeFrom.enabled := calendarDate.myCalendar.hasTime;
	self.txtTimeTo.enabled := calendarDate.myCalendar.hasEndTime;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblDayData" id="a7b07084-e256-4f9c-a72f-5b674dca13f1">
        <source>initTblDayData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

	headingRow : String;
	
begin

	self.tblDayData.clear();
	self.tblDayData.allSelectedObjects.clear();
	self.tblDayData.fixedRows := 1;
	self.tblDayData.rows := 1;
	self.tblDayData.fixedColumns := 0;
	self.tblDayData.columns := 6;
	
	self.tblDayData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblDayData.selectionType := CM_BaseTable.SelectionType_Row;
	
	headingRow := app.getErrorString(Calendar) &amp; Tab
					&amp; app.getErrorString(Year) &amp; Tab
					&amp; app.getErrorString(DateStr) &amp; Tab
					&amp; app.getErrorString(Day) &amp; Tab
					&amp; app.getErrorString(TimeStr) &amp; Tab
					&amp; app.getErrorString(Description);
					
	self.tblDayData.setCellText(1,1,headingRow);
	
	setFilterMacroInfo();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblDayData" id="a3eb151b-b6c1-4ebf-ae70-086eac46cb63">
        <source>populateTblDayData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

	calendar : CM_Calendar;
	dates : CM_CalendarDatesByDateTimedict;
	calendarDate : CM_CalendarDate;
	iterCal : Iterator;
	iter : Iterator;
	jadTableRow : JadeTableRow;
	invalidObject : Boolean;
	lastAddedStr : String;
	tableDisplay : String;
	dups : Boolean;
	errString : String;
	calendarDesc : String;
	index : Integer;

begin

	self.initTblDayData();
	self.cmbCalendar.clear();
	
	if not self.allSelectedCalendars.isEmpty then
		iterCal := self.allSelectedCalendars.createIterator;
	elseif self.myTerminal &lt;&gt; null then
		iterCal := self.myTerminal.allCalendars.createIterator;
	else
		iterCal := app.myRoot.allCalendars.createIterator;
	endif;
	
	create dates transient;
	
	on Exception do app.handleDeletedObject(exception, calendarDate, invalidObject);
	
	while iterCal.next( calendar ) do
	
		dates.clear();
		calendar.getAllCalendarDatesForDay( self.selectedDate, dates);
		calendarDesc := calendar.description;
		
		index := self.cmbCalendar.addItem( calendarDesc );
		self.cmbCalendar.itemObject[index] := calendar;
		
		if dates.isEmpty then
			continue;
		endif;
		
		iter := dates.createIterator;
	
		while iter.next( calendarDate ) do
			self.tblDayData.rows := self.tblDayData.rows + 1;
			jadTableRow := self.tblDayData.accessRow( self.tblDayData.rows );
			jadTableRow.itemObject := calendarDate;
			tableDisplay := calendarDate.getStringForTable;
			tableDisplay := calendarDesc &amp; Tab &amp; tableDisplay;
			if invalidObject then
				self.tblDayData.rows := self.tblDayData.rows - 1;
				invalidObject := false;
				continue;
			endif;
			self.tblDayData.setCellText( self.tblDayData.rows, 1, tableDisplay );
			if tableDisplay = lastAddedStr then
				jadTableRow.backColor := Grey;
				dups := true;
			endif;
			lastAddedStr := tableDisplay;
		endwhile;
		
		delete iter;
	
	endwhile;
	
	self.showButtons();
	
	if dups then
		errString := app.getErrorString(Possible_duplicates);
		app.msgBox(errString, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;

epilog

	delete iterCal;
	delete dates;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterData" id="9de4bcfe-ef8a-483c-ad93-82e1f80f4de6">
        <updating/>
        <source>setFilterData(_calendars : CM_CalendarByCodeDict; _dayTypes : CM_DayTypesByCodeDict; _date : Date ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

begin

	self.selectedDate := _date;
	self.allSelectedCalendars.clear();
	self.allSelectedDayTypes.clear();
	
	if not _calendars.isEmpty then
		_calendars.copy( self.allSelectedCalendars );
	endif;
	
	if not _dayTypes.isEmpty then
		_dayTypes.copy( self.allSelectedDayTypes );
	endif;

epilog

end;</source>
        <Parameter name="_calendars" type="CM_CalendarByCodeDict"/>
        <Parameter name="_dayTypes" type="CM_DayTypesByCodeDict"/>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFilterMacroInfo" id="c6a72009-2859-4a2c-9a29-7ca40574c5d6">
        <source>setFilterMacroInfo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars
	text : String;
	dayType : CM_DayType;
	outputString : String;
	calendar : CM_Calendar;
begin

	outputString := outputString &amp; app.getErrorString(Calendar_dates_for) &amp; self.selectedDate.asStringJMT &amp; " " &amp; app.getErrorString(Only) &amp; CrLf;

	text := null;
	if self.allSelectedCalendars.isEmpty then
		if self.myTerminal &lt;&gt; null then
			outputString := outputString &amp; app.getErrorString1(Includes_calendars_for, self.myTerminal.name) &amp; CrLf;
		else
			outputString := outputString &amp; app.getErrorString(Includes_calendars) &amp; CrLf;
		endif;
	else
		foreach calendar in self.allSelectedCalendars do
			if text = null then
				text := calendar.description;
			else
			//	text := text &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; calendar.description;
				text := text &amp; ", " &amp; calendar.description;
			endif;
		endforeach;
		outputString := outputString &amp; app.getErrorString(Includes_calendars_colon) &amp; Tab &amp; text &amp; CrLf;
	endif;
	
	
	
	text := null;
	if self.allSelectedDayTypes.isEmpty then
		outputString := outputString &amp; app.getErrorString(Includes_all_day_types);
	else
		foreach dayType in self.allSelectedDayTypes do
			if text = null then
				text := dayType.description;
			else
				text := text &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; dayType.description;
			endif;
		endforeach;
		outputString := outputString &amp; app.getErrorString(Includes_day_types_of) &amp; Tab &amp; text;
	endif;
	
	
	
	txtFilterSummary.text := outputString;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b5816ead-eed9-468a-865d-66f1ba43aa4d">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

begin

	self.beginClassNotification(CM_Calendar, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_Calendar, false, Object_Delete_Event, Response_Continuous, null);

	self.caption := "Maintain Calendar Date(s) for " &amp; self.selectedDate.asStringJMT;

	inheritMethod();
	
	self.minimumWidth := 760;
	self.minimumHeight := 495;
	
	self.populateTblDayData();
	self.doClearGrpNewData();

epilog

end;</source>
    </JadeMethod>
