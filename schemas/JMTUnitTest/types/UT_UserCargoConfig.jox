    <JadeMethod name="tTestExtractLoad" id="2217ab94-167b-4822-b5a3-356207cd9fa7">
        <updating/>
        <source>tTestExtractLoad() updating;
// cnwns1
// cnwjre1 CCMS 1776 28082 extract default, extract specific config, remove and reload config, load default
// jlgdap1 TFS 44554 AAT Stevedore Data Access
vars
	count,
	count2	: Integer;
	cargoType1Id,
	cargoType2Id	: Integer;
	cargoType1Desc,
	cargoType2Desc	:  String;
	filePath	: String;
	fileLine	: String;
	expected1,
	expected2	: String;
	
	file		: File;
	user		: CM_User;
	cargoType	: CM_CargoType;
	cargoTypes	: CM_CargoBOLTypeArray;
	ucType,
	ucType2		: CM_UserConfigCargoType;
	ucTab,
	ucTab2		: CM_UserConfigTab;
	ucAttr,
	ucAttr1,
	ucAttr2		: CM_UserConfigAttribute;
	extractAgent	: CM_ExtractLoadAgent;
begin
	// default extract
	create cargoTypes transient;
	foreach cargoType in CM_CargoType.instances do
		count := count + 1;
		if count = 1 then
			cargoType1Id := cargoType.id;
			cargoType1Desc := cargoType.description;
			cargoTypes.add(cargoType);
		elseif count = 2 then
			cargoType2Id := cargoType.id;
			cargoType2Desc := cargoType.description;
			cargoTypes.add(cargoType);
		else
			break;
		endif;
	endforeach;
	create file transient;
	file.fileName := self.getTempDirectory() &amp; "UserCargoConfig1.csv";
	file.mode := File.Mode_Output;
	self.assertTrue(file.tryOpen());
	
	user := app.getMyUser();
	
	create extractAgent;
	extractAgent.extractUserCargoConfig(file, user, cargoTypes);
	
	file.close;
	
	file.mode := File.Mode_Input;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.open;
	
	count := 0;
	while not file.endOfFile() do
		fileLine := file.readLine();
		count := count + 1;
		if count = 2 then
			self.assertEqualMsg(fileLine, user.code &amp; "," &amp; cargoType1Id.String &amp; "," &amp; cargoType1Desc &amp; ",true,,,,,", "Extract file 1 line 2");
		elseif count = 3 then
			self.assertEqualMsg(fileLine, user.code &amp; "," &amp; cargoType2Id.String &amp; "," &amp; cargoType2Desc &amp; ",true,,,,,", "Extract file 1 line 2");
		endif;
	endwhile;
	
	self.assertEqualMsg(count, 3, "Extract file 1 records");
	file.close();

	// set up specific config and extract
	cargoType := self.getCargoType("CONT");
	ucType := user.getUserCargoTypeForEdit(cargoType, false);
	ucType.isDefault := false;
	
	self.updateUserCargoConfig(ucType);
	
	ucType2 := user.allUserCargoTypes[user, cargoType];		// persistent instance just created
	self.assertNotNullMsg(ucType2, "User cargo config for extract");
	count := 0;
	foreach ucTab in ucType2.allUserConfigTabs do
		foreach ucAttr in ucTab.allAttributes do
			count := count + 1;
			if count = 1 then
				ucAttr1 := ucAttr;		// first
			endif;
		endforeach;
	endforeach;
	ucAttr2 := ucAttr;		// last
	
	cargoTypes.clear();
	cargoTypes.add(cargoType);
	file.fileName := self.getTempDirectory() &amp; "UserCargoConfig2.csv";
	file.mode := File.Mode_Output;
	self.assertTrue(file.tryOpen());
	// extract this config
	extractAgent.extractUserCargoConfig(file, user, cargoTypes);
	file.close;
	
	file.mode := File.Mode_Input;
	file.open;
	
	expected1 := "UNITTEST,1,ISO Container,false,GeneralData,General,0,252001,ID";
	//expected2 := "UNITTEST,1,ISO Container,false,ShipOpsData,Ship Ops,0,250658,Bill Of Lading";	// _generalLandingDate : Date	//16 Mar 2016	TFS 1636 
	//expected2 := "UNITTEST,1,ISO Container,false,ShipOpsData,Ship Ops,0,260565,General Landing Date";		// TFS 44554
	//expected2 := "UNITTEST,1,ISO Container,false,ShipOpsData,Ship Ops,0,272786,Stevedore";				// TFS 44554
	//expected2 := "UNITTEST,1,ISO Container,false,ShipOpsData,Ship Ops,0,268150,Voyage External Code";		// TFS 53352
	//expected2 := "UNITTEST,1,ISO Container,false,ShipOpsData,Ship Ops,0,273888,Shipping Line";
	expected2 := "UNITTEST,1,ISO Container,false,ShipOpsData,Ship Ops,0,275489,Port Of Origin";
	count2 := 0;
	while not file.endOfFile() do
		fileLine := file.readLine();
		count2 := count2 + 1;
		if count2 = 2 then
			self.assertEqualMsg(fileLine, expected1, "Extract file 2 first content");
		endif;
	endwhile;
	self.assertEqualMsg(fileLine, expected2, "Extract file 2 last content");
	
	self.assertEqualMsg(count2, count+1, "Extract file 2 records");
	file.close();
	
	// delete all configs and load from file
	self.unitTestBeforeClass();
	
	fileLine := "User,Cargo Type Id, Cargo Type Description,Default,Tab name, Tab Description, Tab Type,Attribute Number,Attribute Description" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,false,GeneralData,General,0,252001,ID" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,false,GeneralData,General,0,255715,Sub-Terminal" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,false,GeneralData,General,0,252836,Voyage" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,false,LocationMoveData,Location,0,253304,Prior Location" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,false,LocationMoveData,Location,0,253306,Prior Stowage" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,false,LocationMoveData,Location,0,252628,Last Moved On" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,false,ReceiveData,Receive/Release,0,253442,Received Date/Time" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,false,ReceiveData,Receive/Release,0,253426,Receipt Transport Mode" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,false,ReceiveData,Receive/Release,0,256554,Expected Date/Time";


	self.userConfigCargoLoad(fileLine, "UserCargoConfig3");
	
	// read the new persistent instance
	cargoType := self.getCargoType("CONT");
	ucType2 := user.allUserCargoTypes[user, cargoType];		// persistent instance just created
	self.assertNotNullMsg(ucType2, "User cargo config from load");
	count := 0;
	count2 := 0;
	foreach ucTab in ucType2.allUserConfigTabs do
		count := count + 1;
		foreach ucAttr in ucTab.allAttributes do
			count2 := count2 + 1;
		endforeach;
	endforeach;
	self.assertEqualMsg(count, 3, "Loaded config tabs");
	self.assertEqualMsg(count2, 9, "Loaded config attributes");
	
	// now load a config and check that it deletes this
	fileLine := "User,Cargo Type Id, Cargo Type Description,Default,Tab name, Tab Description, Tab Type,Attribute Number,Attribute Description" &amp; CrLf &amp;
				"UNITTEST,1,ISO Container,true,,,,,";

	self.userConfigCargoLoad(fileLine, "UserCargoConfig4");
	
	// read the new persistent instance
	cargoType := self.getCargoType("CONT");
	ucType2 := user.allUserCargoTypes[user, cargoType];		// persistent instance just cleared
	self.assertNullMsg(ucType2, "User cargo config from load");

epilog
	if file &lt;&gt; null then
		if file.isOpen then
			file.close();
		endif;
		delete file;
	endif;
	delete extractAgent;
	delete cargoTypes;
	delete ucType;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTestMaintenance" id="d6876acf-b7c3-4744-9280-b5d22a2cc9fd">
        <updating/>
        <source>tTestMaintenance() updating;
// cnwmp6
// cnwjre1 CCMS 1776 28082 user configuration of cargo enquiry tabs, test the maintenance of this
vars
	count		: Integer;
	count2		: Integer;
	user		: CM_User;
	cargoType	: CM_CargoType;
	ucType,
	ucType2		: CM_UserConfigCargoType;
	ucTab,
	ucTab2		: CM_UserConfigTab;
	ucAttr,
	ucAttr1,
	ucAttr2		: CM_UserConfigAttribute;
begin
	user := app.getMyUser();
	cargoType := self.getCargoType("CONT");
	
	ucType := user.getUserCargoTypeForEdit(cargoType, false);
	
	foreach ucTab in ucType.allUserConfigTabs do
		count := count + 1;
		if count = 6 then
			self.assertEqualMsg(ucTab.allAttributes.size, 20, "Default config, 6th tab ["&amp; ucTab.description  &amp;"], number of attributes ");	// TFS 1636		// TFS 53352 shipping line , port of orgin
			foreach ucAttr in ucTab.allAttributes do
				count2 := count2 + 1;
				if count2 = 1 then
					ucAttr1 := ucAttr;
				elseif count2 = 2 then
					ucAttr2 := ucAttr;
				endif;
			endforeach;
		endif;
	endforeach;
	self.assertEqualMsg(count, 6, "Default config number of tabs");
	self.assertEqualMsg(ucType.isDefault, true, "Default config IS default");
	
	// move the first two attributes of the sixth tab to a new 7th tab
	create ucTab2 transient;
	ucTab2.setup("New tab", "tab7", 0, ucType);
	ucAttr1.setup(ucTab2, ucAttr1.myEntTableRow);
	ucAttr2.setup(ucTab2, ucAttr2.myEntTableRow);
	ucType.isDefault := false;
	
	self.updateUserCargoConfig(ucType);
	
	ucType2 := user.allUserCargoTypes[user, cargoType];		// persistent instance just created
	count := 0;
	foreach ucTab in ucType2.allUserConfigTabs do
		count := count + 1;
		if count = 6 then
			self.assertEqualMsg(ucTab.allAttributes.size, 18, "First updated, 6th tab ["&amp; ucTab.description  &amp;"], number of attributes "); // TFS 1636 	// TFS 53352 port of Orgin , Shipping line 
		elseif count = 7 then
			self.assertEqualMsg(ucTab.description, "New tab", "First updated config, 7th tab description");
			self.assertEqualMsg(ucTab.allAttributes.size, 2,  "First updated, 7th tab ["&amp; ucTab.description  &amp;"], number of attributes ");
			count2 := 0;
			foreach ucAttr in ucTab.allAttributes do
				count2 := count2 + 1;
				if count2 = 1 then
					self.assertEqualMsg(ucAttr.myEntTableRow.getHeadingUnaltered(), "Planning State", "First updated, 7th tab, 1st attribute ");
				elseif count2 = 2 then
					self.assertEqualMsg(ucAttr.myEntTableRow.getHeadingUnaltered(), "Ready To Ship", "First updated, 7th tab, 2nd attribute ");
				endif;
			endforeach;
		endif;
	endforeach;
	self.assertEqualMsg(count, 7, "First updated config number of tabs");
	
	// change the order of tabs and attributes
	delete ucType;
	ucType := user.getUserCargoTypeForEdit(cargoType, false);
	count := 0;
	foreach ucTab in ucType.allUserConfigTabs do
		count := count + 1;
		if count = 7 then
			count2 := 0;
			foreach ucAttr in ucTab.allAttributes do
				count2 := count2 + 1;
				if count2 = 1 then
					ucAttr1 := ucAttr;
				elseif count2 = 2 then
					ucAttr2 := ucAttr;
				endif;
			endforeach;
		endif;
	endforeach;
	ucTab.allAttributes.remove(ucAttr1);
	ucTab.allAttributes.remove(ucAttr2);
	ucTab.allAttributes.add(ucAttr2);
	ucTab.allAttributes.add(ucAttr1);
	
	ucType.moveTab(ucTab, true);		// move the last tab up one place

	self.updateUserCargoConfig(ucType);
	
	ucType2 := user.allUserCargoTypes[user, cargoType];		// persistent instance just updated
	count := 0;
	foreach ucTab in ucType2.allUserConfigTabs do
		count := count + 1;
		if count = 6 then
			self.assertEqualMsg(ucTab.description, "New tab", "Second update config, 6th tab description");
			self.assertEqualMsg(ucTab.allAttributes.size, 23, "Second update, 6th tab ["&amp; ucTab.description  &amp;"], number of attributes ");
			count2 := 0;
			foreach ucAttr in ucTab.allAttributes do
				count2 := count2 + 1;
				if count2 = 1 then
					self.assertEqualMsg(ucAttr.myEntTableRow.getHeadingUnaltered(), "Date Time", "Second updated, 6th tab, 1st attribute ");
//					self.assertEqualMsg(ucAttr.myEntTableRow.getHeadingUnaltered(), "Ready To Ship", "Second updated, 6th tab, 1st attribute ");
				elseif count2 = 2 then
					self.assertEqualMsg(ucAttr.myEntTableRow.getHeadingUnaltered(), "Free Storage Expiry Date", "Second updated, 6th tab, 2nd attribute "); 
//					self.assertEqualMsg(ucAttr.myEntTableRow.getHeadingUnaltered(), "Planning State", "Second updated, 6th tab, 2nd attribute ");
				endif;
			endforeach;
		elseif count = 7 then
			self.assertEqualMsg(ucTab.allAttributes.size, 18, "Second update, 7th tab ["&amp; ucTab.description  &amp;"], number of attributes ");		// TFS 1636 	// TFS 53352 port of orgin ,shipping line 
		endif;
	endforeach;
	self.assertEqualMsg(count, 7, "Second updated config number of tabs");
	
	// reset to default, confirm that this deletes the instances
	delete ucType;
	ucType := user.getUserCargoTypeForEdit(cargoType, false);
	ucType.isDefault := true;
	
	self.updateUserCargoConfig(ucType);
	
	ucType2 := user.allUserCargoTypes[user, cargoType];		// persistent instance just updated - should be null now
	self.assertNullMsg(ucType2, "Default user cargo config instance");
epilog
	delete ucType;	// should be no leaked transients
end;
</source>
    </JadeMethod>
    <JadeMethod name="unitTestBeforeClass" id="9f6a52eb-d700-4b13-8dcb-11c8a2de9b86">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
// cnwjre1 delete all CM_UserConfigCargoType instances and children before the test
vars
	uct : CM_UserConfigCargoType;
begin
	beginTransaction;
	foreach uct in CM_UserConfigCargoType.instances do
		uct.erase(NORMAL_ERASE);
	endforeach;
	commitTransaction;

end;
</source>
        <access>protected</access>
    </JadeMethod>
</Class>
