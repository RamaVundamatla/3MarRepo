    <JadeMethod name="setFromRoadJob" id="738bff83-f6b7-42c4-881b-e9b887f88fc2">
        <updating/>
        <source>setFromRoadJob(_job : CM_RoadJob; term : CM_Terminal)updating;
/*
	Created on 18 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	self.myRoadJob 			:= _job;
	self.myTerminal 		:= term;
	self.carrierCode 		:= _job.carrierId;
	self.regNumber 			:= _job.regNumber;
end;</source>
