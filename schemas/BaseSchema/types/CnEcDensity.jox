    <JadeMethod name="convertBaseToTarget" id="cd00245a-127e-496e-ad27-3c5412159539">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;

begin
	if pUnitTo = self.GRAINS_PER_GALLON_UK then
		convertedMeasure	:=	pMeasure * 70157;
	
	elseif pUnitTo = self.GRAINS_PER_GALLON_US then
		convertedMeasure	:=	pMeasure * 58418;
	
	elseif pUnitTo = self.GRAMS_PER_CUBIC_CENTIMETRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.GRAMS_PER_LITRE then
		convertedMeasure	:=	pMeasure * 1000;
	
	elseif pUnitTo = self.GRAMS_PER_MILLILITRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.KILOGRAMS_PER_CUBIC_METRE then
		convertedMeasure	:=	pMeasure * 1000;
	
	elseif pUnitTo = self.KILOGRAMS_PER_LITRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.MEGAGRAMS_PER_CUBIC_METRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.MILLIGRAMS_PER_LITRE then
		convertedMeasure	:=	pMeasure * 1000000;
	
	elseif pUnitTo = self.MILLIGRAMS_PER_MILLILITRE then
		convertedMeasure	:=	pMeasure * 1000;
	
	elseif pUnitTo = self.OUNCES_PER_CUBIC_INCH then
		convertedMeasure	:=	pMeasure / 1.729994044;
	
	elseif pUnitTo = self.OUNCES_PER_GALLON_UK then
		convertedMeasure	:=	pMeasure / 0.006236023;
	
	elseif pUnitTo = self.OUNCES_PER_GALLON_US then
		convertedMeasure	:=	pMeasure / 0.007489152;
	
	elseif pUnitTo = self.POUNDS_PER_CUBIC_FOOT then
		convertedMeasure	:=	pMeasure / 0.016018463;
	
	elseif pUnitTo = self.POUNDS_PER_CUBIC_INCH then
		convertedMeasure	:=	pMeasure / 27.679905;
	
	elseif pUnitTo = self.POUNDS_PER_GALLON_UK then
		convertedMeasure	:=	pMeasure / 0.099776373;
	
	elseif pUnitTo = self.POUNDS_PER_GALLON_US then
		convertedMeasure	:=	pMeasure / 0.119826427;
	
	elseif pUnitTo = self.TONNES_PER_CUBIC_METRE then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.TONS_UK_PER_CUBIC_YARD then
		convertedMeasure	:=	pMeasure / 1.328939184;
	
	elseif pUnitTo = self.TONS_US_PER_CUBIC_YARD then
		convertedMeasure	:=	pMeasure / 1.186552843;
	
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of Density to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="6e8927c2-0ab5-4325-b715-b8b04b6f9fbb">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;

begin
	if pUnitFrom = self.GRAINS_PER_GALLON_UK then
		convertedMeasure	:=	self.measure / 70157;
	
	elseif pUnitFrom = self.GRAINS_PER_GALLON_US then
		convertedMeasure	:=	self.measure / 58418;
	
	elseif pUnitFrom = self.GRAMS_PER_CUBIC_CENTIMETRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.GRAMS_PER_LITRE then
		convertedMeasure	:=	self.measure / 1000;
	
	elseif pUnitFrom = self.GRAMS_PER_MILLILITRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.KILOGRAMS_PER_CUBIC_METRE then
		convertedMeasure	:=	self.measure / 1000;
	
	elseif pUnitFrom = self.KILOGRAMS_PER_LITRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.MEGAGRAMS_PER_CUBIC_METRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.MILLIGRAMS_PER_LITRE then
		convertedMeasure	:=	self.measure / 1000000;
	
	elseif pUnitFrom = self.MILLIGRAMS_PER_MILLILITRE then
		convertedMeasure	:=	self.measure / 1000;
	
	elseif pUnitFrom = self.OUNCES_PER_CUBIC_INCH then
		convertedMeasure	:=	self.measure * 1.729994044;
	
	elseif pUnitFrom = self.OUNCES_PER_GALLON_UK then
		convertedMeasure	:=	self.measure * 0.006236023;
	
	elseif pUnitFrom = self.OUNCES_PER_GALLON_US then
		convertedMeasure	:=	self.measure * 0.007489152;
	
	elseif pUnitFrom = self.POUNDS_PER_CUBIC_FOOT then
		convertedMeasure	:=	self.measure * 0.016018463;
	
	elseif pUnitFrom = self.POUNDS_PER_CUBIC_INCH then
		convertedMeasure	:=	self.measure * 27.679905;
	
	elseif pUnitFrom = self.POUNDS_PER_GALLON_UK then
		convertedMeasure	:=	self.measure * 0.099776373;
	
	elseif pUnitFrom = self.POUNDS_PER_GALLON_US then
		convertedMeasure	:=	self.measure * 0.119826427;
	
	elseif pUnitFrom = self.TONNES_PER_CUBIC_METRE then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.TONS_UK_PER_CUBIC_YARD then
		convertedMeasure	:=	self.measure * 1.328939184;
	
	elseif pUnitFrom = self.TONS_US_PER_CUBIC_YARD then
		convertedMeasure	:=	self.measure * 1.186552843;
	
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of Density to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="51d0b73b-64c4-4d37-88a2-57fccdfdacdd">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.GRAINS_PER_GALLON_UK);
	pAllUnits.add(self.GRAINS_PER_GALLON_US);
	pAllUnits.add(self.GRAMS_PER_CUBIC_CENTIMETRE);
	pAllUnits.add(self.GRAMS_PER_LITRE);
	pAllUnits.add(self.GRAMS_PER_MILLILITRE);
	pAllUnits.add(self.KILOGRAMS_PER_CUBIC_METRE);
	pAllUnits.add(self.KILOGRAMS_PER_LITRE);
	pAllUnits.add(self.MEGAGRAMS_PER_CUBIC_METRE);
	pAllUnits.add(self.MILLIGRAMS_PER_LITRE);
	pAllUnits.add(self.MILLIGRAMS_PER_MILLILITRE);
	pAllUnits.add(self.OUNCES_PER_CUBIC_INCH);
	pAllUnits.add(self.OUNCES_PER_GALLON_UK);
	pAllUnits.add(self.OUNCES_PER_GALLON_US);
	pAllUnits.add(self.POUNDS_PER_CUBIC_FOOT);
	pAllUnits.add(self.POUNDS_PER_CUBIC_INCH);
	pAllUnits.add(self.POUNDS_PER_GALLON_UK);
	pAllUnits.add(self.POUNDS_PER_GALLON_US);
	pAllUnits.add(self.TONNES_PER_CUBIC_METRE);
	pAllUnits.add(self.TONS_UK_PER_CUBIC_YARD);
	pAllUnits.add(self.TONS_US_PER_CUBIC_YARD);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="59040442-d839-4941-bc72-8b9cdffe939f">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.GRAINS_PER_GALLON_UK then
		return "Grains per Gallon (UK)";
	elseif pUnit = self.GRAINS_PER_GALLON_US then
		return "Grains per Gallon (US)";
	elseif pUnit = self.GRAMS_PER_CUBIC_CENTIMETRE then
		return "Grams per Cubic Centimetre";
	elseif pUnit = self.GRAMS_PER_LITRE then
		return "Grams per Litre";
	elseif pUnit = self.GRAMS_PER_MILLILITRE then
		return "Grams per Millilitre";
	elseif pUnit = self.KILOGRAMS_PER_CUBIC_METRE then
		return "Kilograms per Cubic Metre";
	elseif pUnit = self.KILOGRAMS_PER_LITRE then
		return "Kilograms per Litre";
	elseif pUnit = self.MEGAGRAMS_PER_CUBIC_METRE then
		return "Megagrams per Cubic Metre";
	elseif pUnit = self.MILLIGRAMS_PER_LITRE then
		return "Milligrams per Litre";
	elseif pUnit = self.MILLIGRAMS_PER_MILLILITRE then
		return "Milligrams per Millilitre";
	elseif pUnit = self.OUNCES_PER_CUBIC_INCH then
		return "Ounces per Cubic Inch";
	elseif pUnit = self.OUNCES_PER_GALLON_UK then
		return "Ounces per Gallon (UK)";
	elseif pUnit = self.OUNCES_PER_GALLON_US then
		return "Ounces per Gallon (US)";
	elseif pUnit = self.POUNDS_PER_CUBIC_FOOT then
		return "Pounds per Cubic Foot";
	elseif pUnit = self.POUNDS_PER_CUBIC_INCH then
		return "Pounds per Cubic Inch";
	elseif pUnit = self.POUNDS_PER_GALLON_UK then
		return "Pounds per Gallon (UK)";
	elseif pUnit = self.POUNDS_PER_GALLON_US then
		return "Pounds per Gallon (US)";
	elseif pUnit = self.TONNES_PER_CUBIC_METRE then
		return "Tonnes per Cubic Metre";
	elseif pUnit = self.TONS_UK_PER_CUBIC_YARD then
		return "Tons (UK) per Cubic Yard";
	elseif pUnit = self.TONS_US_PER_CUBIC_YARD then
		return "Tons (US) per Cubic Yard";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Density to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
