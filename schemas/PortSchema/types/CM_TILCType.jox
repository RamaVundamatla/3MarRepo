    <JadeMethod name="validateDelete" id="38918832-5c7b-436d-9ace-c6ca29a556bd">
        <source>validateDelete(_passport: CM_Passport input);
// -------------------------------------------
// Created 08 December 2005 by cnwdvb1
// -------------------------------------------
// 04/12/2012	cnwcs5	par 30852 - some delete validation
vars

begin
	// need to check those non-inversed references - booking  ref item &amp; gate entities
	if not self.hasNoNonInversedUsages then											
		// can't be deleted
		app.raiseCMException1(ERR_CannotDeleteTrailerType, self.description, null, null);	
		return;																			
	endif;

	if not self.allTILCs.isEmpty()or not self.allTIMasterTILCs.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, self.description, (self.allTILCs.size + self.allTIMasterTILCs.size).String, null, null);
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="43a4a83c-3cc7-4828-b4f9-2dabb2a83f96">
        <source>validateMe();
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
vars
	ti				: CM_TrackedItem;
	tILCType ,realTILCType: CM_TILCType;

begin
	realTILCType := self.pxyGetRealObject();
	
	tILCType := self.myRoot.allTILCTypes[self.myCargoTypeExtTILC, self.description];
	
	if tILCType &lt;&gt; null and tILCType &lt;&gt; realTILCType then
		//app.raiseCMException2(DuplicateItem, 'Trailer Type with ID  ' &amp; self.code &amp; 'and Description '&amp; self.description , 'System', null, null); //14.06.2022 navds20 53760
		// Trailer Type with ID %1 already exists for Description %2 System : Trail_type_with_alrea_exist_de
		app.raiseCMException2(Trail_type_with_alrea_exist_de, self.code, self.description , null, null); //14.06.2022 navds20 53760
	endif;

	if self.code &lt;&gt; null then
		ti := self.myRoot.lookupTrackedItem(self.code, TI_CargoType_Null, TI_STATE_NORMAL, null, false, null, true);
	endif;
	
	if ti &lt;&gt; null and realTILCType = null then
		//app.raiseCMException2(DuplicateItem, 'A tracked item with an id of ' &amp; ti.id, 'System', null, null); //14.06.2022 navds20 53760
		// A tracked item with an id of %1 already exists for System : Track_item_with_alrea_exist_sy
		app.raiseCMException1(Track_item_with_alrea_exist_sy,  ti.id,  null, null); //14.06.2022 navds20 53760
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="d1b8e20d-2255-48cc-b09a-48c03d9a8a16">
        <source>validateUpdate(_passport: CM_Passport input);
// -------------------------------------------
// Created 12 December 2005 by cnwdvb1
// -------------------------------------------
// 05/12/2012	cnwcs5	par 30753 - don't allow change of cargo type
vars
	type, realType: CM_TILCType;
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Code", null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	endif;
	
	//Need this for combo box display
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Description", null, null);
		app.raiseCMException(Input_required_field_desc, null, null); // cnwdb2	PAR 35364

	endif;
	
	if self.numControllers &lt; 1 then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Number_Of_Controllers), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Number_Of_Controllers), null, null); // cnwdb2	PAR 35364
	endif;
	
	// Need to check for possible existing trailer type duplicates. #24507 13/07/2010
	realType	:= self.pxyGetRealObject();
	type		:= app.myRoot.allTILCTypes[self.myCargoTypeExtTILC, self.code];
	
	if type &lt;&gt; null then	
		// a real trailer type exists already
		if realType = null then 
			// trailer type creation
			app.raiseCMException3(ERR_DUPLICATE_KEY, app.getErrorString(Trailer_Type), self.code, null, null, null);
		else					
			// trailer type update
			if realType &lt;&gt; type then
				app.raiseCMException3(ERR_DUPLICATE_KEY, app.getErrorString(Trailer_Type), self.code, null, null, null);
			endif;
		endif;
	endif;
	
	// par 30753 - GUI should not let user change cargo type.  just make sure here.
	if realType &lt;&gt; null then
		if self.myCargoType &lt;&gt; realType.myCargoType then
			// we expect the GUI to prevent this - just make sure it does not slip through the model
			// users should never see this exception
			app.raiseUnexpectedProgramError (self.class.name, method.name, "Cargo type cannot be changed for existing Trailer Type");
		endif;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
