    <JadeMethod name="utlUpdateRTResetMediator" id="534b643e-bd16-4a46-ae3c-4590e529886d">
        <source>utlUpdateRTResetMediator(pxyMachine : CM_Machine; _passport : CM_Passport input);

vars
	realMach:CM_Machine;
	expectedEdition:Integer;
	
begin
	if pxyMachine = null then
		return;
	endif;
	
	self.initialiseActivity();

	pxyMachine.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pxyMachine.pxyGetRealObjectAndEdition(realMach, expectedEdition);
	
	if realMach = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Machine.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realMach);

	if _passport.noErrors and realMach.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'RT Reset Mediator', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMach, true);
	endif;
	
	if _passport.noErrors then
		realMach.resetMediator();
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMach, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pxyMachine" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRTSWeight" id="72a605cc-6ba9-49a9-b96c-4d96c30edb34">
        <source>utlUpdateRTSWeight(	_weighBridge : CM_WeighBridgeObj;
					_rtsContainer : CM_Container input;
					_totalWeightKgs : Decimal;
					_certifiedBy : String;
					_authPerson : String;
					_passport : CM_Passport input
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2020	jlgndl1	Initial creation

*/

vars

begin

	_weighBridge.doRTSContainerDirectWtUpdate( _rtsContainer, _totalWeightKgs, _certifiedBy, _authPerson, _passport );

epilog

