    <JadeMethod name="initFilterTable" id="3df2e343-4a1d-4bb4-a2d8-4003d49262a4">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------

vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	controller		: CMUI_Controller;
	
begin

	theTable := tblSearch;
	
	controller := app.myController;
	entTableDef := controller.getEntTableDef(ETDef_TAFind);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
		
		// Setup the Road Transfer Area Combo Box
//		theRow := theTable.getRow(ETRow_FilterTAType);
//		theTable.setComboValues(theRow, self.getTATypes);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef TAFind not found');
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="3c02fbe7-0140-49b2-8a0d-748a73e022c8">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initTblInput(self.tblInput1, ETDef_LogRowMaint);
	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.allowPrint 	:= false;
	self.allowExportCSV	:= false;
	self.fldInput.stretchToParent := true;
	self.tblInput1.warningMethod := 'entTableWarning';
	setTblInput1View(false);
	create myViewer as CMUI_ViewLogArea2 transient;
	setVisibility(false);
	self.shtTblInput1.caption := 'Detail';
	self.doComboPositions();
	
	self.fldInput.useSheetBackColors := true;
	self.fldInput.setDefaultSheetBackColors();
	self.fldInput.initSheetBackColors();

end;</source>
