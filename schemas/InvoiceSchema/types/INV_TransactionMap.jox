    <JadeMethod name="doUserNote" id="4b172e86-cb1a-4f01-bf58-8d4f170868be">
        <updating/>
        <source>doUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars

	event : Integer;
	idx : Integer;
	theSB : CM_ServiceBroker;
	aDM : CM_DebtorMap;
	reachedMaxSize : Boolean;
	
begin

	inheritMethod(eventType, theObject, eventTag, userInfo);
	// 23659 ignore notes from activity from load - refresh form at end of load and do it all once then
	//  otherwise the notification processing gets lots of exceptions as it can't build the transients properly
	if self.inLoad then
		return;
	endif;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	// transaction map copy
	if event = EVENT_TRANSACTIONMAP_REFRESH then
		//self.doQuery();
		return;
	endif;

	//04 Oct 2017	NDL	TFS 7055
	if self.lstData.listCount &gt; 30000 and event &lt;&gt; EVENT_TRANSACTIONMAP_DELETE then
		//Allow deletes to process, but don't risk an add or update
		if not refreshWarned then
			//Tell the user if we haven't already.
			self.refreshWarned := true;
			app.msgBox( app.getErrorString(More_than_30000_lines_curre_lo), app.getErrorString(Warning), MsgBox_OK_Only);
		endif;
		return;
	endif;
	
	on Exception do app.handleUE14025(exception, reachedMaxSize);

	if userInfo.isKindOf(CM_TranMap) then
		self.doUserNoteTransactionMap(userInfo.CM_TranMap,event);
	elseif userInfo.isKindOf(CM_TranMapVoyage) then
		self.doUserNoteTransactionMapVoy(userInfo.CM_TranMapVoyage,event);
	elseif userInfo.isKindOf(CM_TranMapEvent) then
		self.doUserNoteTransactionMapEvent(userInfo.CM_TranMapEvent,event);
	elseif userInfo.isKindOf(CM_TranMapWorkOrder) then // TFS 39236
		self.doUserNoteTransactionMapWO(userInfo.CM_TranMapWorkOrder,event); // TFS 39236
	elseif userInfo.isKindOf(CM_TranMapBOL) then	//04 Nov 2019	NDL	TFS 47100
		self.doUserNoteTransactionMapBOL(userInfo.CM_TranMapBOL,event);	//04 Nov 2019	NDL	TFS 47100
	elseif userInfo.isKindOf(CM_TranMapCargoAllocation) then // PAR 35833
		self.doUserNoteTransactionMapCA(userInfo.CM_TranMapCargoAllocation,event); // PAR 35833
	elseif userInfo.isKindOf(CM_TranMapInventoryAllocation) then  // ### TFS 51219 25MAY2021 NAVAB1
		self.doUserNoteTransactionMapInvent(userInfo.CM_TranMapInventoryAllocation,event);  // ### TFS 51219 25MAY2021 NAVAB1
	elseif userInfo.isKindOf(CM_TranMapSSSummary) then
		self.doUserNoteTransactionMapSS(userInfo.CM_TranMapSSSummary,event);
	elseif userInfo.isKindOf(CM_TIServiceMap) then
		self.doUserNoteCargoType(userInfo.CM_TIServiceMap,event);
	elseif userInfo.isKindOf(CM_ContentsMap) then
		self.doUserNoteContents(userInfo.CM_ContentsMap,event);
	elseif userInfo.isKindOf(CM_CommodityMap) then
		self.doUserNoteCommodity(userInfo.CM_CommodityMap,event);
	elseif userInfo.isKindOf(CM_QuantityMap) then
		if userInfo.CM_QuantityMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap)then   //09/02/2017 cnwma1 TFS #2901
				self.doUserNoteQuantityRange(userInfo.CM_QuantityMap.myParentFinancialObject.CM_QuantityRangeMap,EVENT_TRANSACTIONMAP_UPDATE); //09/02/2017 cnwma1 TFS #2901
		else
			self.doUserNoteQuantity(userInfo.CM_QuantityMap,event);
		endif;
	
	elseif userInfo.isKindOf(CM_QuantityRangeMap) then
		self.doUserNoteQuantityRange(userInfo.CM_QuantityRangeMap,event);

	elseif userInfo.isKindOf(CM_ProductGroupMap) then
		self.doUserNoteProductGroup(userInfo.CM_ProductGroupMap,event);
	elseif userInfo.isKindOf(CM_ProductMap) then
		self.doUserNoteProduct(userInfo.CM_ProductMap,event);
	elseif userInfo.isKindOf(CM_DebtorMap) then
		aDM := userInfo.CM_DebtorMap;
		if global.isValidObject(aDM) then
			theSB := aDM.myServiceBroker;
			if aDM.myDebtorNode = null and theSB &lt;&gt; null and theSB.isKindOf(CM_MoveServiceBroker) then // basically the DEFAULT at the debtor level
				self.doUserNoteSBMove(theSB,event);
			else	
				self.doUserNoteDebtor(userInfo.CM_DebtorMap,event);
			endif;
		else	
			self.doUserNoteDebtor(userInfo.CM_DebtorMap,event);
		endif;
	elseif userInfo.isKindOf(CM_InvoiceLineDesc) then
		self.doUserNoteInvoiceLineType(userInfo.CM_InvoiceLineDesc,event);
	
	
	elseif userInfo.isKindOf(CM_ImexServiceMap) then
		self.doUserNoteIMEX(userInfo.CM_ImexServiceMap,event);
	elseif userInfo.isKindOf(CM_ServiceBroker) then
		if userInfo.isKindOf(CM_TransServiceBroker) then
			self.doUserNoteSBTrans(userInfo.CM_ServiceBroker,event);
		elseif userInfo.isKindOf(CM_MoveServiceBroker) then
			self.doUserNoteSBMove(userInfo.CM_ServiceBroker,event);
		elseif userInfo.isKindOf(CM_ResourceServiceBroker) then
			self.doUserNoteSBResource(userInfo.CM_ResourceServiceBroker,event);
		elseif userInfo.isKindOf(CM_EventServiceBroker) then
			self.doUserNoteSBEvent(userInfo.CM_EventServiceBroker,event);
		elseif userInfo.isKindOf(CM_SnapShotServiceBroker) then
			self.doUserNoteSBSumm(userInfo.CM_SnapShotServiceBroker,event);
		elseif userInfo.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
			self.doUserNoteSBWorkOrder(userInfo.CM_WorkOrderServiceBroker,event); // TFS 39236
		elseif userInfo.isKindOf(CM_BOLServiceBroker) then // 01 Nov 2019	NDL	TFS 47100
			self.doUserNoteSBBOL(userInfo.CM_BOLServiceBroker,event); // 01 Nov 2019	NDL	TFS 47100
		elseif userInfo.isKindOf(CM_ToDoResourceServiceBroker) then // 15/05/2023	navkc1	CR 57927 Task 54268
			self.doUserNoteSBToDoRsrc(userInfo.CM_ToDoResourceServiceBroker, event); // 15/05/2023	navkc1	CR 57927 Task 54268
		endif;
	endif;
	
	//04 Oct 2017	NDL	TFS 7055
	if reachedMaxSize then
		if not refreshWarned then
			//Tell the user if we haven't already.
			self.refreshWarned := true;
			app.msgBox( app.getErrorString(More_than_30000_lines_curre_lo), app.getErrorString(Warning), MsgBox_OK_Only);
		endif;
	endif;
	
epilog
	
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteCargoType" id="c4173948-6eab-482e-90ea-7282c7fe1edb">
        <updating/>
        <source>doUserNoteCargoType(_theMap : CM_TIServiceMap; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	trGroup : CMIF_TMCTIGroup;
	tmcGroup : CMIF_TMCGroup;
	idx: Integer;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(_theMap.transactionMap,CMIF_TranMapController.TM_Level_03_TranMap, idx);

		if idx &gt; 0 then
			create trGroup;
			trGroup.myTIServiceMap := _theMap;
			trGroup.itemName := _theMap.getTIClassName;
			trGroup.extractName := _theMap.getItemCode();	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;

		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
	elseif _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_04_CargoType, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_TIServiceMap"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteCommodity" id="4c004584-5b9d-48e5-97c5-3b00fb0d8a30">
        <updating/>
        <source>doUserNoteCommodity(_theMap : CM_CommodityMap; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	trGroup : CMIF_TMCCommodityGroup;
	tmcGroup : CMIF_TMCGroup;

	tmcMove : CMIF_TMCMoveGroup;
	idx		: Integer;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_MOVEPURGE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_09_Commodity, idx);
		tmcMove := tmcGroup.CMIF_TMCCommodityGroup.getMoveGroup(); // get the 'Move'
		idx := 0;
		tmcGroup := self.getIndexInList(tmcMove,CMIF_TranMapController.TM_Level_10_TranServiceBroker, idx); // get the 'Move' index
	
		self.lstData.removeItem(idx);
		delete tmcMove;
	elseif _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(_theMap.contentsMap,CMIF_TranMapController.TM_Level_08_Contents, idx);

		if idx &gt; 0 then
			create trGroup;
			trGroup.myCommodityMap := _theMap;
			trGroup.itemName := _theMap.commodityCode;
			trGroup.extractName := _theMap.getCommodityCode();	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
	elseif _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_09_Commodity, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_CommodityMap"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteContents" id="187cd782-2fed-40d9-ab14-dce803d05f1c">
