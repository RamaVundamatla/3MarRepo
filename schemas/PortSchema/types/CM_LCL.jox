    <JadeMethod name="getPicture" id="607d3fb6-5ac0-499d-ac53-abfd160cc6a7">
        <source>getPicture(): Binary;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePicture : Binary;
begin
	
	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		return null;
	endif;

	thePicture := app.myRoot.getConfig(PicCargoMDF).Binary; 

	return thePicture;

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="validateCubicMetres" id="dfa79410-b99d-4b45-a0e0-23d5d6fb092c">
        <source>validateCubicMetres(pControl: CMIF_TIUpdateController) protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------

// 14 Jul 2011	NDL		Par 27485 - Should be checking volume NOT totalVolume.
//
// ---------------------------------------------------------------------------
vars
	totVolume : Decimal[16,4];
begin
	
	inheritMethod(pControl);
	
	totVolume := self.getMyTotalVolume();		//31.10.2023 navma1 #60920
	
	if totVolume &gt; 150 then																							
		app.raiseCMWarning2(WARN_LARGE_NUMBER, totVolume.String, 'volume', 'volume', pControl.myUserObject, self);	// cnwjk3 PAR 22427 22/02/10
	endif;
	if totVolume &lt; 1 then																							// cnwjk3 PAR 22427 22/02/10
		app.raiseCMWarning2(WARN_SMALL_NUMBER, totVolume.String, 'volume', 'volume', pControl.myUserObject, self);	// cnwjk3 PAR 22427 22/02/10
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
