    <JadeMethod name="getBayOrdinalForOOW" id="5e30ff9c-ec48-4269-b95d-9a854b0b9dfd">
        <source>getBayOrdinalForOOW(_reverse : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:		15 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	first,second,third : Integer;
begin
	if _reverse then // reverse
		if self.bayType = BAY_TYPE_TRIPLE then
			first := 3;
			second := 2;
			third := 1;
		else
			first := 2;
			second := 1;
			third := 3;
		endif;
	else
		first := 1;
		second := 2;
		third := 3;
	endif;

	if self.isFirstInHold() then
		return first;
	elseif self.bayType = BAY_TYPE_TWIN then
		return second;
	elseif self.bayType = BAY_TYPE_TRIPLE then
		if self.isLastInHold() then
			return third;
		else
			return second;
		endif;
	endif;
end;</source>
        <Parameter name="_reverse" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefinedLenOfCellTierId" id="975c53b8-7e36-4b85-8e27-2114b7078339">
        <source>getDefinedLenOfCellTierId() : Integer protected;
/*
 ------------------------------------------------------------------------
Created:			07 November 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	cellLen : Integer;
	tierLen : Integer;
begin
//	cellLen := CM_SlotDefn.cnEcGetStringPropertyLength('cellId');
	cellLen := 2;
//	tierLen := CM_SlotDefn.cnEcGetStringPropertyLength('tierId');
	tierLen := 2;
	return (tierLen + cellLen);

	// The lengths are hardcoded above
	write CM_SlotDefn::cellId.name;
	write CM_SlotDefn::tierId.name;

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefinitionXML" id="0fef8921-55ec-494a-954c-0aa3acae3549">
        <source>getDefinitionXML() : String;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		EXPORT DEFINITION. This is nothing to do with Grids and showing a vessel on the screen
//				It is the definition export .
//				SEE setProxyBayFromXML for the import
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	aLid : CM_HatchLid;
	theXml : String;
	ls : Boolean;
	tml, sml, cml, hold,
	hml : String;
begin
	
	if self.myHold &lt;&gt; null then
		hold := self.myHold.ordinalHold.String;
	endif;

	theXml := "&lt;BAY&gt;&lt;bo&gt;" &amp; self.ordinalBay.String &amp; "&lt;/bo&gt;&lt;id&gt;" &amp; self.id &amp; "&lt;/id&gt;&lt;id4&gt;" &amp; self.idBay40 &amp; "&lt;/id4&gt;&lt;fb&gt;" &amp; self.fortyFootBay.Integer.String &amp; "&lt;/fb&gt;&lt;fo&gt;" &amp; self.fortyFootOnly.Integer.String &amp; "&lt;/fo&gt;&lt;f5b&gt;" &amp; self.fortyFiveFootBay.Integer.String &amp; "&lt;/f5b&gt;&lt;f5o&gt;" &amp; self.fortyFiveFootOnly.Integer.String &amp; "&lt;/f5o&gt;" &amp; 
		"&lt;so&gt;" &amp; self.useCellTierODSequencing.Integer.String &amp; "&lt;/so&gt;&lt;su&gt;" &amp; self.useCellTierUDSequencing.Integer.String &amp; "&lt;/su&gt;&lt;oc&gt;" &amp; self.getAllCellsOnDeck &amp; "&lt;/oc&gt;" &amp; 
		"&lt;uc&gt;" &amp; self.getAllCellsUnderDeck &amp; "&lt;/uc&gt;&lt;ot&gt;" &amp; self.getAllTiersOnDeck &amp; "&lt;/ot&gt;&lt;ut&gt;" &amp; self.getAllTiersUnderDeck &amp; "&lt;/ut&gt;&lt;hi&gt;" &amp; self.getAllCellsHiCubeHeightsString &amp; "&lt;/hi&gt;" &amp; 
		"&lt;as&gt;" &amp; self.athwartships.Integer.String &amp; "&lt;/as&gt;&lt;lf&gt;" &amp; self.lashFromTier &amp; "&lt;/lf&gt;&lt;uf&gt;" &amp; self.unlashFromTier.Integer.String &amp; "&lt;/uf&gt;" &amp; 
		"&lt;tlod&gt;" &amp; self.isTwinLiftOD.Integer.String &amp; "&lt;/tlod&gt;&lt;tlud&gt;" &amp; self.isTwinLiftUD.Integer.String &amp; "&lt;/tlud&gt;" &amp; 
		"&lt;2mi&gt;" &amp; self.maxPileWeight20IB.String &amp; "&lt;/2mi&gt;&lt;2mo&gt;" &amp; self.maxPileWeight20OB.String &amp; "&lt;/2mo&gt;&lt;4mi&gt;" &amp; self.maxPileWeight40IB.String &amp; "&lt;/4mi&gt;" &amp; 
		"&lt;4mo&gt;" &amp; self.maxPileWeight40OB.String &amp; "&lt;/4mo&gt;&lt;mu&gt;" &amp; self.maxPileWeightUD.String &amp; "&lt;/mu&gt;&lt;np&gt;" &amp; self.numOfPlugs.String &amp; "&lt;/np&gt;" &amp; 
		"&lt;bt&gt;" &amp; self.bayType.String &amp; "&lt;/bt&gt;&lt;br&gt;" &amp; self.remarks &amp; "&lt;/br&gt;&lt;bh&gt;" &amp; hold &amp; "&lt;/bh&gt;";

	// do not need this stuff as we are not going to use it for updating. We will only be creating vessels from XML.
	// the cells and tiers are created from the space seperated strings
	cml := "&lt;OCELLS&gt;";
	foreach aCell in self.allCellsOnDeckByOrdinal do
		cml := cml &amp; "&lt;id&gt;" &amp; aCell.id.trimBlanks &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; aCell.ordinal.String.padLeadingZeros(2) &amp; "&lt;/ord&gt;&lt;al&gt;" &amp;  aCell.alignment.String &amp; "&lt;/al&gt;&lt;hi&gt;&lt;/hi&gt;"; 
	endforeach;
	cml := cml &amp; "&lt;/OCELLS&gt;";

	tml := "&lt;OTIERS&gt;";
	foreach aTier in self.allTiersOnDeck do
		tml := tml &amp; "&lt;id&gt;" &amp; aTier.id.trimBlanks &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; aTier.ordinal.String.padLeadingZeros(2) &amp; "&lt;/ord&gt;"; 
	endforeach;
	tml := tml &amp; "&lt;/OTIERS&gt;";

	theXml := theXml &amp; cml &amp; tml;
	
	cml :=  "&lt;UCELLS&gt;";
	foreach aCell in self.allCellsUnderDeckByOrdinal do
		cml := cml &amp; "&lt;id&gt;" &amp; aCell.id.trimBlanks &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; aCell.ordinal.String.padLeadingZeros(2) &amp; "&lt;/ord&gt;&lt;al&gt;" &amp;  aCell.alignment.String &amp; 
					"&lt;/al&gt;&lt;hi&gt;" &amp; aCell.maxNumHighCubesIfFull.String &amp; "&lt;/hi&gt;"; 
	endforeach;
	cml := cml &amp; "&lt;/UCELLS&gt;";

	tml := "&lt;UTIERS&gt;";
	foreach aTier in self.allTiersUnderDeck do
		tml := tml &amp; "&lt;id&gt;" &amp; aTier.id.trimBlanks &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; aTier.ordinal.String.padLeadingZeros(2) &amp; "&lt;/ord&gt;"; 
	endforeach;
	tml := tml &amp; "&lt;/UTIERS&gt;";

	theXml := theXml &amp; cml &amp; tml;


	sml := "&lt;OSLOTS&gt;";	
	foreach aSlot in self.allSlotsOnDeck do
		sml := sml &amp; aSlot.getDefinitionXML();
	endforeach;
	sml := sml &amp; "&lt;/OSLOTS&gt;";
	theXml := theXml &amp; sml;
	sml := "&lt;USLOTS&gt;";	
	foreach aSlot in self.allSlotsUnderDeck do
		sml := sml &amp; aSlot.getDefinitionXML();
	endforeach;
	sml := sml &amp; "&lt;/USLOTS&gt;";
	theXml := theXml &amp; sml;
		
	theXml := theXml  &amp;  "&lt;/BAY&gt;";

	return theXml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="2a529224-487e-4334-8084-59b1d9ff62bd">
        <source>getExtraInfo(_dataCont: CM_DataContainer) ;
// ---------------------------------------------------------------------------
// Created:		July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	block : CM_DataContainerBlock;

begin

	if self.remarks &lt;&gt; null then
		block := _dataCont.addNewBlock;
		block.addNewItem("Remarks", DC_Warning, 4, null);
		block.addNewItem(self.remarks, DC_Data, 4, null);
	endif;

	inheritMethod(_dataCont);


end;</source>
        <Parameter name="_dataCont" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForSlotDefn" id="22d357b7-db23-41b7-a3b0-ff9c2daee7fd">
        <source>getExtraInfoForSlotDefn(_slotDefn : CM_SlotDefn; _dataCont: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	block 	: CM_DataContainerBlock;
	bBlock 	: CM_DataContainerBlock;
	aString	: String;

begin

	block := _dataCont.addNewBlock;
	block.addNewItem("Position" , DC_Label, 1, null);

	aString := "[" &amp; self.myHold.ordinalHold.String.padLeadingZeros(2) &amp; "]";
	aString := aString &amp; " (" &amp;  self.id &amp; ")";
	if self.idBay40 &lt;&gt; null then
		aString := aString &amp; " {" &amp;  self.idBay40 &amp; "}";
	endif;
	if _slotDefn.isOnDeck then
		if self.useCellTierNumbering then
			aString := aString &amp; " " &amp; self.allCellsOnDeckByOrdinal[_slotDefn.ordinalCell].id;
			aString := aString &amp; " " &amp; self.allTiersOnDeck[_slotDefn.ordinalTier].id;
		else
			aString := aString &amp; " " &amp; self.allTiersOnDeck[_slotDefn.ordinalTier].id;
			aString := aString &amp; " " &amp; self.allCellsOnDeckByOrdinal[_slotDefn.ordinalCell].id;
		endif;
	else
	 	if self.useCellTierNumbering then
			aString := aString &amp; " " &amp; self.allCellsUnderDeckByOrdinal[_slotDefn.ordinalCell].id;
			aString := aString &amp; " " &amp; self.allTiersUnderDeck[_slotDefn.ordinalTier].id;
		else
			aString := aString &amp; " " &amp; self.allTiersUnderDeck[_slotDefn.ordinalTier].id;
			aString := aString &amp; " " &amp; self.allCellsUnderDeckByOrdinal[_slotDefn.ordinalCell].id;
		endif;
		bBlock := _dataCont.addNewBlock;
		bBlock.addNewItem("Cell Height" , DC_Label, 1, null);
		bBlock.addNewItem(_slotDefn.myCellDefinition.getHeightStatsString(), DC_Data, 1, null);
	endif;

	block.addNewItem(aString, DC_Data, 1, null);

end;</source>
        <Parameter name="_slotDefn" type="CM_SlotDefn"/>
        <Parameter name="_dataCont" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstLastTier" id="12f542a5-1502-4b7e-b17b-5c3d35aa8bd9">
        <source>getFirstLastTier(_ondeck : Boolean; _first : Boolean; _avail : Boolean) : CM_TierDefn;
// ---------------------------------------------------------------------------
// Created:     MARCH 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTier : CM_TierDefn;
	idx : Integer;
begin

	// NOTE the ordinal on the tier is from the bottom of the bay  upwards
	if _ondeck then
		if _first then
			foreach tmpTier in self.allTiersOnDeck discreteLock do
				if _avail then
					if tmpTier.isTotallyUnavailable() then
						continue;
					else
						return tmpTier;
					endif;
				else // just want the first tier
					return tmpTier;
				endif;
			endforeach;
		else
			foreach tmpTier in self.allTiersOnDeck reversed, discreteLock do
				if _avail then
					if tmpTier.isTotallyUnavailable() then
						continue;
					else
						return tmpTier;
					endif;
				else // just want the last tier
					return tmpTier;
				endif;
			endforeach;
		
		endif;
	else
		if _first then
			foreach tmpTier in self.allTiersUnderDeck discreteLock do
				if _avail then
					if tmpTier.isTotallyUnavailable() then
						continue;
					else
						return tmpTier;
					endif;
				else // just want the first tier
					return tmpTier;
				endif;
			endforeach;
		else
			foreach tmpTier in self.allTiersUnderDeck reversed, discreteLock do
				if _avail then
					if tmpTier.isTotallyUnavailable() then
						continue;
					else
						return tmpTier;
					endif;
				else // just want the last tier
					return tmpTier;
				endif;
			endforeach;
		
		endif;
	
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_ondeck" type="Boolean"/>
        <Parameter name="_first" type="Boolean"/>
        <Parameter name="_avail" type="Boolean"/>
        <ReturnType type="CM_TierDefn"/>
    </JadeMethod>
    <JadeMethod name="getFirstLastTierSlot" id="81129808-674d-42fd-b05b-f1f6875a7854">
        <source>getFirstLastTierSlot(_ondeck : Boolean; _firstTier : Boolean; _availTier : Boolean; _firstSlot : Boolean; _availSlot : Boolean) : CM_SlotDefn;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tier : CM_TierDefn;
	slot : CM_SlotDefn;
begin

	tier := self.getFirstLastTier(_ondeck, _firstTier, _availTier);
	
	if tier = null then
		return null;
	endif;
	
	slot := tier.getFirstLastSlotDefn(_firstSlot, _availSlot);

	return slot;
	
epilog

end;</source>
        <Parameter name="_ondeck" type="Boolean"/>
        <Parameter name="_firstTier" type="Boolean"/>
        <Parameter name="_availTier" type="Boolean"/>
        <Parameter name="_firstSlot" type="Boolean"/>
        <Parameter name="_availSlot" type="Boolean"/>
        <ReturnType type="CM_SlotDefn"/>
    </JadeMethod>
    <JadeMethod name="getFortyFootBayID" id="f2d141a2-dac6-4b0a-b0a2-83e3d88264a2">
        <source>getFortyFootBayID() : String;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theString : String;
begin
	theString := self.idBay40.trimBlanks;
	if theString = null then
		if self.isAftBay then
			if self.myForwardBay = null then
				theString := self.id.trimBlanks;
			else
				theString := self.myForwardBay.idBay40.trimBlanks;
				if theString = null then
					if self.bayType = BAY_TYPE_TRIPLE and self.myForwardBay.myForwardBay &lt;&gt; null then
						theString := self.myForwardBay.myForwardBay.idBay40.trimBlanks;
						if theString = null then
							theString := self.id.trimBlanks;
						endif;
					else
						theString := self.id.trimBlanks;
					endif;
				endif;
			endif;
		else
			theString := self.id.trimBlanks;
		endif;
	endif;
	
	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridDefXMLBayOnly" id="47d5d3d5-6227-419c-9d14-3b83bf3f05c3">
        <source>getGridDefXMLBayOnly(_theRow, _theCol : Integer; _backColour : Integer) : String ;//serverExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		Returns the base information for each grid area for under/over deck
 
// 03 Mar 2008	conks1a		PAR #16047 - remove unnecessary serverExecution for performance
// 
// ---------------------------------------------------------------------------


vars
	colStr		: String;
	underRow,
	slotOD, 
	slotUD	 : Integer;
	tmpStr, 
	oidStr 	: String;

begin

	oidStr := getOidStringForObject(self);

	tmpStr :=  "&lt;lb&gt;" &amp; self.id.trimBlanks &amp; "&lt;/lb&gt;&lt;id40&gt;" &amp; 
				self.getFortyFootBayID() &amp; "&lt;/id40&gt;&lt;oh&gt;" &amp; 
				self.myHold.ordinalHold.String &amp; "&lt;/oh&gt;&lt;SOD&gt;" &amp; 
				slotOD.String &amp; "&lt;/SOD&gt;&lt;SUD&gt;" &amp; 
				slotUD.String &amp; "&lt;/SUD&gt;&lt;cc&gt;" &amp;  
				_backColour.String &amp; "&lt;/cc&gt;";

	colStr := _theCol.String.padLeadingZeros(2);
	
	underRow := _theRow + 1;

	return "&lt;OGA&gt;&lt;BY&gt;" &amp; oidStr &amp; "&lt;/BY&gt;&lt;GO&gt;" &amp; 
			_theRow.String.padLeadingZeros(2) &amp; colStr &amp; "&lt;/GO&gt;" &amp; 
			tmpStr &amp; "&lt;/OGA&gt;" &amp;
			 "&lt;UGA&gt;&lt;BY&gt;" &amp; oidStr &amp; "&lt;/BY&gt;&lt;GO&gt;" &amp; 
			 underRow.String.padLeadingZeros(2) &amp; colStr &amp; "&lt;/GO&gt;" &amp; 
			 tmpStr &amp; "&lt;/UGA&gt;";

	
end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theCol" type="Integer"/>
        <Parameter name="_backColour" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridDefXMLDetails" id="95d99dd7-a17b-41c0-8108-1f9f762426c5">
        <executionLocation>server</executionLocation>
        <source>getGridDefXMLDetails() : Binary serverExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By cnwrs2
//
// Purpose:		Summary definition of the bay
// ---------------------------------------------------------------------------
vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	roundedPW,roundedTPW : Decimal[3,0];
	
	aLid : CM_HatchLid;
	aHold : CM_Hold;
	ls : Boolean;
	xml, sml : String;
	yml : String;
	zml : String;
	slotOD, slotUD,theTierOrdinal  : Integer;
	s1, s3, s4, s5, s6, s7, s8, s9, s10, s11, s12,s13 : String;

begin

	beginLoad;
	
	// ######################
	// ON DECK
	s1 := getOidStringForObject(self);
	s3 := self.id.trimBlanks;
	s8 := self.getFortyFootBayID();
	s9 := self.myHold.ordinalHold.String;
	self.getNumberOfSlotsAvailable(slotOD, slotUD);
	s10 := slotOD.String;
	s11 := slotUD.String;

	if self.allSlotsOnDeck.size &gt; 0 then	

		yml := yml &amp; "&lt;OGA&gt;&lt;BY&gt;" &amp; s1 &amp; "&lt;/BY&gt;" &amp; 
					 "&lt;lb&gt;" &amp; self.id.trimBlanks &amp; "&lt;/lb&gt;&lt;id40&gt;" &amp; s8 &amp; 
					 "&lt;/id40&gt;&lt;oh&gt;" &amp; s9 &amp; "&lt;/oh&gt;&lt;SOD&gt;" &amp; s10 &amp; 
					 "&lt;/SOD&gt;&lt;SUD&gt;" &amp; s11 &amp; "&lt;/SUD&gt;&lt;cl&gt;";

		foreach aCell in self.allCellsOnDeckByOrdinal  do
			s4 := aCell.id.trimBlanks;
			s5 := aCell.ordinal.String.padLeadingZeros(2);
			s6 := aCell.alignment.String;
			s7 := getOidStringForObject(aCell);
			s12 := "";
			s13 := "";
			if self.isKindOf(CM_BayVoyage) then
				roundedPW := (self.CM_BayVoyage.getCellPileWeight(DeckOnDeck,aCell.ordinal,ShpDisplayMode_Actual) / 1000); // PAR 8667 added
				s12 := roundedPW.String;
				s13 := self.maxPileWeight20OB.String;
			endif;
			
			yml := yml &amp; "&lt;id&gt;" &amp; s4 &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; s5 &amp; "&lt;/ord&gt;&lt;al&gt;" &amp;  s6 &amp; "&lt;/al&gt;&lt;CO&gt;" &amp; s7 &amp; "&lt;/CO&gt;&lt;pw&gt;" &amp; s12 &amp; "&lt;/pw&gt;&lt;pwm&gt;" &amp; s13 &amp; "&lt;/pwm&gt;";
		endforeach;

		yml := yml &amp; "&lt;/cl&gt;&lt;tr&gt;";

		// ##############
		theTierOrdinal := 0;
		foreach aTier in self.allTiersOnDeck reversed do
			theTierOrdinal := theTierOrdinal + 1;
			s5 := theTierOrdinal.String.padLeadingZeros(2);
			s4 := aTier.id.trimBlanks;
			s12 := "";
			if self.isKindOf(CM_BayVoyage) then
				roundedTPW := (self.CM_BayVoyage.getTierPileWeight(DeckOnDeck,aTier.ordinal) / 1000);
				s12 := roundedTPW.String;
			endif;
			
			yml := yml &amp; "&lt;id&gt;" &amp; s4 &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; s5 &amp; "&lt;/ord&gt;&lt;pw&gt;" &amp; s12 &amp; "&lt;/pw&gt;";
		endforeach;

		yml := yml &amp; "&lt;/tr&gt;&lt;ld&gt;";

		foreach aLid in self.allHatchLids do
			yml := yml &amp; aLid.getGridDefinitionXML();
		endforeach;

		yml := yml &amp; "&lt;/ld&gt;&lt;sl&gt;";
		foreach aSlot in self.allSlotsOnDeck do
			yml := yml &amp; "&lt;GP&gt;" &amp; aSlot.getGridXMLdefn(CM_CellularVoyageStructure.GRID_VIEW_BAY ) &amp; "&lt;/GP&gt;";
		endforeach;
		yml := yml &amp; "&lt;/sl&gt;&lt;/OGA&gt;";
	else
		yml := yml &amp; "&lt;OGA&gt;&lt;BY&gt;" &amp; s1 &amp; "&lt;/BY&gt;&lt;lb&gt;" &amp; s3 &amp; "&lt;/lb&gt;&lt;id40&gt;" &amp; s8 &amp; "&lt;/id40&gt;&lt;oh&gt;" &amp; 
					s9 &amp; "&lt;/oh&gt;&lt;SOD&gt;" &amp; s10 &amp; "&lt;/SOD&gt;&lt;SUD&gt;" &amp; s11 &amp; "&lt;/SUD&gt;&lt;/OGA&gt;";
	endif;
		
	if self.allSlotsUnderDeck.size &gt; 0 then	
		
		// ######################
		// UNDER DECK
		zml := zml &amp; "&lt;UGA&gt;&lt;BY&gt;" &amp; getOidStringForObject(self) &amp; "&lt;/BY&gt;" &amp; 
					 "&lt;lb&gt;" &amp; self.id.trimBlanks &amp; "&lt;/lb&gt;&lt;id40&gt;" &amp; s8 &amp; "&lt;/id40&gt;&lt;oh&gt;" &amp; s9 &amp; "&lt;/oh&gt;&lt;SOD&gt;" &amp; s10 &amp; "&lt;/SOD&gt;&lt;SUD&gt;" &amp; 
					 s11 &amp; "&lt;/SUD&gt;&lt;cl&gt;";

		foreach aCell in self.allCellsUnderDeckByOrdinal  do
			s4 := aCell.id.trimBlanks;
			s5 := aCell.ordinal.String.padLeadingZeros(2);
			s6 := aCell.alignment.String;
			s7 := getOidStringForObject(aCell);
			s12 := "";
			s13 := "";
			
			if self.isKindOf(CM_BayVoyage) then
				roundedPW := (self.CM_BayVoyage.getCellPileWeight(DeckUnderDeck,aCell.ordinal,ShpDisplayMode_Actual) / 1000); // PAR 8667 added
				s12 := roundedPW.String;
				s13 := self.maxPileWeightUD.String;
			endif;
			
			zml := zml &amp; "&lt;id&gt;" &amp; s4 &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; s5 &amp; "&lt;/ord&gt;&lt;al&gt;" &amp;  s6 &amp; "&lt;/al&gt;&lt;CO&gt;" &amp; s7 &amp; "&lt;/CO&gt;&lt;pw&gt;" &amp; s12 &amp; "&lt;/pw&gt;&lt;pwm&gt;" &amp; s13 &amp; "&lt;/pwm&gt;";
		endforeach;

		zml := zml &amp; "&lt;/cl&gt;&lt;tr&gt;";
		// ##############
		theTierOrdinal := 0;

		foreach aTier in self.allTiersUnderDeck reversed do
			theTierOrdinal := theTierOrdinal + 1;
			s5 := theTierOrdinal.String.padLeadingZeros(2);
			s4 := aTier.id.trimBlanks;
			s12 := "";
			if self.isKindOf(CM_BayVoyage) then
				roundedTPW := (self.CM_BayVoyage.getTierPileWeight(DeckUnderDeck,aTier.ordinal) / 1000);
				s12 := roundedTPW.String;
			endif;
			s6 := getOidStringForObject(aTier);
			
			zml := zml &amp; "&lt;id&gt;" &amp; s4 &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; s5 &amp; "&lt;/ord&gt;&lt;TO&gt;" &amp; s6 &amp; "&lt;/TO&gt;&lt;pw&gt;" &amp; s12 &amp; "&lt;/pw&gt;";
		endforeach;

		zml := zml &amp; "&lt;/tr&gt;&lt;sl&gt;";

		foreach aSlot in self.allSlotsUnderDeck do
			zml := zml &amp; "&lt;GP&gt;" &amp; aSlot.getGridXMLdefn(CM_CellularVoyageStructure.GRID_VIEW_BAY) &amp; "&lt;/GP&gt;";
		endforeach;
		zml := zml &amp; "&lt;/sl&gt;&lt;/UGA&gt;";
	else

		zml := zml &amp; "&lt;UGA&gt;&lt;BY&gt;" &amp; s1 &amp; "&lt;/BY&gt;&lt;lb&gt;" &amp; s3 &amp; "&lt;/lb&gt;&lt;id40&gt;" &amp; s8 &amp; "&lt;/id40&gt;&lt;oh&gt;" &amp; 
				s9 &amp; "&lt;/oh&gt;&lt;SOD&gt;" &amp; s10 &amp; "&lt;/SOD&gt;&lt;SUD&gt;" &amp; s11 &amp; "&lt;/SUD&gt;&lt;/UGA&gt;";
	endif;
	
	endLoad;
	
// cnwdad1 24/02/2009 - PAR #18366.
//	return (yml &amp; zml).compress;
	return (yml &amp; zml).compressToBinary(Binary.Compression_ZLib);

epilog
	endLoad;

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getGridDefinitionArray" id="ad5e42b9-ed86-45c2-a8c0-c5f825b8e609">
        <source>getGridDefinitionArray(_theRow, _theCol : Integer; _backColour : Integer; _dataArray : BinaryArray200 input);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		VOYAGE DEFINITION
// ---------------------------------------------------------------------------
vars
	aCell				: CM_CellDefn;
	aTier				: CM_TierDefn;
	aSlot				: CM_SlotDefn;
	roundedPW			: Decimal[3,0];
	roundedTPW			: Decimal[3,0];
	aLid				: CM_HatchLid;
	tmpMaxPileWeight	: Integer;
	theRow				: Integer;
	slotOD				: Integer;
	slotUD				: Integer;
	theTierOrdinal  	: Integer;
	
begin
	// ######################
	// ON DECK
	theRow := _theRow;
	
	self.getNumberOfSlotsAvailable(slotOD, slotUD);
	
	_dataArray.addString(	GridData_BayAboveDeck &amp;
							GridData_Delimiter &amp; self.getOidStringForObject(self) &amp;
							GridData_Delimiter &amp; theRow.String &amp;
							GridData_Delimiter &amp; _theCol.String &amp;
							GridData_Delimiter &amp; self.id.trimBlanks() &amp;
							GridData_Delimiter &amp; self.getFortyFootBayID() &amp;
							GridData_Delimiter &amp; self.myHold.ordinalHold.String &amp;
							GridData_Delimiter &amp; slotOD.String &amp;
							GridData_Delimiter &amp; slotUD.String &amp;
							GridData_Delimiter &amp; _backColour.String);
/*
	if self.allSlotsOnDeck.size &gt; 0 then
		backColour above was not being sent to the client??
*/
	if self.allSlotsOnDeck.size &gt; 0 then
		foreach aCell in self.allCellsOnDeckByOrdinal  do
			if self.isKindOf(CM_BayVoyage) then
				roundedPW 		 := (self.CM_BayVoyage.getCellPileWeight(DeckOnDeck, aCell.ordinal, ShpDisplayMode_Actual) / 1000); // PAR 8667 added
				tmpMaxPileWeight := self.maxPileWeight20OB;
			else
				roundedPW 		 := 0;
				tmpMaxPileWeight := 0;
			endif;
			
			_dataArray.addString(	GridData_Column &amp;
									GridData_Delimiter &amp; aCell.id.trimBlanks() &amp;
									GridData_Delimiter &amp; aCell.ordinal.String.padLeadingZeros(2) &amp;
									GridData_Delimiter &amp; aCell.alignment.String &amp;
									GridData_Delimiter &amp; self.getOidStringForObject(aCell) &amp;
									GridData_Delimiter &amp; roundedPW.String &amp;
									GridData_Delimiter &amp; tmpMaxPileWeight.String);
		endforeach;
		
		theTierOrdinal := 0;
		
		foreach aTier in self.allTiersOnDeck reversed do
			theTierOrdinal := theTierOrdinal + 1;
			
			if self.isKindOf(CM_BayVoyage) then
				roundedTPW := (self.CM_BayVoyage.getTierPileWeight(DeckOnDeck, aTier.ordinal) / 1000);
			else
				roundedTPW := 0;
			endif;
			
			_dataArray.addString(	GridData_Row &amp;
									GridData_Delimiter &amp; aTier.id.trimBlanks() &amp;
									GridData_Delimiter &amp; theTierOrdinal.String.padLeadingZeros(2) &amp;
									GridData_Delimiter &amp; roundedTPW.String.padLeadingZeros(2) &amp;
									GridData_Delimiter);
		endforeach;
		
		foreach aLid in self.allHatchLids do
			aLid.getGridDefinitionArray(_dataArray);
		endforeach;
		
		foreach aSlot in self.allSlotsOnDeck do
			aSlot.getGridDefinitionArray(_dataArray, CM_CellularVoyageStructure.GRID_VIEW_BAY);
		endforeach;
	endif;
	
	// ######################
	// UNDER DECK
	
	theRow := theRow + 1;
	
	_dataArray.addString(	GridData_BayBelowDeck &amp;
							GridData_Delimiter &amp; self.getOidStringForObject(self) &amp;
							GridData_Delimiter &amp; theRow.String &amp;
							GridData_Delimiter &amp; _theCol.String &amp;
							GridData_Delimiter &amp; self.id.trimBlanks() &amp;
							GridData_Delimiter &amp; self.getFortyFootBayID() &amp;
							GridData_Delimiter &amp; self.myHold.ordinalHold.String &amp;
							GridData_Delimiter &amp; slotOD.String &amp;
							GridData_Delimiter &amp; slotUD.String &amp;
							GridData_Delimiter &amp; _backColour.String);
	
	if self.allSlotsUnderDeck.size() &gt; 0 then	
		
		foreach aCell in self.allCellsUnderDeckByOrdinal  do
			if self.isKindOf(CM_BayVoyage) then
				roundedPW := (self.CM_BayVoyage.getCellPileWeight(DeckUnderDeck, aCell.ordinal, ShpDisplayMode_Actual) / 1000); // PAR 8667 added
				tmpMaxPileWeight := self.maxPileWeightUD;
			else
				roundedPW 		 := 0;
				tmpMaxPileWeight := 0;
			endif;
			
			_dataArray.addString(	GridData_Column &amp;
									GridData_Delimiter &amp; aCell.id.trimBlanks() &amp;
									GridData_Delimiter &amp; aCell.ordinal.String.padLeadingZeros(2) &amp;
									GridData_Delimiter &amp; aCell.alignment.String &amp;
									GridData_Delimiter &amp; self.getOidStringForObject(aCell) &amp;
									GridData_Delimiter &amp; roundedPW.String &amp;
									GridData_Delimiter &amp; tmpMaxPileWeight.String);
		endforeach;
		
		// ##############
		theTierOrdinal := 0;
		
		foreach aTier in self.allTiersUnderDeck reversed do
			theTierOrdinal := theTierOrdinal + 1;
			
			if self.isKindOf(CM_BayVoyage) then
				roundedTPW := (self.CM_BayVoyage.getTierPileWeight(DeckUnderDeck, aTier.ordinal) / 1000);
			else
				roundedTPW := 0;
			endif;
			
			_dataArray.addString(	GridData_Row &amp;
									GridData_Delimiter &amp; aTier.id.trimBlanks() &amp;
									GridData_Delimiter &amp; theTierOrdinal.String.padLeadingZeros(2) &amp;
									GridData_Delimiter &amp; roundedTPW.String &amp;
									GridData_Delimiter);
		endforeach;

		foreach aSlot in self.allSlotsUnderDeck do
			aSlot.getGridDefinitionArray(_dataArray, CM_CellularVoyageStructure.GRID_VIEW_BAY);
		endforeach;
	endif;
end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theCol" type="Integer"/>
        <Parameter name="_backColour" type="Integer"/>
        <Parameter name="_dataArray" type="BinaryArray200" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGridDefinitionXML" id="80bbe50c-cf47-4a09-a096-021614b1f948">
        <source>getGridDefinitionXML(_theRow, _theCol : Integer;_backColour : Integer) : String;// serverExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		Full definition for the Bay
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	roundedPW,roundedTPW : Decimal[3,0];
	
	aLid : CM_HatchLid;
	aHold : CM_Hold;
	ls : Boolean;
	xml, sml : String;
	yml : String;
	zml,lml : String;
	colEnd,theRow,rowStart,rowEnd, slotOD, slotUD,theTierOrdinal  : Integer;
	s1, s2, s3, s4, s5, s6, s7, s8, s9, s10, s11, s12,s13 : String;

begin
	// ######################
	// ON DECK
	theRow := _theRow;
	s1 := getOidStringForObject(self);
	s2 := theRow.String.padLeadingZeros(2) &amp; _theCol.String.padLeadingZeros(2);
	s3 := self.id.trimBlanks;
	s8 := self.getFortyFootBayID();
	s9 := self.myHold.ordinalHold.String;
	self.getNumberOfSlotsAvailable(slotOD,slotUD);
	s10 := slotOD.String;
	s11 := slotUD.String;

	if self.allSlotsOnDeck.size &gt; 0 then	

		yml := yml &amp; "&lt;OGA&gt;&lt;BY&gt;" &amp; s1 &amp; "&lt;/BY&gt;&lt;GO&gt;" &amp; s2 &amp; "&lt;/GO&gt;" &amp; 
					 "&lt;lb&gt;" &amp; self.id.trimBlanks &amp; "&lt;/lb&gt;&lt;id40&gt;" &amp; s8 &amp; 
					 "&lt;/id40&gt;&lt;oh&gt;" &amp; s9 &amp; "&lt;/oh&gt;&lt;SOD&gt;" &amp; s10 &amp; 
					 "&lt;/SOD&gt;&lt;SUD&gt;" &amp; s11 &amp; "&lt;/SUD&gt;&lt;cc&gt;" &amp;  
					 
					 _backColour.String &amp; "&lt;/cc&gt;&lt;cl&gt;";

		foreach aCell in self.allCellsOnDeckByOrdinal  do
			s4 := aCell.id.trimBlanks;
			s5 := aCell.ordinal.String.padLeadingZeros(2);
			s6 := aCell.alignment.String;
			s7 := getOidStringForObject(aCell);
			s12 := "";
			s13 := "";
			if self.isKindOf(CM_BayVoyage) then
				roundedPW := (self.CM_BayVoyage.getCellPileWeight(DeckOnDeck,aCell.ordinal,ShpDisplayMode_Actual) / 1000); // PAR 8667 added
				s12 := roundedPW.String;
				s13 := self.maxPileWeight20OB.String;
			endif;
			
			yml := yml &amp; "&lt;id&gt;" &amp; s4 &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; s5 &amp; "&lt;/ord&gt;&lt;al&gt;" &amp;  s6 &amp; "&lt;/al&gt;&lt;CO&gt;" &amp; s7 &amp; "&lt;/CO&gt;&lt;pw&gt;" &amp; s12 &amp; "&lt;/pw&gt;&lt;pwm&gt;" &amp; s13 &amp; "&lt;/pwm&gt;";
		endforeach;

		yml := yml &amp; "&lt;/cl&gt;&lt;tr&gt;";

		// ##############
		theTierOrdinal := 0;
		foreach aTier in self.allTiersOnDeck reversed do
			theTierOrdinal := theTierOrdinal + 1;
			s5 := theTierOrdinal.String.padLeadingZeros(2);
			s4 := aTier.id.trimBlanks;
			s12 := "";
			if self.isKindOf(CM_BayVoyage) then
				roundedTPW := (self.CM_BayVoyage.getTierPileWeight(DeckOnDeck,aTier.ordinal) / 1000);
				s12 := roundedTPW.String;
			endif;
			
			yml := yml &amp; "&lt;id&gt;" &amp; s4 &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; s5 &amp; "&lt;/ord&gt;&lt;pw&gt;" &amp; s12 &amp; "&lt;/pw&gt;";
		endforeach;

		yml := yml &amp; "&lt;/tr&gt;&lt;ld&gt;";

		foreach aLid in self.allHatchLids do
			yml := yml &amp; aLid.getGridDefinitionXML();
		endforeach;

		yml := yml &amp; "&lt;/ld&gt;&lt;sl&gt;";
		foreach aSlot in self.allSlotsOnDeck do
			yml := yml &amp; "&lt;GP&gt;" &amp; aSlot.getGridXMLdefn(CM_CellularVoyageStructure.GRID_VIEW_BAY ) &amp; "&lt;/GP&gt;";
		endforeach;
		yml := yml &amp; "&lt;/sl&gt;&lt;/OGA&gt;";
	else
		// no slots ondeck but we need a row and columns in the graphic for hatch lids, so use underdeck
		lml := "&lt;cl&gt;";
		foreach aCell in self.allCellsUnderDeckByOrdinal  do
			s4 := aCell.id.trimBlanks;
			s5 := aCell.ordinal.String.padLeadingZeros(2);
			s6 := aCell.alignment.String;
			s7 := getOidStringForObject(aCell);
			s12 := "";
			s13 := "";
			
			lml := lml &amp; "&lt;id&gt;" &amp; s4 &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; s5 &amp; "&lt;/ord&gt;&lt;al&gt;" &amp;  s6 &amp; "&lt;/al&gt;&lt;CO&gt;" &amp; s7 &amp; "&lt;/CO&gt;&lt;pw&gt;" &amp; s12 &amp; "&lt;/pw&gt;&lt;pwm&gt;" &amp; s13 &amp; "&lt;/pwm&gt;";
		endforeach;
		lml := lml &amp; "&lt;/cl&gt;";
		if not self.allHatchLids.isEmpty then
			lml  := lml &amp; "&lt;ld&gt;";
			foreach aLid in self.allHatchLids do
				lml := lml &amp; aLid.getGridDefinitionXML();
			endforeach;
			lml := lml &amp; "&lt;/ld&gt;";
		endif;
		yml := yml &amp; "&lt;OGA&gt;&lt;BY&gt;" &amp; s1 &amp; "&lt;/BY&gt;&lt;GO&gt;" &amp; s2 &amp; "&lt;/GO&gt;&lt;lb&gt;" &amp; s3 &amp; "&lt;/lb&gt;&lt;id40&gt;" &amp; s8 &amp; "&lt;/id40&gt;&lt;oh&gt;" &amp; 
					s9 &amp; "&lt;/oh&gt;&lt;SOD&gt;" &amp; s10 &amp; "&lt;/SOD&gt;&lt;SUD&gt;" &amp; s11 &amp; "&lt;/SUD&gt;" &amp; lml &amp; "&lt;/OGA&gt;";
	endif;
		
	theRow := theRow + 1;
	s2 := theRow.String.padLeadingZeros(2) &amp; _theCol.String.padLeadingZeros(2);
	if self.allSlotsUnderDeck.size &gt; 0 then	
		
		// ######################
		// UNDER DECK
		zml := zml &amp; "&lt;UGA&gt;&lt;BY&gt;" &amp; getOidStringForObject(self) &amp; "&lt;/BY&gt;&lt;GO&gt;" &amp; s2 &amp; "&lt;/GO&gt;" &amp; 
					 "&lt;lb&gt;" &amp; self.id.trimBlanks &amp; "&lt;/lb&gt;&lt;id40&gt;" &amp; s8 &amp; "&lt;/id40&gt;&lt;oh&gt;" &amp; s9 &amp; "&lt;/oh&gt;&lt;SOD&gt;" &amp; s10 &amp; "&lt;/SOD&gt;&lt;SUD&gt;" &amp; 
					 s11 &amp; "&lt;/SUD&gt;&lt;cc&gt;" &amp;  _backColour.String &amp; "&lt;/cc&gt;&lt;cl&gt;";

		foreach aCell in self.allCellsUnderDeckByOrdinal  do
			s4 := aCell.id.trimBlanks;
			s5 := aCell.ordinal.String.padLeadingZeros(2);
			s6 := aCell.alignment.String;
			s7 := getOidStringForObject(aCell);
			s12 := "";
			s13 := "";
			
			if self.isKindOf(CM_BayVoyage) then
				roundedPW := (self.CM_BayVoyage.getCellPileWeight(DeckUnderDeck,aCell.ordinal,ShpDisplayMode_Actual) / 1000); // PAR 8667 added
				s12 := roundedPW.String;
				s13 := self.maxPileWeightUD.String;
			endif;
			
			zml := zml &amp; "&lt;id&gt;" &amp; s4 &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; s5 &amp; "&lt;/ord&gt;&lt;al&gt;" &amp;  s6 &amp; "&lt;/al&gt;&lt;CO&gt;" &amp; s7 &amp; "&lt;/CO&gt;&lt;pw&gt;" &amp; s12 &amp; "&lt;/pw&gt;&lt;pwm&gt;" &amp; s13 &amp; "&lt;/pwm&gt;";
		endforeach;

		zml := zml &amp; "&lt;/cl&gt;&lt;tr&gt;";
		// ##############
		theTierOrdinal := 0;

		foreach aTier in self.allTiersUnderDeck reversed do
			theTierOrdinal := theTierOrdinal + 1;
			s5 := theTierOrdinal.String.padLeadingZeros(2);
			s4 := aTier.id.trimBlanks;
			s12 := "";
			if self.isKindOf(CM_BayVoyage) then
				roundedTPW := (self.CM_BayVoyage.getTierPileWeight(DeckUnderDeck,aTier.ordinal) / 1000);
				s12 := roundedTPW.String;
			endif;
			s6 := getOidStringForObject(aTier);
			
			zml := zml &amp; "&lt;id&gt;" &amp; s4 &amp; "&lt;/id&gt;&lt;ord&gt;" &amp; s5 &amp; "&lt;/ord&gt;&lt;TO&gt;" &amp; s6 &amp; "&lt;/TO&gt;&lt;pw&gt;" &amp; s12 &amp; "&lt;/pw&gt;";
		endforeach;

		zml := zml &amp; "&lt;/tr&gt;&lt;sl&gt;";

		foreach aSlot in self.allSlotsUnderDeck do
			zml := zml &amp; "&lt;GP&gt;" &amp; aSlot.getGridXMLdefn(CM_CellularVoyageStructure.GRID_VIEW_BAY) &amp; "&lt;/GP&gt;";
		endforeach;
		zml := zml &amp; "&lt;/sl&gt;&lt;/UGA&gt;";
	else

		zml := zml &amp; "&lt;UGA&gt;&lt;BY&gt;" &amp; s1 &amp; "&lt;/BY&gt;&lt;GO&gt;" &amp; s2 &amp; "&lt;/GO&gt;&lt;lb&gt;" &amp; s3 &amp; "&lt;/lb&gt;&lt;id40&gt;" &amp; s8 &amp; "&lt;/id40&gt;&lt;oh&gt;" &amp; 
				s9 &amp; "&lt;/oh&gt;&lt;SOD&gt;" &amp; s10 &amp; "&lt;/SOD&gt;&lt;SUD&gt;" &amp; s11 &amp; "&lt;/SUD&gt;&lt;/UGA&gt;";
	endif;
	return yml &amp; zml;	
end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theCol" type="Integer"/>
        <Parameter name="_backColour" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHatchLidsBetween" id="752e88e6-e106-4791-a123-a5e96e79dffd">
        <source>getHatchLidsBetween(_hatchFrom, _hatchTo : CM_HatchLid; _selectedHatches : ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cellFrom, cellTo,
	tmpCell			: Integer;
	tmpHatchLid		: CM_HatchLid;

begin

	if _hatchFrom = null or
	   _hatchTo = null then
		app.raiseCMException1(MethodWithNullParam, 'slotFrom or slotTo', null, null);
		return;
	endif;
	
	cellFrom := _hatchFrom.ordinalUDStartCell;
	tmpCell := _hatchTo.ordinalUDStartCell;
	
	cellTo := tmpCell.max(cellFrom);
	cellFrom := tmpCell.min(cellFrom);

	foreach tmpHatchLid in self.allHatchLids do
		if tmpHatchLid.ordinalUDStartCell &gt;= cellFrom and
		   tmpHatchLid.ordinalUDStartCell &lt;= cellTo then
			if (not _selectedHatches.includes(tmpHatchLid)) then
				_selectedHatches.add(tmpHatchLid);
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="_hatchFrom" type="CM_HatchLid"/>
        <Parameter name="_hatchTo" type="CM_HatchLid"/>
        <Parameter name="_selectedHatches" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getKPIUsed" id="da9a1887-654a-4ff0-ab4e-3dd9c943fed7">
        <source>getKPIUsed(_mode : Integer; _teuAvail, _teuUsed : Integer output);
/*
Purpose:			
Date		Who		Reason
01 September 2011	cnwab1	Initial creation
*/

vars	
	ti : CM_TrackedItem;
	aBay : CM_Bay;
	teu : Integer;
	slot : CM_SlotDefn;
	array : CM_TIArray;
begin

	create array transient;
	
	foreach slot in self.allSlotsByOrdinal  discreteLock where slot.unavailable = false do
			
		_teuAvail := _teuAvail + 1;
		
		//epr par 35006 6/10/14 used to pass _mode into getTIs which is expecting a different constant i.e. REAL_MODE
		if _mode = ShpDisplayMode_Actual then
			slot.CM_SlotDefnVoyage.mySlotController.getTIs(array, REAL_MODE, true);
		elseif _mode = ShpDisplayMode_Proposed then
			slot.CM_SlotDefnVoyage.mySlotController.getProposedTIs(array);
		endif;
	/*	if _mode = PLANNING_MODE then // PROPOSED VIEW
			// includes REMAIN ON BOARD
			foreach ti in slot.CM_SlotDefnVoyage.mySlotController.allTrackedItems  discreteLock where ti.isInTransitOnShip do
				array.add(ti);
			endforeach;
		
		endif;*/
		
		if not array.isEmpty() then
			_teuUsed := _teuUsed + 1;
		endif;
	endforeach;
	
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_teuAvail" type="Integer" usage="output"/>
        <Parameter name="_teuUsed" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getKPIVoyageBayMovesTRAN" id="9c51874c-c11e-44e9-adb5-f87b6e48ef1b">
