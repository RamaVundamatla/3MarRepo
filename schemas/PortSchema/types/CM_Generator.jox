        <updating/>
        <source>setPxyFromCMIF_Receival(isUpdateTI: Boolean;_receival: CMIF_Receival; _passport: CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:	15 October 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
// 17/04/2018    jlgrh7 TFS 38055 MSL - coparn deletes stop fields

------------------------------------------------------------------------------*/
