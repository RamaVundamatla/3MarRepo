    <JadeMethod name="setOffsetStrict" id="850313df-f2e2-4a25-baee-6dc3b6d69279">
        <updating/>
        <source>setOffsetStrict(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpNewOffset : Integer;
begin
	// Strict 'invisible' grid
	if self.is30ft and _ti.isAttributeTrue(TI_Attrib_IsThirty) then
		tmpNewOffset := self.offset30;
	elseif self.is40ft and _ti.isAttributeTrue(TI_Attrib_IsForty) then // PAR 18682
		tmpNewOffset := self.offset40;
	elseif self.is20ft and _ti.isTwenty() then // PAR 18682
		tmpNewOffset := 0;
	elseif self.is45ft and _ti.isAttributeTrue(TI_Attrib_IsFortyFive) then
		tmpNewOffset := self.offset45;
	elseif self.is53ft and _ti.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		tmpNewOffset := self.offset53;
	endif;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; self.getFullId() &amp; " " &amp; tmpNewOffset.String);	
	
	if tmpNewOffset &gt; self.offsetFlexi then
		self.offsetFlexi := tmpNewOffset;
	endif;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. " &amp; self.getFullId() &amp; " " &amp; self.offsetFlexi.String);	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setProductMinMax" id="0387cd4b-7b61-4b11-a214-4cbbfcfc701c">
        <source>setProductMinMax( _pxyLc : CM_LocationsController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2021	navndl1	Initial creation	TFS 49912

*/

vars

	pxyMinMax : CM_TerminalAreaProductMinMax;
	realMinMax : CM_TerminalAreaProductMinMax;

begin

	foreach pxyMinMax in _pxyLc.allProductMinMax discreteLock do
		realMinMax := self.getProductMinMaxObject( pxyMinMax.myCargoType, pxyMinMax.myProduct );
		if realMinMax = null then
			create realMinMax persistent;
		endif;
		realMinMax.setFromPxyLocationMinMax( self, pxyMinMax );
	endforeach;

epilog

end;</source>
        <Parameter name="_pxyLc" type="CM_LocationsController"/>
    </JadeMethod>
