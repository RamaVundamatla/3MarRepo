    <JadeMethod name="displayForXlation" id="279cf6de-e3c9-4da1-aaf9-4e106bf24b25">
        <source>displayForXlation(_codeFirst :Boolean) :String;
/*
Date		Who		Reason
05 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	if _codeFirst then
		return self.code.String &amp; ' [' &amp; self.description.trimBlanks &amp; ']';
	else
		return self.description.trimBlanks &amp; ' [' &amp; self.code.String &amp; ']';
	endif;
epilog

end;</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="erase" id="93a4bc78-0279-43c1-af55-326098105602">
