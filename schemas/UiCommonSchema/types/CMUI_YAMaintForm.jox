    <JadeMethod name="addCriteriaFrame" id="0a7db568-7795-49db-9a25-9808d3c5c05b">
        <updating/>
        <source>addCriteriaFrame(_i: Integer; _criteriaType: CM_YACriteriaType; _tabIndex: Integer io): CMUI_YACriteriaCntl updating;
// 24 Jun 2013	cnwcs5	par 31712
// 28/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
vars
	firstFrame,
	criteriaFrame: CMUI_YACriteriaCntl;
	width: Integer;
	scrollheight : Integer;
begin

	//28/11/2023	navkc1 Bug 60782
	if _i &gt; 1 then
		firstFrame := self.frmCriteria.getControl(1).CMUI_YACriteriaCntl;
	endif;
	
	width 			:= self.shtCriteria.width.Integer - 10;	// par 31712
	criteriaFrame 	:= self.frmCriteria.getControl(_i).CMUI_YACriteriaCntl;
	
	if criteriaFrame = null then
		criteriaFrame := self.frmCriteria.loadControl(_i).CMUI_YACriteriaCntl;
		
		criteriaFrame.formCriteriaChangeMethodName := CMUI_YAMaintForm::doCriteriaChanged.name;
	endif;
	
	criteriaFrame.parentAspect := Control.ParentAspect_StretchRight; //28/11/2023	navkc1 Bug 60782
	
	//08 Oct 2013	NDL	Par 32456
	width := self.picCriteria.width.Integer - 10;
	
	criteriaFrame.parent := self.picCriteria;
	
	
	criteriaFrame.setLabelVisible(true);
	
	if app.isSpecial
	or not self.cmbIMEX.enabled // and self.cmbIMEX.listObject.CM_IMEXStatus.code = TI_IMEX_STATUS_NULL then
	or self.isObjCriteriaLineForm	//12 Dec 2013	NDL	Par 33184
	or self.isGriddedStackHeightForm	//08 Sep 2020	NDL	TFS 49984
	then
		criteriaFrame.setLabelVisible(false);
	endif;
	
	criteriaFrame.visible := true;
	criteriaFrame.tag := "true";	// to active three-state booleans 23 Mar 2015	NDL	Par 35886
	
	criteriaFrame.width := width;	// 28/11/2023	navkc1 Bug 60782
	criteriaFrame.setWidth(width);
	criteriaFrame.parentRightOffset := 0; 	//28/11/2023	navkc1 Bug 60782
	//criteriaFrame.width := width;	// 28/11/2023	navkc1 Bug 60782
	
	criteriaFrame.setCriteriaType(_criteriaType);
	criteriaFrame.setVoyagesReference(self.allVoyages);
	criteriaFrame.setTabIndex(_tabIndex);
	
	criteriaFrame.top := ((_i - 1) * criteriaFrame.height);
	
	//08 Oct 2013	NDL	Par 32456
	scrollheight := ((criteriaFrame.top - picCriteria.height).Integer + criteriaFrame.height ).Integer;
	if scrollheight &lt; 0 then
		scrollheight := 0;
	endif;
	
	self.picCriteria.setScrollRange(ScrollBar_Vertical, 0, scrollheight, 20, 100);
	self.picCriteria.zOrder(0); //epr par 35066 13/10/14 
	
	// //28/11/2023	navkc1 Bug 60782 Temp workaround - check this again
	if self.doWindowsRefresh() then 
		app.doWindowEvents(0); 
	endif;
	
	return criteriaFrame;
end;
</source>
        <Parameter name="_i" type="Integer"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_tabIndex" type="Integer" usage="io"/>
        <ReturnType type="CMUI_YACriteriaCntl"/>
    </JadeMethod>
