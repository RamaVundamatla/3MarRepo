        <updating/>
        <source>showWithTerminalAdminItemClass(_class: Class) updating;
/*
Purpose:			
Date		Who		Reason
07 May 2014	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(_class);

	self.amInitialisingWithMaintItem	:= true;
	self.myInitSOPMaintItemClass 			:= _class;
	
	self.show();

epilog

