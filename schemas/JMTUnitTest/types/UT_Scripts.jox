    <JadeMethod name="uAddCargoEnMass" id="9c03fb0d-c611-49af-96c7-2cfdb7a9018b">
        <source>uAddCargoEnMass();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2016	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	bc : CM_BlockController;
	id : String;
	index : Integer;
	cargo : CM_TrackedItem;
	product: CM_Product;
	voyage : CM_Voyage;

begin

	return;  // took 140 seconds to add 2000 items...

	term := "2351.53".asOid.CM_Terminal;
	cargoType := "2083.3039".asOid.CM_CargoType;
	operator := "2312.12700".asOid.CM_Operator;
	bc := "2289.36884".asOid.CM_BlockController;
	product := "4069.14432".asOid.CM_Product;
	voyage := "4480.495976".asOid.CM_Voyage;
	
	self.opts.addAssoc("Terminal",term.code);
	app.myPassport.setMyTerminal(term);
	term := self.getTerminal;
	
	foreach index in 01 to 2000 do
		id := "ZREBAR" &amp; index.padLeadingWith("0",4);
		addCargoAtLocationDetailed(	id,	//_id: String; 
									cargoType,	//_cargoType : CM_CargoType;
									product,	//_product: CM_Product;
									bc,	//_location: CM_LocationsController;
									"NZPOE",	//_dPort : String;
									1,	//_imex : Integer;
									voyage,	//_voyage : CM_Voyage;
									operator	//_op : CM_Operator
									);
	endforeach;

epilog

	write app.myPassport.getErrorsAndWarningsAsString;
end;</source>
    </JadeMethod>
    <JadeMethod name="uAddCargoEnMassTFS37377" id="4386814c-6c89-4638-9648-2dd75c78a9c7">
        <source>uAddCargoEnMassTFS37377();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37377

*/

vars

	term : CM_Terminal;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	bc : CM_BlockController;
	id : String;
	index : Integer;
	cargo : CM_TrackedItem;
	product: CM_Product;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;

begin

	

	term := "2351.50".asOid.CM_Terminal;		//UT
	cargoType := "2083.33967".asOid.CM_CargoType;	// 37377
	operator := "2312.5430".asOid.CM_Operator;
	bc := "2289.2455462".asOid.CM_BlockController;
	product := "4069.53748".asOid.CM_Product;
	voyage := "4480.8099".asOid.CM_Voyage;
	
	self.opts.addAssoc("Terminal",term.code);
	app.myPassport.setMyTerminal(term);
	term := self.getTerminal;
	
/*	foreach index in 1 to 30000 do
		id := "ALUZ37377" &amp; index.padLeadingWith("0",5);
		addCargoAtLocationDetailed(	id,	//_id: String; 
									cargoType,	//_cargoType : CM_CargoType;
									product,	//_product: CM_Product;
									bc,	//_location: CM_LocationsController;
									"NZPOE",	//_dPort : String;
									1,	//_imex : Integer;
									voyage,	//_voyage : CM_Voyage;
									operator	//_op : CM_Operator
									);
	endforeach; */
	
	//foreach index in 1 to 30000 do
	foreach index in 2420 to 30000 do
		id := "ALUZ37377" &amp; index.padLeadingWith("0",5);
		ti := term.allOnsiteTIsByCargoTypeId.getAtKey( cargoType.id, id );
		if ti &lt;&gt; null then
			self.deleteTrackedItem( ti, null );
		endif;
	endforeach;


epilog

	write app.myPassport.getErrorsAndWarningsAsString;
end;</source>
