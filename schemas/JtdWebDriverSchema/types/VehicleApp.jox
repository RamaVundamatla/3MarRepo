    <JadeMethod name="stop2" id="2b804d6d-863c-40cd-a93e-d42e4427f635">
        <updating/>
        <source>stop2() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2019	jlger1	Initial creation

*/

vars

begin
	
	if self.myWebServiceTestForm &lt;&gt; null then
		// do Logoff
		self.logout;
		
		//close form
		self.myWebServiceTestForm.unloadForm;
		self.myWebServiceTestForm:=null;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateFaultQuestions" id="b4003326-08b1-41b3-9f45-bd2440ca10c4">
        <source>updateFaultQuestions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2019	jlger1	Initial creation

*/

vars
	cmbService :ComboBox;
	cmbOperation :ComboBox;
	btn 			: Button;
	allPropertyNames,
	allPropertyValues : StringArray ;
begin
	cmbService := self.myWebServiceTestForm.cmbService;
	cmbService.gotFocus(cmbService);
	cmbService.listIndex:=app.atcgGetComboStringIndex(cmbService, 1, 'JMTUserInterfaceService', 3);
	cmbService.click(cmbService); 
	
	app.doWindowEvents(shortPause);
	cmbOperation := self.myWebServiceTestForm.cmbOperation;
	cmbOperation.gotFocus(cmbOperation);
	cmbOperation.listIndex:=app.atcgGetComboStringIndex(cmbOperation, 1, 'machineDoUpdateFaultQuestion', 298);
	cmbOperation.click(cmbOperation);
	
	create allPropertyNames transient;
	create allPropertyValues transient;
	allPropertyNames.add("faultQuestionIndex");
	allPropertyNames.add("faultResponse");
	allPropertyValues.add("1");
	allPropertyValues.add("Yes");
	self.myWebServiceTestForm.createEmptyInputMessage(allPropertyNames,allPropertyValues);
	self.sendWebService();
	
	allPropertyNames.clear;
	allPropertyValues.clear;
	allPropertyNames.add("faultQuestionIndex");
	allPropertyNames.add("faultResponse");
	allPropertyValues.add("2");
	allPropertyValues.add("Yes");
	self.myWebServiceTestForm.createEmptyInputMessage(allPropertyNames,allPropertyValues);
	self.sendWebService();
	
	
epilog
	delete allPropertyNames;
	delete allPropertyValues;
end;</source>
    </JadeMethod>
