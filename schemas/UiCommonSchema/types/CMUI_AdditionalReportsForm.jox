    <JadeMethod name="translateForm" id="64246275-4cea-44c4-b28a-314f4ea30b42">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 February 2019 08:29:34.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023219, locale);
	btnAdd.translateCaption(Xlat_0023220, locale);
	btnRemove.translateCaption(Xlat_0023221, locale);
	lblAddReps.translateCaption(Xlat_0023222, locale);
	lblDisplayName.translateCaption(Xlat_0023223, locale);
	lblReportName.translateCaption(Xlat_0023224, locale);
	lblReportView.translateCaption(Xlat_0023225, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="0ccd52f0-6631-42e5-a874-96ca37ffabe0">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

begin

	if not self.allVoyProcReports.isEmpty then
		self.allVoyProcReports.purge();
	endif;
	
	delete self.myJRWReportMgr;

epilog

end;</source>
    </JadeMethod>
