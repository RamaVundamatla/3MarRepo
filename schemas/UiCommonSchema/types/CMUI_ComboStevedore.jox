<GUIClass name="CMUI_ComboStevedore" id="8b1befe0-f1aa-4c5c-aed0-e92dcb95848c">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isDisplayByName" id="cafa24e2-29ae-4e9d-9a53-e0daef3f45d5">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="ffcda926-dbd9-4576-8190-96b8e52d2be0">
        <updating/>
        <source>displayEntry(combobox: ComboBox input; _stevedore : CM_Stevedore; lstIndex: Integer): String updating;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// 25//11/2020	cnwma1	Bug 50442: 49179 ASPA - Deleting a Stevedore on a wagon causes an Error 4
// 08/06/2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	str 		: String;
	invalid		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _stevedore, invalid);  //25.11.2020 cnwma1 #50422
	
	if _stevedore = null then
		return null;
	endif;
	
	str := _stevedore.code;
	
	if invalid then
		return null;
	endif;
	
	if _stevedore.notAvailableForEntry then
		if self.myObject &lt;&gt; _stevedore then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	if self.isDisplayByName then									// TFS 53362
		return _stevedore.description &amp; Tab &amp; _stevedore.code;		// TFS 53362
	else															// TFS 53362
		return _stevedore.code &amp; Tab &amp; _stevedore.description;
	endif;															// TFS 53362

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_stevedore" type="CM_Stevedore"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="9d926dcb-8af4-485b-9387-2d7757c18be1">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return app.myRoot.allStevedores;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="init" id="0747bbac-1363-4817-aeb0-232ff465391d">
        <updating/>
        <source>init() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/06/2022	navdap1		Initial creation TFS 53362 EUP Master Data interface customers between TOS and ERP
//
vars

begin
	self.isDisplayByName := app.myRoot.getConfig(ComboByNameStevedore).Boolean;
	inheritMethod();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setIsDisplayByName" id="3bcf104c-3f35-488d-83f8-556cba539ea6">
        <updating/>
        <source>setIsDisplayByName(_value : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/06/2022	navdap1		Initial creation 53362 TFS EUP Master Data interface customers between TOS and ERP
//
vars

begin
	self.isDisplayByName := _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
