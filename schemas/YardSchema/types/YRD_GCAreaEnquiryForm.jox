    <JadeMethod name="mnuGridBulkEdit_click" id="9f924c07-d499-4b2f-9777-dddafa7df05e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGridBulkEdit_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
