    <JadeMethod name="doSave" id="27a1dcb7-5f32-4e90-96ff-57722c4d0483">
        <updating/>
        <source>doSave(): Boolean updating;
vars
	errObj				: CM_Error;
	idx					: Integer;
	ignoreWarnings,
	rtnValue			: Boolean;
	theForm				: SOP_TableMaintForm;
	pxyEdiFileFormat,
	ediFileFormat		: CM_FileFormatEDI;
	operator			: CM_Operator;
	notUsed				: Boolean;
begin

	theForm := self.myForm; 
	name			:= theForm.tblInput1.getValueByName(ETRow_Name).String;
	operator		:= theForm.cmbOperator.listObject.CM_Operator;
	notUsed			:= theForm.tblInput1.getValueByName(ETRow_NoLongerUsed).Boolean;
	
	if theForm.myProxyObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;

	pxyEdiFileFormat := theForm.myProxyObject.CM_FileFormatEDI;
	pxyEdiFileFormat.setForUpdateUser(name, null, notUsed, operator);
	
	if theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateEDIFileFormat(pxyEdiFileFormat, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="e8e9b79b-4f18-4eb3-9e3d-338e3869abfa">
        <source>getCollection(): Collection;

vars
	ediFileType		: CM_EDIFileType;
	ediFileFormat	: CM_FileFormatEDI;
begin
	self.allFileFormats.clear;

	foreach ediFileType in app.myRoot.allEDIFileTypes do
		foreach ediFileFormat in ediFileType.allFormats do
			self.allFileFormats.add(ediFileFormat);	
		endforeach;
	endforeach;
	
	return self.allFileFormats;
//	return app.myRoot.allEDIActions;

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
