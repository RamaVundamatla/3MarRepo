        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="9e0c1c42-133f-4d77-9039-5d44b574e1fb">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	toolBarRoot					: CM_MenuUserToolbarRoot;
	listCount,
	idx							: Integer;
	menuEntity					: CM_MenuEntity;
	aClonedSeparator			: CM_MenuUserToolbar;
	menuToolbar					: CM_MenuToolbar;
	lstBox						: CMUI_NavigatorListBox2;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	
	create toolBarRoot transient;
	toolBarRoot.setShowCaption(app.myPassport.myUser.myMenuUserToolbarRoot.showCaption);

	lstBox := self.lstIncluded;
	listCount := lstBox.listCount;

	foreach idx in 1 to listCount do
		menuEntity := lstBox.itemObject[idx].CM_MenuEntity;
		if CM_MenuToolbar.hasInstance(menuEntity) then
			toolBarRoot.allChildren.add(menuEntity);
		else//if CM_MenuUserToolbar.hasInstance(menuEntity) then //its a cloned separator
			toolBarRoot.allChildren.add(self.mySeparator);//menuEntity.CM_MenuUserToolbar.mySystemToolbar);
		endif;
	endforeach;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateUserToolbarMenu(app.getMyUser(), toolBarRoot, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Toolbar', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.modalResult := IDOK;

	self.unloadForm();

epilog
	delete toolBarRoot;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doContextMenuMaster" id="00387d77-e4b5-46cc-b80a-3654d855c5ed">
        <updating/>
        <source>doContextMenuMaster(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
	x1, 
	y1					: Real;
	menuEntity			: CM_MenuEntity;
	user				: CM_User;
	terminal			: CM_Terminal;
	idx					: Integer;
begin
	
	menuEntity := listbox.listObject.CM_MenuEntity;
	if menuEntity = null then
		return false;
	endif;
	
	self.lstNotIncluded.listObject := menuEntity;	
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if listbox.top &lt; 0 then
	        y1 := 5;
	    else
	        y1 := listbox.top;
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	self.mnuSelectPicture.visible := true;
	//CNWTH2 deciding users can't change toolbar pics - once we set them up, it is normal practice
	//for users not to be able to change pics
	if app.isSpecial() then
		self.mnuSelectPicture.visible := true;
	else
		self.mnuSelectPicture.visible := false;
	endif;
	
	self.popupMenu(self.mnuMasterContext, x1.Integer, y1.Integer);
	
	return false;                  // cancel further processing

end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDragDrop" id="707b73ce-6c43-49a9-bed8-d6e6ae65f840">
        <updating/>
        <source>doDragDrop(_listbox : ListBox input) protected, updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myPickupItem = null
	or self.pickUpListIndex = null then		// 23/03/2011 cnwar2 #27240
		return;
	endif;
	
	self.lstIncluded.removeItem(self.pickUpListIndex);
	self.lstIncluded.addToolbarItemAt(self.myPickupItem, _listbox.dragListIndex);
	
	self.pickUpListIndex := null;
	
end;</source>
        <access>protected</access>
        <Parameter name="_listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDragOver" id="cc625e40-19d5-40a7-a6eb-aaa93604b63f">
        <source>doDragOver(_listbox : CMUI_NavigatorListBox2 input) protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _listbox.dragListIndex &gt; 0 and 
	   _listbox.dragListIndex &lt; _listbox.listCount then
		_listbox.listIndex := _listbox.dragListIndex;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_listbox" type="CMUI_NavigatorListBox2" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFilterList" id="3b14bc5d-e72f-41cb-aea7-e95c11a26d34">
        <updating/>
        <source>doFilterList() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Sep 2023	navhl20	ChangeRequest 59988: MTN - Add a filter to Customize toolbar Multi Selection
20 Sep 2023 navhl20 Defect 60596: MTN - Customize toolbar Multi Selection filter issue
*/

vars
	filterText 	: String;
	idx,
	count		: Integer;
	cellText 	: String;
	lst			: CMUI_NavigatorListBox2;
	menuEntity	: CM_MenuEntity;
begin
	filterText  := self.txtfilter.text.toUpper();
	lst			:= self.lstNotIncluded;
	//self.displayLists();								//20.9.2023 navhl20 #60596
	foreach menuEntity in self.hiddenrows do			//20.9.2023 navhl20 #60596
		lst.addMenuEntity(menuEntity, null, 2);
	endforeach;
	lst.sorted := true;									//20.9.2023 navhl20 #60596
	self.hiddenrows.clear();							//20.9.2023 navhl20 #60596
	
	if filterText = "" then
		//self.clearfilter();							//20.9.2023 navhl20 #60596
		return;
	else
		self.btnclear.enabled := true;
	endif;
	
	count := lst.listCount;
	
	foreach idx in count to 1 step -1 do
		menuEntity := lst.itemObject[idx].CM_MenuEntity;
		cellText := menuEntity.getHeading().toUpper;
			if not cellText.cnContains(filterText) then
				self.hiddenrows.add(menuEntity);		//20.9.2023 navhl20 #60596
				self.lstNotIncluded.removeItem(idx);
			endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMouseDown" id="e72784e5-ac6e-444d-814d-b56c5d25a705">
        <updating/>
        <source>doMouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if listbox.listIndex &lt; 1 then
		return;
	endif;
	
	self.myPickupItem := self.lstIncluded.itemObject[listbox.listIndex].CM_MenuEntity;
	self.pickUpListIndex := listbox.listIndex;
	
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="569ab2a8-bff1-4a4e-8bc1-0584093ef7d5">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2003		cnwth2	
//
// Purpose:     
// 01 Sep 2023	navhl20		ChangeRequest 59988: MTN - Add a filter to Customize toolbar Multi Selection
// ----------   ----------  --------------------------------------------------
constants
	HorzGap = 10;
	Divisor = 2.5;
	
vars
	selfWidth,
	theTop			: Real;
	remainder		: Integer;
	
begin
	inheritMethod();
	selfWidth 				:= (self.width - (HorzGap * 3)).Integer;
	theTop := self.frmToolbar.height + self.VerticalSpacing + 25;
	
	self.lstNotIncluded.top := theTop;
	self.lstNotIncluded.left 	:= HorzGap;
	self.lstNotIncluded.height 	:= self.height - 115;
	self.lstIncluded.top := theTop;
	self.lstIncluded.height 	:= self.height - 115;
	self.lstNotIncluded.width  	:= (selfWidth / Divisor);
	self.lstIncluded.width  	:= (selfWidth / Divisor);
	
	remainder := (selfWidth - (self.lstNotIncluded.width + self.lstIncluded.width)).Integer;
	
	self.btnAdd.left 		:= self.lstNotIncluded.left + self.lstNotIncluded.width + HorzGap;
	self.btnRemove.left 	:= self.lstNotIncluded.left + self.lstNotIncluded.width + HorzGap;
	self.btnAdd.width		:= remainder - (HorzGap * 2);
	self.btnRemove.width	:= remainder - (HorzGap * 2);
	self.btnAddSep.left 	:= self.btnAdd.left;
	self.btnAddSep.width	:= self.btnAdd.width;
	
	self.lstIncluded.left		:= self.btnAdd.left + self.btnAdd.width + HorzGap;
	self.lblSelected.left 	:= self.lstIncluded.left;
	
	self.txtfilter.left := HorzGap;											//05.9.2023 navhl20 #59988
	self.txtfilter.width := (selfWidth / Divisor) - 53;						//05.9.2023 navhl20 #59988
	self.btnclear.left := self.txtfilter.width + self.txtfilter.left + 3;	//05.9.2023 navhl20 #59988
	
//	self.btnSave.move(self.width -100,self.height - 60, 80, 25);
//	self.btnCancel.move(self.width -190, self.height - 60, 80, 25);
//	self.chkShowCaption.move(10, self.height - 50, 100, 25);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectPicture" id="c5c1603d-1aa4-4cb6-b4d2-fc3a57813bac">
        <updating/>
        <source>doSelectPicture() protected, updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     Only enabled for developers or superuser - at this point
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuToolbar			: CM_MenuToolbar;
	systemDtl			: CM_MenuDtl;
	menuUserItem		: CM_MenuUserItem;
begin
	menuToolbar := self.lstNotIncluded.listObject.CM_MenuToolbar;
	if menuToolbar = null then
		return;
	endif;
	
	if (not self.lstNotIncluded.selectPictures(false, true, true, true)) then
		return;
	endif;

	self.displayLists();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
