        <source>btnCutoffUpdate_click(btn: Button input) updating;
/*
Purpose:	

Date		Who		Reason
10 March 2025	navab1	JIRA 34233
*/

vars
	voyCutoff : CM_ReceivalCutoffVoyage;
begin
	voyCutoff := self.tblVoyageCutoffs.accessRow(self.tblVoyageCutoffs.row).itemObject.CM_ReceivalCutoffVoyage;
	if voyCutoff = null then
		return;
	endif;
	
	self.setRecCutoff(voyCutoff);
	
	self.loadRecCutoffsRow(voyCutoff, self.tblVoyageCutoffs.row);
	self.hideShowCutoffsFrame(not self.frmCutoffDataEntry.visible); // ### JIRA 34553 08APR2025 NAVAB1

	
epilog

end;</source>
