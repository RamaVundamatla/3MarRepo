    <JadeMethod name="setCmbBooking" id="4a659ecd-eb31-4f74-9b55-c9e19027337f">
        <updating/>
        <source>setCmbBooking()updating;
/*
Purpose:		Load the Booking combo with bookings for the selected voyage
Parameters:			
Return Value:		

Date			Who		Reason
18 August 2009	cnwml2	Initial creation
15/03/2010		cnwcs5	par 23159 - noticed this method using .instances so changed to use proper collection on voyage
*/

vars
	booking : CM_BookingRef;
begin
	self.cmbBooking.clear();
	
//	foreach booking in CM_BookingRef.instances do
//		if booking.myTerminal = self.myTerminal then
	foreach booking in self.myVoyage.allBookingRefs do	// par 23159
		//if booking.statusDesc = "Active" and booking.myVoyage = self.myVoyage then
		if booking.status = BOOKING_REF_ACTIVE then		// par 23159
			self.cmbBooking.addItemObject(booking.bookingReference,booking);
		endif;
		if booking = self.myBooking then
			self.cmbBooking.text := booking.bookingReference;
		endif;
//		endif;
	endforeach;
	
	self.refreshForm();
epilog
	
end;</source>
    </JadeMethod>
