    <JadeMethod name="initialise" id="34b351b7-469a-4b72-82f1-62ff9b48f147">
        <updating/>
        <source>initialise(_groupCount: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2017	cnwma1	Initial creation

*/

vars
	ild: CM_InvoiceLineDesc;
	tmcS : CMIF_TMCInvLineDesc;
	sb : CM_ServiceBroker;
	resContractIn : CMIF_TMCResourceContractIN;
	resContractOut : CMIF_TMCResourceContractOUT;
	finObj : CM_FinancialObject;
    qmr : CM_QuantityRangeMap;
    tmcQRM : CMIF_TMCQuantityRangeGroup;
	tmcQRSubM : CMIF_TMCQuantitySubRangeGroup;
				mapping : CM_TranMapInvoiceLineMapping;
begin
	self.myTMCController := self.myGroup.myTMCController;	
	self.hidePictures := self.myTMCController.hidePictures;
	
	finObj := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject;
	if finObj.isKindOf(CM_DebtorMap) then
		sb := finObj.CM_DebtorMap.myServiceBroker;
	elseif finObj.isKindOf(CM_QuantityRangeMap) then
	else
		sb := finObj.CM_ServiceBroker;
	endif;
	if sb.isKindOf(CM_ResourceServiceBroker) then
		create resContractIn;
		resContractIn.myDebtorMap := finObj.CM_DebtorMap;
		resContractIn.myDebtor := resContractIn.myDebtorMap.myDebtorNode;
		resContractIn.myServiceBroker := null; 
		resContractIn.itemName := resContractIn.getItemName();
		resContractIn.extractName := resContractIn.getItemName();	// 23659
		resContractIn.myGroup := self;
		resContractIn.myQuantityRangeMap := self.myQuantityRangeMap;
		resContractIn.initialise(_groupCount);
		
		create resContractOut;
		resContractOut.myDebtorMap := finObj.CM_DebtorMap;
		resContractOut.myDebtor := resContractOut.myDebtorMap.myDebtorNode;
		resContractOut.myServiceBroker := null; //self.myServiceBroker.CM_ResourceServiceBroker;
		resContractOut.itemName := resContractOut.getItemName();
		resContractOut.extractName := resContractOut.getItemName();	// 23659
		resContractOut.myQuantityRangeMap := self.myQuantityRangeMap;
		resContractOut.myGroup := self;
		resContractOut.initialise(_groupCount);
	else
		if  self.myQuantityRangeMap.myChildQuantityMap&lt;&gt; null then
			foreach qmr in self.myQuantityRangeMap.myChildQuantityMap.allQuantityRanges discreteLock do
				create tmcQRM;
				tmcQRM.myGroup := self;
				tmcQRM.itemName := qmr.getName();
				tmcQRM.extractName := qmr.getExtractDetails();	
				tmcQRM.myQuantityRangeMap := qmr;
				tmcQRM.initialise(_groupCount);
				if qmr.myChildQuantityMap &lt;&gt; null then		
					create tmcQRSubM;
					tmcQRSubM.myGroup := tmcQRM;				
					tmcQRSubM.itemName := self.getItemName;
					tmcQRSubM.extractName := tmcQRM.extractName;	// 23659
					tmcQRSubM.myQuantityRangeMap := qmr;
					tmcQRSubM.initialise(_groupCount);
						
				endif;
			endforeach;
		else	
		// TFS 40620 foreach ild in self.myQuantityRangeMap.allInvoiceLineMaps discreteLock do
		foreach mapping in self.myQuantityRangeMap.allTMInvoiceLineMappings do // TFS 40620
			ild := mapping.myTMInvoiceLineDesc; // TFS 40620
			//add in each service in the list
			if self.allGroupMembers[ild.narration] = null then
				create tmcS;
				tmcS.itemName := ild.narration;
				tmcS.extractName := ild.narration;		// 23659
				tmcS.myQuantityRangeMap := self.myQuantityRangeMap;
				tmcS.myGroup := self;
				tmcS.myInvoiceLineDesc := ild;
				tmcS.hidePictures := self.myTMCController.hidePictures;
				_groupCount := _groupCount + 1;	//17 Dec 2019	NDL	TFS 48039
			endif;
		endforeach;
		endif;

	endif;
	
	_groupCount := _groupCount + 1;	//17 Dec 2019	NDL	TFS 48039
	
epilog

end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="86b12b74-2d07-4532-bcc5-b1cf7e1b2286">
        <source>setControllerCurrent();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2017	cnwma1	 TFS #2901:ADP - Variable storage charges based on weight and time


*/

vars
	aTransSB : CM_ServiceBroker; 
	aCommMap : CM_CommodityMap;
	isEvent, isVTMIS : Boolean;
	isBOL : Boolean;	//04 Nov 2019	NDL TFS 47100
begin
	inheritMethod();

	aTransSB := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then	//04 Nov 2019	NDL TFS 47100
		isBOL := true;
	else
		return;
	endif;
	
	myTMCController.myCurrentMapQuantity := self.myQuantityRangeMap.myChildQuantityMap;
	myTMCController.myCurrentMapQuantityRange := self.myQuantityRangeMap;
	
	if aTransSB.isKindOf(CM_ResourceServiceBroker) then
		myTMCController.myCurrentMapTMVoyage := aTransSB.CM_ResourceServiceBroker.myTransMap;
		myTMCController.myCurrentMapDebtor := null;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		myTMCController.myCurrentMapTMEvent := aTransSB.CM_EventServiceBroker.myTranMap;
		myTMCController.myCurrentMapDebtor := null;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
	elseif isBOL then		//04 Nov 2019	NDL TFS 47100
		myTMCController.myCurrentMapTMBOL := aTransSB.CM_BOLServiceBroker.myTransMap;
		myTMCController.myCurrentMapDebtor := null;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
	else
		myTMCController.myCurrentMapDebtor := null;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
		myTMCController.myCurrentMapCommodity := aCommMap;
		myTMCController.myCurrentMapContents := aCommMap.contentsMap;
		myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
		myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
		myTMCController.myCurrentMapProdGrp := myTMCController.myCurrentMapProduct.myProductGroupMap;
		myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
		myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;

	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="e51a5dad-7691-4881-b031-89036ec95ddc">
        <source>setEnableObjects(form: INV_TransactionMap io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/02/2017	cnwma1	TFS #2901:ADP - Variable storage charges based on weight and time
15/01/2019	jlgdap1	TFS 39160 Transaction Map Issues
*/

vars
	allowUpdate : Boolean;
	isEvent, isVTMIS, isWO : Boolean;
	aTransSB : CM_ServiceBroker;
	aQtyMap : CM_QuantityMap;
	isBOL, showLineMapping : Boolean;
begin
	inheritMethod(form);
	
	if self.myQuantityRangeMap = null then
		return;
	endif;
	
	aQtyMap :=self.myQuantityRangeMap.myQuantityMap;
	if aQtyMap.myParentFinancialObject.isKindOf(CM_ServiceBroker ) then
		aTransSB :=aQtyMap.myParentFinancialObject.CM_ServiceBroker;
	endif;	
	if aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_WorkOrderServiceBroker) then
		isWO := true;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then	//01 Nov 2019	NDL	TFS 47100
		isBOL := true;
	endif;
	
	allowUpdate := not self.myQuantityRangeMap.myChildQuantityMap.isDefault();

	// ### JIRA 34596 14APR2025 NAVAB1
	showLineMapping := not isVTMIS;
	if showLineMapping then
		showLineMapping := not self.allGroupMembers.first.isKindOf(CMIF_TMCQuantityRangeGroup);
	endif;
	
	form.modePropertyNew := INV_TransactionMap.ModeProperty_SubQuantity;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_SubQuantity;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_SubQuantity;
	
//	form.btnDelete.enabled := allowUpdate;
	form.btnDelete.enabled := false;	//14 Dec 2018	NDL	TFS 41957
	form.btnNew.enabled := allowUpdate;
	form.btnProperties.enabled := allowUpdate;
	//form.menuSItemDelete.visible := allowUpdate;		// TFS 39160
	form.menuSItemDelete.visible := false;				// TFS 39160
	
	form.mnuSItemUpdate.visible := showLineMapping; // ### JIRA 34596 14APR2025 NAVAB1
	
	form.menuSItemProperties.visible := allowUpdate;
	form.menuSINewSubQTYRange.visible :=true;
	form.menuSINewSubQTY.visible :=false;
	form.menuSINewQTYRange.visible :=false;
	form.btnProperties.enabled := true;
	
	if isVTMIS then
		form.menuTMVnew.visible := allowUpdate;  // MAIN VTMIS NEW MENU
	elseif isEvent then
		form.menuTMEnew.visible := allowUpdate;  // MAIN EVENT NEW MENU
	elseif isWO then
		form.menuTMWOnew.visible := allowUpdate;  // MAIN WORK ORDER NEW MENU
	elseif isBOL then //01 Nov 2019	NDL	TFS 47100
		form.menuTMBOLnew.visible := allowUpdate;  // MAIN BOL NEW MENU
	else
		form.menuSItemNew.visible := allowUpdate;  // MAIN CARGO NEW MENU
	endif;
	
epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="5b26e7f1-9e80-4788-aeda-58617cba3b11">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2017	cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time


*/

vars
	aTransSB : CM_ServiceBroker; 
	aCommMap : CM_CommodityMap;
	aQtyMap: CM_QuantityMap;
	isEvent, isVTMIS : Boolean;
	aDebtorMap : CM_DebtorMap;
	isBOL : Boolean;	//04 Nov 2019	NDL	TFS 47100
begin
 // ### JIRA 34596 14APR2025 NAVAB1	inheritMethod(form);
	
	if self.isKindOf(CMIF_TMCQuantityRangeGroupDeft) then
		return;
	endif;
	
	form.myTMCQuantityRange := self;
	aQtyMap :=self.myQuantityRangeMap.myQuantityMap;
	
	if aQtyMap.myParentFinancialObject.isKindOf(CM_ServiceBroker) then
		aTransSB :=aQtyMap.myParentFinancialObject.CM_ServiceBroker;
	elseif aQtyMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
		aDebtorMap := aQtyMap.myParentFinancialObject.CM_DebtorMap; // 17/02/2017 cnwma1 TFS #2901
		if aDebtorMap&lt;&gt; null then
			aTransSB :=aDebtorMap.myServiceBroker;
		endif;
	endif;
		
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then	//04 Nov 2019	NDL	TFS 47100
		isBOL := true;
	else
		return;
	endif;
	
	form.myCurrentMapQuantity := self.myQuantityRangeMap.myChildQuantityMap;
	form.myCurrentMapQuantityRange := self.myQuantityRangeMap;
	
	if isVTMIS then
		
	elseif isEvent then
	
	elseif isBOL then	//04 Nov 2019	NDL	TFS 47100

	else
		form.myCurrentMapDebtor := aDebtorMap;
		form.myCurrentMapServiceBroker := aTransSB;
		form.myCurrentMapCommodity := aCommMap;
		form.myCurrentMapContents := aCommMap.contentsMap;
		form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
		form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
		form.myCurrentMapProdGrp := form.myCurrentMapProduct.myProductGroupMap;
		form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
		form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;

	endif;

epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
