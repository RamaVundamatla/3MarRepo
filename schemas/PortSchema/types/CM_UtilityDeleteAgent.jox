    <JadeMethod name="utlDeleteInvoiceTMQtyRange" id="e2ef13dd-a52f-4e3a-9b8a-9475f2d69a32">
        <source>utlDeleteInvoiceTMQtyRange(pTIQuantityRangeMap : CM_QuantityRangeMap io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	qm : CM_QuantityMap;
	fsm : CM_FutureStorageMapping;
	invAlloc : CM_InvoiceAllocation;
	ica : CM_InvoiceCargoAllocation;

begin

	self.initialiseActivity();

	// ### JIRA 33083 29OCT2024 NAVAB1
	qm := pTIQuantityRangeMap.myQuantityMap;
	if qm.allQuantityRanges.size = 1 then
		app.raiseCMException(Canno_delet_defau_invoi_line_m, null,null);
		return;
	endif;

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pTIQuantityRangeMap);
	endif;

	if _passport.noErrors then
		
		if pTIQuantityRangeMap.myQuantityMap.allQuantityRanges.size = 1 then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,pTIQuantityRangeMap);
		else
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_DELETE),false,pTIQuantityRangeMap);
		endif;
		
		
		//19 May 2016	NDL	TFS 1981
		qm := pTIQuantityRangeMap.myQuantityMap;
		
		//23 Nov 2017 MPD TFS 7496
		if qm.myInvoiceAllocation &lt;&gt; null then
			if qm.myInvoiceAllocation.isKindOf( CM_InvoiceCargoAllocation) then
				ica := qm.myInvoiceAllocation.CM_InvoiceCargoAllocation;
			else
				invAlloc := qm.myInvoiceAllocation.CM_InvoiceAllocation;
			endif;
		endif;
		if ica &lt;&gt; null then				
			ica.myTransactionMap.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_DELETE), false, null); // TFS 7496
		elseif invAlloc &lt;&gt; null then				
			invAlloc.myServiceBroker.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), false, null);
		endif;
		
		
		if qm.myParentFinancialObject &lt;&gt; null then // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
			if qm.allQuantityRanges.size = 1 then
				qm := null;
			endif;
		endif;
		
		pTIQuantityRangeMap.erase(NORMAL_ERASE);
		
		//19 May 2016	NDL	TFS 1981
		if qm &lt;&gt; null then
			if qm.allQuantityRanges.isEmpty then
				fsm := qm.myFutureStorageMap;
				if fsm &lt;&gt; null then
					fsm.setStorageDetail(null);
					fsm.erase( NORMAL_ERASE );
				endif;
			endif;
		endif;
	endif;

epilog
	return;

end;</source>
        <Parameter name="pTIQuantityRangeMap" type="CM_QuantityRangeMap" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
