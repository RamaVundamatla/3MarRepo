<CollClass name="TimeArray">
    <JadeMethod name="cnEcDoSort" id="e0200f2c-4bdc-48b9-ae49-23fb72df9919">
        <lockReceiver/>
        <updating/>
        <source>cnEcDoSort(pSorterObj : CnEcSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timeValue		: Time;
	sortKeyObj		: Object;

begin
	foreach timeValue in self do
		pSorterObj.addKey(timeValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.allKeys do
		self.add(sortKeyObj.CnEcSortKey.getKey().Time);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="CnEcSorter"/>
    </JadeMethod>
</CollClass>
