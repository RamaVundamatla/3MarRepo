Return Value:		

Date		Who		Reason
03 April 2019	jlger1	Initial creation

*/

vars

begin
	if self.glCode = null then
		return false;
	endif;
	
	if self.glCode = "4102010000.018"  or
		self.glCode = "4102010000.026"  or
		self.glCode = "4102010000.080"  or
		self.glCode = "4102010000.088"  or
		self.glCode = "4102020000.018"  or
		self.glCode = "4102020000.026"  or
		self.glCode = "4102020000.080"  or
		self.glCode = "4102020000.088"   then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
