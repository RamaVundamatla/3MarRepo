    <JadeMethod name="setProxy" id="c3e6ee96-b168-4e85-87a3-0414d51494b4">
        <updating/>
        <source>setProxy(_trackedItem : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myTrackedItem	:= _trackedItem;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="a9d23791-72b1-4aa3-a634-79d8d4e10fd6">
        <source>validateMe(_passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_passport);
	
	if self.myTrackedItem = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'tracked item', 'trackedItem', null);
		app.raiseCMException(Input_required_field_trkdItem, 'trackedItem', null);
		return; //epr par 12714 10/10/06 need to return exception handler resume_next so will get a 1090 below if continue
	endif;

	if self.myTrackedItem.myStockOrderTILine &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, self.myTrackedItem.id &amp; ' is already assigned to a stock order line');
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
