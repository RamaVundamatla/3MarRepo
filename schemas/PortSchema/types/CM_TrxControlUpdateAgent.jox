    <JadeMethod name="trxUpdateBOLStops" id="1c8cde72-5e51-4226-b62d-1159321be047">
        <updating/>
        <source>trxUpdateBOLStops( _bols :CM_BOLSet;  _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2015	cnwndl1	Initial creation	Par 35426

*/

vars

	bol : CM_BOL;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;
	
	beginTransaction;
	
	foreach bol in _bols do
		reserveLock(bol);	//only I can upgrade to exclusive from this point on, but others can get share
		
		app.myUtilityUA.utlUpdateStopsForBOL( bol, _passport);
		
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_bols" type="CM_BOLSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
