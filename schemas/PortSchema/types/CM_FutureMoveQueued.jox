    <JadeMethod name="getRTQueueTask" id="bd416b58-4ed3-4a35-ba09-2a2c55c7b5ef">
        <source>getRTQueueTask(_taskType : Integer) : CM_RTQueueTask;
// ---------------------------------------------------------------------------
// Created:     Feb 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	qEntry : CM_RTQueueEntry;
	qTask : CM_RTQueueTask;
begin

	qEntry := self.getRTQueueEntry();
	
	if qEntry = null then
		return null;
	endif;
	
	foreach qTask in  qEntry.allTasks discreteLock do
		if qTask.taskType = _taskType then
			return qTask;
		endif;
	endforeach;

	return null;
end;</source>
        <Parameter name="_taskType" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getTIFromBackend" id="e0d28df5-a93f-4135-b151-b6de25f7c21b">
        <source>getTIFromBackend(_index : Integer) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     18 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc : CM_LocationsController;
	tmpTI : CM_TrackedItem;
begin
	if self.allLocationsControllers.size &gt; 1 then
		lc := self.allLocationsControllers.last;
		if _index &lt;= lc.allTrackedItems.size then
			tmpTI :=  lc.allTrackedItems[_index];
			if tmpTI.myPrimaryActualLocation = lc then
				return tmpTI;
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
