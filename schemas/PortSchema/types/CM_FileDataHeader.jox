    <JadeMethod name="createFile" id="819ca71d-e347-4eb3-b978-81cb42ea944b">
        <source>createFile(_fileName : String) : Boolean;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich  MES1011 3/9/09             

 Purpose:     Write contents of detailt to file name requested
			  This method will create, open and close file. Use method writeDetailToFile if
			  you want to control file yourself

 Parameters:  File name
 
 Returns:     False if could not create file

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

vars
	file		: File;
	fileDtl		: CM_FileDataStorageDetail;
	tmpBin		: Binary;

begin

	create file transient;
	file.mode		:=	File.Mode_Output;
	file.shareMode	:=	File.Share_Exclusive;
	file.kind		:=	File.Kind_Binary;
	file.fileName	:= _fileName;
	
	if not file.tryOpen() then
		return false;
	endif;
		
	writeDetailToFile (file);
	
	return true;
epilog
	if file &lt;&gt; null and file.isOpen then
		file.close();
	endif;
	
	delete file;
end;</source>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataAsBinary" id="39935107-9452-45d4-8621-474b2603fd87">
        <source>getDataAsBinary() : Binary;
// ---------------------------------------------------------------------------
// Created:     J Harliwich   MES1011 3/9/09
//
// Purpose:     Read file details and return as binary

//				Renamed from getBinary, and replaced getDataAsBinary in subclass
// ---------------------------------------------------------------------------
vars
	tmpBin	: Binary;
	fileDtl	: CM_FileDataStorageDetail;
begin

	foreach fileDtl in self.allFileDataStorageDetail do
// cnwdad1 25/02/2009 - PAR #18366.
//		tmpBin := tmpBin &amp; fileDtl.csvBlob.uncompress;
		if fileDtl.csvBlob.length() &gt; 0 then							// MES1011 got rid of method in subclass that did the same thing except checked length. This should check length too.
			tmpBin := tmpBin &amp; fileDtl.csvBlob.uncompressToBinary();
		endif;
	endforeach;
	
	return tmpBin;
	
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c3580249-07d1-4ab1-9f9f-57c791fff1cf">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 23 January 2007
//
//----------------------------------------------------------------------
// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 15 Feb 2023 	navhl20 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
vars

begin
	
	
	if _attrName = ETRow_FileName then
		return self.fileName;
	elseif _attrName = ETRow_Heading then
		return self.heading;
	elseif _attrName = ETRow_Size then
		return self.getFileDataStorageDetailSize.String;
	elseif _attrName = ETRow_Description then
		if self.description.length &gt; 100 then 					// ### TFS CR 55299 TASK 55520 15DEC2022 NAVAB1
			return self.description[1:100] &amp; "..."; 			// ### TFS CR 55299 TASK 55520 15DEC2022 NAVAB1
		else 													// ### TFS CR 55299 TASK 55520 15DEC2022 NAVAB1
			return self.description;
		endif;
	elseif _attrName = ETRow_AutoPrintOnKiosk then				//22.2.2023 navhl20	#56625[56517]
		if self.actionContext = FileContext_AutoPrintOnKiosk then
			return true.getYesNo;	
		endif;
		return false.getYesNo;									
	elseif _attrName = ETRow_Date then
		return self.systemToLocalTime(self.dateTime).String;	// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileDataStorageDetailSize" id="6e89126a-b04c-4163-8f84-0b13f666d612">
        <source>getFileDataStorageDetailSize() : Integer;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 23 January 2007
//
//----------------------------------------------------------------------

vars
	dataFile : CM_FileDataStorageDetail;
	int : Integer;
begin
	if self.allFileDataStorageDetail.isEmpty then
		return 0;
	endif;
	
	foreach dataFile in self.allFileDataStorageDetail do
		int := int + dataFile.csvBlob.length;
	endforeach;

	return int;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="0973f8f2-5bcf-497e-afd8-0edc9379cc92">
        <updating/>
        <source>setDetails(	_dateTime 	 : TimeStamp;
			_description : String;
			_fileName    : String;
			_heading 	 : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Mar 2018	jlger1	Initial creation
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars

begin
	self.dateTime		:=_dateTime;
	self.description	:=_description;
	self.fileName		:=_fileName;
	self.heading		:=_heading[1:50];			//15.02.2023 navma1 #56561
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromFile" id="2f123894-c669-468f-a3f5-3aa78641db25">
        <updating/>
        <source>setDetailsFromFile(_file : File; _description:String; _heading:String; _context : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2007 by #usercode
//
// Purpose:     
//15 Feb 2023 navma1 ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
//22 Feb 2023 navhl20 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
// ---------------------------------------------------------------------------
vars
	offset,
	fileLength	: Integer;
	dataLength	: Integer;
	fileData	: Binary;
	detail		: CM_FileDataStorageDetail;
begin

	self.fileName 	   := _file.fileName.fileBaseName;
	self.dateTime      := _file.createdTime.TimeStamp;
	self.heading       := _heading[1:50];									//15.02.2023 navma1 #56561
	self.description   := _description;
	self.actionContext := _context;											//22.2.2023 navhl20	#56625[56517]
	fileLength		   :=	_file.fileLength();
	dataLength		   :=	CM_FileDataStorageDetail.COPY_CHUNK_SIZE;

	while offset &lt;= fileLength do
		if (fileLength - offset) &lt; dataLength then
			dataLength	:=	fileLength - offset;
		endif;
		
		if offset &lt;&gt; 0 then
			_file.seek(offset);
		endif;
		
		fileData	:=	_file.readBinary(dataLength);
		offset		:=	offset + fileData.length;
		
		//need this to send an empty file for CAMS.  See above JC	21/06/2004
		if fileData.length() &lt; 1 then
			fileData := CrLf.Binary;
		endif;

		fileData	:=	fileData.compressToBinary(Binary.Compression_ZLib);
		
		if self.isTransient then
			create detail transient;
		else
			create detail persistent;
		endif;

		detail.set(self.fileName, fileData, null, self);
		
	
		if offset &gt;= fileLength then
			break;
		endif;
	endwhile;
	app.writeLog('File (' &amp; _file.fileName &amp; ') loaded.  Size = ' &amp; fileLength.String, LogINFO);
	
epilog

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5c9f9110-7f5d-42cd-a22a-9b48bfc94b93">
        <updating/>
        <source>setForUpdate(_pxyFile : CM_FileDataHeader) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 August 2022		jlizm1	Initial creation TFS 54298 EUP - Simplified Voyage Work Order Process
22 February 2023    navhl20 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk

*/

vars

begin
	self.dateTime 		:= _pxyFile.dateTime;
	self.description 	:= _pxyFile.description;
	self.fileName 		:= _pxyFile.fileName;
	self.heading 		:= _pxyFile.heading;
	self.actionContext  := _pxyFile.actionContext;		//22.2.2023 navhl20	#56625[56517]
epilog

end;</source>
        <Parameter name="_pxyFile" type="CM_FileDataHeader"/>
    </JadeMethod>
    <JadeMethod name="viewFile" id="06a9b3e3-4c9a-44eb-bb1f-179311f54013">
        <updating/>
        <source>viewFile(_file:String) updating;
// ---------------------------------------------------------------------------
// Created:     12 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	NoFileAssociation  = 31;
	GeneralOpenError = 32; // Any result &lt;= this indicates an error
 
vars
	result   : Integer;
	sameSize  : Boolean;
	failedToOpen : Boolean;
	fileData	: Binary;
	fileLength : Integer;
	fileEx : FileException;

begin

	app.mousePointer := Busy;
	fileData	:=	self.getDataAsBinary();
	
	if fileData.length() &lt; 1 then
		return;
	endif;
	
	on FileException do app.fileExceptionHandler(fileEx);	//15 Aug 2016	NDL	TFS 2546
	
	fileData.cnEcViewMe (_file, app.actualTimeServer, 0);
	
	// For bandwidth reasons don't download the file if it exists and
	 // is the correct size.
//	 if (self.existsAsFile(extractDir, sameSize, failedToOpen) and sameSize) or
//	   (not failedToOpen and self.extractToFile(extractDir)) then
	//node.
	/*result := call shellExecute(
		hwndCurrentForm, "open", self.filename, null, extractDir, 1);
	  app.mousePointer := Idle;
	  if result = NoFileAssociation then
	   app.msgBox("Could not open file " &amp; self.filename &amp;
		 " (in folder " &amp; extractDir &amp;
		 ").  This is most likely because there is no " &amp;
		 "program associated with files of this extension.",
		 "File Open Failed", MsgBox_OK_Only + MsgBox_Stop_Icon);
	  elseif result &lt;= GeneralOpenError then
	   app.msgBox("Could not open file " &amp; self.filename &amp;
		 " (in folder " &amp; extractDir &amp; ").",
		 "File Open Failed", MsgBox_OK_Only + MsgBox_Stop_Icon);
	  endif;
//	 endif;*/
 
epilog
 app.mousePointer := Idle;
end;
</source>
        <Parameter name="_file" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeDetailToFile" id="11490c50-2787-49ef-92c2-0df3e131d8cc">
        <source>writeDetailToFile(_file : File) ;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich  MES1011 3/9/09             

 Purpose:     Write contents of detailt to file parameter.
              Calling method must handle open/close of file.
			  Use method createFile if you want this class ot create the file

 Parameters:  File name
 
 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

vars
	
	fileDtl		: CM_FileDataStorageDetail;
	tmpBin		: Binary;

begin
		
	foreach fileDtl in self.allFileDataStorageDetail do
		if fileDtl.csvBlob = null then
			continue;
		endif;
		
		if fileDtl.csvBlob.length() &gt; 0 then
			tmpBin := fileDtl.csvBlob.uncompressToBinary();
			_file.writeBinary(tmpBin);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
</Class>
