    <JadeMethod name="setTranTypes" id="3b524a5c-2fc5-460f-bf6f-01af30d8e5ce">
        <updating/>
        <source>setTranTypes() updating;
/*
Purpose:			

Date		Who		Reason
13 July 2021	navab1	TFS 51515
*/

vars
	criteria : CM_YACriteriaPriority;
	criteriaFrame : CMUI_YACriteriaCntl;
	i : Integer;
	propCount : Integer;
	critType : CM_YACriteriaType;
	event : CM_EventType;
	allCriteriaStr : String;
begin
	criteriaFrame := self.frmTranType;
	criteriaFrame.transparent := true;
	criteriaFrame.setMasterControl(null);
	critType := CM_YATypeInventoryType.firstInstance();
	
	if critType &lt;&gt; null then
		criteriaFrame.setCriteriaType( critType );
		criteriaFrame.setLabelVisible(true);
		
		
		criteriaFrame.setWidth(560);			
		criteriaFrame.move(0, 78, 560, 40);
		criteriaFrame.visible := true;
		
		foreach event in app.myRoot.allEventTypesByType where event.isLocationActivity do
			if allCriteriaStr = null then
				allCriteriaStr:= event.name;
			else
				allCriteriaStr := allCriteriaStr &amp; ", " &amp; event.name;
			endif;
		endforeach;
		criteriaFrame.txtCriteriaValue.text := allCriteriaStr;
		self.handleYAInventoryTypeOK(allCriteriaStr);
	endif;
	criteriaFrame.formCriteriaChangeMethodName := CMUI_LocationActivityEnquiry::handleYAInventoryTypeChange.name;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a5422064-5efa-4ee7-aa24-7c0df3330939">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	inheritMethod();
	
	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.staLine.caption := "";
	self.isSelectorCapable := true;

	self.setTranTypes(); // ### TFS 51515 13JUL2021 NAVAB1
	self.setMoveDirections(); // ### TFS 51515 13JUL2021 NAVAB1
	
	self.doResize();	//19 May 2021	NDL	TFS 51229
	
	if not self.tableInitialised then
		self.initTblLocActivity();
	endif;
	
	self.txtOpenDate.setDate(app.actualTimeAppServer.date.cnEcAddDays(-7));
	
	self.cmbLocationType.clear();
	self.cmbLocationType.addItem( app.getErrorString(TerminalAreas) );
	self.cmbLocationType.addItem( app.getErrorString(Voyages) );
	self.cmbLocationType.addItem( app.getErrorString(Trains) );
	self.cmbLocationType.addItem( app.getErrorString(Vehicle_visit_records) );
	
	self.cmbCargoType.clear();
	self.cmbCargoType.myTerminal := self.myTerminal;
	
	self.setLocationCombos();
	
	self.enableButtons();
	
	self.beginClassNotification(CMEVT_LocationActivity, false, Object_Update_Event, Response_Continuous, 0);
	


epilog

end;</source>
    </JadeMethod>
