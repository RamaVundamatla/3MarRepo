    <JadeMethod name="getProdMinMaxDescription" id="25fc0ad7-ea9e-4d9f-ba24-2bb9c89a3a90">
        <source>getProdMinMaxDescription() : String;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	prodMinMax : CM_TerminalAreaProductMinMax;
	tmpStr : String;
begin
	tmpStr := app.getErrorString(CARGO_SUBTYPE) &amp; Tab &amp; "Volume MIN" &amp; Tab &amp; "Volume MAX" &amp; Tab &amp; "Weight MIN" &amp; Tab &amp; "Weight MAX" &amp; CrLf;
	foreach prodMinMax in self.allProductMinMax discreteLock do
		tmpStr := tmpStr &amp; prodMinMax.getDetailedDescription();
	endforeach;
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductMinMaxObject" id="77af8a72-c1c1-4967-984a-a622645a8862">
        <source>getProductMinMaxObject(_cargoType : CM_CargoType; _prod : CM_Product) : CM_TerminalAreaProductMinMax;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cargoType : CM_CargoType;
begin
	cargoType:=_cargoType;
	if cargoType = null and _prod &lt;&gt; null then
		cargoType:=_prod.myCargoType;
	endif;
	
	return self.allProductMinMax[null,cargoType,_prod];
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_prod" type="CM_Product"/>
        <ReturnType type="CM_TerminalAreaProductMinMax"/>
    </JadeMethod>
    <JadeMethod name="getProductMinMaxWeight" id="f59331bd-9213-48b0-a9bc-2395d6b1add2">
        <source>getProductMinMaxWeight(_productObj:CM_Product; _minimum:Integer output; _maximum:Integer output);
// --------------------------------------------------------------------------------
// Created:		04 March 2008 by cnwdad1
//
// Purpose:		Returns the minimum and maximum weight allowed for the receiver, for
//				the specified Product.
//
// Parameters:	_productObj - A reference to the Product who's limits we require.
//				_minimum - The minimum allowed weight.
//				_maximum - The maximum allowed weight.
//
// Returns:		The minimum and maximum allowed weight, as output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	minMaxObj	: CM_TerminalAreaProductMinMax;
begin
	
	if _productObj = null then
		return;
	endif;

	minMaxObj	:=	self.allProductMinMax[null, _productObj.myCargoType,_productObj];
	
	if minMaxObj &lt;&gt; null then
		_minimum	:=	minMaxObj.minWeight;
		_maximum	:=	minMaxObj.maxWeight;
	endif;
	
end;</source>
        <Parameter name="_productObj" type="CM_Product"/>
        <Parameter name="_minimum" type="Integer" usage="output"/>
        <Parameter name="_maximum" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getRawMeasurementValue" id="ee2f8de9-7cb5-4eed-815d-6889d9b66362">
        <source>getRawMeasurementValue(_rowName: String): Decimal;
/*

Date		Who		Reason
04 Apr 2014	cnwer1	Initial creation CCMS 1366
24 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

begin
	if _rowName = ETRow_TaMaxVolume or _rowName = ETRow_TaMaxVolPerCol then			// TFS 49453
		return null;

	elseif _rowName = ETRow_MaxWeight or _rowName = ETRow_MaxWeightPerCol then		// TFS 49453
		return null;
	else
		return inheritMethod(_rowName);
	endif;
epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
