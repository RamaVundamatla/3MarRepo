begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listFlags" id="b8ed8409-ebf0-4eb8-8079-1db15ad0e3d2">
        <source>listFlags(): String;
// ---------------------------------------------------------------------------
// Created:     Oct 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str: String;
begin
	str := str&amp;inheritMethod();
	if self.secondary then
		str := str&amp;"/Secondary ";
	endif; 
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveVersionCopyRefs" id="84b2f721-b0a9-400d-b517-dd98ca89d14d">
        <source>saveVersionCopyRefs(toClone: CM_Detach input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(toClone);
	toClone.otherTrackedItem := self.otherTrackedItem;
end;</source>
        <access>protected</access>
        <Parameter name="toClone" type="CM_Detach" usage="input"/>
    </JadeMethod>
    <JadeMethod name="secondary" id="7bf7a6cd-48ef-4268-a93c-e7dd0008697c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>secondary(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(SecondaryFlag);
		else
			flags := flags.getValueWithBitUnset(SecondaryFlag);
		endif;
	else
		_value := (flags.bitAnd(SecondaryFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItem" id="8b277a2e-d8c3-47e2-81ee-6bb4aa77cc51">
        <updating/>
        <source>setOtherTrackedItem(pTI: CM_TrackedItem) updating;
/* ---------------------------------------------------------------------------
Created:	28 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	
	//Par17775. ccms1045 APM - Yard Ops, new generator types.
	if pTI.isKindOf(CM_Generator) and ( pTI.CM_Generator.isNoseMounted() or pTI.CM_Generator.isUnderSlung() )
	or pTI.isKindOf( CM_Container )
	or pTI.isKindOf( CM_TILC )
	then	// 2 generator types that can be detached either from a container or from a chassis
		self.otherTrackedItem		:= pTI;
		self.otherTrackedItemId		:= pTI.id;
		self.otherTrackedItemCargoType	:= pTI.cargoType;
	
	else	// there is no other TI to be detached
		inheritMethod(pTI);
		
	endif;



end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
