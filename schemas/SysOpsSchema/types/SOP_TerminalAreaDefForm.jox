    <JadeMethod name="initTableEntDef" id="bbf0c2cb-7b0f-4645-98ef-86d65b34308b">
        <updating/>
        <source>initTableEntDef(_theTable : CM_EntryTable; _entDef : String) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	aTS : TimeStamp;	
begin


	theTable := _theTable;
	theTable.rows := 0;
	theTable.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(_entDef); 
	
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

	theTable.top 	:= 5;
