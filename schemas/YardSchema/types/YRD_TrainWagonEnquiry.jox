    <JadeMethod name="userNotify" id="13e06311-8adb-4797-ba01-31b4b62728da">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 August 2023		jlizm1	Initial creation TFS 59215 Wagon maintenance notifications

*/

vars

begin
	self.handleNotifications(eventType, theObject, eventTag, null);
epilog

end;</source>
