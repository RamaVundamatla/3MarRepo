    <JadeMethod name="searchStart" id="7d0ae7ce-e543-44ba-ac29-b4b4ddb23c63">
        <updating/>
        <source>searchStart( _useYACriteria : Boolean ) updating;

/*

Purpose:			Show search form and initiate search

Parameters:			_useYACriteria - display criteria from currently selected Yard Allocation 

Return Value:		


Date				Who		Reason
08 September 2008	consw1	Initial creation

*/

vars
	theForm : CMUI_YACriteriaSearchForm;
	
begin
	theForm := app.loadForm(CMUI_YACriteriaSearchForm, CMUI_Assistant, false, false, true, self.getTerminal, null).CMUI_YACriteriaSearchForm;
	if theForm = null then
		return;
	endif;

	theForm.set( self.mySearchParameters );

	if _useYACriteria then
		theForm.populateYACriteria( self.getSelectedObjectsYA() );
	endif;
	
	theForm.setParentForm(self.myForm.CM_BaseForm);
	theForm.showModal();
	
	if theForm.modalResult = IDOK then
		self.doSearchYAs();
	endif;

epilog
	delete theForm;
end;</source>
        <Parameter name="_useYACriteria" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectAllYA" id="0ca25cb8-3c55-4808-a702-71a3376eb5e7">
        <updating/>
        <source>selectAllYA() updating;
//19 February 2009	cnwdw1	
//05 Jan 2012	NDL	Par 28889 - Provide unselect functionality if All allocations are selected.
vars
	numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
	hasAtleastOneSelected : Boolean;
	hasAtleastOneUnSelected : Boolean;
begin

	numRows := self.rows;
	
	//what is the current state of the 'allocation' lines
	if numRows &gt; self.fixedRows then
		foreach rowIdx in self.fixedRows + 1 to numRows do
			jRow := self.accessRow(rowIdx);
			if not self.isAllocationRow(rowIdx) then
				continue;
			endif;
			if jRow.selected then
				hasAtleastOneSelected := true;
			else
				hasAtleastOneUnSelected := true;
				break;
			endif;
		endforeach;
	endif;
	
	self.allSelectedObjects.clear();
	
	if hasAtleastOneUnSelected then
		//select them all
		foreach rowIdx in self.fixedRows to numRows do
			jRow := self.accessRow(rowIdx);
			if not jRow.visible or not self.isAllocationRow(rowIdx) then
				continue;
			endif;
			jRow.selected := true;
			if jRow.itemObject &lt;&gt; null then
				self.allSelectedObjects.add(jRow.itemObject);
			endif;
		endforeach;
	elseif hasAtleastOneSelected then
		//unselect them all.
		foreach rowIdx in self.fixedRows to numRows do
			jRow := self.accessRow(rowIdx);
			jRow.selected := false;
		endforeach;
	else
		//nothing to do
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setExpanded" id="3d66d6aa-8e4f-49c6-bd81-7d0afc31c641">
        <updating/>
        <source>setExpanded(row: Integer; _value: Integer) updating;
//22 August 2008	cnwdw1	
// 
vars
	column: Integer;
begin
	column := self.getColumnByRowName(ETRow_HideShow);
	if _value = Expand then
		self.accessCell(row, column).picture := app.myRoot.getConfig(PicYAMExpand).Binary;
	elseif _value = Collapse then
		self.accessCell(row, column).picture := app.myRoot.getConfig(PicYAMCollapse).Binary;
	elseif _value = NoRows then
		self.accessCell(row, column).picture := null;
	endif;
end;</source>
