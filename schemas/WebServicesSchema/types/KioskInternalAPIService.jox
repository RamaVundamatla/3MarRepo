    <JadeMethod name="postTrailerType" id="383942ef-ceb5-4d5b-9ce9-c6436c9f03df">
        <updating/>
        <source>postTrailerType(request : WS_KioskTrailerRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2023	jlier1	Initial creation 59732 
12 Jan 2024 navlc30 Bug 61957: FR | 57937 - [TKT: 61898] - Kiosk - US.050 'b'
17 Apr 2024 navlc30 ChangeRequest 63714: EUP | FR | 53984 - Kiosk - Further issues and Remedial work - Issue 2
10 Jul 2024 navsck1 Defect 65010: MTN - Mobile Apps - Truck Loader / Unloader is no longer return the warning message 79688 (Unavailable for Release)
02 Oct 2024 navsck1 MTN-19665 EUP |  Kiosk -save truck visit on final confirmation webservice
*/

vars
	response : WS_Response;
	gateLane : CM_GateAreaLaneController;
	vbts			: CM_VehicleBookingTimeSlot;
	vbsItem 		: CM_VehicleBookingTimeSlotItem;
	reference : String; 
	terminal  : CM_Terminal;
	trailerType : CM_TILCType;
	kiosk : CM_Kiosk;
	printer  : CM_PrinterDef;
	pxyVVR	 : CM_VehicleVisitRecord;
	//vvr : CM_VehicleVisitRecord;
	//realEntities,
	//entityArray : CMGTE_EntityArray;
	//tmpController	: CMIF_FlexiGateController;
	//pxyChassisIn : CMGTE_TILC;
	//pxyChassisOut		: CMGTE_Release;
	instructionCode		: String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.httpStatusCode := HttpResponseUnauthorized;	
	create response transient;
	
	self.initialisePassportKiosk(gateLane);
		
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	response.result:=HttpResponseNoContent;
	self.httpStatusCode:=HttpResponseNoContent;	
	
	
	terminal:=app.myPassport.myTerminal;
	trailerType:=app.myRoot.allTILCTypes[null,request.id];
	kiosk:=gateLane.getKiosk;
	printer:=gateLane.getPrinter;
	
	if trailerType = null then
		app.raiseCMException1(ERR_INVALID_TRAILER_TYPE, request.id, ETRow_TrailerType , self);
		response.result:=HttpResponseClientError;
		self.httpStatusCode :=HttpResponseClientError;	
		return response;
	endif;
	
	foreach reference in request.references do : outerLoop
		vbts:=null;
		vbts:=terminal.myVehicleBookingTerminal.allVBTimeslotsById[reference];
		if vbts = null then
			vbts:= terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[reference];
		endif;
		if vbts = null then
			app.raiseCMException1(Vehicl_bookin_found_with_refer,reference,null,null);
			break;
		endif;
		//if vbts.myVBTimeSlotType = null or not vbts.myVBTimeSlotType.kioskCheck then					//12.01.2024 navlc30 #61957
		if not vbts.kioskCheck then																		//12.01.2024 navlc30 #61957
			app.raiseCMException(Vehicl_bookin_not_valid_kiosk,null,null);
			break;
		endif;
		//vvr:=vbts.myVehicleVisitRecord;
		foreach vbsItem in vbts.allVehicleBookingItems discreteLock do
			if  not vbsItem.validateTrailerType(trailerType, instructionCode) then										//22.04.2024 navlc30 #63714		
				app.raiseCMException2(Incor_trail_type_instr_gate_of,trailerType.code,instructionCode,null,null);
			endif;
		endforeach;
	endforeach;
	//Below commented code will be removed after all the webservice modified for new kiosk flow
	/*
	//jlier1 TFS 60908 18/10/23
	if vvr &lt;&gt; null and vvr.ownerTrailerID &lt;&gt; null and vvr.myInCMGTE_Chassis = null then	
		beginLoad;
			pxyVVR:=vvr.pxyCreateUpdateProxy;
		endLoad;
		pxyChassisIn:=pxyVVR.pxyGetInChassis;
		create entityArray transient;
		create tmpController transient;
		tmpController.myTerminal			:= vvr.myTerminal;
		tmpController.myVehicleVisitRecord 	:= pxyVVR;
		tmpController.jobType 				:= CMGTE_Entity.JobType_ChassisIN;
		tmpController.id 					:= vvr.ownerTrailerID;
		tmpController.weightTare			:= trailerType.tareWeight;
		tmpController.imexStatus			:= TI_IMEX_STATUS_REMAINONBOARD;
		tmpController.myChassisType := trailerType;
		tmpController.cargoType 	:= trailerType.myCargoType.id;  //epr par 31956 5/7/13
		tmpController.height		:= trailerType.height; //jlier1 TFS 55015 7/12/22
		tmpController.length		:= trailerType.length; //jlier1 TFS 55015 7/12/22
		tmpController.width			:= trailerType.width;
		tmpController.myCarrier		:=vvr.getMyCarrier;
		tmpController.numItems             := 1;
		if vvr.allGateEntities.first &lt;&gt; null then
			tmpController.operatorCode	:=vvr.allGateEntities.first.operatorCode;
		endif;
		 
		
		pxyChassisIn.setPXYFromController(tmpController);
		entityArray.add(pxyChassisIn);		
		
		// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1 Silent Dead Lock Retry
		app.myPassport.setupForDeadlockReplay(125, 2000);
		while true do
			app.myTrxCA.trxCreateInOutFlexiGateEntitys(vvr, entityArray,realEntities, true, app.myPassport, false);
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;

		endwhile;
	endif;
	*/
	
	if app.myPassport.hasErrors then
		response.result:=HttpResponseClientError;
		self.httpStatusCode :=HttpResponseClientError;
		return response;
	endif;
	
	return response;
	
epilog
	if kiosk &lt;&gt; null and app.myPassport.hasErrors then
		kiosk.printKioskErrorsFromPPErrors(printer,request.truckNo.toUpper,request.references.asCSV(false) );
	endif;
	delete pxyVVR;
	//delete entityArray;
	//delete tmpController;
	
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;

	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_KioskTrailerRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postValidateToken" id="fbbfcc1a-8fac-4123-8ca4-66960659d32a">
        <updating/>
        <source>postValidateToken(_token : WS_ValidateTokenRequest) :String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2023	jlier1	Initial creation 59732 

*/

vars
	response : String;
	user: CM_User; 
	terminal: CM_Terminal; 
	gateLane : CM_GateAreaLaneController;
	result : Boolean;
	sessionId : String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.startCnTrx:= cnStartTransaction(method.qualifiedName[1:CN_TRANSACTION_ID_MAXLENGTH]);
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053

	app.createPassport();

	self@validateJWT(_token.token,false,user,terminal,gateLane);
	
	sessionId:=JadeJWTParser@getClaimValue(_token.token, CMIF_WSClaimsObj.JWT_CLAIM_SESSION); 
	self.httpStatusCode := HttpResponseOK;
	result:=true;
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseUnauthorized;	
		result:=false;
		app.myPassport.clearErrorsWarnings;
	endif;
	app.writeLog(method.qualifiedName &amp; "result = " &amp; result.String, LogTRACE);		
	response := '{ "result": ' &amp; result.String &amp;  ', "sessionId": "' &amp; sessionId &amp; '" }';
	
	return response;
epilog
	finaliseJSONResponse(response);	
	return response;
end;</source>
        <Parameter name="_token" type="WS_ValidateTokenRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="transformRequest" id="cf3036b2-3e42-4b37-a73f-c8897e645315">
        <updating/>
        <source>transformRequest(_httpIn: String; _queryStr: String; _pathIn: String; _methodType: String): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2023	jlier1	Initial creation

*/

vars

begin
	return _httpIn;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_httpIn" type="String"/>
        <Parameter name="_queryStr" type="String"/>
        <Parameter name="_pathIn" type="String"/>
        <Parameter name="_methodType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateJWT" id="cc399fcf-f143-49e3-a913-8792ce089a7a">
        <options>4</options>
        <source>validateJWT(_token: String; _isRefreshToken: Boolean; _user: CM_User output; _terminal: CM_Terminal output; _gateLaneController : CM_GateAreaLaneController output) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2023	jlier1	Initial creation 59732 

*/

vars
	appName			: String;
	envName			: String;
	terminalCode 	: String;
	terminal		: CM_Terminal;
	issuer			: String;
	subject			: String;
	secret			: String;
	error			: String;
	hadError		: Boolean;
	audiences		: StringArray;
	audience		: String;
	userCode		: String;
	user			: CM_User;
	nonce			: String;
	nonceKeyName	: String;
	kioskID 		: String;
	gateLaneController : CM_GateAreaLaneController;
begin
// Bail early if we don't even have a token
	if _token = null then
		app.raiseCMException1(ErrApiAuthInvalid, "Token Not Found", null, null);
	endif;
	
	appName := app.getNiceName;
	envName := app.getEnvName.toUpper;
	
	// A bit ass about face, but lets get the terminal from the token first
	terminalCode := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIM_TERMINALID); // 01 Aug 2022 navlw1 tfs 53854 
	if terminalCode &lt;&gt; null then
		terminal := app.myRoot.allTerminals[terminalCode];
	endif;
	if terminal = null then
		app.raiseCMException1(ErrApiAuthInvalid, "Invalid TerminalId", null, null);
	endif;
	
	// then we can work out the secret to actually validate the thing!
	if not _isRefreshToken then
		secret := terminal.getConfig(JWTAccessKey).String;
	else
		secret := terminal.getConfig(JWTRefreshKey).String;
	endif;
	
	// 1. Make sure the token hasn't been tampered with
	if not JadeJWTValidator@validateSymmetricToken(_token, secret, error) then
		app.raiseCMException1(ErrApiAuthInvalid, "Unable to verify token. Token may be invalid or has been tampered with: " &amp; error, null, null);
	endif;
	
	// 2. Make sure the token hasn't expired
	if not JadeJWTValidator@verifyExpiryClaim(false, _token) or not JadeJWTValidator@verifyNotBeforeClaim(true, _token) then
		app.raiseCMException1(ErrApiAuthInvalid, "Token expired or for the future", null, null);
	endif;
	
	// 3. Make sure the token was issued by us
	if not JadeJWTValidator@verifyIssuerClaim(_token, envName) or not JadeJWTValidator@verifySubjectClaim(_token, appName) then
		issuer := JadeJWTParser@getIssuer(_token);
		on Exception do app.cnHandleNullOrInvObjectRef(exception, null, hadError);
		subject := JadeJWTParser@getSubject(_token);	// This currently results in a 1090 - Contact 68876 opened to fix
		on Exception do null;
		if hadError then
			subject := "**invalid**";
		endif;
		app.writeLog(method.qualifiedName &amp; Tab &amp; " Token not issued by us. Got [" &amp; issuer &amp; "," &amp; subject &amp; "] expected [" &amp; envName &amp; "," &amp; appName &amp; "]", LogERROR);
		app.raiseCMException1(ErrApiAuthInvalid, "Token not issued by " &amp; appName, null, null);
	endif;
	
	// 4. Make sure the audience is someone we know
	// No way to know this at this pooint in time... so skipping
	create audiences transient;
	JadeJWTParser@getAudiences(_token, audiences);
	if audiences.size &lt; 1 then
		app.raiseCMException1(ErrApiAuthInvalid, "Token has no audience", null, null);
	endif;
	audience := audiences[1];
	
	// 5. Make sure the user is still valid
	userCode := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIM_USERID); // 01 Aug 2022 navlw1 tfs 53854 
	if userCode &lt;&gt; null then
		user := app.myRoot.allUsers[userCode];
		if user &lt;&gt; null then
			if user.allUserTerminals[terminal] = null then
				user := null;
			elseif user.isSuspendedOrIsDisabled() then
				user := null;
			endif;
		endif;
	endif;
	if user = null then
		// We're not really leaking more info here, as both userCode and terminalCode are already present in the JWT
		app.raiseCMException1(ErrApiAuthInvalid, "User [" &amp; userCode &amp; "] not valid or no longer has access to Terminal [" &amp; terminalCode &amp; "]", null, null);
	endif;
	
	kioskID:=JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIM_KIOSKID); 
	
	gateLaneController:=terminal.getGateLaneControllerFrmLaneID(kioskID);
	if gateLaneController = null then
		app.raiseCMException1(ErrApiAuthInvalid, "Invalid Kiosk ID", null, null);
	endif;
	// 6. Make sure the token hasn't been revoked/replayed
	nonceKeyName := (WS_WebServiceAgent.JWT_NONCE_KEY &amp; "_" &amp; appName &amp; "_" &amp; terminal.code &amp;"-" &amp; kioskID)[1:CM_StateData::key.length];
	nonce := user.getStateData(ConfigGrp_Web, nonceKeyName).String;
	if nonce = null then
		app.raiseCMException1(ErrApiAuthInvalid, "Token has been removed", null, null);
	endif;
	if not JadeJWTValidator@verifyJwtIdClaim(_token, nonce) then
		app.raiseCMException1(ErrApiAuthInvalid, "Token has been revoked", null, null);
	endif;

	
	
	// So far, so good
	_user := user;
	_terminal := terminal;
	_gateLaneController:=gateLaneController;
epilog
	delete audiences;
end;</source>
        <Parameter name="_token" type="String"/>
        <Parameter name="_isRefreshToken" type="Boolean"/>
        <Parameter name="_user" type="CM_User" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="output"/>
        <Parameter name="_gateLaneController" type="CM_GateAreaLaneController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="validateLicense" id="097517f1-1193-4d19-9d3a-99b8ba635d2e">
        <source>validateLicense(path: String): Boolean;
/*

Purpose:			Validates KioskAPI Subscription License

Parameters:			

Return Value:		

Date				Who		Reason
18 October 2023		jlizm1	Initial creation TFS 59606 Kiosk license

*/

vars

begin
	if app.myRoot.canDo(Sub_DriverKioskWeb) then
		return true;
	endif;
	
	app.writeLog("KIOSK API: Kiosk Api Subscription not Active", LogERROR);
	if app.myPassport = null then
		app.createPassport();
	endif;
	
	app.myPassport.addErrorFull(NotLicensedToPerformAction, app.getErrorString1(NotLicensedToPerformAction, app.getPermissionName(Sub_DriverKioskWeb)), null, null, null);
	app.raiseCMException1(NotLicensedToPerformAction, app.getPermissionName(Sub_DriverKioskWeb), null, null);
	return false;

epilog

end;</source>
        <Parameter name="path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
