    <JadeMethod name="getOverlayFrame" id="7acd8ebd-4045-439f-9de8-1efe30316da0">
        <source>getOverlayFrame(_drawing : Boolean) : YRD_ContainerOverDrawingFrame;
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _drawing then
		return self.myDrawingFrame.myOverlayDrawingFrame;
	else
		return self.myDrawingFrame.myOverlayViewingFrame;
	
	endif;
end;</source>
        <Parameter name="_drawing" type="Boolean"/>
        <ReturnType type="YRD_ContainerOverDrawingFrame"/>
