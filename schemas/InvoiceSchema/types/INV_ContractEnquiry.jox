    <JadeMethod name="displaySelectorResults" id="15bc7026-0dc5-4b74-9f86-83d22bffd81e">
        <updating/>
        <source>displaySelectorResults(_resultCollection : Collection; _mode : Integer) updating;
/*

Date				Who		Reason
16 February 2023	navmv20	TFS 55649 Task 56228: UI - Selector Dialog for Contracts

*/
vars
	thisObjTerminal		: CM_Terminal;
	invalidObject		: Boolean;
	pd					: CMS_Progress;
	lastUpdate			: Decimal [20];
	idx 				: Integer;
	anInvoiceContract 	: CM_InvoiceContract;
	otherTerminal       : Boolean;
	
begin
	 
	self.mousePointer := Window.MousePointer_HourGlass;
	
	on CM_ProgressException do haltProgress(exception);
	self.otherTerminal := false;
	
	self.tblData.rows := self.tblData.fixedRows;
	
	self.tblData.clearAllSelected();
	self.doNotableClear();
	
	self.allInvContracts.clear();
	_resultCollection.copy(self.allInvContracts);
	
	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction(app.getErrorString(Loading_invoice_contracts));
	
	if self.allInvContracts &lt;&gt; null then
		if not self.doMaxTableSizeCheck(self.allInvContracts.size(), null) then
			return;
		endif;
		
		pd.progress.partsInJob := self.allInvContracts.size;

	foreach anInvoiceContract in self.allInvContracts as CM_InvoiceContract do 
		idx := idx + 1;
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
				pd.setAction(app.getErrorString(Loading_invoice_contracts));
				pd.progress.partsDone := idx;
				lastUpdate := app.relativeMachineTime;													
			endif;	
		invalidObject := false;
		
		thisObjTerminal := anInvoiceContract.myTerminal;
		
		// Skip any invalid objects
		if invalidObject then
			continue;
		endif;
		
		// Skip any from other than the first terminal
		if self.myTerminal &lt;&gt; null and thisObjTerminal &lt;&gt; self.myTerminal then
			self.otherTerminal := true;
			continue;
		endif;
		// Otherwise, add it to the table
		self.addRowToTable(anInvoiceContract);
			
		if self.tblData.rows = JadeTableRowLimit then
			break;
		endif;
	endforeach;
	
	endif;
	
	self.setLblTablDetail();
	
epilog
	delete pd;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBtnAttachmentClick" id="4130b065-ded3-44ad-b7f9-0f39ceaa8505">
        <source>doBtnAttachmentClick();
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars

begin
	if self.tblData.allSelectedObjects.first = null then
		app.msgBox(app.getErrorString(Please_select_contract),app.getErrorString(Warning),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	self.myAssistant.showFileAttachmentsForm( self.tblData.allSelectedObjects.first.CM_Object, self.myMasterMenuAction);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnAuditClick" id="9d7019ee-25ca-4a33-9518-f35bc6c44270">
        <source>doBtnAuditClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navrv30	Bug 58391: EUP - Audits for Invoice Copy
16 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results

*/

vars
	contract		: CM_InvoiceContract;
	invoiceContractDetails : CM_InvoiceContractDetails;
	contractRateEntryDates : CMIF_ContractRateEntryDates;
	contractRate :  CM_InvoiceContractRate;
begin
		
	if self.fldMain.topSheet = self.shtContract then																		//16.10.2024 navlc30 #19508
		contract := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContract;	
		if contract = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
	
		app.viewAuditFormModal(contract, self.myAssistant.class, self.myTerminal);
		
	elseif self.fldMain.topSheet = self.shtDetails then																					
		invoiceContractDetails := self.tblDetails.accessRow( self.tblDetails.row).itemObject.CM_InvoiceContractDetails;
		if invoiceContractDetails = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
	
		app.viewAuditFormModal(invoiceContractDetails, self.myAssistant.class, self.myTerminal);
		
	elseif self.fldMain.topSheet = self.shtRate then
		contractRateEntryDates := self.tblRates.accessRow(self.tblRates.row).itemObject.CMIF_ContractRateEntryDates;
		if contractRateEntryDates = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		contractRate := contractRateEntryDates.allInvoiceContractRateEntries.first.myInvoiceContractRate;	
		app.viewAuditFormModal(contractRate, self.myAssistant.class, self.myTerminal);
		
	endif;	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnBulkUpdate" id="7daa8f9e-4feb-457b-b78b-24b4b0c3476d">
        <updating/>
        <source>doBtnBulkUpdate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023  navmv20 TFS 55651 Task 57072: UI - Contract Bulk Edit UI

*/

vars
	form 		: INV_ContractBulkRateEntry;
	bank 		: CM_Bank;
	invcontract : CM_InvoiceContract;
	objSet 		: CM_InvoiceContractSet;
	rowSt,
	rowEnd ,
	index  		: Integer;
begin

	rowSt := tblData.fixedRows + 1;
	rowEnd := tblData.rows;
	create objSet transient;
	foreach index in rowSt to rowEnd do
		if tblData.accessRow(index).selected then
			invcontract := tblData.accessRow(index).itemObject.CM_InvoiceContract;
			objSet.add(invcontract);
		endif;
	endforeach;
	if objSet.isEmpty then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	form := app.loadForm(INV_ContractBulkRateEntry, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractBulkRateEntry;
	
	if form &lt;&gt; null then
		form.setInvoiceContracts(objSet);
		form.centreWindow();
		form.showModal;
	endif;
	
	
epilog
	delete objSet;
end;</source>
    </JadeMethod>
