    <JadeMethod name="permCheckNum" id="44faea81-b29e-47c2-91ba-c4638a283dea">
        <source>permCheckNum(_perm : Integer; _str : String io) protected;
// ---------------------------------------------------------------------------
// Created:     14 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	canDo	: Boolean;
	idx		: Integer;
begin

	canDo := self.canDo(_perm);
	idx := 10 - (_perm - PmNum01);
	if canDo then
		_str[idx] := '1';
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_perm" type="Integer"/>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="resetAuditedClassProperties" id="71ce5d10-3ab8-4687-b8a8-eae7436890d8">
        <source>resetAuditedClassProperties();
// ---------------------------------------------------------------------------
// Created:     01 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/02/2011	cnwdap1		PAR #26861 CCMS POL 2031 add destinationTerminal to audited attributed
//02 Oct 2012	cnwrs1		par 30468 audit cargo Weight
// 04/05/2016	cnwdap1		TFS #1699 verified Gross Mass changes
// 22 Feb 2018	jlgsl4		TFS 37088 - use plannedDT instead of hireDT
// 14 Nov 2019	jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
// 08 Jan 2020  cnwma1		Bug 48173: PRP - Customs date.
// 02 Oct 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
// 15 Jun 2022	navsrk20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
// 24 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
// 20 Feb 2023	jlika1		TFS 56496 CUX - Add attribute to cargo (to allow for conversions of MAFI types)
// 27 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
// 20 Oct 2023	jlika1 		TFS 60946 POB - No Edit transaction created on updating Port of Origin
// 13 Nov 2023	jlika1		TFS 61130 61013 CUX | Cargo Priority - Cargo Maintenance
// 11 Dec 2023	jlika1		TFS 61189 61645 RTL - Cargo Maintenance
// 29 Mar 2024	navdap1		TFS 63075 CUX | No Transaction created when Update custom References Via PUT cargo
// 06 Jun 2024 	navhn30 	Bug 63629: CUX | CARGO APIs - Transactions missing for Additional Fields for PUT/cargo
// ---------------------------------------------------------------------------
vars
	clsCol	: ClassColl;

begin
	create clsCol transient;
	
	self.allAuditedClassProperties.purge();

