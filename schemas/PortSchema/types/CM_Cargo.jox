    <JadeMethod name="validateForDefault" id="1192751b-baa9-4ba2-85f3-4877c312bae7">
        <updating/>
        <source>validateForDefault(pControl: CMIF_TIUpdateController input; _passport: CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 April 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 23/09/2013	cnwdap1		PAR #32215 CCMS DPH 2290 New Car Attributes
// 23 July 2022 navhl20 	TFS 53862 EUP - WMS - Damage Recording Extra Details
vars

begin
	if pControl.mode = TI_UPDMODE_NORMAL or
	   pControl.mode = TI_UPDMODE_RECEIPT then
		// Now do the checks which are dependent on the earlier checks
		self.validateCargoType(pControl);
		self.validateId(pControl);
//		self.validateImExStatus(pControl);
		//self.validateStatus(pControl);
		self.validateOperator(pControl, _passport);
		self.validateCommodity(pControl);
		self.validateDamageInstances(pControl);			//23 July 2022 navhl20 TFS 53862
		
		self.validateColour();							// PAR #32215
		self.validateMAFIVoyage(null);		//jlier1 TFS 65290 24/7/24		
		
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
