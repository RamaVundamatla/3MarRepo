    <JadeMethod name="setTIHazards" id="980378bc-3955-4326-9db9-9976a6fd0692">
        <updating/>
        <source>setTIHazards(_tmpHazards: CM_HazardByCodeDict) updating;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	haz		: CM_Hazard;
	tiHaz	: CM_TIHazard;
begin

	self.allTIHazards.purge;

	foreach haz in _tmpHazards do
		create tiHaz transient;
		tiHaz.setForCreate(haz, null, app.myPassport);
		self.allTIHazards.add(tiHaz);
	endforeach;
	
	
end;</source>
        <Parameter name="_tmpHazards" type="CM_HazardByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="validate" id="1d6b28e5-2626-4593-8460-3779044c0550">
        <updating/>
        <source>validate() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	masterInterface : CMIF_Receival;
	masterIFDkt 	: CMIF_BOL;
	child 			: CM_TrackedItem;
	
begin

	if self.myMasterObject.isKindOf(CMIF_Receival) then
		masterInterface := self.myMasterObject.CMIF_Receival;
	elseif self.myMasterObject.isKindOf(CMIF_BOL) then
		masterIFDkt := self.myMasterObject.CMIF_BOL;						
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'myMasterItem is null for attachment');
		return false;
	endif;
	
	if masterInterface &lt;&gt; null then
		if masterInterface.myProxyTrackedItem = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'myMasterItem.myProxyTrackedItem is null for attachment');
			return false;
		endif;
	endif;

	if masterIFDkt &lt;&gt; null then
		if masterIFDkt.myProxyBOL = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'myMasterItem.myProxyDocket is null for attachment');
			return false;
		endif;	
	endif;
	
	//Create this TI as proxy and attach to myMasterItem proxy TI
	if self.myProxyTrackedItem &lt;&gt; null then
		if self.myProxyTrackedItem.cargoType &lt;&gt; self.myCargoType.id then
			// need to erase and re-create
			self.myProxyTrackedItem.erase(NORMAL_ERASE);
		else
			child := self.myProxyTrackedItem;
		endif;
	endif;

	if self.myCargoType = null then
		app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(CargoType) &amp; ' (null), item "' &amp; self.id &amp; '", ', app.getErrorString(Select_cargo_type_again), 'myCargoType', null);
		return false;
	endif;
	
	//cnwmc5 - 9 March 2015 - PAR 34346
	//if ((not self.myCargoType.isSystemCargoBOLType)
	//and self.myProduct = null ) then
	if self.myCargoType.hasProductTypes()
	and self.myProduct = null then
	
		app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Cargo_subtype) &amp; ' (null), item "' &amp; self.id &amp; '", ', app.getErrorString(Select_cargo_subtype_again), 'myProduct', null);
		return false;
	endif;

	

	if child = null then
		child := self.myTerminal.createTI(self.myCargoType, true);
	endif;

	child.setPxyFromCMIF_InOutAttachment(self, app.myPassport);
	
	self.myProxyTrackedItem := child;

	return true;
		
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="53b7405d-5713-46d0-a33f-5c2b08e458b4">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input): Boolean updating;

vars
	masterRec : CMIF_Receival;
begin

	if (not self.validate) then
		return false;
	endif;
	
	// Because when creating a Road In/Out this method is still called even if we are receiving
	// a pre-notified item we do the "includes" check.  In this situation it is really an "edit"
	if self.myMasterObject.isKindOf(CMIF_Receival) then
		//if (not self.myMasterObject.CMIF_Receival.myProxyTrackedItem.allChildren.includes(self.myProxyTrackedItem)) then
		if (not self.myMasterObject.CMIF_Receival.myProxyTrackedItem.hasChild(self.myProxyTrackedItem)) then//PAR 22954
			self.myMasterObject.CMIF_Receival.myProxyTrackedItem.attachChild(self.myProxyTrackedItem, _passport);
		endif;
	endif;

	if self.myMasterObject.isKindOf(CMIF_BOL) then
		if (not self.myMasterObject.CMIF_BOL.myProxyBOL.allTrackedItems.includes(self.myProxyTrackedItem)) then
			self.myMasterObject.CMIF_BOL.myProxyBOL.attachTI(self.myProxyTrackedItem);
		endif;
	endif;

	return true;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="7d54120d-1470-454a-99c5-692f8e8eb002">
        <updating/>
        <source>validateForUpdate(_passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	master : CMIF_TIObject;
	proxyTI : CM_TrackedItem;	
begin

	if (not self.validate) then
		return false;
	endif;
	
	if self.myMasterObject.isKindOf(CMIF_Receival) then
		//if (not self.myMasterObject.CMIF_Receival.myProxyTrackedItem.allChildren.includes(self.myProxyTrackedItem)) then//PAR 22954
		if (not self.myMasterObject.CMIF_Receival.myProxyTrackedItem.hasChild(self.myProxyTrackedItem)) then
			self.myMasterObject.CMIF_Receival.myProxyTrackedItem.attachChild(self.myProxyTrackedItem, _passport);
		endif;
	endif;
	
	if self.myMasterObject.isKindOf(CMIF_BOLIn) then
		//attachements already OK for BOLIn - no need to reattach
		if self.myLocationsController = null then
			if self.myProxyTrackedItem = null
			or (self.myProxyTrackedItem &lt;&gt; null and self.myProxyTrackedItem.site = TI_SITE_OFFSITE) then
				return true;
			endif;
			app.raiseCMException2(ERR_INVALID_VALUE, 'Location (null), item "' &amp; self.id &amp; '",', "Select a location for this item and try again.", 'myLocationsController', null);
			return false;
		endif;
		return true;
	endif;
	
	if self.myMasterObject.isKindOf(CMIF_BOL) then
		if (not self.myMasterObject.CMIF_BOL.myProxyBOL.allTrackedItems.includes(self.myProxyTrackedItem)) then	
			self.myMasterObject.CMIF_BOL.myProxyBOL.attachTI(self.myProxyTrackedItem);
		endif;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
