    <JadeMethod name="setControlsForAddEdit" id="6f1b421d-d5f6-4bcc-99ba-9132a9d981e5">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin

	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;	//13 Oct 2010	NDL Par 23991
	theForm.mulSelect2.userInputEnabled := true;	//13 Oct 2010	NDL Par 23991
				
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);	//29 Jul 2011	NDl	Par 27890
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Ports);
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.setFocus;
		theForm.mulSelect1.setSelected(null);	//13 Oct 2010	NDL Par 23991
		theForm.mulSelect2.setSelected(null);	//13 Oct 2010	NDL Par 23991
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_MTGrade);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Ports);
		theForm.mulSelect1.setSelected(theForm.myProxyObject.CM_MTGrade.allAllowedReleaseTerms);	//13 Oct 2010	NDL Par 23991
		theForm.mulSelect2.setSelected(theForm.myProxyObject.CM_MTGrade.allAllowedEditSubTerms);	//13 Oct 2010	NDL Par 23991
	endif;
	
	self.enableMulSelect1Contents();	//13 Oct 2010	NDL Par 23991
	self.enableMulSelect2Contents();	//13 Oct 2010	NDL Par 23991
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="10cf6f05-1069-4398-8bff-415afef74faa">
        <updating/>
        <source>setCtrlsForView() updating;

