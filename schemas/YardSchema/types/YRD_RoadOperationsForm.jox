/*

Purpose:			


Return Value:		


Date		Who		Reason
07 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	wle : CM_WorkListEntry;
	req	: CM_Request;
	delReq	: CM_DeliveryRequest;

begin

	
	//05 Aug 2014	NDL	Par 34675
	wle := self.mnuComplete.userObject.CM_WorkListEntry;
	if wle &lt;&gt; null then
		req := wle.myRequest;
		if req &lt;&gt; null and req.isAnyId then
			delReq	:= req.CM_DeliveryRequest;
		endif;
	endif;
	
	if delReq &lt;&gt; null then	//05 Aug 2014	NDL	Par 34675
		app.myTrxUA.trxCompleteAnyIdExtraTasks(delReq, app.myPassport);
		
	else
		self.setToDoTaskComplete();
	
	endif;

epilog

end;</source>
