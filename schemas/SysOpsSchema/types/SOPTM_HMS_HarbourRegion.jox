    <JadeMethod name="create" id="f71723af-22a4-4279-b9b5-8ac8af34ccb3">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_HarbourRegion;
	self.permissionView	 := PmHMSRegionView;
	self.permissionMaint := PmHMSRegionMaint;
	self.myDataClass := HMS_HarbourRegion;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="258c153d-9533-4c83-ac3b-ebefc69c1a7a">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyHarbourRegion : HMS_HarbourRegion;
	theForm 		: SOP_HMS_TableMaintForm;
	theHarbour		: HMS_Harbour;
	theTerminal		: CM_Terminal;
	thePreferredBerth : HMS_Berth;
	allCheckPoints 	: HMS_CheckPointByTypeDict;
begin

  	theForm := self.myForm.SOP_HMS_TableMaintForm; 
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_HarbourRegion transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyHarbourRegion := theForm.myProxyObject.HMS_HarbourRegion;
	theForm.tblInput1.setObjectFromTable(pxyHarbourRegion, null, false);
	theHarbour := theForm.cmbHarbour.listObject.HMS_Harbour;
	theTerminal := theForm.cmbTerminal.listObject.CM_Terminal;
	thePreferredBerth := theForm.cmbPrefBerth.listObject.HMS_Berth;
	
	create allCheckPoints transient;
	self.getAllCheckPoints(allCheckPoints);
	
	pxyHarbourRegion.setProxy(	app.myRoot, 
								theHarbour, 
								theTerminal, 
								thePreferredBerth,
								allCheckPoints);
							
	pxyHarbourRegion.allBerthsInRegion.clear();
	theForm.mulSelect1.getSelected(pxyHarbourRegion.allBerthsInRegion);		
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyHarbourRegion, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyHarbourRegion, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
epilog
	delete 	allCheckPoints;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllCheckPoints" id="119f1cd0-5fe8-485d-9359-0cc57fc2660b">
        <source>getAllCheckPoints(_allCheckPoints : HMS_CheckPointByTypeDict io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 June 2008	cnwer1	Initial creation

*/

vars
	theForm: SOP_HMS_TableMaintForm;
begin
	theForm:=self.myForm.SOP_HMS_TableMaintForm; 
	if theForm.cmbChkCurrent.listObject &lt;&gt; null then
		_allCheckPoints.add(theForm.cmbChkCurrent.listObject.HMS_CheckPoint);
	endif;
	if theForm.cmbChkHeight.listObject &lt;&gt; null then
		_allCheckPoints.add(theForm.cmbChkHeight.listObject.HMS_CheckPoint);
	endif;
	if theForm.cmbChkHiLo.listObject &lt;&gt; null then
		_allCheckPoints.add(theForm.cmbChkHiLo.listObject.HMS_CheckPoint);
	endif;
	if theForm.cmbChkTideRange.listObject &lt;&gt; null then
		_allCheckPoints.add(theForm.cmbChkTideRange.listObject.HMS_CheckPoint);
	endif;
	if theForm.cmbChkDay.listObject &lt;&gt; null then
		_allCheckPoints.add(theForm.cmbChkDay.listObject.HMS_CheckPoint);
	endif;
	if theForm.cmbChkShipsDepar.listObject &lt;&gt; null then
		_allCheckPoints.add(theForm.cmbChkShipsDepar.listObject.HMS_CheckPoint);
	endif;
	if theForm.cmbChkUserHook.listObject &lt;&gt; null then
		_allCheckPoints.add(theForm.cmbChkUserHook.listObject.HMS_CheckPoint);
	endif;
	if theForm.cmbChkTideState.listObject &lt;&gt; null then
		_allCheckPoints.add(theForm.cmbChkTideState.listObject.HMS_CheckPoint);
	endif;
epilog

end;</source>
        <Parameter name="_allCheckPoints" type="HMS_CheckPointByTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="3e347664-6685-493f-9039-f67ad09a4009">
        <source>getCollection(): Collection;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	user : CM_User;
	iter : Iterator;
	region : HMS_HarbourRegion;
	term : CM_Terminal;
	failedDAC  :CM_DataAccessController;

begin

//	return app.myRoot.allHMSHarbourRegions;

	//01 Nov 2012	NDL	Par 29892
	self.allUserVisibleRegions.clear();
	
	if app.myPassport &lt;&gt; null then
		user := app.myPassport.myUser;
	endif;
	
	iter := app.myRoot.allHMSHarbourRegions.createIterator;
	while iter.next( region ) do
		term := region.getTerminal;
		if term &lt;&gt; null then
			if not term.canUserAccessSelf( user, failedDAC, app.myPassport ) then
				continue;
			endif;
		endif;
		self.allUserVisibleRegions.add( region );
	endwhile;
	
	return self.allUserVisibleRegions;

epilog

	delete iter;
	
end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
