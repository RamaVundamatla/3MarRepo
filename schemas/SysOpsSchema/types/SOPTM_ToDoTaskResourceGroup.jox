    <JadeMethod name="doDelete" id="fd5da1bc-6fbe-4cff-9449-bedd5c8d89ec">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

begin
