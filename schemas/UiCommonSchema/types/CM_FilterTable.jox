        <source>showColumnOrganiserFrm(_terminal: CM_Terminal; _additionalRows: EntTableRowArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2015	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod(_terminal, _additionalRows);
	
	//might need to refresh the visible columns
	if showingFilters then
		self.doClearFilters(true);
