    <JadeMethod name="setEventDataInternal" id="08ce749e-696c-4cb6-a186-8d657114eb7f">
        <updating/>
        <source>setEventDataInternal(_eventDataDict : CM_EventDataByTypeDict) updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	pxyEventData,
	realEventData : CM_EventData;

begin

	// Does clone to persistent
	foreach pxyEventData in _eventDataDict do
		realEventData := pxyEventData.cloneSelf(false);
		pxyEventData.cloneReferences(realEventData);
		realEventData.setMyBGPRequest(self);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_eventDataDict" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
