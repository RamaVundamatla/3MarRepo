        <updating/>
        <source>validateUserSSO(_upn, _uid : String) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
*/

vars

begin
	return app.myTrxUA.trxUpdateLogonSSO(_upn, _uid, self.myPassport);
epilog

