    <JadeMethod name="comboBoxHMSBerthPriority" id="152d8c27-e839-4090-bece-7085bcf76893">
        <source>comboBoxHMSBerthPriority(pTbl : CM_EntryTable input; pAttrName : String; _priority : Integer);
//--------------------------------------------------
// Created:	15 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	row : Integer;
	str	: String;
begin
	
	row := pTbl.getRow(pAttrName);

	if (not pTbl.isValidRow(row)) then
		return;
	endif;
			
	// Load Berth Booking Priority list
	str := '1 - High' &amp; Tab &amp; 
			'2' &amp; Tab &amp;
			'3' &amp; Tab &amp;
			'4' &amp; Tab &amp;
			'5 - Medium' &amp; Tab &amp;
			'6' &amp; Tab &amp;
			'7' &amp; Tab &amp;
			'8' &amp; Tab &amp;
			'9' &amp; Tab &amp;
			'10 - Low' &amp; Tab;	

	pTbl.setComboValues(row, str);
	
	if _priority &gt;= 2 and _priority &lt;= 4 or
	_priority &gt;= 6 and _priority &lt;= 9 then
		pTbl.setValue(row, _priority.String);
	elseif _priority = 5 then
		pTbl.setValue(row, '5 - Medium');	
	elseif _priority = 10 then
		pTbl.setValue(row, '10 - Low');			
	else
		pTbl.setValue(row, '1 - High');		
	endif;
	
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_priority" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSBerthsForColl" id="5cc9912d-0583-40b1-b3c6-ea9d2cc56b1d">
        <source>comboBoxHMSBerthsForColl(pCmb : CMUI_ComboBox input; pColl :HMS_BerthArray; _berth : HMS_Berth);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2008	cnwer1	Initial creation

*/

vars

	harbourRegion	: HMS_HarbourRegion;
	berth			: HMS_Berth;
begin
	pCmb.clear;
	
	foreach berth in pColl do
		pCmb.addItemObject(self.displayEntryHMSBerth(berth), berth);
	endforeach;

	if _berth &lt;&gt; null then
		pCmb.listIndex := pCmb.findObject(_berth);
	endif;	

epilog

end;</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="pColl" type="HMS_BerthArray"/>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSCheckPoint" id="4722e9b0-77ee-4c97-9158-a72b4cc14b10">
        <source>comboBoxHMSCheckPoint(	_cmb : CMUI_ComboBox input; 
						_checkpointType : Integer;
						_regionObj:HMS_HarbourRegion);
/*
----------   ----------  --------------------------------------------------
Created:	16 October 2006 By cnwth2

Purpose:	

Changed On	Changed By	Reason
	
----------	----------	--------------------------------------------------
23/03/2007	cnwdad1		Added checks to prevent a Restriction being included
//						in the combobox if it has already been used by another
//						Harbour Region for the same type.
*/
vars
	checkpoint		: HMS_CheckPoint;
	dict			: HMS_CheckPointByCodeDict;
	idx				: Integer;
	iter			: Iterator;
	
begin
	_cmb.clear();
	_cmb.sorted	:=	false;
	dict		:=	app.myRoot.allHMSCheckpoints;
	iter		:=	dict.createIterator;
	
	while iter.next(checkpoint) do
		if _checkpointType &lt;&gt; null
		and checkpoint.checkPointType &lt;&gt; _checkpointType
		then
			continue;
		endif;
		
		// If the restriction is already used for this type, then drop it.
		
		if checkpoint.myRegion &lt;&gt; null
		and _regionObj &lt;&gt; null
		and checkpoint.myRegion &lt;&gt; _regionObj
		then
			continue;
		endif;

		// If we got this far, we can include the restriction.
		
		_cmb.itemObject[_cmb.addItem(checkpoint.description)]	:=	checkpoint;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_checkpointType" type="Integer"/>
        <Parameter name="_regionObj" type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSChkPointType" id="b12dec23-141c-47d0-8fc8-881b46588653">
        <source>comboBoxHMSChkPointType(_cmb : CMUI_ComboBox input; _checkPointType : Integer);
/*
----------   ----------  --------------------------------------------------
Created:	13 October 2006 By cnwth2

Purpose:	
*/
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/

vars
	lookForStr : String;
	
begin
	_cmb.clear();
	_cmb.sorted := false;

	_cmb.itemData[_cmb.addItem(app.chkPointTypeEnumToString(HMS_ChkPointType_Current))]			:=	HMS_ChkPointType_Current;
	_cmb.itemData[_cmb.addItem(app.chkPointTypeEnumToString(HMS_ChkPointType_Draft))]			:=	HMS_ChkPointType_Draft;
	_cmb.itemData[_cmb.addItem(app.chkPointTypeEnumToString(HMS_ChkPointType_HiLo))]			:=	HMS_ChkPointType_HiLo;
	_cmb.itemData[_cmb.addItem(app.chkPointTypeEnumToString(HMS_ChkPointType_TimeGap))]			:=	HMS_ChkPointType_TimeGap;
	//jlgak1 TFS 45620 --&gt;
	/*_cmb.itemData[_cmb.addItem(app.chkPointTypeEnumToString(HMS_ChkPointType_TideRange))]		:=	HMS_ChkPointType_TideRange;  
	_cmb.itemData[_cmb.addItem(app.chkPointTypeEnumToString(HMS_ChkPointType_ShipsDepart))]	:=	HMS_ChkPointType_ShipsDepart; 	
	/_cmb.itemData[_cmb.addItem(app.chkPointTypeEnumToString(HMS_ChkPointType_UserHookCode))]	:=	HMS_ChkPointType_UserHookCode;
	//epr par 16884 CCMS 1672
	_cmb.itemData[_cmb.addItem(app.chkPointTypeEnumToString(HMS_ChkPointType_TideState))]		:=	HMS_ChkPointType_TideState; */
	//jlgak1 TFS 45620 &lt;--
	if _checkPointType &lt;&gt; null then
		lookForStr := app.chkPointTypeEnumToString(_checkPointType);
		_cmb.listIndex := _cmb.findString(1, lookForStr);
	endif;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_checkPointType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSCustomerType" id="eeaa3ccf-7129-4507-9846-8ad9f9361617">
        <source>comboBoxHMSCustomerType(_cmb : CMUI_ComboBox input; _customerType : String);
//--------------------------------------------------
// Created:	December 2004 By: cnwgd1
//--------------------------------------------------
vars
	row : Integer;
	str	: String;
begin
	
	_cmb.clear();			

	_cmb.addItem(app.getErrorString(Agent));
