    <JadeMethod name="getISOTypeObject" id="c5573762-f7cb-46fe-8230-3609ba94108d">
        <source>getISOTypeObject() : CM_ISOType;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
