    <JadeMethod name="sh3PrintDriverInstructions" id="fd28aedc-e21e-4722-934a-07b7cd7dcf71">
        <source>sh3PrintDriverInstructions();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	termDict 	: CM_TerminalByCodeDict;
	jadeReport	: JadeReport;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	jrwTrans : CM_JRWAnyDataObject;
	ls		: Boolean;
	reportString : String;
	printerName : String;
	job : CM_RoadJob;
	term : CM_Terminal;
begin
	self.sh3StandardInitialize();
	term := app.myRoot.allTerminals['T01'];
	
	//Assign a job
	//job := '2274.7807'.asOid.CM_RoadJob;
	
	//job := '2274.9343'.asOid.CM_RoadJob;//Multiples
	job := CM_RoadJob.lastInstance();
	
	//job := '2274.7810'.asOid.CM_RoadJob;//Single Booking By ID
	//job := '2274.7811'.asOid.CM_RoadJob;//Receival By Type
	//Print Preview
	create jadeReport transient;
	jadeReport.description := "Default";
	app.printer.setReport(jadeReport);
			
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWAnyDataObject).CM_JRWAnyDataObject;
	create termDict transient;
	termDict.add(term);
	jrwTrans.setAllTerminals(termDict);
	jrwTrans.myDataObject := job;	
	
	// Par 13155 Changed this to cater for a passed in report 
	//reportString := 'CM_Buckslip1';//par 13812
	//reportString := 'CM_DriverDetails'; 
	//reportString := self.myTerminal.getRoadReceiptReport();
	if term &lt;&gt; null then
		reportString := term.getConfig(GateDriverInstructionsReport).String;
	endif;
	if reportString = null then
		reportString := 'SCT_DriverDetails';
	endif;
	jrwManager := app.createReportWriterManager();
	jrwReport := jrwManager.getReport(reportString);
	if jrwReport = null then
		if jrwReport = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Driver Instructions report class not specified in gate config (" &amp; reportString &amp; " does not exist)");
			return;
		endif;
	endif;
	
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		
	jrwReport.setPageOptions(Print_A4, Print_Portrait, 1, 0, 0, 0, 20, 0, false, 0);
	
	//Set up print preview
	jrwReport.setPreviewOptions(true, true, false, true, null);
	
	app.cmsBeginLoad(ls);
	jrwReport.run;

	app.printPreview(jadeReport, true);
epilog
	delete jrwTrans;
	delete jrwManager;
	delete termDict;
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3PrintRoadReceipt" id="2cfe009b-05f3-4621-a123-973ff9534dd5">
        <source>sh3PrintRoadReceipt();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
constants
	VehicleOID = '3100.14009';
vars
	termDict 	: CM_TerminalByCodeDict;
	jadeReport	: JadeReport;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	jrwTrans 	: CM_JRWGateReceipt;
	ls			: Boolean;
	reportString: String;
	visitRecord : CM_VehicleVisitRecord;
	term		: CM_Terminal;
begin
	self.sh3StandardInitialize();
	term := app.myRoot.allTerminals['T01'];
	
	visitRecord := VehicleOID.asOid.CM_VehicleVisitRecord;	
	
	//Print Preview
	create jadeReport transient;
	jadeReport.description := "Default";
	app.printer.setReport(jadeReport);
			
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWGateReceipt).CM_JRWGateReceipt;
	create termDict transient;
	termDict.add(term);
	jrwTrans.setAllTerminals(termDict);
	
	jrwTrans.myVehicleVisit := visitRecord;
	jrwTrans.vehicleVisitOid := visitRecord.getOidAsString;
	visitRecord.allReceivedTrackedItems.copy(jrwTrans.allTrackedItems);
	visitRecord.allReleasedTrackedItems.copy(jrwTrans.allTrackedItems);
	// Par 13155 Changed this to cater for a passed in report 
	//reportString := 'CM_Buckslip1';//par 13812
	reportString := 'SCT_DriverDetailsOutGate'; 
	//reportString := self.myTerminal.getRoadReceiptReport();
	//reportString := 'CM_RoadJobPrintNew';
	
	if reportString = null then
		reportString := DefRep_GateDriverInstructions;
	endif;
	jrwManager := app.createReportWriterManager();
	jrwReport := jrwManager.getReport(reportString);
	jrwReport.setParameter('vehicleVisitOid', jrwTrans.vehicleVisitOid);
	if jrwReport = null then
		if jrwReport = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Driver Instructions report class not specified in gate config (" &amp; reportString &amp; " does not exist)");
			return;
		endif;
	endif;
	
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		
	jrwReport.setPageOptions(Print_A4, Print_Portrait, 1, 0, 0, 0, 20, 0, false, 0);
	
	//Set up print preview
	jrwReport.setPreviewOptions(true, true, false, true, null);
	
	app.cmsBeginLoad(ls);
	jrwReport.run;

	app.printPreview(jadeReport, true);
epilog
	app.cmsEndLoad(ls);
	delete jrwTrans;
	delete jrwManager;
	delete termDict;

end;</source>
    </JadeMethod>
