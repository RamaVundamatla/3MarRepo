    <JadeMethod name="doResize" id="8d9544a4-aac4-4dd0-aacc-174bd49bee54">
        <updating/>
        <source>doResize() updating;
/*
Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
*/

vars
	toolbarTopOffset	: Integer;
	
begin
	inheritMethod();
	if self.frmToolbar.visible then
		toolbarTopOffset := (self.frmToolbar.top + self.frmToolbar.height).Integer;
	else
		toolbarTopOffset := self.frmToolbar.top.Integer;
	endif;

	self.frmStatusLine.left := 0;
	self.frmStatusLine.top := self.height - self.frmStatusLine.height;
	self.frmStatusLine.width := self.clientWidth;
	self.frmStatusLine.doResize();

	self.splMain.move(0, toolbarTopOffset, self.clientWidth, self.frmStatusLine.top - toolbarTopOffset);

	self.splMain.cnEcResizeContents();

	// #################################
	// GridArea INFORMATION
	self.setLastColumnMaxWidth(tblGridAreaInfo);

	self.sptBottom.cnEcResizeContents();

	
	self.frmColLegendTIs.top := 0; 
	self.frmColLegendTIs.left := 0;
	self.frmColLegendTIs.height := self.sptGridArea01.height;
	self.frmColLegendTIs.doResize();
	self.frmModalDialog.centreWindow();
	self.frmModalDialog.height := 60;
	self.frmModalDialog.top := 100;
	
	self.doResizeColumnWidths(self.tblGridAreaInfo, true);
epilog

end;</source>
    </JadeMethod>
