    <JadeMethod name="setForCreateVoyage" id="6af7360b-c221-48e2-84d1-d6e788063e67">
        <updating/>
        <source>setForCreateVoyage(_theJobParams: CMIF_VoyageJobParams input; _allWLEs : CM_WLEArray; _passport: CM_Passport input) updating;
/*
Purpose:			
Date		Who		Reason
13/02/2017	cnwab1	Initial creation
08/03/2017	cnwdap1	TZFS 3516 LNX Hold Planning Quantity
15/10/2021	navdap1	TFS 52293 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
24/11/2021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
06/21/2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
19/02/2022	navdap1	TFS 52801 SAL Direct Delivery - End of Shift Job Transfer
*/

vars
	ti : CM_TrackedItem;
	move : CMIF_MoveController;
	wle : CM_WorkListEntry;
	qty : Integer;
	weight : Decimal [14,4];					// TFS 3516
	hasCars : Boolean;
	chgToDirectDelivery : Boolean;		// TFS 52293
begin
	chgToDirectDelivery := not self.isDirectDelivery and _theJobParams.isDirectDelivery;	// TFS 52293
	
	//inheritMethod(_theJobParams, _passport);								// TFS 3516
	inheritMethod(_theJobParams, _allWLEs, _passport);						// TFS 3516
	
	self.setWLEQuantities(_allWLEs);										// TFS 3516
	if _theJobParams.myLocation &lt;&gt; null then
		if self.isDischarge then
			foreach ti in self.allReceiveTrackedItems discreteLock do
				wle := ti.getWLEForAssignedHoldReq();
				if wle = null then
					//wle := ti.getVoyageWLEUnactioned(false);				// TFS 3516
					wle := ti.getVoyageWLEUnactionedForJob(false, self);	// TFS 3516
				endif;
				if wle &lt;&gt; null then // TFS 3504
					qty := wle.quantity; // TFS 3504
					weight := wle.weight;									// TFS 3516
				endif;
	
				//ti.moveToLocation(_theJobParams.myLocation,self,wle,null,PLANNING_MODE,true,true,false,false,false,false,qty,ti.totalWeight, null,_passport);	// TFS 3516
				ti.moveToLocation(_theJobParams.myLocation,self,wle,null,PLANNING_MODE,true,true,false,false,false,false,qty,weight, null,null,null,_passport);			// TFS 3516
 // ### TFS 53105 08JUN2022 NAVAB1				if ti.isCar then // ### TFS 50669 24AUG2021 NAVAB1
 // ### TFS 53105 08JUN2022 NAVAB1					hasCars := true; // ### TFS 50669 24AUG2021 NAVAB1
 // ### TFS 53105 08JUN2022 NAVAB1				endif; // ### TFS 50669 24AUG2021 NAVAB1
			endforeach;
		else
			foreach ti in self.allReleaseTrackeditems discreteLock do
				wle := ti.getWLEForAssignedHoldReq();
				if wle = null then
					//wle := ti.getVoyageWLEUnactioned(false);				// TFS 3516
					wle := ti.getVoyageWLEUnactionedForJob(true, self);		// TFS 3516
				endif;
	
				if wle &lt;&gt; null then // TFS 3504
					qty := wle.quantity; // TFS 3504
					weight := wle.weight;									// TFS 3516
				endif;
				//ti.moveToLocation(_theJobParams.myLocation,self,wle,null,PLANNING_MODE,true,true,false,false,false,false,qty,ti.totalWeight, null,_passport);	// TFS 3516
				ti.moveToLocation(_theJobParams.myLocation,self,wle,null,PLANNING_MODE,true,true,false,false,false,false,qty,weight, null,null,null,_passport);			// TFS 3516
 // ### TFS 53105 08JUN2022 NAVAB1				if ti.isCar then // ### TFS 50669 24AUG2021 NAVAB1
 // ### TFS 53105 08JUN2022 NAVAB1					hasCars := true; // ### TFS 50669 24AUG2021 NAVAB1
 // ### TFS 53105 08JUN2022 NAVAB1				endif; // ### TFS 50669 24AUG2021 NAVAB1
				if chgToDirectDelivery then													// TFS 52293
					ti.setDirectDelivery(true, false);										// TFS 52293
				endif;																		// TFS 52293
			endforeach;
		endif;
	endif;
	
	self.isDirectDelivery := _theJobParams.isDirectDelivery;		// TFS 52293
	self.originalJobAmount := _theJobParams.originalJobAmount;		// TFS 52360
	
	// TFS 52801 for new direct delivery jobs, need to check for onsite cargo on a truck - this cargo was part
	// of a previous job so needs to be planned to this job
	if self.isDirectDelivery then
		self.handleLinkingOnsiteCargo(_theJobParams);
	endif;
	// TFS 52801 end
	
 // ### TFS 53105 08JUN2022 NAVAB1	if hasCars then // ### TFS 50669 24AUG2021 NAVAB1
 // ### TFS 53105 02JUN2022 NAVAB1		app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,self.getMyTerminal(),self); // ### TFS 50669 24AUG2021 NAVAB1
 // ### TFS 53105 08JUN2022 NAVAB1	endif;

epilog
	delete move;
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_allWLEs" type="CM_WLEArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b50d5965-6ca0-433c-ac4a-bc5b1d83bccd">
        <updating/>
        <source>setForUpdate(_proxyJob: CM_VoyageJob; _theTerminal: CM_Terminal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 14/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 28/10/2021	navdap1		TFS 52293 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 24/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
//
vars
	ti : CM_TrackedItem;
	realShift : CM_Shift;
	removedTIs, addedTIs : CM_TISet;

begin
	inheritMethod(_proxyJob, _theTerminal);
	
	self.attributes := _proxyJob.attributes;
	
	create removedTIs transient;
	create addedTIs transient;
	if self.isDischarge then
		foreach ti in self.allReceiveTrackedItems do
			if not _proxyJob.allReceiveTrackedItems.includes(ti) then
				removedTIs.add(ti);
			endif;
		endforeach;
		foreach ti in _proxyJob.allReceiveTrackedItems do
			if not self.allReceiveTrackedItems.includes(ti) then
				addedTIs.add(ti);
			endif;
		endforeach;
	else
		foreach ti in self.allReleaseTrackeditems do
			if not _proxyJob.allReleaseTrackeditems.includes(ti) then
				removedTIs.add(ti);
			endif;
		endforeach;
		foreach ti in _proxyJob.allReleaseTrackeditems do
			if not self.allReleaseTrackeditems.includes(ti) then
				addedTIs.add(ti);
			endif;
		endforeach;
	endif;
	// copy allocated TIs on proxy to self
	self.allReceiveTrackedItems.clear;
	foreach ti in _proxyJob.allReceiveTrackedItems do
		self.allReceiveTrackedItems.add(ti);
	endforeach;
	self.allReleaseTrackeditems.clear;
	foreach ti in _proxyJob.allReleaseTrackeditems do
		self.allReleaseTrackeditems.add(ti);
	endforeach;
	

	if _proxyJob.myShift&lt;&gt; null then
		if _proxyJob.myShift.isTransient then
			realShift := app.myProxyManager.getRealObject(_proxyJob.myShift).CM_Shift;
			if realShift = null then
				// a real shift was just created from a proxy - in this case there's no proxy link
				realShift := self.myTerminal.allShiftsDay[_proxyJob.myShift.startDateTime, _proxyJob.myShift.code];
			endif;
		else
			realShift := _proxyJob.myShift;
		endif;
		self.myShift := realShift;
	endif;
	
	self.myDLRDischargeJob := _proxyJob.CM_VoyageHoldJob.myDLRDischargeJob;			// TFS 3516
	
	// update or create job requests for each ti
	self.setForUpdateHoldRequests();
	
	// set imex status on added or removed tis
	self.addRemoveTIImexStatus(addedTIs, removedTIs);
	
	self.isDirectDelivery := _proxyJob.CM_VoyageHoldJob.isDirectDelivery;		// TFS 52293
	self.originalJobAmount := _proxyJob.CM_VoyageHoldJob.originalJobAmount;		// TFS 52360
	
epilog
	delete addedTIs;
	delete removedTIs;
end;</source>
        <Parameter name="_proxyJob" type="CM_VoyageJob"/>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateHoldRequests" id="30e4bf09-0c2a-45c4-8aea-30ea351e5f5c">
        <updating/>
        <source>setForUpdateHoldRequests() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/02/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 23/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 07/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
//
vars
	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	request : CM_HoldRequest;
	wle : CM_WorkListEntry;
	req : CM_Request;
	qtyArray : DecimalArray;				// TFS 3516
	tiArray : CM_TIArray;					// TFS 3516
	idx : Integer;							// TFS 3516
	fm : CM_FutureMove;						// TFS 3516
	futureMoves : CM_FutureMoveArray;		// TFS 3516

begin
	// create a hold request and a wle for each TI in this job
	if self.isDischarge then
		tiSet := self.allReceiveTrackedItems;
	else
		tiSet := self.allReleaseTrackeditems;
	endif;
	
	if not self.allRequests.isEmpty then
		return;
	endif;
	create tiArray transient;									// TFS 3516
	foreach req in self.allRequests do							// TFS 3516
		foreach wle in req.allWorkListEntries do				// TFS 3516
			tiArray.add(wle.myTrackedItem);						// TFS 3516
		endforeach;												// TFS 3516
	endforeach;													// TFS 3516
	
	create futureMoves transient;	//19 Jun 2019	NDL	TFS 42876 - move outside loop
	foreach ti in tiSet do
		// check for orphaned future planned moves				// TFS 3516
//		create futureMoves transient;							// TFS 3516
		foreach fm in ti.allPlannedFutureMoves do				// TFS 3516
			if fm.myWorkListEntry = null then					// TFS 3516
				futureMoves.add(fm);							// TFS 3516
			endif;												// TFS 3516
		endforeach;												// TFS 3516
		futureMoves.purge();									// TFS 3516
		// create a request
		create request;
		request.setForUpdateVoyageHoldJob(self);
		// attach the request to this job
		request.setJob(self);
		// set move type (needed here so WLE gets things correct	// TFS 3489
		if ti.getTransitStatus = TI_TransitStatusSOB then			// TFS 3489
			request.setMoveType(SOB_MOVETYPE);						// TFS 3489
		elseif ti.getTransitStatus = TI_TransitStatusDLR then		// TFS 3489
			request.setMoveType(DLR_MOVETYPE);						// TFS 3489
		endif;														// TFS 3489
		// create a WLE
		request.createWLEForTI(ti);
		// now set the wle quantity / weight back 				// TFS 3516
		// if we had an existing one							// TFS 3516
		idx := tiArray.indexOf(ti);								// TFS 3516
		if idx &gt; 0 then											// TFS 3516
			foreach wle in ti.allWorklistEntries where wle.job = self do	// TFS 3516
				if ti.isBulkByQuantity then						// TFS 3516
					wle.setQuantity(qtyArray[idx].Integer);		// TFS 3516
				else											// TFS 3516
					wle.setWeight(qtyArray[idx]);				// TFS 3516
				endif;											// TFS 3516
			endforeach;											// TFS 3516
		endif;													// TFS 3516
		// and attach the TI to me
		self.updateTICollections(ti, null);
	endforeach;
epilog
	delete qtyArray;											// TFS 3516
	delete tiArray;												// TFS 3516
	delete futureMoves;											// TFS 3516
end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdateVoyage" id="3ad7baf5-38bb-427c-9ebf-f672c813dcea">
        <updating/>
        <source>setForUpdateVoyage(	_theJobParams: CMIF_VoyageJobParams input;
					_passport: CM_Passport input
					) updating;
/*
Purpose:			
Date		Who		Reason
14/02/2017	cnwab1	Initial creation
08/03/2017	cnwdap1	TFS 3516 LNX Hold Planning Quantity
28/09/2018 	JLGNS1	Bug 40500: STWO - Hold Planning(STWUJMT2)
31/10/2019	jlgzm1	TFS 47085 Direct Release Ship to Ship
06/21/2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
01/03/2022	navdap1	TFS 52973 MTN Issue found in CR 52801 testing
08/09/2022	navsj20	Bug 52632: MTN - Changing Voyage Hold Job to Non-DD Does Not Change Prenote
10/10/2023	jlizm1	TFS 59730 Kiosk Load Sequence
*/

vars
	ti : CM_TrackedItem;
	move : CMIF_MoveController;
	wle : CM_WorkListEntry;
	wles : CM_WLEArray;
	qty : Integer;
	weight : Decimal [14,4];						// TFS 3516
	oldLocation : CM_LocationsController;
	locationIndex : Integer;
	wasDR	: Boolean;	// TFS 47085
	chgToDirectDelivery : Boolean;			// TFS 52293
	
	fm : CM_FutureMove;
	lc : CM_LocationsController;
	
begin
	chgToDirectDelivery := self.isDirectDelivery &lt;&gt; true and _theJobParams.isDirectDelivery;	// TFS 52293
	
	inheritMethod(_theJobParams, _passport);
	
	if _theJobParams.myLocation &lt;&gt; null then
		foreach wle in self.workListEntries discreteLock do
			if wle &lt;&gt; null and wle.getTargetLocation = _theJobParams.myLocation and wle.myTrackedItem.isRehandle then	
				continue;																				
			endif;	
			oldLocation := wle.getTargetLocation;		
			if oldLocation &lt;&gt; null then
				if wle.isPlanned then 
					locationIndex := wle.myFutureMove.CM_FutureMovePlanned.allLocationsControllers.indexOf(oldLocation);
					if locationIndex &gt; 0 then
						wle.myFutureMove.CM_FutureMovePlanned.changeLocation(_theJobParams.myLocation,locationIndex);
						wle.setLocations(wle.locationSource,wle.myFutureMove.getPrimaryLocationId());
					endif;
				endif;
			endif;	
		endforeach;	
		
		self.isDirectDelivery := _theJobParams.isDirectDelivery;								// TFS 52293
		
		//			Bug 40500 ---  Need to get the location from the WLE as the TI may have more than one planed location 
		/* WAS TFS 52618
		if self.isDischarge then
			foreach ti in self.allReceiveTrackedItems discreteLock do
				if _theJobParams.myLocation &lt;&gt; ti.myPrimaryPlannedLocation then
					wle := ti.getWLEForAssignedHoldReq(); // TFS 3190 This is where the 'Assign to Release' has been used in Voyage Operations
					if wle = null then											// TFS 3516
						wle := ti.getVoyageWLEUnactionedForJob(false, self);	// TFS 3516
					endif;														// TFS 3516
					if wle &lt;&gt; null then // TFS 3504
						qty := wle.quantity; // TFS 3504
						weight := wle.weight;									// TFS 3516
					endif;
					if wle &lt;&gt; null and wle.getTargetLocation = _theJobParams.myLocation and ti.isRehandle then	// TFS 3516
						continue;																				// TFS 3516
					endif;																						// TFS 3516
					if wle &lt;&gt; null and wle.isDRLinkedByFM then					// TFS 47085
						// if wle is currently marked for direct release, will want continue to be direct release
						wasDR := true;											// TFS 47085
					endif;
					ti.undoMove(PLANNING_MODE,_passport);
					//ti.moveToLocation(_theJobParams.myLocation,self,wle,null,PLANNING_MODE,true,true,false,false,false,false,qty,ti.totalWeight, null,_passport);	// TFS 3516
					ti.moveToLocation(_theJobParams.myLocation,self,wle,null,PLANNING_MODE,true,true,false,false,false,false,qty,weight, null,null,null,_passport);			// TFS 3516
					if wasDR then												// TFS 47085
						ti.autoSetDirectReleaseWLE(wle, null, false);			// TFS 47085
					endif;
				endif;
			endforeach;
		else

			foreach ti in self.allReleaseTrackeditems discreteLock do
				if _theJobParams.myLocation &lt;&gt; ti.myPrimaryPlannedLocation then
					wle := ti.getWLEForAssignedHoldReq(); // TFS 3190 This is where the 'Assign to Release' has been used in Voyage Operations
					if wle = null then											// TFS 3516
						wle := ti.getVoyageWLEUnactionedForJob(true, self);		// TFS 3516
					endif;														// TFS 3516
					if wle &lt;&gt; null then // TFS 3504
						qty := wle.quantity; // TFS 3504
						weight := wle.weight;									// TFS 3516
					endif;
					if wle &lt;&gt; null and wle.getTargetLocation = _theJobParams.myLocation and ti.isRehandle then	// TFS 3516
						continue;																				// TFS 3516
					endif;																						// TFS 3516
					if wle &lt;&gt; null and wle.isDRLinkedByFM then					// TFS 47085
						// if wle is currently marked for direct release, will want continue to be direct release
						wasDR := true;											// TFS 47085
					endif;
					ti.undoMove(PLANNING_MODE,_passport);
					//ti.moveToLocation(_theJobParams.myLocation,self,wle,null,PLANNING_MODE,true,true,false,false,false,false,qty,ti.totalWeight, null,_passport);	// TFS 3516
					ti.moveToLocation(_theJobParams.myLocation,self,wle,null,PLANNING_MODE,true,true,false,false,false,false,qty,weight, null,null,null,_passport);			// TFS 3516
					if wasDR then												// TFS 47085
						ti.autoSetDirectReleaseWLE(wle, null, false);			// TFS 47085
					endif;
				endif;
					
				if chgToDirectDelivery then														// TFS 52293
					ti.setDirectDelivery(true, false);											// TFS 52293
				endif;																			// TFS 52293
			endforeach;
	
		endif;
		now TFS 52618 */	
		
		
		create wles transient;
		self.workListEntries.copy(wles);
		// ### TFS 52618 22DEC2021 NAVAB1
		foreach wle in wles discreteLock do
			ti := wle.myTrackedItem;
			lc := wle.getTargetLocation();
			if lc &lt;&gt; null then
				if _theJobParams.myLocation &lt;&gt; lc then
					qty := wle.quantity;
					weight := wle.weight;
					if wle.isDRLinkedByFM then
						// if wle is currently marked for direct release, will want continue to be direct release
						wasDR := true;
					endif;
					
					create move transient;
					move.setMoveMode(PLANNING_MODE);
					move.setMyTrackedItem(ti);
					move.setMyWorkListEntry(wle);
					app.myUtilityUA.utlUpdateMoveTIUndo(move, _passport);
					
					ti.moveToLocation(_theJobParams.myLocation,self,wle,null,PLANNING_MODE,true,true,false,false,false,false,qty,weight, null,null,null,_passport);	
					if wasDR then
						ti.autoSetDirectReleaseWLE(wle, null, false);
					endif;
				endif;		
				// START 08 Sep 2022	navsj20	Bug 52632
				if self.isRelease() then
					if chgToDirectDelivery then	
						ti.setDirectDelivery(true, false);
					else 
						ti.setDirectDelivery(false, false);						
					endif;
				endif;
				// END 08 Sep 2022	navsj20	Bug 52632		
			endif;
		endforeach;
		
	endif;
	
	// TFS 52973 check for onsite cargo that needs to be marked as Direct Delivery
	if chgToDirectDelivery then
		self.handleLinkingOnsiteCargo(_theJobParams);
	endif;
	// TFS 52973 end

epilog
	delete wles;
	
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIsDirectDelivery" id="6e11af31-8d52-4bdd-98a9-a4eb08b488b1">
        <updating/>
        <source>setIsDirectDelivery(_value : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/10/2021	navdap1		Initial creation TFS 52293 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
//
vars

begin
	self.isDirectDelivery := _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
