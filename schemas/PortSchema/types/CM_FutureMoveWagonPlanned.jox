    <JadeMethod name="pxyCreateUpdateProxy" id="74f09a11-30d0-4a1b-9060-a11fe37eb529">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	proxyWP 	: CM_FutureMoveWagonPlanned;
	completedOK	: Boolean;
begin
	proxyWP := inheritMethod();
	
	if proxyWP = null then 
		return null;
	endif;
	
	proxyWP.myRailLine := self.myRailLine;
	proxyWP.myWagon := self.myWagon;
	proxyWP.myTrain := self.myTrain;
	proxyWP.plannedIndex := self.plannedIndex;
	
	completedOK := true;			
	return proxyWP;

epilog
	if not completedOK then			
		delete proxyWP;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCreate" id="09950993-6c90-4c24-a68f-0b4157a27573">
        <updating/>
        <source>setCreate(_wagonPlanned : CM_FutureMoveWagonPlanned) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
 01/05/2023		navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train
*/

vars

begin
	self.myWagon := _wagonPlanned.myWagon;
	self.myRailLine := _wagonPlanned.myRailLine;
	self.myTrain := _wagonPlanned.myTrain;
	self.plannedIndex := _wagonPlanned.plannedIndex;
	self.myTerminal := _wagonPlanned.myTerminal;
	self.moveType := _wagonPlanned.moveType;
	self.isInward := _wagonPlanned.isInward; // 01/05/2023	navkc1	Bug 57742
epilog	

end;</source>
        <Parameter name="_wagonPlanned" type="CM_FutureMoveWagonPlanned"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="d709037a-2b99-421b-84ef-1ffa038c330a">
        <updating/>
        <source>setProxy(_myWagon : CM_Wagon;  _myTrain : CM_Train; _myRailLine : CM_RailLine; _index: Integer; _myTerminal : CM_Terminal; _moveType: Integer; _isInward : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
 01/05/2023		navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train
*/

vars

begin
	self.myWagon := _myWagon;
	self.myRailLine := _myRailLine;
	self.myTrain := _myTrain;
	self.plannedIndex := _index;
	self.myTerminal := _myTerminal;
	self.moveType := _moveType;
	self.isInward := _isInward; // 01/05/2023	navkc1	Bug 57742
epilog

end;</source>
        <Parameter name="_myWagon" type="CM_Wagon"/>
        <Parameter name="_myTrain" type="CM_Train"/>
        <Parameter name="_myRailLine" type="CM_RailLine"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_isInward" type="Boolean"/>
    </JadeMethod>
