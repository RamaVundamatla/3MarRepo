    <JadeMethod name="setProxyForInaportnet" id="d1b945c4-2541-41b0-8647-8f655da8d839">
        <updating/>
        <source>setProxyForInaportnet(	_cmif : CMIF_IPNRKBMDetailItem input;
						_voyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2018	jlger1	Initial creation tfs 240629
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object

*/

vars
	cargoTypeObj        : CM_CargoType;
	totalQuantity : Integer;
	cargoWeight,
	tareWeight,
	totalVolume : Decimal [14,4];
	totalWeight : Decimal [14,4];
	product 			: CM_Product;
	commodity : CM_Commodity;
	jobTransferType : Integer;
	voyageJobTransferType : CM_VoyageJobTransferType;
	holdLocation : CM_GeneralCargoController;
	requiredDT : TimeStamp;
begin
	cargoTypeObj:=_cmif.getCargoType(commodity);
	if cargoTypeObj &lt;&gt; null then
		if cargoTypeObj.isSubCargoTypeRequired then
			product:= cargoTypeObj.allProducts.first;
		endif;
		
		totalWeight:= _cmif.ton.Decimal * 1000;
		if cargoTypeObj.isBulkByVolume then
			if product= null then		
				product := cargoTypeObj.mySystemProductType;		
			endif;
			totalWeight:=_cmif.m3.Decimal * product.myDensityDec.value;		// ### TFS 52193 22Nov2021 NAVPW1
		
		elseif cargoTypeObj.isBreakBulkMulti then
			totalQuantity:=_cmif.unit.Integer;
		endif;
	endif;
	totalVolume:=_cmif.m3.Decimal;

	requiredDT:=null;
	if _cmif.kegiatan.toUpper = "BONGKAR" then
		self.imexStatus := TI_IMEX_STATUS_IMPORT;
		if _cmif.rencanaBongkar &lt;&gt; null then
			requiredDT:=_cmif.rencanaBongkar.asTimeStampFromInaportnet;
			self.estimatedStartTS := requiredDT;	//30 Oct 2018	NDL	TFS 41649
		endif;
	elseif _cmif.kegiatan.toUpper = "MUAT" then
		self.imexStatus := TI_IMEX_STATUS_EXPORT;
		if _cmif.rencanaMuat &lt;&gt; null then
			requiredDT:=_cmif.rencanaMuat.asTimeStampFromInaportnet;
			self.estimatedStartTS := requiredDT;	//30 Oct 2018	NDL	TFS 41649
		endif;
	elseif _cmif.kegiatan = "BM" then
		// something else??
	endif;
	voyageJobTransferType := app.myRoot.getVoyJobTransferTypeByCode(_cmif.penyaluran);
	if voyageJobTransferType &lt;&gt; null then	
		jobTransferType:=voyageJobTransferType.id;
	endif;
	
	if _voyage &lt;&gt; null then
		if _voyage.myGeneralCargoVoyage &lt;&gt; null then
			holdLocation:=_voyage.myGeneralCargoVoyage.allLocationsByOrdinal.first;
		endif;
	endif;
	
	self.numGangs := 	_cmif.gang.asIntegerJMT;

	self.totalQuantity := totalQuantity;
	self.totalVolume := totalVolume;
	self.totalWeight := totalWeight;
	self.transferType := jobTransferType;
	self.weightCargo := cargoWeight;
	self.weightTare := tareWeight;
	self.myCargoSubType := product;
	self.myCargoType := cargoTypeObj;
	self.myCommodity := commodity;
	self.myConsignee := _cmif.getConsignee();
	self.myConsignor := _cmif.getConsignor(); //epr  TFS 41758 5/11/18
	self.myOperator :=_cmif.getOperator(); 
	self.myLocationsController :=holdLocation;
	//epr TFS 42095 22/11/18
	if _voyage &lt;&gt; null then
		self.setMyWorkPoint( _cmif.getWorkPoint(  _voyage.myTerminal) );
	else
		self.setMyWorkPoint( _cmif.getWorkPoint(  app.myPassport.myTerminal) );
	endif;
	
	
	self.bolNumber := _cmif.blNo;

	if self.imexStatus = TI_IMEX_STATUS_IMPORT then
		self.setRKBMNumber(_cmif.noRkbmBongkar);
	else
		self.setRKBMNumber(_cmif.noRkbmMuat);
	endif;
													
	self.setRequiredByDT(requiredDT);

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_IPNRKBMDetailItem" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setProxyForPermit" id="90714927-d9bc-45cb-b069-1559ef1b23ec">
        <updating/>
        <source>setProxyForPermit(_weight : Decimal; _quantity : Integer; _transfer : Integer; _workpoint : CM_WorkPoint; _numgangs : Integer; _cargo : CM_TrackedItem) updating;
/*
Purpose:	// TFS 42221 19DEC18		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/


vars

begin
	self.totalQuantity 		:= _quantity;
	self.totalWeight 		:= _weight;
	self.transferType 		:= _transfer;
	self.myWorkpoint		:= _workpoint;
	self.numGangs 			:= _numgangs;
	self.myCargoType 		:= _cargo.myCargoType;
	self.myCargoSubType 	:= _cargo.myProduct;
	self.dischargePort 		:= _cargo.dischargePort;
	self.myConsignee 		:= _cargo.myConsignee;
	self.myConsignor 		:= _cargo.getConsignorObject();
	self.myFreightForwarder := _cargo.myFreightForwarder;
	self.myOperator 		:= _cargo.myOperator;
	self.taskID 			:= _cargo.id;
	
epilog

end;</source>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_transfer" type="Integer"/>
        <Parameter name="_workpoint" type="CM_WorkPoint"/>
        <Parameter name="_numgangs" type="Integer"/>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromWLE" id="b5dbe118-0f42-451f-bc35-73d6fb6d3c2b">
        <updating/>
        <source>setProxyFromWLE(_wle : CM_VoyageWLE ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation 39166
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object

*/

vars
	cargo : CM_TrackedItem;
	voyageJob : CM_VoyageHoldJob;
	workPointObj : CM_Object;
begin
	if _wle = null then 
		return;
	endif;
	
	if _wle.myTrackedItem = null then
		return;
	endif;
	cargo:= _wle.myTrackedItem;
	
	if not _wle.job.isKindOf(CM_VoyageHoldJob) then
		return;
	endif;
	voyageJob :=_wle.job.CM_VoyageHoldJob;
	
	//set the cargo stuff
	self.dischargePort:=cargo.dischargePort;
	self.loadPort := cargo.loadPort; //20 Jul 2018	NDL	TFS 39837
	self.bolNumber:=cargo.billOfLading;
	self.imexStatus := cargo.getImExStatus;
	self.myCargoType := cargo.myCargoType;
	self.myCargoSubType:=cargo.myProduct;
	self.myCommodity:=cargo.getCommodityObject;
	self.myConsignee:=cargo.myConsignee;
	self.myConsignor:=cargo.getConsignorObject;
	self.myFreightForwarder:=cargo.myFreightForwarder;
	self.myOperator:=cargo.myOperator;
	self.totalQuantity:=cargo.totalQuantity;
	self.totalVolume:=cargo.totalVolume;
	self.totalWeight:=cargo.totalWeight;
	self.weightCargo:=cargo.weightCargo;
	self.weightTare:=cargo.weightTare;
	
	//set the job stuff
	//self.myBerth:=voyageJob.
	workPointObj:=voyageJob.getMyWorkPointObject;
	if workPointObj &lt;&gt; null and workPointObj.isKindOf(CM_WorkPoint) then
		self.setMyWorkPoint( workPointObj.CM_WorkPoint );
	endif;
	self.estimatedEndTS:=voyageJob.estimatedEndTS;
	self.estimatedStartTS:=voyageJob.estimatedStartTS;
	self.numGangs:=voyageJob.numOfGangs;
	self.transferType:=voyageJob.transferType;
epilog

end;</source>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="setProxyWodCargoRequest" id="bbc51b4e-684a-4656-b2f2-b850e1959a4c">
        <updating/>
        <source>setProxyWodCargoRequest(	_dischargePort : String;
							_imexStatus : Integer;
							_numGangs : Integer;
							_totalQuantity : Integer;
							_totalVolume : Decimal;
							_totalWeight : Decimal;
							_transferType : Integer;
							_weightCargo : Decimal;
							_weightTare : Decimal;
							_myCargoSubType : CM_Product;
							_myCargoType : CM_CargoType;
							_myCommodity : CM_Commodity;
							_myConsignee : CM_ConsigneeConsignor;
							_myConsignor : CM_ConsigneeConsignor;
							_myFreightForwarder : CM_ConsigneeConsignor;
							_myLocationsController : CM_LocationsController;
							_myOperator : CM_Operator;
							_myWorkpoint : CM_WorkPoint;
							_allFiles : CM_FileDataSet;
							_permitType : Integer; //27 Jun 2018	NDL	TFS 39246
							_loadPort : String;	//20 Jul 2018	NDL	TFS 39837
							_bolNumber : String;	//20 Jul 2018	NDL	TFS 39837
							_estStartTS : TimeStamp;	//20 Jul 2018	NDL	TFS 39837
							_estEndTS : TimeStamp	//20 Jul 2018	NDL	TFS 39837
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation	TFS 38560
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object

*/

vars

begin
	if app.myRoot.allPorts[_dischargePort] &lt;&gt; null then
		self.dischargePort := _dischargePort;
	endif;
	self.imexStatus := _imexStatus;
	self.numGangs := _numGangs;
	self.permitType := _permitType; //27 Jun 2018	NDL	TFS 39246
	self.totalQuantity := _totalQuantity;
	self.totalVolume := _totalVolume;
	self.totalWeight := _totalWeight;
	self.transferType := _transferType;
	self.weightCargo := _weightCargo;
	self.weightTare := _weightTare;
	
	self.loadPort := _loadPort;	//20 Jul 2018	NDL	TFS 39837
	self.bolNumber := _bolNumber;	//20 Jul 2018	NDL	TFS 39837
	self.estimatedStartTS := _estStartTS;	//20 Jul 2018	NDL	TFS 39837
	self.estimatedEndTS := _estEndTS;	//20 Jul 2018	NDL	TFS 39837
	
	self.myCargoSubType := _myCargoSubType;
	self.myCargoType := _myCargoType;
	self.myCommodity := _myCommodity;
	self.myConsignee := _myConsignee;
	self.myConsignor := _myConsignor;
	self.myFreightForwarder := _myFreightForwarder;
	self.myLocationsController := _myLocationsController;
	self.myOperator := _myOperator;
	self.setMyWorkPoint( _myWorkpoint );
	
	self.allFiles.clear();
	if _allFiles &lt;&gt; null then
		_allFiles.copy( self.allFiles );
	endif;
epilog

end;</source>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_numGangs" type="Integer"/>
        <Parameter name="_totalQuantity" type="Integer"/>
        <Parameter name="_totalVolume" type="Decimal"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_transferType" type="Integer"/>
        <Parameter name="_weightCargo" type="Decimal"/>
        <Parameter name="_weightTare" type="Decimal"/>
        <Parameter name="_myCargoSubType" type="CM_Product"/>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_myCommodity" type="CM_Commodity"/>
        <Parameter name="_myConsignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_myConsignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="_myFreightForwarder" type="CM_ConsigneeConsignor"/>
        <Parameter name="_myLocationsController" type="CM_LocationsController"/>
        <Parameter name="_myOperator" type="CM_Operator"/>
        <Parameter name="_myWorkpoint" type="CM_WorkPoint"/>
        <Parameter name="_allFiles" type="CM_FileDataSet"/>
        <Parameter name="_permitType" type="Integer"/>
        <Parameter name="_loadPort" type="String"/>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_estStartTS" type="TimeStamp"/>
        <Parameter name="_estEndTS" type="TimeStamp"/>
    </JadeMethod>
