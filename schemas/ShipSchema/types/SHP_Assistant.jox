    <JadeMethod name="showVoyagePlanningForm" id="0d2dbf07-b681-477c-8582-210a59a324d4">
        <source>showVoyagePlanningForm(_voyage : CM_Voyage; _bay : CM_Bay input; _displayMode : Integer;_menuAction : CMUI_MenuAction );
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	plnForm : SHP_VoyageAreaForm2;
	menuAction : CMUI_MenuAction;
	alreadySeen : Boolean;
begin
	if _voyage = null and _bay = null then
		return;
	endif;
	
	plnForm := app.getForm(SHP_VoyageAreaForm2::name.name).SHP_VoyageAreaForm2; //PAR 21596
	if plnForm = null then
		plnForm := app.loadForm(SHP_VoyageAreaForm2, SHP_Assistant, false, false, true, self.myTerminal, _menuAction).SHP_VoyageAreaForm2;
		if plnForm = null then
			return;
		endif;
	else
		alreadySeen := true;
	endif;

	if plnForm = null then
		return;
	endif;

	if _bay &lt;&gt; null then			
		plnForm.myCurrentVoyage := _voyage;
		//cnwjo3 par 23105
		app.setMyCurrentVoyage(_voyage);
		
		plnForm.allSelectedHolds.clear(); // PAR 21596
		plnForm.allSelectedHolds.addNoDuplicates(_bay.myHold, false); // PAR 21596
		plnForm.allSelectedBays.clear(); // PAR 21596
		plnForm.allSelectedBays.addNoDuplicates(_bay.CM_BayVoyage, false); // PAR 21596
		plnForm.myStartUpBay := _bay; // Par14064 Mohammad 17/5/2007
		plnForm.displayModeHistory := _displayMode; 
		if alreadySeen then  // PAR 21596
			plnForm.voyageLoad(_displayMode);  // PAR 21596
		else
			plnForm.show();
		endif;
	endif;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_bay" type="CM_Bay" usage="input"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
