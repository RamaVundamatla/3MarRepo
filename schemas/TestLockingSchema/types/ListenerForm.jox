<GUIClass name="ListenerForm" id="5d7880be-1400-4905-9bcb-c20d236c20a5">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lstLog" id="4f3030bb-4468-4ad0-879c-334adbd6df6b">
        <embedded/>
        <type name="ListBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="load" id="fc840a68-da2c-4957-b266-1032cb0d1576">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

begin
	self.caption := self.caption  &amp; " " &amp; node.String;
	
	self.beginClassNotification(ParentClass, false, Any_System_Event, Response_Continuous, null);
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="logMsg" id="19201b84-ebe9-4886-941a-df3ad03ea913">
        <source>logMsg(_msg: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

begin
	self.lstLog.addItemAt(_msg, 1);
	inheritMethod(_msg);
	

epilog

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="ed3d68ac-8672-4c29-8ae7-1f44a794a5d3">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	invalid			: Boolean;
	s				: String;
	name			: String;
	
begin
	if eventType = Object_Delete_Event then
		self.logMsg(method.qualifiedName &amp; " Object_Delete_Event " &amp; theObject.String);
		
	else
		on Exception do app.handleDeletedObject(exception, theObject, invalid);
		
		if eventType = Object_Create_Event then
			s := "Object_Create_Event";
		else
			s := "Object_Update_Event";
		endif;
	
		name := "** deleted **";
		name := theObject.ParentClass.getDescription();
		self.logMsg(method.qualifiedName &amp; " " &amp; s &amp; " " &amp; theObject.String &amp; " " &amp; name);
	
	endif;
	
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
