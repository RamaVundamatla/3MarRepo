    <JadeMethod name="setEndDT" id="3a5828a7-99e9-4c38-80e5-ac3a736f7607">
        <updating/>
        <source>setEndDT(_value :TimeStamp)updating;
/*
Date		Who		Reason
21 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars

begin
