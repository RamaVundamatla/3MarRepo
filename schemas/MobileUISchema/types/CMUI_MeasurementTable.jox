    <JadeMethod name="setValueDefault" id="d3c19961-eb02-41eb-97e0-863e3719be19">
        <updating/>
        <source>setValueDefault(_value : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2013	cnwdap1	Initial creation
*/
vars
	measure		: CM_MeasurementType;
	unit		: String;
	converted	: String;

begin
	if self.measurementType &lt;&gt; null then
		measure := app.getDefaultMeasurementForType(self.measurementType);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit, _value.Decimal);
		self.setValues(converted &amp; Space &amp; unit);
	endif;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setValues" id="c163b5a6-cca6-4e2b-9595-d077fe2031c2">
        <updating/>
        <source>setValues(_str : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 UImperial Measurements
*/
vars
	pos, width	: Integer;
	value, unit : String;
	measure		: CM_MeasurementType;

begin
	pos := _str.reversePos(Space);
	if pos &lt;&gt; null then
		value := _str[1:pos-1];
		unit := _str[pos+1:end];
		self.accessCell(1, self.ColumnUnit).text := unit;
		self.change(self);
		measure := app.myRoot.allMeasurementTypesByShortName[unit];
		if measure &lt;&gt; null then
			value := measure.removeDecimalZeros(value);
		endif;
		self.accessCell(1, self.ColumnValue).text := value;
	endif;
	width := self.getTextExtent(value);
	if width &lt; 40 then
		width := 40;
	endif;
	if self.parent.isKindOf(Table) then
		self.setColumnWidths(width + 10, self.getTextExtent(unit) + 40);
	endif;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setup" id="185f16e3-3025-4f2d-9201-9167663a4d8b">
        <updating/>
        <source>setup(_type : String; _backColor : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	self.measurementType := _type;
	self.loadCombo;
	self.change(self);
	self.accessColumn(self.ColumnSpacer).width := 5;
	self.accessColumn(self.ColumnSpacer).backColor := _backColor;
	if not self.parent.isKindOf(Table) then
		self.tabKey := J_key_Tab;
	endif;
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_backColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="d9183f33-8502-432c-80ed-15e0d7bd1314">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2013	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.columns := 3;
	self.rows := 1;
	self.fixedRows := 0;
	self.fixedColumns := 0;
	self.show3D := self.Show3D_Not3D;
	self.alignment := self.Alignment_Left_Middle;
	self.scrollBars := self.ScrollBars_None;
	
	self.accessCell(1, self.ColumnValue).inputType := self.InputType_TextNumeric;
	self.accessedCell.cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	self.accessCell(1, self.ColumnUnit).inputType := self.InputType_ComboBox;
	self.accessCell(1, self.ColumnSpacer).inputType := self.InputType_None;
	
	self.accessColumn(self.ColumnSpacer).enabled := false;
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
