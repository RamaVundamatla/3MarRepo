    <JadeMethod name="executePostMoveForOrigLocation" id="f68e276a-69c1-4b47-aadd-4de5663bc8c8">
        <updating/>
        <source>executePostMoveForOrigLocation(control: CMIF_MoveController; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwjk3	Initial creation

*/

vars
	aTI : CM_TrackedItem;
begin
	inheritMethod(control, _passport);
	self.reCalcUsedLength(control, false);
	
	if control.moveMode = REAL_MODE then  // cnwrd1 par 28940 21.2.2012
		foreach  aTI in self.allTrackedItems do
			aTI.refreshLocationId(REAL_MODE);
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
