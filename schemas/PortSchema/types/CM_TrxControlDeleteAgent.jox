    <JadeMethod name="trxDeleteEDIActions" id="994f3b2c-949d-4adf-ab57-9edb78f3bb5a">
        <updating/>
        <source>trxDeleteEDIActions(_ediActionSet : CM_EDIActionSet io; _passport : CM_Passport input) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		19 November 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	ediAction : CM_EDIAction;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	foreach ediAction in _ediActionSet discreteLock do
		app.myUtilityDA.utlDeleteEDIAction(ediAction, _passport);
	endforeach;
	
	if _passport.hasErrorsOrWarnings() then
		return;
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ediActionSet" type="CM_EDIActionSet" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
