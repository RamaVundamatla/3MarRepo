        <source>doBaseFormCancel() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2009	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.hasChanged then
		if self.confirmCancel(app.getErrorString(The_Current_Item)) then
			self.unloadForm();
		else
			return;
		endif;
	else	
	self.unloadForm();
	endif;

epilog

end;</source>
