//--------------------------------------------------------------
//Created: 31 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;
	
begin

	if _location = null then
		return null;
	endif;

	//epr par 30528 17/10/12
	if _location.isKindOf(CM_GridController) and not _location.CM_GridController.amIAvailable then
		return null;
	endif;
	
	if (not _location.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	return _location.displayEntry();
end;</source>
