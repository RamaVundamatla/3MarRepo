    <JadeMethod name="setCurrentInvoice" id="e294c52b-1d3c-45a9-8dee-a2d48a41ac02">
        <updating/>
        <source>setCurrentInvoice(_invoice : CM_Invoice)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars

begin
	self.myCurrentInvoice := _invoice;
epilog

