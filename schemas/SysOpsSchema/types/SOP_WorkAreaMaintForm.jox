    <JadeMethod name="addTerminalAreaToTable" id="754365b9-cc98-48cd-b8a7-95f956070e84">
        <source>addTerminalAreaToTable( _ta : CM_TerminalArea ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2014	cnwndl1	Initial creation	Par 33995
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	terminalAreaLineStr : String;
	index : Integer;
	expandTermArea : String;
	gridArea : CM_GridArea;
	gridObject : CM_GridObject;
	obj : Object;
	roroCont : CM_RoRoController;
	loadSubObjects : Boolean;

begin

	if ( _ta.allLocationsControllers.size &lt; 2 )
	//or ( not _ta.isKindOf( CM_GridArea ) and not _ta.isKindOf( CM_RoRoLaneArea ) )													// TFS 49453
	or ( not _ta.isKindOf( CM_GridArea ) and not _ta.isKindOf( CM_RoRoLaneArea ) and not _ta.isKindOf( CM_GeneralCargoAllocRowArea ))	// TFS 49453
	or _ta.type = TA_TYPE_YARD_INTERCHANGE
	or _ta.isKindOf( CM_AreaWithLanes )
	then
		expandTermArea := Exp_Hide;
	else
		expandTermArea := Exp_Expand;
	endif;
	
	terminalAreaLineStr :=	"0" &amp; Tab // Col_Incl_TA
							&amp; _ta.id &amp; Tab // Col_Ta_Name
							&amp; expandTermArea &amp; Tab // Col_Expand_TA
							&amp; " " &amp; Tab // Col_Incl_SubArea
							&amp; " " &amp; Tab // Col_SubArea_Name
							&amp; " " &amp; Tab // Col_Expand_SubArea
							&amp; " " &amp; Tab // Col_Incl_Location
							&amp; " ";  //Col_Location_Name

	index := self.tblAreas.addItem( terminalAreaLineStr );
	self.allLoadedObjects.addNoDuplicates( _ta, false );
	self.tblAreas.accessRow(index).itemObject := _ta;
	self.tblAreas.accessCell(index,Col_Incl_TA).inputType := Table.InputType_CheckBox;
	
	if self.locationAlreadyUsed( _ta ) then
		self.tblAreas.accessRow(index).enabled := false;
		self.tblAreas.accessRow(index).backColor := Grey;
		return;
	endif;
	
	if _ta.allLocationsControllers.size &lt; 2 then
		return;
	endif;
	
	loadSubObjects := self.doLoadSubObjects( _ta );
	
	if loadSubObjects then
		self.loadTerminalAreaSubObjects( _ta, 0 );
	endif;
	
epilog

//	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
