    <JadeMethod name="deleteWorkOrderNoValidation" id="ee0fb493-60b0-4c98-b005-2c79cf00eb7b">
        <source>deleteWorkOrderNoValidation(_workOrder : String);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/03/2022	navdap1		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema 
//
vars
	workOrder : CM_WorkOrder;
	term      : CM_Terminal;
	wod       : CM_WorkOrderDtl;
	job		  : CM_Job;
	jobArr    : CM_JobArray;
	wodTodo	  : CM_WodToDo;
begin
	create jobArr transient;
	
	term      := self.getMyTerminal();
	workOrder := term.allWorkOrders[_workOrder];
	if workOrder &lt;&gt; null then
		
		foreach wod in workOrder.allWoDtls do
			
			if wod.isKindOf(CM_WorkOrderTIDtl) then
				foreach job in wod.CM_WorkOrderTIDtl.allJobs do
					jobArr.add(job);
				endforeach;
				foreach wodTodo in  wod.CM_WorkOrderTIDtl.allToDoRequests do 
					
					foreach job in wodTodo.allJobs do
						jobArr.add(job);
					endforeach;
				endforeach;
			elseif wod.isKindOf(CM_WorkOrderToDoDtl) then
				foreach job in wod.CM_WorkOrderToDoDtl.allJobs do
					jobArr.add(job);
				endforeach;
			endif;
		endforeach;
		
		beginTransaction;
		
		jobArr.purge();
		
		workOrder.erase(NORMAL_ERASE);
		
		commitTransaction;
		self.assertNull(term.allWorkOrders[_workOrder]);
	endif;
epilog
	delete jobArr;
end;</source>
        <Parameter name="_workOrder" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteWorkPoint" id="c8cbfccf-3052-4e05-8a6c-808cbec9811d">
        <source>deleteWorkPoint(_code : String);
//
//27 November 2017	jlgrs1	Initial creation
//
vars
	realWorkPoint	    : CM_WorkPoint;
	obj					: Object;
	objArray 			: ObjectArray;
	voyage				: CM_Voyage;
	jobSheetArray		: CM_JobSheetArray;

begin
	realWorkPoint := self.getTerminal.allWorkPointsByCode[_code];
	if realWorkPoint &lt;&gt; null then
		beginTransaction;
		foreach obj in realWorkPoint.allCraneOpHrsExchange do
			delete obj;
		endforeach;
		foreach obj in realWorkPoint.allCraneOpHrsLabour do
			delete obj;
		endforeach;
		foreach obj in realWorkPoint.allDelays do
			delete obj;
		endforeach;
		foreach obj in realWorkPoint.allKPIVoyageMoveDtls do
			delete obj;
		endforeach;
		commitTransaction;
		
		
		create objArray transient;
		realWorkPoint.allVoyageWorkPointQueues.copy(objArray);
		foreach obj in objArray do
			self.deleteQueue(obj.CM_VoyageWorkPointQueue);
		endforeach;
		
		voyage := self.opts.obj("Voyage").CM_Voyage;
		
		create jobSheetArray transient;
		realWorkPoint.allJobSheets.copy(jobSheetArray);
		foreach obj in jobSheetArray do
			if obj.isKindOf(CM_VoyageJobSheet) then
				self.deleteVoyageJobSheet(obj.CM_VoyageJobSheet);
			endif;
		endforeach; 
		
		app.myTrxDA.trxDeleteWorkPoint(realWorkPoint, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog

	delete jobSheetArray;
	delete objArray;

end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteYA" id="ef4b84c6-2d31-4f2b-8576-0e8da0f23f99">
        <source>deleteYA(name: String);
//17 July 2008	cnwdw1	
//
vars
	ya : CM_YardAllocation;
begin
	ya := self.getTerminal.allYardAllocatonsByCode[name];
	if ya &lt;&gt; null then
		app.myTrxDA.trxDeleteYardAllocation(ya, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
