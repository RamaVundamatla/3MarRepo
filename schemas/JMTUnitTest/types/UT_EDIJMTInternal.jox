    <JadeMethod name="tDeckStowageAdviceAction" id="d09a2b64-186e-4156-83ca-83801df56337">
        <source>tDeckStowageAdviceAction();
//
//14 August 2017	jlgrs1	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	USER_DEF_NAME : String = "JMTInternalStowageAdvice";
	VoyageName = 'VOY002BOL';
	ShipName = 'Ship001';
	TestOperator = 'MSK';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	passportObj := app.myPassport;
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(ShipName);
	vessel := self.getVessel(ShipName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(ShipName, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage	:= self.addVoyageWithContainerStructur(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalDeckStowageAdvice xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalDeckStowageAdvice.xsd"&gt;
	&lt;AllVoyage&gt;
		&lt;Voyage&gt;
			&lt;position/&gt;
			&lt;cargoTypeDescr/&gt;
			&lt;description/&gt;
			&lt;fullOrMT/&gt;
			&lt;id/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;vesselName&gt;'&amp;ShipName&amp;'&lt;/vesselName&gt;
&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;AllLayout&gt;
				&lt;Layout&gt;
					&lt;isRotationMaster/&gt;
					&lt;weight/&gt;
					&lt;area/&gt;
					&lt;longPos/&gt;
					&lt;transPos/&gt;
					&lt;vertPos/&gt;
					&lt;cargoTypeDescr/&gt;
					&lt;description/&gt;
					&lt;fullOrMT/&gt;
					&lt;id/&gt;
					&lt;layoutId/&gt;
					&lt;layoutType/&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;rotation/&gt;
						&lt;AllLayoutPoint&gt;
							&lt;LayoutPoint&gt;
								&lt;longPos/&gt;
								&lt;transPos/&gt;
								&lt;pointOrder/&gt;
								&lt;cargoTypeDescr/&gt;
								&lt;description/&gt;
								&lt;fullOrMT/&gt;
								&lt;id/&gt;
								&lt;layoutId/&gt;
								&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;/LayoutPoint&gt;
						&lt;/AllLayoutPoint&gt;
				&lt;/Layout&gt;
			&lt;/AllLayout&gt;
			&lt;AllStowageAdvice&gt;
				&lt;StowageAdvice&gt;
					&lt;isTranshipItem/&gt;
					&lt;height/&gt;
					&lt;length/&gt;
					&lt;weight/&gt;
					&lt;width/&gt;
					&lt;cooledType/&gt;
					&lt;loadOrder/&gt;
					&lt;quantity/&gt;
					&lt;temperature/&gt;
					&lt;bookingRef/&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;commodity/&gt;
					&lt;commodityDescription/&gt;
					&lt;description/&gt;
					&lt;destinationPort/&gt;
					&lt;dischargePort/&gt;
					&lt;fullOrMT/&gt;
&lt;stowageId&gt;D1010&lt;/stowageId&gt;
					&lt;isoType&gt;2200&lt;/isoType&gt;
					&lt;isoTypeGroup/&gt;
					&lt;loadPort/&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;mode&gt;LOA&lt;/mode&gt;
					&lt;newStowageId/&gt;
					&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
					&lt;remarks/&gt;
					&lt;stowageId/&gt;
				&lt;/StowageAdvice&gt;
			&lt;/AllStowageAdvice&gt;
		&lt;/Voyage&gt;
	&lt;/AllVoyage&gt;
&lt;/JMTInternalDeckStowageAdvice&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tDriverAction" id="45205457-52f9-4114-8814-58c0dda9b3d5">
        <source>tDriverAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalDriver";
	DRIVER : String = "DRIVER01";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	driver : CM_DriverDetails;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	self.deleteDriverDetails(DRIVER);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalDriver xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalDriver.xsd"&gt;
	&lt;AllDriver&gt;
		&lt;Driver&gt;
			&lt;action&gt;A&lt;/action&gt;
			&lt;cargoTypeDescr&gt;&lt;/cargoTypeDescr&gt;
			&lt;carriers&gt;&lt;/carriers&gt;
			&lt;code&gt;'&amp;DRIVER&amp;'&lt;/code&gt;
			&lt;description&gt;&lt;/description&gt;
			&lt;driverStatus&gt;&lt;/driverStatus&gt;
			&lt;fullOrMT&gt;&lt;/fullOrMT&gt;
			&lt;id&gt;&lt;/id&gt;
			&lt;messageMode&gt;&lt;/messageMode&gt;
			&lt;name&gt;Stuff&lt;/name&gt;
			&lt;secondaryCode&gt;&lt;/secondaryCode&gt;
			&lt;vehicles&gt;&lt;/vehicles&gt;
		&lt;/Driver&gt;
	&lt;/AllDriver&gt;
&lt;/JMTInternalDriver&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	driver := self.getDriverDetails(DRIVER);
	self.assertNotNull(driver);
	self.assertEqualMsg(driver.name, "Stuff", "wrong name");
	
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalDriver xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalDriver.xsd"&gt;
  &lt;AllDriver&gt;
    &lt;Driver&gt;
      &lt;action&gt;U&lt;/action&gt;
      &lt;cargoTypeDescr&gt;&lt;/cargoTypeDescr&gt;
      &lt;carriers&gt;&lt;/carriers&gt;
      &lt;code&gt;'&amp;DRIVER&amp;'&lt;/code&gt;
      &lt;description&gt;&lt;/description&gt;
      &lt;driverStatus&gt;&lt;/driverStatus&gt;
      &lt;fullOrMT&gt;&lt;/fullOrMT&gt;
      &lt;id&gt;&lt;/id&gt;
      &lt;messageMode&gt;&lt;/messageMode&gt;
      &lt;name&gt;MoreStuff&lt;/name&gt;
      &lt;secondaryCode&gt;&lt;/secondaryCode&gt;
      &lt;vehicles&gt;&lt;/vehicles&gt;
    &lt;/Driver&gt;
  &lt;/AllDriver&gt;
&lt;/JMTInternalDriver&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	driver := self.getDriverDetails(DRIVER);
	self.assertNotNull(driver);
	self.assertEqualMsg(driver.name, "MoreStuff", "wrong name");
	
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalDriver xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalDriver.xsd"&gt;
  &lt;AllDriver&gt;
    &lt;Driver&gt;
      &lt;action&gt;D&lt;/action&gt;
      &lt;cargoTypeDescr&gt;&lt;/cargoTypeDescr&gt;
      &lt;carriers&gt;&lt;/carriers&gt;
      &lt;code&gt;'&amp;DRIVER&amp;'&lt;/code&gt;
      &lt;description&gt;&lt;/description&gt;
      &lt;driverStatus&gt;&lt;/driverStatus&gt;
      &lt;fullOrMT&gt;&lt;/fullOrMT&gt;
      &lt;id&gt;&lt;/id&gt;
      &lt;messageMode&gt;&lt;/messageMode&gt;
      &lt;name&gt;Stuff&lt;/name&gt;
      &lt;secondaryCode&gt;&lt;/secondaryCode&gt;
      &lt;vehicles&gt;&lt;/vehicles&gt;
    &lt;/Driver&gt;
  &lt;/AllDriver&gt;
&lt;/JMTInternalDriver&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	driver := self.getDriverDetails(DRIVER);
	self.assertIsDeleted(driver);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tEDIReleaseRequestForWagon" id="f1df652d-fec1-44e3-812a-f0561698a9a0">
        <updating/>
        <source>tEDIReleaseRequestForWagon() updating;
//	navra1
constants
	
	VoyageName = "UTRRFW_1";	
	ReleaseRequestNo = "UTRRFW_RR1";	
	TestOperator = 'TRAM';
	TrainName1 = 'UTTRN_WAG';	
	WagonCode = "IX";
	Tr1_WagonName1 = 'IX101';
	Tr1_WagonName2 = 'IX102';	
	TrainName2 = 'UTRRFWTR2';
	Tr2_WagonName1 = 'SK001';
	Tr2_WagonName2 = 'SK002';	
	RAIL_AREA_ID1 	: String = "ZRA001";
	RAIL_AREA_ID2 	: String = "ZRA002";
	BULKCargoType 	: String = "UTDRBULK";		
	VES_CODE 		: String = "UTZVES1";
	VOY_CODE 		: String = "UTZVOY1";	
	BBCargoType 	: String = "UTREBAR"; 	
	UT_WagonReleaseRequest= 'UT Release Request';
	LINE_NUMBER=3;
	
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	ediFile : CM_EDIFile;
	text : String;
	
	tempStr : String;
	passportObj : CM_Passport;
	operator : CM_Operator;
	relRequest : CM_BulkRelease;
	
	shipLineStr 	: String;
	railArea1 		: CM_Rail;
	railLine1 		: CM_RailLine;	
	train1 : CM_Train;
	tr1_wagon1 : CM_Wagon;
	tr1_wagon2 : CM_Wagon;
	bbCargoType 	: CM_CargoType;		
	
	wagMoveControl	: CMIF_WagonMoveController;
	allWagons1: CM_WagonArray;
	wagonClass : CM_WagonClass;	
	
	configCMIF		: CMIF_ConfigOperator;
	codeGroupsColl	: CM_CodeGroupsByTypeDict;	
	emailAddresses	: CM_EmailEntityByTypeNameDict;
	
	loop : Integer;
	lc : CM_WagonController;
	arr:IntegerArray;
	
	totalAllocatedQtyInJobs : Integer;
	
	iter : Iterator;
	wle:CM_WorkListEntry;
	
	oldConfig : Any;
	
begin		

	oldConfig := self.setTerminalConfig(RailReleaseAssignEnhance, true);
	
	create configCMIF transient;		// this is required to pass some extra fields
	create codeGroupsColl transient;
	create emailAddresses transient;	// need to put empty emailAddresses, otherwise there is UE 1090
	
	self.deleteOperator(TestOperator);
	
	operator := self.addOperator(TestOperator, "Awf", null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,codeGroupsColl,null,null,null,null,emailAddresses,null,configCMIF, false, false);	
	passportObj	:=	app.myPassport;
	operator := self.getOperator(TestOperator);
	
	//delete the train and wagons
	wagonClass	:=	app.myRoot.allWagonClasses[WagonCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	self.deleteTrainAndWagons(TrainName1);	
	self.deleteRailArea(RAIL_AREA_ID1);
	
	//delete the release request
	self.deleteReleaseRequest(ReleaseRequestNo);
	relRequest := self.getReleaseRequest(ReleaseRequestNo);
	self.assertIsDeleted(relRequest);
	
	//delete vessel and voyage
	self.deleteVoyage(VOY_CODE);
	self.deleteVessel(VES_CODE);
	
	//setup voyage and release request
	//setup a voyage through with the release cargo comes in and create the release request	next
	vessel := self.addVesselGeneralCargo(VES_CODE, operator, 10);
	self.assertNotNullMsg(vessel, 'vessel');
	voyage := self.addVoyageWithGeneralCargoStruc(VOY_CODE, VES_CODE, operator.code, shipLineStr, 0);
	self.assertNotNullMsg(voyage, 'voyage');
	
	// Create Release Request
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBCargoType);
	if bbCargoType = null then
		self.addCargoType(BBCargoType, false);
		bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBCargoType);
	endif;
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBCargoType &amp; "' not found and could not be created during setup.");
	self.opts.purge();
	self.opts.addAssoc( "number", 10.Integer);	
	self.opts.addAssoc( "FullRelease", true );  // otherwise it defaults to empties only
	self.opts.addAssoc( "Voyage", voyage );
	relRequest := self.addReleaseByTypeRequestOpts(ReleaseRequestNo, BR_TYPE_RAIL, bbCargoType.id);
	
	self.assertTrueMsg(relRequest &lt;&gt; null, "Failed to set up Rail Release 1");
	
	//add 4 more reservations to this release - so in all 5 reservations(1,2,3,4, and 5)
	self.addReserveSelectionOpts(relRequest, CM_ReserveDetail.PackType_Parent, bbCargoType.id);	
	self.addReserveSelectionOpts(relRequest, CM_ReserveDetail.PackType_Parent, bbCargoType.id);	
	self.addReserveSelectionOpts(relRequest, CM_ReserveDetail.PackType_Parent, bbCargoType.id);	
	self.addReserveSelectionOpts(relRequest, CM_ReserveDetail.PackType_Parent, bbCargoType.id);	
	
	//create a train
	train1 :=	self.addTrain(TrainName1, null);
	self.assertNotNull(train1);
	
	//create a newrail area
	railArea1	:=	self.addRailArea(RAIL_AREA_ID1, 4, 5);
	self.assertNotNull(railArea1);
	railLine1	:=	railArea1.allRailLinesByIndex[1];
	
	//create new wagon
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "250".Decimal);	
	self.opts.addAssoc("InternalHeight", 200.Decimal);
	self.opts.addAssoc("InternalLength", 200.Decimal);
	self.opts.addAssoc("InternalWidth", 200.Decimal);
	self.opts.addAssoc("ExternalHeight", 201.Decimal);
	self.opts.addAssoc("ExternalLength", 201.Decimal);
	self.opts.addAssoc("ExternalWidth", 201.Decimal);
	self.opts.addAssoc("Tare", "5443".Decimal);	
	
	
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Boxcar);
	
	wagonClass := self.addWagonClass(WagonCode);
	
	create allWagons1 transient;
	tr1_wagon1 := self.addWagonInRailArea(Tr1_WagonName1, Tr1_WagonName1[1:2], railArea1, train1);
	self.assertTrueMsg(tr1_wagon1 &lt;&gt; null,"Wagon not created. ");
	updateTrainWagon(tr1_wagon1,train1);
	
	allWagons1.add(tr1_wagon1);
	
	tr1_wagon2 := self.addWagonInRailArea(Tr1_WagonName2, Tr1_WagonName2[1:2], railArea1, train1);
	self.assertTrueMsg(tr1_wagon2 &lt;&gt; null,"Wagon not created. ");
	updateTrainWagon(tr1_wagon2,train1);
	
	allWagons1.add(tr1_wagon2);
	
	//assert that the wagon just created does not have any railWLEs initially
	self.assertEqualMsg(tr1_wagon1.allLocationsControllersArray.first.myWagon.id ,Tr1_WagonName1, "The wagon is not the one that we just created!");
	
	//assert that it does not have any wles prior to us assigning
	self.assertTrueMsg(tr1_wagon1.allLocationsControllersArray.first.allRailWLELoad.isEmpty, "First controller already has assigned wle!" );
	
	//confirm train inwards
	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine	:=	railLine1;
	wagMoveControl.targetPosition	:=	1;
	allWagons1.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo	:=	true;
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveControl, passportObj);
	self.assertTrueMsg(passportObj.trxCompletedOK(), "Train/Wagon confirm to Rail failed.");	
	
	//start testing	- UC1 - amount specified, any amount false				
	text:=TrainName1&amp;","&amp;"status,"&amp;Tr1_WagonName1&amp;","&amp;ReleaseRequestNo&amp;","&amp;LINE_NUMBER.String&amp;",9,false";				
	
	if app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, "WagonRelease").CM_EDIFileTypeUser = null then		
		self.createUserDefinedFileType("WagonRelease", self.xmlDef_WagonRelease());	
	endif;
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "WagonRelease", "WagonReleaseAssign_"&amp;method.name);	
	self.assertNotNull(ediFile);	//assert that the edi file was loaded successfully
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);	//assert that the edi file was verified successfully
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);	//assert that the edi file was loaded to memory successfully
	
	//assert that the location controller of thw wagon has some wles now after we assigned the RR to the wagon
	self.assertTrueMsg(not tr1_wagon1.allLocationsControllersArray.first.allRailWLELoad.isEmpty, "First controller does not have a wle!!" );
	
	//assert that the first WLE of the location controller of the wagonhas a bulkRelease
	//self.assertNotNullMsg(tr1_wagon1.allLocationsControllersArray.first.allRailWLELoad.first.job.allRequests.first.myOriginatingBulkRelease,"There is no bulk release in the WLE as expected");
	//self.assertNotNullMsg(tr1_wagon1.allLocationsControllersArray.first.allRailWLELoad.first.job.allRequests.first().myJob.rel.myOriginatingBulkRelease,"There is no bulk release in the WLE as expected");
	
	//assert that the first WLE of the location controller of the wagonhas a bulkRelease which is the one we assigned
	//self.assertEqualMsg(tr1_wagon1.allLocationsControllersArray.first.allRailWLELoad.first.job.allRequests.first.myOriginatingBulkRelease.code,ReleaseRequestNo,"The bulk release code is wrong");		
	self.assertEqualMsg(tr1_wagon1.allLocationsControllersArray.first.allRailWLELoad.first().job.allRequests.first().myJob.id,ReleaseRequestNo,"The bulk release code is wrong");		
	
	//assert that the line number is the one we assigned
	self.assertEqualMsg(tr1_wagon1.allLocationsControllersArray.first.allRailWLELoad.first.job.allRequests.first.myReserveDetail.CM_ReserveSelection.lineNumber,LINE_NUMBER,"The reservation is not the one that should have been assigned to it");			
	
	//assert that you have a qty of 9 in the wle
	self.assertEqualMsg(tr1_wagon1.allLocationsControllersArray.first.allRailWLELoad.first.quantity,9,"The qty is not 9 in the WLE");			
	//
	//start testing	- UC2 - no line number specified, but qty 21 specified, so the 
	text:=TrainName1&amp;","&amp;"status,"&amp;Tr1_WagonName2&amp;","&amp;ReleaseRequestNo&amp;","&amp;",21,false";				
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "WagonRelease", "WagonReleaseAssign_"&amp;method.name);
	self.assertNotNull(ediFile);	//assert that the edi file was loaded successfully
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);	//assert that the edi file was verified successfully
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);	//assert that the edi file was loaded to memory successfully
	
	loop:=1;
	totalAllocatedQtyInJobs := 0;
	
	create arr transient;
	foreach lc in tr1_wagon2.allLocationsControllersArray do
		if lc &lt;&gt; null and lc.allRailWLELoad &lt;&gt; null and lc.allRailWLELoad.size &lt;&gt; 0 then		
			self.assertNotNullMsg(lc.allRailWLELoad.first.myRequest,"There is no request in the WLE as expected");
			self.assertEqualMsg(lc.allRailWLELoad.first.myRequest.CM_YardRequest.deliveryNumber,ReleaseRequestNo,"The bulk release assigned to the WLE is not the one we assigned to it");					
			iter := lc.allRailWLELoad.createIterator();
			while iter.next(wle) do 
				totalAllocatedQtyInJobs:=totalAllocatedQtyInJobs + wle.quantity;
			endwhile;
			//totalAllocatedQtyInJobs:=totalAllocatedQtyInJobs+lc.allRailWLELoad.first.quantity;
		endif;
	endforeach;
	
	self.assertEqualMsg(totalAllocatedQtyInJobs, 21, "The qty is not 21 in total from all the WLEs");	
	
	/*//start testing	- UC2 - no line number specified, but qty 21 specified, so the 
	text:=
"UTTRN_WAG,status,IX101,UTRRFW_RR1,1,,true
UTTRN_WAG,status,IX102,UTRRFW_RR1,1,2,false
UTTRN_WAG,status,IX101,UTRRFW_RR1,1,,true
UTTRN_WAG,status,IX102,UTRRFW_RR1,1,2,false";

	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "wagon release test", "WagonReleaseAssign_"&amp;method.name);
	self.assertNotNull(ediFile);	//assert that the edi file was loaded successfully
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);	//assert that the edi file was verified successfully
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);	//assert that the edi file was loaded to memory successfully
	
	loop:=1;
	totalAllocatedQtyInJobs := 0;
	
	create arr transient;
	foreach lc in tr1_wagon2.allLocationsControllersArray do
		if lc &lt;&gt; null and lc.allRailWLELoad &lt;&gt; null and lc.allRailWLELoad.size &lt;&gt; 0 then		
			self.assertNotNullMsg(lc.allRailWLELoad.first.myRequest,"There is no request in the WLE as expected");
			self.assertEqualMsg(lc.allRailWLELoad.first.myRequest.CM_YardRequest.deliveryNumber,ReleaseRequestNo,"The bulk release assigned to the WLE is not the one we assigned to it");					
			totalAllocatedQtyInJobs:=totalAllocatedQtyInJobs+lc.allRailWLELoad.first.quantity;
		endif;
	endforeach;
	
	self.assertEqualMsg(totalAllocatedQtyInJobs, 4, "The qty is not 4 in total from all the WLEs");	*/
	
epilog
	
	delete iter;
	
	delete allWagons1;
	delete wagMoveControl;
	
	delete arr;
	
	self.deleteTrainAndWagons(TrainName1);	
	
	self.deleteVoyage(VOY_CODE);
	self.deleteVessel(VES_CODE);
	
	
	self.deleteOperator(TestOperator);
	self.deleteReleaseRequest(ReleaseRequestNo);
	
	delete configCMIF;
	delete codeGroupsColl;
	delete emailAddresses;
	
	self.setTerminalConfig(RailReleaseAssignEnhance, oldConfig);

end;</source>
    </JadeMethod>
    <JadeMethod name="tFleetAction" id="fc2a2af3-5140-4878-b414-b4600d800cd5">
        <source>tFleetAction();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
constants
	USER_DEF_NAME : String = "JMTInternalFleet";
	TIMASTER : String = "UT_TRLRFLEET";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	master : CM_TIMaster;
	ediText : String;
	errorMsg : String;
begin
	passportObj	:=	app.myPassport;
	self.deleteMasterTi(TIMASTER);
	master := app.myRoot.findTIMasterTrailerByID(TIMASTER);
	if master &lt;&gt; null then
//		app.myTrxDA.trxDeleteCMObject(master, app.myPassport);
beginTransaction;
master.erase(NORMAL_ERASE);
commitTransaction;
	endif;
	self.assertIsDeleted(master);
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalFleet&gt;
	&lt;AllFleet&gt;
		&lt;Fleet&gt;
			&lt;isForDelete/&gt;
			&lt;height/&gt;
			&lt;intHeight&gt;90.0000&lt;/intHeight&gt;
			&lt;intLength&gt;190.0000&lt;/intLength&gt;
			&lt;intWidth&gt;490.0000&lt;/intWidth&gt;
			&lt;length&gt;&lt;/length&gt;
			&lt;tareWeight&gt;4000.0000&lt;/tareWeight&gt;
			&lt;weight&gt;6000.0000&lt;/weight&gt;
			&lt;coolingType&gt;1&lt;/coolingType&gt;
			&lt;extHeight&gt;100&lt;/extHeight&gt;
			&lt;extLength&gt;200&lt;/extLength&gt;
			&lt;extWidth&gt;500&lt;/extWidth&gt;
			&lt;voltageType&gt;&lt;/voltageType&gt;
			&lt;volume&gt;12000&lt;/volume&gt;
			&lt;cargoTypeDescr&gt;Trailer&lt;/cargoTypeDescr&gt;
			&lt;description&gt;UT Test Process Fleet&lt;/description&gt;
			&lt;from/&gt;
			&lt;fullOrMT/&gt;
 			&lt;generatorType&gt;null&lt;/generatorType&gt;
			&lt;id&gt;'&amp;TIMASTER&amp;'&lt;/id&gt;
			&lt;isCommunicating&gt;no&lt;/isCommunicating&gt;
			&lt;isHeavyLift&gt;no&lt;/isHeavyLift&gt;
			&lt;isoGroup&gt;2030&lt;/isoGroup&gt;
			&lt;isoType&gt;2030&lt;/isoType&gt;
			&lt;licenseIssuer&gt;MH5&lt;/licenseIssuer&gt;
			&lt;licenseNumber&gt;1234&lt;/licenseNumber&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;DOUG&lt;/operatorCode&gt;
			&lt;owner&gt;DOUG&lt;/owner&gt;
			&lt;tILCType&gt;UTTRLR&lt;/tILCType&gt;
			&lt;type&gt;&lt;/type&gt;
		&lt;/Fleet&gt;
	&lt;/AllFleet&gt;
&lt;/JMTInternalFleet&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	master := app.myRoot.findTIMasterTrailerByID(TIMASTER);
	self.assertNotNull(master);
	self.assertEqualMsg(master.description, "UT Test Process Fleet", "wrong description");
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;fails16092014&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tFleetWagonAction" id="0fe28928-9236-498d-a459-e3df5f10ca72">
        <source>tFleetWagonAction();
//
//14 August 2017	jlgrs1	Initial creation
//17 August 2022	jlika1	TFS 53741 - EUP- Max Wagon Payload
constants
	USER_DEF_NAME : String = "JMTInternalFleetWagon";
	WAGONMASTER : String = "WAGON001";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	wagonMaster : CM_WagonMaster;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj	:= app.myPassport;
	wagonMaster	:= self.getRoot.allWagonMasters[WAGONMASTER];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	wagonMaster	:= self.getRoot.allWagonMasters[WAGONMASTER];
	self.assertIsDeleted(wagonMaster);
	
	//TFS 53741 jlika1 expects it to be what was on the wagon class so empty the tare weight in the xml so the assert will compare it to the Wagon Class
	
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalFleetWagon&gt;
	&lt;AllFleet-wagon&gt;
		&lt;Fleet-wagon&gt;
			&lt;maxCargoHeight/&gt;
			&lt;maxCargoWeight/&gt;
			&lt;tareWeight&gt;&lt;/tareWeight&gt;
			&lt;cargoTypeDescr/&gt;
			&lt;carrier/&gt;
			&lt;description/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;WAGONMASTER&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;wagonClass&gt;UK&lt;/wagonClass&gt;
		&lt;/Fleet-wagon&gt;
	&lt;/AllFleet-wagon&gt;
&lt;/JMTInternalFleetWagon&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	wagonMaster	:= self.getRoot.allWagonMasters[WAGONMASTER];
	self.assertNotNull(wagonMaster);
	
	//TFS 53741 jlika1 expects it to be what was on the wagon class
	self.assertEqualMsg(wagonMaster.tareWeight.String, "15000.00", "wrong tare weight");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tGateDocComplete" id="d9d7fc34-0e1b-4028-96cf-a57d3aed4628">
        <source>tGateDocComplete();
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
constants
	USER_DEF_NAME : String = "JMTInternalGateDoc";
	BOOKING001 : String = "BK100001";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	RELEASE_001 : String = "UT_REL2221011";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	bookingRef : CM_BookingRef;
	relRequest : CM_BulkRelease;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	self.setTerminalConfig(EdiGateDocInvConsignor, false);
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteBooking(BOOKING001);
	bookingRef := self.getBooking(BOOKING001);
	self.assertIsDeleted(bookingRef);
	self.deleteReleaseRequest(RELEASE_001);
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertIsDeleted(relRequest);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	ediText :=
'&lt;?xml version="1.0"?&gt;
