    <JadeMethod name="tblData_keyDown" id="308498a9-51e6-486e-8792-886b79a3e8f6">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_keyDown(table: CM_DataTable input; keyCode: Integer io; shift: Integer) updating;
/*

Date		Who		Reason
08 September 2016	cnwer1	Initial creation TFS

*/

vars
	col : Integer;
begin
	if keyCode &gt;= 37 and keyCode &lt;= 40 then
		//arrow keys
		return;
	endif;	
	
	if self.isEditMode then 
		col	:= table.getColumnByRowName(ETRow_HasChanged);
		if col &gt; 0 then
			table.accessCell(table.row, col).text := CMUI_EDIForm.HAS_CHANGED;			
		endif;	
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_mouseUp" id="b9b47bb5-e77e-4fa3-9460-e8a161df45a3">
