    </JadeMethod>
    <JadeMethod name="closeDiskFileDbServer" id="2ae49588-5bb6-4c68-90de-de0d48e98e56">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>closeDiskFileDbServer(pDiskFileObj:File io) updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		08 July 2002 by cnwdad2
