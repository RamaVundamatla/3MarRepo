<Class name="CM_TrxControlRTAgent" id="0cf40630-6633-4066-ae25-624d97928e8e">
    <superclass name="CM_TrxControlAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="trxAcceptRTQueueEntries" id="5a00ebef-8cb6-4f8b-b399-87302b03a4a6">
        <updating/>
        <source>trxAcceptRTQueueEntries(	_allRTQueueEntries : CM_RTQueueEntryArray input;
							_machine : CM_Machine input;
							_passport : CM_Passport input	) updating;
/*
Date		Who		Reason
06 August 2014	cnwer1	Initial creation PAR

*/

vars
	rtQueueEntry : CM_RTQueueEntry;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport);

	
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	foreach rtQueueEntry in _allRTQueueEntries discreteLock do
		//epr TFS 995 16/5/17 refactored for VMT mobile
		app.myUtilityUA.utlMachineValidateAcceptTask(_machine,rtQueueEntry.allTasks.first,_passport);
		
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_allRTQueueEntries" type="CM_RTQueueEntryArray" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAcceptSpecifiedTask" id="e22a7a8b-b2e7-40d9-915b-afaff1b7575f">
        <updating/>
        <source>trxAcceptSpecifiedTask(_rtQueueTask : CM_RTQueueTask input;
					   _mediator : CM_RadioTelemetryMediator input; 
					   _trxHook : CMIF_InterfaceTransactionHook input;
					   _passport : CM_Passport input) updating;


/*
		
Purpose:			Accept the specific passed in task, if it is OK to do so.

Parameters: 		_trxHook : Optional hook to invoke wrap up processing method for calling interface.

Return Value:		


Date		Who		Reason
14 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
16 Dec 2010	cnwkpd1	PAR #26522 - Stop checking restricted access on Accept, to allow for
					auto resequence to work

*/

vars
	machine : CM_Machine;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport);

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	machine := _mediator.machine;
	
//	app.myValRT.valAcceptTask(machine,_rtQueueTask,null,false,true,true);		// PAR #26522
	//epr TFS 995 vmt refactoring
	app.myValUA.valMachineAcceptTask(machine,_rtQueueTask,null,false,true,false);
	
	if _passport.hasErrors() then
		return;
	endif;
	// cnwkpd1 - Process here cloned from trxRTGAcceptTask
	beginTransaction;
	//epr TFS 995 vmt refactoring
	app.myUtilityUA.utlMachineAcceptTask(machine,_rtQueueTask,_passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	_mediator.task := _rtQueueTask;

	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAcceptTask" id="d4e93705-fe4f-4c05-ba00-722061a02670">
        <updating/>
        <source>trxAcceptTask(_mediator : CM_RadioTelemetryMediator input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
16 Mar 2009	cnwkpd1	PAR #19125 - change to validate task on machine, not mediator

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException  do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachineTask(_mediator);		// PAR #19125
	
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;
	
	app.myUtlRT.utlAcceptTask(_mediator, _passport);	
	
epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxActionCranePickup" id="e8c55ccf-3abe-4927-94dc-fabd7f153e21">
        <updating/>
        <source>trxActionCranePickup(_ti,
					 _twinTi : CM_TrackedItem input;
					_mediator : CM_RadioTelemetryMediator input;
					_acceptTask : Boolean; 
					_doPickup : Boolean; 
					_trxHook : CMIF_InterfaceTransactionHook input;
					_passport : CM_Passport input) updating;

/*

Purpose:			Find or create the RT queue tasks for the passed in ti(s), and if they are available
					accept them and action a pickup for the passed in machine

Parameters:			Tracked Item(s) to be picked up
					RT mediator
					Accept task?
					Pickup TI?					
					Optional hook to invoke wrap up processing method for calling interface.

Return Value:		None


Date		Who		Reason
05 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
27 Feb 2015 cnwer1	PAR 35702  - CCMS 2457
*/

vars
	machine			: CM_Machine;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport);

	app.setContinueCMExceptions(false);
	
	app.initialiseForStartAutoPlan(_passport);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	
	self.raiseExceptionIfNull(_ti, app.getErrorString(Container));
	
	if _passport.hasErrors() then
		return;
	endif;

	machine := _mediator.machine;

	beginTransaction;
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	app.myUtilityUA.utlMachineCranePickup(_ti,_twinTi,machine,	_acceptTask,_doPickup ,	_passport );
	
	_passport.doDeferredUpdates();
	
	// Update the mediator timestamp
	if not _passport.hasErrors then
		_mediator.task:= _mediator.machine.currentQueueTask;
		app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);
	endif;

	
	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_acceptTask" type="Boolean"/>
        <Parameter name="_doPickup" type="Boolean"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxActionDirectorTask" id="2cf17da8-d894-4a91-9fc7-25c0eedb99ab">
        <updating/>
        <source>trxActionDirectorTask(_tiId : String;
					  _twinTiId : String;
					  _mediator : CM_RadioTelemetryMediator input;
					  _acceptTask : Boolean; 
					  _doPickup : Boolean; 
					  _trxHook : CMIF_InterfaceTransactionHook input;
					  _bbQuantity : Integer;
					  _moveWeight : Decimal;
					  _passport : CM_Passport input) updating;
					  
// -------------------------------------------
// Created 03 February 2006 by cnwdvb1
// -------------------------------------------
/*
Parameters: 		_trxHook : Optional hook to invoke wrap up processing method for calling interface.

Date		Who		Reason
25 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
25 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Change signature to include optional twin container
30 Jul 2009	cnwkpd1	PAR #20369 - If two containers have been provided, but the machine only
					has one Director task, then return an error
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
06 Sep 2013 cnwer1	PAR 32408 - added bbQuantity
*/

vars	
	machine			: CM_Machine;
	ti,
	twinTi			: CM_TrackedItem;
	terminal : CM_Terminal;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.initialiseForStartAutoPlan(_passport);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	// Set up machine
	machine := _mediator.machine;
	
	beginTransaction;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	terminal:= machine.getMyTerminal();
	//epr TFS 6863 14/9/17 
	if _twinTiId &lt;&gt; null then
		twinTi := app.myValUA.valRTTaskFindTrackedItem(_twinTiId, machine.getCurrentTwinTask(),terminal);
	endif;
	ti :=app.myValUA.valRTTaskFindTrackedItem(_tiId, machine.currentQueueTask,terminal);
	//epr TFS 995 refactoring 16/5/17
	app.myUtilityUA.utlMachineDirectorTask(ti , twinTi ,machine,_doPickup,_bbQuantity,_moveWeight,_passport);
		
	_passport.doDeferredUpdates();
	
	// Update the mediator timestamp
	if not _passport.hasErrors then
		_mediator.task:= machine.currentQueueTask;
		app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);
	endif;

	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_twinTiId" type="String"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_acceptTask" type="Boolean"/>
        <Parameter name="_doPickup" type="Boolean"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_bbQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxActionYardPickup" id="94675cfc-b505-4cb9-aee9-02f59ba33ffe">
        <updating/>
        <source>trxActionYardPickup(_ti,
					_twinTi : CM_TrackedItem input;
					_mediator : CM_RadioTelemetryMediator input;
					_doPickup : Boolean; 
					_trxHook : CMIF_InterfaceTransactionHook input;
					_passport : CM_Passport input) updating;

/*

Purpose:			Find the RT queue task(s) for the passed in ti(s), and if they are available
					accept them and action a pickup for the passed in machine

Parameters:			Tracked Item(s) to be picked up
					RT mediator
					Pickup TI(s)?
					Optional hook to invoke wrap up processing method for calling interface.

Return Value:		None


Date		Who		Reason
05 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
23 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
*/

vars
	task,
	twinTask		: CM_RTQueueTask;
	machine			: CM_Machine;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport);

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	
	self.raiseExceptionIfNull(_ti, "_ti");
	
	if _passport.hasErrors() then
		return;
	endif;
	
	machine := _mediator.machine;
	
	beginTransaction;
	
	// Can't guarantee which passport we are working with.
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	// Find the task for the primary TI
	task := app.myUtlRT.utlGetTaskForTI(_ti, machine, _passport);
	if _passport.hasErrors() then
		return;
	endif;
	
	// If there's a twin TI, then need to get and validate it's task too
	if _twinTi &lt;&gt; null then
		twinTask := app.myUtlRT.utlGetTaskForTI(_twinTi, machine, _passport);
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	// Now validate the acceptance of the single or twin tasks - this actually checks whether the
	// two tasks are twinnable if two task are passed in
	//epr TFS 995 refactoring 16/5/17
	app.myValUA.valMachineAcceptTask(machine, task, twinTask,false,false,true);
	if _passport.hasErrors() then
		return;
	endif;
	
	// If eveything is OK, then Accept them
	//epr TFS 995 refactoring 16/5/17
	app.myUtilityUA.utlMachineAcceptTask(machine, task,_passport);
	if _passport.hasErrors() then
		return;
	endif;
	
	if twinTask &lt;&gt; null then
		app.myUtilityUA.utlMachineAcceptTask(machine, twinTask, _passport);
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	// Do the pickup if required
	if _doPickup then
		//epr TFS 995 refactoring 16/5/17
		app.myUtilityUA.utlMachinePickupTask(machine,null,null,null);
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	_passport.doDeferredUpdates();
	
	// Update the mediator timestamp
	if not _passport.hasErrors then
		_mediator.task := machine.currentQueueTask;
		app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);
	endif;

	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_doPickup" type="Boolean"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxChangeAllTasksStatus" id="3f206da4-4a62-4946-bf0e-f522ffc12816">
        <updating/>
        <source>trxChangeAllTasksStatus(_rtQueueTasks :  CM_RTQueueTaskArray input;
						_machine : CM_Machine input;
						_newStatus : Integer;
						_passport : CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	ti : CM_TrackedItem;
	machineStatus : Integer;
	status : Integer;
	primaryQueueDesc : String;
	rtQueueTask :  CM_RTQueueTask;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718
	app.setContinueCMExceptions(false);
	if _machine = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Machine is null.', null, null);
		return;
	endif;
	
	if _rtQueueTasks = null or _rtQueueTasks.size = 0 then
		if _machine.myPrimaryQueue &lt;&gt; null then
			primaryQueueDesc:= _machine.myPrimaryQueue.id;
		endif;
		app.raiseCMException2(ERR_ALERT_NOTASKS,_machine.id,primaryQueueDesc,null,null);
		return;
	endif;

	beginTransaction;
	
	if _machine.machineStatus &lt;&gt; STATUS_WORKING then
		if _machine.machineStatus = STATUS_IDLE then
			//epr TFS 995 18/5/17
			app.myUtilityUA.utlUpdateMachineStatus(_machine, STATUS_ASSIGNED, "", false, _passport);	
		endif;
		if _passport.hasErrors() then
			return;
		endif;
		app.myUtilityUA.utlUpdateMachineStatus(_machine, STATUS_WORKING  , "", false, _passport);
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	
	
	foreach rtQueueTask in _rtQueueTasks do 
		if rtQueueTask.machine &lt;&gt;  null and rtQueueTask.machine &lt;&gt; _machine then
			continue;
		endif;	
//epr TFS 995 18/5/17
		app.myUtilityUA.utlChangeTaskStatus(rtQueueTask,_machine,_newStatus,_passport);
	endforeach;
	
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_rtQueueTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxChangePassword" id="97e355cc-0816-4a64-933f-141baa6c8504">
        <updating/>
        <source>trxChangePassword(	_userCode, _oldPass,
					_newPass, _newPass2 : String;
					_tmpUser			: CM_User output;
					_userEdition		: Integer output;
					_passport			: CM_Passport input) updating;
// -------------------------------------------
// Created 08 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);

	app.myValUA.valUserPassword(true, _userCode, _oldPass, _newPass, _newPass2, _tmpUser, _userEdition);
	
	if _passport.hasErrors() then
		return;
	endif;
	
		// Can't guarantee which passport we are working with.
	_passport.setWarningsIgnored(_passport.warningsAcknowledged);
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdatePassword(_tmpUser, _userEdition, _newPass, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_oldPass" type="String"/>
        <Parameter name="_newPass" type="String"/>
        <Parameter name="_newPass2" type="String"/>
        <Parameter name="_tmpUser" type="CM_User" usage="output"/>
        <Parameter name="_userEdition" type="Integer" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateMachineInitiatedMove" id="870ecce2-4e33-4c60-8c2b-cbd958291276">
        <updating/>
        <source>trxCreateMachineInitiatedMove(_ti : CM_TrackedItem input;
							  _mediator : CM_RadioTelemetryMediator input;
							  _trxHook : CMIF_InterfaceTransactionHook input;
							  _passport : CM_Passport input) : CM_RTQueueTask updating;

/*

Purpose:			Create a machine initiated move of the passed in Tracked Item, and assign it to the 
					passed in machine
					
Parameters:			Tracked Item to be moved
					Machine RT mediator
					Optional hook to invoke wrap up processing method for calling interface.

Return Value:		None


Date		Who		Reason
16 Sep 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move

*/

vars
	machine			: CM_Machine;
	tiTask,
	twinTask 		: CM_RTQueueTask;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport);

	app.setContinueCMExceptions(false);
	
	app.initialiseForStartAutoPlan(_passport);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	
	self.raiseExceptionIfNull(_ti, app.getErrorString(Container));
	//epr 33435 18/2/14
	if _passport.hasErrors() then
		return null;
	endif;
	
	beginTransaction;
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	//epr TFS 995 refactoring 16/5/17 
	tiTask := app.myUtilityUA.utlMachineCreateInitiatedMove(_ti, null,_mediator.machine,null,null,true,false, _passport);
	//tiTask := app.myUtlRT.utlCreateMachineInitiatedMove(_ti, _mediator.machine,null,null,true, _passport);
	
	if _passport.hasErrors() then
		return null;
	endif;

	_passport.doDeferredUpdates();
	
	// Update the mediator timestamp
	if not _passport.hasErrors then
		_mediator.task := _mediator.machine.currentQueueTask;
		app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);
	endif;

	if _passport.hasErrors() then
		return null;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
	return _mediator.task;
	
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="trxEnqTrackedItem" id="5d59ad66-cdb0-40e3-860f-defaba88fec1">
        <updating/>
        <source>trxEnqTrackedItem(_tiId : String; _mediator : CM_RadioTelemetryMediator input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 23 January 2006 by cnwdvb1
// -------------------------------------------
vars

	ti	: CM_TrackedItem;
	task : CM_RTQueueTask;
begin
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//17 Nov 2014	NDL	Par 35210
	if _mediator &lt;&gt; null then
		task := _mediator.task;
	endif;
	
	///epr TFS 995 vmt 17/5/17
	ti := app.myValUA.valRTTaskFindTrackedItem(_tiId, task,app.getMyTerminalDO_NOT_USE());
	
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;
	
	_mediator.myCurrentTi := ti;
	
epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxLogOff" id="74ddad5d-ed4c-4322-9bc5-fe675e07218e">
        <updating/>
        <source>trxLogOff(_agent : RadioTelemetryAgent input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
vars

	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_agent.myMediator);
	app.myValRT.valMediatorMachine(_agent.myMediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	app.myValRT.valLogOff(_agent.myMediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if _passport.hasWarnings and not _passport.warningsAcknowledged then
		return;
	endif;
	
	_passport.setWarningsIgnored(_passport.warningsAcknowledged);

	beginTransaction;
	
	app.myUtlRT.utlLogOff(_agent, _passport);

epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_agent" type="RadioTelemetryAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxLogoffForInterface" id="debdef87-16e2-4deb-b46c-d63118b87b10">
        <updating/>
        <source>trxLogoffForInterface(_mediator : CM_RadioTelemetryMediator io;
					 _trxHook : CMIF_InterfaceTransactionHook input;
					 _passport : CM_Passport input) updating;

/*

Purpose:			Logoff mechanism for the TCP/ITS interface.  Logs off the machine connected to the passed
					in RT Mediator, then deletes the mediator

Parameters:			Mediator session to log off, and passport (user and terminal already set).
					Optional hook to invoke wrap up processing method for calling interface.
					
Return Value:		None


Date		Who		Reason
25 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport);

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	app.myValRT.valLogoffForInterface(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	_passport.setWarningsIgnored(true);

	beginTransaction;
	
	app.myUtlRT.utlLogoffForInterface(_mediator, _passport);

	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for the calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	
end;
</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="io"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxLogon" id="35a9b5c6-02aa-40c4-afd3-21f1c2c1904a">
        <updating/>
        <source>trxLogon(_agent : RadioTelemetryAgent input; _clientConnectionDetails : String; _reset  : Boolean; _passport : CM_Passport input) : Integer updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors() then
		return 0;
	endif;
	
	beginTransaction;
	
	return app.myUtlRT.utlLogon(_agent, _clientConnectionDetails, _reset, _passport);
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_agent" type="RadioTelemetryAgent" usage="input"/>
        <Parameter name="_clientConnectionDetails" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxLogonForInterface" id="ac774042-e141-4ee1-824d-9a38ef4321dd">
        <updating/>
        <source>trxLogonForInterface(	_machine 		: CM_Machine input;
						_allowTwinLift 	: Boolean;
						_trxHook 		: CMIF_InterfaceTransactionHook input;
						_passport 		: CM_Passport input) updating;

/*

Purpose:			Logon mechanism for the TCP/ITS interface.  Logs the machine on, and creates an RT Mediator
					for it

Parameters:			Machine to be logged on, and passport (user and terminal already set).
					_allowTwinLift - Flag to indicate if interface supports twin lift.
					_trxHook - Optional hook to invoke wrap up processing method for calling interface.
					
Return Value:		None


Date		Who		Reason
25 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport);

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;
	
	app.myUtlRT.utlLogonForInterface(_machine, _allowTwinLift, _passport);

	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_allowTwinLift" type="Boolean"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxManipulateOnHold" id="189f321a-d0fc-44e9-8f88-c9b75008abd4">
        <updating/>
        <source>trxManipulateOnHold(_placeOnHold : Boolean; _mediator : CM_RadioTelemetryMediator input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	
	//epr 33435 18/2/14
	if _passport.hasErrors() then
		return;
	endif;
	
	app.myValRT.validateOnHoldState(_mediator, _placeOnHold);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if _placeOnHold then
		app.myValRT.valMediatorTask(_mediator);
	else
		app.myValRT.valMediatorOnHoldTask(_mediator);	
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	app.myValRT.valMediatorMachine(_mediator);
	
			
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;
	//-------------------
	//Requested a Task
	//-------------------
	
	app.myUtlRT.utlManipulateOnHold(_placeOnHold, _mediator);	
	
epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_placeOnHold" type="Boolean"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTI" id="effc8932-d7c7-4576-91a4-bf16a1f5f8f5">
        <updating/>
        <source>trxMoveTI(_toLocationId : String; _tandemTIid : String; _mediator : CM_RadioTelemetryMediator input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
vars

	location	: CM_LocationsController;
	compareTi,
	tandemTI,
	ti			: CM_TrackedItem;
	task : CM_RTQueueTask;
	machine  : CM_Machine;
	terminal : CM_Terminal;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	
	//epr 33435 18/2/14
	if _passport.hasErrors() then
		return;
	endif;
	
	
	ti := app.myValRT.valMediatorTI(_mediator);
	
	// Par 13465 Catch hole where tis can be moved back on site.
	if not ti.isOnSite() then
		app.raiseCMException(This_item_offsi_pleas_refre_yo ,null, null);
		return;
	endif;
		
	if _passport.hasErrors() then
		return;
	endif;
	machine:=_mediator.machine;
	terminal:=machine.getMyTerminal;
	// Need transaction state here!	
	//epr TFS 995 vmt refactoring 18/5/17
	location := app.myValUA.valGetTargetLocation(terminal, _toLocationId,  _passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	
	if location &lt;&gt; null and location.isKindOf(CM_ShipBlockController) and ti.myVoyage &lt;&gt; location.CM_ShipBlockController.myVoyage then
		app.raiseCMException3(WARN_DIFF_SHIP_VOYAGE, ti.id, ti.myVoyage.code, location.CM_ShipBlockController.myVoyage.code, null, null);
	endif;	
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//epr par 24517 refactored into method on machine
	machine.validateForMove(location,ti,true);	
				
	if _passport.hasErrors() then
		return;
	endif;
	
	//17 Nov 2014	NDL	Par 35210;
	if _mediator &lt;&gt; null then
		task := _mediator.task;
	endif;

	if _tandemTIid &lt;&gt; null then
		//epr TFS 995 vmt refactoring 18/5/17
		tandemTI := app.myValUA.valRTTaskFindTrackedItem(_tandemTIid, task,ti.getMyTerminal());
	
		if _passport.hasErrors() then
			return;
		endif;

		//epr par 24517 refactored into method on machine
		machine.validateForMove(location,tandemTI,true);	
			
		if _passport.hasErrors() then
			return;
		endif;

		compareTi := ti.getTandemLiftBox();
		
		if compareTi &lt;&gt; null and compareTi &lt;&gt; tandemTI then
	
			app.raiseCMWarning1(WARN_NOT_TANDEM_CONT, compareTi.id, null, null,compareTi);
		endif;
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;
	
	_passport.setWarningsIgnored(_passport.warningsAcknowledged);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	//epr TFS 995 17/5/17 VMT refactoring
	app.myUtilityUA.utlMachineMoveTI( _mediator.machine,ti,tandemTI,location,null,null,null,false,app.myPassport);
	
/*	if tandemTI = null then
		app.myUtlRT.utlMoveTI(location, _mediator.machine, ti,null,false);	
	else
		app.myUtlRT.utlMoveTiTandem(location, _mediator.machine, ti, tandemTI, null,false);	
	endif;*/
	
	_passport.doDeferredUpdates();
	
	return;
	
epilog

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_toLocationId" type="String"/>
        <Parameter name="_tandemTIid" type="String"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveToPreviousLocation" id="f09f68e2-9908-43bf-be61-7f35a54e07b1">
        <updating/>
        <source>trxMoveToPreviousLocation(trackedItems : CM_TIArray input; job : CM_VoyageJob input; slotControllers : CM_LCArray) updating;
// Move all the tracked items to there previous location, and create a future move from the previous location to the current location


// 10/12/2014  cnwdb2	PAR 35364


vars
	i : Integer;
	trackedItem : CM_TrackedItem;
	slotController : CM_SlotController;
	previousLocation : CM_LocationsController;
	tmpVoid : Integer;
	futureMoveController : CMIF_MoveController;
	workListEntry : CM_WorkListEntry;

begin
	self.initialiseActivityWithPassport(app.myPassport, method);
	on Exception do agtPassportExHandler(exception, app.myPassport);
	on LockException do agtPassportLockExHandler(exception, app.myPassport); 
	app.setContinueCMExceptions(false);
	
	app.myPassport.setWarningsIgnored(app.myPassport.warningsAcknowledged);

	beginTransaction;
	
	foreach trackedItem in trackedItems do
		i := i + 1;
		slotController := slotControllers[i].CM_SlotController;
		if slotController = null or job = null then
		//	app.raiseCMException1(REQUIRED_FIELD, "Job or Location", null, self);
			app.raiseCMException(Input_required_field_jobOrLocn, null, self); // cnwdb2	PAR 35364
			return;
		endif;
		
		self.reserveLock(slotController);
		
		// Move the item back to previous location
		app.myPassport.myTerminal.findLocationFromString(trackedItem.priorLocation, false, previousLocation, tmpVoid);
		workListEntry := job.getWLEForTI(trackedItem);
		//epr TFS 995 17/5/17 VMT refactoring
		app.myUtilityUA.utlMachineMoveTI( job.getJobCrane(),trackedItem,null,previousLocation,workListEntry,null,null,true,app.myPassport);
		//app.myUtlRT.utlForcedMoveTI(previousLocation, job.getJobCrane(), trackedItem, workListEntry, false);
		if app.myPassport.hasErrors() then
			return;
		endif;
		
		// Need to recreate the future move 
		workListEntry.setStatus(WLE_UNACTIONED);
		delete futureMoveController;
		create futureMoveController transient;
		futureMoveController.setMoveMode(PLANNING_MODE);
		futureMoveController.setMyWorkListEntry(workListEntry);
		futureMoveController.setMyTrackedItem(trackedItem);
		futureMoveController.setMyToPrimaryLocation(slotController);
		futureMoveController.executeMove(app.myPassport);
		if app.myPassport.hasErrors() then
			return;
		endif;
		
		self.unlock(slotController);
		
	endforeach;
	
epilog
	delete futureMoveController;
	self.unlock(slotController);
	self.finaliseActivityWithPassport(app.myPassport);
end;</source>
        <Parameter name="trackedItems" type="CM_TIArray" usage="input"/>
        <Parameter name="job" type="CM_VoyageJob" usage="input"/>
        <Parameter name="slotControllers" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="trxPickupDirectorSingleTask" id="71a848b2-9b8f-4d3b-bbbd-ebfc129c2d78">
        <updating/>
        <source>trxPickupDirectorSingleTask(_machine : CM_Machine input; 
							_task : CM_RTQueueTask input;
							_ti 	: CM_TrackedItem input;
							_quantity : Integer;
							_weight : Decimal;
							_passport : CM_Passport input) updating;
		/*

Date		Who		Reason
14 August 2014	cnwer1	Initial creation PAR

*/

vars
	bbTask,
	task		: CM_RTQueueTask;
	allBRTIsAssigned : CM_TISet;
	tisRelease : CM_ReserveDetail;
	br : CM_BulkRelease;
	mediator : CM_RTConnectMediator;
	bbWLE 		: CM_WorkListEntry;
	bbTI 		: CM_TrackedItem;
	fm 			: CM_FutureMove;
	notInBR 	: Boolean;
	request 		: CM_Request;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.initialiseForStartAutoPlan(_passport);
	
	beginTransaction;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	task:=_task;
	//epr par 32408 10/9/13
	if task &lt;&gt; null and task.myEntry.myBreakBulkMaster &lt;&gt; null then
		bbTask :=task;
	endif;
	
	create allBRTIsAssigned transient;
	//epr 32408 10/9/13 par 33175
	if bbTask &lt;&gt; null then
		bbWLE:=bbTask.myEntry.myWorkListEntry;
		if bbWLE &lt;&gt; null and bbWLE.myRequest &lt;&gt; null then
			request:=bbWLE.myRequest;
			br:=request.getBulkRelease();
			if br &lt;&gt; null then
				br.allTrackedItemsAssigned.copy(allBRTIsAssigned);
			endif;
		endif;
	endif;
	
	//epr par 35108 22/10/14
	notInBR:=false;
	if br &lt;&gt; null and not br.allTrackedItemsAssigned.includes(_ti) then
		notInBR:=true;
	endif;
	
	//assign it to the task.
	create mediator transient;
	mediator.machine := _machine;
	mediator.task := task;	
	mediator.setActiveTerminal(task.myEntry.myQueue.getMyTerminal()); 

	app.myUtlRT.utlActionDirectorTask(_ti, mediator, _passport);	
	
	if _passport.hasErrors() then
		return;
	endif;
	
	task:=mediator.task;
	
	_machine.executePickupSingleTask( task, _quantity,_weight,null,_passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//epr par 35116 23/10/14
	
	//epr par 35043 6/11/14
	if  bbWLE &lt;&gt; null then		
		if bbWLE &lt;&gt; _machine.currentQueueTask.myEntry.myWorkListEntry then		
			bbTI:=bbWLE.myTrackedItem;			
			bbWLE.setMyTrackedItem(null);	
			if bbWLE.job &lt;&gt; null then
				bbWLE.job.updateTICollectionsUnassign(bbTI);
			endif;
		
			fm:= bbWLE.myFutureMove;
			if fm &lt;&gt; null then
				delete fm;
			endif;
		endif;
	endif;
	
	//epr par 35108 22/10/14
	if br &lt;&gt; null and _ti &lt;&gt; task.ti  and notInBR and request &lt;&gt; null then	
		request.removeBulkReleaseTI(_ti);	
	endif;
	
	_passport.doDeferredUpdates();
epilog
	delete mediator;
	delete allBRTIsAssigned;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxPickupDriverInitiatedMove" id="5a2e491d-354b-4220-9234-2105086c8fda">
        <updating/>
        <source>trxPickupDriverInitiatedMove(	_machine : CM_Machine input;
								_ti : CM_TrackedItem input;
								_moveQuantity : Integer;
								_moveWeight : Decimal;
								_autoPlanMove : Boolean;
								_passport : CM_Passport input) updating;
/*

Date		Who		Reason
19 August 2014	cnwer1	Initial creation PAR

*/

vars
	tiTask : CM_RTQueueTask;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	if _machine = null then
		app.raiseCMException(ERR_MACH_NULL,null,null);
	endif;
	
	if _ti = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Cargo is null.', null, null);
	endif;
	app.initialiseForStartAutoPlan(_passport);
	
	beginTransaction;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	//epr TFS 995 vmt refactoring 18/5/17 
	tiTask := app.myUtilityUA.utlMachineCreateInitiatedMove(_ti,null, _machine,_moveQuantity,_moveWeight,false,false, _passport);
	
	
	
	if _passport.hasErrors() then
		return;
	endif;
	_machine.executePickupSingleTask( tiTask, _moveQuantity,_moveWeight,null,_passport);
	
	
	
	_passport.doDeferredUpdates();
epilog
		self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <Parameter name="_autoPlanMove" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxPickupSingleTask" id="6705a728-05e4-4255-88ea-61ab74fe54af">
        <updating/>
        <source>trxPickupSingleTask(_machine : CM_Machine input; 
					_task : CM_RTQueueTask input;
					_quantity : Integer;
					_weight : Decimal;
					_passport : CM_Passport input) updating;
/*

Date		Who		Reason
11 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	if _machine = null then
		app.raiseCMException(ERR_MACH_NULL,null,null);
	endif;

	if _task = null then		
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Task Is Invalid.', null, null);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	
	beginTransaction;
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	//do stuff
	_machine.executePickupSingleTask(_task,_quantity,_weight,null,_passport);
	
	_passport.doDeferredUpdates();
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxPickupWithTask" id="d5351ef2-e9fe-4b92-9e06-f48f8bc64f37">
        <updating/>
        <source>trxPickupWithTask(_mediator : CM_RadioTelemetryMediator input; _tandemTIid : String; _acceptTask : Boolean; 
					_trxHook : CMIF_InterfaceTransactionHook input; _primaryQuantity : Integer; _passport : CM_Passport input)  updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
/*
Date		Who		Reason
25 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
05 Feb 2009	cnwer1  CCMS 1032  - refactored removed return Integer was never used
16 Mar 2009	cnwkpd1	PAR #19125 - change to validate task on machine, not mediator
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
*/

vars
	rtnValue	: Integer;
	tandemTI	: CM_TrackedItem;
	task : CM_RTQueueTask;
	machine : CM_Machine;
	terminal : CM_Terminal;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	//epr 33435 18/2/14
	if _passport.hasErrors() then
		return;
	endif;
	
	machine:=_mediator.machine;
	terminal:=machine.getMyTerminal();
	
	app.myValRT.valMediatorMachineTask(_mediator);			// PAR #19125
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//17 Nov 2014	NDL	Par 35210
	if _mediator &lt;&gt; null then
		task := _mediator.task;
	endif;
	
	// 04/04/2008 cnwar2 #16380
	if _tandemTIid &lt;&gt; null then
		//epr TFS 995 vmt refactoring 18/5/17
		tandemTI := app.myValUA.valRTTaskFindTrackedItem(_tandemTIid, task,terminal);
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	beginTransaction;
	
	_passport.setWarningsIgnored(_passport.warningsAcknowledged);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	if _acceptTask then
		app.myUtlRT.utlAcceptTask(_mediator, _passport);	
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	//epr TFS 995 vmt refactoring 18/5/17
	 app.myUtilityUA.utlMachinePickupTask(_mediator.machine, tandemTI,_primaryQuantity,null);	
	
	// Update the mediator timestamp
	if not _passport.hasErrors then
		_mediator.task:= _mediator.machine.currentQueueTask;
		app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);
	endif;
	
	_passport.doDeferredUpdates();
	
	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_tandemTIid" type="String"/>
        <Parameter name="_acceptTask" type="Boolean"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_primaryQuantity" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRAILSetToGround" id="f1f7112c-9e67-4694-a2e7-791573f93a40">
        <updating/>
        <source>trxRAILSetToGround(_ti : CM_TrackedItem input;_machine : CM_Machine input;
					_passport : CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 December 2006	cnwer1	Initial creation - PAR#xxxx
// 10/12/2014  cnwdb2	PAR 35364

*/
vars
	currentRTTask : CM_RTQueueTask;
	currentLocation,queuedLocation,
	rtaLocation : CM_LocationsController;
	rta : CM_YardTransferArea;
	wagon : CM_WagonController;
	sourceLocationId : String;
	histEntry 			: CM_MachineMoveHistory;
	moveTransaction 	: CM_Move;
begin
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718
	
	if _ti = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"Tracked Item",null,self);
		app.raiseCMException(Input_required_field_trakedItm,null,self); // cnwdb2	PAR 35364
		return;
	endif;
	
	currentLocation:=_ti.getPrimaryLocation(REAL_MODE);
	queuedLocation:=_ti.getPrimaryLocation(QUEUE_MODE);

	//either its currrent location or its queued location has to be an wagonController or
	
	//coming from 
	if currentLocation &lt;&gt; null and currentLocation.isKindOf(CM_WagonController) then
		wagon:=currentLocation.CM_WagonController;
	elseif queuedLocation &lt;&gt; null and queuedLocation.isKindOf(CM_WagonController) then
		wagon:=queuedLocation.CM_WagonController;
	endif;
	
	if wagon = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"Wagon Controller",null,self);
		app.raiseCMException(Input_required_field_WgnContr,null,self); // cnwdb2	PAR 35364

		return;
	endif;
	
	if wagon.myTerminalArea = null or not wagon.myTerminalArea.isKindOf(CM_Rail) then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"Wagon Controllers terminal area is not a CM_Rail object",null,self);
		return;
	endif;
	
	rta:=wagon.myTerminalArea.CM_Rail.myTransferArea;
	
	if rta = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"Rail Transfer Area",null,self);
		app.raiseCMException(Input_required_field_railTrns,null,self); // cnwdb2	PAR 35364
		return;
	endif;
	
	rtaLocation:=rta.myLocationsController;
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	//epr TFS 995 vmt 17/5/17
	app.myUtilityUA.utlMachineMoveTI(_machine,_ti,null,rtaLocation,null,null,null,false,_passport);
	//app.myUtlRT.utlMoveTI(rtaLocation,_machine,_ti,null,false);
	_passport.doDeferredUpdates();
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRTGMoveTI" id="26d4ba3a-e3b6-4ed9-80e2-76005279fe97">
        <updating/>
        <source>trxRTGMoveTI(	_machine : CM_Machine input;
				_ti 		: CM_TrackedItem input;
				_wle 		: CM_WorkListEntry input;
				_toLocation : CM_LocationsController input;
				_isOverstow: Boolean;
				_isForcedMove:Boolean;	// par 17123
				_currentTask : CM_RTQueueTask input;
				_setComplete : Boolean;
				_imvMachine : CM_Machine input;
				_imvTask    : CM_RTQueueTask input;
				_quantity 	: Integer; // epr par 31915 6/1/14
				_passport : CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date				Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx
23 June 2008		concms1 Par 17123 - New parameter _isForcedMove
18/11/2010			cnwcs5	par 23714/ccms 1132 - move creation of IMV history into the utl method
08/05/2018			jlgmd1	TFS #38663 QNS - Jade Lock issue
*/
vars
	moveController 		: CMIF_MoveController;
	task: CM_RTQueueTask;
	sourceLocation: CM_LocationsController;
	isDoorTurnaround,
	isInvalid: Boolean;
	internalJobWLE : CM_WorkListEntry;
	otherTI : CM_TrackedItem;
	futureMove : CM_FutureMove;
	fmIndex 	: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport); //epr par 14718

	// Defer our actual updates until the end
	_passport.useTITransactionDeferUpdate := true;		// TFS 38663
	_passport.useTIDictDeferUpdate := true;				// TFS 38663

	app.setContinueCMExceptions(false);
	
	_machine.validateForMove(_toLocation,_ti,true);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//have to validate it can move it to the imv if imv is involved
	if _imvMachine &lt;&gt; null then
		_imvMachine.validateForMove(_toLocation,_ti,true);

	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;		
	//make sure the imv has accepted the task and the rtTasks machine ref is set to the imv
	if _wle &lt;&gt; null and not _isOverstow then
		if _imvMachine &lt;&gt; null  and _imvTask &lt;&gt; null then
			//PAR 20700 at this point if the _imvTask is offered to another machine then reject that offered task
			if _imvTask.machine &lt;&gt; null and _imvTask.machine &lt;&gt;  _imvMachine then
				
				app.myUtlRT.utlRejectSpecificTask(_imvTask.machine,_imvTask,_passport);
				if _passport.hasErrors() then
					return;
				endif;
			endif;
			app.myUtlRT.utlIMVAcceptTask(_imvMachine,_imvTask,_passport);
		endif;
		
		if _passport.hasErrors() then
			return;
		endif;
		
		sourceLocation:=_ti.myPrimaryActualLocation;
		if _wle.job &lt;&gt; null and _wle.job.isKindOf(CM_YardInternalJob) then
			if _wle.job.CM_YardInternalJob.type = Door_Turnaround then
				isDoorTurnaround := true;
				if _ti.jobYardDoor &lt;&gt; null then
					internalJobWLE:=_ti.jobYardDoor.workListEntries.first;
				endif;
			endif;
		endif;
		
		futureMove:=_wle.myFutureMove;
	endif;
	
	//epr par 21459 29/10/09 this was done because we have changed from moving the container to moving the chassis with the container on it
	// need to change the wles ti and the rt tasks ti to the chassis rather than the container - the rest should flow through in the move controller
	if _isForcedMove and _wle &lt;&gt; null and _wle.myTrackedItem &lt;&gt; _ti and _currentTask.ti &lt;&gt; _ti then
		otherTI:=_wle.myTrackedItem;
		_wle.setMyTrackedItem(_ti);
		_currentTask.ti:=_ti;
		
	endif;
	
	app.myUtlRT.utlRTGMoveTI(_currentTask,_toLocation, _machine, _ti,_wle,_isOverstow,true, _isForcedMove, _imvMachine, _imvTask,_quantity);	// 18/11/2010 cnwcs5 par 23714/ccms 1132
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//if it was going to the queued location then rtQueueTask is deleted
	if _setComplete then
		if global.isValidObject(_currentTask) and  _currentTask &lt;&gt; null then					
			_currentTask.setStatusComplete();
			foreach task in _currentTask.relatedTasks discreteLock where task &lt;&gt; _currentTask  do
				task.setStatusComplete();
			endforeach;
			if _passport.hasErrors() then
				return;
			endif;		
		endif;
		
		if (not isDoorTurnaround) and (not _isOverstow) then //14355 cnwer1 28/6/07
			create moveController transient;
			moveController.setMoveMode(QUEUE_MODE);
			//epr par 21459 29/10/09-changed the wles ti undo the queued move for the orginal ti
			if otherTI &lt;&gt; null then
				moveController.setMyTrackedItem(otherTI);
				app.myUtilityUA.utlUpdateMoveTIUndo(moveController, _passport);
				if _passport.hasErrors() then
					return;
				endif;
			endif;
			
			fmIndex:= _ti.allQueuedFutureMoves.indexOf(futureMove);
			//have to unqueue if the _ti is still queued i.e. it was moved to a location it was not queued to
			//if _ti.myPrimaryQueuedLocation &lt;&gt; null and _ti.myPrimaryQueuedLocation &lt;&gt; _toLocation then
			if 	fmIndex &gt; 0 then
				moveController.setMoveIndex(fmIndex);
				moveController.isFullyUnplan:=true;
				moveController.setMyTrackedItem(_ti);
				app.myUtilityUA.utlUpdateMoveTIUndo(moveController, _passport);
				if _passport.hasErrors() then
					return;
				endif;
			endif;
		endif;
			
		if isDoorTurnaround then
			//epr par 23121 12/3/09
			on Exception do app.handleDeletedObject(exception, internalJobWLE, isInvalid); 
		// have to update the wle requests door direction 
			if   internalJobWLE &lt;&gt; null then
				if internalJobWLE.myRequest &lt;&gt; null and internalJobWLE.myRequest.isKindOf(CM_YardRequest) then
					internalJobWLE.myRequest.setDoorDir(not internalJobWLE.myRequest.CM_YardRequest.doorsForward);
				endif;
			endif;
		endif;

		//if an imv  machine was involved and it is a set down and it does not have any
		// more tasks then make sure the machine is now idle
		if _imvMachine &lt;&gt; null and _imvMachine.allCurrentQueueTasks.size = null then
			if _imvMachine.machineStatus = STATUS_WORKING then
				app.myUtilityUA.utlUpdateMachineStatus(_imvMachine, STATUS_IDLE  , "", false, _passport);
			endif;
		endif;
	endif; 
	
	//Set the rtg to idle 
	if not _isOverstow then
		if _machine &lt;&gt; null and _machine.allCurrentQueueTasks.size = null then
			if _machine.machineStatus = STATUS_WORKING then
				app.myUtilityUA.utlUpdateMachineStatus(_machine, STATUS_IDLE  , "", false, _passport);
			endif;
		endif;
	endif;
	
	if _passport.noErrors then				// TFS 38663
		_passport.doDeferredUpdates();		// TFS 38663
	endif;									// TFS 38663

epilog
	if moveController &lt;&gt;  null then
		delete moveController;
	endif;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_toLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_isOverstow" type="Boolean"/>
        <Parameter name="_isForcedMove" type="Boolean"/>
        <Parameter name="_currentTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_setComplete" type="Boolean"/>
        <Parameter name="_imvMachine" type="CM_Machine" usage="input"/>
        <Parameter name="_imvTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRejectTask" id="025897ab-37da-46f8-b832-461d13b1d3f3">
        <updating/>
        <source>trxRejectTask(	_mediator : CM_RadioTelemetryMediator input; 
				_trxHook : CMIF_InterfaceTransactionHook input;
				_passport : CM_Passport input) updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
/*
Parameters: 		_trxHook : Optional hook to invoke wrap up processing method for calling interface.

Date		Who		Reason
30 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
10 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
*/

vars
	task			: CM_RTQueueTask;
	invalidTask		: Boolean;
	tempEdition		: Integer;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException  do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	//epr 33435 18/2/14
	if _passport.hasErrors() then
		return;
	endif;
	// PAR #18743 - Replace isValidObject with exception handler
	on Exception do app.handleDeletedObject(exception, task, invalidTask);

//	if not global.isValidObject(_mediator.task) or not global.isValidObject(_mediator.machine.currentQueueTask) then
//		return;
//	endif;

	// Need to dereference both task objects explicitly instead
	task := _mediator.task;
	if task = null then
		return;
	endif;
	tempEdition := task.edition;
	if invalidTask then
		return;
	endif;
	
	task := _mediator.machine.currentQueueTask;
	if task = null then
		return;
	endif;
	tempEdition := task.edition;
	if invalidTask then
		return;
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;

	beginTransaction;
	//-------------------
	//Requested a Task
	//-------------------
	//epr TFS 995 vmt refactoring
	app.myUtilityUA.utlMachineRejectTasks(null,_mediator.machine ,true,_passport);
		
	// Update the mediator timestamp
	if not _passport.hasErrors then
		app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);
	endif;

	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRequestTask" id="3ed278c4-bde6-4c18-ae35-18be3ec853ff">
        <updating/>
        <source>trxRequestTask(	_mediator : CM_RadioTelemetryMediator input;
				_trxHook : CMIF_InterfaceTransactionHook input; 
				_passport : CM_Passport input		) : Integer updating;
// -------------------------------------------
// Created 09 January 2006 by cnwdvb1
// -------------------------------------------
/*
Parameters: 		_trxHook : Optional hook to invoke wrap up processing method for calling interface.

Date		Who		Reason
30 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
*/

vars
	returnVal		: Integer;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException  do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	app.myValRT.valMediatorMachine(_mediator);
	
	//epr 33435 18/2/14
	if _passport.hasErrors() then
		return 0;
	endif;
	app.myValRT.validateOnHoldForRequestTask(_mediator);
	
	if _passport.hasErrors() then
		return 0;
	endif;

	beginTransaction;
	//-------------------
	//Requested a Task
	//-------------------
	
	app.setContinueCMExceptions(true);
	
	returnVal := _mediator.machine.executeGetTasks(_mediator, true);

	
	// Update the mediator timestamp
	if not _passport.hasErrors then
		app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);
	endif;

	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null and
	   not _passport.hasErrors then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
	return returnVal;
	
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_trxHook" type="CMIF_InterfaceTransactionHook" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxSetMediatorState" id="006a0952-9846-459b-b7e7-98c562016cc0">
        <updating/>
        <source>trxSetMediatorState(_mediator : CM_RadioTelemetryMediator input; _state : Integer; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 16 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	app.myValRT.valMediator(_mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;
	//-------------------
	//Requested a Task
	//-------------------
	_mediator.setState(_state);
	
epilog

	self.finaliseActivityWithPassport(_passport);


end;</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSetUserColors" id="ddeca496-47a6-45d7-8a60-95b140ddba99">
        <updating/>
        <source>trxSetUserColors(_colorBackGeneralRT, _colorForeGeneralRT, _colorBackTableRT, _colorForeTableRT : Integer; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 25 January 2006 by cnwdvb1
// -------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	beginTransaction;
	//-------------------
	//Requested a Task
	//-------------------
	
	app.myUtlRT.utlSetUserColors(_colorBackGeneralRT, _colorForeGeneralRT, _colorBackTableRT, _colorForeTableRT, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_colorBackGeneralRT" type="Integer"/>
        <Parameter name="_colorForeGeneralRT" type="Integer"/>
