    <JadeMethod name="loadList" id="7b361fe3-a661-408e-8668-0e017fffaf9c">
        <source>loadList(listbox: ListBox; level: Integer);

vars
	tmc : CMIF_TranMapController;
	pic : Picture;
	str : String;
	int : Integer;
begin
	int := 1;
	if self.itemName &lt;&gt; null then
		str := itemName.scanUntil(Tab, int);
	endif;
	str := str.trimRight;
	
	listbox.addItem(str);
	listbox.itemLevel[listbox.newIndex] := level;
	listbox.itemObject[listbox.newIndex] := self;
	listbox.itemData[listbox.newIndex] := self.getType();
	pic := getPicture(listbox.form.INV_TransactionMap);
	if pic &lt;&gt; null then
		listbox.itemPicture[listbox.newIndex] := pic.picture;
	endif;

	foreach tmc in self.allGroupMembers do
		tmc.loadList(listbox, level + 1);
	endforeach;

end;</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadList2At" id="22df9234-a9a0-4394-a540-8b6ad0f99eb3">
        <source>loadList2At(listbox: ListBox; level: Integer; at: Integer io);

vars
	tmc : CMIF_TranMapController;
	i :Integer;
	pic : Picture;
	str : String;
	int : Integer;
begin
	int := 1;
	if self.itemName &lt;&gt; null then
		str := itemName.scanUntil(Tab, int);
	endif;
	str := str.trimRight;
	
	listbox.addItemAt(str, at);
	listbox.itemLevel[listbox.newIndex] := level;
	listbox.itemObject[listbox.newIndex] := self;
	listbox.itemData[listbox.newIndex] := self.getType();
	pic := getPicture(listbox.form.INV_TransactionMap);
	if pic &lt;&gt; null then
		listbox.itemPicture[listbox.newIndex] := pic.picture;
	endif;

	i := at;
	foreach tmc in self.allGroupMembers do
		i := i + 1;
		tmc.loadList2At(listbox, level + 1, i);
	endforeach;
	at := i;
end;</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="at" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadListaAt" id="a4e273e9-146d-4b0f-8423-7a56b9a44c67">
