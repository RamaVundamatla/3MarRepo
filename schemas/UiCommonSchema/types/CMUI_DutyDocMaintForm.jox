    <JadeMethod name="initFromUserWindow" id="abd2c8d5-080e-45b7-be8b-4266ae2b3b65">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2014	cnwndl1	Initial creation

*/

vars
	xml : String;
begin
	inheritMethod(_userWindow);
	
	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblDutyDocItems.XMLTag_Table &amp; self.tblDutyDocItems.name);
	if xml &lt;&gt; null then
		self.xmlStrTblText := global.formatAsXMLPrefix(self.tblDutyDocItems.XMLTag_Table &amp; self.tblDutyDocItems.name) &amp; 
								  xml &amp;
								  global.formatAsXMLSuffix(self.tblDutyDocItems.XMLTag_Table &amp; self.tblDutyDocItems.name);
	endif;

epilog

end;</source>
