    }
]';

	BadLogin : String = '{
	"userId": "baduser",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "LWT",
		"yardId": "MTN"
	},
	"applicationId": "c0769874-2092-493e-8956-04ea6cb0effc"
}';

vars
	utHelperTerminal		: UT_HelperAdmTerm;
	incomingJsonString,
	terminalCode,
	loginJson,
	params,
	shippingLineCode		: String;
	terminal				: CM_Terminal;
	expectFailure			: Boolean;
	root					: CM_Root;
	booking					: CM_BookingRef;
	bookingItem				: CM_BookingRefItem;
	contCargoType			: CM_CargoType;
	contCargoTypeId			: Integer;
	
	operatorOrig1,
	operatorOrig2			: CM_Operator;
	vesselOrig1,
	vesselOrig2				: CM_Vessel;
	voyageOrig1,
	voyageOrig2				: CM_Voyage;
	consignorOrig1,
	consignorOrig2,
	consigneeOrig1,
	consigneeOrig2,
	freightForwarderOrig1,
	freightForwarderOrig2	: CM_ConsigneeConsignor;
	carrier1,
	carrier2				: CM_Carrier;
	stevedore,
	stevedoreOrig1,
	stevedoreOrig2			: CM_Stevedore;
	
	pxyBooking				: CM_BookingRef;
	pxyBookingItem			: CM_BookingRefItem;
	
begin
	create utHelperTerminal transient;
	root := app.myRoot;
	
	//Get terminal
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	
	app.writeLog("Changing MaxLiftWeightWarnOnly Terminal Config to true", LogINFO);
	app.writeLog("Changing IsSubTerminalsOn Terminal Config to false", LogINFO);
	self.setTerminalConfig(MaxLiftWeightWarnOnly, true);
	self.setTerminalConfig(IsSubTerminalsOn, false);
	
	/*
	** Original Booking 1 Creation
	*/
	//Get operator
	operatorOrig1 := root.allOperators[UTOperatorIdOrig1];
	self.assertTrueMsg(operatorOrig1 &lt;&gt; null, method.name &amp; " | Setup: operatorOrig1 is null/could not be found | Operator Code: " &amp; UTOperatorIdOrig1);
	
	//Get consignor
	consignorOrig1 := root.allConsigneeConsignors[UTConsignorCodeOrig1];
	self.assertTrueMsg(consignorOrig1 &lt;&gt; null, method.name &amp; " | Setup: consignorOrig1 is null/could not be found | Consignor Code: " &amp; UTConsignorCodeOrig1);
	
	//Get consignee
	consigneeOrig1 := root.allConsigneeConsignors[UTConsigneeCodeOrig1];
	self.assertTrueMsg(consigneeOrig1 &lt;&gt; null, method.name &amp; " | Setup: consigneeOrig1 is null/could not be found | Consignee Code: " &amp; UTConsigneeCodeOrig1);
	
	//Get freightForwarder
	freightForwarderOrig1 := root.allConsigneeConsignors[UTFreightForwarderCodeOrig1];
	self.assertTrueMsg(freightForwarderOrig1 &lt;&gt; null, method.name &amp; " | Setup: freightForwarderOrig1 is null/could not be found | Freight Forwarder Code: " &amp; UTFreightForwarderCodeOrig1);
	
	//Get carrier
	carrier1 := root.allCarriers[UTCarrierCode1];
	self.assertTrueMsg(carrier1 &lt;&gt; null, method.name &amp; " | Setup: carrier1 is null/could not be found | Carrier Code: " &amp; UTCarrierCode1);
	
	//Get stevedore
	stevedoreOrig1 := root.allStevedores[UTStevedoreCodeOrig1];
