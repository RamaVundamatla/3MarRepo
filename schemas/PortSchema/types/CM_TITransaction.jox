// ---------------------------------------------------------------------------
vars

begin

	if self.myTrackedItem = null and
	   (not self.hasStockMovements) then
		// This has been removed from the tracked item already so safe to delete
		self.erase(eraseLevel);
	endif;

end;</source>
        <Parameter name="eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fromHandHeld" id="246aef67-7377-478e-832b-533f400c51d2">
        <source>fromHandHeld() : Boolean;

/*

Purpose: Determine if the caller is from the Handheld Truck unloader

Parameters:			

Return Value:		


Date		Who		TFS		Reason
21 Nov 2019	jlgdi1	46578	To fix conflicting terminal configuration between 
							Handheld  Trunck Unloader Edit Unload (STWO) and 
							Road Operation Delete Current Entry Option (SNO)
*/
constants
	HandHeld_TruckUnloaderAllCargo : String = "MOB_HHTruckUnloaderAllCargo";
	HandHeld_TruckUnloaderCargo : String = "MOB_HHTruckUnloaderCargo";
	
vars
	extraData : Any;
	
begin
	extraData := self.getExtraData(TrnsExtraDataContext);
	return (extraData &lt;&gt; null) and 
	((extraData.String = HandHeld_TruckUnloaderAllCargo) or (extraData.String = HandHeld_TruckUnloaderCargo));
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="generateEditAudit" id="0f9b8f5f-ada3-4938-aabf-1397fd61cb3a">
        <source>generateEditAudit(_passport : CM_Passport input);
/* NFS 3798 AJA 23/1/01: Called after an edit on a transaction.
Creates a new edit transaction to record details of the change
If needed, also creates an invoice audit from the edit transaction to enable accounts
to audit the invoice line.
*/
vars
	errorAudit:        CM_AuditTIEdit;
	edit : CM_Edit;
	txnParams : CMIF_TITransactionController;
	undeleted : Boolean;
	invLine : CM_InvoiceLine;
begin

	if self.myTrackedItem = null then
		return;		//Lost ref: just abort
	endif;

	if _passport = null then // PAR 20155
		return;
	endif;
	
	create txnParams transient;
	txnParams.type 		:= TRANS_TYPE_EDIT;
//Par 15270
//	txnParams.userId 	:= self.userId;
	txnParams.userId 	:= _passport.userCode;
	txnParams.noCharge 	:= false; // TFS 3844 changed to false
			
	edit := self.myTrackedItem.createTransaction(txnParams, _passport).CM_Edit;
	//Work out what got changed and add to edit transaction
	edit.fieldsValues.add(self.typeString &amp; " Transaction ");

	if deleted = true then
		edit.fieldsValues.add("Deleted");
	elseif self.previousVersions.size &gt; 0 and self.previousVersions.last.deleted = true then
		edit.fieldsValues.add("Undeleted");
		undeleted := true;
	elseif ammended = true then
		if previousVersions.size &gt; 0 then
			if previousVersions.last.dateTime &lt;&gt; self.dateTime then
				edit.fieldsValues.add("Date Time");
			else		//Must be something else
				edit.fieldsValues.add("Details");
			endif;
		else
			edit.fieldsValues.add("Amended");		//Default !
		endif;
	endif;
	
	foreach invLine in self.allInvoiceLines discreteLock do
		if invLine &lt;&gt; null then
			//If txn generated an invoice line then also create an audit against the invoice
			if deleted = true then
				//create a 'deleted' warning
				create errorAudit;
				errorAudit.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036
				errorAudit.setTrackedItem(self.myTrackedItem);
				errorAudit.setTransaction(edit);
				errorAudit.remarks := self.typeString &amp; " transaction manually deleted";
				errorAudit.unauditedFOs.add(invLine.invoice);
				
			elseif undeleted = true then
				//create an 'undeleted' warning
				create errorAudit;
				errorAudit.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036
				errorAudit.setTrackedItem(self.myTrackedItem);
				errorAudit.setTransaction(edit);
				errorAudit.remarks := self.typeString &amp; " transaction manually undeleted";
				errorAudit.unauditedFOs.add(invLine.invoice);		
			elseif ammended = true then
				//create an 'edited' warning
				create errorAudit;
				errorAudit.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036
				errorAudit.setTrackedItem(self.myTrackedItem);
				errorAudit.setTransaction(edit);
				errorAudit.remarks := self.typeString &amp; " transaction manually edited";
				errorAudit.unauditedFOs.add(invLine.invoice);		
			
			endif;
		endif;
	endforeach;
epilog
	delete txnParams;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="generateEditAuditForDelete" id="47c2f8c1-6020-4512-91e6-c78149748201">
        <source>generateEditAuditForDelete(_passport : CM_Passport input; _reasonObject : CM_Object);
/* ---------------------------------------------------------------------------
Created:     June 2009 ANDREW BISHOP
PAR 20155

Date		By		TFS		Description
21 Nov 2019	jlgdi1	46578	Fixed Conflicting terminal configuration between 
							Handheld  Truck Unloader Edit Unload (STWO) and 
							Road Operation Delete Current Entry Option (SNO)
---------------------------------------------------------------------------*/

vars
	errorAudit:        CM_AuditTranDeleted;
	edit : CM_Edit;
	txnParams : CMIF_TITransactionController;
	undeleted : Boolean;
	invLine : CM_InvoiceLine;
	niceName : String;
	voidInvoiceLine : Boolean;	//29 Aug 2018	NDL	TFS 39769
	invoiceLineStatus : CMIF_InvoiceStatus;	//29 Aug 2018	NDL	TFS 39769
begin

	if self.myTrackedItem = null then
		return;	
	endif;

	if _passport = null then
		return;
	endif;
	
	if self.fromHandHeld() then 
		//29 Aug 2018	NDL	TFS 39769
		voidInvoiceLine := self.isKindOf( CM_ReceiveRoad ) and self.myTerminal.getConfig( HhTUnloadEdit ).Boolean;
	endif;

	
	if _reasonObject &lt;&gt; null then
		niceName := "(" &amp; _reasonObject.getNiceName() &amp; " " &amp; _reasonObject.getTranDeleteMessage()  &amp; ")"; // Will be voyage or wagon etc
	endif;
	
	create errorAudit;
	errorAudit.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); 
	errorAudit.init(self.myTrackedItem,self);
	if voidInvoiceLine then	//29 Aug 2018	NDL	TFS 39769
		errorAudit.remarks := self.typeString &amp; " transaction deleted, any invoice lines voided " &amp; niceName;
		create invoiceLineStatus transient;
		invoiceLineStatus.newStatus:= CM_InvoiceLine.STATUS_VOIDED;
	else
		errorAudit.remarks := self.typeString &amp; " transaction deleted " &amp; niceName;
	endif;

	foreach invLine in self.allInvoiceLines discreteLock do
	//	if invLine &lt;&gt; null then	//23 Jan 2014	NDL	Par 31538 - removed, not needed... Inversed collection
			errorAudit.unauditedFOs.add(invLine);
			if invLine.invoice &lt;&gt; null then
				if not errorAudit.unauditedFOs.includes(invLine.invoice) then	//23 Jan 2014	NDL	Par 31538
					errorAudit.unauditedFOs.add(invLine.invoice);
				endif;
			endif;
			//29 Aug 2018	NDL	TFS 39769
			if voidInvoiceLine then	
				if not invLine.voided then // TFS 43075 JLGAB1
					invLine.setForUpdateStatus(invoiceLineStatus);
				endif;
			endif;
	//	endif;
	endforeach;
epilog
	delete txnParams;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_reasonObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getAmountDisplay" id="c21bd44a-6aad-4302-8ace-44cc9c3d08d5">
        <source>getAmountDisplay() : String;
/*

Date		Who		Reason
07 December 2016	cnwer1	Initial creation TFS 2996

*/

vars
	ct : CM_CargoType;
	product : CM_Product;
	ti	: CM_TrackedItem;
	density  	: Decimal[14,4];
begin
	if not self.getCargoTypeAndSubType(ct,product) then
		return null;
	endif;
	
	if ct.isBreakBulkMulti then
		if self.totalQuantity &gt;  1 then
			return self.totalQuantity.asStringJMT ;
		endif;
	elseif ct.isBulkMulti then
		ti:= self.myTrackedItem;
		density:=ti.getDensity;
		
		return  ct.getBulkTrackByDisplayForWeight( self.totalWeight,density,true) ;	
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="7f40e7dc-a3a3-41e6-b924-fb090799a22b">
        <source>getAuditText(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file add inherit method

*/

vars

	text : String;
	resourceUsage : CM_ResourceTypeUsage;
	//count : Integer;
	resourceUsageName : String;
	propName : String;
	propValue : String;
	resourceUsageText : String;
	
begin
	text := inheritMethod();
	
	foreach resourceUsage in self.allResourceUsages do
	
	//	count := self.getInstanceIdForObject(resourceUsage).Integer;
	//	resourceUsageName := "Resource" &amp; count.String &amp; "_";
		resourceUsageName := resourceUsage.identifier() &amp; "_";
		resourceUsageText := null;
		
		propName := resourceUsageName &amp; CM_ResourceTypeUsage::myResourceType.name;
		propValue := resourceUsage.myResourceType.description;
		resourceUsageText := self.formatAuditText(propName, propValue);
		
		propName := resourceUsageName &amp; CM_ResourceTypeUsage::quantity.name;
		propValue := resourceUsage.quantity.String &amp; " " &amp; resourceUsage.myResourceType.unitDescription;
		resourceUsageText := resourceUsageText &amp; self.formatAuditText(propName, propValue);
		
		propName := resourceUsageName &amp; CM_ResourceTypeUsage::remarks.name;
		propValue := resourceUsage.remarks;
		resourceUsageText := resourceUsageText &amp; self.formatAuditText(propName, propValue);

		propName := resourceUsageName &amp; CM_ResourceTypeUsage::noCharge.name;
		propValue := resourceUsage.noCharge.String;
		resourceUsageText := resourceUsageText &amp; self.formatAuditText(propName, propValue);
		
		propName := resourceUsageName &amp; CM_ResourceTypeUsage::status.name;
		propValue := resourceUsage.getStatusString &amp; "[" &amp; resourceUsage.status.String &amp; "]";
		resourceUsageText := resourceUsageText &amp; self.formatAuditText(propName, propValue);
		
		text := text &amp; resourceUsageText;
		
	endforeach;
	
	return text;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBusinessUnitObject" id="ba87d3e3-3b65-477e-9af4-db7dfd301d22">
        <source>getBusinessUnitObject() : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		19 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
// ---------------------------------------------------------------------------
vars
begin
	if self.companyCode = null then
		return null;
	endif;
	
	if app.myRoot = null then
		return null;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then          //16.10.2019 cnwma1 #46974
		return self.myTrackedItem.companyOid;
	endif;

	return app.myRoot.getCompanyByCode(self.myTerminal, self.companyCode);

end;</source>
