    <JadeMethod name="resizeInvPropFrame" id="7afec861-b35d-48e9-b8ba-96d7dad4e5ad">
        <source>resizeInvPropFrame();
/*

Date		Who		Reason
28 September 2015	cnwer1	Initial creation PAR 36958

*/

vars
	theHeight : Real; 
begin
	self.tblInvProperties.resetHeight();
	theHeight:= self.tblInvProperties.clientHeight;
	self.frmInvPropParent.height :=  theHeight;
	self.frmInvProperties.height := self.frmInvToolbar.height + theHeight + 30;
