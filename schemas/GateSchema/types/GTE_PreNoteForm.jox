        <source>initMainTable()updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed on	By			Reason
// ----------	--------	--------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
vars
	
begin

	inheritMethod();
	//self.myAssistant.GTE_Assistant.receival_InitTblMain(tblMain); done above
	self.myAssistant.GTE_Assistant.comboBoxTransportMode(tblMain, ETRow_TransportMode, self.lastTransportMode);
	
	//if self.viewTransportMode &lt;&gt; app.getErrorString(BR_TYPE_DESCR_SHIP) then // cnwrd1 par 18519 6.3.09	// PAR #27972
	if self.viewTransportMode &lt;&gt; BR_TYPE_SHIP_STR then // cnwrd1 par 18519 6.3.09							// PAR #27972
		tblMain.hideRowByName(ETRow_YardLocationTxt, false);
	else
		tblMain.hideRowByName(ETRow_ReceiptTransportMode, false);
	endif;
	//Par 5846 23092003 CNWSH3	
	//Used in doCancel method to check if a change has occured on the CM_EntryTable control
	tblMain.changeMode := tblMain.ChangeMode_FirstOnly;
end;</source>
