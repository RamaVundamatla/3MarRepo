<Class name="CM_WOVBSToDoSlotWLE" id="3eb240ea-7199-4ded-8038-8dee6dd39fa1">
    <superclass name="CM_WOToDoWLE"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myVBSlot" id="b0f4f9d9-0793-43bc-a510-a24921e529f5">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_VehicleBookingTimeSlot"/>
        <access>readonly</access>
        <Inverse name="CM_VehicleBookingTimeSlot::allWorkOrderWLEs"/>
    </ExplicitInverseRef>
    <JadeMethod name="addToDoTask" id="38ca4759-5312-4097-8add-883c94a08e04">
        <updating/>
        <source>addToDoTask() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoDesc 		: CM_ToDoTaskDesc;
	vbsTask			: CM_ToDoTask;
	passport 		: CM_Passport;
	
begin
	
	if self.myVBSlot = null then
		//throw error
		return;
	endif;
	
	passport := app.myPassport;
	
	toDoDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;

	if vbsTask = null then //add task
		vbsTask := self.myVBSlot.createToDoTask(toDoDesc.code, self.job.myWorkOrderDtlToDo); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.job.myWorkOrderDtlToDo.allToDoTasks.add(vbsTask);
	endif;
	
	self.myToDoTask := vbsTask;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setVBSlot" id="948b081a-700c-424a-8fac-ee9c62175166">
        <updating/>
        <source>setVBSlot(_vbSlot : CM_VehicleBookingTimeSlot) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	self.myVBSlot := _vbSlot;
	
	self.addToDoTask();	
epilog

end;</source>
        <Parameter name="_vbSlot" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
</Class>
