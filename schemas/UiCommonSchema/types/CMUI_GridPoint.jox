    <JadeMethod name="setForCreateSuperClass" id="ac400adf-c960-4814-ac2d-b7238742b7ca">
        <updating/>
        <source>setForCreateSuperClass(_gridArea : CMUI_GridArea; _row, _col : Integer) updating, protected;

vars

begin
	self.myGridRow		:= _gridArea.allGridRows[_row];	//09 Oct 2012	NDL	Par 30476
	self.myGridColumn 	:= _gridArea.allGridColumns[_col];
//	self.myGridRow		:= _gridArea.allGridRows[_row];
