begin

	if (not self.getProxyObject(CM_Depot)) then
		return false;
	endif;

	proxyTA := self.myProxyObject.CM_Depot;

	tmpID := tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType := TA_TYPE_DEPOT_LCL;
	tmpHeight := 3;
	tmpTypeString := tblMain.getValueByName(ETRow_Type).String.trimBlanks;
	tmpRel := tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpStockControlled := tblMain.getValueByName(ETRow_StockControlled).Boolean;
	tmpMax := tblMain.getValueByName(ETRow_MaxCapacity).Integer;
	tmpComment := tblMain.getValueByName(ETRow_Comment).String;
	tmpHide:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	tmpInterchange	:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea	:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;
	
	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);

	proxyTA.setProxy(tmpID, tmpComment, tmpType, tmpHeight, tmpTypeString, tmpMax,tmpRel,self.myTerminal, tmpStockControlled, tmpHide,selectedInterchangeAreas, interchangeArea);
	self.createDeckingOptionsProxy(proxyTA);
	return true;

epilog
	delete selectedInterchangeAreas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTAFork" id="728ad20e-d1e7-4c19-aa12-4d9fa596bd64">
        <updating/>
        <source>setTAFork() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010	cnwcs5	par 24292 - use array instead of set
// ---------------------------------------------------------------------------
vars
	proxyTA 						: CM_ForkLiftStack;
	tmpComment,
	tmpBottomLbl,tmpTopLbl,tmpLeftLbl,tmpRightLbl,
	tmpID, tmpTypeString, tmpStagger		: String;
	tmpRows, tmpCols, tmpHeight, tmpType,tmpColour	: Integer;
	tmpRel, tmpBack, tmpFront, snapStrict,
	use40ftIds								: Boolean;
	tmpMaxFull, tmpMaxMT, tmpMaxPower		: Real;
	tmpStockControlled	,tmpHide, snapLeft, goRight, useSide	: Boolean;
	tmpDeckingStartType						: Integer;
	tmpInterchange	: String;
	interchangeArea	: CM_InterchangeArea;
	selectedInterchangeAreas : CM_InterchangeAreaArray;	// par24292
begin

	if (not self.getProxyObject(CM_ForkLiftStack)) then
		return false;
	endif;
	proxyTA := self.myProxyObject.CM_ForkLiftStack;
	
	tmpDeckingStartType := self.cmbColumnDir.getCurrentItemData();
	tmpID := tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType := TA_TYPE_FORK_LIFT_STACK;
	tmpRows := tblMain.getValueByName(ETRow_Rows).Integer;
	tmpCols := tblMain.getValueByName(ETRow_Cols).Integer;
	tmpHeight := tblMain.getValueByName(ETRow_Height).Integer;
	tmpRel  := tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpTypeString := tblMain.getValueByName(ETRow_Type).String;
	tmpRel := tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpBack := tblMain.getValueByName(ETRow_AccessBack).Boolean;
	tmpFront := tblMain.getValueByName(ETRow_AccessFront).Boolean;
	
	//20/06/2011 cnwdz2 27732
	tmpTopLbl:=tblMain.getValueByName(ETRow_TopLabel).String;
	tmpBottomLbl:=tblMain.getValueByName(ETRow_BottomLabel).String;
	tmpLeftLbl:=tblMain.getValueByName(ETRow_LeftLabel).String;
	tmpRightLbl:=tblMain.getValueByName(ETRow_RightLabel).String;
	
	tmpMaxFull := tblMain.getValueByName(ETRow_MaxHeightFull).String.asRealJMT;		// 36603 was .Real
	tmpMaxMT := tblMain.getValueByName(ETRow_MaxHeightMT).String.asRealJMT;			// 36603 was .Real
	tmpMaxPower := tblMain.getValueByName(ETRow_MaxHeightPower).String.asRealJMT;	// 36603 was .Real
	tmpStagger := tblMain.getValueByName(ETRow_StaggerHeights).String;
	tmpStockControlled := tblMain.getValueByName(ETRow_StockControlled).Boolean;
	tmpColour := tblMain.getValueByName(ETRow_Colour).Integer;
	tmpComment := tblMain.getValueByName(ETRow_Comment).String;
	tmpHide:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	snapLeft := tblMain.getValueByName(ETRow_IsSnapToBackend).Boolean; // PAR 18682 CCMS SFW 1055
	goRight := tblMain.getValueByName(ETRow_IsAlignRight).Boolean; // PAR 18682 CCMS SFW 1055
	snapStrict := tblMain.getValueByName(ETRow_IsSnapStrictGrid).Boolean; // PAR 18682 CCMS SFW 1055
	tmpInterchange	:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea	:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;
	useSide := tblMain.getValueByName(ETRow_UseSideAccessRules).Boolean;	// PAR 21532 CCMS SFW 1025
	use40ftIds := tblMain.getValueByName(ETRow_Use40ftIds).Boolean;   	// PAR 24463 epr 14/7/10
	
	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);
	
	if proxyTA.myLayoutGraphic &lt;&gt; null then
		proxyTA.myLayoutGraphic.setProxyColour(tmpColour, White);
	else
		// 24/06/2009 - added next line to make sure the colour gets saved 
		// to the proxy even for a  new TA
		self.setGraphicLayout(tmpColour);
	endif;
	if self.mode = Mode_Add then
		proxyTA.setIsEmpty(true);
	endif;	
	proxyTA.setProxy(tmpID, 
					tmpComment,
					tmpType, 
					tmpRows, 
					tmpCols, 
					tmpHeight, 
					tmpTypeString, 
					tmpBack, 
					tmpFront, 
					tmpMaxFull, 
					tmpMaxMT, 
					tmpMaxPower, 
					tmpStagger, 
					tmpRel, 
					self.myTerminal, 
					tmpStockControlled, tmpHide, tmpDeckingStartType, true, true,
					snapLeft, goRight, snapStrict, selectedInterchangeAreas,interchangeArea, useSide,use40ftIds,
					tmpLeftLbl,tmpRightLbl,tmpTopLbl,tmpBottomLbl); //20/06/2011 cnwdz2 27732
					
	self.createDeckingOptionsProxy(proxyTA);

	self.setGridOffsets(proxyTA);
	
	self.setTAGridLCsAssocICAreas();
	
	return true;

epilog
	delete selectedInterchangeAreas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTAGeneralAllocRow" id="a96efbd8-b6ab-4ddd-999e-bfd27a966d3b">
        <updating/>
        <source>setTAGeneralAllocRow() : Boolean updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	taType : CM_TerminalAreaType;
	proxyTA : CM_GeneralCargoAllocRowArea;
	id, typeString, comment : String;
	type, colour, areaLength, areaWidth : Integer;
	columns, dividers : String;
	colArray, divArray : StringArray;
	rel, hide, stock : Boolean;
	interchange : String;
	interchangeArea : CM_InterchangeArea;
	selectedInterchanges : CM_InterchangeAreaArray;
	error : Integer;
	divError : String;
	product : CM_Product;
	cargoType : CM_CargoType;
	pxyProdMinMax : CM_TerminalAreaProductMinMax;
	maxVolume, minVolume : Decimal [16,4];
	maxWeight, minWeight, maxQuantity : Integer;

begin
	if not self.getProxyObject(CM_GeneralCargoAllocRowArea) then
		return false;
	endif;
	
	taType := self.getTAStringToType(self.tblMain.getValueByName(ETRow_Type).String);
	proxyTA := self.myProxyObject.CM_GeneralCargoAllocRowArea;
	
	id := self.tblMain.getValueByName(ETRow_Id).String[1:6];
	type := taType.type;
	typeString := self.tblMain.getValueByName(ETRow_Type).String.trimBlanks;
	comment := self.tblMain.getValueByName(ETRow_Comment).String;
	colour := self.tblMain.getValueByName(ETRow_Colour).Integer;
	rel := self.tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	stock := self.tblMain.getValueByName(ETRow_StockControlled).Boolean;
	hide := self.tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	interchange := self.tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea := self.myTerminal.allTerminalAreas[interchange].CM_InterchangeArea;
	areaLength := self.tblMain.getValueByName(ETRow_Length).Integer;
	areaWidth := self.tblMain.getValueByName(ETRow_WidthOfArea).Integer;
	columns := self.tblMain.getValueByName(ETRow_ColumnLabels).String;
	dividers := self.tblMain.getValueByName(ETRow_DividersBefore).String;
	
	create colArray transient;
	create divArray transient;
	if not self.validateColumnsAndDividers(columns, dividers, colArray, divArray, error, divError) then
		if divError = null then
			app.raiseCMException(error, null, null);
		else
			app.raiseCMException1(error, divError, null, null);
		endif;
		return false;
	endif;
	
	create selectedInterchanges transient;
	self.listsTermAreas.getSelected(selectedInterchanges);
	
	if proxyTA.myLayoutGraphic &lt;&gt; null then
		proxyTA.myLayoutGraphic.setProxyColour(colour, White);
	else
		self.setGraphicLayout(colour);
	endif;
	if mode = Mode_Add then
		proxyTA.setIsEmpty(true);
	endif;	

/*	product := self.cmbProduct.listObject.CM_Product;
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	if cargoType &lt;&gt; null or product &lt;&gt; null then
		pxyProdMinMax := proxyTA.getProductMinMaxObject(cargoType, product);
		
		if pxyProdMinMax = null then
			create pxyProdMinMax transient;
		endif;
		
		maxVolume	:= tblExtra.getMeasurementValueByName(ETRow_TaMaxVolPerCol).String.asDecimalJMT;
		maxWeight	:= tblExtra.getMeasurementValueByName(ETRow_MaxWeightPerCol).Decimal.Integer;
		maxQuantity	:= tblExtra.getValueByName(ETRow_MaxQtyPerCol).asStringJMT.Integer;
		pxyProdMinMax.setupProxy(lc, cargoType, product, proxyTA, minVolume, minWeight, maxVolume, maxWeight, maxQuantity);
	endif; */
	
	proxyTA.setProxy(id, comment, type, areaLength, areaWidth, rel, self.myTerminal, false, false, null, false, stock, hide, selectedInterchanges, interchangeArea);
	self.createDeckingOptionsProxy(proxyTA);
	proxyTA.createProxyLCsAndGroups(colArray, divArray);
	
	return true;
	
epilog
	delete colArray;
	delete divArray;
	delete selectedInterchanges;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTAGridLCsAssocICAreas" id="6b381a4e-bc16-4ce7-a7d6-c7726979e2e0">
        <source>setTAGridLCsAssocICAreas() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwer1	Initial creation

*/

vars
	obj 	: Object;
	cmifGridLCsAssocICArea : CMIF_GridLCsAssocICArea;
	iter	: Iterator;
	gridController  :CM_GridController;
	invalidObj : Boolean;
begin
	if self.allCMIFGridLCsAssocICArea.isEmpty then
		return;
	endif;
	
	//epr par 37377 18/1/16
	on Exception do app.handleDeletedObject(exception,gridController,invalidObj);
	
	foreach obj in self.allCMIFGridLCsAssocICArea do
		cmifGridLCsAssocICArea:=obj.CMIF_GridLCsAssocICArea;
		delete iter;
		iter:=cmifGridLCsAssocICArea.allGridControllers.createIterator;
		while iter.next(gridController) do		
			gridController.setMyAssocGridInterchangeArea(cmifGridLCsAssocICArea.myInterchangeArea);	
		endwhile;	
		
		if invalidObj then
			cmifGridLCsAssocICArea.allGridControllers.removeInvalidObjects();
			invalidObj:=false;
		endif;
	endforeach;
epilog
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTALog" id="981d3ca1-02da-4bf3-a708-9387649c022a">
        <updating/>
        <source>setTALog() : Boolean protected, updating;
// 26/05/2010	cnwcs5	par 24292 - use array instead of set
vars

	proxyTA  						: CM_RowArea;
	 isGapManaged					: Boolean;
	isMarked								: Boolean;
	tmpID									: String;
	 tmpType,
	 tmpLength, tmpWidth			: Integer;
	tmpRel	 								: Boolean;
	tmpComment,
	labels									: String;
	tmpAutoRestrict,
	tmpStockControlled						: Boolean;
	tmpInterchange	: String;
	interchangeArea	: CM_InterchangeArea;
	selectedInterchangeAreas : CM_InterchangeAreaArray;	// par 24292
begin

	if (not self.getProxyObject(CM_LogArea)) then
		return false;
	endif;

	proxyTA := self.myProxyObject.CM_LogArea;
	tmpID := tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType := TA_TYPE_LOGAREA;
	tmpRel  := true;
	tmpLength := tblMain.getValueByName(ETRow_Length).Integer;
	isMarked := tblMain.getValueByName(ETRow_MarkedUp).Boolean;
	if isMarked then
		tmpWidth := tblMain.getValueByName(ETRow_Width).Integer;
	endif;
	isGapManaged := tblMain.getValueByName(ETRow_GapManaged).Boolean;
	labels :=  tblMain.getValueByName(ETRow_Labels).String;
	tmpStockControlled := tblMain.getValueByName(ETRow_StockControlled).Boolean;
	tmpComment := tblMain.getValueByName(ETRow_Comment).String;
	tmpAutoRestrict := tblMain.getValueByName(ETRow_AutoRestrictionsEnabled).Boolean;
	tmpInterchange	:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea	:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;
	
	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);
	
	proxyTA.setProxy(tmpID, tmpComment,
					tmpType, 
					tmpLength, 
					tmpWidth, 
					tmpRel, 
					self.myTerminal, 
					isGapManaged, 
					isMarked, 
					labels,
					tmpAutoRestrict,
					tmpStockControlled,false,
					selectedInterchangeAreas,
					interchangeArea);
	return true;
epilog
	delete selectedInterchangeAreas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTARTG" id="6fe3d7bc-810c-459a-8637-fb5adf1aac9a">
        <updating/>
        <source>setTARTG(_type : Integer): Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
08/04/2011	 cnwmh5		 PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state	
----------   ----------  --------------------------------------------------
*/
vars

	proxyTA 				: CM_RTGArea;
	tmpComment,
	tmpID,
	tmpBottomLbl,
	tmpTopLbl: String;
	tmpRows, tmpCols, tmpHeight,
	tmpType,tmpColour 				: Integer;
	tmpMaxHeight	: Real;
	tmpRel, snapLeft, goRight, snapStrict					: Boolean;
	tmpAutoRestriction,
	tmpStockControlled,
	tmpHide, useSide				: Boolean;
	
	tmpDeckingStartType,
	interchangePosition,
	laneIndex: Integer;
	use40ftIds: Boolean;
	rtgLane,
	pxyRTGLane : CM_RTGLane;
begin
	
	if (not self.getProxyObject(CM_RTGArea)) then
		return false;
	endif;
	
	proxyTA := self.myProxyObject.CM_RTGArea;
	
	tmpDeckingStartType 	:= self.cmbRowDir.getCurrentItemData();
	tmpID 					:= tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType 				:= _type;
	tmpRows 				:= proxyTA.allGridRows.size;
	tmpCols 				:= tblMain.getValueByName(ETRow_Bays).Integer;
	tmpHeight 				:= tblMain.getValueByName(ETRow_Height).Integer;
	tmpStockControlled 		:= tblMain.getValueByName(ETRow_StockControlled).Boolean;
	tmpRel  				:= tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpColour 				:= tblMain.getValueByName(ETRow_Colour).Integer;
	tmpComment 				:= tblMain.getValueByName(ETRow_Comment).String;
	tmpHide					:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	tmpAutoRestriction 		:= tblMain.getValueByName(ETRow_AutoRestrictionsEnabled).Boolean;
	
	snapLeft := tblMain.getValueByName(ETRow_IsSnapToBackend).Boolean; // PAR 18682 CCMS SFW 1055
	goRight := tblMain.getValueByName(ETRow_IsAlignRight).Boolean; // PAR 18682 CCMS SFW 1055
	snapStrict := tblMain.getValueByName(ETRow_IsSnapStrictGrid).Boolean; // PAR 18682 CCMS SFW 1055
	
	use40ftIds := tblMain.getValueByName(ETRow_Use40ftIds).Boolean;
	interchangePosition :=self.cmbSideICPos.getCurrentItemData();
	useSide := tblMain.getValueByName(ETRow_UseSideAccessRules).Boolean;	// PAR 21532 CCMS SFW 1025
	tmpBottomLbl:=tblMain.getValueByName(ETRow_BottomLabel).String;
	tmpTopLbl:=tblMain.getValueByName(ETRow_TopLabel).String;
	// 27198
	tmpMaxHeight := tblMain.getValueByName(ETRow_MaxHeight).String.asRealJMT;	// 36603 was .Real
	
	rtgLane			:= self.cmbLaneGroup.listObject.CM_RTGLane;
	if rtgLane	 &lt;&gt; null then
		if self.cmbNextArea.listIndex = -1 then
			laneIndex := self.cmbPrevArea.listIndex + 1;
		else
			laneIndex :=self.cmbNextArea.listIndex.Integer;
		endif;
	endif;
	
	self.setGraphicLayout(tmpColour);
	
	if proxyTA.myLayoutGraphic &lt;&gt; null then
		proxyTA.myLayoutGraphic.setProxyColour(tmpColour, White);
	endif;
	if self.mode = Mode_Add then
		proxyTA.setIsEmpty(true);
	endif;	
	
	proxyTA.allAssociatedInterchangeAreas.purge;

	proxyTA.setGridAreaProxy(tmpID, 
					tmpComment,
					tmpType,
					tmpRows,
					tmpCols,
					tmpHeight,
					tmpRel, 
					self.myTerminal,
					tmpAutoRestriction,
					tmpStockControlled,
					tmpHide,
					tmpDeckingStartType,
					false, false, snapLeft, goRight, snapStrict, null,null, use40ftIds, useSide,
					null,null,tmpTopLbl,tmpBottomLbl); //set labels
	proxyTA.setMaxHeight(tmpMaxHeight);

	self.createDeckingOptionsProxy(proxyTA);
	
	beginLoad;

	proxyTA.setProxyGantryICAreas(proxyTA,interchangePosition);
	
	if rtgLane &lt;&gt; null and laneIndex &gt; 0 then
		pxyRTGLane:=rtgLane.pxyCreateUpdateProxy;
		rtgLane.allTAsByTypeId.copy(pxyRTGLane.allTAsByTypeId);
		if self.myCurrentObject &lt;&gt; null and pxyRTGLane.allTAsByTypeId.includes(self.myCurrentObject.CM_RTGArea) then
			pxyRTGLane.allTAsByTypeId.remove(self.myCurrentObject.CM_RTGArea);
		endif;
		if  laneIndex &gt; pxyRTGLane.allTAsByTypeId.size then
			pxyRTGLane.allTAsByTypeId.add(proxyTA);
		else
			pxyRTGLane.allTAsByTypeId.insert(laneIndex,proxyTA);
		endif;
	endif;
	endLoad;
	
	self.setGridOffsets(proxyTA);

	return true;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTARTGLane" id="3c57c340-6f6a-4c9c-a295-a9bda4cb4d16">
        <source>setTARTGLane(_type :Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwer1	Initial creation

*/

vars
	proxyTA, lNewTA 				: CM_RTGLane;
	tmpComment,
	tmpID							: String;
	tmpType							: Integer;
	selectedTAs						: CM_TerminalAreaArray;
begin
	

	
	proxyTA := self.myProxyObject.CM_RTGLane;
	

	tmpID 					:= tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType 				:= _type;
	tmpComment				:= tblMain.getValueByName(ETRow_Comment).String;
	
	create selectedTAs transient;
	listsTermAreas.getSelected(selectedTAs);
	
	proxyTA.setProxy(tmpID, 
					_type,
					self.myTerminal,
					tmpID,
					tmpComment,
					selectedTAs);

epilog
	delete selectedTAs;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTARail" id="404710f4-e38d-454d-b2bc-39209aeaf7ac">
        <updating/>
        <source>setTARail() : Boolean updating, protected;
// 26/05/2010	cnwcs5	par 24292 - use array instead of set
vars

	proxyTA						:	CM_Rail;
	tmpRel,
	tmpDef,
	tmpCon,
	tmpWork,
	tmpStockControlled,
	tmpHide						:	Boolean;
	tmpType,
	tmpRows,
	tmpColour,
	tmpCols						:	Integer;
	tmpTypeString,
	tmpComment,
	tmpID,
	tmpInterchange,
	tmpRailTransfer				: String;
	interchangeArea				: CM_InterchangeArea;
	selectedInterchangeAreas 	: CM_InterchangeAreaArray;	// par 24292
	railTransferArea			: CM_YardTransferArea;		// 13/12/2010 cnwar2 #25956
	
begin
	if (not self.getProxyObject(CM_Rail)) then
		return false;
	endif;

	proxyTA 			:= self.myProxyObject.CM_Rail;

	tmpID 				:= tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpCon				:= tblMain.getValueByName(ETRow_ConfirmFromFarEnd).Boolean;
	tmpDef 				:= tblMain.getValueByName(ETRow_DefaultToOppositeView).Boolean;
	tmpWork 			:= tblMain.getValueByName(ETRow_WorkFromFarEnd).Boolean;
	tmpType 			:= TA_TYPE_RAILWAY_TRACK;
	tmpRows 			:= tblMain.getValueByName(ETRow_NumberOfRailLines).Integer;
	tmpCols 			:= tblMain.getValueByName(ETRow_NumberOfWagonPositions).Integer;
	tmpTypeString 		:= tblMain.getValueByName(ETRow_Type).String.trimBlanks;
	tmpRel  			:= tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpStockControlled 	:= tblMain.getValueByName(ETRow_StockControlled).Boolean;
	tmpColour 			:= tblMain.getValueByName(ETRow_Colour).Integer;
	tmpComment 			:= tblMain.getValueByName(ETRow_Comment).String;
	tmpHide				:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	tmpInterchange		:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea		:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;
	tmpRailTransfer		:= tblMain.getValueByName(ETRow_RailTransferArea).String;					// 13/12/2010 cnwar2 #25956
	railTransferArea	:= self.myTerminal.allTerminalAreas[tmpRailTransfer].CM_YardTransferArea;	// 13/12/2010 cnwar2 #25956
	
	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);

	if proxyTA.myLayoutGraphic &lt;&gt; null then
		proxyTA.myLayoutGraphic.setProxyColour(tmpColour, White);
	else
		// 24/06/2009 - added next line to make sure the colour gets saved 
		// to the proxy even for a  new TA
		self.setGraphicLayout(tmpColour);
	endif;
	proxyTA.setProxy(tmpID, tmpComment,
					tmpType, 
					tmpRows, 
					tmpCols, 
					tmpTypeString, 
					tmpCon, 
					tmpDef, 
					tmpWork,
					tmpRel, 
					self.myTerminal,
					tmpStockControlled,tmpHide,
					selectedInterchangeAreas,
					interchangeArea,
					railTransferArea);
	return true;

epilog
	delete selectedInterchangeAreas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTARoRoLaneArea" id="5e0f2e95-5cf5-4e85-b78b-66ffc492d861">
        <updating/>
        <source>setTARoRoLaneArea() : Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
20 November 2009	cnwjk3	Initial creation
26/05/2010			cnwcs5	par 24292 - use array instead of set
*/

vars
	pxyTA, ta		: CM_RoRoLaneArea;
	id 				: String;
	comment 		: String;
	numLanes 		: Integer;
	maxLaneLen 		: Decimal[6,2];
	standardGap 	: Decimal[4,2]; 
	leftLabel 		: String;
	rightLabel 		: String;
	laneId			: String;
	length			: Decimal[6,2];
	width			: Decimal[4,2];
	startOffset		: Decimal[4,2];
	interchange		: String;
	lane,dupLane			: CM_RoRoController;
	idCol,
	startCol,
	lengthCol,
	widthCol		: Integer;
	row				: Integer;
	releasePoint,
	hideOverview	: Boolean;
	interchangeArea	: CM_InterchangeArea;
	pDO: CM_YADeckingOptionsTA;
	selectedInterchangeAreas : CM_InterchangeAreaArray;	// par 24292
begin
	if (not self.getProxyObject(CM_RoRoLaneArea)) then
		return false;
	endif;

	if  not self.doUpdateNumLanes() then	// epr par 30461 23/10/12
		return false;
	endif;
	
	pxyTA 			:= self.myProxyObject.CM_RoRoLaneArea;
	id 				:= self.tblMain.getValueByName(ETRow_Id).String[1:13];
	comment 		:= tblMain.getValueByName(ETRow_Comment).String;
	numLanes 		:= tblMain.getValueByName(ETRow_LaneCount).Integer;
	maxLaneLen		:= tblMain.getValueByName(ETRow_MaxLaneLen).String.asDecimalJMT();
	standardGap 	:= tblMain.getValueByName(ETRow_StandardGap).String.asDecimalJMT();
	leftLabel 		:= tblMain.getValueByName(ETRow_LeftLabel).String;	
	rightLabel 		:=  tblMain.getValueByName(ETRow_RightLabel).String;	
	releasePoint	:= tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	hideOverview 	:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	interchange	:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea	:= self.myTerminal.allTerminalAreas[interchange].CM_InterchangeArea;

	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);
	
	pxyTA.setProxy(
		id,
		comment,
		maxLaneLen,
		standardGap,
		self.myTerminal,
		releasePoint,
		hideOverview,
		numLanes,
		leftLabel,
		rightLabel,
		selectedInterchangeAreas,
		interchangeArea);
		
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_Id, idCol);
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_Length, lengthCol);
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_Width, widthCol);
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_StartOffset, startCol);

	// Make sure lane ids are unique before we go any further
	if not self.validateRoRoLaneIds() then //cnwjo3 par 23873
		return false;
	endif;
	
	// Note that we don't need to update the direction members of each lane,as we keep the data in synch
	// withe the combobox values as they change (as this helps us when the terminal labels change and we have
	// to update the table cells).
	row := self.tblGateLanes.fixedRows+1;
	
	foreach lane in pxyTA.allLanesByLaneNumber do 
		
		laneId 		:= self.tblGateLanes.accessCell(row, idCol).text.trimBlanks();
		length 		:= self.tblGateLanes.accessCell(row, lengthCol).text.asDecimalJMT();
		width  		:= self.tblGateLanes.accessCell(row, widthCol).text.asDecimalJMT();
		startOffset	:= self.tblGateLanes.accessCell(row, startCol).text.asDecimalJMT();
		
		lane.setLength(length);
		lane.setWidth(width);
		lane.setStartOffset(startOffset);
		dupLane:=pxyTA.allLanesById[laneId];
		if dupLane &lt;&gt; null then
			dupLane.setLaneId("/" &amp;laneId);
		endif;
		lane.setLaneId(laneId);
	
		row := row + 1;
	endforeach;

	//epr par 37302 21/1/16
	if (not app.isValidObject(self.myPxyDeckingOptions)) then
		self.myPxyDeckingOptions := null;
	endif;

	delete self.myPxyDeckingOptions;
	create self.myPxyDeckingOptions transient;
	ta := pxyTA.pxyGetRealObject();
	if ta = null then
		ta := pxyTA;
	endif;
	self.myPxyDeckingOptions.setProxy(false, true, ta);
	self.myPxyDeckingOptions.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	return true;
epilog
	
	delete selectedInterchangeAreas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTAStraddle" id="1ac3a43c-be66-48e8-886f-e90b120c37fe">
        <updating/>
        <source>setTAStraddle() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010	cnwcs5		par 24292 - change IC area collection from set to array
// ---------------------------------------------------------------------------
vars

	proxyTA 				: CM_StraddleStack;
	 snapStrict					: Boolean;
	tmpComment,	tmpID,
	tmpBottomLbl,tmpTopLbl,tmpLeftLbl,tmpRightLbl : String;
	tmpRows, tmpCols, tmpHeight,
	tmpType,tmpColour 				: Integer;
	tmpRel	 						: Boolean;
	tmpAutoRestriction,
	tmpStockControlled,
	tmpHide, 
	useSide,
	use40ftIds: Boolean;
	tmpDeckingStartType				: Integer;
	noLeft, noRight, snapLeft, goRight : Boolean;
	tmpInterchange	: String;
	interchangeArea	: CM_InterchangeArea;
	selectedInterchangeAreas : CM_InterchangeAreaArray;	// par 24292
begin

	if (not self.getProxyObject(CM_StraddleStack)) then
		return false;
	endif;

	proxyTA := self.myProxyObject.CM_StraddleStack;
	
	tmpDeckingStartType := self.cmbRowDir.getCurrentItemData();
	tmpID := tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType := TA_TYPE_STRADDLE_STACK;
	tmpRows := tblMain.getValueByName(ETRow_Rows).Integer;
	tmpCols := tblMain.getValueByName(ETRow_Cols).Integer;
	tmpHeight := tblMain.getValueByName(ETRow_Height).Integer;
	tmpStockControlled := tblMain.getValueByName(ETRow_StockControlled).Boolean;
	tmpRel  := tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpColour := tblMain.getValueByName(ETRow_Colour).Integer;
	tmpComment := tblMain.getValueByName(ETRow_Comment).String;
	tmpHide:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	tmpAutoRestriction := tblMain.getValueByName(ETRow_AutoRestrictionsEnabled).Boolean;
	noLeft := tblMain.getValueByName(ETRow_NoAccessLeft).Boolean;
	noRight := tblMain.getValueByName(ETRow_NoAccessRight).Boolean;
	
	//20/06/2011 cnwdz2 27732
	tmpTopLbl:=tblMain.getValueByName(ETRow_TopLabel).String;
	tmpBottomLbl:=tblMain.getValueByName(ETRow_BottomLabel).String;
	tmpLeftLbl:=tblMain.getValueByName(ETRow_LeftLabel).String;
	tmpRightLbl:=tblMain.getValueByName(ETRow_RightLabel).String;
	
	snapLeft := tblMain.getValueByName(ETRow_IsSnapToBackend).Boolean; // PAR 18682 CCMS SFW 1055
	goRight := tblMain.getValueByName(ETRow_IsAlignRight).Boolean; // PAR 18682 CCMS SFW 1055
	snapStrict := tblMain.getValueByName(ETRow_IsSnapStrictGrid).Boolean; // PAR 18682 CCMS SFW 1055
	tmpInterchange	:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea	:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;
	useSide := tblMain.getValueByName(ETRow_UseSideAccessRules).Boolean;	// PAR 21532 CCMS SFW 1025
	use40ftIds := tblMain.getValueByName(ETRow_Use40ftIds).Boolean;
	
	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);
	
	self.setGraphicLayout(tmpColour);
	
	if proxyTA.myLayoutGraphic &lt;&gt; null then
		proxyTA.myLayoutGraphic.setProxyColour(tmpColour, White);
	endif;
	if self.mode = Mode_Add then
		proxyTA.setIsEmpty(true);
	endif;	
		
	proxyTA.setProxy(tmpID, 
					tmpComment,
					tmpType, 
					tmpRows, 
					tmpCols, 
					tmpHeight,
					tmpRel, 
					self.myTerminal,
					tmpAutoRestriction,
					tmpStockControlled,
					tmpHide,
					tmpDeckingStartType, noLeft, noRight, snapLeft, goRight,
					snapStrict,selectedInterchangeAreas, interchangeArea, useSide,use40ftIds,
					//20/06/2011 cnwdz2 27732
					tmpLeftLbl,tmpRightLbl,tmpTopLbl,tmpBottomLbl);
 
	
	self.createDeckingOptionsProxy(proxyTA);
	self.setGridOffsets(proxyTA);
	
	self.setTAGridLCsAssocICAreas();

	return true;

epilog

	delete selectedInterchangeAreas;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTATerminalTransfer" id="7a712395-55e1-4d63-ab20-84cd44abb888">
        <updating/>
        <source>setTATerminalTransfer() : Boolean protected, updating;
// -------------------------------------------
// Created 22 July 2004 by cnwdvb1
// -------------------------------------------
// 3/06/2010	cnwcs5	par 24292 - changed parameter type from set to array
vars

	taType 					: CM_TerminalAreaType;
	proxyTA					: CM_InterTerminalTransferArea;
	tmpId					: String;
	tmpType					: Integer;
	tmpHeight,tmpColour		: Integer;
	tmpTypeString			: String;
	tmpRel					: Boolean;
	tmpMax					: Integer;
	tmpRows					: Integer;
	tmpColumns				: Integer;
	tmpEnforceMaxCap		: Boolean;
	tmpComment,
	tmpID					: String;
	tmpAutoRestrict,
	tmpOverlapped,
	tmpStockControlled,
    tmpAutoPlanEnabled, 
    tmpHide					: Boolean;
    terminal				: CM_Terminal;
	tmpInterchange			: String;
	interchangeArea			: CM_InterchangeArea;
    selectedInterchangeAreas : CM_InterchangeAreaArray;	// par 24292
begin

	if (not self.getProxyObject(CM_InterTerminalTransferArea)) then
		return false;
	endif;
	
	taType := self.getTAStringToType(self.tblMain.getValueByName(ETRow_Type).String);
	proxyTA := self.myProxyObject.CM_InterTerminalTransferArea;

	tmpID 						:= self.tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType 					:= taType.type;
	tmpHeight 					:= 3;
	tmpTypeString 				:= self.tblMain.getValueByName(ETRow_Type).String.trimBlanks;
	tmpRel 						:= true;
	tmpMax 						:= self.tblMain.getValueByName(ETRow_MaxCapacity).Integer;
	tmpRows 					:= self.tblMain.getValueByName(ETRow_Rows).Integer;	//29 Aug 2011	NDL	Par 28076
	tmpColumns 					:= self.tblMain.getValueByName(ETRow_Cols).Integer;	//29 Aug 2011	NDL	Par 28076
	tmpEnforceMaxCap			:= self.tblMain.getValueByName(ETRow_EnforceMaxCapacity).Boolean;	//29 Aug 2011	NDL	Par 28076
	tmpStockControlled 			:= false;
	tmpOverlapped 				:= false;
	tmpHide						:= self.tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	tmpAutoRestrict 			:= false;
   	tmpAutoPlanEnabled 			:= false;
	tmpColour 					:= self.tblMain.getValueByName(ETRow_Colour).Integer;
	tmpComment					:= self.tblMain.getValueByName(ETRow_Comment).String;
	terminal					:= self.cmbTerminal.listObject.CM_Terminal;
	tmpInterchange				:= self.tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea				:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;
	
	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);
	
	if proxyTA.myLayoutGraphic &lt;&gt; null then
		proxyTA.myLayoutGraphic.setProxyColour(tmpColour, White);
	else
		// 24/06/2009 - added next line to make sure the colour gets saved 
		// to the proxy even for a  new TA
		self.setGraphicLayout(tmpColour);
	endif;
	
	proxyTA.setInterTerminalProxy(tmpID, 
					tmpComment,
					tmpType, 
					tmpHeight, 
					tmpRows,	//29 Aug 2011	NDL	Par 28076
					tmpColumns,	//29 Aug 2011	NDL	Par 28076
					tmpEnforceMaxCap,	//29 Aug 2011	NDL	Par 28076	
					tmpTypeString, 
					tmpMax,
					tmpRel,
					null, 
					self.myTerminal,
					tmpAutoRestrict,
					tmpAutoPlanEnabled,
					tmpStockControlled,
					tmpOverlapped,tmpHide,
					terminal,
					selectedInterchangeAreas,
					interchangeArea);
	return true;

epilog
	delete selectedInterchangeAreas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTAWorkPointInterchange" id="3c28a2eb-b7b4-43d9-ba18-e884d7e0f5cf">
        <updating/>
        <source>setTAWorkPointInterchange():Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	type 			: CM_TerminalAreaType;
	proxy			: CM_WorkPointInterchangeArea;
	tmpType			: Integer;
	tmpColour		: Integer;
	tmpRel			: Boolean;
	tmpComment,
	tmpID			: String;
    tmpHide			: Boolean;
	tmpLaneCount	: Integer;
	selectedTAs		: CM_TerminalAreaSet;
	workPoint 		: CM_WorkPoint;

begin
	if (not self.getProxyObject(CM_WorkPointInterchangeArea)) then
		return false;
	endif;
		
	type 	:= self.getTAStringToType(tblMain.getValueByName(ETRow_Type).String);
	proxy 	:= self.myProxyObject.CM_WorkPointInterchangeArea;

	tmpID 			:= tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType 		:= type.type;
	tmpRel 			:= tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpHide			:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	tmpColour		:= tblMain.getValueByName(ETRow_Colour).Integer;
	tmpComment		:= tblMain.getValueByName(ETRow_Comment).String;
	tmpLaneCount	:= tblMain.getValueByName(ETRow_LaneCount).Integer;
	workPoint		:= self.cmbWorkPoint.listObject.CM_WorkPoint;
	if proxy.myLayoutGraphic &lt;&gt; null then
		proxy.myLayoutGraphic.setProxyColour(tmpColour, White);
	else
		self.setGraphicLayout(tmpColour);
	endif;
	
	create selectedTAs transient;
	listsTermAreas.getSelected(selectedTAs);
	
	if self.mode = Mode_Add then
		proxy.setIsEmpty(true);
	endif;	
	
	proxy.setProxy(tmpID, tmpComment, self.myTerminal,workPoint,tmpRel, tmpHide,    selectedTAs,tmpLaneCount);
	
	self.setProxyGateLanes(proxy);
	
	return true;
	
epilog
	delete selectedTAs;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTAYardInterchangeArea" id="c2276465-47f7-4545-90ea-b8d6b546d94a">
        <updating/>
        <source>setTAYardInterchangeArea():Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config, par 20582
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/05/2010	cnwcs5		par 24292 - intechange area capacity
// 18/06/2010	cnwcs5		par 24418 - vehicle machine access rules
// ---------------------------------------------------------------------------
vars
	type 			: CM_TerminalAreaType;
	proxy			: CM_YardInterchangeArea;
	tmpType			: Integer;
	tmpColour		: Integer;
	tmpRel			: Boolean;
	tmpComment,
	tmpID			: String;
    tmpHide			: Boolean;
	tmpGateName		: String;
	tmpLaneCount	: Integer;
	defExitGate		: CM_Gate;
	selectedTAs		: CM_TerminalAreaSet;
	accessRule		: Integer;	// par 24418 cnwcs5 18/06/2010
begin

	if (not self.getProxyObject(CM_YardInterchangeArea)) then
		return false;
	endif;
	
	type 	:= self.getTAStringToType(tblMain.getValueByName(ETRow_Type).String);
	proxy 	:= self.myProxyObject.CM_YardInterchangeArea;

	tmpID 			:= tblMain.getValueByName(ETRow_IdInterchange).String[1:13];//cnwrd1 par 28100 6.12.2011
	//tmpID 			:= tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType 		:= type.type;
	tmpRel 			:= tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpHide			:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	tmpColour		:= tblMain.getValueByName(ETRow_Colour).Integer;
	tmpComment		:= tblMain.getValueByName(ETRow_Comment).String;
	tmpGateName		:= tblMain.getValueByName(ETRow_DefaultExitGate).String;
	tmpLaneCount	:= tblMain.getValueByName(ETRow_LaneCount).Integer;
	
	//epr par 32613 3/10/13
	if tblMain.getValueByName(ETRow_IsBufferZone).Boolean then
		tmpLaneCount:=0;
	endif;
	// par 24418 - vehicle/machine access rules
	if self.cmbVehicleAccess.listIndex &gt; 0 then
		accessRule  := self.cmbVehicleAccess.itemData [self.cmbVehicleAccess.listIndex]; 
	else
		accessRule	:= CM_InterchangeArea.Access_VehicleMachines;
	endif;
	//  par 24418 - end
	defExitGate		:= self.myTerminal.allGates[tmpGateName];
	
	if proxy.myLayoutGraphic &lt;&gt; null then
		proxy.myLayoutGraphic.setProxyColour(tmpColour, White);
	else
		self.setGraphicLayout(tmpColour);
	endif;
	
	create selectedTAs transient;
	listsTermAreas.getSelected(selectedTAs);
	
	if self.mode = Mode_Add then
		proxy.setIsEmpty(true);
	endif;	
	
	proxy.setProxy(tmpID, tmpComment, self.myTerminal, tmpRel, tmpHide, accessRule, defExitGate,  selectedTAs,tmpLaneCount);
	
	self.setProxyGateLanes(proxy);
		
	return true;
	
epilog
	delete selectedTAs;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTerminalsForTransfer" id="665fddef-c94e-42d2-8dd8-1fa094988a60">
        <source>setTerminalsForTransfer() protected;
// -------------------------------------------
// Created 22 July 2004 by cnwdvb1
// -------------------------------------------
vars

	myTerminal	: CM_Terminal;

begin
	
	myTerminal := app.myPassport.myTerminal;
	myTerminal.getOtherTerminals(self.allOtherTerminals);
	self.cmbTerminal.listCollection(self.allOtherTerminals, false, 0);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setToolbarButtons" id="81c22075-026c-4071-bbde-c9c3822ab6d6">
        <updating/>
        <source>setToolbarButtons(terminalArea: CM_TerminalAreaMaster; _enable : Boolean) updating;
// Set the toolbar buttons for the type of area being designed
/*

Date		Who		Reason
15/12/2008	cnwjk3	CCMS 1032 
19 Mar 2009	cnwkpd1	PAR #19194 - ensure Decking Button is disabled when editing,
					and completely hidden when not applicable

*/

vars
	taType					: CM_TerminalAreaType;
begin
	self.btnPenLabelCol40.visible:=false;
	
	// cnwjk3 CCMS 1032 15/12/2008
	if terminalArea = null then
		taType := self.cmbTAType.listObject.CM_TerminalAreaType;
		if taType &lt;&gt; null and taType.type = TA_TYPE_STRADDLE_STACK then		
			self.btnDoorFwd.visible := true;
			self.btnDoorAft.visible := true;
			self.btnDoorFwd.enabled := _enable;
			self.btnDoorAft.enabled := _enable;		
		endif;
	elseif terminalArea.isKindOf(CM_StraddleStack) or
		terminalArea.isKindOf(CM_RTGArea) or
		terminalArea.isKindOf(CM_GridArea)	then
		self.btnDoorFwd.visible := true;
		self.btnDoorAft.visible := true;
		self.btnDoorFwd.enabled := _enable;
		self.btnDoorAft.enabled := _enable;
		self.btnPenLabelCol40.visible:=terminalArea.CM_GridArea.use40ftIds;
		self.btnPenLabelCol40.enabled:=_enable;
	else
		self.btnDoorFwd.enabled :=false;
		self.btnDoorAft.enabled := false;
		self.btnDoorFwd.visible := false;
		self.btnDoorAft.visible := false;
		self.frmToolbarDesign.positionToolbarControls();
	endif;

	if terminalArea.isKindOf(CM_IrregularBlockArea) then
		self.btnBlockLabelsX.enabled := _enable;
		self.btnBlockLabelsY.enabled := _enable;
		self.btnBlockNew.enabled := _enable;
		self.btnBlockDelete.enabled := false;
		self.btnBlockEdit.enabled := false;
	else
		// cnwjk3 CCMS 1032 15/12/2008
		self.btnTwinLift.enabled := _enable;

		self.btnPenBuilding.visible := true;
		self.btnPenBuilding.enabled := _enable;
		self.btnPenClear.enabled := _enable;
		self.btnPenGap.visible := true;
		self.btnPenGap.enabled := _enable;
		self.btnPenLabelsRow.enabled := _enable;
		self.btnPenLabelsCol.enabled := _enable;
		self.btnPenLight.enabled := _enable;
		self.btnPenPower.enabled := _enable;
		self.btnPenReeferGant.enabled := _enable;
		self.btnPenUnavail.enabled := _enable;
		self.btnPen20.enabled := _enable; // PAR 18682
		self.btnPen30.enabled := _enable;
		self.btnPen45.enabled := _enable;
		self.btnPen40.enabled := _enable; // PAR 18682
		self.btnPen53.enabled := _enable;
		self.btnPenOHCol.enabled := _enable; // PAR 18682
	endif;
	
	
	//comented, making btnDeckingOptions always visible and available. Par 18954 Mar 2009.
	/*if terminalArea &lt;&gt; null and terminalArea.isDeckable then
		self.btnDeckingOption.visible := true;	
		self.btnDeckingOption.enabled := not _enable;		// PAR #19194
	else	
		self.btnDeckingOption.visible := false;	
		self.btnDeckingOption.enabled := false;	
	endif;*/
	
	self.btnPenInsert.enabled := _enable;
	self.btnPenDelete.enabled := _enable;
	self.frmToolbar.positionToolbarControls();
	
end;</source>
        <Parameter name="terminalArea" type="CM_TerminalAreaMaster"/>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupBtnPens" id="3844497c-b24a-440d-b283-0d8d7ad1a15f">
        <source>setupBtnPens() protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	atttDict	: CM_DrawingAttributesByCodeDict;
	drawAttr	: CM_DrawingAttribute;
	ls			: Boolean;
	
begin

	atttDict := self.frmMain.allDrawingAttributes;

	app.cmsBeginLoad(ls);	
	
	drawAttr := atttDict[PicTIUnavail];
	if drawAttr &lt;&gt; null then
		self.btnPenUnavail.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTIBuilding];
	if drawAttr &lt;&gt; null then
		self.btnPenBuilding.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTIGap];
	if drawAttr &lt;&gt; null then
		self.btnPenGap.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTILight];
	if drawAttr &lt;&gt; null then
		self.btnPenLight.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTIPower];
	if drawAttr &lt;&gt; null then
		self.btnPenPower.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTIReeferGantry];
	if drawAttr &lt;&gt; null then
		self.btnPenReeferGant.setFontFromDrawingAttr(drawAttr);
	endif;

epilog
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="072c0252-0cc4-4d55-92aa-713e807f0048">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//24 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
vars

begin
	
	inheritMethod();
	self.setMyTerminal(app.getMyTerminalDO_NOT_USE()); //+ cnwmd1, Par 20643
	
	self.tblGateLanes.tabKey := J_key_Tab;
	self.btnDoorAft.caption:="Door right";
	self.btnDoorAft.bubbleHelp:=self.btnDoorAft.caption;
	self.btnDoorFwd.caption:="Door left";
	self.btnDoorFwd.bubbleHelp:=self.btnDoorFwd.caption;
	
	self.setupBtnPens();
	self.sptDataFilter.setLeftToRightSizeAndResize(80); // PAR 9391
	
	self.frmAssocICArea.visible:=false;
	self.btnAssocIC.visible:=false;
	mnu4.visible := false;
	mnu5.visible := false;
	mnu6.visible := false;

	self.mnu1.visible := false;
	self.mnu2.visible := false;
	self.mnu3.visible := false;
	self.minimumHeight := 550;
	self.minimumWidth := 500;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showAreaRestrictions" id="611f1eef-97cb-44f8-a419-23c271009b9b">
        <source>showAreaRestrictions();
// ---------------------------------------------------------------------------
// Created:		12 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	theTerminalArea : CM_TerminalArea;
	aForm 			: CM_TableViewForm;
	menuAction 		: CMUI_MenuAction;
begin

	if self.myCurrentObject = null then
		return;
	endif;
	
	if self.myCurrentObject.isKindOf(CM_TerminalArea) then
		theTerminalArea := self.myCurrentObject.CM_TerminalArea;
		menuAction := app.myController.createMenuAction(PmAdmPadeditView, null, self.myMasterMenuAction, self.myTerminal);
		if menuAction = null then
			return;
		endif;
		
		aForm := menuAction.goToObject(null, null, false, null).CM_TableViewForm; 
		if aForm = null then
			return;
		endif;
	//	aForm.showWithObject(theTerminalArea,false,false);
		
		//aForm.sendMsgWithParams("doInitializeWithObject",theTerminalArea);
		//setInitializeWithObject(_anArea, _areaMode, _initObject, _flipH, _flipV);
		aForm.sendMsgWithParams("setInitializeWithObject",theTerminalArea, 1, null, null, null);
		aForm.show;	
	else			
		app.writeStatement(self.class.name &amp; "::" &amp; method.name &amp; " Do not handle " &amp; self.myCurrentObject.String &amp; ". See developer. ");
		return;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showDeckingOptionsForArea" id="aa750191-7897-4625-ac73-9aad33b7eb6c">
        <updating/>
        <source>showDeckingOptionsForArea(_termArea: CM_TerminalArea) updating;
//----------------------------------------------------------------
//	Created:	17 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxyDeckingOptions,
	deckingOptions		: CM_YADeckingOptions;
	returnVal			: Integer;
	applyUpToLevel		: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	
	deckingOptions := _termArea.myYADeckingOptions;
		
	if deckingOptions = null then
		return;
	endif;
	
//	startOption := DeckingRule_Null;

	pxyDeckingOptions := app.createUpdateProxy(deckingOptions).CM_YADeckingOptions;
	
	returnVal := self.myAssistant.showDeckingOptions(pxyDeckingOptions, DeckingRule_Null, true);
	if returnVal = IDCANCEL then
		delete pxyDeckingOptions;
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	if app.msgBox(app.getErrorString(ApplyDeckingToAll) &amp; CrLf &amp; 
					"("&amp; app.getErrorString(NoForTAOnly) &amp; ")", self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		applyUpToLevel := DeckingLevel_YA;
	else
		applyUpToLevel := DeckingLevel_TA;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxApplyDeckingRule(pxyDeckingOptions, applyUpToLevel, app.myPassport);	
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Set Decking Options', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;


epilog
	delete pxyDeckingOptions;
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="showGridFrameContextMenu" id="84b091a0-073f-473b-b74c-ee33b7528f02">
        <updating/>
        <source>showGridFrameContextMenu(x, y : Integer; _isColumn : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
	validate		: Integer;
	x1				: Real;
	y1				: Real;
	gridArea		: CM_GridArea;
	taType			: Integer;
begin
	if CM_GridArea.hasInstance(self.myCurrentObject) then
		gridArea := self.myCurrentObject.CM_GridArea;
	endif;


	validate := validateState();
	if validate = Return_Wrong_Mode then
		x1 := x;
		y1 := y;
		frmMain.windowToScreen(x1, y1);
		self.screenToWindow(x1, y1);   // convert x, y relative to form
		self.popupMenu(mnuNoEdit, x1.Integer, y1.Integer);
	else
		self.setContextMenu(Labels_Menu);
		x1 := x;
		y1 := y;
		frmMain.windowToScreen(x1, y1);
		self.screenToWindow(x1, y1);   // convert x, y relative to form
		self.popupMenu(mnuSetAttribute, x1.Integer, y1.Integer);
	endif;
epilog
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="_isColumn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showICAreaForm" id="cbf16760-4b17-4b09-b161-e63aff019b43">
        <source>showICAreaForm(_ta : CM_IrregularBlockArea);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2022	navhl20	ChangeRequest 53921: MTN - GC Area Terminal Area Defn Transfer Areas.

*/

vars
	frm 		  : SOP_TerminalAreaBulk;
	locationProxy :	CM_IrregularBlockController;
	blockArea	  : CM_IrregularBlockArea;
begin
	//app.mousePointer := MP_HOURGLASS;

	create frm;
	frm.setLocations(self.myProxyObject.CM_TerminalArea.allLocationsControllers);
	frm.myTerminal := self.myTerminal;
	
	frm.createMyAssistant(SOP_Assistant);
	
	if frm.showModal = IDOK then
		foreach locationProxy in frm.allSelectedAreas as CM_IrregularBlockController do
			blockArea := self.myProxyObject.CM_IrregularBlockArea;
			locationProxy.setProxy(	blockArea,
									locationProxy.ident,
									locationProxy.CM_IrregularBlockController.region,
									locationProxy.CM_IrregularBlockController.colour,	//_colour : Integer;
									locationProxy.CM_IrregularBlockController.defaultCapacity,	//_defaultCapacity : Integer;
									locationProxy.CM_IrregularBlockController.locationType,	//_locationProxyType : Integer;
									locationProxy.CM_IrregularBlockController.maximumWeight,	//_maximumWeight : Real;
									frm.cmbTerminalArea.listObject.CM_InterchangeArea	//_myICArea : CM_InterchangeArea
									);	
			self.frmBlkArea.myDrawingController.editLocation(locationProxy);
		endforeach;
	endif;

epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_ta" type="CM_IrregularBlockArea"/>
    </JadeMethod>
    <JadeMethod name="showLengthWarning" id="087f7ee6-470f-47a7-a0e1-bfc06d75a66f">
        <updating/>
        <source>showLengthWarning(_lenStr : String) updating;
// ---------------------------------------------------------------------------
// Created:     13 February 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
begin
	self.warningLen := _lenStr;
	
	tmpStr := self.lblStrictGrid.caption.replaceString("##", _lenStr);
	self.lblStrictGrid.caption := tmpStr;

	self.setToolbarButtons(null,false);
	
	if _lenStr = "30" then
		self.picStrictGrid.picture := self.picStrictGrid30.picture;
	elseif _lenStr = "20" then
		self.picStrictGrid.picture := self.picStrictGrid20.picture;
	elseif _lenStr = "40" then
		self.picStrictGrid.picture := self.picStrictGrid40.picture;
	elseif _lenStr = "45" then
		self.picStrictGrid.picture := self.picStrictGrid45.picture;
	elseif _lenStr = "53" then
		self.picStrictGrid.picture := self.picStrictGrid53.picture;
	endif;

	self.frmStrictGrid.visible := true;
	self.frmStrictGrid.zOrder(1);
	self.frmStrictGrid.centreWindow();

epilog

end;</source>
        <Parameter name="_lenStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="showReeferWalkPathForm" id="9ad142e5-54b1-4fec-abf9-e66a1f2fdaf2">
        <source>showReeferWalkPathForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	form : SOP_ReeferWalkPathForm;
	obj : Object;
	terminalArea : CM_TerminalArea;

begin

	obj := self.myCurrentObject;
	if obj &lt;&gt; null and obj.isKindOf( CM_TerminalArea ) then
		terminalArea := obj.CM_TerminalArea;
	endif;
	if terminalArea &lt;&gt; null then
		if not terminalArea.type.isOneOf( TA_TYPE_FORK_LIFT_STACK, TA_TYPE_RTG, TA_TYPE_STRADDLE_STACK ) then
			terminalArea := null;
		endif;
	endif;

	form := app.loadForm(SOP_ReeferWalkPathForm, CMUI_Assistant, false, false, true, self.myTerminal, null).SOP_ReeferWalkPathForm;
	form.setMyDefaultTerminalArea( terminalArea );
	form.showModal;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showTermAreaStorageGroups" id="8dfb03c0-7a7e-4d1a-96f2-5b233edb14d5">
        <source>showTermAreaStorageGroups() protected;

vars
