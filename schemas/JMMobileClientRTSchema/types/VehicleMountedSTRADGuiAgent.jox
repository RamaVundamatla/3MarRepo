    <JadeMethod name="enqTIsForCranePickup" id="6a56c570-1434-4396-8387-c3020f3d9f55">
        <source>enqTIsForCranePickup(	_form: VehicleMounted_STRADForm input; 
						_tiId,
						_twinTiID: String; 
						_errorMsgs:  DTO_HandHeldGateErrorDict input): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason


*/

vars

	packageDTO ,
	packageDTOTwin : MobileServerRTThin::DTO_EnquiryGradingTasks;
	rtnValue		: Boolean;
	ti,
	twinTI 			: CM_TrackedItem;
begin
	create packageDTO transient;
	if _twinTiID &lt;&gt; null then
		create packageDTOTwin transient;
	endif;
	
	rtnValue := self.myVehicleMountedSTRADAgent.enqTIsForCranePickup(_tiId,_twinTiID, 	ti,twinTI, _errorMsgs);


	if rtnValue then
		packageDTO.setFromTI(ti);
		_form.loadMoveTable (packageDTO,ti);
		if packageDTOTwin &lt;&gt; null then
			packageDTOTwin.setFromTI(twinTI);
			_form.loadMoveTable (packageDTOTwin,twinTI);
		endif;
	endif;

	return rtnValue;
epilog
	delete packageDTO;
	if packageDTOTwin &lt;&gt; null then
		delete packageDTOTwin;
	endif;
end;</source>
        <Parameter name="_form" type="VehicleMounted_STRADForm" usage="input"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_twinTiID" type="String"/>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTrackedItem" id="4443695c-d561-423d-b438-600c85816759">
        <source>findTrackedItem(_form: VehicleMounted_STRADForm input; 
					_tiId: String; 
					_errorMsgs:  DTO_HandHeldGateErrorDict input): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (CCMS 1671) DCT Gdansk

*/

vars

	packageDTO 		: MobileServerRTThin::DTO_EnquiryGradingTasks;
	rtnValue		: Boolean;
	ti 				: CM_TrackedItem;
begin
	create packageDTO transient;

	rtnValue := self.myVehicleMountedSTRADAgent.enqTrackedItem(_tiId, packageDTO, ti,_errorMsgs);

	if rtnValue then
		_form.loadMoveTable (packageDTO,ti);
	endif;

	return rtnValue;
epilog
	delete packageDTO;
end;</source>
        <Parameter name="_form" type="VehicleMounted_STRADForm" usage="input"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
