    <JadeMethod name="displayEntryErrorCode" id="929c8b47-636b-4f68-925c-7984ac1e1735">
        <source>displayEntryErrorCode(pObj : XLAT_Translation) : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2008	cnwrd1	Initial creation

*/
begin
	return self.myAssistant.displayEntryErrorWarning(pObj);
end;</source>
