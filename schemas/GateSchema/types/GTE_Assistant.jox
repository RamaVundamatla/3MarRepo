    <JadeMethod name="showEditReleaseReqBlockEDI" id="f7f9318b-9c17-4eb8-a273-4a53abda2652">
        <source>showEditReleaseReqBlockEDI(_allReleaseRequests :CM_BulkReleaseSet):Boolean;
/*
Date		Who		Reason
28 Nov 2011	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 - Empty Releases via COPARN
*/
vars
	form	: GTE_EditReleaseReqBlockEDIForm;
begin

	if _allReleaseRequests.isEmpty() then
		// Please select a Release request for this operation
		app.msgBox(	app.getString( NothingSelected, app.getString( Release_request ) ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return false;
	endif;
	
	form	:= app.loadForm(	GTE_EditReleaseReqBlockEDIForm,
								GTE_Assistant,
								false,							// Maximized
								false,							// Show
								true,							// Modal
								self.myTerminal,
								null ).GTE_EditReleaseReqBlockEDIForm;
	
	if form = null then
		// must of had a security issue.
		return false;
	endif;
	
	// set the collection and display the form
	form.setAllReleaseRequests( _allReleaseRequests );
	form.showModal();
	
	return form.modalResult = IDOK;
	
epilog
	
end;
</source>
        <Parameter name="_allReleaseRequests" type="CM_BulkReleaseSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showEditReleaseReqStatus" id="0c9a84d9-8440-43da-9b6c-ef3ce1b2f43a">
        <source>showEditReleaseReqStatus( _allReleaseRequests : CM_BulkReleaseSet ) : Boolean;

/*
Purpose:		Show the GTE_EditReleaseReqStatusForm form in modal mode.
Parameters:		The collection is all selected ReleaseRequests.
Return Value:	True if the modal form has done some updating OK.

Date				Who		Reason
24 July 2009		cnwrl1	Initial creation as part of CCMS 1827 - PAR 20349 - Archive Empty Release Requests
*/
	
vars
	form		: GTE_EditReleaseReqStatusForm;
	
begin
	if _allReleaseRequests.isEmpty() then
		// Please select a Release request for this operation
		app.msgBox(	app.getString( NothingSelected, app.getString( Release_request ) ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return false;
	endif;
	
	form	:= app.loadForm(	GTE_EditReleaseReqStatusForm,
								GTE_Assistant,
								false,							// Maximized
								false,							// Show
								true,							// Modal
								self.myTerminal,
								null ).GTE_EditReleaseReqStatusForm;
	
	if form = null then
		// must of had a security issue.
		return false;
	endif;
	
	// set the collection and display the form
	form.setAllReleaseRequests( _allReleaseRequests );
	form.showModal();
	
	return form.modalResult = IDOK;
	
epilog
	
end;
</source>
        <Parameter name="_allReleaseRequests" type="CM_BulkReleaseSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
