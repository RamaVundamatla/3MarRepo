    <JadeMethod name="loadStopTables" id="fb75c7f4-f2b5-49d6-8b13-df437cb3be56">
        <source>loadStopTables() protected;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 Oct 2022	navhl20		TFS 53862	EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------

vars
	aRole : CM_SecurityRole;
	aStopTable : CM_StopsTable;
	theCargoTypes : CM_CargoTypeSet;
	aTIType :	CM_CargoType;
	theRoot : CM_Root;
begin	
	theRoot := CM_Root.firstInstance;
	
	theRoot.allStopsTable.purge;
	// Give all the different types to all the stops
	create theCargoTypes transient;
	foreach aTIType  in theRoot.allCargoTypesById do
		theCargoTypes.add(aTIType);
	endforeach;
	
	beginTransaction;

	// ##########################
	if theRoot.allStopsTable[TI_Stop_Customs] = null then
		create aStopTable;
		aStopTable.id := TI_Stop_Customs;
		// Give all the different types to all the stops
		//theCargoTypes.copy(aStopTable.allCargoTypesNew);	//25.10.2022	navhl20	TFS 53862
		aStopTable.code := "C";
//		aStop.defaultImportStop := false;
		aStopTable.heading := "Customs";
		aStopTable.shortHeading := "CUST";
//		aStop.canIYardMove := true;
//		aStop.canIDeliveryRequest := true;
//		aStop.canIReleaseRequest := true;
		aStopTable.myRoot := theRoot;
	endif;		
	// ##########################
	if theRoot.allStopsTable[TI_Stop_CustomsDocs] = null then
		create aStopTable;
		aStopTable.id := TI_Stop_CustomsDocs;
		// Give all the different types to all the stops
		//theCargoTypes.copy(aStopTable.allCargoTypesNew);	//25.10.2022	navhl20	TFS 53862
		aStopTable.code := "D";
//		aStop.defaultImportStop := true;
		aStopTable.heading := "Customs Docs";
		aStopTable.shortHeading := "CUSTDOC";
//		aStop.canIYardMove := true;
//		aStop.canIDeliveryRequest := true;
//		aStop.canIReleaseRequest := true;
		aStopTable.myRoot := theRoot;
	endif;	
	// ##########################

	if theRoot.allStopsTable[TI_Stop_MAF] = null then
		create aStopTable;
		aStopTable.id := TI_Stop_MAF;
		// Give all the different types to all the stops
		//theCargoTypes.copy(aStopTable.allCargoTypesNew);	//25.10.2022	navhl20	TFS 53862
