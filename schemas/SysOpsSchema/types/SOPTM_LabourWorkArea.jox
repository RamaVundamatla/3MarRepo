    <JadeMethod name="getSelectedLabourWorkArea" id="8a1b4926-03f8-4b36-812c-ce29e038e14b">
        <source>getSelectedLabourWorkArea():CM_LabourWorkArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation

*/

vars

	theForm : SOP_TableMaintForm;
	obj : Object;
	labourWorkArea : CM_LabourWorkArea;

begin

	theForm := self.myForm;

	if not theForm.tblData.allSelectedObjects.isEmpty then
		obj := theForm.tblData.allSelectedObjects.first;
	endif;
	if obj &lt;&gt; null and obj.isKindOf( CM_LabourWorkArea ) then
		labourWorkArea := obj.CM_LabourWorkArea;
	endif;
	
	return labourWorkArea;

epilog

end;</source>
        <ReturnType type="CM_LabourWorkArea"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="3c633381-7ad5-4abf-a860-5c67562d42ec">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgrh7	Initial creation Ticket 39091: Voyage Planning Codes do not show in terminal Admin (Labour Area Table not working in this scenario either)
*/

vars

begin
	if self.includeNotAvailableEntries  then
		return true;
	else
		return not  _obj.CM_LabourWorkArea.notAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
