    <JadeMethod name="getAdjustedLeft" id="63acb9c8-9d65-4e4c-82d9-878ff4142380">
        <source>getAdjustedLeft() : Real;
/*

Purpose:		cope with rotation	

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2009	cnwer1	Initial creation

*/

vars
	machWorkzone : CMIF_MachineWorkzone;
begin
	
	if 	self.userObject.isKindOf(CMIF_MachineWorkzone) then
		machWorkzone:=self.userObject.CMIF_MachineWorkzone;
		if machWorkzone.rotated90 then
			return self.top;
		else
			return self.left;
		endif;
	endif;
	
	return self.left;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAdjustedOrigLeft" id="1c13e241-77c7-4f7a-8916-af7d7a385574">
        <source>getAdjustedOrigLeft() : Real;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2009	cnwer1	Initial creation

*/

vars
	machWorkzone : CMIF_MachineWorkzone;
begin
	
	if 	self.userObject.isKindOf(CMIF_MachineWorkzone) then
		machWorkzone:=self.userObject.CMIF_MachineWorkzone;
		if machWorkzone.rotated90 then
			return self.origTop;
		else
			return self.origLeft;
		endif;
	endif;
	
	return self.origLeft;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAdjustedOrigWidth" id="6ea23ebd-8caa-4bfe-8a49-df827276c6b2">
