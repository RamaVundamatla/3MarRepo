    <JadeMethod name="setMachineStatus" id="681fd842-3cdc-4088-b1d8-e05fea68a096">
        <updating/>
        <source>setMachineStatus(newStatus : Integer; availCode: String; _fromLogOn	: Boolean) updating;
//Sets the machines current status. This is now an object
//If fromQWindow is set, then no reason code is required.
//reference.
vars
	aStatus : CM_MachineStatus;
begin
	//-------------
	//If NO R/T, then quit.
	//-------------
	if not self.hasRadioTelemetry then
		//-------------
		//If NO R/T, then quit.
		//-------------
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_MACH_NO_RT, id, null, null);
		return;
	endif;
	if self.myPrimaryQueue = null and newStatus &lt;&gt; STATUS_OFFLINE then
		//----------
		//No Queue!
		//----------
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_MACH_NO_QUEUE, self.id, null, null);
		return;
	endif;
	//---------------
	//Devolve work to the machineStatus object.
	//---------------
	if self.status = null then
		create aStatus;	//Create it.
		self.status := aStatus;		// sets machine on status object
	endif;
	status.set(newStatus, availCode, _fromLogOn);
	if newStatus = STATUS_OFFLINE then
		// CCMS 1310
		self.myLastTA := null;
		self.setLoggedOn(false);
	endif;
	//epr par 22748 16/3/10
	if newStatus = STATUS_RESTORE and self.status &lt;&gt; null then
		if self.status.status &lt;&gt; STATUS_OFFLINE then
			self.setLoggedOn(true);
		endif;
	endif;
	
	//epr CCMS 1391 -refactored was being done everywhere after settng machine status to idle
	if newStatus = STATUS_IDLE then
		self.workingInQueue:=null;//Clear out the working queue.
	endif;
	
	if self.myTerminal &lt;&gt; null then
		if 	newStatus = STATUS_RESTORE or newStatus = STATUS_OFFLINE or _fromLogOn then
			self.causeEvent(self.myTerminal.getTerminalEvent(RTMachine_Update_Event), false, null);
		endif;
	endif;
end;</source>
        <Parameter name="newStatus" type="Integer"/>
        <Parameter name="availCode" type="String"/>
        <Parameter name="_fromLogOn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyLastKnowLocation" id="7f9449ed-53dd-4b13-9545-61bf1f6cf223">
        <updating/>
        <source>setMyLastKnowLocation( _value : CM_LocationsController) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwer1	Initial creation

