    <JadeMethod name="setProductCode" id="115a1d9f-8d9d-4a71-8217-80be58a7101e">
        <updating/>
        <source>setProductCode() updating;
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	treatmentCode, typeCode, typeLength : String;
begin

	if self.cmbSpecies.listObject = null then
		return;
	endif;
	if self.cmbTreatment.listObject &lt;&gt; null then
		treatmentCode := self.cmbTreatment.listObject.CM_LogTreatment.code;
	endif;
	if self.cmbType.listObject &lt;&gt; null then
		typeCode := self.cmbType.listObject.CM_LogType.code;
	endif;
	if self.cmbLength.listObject &lt;&gt; null then
		typeLength  := self.cmbLength.listObject.CM_LogLength.code;
	endif;
	self.productCode := app.buildLogProductCode(self.cmbSpecies.listObject.CM_LogSpecies.code, 
												  	   self.cmbGrade.listObject.CM_LogGrade.code, 
												  	   typeCode,
												  	   treatmentCode,
												  	   typeLength );

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="919dfa97-dab6-42d4-8207-d6a544a84111">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveBase.enabled:= false;
		self.tblNewSpecs.userInputEnabled := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showSOHLocationsAssigned" id="a53a23cc-c7c2-4452-9c64-d5c2b5d5d4d6">
        <updating/>
        <source>showSOHLocationsAssigned()updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	sohLocn : CM_SOHLocation;
	str : String;
	idx,
	backColour : Integer;
	loadStateSet : Boolean;
begin
	app.cmsBeginLoad(loadStateSet);
	self.mode := Mode_Detail;
	self.tblDetails.rows := self.tblDetails.fixedRows;
	self.tblDetails.resortTableByColumn(0);
		
	foreach sohLocn in self.allSOHLocationsLoadedForLot do
		sharedLock(sohLocn);
		if self.tblDetails.rows mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;
		str := self.tableDisplayRow(tblDetails, sohLocn);			
		idx := tblDetails.addItem(str);
		tblDetails.accessRow(idx).itemObject := sohLocn;
		tblDetails.accessedRow.backColor := backColour;		
	endforeach;
	
	if tblDetails.rows &gt; tblDetails.fixedRows then
		tblDetails.row := tblDetails.fixedRows + 1;
		tblDetails.accessRow(tblDetails.row).selected := true;
	endif;
	tblDetails.accessColumn(tblDetails.getColumnByRowName(ETRow_Hatch)).visible := true;
	tblDetails.accessColumn(tblDetails.getColumnByRowName(ETRow_Place)).visible := true;		
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
    <JadeMethod name="showSummaries" id="fc20cb2f-9a61-44e3-8851-0e114ccede60">
        <updating/>
        <source>showSummaries()updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	loadStateSet	: Boolean;
	str				: String;
	theProduct		: CM_Product;
	volume 			: Decimal[16,4];
	idx,
	colPieces, colVol,
	pieces,	backColour 	: Integer;
	sohLocn, sohLocn2 	: CM_SOHLocation;	
begin
	app.cmsBeginLoad(loadStateSet);
	self.mode := Mode_Summary;
	self.tblDetails.rows := self.tblDetails.fixedRows;
	colPieces := tblDetails.getColumnByRowName(ETRow_NumTIs);
	colVol := tblDetails.getColumnByRowName(ETRow_CurrentVolume);
	self.tblDetails.resortTableByColumn(0);
	self.allSOHLocnsLoadedByProduct.clear();
	foreach sohLocn in self.allSOHLocationsLoadedForLot do
		sharedLock(sohLocn);	
		if (not self.allSOHLocnsLoadedByProduct.includesKey(sohLocn.myProduct)) then
			self.allSOHLocnsLoadedByProduct.add(sohLocn);
		endif;
	endforeach;	

	foreach sohLocn in self.allSOHLocnsLoadedByProduct do
		sharedLock(sohLocn);
		theProduct := sohLocn.myProduct;
		pieces := 0;
		volume := 0;
		str := self.tableDisplayRow(tblDetails, sohLocn);			
		idx := tblDetails.addItem(str);	
		foreach sohLocn2 in self.allSOHLocationsLoadedForLot do
			if sohLocn2.myProduct &lt;&gt; theProduct then
				continue;
			else
				pieces := pieces + sohLocn2.numTIs;
				volume := volume + sohLocn2.currentVolume;
			endif;
		endforeach;						
		if self.tblDetails.rows mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;
		tblDetails.accessRow(idx).itemObject := sohLocn;
		tblDetails.accessedRow.backColor := backColour;	
		tblDetails.accessCell(idx, colPieces).text := pieces.String;
		tblDetails.accessCell(idx, colVol).text := volume.jasVolumeString;				
	endforeach;	

	if tblDetails.rows &gt; tblDetails.fixedRows then
		tblDetails.row := tblDetails.fixedRows + 1;
		tblDetails.accessRow(tblDetails.row).selected := true;
	endif;
	tblDetails.accessColumn(tblDetails.getColumnByRowName(ETRow_Hatch)).visible := false;
	tblDetails.accessColumn(tblDetails.getColumnByRowName(ETRow_Place)).visible := false;
		
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
    <JadeMethod name="tableDisplayRow" id="3fec0685-6209-4cc2-b8cc-d4534546e42e">
        <source>tableDisplayRow(_table : CM_DataTable input; _obj : CM_Object) : String;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return _obj.getAttributeStringForDefArray(_table.allTblDataEntRows);
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblDetails_click" id="08dad16d-0bb5-4113-bdc9-9f24369fd716">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDetails_click(table: Table input) updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	app.mousePointer := MousePointer_HourGlass;

	if table.row &lt;= table.fixedRows then
		return;
	endif;
	self.setMyCurrentSOHLocation();
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDetails_contextMenu" id="03863750-22d9-47c8-be5d-c085ec994e6d">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDetails_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------------------
//Created: 17 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	x1 : Real;
	y1 : Real;

begin
	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 1 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form

	self.popupMenu(mnuTblLocations, x1.Integer, y1.Integer);
	return false;                  // cancel further processing
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
