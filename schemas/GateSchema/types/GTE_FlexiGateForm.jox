        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldrDetails_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2016	cnwndl1	Initial creation	TFS 2473

*/

vars

begin

	if newSheet = self.shtTransfers then // yep it is transfers sheet, even tho the table is releases...
		self.beginTimer(100,Timer_OneShot,2473);
