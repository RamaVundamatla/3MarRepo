end;</source>
        <Parameter name="pCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="handleMultiMoveValidation" id="de197ffe-27a9-4419-ba9e-13ac9cdec5b3">
        <source>handleMultiMoveValidation(	_exc : Exception;
							_excHandlerIsMoveValidate : Boolean output;
							_excHandlerMess : String output;
							_isWarningOnly : Boolean output
							):Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2011	cnwndl1	Initial creation	Par 28035
Should only be used in teh multi move scenario, to ignore Yard Allocation warnings...

*/

vars

	returnVal : Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if not _exc.isJadeException then
	
		returnVal := Ex_Resume_Next;
		
		if _exc.errorCode = WARN_TI_NOTMATCH_ALLOCATION_AT then // error 82959
			// this is just a yard allocation warning, and we simply don't want to know.
			returnVal := Ex_Continue;

		else
			_excHandlerIsMoveValidate := true;
			_excHandlerMess := _exc.extendedErrorText;
			
			if _exc.isKindOf(CM_Exception) then
				_isWarningOnly := _exc.CM_Exception.isWarning;
				if _isWarningOnly then
					returnVal := Ex_Continue;
				endif;
			endif;
			
		endif;
		
		
	endif;
	
	return returnVal;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_excHandlerIsMoveValidate" type="Boolean" usage="output"/>
        <Parameter name="_excHandlerMess" type="String" usage="output"/>
        <Parameter name="_isWarningOnly" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handlePowerRequirements" id="8937b5ec-9c80-4117-8189-b911eead0e69">
        <source>handlePowerRequirements(pPowerReq : String; pNeedCOU, pNeedGenerator : Boolean io);
// ---------------------------------------------------------------------------
// Created:     27 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin


	if pPowerReq = POWER_COU then
		pNeedCOU := true;
		pNeedGenerator := false;
	elseif pPowerReq = POWER_GEN then
		pNeedCOU := false;
		pNeedGenerator := true;
	elseif pPowerReq = POWER_BOTH then
		pNeedCOU := true;
		pNeedGenerator := true;
	else
		pNeedCOU := false;
		pNeedGenerator := false;
	endif;

end;</source>
        <Parameter name="pPowerReq" type="String"/>
        <Parameter name="pNeedCOU" type="Boolean" usage="io"/>
        <Parameter name="pNeedGenerator" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleTicketSequences" id="1d1239b9-23bc-4b22-b15b-785475f5f50a">
        <updating/>
        <source>handleTicketSequences(_cargoBOLId : Integer; _tblMain, _tblExtra : CM_EntryTable input; 
					  _seqs : CM_TicketSequenceSet input; _displayStr : String output) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ticketSeq	: CM_TicketSequence;
	ticketRules : CMUI_TicketSeqRules;
	//existing,
	cnt			 : Integer;

begin

	app.setContinueCMExceptions(false);	
	
	create ticketRules transient;
	ticketRules.jasScaled 			:= self.mainExtraGetValue(_tblMain, _tblExtra, ETRow_JasScaled).Boolean;
	ticketRules.ticketedAll 		:= self.mainExtraGetValue(_tblMain, _tblExtra, ETRow_TicketedAll).Boolean;
	ticketRules.percentageScaled 	:= self.mainExtraGetValue(_tblMain, _tblExtra, ETRow_PercentScaled).Integer;
	ticketRules.numberOfTickets 	:= self.mainExtraGetValue(_tblMain, _tblExtra, ETRow_NumItems).Integer;

	if ticketRules.numberOfTickets &lt;= 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Piece Count', ETRow_NumItems, null);
		app.raiseCMException(Input_required_field_peceCount, ETRow_NumItems, null); // cnwdb2	PAR 35364
	endif;

	_seqs.copy(ticketRules.allTicketSequences);
	
	/*This was preventing updates to the sequence numbers
	and is validated on the BOL extension was docket saved
	existing := ticketRules.calculateExisting();
	if existing &gt; ticketRules.numberOfTickets then
		app.raiseCMException4(ERR_IMBALANCE, 'Docket', ticketRules.numberOfTickets.String,
							 'Ticket Sequences', 'of ' &amp; existing.String, ETRow_NumItems, null);
	endif;*/

	self.inputTicketSequence(ticketRules);
	
	_seqs.clear();
	ticketRules.allTicketSequences.copy(_seqs);

	foreach ticketSeq in _seqs do
		if cnt &gt;= 1 then
			_displayStr := _displayStr &amp; ' plus...';
			break;
		endif;
		_displayStr := ticketSeq.fromId &amp; ' to ' &amp; ticketSeq.toId;
		cnt := cnt + 1;
	endforeach;

//	pTable.setValueByName(ETRow_TicketSequence, _displayStr &amp; '--Dbl click to Add/Update--');		

epilog
	delete ticketRules;
end;</source>
        <Parameter name="_cargoBOLId" type="Integer"/>
        <Parameter name="_tblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="_tblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="_seqs" type="CM_TicketSequenceSet" usage="input"/>
        <Parameter name="_displayStr" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="hazardlistTableLostFocus" id="35df4ce6-6706-4407-9be5-981c1d145982">
        <source>hazardlistTableLostFocus(_table : CM_EntryTable input; _saveHeight : Real io; _hazTable : CMUI_HazardsListTable);
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	theRow,
	idx		: Integer;
	str		: String;
	tbl		: CM_EntryTable;
	obj		: Object;
	hazList	: CMUI_HazardsListTable;
	entRowTrans : EntTableRowTransient;
begin
	tbl		:= _table;
	hazList	:= _hazTable;
	theRow := _table.getRowByControlName(hazList.name);

	if (theRow &gt; tbl.fixedRows) and (theRow &lt;= tbl.rows) then
		tbl.accessRow(theRow).height := _saveHeight.Integer;
		hazList.height := _saveHeight.Integer;
		_saveHeight := 0;		// set to 0 so that can use in pTable.cellInputReady;
		tbl.scrollBars := Table.ScrollBars_Both;
		
		foreach obj in hazList.allSelectedObjects do
			if str &lt;&gt; null then
				str := str &amp; '; ';
			endif;
			
			str := str &amp; obj.CM_TIHazard.getTableDisplay(false, true);
		endforeach;
		
		obj := tbl.accessRow(theRow).itemObject; //+ Par 25529
		entRowTrans := obj.EntTableRowTransient;
		if entRowTrans.originalValue &lt;&gt; str then
			entRowTrans.hasChanged := true;
		endif;
		
		tbl.setValue(theRow, str);
		tbl.doChangedComparison(theRow);//added by cnwyl1 for par 13017
	endif;
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_saveHeight" type="Real" usage="io"/>
        <Parameter name="_hazTable" type="CMUI_HazardsListTable"/>
    </JadeMethod>
    <JadeMethod name="inputAttachments" id="1be5e1eb-c1f1-4e68-8ffb-5e98a64fefb6">
        <source>inputAttachments(_allAttachments : CMIF_InOutAttachmentArray; 
				_table : CM_EntryTable input; 
				_addAttachRow : Integer; 
				_cargoType : Integer;
				_operator : CM_Operator);
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
	tmpRow				: Integer;
	attachFrm			: CMUI_Attachments;
	intFaceAttach		: CMIF_InOutAttachment;
	tmpAttachments		: CMIF_InOutAttachmentArray;
	
begin

	tmpAttachments := _allAttachments;

	if _table.row &gt; _addAttachRow then
		// user has selected a row with an existing attachment so ...
		tmpRow := _table.row - _addAttachRow;
		if tmpRow &lt;= tmpAttachments.size then
			intFaceAttach := tmpAttachments[tmpRow];
		endif;
	endif;
	
	//attachFrm := app.loadForm(CMUI_Attachments, self.class, false, false, false, self.myTerminal, null).CMUI_Attachments;
	create attachFrm transient;
	
	//create attachFrm transient;
	if attachFrm = null then
		return;
	endif;
	
	if _operator &lt;&gt; null then
		attachFrm.myOperator := _operator;
	endif;	
	attachFrm.centreWindow;
	attachFrm.setItem(tmpAttachments, intFaceAttach);
	
	attachFrm.initForm(_cargoType, self.myTerminal);
	
	if attachFrm.showModal &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	// clear any existing attachment(s)
	tmpAttachments.purge;
	attachFrm.allAttachments.copy(tmpAttachments);
	
	if _cargoType = BOLType_Log then
		_table.setValueByName('addLogs', tmpAttachments.size.String &amp; ' ' &amp; 'added. --Dbl click to Add/Update--');
		_table.setValueByName('ticketSequence', ' ' &amp; '--Dbl click to Add/Update--');
//		self.setLogs(tmpAttachments, pTable, pAddAttachRow);		
	else
		self.showAttachments(tmpAttachments, _table, _addAttachRow);
	endif;

epilog
	if attachFrm &lt;&gt; null then
		delete attachFrm;
	endif;
	
end;</source>
        <Parameter name="_allAttachments" type="CMIF_InOutAttachmentArray"/>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_addAttachRow" type="Integer"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="inputBreakBulkAttachments" id="5f97fe95-511d-4f4a-976d-95b8fd792995">
        <source>inputBreakBulkAttachments(_allAttachments : CMIF_InOutAttachmentArray input; 
				_table : CM_EntryTable input; 
				_addAttachRow : Integer;
				_bookingRef	: CM_BookingRef;
				_bookingRefItem	: CM_BookingRefItem;
				_cargoType : Integer;
				_operator : CM_Operator;
				_voyage : CM_Voyage;
				_isFromGTEShpPreNote : Boolean;
				_forExport : Boolean;
				_taType	: CM_TerminalAreaType;
				_terminalArea : CM_TerminalArea;
				_bol : String; _destPort : CM_Port; _disPort : CM_Port; _imex : Integer; _conr : CM_ConsigneeConsignor; _cone : CM_ConsigneeConsignor; _comm : CM_Commodity);
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     _voyage and _isFromGTEShpPreNote added 01/2006 to handle diffeences
//			 	need when creating General Cargo on a ship 
// ----------   ----------  --------------------------------------------------
vars
	tmpRow				: Integer;
	attachFrm			: CMUI_AttachBreakBulkModal;
	intFaceAttach		: CMIF_InOutAttachment;
	brItem 				: CM_BookingRefItem;
begin
	if _table &lt;&gt; null then
		if _table.row &gt; _addAttachRow then
			// user has selected a row with an existing attachment so ...
			tmpRow := _table.row - _addAttachRow;
			
			if tmpRow &lt;= _allAttachments.size then
				intFaceAttach := _allAttachments[tmpRow];
			endif;
		endif;
	endif;		
	
	attachFrm	:=	app.loadForm(	CMUI_AttachBreakBulkModal,
									self.class,
									false,
									false,
									false,
									self.myTerminal, null).CMUI_AttachBreakBulkModal;
	
	//create attachFrm transient;
	if attachFrm = null then
		return;
	endif;
	
	// cnwsb1 14 May 2003 - CM_BaseForm::showModal() now sets isModal:
	// attachFrm.isModal := true;
	//We may have already loaded from xml settings the terminal area we want. PAR14111
	if attachFrm.aTerminalAreaType = null then
		attachFrm.aTerminalAreaType	:=	_taType.type;
	endif;
	attachFrm.aMyTerminalArea	:=	_terminalArea;
	attachFrm.aMyCargoType		:=	app.myRoot.allCargoTypesById[_cargoType];
	
	if _bookingRef &lt;&gt; null then
		attachFrm.aMyBookingRef := _bookingRef;
		if _bookingRefItem &lt;&gt; null then
			brItem := _bookingRefItem;
		elseif _bookingRef.allBookingRefItems.size = 1 then
			brItem := _bookingRef.allBookingRefItems.first;
		endif;
		if brItem &lt;&gt; null then
			attachFrm.aMyBookRefItem := brItem;
			if brItem.cargoType &lt;&gt; null then
				attachFrm.aMyCargoType		:=	app.myRoot.allCargoTypesById[brItem.cargoType];
			endif;
		
		endif;
	endif;
	
	attachFrm.aMyOperator		:=	_operator;
	attachFrm.aIsForCreation	:=	_forExport;
	attachFrm.aNumberOfItems	:=	_table.getValueByName(ETRow_NumItems).Integer;
	attachFrm.centreWindow;
	attachFrm.setItem(_allAttachments, intFaceAttach);
	attachFrm.mdiFrame			:=	true;
	attachFrm.aMyVoyage			:= _voyage;
	attachFrm.isFromShipPreNote := _isFromGTEShpPreNote;
	
	attachFrm.bolNumber := _bol;
	attachFrm.myDestinationPort := _destPort;
	attachFrm.myDischargePort := _disPort;
	attachFrm.imexStatus := _imex;
	attachFrm.myConsignee := _cone;
	attachFrm.myCommodity := _comm;
	attachFrm.myConsignor := _conr;
	
	if attachFrm.showModal &lt;&gt; MsgBox_Return_OK then
		return;
	endif;

	// clear any existing attachment(s)
	_allAttachments.clear();
	attachFrm.aAllAttachments.copy(_allAttachments);

	if _table &lt;&gt; null then 
		if attachFrm.aIsItemsIncreased then
			_table.setValueByName(ETRow_NumItems, attachFrm.aNumberOfItems);
		endif;
		self.showAttachments(_allAttachments, _table, _addAttachRow);
	endif;	
epilog
	delete attachFrm;
end;</source>
        <Parameter name="_allAttachments" type="CMIF_InOutAttachmentArray" usage="input"/>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_addAttachRow" type="Integer"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_isFromGTEShpPreNote" type="Boolean"/>
        <Parameter name="_forExport" type="Boolean"/>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_destPort" type="CM_Port"/>
        <Parameter name="_disPort" type="CM_Port"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_conr" type="CM_ConsigneeConsignor"/>
        <Parameter name="_cone" type="CM_ConsigneeConsignor"/>
        <Parameter name="_comm" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="inputMoveToData" id="a2434ccf-bfcf-4aac-8cc6-8d1d0d84653f">
        <source>inputMoveToData(_ti : CM_TrackedItem);
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	moveToForm	: CMUI_MoveToForm;
	tiArray		: CM_TIArray;
begin

	moveToForm := app.loadForm(CMUI_MoveToForm, self.class, false, false, true, self.myTerminal, null).CMUI_MoveToForm;

	if moveToForm = null then
		return;
	endif;

	moveToForm.centreWindow;
	create tiArray transient;
	tiArray.add(_ti);
	moveToForm.setMyTrackedItems(tiArray);
	
	if moveToForm.showModal &lt;&gt; MsgBox_Return_OK then
		return;
	endif;

epilog
	delete tiArray;
	if moveToForm &lt;&gt; null then
		delete moveToForm;
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="inputTicketSequence" id="a709c237-60ac-4d40-9a23-d1eb5184b932">
        <source>inputTicketSequence(_ticketRules : CMUI_TicketSeqRules io);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cnt : Integer;
	str : String;
	ticketSeqFrm : CMUI_TicketSequences;
	ticketSeq : CM_TicketSequence;
begin

	//ticketSeqFrm := app.loadForm(CMUI_TicketSequences, self.class, false, false, false, self.myTerminal, null).CMUI_TicketSequences;
	create ticketSeqFrm transient;
