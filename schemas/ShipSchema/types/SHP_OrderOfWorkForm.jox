    </JadeMethod>
    <JadeMethod name="setFormCaption" id="67b7e146-b544-498c-81dc-1a5dc125a8a4">
        <updating/>
        <source>setFormCaption() updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// 02 Nov 2012	PJS		PAR #30631
// ---------------------------------------------------------------------------

vars
	formString : String;
	craneString : String;
	naviString : String;
begin

	//ccms 1033 epr 28/7/2011
	if self.filterWorkPoint &lt;&gt; null then
		craneString := self.filterWorkPoint.getID;
	else
		craneString := self.fldMain.topSheet.caption;
	endif;
	
	if self.myCurrentVoyage &lt;&gt; null then
		formString := app.getErrorString(Order_Of_Work) &amp; " - " &amp; craneString &amp; " " &amp;  self.myCurrentVoyage.code;
		naviString := craneString &amp; " " &amp;  self.myCurrentVoyage.code;
	else
		formString := app.getErrorString(Order_Of_Work);
		naviString := formString;
	endif;
	
	self.setCaption(formString);
	self.setNavigatorHeading(naviString);

end;</source>
    </JadeMethod>
    <JadeMethod name="setHeaderRows" id="d824ba3b-a916-41b2-96cf-149896af6795">
        <source>setHeaderRows(_entView: String) protected;
//----------------------------------------------------------------
//	Created:	02 September 2005	by Jason Chapman  (cnwjc2)
//
// 05 Nov 2012		PJS		Par #30631  - changed to use translatable strings
//----------------------------------------------------------------
vars
	theTable		: CM_DataTable;
	showLashInfo,
	showTimes		: Boolean;
begin

	theTable := self.tblData;

	
	if _entView = View_NoLashNoTimes then
	
		//row 1
		theTable.addItemAt(Tab &amp;  Tab &amp;  Tab &amp; Tab &amp; Tab &amp; app.getErrorString(Discharge) &amp; Tab  &amp; Tab  &amp; Tab  &amp; Tab &amp; app.getErrorString(Loading) &amp; Tab  &amp; Tab  &amp; Tab  &amp; Tab 
							&amp; app.getErrorString(MOVE_SHIFT) &amp; Tab  &amp; Tab &amp; app.getErrorString(Remarks) &amp; Tab  &amp; Tab &amp; app.getErrorString(Moves) &amp;  Tab &amp; Tab  &amp; Tab  &amp; Tab &amp; Tab &amp; app.getErrorString(Lid),1);
		//row 2
		theTable.addItemAt(Tab &amp; app.getErrorString(Location) &amp; Tab &amp; Tab &amp; app.getErrorString(Work_point) &amp; Tab &amp; Tab &amp; app.getErrorString(Import)  &amp; Tab &amp; Tab &amp; app.getErrorString(Rehandle) &amp; Tab &amp; Tab &amp; app.getErrorString(Export) &amp; Tab &amp; Tab &amp; app.getErrorString(Rehandle)
							&amp; Tab  &amp; Tab &amp;  " " &amp; Tab &amp; " " &amp; Tab &amp;  "20'"&amp; Tab &amp; app.getErrorString(Reefers_oversized) &amp; Tab &amp; app.getErrorString(Job) &amp; Tab &amp; Tab &amp; app.getErrorString(Running_Totals) &amp; Tab &amp; Tab &amp; app.getErrorString(Cargo) ,2);	
	elseif _entView = View_LashNoTimes then

		showLashInfo := true;
		//row 1
		theTable.addItemAt(Tab &amp;  Tab &amp;  Tab &amp; Tab &amp; Tab &amp; app.getErrorString(Discharge) &amp; Tab  &amp; Tab  &amp; Tab  &amp; Tab &amp; app.getErrorString(Loading) &amp; Tab  &amp; Tab  &amp; Tab  &amp; Tab 
							&amp; app.getErrorString(MOVE_SHIFT) &amp; Tab  &amp; Tab &amp; app.getErrorString(Remarks) &amp; Tab  &amp; Tab &amp; app.getErrorString(Moves) &amp;  Tab &amp; Tab  &amp; Tab  &amp; Tab &amp; Tab &amp; app.getErrorString(Lash) &amp; Tab  &amp; Tab &amp; app.getErrorString(Lid),1);
		//row 2
		theTable.addItemAt(Tab &amp; app.getErrorString(Location) &amp; Tab &amp; Tab &amp;  app.getErrorString(Work_point) &amp; Tab &amp; Tab &amp; app.getErrorString(Import)   &amp; Tab &amp; Tab &amp; app.getErrorString(Rehandle) &amp; Tab &amp; Tab &amp; app.getErrorString(Export) &amp; Tab &amp; Tab &amp; app.getErrorString(Rehandle)
							&amp; Tab  &amp; Tab &amp;  " " &amp; Tab &amp; " " &amp; Tab &amp;  "20'"&amp; Tab &amp; app.getErrorString(Reefers_oversized) &amp; Tab &amp; app.getErrorString(Job) &amp; Tab &amp; Tab &amp; app.getErrorString(Running_Totals) &amp; Tab &amp; Tab &amp; app.getErrorString(Cargo) &amp; Tab &amp; app.getErrorString(Cage) &amp; Tab &amp; app.getErrorString(Cage) &amp; Tab ,2);
	
	elseif _entView = View_NoLashTimes then
		showTimes := true;
		//row 1
		theTable.addItemAt(Tab &amp;  Tab &amp;  Tab &amp; Tab &amp; Tab &amp; app.getErrorString(Discharge) &amp; Tab  &amp; Tab  &amp; Tab  &amp; Tab &amp; app.getErrorString(Loading) &amp; Tab  &amp; Tab  &amp; Tab  &amp; Tab 
							&amp; app.getErrorString(MOVE_SHIFT) &amp; Tab  &amp; Tab &amp; app.getErrorString(Remarks) &amp; Tab  &amp; Tab &amp; app.getErrorString(Moves) &amp;  Tab &amp; Tab  &amp; Tab  &amp; Tab &amp; Tab &amp; app.getErrorString(Lid) &amp; Tab &amp; app.getErrorString(Job_Times) &amp; Tab,1);
		//row 2
		theTable.addItemAt(Tab &amp; app.getErrorString(Location) &amp; Tab &amp; Tab &amp; app.getErrorString(Work_point) &amp; Tab &amp; Tab &amp; app.getErrorString(Import)   &amp; Tab &amp; Tab &amp; app.getErrorString(Rehandle) &amp; Tab &amp; Tab &amp; app.getErrorString(Export) &amp; Tab &amp; Tab &amp; app.getErrorString(Rehandle)
							&amp; Tab  &amp; Tab &amp;  " " &amp; Tab &amp; " " &amp; Tab &amp;  "20'"&amp; Tab &amp; app.getErrorString(Reefers_oversized) &amp; Tab &amp; app.getErrorString(Job) &amp; Tab &amp; Tab &amp; app.getErrorString(Running_Totals) &amp; Tab &amp; Tab &amp; app.getErrorString(Cargo) &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab,2);
	
	elseif _entView = View_LashTimes then
		showTimes := true;
		showLashInfo := true;
		//row 1
		theTable.addItemAt(Tab &amp;  Tab &amp;  Tab &amp; Tab &amp; Tab &amp; app.getErrorString(Discharge)&amp; Tab  &amp; Tab  &amp; Tab  &amp; Tab &amp; app.getErrorString(Loading) &amp; Tab  &amp; Tab  &amp; Tab  &amp; Tab 
							&amp; app.getErrorString(MOVE_SHIFT) &amp; Tab  &amp; Tab &amp; app.getErrorString(Remarks) &amp; Tab  &amp; Tab &amp; app.getErrorString(Moves) &amp;  Tab &amp; Tab  &amp; Tab  &amp; Tab &amp; Tab &amp; app.getErrorString(Lash) &amp; Tab  &amp; Tab &amp; app.getErrorString(Lid) &amp; Tab &amp; app.getErrorString(Job_Times) &amp; Tab,1);
		//row 2
		theTable.addItemAt(Tab &amp; app.getErrorString(Location) &amp; Tab &amp; Tab &amp; app.getErrorString(Work_point) &amp; Tab &amp; Tab &amp; app.getErrorString(Import)   &amp; Tab &amp; Tab &amp; app.getErrorString(Rehandle) &amp; Tab &amp; Tab &amp; app.getErrorString(Export) &amp; Tab &amp; Tab &amp; app.getErrorString(Rehandle)
							&amp; Tab  &amp; Tab &amp;  " " &amp; Tab &amp; " " &amp; Tab &amp;  "20'"&amp; Tab &amp; app.getErrorString(Reefers_oversized) &amp; Tab &amp; app.getErrorString(Job) &amp; Tab &amp; Tab &amp; app.getErrorString(Running_Totals) &amp; Tab &amp; Tab &amp; app.getErrorString(Cargo) &amp; Tab &amp; app.getErrorString(Cage) &amp; Tab &amp; app.getErrorString(Cage) &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab,2);
	
	endif;


	// LINE 1
	// DISCHARGE
	theTable.accessCell(1,6).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(1,6).alignment := Table.Alignment_Center_Middle;
	// LOADING
	theTable.accessCell(1,10).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(1,10).alignment := Table.Alignment_Center_Middle;
	// SHIFT
	theTable.accessCell(1,14).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(1,14).alignment := Table.Alignment_Center_Middle;
	// REMARKS
	theTable.accessCell(1,16).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(1,16).alignment := Table.Alignment_Center_Middle;
	// MOVES
	theTable.accessCell(1,18).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(1,18).alignment := Table.Alignment_Center_Middle;
	theTable.accessCell(1,22).mergeCells := Table.MergeCells_NotAvailable;	

	// LID OR LASH
	theTable.accessCell(1,23).mergeCells := Table.MergeCells_Merge;		
	theTable.accessCell(1,23).alignment := Table.Alignment_Center_Middle;	
	
	if showLashInfo then
		// LID
		theTable.accessCell(1,25).mergeCells := Table.MergeCells_Merge;		
		theTable.accessCell(1,25).alignment := Table.Alignment_Center_Middle;	
		if showTimes then
			// LID
			theTable.accessCell(1,26).mergeCells := Table.MergeCells_Merge;		
			theTable.accessCell(1,26).alignment := Table.Alignment_Center_Middle;	
		endif;
	else
		if showTimes then
			// LID
			theTable.accessCell(1,24).mergeCells := Table.MergeCells_Merge;		
			theTable.accessCell(1,24).alignment := Table.Alignment_Center_Middle;	
		endif;
	endif;
	

	// LINE 2
	// DISCHARGE
	theTable.accessCell(2,6).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(2,6).alignment := Table.Alignment_Center_Middle;
	// DISCHARGE
	theTable.accessCell(2,8).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(2,8).alignment := Table.Alignment_Center_Middle;
	// DISCHARGE
	theTable.accessCell(2,10).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(2,10).alignment := Table.Alignment_Center_Middle;
	// DISCHARGE
	theTable.accessCell(2,12).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(2,12).alignment := Table.Alignment_Center_Middle;
	// DISCHARGE
	theTable.accessCell(2,18).mergeCells := Table.MergeCells_Merge;			
	theTable.accessCell(2,18).alignment := Table.Alignment_Center_Middle;	
	theTable.accessCell(2,20).mergeCells := Table.MergeCells_Merge;			
	theTable.accessCell(2,20).alignment := Table.Alignment_Center_Middle;	
	
	theTable.accessCell(2,22).mergeCells := Table.MergeCells_NotAvailable;	

	theTable.accessColumn(4).width := 32;
	theTable.accessColumn(5).width := 31;
	theTable.accessedColumn.alignment := Table.Alignment_Center_Middle;

end;</source>
        <access>protected</access>
        <Parameter name="_entView" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLengthReportingOptions" id="d0bcfe1c-69d1-4058-9957-969538e759f9">
        <updating/>
        <source>setLengthReportingOptions() updating;
// ---------------------------------------------------------------------------
// Created:	28 May 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	show30 : Integer;
	show45 : Integer;
	show53 : Integer;
begin
	show30 := self.myTerminal.getConfig(Is30IncludedForReports).Integer;
	show45 := self.myTerminal.getConfig(Is45IncludedForReports).Integer;
	show53 := self.myTerminal.getConfig(Is53IncludedForReports).Integer;
	self.showLengthOther := (show30 = 2) or (show45 = 2) or (show53 = 2);
	self.showLength30 := (show30 = 1);
	self.showLength45 := (show45 = 1);
	self.showLength53 := (show53 = 1);
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="5777c7bb-7cc0-44e0-9bb4-67db9f9c89bb">
        <updating/>
        <source>setMyCurrentVoyage(_newVoyage : CM_Voyage)updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if self.myCurrentVoyage = _newVoyage then
		return;
	endif;
	
	if self.myCurrentVoyage &lt;&gt; null then
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event));
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(JobSheet_Update_Event));
		if self.myCurrentVoyage.myCellularVoyageStructure &lt;&gt; null then	//12 Jul 2016	NDL	TFS 2055
			self.endNotification(self.myCurrentVoyage.myCellularVoyageStructure, self.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE));
		endif;
	endif;
	if _newVoyage = null then
		self.btnOOWConfirm.enabled := false;	//14 Jun 2018	NDL	TFS 39197
		self.btnAlloc.enabled:=false;
		return;
	endif;
	
	self.btnOOWConfirm.enabled := _newVoyage.myVoyageProcess &lt;&gt; null and _newVoyage.myVoyageProcess.showOOWConfirmation(_newVoyage);	//15 Jun 2018	NDL	TFS 39167
	self.btnAlloc.enabled:=true;
	self.myCurrentVoyage:=_newVoyage;
	
	//cnwjo3 par 23105
	app.setMyCurrentVoyage(self.myCurrentVoyage);
	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(JobSheet_Update_Event), Response_Continuous, null);
	if self.myCurrentVoyage.myCellularVoyageStructure &lt;&gt; null then	//12 Jul 2016	NDL	TFS 2055
		self.beginNotification(self.myCurrentVoyage.myCellularVoyageStructure, self.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), Response_Continuous, null);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newVoyage" type="CM_Voyage"/>
    </JadeMethod>
