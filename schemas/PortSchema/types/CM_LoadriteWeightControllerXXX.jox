    </JadeMethod>
    <JadeMethod name="openEvent" id="05a356fc-0677-48f5-b34d-4db837c9d457">
        <updating/>
        <source>openEvent(_connection: Connection) updating, protected;
/* ---------------------------------------------------------------------------
Created:     17 September 2010 by cnwrs2

Purpose:     
        
------------------------------------------------------------------------------*/
/*

Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite

*/
vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.myConnection.String &amp; " listeningState=" &amp; self.listeningState.String);
	
	self.listeningState := self.Listening;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_connection" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="readEvent" id="63ac1798-6488-436b-b4b0-51fbeaa2815a">
        <updating/>
        <source>readEvent(_connection: Connection; _binaryData: Binary) updating, protected;
/* ---------------------------------------------------------------------------
Created:     17 September 2010 by cnwrs2

Purpose:     
        
------------------------------------------------------------------------------*/
/*

Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.myConnection.String &amp; " listeningState=" &amp; self.listeningState.String);


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_connection" type="Connection"/>
        <Parameter name="_binaryData" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="startListening" id="6b48040e-eeb8-4c61-8a72-bdc6c7f79fe6">
        <updating/>
        <source>startListening() updating;
/* ---------------------------------------------------------------------------
Created:     17 September 2010 by cnwrs2

Purpose:     
        
------------------------------------------------------------------------------*/
/*

Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " registering for process notification");
	
	self.beginNotification(process, 64999, Response_Continuous, 0);
	self.isNoteActive := true;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="stopListening" id="5bfb8b31-6fa0-4890-8b39-cdf22b7268ce">
        <updating/>
        <source>stopListening() updating;
/* ---------------------------------------------------------------------------
Created:     17 September 2010 by cnwrs2

Purpose:     
        
------------------------------------------------------------------------------*/
/*

Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite

*/

vars

begin
	self.diagnosticLog(method.qualifiedName);
	
	if self.isNoteActive then
		self.endNotification(process, 64999);
		self.isNoteActive := false;
	endif;
	
	self.listeningState := self.PendingDelete;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="38e57bad-9045-4f31-86be-e116474dad55">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/* ---------------------------------------------------------------------------
Created:     17 September 2010 by cnwrs2

Purpose:     
        
------------------------------------------------------------------------------*/
/*

Date		Who		Reason
14 Jul 2016	cnwkpd1	TFS 2357 - Capture VGM info using Loadrite

*/

vars

begin
	if theObject = process and eventType = 64999 then
	
		// Send the received weight back
		self.myWeightCallerInterface.sendWeight(userInfo.Integer);

	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
