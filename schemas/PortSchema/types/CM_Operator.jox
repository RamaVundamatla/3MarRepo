    <JadeMethod name="setForCreate" id="6875e209-64b8-4730-8edf-290347f9d5b3">
        <updating/>
        <source>setForCreate(pProxyOperator:CM_Operator; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDAC	: CM_DataAccessController;
	
begin

	setForUpdate(pProxyOperator);
	self.myRoot := app.myRoot;

	tmpDAC := _passport.allDataAccessControllers[CM_Operator.name];
	if tmpDAC &lt;&gt; null then
		tmpDAC.addObject(self);
	endif;

end;</source>
        <Parameter name="pProxyOperator" type="CM_Operator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5947d8dd-4e39-47a9-ac49-a709dae2d44d">
        <updating/>
        <source>setForUpdate(_proxy:CM_Operator) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/03/2011	cnwcs5		par 26909 - new config item
// 20/10/2011	cnwdap1		PAR # 28524 CCMS POL 2096 added Bookings Unique by Number attribute
// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259
// 15 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 22 Aug 2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
// ---------------------------------------------------------------------------
vars
	origCodeGroup	: CM_CodeGroup;
	pxyOpTerm,
	realOpTerm		: CM_OperatorTerminal;
	operGroup 		: CM_OperatorGroup;
	term 			: CM_Terminal;	//06 Jan 2015	NDL	Par 37088
	camGroups 		: CM_CamGroupSet;	//06 Jan 2015	NDL	Par 37088
	camGroup 		: CM_CamGroup;	//06 Jan 2015	NDL	Par 37088
	needsRefresh : Boolean;
begin
	// par 31259 - make sure xlations updated with new code
	if self.code &lt;&gt; _proxy.code then
		self.updateXlations_Code (_proxy.code.String, self.code.String, self.allXlations);
		//06 Jan 2015	NDL	Par 37088
		if self.code &lt;&gt; null then // I.e. it already exists as something, and is changing
			foreach term in app.myRoot.allTerminals discreteLock do
				foreach camGroup in term.camGroups discreteLock do
					if camGroup.operators.includes( self ) then
						if camGroups = null then
							create camGroups transient;
						endif;
						camGroup.removeOperator( self );
						camGroups.addNoDuplicates( camGroup, false );
					endif;
				endforeach;
			endforeach;
		endif;
		
	endif;
	
	self.code 					:= _proxy.code.trimBlanks;
	self.isNotAvailableForEntry := _proxy.isNotAvailableForEntry;
	self.colour 				:= _proxy.colour;
	
	if _proxy.debtor &lt;&gt; self.debtor then
		app.myRoot.causeEvent(EVENT_DEBTORNODE_UPDATE,false,self.debtor);
		app.myRoot.causeEvent(EVENT_DEBTORNODE_UPDATE,false,_proxy.debtor);
	endif;
	
	self.debtor 				:= _proxy.debtor;
	if self.description &lt;&gt; _proxy.description then	//03 Apr 2019	NDL	TFS 44194
		self.description 		:= _proxy.description.trimBlanks;
		needsRefresh 			:= true;	//03 Apr 2019	NDL	TFS 44194
	endif;
	self.displayTempFahrenheit 	:= _proxy.displayTempFahrenheit;

	if(self.notRailIds = null) then
		create self.notRailIds persistent;
	else
		self.notRailIds.clear;
	endif;
	
	if _proxy.notRailIds &lt;&gt; null then
		_proxy.notRailIds.clone(self.notRailIds);
	endif;

	if(self.notRoadIds = null) then
		create self.notRoadIds persistent;
	else
		self.notRoadIds.clear;
	endif;
	
	if _proxy.notRoadIds &lt;&gt; null then
		_proxy.notRoadIds.clone(self.notRoadIds);
	endif;

	self.requiresBookingReference 	:= _proxy.requiresBookingReference;
	self.requiresCVC 				:= _proxy.requiresCVC;
	self.requiresConsigneeConsignor	:= _proxy.requiresConsigneeConsignor;
	self.requiresDeliveryRelease 	:= _proxy.requiresDeliveryRelease;
	self.requiresHumidity 			:= _proxy.requiresHumidity;
	self.requiresRequestNumber 		:= _proxy.requiresRequestNumber;
	self.requiresVentilation 		:= _proxy.requiresVentilation;
	self.requiresVoyage 			:= _proxy.requiresVoyage;
	
	self.setCargoReleaseImpFFUpdAllowed(_proxy.getCargoReleaseImpFFUpdAllowed); // adm 210708 CCMS 1738
	
	//cnwrd1 4.11.08 CCMS JMT 1743/1764 
	self.setRequiresExportOperatorNo(_proxy.getRequiresExportOperatorNo); // adm 210708 CCMS 1738
	self.setRequiresImportFF(_proxy.getRequiresImportFF); // adm 210708 CCMS 1738
	self.setRequiresImpOperatorPIN(_proxy.getRequiresImpOperatorPIN); // adm 210708 CCMS 1738
	self.reeferReadingsPerDay := _proxy.reeferReadingsPerDay;
	
	self.allCodeGroups.clear();
	_proxy.allCodeGroups.copy(self.allCodeGroups);
	
	//self.allCarriersByCargoTypeId.clear();									// TFS 45836
	//_proxy.allCarriersByCargoTypeId.copy(self.allCarriersByCargoTypeId);		// TFS 45836

	// cnwrd1 update for sql native par 34536
	foreach operGroup in self.allOperatorGroups do
		self.updateObjectEdition(operGroup);
	endforeach;
	
	self.allOperatorGroups.clear();
	_proxy.allOperatorGroups.copy(self.allOperatorGroups);
	
	// cnwrd1 update for sql native par 34536
	foreach operGroup in self.allOperatorGroups do
		self.updateObjectEdition(operGroup);
	endforeach;
	
	foreach pxyOpTerm in _proxy.allOperatorTerminals do
		realOpTerm := self.getOperatorTerminal(pxyOpTerm.myTerminal, true);
		realOpTerm.setFromProxy(pxyOpTerm);
	endforeach;
	
	if self.debtor &lt;&gt; null then
		self.debtor.setShipLineGroupDebtor(); // 2006FEB AKB PASHA DEMO
	endif;
	
	//25 Aug 2009	NDL	Par 20521 CCMS 1609
	self.allEmailAddresses.clear;
	if not _proxy.allEmailAddresses.isEmpty then
		_proxy.allEmailAddresses.copy(self.allEmailAddresses);
	endif; 

	//cnwjo3 CCMS 1892, par 23587
	self.washExpiryReefer := _proxy.washExpiryReefer;
	
	//+cnwml2 PAR23715 SFW CCMS1131
	self.sealCheckRailReceival	:= _proxy.sealCheckRailReceival;
	self.sealCheckRailRelease	:= _proxy.sealCheckRailRelease;
	self.sealCheckRoadReceival	:= _proxy.sealCheckRoadReceival;
	self.sealCheckRoadRelease	:= _proxy.sealCheckRoadRelease;
	self.sealCheckShipReceival	:= _proxy.sealCheckShipReceival;
	self.sealCheckShipRelease	:= _proxy.sealCheckShipRelease;
	
	// cnwcs5 par 26909
	self.setShowOpExportReleaseWarning (_proxy.getShowOpExportReleaseWarning);
	
	// PAR #28524
	self.bookingsUniqueByNumber	:= _proxy.bookingsUniqueByNumber;
	
	//06 Jan 2015	NDL	Par 37088
	if camGroups &lt;&gt; null then
		foreach camGroup in camGroups do
			camGroup.addOperator( self );
		endforeach;
	endif;
	
	//03 Apr 2019	NDL	TFS 44194
	if needsRefresh then
		if app.myAlternateDict &lt;&gt; null then
			app.myAlternateDict.setOperatorDictNeedsRefresh();
		endif;
	endif;
	
epilog
	delete camGroups;
end;</source>
        <Parameter name="_proxy" type="CM_Operator"/>
    </JadeMethod>
