    <JadeMethod name="message" id="0e519bdc-3709-4e35-ad29-147e0487e6b0">
        <source>message():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2010	cnwndl1	Initial creation

*/

vars

	retValue : String;

begin

	retValue := lastModified.Date.String &amp; "  " &amp; lastModified.Time.String &amp; " - " &amp; classMethod;
	if author &lt;&gt; null then
		retValue := retValue &amp; " - " &amp; author;
	endif;
	
	return retValue;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="b4b1e82d-d32d-4aea-be7d-cf5b57ee4c16">
        <updating/>
        <source>setDetails(	_author : String;
			_classMethod : String;
			_lastModified : TimeStamp;
			_myBlame : UM_Blame
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2010	cnwndl1	Initial creation

*/

vars

begin

	self.author := _author;
	self.classMethod := _classMethod;
	self.lastModified := _lastModified;
	self.myBlame := _myBlame;
		
epilog

end;</source>
        <Parameter name="_author" type="String"/>
        <Parameter name="_classMethod" type="String"/>
        <Parameter name="_lastModified" type="TimeStamp"/>
        <Parameter name="_myBlame" type="UM_Blame"/>
    </JadeMethod>
</Class>
