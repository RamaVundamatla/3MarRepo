	endif;
	
	app.writeLog(method.qualifiedName &amp; "WodReceive  For Cargo Work Orders Enhancements", LogINFO); 
	if _controller &lt;&gt; null then
		_controller.logEntry("WodReceive  For Cargo Work Orders Enhancements") ;	
	endif;
	beginTransaction;
	
	foreach wodReceive in CM_WodReceive.instances do
