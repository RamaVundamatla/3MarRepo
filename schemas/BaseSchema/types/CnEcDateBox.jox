    <JadeMethod name="click" id="d5c77ca5-580c-484e-87e4-c0899d9ec992">
        <updating/>
        <source>click(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		18 June 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 18/06/2003	cnwdad1		Added this method to handle the cursor being positioned
//							using the mouse, and to still skip over the separator
//							characters.
// --------------------------------------------------------------------------------
begin
	if self.selStart = textbox.text.length() then
		self.cursorPosition	:=	self.selStart;
	else
		self.cursorPosition	:=	self.selStart + 1;
	endif;
	
	if self.text[self.cursorPosition:1] = self.myDateFormat.separator then
		self.cursorPosition	:=	self.cursorPosition + 1;
		self.selStart		:=	self.cursorPosition - 1;
	endif;
	
	inheritMethod(textbox);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcDate" id="5bd7405f-1f19-45ea-ac49-1b3608d38c39">
        <source>cnEcDate(): Date;
// -----------------------------------------------------------------------------
// Created:		21 November 2001 by cnwdad1
//
// Purpose:		Returns the receiver's current date setting, provided that the
//				date is valid, otherwise a null value is returned.
//
// Parameters:	None
//
// Returns:		The current date setting.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.date.isValid() then
		return self.date;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcDecimal" id="74fee3d2-8026-400e-8d91-f472e4e98bd6">
        <source>cnEcDecimal(): Decimal;
// -----------------------------------------------------------------------------
// Created:		21 November 2001 by cnwdad1
//
// Purpose:		Returns the receiver's current date setting as a Decimal Julian
//				day number.
//
// Parameters:	None
//
// Returns:		The Julian day number.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.date.isValid() then
		return self.date.Decimal;
	else
		return 0;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
