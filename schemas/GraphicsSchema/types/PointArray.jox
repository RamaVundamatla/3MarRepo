<CollClass name="PointArray">
    <JadeMethod name="edgeIntersection" id="4e66fced-c0b8-4d19-9d66-d065ac838a11">
        <source>edgeIntersection( a , b, c, d : Point input ) : Boolean protected;
/*

Purpose:			

Parameters:		one edge is a &amp; b  the other edge is c &amp; d	determines if the lines intersect 
   
                as used in the Separating Axis Theorem - http://content.gpwiki.org/index.php/Polygon_Collision
				
Return Value:		


Date		Who		Reason
18 January 2012	cnwer1	Initial creation PAR 29079

*/

vars	

	n_a,
	n_b,
	ua,ub,
    det : Real;
begin
	
	det:= (d.y - c.y) * (b.x - a.x) - (d.x - c.x) * (b.y - a.y);
	
	n_a:=  (d.x - c.x) * (a.y - c.y) - (d.y - c.y) * (a.x - c.x);
	
	n_b:=(b.x - a.x)  * (a.y - c.y) -(b.y - a.y) * (a.x -  c.x);
	 // Make sure there is not a division by zero - this also indicates that
	 // the lines are parallel.  
	 // If n_a and n_b were both equal to zero the lines would be on top of each 
	 // other (coincidental).  This check is not done because it is not 
	 // necessary for this implementation (the parallel check accounts for this).
	if (det = 0 ) then
		return false;
	endif;
	
	ua := n_a/det;
	ub:= n_b/det;
	if (ua &gt;= 0 and ua &lt;= 1 and ub &gt;= 0 and ub &lt;= 1) then
       
           // ptIntersection.X = L1.X1 + (ua * (L1.X2 - L1.X1));
           // ptIntersection.Y = L1.Y1 + (ua * (L1.Y2 - L1.Y1));
        return true;
    else
         return false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="a" type="Point" usage="input"/>
        <Parameter name="b" type="Point" usage="input"/>
        <Parameter name="c" type="Point" usage="input"/>
        <Parameter name="d" type="Point" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getExtremesForText" id="358e0f39-5884-4ef6-b72e-5de7436215be">
        <source>getExtremesForText(_x1, _y1, _x2, _y2 : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwmc5	Initial creation

*/

vars
	bestPlace 		: PointArray;
	frame 			: Frame;
	point			: Point;
	wasOut			: Boolean;
	offset, minY, 
	maxX, maxY, 
	height, minX,
 	diffY, diffX    : Integer;
	yChk, xChk		: Boolean;
	
begin
	wasOut := false;
	create bestPlace transient;
	yChk := true;
	xChk := false;
	
	// Starting points
	foreach point in self do	
		//Find the largest Y point
		if maxY = null then
			maxY := point.y;
		elseif maxY &lt; point.y then
			maxY := point.y;
		endif;
		
		//Find the smallest Y point
		if minY = null then
			minY := point.y;
		elseif minY &gt; point.y then
			minY := point.y;
		endif;
		
		//Find the largest X point
		if maxX = null then
			maxX := point.x;
		elseif maxX &lt; point.x then
			maxX := point.x;
		endif;
		
		//Find the smallest X point
		if minX = null then
			minX := point.x;
		elseif minX &gt; point.x then
			minX := point.x;
		endif;
	endforeach;
	
	diffY := maxY - minY;
	diffX := maxX - minX;
	//height := (diffY/2).Integer;
	
	// Calculate starting points...
	point.set(minX.Integer, minY.Integer);
	bestPlace.add(point);
	point.set(maxX.Integer, maxY.Integer);
	bestPlace.add(point);
	
	//Build opposites... only needed for check if inside polygon.
	point.set(bestPlace[1].x, bestPlace[2].y);
	bestPlace.add(point);
	point.set(bestPlace[2].x, bestPlace[1].y);
	bestPlace.add(point);
	
	// Find the best place...
	while self.intersectsPolygon(bestPlace) = false do
		while not bestPlace[2].y &gt; maxY and yChk do
			bestPlace[1].setY(bestPlace[1].y + 2);
			bestPlace[2].setY(bestPlace[2].y + 2);
			bestPlace[3].setY(bestPlace[3].y + 2);
			bestPlace[4].setY(bestPlace[4].y + 2);
			if bestPlace[2].y &gt;= maxY then
				xChk := true;
			else
				yChk := false;
				minY := minY + 35;
			endif;
		endwhile;
		
		if ((minY + diffY) - minY) &gt;= 10 then
			diffY := diffY - 1;
			//minY := minY + 1;
			bestPlace[1].setY(minY);
			bestPlace[2].setY(minY + diffY);
			bestPlace[3].setY(minY + diffY);
			bestPlace[4].setY(minY);
		else
			break;
		endif;
		
		while not bestPlace[2].x &gt; maxX and xChk do
			bestPlace[1].setX(bestPlace[1].x + 2);
			bestPlace[2].setX(bestPlace[2].x + 2);
			bestPlace[3].setX(bestPlace[3].x + 2);
			bestPlace[4].setX(bestPlace[4].x + 2);
			if bestPlace[2].x &gt;= maxX then
				yChk := true;
			else
				xChk := false;
				minX := minX + 35;
			endif;
		endwhile;
		
		if ((minX + diffX) - minX) &gt;= 10 then
			diffX := diffX - 1;
			//minX := minX + 1;
			bestPlace[1].setX(minX);
			bestPlace[2].setX(minX + diffX);
			bestPlace[3].setX(minX);
			bestPlace[4].setX(minX + diffX);
		else
			break;
		endif;
		
		wasOut := true;
	endwhile;
	
	offset := 2;
	
	// Put into param's for output
	_x1 := bestPlace[1].x + offset;
	_y1 := bestPlace[1].y + offset;
	_x2 := bestPlace[2].x + offset;
	_y2 := bestPlace[2].y + offset;
	
epilog
	delete bestPlace;
end;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwmc5	Initial creation

*/

/*vars
	bestPlace 		: PointArray;
	frame 			: Frame;
	point			: Point;
	wasOut			: Boolean;
