    <JadeMethod name="btnSearchMode_click" id="00293fa3-64ab-4f35-b1e5-4c5102e59937">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearchMode_click(btn: Button input) updating;
/*

Date		Who		Reason
18 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	//
	//
	if self.searchMode = self.SEARCH_TASKS then
		self.searchMode := self.SEARCH_CARGO;
	else
		self.searchMode:=self.SEARCH_TASKS;
	endif;
	if self.searchMode = self.SEARCH_TASKS then
		self.txtSearch.text:="Search Tasks";
	else
		self.txtSearch.text:="Search Cargo";
	endif;
	self.txtSearch.foreColor:=self.txtSearch.getSystemColor(Window.Color_3DShadow);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
