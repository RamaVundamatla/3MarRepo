    <JadeMethod name="displaySelectorResults" id="d3f5cc20-d5e8-4a3c-b06c-6922008e28a4">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox('The grid area screen cannot display item for the selected mode (' &amp; _mode.String &amp; ')', 'Invalid selector mode', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.myCurrentDrawingController.allSelectorTIs.clear;
	_resultCollection.copy(self.myCurrentDrawingController.allSelectorTIs);
	self.myCurrentDrawingController.drawSelf(true);	

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dkbColorLegend_queryDock" id="1286c68a-73e3-4ac1-9431-6f9251eda60c">
        <controlMethod name="JadeDockBar::queryDock"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dkbColorLegend_queryDock(dockbar: JadeDockBar input; dockWith: Window input; dockPosn: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if dockWith = self.dkcExtraInfo or
	   dockWith = self then
		// only allow to be docked in ExtraInfo or form
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="dockbar" type="JadeDockBar" usage="input"/>
        <Parameter name="dockWith" type="Window" usage="input"/>
        <Parameter name="dockPosn" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dkbColorLegend_userResize" id="afeb8209-9556-4982-aa1e-933277f97949">
        <controlMethod name="JadeDockBar::userResize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dkbColorLegend_userResize(dockBar: JadeDockBar input) updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (not dockBar.isFloating) then
		self.dkbGridArea.userResize(self.dkbGridArea);
		self.redraw;
	endif;
end;</source>
        <Parameter name="dockBar" type="JadeDockBar" usage="input"/>
    </JadeMethod>
