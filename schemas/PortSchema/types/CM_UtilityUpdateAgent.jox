    <JadeMethod name="utlUpdateCustomerPriority" id="7fa7fd29-eb32-419c-9ba4-9e8bd0354b38">
        <source>utlUpdateCustomerPriority(pProxyCustomerPriority:CM_CustomerPriority; _passport : CM_Passport input);
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//-----------------------------------------
vars
	cancelSave:Boolean;
	realCustomerPriority:CM_CustomerPriority;
	expectedEdition:Integer;
begin

	self.initialiseActivity();

	pProxyCustomerPriority.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyCustomerPriority.pxyGetRealObjectAndEdition(realCustomerPriority, expectedEdition);
	
	if realCustomerPriority = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CustomerPriority.name, null, null);
		return;
	endif;

	app.myValUA.valCustomerPriority(realCustomerPriority, pProxyCustomerPriority);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realCustomerPriority);

	if _passport.noErrors and realCustomerPriority.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'MachineAvailability', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCustomerPriority, true);
	endif;
	
	if _passport.noErrors then
		realCustomerPriority.setForUpdate(pProxyCustomerPriority);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCustomerPriority, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyCustomerPriority" type="CM_CustomerPriority"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCustomsAgent" id="4f6a5c4d-4be9-4343-ba62-b8348ba7bd3c">
        <updating/>
        <source>utlUpdateCustomsAgent(pProxyCustomsAgent:CM_CustomsAgent; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realCustomsAgent:CM_CustomsAgent;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyCustomsAgent.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyCustomsAgent.pxyGetRealObjectAndEdition(realCustomsAgent, expectedEdition);
	
	if realCustomsAgent = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MTGrade.name, null, null);
		return;
	endif;

	app.myValUA.valCustomsAgent(realCustomsAgent, pProxyCustomsAgent);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCustomsAgent);

	if _passport.noErrors and realCustomsAgent.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'CustomsAgent', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCustomsAgent, true);
	endif;
	
	if _passport.noErrors then
		realCustomsAgent.setForUpdate(pProxyCustomsAgent);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCustomsAgent, false);
	endif;

end;</source>
        <Parameter name="pProxyCustomsAgent" type="CM_CustomsAgent"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCustomsMessageCSV" id="e8b71ffd-a4dc-47c1-8399-b465c7748b72">
        <updating/>
        <source>utlUpdateCustomsMessageCSV(_allFileRows : ObjectArray; _passport : CM_Passport input) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 19 February 2009
//
// Implemented version: 7.7.1
// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
// Provide the ability to import Customs Message templates (that are in the form of
// EDIActions) from a CSV file.
//----------------------------------------------------------------------
/*

Date			Who		Reason
11 Jan 2011		cnwkpd1	PAR #26678 - Tidy up transient leaks
26 Sep 2018		NDL		TFS 40940 - major rewrite to deal with all tyopes not just the latest one at the time.
03 July 2023	navpw1	TFS 58831 (58833) - Added role code
*/
vars
	pxyEDIAction,
	realEDIAction,
	ediAction : CM_EDIAction;
	object : Object;
	stringArray : HugeStringArray;
	ediActions : CM_EDIActionByNameDict;
	stopDict : CM_StopsTableByHeadingIdDict;
	todoDict : CM_ToDoTaskDescByShortDesc;
	actionObject : CM_Object;
//	ediFileType : CM_EDIFileType;
	iter : Iterator;
	found : Boolean;
//	count : Integer;
	//Fields to assign proxy
	//code : String;
	descrip : String;
	actionType : String;
	name : String;
//	stopHeading : String;
	
	//26 Sep 2018	NDL	TFS 40940
	typeString : String;
	fileType : CM_EDIFileType;
	validFileTypes : CM_EDIFileTypeSet;
	foundFileType : Boolean;
	keyword : String;
	keyFileSegment : String;
	actionHeading : String;
	
begin
	self.initialiseActivity();
	create ediActions transient;
	create stopDict transient;
	create todoDict transient;
	app.myRoot.allStopsTable.copy(stopDict);
	app.myRoot.allToDoTaskDescsByShortDesc.copy(todoDict);
	app.myRoot.allEDIActions.copy(ediActions);
	iter := ediActions.createIterator();
	
	
	//26 Sep 2018	NDL	TFS 40940 - get a list of valid file types
	create validFileTypes transient;
	fileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_XMLOneStopCust, "");
	if fileType &lt;&gt; null and fileType.type = EDIFileType_XMLOneStopCust then
		validFileTypes.add( fileType );
	endif;
	fileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_CusRes, "");
	if fileType &lt;&gt; null and fileType.type = EDIFileType_CusRes then
		validFileTypes.add( fileType );
	endif;
	fileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeCAMIR_CustomsStatus, "");
	if fileType &lt;&gt; null and fileType.type = EDIFileTypeCAMIR_CustomsStatus then
		validFileTypes.add( fileType );
	endif;
	fileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_JMTInternal, "");
	if fileType &lt;&gt; null and fileType.type = EDIFileType_JMTInternal then 
		validFileTypes.add( fileType );
	endif;
	
	
	foreach object in _allFileRows do
	
		actionType := null;
		actionHeading := null;
		actionObject := null;
		keyword := null;
		descrip := null;
		keyFileSegment := null;
		name := null;
		found := false;
		iter.reset();
		
		stringArray := object.HugeStringArray;
		//The file needs to have at least 3 fields. Identified during PAR19517
		if stringArray.size &lt; 4 then
			app.raiseCMException(ERR_CSVLoadError, null, null);
			return;
		endif;
		
		if typeString = null then
			typeString := stringArray[1];	
			foreach fileType in validFileTypes do
				if fileType.getCustomActionsName = typeString then
					foundFileType := true;
					break;
				endif;
			endforeach;
			if not foundFileType then
				app.raiseCMException(ERR_CSVLoadError, null, null);
				return;
			endif;
		endif;
		
		if fileType.type.isOneOf( EDIFileType_XMLOneStopCust, EDIFileType_CusRes, EDIFileType_JMTInternal ) then
			name := stringArray[2];
			keyword := stringArray[3];
			keyFileSegment := stringArray[4];
			descrip := keyword;
		elseif fileType.type = EDIFileTypeCAMIR_CustomsStatus then
			keyword := stringArray[2];
			name := stringArray[3];
			descrip := stringArray[4];
			keyFileSegment := "R02";
		endif;
		if stringArray.size &gt; 4 then
			actionType 	:= stringArray[5].removeTabCrLfs();
		endif;
		if stringArray.size &gt; 5 then
			actionHeading := stringArray[6].removeTabCrLfs();
		endif;
		
		//Check an ediAction does not already exist.
		ediActions.startKeyGeq(name, iter);
		while iter.next(ediAction) do
			if ediAction.name &lt;&gt; name then
				break;
			endif;
			//Do the values match an existing ediAction?
			if ediAction.attributesMatchForX12(keyword, name, descrip, actionType, actionHeading, keyFileSegment) then
				found := true;
				break;
			endif;
		endwhile;
		
		//We didn't find a matching ediAction so we can create a new one.
		if not found then
		
			if actionHeading &lt;&gt; null then
				if actionHeading.length &gt; 10 and actionHeading[1:10] = "ToDo Task " then
					actionObject := todoDict.getAtKey(actionHeading[11:end]);
				elseif actionHeading.length &gt; 5 and actionHeading[1:5] = "Stop " then
					actionObject := stopDict.getAtKeyGeq(actionHeading[6:end], null);
					if actionObject &lt;&gt; null and actionObject.getEDIActionName &lt;&gt; actionHeading then
						actionObject := null;
					endif;
				else
					actionObject := stopDict.getAtKeyGeq(actionHeading, null);
				endif;
			endif;
			
			//If the stop does not apply to General Cargo Bills then we shouldn't be using it for US Customs. They only apply
			//these types of holds on Bills of Lading which then filter to the tracked items.
			if actionObject &lt;&gt; null and fileType.type = EDIFileTypeCAMIR_CustomsStatus then
				if actionObject.isKindOf(CM_StopsTable) and  
					not actionObject.CM_StopsTable.isValidForCargoType(BOLType_GeneralBillOfLading) then 
					actionObject := null;
				endif;
			endif;
			
			create pxyEDIAction transient;
			pxyEDIAction.setProxy(name, keyword, keyFileSegment, actionType, actionObject, fileType, descrip, null, null, null);		//cnwmc5 - 5 Dec 2014 - PAR 35351
			
			//Create ediAction
			app.myUtilityCA.utlCreateEDIAction(pxyEDIAction, realEDIAction, _passport);
			
			delete pxyEDIAction;
			
		endif;	
		
	endforeach;
	
epilog
	delete pxyEDIAction;
	delete stopDict;
	delete ediActions; //cnwrs1 20 may 2010 leaking in unit test
	delete iter;			// PAR #26678
	delete validFileTypes;	//26 Sep 2018	NDL	TFS 40940
	delete todoDict;	//26 Sep 2018	NDL	TFS 40940
	
end;</source>
        <Parameter name="_allFileRows" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCustomsReferences" id="8b4c33dd-a1bf-48f4-aed1-2112b09527dc">
        <source>utlUpdateCustomsReferences(_pxyCustomsReferenceDict: CM_CustomsReferenceDict input; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 March 2023	navpw1	Initial creation TFS: 55215
27/02/2024		navcs2	Defect 62587: CUX | POST/CustomsStatus Method Does not create any Transaction
09 April 2024	navlw1 	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode

*/

vars
	pxyCustomsReference,
	realCustomsReference	: CM_CustomsReference;
	expectedEdition			: Integer;
begin
	self.initialiseActivity();
	
	foreach pxyCustomsReference in _pxyCustomsReferenceDict do
		pxyCustomsReference.raiseExceptionIfNotProxy(method);
		
	endforeach;
	
	app.setContinueCMExceptions(true);

	foreach pxyCustomsReference in _pxyCustomsReferenceDict do
		pxyCustomsReference.pxyGetRealObjectAndEdition(realCustomsReference, expectedEdition);
		
		if realCustomsReference = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CustomsReference.name, null, null);
			return;
		endif;
		
		// navlw1 #63566
		app.myValUA.valCustomsReference(pxyCustomsReference);
		
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	//Lock all our objects in one go in case someone grabs the last one and updates it
	foreach pxyCustomsReference in _pxyCustomsReferenceDict do
		pxyCustomsReference.pxyGetRealObjectAndEdition(realCustomsReference, expectedEdition);
		exclusiveLock(realCustomsReference);
		
	endforeach;
	
	//Loop through our transients and update the real object
	foreach pxyCustomsReference in _pxyCustomsReferenceDict do
		pxyCustomsReference.pxyGetRealObjectAndEdition(realCustomsReference, expectedEdition);
		
		if _passport.noErrors and realCustomsReference.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Line Desc', null, null);
			return;
		endif;
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realCustomsReference, true);
		endif;
		
		if _passport.noErrors then
			realCustomsReference.setForUpdate(pxyCustomsReference);
		endif;

		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realCustomsReference, false);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_pxyCustomsReferenceDict" type="CM_CustomsReferenceDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDamageDefCode" id="1dcf0e22-7c7d-400b-a73b-749a68052232">
        <source>utlUpdateDamageDefCode(_pxyDamageDefCode : CM_DamageDefinitionCode input;
						_passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	realDamageDefCode 		: CM_DamageDefinitionCode;
	expectedEdition 		: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyDamageDefCode, 'Damage definition code oroxy');
	
	_pxyDamageDefCode.pxyGetRealObjectAndEdition(realDamageDefCode, expectedEdition);
	self.raiseExceptionIfNull(realDamageDefCode, 'Damage definition code');
	
	_pxyDamageDefCode.validateForUpdate();
	
	if not _passport.noErrors then
		return;
	endif;
	
	realDamageDefCode.setForUpdate(_pxyDamageDefCode);
	
epilog

end;
</source>
        <Parameter name="_pxyDamageDefCode" type="CM_DamageDefinitionCode" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
