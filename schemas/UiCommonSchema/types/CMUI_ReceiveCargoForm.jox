begin
	if self.isAutoVolumeCalcCT then 	// 14.8.2017 cnwma1 TFS #5695
		if not self.txtQuantity.isHidden then		// 20/6/19 MAP TFS41707
			self.autoCalcVolumeQtyPieces();
