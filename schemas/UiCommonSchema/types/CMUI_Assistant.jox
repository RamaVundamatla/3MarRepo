    <JadeMethod name="showVehicleBookingAssociation" id="288e85fc-4b9b-4cb1-8361-94a01e704fe9">
        <source>showVehicleBookingAssociation( _form : CM_BaseForm; _realVVR : CM_VehicleVisitRecord; _proxyTrackedItem : CM_TrackedItem; _carrier : CM_Carrier );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	vsAssocForm : CMUI_VehicleBookingAssociate;
	carrier : CM_Carrier;
	existingVbBooking : CM_VehicleBookingTimeSlot;

begin

	if not self.myTerminal.isVehicleBookingEnabled then
		// this sucker is licensed...
		return;
	endif;
	
	carrier := _carrier;
	if _proxyTrackedItem &lt;&gt; null then
		existingVbBooking := _proxyTrackedItem.myVehicleBookingTimeslot;
		if existingVbBooking &lt;&gt; null then
			carrier := existingVbBooking.myCarrier;
		endif;
	endif;

	if _realVVR = null and ( _proxyTrackedItem = null or carrier = null ) then
		return;
	endif;

	vsAssocForm := app.loadForm(CMUI_VehicleBookingAssociate, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingAssociate;
	if vsAssocForm &lt;&gt; null then
		vsAssocForm.setMyVehicleVisitRecord( _realVVR, _proxyTrackedItem, carrier );
		vsAssocForm.setParentForm( _form );
		vsAssocForm.showModal;
	endif;

epilog

end;</source>
        <Parameter name="_form" type="CM_BaseForm"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_proxyTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="showVehicleBookingEntryForm" id="eeb54e54-a72a-4753-a82c-f0bc871f7110">
        <source>showVehicleBookingEntryForm(_obj : CM_Object; _masterMenuAction : CMUI_MenuAction);
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 21 November 2007
//
//----------------------------------------------------------------------

vars
	formCls,
	assistCls	: Class;
	vehicleBookingForm : CM_BaseForm;
	menuAction : CMUI_MenuAction;
	subSys : CMUI_SubSystem;
	term : CM_Terminal;
	
begin
	subSys := app.myController.allSubSystems['GateSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('GTE_VehicleBookingEntryForm', formCls, assistCls);
	endif;
	
	if formCls = null then
		return;
	endif;

	if _obj &lt;&gt; null then
		//term := _obj.myTerminal;	
	else
		term := self.myTerminal;
	endif;
	term := self.myTerminal;
	
	vehicleBookingForm := app.loadForm(formCls, assistCls, false, false, true, term, null).CM_BaseForm;
	if vehicleBookingForm = null then
		return;
	endif;	

	vehicleBookingForm.show();
end;

</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showVehicleVisitForm" id="70286a14-2f82-4679-87cd-7dfc4ffa6fa7">
        <source>showVehicleVisitForm(_vehicleVisit : CM_VehicleVisitRecord input; _masterMenuAction : CMUI_MenuAction);
/*

Date		Who		Reason
18 March 2014	cnwer1	Initial creation PAR

*/

vars
	schema		: Schema;
	vehicleVisitForm 	: CM_TableViewForm;
	menuAction 	: CMUI_MenuAction;

begin

	menuAction := app.myController.createMenuAction(PmGteVisitRecordView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
		
	vehicleVisitForm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	if vehicleVisitForm = null then
		return;
	endif;
	
	if _vehicleVisit &lt;&gt; null then
		vehicleVisitForm.showWithObject(_vehicleVisit, true, false);
	else
		vehicleVisitForm.showForNew(true, true);	
	endif;

epilog

end;</source>
