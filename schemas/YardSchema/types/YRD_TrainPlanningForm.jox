        <updating/>
        <source>tblInfo_dblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	anObject : Object;
begin
	if (not app.isAllowedToInspect()) then
		return;
	endif;
	
	if table.row &gt; 0 and table.column &gt; 0 then
		anObject := table.accessCell(table.row,table.column).itemObject;
		if anObject &lt;&gt; null then
			anObject.inspect;
		endif;
	endif;
end;</source>
