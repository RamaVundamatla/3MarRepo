    <JadeMethod name="doNotableClear" id="390b2f19-fd0f-43b9-ac38-75ff27bf565e">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="825bc7a1-3231-45ff-872a-d6a09886fb33">
        <updating/>
        <source>doPrint() updating;
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theReport		: CMUI_ReportLine;
	theCode			: String;
	pxyJadeReport	: JadeReport;
	tblPrintParams	: CMIF_PrintTableParams;
//	tblClone		: CM_DataTable;
begin

	if self.filterVoyageCode = null then
		theCode := "All Voyages";
	else
		theCode := "Voyage " &amp; self.filterVoyageCode;
	endif;
		
	create theReport;
	theReport.initReport;
	theReport.lblTitle01.caption := "Break Bulk Delivery Orders  :";
	theReport.lblTitle03.caption :=  theCode;
	theReport.lblTitle02.caption := "Dated " &amp; self.txtStartDate.text &amp; " to " &amp; self.txtEndDate.text; 
	theReport.lblTitle04.caption := "";
	theReport.lblPrintedBy.caption := null;
	theReport.lblPrintedBylbl.caption := null;
	
	app.printer.setHeader(theReport.frHeader);
	app.printer.setFooter(null);
	app.printer.suppressDialog := true;
	
	create pxyJadeReport transient;
	
	create tblPrintParams transient;
	tblPrintParams.closePrinter := true;
	tblPrintParams.jadeReport := pxyJadeReport;
	tblPrintParams.newReport := true;
	tblPrintParams.printFrame := self.frmReport;
	tblPrintParams.printLabel := self.lblReport;
	tblPrintParams.useSmallFont := true;
	tblPrintParams.useTableFontAttributes := false;
	tblPrintParams.useTableColours := false;

	app.printer.orientation := Print_Portrait;
	app.printer.orientation := Print_Landscape;
	
	self.tblData.doPrintTable(tblPrintParams);

epilog
	self.doResize();
	delete theReport;
	delete tblPrintParams;
//	delete tblClone;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="fbded2bc-fa48-47cd-8fac-4fc710a00c58">
        <updating/>
        <source>doQuery() updating;
//----------------------------------------------------------------
//	Created:	05 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
11 Mar 2015	cnwkpd1	PAR #35843 - Make progress bar updates time-based, not object counts
	
*/

vars
	rowIdx,
	idx			: Integer;
	ediTI		: CM_EDITrackedItem;
	ediData		: CM_EDIData;	//par 26739 cnwrs1 17 Jan 2011
	ediConfig	: CM_EDIConfig;
	tbl			: CM_DataTable;
	passport	: CM_Passport;
	monitor		: CMIF_Monitor;
	todo		: Integer;
	lastUpdate	: Decimal[20];
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	passport := app.myPassport;
	
	if passport.myCMIFMonitor = null then
		create monitor transient;
		monitor.myParent := self;
		passport.setMyCMIFMonitor(monitor);
	endif;
	
	self.lblModalMessage.caption := "Loading Items";
	self.frmModalDialog.visible := true;
	self.lblModalInfo.caption := "Getting Break Bulk Delivery Orders";
	self.initTableData(null);
	endNotificationForSubscriber(self);
	ediConfig := self.myTerminal.myEdiConfig;
	
	if ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI config is null');
		return;
	endif;
//cnwrs1 par 24210 13 may 2010	
//	if not ediConfig.getEDIDataFromDataType(EDIDataType_CustomStop, ediData) then
//		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI CUSRES is null');
//		return;
//	endif;

	//clear all selected objects

	//make sure filter voyage is refreshed
	self.doCmbVoyageClick();
	
	//set all filterText attributes now
	self.setTextSearchAttributes();
	
	tbl := self.tblData;
	self.doWindowEvents(0);

	//foreach ediTI in ediData.allEDITrackedItems do
//	foreach ediTI in ediData.CM_EDIDataCustomStop.allUnprocCustByRespID do
//	foreach ediTI in ediConfig.allEDITrackedItemsByIdStatus do //cnwrs1 par 24210 13 may 2010
	foreach ediData in ediConfig.ediDatas discreteLock do	//par 26739 cnwrs1 17 Jan 2011
		if ediData.ediDataType = EDIDataType_CustomStop then
			foreach ediTI in ediData.allEDITrackedItems do
				if ediTI.cargoType &lt;&gt; TI_CargoType_BreakBulk then
					continue;
				endif;
				//add this one
				if self.includeObject(ediTI) then	//do filtering
					rowIdx := tbl.addItemObject(ediTI, ediTI.getAttributeStringForDefArray(tbl.allTblDataEntRows));
					tbl.accessRow(rowIdx).backColor := ediTI.getDisplayRowColour();
					self.armNotesForObject(ediTI);
					idx := idx + 1;	
					if passport.myCMIFMonitor &lt;&gt; null
					and ((app.relativeMachineTime() - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates) then
						passport.myCMIFMonitor.updateProgress("Getting Break Bulk Delivery Orders - " &amp; idx.String, todo, idx);
						lastUpdate := app.relativeMachineTime();
					endif;
				endif;
			endforeach;
		endif;
	endforeach;
	
	self.resetNotifications();
epilog
	passport.setMyCMIFMonitor(null);
	delete monitor;
	self.frmModalDialog.visible := false;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
