    <JadeMethod name="shouldAuditProperty" id="9c56ae19-2ebb-42d0-ac89-5e3f786bf98c">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55524

*/

vars

begin
	
	if _property = null then
		return false;
	endif;
	
	// we are using next seq number in self.nextSequenceNumArray, audit that instead
	if _property = CM_AutoExternalReceiptGen::nextSequenceNum then
		return false;
	else	
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
