// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.type = CM_MachineHistory.Type_DelayEnd;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
