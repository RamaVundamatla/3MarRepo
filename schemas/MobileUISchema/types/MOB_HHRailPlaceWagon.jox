end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnRakeBackward" id="505e74af-8aa6-4513-8658-3381f83cf800">
        <source>clickBtnRakeBackward();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	pos : Integer;
	
begin

	app.mousePointer :=	Busy;

	pos := self.cmbRakePos.listIndex;
	if self.cmbRakePos.listCount &gt; 1 then
		if pos &gt; 1 then
			self.cmbRakePos.listIndex := pos - 1;
		elseif pos &gt; self.cmbRakePos.listCount then
			self.cmbRakePos.listIndex := self.cmbRakePos.listCount;
		endif;
		self.cmbRakePos.click(cmbRakePos);
	endif;
	// 27012 04/2011 Cursor should automatically default to wagon field
	self.cmbWagon.setFocus();
	
epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnRakeForward" id="0257135c-f588-412d-b904-af1a49e53098">
        <source>clickBtnRakeForward();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	pos : Integer;
	
begin

	app.mousePointer :=	Busy;

	pos := self.cmbRakePos.listIndex;
	if self.cmbRakePos.listCount &gt; 1 then
		if pos &lt; 0 then
			self.cmbRakePos.listIndex := 1;
		elseif pos &lt; self.cmbRakePos.listCount then
			self.cmbRakePos.listIndex := pos + 1;
		endif;
		self.cmbRakePos.click(cmbRakePos);
	endif;
	// 27012 04/2011 Cursor should automatically default to wagon field
	self.cmbWagon.setFocus();
	
epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnRakeList" id="3e4061d6-3a8a-408d-afa2-6d2d4acdb2fc">
        <updating/>
        <source>clickBtnRakeList() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin

	app.mousePointer :=	Busy;

	//go to the Wagon/Cargo list
	self.myMobileGenericAgent.setMyCurrentWagon(cmbWagon.listObject.CM_Wagon);
	self.gotoForm( MOB_HHRailAllRakesList, false );
	
epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnWagonChecks" id="5e572e2d-5ab8-4ee3-8eac-89442b9276cf">
        <updating/>
        <source>clickBtnWagonChecks() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	wagon : CM_Wagon;
	
begin

	app.mousePointer :=	Busy;

	wagon := self.cmbWagon.listObject.CM_Wagon;
	
	if wagon = null then
		app.mousePointer :=	Idle;
		self.msgBox(app.getErrorString(Edit_damage_until_wagon_create),app.getErrorString(Error),MsgBox_OK_Only, false);
		return;
	endif;

	self.myMobileGenericAgent.setMyCurrentWagon(wagon);
	if self.isInward then
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.WagonUnload);
	else
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.WagonLoad);
	endif;
	self.gotoForm( MOB_HHWagonCheckCargo, false );	//11 Mar 2015	NDL	Par 35828
	return;
	
	//self.gotoForm( MOB_HHRailWagonDamage, false );
	
epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnWagonPos" id="686c8c22-77e7-49ae-b2e6-a7b21664edaf">
        <updating/>
        <source>clickBtnWagonPos( _btn : Button ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	wagonCont : CM_WagonController;
	
begin

	app.mousePointer :=	Busy;

	if _btn = null or _btn.userObject = null then
		return;
	endif;
	
	wagonCont := _btn.userObject.CM_WagonController;
	if wagonCont = null then
		return;
	endif;

	self.myMobileGenericAgent.setMyCurrentWagon(cmbWagon.listObject.CM_Wagon);
	self.myMobileGenericAgent.setMyLocationsController(wagonCont);
	self.myMobileGenericAgent.setMyNextTiToAction(null);

	self.gotoForm( MOB_HHRailPlaceCargo, false );

epilog

	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="_btn" type="Button"/>
    </JadeMethod>
