    <JadeMethod name="checkForChanges" id="e24163b0-9514-42fc-ac0e-fe1a29ee9129">
        <updating/>
        <source>checkForChanges():Boolean updating, protected;

// return value - true = no changes found, or changes saved or abandoned, so continue action
//				  false = changes found, cancel action

vars
	row 			: Integer;
	translation 	: XLAT_Translation;
	changesFound	: Boolean;
	flag			: Integer;
	locale			: CM_Locale;
	text			: String;
	constantName	: String;
	shortText		: String;
begin
	
	if self.myTranslatableText = null then
		return false;
	endif;
	
	// compare text in table with stored text (and shortText) values, note there maybe no translation defined
	foreach row in tblTranslations.fixedRows + 1 to tblTranslations.rows do
	
		locale := tblTranslations.accessRow(row).itemObject.CM_Locale;
		translation := self.myTranslatableText.getTranslationText(locale, constantName, text, shortText);
				
		if text &lt;&gt; tblTranslations.accessCell(row, Col_Text).text then
			changesFound := true;
		endif;
		
		if self.myTranslatableText.usesShortText then
			if shortText &lt;&gt; tblTranslations.accessCell(row, Col_ShortText).text then
				changesFound := true;
			endif;
		endif;
		
	endforeach;

	if changesFound = false then
		return true;
	endif;
	
	// changes found
	flag := app.msgBox('Save changes?', caption, MsgBox_Yes_No_Cancel + MsgBox_Stop_Icon);

	if flag = MsgBox_Return_Yes then
		return doSave;
	elseif flag = MsgBox_Return_No then
		return true;
	endif;
	
	return false;
		

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
