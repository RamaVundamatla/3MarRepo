    <JadeMethod name="doResize" id="83415a0d-1d23-48f2-afa5-c0c3f68b1814">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/10/2008	consw1		SFW1030 - Rework of Yard Allocations
// 04/06/2021	navmd1		TFS 51320 - Add filter to Sys/Terminal Admin tables
// 06/12/2021   navlw1		TFS 52477 - Overlapping Labels
// ---------------------------------------------------------------------------
vars
	tmpLeft	: Real;
begin
	if lblTable.visible then
		lblTable.top 	:= self.frmToolbar.height + VerticalSpacing;
		cmbTable.top 	:= self.frmToolbar.height + VerticalSpacing;
		
		lblTable.left	:= WinLeftMargin;
		cmbTable.left	:= WinLeftMargin + lblTable.width + HorizontalSpacing;
//		chkShowNotAvail.move((cmbTable.left + cmbTable.width + 8), (cmbTable.top + 3), chkShowNotAvail.width, chkShowNotAvail.height);
		
		//25/06/2024	navkc1 CR 64823 Task 64824
		//lblFilterBox.top	:= lblTable.top;
		//txtFilterBox.top	:= cmbTable.top;
		
		//lblFilterBox.left	:= WinLeftMargin + cmbTable.left + cmbTable.width + HorizontalSpacing;
		//txtFilterBox.left	:= lblFilterBox.left + lblFilterBox.width + HorizontalSpacing;
		
		/*tmpLeft := lblFilterBox.left + lblFilterBox.width;
		if tmpLeft &lt; self.width then
			txtFilterBox.width := (self.width - tmpLeft).min(265) - 15;
			if self.useTblData then
				lblFilterBox.visible := true;
				txtFilterBox.visible := true;
			endif;
		else
			lblFilterBox.visible := false;
			txtFilterBox.visible := false;
		endif;
		*/
		//navlw1 tfs# 52477 06 Dec 2021
		if cmbTable.text = SOP_TableMaintForm.Table_WeightRange then
			self.lblWeightType.left := self.cmbTable.left + self.cmbTable.width + 10;
			self.cmbWeightType.left := self.lblWeightType.left + self.lblWeightType.width + 10;
			//self.lblFilterBox.left := self.cmbWeightType.left + self.cmbWeightType.width + 10;	//25/06/2024	navkc1 CR 64823 Task 64824
			//self.txtFilterBox.left := self.lblFilterBox.left + self.lblFilterBox.width + 10;	//25/06/2024	navkc1 CR 64823 Task 64824
		endif;
	endif;
	
	inheritMethod();
	
	self.btnAdvanced.move((self.clientWidth - btnAdvanced.width - 6), cmbTable.top, btnAdvanced.width, btnAdvanced.height);  // CNWAB1 METRO JMT

	if self.myCurrentTableItem &lt;&gt; null then 
		self.myCurrentTableItem.doResize();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="b1f9d553-852a-43fe-bc89-ce7b045366b6">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/08/2023	jlizm1		TFS 59549 Kiosk maintenance terms and conditions
// ---------------------------------------------------------------------------
vars
	trxResult		: Boolean;
	warningsResult	: Integer;
	terminal		: CM_Terminal;
begin
	executeWhen JMTDevelopmentEnvironment;
		terminal := self.getMyTerminal;
		if terminal &lt;&gt; null and terminal.code = "UT" then	//28.Jul.2023 navsp1 - Just for testing will remove it
			if app.msgBox('Please make sure to update it back after testing if it is a temporary change', 'Warning!', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then 
				return false;
			endif;
		endif;
	endExecuteWhen;
	
	if self.mode &lt;&gt; Mode_Add
	and self.mode &lt;&gt; Mode_Update
	then
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.mode.String &amp; ')');
		return false;
	endif;

	while true do
		trxResult := self.myCurrentTableItem.doSave();
		
		if trxResult then
			self.clearErrorWarnings();
			break;
		endif;

		// the ports give a special warning as a message box so
		// want to trap for that and break if user has pressed cancel. PAR12482
		if self.myCurrentTableItem.isKindOf(SOPTM_Port) or
			self.myCurrentTableItem.isKindOf(SOPTM_Kiosk) then
			if (not app.myPassport.hasErrorsOrWarnings()) then
				break;
			endif;
		endif;

		warningsResult := app.showErrorWarningDialog(self.myCurrentTableItem.name, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors and
		   warningsResult = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;

		break;
	endwhile;

	return trxResult;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSptMainMove" id="56928e43-1770-4b7c-a19e-80147a5fadcb">
