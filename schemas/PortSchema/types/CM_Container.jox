    <JadeMethod name="isOverDimensions" id="3a34b680-84eb-4343-bf0f-dbcc14d3f8dd">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isOverDimensions(set: Boolean; _value: Boolean io) updating, mapping;
// This is used by Invoice Mapping - do not delete (refer to method text)
// rs 21 Aug 2003 par 5688 this is no longer overridden on CM_Container
// an ISOtype is never Over Dimension but the cargo that is a specfic ti
// may be Over Dimension
//
// 09/03/2010	cnwdap1	PAR #22741 isOverDimensions made non-virtual
// 12 July 2017	jlgrh7 TFS #40020 STWR - Steinweg Rotterdam Over Dimension Tickbox Issue
vars

begin

	if set then
		//app.raiseSetVirtualError(class.name, method.name);	// PAR #22741
		inheritMethod(set, _value);
		return;
	endif;
	_value := false;	
	
	if self.overHeight = null and  self.overLengthFront  = null  and  self.overLengthRear = null and  self.overWidthRight = null and  self.overWidthLeft = null then				//+TFS40020 always retain as false if nothing in sizes
		return;
	endif;
	
	if self.height &gt; 0 or   self.width &gt; 0 or self.length &gt; 0  then
		_value := true;
		return;
	endif;
	
	// PAR #22741 include new over dimensions fields here
	if self.overHeight &gt; 0 or self.overLengthFront &gt; 0 or self.overLengthRear &gt; 0 or self.overWidthRight &gt; 0 or self.overWidthLeft &gt; 0 then
		_value := true;
		return;
	endif;
	

	/*//-TFS40020 
	if self.isOverDimensions then
		_value := true;
		return;
	endif;
	*/
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
