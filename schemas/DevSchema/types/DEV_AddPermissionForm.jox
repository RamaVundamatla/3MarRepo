    <JadeMethod name="addPictureToCombos2021" id="b5874067-6600-4c8d-bb9e-49db60b9840f">
        <source>addPictureToCombos2021(_pictureString : String);
/*
Purpose:			

Date		Who		Reason
21OCT2021	NAVAB1	TFS 50421
*/

vars
	thePicture : Binary;
	idx : Integer;
begin

	thePicture := app.myRoot.getConfig(_pictureString).Binary; 

	idx := self.cmbPicDown.addItem(_pictureString);
	self.cmbPicDown.itemPicture[idx] := thePicture;
	
	idx := self.cmbPicLeaf.addItem(_pictureString);
	self.cmbPicLeaf.itemPicture[idx] := thePicture;

	idx := self.cmbPicUp.addItem(_pictureString);
	self.cmbPicUp.itemPicture[idx] := thePicture;

end;</source>
        <Parameter name="_pictureString" type="String"/>
    </JadeMethod>
    <JadeMethod name="btnAddCatagory_click" id="7059ec20-c339-458b-8cda-b7cebc08a848">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddCatagory_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cataStr :String;
begin
	read cataStr;
	if cataStr &lt;&gt; null then
		cmbCatagory.addItem(cataStr);
		cmbCatagory.text := cataStr; 
	endif; 
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="4196eca1-4a24-4b32-9fc5-d0fb4e6ef127">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	modalResult := IDCANCEL;
	unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnMaintExpl_click" id="2edc4828-20d6-45d0-8519-6d33ab12ca96">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMaintExpl_click(btn: Button input) updating;
//----------------------------------------------------------------
//	Created:	29 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	title, explan, long, short : String;
begin
	long := "This permission allows users to update data in the screen for ";
	short := "Allows users to maintain ";
	
	title := self.txtHeading.text.trimBlanks();
	if title= "" then
		title := self.txtDescription.text;
	endif;
	
	title := self.removeStringsFromTitle(title);
	
	if title.length() &gt; (100 - short.length()) then
		explan := title;
	elseif title.length() &gt; (100 - long.length()) then
		explan := short &amp; title;
	else
		explan := long &amp; title;
	endif;
	
	self.txtExplanation.text := explan;


end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="61100a48-52a9-40aa-8a25-caf06b8483dd">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 Sep 2019	jlgdi1		45802	Added form type validation
// ---------------------------------------------------------------------------
vars

begin
	// ### JIRA 33501 16JAN2025 NAVAB1
	if not checkConstantName() then
		if self.isSystemModule then
			app.msgBox("You must enter a unique global constant name." &amp; CrLf &amp;
							"System License Modules should begin with 'Mod_'",
							"Global Constant Issue",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		elseif self.isSubscription() then
			app.msgBox("You must enter a unique global constant name." &amp; CrLf &amp;
							"Subscription License Modules should begin with 'Sub_'",
							"Global Constant Issue",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		else
			app.msgBox("You must enter a unique global constant name." &amp; CrLf &amp;
					"Permissions should not begin with 'Sub_' or 'Mod_'",
					"Global Constant Issue",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);

		endif;
		return;
	endif;
	// lstLicensePerm is not visible for SPECIAL licenses which are MODULE licenses
	if lstLicensePerm.visible = true and lstLicensePerm.selectedCount = 0 then
		app.msgBox("You must select at least 1 license module","Module Issue",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if (txtDescription.text = null) or (cmbCatagory.text = null)  or (txtConstName.text = null) then
		app.msgBox("You must enter a description, category and constant name","Incomplete user input",0);
		return;
	endif;
	
	if cmbPermType.text &lt;&gt; PermType_SpecialStr and cmbPermType.text &lt;&gt; PermType_SubscriptionsStr then	//04 Oct 2019	NDL	TFS 46169
		// 45802
		if cmbFormType.listIndex &lt; 0 then 
			app.msgBox("Form Type must be selected", "Incomplete user input", 0);
			return;
		endif;
	endif;
	
//	if checkUserInput then
		self.updatePermission();
		self.modalResult := IDOK;
		unloadForm;
//	else	
//		app.msgBox("You must enter all data before continuing","Incomplete user input",0);
//	endif;
	
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnViewExpl_click" id="78ea7b78-fe5a-41a6-89af-19681566a402">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnViewExpl_click(btn: Button input) updating;
//----------------------------------------------------------------
//	Created:	29 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	title, explan, long, short : String;
begin
	long := "This permission allows users to view data in the screen for ";
	short := "Allows users to view ";
	
	title := self.txtHeading.text.trimBlanks();
	if title= "" then
		title := self.txtDescription.text;
	endif;
	
	title := self.removeStringsFromTitle(title);
	
	if title.length() &gt; (100 - short.length()) then
		explan := title;
	elseif title.length() &gt; (100 - long.length()) then
		explan := short &amp; title;
	else
		explan := long &amp; title;
	endif;
	
	self.txtExplanation.text := explan;end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkConstantName" id="a7f70fb9-5338-4db7-934d-d766f1690017">
        <source>checkConstantName() :Boolean;
/*
Purpose:			
Date				Who			Reason
JUNE 2016		CNWAB1		Initial creation
*/

vars
	
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	constName,
	rtnStr,
	constantStr	: String;
	result			: Integer;	
	p : CM_PermissionObject;
begin
	
	category := currentSchema.getCategory(XLAT_Permissions);		
	constDict := category.getConstants();
	p := self.myPermissionObject;
	

	if p.myConstant = null then // ADD
		constName := txtConstName.text.trimBlanks();
		const := constDict[constName];
	
		if const &lt;&gt; null then
			return false;
		endif;
	
		// ### JIRA 33501 15JAN2025 NAVAB1
		if self.isSubscription then
			if constName[1:4] &lt;&gt; "Sub_" then
				return false;
			endif;
		elseif self.isSystemModule then
			if constName[1:4] &lt;&gt; "Mod_" then
				return false;
			endif;
		else
			if constName[1:4] = "Sub_" 
			or constName[1:4] = "Mod_" then
				return false;
			endif;
			
		endif;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkUserInput" id="f79dd360-2597-4325-8852-2b25b6ad23bc">
        <source>checkUserInput() :Boolean;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	

begin
	
	if (txtDescription.text = null) or (cmbCatagory.text = null)  or (txtConstName.text = null) then
		return false;
	else
		return true;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="disableModuleOnList" id="11fd958f-ce0c-47fe-bba7-cfe3b09a1425">
        <source>disableModuleOnList(_module : Integer);
/*
Purpose:	

Date		Who		Reason
08 January 2025	navab1	JIRA 33501
*/

vars
	licPerm : CM_PermissionObject;
	childIdx : Integer;
begin
	licPerm := self.getLicensePermByValue(_module);
	if licPerm &lt;&gt; null then
		childIdx := lstLicensePerm.findObject(licPerm);
		if childIdx &gt; 0 then
			lstLicensePerm.itemEnabled[childIdx] := false;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_module" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLicensePermByValue" id="cc5eb018-acfd-4bb0-bbc2-639a8094a0db">
        <source>getLicensePermByValue(_value : Integer) : CM_PermissionObject;
// ---------------------------------------------------------------------------
// Created:     26 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.allLicensePermsByValue[_value];

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="CM_PermissionObject"/>
    </JadeMethod>
    <JadeMethod name="init" id="7edf89f7-d830-4269-ba6f-c47beb1cf096">
        <updating/>
        <source>init() updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
//
// Changed On   Changed By  TFS		Reason
// ----------   ----------  --------------------------------------------------
// 03 Sep 2019	jlgdi1		45802	Set the value of the Form Type combo box
// ---------------------------------------------------------------------------
vars
	permObj,
	licPerm		: CM_PermissionObject;
	childIdx,
	tmpChildValue	: Integer;
begin

	self.modalResult := IDCANCEL;
	
	permObj := self.myPermissionObject;

	self.initCmbPermType();
	if self.isSystemModule or self.isSubscription then	//16 Jun 2020	NDL	TFS 49569
		self.cmbFormType.visible := false;
		self.lblFormType.visible := false;
		self.lstApps.visible := false;
		self.grpMenuDtls.visible 	:= false;
		self.grpMenuDtls.enabled 	:= false;
		self.lstLicensePerm.visible	:= false;
		self.lblLicensePerm.visible	:= false;
		self.lblApps.visible	:= false;
		self.cbIsInternal.visible	:= false;
		if self.isSubscription then
			self.cmbCatagory.enabled := false;
			self.btnAddCatagory.visible := false;
			self.label4_1_1_1.visible := false;
			self.label4_1_1.visible := false;
			self.lblWebservices.visible := false;
			self.lblHHApp.visible := false;
			self.btnViewExpl.visible := false;
			self.btnMaintExpl.visible := false;
		endif;
	else
		self.initCmbFormType();
		self.cmbFormType.visible := true;
		self.lblFormType.visible := true;
		self.lstApps.visible := true;
		self.grpMenuDtls.enabled 	:= true;
		self.lstLicensePerm.visible	:= true;
		self.lblLicensePerm.visible	:= true;
		self.lblApps.visible	:= true;
		self.initLstLicensePerm();
		self.cbIsInternal.visible	:= true;
	endif;
	

	txtId.enabled := false;
	
	//display permission  object attribs
	if permObj &lt;&gt; null then
		txtConstName.text 		:= permObj.constName; 
		txtValue.text 			:= permObj.constValue.String;
		self.txtExplanation.text := permObj.explanation;
		cmbCatagory.text 		:= permObj.category;
		txtDescription.text 	:= permObj.description;
		cbIsInternal.value 		:= permObj.isInternal;
		cmbPermType.text 		:= global.permTypeToString(permObj.permType);
		cmbFormType.text := global.formTypeToString(permObj.formType);		// 45802
		
		// ### JIRA 33501 08JAN2025 NAVAB1 - do not let a permission be added to these modules
		if self.updating then
			self.disableModuleOnList(Mod_DutyDoc);
			self.disableModuleOnList(Mod_Logs);
		endif;
		
		
		if (not self.isSystemModule) and (not self.isSubscription) then
			if (not permObj.allChildValues.isEmpty) then
				foreach tmpChildValue in permObj.allChildValues do
					licPerm := self.getLicensePermByValue(tmpChildValue);
					if licPerm &lt;&gt; null then
						childIdx := lstLicensePerm.findObject(licPerm);
						if childIdx &gt; 0 then
							lstLicensePerm.itemSelected[childIdx] := true;
							lstLicensePerm.itemEnabled[childIdx] := true; // ### JIRA 33501 08JAN2025 NAVAB1 being used already so enable
						endif;
					endif;
				endforeach;
			endif;
		endif;

		txtActionClass.text		:= permObj.actionClass;
		txtExtraTblDef.text		:= permObj.extraTableDef;
		txtHeading.text			:= permObj.heading;
		txtId.text				:= permObj.id;
		txtMainTblDef.text		:= permObj.mainTableDef;
		txtSchemaName.text		:= permObj.schemaName;
		txtWindowClass.text		:= permObj.windowClass;

		txtAttr1.text			:= permObj.attr1;
		txtParam1.text			:= permObj.param1;
		
		if txtActionClass.text = null then
			txtActionClass.text := 'CMUI_MenuAction';
		endif;
		
	endif;
	self.cmbPicLeaf.fontSize := 20;
	self.cmbPicDown.fontSize := 20;
	self.cmbPicUp.fontSize := 20;
	self.initMobileApps;
	self.initWebservices;
	 // ### TFS 50421 20OCT2021 NAVAB1 self.loadPictures();
	 self.loadPictures2021(); // ### TFS 50421 20OCT2021 NAVAB1
	 
	 self.cmbPicDown.visible := false; // TFS 50421
	 self.cmbPicLeaf.visible := false; // TFS 50421
	 self.lblLeafPic.visible := false; // TFS 50421
	 self.lblToolbarPicDow.visible := false; // TFS 50421
	 
end;</source>
    </JadeMethod>
    <JadeMethod name="initCmbFormType" id="b8a233f1-b63e-4b2a-83db-758bcfebe3f9">
        <source>initCmbFormType();
/*

Purpose: Initialized the Form Type combo box

Parameters:			

Return Value:		

Date		Who		TFS		Reason
03 Sep 2019	jlgdi1	45802	Initial creation

*/
begin
	self.cmbFormType.sorted := false;
	self.cmbFormType.clear();
	self.cmbFormType.addItem(ViewTypeStr);
	self.cmbFormType.addItem(MaintenanceTypeStr);	
end;</source>
    </JadeMethod>
    <JadeMethod name="initCmbPermType" id="bcf14644-5091-4335-b1e4-4ae8d9151397">
        <source>initCmbPermType();
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	cmbPermType.clear;
	
	if self.isSubscription then	//16 Jun 2020	NDL	TFS 49569
		cmbPermType.addItem(PermType_SubscriptionsStr);
	elseif self.isSystemModule then // ### JIRA 33501 16JAN2025 NAVAB1
		cmbPermType.addItem(PermType_SpecialStr);
	else
		cmbPermType.addItem(PermType_TerminalStr);
		cmbPermType.addItem(PermType_SystemStr);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="initLstLicensePerm" id="4243568f-013e-4c3a-b1e7-23312de5f734">
        <updating/>
        <source>initLstLicensePerm() updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	permAgent	: CM_PermissionAgent;
	permObj : CM_PermissionObject;
begin

	lstLicensePerm.clear();

	permAgent := self.myLicensePermissionAgent;
	//permAgent.populatePermissionDict(false, false);	// only PermType_Special
	permAgent.getPermDictWithoutNumbers(self.allLicensePermsByName,false);
	
	permAgent.allPermissionsByName.copy(self.allLicensePermsByValue);

	// ### JIRA 33501 08JAN2025 NAVAB1
	if not self.updating then // adding
		self.removeModuleFromList(Mod_DutyDoc);
		self.removeModuleFromList(Mod_Logs);
	endif;
	
	/* // ### JIRA 33501 04DEC2024 NAVAB1
	//jlier1 TFS  55404 30/11/22
	create self.mySubsriptionAgent transient;
	self.mySubsriptionAgent.populatePermissionDict(false,false,PermType_Subscriptions);
	self.mySubsriptionAgent.allPermissionsByName.copy(self.allLicensePermsByValue);
	self.mySubsriptionAgent.allPermissionsByName.copy(self.allLicensePermsByName);
	*/
	
	lstLicensePerm.listCollection(self.allLicensePermsByName, false, 0);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initMobileApps" id="e231d7e7-c110-43da-8d4a-6c4c6c008a3c">
        <source>initMobileApps();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2018	jlger1	Initial creation

*/

vars
	allMobileApps : StringArray;
	appName : String;
	idx 	: Integer;
begin
	create allMobileApps transient;
	self.myLicensePermissionAgent.getAllMobileApps(allMobileApps);

	foreach appName in allMobileApps do
		idx :=lstApps.addItem(appName);
		if self.myPermissionObject &lt;&gt; null then
			if self.myPermissionObject.allMobileApps.includes(appName) then
				lstApps.itemSelected[idx]:=true;
			endif;
		endif;
	endforeach;
	
epilog
	delete allMobileApps;
end;</source>
    </JadeMethod>
    <JadeMethod name="initWebservices" id="d2312e41-8abe-4c6a-b44e-3d43fd09eea2">
        <source>initWebservices();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2018	jlger1	Initial creation

*/	
vars

	keyword : String;
	
begin	
	self.lblWebservices.caption:="NONE";
	if self.myPermissionObject &lt;&gt; null then
		keyword:= self.myPermissionObject.allWebservices.concatenate(", ");
		self.lblWebservices.caption:=keyword;
		if keyword = null then
			self.lblWebservices.caption:="NONE";
		endif;
	endif;
	self.lblHHApp.caption:="NONE";
	if self.myPermissionObject &lt;&gt; null then
		keyword:= self.myPermissionObject.allHandheldApps.concatenate(", ");
		self.lblHHApp.caption:=keyword;	
		if keyword = null then
			self.lblHHApp.caption:="NONE";
		endif;
	endif;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="isSubscription" id="91cbd079-1259-47dd-9b36-12b05fc2c5bc">
        <source>isSubscription():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

begin

	return self.currentMode = DEV_ErrorMsgFrm.Mode_Subscriptions;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSystemModule" id="eec72759-ed7a-4b9b-8a4e-6abdce22790a">
        <methodInvocation>mapping</methodInvocation>
        <source>isSystemModule(set : Boolean; _value : Boolean io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2020	jlgndl1	Initial creation
// ### JIRA 33501 16JAN2025 NAVAB1 changed name to make clearer
*/

vars

begin

	if not set then
		_value := ( self.currentMode = DEV_ErrorMsgFrm.Mode_SpecialPermissions );
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
