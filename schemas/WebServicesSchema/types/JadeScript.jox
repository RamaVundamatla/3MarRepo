    <JadeMethod name="koFindGConsts" id="ede6ea44-9b27-47c6-976c-03915763602e">
        <source>koFindGConsts();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2008	cnwkao1	Initial creation

*/
constants
	KeywordLower	: String = "foreground";
	ConstCategory	: String = EntTableRows;
vars
	gConst : GlobalConstant;
begin
	foreach gConst in GlobalConstant.instances where gConst.getPropertyValue(GlobalConstant::category.name).ConstantCategory.name = ConstCategory do
		/*
		if gConst.name.toLower().pos(KeywordLower, 1) &lt;&gt; 0 then
			write gConst.name &amp; " = " &amp; gConst.source;			
		endif;
		*/
		
		if gConst.getSource.toLower().pos(KeywordLower, 1) &lt;&gt; 0 then
			write gConst.name &amp; " = " &amp; gConst.getSource;			
		endif;
		
	endforeach;
end;</source>
    </JadeMethod>
