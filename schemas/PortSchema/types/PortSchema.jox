    <JadeMethod name="deliveryReasonEnumToString" id="b4db09c3-23c0-478a-b877-2cac261d0fa2">
        <source>deliveryReasonEnumToString(_value : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	reason: CM_DeliveryReleaseReason;
begin

	// Check User reasons PAR 21885
	if _value &gt; app.getDeliveryRelReasonUserOffset then
		reason := app.myRoot.allDeliveryReasonselReasons[_value - app.getDeliveryRelReasonUserOffset];
		if reason &lt;&gt; null then
			return reason.description;
		endif;
	endif;
	
	if _value = DEL_IST then
		return DELSTR_IST;
	elseif _value = DEL_NIB then
		return DELSTR_NIB;
	elseif _value = DEL_RPK then
		return DELSTR_RPK;
	elseif _value = DEL_SNT then
		return DELSTR_SNT;
	elseif _value = DEL_TSC then
		return DELSTR_TSC;
	elseif _value = DEL_PEX then
		return DELSTR_PEX;
	else
		return DELSTR_NULL;
	endif;
    
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="deliveryReasonStringToEnum" id="935e3c71-81e5-417a-a2a9-398c7d4c4e81">
        <source>deliveryReasonStringToEnum(_value : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	reason: CM_DeliveryReleaseReason;
begin
	if _value = DELSTR_IST then
		return DEL_IST;
	elseif _value = DELSTR_NIB then
		return DEL_NIB;
	elseif _value = DELSTR_RPK then
		return DEL_RPK;
	elseif _value = DELSTR_SNT then
		return DEL_SNT;
	elseif _value = DELSTR_TSC then
		return DEL_TSC;
	elseif _value = DELSTR_PEX then
		return DEL_PEX;
	else
		// Check the user defined reasons PAR 21855
		foreach reason in app.myRoot.allDeliveryReasonselReasons do
			if reason.description = _value then
				return reason.id + app.getDeliveryRelReasonUserOffset;
			endif;
		endforeach;
		return DEL_NULL;
	endif;

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDumpStack" id="bba1c7df-8688-424c-adcb-1c17f6832fc9">
        <source>doDumpStack(exObj: Exception);
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stackDump	: CnStackDump;
	cc  		: CnCntrl;
	saveMini	: Boolean;
begin

	if exObj = null then
		return;
	endif;

	cc 	:= app.myCnCntrl;
	if cc = null then 
		// error to protect against par 11410 
		app.writeLog('No CnCntrl on app!!!', LogINFO);
		return;
	endif;

	saveMini := cc.logMiniStackDump;
	
	if DeadlockException.hasInstance(exObj) then
		// only do a mini-stackdump for deadlocks (rjs 27Apr04)
		cc.setLogMiniStackDump(true);
	endif;

	create stackDump transient;
	
	stackDump.dumpStack(exObj);
	
epilog
	if cc &lt;&gt; null then 
		cc.setLogMiniStackDump(saveMini);
	endif;
	
	delete stackDump;
	
end;</source>
        <Parameter name="exObj" type="Exception"/>
    </JadeMethod>
    <JadeMethod name="doDumpStackAsHugeStingArray" id="88124ea7-91a6-41d3-b526-61ca315082c7">
        <source>doDumpStackAsHugeStingArray(exObj : Exception; _array : HugeStringArray input);
// ---------------------------------------------------------------------------
// Created:     15 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	msgStr			: String;
	callStack 		: ProcessStackArray;
	methCallDesc	: MethodCallDesc;
	lockEx			: LockException;
	dlockEx			: DeadlockException;
	sourceStr		: String;
	aPos			: Integer;
	exPos			: Integer;
	nextLF			: Integer;
	aStr 			: String;
	aTime 			: TimeStamp;

begin

	if exObj = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'exObj', null, null);
		return;
	endif;

	if _array = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_array', null, null);
		return;
	endif;


	//----------------
	//Add this stuff as additional details
	//----------------
	msgStr := "Exception Info follows... Exception is of type :" &amp; exObj.String;
	_array.add(msgStr);
	if exObj.currentMethodDesc &lt;&gt; null then
		msgStr := "Current method :" &amp; exObj.currentMethodDesc.display;
		_array.add(msgStr);
		msgStr := "Current method position :" &amp; exObj.currentMethodDesc.position.String;
		_array.add(msgStr);
		msgStr := "Exception occurred on Object :" &amp; exObj.errorObject.String;
		_array.add(msgStr);
		//-------------------------
		//Now, work out the line method source
		//-------------------------
		//if exObj.currentMethodDesc.method.isKindOf(JadeMethod) then
			/*
			sourceStr := exObj.currentMethodDesc.method.getPropertyValue("source").String;
 			if sourceStr &lt;&gt; null then
 				//Search BACKWARDS from position to find first lf
 				exPos := exObj.currentMethodDesc.position;
 				aPos := exPos;
				_array.add("Code @ Pos (First pos for 10 chars) " &amp; sourceStr[exPos:10]);
				while true do 
					if aPos &lt; 0 then 
						break;
					endif;
					if sourceStr[aPos:1] = Lf then
						nextLF := (sourceStr.pos(Cr, exPos) -1) - aPos;
						sourceStr := sourceStr[aPos +1 : nextLF];
						_array.add("Code line " &amp; sourceStr);
						break;
					endif;					
					aPos := aPos -1;
				endwhile;
 			endif;
 			*/
			create callStack;
			//-------------
			// get the stack for the current process
			//-------------
			process.currentStack(callStack);
			//-------------
			// cut back the stack to the current method
			//-------------
			while callStack.size &gt; 0 and callStack[1].method &lt;&gt; exObj.currentMethodDesc.method do
				delete callStack.removeAt(1);		// PAR #18009
			endwhile;
			//-------------
			//Add the call stack to the alert
			//-------------
			_array.add("System Call Stack follows...");
			foreach methCallDesc in callStack do
				_array.add(methCallDesc.display());
			endforeach;
 		//endif;
	endif;
	msgStr := "Error Item : " &amp; exObj.errorItem;
	_array.add(msgStr);
	msgStr := "Extended Error Text : " &amp; exObj.extendedErrorText;
	_array.add(msgStr);
	//------------------
	//If a lock exception, try and give more details
	//------------------
	if exObj.isKindOf(LockException)  then
		lockEx := exObj.LockException;
		if lockEx.lockType = Share_Lock then
			msgStr := " Share_Lock ";
		elseif lockEx.lockType =  Reserve_Lock then
			msgStr := " Reserve_Lock ";
		elseif lockEx.lockType =  Exclusive_Lock then
			msgStr :=  " Exclusive_Lock ";
		endif;
		//getOidStringForObject gets the oid out of the buffer, using .string may fail!
		msgStr := msgStr &amp; " Of Object :" &amp; getOidStringForObject(lockEx.lockTarget); //getName;
		if lockEx.targetLockedBy &lt;&gt; null then
			msgStr := msgStr &amp; " By " &amp; lockEx.targetLockedBy.userCode &amp; " " &amp; lockEx.targetLockedBy.userInfo;
		else
			msgStr := msgStr &amp; " By unknown user";
		endif;
		process.getLockDuration(lockEx.lockTarget, aTime, aStr);

		msgStr := msgStr &amp; " Locked on" &amp; aTime.display &amp; " for " &amp; aStr;
		_array.add(msgStr);

	elseif exObj.isKindOf(DeadlockException) then
		dlockEx := exObj.DeadlockException;
		if dlockEx.lockType = Share_Lock then
			msgStr := " DeadLock Share_Lock ";
		elseif dlockEx.lockType =  Reserve_Lock then
			msgStr := " DeadLock Reserve_Lock ";
		elseif dlockEx.lockType =  Exclusive_Lock then
			msgStr :=  " DeadLock Exclusive_Lock ";
		endif;
		//getOidStringForObject gets the oid out of the buffer, using .string may fail!
		msgStr := msgStr &amp; " Of Object :" &amp; getOidStringForObject(dlockEx.lockTarget); //getName;
		if dlockEx.targetLockedBy &lt;&gt; null then
			msgStr := msgStr &amp; " By " &amp; dlockEx.targetLockedBy.userCode &amp; " " &amp; dlockEx.targetLockedBy.userInfo;
		else
			msgStr := msgStr &amp; " By unknown user";
		endif;
		process.getLockDuration(dlockEx.lockTarget, aTime, aStr);

		msgStr := msgStr &amp; " DeadLocked on" &amp; aTime.display &amp; " for " &amp; aStr;
		_array.add(msgStr);
	endif;
	if exObj.reportingMethodDesc &lt;&gt; null then
		msgStr := "Reporting Method Desc : " &amp; exObj.reportingMethodDesc.display;
		_array.add(msgStr);
		msgStr := "Reporting Method line # : " &amp; exObj.reportingMethodDesc.position.String;
		_array.add(msgStr);
		//msgStr := "Reporting Method receiver : " &amp; exObj.reportingMethodDesc.receiverAsString;
		_array.add(msgStr);
	endif;
	msgStr := "Description : " &amp; exObj.text;
	_array.add(msgStr);

epilog
	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;	
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLogging" id="4c8ffb4c-4116-4a7f-9f1d-8b73e58d1d67">
        <source>doFormLogging( _source : Method; _str : String; _logLevelStr : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2011	cnwndl1	Initial creation

*/

vars

	invalidObject : Boolean;

begin

	if self.myLoggingForm = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myLoggingForm, invalidObject );

	self.myLoggingForm.sendMsgWithParams("addOutput",_source,_str,_logLevelStr);

epilog

end;</source>
        <Parameter name="_source" type="Method"/>
        <Parameter name="_str" type="String"/>
        <Parameter name="_logLevelStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doResetForLogout" id="71687527-622f-498f-9ce0-07f386c32a90">
        <updating/>
        <source>doResetForLogout() updating;

/*

Purpose:			Clear/reset any properties prior to a logout, to ensure nothing is carried over
					to a new session in a logout/login situation

Parameters:			None

Return Value:		None


Date		Who		Reason
01 Jul 2008	cnwkpd1	PAR #16757 - Prevent logout exceptions
21 Jan 2019	jlgmd1	TFS #43007 - Remove Teklogix

*/

vars

begin
	self.allReportTIs.clear;
	self.setMyCurrentVoyage(null);
//	app.setTheCurrentBank(null);	//18 Apr 2012	NDL	Par 29393
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="dssExceptionHandler" id="71fba88b-671a-487d-9906-c84e24e909ac">
        <source>dssExceptionHandler(dssexception: Exception): Integer;
begin

	if dssexception.errorCode = 4037 then
		if dssexception.errorItem = "dbinit" or dssexception.errorItem = "dbexit" then
			app.msgBox("Please install the SQL Server Client software and try again.", "SQL Server client not installed!", MsgBox_OK_Only);
			terminate;
		endif;
	else
		
		// AKB Added 29/12/2000
		// AllowInvalidTransientSharing=true added to INI,` Since Jade5108 sharing nonshared transients is not allowed, so we now get exception when sharing non shared transient object (mgrSQLServer)
		// if this is not in the INI an exception will be delivered here
	    app.msgBox("dssExceptionHandler. ErrorCode: " &amp; dssexception.errorCode.String &amp; 
	               " dssexception.errorItem: "  &amp; dssexception.errorItem.String &amp; ", Terminating", "DSS Exception", MsgBox_OK_Only);
			terminate;
	endif;

	return Ex_Abort_Action;
end;</source>
        <Parameter name="dssexception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dualInverseExceptionHandler" id="0400076e-d593-42c7-89f1-d87e1ef5c24e">
        <updating/>
        <source>dualInverseExceptionHandler(_exc : Exception) : Integer updating ;

/*
Date		Who		Reason
3 Sep 2008	cnwdz2	Par17801 handl error 1210: Duplicated relationship reference.
*/
constants
	DualInverse	= 1210;
	
vars
	returnVal		: Integer;
	
begin
	if _exc.errorCode = DualInverse then
		returnVal := Ex_Resume_Next;
	else
		returnVal := Ex_Pass_Back;
	endif;
	
epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="emailArchitectSetLicenseOAuth" id="792a572b-ea4b-44dd-90e1-1b0e1506a03a">
        <source>emailArchitectSetLicenseOAuth(_emailClient : JadeDotNetType input; _terminal : CM_Terminal) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/07/2020	jlgdap1		Initial creation TFS 49764 MTN Retire Basic Authentication to Exchange Online
// 17/01/2024	navmd1		TFS 55021 EASendMail Refactor
//
vars
	licType	: Integer;

begin
	// If we're reading emails, this is done using Terminal level config options
	// If we're sending email, this is done with Root level config options
	if _emailClient.isKindOf(EAGetMailSupportClass) then
		licType := _terminal.getEmailLicenseType();
	else
		licType := app.myRoot.getEmailLicenseType();
	endif;

	/* This application utilizes a licensed copy of ADS Objects. ADS
	Objects is copyrighted and owned exclusively by ADMINSYSTEM SOFTWARE
	LIMITED. All rights reserved. Use of the objects outside of the
	context of this application is a violation of federal copyright laws
	and international treaty provisions */
	
	if licType = EmailLicenseType_2 or licType = EmailLicenseType_3 then // ### TFS 51526 23Feb2022 NAVPW1
		if _emailClient.isKindOf(EASendMailSupportClass) then
			return EmailArchitectSendLicenseKey;	//"ES-D1508812687-00850-CACTUADE8161T4B4-E45E7196A5CCE2C8"
		elseif _emailClient.isKindOf(EAGetMailSupportClass) then
			return EmailArchitectReadLicenseKey;	//"EG-C1508812802-00329-C123B26U83BCD3FB-7666DBF86CV3D5AE"
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_emailClient" type="JadeDotNetType" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
