    <JadeMethod name="getTaxCodesForCharges" id="20b568bc-4c32-484a-9c3a-4033944a0dfd">
        <source>getTaxCodesForCharges(_taxCodes : StringArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export
20-04-2023 	navtnr20 Task 57620: EUP - Invoice Line Type / Services Configuration Updated Requirements
*/

vars
	charge : CM_Charge;
	taxStr : String;
begin
	_taxCodes.clear();
	foreach charge in self.charges do
		// ### TFS 55744 06DEC2022 NAVAB1
		taxStr:= charge.getTaxDescription(false);
		if taxStr &lt;&gt; null then //navtnr20 20-04-2023 TFS 57620
			if _taxCodes.cnFind(taxStr) = 0 then	//navtnr20 20-04-2023 TFS 57620
				_taxCodes.add(taxStr);
			endif;
		endif;
 // ### TFS 55744 06DEC2022 NAVAB1		_taxAmount.add(charge.getTaxAmountForCharge());
	endforeach;
epilog

end;</source>
