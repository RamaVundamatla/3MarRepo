	commitTransaction;
	
	beginTransaction;
	foreach isoType in CM_ISOType.instances discreteLock do
	
		if isoType.colour = 0 then
		
			colourInt := app.randomRange(0, 16777215);
			isoType.setPropertyValue("colour", colourInt);
		
		endif;
	
	endforeach;
	commitTransaction;
	
	beginTransaction;
	foreach jobType in CM_JobType.instances discreteLock do
	
		if jobType.colour = 0 then
		
			colourInt := app.randomRange(0, 16777215);
			jobType.setPropertyValue("colour", colourInt);
		
		endif;
	
	endforeach;
	commitTransaction;
	
	
	beginTransaction;
	foreach operator in CM_Operator.instances discreteLock do
	
		if operator.colour = 0 then
		
			colourInt := app.randomRange(0, 16777215);
			operator.setPropertyValue("colour", colourInt);
		
		endif;
	
	endforeach;
	commitTransaction;

	beginTransaction;
	foreach port in CM_Port.instances discreteLock do
	
		if port.colour = 0 then
		
			colourInt := app.randomRange(0, 16777215);
			port.setPropertyValue("colour", colourInt);
		
		endif;
	
	endforeach;
	commitTransaction;
	
	beginTransaction;
	foreach weightRange in CM_WeightRange.instances discreteLock do
	
		if weightRange.colour = 0 then
		
			colourInt := app.randomRange(0, 16777215);
			weightRange.setPropertyValue("colour", colourInt);
		
		endif;
	
	endforeach;
	commitTransaction;
	
	

epilog


end;
