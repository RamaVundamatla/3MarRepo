    <JadeMethod name="adjustFormForDevice" id="f733cefe-1736-4be1-9bda-d3e1fbe9d168">
        <updating/>
        <source>adjustFormForDevice() updating, protected;
// ---------------------------------------------------------------------------
// Created:	13 August 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	scaleFactorX : Real;
	scaleFactorY : Real;
begin
	if self.width &gt; 650.0 then
		return;
	endif;
	inheritMethod;
	scaleFactorX :=  self.width / 650.0;
	scaleFactorY :=  self.height / 450.0;
/*
	app.msgBox( "H W L T" &amp; CrLf &amp; "Form " &amp; self.height.asStringJMT &amp; " " &amp; self.width.asStringJMT &amp; " " &amp; self.left.asStringJMT &amp; " " &amp; self.top.asStringJMT
	&amp; CrLf &amp; "Frame " &amp; frm_Logon.height.asStringJMT &amp; " " &amp; frm_Logon.width.asStringJMT &amp; " " &amp; frm_Logon.left.asStringJMT &amp; " " &amp; frm_Logon.top.asStringJMT
	&amp; CrLf &amp; "txt Heights " &amp; txtUserName.height.asStringJMT &amp; " " &amp; txtPassword.height.asStringJMT
	&amp; CrLf &amp; "BtnOK " &amp; btnOK.height.asStringJMT &amp; " " &amp; btnOK.width.asStringJMT &amp; " " &amp; btnOK.left.asStringJMT &amp; " " &amp; btnOK.top.asStringJMT
	&amp; CrLf &amp; "BtnCancel " &amp; btnCancel.height.asStringJMT &amp; " " &amp; btnCancel.width.asStringJMT &amp; " " &amp; btnCancel.left.asStringJMT &amp; " " &amp; btnCancel.top.asStringJMT, "Form Size", MsgBox_OK_Only );
*/	
	txtPassword.top := (txtPassword.top*scaleFactorY).roundedUp+15;
	txtPassword.left := (txtPassword.left*scaleFactorX).roundedUp+20;
	txtPassword.height := (txtPassword.height*scaleFactorY).truncated;	
	txtPassword.width := (txtPassword.width*scaleFactorX).roundedUp;
	txtPassword.fontSize := (txtPassword.fontSize*scaleFactorY).roundedUp;
	
	txtUserName.top := (txtUserName.top*scaleFactorY).roundedUp;
	txtUserName.left := (txtUserName.left*scaleFactorX).roundedUp+20;
	txtUserName.height := (txtUserName.height*scaleFactorY).truncated;	
	txtUserName.width := (txtUserName.width*scaleFactorX).roundedUp;
	txtUserName.fontSize := (txtUserName.fontSize*scaleFactorY).roundedUp;
	
	lblPassword.top := (lblPassword.top*scaleFactorY).roundedUp+15;
	lblPassword.left := (lblPassword.left*scaleFactorX).roundedUp;
	lblPassword.height := (lblPassword.height*scaleFactorY).roundedUp;	
	lblPassword.width := (lblPassword.width*scaleFactorX).roundedUp+15;
	lblPassword.fontSize := (lblPassword.fontSize*scaleFactorY).roundedUp;
	
	lblUserName.top := (lblUserName.top*scaleFactorY).roundedUp;
	lblUserName.left := (lblUserName.left*scaleFactorX).roundedUp;
	lblUserName.height := (lblUserName.height*scaleFactorY).roundedUp;	
	lblUserName.width := (lblUserName.width*scaleFactorX).roundedUp;
	lblUserName.fontSize := (lblUserName.fontSize*scaleFactorY).roundedUp;
	
	btnCancel.top := (btnCancel.top*scaleFactorY).roundedUp;
	btnCancel.left := (btnCancel.left*scaleFactorX).roundedUp;
	btnCancel.height := (btnCancel.height*scaleFactorY).roundedUp;	
	btnCancel.width := (btnCancel.width*scaleFactorX).roundedUp;
	btnCancel.fontSize := (btnCancel.fontSize*scaleFactorY).roundedUp;
	
	btnOK.top := (btnOK.top*scaleFactorY).roundedUp;
	btnOK.left := (btnOK.left*scaleFactorX).roundedUp;
	btnOK.height := (btnOK.height*scaleFactorY).roundedUp;
	btnOK.width := (btnOK.width*scaleFactorX).roundedUp;
	btnOK.fontSize := (btnOK.fontSize*scaleFactorY).roundedUp;
	
/*	
	app.msgBox( "H W L T" &amp; CrLf &amp; "Form " &amp; self.height.asStringJMT &amp; " " &amp; self.width.asStringJMT &amp; " " &amp; self.left.asStringJMT &amp; " " &amp; self.top.asStringJMT
	&amp; CrLf &amp; "Frame " &amp; frm_Logon.height.asStringJMT &amp; " " &amp; frm_Logon.width.asStringJMT &amp; " " &amp; frm_Logon.left.asStringJMT &amp; " " &amp; frm_Logon.top.asStringJMT
	&amp; CrLf &amp; "txt Heights " &amp; txtUserName.height.asStringJMT &amp; " " &amp; txtPassword.height.asStringJMT
	&amp; CrLf &amp; "BtnOK " &amp; btnOK.height.asStringJMT &amp; " " &amp; btnOK.width.asStringJMT &amp; " " &amp; btnOK.left.asStringJMT &amp; " " &amp; btnOK.top.asStringJMT
	&amp; CrLf &amp; "BtnCancel " &amp; btnCancel.height.asStringJMT &amp; " " &amp; btnCancel.width.asStringJMT &amp; " " &amp; btnCancel.left.asStringJMT &amp; " " &amp; btnCancel.top.asStringJMT, "Form Size", MsgBox_OK_Only );
*/	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
