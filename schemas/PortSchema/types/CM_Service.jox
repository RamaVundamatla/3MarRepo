    <JadeMethod name="getPaymentType" id="f2cdf935-f55b-41eb-870f-5f9f4f215faa">
        <source>getPaymentType( _dr : CM_Debtor ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281
19 Oct     2018 cnwma1 ChangeRequest 41281: PEL1 - Payment Method on Services
*/

vars

	payTypeMapping : CM_ServicePayTypeMapping;
	defaultDebtor  : CM_Debtor;
begin

	if _dr &lt;&gt; null  then
		payTypeMapping := self.bank.getServicePayTypeMapping( self, _dr, true );	 // this debtor or otherwise the default debtor.
		if payTypeMapping &lt;&gt; null then
			return payTypeMapping.paymentType;
	//24 Oct 2018	NDL	TSF 41281 - call needs to be mopre generic, moved to getServicePayTypeMapping
	/*	else
			// 19.10.2018 cnwma1 TFS # 
			defaultDebtor := app.myRoot.getDefaultDebtor(null);
			payTypeMapping := self.bank.getServicePayTypeMapping( self, defaultDebtor );
			if payTypeMapping &lt;&gt; null then
				return payTypeMapping.paymentType;
			else
				return _dr.getDefaultPaymentType( self.getMyTerminal );
			endif; */
		else
			return _dr.getDefaultPaymentType( self.getMyTerminal );
		endif; 
	endif;
	
	return 0;

epilog

end;</source>
        <Parameter name="_dr" type="CM_Debtor"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTaxCodeForPayment" id="9969afbd-970c-4b33-8b5a-c7d96c8e23a5">
        <source>getTaxCodeForPayment(_description: Boolean) : String;
/*
Purpose:	TFS 44275		
Date				Who			Reason
MAY 2019		JLGAB1 initial creation
*/


vars
	taxCode : String;
	theBank : CM_Bank;
begin
	theBank := self.bank;
	
	if self.myTaxCode&lt;&gt; null then
	   if _description then
			taxCode := self.myTaxCode.description;
		else
			taxCode := self.myTaxCode.code;
		endif;
	else
		taxCode := "";
	endif;
	
	
	return taxCode;
end;</source>
        <Parameter name="_description" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxRate" id="f5678795-7415-41be-8f83-ab94bc4d6062">
        <source>getTaxRate(_debtor : CM_Debtor; _effectiveDate : TimeStamp) : Real;
/*
Purpose:			
Date				Who			Reason
NOV 2017		CNWAB1		Initial creation
*/

vars
	taxCode : CM_TaxCode;
	taxRateAmount : Real;
	taxRateObject : CM_TaxRate;
	theInvoice : CM_Invoice;
	theBank : CM_Bank;
begin
	theBank := self.bank;
	
	if _debtor &lt;&gt; null and _debtor.isZeroRatedTax then
		return 0;
	endif;


	if theBank.terminal.getConfig(InvoiceMultiTaxRates).Boolean then
		
		taxCode := self.myTaxCode;

		if taxCode &lt;&gt; null then
			taxRateObject := taxCode.getTimeRate(_effectiveDate);
			if taxRateObject &lt;&gt; null then
				taxRateAmount := taxRateObject.rate;
			else
				taxRateAmount := 0;
			endif;
		endif;
	else
		taxRateAmount := theBank.taxPercentageRate;
	endif;
	

	return taxRateAmount;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_effectiveDate" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
