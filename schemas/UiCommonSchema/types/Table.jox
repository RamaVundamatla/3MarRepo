<GUIClass name="Table">
    <Constant name="AllValues" id="1fff3dfc-fa2f-4df7-af47-452f95143c23">
        <source>"- All -"</source>
        <type name="String"/>
    </Constant>
    <Constant name="ClearFilters" id="4e28e115-999c-413a-b237-9be63770594d">
        <source>"- Clear -"</source>
        <type name="String"/>
    </Constant>
