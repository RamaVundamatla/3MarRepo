    <JadeMethod name="calculateGraphSize" id="dd3e3179-2b33-4cac-8964-a419d1f4b9ff">
        <updating/>
        <source>calculateGraphSize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.borderStyle = 0 then
		self.graphHeight	:=	(self.height - self.graphLabelHeight - 0).Integer;
		self.graphWidth		:=	(self.width  - 3).Integer;
	else
		self.graphHeight	:=	(self.height - self.graphLabelHeight - 2).Integer;
		self.graphWidth		:=	(self.width  - 6).Integer;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkData" id="49545fd8-4106-4026-a363-a7394c214a37">
        <source>checkData():String protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue			: String;
	numberOfPieces 		: Integer;
	totalValueOfPieces 	: Integer;
	sliceValue			: Integer;
	position			: Integer;
	sliceColor			: Integer;
	colorArray			: IntegerArray;
	
begin
	numberOfPieces	:=	self.allGraphValues.size();
	
	if numberOfPieces &lt; 1 then
		returnValue	:=	"No Data provided";
		return returnValue;
	endif;
	
	if numberOfPieces &gt; self.allGraphColors.size() then
		returnValue	:=	"Not enough colors set";
		return returnValue;
	endif;
	
	foreach sliceValue in self.allGraphValues do
		totalValueOfPieces	:=	totalValueOfPieces + sliceValue;
	endforeach;
	
	if totalValueOfPieces &gt; 100 then
		returnValue	:=	"Data totals &gt; 100%";
		return returnValue;
	endif;
	
	create colorArray transient;
	
	foreach position in 1 to numberOfPieces do
		sliceColor	:=	self.allGraphColors[position];
		
		if not colorArray.includes(sliceColor) then
			colorArray.add(sliceColor);
		else
			returnValue	:=	"Color used more than once";
			return returnValue;
		endif;
	endforeach; 
	
	return returnValue;
epilog
	delete colorArray;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createLegendLabel" id="4577b471-b8a7-4b9a-9566-7b23467eb2f0">
        <updating/>
        <source>createLegendLabel() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLabel	: JSSLabel;
	
begin
	if self.myLegendLabel &lt;&gt; null then
		delete self.myLegendLabel;
	endif;
	
	create theLabel transient;
	theLabel.name		:=	self.LEGEND_LABEL;
	theLabel.parent		:=	self;
	theLabel.left		:=	1;
//	theLabel.top		:=	self.graphLabelHeight + self.graphHeight;
	theLabel.top		:=	self.graphHeight;
	theLabel.visible	:=	true;
	//theLabel.height	:=	theLabel.getTextHeight(self.graphTitle);
	theLabel.height		:=	self.graphLabelHeight;
	theLabel.width		:=	self.width - 2;
	theLabel.backColor	:=	self.backColor;
	theLabel.foreColor	:=	Black;
	theLabel.alignment	:=	Label.Alignment_Center_Middle;
	self.form.addControl(theLabel);
	theLabel.caption	:=	"";
	self.myLegendLabel	:=	theLabel;
	
	if self.isShowPieLegend then
		self.setLegendLabel(0);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createPieces" id="3834e767-d4be-4ccf-8f67-7e5473d8994a">
        <updating/>
        <source>createPieces() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startX			: Real;
	startY			: Real;
	endX			: Real;
	endY			: Real;
	pieColor		: Integer;
	sliceValue		: Integer;
	valueSubtotal	: Integer;
	position		: Integer;
	sliceDegrees	: Real;
	numberOfPieces	: Integer;
	
begin
	position		:=	1;
	self.autoRedraw	:=	true;
	
	numberOfPieces := self.allGraphValues.size();
	
	while position &lt;= numberOfPieces do
		sliceValue		:=	self.allGraphValues[position];
		valueSubtotal	:=	valueSubtotal + sliceValue;
		sliceDegrees	:=	valueSubtotal * 3.6;
		pieColor		:=	self.allGraphColors[position];
		
		endX				:=	self.determineX(sliceDegrees);
		endY				:=	self.determineY(sliceDegrees);
		self.drawFillColor	:=	pieColor;
		self.drawPie(3, self.graphLabelHeight, self.graphWidth, self.graphHeight, startX, startY, endX, endY, pieColor);
		
		startX		:=	endX;
		startY		:=	endY;
		position	:=	position + 1;
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="determineX" id="3fc444ee-c898-493f-a458-2d43d5ce8e38">
        <source>determineX(pDegrees:Real):Real protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: Real;
	
begin
	if pDegrees &lt;= 90 then	//1-90
		returnValue	:=	0;
	elseif pDegrees &lt; 135 then //91-134
		returnValue	:=	((self.graphWidth / 2) - ((self.graphWidth/2) * (135 - pDegrees).Real.sin));
	elseif pDegrees = 135 then //135
		returnValue	:=	(self.graphWidth / 2);
	elseif pDegrees &lt; 180 then //136-179
		returnValue	:=	((self.graphWidth / 2 ) + ((self.graphWidth/2) * (pDegrees - 135).Real.sin));
	elseif pDegrees &lt;= 270 then //180-270
		returnValue	:=	self.graphWidth;
	elseif pDegrees &lt; 315 then //271-314
		returnValue	:=	((self.graphWidth / 2 ) + ((self.graphWidth/2) * (315 - pDegrees).Real.sin));
	elseif pDegrees = 315 then //315
		returnValue	:=	(self.graphWidth/2);
	elseif pDegrees &lt; 360 then //316 - 359
		returnValue	:=	((self.graphWidth / 2 ) - ((self.graphWidth/2) * (pDegrees - 315).Real.sin));
	else //360
		returnValue := 0;
	endif;

/*
	if pDegrees &lt;= 90 then	//1-90
		returnValue	:=	0;
	elseif pDegrees &lt;= 180 then //91-179
		returnValue	:=	(self.myBackground.width / 90) * (pDegrees - 90);
	elseif pDegrees &lt; 270 then //180-270
		returnValue	:=	self.myBackground.width;
	else
		returnValue	:=	(self.myBackground.width - (self.myBackground.width / 90) * (pDegrees - 270));
	endif;
*/
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="pDegrees" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="determineY" id="eceddda5-ee1c-4cb9-87c1-63a5741330d5">
        <source>determineY(pDegrees:Real):Real protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: Real;
	
begin
	if pDegrees &lt; 45 then	//1-44
		returnValue	:=	((self.graphHeight / 2) - ((self.graphHeight/2) * (45 - pDegrees).Real.sin));
	elseif pDegrees = 45 then	//45
		returnValue	:=	(self.graphHeight / 2);
	elseif pDegrees &lt; 90 then	//46-89
		returnValue	:=	(self.graphHeight / 2) + ((self.graphHeight / 2) * (pDegrees - 45).Real.sin);
	elseif pDegrees &lt; 180 then //90-179
		returnValue	:=	self.graphHeight;
	elseif pDegrees &lt;= 225 then //180-225
		returnValue	:=	(self.graphHeight / 2) + ((self.graphHeight / 2) * (225 - pDegrees).Real.sin);
	elseif pDegrees = 225 then //225
		returnValue	:=	(self.graphHeight / 2);
	elseif pDegrees &lt;= 270 then //226-270
		returnValue	:=	((self.graphHeight / 2) - ((self.graphHeight / 2) * (pDegrees - 225).Real.sin));
	else
		returnValue := 0; //271 +
	endif;
	
	return returnValue;
end;

/*
vars
	returnValue : Real;
	
begin
	
	if pDegrees &lt; 90 then	//46-90
		returnValue	:=	((self.myBackground.height / 90 ) * pDegrees);
	elseif pDegrees &lt; 180 then //90-180
		returnValue	:=	self.myBackground.height;
	elseif pDegrees &lt;= 270 then //180-270
		returnValue	:=	(self.myBackground.height - (self.myBackground.height / 90) * (pDegrees - 180));
	else
		returnValue	:=	0;
	endif;
	
	return returnValue;
end;
*/</source>
        <access>protected</access>
        <Parameter name="pDegrees" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="0e7ae915-40f1-4ca6-b060-4306c06fc8bc">
        <updating/>
        <source>drawGraph() updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	
begin
	inheritMethod();
	
	errorMessage	:=	self.checkData();
	
	if errorMessage = "" then
		self.calculateGraphSize();
		self.setupForm();
	else
		self.doDataError(errorMessage);
	endif;
	
	if self.myLegend &lt;&gt; null then
		self.myLegend.drawGraph();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="2a57ba1b-3dfc-4f59-87c3-f9d777921eac">
        <updating/>
        <source>mouseUp(cntrl: BaseControl input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(self, button, shift, x, y);
	
	if self.isShowPieLegend then
		if (not self.isInPainter()) then
			self.setLegendLabel(self.getPoint(x, y));
		endif;
	endif;
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="eaa5ce22-3808-4ef5-9f77-1692df8177e1">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.graphTitle	:=	self.name &amp; " - Sample data";
	
	self.allGraphValues.add(10);
	self.allGraphValues.add(20);
	self.allGraphValues.add(50);
	self.allGraphValues.add(10);
	self.allGraphValues.add(10);
	
	self.allGraphColors.add(Red);
	self.allGraphColors.add(Green);
	self.allGraphColors.add(Blue);
	self.allGraphColors.add(Purple);
	self.allGraphColors.add(Yellow);
	
	self.allGraphLegends.add("Old");
	self.allGraphLegends.add("New");
	self.allGraphLegends.add("Renewals");
	self.allGraphLegends.add("Retired");
	self.allGraphLegends.add("Inactive");
	
	self.transparent	:=	false;
	
	if self.height &lt; 100 then
		self.height	:=	100;
	endif;
	
	if self.width &lt; 100 then
		self.width	:=	100;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLegendLabel" id="95d3768b-48d4-4aee-8d1a-b63e734a9ca4">
        <source>setLegendLabel(pColor:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	legendIndex		: Integer;
	theControl		: Control;
	theLabel		: Label;
	valueString		: String;
	
begin
	legendIndex :=  self.allGraphColors.indexOf(pColor);
	
	if isInPainter() then
		valueString						:=	"Legend Label";
		self.myLegendLabel.foreColor	:=	Black;
	else
		if legendIndex &lt;&gt; 0 then
			valueString	:=	self.allGraphValues[legendIndex].String &amp; "%";
			
			if legendIndex &lt;= self.allGraphLegends.size() then
				valueString	:=	self.allGraphLegends[legendIndex] &amp; " - " &amp; valueString;
			else
				valueString	:=	"No legend - " &amp; valueString;
			endif;
		else
			valueString	:=	"Click on piece of Pie for Legends";
		endif;
	endif;
	
	self.myLegendLabel.caption	:=	valueString;
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="03523fc5-93f9-4838-814f-29e4a09784be">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.createPieces();
	
	if self.isShowPieLegend then
		self.createLegendLabel();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
