    <JadeMethod name="setupThumbnailDetails" id="c2977453-8c88-4dbd-a2a3-e36d6f71a26b">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_FaultStatusMaint);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_FaultStatusMaint);
	theForm.shtTblInput1.visible := true;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="2af69d34-2e56-4d17-8f85-b29b8de06252">
        <updating/>
        <source>showThumbnail(pFaultStatus: CM_FaultStatus) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theForm				: SOP_TableMaintForm;
begin
	theForm	:=	self.myForm;
	theForm.tblInput1.clearValues();
	theForm.tblInput1.showRowByName(ETRow_Code, false);
	theForm.tblInput1.setValueByName(ETRow_Code, pFaultStatus.code);
	theForm.tblInput1.setValueByName(ETRow_Description, pFaultStatus.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailable,	pFaultStatus.isUnavailable);	
	theForm.tblInput1.setValueByName(ETRow_IsDefault, pFaultStatus.isDefault);

epilog

end;</source>
        <Parameter name="pFaultStatus" type="CM_FaultStatus"/>
    </JadeMethod>
</Class>
