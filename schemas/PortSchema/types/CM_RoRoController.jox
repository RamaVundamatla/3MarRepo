    <JadeMethod name="getSpareLengthWithTap" id="0281899c-12bc-44fe-a91b-a4c8b55e5e00">
        <source>getSpareLengthWithTap( _num : Integer io; _yaAgent : CM_YAAutoplanAgent ) : Decimal;
/*

Purpose:			

Parameters:			'tap' Test Auto plan

Return Value:		

Date		Who		Reason
22 July 2013	cnwndl1	Initial creation	Par 32037

*/

vars

	tapNum : Integer;
	standardGap : Real;

begin

	if _yaAgent &lt;&gt; null then
		tapNum := _yaAgent.getTestPlannedCargoCountFor( self );
		_num := _num + tapNum;
		standardGap := self.myRoRoLaneArea.standardGap;
		return self.getSpareLength() - ( _yaAgent.getTestPlannedCargoLengthFor( self ) + ( standardGap * tapNum ) );
		
	else
		return self.getSpareLength();
		
	endif;

epilog

end;</source>
        <Parameter name="_num" type="Integer" usage="io"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTILengthInMetres" id="7a0ddeb5-0b53-449a-b046-67ecd92c78b9">
        <source>getTILengthInMetres( _ti : CM_TrackedItem) : Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2009	cnwjk3	Initial creation


*/
constants
	DEFAULT_LEN	 	: Real = 610;
	DEFAULT_CAR_LEN : Real = 4.5;
	MIN_LEN			: Real = .5;
vars
	len : Real;
begin
	len := _ti.getLengthInMetres();
	
	// Just incase something got through the gate without a length.
	// Note that I have updated CM_Car validation to ensure that a valid
	// length is entered.
	
	if len = 0 then 
		if _ti.isKindOf(CM_Car) then
			len := DEFAULT_CAR_LEN;
		else
			len := DEFAULT_LEN/100;
		endif;
	endif;
	
	// Ensure that the length never drops below the minimum supported value
	len := len.max(MIN_LEN);
	
	return len;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
