    <JadeMethod name="doDelete" id="d93e6c8e-ecc9-42da-87e7-f42a8a62cd5d">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars
	result			: Integer;
	controller		: CM_RowController;
	
begin

	// Get current log controller.
	controller := self.myCurrentObject.CM_RowController;
	// Call trx delete row controller method.
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteRowController(controller, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			setVisibility(false);
			break;
		else
			result := app.showErrorWarningDialog('Delete Row', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="03299693-096d-420b-9e30-b690fa782d3f">
        <source>doEnableControls(_enable : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
	
begin

	// Enable or disable user input for input table.
	if _enable then
		self.tblInput1.userInputEnabled := true;
	else
		self.tblInput1.userInputEnabled := false;
	endif;
	
	// Enable or disable multi group boxes.
	self.multiOne.readOnly := not _enable;
	self.multiTwo.readOnly := not _enable;
	self.multiThree.readOnly := not _enable;
	self.multiFour.readOnly := not _enable;
	self.multiFive.readOnly := not _enable;
	self.multiSix.readOnly := not _enable;
	self.multiSeven.readOnly := not _enable;
	self.multiEight.readOnly := not _enable;
	
	// Enable or disable sheets.
	if not _enable then
		self.shtOne.visible := false;
		self.shtTwo.visible := false;
		self.shtThree.visible := false;
		self.shtFour.visible := false;			
		self.shtFive.visible := false;
		self.shtSix.visible := false;
		self.shtSeven.visible := false;
		self.shtEight.visible := false;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doGetPreviousData" id="1898b225-a520-4c08-89d3-0cbc5ec27c9a">
        <source>doGetPreviousData(_label : String; _typeOfSearch : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

	previousName	: String;
	prevDistance	: Real;

begin

	// Call the rowArea method to return previous row controller.
	self.myCurrentRowArea.getPreviousData(_label, previousName, prevDistance, _typeOfSearch);
	self.tblInput1.setValueByName(ETRow_PreviousRow, previousName);
	self.cmbPreviousRow.text := previousName;
	// If area is gap managed then set the distance from previous value.
	if self.myCurrentRowArea.isGapManaged then
		self.tblInput1.setValueByName(ETRow_DistanceFromPrevious, prevDistance);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="String"/>
        <Parameter name="_typeOfSearch" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLoadLabels" id="84bbca98-18ee-4137-b7af-04b82ca2a1ff">
        <source>doLoadLabels(_area : CM_RowArea) protected;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

	string : String;

begin

	// Load row id and starting label combo boxes with labels from row area.
	if _area &lt;&gt; null then
		self.cmbRowId.clear;
		self.cmbStartingLabel.clear;
		foreach string in _area.allLabels do
			self.cmbRowId.addItem(string);
			self.cmbStartingLabel.addItem(string);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_area" type="CM_RowArea"/>
    </JadeMethod>
    <JadeMethod name="doLoadPreviousRows" id="d06e96c8-7a03-40ec-814f-01dbc587a4a5">
        <source>doLoadPreviousRows(_area : CM_RowArea) protected;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

	controller	: CM_RowController;
	
begin


	// Load previous row and split row combo boxes with available row controllers for row area.
	self.cmbPreviousRow.clear;
	self.cmbSplitRow.clear;
	self.cmbPreviousRow.addItem(' ');
	foreach controller in _area.allRowControllersById do
		self.cmbPreviousRow.addItem(controller.CM_RowController.id);
		self.cmbSplitRow.addItem(controller.CM_RowController.id);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_area" type="CM_RowArea"/>
    </JadeMethod>
