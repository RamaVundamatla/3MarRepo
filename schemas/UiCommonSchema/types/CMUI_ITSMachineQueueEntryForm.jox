    <JadeMethod name="displayQueueEntries" id="beda0483-c869-4bb7-a8ae-f4bc5e99024a">
        <source>displayQueueEntries();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	#cnwdz2	 par21593

*/

vars
	iter 			: Iterator;
	message			: CM_ITSInterfaceResponse;
	messageToDisplay : CMIF_ITSInterfaceMsg;
begin
	app.mousePointer := Busy;
	self.tblData.rows := self.tblData.fixedRows;
	self.allMessagesToDisplay.purge();
	
	iter := self.myMachine.allITSInterfaceResponsesActive.createIterator();
	while iter.next(message) do
		if not message.isDisplayed() then
			continue;
		endif;
		
		create messageToDisplay transient;
		messageToDisplay.setMessage(message,false);
		self.allMessagesToDisplay.add(messageToDisplay);
		self.displayMessage(messageToDisplay);
	endwhile;
	self.statusLine.caption := (self.tblData.rows-self.tblData.fixedRows).String &amp; ' rows.';	
epilog
	app.mousePointer := Idle;
	delete iter;
end;</source>
    </JadeMethod>
