    <JadeMethod name="populateBaseData" id="9945256e-c141-41c9-abac-873caf1539c7">
        <updating/>
        <source>populateBaseData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/03/2018	jlgndl1	Initial creation	TFS 37818
21/06/2018	jlgdap1	TFS 39355 PEL1 Pilot Surcharges
24/08/2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
*/

begin
	if self.myInvoiceType = null then
		self.myCurrentInvTypeSurExempt := null;
		self.caption := app.getErrorString(Invoice_type) &amp;  " - " &amp; app.getErrorString(Surcharges_exemptions);
	else
		self.myCurrentInvTypeSurExempt := self.myInvoiceType.mySurchargeAndExemptions;
		self.caption := app.getErrorString(Invoice_type) &amp;  " '" &amp; self.myInvoiceType.description &amp; "' - " &amp; app.getErrorString(Surcharges_exemptions);
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
		if self.myCurrentInvTypeSurExempt.getMinChargeInvoiceLineType = null then
			self.cmbMinChgLineType.listIndex := -1;
		else
			self.cmbMinChgLineType.listIndex := self.cmbMinChgLineType.findObject( self.myCurrentInvTypeSurExempt.getMinChargeInvoiceLineType );
		endif;
		self.txtMinCharge.text :=  self.myCurrentInvTypeSurExempt.minimumChargeAmount.asStringJMT();
		
		//02 Nov 2018	NDL	TFS 41684
		if self.myCurrentInvTypeSurExempt.myCurrencyType &lt;&gt; null then
			self.cmbCurrency.listIndex := self.cmbCurrency.findObject(  self.myCurrentInvTypeSurExempt.myCurrencyType );
		endif;
		if self.cmbCurrency.listIndex &lt; 1 then
			self.cmbCurrency.listIndex := self.cmbCurrency.findStringExact( 1, app.getErrorString( Default_currency ) );
		endif;
		
		//07 May 2019	NDL	TFS 44651
		if self.myCurrentInvTypeSurExempt.myInvoiceDescForSeperateTax = null then
			self.cmbTaxExeInvType.listIndex := -1;
		else
			self.cmbTaxExeInvType.listIndex := self.cmbTaxExeInvType.findObject( self.myCurrentInvTypeSurExempt.myInvoiceDescForSeperateTax );
		endif;
		
	else
		self.txtMinCharge.text := null;
		self.cmbMinChgLineType.listIndex := -1;
		
	endif;
	
	self.populateShtACS();
	self.populateShtET();
	self.populateShtAF();
	self.populateShtSCT();
	self.populateShtDMC();
	self.populateShtVMC();
	self.populateShtSP();		// TFS 39355
	self.populateShtGMC();		//20 Mar 2019	NDL	TFS 43687
	self.populateShtISA();		// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	
	self.setVisibility();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="50a4c925-f9cf-4b52-8006-b82f19b7c160">
        <updating/>
        <source>populateCombos() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/03/2018	jlgndl1	Initial creation	TFS 37818
21/06/2018	jlgdap1	TFS 39355 PEL1 Pilot Surcharges
24/08/2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
15/09/2022	navpw1	TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges
07/02/2025	navlw1	JIRA-33945: MTN | Add Filter MSG to Some Forms
*/

vars
	bank				: CM_Bank;
	dr					: CM_Debtor;
	drTerm				: CM_DebtorTerminal;
	index				: Integer;
	rowIndex			: Integer;
	invoiceType			: CM_InvoiceLineDesc;
	defaultDebtor		: CM_VoidDebtor;
	vessel				: CM_Vessel;
	defaultVessel		: CM_NullVessel;
	term				: CM_Terminal;
	currency			: CM_CurrencyType;			//02 Nov 2018	NDL	TFS 41684
	invType				: CM_InvoiceDesc;
	financialPeriod		: CM_FinancialPeriodEnd;	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	idx					: Integer;					// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	cargoBOLTypeArray,
 	cargoTypeArray		: CM_CargoBOLTypeArray;		// ### TFS 54565 (54385) 14Sep2022 NAVPW1
	cargoBOLType		: CM_CargoBOLType;			// ### TFS 54565 (54385) 14Sep2022 NAVPW1
	debtors				: CM_DebtorSet;				// ### TFS 54565 (54385) 14Sep2022 NAVPW1
	cargoSubTypeArray	: CM_ProductArray;			// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	commodityArray		: CM_CommodityArray;		// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	
begin
	defaultDebtor := CM_VoidDebtor.firstInstance; // This is the 'CM_Debtor' that holds any default values that would apply to 'all'.
	defaultVessel := CM_NullVessel.firstInstance; // This is the 'CM_Vessel' that holds any default values that would apply to 'all'.
	
	term := self.myTerminal;
//	bank := term.getDefaultCompanyBank();
	bank := self.myInvoiceType.company;	//19 Jun 2018	NDL	TFS 39296
	
	//02 Nov 2018	NDL	TFS 41684
	foreach currency in app.myRoot.allCurrencyTypes do
		self.cmbCurrency.itemObject[ self.cmbCurrency.addItem( currency.getDisplayDetails(true) ) ] := currency;
	endforeach;
	index := self.cmbCurrency.addItem( app.getErrorString( Default_currency ) );
	self.cmbCurrency.listIndex := index;
	
	self.myAssistant.comboBoxInvoiceLineType( self.cmbMinChgLineType, false, bank );
	//09 May 2019	NDL	TFS 44651
	self.cmbTaxExeInvType.clear;
	cmbTaxExeInvType.addItem(" ");
	foreach invType in bank.invoiceTypes where not invType.isNotAvailableForEntry do
		index := self.cmbTaxExeInvType.addItem(invType.description);
		self.cmbTaxExeInvType.itemObject[index] := invType;
	endforeach;
	
	self.myAssistant.comboBoxInvoiceLineType( self.cmbACSInvLineType, false, bank );
	
	self.cmbACSDebtor.clear();	
	index := self.cmbACSDebtor.addItem( app.getErrorString(Default_debtor) );
	self.cmbACSDebtor.itemObject[ index ] := defaultDebtor;
	foreach dr in app.myRoot.myRootCompany.debtors do
		if not dr.isKindOf( CM_Debtor )then
			continue;
		endif;
		drTerm := dr.allDebtorTerminals[term];
		if drTerm &lt;&gt; null and drTerm.isAutoCollection then
			index := self.cmbACSDebtor.addItem( dr.name );
			self.cmbACSDebtor.itemObject[ index ] := dr;
		endif;
	endforeach;
	
	self.lstAFInvLineTypes.clear();
	foreach invoiceType in bank.invoiceLineDescriptors discreteLock where not invoiceType.isNotAvailableForEntry do
		rowIndex := self.lstAFInvLineTypes.addItem( '0' &amp; Tab &amp; invoiceType.getComboDescription()); // ### TFS BUG 59913 31AUG2023 NAVAB1 
		self.lstAFInvLineTypes.accessRow(rowIndex).itemObject := invoiceType;
	endforeach;
	 // ### TFS BUG 59913 31AUG2023 NAVAB1 
	self.lstAFInvLineTypes.sortColumn[1] := 2;
	self.lstAFInvLineTypes.resort();
	
	self.cmbAFDebtor.clear();
	index := self.cmbAFDebtor.addItem( app.getErrorString(Default_debtor) );
	self.cmbAFDebtor.itemObject[ index ] := defaultDebtor;
	foreach dr in app.myRoot.myRootCompany.debtors do
		if not dr.isKindOf( CM_Debtor )then
			continue;
		endif;
		index := self.cmbAFDebtor.addItem( dr.name );
		self.cmbAFDebtor.itemObject[ index ] := dr;
	endforeach;
	
	self.myAssistant.comboBoxInvoiceLineType( self.cmbSCTInvLineType, false, bank );
	
	//self.myAssistant.comboBoxCargoTypes(self.cmbSCTCargoType, null); // ### TFS 54565 (54385) 19Sep2022 NAVPW1
	
	self.mulSCTInvLineTypes.myAvailableListBox.sorted := true;
	self.mulSCTInvLineTypes.mySelectedListBox.sorted := true;
	self.mulSCTInvLineTypes.height := 180; // navlw1 #JIRA-33945 07/02/2025
	self.mulSCTInvLineTypes.setupControl( null, bank.invoiceLineDescriptors, INV_InvTypeSurchargeExemptions::getInvLineTypeNarration.name );
	self.mulSCTInvLineTypes.availableHeading := app.getErrorString(Availab_invoice_line_types);
	self.mulSCTInvLineTypes.selectedHeading := app.getErrorString(Selecte_invoice_line_types);
	self.mulSCTInvLineTypes.setSelected( null );
	
	// ### TFS 54565 (54385) 14Sep2022 NAVPW1
	create cargoBOLTypeArray transient;
	create cargoTypeArray transient;
	
	if self.myTerminal = null then
		app.myRoot.allCargoTypesById.copy(cargoBOLTypeArray);
	else
		self.myTerminal.allCargoBOLTypes.copy(cargoBOLTypeArray);
	endif;
	
	foreach cargoBOLType in cargoBOLTypeArray discreteLock do
		if (not CM_CargoType.hasInstance(cargoBOLType)) then
			continue;
		endif;
		cargoTypeArray.add(cargoBOLType);
	endforeach;
	
	self.mulSCTCargoTypes.myAvailableListBox.sorted	:= true;
	self.mulSCTCargoTypes.mySelectedListBox.sorted	:= true;
	self.mulSCTCargoTypes.height := 180; // navlw1 #JIRA-33945 07/02/2025
	self.mulSCTCargoTypes.setupControl(null, cargoTypeArray, INV_InvTypeSurchargeExemptions::getCargoTypeDescription.name);
	self.mulSCTCargoTypes.availableHeading	:= app.getErrorString(Available_cargo_types);
	self.mulSCTCargoTypes.selectedHeading	:= app.getErrorString(Selected_cargo_types);
	self.mulSCTCargoTypes.myBaseForm		:= self;
	self.mulSCTCargoTypes.setSelected(null);
	
	create cargoSubTypeArray transient;
	self.mulSCTSubCargoTypes.myAvailableListBox.sorted	:= true;
	self.mulSCTSubCargoTypes.mySelectedListBox.sorted	:= true;
	self.mulSCTSubCargoTypes.height := 180; // navlw1 #JIRA-33945 07/02/2025
	self.mulSCTSubCargoTypes.setupControl(null, cargoSubTypeArray, INV_InvTypeSurchargeExemptions::getCargoSubTypeDescription.name);
	self.mulSCTSubCargoTypes.availableHeading	:= app.getErrorString(AvailableCargoSubtypes);
	self.mulSCTSubCargoTypes.selectedHeading	:= app.getErrorString(SelectedCargoSubtypes);
	self.mulSCTSubCargoTypes.myBaseForm			:= self;
	self.mulSCTSubCargoTypes.setSelected(null);
	
	create commodityArray transient;
	self.mulSCTCommodities.myAvailableListBox.sorted	:= true;
	self.mulSCTCommodities.mySelectedListBox.sorted		:= true;
	self.mulSCTCommodities.height := 180; // navlw1 #JIRA-33945 07/02/2025
	self.mulSCTCommodities.setupControl(null, commodityArray, INV_InvTypeSurchargeExemptions::getCommodityDescription.name);
	self.mulSCTCommodities.availableHeading	:= app.getErrorString(Available_commodities);
	self.mulSCTCommodities.selectedHeading	:= app.getErrorString(Selected_commodities);
	self.mulSCTCommodities.myBaseForm		:= self;
	self.mulSCTCommodities.setSelected(null);
	
	create debtors transient;
	foreach dr in app.myRoot.myRootCompany.debtors do
		if not dr.isKindOf(CM_Debtor)then
			continue;
		endif;
		debtors.add(dr);
	endforeach;
	
	self.mulSCTDebtors.myAvailableListBox.sorted 	:= true;
	self.mulSCTDebtors.mySelectedListBox.sorted 	:= true;
	self.mulSCTDebtors.height := 180;
	// navlw1 Start #JIRA-33945 07/02/2025
	self.mulSCTDebtors.myAvailableListBox.stretchHeight		:= false;
	self.mulSCTDebtors.myAvailableListBox.stretchWidth		:= false;
	self.mulSCTDebtors.myAvailableListBox.integralHeight	:= false;

	self.mulSCTDebtors.mySelectedListBox.stretchHeight		:= false;
	self.mulSCTDebtors.mySelectedListBox.stretchWidth		:= false;
	self.mulSCTDebtors.mySelectedListBox.integralHeight		:= false;
	// navlw1 End #JIRA-33945 07/02/2025
	
	self.mulSCTDebtors.setupControl(null, debtors, INV_InvTypeSurchargeExemptions::getDebtorsDescription.name);
	self.mulSCTDebtors.availableHeading	:= app.getErrorString(Available_debtors);
	self.mulSCTDebtors.selectedHeading	:= app.getErrorString(Selected_debtors);
	self.mulSCTCommodities.myBaseForm	:= self;
	self.mulSCTDebtors.setSelected(null);
	// ### TFS 54565 (54385) 14Sep2022 NAVPW1
	
	self.cmbETDebtor.clear();	
	foreach dr in app.myRoot.myRootCompany.debtors do 
		if not dr.isKindOf( CM_Debtor )then
			continue;
		endif;
		index := self.cmbETDebtor.addItem( dr.name );
		self.cmbETDebtor.itemObject[ index ] := dr;
	endforeach;
	
	self.cmbETTaxRule.clear();
	self.cmbETTaxRule.sorted := false;
	index := self.cmbETTaxRule.addItem( "Tax - Full" );
	self.cmbETTaxRule.itemData[ index ] := ExternalTaxRuleFull;
	index := self.cmbETTaxRule.addItem( "Tax - Exempt" );
	self.cmbETTaxRule.itemData[ index ] := ExternalTaxRuleExempt;
	
	self.cmbVMCVessel.clear();
	index := self.cmbVMCVessel.addItem( app.getErrorString(Default_vessel) );
	self.cmbVMCVessel.itemObject[ index ] := defaultVessel;
	foreach vessel in app.myRoot.allVessels do 
		if not dr.isKindOf( CM_Debtor )then
			continue;
		endif;
		index := self.cmbVMCVessel.addItem( vessel.name );
		self.cmbVMCVessel.itemObject[ index ] := vessel;
	endforeach;
	
	self.myAssistant.comboBoxInvoiceLineType( self.cmbVMCInvLineType, false, bank );
	
	self.cmbDMCDebtor.clear();
	index := self.cmbDMCDebtor.addItem( app.getErrorString(Default_debtor) );
	self.cmbDMCDebtor.itemObject[ index ] := defaultDebtor;
	foreach dr in app.myRoot.myRootCompany.debtors do 
		if not dr.isKindOf( CM_Debtor )then
			continue;
		endif;
		index := self.cmbDMCDebtor.addItem( dr.name );
		self.cmbDMCDebtor.itemObject[ index ] := dr;
	endforeach;
	
	self.myAssistant.comboBoxInvoiceLineType( self.cmbDMCInvLineType, false, bank );
	
	self.myAssistant.comboBoxInvoiceLineType(self.cmbSPNotReady, false, bank);			// TFS 39355
	self.myAssistant.comboBoxInvoiceLineType(self.cmbSPTooSoon, false, bank);			// TFS 39355
	
	//21 Mar 2019	NDL	TFS 43687
	self.mulGMCInvLineTypes.myAvailableListBox.sorted := true;
	self.mulGMCInvLineTypes.mySelectedListBox.sorted := true;
	self.mulGMCInvLineTypes.height := 180; // navlw1 #JIRA-33945 07/02/2025
	self.mulGMCInvLineTypes.setupControl( null, bank.invoiceLineDescriptors, INV_InvTypeSurchargeExemptions::getInvLineTypeNarration.name );
	self.mulGMCInvLineTypes.availableHeading := app.getErrorString(Availab_invoice_line_types);
	self.mulGMCInvLineTypes.selectedHeading := app.getErrorString(Selecte_invoice_line_types);
	self.mulGMCInvLineTypes.setSelected( null );
	
	self.myAssistant.comboBoxInvoiceLineType( self.cmbGMCInvLineType, false, bank );
	
	self.cmbGMCMoveType.clear();
	self.cmbGMCMoveType.itemData[ self.cmbGMCMoveType.addItem( null ) ] := 0;
	self.cmbGMCMoveType.itemData[ self.cmbGMCMoveType.addItem( app.getMoveTypeDescription(HMSMovementTypeArrival) ) ] := 1;
	self.cmbGMCMoveType.itemData[ self.cmbGMCMoveType.addItem( app.getMoveTypeDescription(HMSMovementTypeShift) ) ] := 2;
	self.cmbGMCMoveType.itemData[ self.cmbGMCMoveType.addItem( app.getMoveTypeDescription(HMSMovementTypeDeparture) ) ] := 3;
	
	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	//Populate Debtor
	self.cmbISADebtor.clear();
	index := self.cmbISADebtor.addItem( app.getErrorString(Default_debtor) );
	self.cmbISADebtor.itemObject[ index ] := defaultDebtor;
	foreach dr in app.myRoot.myRootCompany.debtors do
		if not dr.isKindOf( CM_Debtor )then
			continue;
		endif;
		index := self.cmbISADebtor.addItem( dr.name );
		self.cmbISADebtor.itemObject[ index ] := dr;
	endforeach;
	
	//Populate Accural Types
	self.cmbISAAccuralType.clear;
	self.cmbISAAccuralType.addItemAt("Until Closed", 1);
	self.cmbISAAccuralType.itemObject[1] := null;
	self.cmbISAAccuralType.itemData[1] := CM_InvoiceDesc.Accrue_Until_Manually_Closed;
	
	idx  := 1;
	foreach financialPeriod in app.myRoot.myRootCompany.allFinancialPeriods do
		idx := idx + 1;
		self.cmbISAAccuralType.addItemAt(financialPeriod.description, idx);
		self.cmbISAAccuralType.itemObject[idx] := financialPeriod;
		self.cmbISAAccuralType.itemData[idx] := CM_InvoiceDesc.Accrue_For_Financial_Period;
	endforeach;
	
epilog
	delete cargoBOLTypeArray;
	delete cargoTypeArray;
	delete cargoSubTypeArray;
	delete commodityArray;
	delete debtors;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateShtACS" id="9bbd1ee5-7974-4ff2-8925-81cad46de992">
        <source>populateShtACS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2018	jlgndl1	Initial creation	TFS 37818
*/

vars

	iter : Iterator;
	drSurcharge : CM_DebtorSurchargeRate;
	index : Integer;
	lineTypeStr : String;
	drName : String;

begin

	self.tblACS.clear();
	
	self.tblACS.columns := 3;
	self.tblACS.fixedColumns := 0;
	self.tblACS.rows := 1;
	self.tblACS.fixedRows := 1;
	self.tblACS.selectMode := Table.SelectMode_CurrentRow;
	
	self.tblACS.setCellText(1,1, app.getErrorString(INV_Debtor) &amp; Tab &amp; app.getErrorString(Surcharge_percentage) &amp; Tab &amp; app.getErrorString(Surcharge_line_type) );
	
	if self.tblACS.sortColumn[1] &gt; 0 then
		self.tblACS.accessRow(1).fontBold := false;
		self.tblACS.accessCell(1, self.tblACS.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
	
		iter := self.myCurrentInvTypeSurExempt.allDebtorSurchargeRates.createIterator;
		while iter.next( drSurcharge ) do
			if drSurcharge.getSurchargeInvoiceLineType = null then
				lineTypeStr := null;
			else
				lineTypeStr := drSurcharge.getSurchargeInvoiceLineType.narration;
			endif;
			if drSurcharge.myDebtor.isDefaultDebtor then
				drName := app.getErrorString(Default_debtor);
			else
				drName := drSurcharge.myDebtor.name;
			endif;
			index := self.tblACS.addItem( drName &amp; Tab &amp; drSurcharge.surchargeRate.asStringJMT &amp; Tab &amp; lineTypeStr );
			self.tblACS.accessRow(index).itemObject := drSurcharge;
		endwhile;
		
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateShtAF" id="4bf19079-0304-4012-9046-2425646aaea0">
        <source>populateShtAF();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgndl1	Initial creation	TFS 37819

*/

vars

	iter : Iterator;
	additionalChg : CM_InvTypeAdditionalCharges;
	index : Integer;
	rangeStr : String;
	lineTypesStr : String;
	drName : String;

begin

	self.tblAF.clear();
	
	self.tblAF.columns := 3;
	self.tblAF.fixedColumns := 0;
	self.tblAF.rows := 1;
	self.tblAF.fixedRows := 1;
	self.tblAF.selectMode := Table.SelectMode_CurrentRow;
	
	self.tblAF.setCellText(1,1, app.getErrorString(INV_Debtor) &amp; Tab &amp; app.getErrorString(Invoice_total_range) &amp; Tab &amp; app.getErrorString(Invoice_line_type) );
	
	if self.tblAF.sortColumn[1] &gt; 0 then
		self.tblAF.accessRow(1).fontBold := false;
		self.tblAF.accessCell(1, self.tblAF.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
		iter := self.myCurrentInvTypeSurExempt.allInvTypeAdditionalCharges.createIterator;
		while iter.next( additionalChg ) do
			lineTypesStr := additionalChg.getLineTypesStr;
			rangeStr := additionalChg.getRangeStr;
			if additionalChg.myDebtor.isDefaultDebtor then
				drName := app.getErrorString(Default_debtor);
			else
				drName := additionalChg.myDebtor.name;
			endif;
			index := self.tblAF.addItem( drName &amp; Tab &amp; rangeStr &amp; Tab &amp; lineTypesStr );
			self.tblAF.accessRow(index).itemObject := additionalChg;
		endwhile;
		
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateShtDMC" id="3d9d9f20-53aa-484f-a048-c800a4796749">
        <source>populateShtDMC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38914
*/

vars

	iter : Iterator;
	drMinCharge : CM_InvTypeDebtorMinCharge;
	index : Integer;
	lineTypeStr : String;
	drName : String;

begin

	self.tblDMC.clear();
	
	self.tblDMC.columns := 3;
	self.tblDMC.fixedColumns := 0;
	self.tblDMC.rows := 1;
	self.tblDMC.fixedRows := 1;
	self.tblDMC.selectMode := Table.SelectMode_CurrentRow;
	
	self.tblDMC.setCellText(1,1, app.getErrorString(INV_Debtor) &amp; Tab &amp; app.getErrorString(Min_charge) &amp; Tab &amp; app.getErrorString( Minimum_charge_line_type ) );
	
	if self.tblDMC.sortColumn[1] &gt; 0 then
		self.tblDMC.accessRow(1).fontBold := false;
		self.tblDMC.accessCell(1, self.tblDMC.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
	
		iter := self.myCurrentInvTypeSurExempt.allInvTypeDebtorMinCharges.createIterator;
		while iter.next( drMinCharge ) do
			if drMinCharge.getMinimumChargeInvLineType = null then
				lineTypeStr := null;
			else
				lineTypeStr := drMinCharge.getMinimumChargeInvLineType.narration;
			endif;
			if drMinCharge.myDebtor.isDefaultDebtor then
				drName := app.getErrorString(Default_debtor);
			else
				drName := drMinCharge.myDebtor.name;
			endif;
			index := self.tblDMC.addItem( drName &amp; Tab &amp; drMinCharge.minimumChargeAmount.asStringJMT &amp; Tab &amp; lineTypeStr );
			self.tblDMC.accessRow(index).itemObject := drMinCharge;
		endwhile;
		
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateShtET" id="a16d1ec0-ea81-4e59-9c67-142d586002a8">
        <source>populateShtET();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37821

*/

vars

	iter : Iterator;
	extTax : CM_InvoiceTypeExternalTax;
	index : Integer;
	rangeStr : String;
	exempt : Boolean;
	drName : String;

begin

	self.tblET.clear();
	
	self.tblET.columns := 4;
	self.tblET.fixedColumns := 0;
	self.tblET.rows := 1;
	self.tblET.fixedRows := 1;
	self.tblET.selectMode := Table.SelectMode_CurrentRow;
	
	self.tblET.setCellText(1,1, app.getErrorString(INV_Debtor) &amp; Tab &amp; app.getErrorString(Invoice_total_range) &amp; Tab &amp; "External Tax Code" &amp; Tab &amp; "Exempt" );
	
	if self.tblET.sortColumn[1] &gt; 0 then
		self.tblET.accessRow(1).fontBold := false;
		self.tblET.accessCell(1, self.tblET.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
		iter := self.myCurrentInvTypeSurExempt.allInvTypeExternalTax.createIterator;
		while iter.next( extTax ) do
			rangeStr := extTax.getRangeStr;
			exempt := extTax.isTaxExempt;
			if extTax.myDebtor.isDefaultDebtor then
				drName := app.getErrorString(Default_debtor);
			else
				drName := extTax.myDebtor.name;
			endif;
			index := self.tblET.addItem( drName &amp; Tab &amp; rangeStr &amp; Tab &amp; extTax.externalTaxCode &amp; Tab &amp; exempt.getYesNo );
			self.tblET.accessRow(index).itemObject := extTax;
		endwhile; 	
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateShtGMC" id="3befa07a-42b1-4809-8e58-5d1903229f5d">
        <source>populateShtGMC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	iter : Iterator;
	grpMinCharge : CM_InvTypeGroupingMinCharge;
	index : Integer;
	lineTypeStr : String;
	headingStr : String;
	lineStr : String;

begin

	self.tblGMC.clear();
	
	self.tblGMC.columns := 5;
	self.tblGMC.fixedColumns := 0;
	self.tblGMC.rows := 1;
	self.tblGMC.fixedRows := 1;
	self.tblGMC.selectMode := Table.SelectMode_CurrentRow;
	
	headingStr := 	app.getErrorString(CM_Description)
					&amp; Tab &amp; app.getErrorString(Movement_type)
					&amp; Tab &amp; app.getErrorString( Line_Types )
					&amp; Tab &amp; app.getErrorString( Minimum_charge_line_type )
					&amp; Tab &amp; app.getErrorString( Min_charge );
	
	self.tblGMC.setCellText( 1, 1, headingStr );
	
	if self.tblGMC.sortColumn[1] &gt; 0 then
		self.tblGMC.accessRow(1).fontBold := false;
		self.tblGMC.accessCell(1, self.tblGMC.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
	
		iter := self.myCurrentInvTypeSurExempt.allInvTypeGroupingMinCharges.createIterator;
		while iter.next( grpMinCharge ) do
			if grpMinCharge.getMinimumChargeInvLineType = null then
				lineTypeStr := null;
			else
				lineTypeStr := grpMinCharge.getMinimumChargeInvLineType.narration;
			endif;
			
			lineStr := grpMinCharge.description
					&amp; Tab &amp; grpMinCharge.moveType
					&amp; Tab &amp; grpMinCharge.getLineTypesDisplay()
					&amp; Tab &amp; lineTypeStr
					&amp; Tab &amp; grpMinCharge.minimumChargeAmount.asStringJMT;
					
			index := self.tblGMC.addItem( lineStr );
			self.tblGMC.accessRow(index).itemObject := grpMinCharge;
		endwhile;
		
	endif; 

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateShtISA" id="e34266b3-1aa9-46b6-b631-ff335d318330">
        <source>populateShtISA();
/*

Purpose:			Populates the sheet for Invoice Type Debtor Separation

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
24 August 2022	navpw1	Initial creation TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges

*/

vars
	iter 						: Iterator;
	invoiceTypeDebtorSeparator 	: CM_InvTypeDebtorSeparation;
	accrualType					: CM_FinancialPeriodEnd;
	accrualDescription			: String;
	index 						: Integer;
	
begin
	self.tblISA.clear();
	
	self.tblISA.columns := 3;
	self.tblISA.fixedColumns := 0;
	self.tblISA.rows := 1;
	self.tblISA.fixedRows := 1;
	self.tblISA.selectMode := Table.SelectMode_CurrentRow;
	
	self.tblISA.setCellText(1,1, app.getErrorString(Debtor_GC) &amp; Tab &amp; app.getErrorString(Accrual_type) &amp; Tab &amp; app.getErrorString(Separated_by));
	
	if self.tblISA.sortColumn[1] &gt; 0 then
		self.tblISA.accessRow(1).fontBold := false;
		self.tblISA.accessCell(1, self.tblISA.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
		iter := self.myCurrentInvTypeSurExempt.allInvoiceTypeDebtorSeparation.createIterator;
		while iter.next(invoiceTypeDebtorSeparator) do
			accrualType := invoiceTypeDebtorSeparator.myAccrualType;
			if  accrualType &lt;&gt; null then
				accrualDescription := accrualType.description;
			else
				accrualDescription := "Until Closed";
			endif;
			
			index := self.tblISA.addItem(invoiceTypeDebtorSeparator.myDebtor.name &amp; Tab &amp; accrualDescription.asStringJMT() &amp; Tab &amp; invoiceTypeDebtorSeparator.getSeparationDescriptions());
			self.tblISA.accessRow(index).itemObject := invoiceTypeDebtorSeparator;
			
		endwhile;
		
	endif;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateShtSCT" id="1c7820a8-d891-4f1c-b824-9afbeeef64aa">
        <source>populateShtSCT();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018		jlgndl1	Initial creation	TFS 37818
19 September 2022	navpw1	TFS 54565 (54385) - EUP - Inv Config - Invoice Surcharges
31 October 2022		navpw1	TFS 55234 - Made changes to Surcharge Percentage/Fixed Amount column
19-04-2023			navtnr20 Bug 57646: FR | 53978 - EUP - Invoicing -  Configuration Enhancements - Surcharges and Exemptions- Surcharge logic - By Line Total or By Qty filed in the Column organizer
19-04-2023			navmk20	 Bug 57645: EUP -FR | 53978 - EUP - Invoicing -  Configuration Enhancements - Surcharges and Exemptions- Date ranges (From and to) mentioned in the column organizer
*/

vars
	iter						: Iterator;
	//ctSurcharge				: CM_InvTypeCargoSurcharge;
	ctSurcharge					: CM_InvTypeCargoMultiSurcharge;	// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	index						: Integer;
	lineTypeStr					: String;
	allCargoSubTypes,
	allCommodities,
	messstring,
	allDebtors					: String;							// ### TFS 51219 03JUN2021 NAVAB1
	surchargePercentageOrAmount : Decimal[19,3];					// ### TFS 55234 31Oct2022 NAVPW1
	line						: String;
	quantity 					: String;
	dateRangeFrom 				: TimeStamp; 	// 19.4.2023 navmk20 TFS 57645
	dateRangeTo					: TimeStamp;	// 19.4.2023 navmk20 TFS 57645
begin
	self.tblSCT.clear();
	//self.tblSCT.columns := 6;navtnr20 19-04-2023 Bug 57646
	self.tblSCT.columns := 9;	//navtnr20 19-04-2023 Bug 57646
	self.tblSCT.fixedColumns := 0;
	self.tblSCT.rows := 1;
	self.tblSCT.fixedRows := 1;
	self.tblSCT.selectMode := Table.SelectMode_CurrentRow;
	
	self.tblSCT.setCellText(1,1, app.getErrorString(Debtors) &amp; Tab &amp; app.getErrorString(CargoTypes) &amp; Tab &amp; app.getErrorString(Cargo_subtypes) &amp; Tab &amp; app.getErrorString(Commodities) &amp; Tab &amp; app.getErrorString(Surcharge_percentage) &amp; Tab &amp; app.getErrorString(Surcharge_line_type) &amp; Tab &amp; app.getErrorString(TYPE) &amp; Tab &amp; app.getErrorString(Date_range_from) &amp; Tab &amp; app.getErrorString(Date_range_to));
	
	if self.tblSCT.sortColumn[1] &gt; 0 then
		self.tblSCT.accessRow(1).fontBold := false;
		self.tblSCT.accessCell(1, self.tblSCT.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
		//iter := self.myCurrentInvTypeSurExempt.allInvTypeCargoSurcharges.createIterator;
		iter := self.myCurrentInvTypeSurExempt.allInvTypeCargoMultiSurcharges.createIterator; 							// ### TFS 54565 (54385) 19Sep2022 NAVPW1
		while iter.next( ctSurcharge ) do
			if ctSurcharge.getCargoSurchargeInvLineType = null then
				lineTypeStr := null;
			else
				lineTypeStr := ctSurcharge.getCargoSurchargeInvLineType.narration;
			endif;
			
			// ### TFS 54565 (54385) 19Sep2022 NAVPW1
			//messstring := "All Cargo Types"; // ### TFS 51219 03JUN2021 NAVAB1 allow for ALL CARGO TYPES
			/*if ctSurcharge.myCargoType &lt;&gt; null then // ### TFS 51219 03JUN2021 NAVAB1
				messstring := ctSurcharge.myCargoType.description; // ### TFS 51219 03JUN2021 NAVAB1
			endif;*/
			// ### TFS 54565 (54385) 19Sep2022 NAVPW1
			
			// ### TFS 54565 (54385) 19Sep2022 NAVPW1
			allDebtors := ctSurcharge.allDebtorsDescription();
			
			messstring := ctSurcharge.allCargoTypesDescription();
			
			allCargoSubTypes := ctSurcharge.allCargoSubTypesDescription();
			
			allCommodities := ctSurcharge.allCommoditiesDescription();
			// ### TFS 54565 (54385) 19Sep2022 NAVPW1
			// Start navtnr20 19-04-2023 Bug 57646
			line := app.getErrorString(Quantity_filed);
			if ctSurcharge.applyGreaterThanLineTotal then
				line := app.getErrorString(Line_total);				
			endif;
			// End navtnr20 19-04-2023 Bug 57646
			// Start - 19.4.2023 navmk20 TFS 57645
			if ctSurcharge.validFrom &lt;&gt; null then
				dateRangeFrom := ctSurcharge.validFrom;
			endif;
			if ctSurcharge.validTo &lt;&gt; null then
				dateRangeTo := ctSurcharge.validTo;
			endif;
			// End - 19.4.2023 navmk20 TFS 57645
			
			// ### TFS 55234 31Oct2022 NAVPW1
			if ctSurcharge.surchargeRate &lt;&gt; 0 then
				surchargePercentageOrAmount := ctSurcharge.surchargeRate;
			else
				surchargePercentageOrAmount:= ctSurcharge.surchargeAmount;
			endif;
			// ### TFS 55234 31Oct2022 NAVPW1
			
			index := self.tblSCT.addItem( allDebtors &amp; Tab &amp; messstring &amp; Tab &amp; allCargoSubTypes &amp; Tab &amp; allCommodities &amp; Tab &amp; surchargePercentageOrAmount.asStringJMT() &amp; Tab &amp; lineTypeStr &amp; Tab &amp; line.asStringJMT  &amp; Tab &amp; dateRangeFrom.asStringJMT &amp; Tab &amp; dateRangeTo.asStringJMT); // ### TFS 51219 03JUN2021 NAVAB1
			self.tblSCT.accessRow(index).itemObject := ctSurcharge;
		endwhile; 	
	endif;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateShtSP" id="e81bf968-d7ec-4acb-a6d8-678f5f8dde06">
        <source>populateShtSP();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharge
//
vars
	iter : Iterator;
	pilotSurcharge : CM_InvTypePilotSurcharge;
	notReadyType, tooSoonType : CM_InvoiceLineDesc;
	notReadyStr, tooSoonStr : String;
	index : Integer;

begin
	self.tblSP.clear();
	
	self.tblSP.columns := 2;
	self.tblSP.fixedColumns := 0;
	self.tblSP.rows := 1;
	self.tblSP.fixedRows := 1;
	self.tblSP.selectMode := Table.SelectMode_CurrentRow;
	
	self.tblSP.setCellText(1,1, app.getErrorString(Voyage_not_ready_inv_line_type) &amp; Tab &amp; app.getErrorString(Reques_soon_invoic_line_type));
	
	if self.tblSP.sortColumn[1] &gt; 0 then
		self.tblSP.accessRow(1).fontBold := false;
		self.tblSP.accessCell(1, self.tblSP.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
		iter := self.myCurrentInvTypeSurExempt.allInvTypePilotSurcharges.createIterator;
		while iter.next( pilotSurcharge ) do
			if pilotSurcharge.getNotReadyInvLineType = null then
				notReadyStr := null;
			else
				notReadyStr := pilotSurcharge.getNotReadyInvLineType.narration;
			endif;
			if pilotSurcharge.getTooSoonInvLineType = null then
				tooSoonStr := null;
			else
				tooSoonStr := pilotSurcharge.getTooSoonInvLineType.narration;
			endif;
			index := self.tblSP.addItem( notReadyStr &amp; Tab &amp; tooSoonStr );
			self.tblSP.accessRow(index).itemObject := pilotSurcharge;
		endwhile;
	endif;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateShtVMC" id="0ba96445-d24c-48ea-bd35-de13d82d77a4">
        <source>populateShtVMC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38914
08 Dec 2018 cnwma1  Bug 42451: PEL1 - Invoice Type - Surcharges and Exemptions - 1090 Error
*/

vars

	iter : Iterator;
	vessMinCharge : CM_InvTypeVesselMinCharge;
	index : Integer;
	lineTypeStr : String;
	vesselName : String;

begin

	self.tblVMC.clear();
	
	self.tblVMC.columns := 3;
	self.tblVMC.fixedColumns := 0;
	self.tblVMC.rows := 1;
	self.tblVMC.fixedRows := 1;
	self.tblVMC.selectMode := Table.SelectMode_CurrentRow;
	
	self.tblVMC.setCellText(1,1, app.getErrorString(CM_Vessel_GC) &amp; Tab &amp; app.getErrorString(Min_charge) &amp; Tab &amp; app.getErrorString( Minimum_charge_line_type ) );
	
	if self.tblVMC.sortColumn[1] &gt; 0 then
		self.tblVMC.accessRow(1).fontBold := false;
		self.tblVMC.accessCell(1, self.tblVMC.sortColumn[1]).fontBold := true;
	endif;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
	
		iter := self.myCurrentInvTypeSurExempt.allInvTypeVesselMinCharges.createIterator;
		while iter.next( vessMinCharge ) do
			if vessMinCharge.getMinimumChargeInvLineType = null then
				lineTypeStr := null;
			else
				lineTypeStr := vessMinCharge.getMinimumChargeInvLineType.narration;
			endif;
			if vessMinCharge.myVessel &lt;&gt; null then                //08.12.2018 cnwma1 Bug #42451
				if vessMinCharge.myVessel.isNullVessel then
					vesselName := app.getErrorString(Default_vessel);
				else
					vesselName := vessMinCharge.myVessel.name;
				endif;
			else
				vesselName := app.getErrorString(Default_vessel);  //08.12.2018 cnwma1 Bug #42451
			endif;
			index := self.tblVMC.addItem( vesselName &amp; Tab &amp; vessMinCharge.minimumChargeAmount.asStringJMT &amp; Tab &amp; lineTypeStr );
			self.tblVMC.accessRow(index).itemObject := vessMinCharge;
		endwhile;
		
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="resize" id="42f9a621-fd9e-44f4-a8ce-8067b75a9e34">
        <controlMethod name="CM_BaseForm::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>resize() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2018	jlgndl1	Initial creation	TFS 37818
24 August 2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges

*/

begin
	inheritMethod();
	
	self.frmACS.left := ( self.clientWidth - self.frmACS.width ) / 2;
	self.frmACS.top := ( self.clientHeight - self.frmACS.height ) / 2;
	
	self.frmET.left := ( self.clientWidth - self.frmET.width ) / 2;
	self.frmET.top := ( self.clientHeight - self.frmET.height ) / 2;
	
	self.frmAF.left := ( self.clientWidth - self.frmAF.width ) / 2;
	self.frmAF.top := ( self.clientHeight - self.frmAF.height ) / 2;
	
	self.frmSCT.left := ( self.clientWidth - self.frmSCT.width ) / 2;
	self.frmSCT.top := ( self.clientHeight - self.frmSCT.height ) / 2;
	
	self.frmVMC.left := ( self.clientWidth - self.frmVMC.width ) / 2;
	self.frmVMC.top := ( self.clientHeight - self.frmVMC.height ) / 2;
	
	self.frmDMC.left := ( self.clientWidth - self.frmDMC.width ) / 2;
	self.frmDMC.top := ( self.clientHeight - self.frmDMC.height ) / 2;
	
	//21 Mar 2019	NDL	TFS 43687
	//self.frmGMC.left := ( self.clientWidth - self.frmDMC.width ) / 2;
	//self.frmGMC.top := ( self.clientHeight - self.frmDMC.height ) / 2;
	self.frmGMC.left := ( self.clientWidth - self.frmGMC.width ) / 2; // ### TFS 54565 (54384) 24Aug2022 NAVPW1 - fixed typo
	self.frmGMC.top := ( self.clientHeight - self.frmGMC.height ) / 2; // ### TFS 54565 (54384) 24Aug2022 NAVPW1 - fixed typo
	
	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	self.frmISA.left := ( self.clientWidth - self.frmISA.width ) / 2;
	self.frmISA.top := ( self.clientHeight - self.frmISA.height ) / 2;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyInvoiceType" id="ed1bd802-65ef-4e70-b838-e4c0ecc961fa">
        <updating/>
        <source>setMyInvoiceType( _invType : CM_InvoiceDesc input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

begin

	self.myInvoiceType := _invType;

epilog

end;</source>
        <Parameter name="_invType" type="CM_InvoiceDesc" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setVisibility" id="2214fc23-7490-4ed5-b62b-510aebc1e90a">
        <updating/>
        <source>setVisibility()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/03/2018	jlgndl1	Initial creation	TFS 37818, 37822, 37819
22/06/2018	jlgdap1	TFS 39355 PEL1 Pilot Surcharges
24/08/2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
*/

vars
	hasSelectedACS	: Boolean;
	hasSelectedET	: Boolean;
	hasSelectedAF	: Boolean;
	hasSelectedSCT	: Boolean;
	hasSelectedDMC	: Boolean;
	hasSelectedVMC	: Boolean;
	hasSelectedSP	: Boolean;	// TFS 39355
	hasSelectedGMC	: Boolean;	//20 Mar 2019	NDL	TFS 43687
	hasSelectedISA	: Boolean;	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	
begin
	self.shtACS.enabled	:= false;
	self.shtET.enabled	:= false;
	self.shtAF.enabled	:= false;
	self.shtSCT.enabled	:= false;
	self.shtDMC.enabled	:= false;
	self.shtVMC.enabled	:= false;
	self.shtSP.enabled	:= false;	// TFS 39355
	self.shtGMC.enabled	:= false;	//20 Mar 2019	NDL	TFS 43687
	self.shtISA.enabled	:= false;	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	
	self.btnSave.enabled := self.allowUpdate;
	
	if self.myCurrentInvTypeSurExempt &lt;&gt; null then
		self.shtACS.enabled	:= true;
		self.shtET.enabled	:= true;
		self.shtAF.enabled	:= true;
		self.shtSCT.enabled	:= true;
		self.shtDMC.enabled	:= true;
		self.shtVMC.enabled	:= true;
		self.shtSP.enabled	:= true;	// TFS 39355
		self.shtGMC.enabled	:= true;	//20 Mar 2019	NDL	TFS 43687
		self.shtISA.enabled	:= true;	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	endif;
	
	// ACS Sheet
	if self.tblACS.row &gt; 0 then
		hasSelectedACS := self.tblACS.accessRow(self.tblACS.row).itemObject &lt;&gt; null;
	endif;
	self.btnACSAdd.enabled		:= self.allowUpdate;
	self.btnACSEdit.enabled		:= self.allowUpdate and hasSelectedACS;
	self.btnACSDelete.enabled	:= self.allowUpdate and hasSelectedACS;
	self.btnACSSave.enabled		:= self.allowUpdate;
	
	//ET Sheet
	if self.tblET.row &gt; 0 then
		hasSelectedET := self.tblET.accessRow(self.tblET.row).itemObject &lt;&gt; null;
	endif;
	self.btnETAdd.enabled		:= self.allowUpdate;
	self.btnETEdit.enabled		:= self.allowUpdate and hasSelectedET;
	self.btnETDelete.enabled	:= self.allowUpdate and hasSelectedET;
	self.btnETSave.enabled		:= self.allowUpdate;
	
	// AF Sheet
	if self.tblACS.row &gt; 0 then
		hasSelectedAF := self.tblAF.accessRow(self.tblAF.row).itemObject &lt;&gt; null;
	endif;
	self.btnAFAdd.enabled		:= self.allowUpdate;
	self.btnAFEdit.enabled		:= self.allowUpdate and hasSelectedAF;
	self.btnAFDelete.enabled	:= self.allowUpdate and hasSelectedAF;
	self.btnAFSave.enabled		:= self.allowUpdate;
	
	//SCT Sheet
	if self.tblSCT.row &gt; 0 then
		hasSelectedSCT := self.tblSCT.accessRow(self.tblSCT.row).itemObject &lt;&gt; null;
	endif;
	self.btnSCTAdd.enabled		:= self.allowUpdate;
	self.btnSCTEdit.enabled		:= self.allowUpdate and hasSelectedSCT;
	self.btnSCTDelete.enabled	:= self.allowUpdate and hasSelectedSCT;
	self.btnSCTSave.enabled		:= self.allowUpdate;
	
	//DMC Sheet
	if self.tblDMC.row &gt; 0 then
		hasSelectedDMC := self.tblDMC.accessRow(self.tblDMC.row).itemObject &lt;&gt; null;
	endif;
	self.btnDMCAdd.enabled		:= self.allowUpdate;
	self.btnDMCEdit.enabled		:= self.allowUpdate and hasSelectedDMC;
	self.btnDMCDelete.enabled	:= self.allowUpdate and hasSelectedDMC;
	self.btnDMCSave.enabled		:= self.allowUpdate;
	
	//VMC Sheet
	if self.tblVMC.row &gt; 0 then
		hasSelectedVMC := self.tblVMC.accessRow(self.tblVMC.row).itemObject &lt;&gt; null;
	endif;
	self.btnVMCAdd.enabled		:= self.allowUpdate;
	self.btnVMCEdit.enabled		:= self.allowUpdate and hasSelectedVMC;
	self.btnVMCDelete.enabled	:= self.allowUpdate and hasSelectedVMC;
	self.btnVMCSave.enabled		:= self.allowUpdate;
	
	// SP Sheet																		// TFS 39355
	if self.tblSP.row &gt; 0 then														// TFS 39355
		hasSelectedSP := self.tblSP.accessRow(self.tblSP.row).itemObject &lt;&gt; null;	// TFS 39355
	endif;																			// TFS 39355
	self.btnSPAdd.enabled		:= self.allowUpdate;								// TFS 39355
	self.btnSPEdit.enabled		:= self.allowUpdate and hasSelectedSP;				// TFS 39355
	self.btnSPDelete.enabled	:= self.allowUpdate and hasSelectedSP;				// TFS 39355
	self.btnSPSave.enabled		:= self.allowUpdate;								// TFS 39355
	
	//GMC Sheet	- 20 Mar 2019	NDL	TFS 43687
	if self.tblGMC.row &gt; 0 then
		hasSelectedGMC := self.tblGMC.accessRow(self.tblGMC.row).itemObject &lt;&gt; null;
	endif;
	self.btnGMCAdd.enabled		:= self.allowUpdate;
	self.btnGMCEdit.enabled		:= self.allowUpdate and hasSelectedGMC;
	self.btnGMCDelete.enabled	:= self.allowUpdate and hasSelectedGMC;
	self.btnGMCSave.enabled		:= self.allowUpdate;
	
	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	// ISA Sheet
	if self.tblISA.row &gt; 0 then
		hasSelectedISA := self.tblISA.accessRow(self.tblISA.row).itemObject &lt;&gt; null;
	endif;
	self.btnISAAdd.enabled		:= self.allowUpdate;
	self.btnISAEdit.enabled		:= self.allowUpdate and hasSelectedISA;
	self.btnISADelete.enabled	:= self.allowUpdate and hasSelectedISA;
	self.btnISASave.enabled		:= self.allowUpdate;
	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="57f2e6e5-63f2-4a63-994a-53c905d3a1cc">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

begin

	self.allowUpdate := app.getMyUser.canDo( self.myTerminal, PmAdmInvSurchargesMaint );

	self.minimumWidth := 620;
	self.minimumHeight := 320;

	self.frmMain.left := 1;
	self.frmMain.top := 1;
	self.frmMain.width := self.clientWidth - 2;
	self.frmMain.height := self.clientHeight - 2;
	self.frmMain.parentAspect := 3; //Stretch both
	
	inheritMethod();

	self.populateCombos();
	
	self.populateBaseData();
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideFrmACS" id="da71cb6e-4f5f-423b-8b3d-aca04ddf0ee3">
        <updating/>
        <source>showHideFrmACS( _hide : Boolean; _rate : CM_DebtorSurchargeRate ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

	invalidObj : Boolean;
	load : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, self.myProxyDrSurRate, invalidObj );
	if self.myProxyDrSurRate &lt;&gt; null then
		delete self.myProxyDrSurRate;
	endif;
	
	if not _hide then
		self.resize();
	endif;
	
	self.frmACS.visible := not _hide;
	self.frmMain.enabled := _hide;
	
	self.cmbACSInvLineType.listIndex := -1;
	self.cmbACSDebtor.listIndex := -1;
	self.txtACSPercent.text := null;
	
	if not _hide then
		self.frmACS.ignoreSkin := true;
		if _rate &lt;&gt; null then
			if  _rate.getSurchargeInvoiceLineType &lt;&gt; null then
				self.cmbACSInvLineType.listIndex := self.cmbACSInvLineType.findObject( _rate.getSurchargeInvoiceLineType );
			endif;
			if  _rate.myDebtor &lt;&gt; null then
				self.cmbACSDebtor.listIndex := self.cmbACSDebtor.findObject( _rate.myDebtor );
			endif;
			self.txtACSPercent.text := _rate.surchargeRate.asStringJMT();
			app.cmsBeginLoad( load );
			self.myProxyDrSurRate := _rate.pxyCreateUpdateProxy();
			app.cmsEndLoad( load );
		else
			create self.myProxyDrSurRate transient;
		endif;
		self.frmMain.zOrder(0);
	endif;

epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_rate" type="CM_DebtorSurchargeRate"/>
    </JadeMethod>
    <JadeMethod name="showHideFrmAF" id="855759d0-cff4-4bf8-a4e3-33b829132167">
        <updating/>
        <source>showHideFrmAF( _hide : Boolean; _aFee : CM_InvTypeAdditionalCharges ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgndl1	Initial creation	TFS 37819

*/

vars

	invalidObj : Boolean;
	load : Boolean;
	rowIndex : Integer;
	invLineType : CM_InvoiceLineDesc;

begin

	on Exception do app.handleDeletedObject( exception, self.myProxyAFCharges, invalidObj );
	if self.myProxyAFCharges &lt;&gt; null then
		delete self.myProxyAFCharges;
	endif;
	
	if not _hide then
		self.resize();
	endif;
	
	self.frmAF.visible := not _hide;
	self.frmMain.enabled := _hide;
	
	foreach rowIndex in 1 to self.lstAFInvLineTypes.rows do
		self.lstAFInvLineTypes.accessCell(rowIndex,1).text := '0';
	endforeach;
	self.cmbAFDebtor.listIndex := -1;
	self.txtAFRangeStart.text := null;
	self.txtAFRangeEnd.text := null;
	
	if not _hide then
		self.frmAF.ignoreSkin := true;
		if _aFee &lt;&gt; null then
			foreach rowIndex in 1 to self.lstAFInvLineTypes.rows do
				invLineType := self.lstAFInvLineTypes.accessRow(rowIndex).itemObject.CM_InvoiceLineDesc;
				if invLineType &lt;&gt; null and _aFee.allAdditionChargeInvTypes.includes(invLineType) then
					self.lstAFInvLineTypes.accessCell(rowIndex,1).text := '1';
				endif;
			endforeach;
			if  _aFee.myDebtor &lt;&gt; null then
				self.cmbAFDebtor.listIndex := self.cmbAFDebtor.findObject( _aFee.myDebtor );
			endif;
			self.txtAFRangeStart.text := _aFee.rangeStart.asStringJMT();
			self.txtAFRangeEnd.text := _aFee.rangeEnd.asStringJMT();
			app.cmsBeginLoad( load );
			self.myProxyAFCharges := _aFee.pxyCreateUpdateProxy();
			app.cmsEndLoad( load );
		else
			create self.myProxyAFCharges transient;
		endif;
		self.frmMain.zOrder(0);
	endif;

epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_aFee" type="CM_InvTypeAdditionalCharges"/>
    </JadeMethod>
    <JadeMethod name="showHideFrmDMC" id="ddf6a12a-61b3-4411-b812-cc8d8e482929">
        <updating/>
        <source>showHideFrmDMC( _hide : Boolean; _minChg : CM_InvTypeDebtorMinCharge ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2018	jlgndl1	Initial creation	TFS 38914

*/

vars

	invalidObj : Boolean;
	load : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, self.myProxyDMCharges, invalidObj );
	if self.myProxyDMCharges &lt;&gt; null then
		delete self.myProxyDMCharges;
	endif;
	
	if not _hide then
		self.resize();
	endif;
	
	self.frmDMC.visible := not _hide;
	self.frmMain.enabled := _hide;
	
	self.cmbDMCInvLineType.listIndex := -1;
	self.cmbDMCDebtor.listIndex := -1;
	self.txtDMCMinCharge.text := null;
	
	if not _hide then
		self.frmDMC.ignoreSkin := true;
		if _minChg &lt;&gt; null then
			if  _minChg.getMinimumChargeInvLineType &lt;&gt; null then
				self.cmbDMCInvLineType.listIndex := self.cmbDMCInvLineType.findObject( _minChg.getMinimumChargeInvLineType );
			endif;
			if  _minChg.myDebtor &lt;&gt; null then
				self.cmbDMCDebtor.listIndex := self.cmbDMCDebtor.findObject( _minChg.myDebtor );
			endif;
			self.txtDMCMinCharge.text := _minChg.minimumChargeAmount.asStringJMT();
			app.cmsBeginLoad( load );
			self.myProxyDMCharges := _minChg.pxyCreateUpdateProxy();
			app.cmsEndLoad( load );
		else
			create self.myProxyDMCharges transient;
		endif;
		self.frmMain.zOrder(0);
	endif;

epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_minChg" type="CM_InvTypeDebtorMinCharge"/>
