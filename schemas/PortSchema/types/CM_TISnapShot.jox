    <JadeMethod name="hsCode" id="7b72ea63-4994-4cfc-9ec5-6808a02dcb94">
        <methodInvocation>mapping</methodInvocation>
        <source>hsCode(set: Boolean; _value: String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if set then
		global.setExtraData(self.allExtraData, self, HSCode, _value);
	else
		global.getExtraData(self.allExtraData, HSCode, _value);
	endif;

epilog

end;</source>
