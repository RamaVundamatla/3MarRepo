        <source>valPrenoteHazardous(_pxyTI : CM_TrackedItem; 
					_hazHazLabels : Boolean;
					_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	cnwer1	Initial creation

*/

vars
	realTI : CM_TrackedItem;
begin
	
	realTI:=_pxyTI.pxyGetRealObject;
	if realTI = null then
		return;
	endif;
	
	if realTI.isPreNote then
		if realTI.isHazardous and not _hazHazLabels then
			
			app.raiseCMWarning(Cargo_Not_Haz_Prenote_Haz,null,null,null);
		elseif not realTI.isHazardous and _hazHazLabels then
			//Cargo_Haz_Labels_Prenote_Not
			app.raiseCMWarning(Cargo_Haz_Labels_Prenote_Not,null,null,null);
			
		endif;
	endif;
	
epilog
	
end;</source>
