    <JadeMethod name="importMyReferencesXML" id="0c5bdcd7-c5d7-4f5c-8ab4-950653d651b4">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	opCode					: String;
	terminal				: CM_Terminal;
	operator				: CM_Operator;
begin
	terminal := app.myRoot.allTerminals['POE'];
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'POE terminal could not be found');
		return;
	endif;
	
	opCode := _referencesBlock.cnEcGetTagValueOfName('myOperator');
	operator := app.myRoot.allOperators[opCode];
	if operator = null then
		return;
	endif;
	
	if operator.allStockOrderHeaders[self.orderNo] &lt;&gt; null or
	   operator.allStkOrdByProcessFulfillStat[self.processOption, self.fulfilledStatus, self.orderNo] &lt;&gt; null then
		return;
	endif;

	self.myOperator := operator;
	
	if terminal.allStockOrderHeaders[self.type, self.myOperator, self.orderNo] &lt;&gt; null or
	   terminal.allStkOrdByProcessFulfillStat[self.processOption, self.fulfilledStatus, self.orderNo] &lt;&gt; null then
		return;
	endif;

	self.myTerminal := terminal;

end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
