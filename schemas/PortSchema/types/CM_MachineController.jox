/*

Purpose:			


Return Value:		


Date		Who		Reason
16 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod(queueSet);

	if self.myTerminal &lt;&gt; null then
		self.myTerminal.getQueues(queueSet);
	endif;
	
epilog

end;</source>
        <Parameter name="queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
