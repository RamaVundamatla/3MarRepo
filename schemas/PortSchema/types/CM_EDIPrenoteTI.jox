    <JadeMethod name="doDefaultInvalidVoyageToNull" id="e1b1c960-cdd2-4453-ae35-d3e7da446fbf">
        <source>doDefaultInvalidVoyageToNull():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 January 2019	jlgndl1	Initial creation	TFS 42303
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 

*/

vars

begin

	if self.myEDIData &lt;&gt; null and self.myEDIData.isKindOf( CM_EDIDataPrenote ) then
		return self.myEDIData.CM_EDIDataPrenote.doDefaultInvalidVoyageToNull();
