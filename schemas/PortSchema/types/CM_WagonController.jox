    <JadeMethod name="getWLEForTI" id="e86e437e-acb4-4826-a078-610ad774050c">
        <source>getWLEForTI(_ti: CM_TrackedItem): CM_WorkListEntry;
/*
Purpose:			

Date		Who		Reason
10 February 2022	navab1	TFS 51855
*/

vars

	job : CM_Job;
	wle : CM_WorkListEntry;
begin
	if self.myWagon &lt;&gt; null then
	
		foreach job in self.myWagon.allRailJobs discreteLock do
			foreach wle in job.workListEntries discreteLock do
				if wle.myTrackedItem = _ti then
					return wle;
				endif;
				
			
			endforeach;
		endforeach;
		
	
	endif;
	return inheritMethod(_ti);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
