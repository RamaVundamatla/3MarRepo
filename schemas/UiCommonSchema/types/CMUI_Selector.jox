        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//----------------------------------------------------------------
//	Created:	08 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin


	self.handleNotification(eventType, theObject, eventTag, userInfo);
	

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateCriteriaLineRemoval" id="709e44b2-5c17-452c-b158-644adbb8c8e4">
        <source>validateCriteriaLineRemoval(_crit : CM_SelectorCriteriaLine) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:   
// 25/03/2024   navrv30		Bug 62640: MTN - Selector Translations  		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _crit = null then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(CMUI_Selector_CriteriaLine), app.getErrorString(Delete)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	if (_crit.myQueryProperty.propertyName = 'site') and (self.defaultSiteStr &lt;&gt; null) then
		app.msgBox(app.getErrorString1(CMUI_Selector_No_Retreive, app.getErrorString(Site)), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return false;
	elseif (self.myTerminal &lt;&gt; null) and 
	   (_crit.myQueryProperty.propertyName = 'myTerminal' or _crit.myQueryProperty.propertyName = 'getTerminal') then		// 34364 getTerminal for invoice line
		app.msgBox(app.getErrorString1(CMUI_Selector_No_Retreive, app.getErrorString(Terminal)), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return false;
	elseif (_crit.myQueryProperty.propertyName = 'isInwards') and (self.bolClass &lt;&gt; null) then
		app.msgBox(app.getErrorString1(CMUI_Selector_No_Retreive, app.getErrorString(DocketType)), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return false;
	elseif (_crit.myQueryProperty.propertyName = 'bolType') and (self.myQDef.mode &gt; BOLType_Min) then
		app.msgBox(app.getErrorString1(CMUI_Selector_No_Retreive, app.getErrorString(DocketType)) , app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return false;
	elseif _crit.myQueryProperty.propertyName = 'voyageCode' and self.myDefaultVoyage &lt;&gt; null then
		app.msgBox(app.getErrorString1(CMUI_Selector_No_Retreive, app.getErrorString(Voyage)), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return false;
	elseif (_crit.myQueryProperty.propertyName = 'bayId') and (not self.allDefaultBays.isEmpty) then
		app.msgBox(app.getErrorString1(CMUI_Selector_No_Retreive, app.getErrorString(Bay)), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return false;
	elseif (_crit.myQueryProperty.propertyName = 'myTerminalArea') and (not self.allDefaultTerminalAreas.isEmpty) then
		app.msgBox(app.getErrorString1(CMUI_Selector_No_Retreive, app.getErrorString(TerminalArea)), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return false;
	//this is Log property stuff - because they have dependancies
	elseif (_crit.myQueryProperty.propertyName = 'operatorCode') then
		if _crit.myCriteriaLineHolder.allCriteriaByPropertyName.includesKey('myLogSpecies', 'CM_Log') then
			// 25/03/2024   navrv30		Bug 62640
			app.msgBox(app.getErrorString(Must_first_remove_specie_crite), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	
	elseif (_crit.myQueryProperty.propertyName = 'myLogSpecies') then
		if _crit.myCriteriaLineHolder.allCriteriaByPropertyName.includesKey('myLogGrade', 'CM_Log') then
			app.msgBox(app.getErrorString(Must_first_remove_grade_criter), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	elseif _crit.myQueryProperty.propertyName = 'myLogGrade' then
		if _crit.myCriteriaLineHolder.allCriteriaByPropertyName.includesKey('myLogType', 'CM_Log') then
			app.msgBox(app.getErrorString(Must_first_remove_type_criter), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	
		if _crit.myCriteriaLineHolder.allCriteriaByPropertyName.includesKey('myLogTreatment', 'CM_Log') then
			app.msgBox(app.getErrorString(Must_first_remove_treatm_crite), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		
		if _crit.myCriteriaLineHolder.allCriteriaByPropertyName.includesKey('myLogLength', 'CM_Log') then
			app.msgBox(app.getErrorString(Must_first_remove_length_crite), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;	
	elseif _crit.myQueryProperty.propertyName = 'cargoType' then
		if _crit.myCriteriaLineHolder.allCriteriaByPropertyName.includesKey('myProduct', 'CM_TrackedItem') then
			app.msgBox(app.getErrorString(Remove_cargo_subtype_criteria), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endif;


	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_crit" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCriteriaLineUpdate" id="9b6d8aac-bf1b-49e8-a532-423ee4696ccd">
        <source>validateCriteriaLineUpdate(_propertyName : String) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     24 November 2003	cnwth2
//
// Purpose:     
//		
// 25/03/2024   navrv30		Bug 62640: MTN - Selector Translations	 
// ----------   ----------  --------------------------------------------------
vars
	tblSheet			: JadeTableSheet;
	tbl					: CM_DataTable;
	criteriaHolder		: CM_QueryCriteriaLineHolder;
begin
	tbl := self.tblCriteria;
	tblSheet := tbl.accessSheet(tbl.topSheet);
	criteriaHolder := tblSheet.itemObject.CM_QueryCriteriaLineHolder;
	
	if _propertyName = 'operatorCode' then
		if criteriaHolder.allCriteriaByPropertyName['myLogSpecies', 'CM_Log'] &lt;&gt; null then
			app.msgBox(app.getErrorString(Must_first_remove_specie_crite), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	
	elseif _propertyName = 'myLogSpecies' then
		if criteriaHolder.allCriteriaByPropertyName.includesKey('myLogGrade', 'CM_Log') then
			app.msgBox(app.getErrorString(Must_first_remove_grade_criter), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	
	elseif _propertyName = 'myLogGrade' then
		if criteriaHolder.allCriteriaByPropertyName.includesKey('myLogType', 'CM_Log') then
			app.msgBox(app.getErrorString(Must_first_remove_type_criter), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	
		if criteriaHolder.allCriteriaByPropertyName.includesKey('myLogTreatment', 'CM_Log') then
			app.msgBox(app.getErrorString(Must_first_remove_treatm_crite), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		
		if criteriaHolder.allCriteriaByPropertyName.includesKey('myLogLength', 'CM_Log') then
			app.msgBox(app.getErrorString(Must_first_remove_length_crite), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;	
	elseif _propertyName = 'cargoType' then
		if criteriaHolder.allCriteriaByPropertyName.includesKey('myProduct', 'CM_TrackedItem') then
			app.msgBox(app.getErrorString(Remove_cargo_subtype_criteria), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endif;


	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_propertyName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="valuesCleanUp" id="1b203b4b-9125-4642-8042-f35109f98178">
        <updating/>
        <source>valuesCleanUp() updating;
// cnwjre1 May 2011 27097, reset stuff set up from calling forms
vars
	obj	: Object;
begin
	foreach obj in self.values do
		if obj.isKindOf(CM_Association) or obj.isKindOf(CM_ObjectSet) then
			delete obj;
		endif;
	endforeach;
	self.operators.clear();
	self.properties.clear();
	self.values.clear();
	self.mnuSendCargo.visible := false;
	self.mnuSendLocation.visible := false;
	self.mnuSendGridObj.visible := false;
end;</source>
    </JadeMethod>
</GUIClass>
