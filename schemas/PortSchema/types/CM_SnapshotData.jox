    <JadeMethod name="getInvoiceLineCount" id="36333675-7106-43d9-8acd-605202ba417a">
        <source>getInvoiceLineCount() : Integer;
// Nov 2010 for CCMS 1043, show number of generated invoice lines in snapshot summary form
vars
	count	: Integer;
	dos		: CM_DynamicObject_Snapshot;
	invLine	: CM_InvoiceLine;
begin
	foreach dos in self.allSnapshotData do
		foreach invLine in dos.allInvoiceLines do 
			count := count + 1;
		endforeach;
	endforeach;
	
	return count;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
