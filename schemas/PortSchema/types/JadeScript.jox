    <JadeMethod name="qnsAddManualLine" id="c9ba2be5-da52-4559-8f32-beebd5b65171">
        <source>qnsAddManualLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 January 2019	jlgma1	Initial creation
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	cashPayment : CM_CashPayment;
	cashRec     : CM_CashReceipt;
	invoice     : CM_Invoice;
	service     : CM_Service;
	invLineDesc : CM_InvoiceLineDesc;
	term        : CM_Terminal;
	bank        : CM_Bank;
	newLine     : CM_InvoiceLine;
	debtor : CM_Debtor;
	seqNum : Integer;
	charge : CM_Charge;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
    term := app.myRoot.allTerminals["CASH"]; 
	bank := term.companies["MILA"];
	
	
	cashPayment := "".asOid.CM_CashPayment;
	cashRec     := "".asOid.CM_CashReceipt;
	invoice     := "".asOid.CM_Invoice;
	service     := "".asOid.CM_Service;
	invLineDesc := "".asOid.CM_InvoiceLineDesc;

	debtor := cashPayment.getDebtor();
	
	create newLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
	newLine.setForCreate(	seqNum,
							true,
							null,
							invLineDesc,
							invoice,
							debtor,
							bank,
							1,
							cashPayment.createdTime
							);
	newLine.createCharges;
	foreach charge in newLine.charges do
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
		endif;
		charge.evaluateRate();
		charge.total := cashPayment.cashValue;
		charge.setOverriden();
		charge.setRateForMinMax(charge.total);
	endforeach;
	if newLine &lt;&gt; null then
		cashPayment.setPropertyValue("myInvoiceLine",newLine);
	endif;
epilog
	
	

	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="qnsCashTotalPaymentTotal" id="fb2c4d2c-ede9-44bd-a06a-bb272f68e14f">
        <source>qnsCashTotalPaymentTotal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2019	jlgma1	Initial creation

*/


vars

	term : CM_Terminal;
	pel : CM_Pelindo1Interface;
	currentInv,
	orginalInv: CM_Invoice;
	bank    : CM_Bank;
	cashRecsExcluded: ObjectArray;
	invLine			: CM_InvoiceLine;
	voyage      	: CM_Voyage;
	wo 			 	: CM_WorkOrder;
	cashRec      	: CM_CashReceipt;
	proforma     	: CM_ProformaDetails;
	cashRecMatched  : ObjectArray;
	obj : Object;
	lFile      		: File;
begin
	
	if app.myPassport = null then
		app.initialize;
	endif;

	
	term := app.myRoot.allTerminals["1002"]; 
	bank := term.companies["INT"];
	currentInv := bank.allInvoices[term,bank,2859];
	
	if currentInv.myOriginalAddFeesInvoice &lt;&gt; null then
	
		orginalInv := currentInv.myOriginalAddFeesInvoice;
	endif;
	
	if term = null or orginalInv = null  or bank = null then 
		app.msgBox("false1","",0);
	endif;
			
	
	if orginalInv.myVoyage = null then
		app.msgBox("orginalInv.myVoyage = null",orginalInv.myVoyage.code,0);
	endif;
	
	app.msgBox("orginalInv Voyage",orginalInv.myVoyage.code,0);
	
	
	voyage :=currentInv.myVoyage;
	
	app.msgBox("currentInv Voyage",currentInv.myVoyage.code,0);

	create cashRecsExcluded transient;
	create cashRecMatched transient;
	foreach invLine   in currentInv.invoiceLines discreteLock do  //Invoice Lines Loop
		
		if invLine.manual then
			continue;
		endif;
		
		foreach wo in voyage.allWorkOrders discreteLock do  			  // Work Order Loop //02.10.2019 cnwma1 #46853
			
			if wo.taskStatus = WO_STATUS_CANCELLED then  // 05.12.2018 cnwma1 42366
				continue;
			endif;
			
			foreach cashRec in wo.allCashReceipts discreteLock do    // Cash Receipt Loop  //02.10.2019 cnwma1 #46853
				
				if cashRec.getDebtor &lt;&gt; currentInv.getDebtor then
					continue;
				endif;
				
				if cashRec.paymentType &lt;&gt; currentInv.paymentType then
					continue;
				endif;
				
				/*
				First Iteration
				*/
				if not cashRecsExcluded.includes(cashRec) then
					foreach proforma in cashRec.allProformaDetails discreteLock do           //02.10.2019 cnwma1 #46853
					
						if proforma.transactionType = 0 then
							continue;
						endif;
						
						if proforma.myInvoiceLineType.invoiceType &lt;&gt;  currentInv.invoiceType then   //08.12.2018 cnwma1 TFS #42441
							continue;
						endif;
						
						if proforma.myInvoiceLineType &lt;&gt; invLine.invoiceLineDesc then
							continue;
						endif;
							
						if proforma.quantity &lt;&gt; invLine.quantity then
							continue;
						endif;
						
						if proforma.lineTotal &lt;&gt; invLine.lineTotal then
							continue;
						endif;
						//return cashRec;
						cashRecMatched.addExclusive(cashRec);
						cashRecsExcluded.addExclusive(cashRec);
					endforeach;
					
					/*
					21.11.2018 cnwma1 TFS #42129
					A second iteration of searching without taking the invoice line qty or total as a factor
					*/
					foreach proforma in cashRec.allProformaDetails discreteLock do           //02.10.2019 cnwma1 #46853
					
						if proforma.transactionType = 0 then
							continue;
						endif;
						
						if proforma.myInvoiceLineType.invoiceType &lt;&gt;  currentInv.invoiceType then   //08.12.2018 cnwma1 TFS #42441
							continue;
						endif;
						
						if proforma.myInvoiceLineType &lt;&gt; invLine.invoiceLineDesc then
							continue;
						endif;
						
						
						if invLine.myTransactionHMS &lt;&gt; null then
							if proforma.transactionType &lt;&gt; invLine.myTransactionHMS.type then
								continue;
							endif;
						endif;
						cashRecMatched.addExclusive(cashRec);
						cashRecsExcluded.addExclusive(cashRec);
					endforeach;
					/*
						08.12.2018 cnwma1 Bug #42441
						3rd Iteration to handle creating invoices from estimations with diffrent invoice line type,
						The Only thing we going to match here the GL Code of the invoice line used by the esstimation and invoice line
						used by the invoice.
					*/
					foreach proforma in cashRec.allProformaDetails discreteLock do       //02.10.2019 cnwma1 #46853
					
						if proforma.transactionType = 0 then
							continue;	
						endif;
						if proforma.myInvoiceLineType.invoiceType &lt;&gt; invLine.invoiceLineDesc.invoiceType then
							continue;
						endif;
						
						/* Checking the GL Code*/
						
						if proforma.getServiceGLCode &lt;&gt;  invLine.getServiceGLCode  then
							continue;
						endif; 
						if proforma.getServiceGLCode &lt;&gt; null and invLine.getServiceGLCode &lt;&gt; null then 
							cashRecMatched.addExclusive(cashRec);
							cashRecsExcluded.addExclusive(cashRec);
						endif;
					endforeach;
					
						foreach proforma in cashRec.allProformaDetails discreteLock do       //02.10.2019 cnwma1 #46853
					
							
					
							if proforma.myInvoiceLineType.invoiceType &lt;&gt; invLine.invoiceLineDesc.invoiceType then
								continue;
							endif;
						
					
							
								cashRecMatched.addExclusive(cashRec);
								cashRecsExcluded.addExclusive(cashRec);
					
					endforeach;
				endif;
			endforeach;
		endforeach; // Work Order Loop

	endforeach;   //Invoice Lines Loop
	
	if cashRecMatched.isEmpty then
		app.msgBox("Empty","",0);
	endif;
	if cashRecMatched.isNotEmpty then
		create lFile transient;
		 lFile.fileName := "C:\temp\PEL\ccc.csv";
		 lFile.open;
		
		foreach obj in cashRecMatched discreteLock do
			lFile.writeLine(obj.CM_CashReceipt.externalInvoiceNumber);
		
		endforeach;
		 lFile.close;
	endif;
	
epilog
	delete cashRecMatched;
	delete cashRecsExcluded;
		delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="randomString" id="577e3f53-beea-4ff0-a84d-a3d2327828ad">
        <source>randomString(_length : Integer): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	navcs2	Initial creation

*/

vars
	letters : String;
	result 	: String;
	index	: Integer;
	i		: Integer;
begin
	letters := "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ";
    foreach i in 0 to _length do
        index := app.random(letters.length-1)+1;
        result := result &amp; letters[index];
	endforeach;
	
    return result;
epilog

end;</source>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
