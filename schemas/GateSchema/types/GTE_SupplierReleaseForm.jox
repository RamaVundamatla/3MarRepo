    <JadeMethod name="addObjectsToTable" id="fee0c8d6-b9bc-4edd-9736-ee61ac36bbe7">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	object	: Object;
	order	: CM_StockOrderHeader;
	passport : CM_Passport;
	breakOut	: Boolean;
begin
	passport := app.myPassport;
	
	foreach order in self.myTerminal.allStockOrderHeaders do
		if self.includeObject(order, passport) then
			self.addObjectToTable(order, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="autoSetQuantity" id="47cb1e39-0358-4fa3-a294-441d073e3392">
        <source>autoSetQuantity() protected;

// cnwdvb1 23 October 2002 

vars

	location	: CM_LocationsController;
	soh			: CM_SOHLocation;
	unit		: String;

begin

	unit := self.tblInput1.getValueByName(ETRow_WholeRow).String;
	if unit = Choice_All then	
		location := self.cmbLocations.listObject.CM_LocationsController;	
		if location &lt;&gt; null then
			soh := self.getSOH(location);
			if soh &lt;&gt; null then
				self.tblInput1.setValueByName(ETRow_ReqdQuantity, soh.allTrackedItems.size.String);
			endif;		
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="changeView" id="4ac37d52-aa04-4369-a2a2-866d4712bbe5">
        <updating/>
        <source>changeView(_cargoType : CM_CargoType) protected, updating;

// cnwdvb1 18 October 2002 

vars

begin

	if _cargoType &lt;&gt; null then
		self.myCargoType := _cargoType;
		if self.myCargoType.id = TI_CargoType_Log  then
			self.tblInput1.showHideRowsByViewName('viewSuppRelLog', CM_EntryTable.ShowHideRows, false); 
		else
			self.tblInput1.showHideRowsByViewName('viewSuppRelOther', CM_EntryTable.ShowHideRows, false); 
			self.loadProductTypes(_cargoType);
		endif;
		self.tblInput1.adjustHeight(1000);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="clear" id="fc8e215d-1485-4f5b-a2dd-fc9ed35706b4">
        <source>clear(_level : Integer) protected;

vars

begin

	if _level &gt;=CLEAR_SUPPLIER then
		self.tblInput1.setValueByName(ETRow_Supplier, null);
	endif;
	
	if _level &gt;=CLEAR_SPECIES then
		self.tblInput1.setValueByName(ETRow_LogSpecies, null);
		self.cmbSpecies.clear;
		self.cmbSpecies.setObjectAndOperator(null,null);
	endif;
	
	if _level &gt;=CLEAR_GRADE then
		self.tblInput1.setValueByName(ETRow_LogGrade, null);
		self.cmbGrade.clear;
		self.cmbGrade.setObjectAndSpecies(null,null);
	endif;
	
	if _level &gt;=CLEAR_TTL then
		self.tblInput1.setValueByName(ETRow_LogType, null);
		self.cmbType.clear;
		self.cmbType.setObjectAndGrade(null,null);
		self.tblInput1.setValueByName(ETRow_LogTreatment, null);
		self.cmbTreatment.clear;
		self.cmbTreatment.setObjectAndGrade(null,null);
		self.tblInput1.setValueByName(ETRow_LogLength, null);
		self.cmbLength.clear;
		self.cmbLength.setObjectAndGrade(null,null);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearForm" id="657e4b90-eb0f-4a2a-a232-78f642075134">
        <source>clearForm() protected;

// cnwdvb1 24 October 2002 

vars

begin

	self.tblInput1.setValueByName(ETRow_OrderNo, null);
	self.tblInput1.setValueByName(ETRow_ReqdQuantity, null);
	self.tblInput1.setValueByName(ETRow_MyOperator, null);
	self.tblInput1.setValueByName(ETRow_Quantity, null);

//	self.cmbOperator.listObject := null;
	self.cmbOperator.setObject(null);
	self.tblInput1.setValueByName(ETRow_Audit, 0);
	self.tblInput1.setValueByName(ETRow_Comments, null);
	
	self.tblInput1.setValueByName(ETRow_Transfer, 0);
	self.tblInput1.setValueByName(ETRow_MyConsignee, null);
//	self.cmbConsignee.listObject := null;
	self.cmbConsignee.clear();
	self.cmbConsignee.setObject(null);
	self.tblInput1.setValueByName(ETRow_Terminal, null);
	self.cmbTerminal.listObject := null;
	self.tblInput1.setValueByName(ETRow_WholeRow, Choice_All);
	self.cmbWhole.text := Choice_All;
	self.tblInput1.setValueByName(ETRow_LogSpecies, null);
//	self.cmbSpecies.listObject := null;
	self.cmbSpecies.setObjectAndOperator(null,null);
	self.tblInput1.setValueByName(ETRow_LogGrade, null);
//	self.cmbGrade.listObject := null;
	self.cmbGrade.setObject(null);
	self.tblInput1.setValueByName(ETRow_LogType, null);
//	self.cmbType.listObject := null;
	self.cmbType.setObject(null);
	self.tblInput1.setValueByName(ETRow_LogTreatment, null);
//	self.cmbTreatment.listObject := null;
	self.cmbTreatment.setObject(null);
	self.tblInput1.setValueByName(ETRow_LogLength, null);
//	self.cmbLength.listObject := null;
	self.cmbLength.setObject(null);
	self.tblInput1.setValueByName(ETRow_Location, null);
	self.cmbLocations.listObject :=	null;
	self.cmbProduct.listObject := null;
end;</source>
        <access>protected</access>
    </JadeMethod>
