    <JadeMethod name="doesTIMatchMe" id="35ec4622-fea8-4c7f-923d-904539257a36">
        <source>doesTIMatchMe(_cmifAutoPlan : CMIF_YAAutoPlan) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2010	cnwdap1	Initial creation
*/
vars
	criteria : CM_YACargoCheckCriteria;

begin
	foreach criteria in self.allCriteria do
		if not criteria.isCMIFAutoPlanDataMatch(_cmifAutoPlan) then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="34c7ac63-d485-4791-851d-51e2213dda0d">
        <source>getDisplayString() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/02/2010	cnwdap1	Initial creation
04/03/2010	cnwdap1	PAR #22741 Include criteria description string
09/03/2010	cnwdap1	PAR #22742 Return Yes/No for required, not boolean value
*/
vars
	str 		: String;
	criteria	: CM_YACargoCheckCriteria;
	text		: String;

begin
	foreach criteria in self.allCriteria do
		text := text &amp; criteria.getListDisplay &amp; " ";
	endforeach;
	
	str := self.name &amp; Tab;
	if self.myToDoTaskDesc &lt;&gt; null then	
		str := str &amp; self.myToDoTaskDesc.description &amp; Tab;
	else
		str := str &amp; Tab;
	endif;
	str := str &amp; self.requiredExtraInfo &amp; Tab &amp; self.required.cnEcGetYesNo &amp; Tab &amp; text;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="cd9c55f8-2255-4628-97e2-0df347ed2866">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2010	cnwdap1	Initial creation
*/
vars

begin
	if _attrName = ETRow_Name then
		return self.name;
	elseif _attrName = ETRow_ToDoTask then
		return self.myToDoTaskDesc.description;
	elseif _attrName = ETRow_RequiredExtraInfo then
		return self.requiredExtraInfo;
	elseif _attrName = ETRow_Required then
		return self.required.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidForTallyman" id="8889cfaa-018c-4cf2-b053-521ddc8516aa">
        <source>isValidForTallyman( _ti : CM_TrackedItem ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars
	sealCheckType : Integer;
begin
	if _ti = null then
		return false;
	endif;
	
	if ( not self.myCargoCheck.context = CARGO_CHECK_CONTEXT_TMANLOAD
	and not self.myCargoCheck.context = CARGO_CHECK_CONTEXT_TMANDISC ) then
		return false;
	endif;
	
	if self.requiredExtraInfo = "Seals" then
		// only valid for seals if "SHIP" seals check type set to a recordable value.
		if self.myCargoCheck.context = CARGO_CHECK_CONTEXT_TMANLOAD then
			sealCheckType := _ti.getSealCheckTypeForContext(CARGO_CHECK_CONTEXT_SHIP_LOAD); // yes deliberately use the Ship one...
		elseif self.myCargoCheck.context = CARGO_CHECK_CONTEXT_TMANDISC then
			sealCheckType := _ti.getSealCheckTypeForContext(CARGO_CHECK_CONTEXT_SHIP_DISC);
		endif;
		if sealCheckType = SEAL_CHECK_VIEW	//2
		or sealCheckType = SEAL_CHECK_FULL	//3
		or  sealCheckType = SEAL_CHECK_STRICT //	4
		then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="persistCriteria" id="ea1f960b-1f92-4d17-9ea6-0a39e8a72723">
        <updating/>
        <source>persistCriteria(_allTransientCriteriaObj : CMIF_Array; _passport : CM_Passport input) updating;
/*
Purpose:			Persists the transient filter cirterai from transient representations

Parameters:			_allTransientCriteriaObj - an array of transient objects containing the criteria information
					_passport - the user's "passport"

Return Value:		None

Date		Who		Reason
28/02/2010	cnwdap1	CCMS 1071 - Cargo Checks
*/
vars
	criteriaObj		: CM_YACargoCheckCriteria;
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	realCPObj		: CM_YACriteriaPriority;
	isCreateDone	: Boolean;
	isDeleteDone	: Boolean;
	isUpdateDone	: Boolean;

begin
	foreach criteriaObj in self.allCriteria reversed do
		criteriaObj.setPriorityValue(criteriaObj.priorityValue * -1);
	endforeach;
	
	isCreateDone	:= false;
	isDeleteDone	:= false;
	isUpdateDone	:= false;
	
	foreach cmifObject in _allTransientCriteriaObj do
		transientObj	:= cmifObject.CMIF_YACriteriaPriority;
		proxyObj		:= transientObj.myProxy;
		realCPObj		:= transientObj.myCriteriaPriority;
		proxyObj.CM_YACargoCheckCriteria.setCargoCheckItem(self);
		
		// Do "New" first, because the "changed" flag can be set if a new Criteria
		// is changed after it is added, but before it is saved to the database
		if transientObj.isNew then
			app.myUtilityCA.utlCreateYACriteriaPriority(proxyObj, realCPObj, _passport);
			isCreateDone := true;
			
		elseif transientObj.isChanged then
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
			isCreateDone := true;
			
		elseif transientObj.isDeleted then
			app.myUtilityDA.utlDeleteYACriteriaPriority(realCPObj, _passport);
			isCreateDone := true;
			
		else
			// The Criteria/Priority has not been touched, however, we still need to update it,
			// because all priority values have been made negative as they all need to be 
			// resequenced for new or deleted Criteria
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
		endif;
	endforeach;
	
	self.recalculateCriteriaPriorities();
	
	self.validateCriteria();
	
	if isCreateDone or isUpdateDone or isDeleteDone then
		self.causeEvent(app.getMyTerminalDO_NOT_USE().getTerminalEvent(EVENT_YA_CP_UPDATE), false, process);
	endif;
			
epilog

end;</source>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="recalculateCriteriaPriorities" id="9fb0e351-336f-44c2-9fee-c931092fc72a">
        <updating/>
        <source>recalculateCriteriaPriorities() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2010	cnwdap1	Initial creation
*/
vars
	criteriaObj			: CM_YACriteria;
	allCriteriaSetObj	: CM_YACriteriaSet;
	priorityTotal		: Real;
	
begin
	create allCriteriaSetObj transient;
	self.allCriteria.copy(allCriteriaSetObj);
	priorityTotal	:= 0;
	
	foreach criteriaObj in allCriteriaSetObj do
		priorityTotal	:= priorityTotal + criteriaObj.calculatePriority();
	endforeach;
	
epilog
	delete allCriteriaSetObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cd4034fe-2cc0-4b88-ae66-72fd4c669bab">
