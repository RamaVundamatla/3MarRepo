    <JadeMethod name="setTaxDetailsFromLines" id="6d66b9bc-4765-474c-b043-d58edaa3bda9">
        <updating/>
        <source>setTaxDetailsFromLines() updating;
/*
Purpose:			

Date		Who		Reason
26 March 2024	navab1	CR 62992 TASK 62994 
*/

vars
	invLine : CM_InvoiceLine;
	charge : CM_Charge;
begin
	// ### JIRA 35502 18JUL2025 NAVAB1 this is not needed
	if app.isInProformaMode then
		return;
	endif;

	self.taxCodes := "";
	self.taxDescriptions := "";
	self.taxRates := "";
	self.taxValue := 0;
	
	foreach invLine in self.invoiceLines discreteLock do
	/* // ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1
		self.setTaxCodes(invLine.taxCode);
		self.setTaxDescriptions(invLine.taxDescription);
		self.setTaxRates(invLine.taxRate.asStringJMTWithPrecision(2,false));
		self.setTaxValue(invLine.taxValue);
		*/
		if invLine.status = CM_InvoiceLine.STATUS_VOIDED then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
			continue;
		endif;
		
		foreach charge in invLine.charges discreteLock do
			self.setTaxCodes(charge.taxCode);
			self.setTaxDescriptions(charge.taxDescription);
			self.setTaxRates(charge.taxRate.asStringJMTWithPrecision(2,false));
		
		
		endforeach;
		
		self.setTaxValue(invLine.taxValue);
		
	endforeach;
epilog

end;</source>
    </JadeMethod>
