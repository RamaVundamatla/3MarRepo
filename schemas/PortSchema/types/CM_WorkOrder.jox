    <JadeMethod name="canManuallyAttachToInvoice" id="b4840b91-1489-4271-8e7f-9b5b1d2a95ea">
        <source>canManuallyAttachToInvoice() : Boolean;
/*
Purpose:			

Date		Who		Reason
25 May 2023	navab1	TFS BUG 58089
*/

vars

begin

	if self.taskStatus = WO_STATUS_CANCELLED
	or self.taskStatus = WO_STATUS_HELD
	or self.taskStatus = WO_STATUS_INAPORTNET
	or self.taskStatus = WO_STATUS_PENDING_CANCEL then
		return false;
	endif;
	
	return self.archived;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canPrintWorkOrderReport" id="3d5f4974-b8bb-453c-a04b-782b36a6e96b">
        <source>canPrintWorkOrderReport():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgndl1	Initial creation	TFS 40213

*/

vars

	inv : CM_Invoice;
	iter : Iterator;
	paidStatus : Integer;

begin

	paidStatus := CM_Invoice.INVOICE_PAYMENT_PAID;

	iter := self.allInvoices.createIterator;
	while iter.next( inv ) do
		if inv.paymentStatus &lt;&gt; paidStatus then
			return false;
		endif;
	endwhile;
	
	
	return self.numPrints = 0; // JLGAB1 4SEP18
	
// JLGAB1 4SEP18	return true;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
