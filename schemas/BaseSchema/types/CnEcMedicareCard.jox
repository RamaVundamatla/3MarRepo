    <DbClassMap file="basedvpr"/>
    <JadeMethod name="doValidateCardNumber" id="287c53ff-cdac-4a5c-b86f-666075235e1d">
        <source>doValidateCardNumber(): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		06 August 2002 by cnwdad2
//
// Purpose:		This method will validate an Australian Medicare Card number.
//
// Parameters:	pCardNumber - The card number to validate.
//
// Returns:		True if the card number is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	workString		: String;
	allNumbers		: IntegerArray;
	accumulate		: String[1];
	digitResult		: Integer;
	resultString	: String;
	digitCount		: Integer;

begin
	workString	:=	self.cardNumber;
	create allNumbers transient;

	if (workString.trimBlanks.length = 0) then
		return false;
	endif;

	if (not workString.trimBlanks.cnEcIsNumeric()) then
		// Medicare number must be all numeric digits.
		return false;
	endif;

	if workString.length &lt;&gt; 10 then
		// Medicare number can't be greater or less than 10
		return false;
	endif;

	digitCount	:=	1;

	while (digitCount &lt;= 9) do
		allNumbers.add(workString.trimBlanks[digitCount:1].Integer);
		digitCount	:=	digitCount + 1;
	endwhile;
	
	accumulate		:=	allNumbers[1].String;
	digitResult		:=	allNumbers[2] * 3;
	resultString	:=	digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;	
	
	digitResult		:=	accumulate.Integer + resultString.Integer;
	resultString	:=	digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;

	accumulate		:=	resultString;
	digitResult		:=	allNumbers[3] * 7;
	resultString	:=	digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	digitResult		:= accumulate.Integer + resultString.Integer;
	resultString	:= digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	accumulate		:=	resultString;
	digitResult		:=	allNumbers[4] * 9;
	resultString	:=	digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	digitResult		:= accumulate.Integer + resultString.Integer;
	resultString	:= digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	accumulate		:=	resultString;
	digitResult		:=	accumulate.Integer + allNumbers[5];
	resultString	:= digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	accumulate		:=	resultString;
	digitResult		:=	allNumbers[6] * 3;
	resultString	:=	digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	digitResult		:= accumulate.Integer + resultString.Integer;
	resultString	:= digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;

	accumulate		:=	resultString;
	digitResult		:=	allNumbers[7] * 7;
	resultString	:=	digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	digitResult		:= accumulate.Integer + resultString.Integer;
	resultString	:= digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	accumulate		:=	resultString;
	digitResult		:=	allNumbers[8] * 9;
	resultString	:=	digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	digitResult		:= accumulate.Integer + resultString.Integer;
	resultString	:= digitResult.String;
	
	if resultString.length &gt; 1 then
		resultString := resultString[2:1];
	else
		resultString := resultString[1:1];
	endif;
	
	accumulate	:=	resultString;
	if (not accumulate = allNumbers[9].String) then
		// CareSys Error messages 028550, 028560, 920148.
		return false;
	endif;

	return true;
epilog
	delete allNumbers;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
