    </JadeMethod>
    <JadeMethod name="includeAlert" id="ba05a372-4b76-42f6-938e-e3b4cb407663">
        <source>includeAlert(_alert : CM_SystemAlert; _currentButton : Integer) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//
// Purpose:     
// 16 Jun 2022  navsj20 Bug 53809: MTN - System Alert Notifications being processed when they shouldn't
// 02 Sept 2022 navsj20 Bug 53809: MTN - System Alert Notifications being processed when they shouldn't
// ---------------------------------------------------------------------------
vars
	tmpSeverity	: Integer;
	endTS,startTS,currentTS: TimeStamp;
	endTime: Time;
begin
	/*
	Date		      Who		Reason
	31 July 2008	cnwdz2	    Par16737 - Use app.handleDeletedObject() to handle invalid object reference instead of isValidObject().
	*/
//	if not global.isValidObject(_alert) then // and alert.hasDetails then
//		return false;
//	endif;
	// start 16 Jun 2022 navsj20 Bug 53809
	if self.queryDateFrom.isValid then
		startTS := self.queryDateFrom.asTimeStamp();
		startTS.setTime( self.queryTimeFrom );
		if startTS &gt; currentTS then
			return false;
		endif;
	endif;
	if self.queryDateTo.isValid then
		endTS.setDate( self.queryDateTo );
		endTime.setTime( self.queryTimeTo.hour, self.queryTimeTo.minute, 59, 999 );
		endTS.setTime( endTime );
	endif;	
	if startTS &lt;&gt; currentTS and (_alert.dateTime &lt; startTS or _alert.dateTime &gt; endTS)  then  // 02 Sept 2022 navsj20 Bug 53809
		return false; 												 
	endif;        										
	// end 16 Jun 2022  navsj20 Bug 53809
	tmpSeverity := _alert.severity;
	if _currentButton = self.BTN_ALL or 
	   _currentButton = tmpSeverity or 
	   (_currentButton = self.BTN_INFO and tmpSeverity = SEVERE_INFO) or 
	   self.alertsAreSimilar(tmpSeverity, _currentButton)then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_alert" type="CM_SystemAlert"/>
        <Parameter name="_currentButton" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="d71ba802-4c14-465e-8d59-b4a4e1e05e7b">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     16 December 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	list			:CMUI_ListTable;
	dict, 
	selected		:CM_SystemAlertTypesByTypeDict;
	block, value	:String;
	startPos		:Integer;
	type			:CM_SystemAlertType;
begin
	inheritMethod(_userWindow);
	
	dict 		:= app.myRoot.allSystemAlertTypes;
	list		:= self.lstAlertTypes;
	block 		:= _userWindow.xmlInfo.cnEcGetTagValueOfName(CMUI_ListTable.XMLTag_ListTable &amp; list.name);
	selected	:= self.queryAlertTypes;
	startPos 	:= 1;
	
	while startPos &lt;&gt; 0 do
		value := block.cnEcGetNextTagValueOfName(CMUI_ListTable.XMLTag_SelectedValue, startPos);
		if value &lt;&gt; null then
			type := dict[value.Integer];
			
			if type &lt;&gt; null then
				selected.add(type);
			endif;
		endif;
	endwhile;
	
	list.setSelected(selected);	

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="04480845-5708-4d7b-8288-e87e26a2f437">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	theTable : CM_DataTable;
	entTableDef		: EntTableDef;
	idx : Integer;
	allHideIdxs			: IntegerArray;
begin
	theTable := self.tblAlerts;
	theTable.selectMode := Table.SelectMode_Row;
	theTable.accessMode := Table.AccessMode_Row;
	theTable.fixedColumns:=0;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	theTable.selectionType := CM_BaseTable.SelectionType_Row;
	theTable.defaultRowHeight := 17;
	theTable.allSelectedObjects.clear;
	
	theTable.rows := theTable.fixedRows;
	entTableDef := app.myController.getEntTableDef(ETDef_SystemAlertTbl);
	theTable.userInputEnabled := false;
	theTable.zAddSortColumn("Date", true);
	theTable.setTblDataEntRowsFromDef(entTableDef);

	// 20/08/2010 cnwar2 #25502 - hiding columns is causing issues as they can be included in the system default
	/*theTable.hideColumnByColPropertyName(ETRow_Remarks);
	theTable.hideColumnByColPropertyName(ETRow_Reviewed);
	theTable.hideColumnByColPropertyName(ETRow_ReviewedBy);
	theTable.hideColumnByColPropertyName(ETRow_ReviewedDate);*/

epilog
	delete allHideIdxs;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblQuery" id="20907e8b-1f09-4935-9823-650d2a874177">
        <updating/>
        <source>initTblQuery() protected, updating;
// ---------------------------------------------------------------------------
// Created:     13 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 08/12/2010	cnwcs5	CCMS MES 1112/Par 24464 - filter by alert type
//												- use local variables for form properties
vars
	table	:CM_EntryTable;
	list	:CMUI_ListTable;
//	dd		:DynaDictionary;
begin
	table 	:= self.tblQuery;
	list	:= self.lstAlertTypes;
	
	table.setEntTableDefByName(ETDef_SystemAlertQuery);
	table.adjustHeight(self.shtDateRange.clientHeight);

	// we want to display the alert types in name order to make it easier to find what you want
//	create dd transient;
//	dd.setMembership (CM_SystemAlertType);
//	dd.addMemberKey(CM_SystemAlertType::name.name, false, true);
//	dd.endKeys (true);
	
//	app.myRoot.allSystemAlertTypes.copy (dd);

//	app.myRoot.allSystemAlertTypes.copy (dd);

//	list.displayCollection(dd, false, null, null);

	//14 May 2012	NDL	Par 29556
	self.allAlertTypes.clear();	
	app.myRoot.allSystemAlertTypes.copy (self.allAlertTypes);
	list.displayCollection(self.allAlertTypes, false, null, null);
	
	// 27/11/2008 cnwdz2 par18433 The data filter should be default to "All dates" when the Alerts form is opened for a specific object.
	if self.displayType &lt;&gt; DISPLAY_SPECIFIC then
		self.setQueryDefaults(true);
	endif;
epilog
//	delete dd;
end;</source>
        <access>protected</access>
    </JadeMethod>
