	myCMUI_Navigator_1.lstTest.listIndex:=app.atcgGetListHierarchicalIndex(myCMUI_Navigator_1.lstTest, 'System Items|General Cargo|', 143);
	myCMUI_Navigator_1.lstTest.itemSelected[myCMUI_Navigator_1.lstTest.listIndex]:=true;
	myCMUI_Navigator_1.lstTest.pictureClick(myCMUI_Navigator_1.lstTest,myCMUI_Navigator_1.lstTest.listIndex,1);  // 15:00:26
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cp252_CSAF_picture_click" id="30e59655-6df1-4e4d-b926-3891ffb89a7e">
        <updating/>
        <source>cp252_CSAF_picture_click():Integer updating;

vars
	picture:Picture;
begin
	/*picture:=app.atcgGetAddedControl(myCMUI_SuperAppForm2_1, 'Item Selector;picture;CMUI_ToolbarOverlay;0;-20;0;0;|Item Selector;frame;CMUI_ToolbarButton;100;-889;0;6;|').Picture;
	picture.mouseDown(picture, 1, 0, 10, 13);
	app.doWindowEvents(shortPause);
	picture:=app.atcgGetAddedControl(myCMUI_SuperAppForm2_1, 'Item Selector;picture;CMUI_ToolbarOverlay;0;-20;0;0;|Item Selector;frame;CMUI_ToolbarButton;100;-889;0;6;|').Picture;
	picture.mouseUp(picture, 1, 0, 10, 13);
	app.doWindowEvents(shortPause);/**/
	
	/*picture:=app.atcgGetAddedControl(myCMUI_SuperAppForm2_1, 'Item Selector;picture;CMUI_ToolbarOverlay;0;-20;0;0;|Item Selector;frame;CMUI_ToolbarButton;100;-889;0;6;|').Picture;
	app.doWindowEvents(shortPause);
	if picture &lt;&gt; null then  // everyone brings this up, if they have the right toolbar
		picture.click(picture);  // Item Selector  // 15:01:18
	endif;/**/
	
	// item selector is no longer on toolbar - use navigator instead
	myCMUI_Navigator_1.lstTest.listIndex:=app.atcgGetListHierarchicalIndex(myCMUI_Navigator_1.lstTest, 'Port Otago|Selector|', 1);
	myCMUI_Navigator_1.lstTest.itemSelected[myCMUI_Navigator_1.lstTest.listIndex]:=true;
	myCMUI_Navigator_1.lstTest.dblClick(myCMUI_Navigator_1.lstTest);/**/
	
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cp999_tidyUp" id="723be78e-9d8f-4bb5-ad0b-4d3c93e133c4">
        <updating/>
        <source>cp999_tidyUp():Integer updating;

vars
	keyCode:Integer;
begin
	myCMUI_Selector_1:=app.getForm('CMUI_Selector').CMUI_Selector;
	/*myCMUI_Selector_1.cmbAttr.gotFocus(myCMUI_Selector_1.cmbAttr);
	keyCode:=18;
	myCMUI_Selector_1.cmbAttr.keyDown(myCMUI_Selector_1.cmbAttr, keyCode, 4);
	app.doWindowEvents(shortPause);
	keyCode:=9;
	myCMUI_Selector_1.cmbAttr.keyUp(myCMUI_Selector_1.cmbAttr, keyCode, 4);
	app.doWindowEvents(shortPause);
	keyCode:=18;
	myCMUI_Selector_1.cmbAttr.keyUp(myCMUI_Selector_1.cmbAttr, keyCode, 0);
	app.doWindowEvents(shortPause);/**/
	return 0;
end;</source>
        <ReturnType type="Integer"/>
