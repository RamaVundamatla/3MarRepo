    <JadeMethod name="doAcceptTask" id="42107dc5-696f-4d23-803a-d0674f58997d">
        <updating/>
        <source>doAcceptTask()  protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars


	objSet		: CM_RTQueueTaskArray;
begin

	app.mousePointer	:=	Busy;
	create objSet transient;
	self.getSelectedTableObjects(objSet);
	if objSet.isEmpty then
		return;
	endif;
	self.clearErrors;
	app.myVehicleMountedIMVGuiAgent.doAcceptTasks(objSet,allErrorMsgs);
	
	if self.checkErrors then
		return;
	else
		self.btnReject.enabled:=true;
		self.btnComplete.enabled:=true;
	endif;

	

epilog
	app.mousePointer	:=	Idle;
	delete objSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
