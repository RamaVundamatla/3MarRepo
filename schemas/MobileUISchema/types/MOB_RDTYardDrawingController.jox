    <JadeMethod name="gotoLocationByID" id="ccbaa533-fa51-4af2-8c28-6e9949e208c7">
        <updating/>
        <source>gotoLocationByID(_lc : CM_LocationsController; _mode : Integer; _calcBestZoom : Boolean) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars
begin	
	if _lc = null then
		return false;
	endif;
		
	if _calcBestZoom then
		self.calcBestZoom();
	endif;
		
	self.resetScrollOffsets();
	self.resizeDrawingFrames();
	
	self.reDrawAreaFromLocation(_lc, _mode);

	return true;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_calcBestZoom" type="Boolean"/>
        <ReturnType type="Boolean"/>
