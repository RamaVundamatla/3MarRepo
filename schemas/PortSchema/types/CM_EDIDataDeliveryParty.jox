    <JadeMethod name="getDataTypeFromDefName" id="34a4b181-3eb4-4dec-9b23-84b82643ec8c">
        <source>getDataTypeFromDefName(_name: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2025	jlier1	Initial creation

*/

vars

begin
	if _name = ETDef_EDITIDeliveryParty then
		return EDIDataType_DeliveryParty;
	elseif _name = ETDef_EDITIAddress then
		return EDIDataType_Address;
	endif;

	return inheritMethod(_name);

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="cb6f3d17-e740-45d5-87f5-f21d5dea3101">
        <source>getDisplayStrForDefName(_name: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2025	jlier1	Initial creation
07 Feb 2025	navhl20 Bug MTN-34020: MTN - EDI Data Type - Delivery Party tab name
*/

vars

begin
	if _name = ETDef_EDITIAddress then
		return app.getErrorString(Address);
	elseif _name = ETDef_EDITIDeliveryParty then		//07.02.2025 navhl20 #34020
		return app.getErrorString(Delivery_party);
	endif;

	return inheritMethod(_name);

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
