    <JadeMethod name="vp029_fillLoadSlots" id="eaaf3b64-0d26-4b14-8335-c41deeec8f0d">
        <source>vp029_fillLoadSlots();
//	'color code' slot positions with attributes that match our onsite containers so
//	as to ensure success of auto load planning
vars
	ti					: CM_TrackedItem;
	bayVoy				: CM_BayVoyage;
	slotDefn			: CM_SlotDefn;
	aftSlot,slot		: CM_SlotController;
	ccAttr				: String;
	foundSlot			: Boolean;
	tmpLoadCC			: CMIF_LoadColorCode;
	tmpSlots			: CM_SlotControllerArray;
	tmpEditions			: CM_ObjectByOidEditionDict;
begin
	app.logMessage(method.qualifiedName);
	//first, construct two synchronous arrays of containers and corresponding available slot controllers
	create tmpLoadCC transient;
	create tmpEditions transient;
	create tmpSlots transient;
	allLoadSlots.clear();
	tmpLoadCC.myCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	
	foreach ti in self.allTrackedItems do : tiLoop
		foundSlot := false;
		foreach bayVoy in self.myVoyage.myCellularVoyageStructure.allBayVoyagesByOrdinal do : bayLoop
			foreach slotDefn in bayVoy.allSlotsByOrdinal do : slotLoop
				if slotDefn.unavailable then
					continue slotLoop;
				endif;
				
				slot := slotDefn.CM_SlotDefnVoyage.mySlotController;
				aftSlot := slot.myAftSlot;
				if allLoadSlots.includes(slot) or
				   (not slot.allTrackedItems.isEmpty) or
				   (not slot.allSlotRequestsLoad.isEmpty) or//already load CC
				   slot.isFortyBack or //40ft backend
				   (aftSlot &lt;&gt; null and ti.isForty and (not aftSlot.allTrackedItems.isEmpty)) then//aft slot has containers
					continue slotLoop;
				endif;
				
				tmpLoadCC.myDischargePort := app.myRoot.allPorts[ti.dischargePort];
				tmpLoadCC.isForty := ti.isForty;
				tmpLoadCC.isEmpty := ti.isEmpty;
				
				if ti.isForty then
					ccAttr := CM_SlotRequest.Attribute_Forty;
				elseif ti.CM_Container.isReefer then
					ccAttr := CM_SlotRequest.Attribute_Reefer;
				elseif ti.CM_Container.isEmpty then
					ccAttr := CM_SlotRequest.Attribute_Empty;
				endif;
				
				foundSlot := true;
				tmpSlots.clear();
				tmpSlots.add(slot);
				
				tmpEditions.clear();
				tmpEditions.add(slot);
				
				app.myTrxUA.trxUpdateSlotRequestAttribute(tmpSlots, null, true,
						tmpEditions, ccAttr, tmpLoadCC, app.myPassport);	
					
				self.assert(app.myPassport.trxCompletedOK, slot);
				//it's a done deal - add to our collection which we will later to use for the load planning stage
				self.allLoadSlots.add(slot);
				break bayLoop;
			endforeach;
		endforeach;
		
		self.assert(foundSlot, ti);//no matching slot could be found
	endforeach;
	
	self.assert(self.allLoadSlots.size = self.allTrackedItems.size, self.allLoadSlots);
	
	self.myShipPlanningForm.unloadForm();
epilog
	delete tmpLoadCC;
	delete tmpEditions;
	delete tmpSlots;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp031_allocateCranes" id="fbd18303-80cf-4b3f-b31c-de81535a7be0">
        <updating/>
        <source>vp031_allocateCranes() updating;

vars
	objArray	: ObjectArray;
begin
	app.logMessage(method.qualifiedName);
	
	// allocate ALL the portainer cranes to work the ship
	assert(not allPortainerCranes.isEmpty, self);
	create objArray transient;
	allPortainerCranes.copy(objArray);
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateVoyageJobSheet(objArray, myVoyage, CM_VoyageJobSheet, app.myPassport);
	assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	allPortainerCranes.clear;  // we're done with them now
epilog
	delete objArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="vp038_dischargePlanning" id="38d78bd1-1491-4f97-9776-b44be3411a48">
        <updating/>
        <source>vp038_dischargePlanning() updating;
//	Create plan moves for the import cargo being unloaded from the voyage
vars
	bayVoy 			: CM_BayVoyage;
	slotRequest		: CM_SlotRequest;
	iter			: Iterator;
	requestDict		: CM_SlotRequestByMoveTypeDict;
	wle				: CM_WorkListEntry;
begin
	app.logMessage(method.qualifiedName);
		
	foreach bayVoy in self.myVoyage.myCellularVoyageStructure.allBayVoyagesById do : bayLoop
		delete iter;
		requestDict := bayVoy.allSlotRequestByMoveType;
		iter := requestDict.createIterator;
		requestDict.startKeyGeq(DISCHARGE_MOVETYPE, iter);
		while iter.next(slotRequest) do : slotLoop
			if slotRequest.moveType &lt;&gt; DISCHARGE_MOVETYPE then
				continue bayLoop;
			endif;
			
			wle := slotRequest.allWorkListEntries.first;
			if wle.job = null then
				continue slotLoop;
			endif;
			
			app.myTrxUA.trxUpdateWLEAutoplan(wle, PLANNING_MODE, app.myPassport);
			self.assert(app.myPassport.returnCode &lt;&gt; INFO_NO_AUTOPLAN, slotRequest);//i.e check that the return code DOESN'T = INFO_NO_AUTOPLAN
			self.assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
			app.logMessage(method.qualifiedName &amp; ' auto discharge planned ' &amp; slotRequest.allWorkListEntries.first.myTrackedItem.id);
			if pauseAndStop(0) then return; endif;
		endwhile;
	endforeach;
	voyageDefinitionComplete:=true;
epilog
	delete iter;
end;
</source>
    </JadeMethod>
