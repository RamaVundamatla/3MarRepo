    <JadeMethod name="cloneReferences" id="d45f0267-d5af-46cb-813d-5669413a4073">
        <updating/>
        <source>cloneReferences(_obj: CMQF_InvoiceRate; _transient: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2010	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(_obj, _transient);
	
	self.setMyBank( _obj.getMyBank );
	self.setMyDebtor( _obj.getMyDebtor );
	self.setMyServiceGroup( _obj.getMyServiceGroup );
	self.setMyService( _obj.getMyService );
	

epilog

end;</source>
        <Parameter name="_obj" type="CMQF_InvoiceRate"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryDebtor" id="e6c4d4dc-ede4-49df-9e79-7142e2f5537e">
        <updating/>
        <source>doQueryDebtor( _collection: Collection input ) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//				July 2010 cnwjre1 24019 add option to show services by group, 24052 add multi-selection
//										of debtors and services
// Purpose:		query of rates by debtor and service
//
// ---------------------------------------------------------------------------
constants
	MaxString = 500;
vars
	obj:			  Object;
	dn:               CM_DebtorNode;
	debtorRoot:		  CM_DebtorNode;
	child:			  CM_DebtorNode;
	children:		  CM_DebtorNodeByNameDict;
	services,
	allSelectedDebtors,
	allNonChildDebtors,
	allSelectedServices:		  CM_ObjectArray;
	allChildren:	  CM_ObjectArray;
	dynaDict:		  DynaDictionary;
	service:		  CM_Service;
	ts:               TimeStamp;
	level: 		Integer;
	ls			: Boolean;
	key:		 String;
	rateTable : Table;
	bank : CM_Bank;
begin


	create allSelectedDebtors transient;
	create allNonChildDebtors transient;
	create allSelectedServices transient;

	
	// populate debtors
	if self.getMyDebtor &lt;&gt; null then
		allSelectedDebtors.add(self.getMyDebtor);
	else
		app.myRoot.myRootCompany.debtorNodes.copy(allSelectedDebtors);
	endif;


	if allSelectedDebtors.size = 0 then
			//app.msgBox("Please choose a debtor to query","Query Error",MsgBox_OK_Only);
		return;
	endif;
	
	
	// 24052 multi-service selection
	create services transient;
	
	if self.getMyService &lt;&gt; null then
		services.add( self.getMyService ); 
	else
		self.getMyBank.serviceObjects.copy(services);
	endif;
	

	if services.size = 0 then
			//app.msgBox("Please choose a service to query","Query Error",MsgBox_OK_Only);
		return;
	endif;


	// 24019 July 2010 show services either by service name or group then service name
	create dynaDict transient;
	dynaDict.setMembership(CM_Object);				// use for both debtors and services
	dynaDict.addExternalKey(String, MaxString, false, false);	// 500 byte String, ascending, case sensitive
	dynaDict.endKeys(true);							// duplicates true (mainly in case of MaxString length exceeded)

	foreach obj in services where obj.isKindOf(CM_Service) do 
		service := obj.CM_Service;
		if self.getMyServiceGroup = null then			
			key := service.getFullName()[1:MaxString];
		else
			key := service.name;
		endif;
		// check here for servive group filtering?!?
		if ( self.getMyServiceGroup = null)  or ( self.getMyServiceGroup &lt;&gt; null and service.group = self.getMyServiceGroup) then
			dynaDict.putAtKey(key, service);
		endif;
		
	endforeach;
	
	allSelectedServices.clear;
	foreach obj in dynaDict do
		allSelectedServices.add(obj);
	endforeach;
	
	// 24052 multi-select of debtors may include children of other selections, filter these out as they will
	// 		be included with their parent debtors
	create children transient;
	create allChildren transient;
	foreach obj in allSelectedDebtors do
		dn := obj.CM_DebtorNode;
		if dn.isRootDebtorGroup then
			debtorRoot := dn;
		endif;
		children.clear;
		level := 1;
		dn.getChildren(children, level);
		foreach child in children do
			if not allChildren.includes(child) then
				allChildren.add(child);
			endif;
		endforeach;
	endforeach;
	// write debtors to dynaDict to sort on name, excluding children of selected debtors
	dynaDict.clear();
	// if the root debtor is chosen, use this one only
	if debtorRoot &lt;&gt; null then
		key := debtorRoot.name;
		dynaDict.putAtKey(key, debtorRoot);
	else
		foreach obj in allSelectedDebtors do
			dn := obj.CM_DebtorNode;
			key := dn.name;
			if not allChildren.includes(dn) then
				dynaDict.putAtKey(key, dn);
			endif;
		endforeach;
	endif;

	foreach obj in dynaDict do
		dn := obj.CM_DebtorNode;
		allNonChildDebtors.add(dn);
	endforeach;
	
	bank := self.getMyBank;
	
	app.cmsBeginLoad(ls);
	foreach obj in allNonChildDebtors do
		dn := obj.CM_DebtorNode;
		self.processDebtor( dn, bank,ts,allSelectedServices , _collection);
	endforeach;

epilog
	app.cmsEndLoad(ls);
	delete children;
	delete allChildren;
	delete services;
	delete dynaDict;
	delete allSelectedDebtors;
	delete allNonChildDebtors;
	delete allSelectedServices;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="4c4b1585-d5b8-48ed-864d-dad4f3c237e7">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2010	cnwrd1	Initial creation

*/

vars

begin

	if self.getMyBank = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(CM_CompanyBank), 'Bank', null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_CompanyBank), 'Bank', null); // cnwdb2	PAR 35364
		return;	
	endif;
	
	self.doQueryDebtor( _collection );
	
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f4bc5ac9-2d07-4b27-a086-77d436ca506c">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2010	cnwrd1	Initial creation

*/

vars
	str : String;
	oid : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);

epilog

end;</source>
