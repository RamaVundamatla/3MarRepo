    <JadeMethod name="doShowTrackedItems" id="294d4275-b290-437a-8d24-5bd83d42a5a1">
        <source>doShowTrackedItems( _showTerm : CM_Terminal );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2008	cnwrd1	Initial creation

*/

vars
	cargoEnquiry 	: CM_ContainerEnqForm;
	tmpTi			: CM_TrackedItem;
	tiColl			: CM_ObjectSet;
	iter			: Iterator;
	ti				: CM_TrackedItem;
begin


// show either on site or  (my current) or all ti's asociated with this master ti
// some terminal funkiness as were in sys items and have no terminal. 


	create tiColl transient;
	iter := self.myCurrentTiMaster.allTis.createIterator();

	
	if _showTerm &lt;&gt; null  then
	
		cargoEnquiry := app.loadForm(CM_ContainerEnqForm, CMUI_Assistant, false, false, false, _showTerm , null).CM_ContainerEnqForm;	
		cargoEnquiry.setMyTerminal(_showTerm);	
		cargoEnquiry.setFilterCargoTypeId (true);
			
		if cargoEnquiry = null then
			return;
		endif;
		
		while iter.next(ti) do
			if ti.myTerminal = _showTerm then
				tiColl.add(ti);
			endif;
		endwhile;
	
		cargoEnquiry.show(); 
		cargoEnquiry.displaySelectorResults(tiColl, null);
	
	else
		tmpTi := self.myCurrentTiMaster.getCurrentTi();
		
		cargoEnquiry := app.loadForm(CM_ContainerEnqForm, CMUI_Assistant, false, false, false, tmpTi.myTerminal, null).CM_ContainerEnqForm;	
		cargoEnquiry.setMyTerminal(tmpTi.myTerminal);	
		cargoEnquiry.setFilterCargoTypeId (true);		
	
		if cargoEnquiry = null then
			return;
		endif;
	
		self.myAssistant.setMyTerminal(tmpTi.myTerminal ) ;
		self.myAssistant.showCargoEnquiryForm( tmpTi ,self.myMasterMenuAction, true, false);
	endif;

epilog
	delete tiColl;
	delete iter;
end;</source>
        <Parameter name="_showTerm" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="doViewAudits" id="96d56c63-dd8d-4dd4-a05e-c45d4c502aa9">
