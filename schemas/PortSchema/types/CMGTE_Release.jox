    <JadeMethod name="updatePxyRequest" id="985becef-1136-4745-9eb1-da2d4c15ee1d">
        <source>updatePxyRequest() : CM_DeliveryRequest;
/*

Date				Who		Reason
16 October 2014		cnwer1	Initial creation PAR
25 September 2024	navpw1	TFS: 65623 (65624) - Added code to set isAnyAmount to null as it is not used in this context

*/

vars
	pxyYardRequest : CM_DeliveryRequest;
	tmpDeliveryNumber: String;
begin

	if self.myYardRequest = null then
		return null;
	endif;
	
	if not self.myYardRequest.isKindOf(CM_DeliveryRequest) then
		return null;
	endif;
	
	pxyYardRequest:= self.myYardRequest.pxyCreateUpdateProxy().CM_DeliveryRequest;
	
	if self.deliveryReleaseNumber = null then
		tmpDeliveryNumber:= pxyYardRequest.deliveryNumber;
	endif;
			
	pxyYardRequest.CM_DeliveryRequest.setFromFlexiGate(self.consigneeCode, self.consignorVoyageCode, tmpDeliveryNumber, 
					   self.eirNumber, self.isoType, self.operatorCode,
					   self.myOperatorGroup,
					   self.myCargoType,
					   self.myTILCType,
					   self.clean, self.doISOGroupCheck, self.doorsDirection, 
					   self.heavyRated,
					   false, 	/* isReceipt */
					   self.needCOU, self.needGenerator,
					   self.removeStops, self.numItems,
					   null,	/* reasonCode */
					   self.allAvailabilityGrades, self.deliveryReason, self.remarks, 				//cnwmc5 - 19 May 2014 - PAR 34173
					   null,	/* ids */
					  // self.myBulkRelease.getPinNumber(),	// pinNo	CCMS1037
					   pxyYardRequest.pinNo,//for par13816
					   self.myTransferToTerminal,
					   self.myBulkRelease,
					   self.mySubTerminalSource,// cnwdad1 02/07/2009 - CCMS 1735.				   
					   // New fields for flexi-gate 					 
					   self.customEntryNumber,
					   self.isoGroup,
					   self.voyageCode,
					   self.billOfLading,
					   self.myProduct,
					   self.mark,
					   self.markNumber,
					   self.description,
					   self.weight,
					   self.length,
					   self.getMyVolume,
					   self.width,
					   self.height,
					   self.widthString,
					   self.heightString,
					   self.lengthString,
					   self.density,
					   self.quantity,
					   self.colour,
					   self.yardInstructions,
					   self.type,
					   self.commodity,
					   self.myReserveDetail,
					   self.imexStatus,
					   null						// ### TFS 65623 (65624) 25Sep2024 NAVPW1
					   ); 			
	
	return pxyYardRequest;
epilog
	
end;</source>
        <ReturnType type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="c9c4d82e-506f-4130-814e-2937969a574c">
        <updating/>
        <source>validateForCreate(_passport: CM_Passport input; _pxyTI : CM_TrackedItem io): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2009	cnwjk3	Initial creation
22 May 2018 jlggb1	TFS 36933 PEN X12 315 processing
10 Jul 018  cnwma1	Ticket 39629: Release to Carrier
// 20 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
19 Aug 2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
08 Nov 2023 navlc30 Bug 61124: EUP Testing | 1090 error when selecting staged items in Road Gate
*/

vars
	carrier: CM_Carrier;
	operator: CM_Operator;
	operatorStr: String;
	release: CM_BulkRelease;
	dac: CM_DataAccessController;
	theCargoType : CM_CargoType;
	cargoSubType : String;							// TFS 45836
	trailerType : String;							// TFS 45836
begin
	// Should be called on a transient instance
	if not self.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'transient method called for persistent object');
		return false;
	endif;	

	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	//carrier := self.myVehicleVisitRecord.getCarrier();		// 14/9/17 MAP TFS2749						//08.11.2023 navlc30 #61124
	if self.myVehicleVisitRecord &lt;&gt; null then 																//08.11.2023 navlc30 #61124
		carrier := self.myVehicleVisitRecord.getCarrier();
	endif;
	operator := app.myRoot.allOperators[self.operatorCode];
	release := self.myBulkRelease;
	if carrier &lt;&gt; null and not carrier.canCarrierAccessForOperator(operator, dac, true) then
		if operator &lt;&gt; null then
			operatorStr := operator.description;
		endif;
		app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
	endif;
	// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
	if self.myProduct &lt;&gt; null then													// TFS 45836
		cargoSubType := self.myProduct.code;										// TFS 45836
	endif;																			// TFS 45836
	if self.myTILCType &lt;&gt; null then													// TFS 45836
		trailerType := self.myTILCType.code;										// TFS 45836
	endif;																			// TFS 45836
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_TILC) then		// TFS 45836
		trailerType := self.myTrackedItem.CM_TILC.myTILCType.code;					// TFS 45836
	endif;																			// TFS 45836
	if carrier &lt;&gt; null and
	   operator &lt;&gt; null and
	   theCargoType &lt;&gt; null and
	  ( not (self.getIsAnyAmount and self.getIsAnyAmount) ) and	//18 May 2021	NDL	TFS 51183
	   //not operator.canOpAccessCarrierForCargoType(carrier, self.cargoType) then											// TFS 45836
	   not operator.canOpAccessCarrierForCargoType(carrier, self.cargoType, cargoSubType, self.isoType, trailerType) then	// TFS 45836
		app.raiseCMException3(Opera_denie_carri_acces_cargo_, operator.description, carrier.description, theCargoType.description, null, null);
	endif;
	
	if self.getMyTerminal.getConfig(OnlyReleaseToCarrier).Boolean then //22 May 2018 jlggb1 TFS 36933
		if release &lt;&gt; null and release.carrierId &lt;&gt; null then
			if carrier.code &lt;&gt; release.carrierId then 
				// For security reasons do not tell them which carrier it should be.
				app.raiseCMException2(Carrier_not_assigne_release, carrier.code, release.getDescription(true), null, null);
			endif;
		endif;
	endif;

	if self.isReleaseById then
		return self.validateForCreateById(_passport, _pxyTI);
	else
		return self.validateForCreateByType(_passport);
	endif;


epilog
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreateById" id="804bfadc-3728-4ea9-b48c-276a2a0dabe9">
        <updating/>
        <source>validateForCreateById(_passport: CM_Passport input; _pxyTI : CM_TrackedItem io) : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04/06/2009	cnwjk3	Initial creation
*/

vars
	sameBBCargo : Boolean;
	pxyTI,
	theTI 	: CM_TrackedItem; 
	control	: CMIF_TIUpdateController;
	
begin

	//--------------------------------------------------------------------
	// BEGIN code refactored from CMIF_ReleaseById::validateForCreate() 
	//--------------------------------------------------------------------
	// Locate the onsite TI
	if self.getIsAnyId() then		//01 Aug 2014	NDL	Par 34675
		return true;
	elseif self.id = null then
		if self.myBulkRelease = null or self.myBulkRelease.allTrackedItemsAssigned.size = 0 or not self.getBestPick() then  // PAR 26482  //cnwrd1 par 27029 17.2.2011 - if not best pick we need an ID
		//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Id', ETRow_IdCombo, null);
			app.raiseCMException(Input_required_field_cargoId, ETRow_IdCombo, null); // cnwdb2	PAR 35364
			return false;
		endif;
		return true;
	else	
		if self.imexStatus = TI_IMEX_STATUS_REMAINONBOARD then
			return true;
		endif;
		theTI:=self.myTrackedItem;		
	
		if theTI = null or theTI.isTransient then
			theTI := self.findCargo(self.id, self.cargoType);
			if theTI = null then 
				app.raiseCMException1(ERR_TI_NOT_ONSITE, self.id, 'id', null);
				return false;
			endif;
		endif;
	endif;
	
	//17 Nov 2015	NDL	Par 37092
	if self.myReserveDetail &lt;&gt; null then
		if self.myReserveDetail.isBulkMulti or self.myReserveDetail.byTypeByWeight then
			//by weight
			self.myReserveDetail.validateWeightQuantityAdd(	0, self.weight, true );
		else
			//by quantity
			self.myReserveDetail.validateWeightQuantityAdd(	self.numItems, 0, true );
		endif;
	endif;

	///theTI.validateForBulkRelease(self.deliveryReleaseNumber);		// 02/12/2010 cnwmh5 #26400
	if self.myBulkRelease &lt;&gt; null then
		theTI.validateForBulkRelease(self.myBulkRelease.getDeliveryReleaseNumber());
	endif;
	//epr par 32330 29/8/13 need this validation
	self.validateReleaseReqForCreate();
	//cnwrd1 6.11.08 CCMS JMT 1743/1764
	//validate freight forwarder
	theTI.validateOperatorRequiredFF();
	
//	// validate ti for op imp release PIN	- this should be done against the proxy TI once created
//	theTI.validateOpImpReleasePIN(self.importReleasePIN);	// cnwrl1 11/10/2010 PAR 25958 - what it was
	
	if _passport.hasErrors then
		// no point in going any further
		return false;
	endif;
		
	

	if self.isReleaseOfSameBBCargo then
		pxyTI:=theTI.pxyGetProxyObject;
	endif;
	
	
	//Deep copy the real TI, update its data and validate it
	if pxyTI = null then
		pxyTI := app.createUpdateProxy(theTI).CM_TrackedItem;
	endif;
	pxyTI.setPxyFromCMGTE_Release(self);
	
	control := app.createTIUpdateControl(TI_UPDMODE_RELEASE, null, null);
	pxyTI.validateToDoOnReleaseAsError( self.myBulkRelease );	//20 Sep 2011	NDL	Par 28189
	pxyTI.validateTrackedItem(control, _passport);
	
	// cnwrl1 11/10/2010 PAR 25958 - moved from above approx line 44
	if theTI.myPinNo = null and theTI.getImExStatus = TI_IMEX_STATUS_IMPORT then  //cnwrd1 par 27161 8.3.2010  only validae if we do NOT have a JMT pin  + par 27209
		pxyTI.validateOpImpReleasePIN(self.importReleasePIN); //31849 cnwgb1 11.11.2013 Reestablish
	endif;


	theTI.validateCustDocRelease(self,app.myPassport); // ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1

	return true;
	
	//--------------------------------------------------------------------
	// END code refactored from CMIF_ReleaseById::validateForCreate() 
	//--------------------------------------------------------------------	
	
epilog
	_pxyTI := pxyTI; // return this.  Caller must destroy! //cnwrd1 par 22651 10.3.2010 this NEEDS to be set regardless for clean up later, a continueexeption-&gt;false in stop hook code can bomb out in this method leaving this unset.
	
	//delete pxyTI; caller will delete
	delete control; //epr par 21011 7/10/09
end;
</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreateByType" id="4d2ec06f-0818-4300-889b-6f23fd3d1520">
        <updating/>
        <source>validateForCreateByType(_passport: CM_Passport input) : Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/06/2009	cnwjk3	Initial creation
07/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - validate weight/volume are supplied
19/10/2016	cnwdap1	TFS 2791 For break/bulk by type, check number of items has been entered
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
17/07/2023	navkc1	CR 58406 Task 58964: Jade - Road Gate Release Use Rel Req Cargo Group Items
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
08/10/2024	navcs2	Story MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes
24/10/2024	navpw1	JIRA MTN-12518 - Added a check to not allow the release weight to exceed the release request weight
30/06/2025  navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/

vars
	tmpBRI					: CM_BookingRefItem;
	tmpOperatorGroup		: CM_OperatorGroup;
	tmpDeliveryReq			: CM_DeliveryRequest;
	theBulkRelease			: CM_BulkRelease;
	tmpPinNo,
	tmpDeliveryNumber,
	tmpCarrierID			: String;
	bolDtl					: CM_BOLDtl;						//08 Oct 2020	NDL	TFS 49189
	iter					: Iterator;
	reserveDetails			: CM_ReserveDetail;
	vbsti					: CM_VehicleBookingTimeSlotItem;	// ### TFS 61525 (61527) 18Jul2024 NAVPW1
	vbsMaxWeight			: Decimal[14,4];					// ### TFS 61525 (61527) 18Jul2024 NAVPW1
	vbsProcess				: CM_VBSProcess;					// ### TFS 61525 (61527) 24Jul2024 NAVPW1
	outstanding				: Decimal[14,4];					// ### JIRA MTN-12518 24Oct2024 NAVPW1
	bulkRelease				: CM_BulkRelease;
	cType,					
	bolCType				: CM_CargoType;
begin
	
	bulkRelease	:= self.myBulkRelease;							//30.06.2025 navma1 #MTN-34090
	
	if bulkRelease &lt;&gt; null then
		if self.isContainer() then
			if not self.mtOnly and not bulkRelease.fullRelease then				
				app.raiseCMException(ERROR_FULL_CONT_MT,null,self);
			elseif self.mtOnly and bulkRelease.fullRelease then				
				app.raiseCMException(ERROR_MT_CONT_FULL,null,self);
			endif;
		endif;
	endif;
	
	//--------------------------------------------------------------------
	// BEGIN code refactored from CMIF_ReleaseByType::validateForCreate() 
	//--------------------------------------------------------------------
	
	tmpOperatorGroup := self.validateOperatorGroup();
	create tmpDeliveryReq transient;
	
	tmpDeliveryNumber := self.deliveryReleaseNumber;
	if tmpDeliveryNumber = null then
		// Par8380 use BR system code if there is one as a system BR is created if one is not found
		// all subsequent requests that dont have a BR will be attached to the system generated BR
		tmpDeliveryNumber := self.systemBulkReleaseCode;
	endif;

	//added by cnwyl1 for par 13816
	if bulkRelease &lt;&gt; null then							//30.06.2025 navma1 #MTN-34090
		tmpPinNo := bulkRelease.getPinNumber();			//30.06.2025 navma1 #MTN-34090
	else
		tmpPinNo := null;
	endif;
	
	reserveDetails := self.myReserveDetail; 			//23/06/2023	navkc1	CR 58406 Task 58408
	
	//9 Dec 2015	NDL	TFS 85-15
	if reserveDetails &lt;&gt; null then
		if reserveDetails.isBulkMulti or reserveDetails.byTypeByWeight then			// 6/12/2023 navcs2 ChangeRequest 57537
			//by weight
			reserveDetails.validateWeightQuantityAdd(	0, self.weight, true );
		else
			//by quantity
			reserveDetails.validateWeightQuantityAdd(	self.numItems, 0, true );
		endif;
	endif;
	
	//08 Oct 2020	NDL	TFS 49189
	bolDtl := self.myBOLDtl;
	if bolDtl &lt;&gt; null then
		bolCType := bolDtl.myCargoType;												//30.06.2025 navma1 #MTN-34090
		if bolCType &lt;&gt; null and bolCType.isBulkMulti and self.weight &lt;= 0 then		//30.06.2025 navma1 #MTN-34090
			app.raiseCMException(Must_enter_move_amount_move, null, null);
		elseif self.numItems &lt;= 0 then
			app.raiseCMException(Input_required_field_numOfItem, null, null);
		endif;
		bolDtl.validateOnQtyWtOnSite( self );
	endif;

	tmpDeliveryReq.set(self.consigneeCode, 
					   self.consignorVoyageCode, 
					   tmpDeliveryNumber, 
					   self.eirNumber, 
					   self.isoType, 
					   self.operatorCode,
					   tmpOperatorGroup,
					   app.myRoot.allCargoTypesById[self.cargoType],
					   self.clean, 
					   self.doISOGroupCheck, 
					   self.doorsDirection, 
					   self.heavyRated,
					   false, 	/* isReceipt */
					   self.needCOU,
					   self.needGenerator,
					   self.removeStops, 
					   self.numItems,
					   null,	/* reasonCode */
					   self.allAvailabilityGrades, self.deliveryReason, self.remarks, 		//cnwmc5 - 19 May 2014 - PAR 34173
					   null,	/* ids */
					   tmpPinNo,//for par13816
					   self.myTransferToTerminal,
					   bulkRelease,
					   self.mySubTerminalSource, 	// cnwdad1 02/07/2009 - CCMS 1735.
					   self.isoGroup,				/*isoGroup*/// MES1008 JMH 29/9/09 Add iso group  //cnwrd1 par 20810 9/10/9 set the thing!
					   self.imexStatus,				// CCMS 1101
					   self.colour,
					   self.mark,
					   self.billOfLading	//18 Feb 2014	NDL	Par 33524
					   );
	tmpDeliveryReq.voyageCode := self.voyageCode;//18 Feb 2014	NDL	Par 33524				   
	tmpDeliveryReq.setIds(self.ids);
	
	
	//th2 for PAR 14966 - set the road job so that in the following validation, the
	//total number of delivery requests being made can by assessed in comparison the 
	//associated release request's outstanding quantity and raise a warning if this is
	//about to be exceeded.
	if self.myVehicleVisitRecord &lt;&gt; null and self.myVehicleVisitRecord.myRoadJob &lt;&gt; null then
		tmpDeliveryReq.setJob(self.myVehicleVisitRecord.myRoadJob);
	endif;
	
	//tmpDeliveryReq.
	// CCMS 1412
	tmpDeliveryReq.validateForCreate(null);
	
	// cnwjk3 13/10/09 PAR 21169	
	// Added this call, as the above validation on the Cm_DeliveryRequest object
	// expects the job to have been created by now.  validateReleaseReqForCreate()
	// comments for full details.
	self.validateReleaseReqForCreate();
	
	// CCMS 1412 Test carrier is the same as the one assigned to the bulk release
	// have to do it here as the job is not assigned to the delivery request at this stage
	tmpCarrierID   := self.myVehicleVisitRecord.carrierCode;
	theBulkRelease := tmpDeliveryReq.myOriginatingBulkRelease;
	if tmpCarrierID &lt;&gt; null
	and theBulkRelease &lt;&gt; null
	and theBulkRelease.carrierId &lt;&gt; null then
		if tmpCarrierID &lt;&gt; theBulkRelease.carrierId then
			// For security reasons do not tell them which carrier it should be.
			
			app.raiseCMWarning2(ERROR_CARRIER_NOT_TO_RELEASE,tmpCarrierID,theBulkRelease.getDescription(true),
								ETRow_CarrierId, null, theBulkRelease);
		endif;
	endif;	
	//--------------------------------------------------------------------
	// END code refactored from CMIF_ReleaseByType::validateForCreate() 
	//--------------------------------------------------------------------

	tmpBRI := self.myBookingRefItem;
	// 11/02/2010	cnwjre1	CCMS 1101 validate destination terminal area if entered
	if self.yardLocationTxt &lt;&gt; null then
		if self.myTerminal.lookupTerminalArea(self.yardLocationTxt) = null then
			app.raiseCMException2(ERR_INVALID_TA_ID, self.yardLocationTxt, null, null, self);
		endif;
	endif;
	
	// ### TFS 61525 (61527) 18Jul2024 NAVPW1
	vbsProcess := self.myTerminal.getMyVBSProcess();
	
	vbsti := self.myVbsti;
	
	if vbsti &lt;&gt; null then
		vbsMaxWeight := vbsti.maxWeight;
	endif;
	
	if vbsProcess &lt;&gt; null and															// ### TFS 65399 26Jul2024 NAVPW1
		vbsProcess.isVbsSlotValidation and vbsti &lt;&gt; null and vbsMaxWeight &lt;&gt; null and
		reserveDetails &lt;&gt; null and reserveDetails.myReserveHeader.releaseByType 
	then
		//if self.releaseWeight &gt; vbsMaxWeight then																					// 08/10/2024	navcs2	Story MTN-14819
			//app.raiseCMException1(Vbs_max_weight_exceeded, app.getWeightForDefaultDisplay(vbsMaxWeight), null, null);				// 08/10/2024	navcs2	Story MTN-14819
		//endif;																													// 08/10/2024	navcs2	Story MTN-14819
		
		if self.releaseWeight &gt; reserveDetails.weightRequested and reserveDetails.byTypeByWeight then
			app.raiseCMException1(Release_weight_exceeded, app.getWeightForDefaultDisplay(reserveDetails.weightRequested), null, null);
		endif;
		
	endif;
	// ### TFS 61525 (61527) 18Jul2024 NAVPW1
	
	// ### JIRA MTN-12518 24Oct2024 NAVPW1
	//If we have a release weight and the release request is by type by weight and we are using vas then validate the release weight
	if self.releaseWeight &lt;&gt; null and reserveDetails.byTypeByWeight and app.myPassport.isVASEnabled then
		//Check reserve detail is not already filled
		outstanding := reserveDetails.getWeightOutstanding() - reserveDetails.getWeightLoaded();
		
		if outstanding - self.releaseWeight &lt; 0 then
			app.raiseCMException1(Release_weight_exceeded, app.getWeightForDefaultDisplay(reserveDetails.weightRequested), null, null);
		endif;
		
	endif;
	// ### JIRA MTN-12518 24Oct2024 NAVPW1
	
	if self.getIsAnyId() then
		return _passport.noErrors();		// 13/2/17 MAP TFS3316
	endif;
	
	cType := self.myCargoType;				//30.06.2025 navma1 #MTN-34090
	if cType &lt;&gt; null and cType.isBulkMulti and self.weight = null then //epr par 34406 24/6/14								
		if self.myCargoType.isTrackByWeight  then								
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_Weight), null, null);		


		elseif cType.isTrackByVolume  then							
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_Volume), null, null);		
		endif;																						
	endif;		
	
	if cType &lt;&gt; null and cType.isBreakBulkMulti and self.numItems = 0 then					// TFS 2791
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_Total_Quantity), null, null);	// TFS 2791
	endif;																											// TFS 2791
	
	if cType &lt;&gt; null and cType.hasProductTypes then													// PAR #33606
		if cType.mySystemProductType = null and self.myProduct = null then							// PAR #33606
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_Product_GC), null, null);	// PAR #33606
		endif;																						// PAR #33606
	endif;																							// PAR #33606
	
	//jlier1 TFS 53678 27/7/22
	if bulkRelease &lt;&gt; null and bulkRelease.context = RelReqContext_CargoGroupReview then
		if reserveDetails &lt;&gt; null and not self.getIsAnyId and reserveDetails.myCargoGroup &lt;&gt; null then			
			// get allTIs assigned not offsite getting total weight and total quantity
			if reserveDetails.isKindOf(CM_ReserveSelection) then
				//17/07/2023	navkc1	CR 58406 Task 58964
				reserveDetails.CM_ReserveSelection.checkAvailQuantityAndWeight(self.totalQuantity, self.weightRequested);
			endif;
		endif;
	endif;
	
epilog
	delete tmpDeliveryReq;
	delete iter;
	return _passport.noErrors();
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateOperatorGroup" id="36cec626-a272-4c01-b747-fb7019e85f2c">
        <updating/>
        <source>validateOperatorGroup() : CM_OperatorGroup protected, updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
begin
	if self.myOperatorGroup = null then
		if self.operatorGroupCode &lt;&gt; null then
			self.myOperatorGroup := app.myRoot.allOperatorGroups[self.operatorGroupCode];
			if self.myOperatorGroup = null then
				app.raiseCMException1(ERR_INVALID_OPERATOR_GROUP, self.operatorGroupCode, ETRow_MyOperatorGroup, null);
			endif;
		endif;
	endif;

epilog	
	return self.myOperatorGroup;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_OperatorGroup"/>
    </JadeMethod>
    <JadeMethod name="validateReleaseReqForCreate" id="4a24bdde-98ea-4cb9-a81a-b49f533d635b">
        <source>validateReleaseReqForCreate() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2009	cnwjk3	PAR 21169

CM_DeliveryRequest::validateForCreate() was being correctly called, but much of the validation code wasn't
actually being executed, due their being an assumption made that the road job would have been created in time for each
gate entity being validated.  With the new gate, this is not the case, as the road job is created as one of the 
last steps, when the big save is pressed.  It's not just a case of creating the road job at the same time as when
the vehicle visit is created either.  Believe me, I've looked... The main problem being that as soon as 
we create the road job, it appears in the Road Ops screen, and we may not push the big save at all...

*/

vars
	numReleased,
	numRequested,
	numCurrentlyActioned,
	numShouldReceive,
	totalRequestedThisJob	: Integer;
	releaseDesc				: String;
	isForBBMultiCargo : Boolean;
begin
	if self.myBulkRelease = null then
		return;
	endif;
	
	if self.myReserveDetail = null then
		return;
	endif;
	
	releaseDesc := self.myBulkRelease.code;
	totalRequestedThisJob := self.numItems;
	//epr par 32330 29/8/13
	if self.myTrackedItem &lt;&gt; null then
		isForBBMultiCargo:=self.myTrackedItem.myCargoType.isBreakBulkMulti ;
		if isForBBMultiCargo and self.numItems = 0 then
			//raise exception 
		//	app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(CM_Total_Quantity),null,null);
			app.raiseCMException1(Input_required_field_Required,app.getErrorString(CM_Total_Quantity),null,null); // cnwdb2	PAR 35364
			return;
		endif;
	endif;
	
	
	numReleased := self.myReserveDetail.getTotalReleased(); //epr par 34623 23/7/14
	numRequested := self.myReserveDetail.getTotalRequested(); //epr par 34623 23/7/14
	numCurrentlyActioned := self.myReserveDetail.getNumItemsBeingActioned(null);
	if numRequested &lt;= 0 then
		return;
	endif;

	numShouldReceive := numRequested - (numReleased + numCurrentlyActioned);
	if totalRequestedThisJob &gt; numShouldReceive then
		//Par 15487 - clients need a red warning to avoid of changing requested amount of containers in the Gate Out screen for an existing relese request. The practise is - to edit quantity in the Release Request maintenance screen.
		app.raiseCMException5(Error_relea_items_alrea_relea_,
								releaseDesc, numReleased.String, numCurrentlyActioned.String, totalRequestedThisJob.String, numRequested.String, 
								ETRow_Quantity, self.myBulkRelease);
	endif;

	if self.myTrackedItem &lt;&gt; null then
		if totalRequestedThisJob &gt;  self.myTrackedItem.totalQuantity.max(1) then
				app.raiseCMWarning3(Release_too_many,self.myTrackedItem.totalQuantity.max(1).asStringJMT &amp;  " " &amp; self.myTrackedItem.id, self.myTrackedItem.getPrimaryLocationId(REAL_MODE),totalRequestedThisJob.asStringJMT,null,null,null);
			
			
		endif;
	endif;

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
