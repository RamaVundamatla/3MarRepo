    <JadeMethod name="addRTDevice" id="2b539a54-4797-41be-9b9f-ee6a71cd7726">
        <source>addRTDevice(_type: String;
			_id,
			_model,
			_computerName	: String;
			_machine 		: CM_Machine; // only for CM_RTDeviceVehicleMount
			_isPasswordCompulsory,
			_useSerialConnection 	: Boolean;
			_useLocalTCPConnection : Boolean) : CM_RadioTelemetryDevice;
//09 September 2010	by cnwvu1
//17/08/2016 cnwrh7	TFS	2501

vars
	pxyRTDevice,	newRTDevice		: CM_RadioTelemetryDevice;
	
begin

	if _type = RTDevice_HandHeld then
		create pxyRTDevice as CM_RTDeviceHandHeld transient;
		pxyRTDevice.CM_RTDeviceHandHeld.setProxyForHandHeld(_id, self.getTerminal.radioTelemetry, _model, _computerName, _isPasswordCompulsory, _useSerialConnection, _useLocalTCPConnection, 0, null); 	// +17/08/2016 cnwrh7	TFS	2501
		
	elseif _type = RTDevice_Scanner then
		create pxyRTDevice as CM_RTDeviceScanner transient;
		pxyRTDevice.CM_RTDeviceScanner.setProxyForScanner(_id, self.getTerminal.radioTelemetry, _model, _computerName, _useSerialConnection, _useLocalTCPConnection, 0);	//+ 17/08/2016 cnwrh7	TFS	2501
		
	elseif _type = RTDevice_Vehicle then
		create pxyRTDevice as CM_RTDeviceVehicleMount transient;
		pxyRTDevice.CM_RTDeviceVehicleMount.setProxyForVehicleMount(_id, self.getTerminal.radioTelemetry, _machine, _model, _computerName, _useSerialConnection,_useLocalTCPConnection);	// +17/08/2016 cnwrh7	TFS	2501
		
	endif;
	
	if self.opts.includesKey("RTDevice_ComputerName") then											// 28/07/2011 cnwmh5
		pxyRTDevice.setPropertyValue('computerName', self.opts.str("RTDevice_ComputerName"));
	endif;

	app.myTrxCA.trxCreateRTDevice(pxyRTDevice, newRTDevice, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();

	return newRTDevice;
	
epilog
	delete pxyRTDevice;
	
end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_model" type="String"/>
        <Parameter name="_computerName" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_isPasswordCompulsory" type="Boolean"/>
        <Parameter name="_useSerialConnection" type="Boolean"/>
        <Parameter name="_useLocalTCPConnection" type="Boolean"/>
        <ReturnType type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="addRTGArea" id="38b90351-3c87-4612-8a17-cb386bc31980">
        <source>addRTGArea(_name: String; _rows,_stacks,_tiers: Integer): CM_RTGArea;
//01 September 2008	cnwdw1	 
// 24/08/2011	cnwmh5	Change so uses opts for use40ftIds
vars
	pxyCMIFTerminalArea: CMIF_RTGArea;
	realTA 		: CM_TerminalAreaMaster;
	pxyRTGArea: CM_RTGArea;
	pDO: CM_YADeckingOptionsTA;
	pxyGridRow: CM_RTGRow;
	pxyGridCol: CM_RTGColumn;
	pxyStackCntrl: CM_RTGController;
	row, column: Integer;
	label: String;
	
	pxyTA				: CM_TerminalAreaMaster;
	use40ftIds			: Boolean;
	
begin
	create pxyRTGArea transient;
	
	use40ftIds := self.opts.bool("use40ftIds");			// 26/08/2011 cnwmh5
	
	pxyRTGArea.setIsEmpty(true);
	pxyRTGArea.setGridAreaProxy(_name, 
					"",
					TA_TYPE_RTG,
					_rows,
					_stacks,
					_tiers,
					true, 
					self.getTerminal,
					false,
					false,
					false,
					0,
					 false, false, false, false, false, null,null, use40ftIds, false,
					 null,null,null,null);
	
	create pDO transient;
	pDO.setProxy(false, true, pxyRTGArea);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	foreach row in 1 to _rows do
		label := row.stringWithLeadingZeros(2);
		create pxyGridRow transient;
		pxyGridRow.setForProxy(row, label, pxyRTGArea);
		foreach column in 1 to _stacks do
			label := column.stringWithLeadingZeros(4);
			pxyGridCol := pxyRTGArea.allGridColumns[column].CM_RTGColumn;
			if pxyGridCol = null then
				create pxyGridCol transient;
				pxyGridCol.setForProxy(column, label, pxyRTGArea);
			endif;
			
			create pxyStackCntrl transient;
			pxyStackCntrl.setForProxy(PAD_AVAILABLE, 
							NORMAL_USE, 
							pxyGridRow.row, 
							pxyGridCol.column,
							pxyGridRow.label &amp; pxyGridCol.label,
							2,
							false,
							false,
							null,
							pxyRTGArea, false,null, false, null, false, null);
	

			/*pxyStackCntrl.setForProxyGridController(pxyGridRow.label &amp; pxyGridCol.label, 
								pxyGridCol,
								pxyGridRow,
								2);*/

		endforeach;
	endforeach;
	
	pxyRTGArea.setProxyGantryICAreas(pxyRTGArea, CM_RTGArea.ICPosition_BeforeRow1);

	// 26/08/2011 cnwmh5
	pxyTA := pxyRTGArea;
	// only do this if use40ftIds is set as returns correct location but slightly different format
	if use40ftIds then
		create pxyCMIFTerminalArea transient;
		pxyCMIFTerminalArea.numRows :=  _rows;
		pxyCMIFTerminalArea.numColumns := _stacks;
		pxyCMIFTerminalArea.myPxyTerminalAreaMaster := pxyRTGArea;
		pxyCMIFTerminalArea.startNumColumn := 1;
		pxyCMIFTerminalArea.startNumRow := 1;
		pxyCMIFTerminalArea.labelLengthCol := 4;
		pxyCMIFTerminalArea.labelLengthRow := 4;
		pxyCMIFTerminalArea.use40ftIds := use40ftIds;
		pxyCMIFTerminalArea.createProxyStructure();
		pxyTA := pxyCMIFTerminalArea.myPxyTerminalAreaMaster;
	endif;		
	
	app.myTrxCA.trxCreateTerminalArea(pxyTA, realTA, app.myPassport);				// 26/08/2011 cnwmh5
	self.assertNoTrxErrorsOrWarnings();

	return realTA.CM_RTGArea;
	
epilog

//	pxyCMIFTerminalArea.myPxyTerminalAreaMaster.inspectModal();
	if pxyRTGArea &lt;&gt; null then	// 22/11/2011 cnwmh5 - Added so if error occurs before created that is returned not 1090 from .erase
		pxyRTGArea.erase(0);	//12 Jan 2011	NDL Leaking transients	 must use erase, delete incomplete...
	endif;
	delete pxyCMIFTerminalArea;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_stacks" type="Integer"/>
        <Parameter name="_tiers" type="Integer"/>
        <ReturnType type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="addRTGAreaFromProxy" id="b0aedae2-f505-4fce-a12a-e23a7a3397a7">
        <source>addRTGAreaFromProxy(pxyRTGArea: CM_RTGArea; _rows,_stacks: Integer): CM_RTGArea;
//01 September 2008	cnwdw1	 
//
vars
	pxyCMIFTerminalArea: CMIF_RTGArea;
	realTA		: CM_TerminalAreaMaster;
	pDO: CM_YADeckingOptionsTA;
begin
	create pDO transient;
	pDO.setProxy(false, true, pxyRTGArea);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	create pxyCMIFTerminalArea transient;
	pxyCMIFTerminalArea.numRows :=  _rows;
	pxyCMIFTerminalArea.numColumns := _stacks;
	pxyCMIFTerminalArea.myPxyTerminalAreaMaster := pxyRTGArea;
	pxyCMIFTerminalArea.startNumColumn := 1;
	pxyCMIFTerminalArea.startNumRow := 1;
	pxyCMIFTerminalArea.labelLengthCol := 4;
	pxyCMIFTerminalArea.labelLengthRow := 4;
	pxyCMIFTerminalArea.createProxyStructure();
	
	app.myTrxCA.trxCreateTerminalArea(pxyCMIFTerminalArea.myPxyTerminalAreaMaster,realTA,  app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_RTGArea;
epilog
	delete pxyCMIFTerminalArea;
end;</source>
        <Parameter name="pxyRTGArea" type="CM_RTGArea"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_stacks" type="Integer"/>
        <ReturnType type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="addRailArea" id="40a8416b-255f-47ef-b1f4-131c6ef904fa">
        <source>addRailArea(_id : String; _numLines, _numPositions : Integer) : CM_Rail ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2009	cnwmd1	Initial creation

*/

vars
	pxyRail : CM_Rail; //Rail Area
	pDO: CM_YADeckingOptionsTA;
	realTA 	: CM_TerminalAreaMaster;
begin
	create pxyRail transient;
	pxyRail.setProxy(_id,
						null,
						TA_TYPE_RAILWAY_TRACK,
						_numLines,
						_numPositions,
						null,
						false,
						false,
						false,
						false,
						app.myPassport.myTerminal,
						false,
						false,
						null,null,null);
					
	create pDO transient;
	pDO.setProxy(false, true, pxyRail);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
							
	app.myTrxCA.trxCreateTerminalArea(pxyRail,realTA,  app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_Rail;					
						
epilog

	delete pDO;

	if pxyRail &lt;&gt; null and pxyRail.myLayoutGraphic &lt;&gt; null then

		delete pxyRail.myLayoutGraphic;
	endif;
	delete pxyRail;

	//delete pDO;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_numLines" type="Integer"/>
        <Parameter name="_numPositions" type="Integer"/>
        <ReturnType type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="addRailPreNote" id="a2793e64-c4bc-4b3c-99f6-c7f7c478de60">
        <source>addRailPreNote( _wagonId : String; _wagonClassId : String; _id: String ) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2014	cnwndl1	Initial creation	Par 35040

*/

vars
	ifArray: CMIF_TIObjectArray;
	ifPreNote: CMIF_PreNote;
	verify : Boolean;
	term : CM_Terminal;
begin

	term := self.getTerminal;
	
	create ifArray transient;
	create ifPreNote transient;	
	ifPreNote.id := _id;
	ifPreNote.myTerminal := term;
	
	ifPreNote.cargoType := TI_CargoType_Container;
	if self.opts.includesKey("CargoType") then
		ifPreNote.cargoType := self.opts.int("CargoType");
	endif;
	
	if ifPreNote.cargoType = TI_CargoType_Container then
		if self.opts.includesKey("ISOType") then
			ifPreNote.isoType := self.opts.str("ISOType");
		else
			ifPreNote.isoType := "2200";
		endif;
	endif;
	ifPreNote.commodity := term.getDefaultEmptyCommodity;	
	
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
	ifPreNote.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	ifPreNote.weightTotal := 4000;
	ifPreNote.voyageCode := term.getNullVoyage.code;

	ifPreNote.transportMode := TI_TRANSMODE_RAIL_STR;

	ifPreNote.directDelivery := self.opts.bool("DD");
	
	ifPreNote.wagon := _wagonId;
	if _wagonClassId &lt;&gt; null then
		ifPreNote.myWagonClass := getRoot.allWagonClasses.getAtKey(_wagonClassId);
	endif;

	ifArray.add(ifPreNote);
	
	verify := self.opts.bool("Verify");
	if not verify then
		self.ignoreTrxWarnings(true);

	endif;
	app.myTrxCA.trxCreatePreNotes(ifArray, verify, app.myPassport);
	if not verify then
		self.assertNoTrxErrorsOrWarnings;
	endif;
	return ifPreNote.myPersistentTrackedItem;
	
epilog

	delete ifArray;
	delete ifPreNote;
	
	app.myEventManager.dispatchAllEvents;

end;</source>
        <Parameter name="_wagonId" type="String"/>
        <Parameter name="_wagonClassId" type="String"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addReceiveTransArea" id="081fb3ce-f86b-4f34-aa63-66247a5ef98f">
        <source>addReceiveTransArea(_name: String; _max: Integer; _icArea :Any): CM_BlockStack;
// 20/1102/14	cnwdap1
// PAR #35236

vars
	pxyBlockStack	: CM_BlockStack;
	realTA 			: CM_TerminalAreaMaster;
	pDO				: CM_YADeckingOptionsTA;
	icArray 		: CM_InterchangeAreaArray;
	
begin
	self.deleteTerminalArea(_name);
	if _icArea &lt;&gt; null  then
		create icArray transient;
		if _icArea.isKindOf (CM_InterchangeArea) then
			icArray.add(_icArea.CM_InterchangeArea);
		elseif _icArea.isKindOf (ObjectArray) then
			_icArea.ObjectArray.copy (icArray);
		endif;
	endif;
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(_name, 
					"",
					TA_TYPE_RECTRANS, 
					_max,
					5,
					5,
					false,
					"", 
					_max,
					true, 
					null,
					self.getTerminal,
					false,
					false,
					false,
					false,
					false,
					icArray,
					null,
					false
					);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	if self.opts.includesKey("ActAsReleasePoint") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::actAsReleasePoint.name, self.opts.int("ActAsReleasePoint"));
	endif;
	
	if self.opts.includesKey("StockControlled") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::isStockControlled.name, self.opts.bool("StockControlled"));
	endif;
	
	if self.opts.includesKey("Comment") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::comment.name, self.opts.str("Comment"));
	endif;
	
	if self.opts.includesKey("DefaultYIC") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::myDefaultInterchangeArea.name, self.opts.obj("DefaultYIC").CM_YardInterchangeArea);
	endif;
	
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, realTA, app.myPassport);
	if not self.opts.includesKey("ExpectErrors") then
		self.assertNoTrxErrorsOrWarnings();
	endif;

	if realTA = null then
		return null;
	else
		return realTA.CM_BlockStack;
	endif;
epilog
	delete pxyBlockStack;		//+cnwml2 MSL CCMS 1012  pDo gets deleted when deleting pxyBlockStack
	//delete pDO;
	delete icArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_icArea" type="Any"/>
        <ReturnType type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="addRecipeComponent" id="2273e362-5a43-48c5-bb1b-0a99f82106f5">
        <source>addRecipeComponent( _seq : Integer; _obj : CM_Object; _amount : Decimal ):CM_RecipeComponent;
/*

Purpose:			

Parameters:			creates and passes back a TRANSIENT recipe component ( as happens on the CMUI_Recipe form )


Return Value:		

Date		Who		Reason
28 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	transientComp : CM_RecipeComponent;
	cargoType : CM_CargoType;
	product : CM_Product;
	
	quantity : Integer;
	volume : Decimal[14,4];
	weight : Decimal[14,4];
	
	code : String;
	description : String;

begin

	if _obj = null then
		return null;
	elseif _obj.isKindOf(CM_CargoType) then
		cargoType := _obj.CM_CargoType;
	elseif _obj.isKindOf(CM_Product) then
		cargoType := _obj.CM_Product.myCargoType;
		product := _obj.CM_Product;
	else
		return null;
	endif;
	
	create transientComp transient;
	
	if cargoType.isTrackByVolume then
		volume := _amount;
	elseif cargoType.isTrackByWeight then
		weight := _amount;
	else
		quantity := _amount.Integer;
	endif;
	
	transientComp.setProxy(	code,	//_code : String;
							description,	//_description : String;
							cargoType,	//_myCargoType : CM_CargoType;
							product,	//_myProduct : CM_Product;
							_seq,	//_order : Integer;
							quantity,	//_quantity : Integer;
							volume,	//_volume : Decimal;
							weight	//_weight : Decimal
							);
	
	return transientComp;

epilog

end;</source>
        <Parameter name="_seq" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_amount" type="Decimal"/>
        <ReturnType type="CM_RecipeComponent"/>
    </JadeMethod>
    <JadeMethod name="addReleaseById" id="c77a7e8f-57eb-4acc-b7a5-6dbefcda5ddf">
        <source>addReleaseById(_releaseNumber: String; _releaseType: Integer; _cargo: Any): CM_BulkRelease;
/* Changes

Date		Name	TFS#			Description
============================================================================
23 December 2008	cnwdw1	
23/04/2012	cnwcs5	CCMS POL 2172 
					/ par 29480 	coparn release updates
24/10/2012	cnwmh5	#30539 			Update to allow Allow Cargo On Multiple Releases to be set
12 May 2016	cnwns1	TFS 488 		Multi Timezone Support
25/01/2019	jlgka1	41708			As a result of the changes in the CM_BulkRelease.setProxy
									we also need to add myBOLIn here.
============================================================================*/
vars
	release				: CM_BulkRelease;
	pxyReleaseRequest	: CM_BulkRelease;
	pxyReserveTI		: CM_ReserveTI;
	fullRelease			: Boolean;
	terminalArea		: CM_TerminalArea;
	number				: Integer;
	voyage				: CM_Voyage;
	voyageCode			: String;
	cargo				: CM_TrackedItem;
	delReasonCode		: Integer;
	delReasonDesc		: String;
	delRelRemarks   	: String;
	allowMultiReleases 	: Boolean;
	consigneeCode		: String;
	operator : CM_Operator;
begin
	deleteReleaseRequest(_releaseNumber);
	
	
	if self.opts.includesKey("operator") then    // cnwmk3 11/03/2016 for UT_Gate: tUpdateConsignee
		operator := self.getOperator(self.opts.str("operator"));
	else
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	endif;
	
	fullRelease := self.opts.bool("FullRelease");
	terminalArea := self.opts.obj("TerminalArea").CM_TerminalArea;
	number := self.opts.int("Number");
	if number = 0 then
		number := 1;
	endif;
	
	voyage := self.opts.obj("Voyage").CM_Voyage;
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
	endif;
	
	delReasonCode := self.opts.int ("DeliveryReleaseReason");
	
	allowMultiReleases := self.opts.bool("AllowCargoMultipleReleases");					// 24/10/2012 cnwmh5 #30539
	
	if delReasonCode &lt;&gt; null then
		delReasonDesc := app.deliveryReasonEnumToString (delReasonCode);
	endif;
	
	if self.opts.includesKey("RelRemarks") then    //cnwma1 30/10/2014 PAR #35088
	delRelRemarks := self.opts.str("RelRemarks");
	else
	delRelRemarks:= null;
	endif;
	
	if self.opts.includesKey("consigneeCode") then    // cnwmk3 11/03/2016 for UT_Gate: tUpdateConsignee
	consigneeCode := self.opts.str("consigneeCode");
	else
	consigneeCode:= null;
	endif;
	
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(_releaseNumber,
								_releaseType,
								false,
								BR_ACTIVE,
								null,
								null,
								self.getProfileStr(UT_Profile.P_CARRIER),
								delRelRemarks,// Remarks						// 24/10/2012 cnwmh5 #30539
								consigneeCode,
								null,
								null,
								null,
								null,//consign voyage
								app.actualTimeServer(),		// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
								null, //today,		// cnwdad1 30/05/2007 - PAR #14132: Do not default required date to today.
								delReasonCode,
								delReasonDesc,
								null,
								null, //door dir
								null,
								self.opts.obj("Booking").CM_BookingRef,
								self.getTerminal().getDefaultPort,//load port
								null,//_destinationPort
								null,
								self.opts.str("FreightForwarder"),//freightForwarder
								null,
								self.getTerminal(),
								operator,
								null,
								voyage,//voyage
								null,//bank
// TFS 2686								false,
								fullRelease,
								null,null,null,
								self.getTerminal().getDefaultSubTerminalForRel(_releaseType),
								null, // subterm target//cnwrd1 par 23219 17.3.2010
								null, 	//_assignedTrain : CM_Train
								allowMultiReleases,							// 24/10/2012 cnwmh5 #30539
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								false, false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false, 	// par 29480 april 2012
								null,	// CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	// jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
	if _cargo.isKindOf(CM_TrackedItem) then
		create pxyReserveTI transient;
		pxyReserveTI.setMyHeader(pxyReleaseRequest);
		pxyReserveTI.allTrackedItems.add(_cargo.CM_TrackedItem);
		if self.opts.int("TotalRequested") &gt; 0 and _cargo.isKindOf(CM_BreakBulkGeneric) then
			pxyReserveTI.setTotalRequested(self.opts.int("TotalRequested"));
		endif;
		//18 Mar 2021	NDL	TFS 50940
		if self.opts.int("AnyAmtAnyIdAllowedAmount") &gt; 0 and _cargo.isKindOf(CM_BreakBulkGeneric) then
			pxyReserveTI.setTotalRequestedAllowed(self.opts.int("AnyAmtAnyIdAllowedAmount"));
		endif;
		
	else
		foreach cargo in _cargo.CM_TISet do
			create pxyReserveTI transient;
			pxyReserveTI.setMyHeader(pxyReleaseRequest);
			pxyReserveTI.allTrackedItems.add(cargo.CM_TrackedItem);
			pxyReleaseRequest.allTrackedItemsAssigned.add(cargo.CM_TrackedItem);
			if self.opts.int("TotalRequested") &gt; 0 and cargo.isKindOf(CM_BreakBulkGeneric) then
				pxyReserveTI.setTotalRequested(self.opts.int("TotalRequested"));
			endif;
			//18 Mar 2021	NDL	TFS 50940
			if self.opts.int("AnyAmtAnyIdAllowedAmount") &gt; 0 and _cargo.isKindOf(CM_BreakBulkGeneric) then
				pxyReserveTI.setTotalRequestedAllowed(self.opts.int("AnyAmtAnyIdAllowedAmount"));
			endif;
		endforeach;
	endif;
	
	if opts.bool("CreateDeliveryRequest") then 					
		pxyReleaseRequest.createRequests();
	endif;	
	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, release,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return release;
epilog
	delete pxyReleaseRequest;
end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_cargo" type="Any"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="addReleaseByTypeRequest" id="87f130e9-6d7b-4863-ab59-d7202d41826a">
        <source>addReleaseByTypeRequest(_releaseNumber: String; _releaseType: Integer; _cargoType: Integer; _isoCode: String): CM_BulkRelease;
//23 December 2008	cnwdw1	
vars
begin
	///self.opts.purge;								// 23/06/2015 cnwmh5
	self.opts.addAssoc("ISOType", _isoCode);
	return self.addReleaseByTypeRequestOpts(_releaseNumber, _releaseType, _cargoType);
epilog
end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_isoCode" type="String"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="addReleaseByTypeRequestOpts" id="a413dd56-0df6-4714-ac84-1b3e826ef248">
        <source>addReleaseByTypeRequestOpts(_releaseNumber: String; _releaseType: Integer; _cargoType: Integer): CM_BulkRelease;
//23 December 2008	cnwdw1	
// Opts :- ISoType -&gt; string
// Opts :- ISOGroup -&gt; string
// Opts :- BookingItem
// Opts :- Product
// Opts :- Number
// Opts :- Train
// Opts :- CreateDeliveryRequest
/* Changes

Date		Name	TFS#			Description
============================================================================
12/08/2011	cnwmh5					Change to use UT_UnitTest's opts rather than passing it
23/04/2012	cnwcs5	CCMS POL 2172 
					/ par 29480 	coparn release updates
06/05/2012	cnwcs5					add consignor/consignee
09 Sep 2014	cnwrs1	CCMS 2351 		att Sequence to Release request 
20/11/2014	cnwdap1	PAR #35236 		set iso group on bulk release if supplied
01/07/2015	cnwma1	PAR #36555 
					CCMS 2509 TFS 	Multi-location selection for MTs for vessel release
12/05/2016	cnwns1	TFS 488 		Multi Timezone Support
25/01/2019	jlgka1	41708			As a result of the changes in the CM_BulkRelease.setProxy
									we also need to add myBOLIn here.
19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level	
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
01 Sep 2023 navhl20 ChangeRequest 59819:[60443] EUP | Delivery Dispatch Screen - Unit Tests - [3]
TFS CR 60922 TASK 60980 30OCT2023 NAVAB1 - context and cargo group
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
06 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation
07/11/2025	jlizm1	MTN 36328 Rotabox Assign Release To Vessel Unit Test
============================================================================*/
vars
	release				: CM_BulkRelease;
	pxyReleaseRequest	: CM_BulkRelease;
	pxyReserveSelection	: CM_ReserveSelection;
	pxyReserveSelection2: CM_ReserveSelection;
	pxyDeliveryRequest 	: CM_DeliveryRequest;
	isoType				: CM_ISOType;
	isoGroup			: CM_ISOTypeGroup; 
	isoGroup2			: CM_ISOTypeGroup;
	fullRelease			: Boolean;
	canBeHiLoCube 		: Boolean;
	ta					: CM_TerminalArea;
	number,
	numberReserve		: Integer;
	voyage				: CM_Voyage;
	voyageCode			: String;
	operator 			: CM_Operator;
	grade 				: CM_MTGrade;
	availGrades 		: IntegerArray;
	carrierId 			: String;
	consignor			: String;
	consignee			: String;
	matchYACriteria 	: CM_ReleaseByTypeCriteria;
	delRequest 			: CM_DeliveryRequest;
	reserveSel 			: CM_ReserveSelection;
	allTermAreaDict		: CM_TAByIdDict;
	doDelete 			: Boolean;
	weightSelection 	: Decimal[14,4];
	weightRequested 	: Decimal[14,4];	
	tempWeightSelection : Decimal[14,4];
	measurementType 	: CM_MeasurementType;
	unit 				: String;
	customerRef			: String;	//19-07-2022 navtnr20 53974
	lineNum				: Integer;	//19-07-2022 navtnr20 53974
	isoTypeStr			: String;
	packType,
	packType1			: Integer;
	cargoType			: CM_CargoType;
	context : String;
	cargoGroup : CM_CargoGroup;
	commodity : CM_Commodity;
	contentsCT			: CM_CargoType;
begin

	doDelete := true;
	
	// ### TFS CR 60922 TASK 60980 31OCT2023 NAVAB1
	if self.opts.includesKey("Context") then
		context := self.opts.str("Context");
	endif;
	if self.opts.includesKey("CargoGroup") then
		cargoGroup := self.opts.obj("CargoGroup").CM_CargoGroup;
	endif;
	
	if opts.includesKey("NoDelete") then
		doDelete := not self.opts.bool("NoDelete");
	endif;
	if doDelete then
		self.deleteReleaseRequest(_releaseNumber);
	endif;
	
	fullRelease := self.opts.bool("FullRelease");
	canBeHiLoCube := self.opts.bool("CanBeHiLoCube");
	
	if self.opts.includesKey("ISOType") then
		isoTypeStr := self.opts.str("ISOType");
	elseif self.opts.includesKey(UT_OPTS_ISOType) then
		isoTypeStr := self.opts.str(UT_OPTS_ISOType);
	endif;
	
	isoType := app.myRoot.allISOTypes[isoTypeStr];
	isoGroup := app.myRoot.allISOTypeGroups[self.opts.str("ISOGroup")];
	isoGroup2 := app.myRoot.allISOTypeGroups[self.opts.str("ISOGroup2")];
	ta := self.opts.obj("TerminalArea").CM_TerminalArea;
	create allTermAreaDict transient;
	if ta &lt;&gt; null then
		allTermAreaDict.add(ta);
	endif;
	if self.opts.includesKey("Number") then
		number := self.opts.int("Number");
	elseif self.opts.includesKey(UT_OPTS_Number) then
		number := self.opts.int(UT_OPTS_Number);
	endif;
	
	if number = 0 then
		number := 1;
	endif;
	
	if self.opts.includesKey("NumberSec") then		//08.9.2023 navhl20 #59819[60443]
		numberReserve := self.opts.int("NumberSec");
	endif;
	
	if numberReserve = 0 then
		numberReserve := 1;
	endif;
	
	if self.opts.includesKey("CargoType") then		//08.9.2023 navhl20 #59819[60443]
		cargoType := self.opts.obj("CargoType").CM_CargoType;
	else
		cargoType := app.myRoot.allCargoTypesById[_cargoType];
	endif;
	
	if self.opts.includesKey("ContentsCargoType") then
		contentsCT := self.opts.obj("ContentsCargoType").CM_CargoType;
	endif;
	
	if self.opts.includesKey("Commodity") then
		commodity := self.opts.obj("Commodity").CM_Commodity;
	endif;
	
	if self.opts.includesKey("PackType1") then		//01.9.2023 navhl20 #59819[60443]
		packType1 := self.opts.int("PackType1");
	endif;
	
	if self.opts.includesKey("PackType") then		//01.9.2023 navhl20 #59819[60443]
		packType := self.opts.int("PackType");
	endif;
	
	voyage := self.opts.obj("Voyage").CM_Voyage;
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
	endif;
	
	operator := self.opts.obj("Operator").CM_Operator; 
	if operator = null then
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	endif;	
	
	grade := self.opts.obj("Grade").CM_MTGrade;
	if grade &lt;&gt; null then
		create availGrades transient;
		availGrades.add(grade.code);
	endif;
	
	carrierId := self.getProfileStr(UT_Profile.P_CARRIER);			// 08/11/2011 cnwmh5
	if self.opts.includesKey("Carrier") then
		carrierId := self.opts.obj("Carrier").CM_Carrier.code;
	endif;
	
	if opts.includesKey(UTTI_Consignee) then
		consignee := opts.str(UTTI_Consignee);
	endif;
	if opts.includesKey(UTTI_Consignor) then
		consignor := opts.str(UTTI_Consignor);
	endif;
	//start 19-07-2022 navtnr20 53974
	if opts.includesKey(UTTI_CustomerReference) then
		customerRef := opts.str(UTTI_CustomerReference);
	endif;
	
	if self.opts.includesKey(UTTI_LineNumber) then			
		lineNum := self.opts.int(UTTI_LineNumber);
	endif;
	
	//end 19-07-2022	navtnr20 53974
	//18 Jun 2015	NDL	Par 36338
	if opts.includesKey(ETRow_SetCriteria) then
		matchYACriteria := self.opts.obj(ETRow_SetCriteria).CM_ReleaseByTypeCriteria;
	endif;
	
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(_releaseNumber,
								_releaseType,
								true,
								BR_ACTIVE,
								null,
								null,
								//self.getProfileStr(UT_Profile.P_CARRIER),
								carrierId,
								null,
								consignee,
								null,
								consignor,
								null,
								null,//consign voyage
								app.actualTimeServer(),		// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
								null, //today,		// cnwdad1 30/05/2007 - PAR #14132: Do not default required date to today.
								null,
								null,
								null,
								null, //door dir
								null,
								self.opts.obj("Booking").CM_BookingRef,
								self.getTerminal().getDefaultPort,//load port
								self.opts.obj("Destination").CM_Port,//_destinationPort
								self.opts.obj("DischargePort").CM_Port,
								null,//freightForwarder
								null,
								self.getTerminal(),
								operator,
								null,
								voyage,//voyage
								null,//bank
// TFS 2686								false,
								fullRelease,
								null,null,null,
								self.getTerminal().getDefaultSubTerminalForRel(_releaseType),
								null, // subterm target//cnwrd1 par 23219 17.3.2010
								self.opts.obj("Train").CM_Train, 	//_assignedTrain : CM_Train
								false,
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								canBeHiLoCube, false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false, // par 29480 April 2012
								null, 	//CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	// jlgka1 TFS 41708
								context // ### TFS CR 60922 TASK 60980 31OCT2023 NAVAB1	// ### TFS 53953 27June2022 NAVPW1
								);
								
	if isoGroup &lt;&gt; null then															// PAR #35236
		pxyReleaseRequest.setPropertyValue(CM_BulkRelease::myISOGroup.name, isoGroup);	// PAR #35236
	endif;																				// PAR #35236
	
	if self.opts.includesKey("weightRequested") then					
		weightRequested := self.opts.dec("weightRequested");
	endif;
	if self.opts.includesKey("WeightSelection") then						// 18/03/2016 cnwmh5
		weightSelection := self.opts.dec("WeightSelection");
	endif;
	
	if self.opts.includesKey("MeasurementType")then							// 18/03/2016 cnwmh5
		measurementType := self.opts.obj("MeasurementType").CM_MeasurementType;
		weightSelection := app.convertMeasurementForStorage(measurementType.shortName, weightSelection);
		weightRequested := app.convertMeasurementForStorage(measurementType.shortName, weightRequested);
	endif;
	
	create pxyReserveSelection transient;
	pxyReserveSelection.setMyHeader(pxyReleaseRequest);
	pxyReserveSelection.setPxyDefaults();

	pxyReserveSelection.setProxy(packType,				//01.9.2023 navhl20 #59819[60443] 
								app.myRoot.allCargoTypesById[_cargoType],
								self.opts.obj("BookingItem").CM_BookingRefItem,
								isoType,
								isoGroup,
								self.opts.obj("Product").CM_Product,
								null,
								null,
								number,
								availGrades, //avail grades
								null,//clean
								null, //iso check
								false, //heavy rated
								null, //mask ids
								0,
								self.opts.str("Colour"),
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								weightSelection,					// 18/03/2016 cnwmh5  null,
								null,
								self.opts.str("Mark"),
								null,
								null,
								//ta,					// 01/07/2015 cnwma1 PAR #36555
								allTermAreaDict,		 // 01/07/2015 cnwma1 PAR #36555
								self.opts.obj("BOL").CM_BOLIn,
								self.opts.bool("BestPick"),
								null,
								null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
								null,	// ### TFS 53953 11July2022 NAVPW1
								null,null,  //12-07-2022 navtnr20 53974
								cargoGroup, // ### TFS CR 60922 TASK 60980 31OCT2023 NAVAB1 //28/06/2023 navmv20 CR 58410 Task 58411 
								false,		// 6/12/2023 navcs2 ChangeRequest 57537
								false,	//19/02/2023	navkc1 CR 60078 Task 62450
								commodity,	//24/04/2025	navrv30	MTN 34319
								contentsCT);
								
	//18 Jun 2015	NDL	Par 36338
	if matchYACriteria &lt;&gt; null then
		matchYACriteria.setProxyBaseData(pxyReserveSelection);
	endif;
	
	if self.opts.includesKey("weightRequested") then
		pxyReserveSelection.setWeightRequested(weightRequested);
	endif;
    
	if isoGroup2 &lt;&gt; null or packType1 &lt;&gt; null then				//01.9.2023 navhl20 #59819[60443]
		/// Create a second release item sane as first but for isogroup
		create pxyReserveSelection2 transient;
		pxyReserveSelection2.setMyHeader(pxyReleaseRequest);
		pxyReserveSelection2.setPxyDefaults();
		
		pxyReserveSelection2.setProxy(packType1, 				//01.9.2023 navhl20 #59819[60443]
								cargoType,							//08.9.2023 navhl20 #59819[60443]
								self.opts.obj("BookingItem").CM_BookingRefItem,
								isoType,
								isoGroup2,
								self.opts.obj("Product").CM_Product,
								null,
								null,
								numberReserve,						//08.9.2023 navhl20 #59819[60443]
								availGrades, //avail grades
								null,//clean
								null, //iso check
								false, //heavy rated
								null, //mask ids
								0,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								//ta, 				// 01/07/2015 cnwma1 PAR #36555
								allTermAreaDict,    // 01/07/2015 cnwma1 PAR #36555
								self.opts.obj("BOL").CM_BOLIn,
								self.opts.bool("BestPick"),
								null,
								null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
								null,	// ### TFS 53953 11July2022 NAVPW1
								null,null,  //12-07-2022 navtnr20 53974
								null, //28/06/2023 navmv20 CR 58410 Task 58411
								false,
								false, //19/02/2023	navkc1 CR 60078 Task 62450
								null,	//24/04/2025	navrv30	MTN 34319 
								contentsCT);

	endif;
	
	if opts.bool("CreateDeliveryRequest") then							
		pxyDeliveryRequest := pxyReleaseRequest.createRequests();
		if not fullRelease then
			pxyDeliveryRequest.setMTCommodity();
		endif;
	endif;	
	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, release,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//18 Jun 2015	NDL	Par 36338
	if matchYACriteria &lt;&gt; null then
		delRequest := release.requests.first.CM_DeliveryRequest;
		reserveSel := release.allReserveDetails.first.CM_ReserveSelection;
		if delRequest &lt;&gt; null then
			beginTransaction;
			delRequest.setReserveDetail( reserveSel ); 
			commitTransaction;
		endif;
	endif;
			
	return release;
epilog
	delete pxyReleaseRequest;
	delete availGrades;
	delete allTermAreaDict;
end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="addReleaseTransArea" id="4f157c0c-fc74-4c92-be91-569546f141b4">
        <source>addReleaseTransArea(_name: String; _max: Integer; _icArea :Any): CM_BlockStack;
/*

Purpose:		Create Release Transfer Area

Date			Who		Reason
25/06/2015		cnwmh5	Initial creation

*/

vars
	pxyBlockStack	: CM_BlockStack;
	realTA 			: CM_TerminalAreaMaster;
	pDO				: CM_YADeckingOptionsTA;
	icArray 		: CM_InterchangeAreaArray;
	
begin
	self.deleteTerminalArea(_name);
	if _icArea &lt;&gt; null  then
		create icArray transient;
		if _icArea.isKindOf (CM_InterchangeArea) then
			icArray.add(_icArea.CM_InterchangeArea);
		elseif _icArea.isKindOf (ObjectArray) then
			_icArea.ObjectArray.copy (icArray);
		endif;
	endif;
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(_name, 
					"",
					TA_TYPE_RELTRANS, 
					_max,
					5,
					5,
					false,
					"", 
					_max,
					true, 
					null,
					self.getTerminal,
					false,
					false,
					false,
					false,
					false,
					icArray,
					null,
					false
					);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	if self.opts.includesKey("ActAsReleasePoint") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::actAsReleasePoint.name, self.opts.int("ActAsReleasePoint"));
	endif;
	
	if self.opts.includesKey("StockControlled") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::isStockControlled.name, self.opts.bool("StockControlled"));
	endif;
	
	if self.opts.includesKey("Comment") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::comment.name, self.opts.str("Comment"));
	endif;
	
	if self.opts.includesKey("DefaultYIC") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::myDefaultInterchangeArea.name, self.opts.obj("DefaultYIC").CM_YardInterchangeArea);
	endif;
	
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, realTA, app.myPassport);
	if not self.opts.includesKey("ExpectErrors") then
		self.assertNoTrxErrorsOrWarnings();
	endif;

	if realTA = null then
		return null;
	else
		return realTA.CM_BlockStack;
	endif;
epilog
	delete pxyBlockStack;		//+cnwml2 MSL CCMS 1012  pDo gets deleted when deleting pxyBlockStack
	//delete pDO;
	delete icArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_icArea" type="Any"/>
        <ReturnType type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="addReleaseTransAreaAuto" id="0c09de4f-0dbe-427e-a8d0-c2d68edcc26e">
        <source>addReleaseTransAreaAuto(_areaName : String) : CM_TerminalAreaMaster;
/*
Purpose:			
Date				Who			Reason
OCTOBER 2018		NAVAB1		Initial creation
*/
	
vars

	pxyBlockStack : CM_BlockStack;
	pDO : CM_YADeckingOptionsTA;
	area : CM_TerminalAreaMaster;
begin

	create pxyBlockStack transient;
	pxyBlockStack.setProxy(_areaName, 
							"",
							TA_TYPE_RELTRANS, 
							1,
							5,
							5,
							false,
							"", 
							99,
							true, 
							null,
							self.getTerminal,
							false,
							false,
							false,
							false,
							false,
							null,
							null,
							false
							);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	pxyBlockStack.setAutoRelease(	true,	//_autoRelease : Boolean;
									TRANS_TYPE_REL_ROAD	//_trxTypeOnRelease : Integer
									);
	
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, area, app.myPassport);

	return area;
epilog

	delete pxyBlockStack;

end;</source>
        <Parameter name="_areaName" type="String"/>
        <ReturnType type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="addReserveSelectionOpts" id="0e535c19-2278-4373-beb4-67cd4e9486a2">
        <source>addReserveSelectionOpts(	_bulkRelease: CM_BulkRelease input; 
							_packType	: Integer; // = CM_ReserveDetail.PackType_Parent, or CM_ReserveDetail.PackType_Child for packing children
							_cargoType	: Integer);
//12 January 2011	cnwvu1
//09 Sep 2014	cnwrs1	CCMS 2351 att Sequence to Release request 
//01/07/2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level	
//28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request	
//6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
//11 Jul 2025	navhl20 Bug MTN-35305: MTN - Optimize Saving Road Jobs to Avoid Redundant Yard Allocation Checks															
vars
	pxyBulkRelease		: CM_BulkRelease;
	pxyReserveSelection,
	realReserveSelection: CM_ReserveSelection;
	voyage				: CM_Voyage;
	voyageCode			: String;
	ta					: CM_TerminalArea;
	tas					: CM_TAByIdDict;
	matchYACriteria 	: CM_ReleaseByTypeCriteria;
	volume 				: Decimal [16,4];
	weight 				: Decimal [16,4];
	measurementType 	: CM_MeasurementType;
	customerRef 		: String;//19-07-2022 navtnr20 53974
	lineNum 			: Integer;//19-07-2022 navtnr20 53974
	pxyDeliveryRequest 	: CM_DeliveryRequest;
begin

	voyage := self.opts.obj("Voyage").CM_Voyage;
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
	endif;

	ta := opts.obj("TerminalArea").CM_TerminalArea;
	create tas transient;
	if ta &lt;&gt; null then
		tas.add(ta);
	endif;
	
	pxyBulkRelease := app.createUpdateProxy(_bulkRelease).CM_BulkRelease;
	//pxyBulkRelease := _bulkRelease.pxyCreateUpdateProxy();
	
	if opts.includesKey(UTTI_Volume) then
		volume := self.opts.dec(UTTI_Volume);
	endif;
	if opts.includesKey(UTTI_TotalWeight) then
		weight := self.opts.dec(UTTI_TotalWeight);
	endif;
	
	if self.opts.includesKey("MeasurementType") then						// 18/03/2016 cnwmh5
		measurementType := self.opts.obj("MeasurementType").CM_MeasurementType;
		weight := app.convertMeasurementForStorage(measurementType.shortName, weight);
	endif;
	//19-07-2022 navtnr20 53974
	if opts.includesKey(UTTI_CustomerReference) then
		customerRef := opts.str(UTTI_CustomerReference);
	endif;
	
	if self.opts.includesKey(UTTI_LineNumber) then			
		lineNum := self.opts.int(UTTI_LineNumber);
	endif;
	
	//19-07-2022 navtnr20 53974
	create pxyReserveSelection transient;

	//pxyReserveSelection.setMyHeader(pxyReleaseRequest); moved below
	pxyReserveSelection.setPxyDefaults();
	
	pxyReserveSelection.setProxy(_packType, 
								app.myRoot.allCargoTypesById[_cargoType],
								opts.obj("BookingItem").CM_BookingRefItem,
								app.myRoot.allISOTypes[opts.str("ISOType")],
								app.myRoot.allISOTypeGroups[opts.str("ISOGroup")],
								opts.obj("Product").CM_Product,
								null,
								null,
								opts.int("Number"),
								null, //avail grades
								null,//clean
								null, //iso check
								false, //heavy rated
								null, //mask ids
								0,	//_maxToRelease
								null,	//_color
								null,	//_descriptionSelection
								null,	//_heightSelection
								null,	//_lengthSelection
								null,	//_markNumber
								null,	//_quantitySelection
								null,	//_remarksSelection
								volume,	//_volumeSelection : Decimal;
								weight,	//_weightSelection : Decimal;
								null,	//_widthSelection
								null,	//_markSelection
								null,	//_densitySelection
								null,	//_typeSelection
								//opts.obj("TerminalArea").CM_TerminalArea,  // 01/07/2015 cnwma1 PAR #36555
								tas,     // 01/07/2015 cnwma1 PAR #36555
								opts.obj("BOL").CM_BOLIn,
								opts.bool("BestPick"),
								null,	//_sequence
								null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
								null,	// ### TFS 53953 11July2022 NAVPW1
								lineNum,customerRef,  //12-07-2022 navtnr20 53974
								null, //28/06/2023 navmv20 CR 58410 Task 58411
								false,	// 6/12/2023 navcs2 ChangeRequest 57537
								false, //19/02/2023	navkc1 CR 60078 Task 62450
								null, //24/04/2025	navrv30	MTN 34319
								null);
								
	if opts.includesKey(ETRow_SetCriteria) then
		matchYACriteria := self.opts.obj(ETRow_SetCriteria).CM_ReleaseByTypeCriteria;
		if matchYACriteria &lt;&gt; null then
			matchYACriteria.setProxyBaseData(pxyReserveSelection);
		endif;
	endif;

	pxyReserveSelection.setMyHeader(pxyBulkRelease);
	
	if opts.bool("CreateDeliveryRequest") then											//11.07.2025 navhl20 #35305							
		pxyDeliveryRequest := pxyBulkRelease.createRequests();
	endif;

	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
epilog
	delete pxyBulkRelease;
	delete tas;
	
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_packType" type="Integer"/>
        <Parameter name="_cargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSealOperatorConfig" id="00ff1c9a-a70b-480e-a7e0-2df2aa5a86c8">
        <source>addSealOperatorConfig(_operator : CM_Operator io; _sealShipRec : Integer; _sealShipRel : Integer; _sealRailRec : Integer; _sealRailRel : Integer; _sealRoadRec : Integer; _sealRoadRel : Integer);
//26 August 2010	cnwml2
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	pxyOperator : CM_Operator;
	tmpConfig : CMIF_ConfigOperator;
begin
	if _operator = null then		
		return;
	endif;
	
	beginLoad;
	pxyOperator := _operator.pxyCreateUpdateProxy();
	endLoad;
	pxyOperator.setSealCheckProxy(_sealShipRec, _sealShipRel, _sealRailRec, _sealRailRel, _sealRoadRec, _sealRoadRel);
	
	create tmpConfig transient;
	tmpConfig.setFromPersistentData(_operator);
	
	app.myTrxUA.trxUpdateOperator(pxyOperator, tmpConfig, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyOperator;
	delete tmpConfig;
end;</source>
        <Parameter name="_operator" type="CM_Operator" usage="io"/>
        <Parameter name="_sealShipRec" type="Integer"/>
        <Parameter name="_sealShipRel" type="Integer"/>
        <Parameter name="_sealRailRec" type="Integer"/>
        <Parameter name="_sealRailRel" type="Integer"/>
        <Parameter name="_sealRoadRec" type="Integer"/>
        <Parameter name="_sealRoadRel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSealTI" id="a1e5dac2-9b81-4753-9628-b316ad9f0ebd">
        <source>addSealTI(_allSealNums : HugeStringArray; _myTrackedItem : CM_TrackedItem input; _sealType : String): CM_TrackedItem;
/* Changes

Date		Name	TFS#		Description
============================================================================
20/08/2010	cnwml2
08/04/2011	cnwmh5	PAR #27347 	Add cmsEndLoad or endLoad to epilog so that 
								if error occurs it will not leave it in beginLoad state
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.								
============================================================================*/
vars
	pxySealTI 			: CM_SealTI;
	pxyTI 				: CM_TrackedItem;
	extraParams			: CMIF_TIUpdateExtraParams;
	txnControllerDict	: CMIF_TITxnContrlrByTypeDTDict;
	strValue, 
	str, 
	strSeal 			: String;
	seal				: CM_SealTI;
	foundSeal 			: Boolean;
begin
	create extraParams transient;	
	create txnControllerDict transient;
	beginLoad;
	pxyTI := _myTrackedItem.pxyCreateUpdateProxy();
	endLoad;
		
	if _myTrackedItem.allSeals.size &gt; 0 then
		foreach seal in pxyTI.allSeals do
			if pxyTI.allSeals.includesKey(_sealType) then					//found existing seal in ti
				foreach str in _allSealNums do
					if strValue &lt;&gt; null then
						strValue:= strValue&amp; ", " &amp; str;
					else
						strValue := str;
					endif;
				endforeach;
				foreach str in seal.allSealNums do
					if strSeal &lt;&gt; null then
						strSeal := strSeal &amp; ", " &amp; str;
					else
						strSeal := str;
					endif;
				endforeach;
				if strValue &lt;&gt; strSeal then
					seal.setPreviousSeal(strSeal);
				endif;
				
				seal.allSealNums.clear();
				seal.allSealNums.add(strValue);
				foundSeal := true;
				break;
			else
				create pxySealTI transient;
				_allSealNums.copy(pxySealTI.allSealNums);
				pxySealTI.setMyTrackedItem(pxyTI);
				pxySealTI.setSealType(_sealType);
			endif;
		endforeach;
	else
		create pxySealTI transient;
		_allSealNums.copy(pxySealTI.allSealNums);
		pxySealTI.setMyTrackedItem(pxyTI);
		pxySealTI.setSealType(_sealType);
	endif;
	
	app.myTrxUA.trxUpdateTIandExtraInfo(pxyTI, TI_UPDMODE_NORMAL, extraParams, txnControllerDict, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return _myTrackedItem;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxySealTI;
	delete pxyTI;
	delete extraParams;
	delete txnControllerDict;
	
end;</source>
        <Parameter name="_allSealNums" type="HugeStringArray"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_sealType" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addSealTerminalConfig" id="acea82ad-3e40-4ab2-9ea3-f040d1007fc2">
        <source>addSealTerminalConfig(	_terminal : CM_Terminal io;
						_sealShipRec : Integer;
						_sealShipRel : Integer;
						_sealRailRec : Integer;
						_sealRailRel : Integer;
						_sealRoadRec : Integer;
						_sealRoadRel : Integer;
						_sealPack : Integer;
						_sealUnpack : Integer;
						_sealWagonLoad : Integer;
						_sealWagonDischarge : Integer;
						_sealTruckLoad : Integer;
						_sealTruckDischarge : Integer
						);
//26 August 2010	cnwml2
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	pxyTerminal : CM_Terminal;
	tmpConfig : CMIF_ConfigTerminal;
begin
	if _terminal = null then		
		return;
	endif;
	
	beginLoad;
	pxyTerminal := _terminal.pxyCreateUpdateProxy();
	endLoad;
	pxyTerminal.setSealCheckProxy(_sealShipRec, _sealShipRel, _sealRailRec, _sealRailRel, _sealRoadRec, _sealRoadRel, _sealPack, _sealUnpack, _sealWagonLoad, _sealWagonDischarge, _sealTruckLoad, _sealTruckDischarge);
	
	create tmpConfig transient;
	tmpConfig.setFromPersistentData(_terminal);
	
	app.myTrxUA.trxUpdateTerminal(pxyTerminal, tmpConfig, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyTerminal;
	delete tmpConfig;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="io"/>
        <Parameter name="_sealShipRec" type="Integer"/>
        <Parameter name="_sealShipRel" type="Integer"/>
        <Parameter name="_sealRailRec" type="Integer"/>
        <Parameter name="_sealRailRel" type="Integer"/>
        <Parameter name="_sealRoadRec" type="Integer"/>
        <Parameter name="_sealRoadRel" type="Integer"/>
        <Parameter name="_sealPack" type="Integer"/>
        <Parameter name="_sealUnpack" type="Integer"/>
        <Parameter name="_sealWagonLoad" type="Integer"/>
        <Parameter name="_sealWagonDischarge" type="Integer"/>
        <Parameter name="_sealTruckLoad" type="Integer"/>
        <Parameter name="_sealTruckDischarge" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSealType" id="6c9d269d-899d-4318-a04d-250e6f00893d">
        <source>addSealType(_code: String; _description: String; _cargoTypes: Any; _allowMultipleSealNums: Boolean; _showSealOnCheck: Boolean; _useForTrucks : Boolean) : CM_SealType;
// cnwdw1	 
// Add a seal type
vars
	proxy, 
	sealType   : CM_SealType;
	cargoTypes: CM_CargoTypeSet;
begin
	
	create cargoTypes transient;
	if _cargoTypes.isKindOf(String) then
		cargoTypes.add(self.getCargoType(_cargoTypes.String));
	else	
		if _cargoTypes &lt;&gt; null then
			_cargoTypes.CM_CargoTypeSet.copy(cargoTypes);
		endif;
	endif;
	
	create proxy transient;
	proxy.setProxy(_code, _description, cargoTypes, _allowMultipleSealNums, false,  _showSealOnCheck, false, _useForTrucks);
	
	app.myTrxCA.trxCreateSealType(proxy, sealType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return sealType;
epilog
	delete proxy;
	delete cargoTypes;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_cargoTypes" type="Any"/>
        <Parameter name="_allowMultipleSealNums" type="Boolean"/>
        <Parameter name="_showSealOnCheck" type="Boolean"/>
        <Parameter name="_useForTrucks" type="Boolean"/>
        <ReturnType type="CM_SealType"/>
    </JadeMethod>
    <JadeMethod name="addSecurityRole" id="04820165-d731-45ab-a96c-592c2e592566">
        <source>addSecurityRole(_systemRole : Boolean; _name : String) : CM_SecurityRole;

/*

Purpose:		Add / Create a security role

Date			Who		Reason
10/02/2014		cnwmh5	Initial creation
22/03/2018		jlgdap1	TFS 37445 PEL1 Voyage Status Security
02/11/2022		navds20 Task ChangeRequest 54253: EUP - VAS Work Orders
*/

vars

	securityRole					: CM_SecurityRole;
	parentRole						: CM_SecurityRole;
	pxyRole							: CM_SecurityRole;
	permissionAgent					: CM_PermissionAgent;
	permissions						: BooleanArray;
begin

	self.deleteSecurityRole(_name);

	create permissions transient;
	create permissionAgent transient;
	
	if _systemRole then
		create pxyRole as CM_SecurityRoleSystem transient;
		parentRole := CM_SecurityRoleSystemRoot.firstInstance;
		permissionAgent.populatePermissionDict(true, true, 0);
		permissionAgent.setAllPermissionValues(true);
		permissionAgent.getPermissionValues(permissions, true, true);
	else
		create pxyRole as CM_SecurityRoleTerminal transient;
		parentRole := CM_SecurityRoleTerminalRoot.firstInstance;
		permissionAgent.getPermissionValues(permissions, false, true);
	endif;
	
	if self.opts.includesKey("ParentRole") then					// 03/02/2016 cnwmh5
		parentRole := self.opts.obj("ParentRole").CM_SecurityRole;
	endif;
	
	pxyRole.setProxy(_name,
		parentRole,
		permissions,
		true,
		app.myRoot,
		null,
		null,
		null,
		null,
		null,
		null,
		null,
		null,	// TFS 39618		
		null,					// TFS 37445
		null,
		null,	//09 Mar 2020	NDL	TFS 48784
		null	//02/11/2022 navds20 TFS 54253
		);
	
	app.myTrxCA.trxCreateSecurityRole(pxyRole, permissionAgent, securityRole, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	return securityRole;

epilog

	delete pxyRole;
	delete permissions;
	delete permissionAgent;
	
end;</source>
        <Parameter name="_systemRole" type="Boolean"/>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_SecurityRole"/>
    </JadeMethod>
