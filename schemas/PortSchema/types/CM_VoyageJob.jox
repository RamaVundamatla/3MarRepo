        <source>hasUnderDeckRequests() : Boolean;

vars
	req : CM_Request;
	sr : CM_SlotRequest;
begin

	foreach req in allRequests do
		if not req.isKindOf(CM_SlotRequest) then
			return false;        
		endif;
		sr := req.CM_SlotRequest;
		if sr.ordinalDeck = DeckUnderDeck then
			return true;
		endif;
    endforeach;

    return false;
end;</source>
