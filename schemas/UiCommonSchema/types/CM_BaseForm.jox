    <JadeMethod name="doSendToScreen_DisplayColl" id="85b98cc5-95b9-422a-a2cd-dc34a191a75f">
        <source>doSendToScreen_DisplayColl(_form :CM_BaseForm input; _coll :Collection; _mode :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _form.name = CM_ContainerEnqForm.name then
		_form.CM_ContainerEnqForm.setCurrentCargoBOLType(_coll.first.CM_TrackedItem.myCargoType); // ### TFS 52923 22Mar2022 NAVPW1
		_form.show(); // CCMS Tranship already created, show (this is ignored if already open) then populate it.
		_form.CM_ContainerEnqForm.setFilterCargoTypeId (true);//added by cnwyl1 30052006 for PAR 11826
		_form.displaySelectorResults(_coll, _mode);
	elseif _form.name = CM_AuditViewForm.name then
		_form.show();
		_form.displaySelectorResults(_coll, _mode);
	else
		_form.displaySelectorResults(_coll, _mode);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_DisplayForm" id="2a293cf3-ead2-4382-a292-31714d23a821">
        <source>doSendToScreen_DisplayForm(_table :Table input; _form :Form)protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	formName	:String;
	row			:Integer;
begin
	if _form = self then
		return;
	endif;
	
	formName := _form.caption;

	if formName.length &gt; 20 then
		formName := formName[1:17] &amp; '...';
	endif;
	
	row := _table.addItem('0' &amp; Tab &amp; formName);
	
	_table.accessRow(row).itemObject := _form;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_form" type="Form"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_DisplayForms" id="717653a1-00fe-4a71-afb4-f78326efa273">
        <source>doSendToScreen_DisplayForms(_table :CMUI_ListTable input; _forms :ObjectSet)protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj			:Object;
	formName	:String;
	row			:Integer;
begin
	_table.allSelectedObjects.clear();
	
	_table.rows 	:= 0;
	_table.columns	:= 2;

	
	foreach obj in _forms do
		self.doSendToScreen_DisplayForm (_table, obj.Form);
	endforeach;
	
	if _forms.size = 1 then
		_table.setCellText(1, 1, '1');//i.e check a single screen if there is only one
		obj := _table.accessRow(1).itemObject;
		_table.accessedRow.selected := true;
		if not _table.allSelectedObjects.includes(obj) then
			_table.allSelectedObjects.add(obj);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_forms" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_GetFirstTerm" id="c99ef95c-18b1-4889-8c4e-9baee528b652">
        <source>doSendToScreen_GetFirstTerm(_collAll, _collSelected :Collection):CM_Terminal protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter 			:Iterator;
	firstObj		:Object;
	invalidObject	:Boolean;
	firstTerminal	:CM_Terminal;
begin
	if _collSelected = null or _collSelected.isEmpty then
		iter := _collAll.createIterator;
	else
		iter := _collSelected.createIterator;
	endif;

	on Exception do app.handleDeletedObject(exception, firstObj, invalidObject);
	
	while iter.next(firstObj) do
		invalidObject := false;
		
		if CM_TrackedItem.hasInstance(firstObj) then
			firstTerminal := firstObj.CM_TrackedItem.myTerminal;
		elseif CM_BOL.hasInstance(firstObj) then
			firstTerminal := firstObj.CM_BOL.myTerminal;
		elseif firstObj.isKindOf(CM_Transaction) then		// Feb 2012 CCMS 1262
			firstTerminal := firstObj.CM_Transaction.getMyTerminal();
		endif;
		
		if not invalidObject then		// make sure we check at least one valid object
			break;
		endif;
	endwhile;
	
	if firstTerminal = null then
		firstTerminal := app.getMyTerminalDO_NOT_USE();
	endif;
	
	return firstTerminal;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_collAll" type="Collection"/>
        <Parameter name="_collSelected" type="Collection"/>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_GetForms" id="1909d42c-c83c-4d38-b28c-5500c0644315">
        <source>doSendToScreen_GetForms(_forms, _defaultForms :ObjectSet input; _firstTerminal :CM_Terminal) protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx, numForms		:Integer;
	frm					:Form;
	createCargoEnqFrm	:Boolean;
	form				:Form;
begin
	// CCMS Tranship open cargo enquiry if terminal selected
	createCargoEnqFrm	:= _firstTerminal &lt;&gt; null;
	
	numForms := app.formsCount;

	foreach idx in 1 to numForms do
		frm := app.forms(idx);
		if CM_BaseForm.hasInstance(frm) and frm.CM_BaseForm.isSelectorCapable then
			if _firstTerminal &lt;&gt; null and 
				frm.CM_BaseForm.myTerminal &lt;&gt; null and 
				_firstTerminal &lt;&gt; frm.CM_BaseForm.myTerminal then
				continue;
			endif;
			
			_forms.add(frm);	
			
			if frm.name = CM_ContainerEnqForm.name and
			   frm.CM_TableViewForm.numItemsShown = 0 then		// If form has items already displayed then still allow a new one
				// CCMS Tranship already open, don't create another
				createCargoEnqFrm := false;
			endif;
		endif;
	endforeach;

	// CCMS Tranship open cargo enquiry
	if createCargoEnqFrm then
		form := app.loadForm(CM_ContainerEnqForm, CMUI_Assistant, false, false, false, _firstTerminal, null);	
		if form &lt;&gt; null then
			form.CM_ContainerEnqForm.setMyTerminal(_firstTerminal);	
			
			_forms.add(form);
			_defaultForms.add(form);	
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_forms" type="ObjectSet" usage="input"/>
        <Parameter name="_defaultForms" type="ObjectSet" usage="input"/>
        <Parameter name="_firstTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_Send" id="5f543803-1205-4a77-bf34-c0aa4d6133ff">
        <updating/>
        <source>doSendToScreen_Send(_table :CMUI_ListTable; _coll :Collection; _mode :Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// 				Moving send to screen code from CMUI_Selector to CM_BaseForm
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	formArray		: ObjectArray;
	obj				: Object;
begin
	// PAR #16736 - check for any forms deleted since the table was built by rebuilding the 
	foreach obj in _table.allSelectedObjects do
		if not app.isValidObject(obj) then			// OK to use isValidObject for transients
			self.showScreensToSendTo();
			return;
		endif;
	endforeach;
	
	formArray := _table.allSelectedObjects;
	
	if formArray.isEmpty then
		app.msgBox('No screens to which to return results have been selected', 'Nothing selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	foreach obj in formArray do
		self.doSendToScreen_DisplayColl (obj.CM_BaseForm, _coll, _mode);
	endforeach;
	
	formArray.last.CM_BaseForm.setFocus;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CMUI_ListTable"/>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_ShowPopup" id="35ba7af6-a02c-48f7-9516-2272ddcec5e9">
        <source>doSendToScreen_ShowPopup(_collAll, _collSelected :Collection; _table :CMUI_ListTable input; _defaultForms :ObjectSet input) protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				Copied from CMUI_Selector::showScreensToSendTo
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	frmSet				: ObjectSet;
	firstTerminal		: CM_Terminal; //used to compare available screen's terminals with first obj temrinal 
begin
	app.mousePointer := Busy;

	if _collAll.isEmpty then
		app.msgBox('You do not have any results to send yet','No result to send', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// 	get terminal for first object 
	firstTerminal := self.doSendToScreen_GetFirstTerm (_collAll, _collSelected);
	
	//	If null, then fail
	if firstTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 
										'First result object was neither a tracked item, a transaction or BOL. Could not establish' &amp; CrLf &amp;
										'a comparison terminal');
		return;
	endif;
	
	// get forms to include in list forms we can send output to
	create frmSet transient;

	self.doSendToScreen_GetForms (frmSet, _defaultForms, firstTerminal);
	
	if frmSet.isEmpty then
		app.msgBox(app.getErrorString(CMUI_SelectorNoScreens), app.getErrorString(CMUI_OperationNotPossible), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// display forms in table
	self.doSendToScreen_DisplayForms (_table, frmSet);
	
epilog
	delete frmSet;	
	app.mousePointer := Idle;
end;</source>
        <access>protected</access>
        <Parameter name="_collAll" type="Collection"/>
        <Parameter name="_collSelected" type="Collection"/>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_defaultForms" type="ObjectSet" usage="input"/>
    </JadeMethod>
