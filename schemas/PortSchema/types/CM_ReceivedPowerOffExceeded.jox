    <JadeMethod name="getDisplayStringForAttribute" id="0ef6d78a-1d40-454a-8a40-519ef6c2af7a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := app.getErrorString1(Allowable_Time_Off_Power_Is, self.getAllowableTimeOffPower.asHrsMins);
			lDetail := lDetail &amp; ' ; ' &amp; app.getErrorString1(Date_Time_Required_Power_Is, self.getTimeRequiredOnPower.asStringJMT);
		
			return lDetail;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="f9ecb25d-d669-455e-a7a8-755ac4cc48a0">
        <source>getEnquiryRow(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2010	cnwmd1	Initial creation

*/

vars
	detail : String;
begin
	detail := inheritMethod();
	
	detail := detail &amp; app.getErrorString1(Allowable_Time_Off_Power_Is, self.getAllowableTimeOffPower.asHrsMins);
	detail := detail &amp; ' ; ' &amp; app.getErrorString1(Date_Time_Required_Power_Is, self.getTimeRequiredOnPower.asStringJMT);
epilog
	return detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
