    <JadeMethod name="createProxiesForExtraCharges" id="237a75f5-e49d-4b62-9486-ea63c0a22a2e">
        <source>createProxiesForExtraCharges( allExtraChargeInvs : CM_InvoiceSet input; now : TimeStamp; drTerm : CM_DebtorTerminal; allPxyCashPays : ObjectArray input ) protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	user 			: CM_User;
	invoice 		: CM_Invoice;
	pxyCashPay 		: CM_CashPayment;
	totalCharges	: Decimal[23,6];
	cashAmount,
	invCashCharge   : Decimal[16,4];

begin

	user 	  := app.getMyUser;
	
	foreach invoice in allExtraChargeInvs do
	
		if invoice.isExtraChargeForDutyDocSystem( totalCharges, cashAmount, invCashCharge) then
	
			create pxyCashPay transient;
				
			pxyCashPay.setProxy(	invCashCharge,	//_cashValue : Decimal;
									0,				//_taxAmount : Decimal;
									now,			//_dateTime : TimeStamp;
									null,			//_proformaDesc : String;
									false,			//_manual : Boolean;
									0,				//_status : Integer;
									false,			//_voided : Boolean;	
									drTerm,			//_myDebtorTerminal : CM_DebtorTerminal;
									null,			//_myTrackedItem : CM_TrackedItem;
									invoice,		//_myInvoice : CM_Invoice;
									null,			//_vvr : CM_VehicleVisitRecord;
									user			//_myUser : CM_User;
									);
			allPxyCashPays.add( pxyCashPay );
			
		endif;
			
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="allExtraChargeInvs" type="CM_InvoiceSet" usage="input"/>
        <Parameter name="now" type="TimeStamp"/>
        <Parameter name="drTerm" type="CM_DebtorTerminal"/>
        <Parameter name="allPxyCashPays" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createProxyCashReceipts" id="fc68efa1-07dc-4fee-9560-c2b0ab0e7ca7">
        <source>createProxyCashReceipts(	_allPxyCashRecs : ObjectArray input;
							_drTerm : CM_DebtorTerminal;
							_now : TimeStamp;
							_user : CM_User
							) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	row : Integer;
	pxyCashRec : CM_CashReceipt;
	payMeth : CM_PaymentMethod;
	chequeDateStr : String;
	chequeDate : Date;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	cashValue : Decimal [16,4];
	seqNum : Integer;
	dutyDoc : CM_DutyDoc;

begin

	foreach row in 2 to self.tblPayments.rows do
	
		create pxyCashRec transient;
		payMeth := self.tblPayments.accessCell(row,ColumnPayMethod).itemObject.CM_PaymentMethod; 
		chequeDateStr := self.tblPayments.getCellText(row,ColumnPayChqDate);
		chequeDate := chequeDateStr.Date;
		chequeBank := self.tblPayments.getCellText(row,ColumnPayChqBank);
		chequeBranch := self.tblPayments.getCellText(row,ColumnPayChqBranch);
		chequeNumber := self.tblPayments.getCellText(row,ColumnPayChqNumber);
		cashValue := self.tblPayments.accessCell(row,ColumnPayAmount).text.asDecimalFromCurrencyString;
		if seqNum &gt; 0 then
			seqNum := seqNum + 1;
		else
			seqNum := _drTerm.getNextRecSeqNum;
		endif;
		
		pxyCashRec.setProxy(	cashValue,	//_cashValue : Decimal;
								_now,	//_dateTime : TimeStamp;
								_user,	//_myUser : CM_User;
								seqNum,	//_sequenceNum : Integer;
								chequeBank,	//_chequeBank : String;
								chequeBranch,	//_chequeBranch : String;
								chequeNumber,	//_chequeNumber : String;
								chequeDate,	//_chequeDate : Date;
								payMeth,	//_myPaymentMethod : CM_PaymentMethod;
								_drTerm,	//_myDebtorTerminal : CM_DebtorTerminal;
								0	//_paymentType : Integer
								);
								
		//18 Dec 2013	NDL	Par 33182
		dutyDoc := self.firstDutyDocSelected();
		if dutyDoc &lt;&gt; null then
			pxyCashRec.setDutyDocBillNumber( dutyDoc.id );
		endif;
		
		_allPxyCashRecs.add( pxyCashRec );
								
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allPxyCashRecs" type="ObjectArray" usage="input"/>
        <Parameter name="_drTerm" type="CM_DebtorTerminal"/>
        <Parameter name="_now" type="TimeStamp"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="deleteProformaAgents" id="01e07f6f-1885-4d63-bf09-648232fc2a9a">
        <source>deleteProformaAgents() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	row : Integer;
	proformaAgent : CM_CashInvoiceProformaAgent;
	
begin

	row:=1;
	while row &lt; self.tblCharges.rows do
		row := row + 1;
		if self.tblCharges.accessRow(row).itemObject.isKindOf(CM_CashInvoiceProformaAgent) then
			proformaAgent:=self.tblCharges.accessRow(row).itemObject.CM_CashInvoiceProformaAgent;
		endif;
		if proformaAgent &lt;&gt;  null then
			delete proformaAgent;
		endif;
	endwhile;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayPaymentLine" id="54cb7f51-26a3-4b7e-a8bd-a1711cea0a2f">
        <source>displayPaymentLine( _show : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	rowIndex : Integer;
	payMethStr : String;
	dateStr : String;
	bankStr : String;
	branchStr : String;
	chqNum : String;
	amountStr : String;
	today : Date;

begin

	if _show then
		self.frmMain.enabled := false;
		self.frmPayDetails.visible := true;
		self.frmPayDetails.zOrder(1);
		
		rowIndex := self.tblPayments.row;
		if rowIndex &gt; 1 and rowIndex &lt;= self.tblPayments.rows and self.tblPayments.accessRow(rowIndex).selected then	
			payMethStr := self.tblPayments.getCellText(rowIndex,ColumnPayMethod);
			dateStr := 	self.tblPayments.getCellText(rowIndex,ColumnPayChqDate);
			bankStr := self.tblPayments.getCellText(rowIndex,ColumnPayChqBank);
			branchStr := self.tblPayments.getCellText(rowIndex,ColumnPayChqBranch);
			chqNum := self.tblPayments.getCellText(rowIndex,ColumnPayChqNumber);
			amountStr := self.tblPayments.getCellText(rowIndex,ColumnPayAmount);
			
			self.cmbMOP.listIndex := self.cmbMOP.findStringExact( 1, payMethStr );
			self.doChangeMOP();
			self.txtChqDate.setDate ( dateStr.Date );
			
		else		
			self.cmbMOP.listIndex := -1;
			self.doChangeMOP();
			self.txtChqDate.setDate ( today );
			
		endif;
		
		self.txtChqBank.text := bankStr;
		self.txtChqBranch.text := branchStr;
		self.txtChqNumber.text := chqNum;
		self.txtLineAmount.text := amountStr;
			
	else
		self.frmMain.enabled := true;
		self.frmPayDetails.visible := false;
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAddCashPaymentLine" id="00e25168-582f-4f77-9b18-26be2eab17bf">
        <source>doAddCashPaymentLine() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	rowIndex : Integer;

begin

	foreach rowIndex in 1 to self.tblPayments.rows do
		self.tblPayments.accessRow(rowIndex).selected := false;
	endforeach;
	
	self.displayPaymentLine( true );
	
	rowIndex := self.tblPayments.row;
	if rowIndex &gt; 1 and rowIndex &lt;= self.tblPayments.rows then
		self.tblPayments.accessRow(rowIndex).selected := false;
		self.tblPayments.row := 1;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
