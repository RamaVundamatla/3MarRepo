<Class name="WS_Product" id="6d21bd0b-d4f7-44d0-9c96-b7bb72a0194b">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents Cargo Sub type for a specific cargo type.</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allProductAttrs" id="7bd46047-0d76-473e-b4fe-3dc577b99e6a">
        <memberTypeInverse/>
        <type name="WS_ProductAttrArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="code" id="01d8fcc8-e78a-48e4-836f-f137a285ce0d">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Sub Type code</text>
    </PrimAttribute>
    <PrimAttribute name="comboboxDescription" id="d45acd53-cc09-4aa5-83e7-e3c330d7fe2f">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <text>Concatenated code and description of the sub cargo type.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="a78e599b-35eb-4e01-8e18-31702fc8d985">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <text>Sub type description</text>
    </PrimAttribute>
    <PrimAttribute name="isReefer" id="96d45873-6090-4619-b1ea-ed5863baaba6">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="37c69830-198f-49ac-b9d2-838a963db70e">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023	navcs2	Initial creation

*/

vars

begin
	self.allProductAttrs.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="7b70b436-a2a6-4681-8b85-d65373663dfb">
        <updating/>
        <source>setProxyFromObject(_object: CM_Product) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	#cnwdz2	 23232
30 May 2023	navcs2	Defect 58048: MTN - Mobile Apps cargo damage repair details adding for cargo dimensions issue


*/

vars
	attr			: Object;
	productAttr		: CM_ProductAttr;
	wsProductAttr	: WS_ProductAttr;
	productAttrs	: ObjectSet;
begin
	inheritMethod(_object);
	self.code := _object.code;
	self.description := _object.description;
	self.comboboxDescription := self.code &amp; " " &amp; self.description; //12/05/2010 cnwdz2 23379
	
	self.isReefer := _object.isReefer;		//cnwmc5 - 12 August 2016 - TFS 1190
	
	// Start 30/05/2023	navcs2	Defect 58048
	create productAttrs transient;
	_object.getAllProductAttributes(productAttrs);
	
	foreach attr in productAttrs do
		create wsProductAttr transient;
		productAttr := attr.CM_ProductAttr;
		wsProductAttr.setProxyFromObject(productAttr);
		self.allProductAttrs.add(wsProductAttr);
	endforeach;
	// End 30/05/2023	navcs2	Defect 58048
epilog
	delete productAttrs;
end;</source>
        <Parameter name="_object" type="CM_Product"/>
    </JadeMethod>
</Class>
