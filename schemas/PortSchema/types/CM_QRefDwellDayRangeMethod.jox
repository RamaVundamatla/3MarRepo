    <JadeMethod name="create" id="7e70cd09-b915-47df-bcf5-12f1156a16e0">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwndl1	Initial creation

*/

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);	
epilog


end;</source>
