    <JadeMethod name="defaultExceptionHandler" id="cb7af7a7-d182-40ef-92d0-46569336ff51">
        <updating/>
        <source>defaultExceptionHandler(ex : Exception) : Integer updating;

/*****************************************************
	Written by	:	cnwpra1		10 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

constants
	LockExceptionCode			= 1027;
	NotifException				= 1227;
	ArchiveLockException		= 3079;
	OLE_CLOSE_FAILED			= 14081;
	OLE_CREATE_FAILED			= 14088;
	OLE_OBJECT_VERB_UNKNOWN		= 14089;

vars
	fileName			: String;
	excelDA				: ExcelApplicationDA;
	int					: Integer;

begin
	if process.isInTransactionState then
		abortTransaction;
	endif;
	
	if ex.errorCode = 5025 or ex.errorCode = 5030 then			// can't purge the JccExcel directory, leave it there, doesn't do any harm
		logExcelException(ex);
		return Ex_Resume_Next;
	endif;
	
	if ex.errorCode = 14108 then				// User Interface exception
		if ex.extendedErrorText.pos('0x80010001', 1) &lt;&gt; 0 then	// the Window error =  0x80010001 - Call was rejected by callee.
			app.msgBox('It appears the active cell in Excel has not yet been finished.' &amp; CrLf &amp; CrLf &amp;
							'Go to the workbook and use Enter or Arrow out of the current cell and try again', 'Excel not able to continue', MsgBox_OK_Only);
			return Ex_Abort_Action;
		endif;
	endif;
	
	// PAR 8857 detect the inability to create the automation object
	if ex.errorCode = 14213 then				// Failed to create automation object
		int := ex.extendedErrorText.pos('0x800040', 1);
		if  int &lt;&gt; 0 then	// the Window error =  0x80004014 - Remote activation was necessary
			app.msgBox('Unable to start Excel, please check the Excel installation being used for the local machine, error ' &amp;
							ex.extendedErrorText[int : 10] &amp; CrLf &amp; CrLf &amp; 
							'Please contact your system administrator', 'Excel not able to start', MsgBox_OK_Only);
			return Ex_Abort_Action;
		else
			int := ex.extendedErrorText.pos('0x80040154', 1);
			if  int &lt;&gt; 0 then	// the Window error =  0x80004014 - Remote activation was necessary
				app.msgBox('Unable to start Excel, please check the Excel installation being used for the local machine, error ' &amp;
								'0x80040154' &amp; CrLf &amp; CrLf &amp; 
								'Please contact your system administrator', 'Excel not able to start', MsgBox_OK_Only);
				return Ex_Abort_Action;
			endif;
		endif;
	endif;
	
	//ex.inspectModal;
	app.msgBox('An unexpected exception ' &amp; ex.errorCode.String &amp; ' has occurred.' &amp; CrLf &amp; CrLf &amp;
					'Refer to the latest ExcelSchema log file in the server log directory for details' &amp; CrLf &amp; CrLf &amp;
					'Please advise your system administrator', 'System Error', MsgBox_OK_Only);
	
	logExcelException(ex);
	
	excelDA := ExcelApplicationDA.firstProcessTransientInstance;
	if excelDA &lt;&gt; null then
		delete excelDA;
	endif;
	
	return Ex_Abort_Action;

epilog

end;</source>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
