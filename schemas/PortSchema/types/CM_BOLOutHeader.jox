<Class name="CM_BOLOutHeader" id="513c078e-a852-44dc-a6ea-fc2117fc5efd">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
Intermediate class to store the IDs of trackedItems
that have been released on a CM_BOLOut which is not
yet known to the system.</text>
    <DbClassMap file="bol"/>
    <CompAttribute name="allTrackedItemIDs" id="22cf7caa-dddd-40da-acd9-4342fab4213f">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="bolNumber" id="4cf744b8-194a-42c9-9421-4c5bd69e2795">
        <length>36</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="bolType" id="dbadac1e-06f3-4d7c-8363-93f19a33b6a7">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="inputDateTime" id="ba630e76-a896-494e-b240-5d259c88e1b8">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="8167357a-bfee-4909-b70e-8b16530ad8cf">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allBOLOutHeadersUnmatched"/>
    </ExplicitInverseRef>
    <PrimAttribute name="operatorCode" id="e1f45d31-6948-4a3a-b7b8-44fcd1ff5b60">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="userCode" id="3b95e4ca-3130-4894-ad13-ae943629e8bd">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="attemptMatch" id="5af0310f-67a8-4030-a842-02dac9ba9d6b">
        <source>attemptMatch(_passport : CM_Passport input) : Boolean;
//--------------------------------------------------------------
//Created: 24 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolOut	 	: CM_BOLOut;
	rtnValue	: Boolean;

begin

	bolOut := self.myTerminal.allBOLOutUnmatched.getAtKey(self.operatorCode, self.bolType, self.bolNumber);

	if bolOut &lt;&gt; null then
		rtnValue := bolOut.updateFromCM_BOLOutHeader(self, _passport);
	endif;
	
	return rtnValue;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eb044bed-ea86-4f39-9b94-6a9a35982d35">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 05 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	localTime: TimeStamp;
begin
	if _attrName = ETRow_DocketNumber then
		return self.bolNumber;
	elseif _attrName = ETRow_Supplier then
		return self.operatorCode;		
	elseif _attrName = ETRow_NoLogs then
		return self.allTrackedItemIDs.size.String;		
	elseif _attrName = ETRow_DateTime then
		localTime := self.systemToLocalTime(self.inputDateTime);
		return localTime.Date.shortFormatJMT() &amp; ' ' &amp; localTime.Time.shortFormatJMT();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_IsReleaseDocket then
		return 'Release';			
	elseif _attrName = ETRow_MatchFound then
		return null;					
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInputDateTimeLocalTZ" id="1d938284-8f2c-4d6b-b4ba-0dbb14ad206c">
        <source>getInputDateTimeLocalTZ():TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars

begin
	return self.systemToLocalTime(self.inputDateTime);
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="0f5bd16b-19dd-4cec-9978-20df4747da08">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2016	cnwmp6	Initial creation

*/

vars

begin
	return self.myTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getThumbnailData" id="f9c3a8f5-a3f8-4420-9ec3-402028cea7d9">
        <updating/>
        <source>getThumbnailData(_thumbnailArray : HugeStringArray input) updating;
//--------------------------------------------------------------
//Created: 04 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str,
	strTerm : String;
begin
	_thumbnailArray.add('Docket: ' &amp; Tab &amp; self.bolNumber.String);

	strTerm := app.getTerminologyAlternate(app.myRoot.allBOLTypes[BOLType_Log], self.myTerminal, 
													CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');

	_thumbnailArray.add(strTerm &amp; ': ' &amp; Tab &amp; self.operatorCode);
	_thumbnailArray.add('Entered: ' &amp; Tab &amp; self.systemToLocalTime(self.inputDateTime).String);	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	
	if self.bolType = BOLType_Log then
		_thumbnailArray.add('Scaler: ' &amp; Tab &amp; self.userCode);
	else	
		_thumbnailArray.add('User: ' &amp; Tab &amp; self.userCode);
	endif;
	
	if self.bolType = BOLType_Log then
		_thumbnailArray.add(Tab &amp; 'Log IDs: ');	
	else	
		_thumbnailArray.add(Tab &amp; 'TrackedItem IDs: ');
	endif;
					
	foreach str in self.allTrackedItemIDs do
		_thumbnailArray.add(Tab &amp; str);
	endforeach;				

end;</source>
        <Parameter name="_thumbnailArray" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="488645e5-e397-4a21-8109-a901cbdaeff0">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 05 November 2002 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	proxyHeader : CM_BOLOutHeader;
	completedOK		: Boolean;
begin

	proxyHeader := inheritMethod();
	proxyHeader.myTerminal := self.myTerminal;
	self.allTrackedItemIDs.copy(proxyHeader.allTrackedItemIDs);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyHeader;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyHeader;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8b10c59f-f203-4fcd-ba1e-ef923ae80ff0">
        <updating/>
        <source>setForCreate(_pxyBOLOutHdr : CM_BOLOutHeader)updating;
//--------------------------------------------------------------
//Created: 24 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setForUpdate(_pxyBOLOutHdr);
end;</source>
        <Parameter name="_pxyBOLOutHdr" type="CM_BOLOutHeader"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d9e2c943-fde1-4738-8ab0-38ec36883b8e">
        <updating/>
        <source>setForUpdate(_pxyBOLOutHdr : CM_BOLOutHeader)updating;
//--------------------------------------------------------------
//Created: 24 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.bolType		:= _pxyBOLOutHdr.bolType;
	self.bolNumber 		:= _pxyBOLOutHdr.bolNumber;
	self.inputDateTime	:= _pxyBOLOutHdr.inputDateTime;
	self.operatorCode 	:= _pxyBOLOutHdr.operatorCode;
	self.userCode 		:= _pxyBOLOutHdr.userCode;
	self.myTerminal		:= _pxyBOLOutHdr.myTerminal;

	self.allTrackedItemIDs.clear();
	_pxyBOLOutHdr.allTrackedItemIDs.copy(self.allTrackedItemIDs);
end;</source>
        <Parameter name="_pxyBOLOutHdr" type="CM_BOLOutHeader"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c9ae935a-a1c9-441b-a080-61f31e2139a2">
        <updating/>
        <source>setProxy(	_bolType : Integer;
			_bolNumber,
			_operCode,
			_userCode : String;
			_inputDT : TimeStamp;
			_terminal : CM_Terminal)updating;
//--------------------------------------------------------------
//Created: 24 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.bolType		:= _bolType;
	self.bolNumber 		:= _bolNumber;
	self.inputDateTime  := _inputDT;
	self.operatorCode 	:= _operCode;
	self.userCode 		:= _userCode;
	self.myTerminal		:= _terminal;
end;</source>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_operCode" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_inputDT" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
