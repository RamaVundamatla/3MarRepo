    <JadeMethod name="doExportCSV" id="e07a047e-7d68-4570-aae7-d63acff59a99">
        <updating/>
        <source>doExportCSV() updating;
/* ---------------------------------------------------------------------------
Created:     01 October 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.tblData.rows &lt;= self.tblData.fixedRows then
		app.raiseCMException(ERR_NoDataToExtract, app.getErrorString(Table_data), self.tblData);
		return;
	endif;
	
	self.tblData.outputAsCSV(null);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doGetJobs" id="c023e94d-373c-4b79-812f-867069b32a6f">
        <source>doGetJobs(_theVoyage : CM_Voyage;_theJobs : CM_JobArray input; _crane: CM_Crane; _jobsType : Integer);
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	craneID 			: String;
	aCrane 				: CM_Crane;
begin
	
	if _theVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	aCrane := _crane;
	if aCrane &lt;&gt; null then
		craneID:=aCrane.id.trimBlanks;
	endif;
	_theVoyage.getOOWJobs(_jobsType,craneID,false,_theJobs);
	
epilog
	
end;</source>
        <Parameter name="_theVoyage" type="CM_Voyage"/>
        <Parameter name="_theJobs" type="CM_JobArray" usage="input"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_jobsType" type="Integer"/>
    </JadeMethod>
