    <JadeMethod name="applyAdvancedDeckingRules" id="09925918-d5f7-4ee4-be8c-58d75d9608c1">
        <source>applyAdvancedDeckingRules(_rule: CM_YADeckingRule; _isIn: Boolean; _locations: CM_LCSet; _offset: Integer);
//31 December 2008	cnwdw1	
vars
	location: CM_YardController;
	cells: CM_YALocationCellArray;
	newCellOrder: DynaDictionary;
	cell: CM_YALocationCell;
begin
	
	if _isIn then
		cells := self.myDeckingOptions.allYALocationCellsIn;
	else
		cells := self.myDeckingOptions.allYALocationCellsOut;
	endif;
	
	// Sort the locations by laneNumber
	create newCellOrder transient;
	newCellOrder.setMembership(CM_YALocationCell);
	newCellOrder.addMemberKey("row", _rule.rowRule = DeckingRule_Decreasing, true);
	newCellOrder.endKeys(false);
	
	foreach cell in cells do
		newCellOrder.add(cell);
	endforeach;
	
	cells.clear;
	newCellOrder.copy(cells);
epilog
	newCellOrder.clear;
	delete newCellOrder;
end;</source>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_locations" type="CM_LCSet"/>
        <Parameter name="_offset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildLocationStatistics" id="e01c8e1e-2b39-44a7-9044-2074ec8b5433">
        <updating/>
        <source>buildLocationStatistics() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwjk3	Initial creation

*/

vars
	c20Free				: Integer;
	c20PlannedIn		: Integer;
	c20PlannedOut		: Integer;
	c20Projected		: Integer;
	c20QueuedIn			: Integer;
	c20QueuedOut		: Integer;
	c20Total			: Integer;
	c20Used				: Integer;
	c30Free				: Integer;
	c30PlannedIn		: Integer;
	c30PlannedOut		: Integer;
	c30Projected		: Integer;
	c30QueuedIn			: Integer;
	c30QueuedOut		: Integer;
	c30Total			: Integer;
	c30Used				: Integer;
	c40Free				: Integer;
	c40PlannedIn		: Integer;
	c40PlannedOut		: Integer;
	c40Projected		: Integer;
	c40QueuedIn			: Integer;
	c40QueuedOut		: Integer;
	c40Total			: Integer;
	c40Used				: Integer;
	c45Free				: Integer;
	c45PlannedIn		: Integer;
	c45PlannedOut		: Integer;
	c45Projected		: Integer;
	c45QueuedIn			: Integer;
	c45QueuedOut		: Integer;
	c45Total			: Integer;
	c45Used				: Integer;
	c53Free				: Integer;
	c53PlannedIn		: Integer;
	c53PlannedOut		: Integer;
	c53Projected		: Integer;
	c53QueuedIn			: Integer;
	c53QueuedOut		: Integer;
	c53Total			: Integer;
	c53Used				: Integer;
	statisticsObj		: CM_LocationStatistics;
	proxyStatsObj		: CM_LocationStatistics;
	taStatsObj			: CM_LocationStatistics;
	fm					: CM_FutureMove;
	fmq					: CM_FutureMoveQueued;
	fmp					: CM_FutureMovePlanned;
	ti					: CM_TrackedItem;
	
	tmpTI				: CM_TrackedItem;
	gcQueuedOut			: Integer;
	gcPlannedOut		: Integer;
	gcQueuedIn			: Integer;
	gcPlannedIn			: Integer;
	container			: CM_Container;
	roro				: CM_RoRoController;
	yc					: CM_YardController;
	tmpStats			: CM_LocationStatistics;
begin
	if self.myLocationStatistics = null then
		create proxyStatsObj transient;
		proxyStatsObj.setParent(self);
		create statisticsObj  persistent;
		statisticsObj.setupForCreate(proxyStatsObj);
	else
		statisticsObj	:=	self.myLocationStatistics;
	endif;
	
	taStatsObj := self.myLocationStatistics;

	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts();  //clear values so we can start a fresh
	
	foreach yc in self.allYardControllers do
		if yc.isKindOf(CM_RoRoController) then
			roro := yc.CM_RoRoController;
			roro.buildLocationStatsTranisent(tmpStats);
			
			statisticsObj.total := statisticsObj.total + tmpStats.total;
			statisticsObj.used := statisticsObj.used + tmpStats.used;
			statisticsObj.queuedIn := statisticsObj.queuedIn + tmpStats.queuedIn;
			statisticsObj.queuedOut := statisticsObj.queuedOut + tmpStats.queuedOut;
			statisticsObj.free := statisticsObj.free + tmpStats.free;
			statisticsObj.plannedIn := statisticsObj.plannedIn + tmpStats.plannedIn;
			statisticsObj.plannedOut := statisticsObj.plannedOut + tmpStats.plannedOut;
			
			delete tmpStats;
		endif;
	endforeach;
	
	
	self.myLocationStatistics.setUpdateTimestamp();
epilog
	delete tmpStats;
	delete proxyStatsObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLocationsString" id="7fdd8d85-0053-48ba-849b-404959cc55d8">
        <source>getLocationsString(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwjk3 ccms 1018

*/

vars
	minLaneNum,
	maxLaneNum	: Integer;
	yc			: CM_YardController;
	minRow,
	maxRow,
	rc			: CM_RoRoController;
	locString	: String;
begin
	foreach yc in self.allYardControllers do
		rc := yc.CM_RoRoController;
		if minLaneNum = 0 or rc.laneNumber &lt; minLaneNum then
			minLaneNum := rc.laneNumber;
			minRow := rc;
		endif;
		if rc.laneNumber &gt; maxLaneNum then
			maxLaneNum := rc.laneNumber;
			maxRow := rc;
		endif;	
	endforeach;
	if minRow &lt;&gt; null and minRow = maxRow then
		locString := minRow.getID();
	else
		if minRow &lt;&gt; null and maxRow &lt;&gt; null then
			locString := minRow.getID() &amp; "-" &amp; maxRow.getID();
		endif;
	endif;
	return locString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRoRoBlockController" id="ece5bcce-90fd-4727-a3dd-125bba59ca84">
        <source>getRoRoBlockController(): CM_RoRoController protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwjk3	Initial creation

*/

vars
	tmpController : CM_YardController;
begin
	tmpController := self.allYardControllers.first;
	if (not CM_RoRoController.hasInstance(tmpController)) then
		// should never happen
		return null;
	endif;
	return tmpController.CM_RoRoController;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_RoRoController"/>
    </JadeMethod>
    <JadeMethod name="getRoRoLaneBlockController" id="978b34e6-35f0-4a80-af37-a1945e9ca644">
        <source>getRoRoLaneBlockController() : CM_RoRoController;
/* ---------------------------------------------------------------------------
Created:     29 November 2009 by cnwjk3

Purpose:     ccms 1018
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpController	: CM_YardController;
begin
	tmpController := self.allYardControllers.first;
	if (not CM_RoRoController.hasInstance(tmpController)) then
		// should never happen
		return null;
	endif;
	return tmpController.CM_RoRoController;
	
epilog

end;</source>
        <ReturnType type="CM_RoRoController"/>
    </JadeMethod>
    <JadeMethod name="getYAMDisplay" id="16477671-2c8f-4278-a39b-a67b341acd02">
        <source>getYAMDisplay(pIsSortIn: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwjk3	ccms 1018

*/

vars

begin
	return inheritMethod(pIsSortIn) &amp; " " &amp; self.getLocationsString();
epilog

end;</source>
        <Parameter name="pIsSortIn" type="Boolean"/>
