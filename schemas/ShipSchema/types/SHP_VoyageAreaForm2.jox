    <JadeMethod name="btnSelectVoyOK_click" id="503971db-1edb-455a-ae6d-b636d1ddf423">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelectVoyOK_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	newVoyage	: CM_Voyage;
	aBay : CM_Bay;
begin

	newVoyage := self.cmbVoyage.listObject.CM_Voyage;

	self.frmSelectVoyage.visible := false;

	self.setMyCurrentVoyage(newVoyage, true, false);
	self.allSelectedBays.clear();
	self.allSelectedHolds.clear();

	if self.selectMode = self.SelectModeHold then
		self.msgHolds.getSelected(self.allSelectedHolds);
	elseif self.selectMode = self.SelectModeMulti then
		self.msgHolds.getSelected(self.allSelectedBays);
		foreach aBay in self.allSelectedBays do
			if aBay.myHold = null then
				continue;
			endif;
			if not self.allSelectedHolds.includes(aBay.myHold) then
				self.allSelectedHolds.add(aBay.myHold);
			endif;
		endforeach;
	endif;
	
	
	if (not self.voyageLoad(self.displayMode)) then
		// reshow the selector
		self.frmSelectVoyage.visible := true;
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
