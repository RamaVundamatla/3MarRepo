    <JadeMethod name="setProxyAdjacentLocations" id="a4299ce7-7461-45ef-8ed9-e422a42244b3">
        <source>setProxyAdjacentLocations(_roroLocnDefn : CM_ROROLocnDefn input);
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
03/02/2012	cnwmh5	#28904 - check that adjacent aft / fwd locations aren't the same
*/

vars
	adjSlotAft,adjSlotFwd 	: CM_ROROLocnDefn;
	location1Str		 	: String;
	location2Str			: String;
	locationIdStr			: String;
begin
	if _roroLocnDefn.isTransient() then
		if _roroLocnDefn &lt;&gt; null then
			adjSlotAft := self.cmbAdjSlotAft.listObject.CM_ROROLocnDefn;
			adjSlotFwd := self.cmbAdjSlotFwd.listObject.CM_ROROLocnDefn;
			if adjSlotAft &lt;&gt; null and adjSlotFwd &lt;&gt; null and adjSlotAft = adjSlotFwd then					// 03/02/2012 cnwmh5
				if app.activeControl() = self.cmbAdjSlotAft then
					self.cmbAdjSlotAft.setFocus();
					self.cmbAdjSlotAft.listIndex := -1;
					location1Str := "Aft";
					location2Str := "Fwd";
					locationIdStr := adjSlotAft.code;
				elseif app.activeControl() = self.cmbAdjSlotFwd then
					self.cmbAdjSlotFwd.setFocus();
					self.cmbAdjSlotFwd.listIndex := -1;
					location1Str := "Fwd";
					location2Str := "Aft";
					locationIdStr := adjSlotFwd.code;
				endif;
				app.raiseCMException3(Adjac_Aft_Locn_NotBSame_Fwd, location1Str, locationIdStr, location2Str, null, self);
				return;
			endif;
			if (adjSlotAft &lt;&gt; null and adjSlotAft.isTransient()) and (adjSlotFwd &lt;&gt; null and adjSlotFwd.isTransient()) then
				_roroLocnDefn.setProxyAdjacent(adjSlotAft, adjSlotFwd);
			else
				if (adjSlotAft &lt;&gt; null and not adjSlotAft.isTransient()) then
					adjSlotAft := adjSlotAft.pxyCreateUpdateProxy();
				endif;
				if (adjSlotFwd &lt;&gt; null and not adjSlotFwd.isTransient()) then
					adjSlotFwd := adjSlotFwd.pxyCreateUpdateProxy();
				endif;
				_roroLocnDefn.setProxyAdjacent(adjSlotAft, adjSlotFwd);
			endif;
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="_roroLocnDefn" type="CM_ROROLocnDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyDetails" id="8ec4e36b-f6ce-44ae-bf5e-b2bd97135aa2">
        <source>setProxyDetails(_pxyLocnDefn : CM_ROROLocnDefn input);
/*
Date		    Who			Reason
29 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	hazs : CM_HazardByCodeDict;
begin
	_pxyLocnDefn.setProxyCode(self.txtLocationCode.text);
	self.setProxyAdjacentLocations(_pxyLocnDefn);
	_pxyLocnDefn.setProxyIsRotatable(self.chkRotatable.value);
	_pxyLocnDefn.setProxyRemarks(self.txtRemarks.text);
	self.setProxySlotsAvailability(_pxyLocnDefn);
	create hazs transient;
	self.lstHazard.allSelectedObjects.copy(hazs);
	_pxyLocnDefn.setProxyHazards(hazs);	
epilog
	delete hazs;
end;
</source>
        <Parameter name="_pxyLocnDefn" type="CM_ROROLocnDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxySlotsAvailability" id="9c7a98c4-acd7-4bfc-9aee-706fcc12c9a9">
        <source>setProxySlotsAvailability(_pxyLocnDefn : CM_ROROLocnDefn input);
/*
Date		    Who			Reason
02 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
03/02/2012		cnwmh5		#29083 - Change so that sets the details correctly
*/

vars
	btn 			: CMUI_Button;
	label 			: CMUI_Label;
	idx				: Integer;
	verticalPosition: Real;
	slot            : CM_ROROSlotDefn;
begin
	
	foreach slot in  _pxyLocnDefn.allROROSlotDefnByOrdinal reversed do
		idx := idx + 1;
		btn := self.getControlByName('btnSlot' &amp; idx.asStringJMT()).CMUI_Button;
		if slot.isTransient() then	
			slot.setProxyIsAvailable(btn.value);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_pxyLocnDefn" type="CM_ROROLocnDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSaveCancelButtonsVisibility" id="1651252d-daad-4423-9c8b-f9a2d17f53b6">
        <source>setSaveCancelButtonsVisibility(_visible : Boolean);
/*
Date		    Who			Reason
29 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if self.myParentForm &lt;&gt; null and self.myParentForm.name = "SHP_ROROPlanningForm" then
		self.btnCancelChanges.visible := _visible;
		self.btnSaveChanges.visible := _visible;
	endif;
epilog

end;</source>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="80edaea4-a47c-4dc8-ae9a-2cbfeb2f49bb">
        <updating/>
        <source>setupForm() updating;
/*
Date		    Who			Reason
03 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	idx,noOfSlots : Integer;
	btn	: CMUI_Button;
	horizontalPosition,verticalPosition : Real;
begin
	inheritMethod();
	
	self.toolbarStyle 	:= self.ToolbarStyle_None;
	self.caption		:= self.myROROLocnDefn.code &amp; " - " &amp; self.caption; 
	self.borderStyle 	:= 3;

	self.mnuFile.visible := false;
	self.mnuHelp.visible := false;
	self.mnuOptions.visible := false;
	self.mnuWindows.visible := false;
	self.mnuTerminal.visible := false;
	self.mnuView1.visible := false;
		
	self.grpSlotAvailable.left := 5;
	self.grpSlotAvailable.top := 5;
	self.grpInfo.left := self.grpSlotAvailable.left + self.grpSlotAvailable.width + 3;
	self.grpInfo.top := self.grpSlotAvailable.top;
	self.width := self.grpInfo.left + self.grpInfo.width + 10;
	self.height := self.grpInfo.top + self.grpInfo.height + 40;
	
	
	
	self.setupSlots();
	self.doFillLocationInfoFields();
	self.doBuildComboLocn();
	self.txtLocationCode.setFocus();
	self.setSaveCancelButtonsVisibility(false);
	self.isBiggerChange := false; //turned on when it's not a trivial attributes change in the locn defn item =&gt; semi-full proxy structure creation
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupSlots" id="bce760c5-e281-4a43-b634-25990835b687">
        <source>setupSlots();
/*
Date		    Who			Reason
04 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	btn 			: CMUI_Button;
	label 			: CMUI_Label;
	idx,noOfSlots 	: Integer;
	verticalPosition: Real;
	slot            : CM_ROROSlotDefn;
	textbox			: CMUI_TextBox;
begin
	
	noOfSlots := self.myROROLocnDefn.allROROSlotDefnByOrdinal.size();
	
	btn := self.getControlByName('btnSlot1').CMUI_Button;
	verticalPosition := (self.grpSlotAvailable.height - (noOfSlots * btn.height + (noOfSlots-1) * 10))/2;	

	foreach slot in self.myROROLocnDefn.allROROSlotDefnByOrdinal reversed, discreteLock do // PAR 28879 Some Slots from Mr Portunato at MESSINA had ordinals strating at 2  // 17/01/2012 cnwmh5 #28838
		idx := idx + 1;
//	foreach idx in 1 to noOfSlots reversed do 
//		slot := self.myROROLocnDefn.allROROSlotDefnByOrdinal.getMemberByOrdinal(idx);		
		btn := self.getControlByName('btnSlot' &amp; idx.asStringJMT()).CMUI_Button;		
		btn.top := verticalPosition;
		btn.userObject := slot;		
		btn.visible := true;
		btn.value := slot.isAvailable;
		btn.click(btn);
		if self.myParentForm &lt;&gt; null and self.myParentForm.name = "SHP_ROROPlanningForm" then
			label := self.getControlByName('lblSlotCode' &amp; idx.asStringJMT()).CMUI_Label;		
			label.caption := slot.code;
			label.top := verticalPosition;
			label.visible := true;
		else
			textbox := self.getControlByName('txtSlotCode' &amp; idx.asStringJMT()).CMUI_TextBox;		
			textbox.text := slot.code;
			textbox.top := verticalPosition;
			textbox.visible := true;
		endif;
		verticalPosition := verticalPosition + btn.height + 10;
	endforeach;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="slotCodeChanged" id="fbbce941-c79f-4425-9c34-8d950bcb5e93">
        <source>slotCodeChanged(_code : String; _slotOrdinal : Integer) ;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
21/11/2011		cnwmh5	Initial creation #28838

*/

vars
	slotDefn			: CM_ROROSlotDefn;
begin

	foreach slotDefn in self.myROROLocnDefn.allROROSlotDefnByOrdinal discreteLock do
		if slotDefn.ordinal = _slotOrdinal then
			slotDefn.setCode(_code);
			break;
		endif;	
	endforeach;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_slotOrdinal" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="slotCodeTXTChanged" id="2495b49d-3a89-465c-94b8-8dfd16927697">
        <source>slotCodeTXTChanged(textbox: TextBox input) ;
/*
Purpose:			
Date				Who			Reason
FEB 2012		CNWAB1		Initial creation
*/

vars
	slotDefn			: CM_ROROSlotDefn;
	code : String; 
	slotOrdinal : Integer;
begin
	code := textbox.text.trimBlanks();
	slotOrdinal := textbox.name[textbox.name.length:1].Integer;
	
	
	foreach slotDefn in self.myROROLocnDefn.allROROSlotDefnByOrdinal discreteLock do
		if slotDefn.ordinal = slotOrdinal then
			// PAR 29088
			if not slotDefn.setCode(code) then
				app.msgBox(app.getErrorString2(DUPLICATE_ID_ERROR, app.getErrorString(Slot), "("&amp; code &amp; ")"), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
				textbox.text := slotDefn.code;
				textbox.setFocus();
				return;
			endif;
			// PAR 29088
			self.myROROLocnDefn.setLabelManuallyChanged(true);				// 29073 cnwmh5 31/01/2012
			
			break;
		endif;	
	endforeach;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3348b6a8-2c63-4084-8798-7f173975fda5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016114, locale);
	btnCancelChanges.translateCaption(Xlat_0016905, locale);
	btnSaveChanges.translateCaption(Xlat_0016906, locale);
	chkRotatable.translateCaption(Xlat_0016115, locale);
	chkSelectAll.translateCaption(Xlat_0016116, locale);
	grpInfo.translateCaption(Xlat_0016117, locale);
	grpSlotAvailable.translateCaption(Xlat_0016118, locale);
	lblAdjLocnAft.translateCaption(Xlat_0016119, locale);
	lblAdjLocnFwd.translateCaption(Xlat_0016120, locale);
	lblHazardousDtls.translateCaption(Xlat_0016121, locale);
	lblLocationCode.translateCaption(Xlat_0016122, locale);
	lblRemarks.translateCaption(Xlat_0016123, locale);
	lblSlotCode1.translateCaption(Xlat_0016124, locale);
	lblSlotCode2.translateCaption(Xlat_0016125, locale);
	lblSlotCode3.translateCaption(Xlat_0016126, locale);
	lblSlotCode4.translateCaption(Xlat_0016127, locale);
	lblSlotCode5.translateCaption(Xlat_0016128, locale);
	lblSlotCode6.translateCaption(Xlat_0016129, locale);
	lblSlotCode7.translateCaption(Xlat_0016130, locale);
	lblSlotCode8.translateCaption(Xlat_0016131, locale);
	lblTierHeight.translateCaption(Xlat_0016132, locale);
end;</source>
    </JadeMethod>
