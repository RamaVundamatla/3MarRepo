    <JadeMethod name="loadControlsForReport" id="2edd0819-0665-4c7e-a6e0-3d091ade7081">
        <updating/>
        <source>loadControlsForReport(_entDef : EntTableDef) updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity		: CM_MenuEntity;
	tc	: JadeTableCell;
begin

	menuEntity := self.myMenuEntity;
	if menuEntity = null then
		return;
	endif;
	
	self.myReportAgent.loadControlsForReport(_entDef, menuEntity);
	
	if app.activeForm = self then
		self.tblParameter.setFocus();
	endif;
	
end;</source>
