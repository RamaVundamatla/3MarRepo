    <JadeMethod name="buildComboSubType" id="e9569d0a-54e1-4271-93e4-1ce69c5b3988">
        <source>buildComboSubType(_cargoType : CM_CargoType; _combo : CMUI_ComboBox input);
/*
Purpose:			

Date		Who		Reason
09 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars
	subType : CM_Product;
	idx : Integer;
begin
	_combo.clear();
	_combo.sorted := true;
	
	if _cargoType = null then
		return;
	endif;
	
	foreach subType in _cargoType.allProducts discreteLock do
		idx := _combo.addItemObject(subType.description, subType);
	endforeach;
	
	_combo.sorted := false;
	_combo.addItemAt("",1);
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildComboTransferType" id="3efe0992-4096-4a13-bb2b-a7a4cae3d20c">
        <source>buildComboTransferType();
/*
Purpose:			

Date		Who		Reason
27FEB2023	NAVAB1	CR 56806 TASK 56807 
*/

vars

	voyTfrType : CM_VoyageJobTransferType;
	
	defaultLOLO : CM_VoyageJobTransferType;
	index : Integer;

begin
	
	self.cmbTransferType.clear();
	self.cmbTransferType.sorted := true;
	
	foreach voyTfrType in app.myRoot.allVoyageJobTransferTypes do
		if voyTfrType.id = 0 then
			continue;
		elseif voyTfrType.id = 1 then
			defaultLOLO := voyTfrType;
		endif;
		index := self.cmbTransferType.addItem( voyTfrType.description );
		self.cmbTransferType.itemObject[ index ] := voyTfrType;
	endforeach;
	
	if defaultLOLO &lt;&gt; null then
		self.cmbTransferType.listIndex := self.cmbTransferType.findObject( defaultLOLO );
	else
		self.cmbTransferType.listIndex := -1;
	endif;
	
	self.cmbTransferType.sorted := false;
	self.cmbTransferType.addItemAt("",1);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboVoyages" id="c9c78f09-6aca-446a-be8e-dbeacfb03307">
        <updating/>
        <source>buildComboVoyages() updating;
/*
Purpose:			

Date		Who		Reason
27FEB2023	NAVAB1	CR 56806 TASK 56807 
22 Nov 2023	jlika1	TFS 61494 CUX | CUX | FLP Enable Filter Functionality
*/

vars
	current : Boolean;
	currVoyage : CM_Voyage;
begin
	current := true;

	self.allVoyages.clear;
	self.myTerminal.getAllVoyagesOperational(self.allVoyages, current, app.myPassport);	
	self.cmbVoyage.listCollection(self.allVoyages, false, 0);
	
	currVoyage := app.getMyCurrentVoyage();
	if currVoyage &lt;&gt; null then
		if self.cmbVoyage.findObject(currVoyage) &gt; 0 then
			self.cmbVoyage.listObject := currVoyage;
			self.setCurrentVoyage(currVoyage);
			self.doQuery(false);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
