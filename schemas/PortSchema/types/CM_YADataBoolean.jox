    <JadeMethod name="isSameCriteria" id="dd6c3a3c-68d0-44c8-9881-0695626a05bc">
        <source>isSameCriteria(_compareData: SelfType): Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return self.value = _compareData.value;


