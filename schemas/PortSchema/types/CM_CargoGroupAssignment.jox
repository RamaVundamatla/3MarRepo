epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createCargoGroupPxy" id="ea4f3e63-aabf-4569-919e-ecc779454c5f">
        <source>createCargoGroupPxy(	_cargoGroupId : String;
						_oper : CM_Operator;
						_cargoType : CM_CargoType;
						_minWeight : Decimal;
						_maxWeight : Decimal;
						_remarks : String;
						_defaultLocation : String;
						_allPreAssigned : StringArray
						):CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	pxyTI : CM_TrackedItem;
	realTI : CM_TrackedItem;
	subT : CM_SubTerminal;
	invalidObj : Boolean;
	terminal : CM_Terminal;
	existingTI : CM_TrackedItem;

begin

	terminal := self.myTerminal;
	if terminal = null then
		app.raiseCMException( Select_Terminal, null, null );
		return null;
	endif;

	if _cargoType = null then
		app.raiseCMException( Unspecified_Cargo_Type, null, null );
		return null;
	elseif not _cargoType.isCargoGroup then
		app.raiseCMException1( Cargo_type_selec_not_defin_car, _cargoType.description, null, null );
		return null;
	endif;
	
	if _cargoGroupId = null then
		app.raiseCMException( ERR_INVALID_TI_ID, null, null );
		return null;
	endif;
	
	existingTI := terminal.allCargoGroupsByCargoTypeId.getAtKey( _cargoType.id, _cargoGroupId );
	if existingTI &lt;&gt; null then
		app.raiseCMException1( Cargo_group_already_used, _cargoGroupId, null, null );
		return null;
	endif;
	
	if _oper = null then
		app.raiseCMException( Please_select_operator, null, null );
		return null;
	endif;
	
	pxyTI := terminal.createTI(_cargoType, true);
	pxyTI.zSetPxyTerminal( terminal );
	pxyTI.setCargoType(_cargoType.id);

	pxyTI.setMyOperator( _oper );
			
	pxyTI.setImExStatus(TI_IMEX_STATUS_STORAGE);

	pxyTI.zSetPxyCompany(terminal.getDefaultCompanyBank);
		
	if app.isSubTerminalsOn(terminal) then
		subT := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem, 0, TI_IMEX_STATUS_STORAGE, null, false); 
		pxyTI.setSubTerminal(subT,null);
	endif;
	pxyTI.zSetPxyId( _cargoGroupId );
	pxyTI.CM_CargoGroup.setPxyMinMaxWeights( _minWeight, _maxWeight );
	pxyTI.setRemarks( _remarks, false );
	pxyTI.CM_CargoGroup.setDefaultLocation( _defaultLocation );
	pxyTI.CM_CargoGroup.setAllPreAssigned( _allPreAssigned );
	pxyTI.CM_CargoGroup.setMyCargoGroupAssignment( self );
	
	
	return pxyTI.CM_CargoGroup;
	
epilog

end;</source>
        <Parameter name="_cargoGroupId" type="String"/>
        <Parameter name="_oper" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_minWeight" type="Decimal"/>
        <Parameter name="_maxWeight" type="Decimal"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_defaultLocation" type="String"/>
        <Parameter name="_allPreAssigned" type="StringArray"/>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="createUpdateCargoGroupReal" id="f2f04515-e351-4eb5-b739-f66071f816cd">
        <source>createUpdateCargoGroupReal(	_pxyCargoGroup : CM_TrackedItem input):CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	realTI : CM_TrackedItem;
	subT : CM_SubTerminal;
	terminal : CM_Terminal;
	existingTI : CM_TrackedItem;
	cargoType : CM_CargoType;
	cargoGroupId : String;

begin

	terminal := _pxyCargoGroup.myTerminal;
	cargoType := _pxyCargoGroup.myCargoType;
	cargoGroupId := _pxyCargoGroup.id;
	existingTI := terminal.allCargoGroupsByCargoTypeId.getAtKey( cargoType.id, cargoGroupId );
	if existingTI &lt;&gt; null then
		app.raiseCMException1( Cargo_group_already_used, cargoGroupId, null, null );
		return null;
	endif;
	
	realTI := _pxyCargoGroup.pxyGetRealObject().CM_CargoGroup;
	
	if realTI = null then
		app.myUtilityCA.utlCreateTrackedItem( _pxyCargoGroup, realTI, app.myPassport );
		realTI.CM_CargoGroup.setMyCargoGroupAssignment( self ); 
	else
		app.myUtilityUA.utlUpdateTrackedItem( _pxyCargoGroup, null, TI_UPDMODE_NORMAL, null, null, null, app.myPassport );
	endif;
	
	return realTI.CM_CargoGroup;
	
epilog

end;</source>
        <Parameter name="_pxyCargoGroup" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="delete" id="f5730282-3aa3-490f-a4b8-231d9f06612a">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	cg : CM_TrackedItem;	//CM_CargoGroup;

begin

	if self.isTransient then
		foreach cg in self.allCargoGroupsByIdDict do
			if cg.isTransient then
				delete cg;
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllCargoGroupsByIdDict" id="016d893d-7ba6-49de-8f49-44061ef2f9dd">
        <source>getAllCargoGroupsByIdDict( _allCargoGroupsByIdDict : CM_TIByIdCargoTypeDict input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	ncg : CM_NotifiedCargoGroup;
	cg : CM_CargoGroup;

begin
	
	if not self.allCargoGroupsByIdDict.isEmpty then
		self.allCargoGroupsByIdDict.copy( _allCargoGroupsByIdDict );
	else
		if not self.allNotifiedCargoGroupByIdDict.isEmpty then
			foreach ncg in self.allNotifiedCargoGroupByIdDict discreteLock do
				cg := ncg.getMatchingCargoGroup();
				if cg &lt;&gt; null then
					_allCargoGroupsByIdDict.addNoDuplicates( cg, false );
				endif;
			endforeach;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_allCargoGroupsByIdDict" type="CM_TIByIdCargoTypeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAssignedObject" id="5ddc37e2-b229-4827-b6c3-3b11ad710b71">
        <source>getAssignedObject( _cargoId : String ) : CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	notifiedCargoGroup : CM_NotifiedCargoGroup;
	cargoGroup : CM_TrackedItem;

begin

	if self.cargoIdsInclude(_cargoId) then
		return self;
	endif;
	
	//02 Oct 2018	NDL	TFS 39186
	foreach cargoGroup in self.allCargoGroupsByIdDict do
		if cargoGroup.CM_CargoGroup.preAssignedCargoIdsInclude(_cargoId) then
			return cargoGroup;
		endif;
	endforeach;
	
	foreach notifiedCargoGroup in self.allNotifiedCargoGroupByIdDict do
		if notifiedCargoGroup.preAssignedCargoIdsInclude(_cargoId) then
			return self.myTerminal.getCargoGroupItem( notifiedCargoGroup.id );	//02 Oct 2018	NDL	TFS 39186
		//	return notifiedCargoGroup;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getAssignmentType" id="e2610a58-c1d4-46ea-9532-dd9db6444977">
        <source>getAssignmentType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

	retValue : String;

begin

	
	if self.isSelectable then
		 retValue := app.getErrorString(Selectable);
	elseif self.isPreAssigned then
		retValue := retValue &amp; app.getErrorString(Preassigned);
	endif;
	
	return retValue;
		
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="135f7475-9afb-4cbd-a195-c19a9acc11aa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

begin

	if _attrName = ETRow_AssignmentId then
		return self.id;
	
	elseif _attrName = ETRow_AssignmentType then
		return self.getAssignmentType();
	
	elseif _attrName = ETRow_Status then
		return self.getStatusString();
	
	elseif _attrName = ETRow_NumberComplete then
		return getNumberComplete().String;
	
	elseif _attrName = ETRow_NumberOutsanding then
		return getNumberOutsanding().String;
		
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="b2fdf7b7-8e25-4612-bbeb-a27beb16c18d">
