    <JadeMethod name="isGateAreaForGate" id="fcee9d29-1911-4583-a8bf-b2a1ff1f780a">
        <source>isGateAreaForGate(_gate :CM_Gate):Boolean;
// Return true if this gate area is used by _Gate
vars
	usage	:CM_GateAreaUsage;
begin
	foreach usage in self.allGates_IN do
		if usage.myGate = _gate then
			return true;
		endif;
	endforeach;
	
	foreach usage in self.allGates_OUT do
		if usage.myGate = _gate then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_gate" type="CM_Gate"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
