    <JadeMethod name="canBeUserDisabled" id="24b27770-2f27-4f64-9992-7304938a137d">
        <source>canBeUserDisabled():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin

	if className = CM_Edit.name
	or className = CM_VehicleVisitRecord.name
	or className = CMEVT_TruckEvent.name
	or className = CMEVT_VoyageEvent.name
	or className = CMEVT_TrainTransaction.name
	or className = CM_QryReport.name
	or className = CM_TranMapInventoryAllocation.name // ### TFS 51219 28MAY2021 NAVAB1
	or className = CM_InvoiceInventoryAllocation.name // ### TFS 51219 28MAY2021 NAVAB1
	
	
	then
		//whether or not these classes are being auditted is up to the clients.
		// so return yes.
		return true;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
