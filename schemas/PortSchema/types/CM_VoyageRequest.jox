    <JadeMethod name="getAttrHasLengthSet" id="a9687c44-6305-4574-9c71-81aa0e44eeee">
        <source>getAttrHasLengthSet() : Boolean;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	criteria : CM_YACriteria;
	voyAlloc : CM_VoyageAllocation;
begin
	voyAlloc := self.allAllocations.first().CM_VoyageAllocation; // 11/10/2022	navkc1	#54935
	if voyAlloc &lt;&gt; null then // 11/10/2022	navkc1	#54935
		//criteria := self.getAttrByType(YACriteriaType_IsForty);
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsForty); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;
		endif;
		
		//criteria := self.getAttrByType(YACriteriaType_IsTwenty);
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsTwenty); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;
		endif;
		
		//criteria := self.getAttrByType(YACriteriaType_IsThirty);
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsThirty); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;
		endif;
		
		//criteria := self.getAttrByType(YACriteriaType_IsFiftyThree);
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsFiftyThree); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;
		endif;
		
		//criteria := self.getAttrByType(YACriteriaType_IsFortyFive);
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsFortyFive); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;
		endif;

		//criteria := self.getAttrByType(YACriteriaType_ISOGroup); 
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_ISOGroup); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 0 then
				return true;
			endif;
		endif;
		//criteria := self.getAttrByType(YACriteriaType_ISO); 
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_ISO); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
