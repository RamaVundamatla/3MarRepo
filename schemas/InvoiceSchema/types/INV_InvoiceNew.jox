    <JadeMethod name="cmbVoyageGen_click" id="0ff21945-5877-4736-8e18-1f0eb0dc1fa6">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyageGen_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/11/2023	navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed

*/

vars
	thevoyage	: CM_Voyage;
	theTable	: CM_EntryTable;
	
begin
	
	theTable := self.tblInvProperties;
	
	theTable.setValueByControlName(combobox.name, combobox.text);

	thevoyage := combobox.listObject.CM_Voyage;
	
	if thevoyage &lt;&gt; null then
		if thevoyage.arrivedDT &lt;&gt; null then
			theTable.setValueByName(ETRow_ArrivalTSGeneral,self.systemToLocalTime(thevoyage.arrivedDT).String);
		else
			theTable.setValueByName(ETRow_ArrivalTSGeneral,"Not Set Yet");
		endif;
		if thevoyage.departedDT &lt;&gt; null then
			theTable.setValueByName(ETRow_DepartureTSGeneral,self.systemToLocalTime(thevoyage.departedDT).String);
		else
			theTable.setValueByName(ETRow_DepartureTSGeneral,"Not Set Yet");
		endif;
		theTable.setValueByName(ETRow_VoyageDescGeneral,thevoyage.getDisplayDetails(false));
	endif;
epilog

end;</source>
