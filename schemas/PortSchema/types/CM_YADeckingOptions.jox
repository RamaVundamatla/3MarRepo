    <JadeMethod name="hasChanged" id="e0f14f72-b603-48f1-bc4e-16d40fd6d79c">
        <source>hasChanged() : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	21 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	otherSelf	: SelfType;
begin
	if self.isTransient then
		otherSelf := self.pxyGetRealObject();
	else
		otherSelf := self.pxyGetProxyObject();
	endif;	

	return (self.inOptionType &lt;&gt; otherSelf.inOptionType) or
			(self.outOptionType &lt;&gt; otherSelf.outOptionType) or
			(self.showHeightsForCustom &lt;&gt; otherSelf.showHeightsForCustom) or
			(self.useReverseOfIn &lt;&gt; otherSelf.useReverseOfIn);
			
			
end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="inOptionType" id="e1175b3d-7db5-4025-b441-418333239853">
        <methodInvocation>mapping</methodInvocation>
        <source>inOptionType(set: Boolean; _value: Integer io) mapping;
//----------------------------------------------------------------
//	Created:	12 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		return;
	else
		if self.allDeckingRulesIn.size = 1 then
			//use the rule type
			_value := self.allDeckingRulesIn.first.deckingRuleType;
		else
			_value := DeckingRule_Multi;
		endif;
		
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
