    <JadeMethod name="setProxyObject" id="81394067-3695-40b2-9e7d-d300caff768c">
        <updating/>
        <source>setProxyObject(_any : Any) updating;

/*
Date		Who		Reason
 // ### TFS 53105 02JUN2022 NAVAB1	
*/


vars
	helper 	: CMIF_InvGoods;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName		:= helper.tableName;	
	self.gkey			:= helper.gkey ;
	self.consignee	:= helper.consignee;
	self.shipper		:= helper.shipper;
	self.consignee_bzu		:= helper.consignee_bzu;
	self.shipper_bzu		:= helper.shipper_bzu;
	self.commodity_gkey		:= helper.commodity_gkey;	
	self.origin	:= helper.origin;
	self.destination	:= helper.destination;
	self.hazardous	:= helper.hazardous;
	self.bl_nbr	:= helper.bl_nbr;
	
epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
