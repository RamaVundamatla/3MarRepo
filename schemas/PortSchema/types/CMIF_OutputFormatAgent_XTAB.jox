    <JadeMethod name="getDisplayBooleanFromKey_Long" id="3fd57df9-54c9-479c-a628-ff5f0c71a591">
        <source>getDisplayBooleanFromKey_Long(_value :String):String protected;
// ---------------------------------------------------------------------------
// Created:     22 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	value		:Boolean;
begin
	value 		:= self.getBooleanFromKeyValue (_value);

	if _value.length &gt; 1 then
		return _value[2:end] &amp; ' [' &amp; value.getYesNo &amp; ']';
	endif;
	
	return value.getYesNo;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayBooleanFromKey_Short" id="d20c5e09-e2a3-451a-9035-6bbb8e891232">
