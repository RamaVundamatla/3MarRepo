	elseif _type = TODO_TYPE_GROUP_NONOPS then
		return TODO_TYPE_GROUP_NONOPS_STR;
	elseif _type = TODO_TYPE_GROUP_ALL then
		return TODO_TYPE_GROUP_ALL_STR;
	endif;
epilog

end;</source>
