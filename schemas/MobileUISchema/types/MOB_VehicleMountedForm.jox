	global.beep;
	app.msgBox(app.getErrorString(Control_reset_your_sesssio),"",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
	//self.doLogOff();
	
	app.myLogonAgent.doLogoff();
	app.myMobileAgent.doLogout;
	self.gotoForm( MOB_HandHeldLogonForm , true);
	//01/03/2011 cnwdz2 25425 end
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doControlSentMessage" id="def06a26-81da-48a7-8b5e-764d84f86dbb">
        <interfaceImplements>
