    <JadeMethod name="mnuActsApplied_click" id="da49866a-e57b-4c0f-8206-939cd7d285dd">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuActsApplied_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	YFS 2649 / 2001

*/

vars

	obj : Object;
	docAction : CM_DocumentActions;
	maintForm : CMUI_DocumentActionMaint;

begin

	obj := menuItem.userObject;
	if obj &lt;&gt; null and menuItem.userObject.isKindOf( CM_DocumentActions ) then
		docAction := obj.CM_DocumentActions;
	endif;

	if docAction &lt;&gt; null then
		maintForm := app.loadForm(CMUI_DocumentActionMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DocumentActionMaint;
		if maintForm &lt;&gt; null then
			maintForm.setMyDocumentAction( docAction );
			maintForm.showModal();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
