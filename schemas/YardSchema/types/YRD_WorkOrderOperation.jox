    <JadeMethod name="mnuCompleteJob_click" id="7a199542-953b-46fc-a99b-bdae393a41ae">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCompleteJob_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Jun 2023	navhl20	ChangeRequest 58344: EUP | Delivery Dispatch Screen - VAS Operation
19 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
20 Mar 2024 navhl20 Bug 62770: EUP - 1090 exception when clicking on the Instructions button on the Complete To Do Tasks form
23 Aug 2024 navlc30 Bug 65665: EUP | Complete Job button should not be available on the Unallocated tab for the VAS work orders
11 Nov 2024 navbs1 	Bug MTN-33403: EUP - New To Do Complete form is not available for non-cargo To Do Task jobs
*/

vars
	taskFormName 		: String;
	taskFormNameLength  : Integer;
	task 				: CM_WorkOrderDtl;
	passedAction 		: Integer;
	toDoSet				: Cm_ToDoTaskSet;
	toDoTask			: CM_ToDoTask;
	tbl					: CM_DataTable;
	wle					: CM_WorkListEntry;
	tiSet				: CM_TISet;
	ti					: CM_TrackedItem;
	job					: CM_Job;
begin
	tbl := self.mnuCompleteJob.userObject.CM_DataTable;
	if tbl = null or tbl.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	job :=  tbl.allSelectedObjects.first.CM_Job; // ### TFS CR 62818 TASK 62821 21MAR2024 NAVAB1
	self.showCompleteJobform(job);				//11.11.2024 navbs1 #33403

	/*11.11.2024 navbs1 #33403 START
	if job.myWODtl &lt;&gt; null then
		task  := job.myWODtl;
	elseif job.myWorkOrderDtlToDo &lt;&gt; null then
		task  := job.myWorkOrderDtlToDo;
	endif;
	taskFormName	   := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	
	if task.isKindOf(CM_WorkOrderToDoDtl) then
	
		create toDoSet transient;
		11.11.2024 navbs1 #33403 END*/
		
		/*foreach toDoTask in task.CM_WorkOrderToDoDtl.allToDoTasks do							//19.7.2023 navhl20 #58333
			if toDoTask.canUserSetComplete(app.myPassport) then
				toDoSet.addNoDuplicates(toDoTask,false);
			endif;
		endforeach;*/
		
		/*11.11.2024 navbs1 #33403 START
		foreach wle in job.workListEntries do					//19.7.2023 navhl20 #58333
			toDoTask := wle.CM_WOToDoWLE.myToDoTask;
			if toDoTask &lt;&gt; null and toDoTask.canUserSetComplete(app.myPassport) then
				toDoSet.addNoDuplicates(toDoTask,false);
			endif;
		endforeach;
		
		if toDoSet.size &gt; 0 then
			self.myAssistant.showTasksFormTasks(toDoSet,  true, passedAction, task.CM_WorkOrderToDoDtl);
		endif;
		11.11.2024 navbs1 #33403 END*/
	/*elseif task.isKindOf(CM_WodToDo) then // ### TFS CR 62818 TASK 62821 18MAR2024 NAVAB1			//23.08.2024 navlc30 #65665
		if not job.isRetrospective then																//20.03.2024 navhl20 #62770
			create tiSet transient;																	//19.7.2023 navhl20 #58333
			foreach wle in tbl.allSelectedObjects.first.CM_Job.workListEntries do					//19.7.2023 navhl20 #58333
				ti := wle.CM_WOToDoWLE.myTrackedItem;
				if ti &lt;&gt; null then
					tiSet.addNoDuplicates(ti,false);
				endif;
			endforeach;
			
			// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
			if wle &lt;&gt; null and wle.isForToDoWOTransaction() then
				self.setToDoTaskComplete(wle);
			else 
				//self.myAssistant.showTasksForm(null, task.CM_WodToDo.allActionedTIs,  true, 2);	//19.7.2023 navhl20 #58333
				self.myAssistant.showTasksForm(null, tiSet,  true, 2);								//19.7.2023 navhl20 #58333
			endif;
		else
			self.showCompleteJobform(job);
		endif;*/
	/*11.11.2024 navbs1 #33403 START
	else																						//09.02.2023 navhl20 #62093	
		self.showCompleteJobform(job);
	endif;
	11.11.2024 navbs1 #33403 END*/
	
epilog
	delete toDoSet;
end;</source>
