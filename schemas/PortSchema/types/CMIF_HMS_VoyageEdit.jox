<Class name="CMIF_HMS_VoyageEdit" id="5ab38f16-4743-4e8f-b325-e86ffbdbd903">
    <superclass name="CMIF_HMS_StackChange"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ImplicitInverseRef name="appliesToVoyage" id="c36e8702-6d14-4423-b8e8-19740db28bf0">
        <embedded/>
        <type name="CMIF_HMS_WorkingVoyage"/>
    </ImplicitInverseRef>
    <JadeMethod name="applyChange" id="f22cc3a2-ab0d-4f0d-a75b-1b6871939e75">
        <updating/>
        <source>applyChange() updating;

vars
    workingMovement:	CMIF_HMS_WorkingMovement;
begin
	// Update references to next and previous verisons of the voyage
	self.appliesToVoyage.versionPrevious := self.versionPrevious.CMIF_HMS_WorkingVoyage;

 	// Remove old workingVoyage from view collections 
	self.appliesToVoyage.versionPrevious.ofCurrentView := null;
 	// and add new working voyage to view collections
	self.appliesToVoyage.ofCurrentView := ofViewController;

	// copy movement references (if they are not already there)
	if self.appliesToVoyage.allWorkingMovements.isEmpty then
    	foreach workingMovement in self.appliesToVoyage.versionPrevious.allWorkingMovements do
    		workingMovement.myVoyageForDisplay := self.appliesToVoyage;
    		workingMovement.myWorkingVoyage := self.appliesToVoyage;
    	endforeach;
    endif;

    // Update views
 	self.ofViewController.view_NewSelectedMovement(self.appliesToVoyage.allWorkingMovements.first, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="getMyWorkingVoyage" id="545a963b-76fd-446a-9454-82f7623e5f0f">
        <source>getMyWorkingVoyage(): CMIF_HMS_WorkingVoyage;
//--------------------------------------------------
// Created:	20 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.appliesToVoyage;

end;</source>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="undoChange" id="5f245ad1-89ae-492b-ac49-2692ca420427">
        <updating/>
        <source>undoChange() updating;

vars
  	workingMovement:	CMIF_HMS_WorkingMovement;
begin
	// Update references to next and previous verisons of the voyage
	appliesToVoyage.versionPrevious:=versionPrevious.CMIF_HMS_WorkingVoyage;

 	// Remove old current workingVoyage from view collections and back old
 	// workingVoyage to view collections

	appliesToVoyage.ofCurrentView:=null;

 	appliesToVoyage.versionPrevious.ofCurrentView:=ofViewController;

 	// copy movement references 
    foreach workingMovement in appliesToVoyage.allWorkingMovements do
    	workingMovement.myVoyageForDisplay:=appliesToVoyage.versionPrevious;
    	workingMovement.myWorkingVoyage:=appliesToVoyage.versionPrevious;
    	//workingMovement.vesselName:=workingMovement.ofWorkingVoyage.ofVessel.name;
    endforeach;

    // Update the vessel name on all movements if it has changed
    //if appliesToVoyage.ofVessel&lt;&gt;appliesToVoyage.versionPrevious.ofVessel then
    	//foreach workingMovement in appliesToVoyage.versionPrevious.allWorkingMovements do
    		//workingMovement.vesselName:=appliesToVoyage.versionPrevious.ofVessel.name;
    		//workingMovement.notYetSaved:=true;
    	//endforeach;
    //endif;


    // Update views
 	ofViewController.view_NewSelectedMovement(appliesToVoyage.versionPrevious.allWorkingMovements.first, false);
end;</source>
    </JadeMethod>
</Class>
