    <JadeMethod name="displayProduct" id="af9900d6-c519-4fb4-ab5b-b30305329ab3">
        <source>displayProduct(_theObject : Object) : String protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _theObject = null then
		return null;
	else
		return _theObject.CM_Product.code;
	endif;
end;</source>
