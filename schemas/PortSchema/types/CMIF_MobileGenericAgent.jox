    <JadeMethod name="setTruckCollections" id="7b870388-e891-4e42-b735-8d3a144b86e2">
        <source>setTruckCollections( _updateWLEsToLoad : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2016	cnwndl1	Initial creation

*/

vars
	wleArray: CM_WLEArray;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	vvrd : CM_VehicleVisitRecordDetail;
begin
	//Gate Checker
	self.allConfirmedTis.clear();
	self.allTruckTis.clear();	// also used in Truck unloader
	
	//Truck Unloader
	self.allLoadedWles.clear;
	self.allUnloadedTis.clear;
	
	//Truck Loader
	if _updateWLEsToLoad then
		self.allWlesToLoad.clear;
	endif;
	self.allLoadedTis.clear;
	
	if self.myTruck &lt;&gt; null then
	
		create wleArray transient;
		self.myTruck.getAllWLEs(wleArray);
		
		foreach wle in wleArray do
			ti := wle.myTrackedItem;
			if ti &lt;&gt; null then
				if ti.hasBeenMerged then
					continue;
				endif;
				if wle.isReceipt and wle.status &lt;&gt; WLE_COMPLETED then
					if not self.allTruckTis.includes(ti) then
						self.allTruckTis.add(ti);
					endif;
				elseif not wle.isReceipt and wle.status = WLE_COMPLETED then
					// checking the loaded ti's on the way out the gate.
					if not self.allTruckTis.includes(ti) then
						self.allTruckTis.add(ti);
					endif;
				endif;
				if ti.isOnVehicle( self.myTruck ) then
					self.allLoadedWles.add(wle);
					if not self.allLoadedTis.includes(ti) then
						self.allLoadedTis.add(ti);
					endif;
				else
					if wle.isReceipt then
						if not self.allUnloadedTis.includes(ti) then
							self.allUnloadedTis.add(ti);
						endif;
					else
						if  wle.status &lt;&gt; WLE_COMPLETED and _updateWLEsToLoad  then
							self.allWlesToLoad.add(wle);
						endif;
					endif;
				endif;
			else
				//receival by type	(or maybe booking)
				if wle.isReceipt and wle.status &lt;&gt; WLE_COMPLETED then	// 23 Mar 2010	NDL	Par 23274
					self.allLoadedWles.add(wle);
				endif;
				if  _updateWLEsToLoad  then
					//release by type (or maybe bol)
					if ( not wle.isReceipt ) and wle.status &lt;&gt; WLE_COMPLETED then		// 23 Mar 2010	NDL	Par 23274
						self.allWlesToLoad.add(wle);
					endif;
				endif;
			endif;
		endforeach;
	
		if self.myTruck.locationsController &lt;&gt; null then
			foreach ti in self.myTruck.locationsController.allTrackedItems do
				// must have been found and selected without an associated Wle.
				if not self.allLoadedTis.includes(ti) then
					self.allLoadedTis.add(ti);
				endif;
				if not self.allTruckTis.includes(ti) then
					self.allTruckTis.add(ti);
				endif;
			endforeach;
		endif;
		
		// need to catch cargo that has been split off...
		if self.myTruck.visitRecords.last &lt;&gt; null then
			foreach vvrd in self.myTruck.visitRecords.last.allVehicleVisitRecordDetails do
				if vvrd.recordType = VisitRecord_CargoRemoved then
					ti := vvrd.getExtraInfo_TrackedItem;
					if ti = null or ti.hasBeenMerged then
						continue;
					endif;
					if ti &lt;&gt; null and ti.canSplitTotalQuantity then
						if not self.allTruckTis.includes(ti) then // hasn't been loaded back on
							if not self.allUnloadedTis.includes(ti) then
								self.allUnloadedTis.add(ti);
							endif;
						endif;
					endif;
				endif;
			endforeach;
		endif;
	
	endif;
epilog
	delete wleArray;
end;</source>
        <Parameter name="_updateWLEsToLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUnPackContainerDetails" id="0ad889fb-8186-42bb-8097-9c883b4598ea">
        <updating/>
        <source>setUnPackContainerDetails(	_trackedItem : CM_TrackedItem;
