    <JadeMethod name="getDisplayStringForAttribute" id="c297a196-381d-420e-b54c-a02b5b8c7cea">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if _attrName = ETRow_IsNotAvailableForEntry then
		return self.isNotAvalableForEntry.String;
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
