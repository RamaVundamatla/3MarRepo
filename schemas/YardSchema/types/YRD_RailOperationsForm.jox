    <JadeMethod name="doMnuConfirmInClick" id="f662b698-bc7b-4cb9-be92-fcaccfd05682">
        <updating/>
        <source>doMnuConfirmInClick(menuItem : MenuItem) updating ;
// ---------------------------------------------------------------------------
// Created:     28 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
theReturn : Integer;
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_WagonArray;
	tmpStr,tmpStr2, areaStr : String;	
	control : CMIF_WagonMoveController;
	msg : String;
begin
	areaStr := app.getErrorString(Inward_Rail);
	create objArray transient;
	create control transient;
	
	wagon := self.mnuConfirmWagonIn.userObject.CM_Wagon;
	
	if wagon.myRailLine = null then
		if tmpStr2 = null then
			tmpStr2 := wagon.id;
		else
			tmpStr2 := tmpStr2 &amp; ", " &amp; wagon.id;
		endif;
	endif;
	
	objArray.add(wagon);
	if tmpStr = null then
		tmpStr := wagon.id;
	else
		tmpStr := tmpStr &amp; ", " &amp; wagon.id;
	endif;

	if tmpStr2 &lt;&gt; null then
		app.msgBox(app.getErrorString1(Canno_confi_they_have_been_ass, tmpStr2), app.getErrorString(Wagon_confirmation), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if objArray.isEmpty() then
		return;
	endif;

	if app.msgBox(app.getErrorString2(Pleas_confi_that_want_confi_wa, tmpStr, areaStr), app.getErrorString(Wagon_confirmation), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	// PAR 20531
	control.doAutoPlanOfCargo := (app.msgBox(app.getErrorString(Want_autop_cargo_into_yard), app.getErrorString(DO_AUTOPLAN_YA) &amp; '?',MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes);
	
	//25 Feb 2021	NDL	TFS 50837
	if not validateRetrospectiveTS( control ) then
		return;
	endif;
		
	while true do
		app.myTrxUA.trxUpdateWagonConfirm(objArray, true, control, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	delete objArray;
	delete control;
end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuConfirmOutClick" id="784a7498-1568-4951-9bbd-bbd2dcb2e9cc">
        <updating/>
        <source>doMnuConfirmOutClick(_menuItem: MenuItem) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwndl1	Initial creation CCMS 1094

*/

vars

	wagonArray : CM_WagonArray;
	unconfirmedWagons : CM_WagonArray; 
	wagon : CM_Wagon;
	moveController : CMIF_WagonMoveController;
	msg : String;
	
begin

	create wagonArray transient;
	create unconfirmedWagons transient;
	self.getSelectedWagons(wagonArray, null);
	
	if wagonArray.isEmpty then
		wagon := _menuItem.userObject.CM_Wagon;
		if wagon &lt;&gt; null then
			wagonArray.add( wagon );
		endif;
	endif;
	
	foreach wagon in wagonArray do
		if wagon.confirmedOutwards then
			continue;
		endif;
		unconfirmedWagons.add(wagon);
	endforeach;
	
	if unconfirmedWagons.isEmpty then
		app.msgBox(app.getErrorString(No_Unconfirmed_wagons_selected), app.getErrorString(Wagon_confirmation) &amp; " - " &amp; app.getErrorString(Outwards), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//25 Feb 2021	NDL	TFS 50837
	create moveController transient;
	if not validateRetrospectiveTS(moveController) then
		return;
	endif;
		
	self.myAssistant.YRD_Assistant.doConfirmWagonsOutward( moveController, unconfirmedWagons, _menuItem );
	
//	inheritMethod(_menuItem);

epilog

	delete unconfirmedWagons;
	delete moveController;
	
end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuConnect" id="8d326044-b67f-4295-b4ba-9ebe8704ff1f">
        <updating/>
        <source>doMnuConnect(menuItem: MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	anObject	: Object;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	anObject := menuItem.userObject;
	if anObject = null then 
		return;
	endif;
	
	if not anObject.isKindOf(CM_Container) then
		return;
	endif;
	//epr par 36103 22/4/15 refactoring
	self.myAssistant.showReeferConnectAttachForm(anObject.CM_Container,self);
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext" id="6ab854a6-8710-49ff-ab66-a624a5c84ee0">
        <updating/>
        <source>doMnuContext(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:      08 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	lX, lY : Real;
	gridPoint : CMUI_GridPoint;

begin
	if cntrl &lt;&gt; null and
			cntrl.isKindOf(CMUI_GridAreaFrame) and
			cntrl.CMUI_GridAreaFrame.myGridArea &lt;&gt; null then
		gridPoint := cntrl.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(x, y); 
	endif;
	
	if gridPoint &lt;&gt; null then
		self.myCurrentLocation := gridPoint.myLocationsController;
	endif;

	lX := x;
	lY := y;
	conwin.windowToScreen(lX, lY);
	self.screenToWindow(lX, lY);
	self.setGridAreaContextMenu(gridPoint, lX.Integer, lY.Integer);
	
	return false;
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
