    <JadeMethod name="getDisplayStringForAttribute" id="2c60d73c-d9c0-4967-9cbd-80704bb0306f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     02 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
// 28 July 2022 navvt20 Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
vars
	tmpBOLOut		: CM_BOLOut;
	str,
	tmpProcessOpt,
	tmpTransMode	: String;
	order			: CM_StockOrderLine;
	
begin
	if _attrName = ETRow_CargoType and self.type = StockOrderHeaderType_Domestic then
		order := self.allStockOrderLines.first;
		if order &lt;&gt; null then
			if CM_StockOrderProductLine.hasInstance(order) then
				return order.CM_StockOrderProductLine.myProduct.myCargoType.description;
			endif;
		endif;
		
	elseif _attrName = ETRow_DeadlineDate then
		if self.fulfilledStatus &lt;&gt; OrderStatus_Fulfilled then
			return 'N/A';
		else
			return self.systemToLocalTime(self.deadlineDT).date.shortFormatJMT();
		endif;
		
	elseif _attrName = ETRow_DeadlineTime then
		if self.fulfilledStatus &lt;&gt; OrderStatus_Fulfilled then
			return 'N/A';
		else
			return self.systemToLocalTime(self.deadlineDT).time.String;
		endif;
	elseif _attrName = ETRow_Dockets then
		foreach tmpBOLOut in self.allBOLOuts do
			str := str &amp; tmpBOLOut.number &amp; ', ';
		endforeach;
		
		if str = null then
			str := 'None';
		endif;
		
		return str;
	elseif _attrName = ETRow_EntryDate then
		return self.systemToLocalTime(self.createdTime).date.shortFormatJMT();
	elseif _attrName = ETRow_FulfilledStatus then
		return app.orderStatusEnumToString(self.fulfilledStatus);

	
	elseif _attrName = ETRow_MyOperator then
		//if self.myOperator &lt;&gt; null then			   //28.07.2022 navvt20 TFS 54199
		//	return self.myOperator.code;			   //28.07.2022 navvt20 TFS 54199
		//else										   //28.07.2022 navvt20 TFS  54199
		//	return null;							   //28.07.2022 navvt20 TFS 54199
		//endif;                                       //28.07.2022 navvt20 TFS 54199
		
		// START 28.07.2022 navvt20 TFS 54199
		if app.myRoot.getConfig(ComboByNameOperator).Boolean and self.myOperator &lt;&gt; null then    
            return self.myOperator.description;                                                    
        endif;                                                                                    
        return self.myOperator.code;
		//END 28.07.2022 navvt20 TFS 54199
	elseif _attrName = ETRow_PercentFulfilled then
		return self.percentFulfilled.Integer.String &amp; '%';
		
	elseif _attrName = ETRow_ProcessOption then
		if self.processOption &lt;&gt; null then
			return app.processOptionEnumToString(self.processOption);
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_TransportMode then
		if self.transportMode &lt;&gt; null then
			return app.transModeToString(self.transportMode);
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_OrderNo then
		return orderNo.String;
		

	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="2347e837-c0e9-422b-8358-85df20acd052">
        <source>getExtraInfoLogVoyOps(_array: HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpDischargePort : CM_Port;
begin
	
	if self.dischargePort &lt;&gt; null then
		//tmpDischargePort := app.myRoot.allPorts[dischargePort];
		tmpDischargePort := app.myRoot.allPorts[dischargePort];
		if tmpDischargePort &lt;&gt; null then
			_array.add("Discharge Port" &amp; Tab &amp; self.dischargePort);
		endif;
	endif;
	_array.add("Voyage" &amp; Tab &amp; self.myVoyage.code &amp; ' ' &amp; self.myVoyage.description);
	
	if self.myVoyage.vesselName &lt;&gt; null then
		_array.add("Vessel" &amp; Tab &amp; self.myVoyage.vesselName);
	endif;
	
	_array.add("Order Date" &amp; Tab &amp; self.orderDate.shortFormatJMT());			
	
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
