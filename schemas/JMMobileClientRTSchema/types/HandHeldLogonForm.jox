    <JadeMethod name="setupForm" id="d403aff7-3ba3-499f-9c15-04b9be2fd76a">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
04 Jul 2008	 CNWKPD1/CNWER1	  PAR#17457 - Remove title bar for hand held apps

*/
vars

begin
	//assumed screen size for LXE MX7 hand-held device of 240x320 less
	//32 pixels for the start bar yields 240x288
	self.controlBox := not app.isRunningOnCE;	// PAR #17457
	
	self.centreWindow;
	self.btnLogon.default := true;
	self.btnExit.cancel := true;
	//self.getClientConnectionDetails();
	
	inheritMethod();
	if app.isDevelopmentSystem then
		//app.msgBox('Debug app.computerName: "' &amp; app.computerName &amp; '"', null,0);
	endif;
	if app.myHandHeldGuiAgent &lt;&gt; null then
		//app.myHandHeldGuiAgent.writeLog(app.computerName);
	elseif app.myLogonGuiAgent  &lt;&gt; null then
		//app.myLogonGuiAgent.writeLog(app.computerName);
	endif;
	
end;


</source>
