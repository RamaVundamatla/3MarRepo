    <JadeMethod name="populateCargoCommodities" id="b0de5e52-2ba7-42ae-b8c1-2ed80a91e754">
        <source>populateCargoCommodities(_cargoType : CM_CargoType);
/*
Purpose:	

Date		Who		Reason
15 October 2024	navab1	JIRA 33006
*/

vars
	combo : CMUI_ComboBox;
	subType : CM_Commodity;
	collect : Collection;
	cbolType : CM_CargoBOLType;
	cargotype : CM_CargoType;
begin
	combo := self.cmbCargoCommodity;
	
	combo.clear();
	combo.sorted := true;
	
	if _cargoType &lt;&gt; null then
		foreach subType in  _cargoType.allCommodities discreteLock do

			combo.addItemObject(subType.code &amp; " - " &amp; subType.description,subType);
		endforeach;
	else
		foreach cbolType in self.myTerminal.allCargoBOLTypes do
			if cbolType.isCargoType then
				cargotype:= cbolType.CM_CargoType;
				foreach subType in  cargotype.allCommodities discreteLock do
	
					combo.addItemObject(subType.code &amp; " - " &amp;subType.description,subType);
				endforeach;
			endif;
		endforeach;	
	
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="populateCargoOperLocns" id="f4725dbc-dfb9-405a-902f-f6da40945f84">
        <source>populateCargoOperLocns() protected;
/*

Purpose:			Populates the cargo operators in the combo box

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	iter		: Iterator;
	operTerm	: CM_OperatorTerminal;
	oper		: CM_Operator;

begin
	iter := self.myTerminal.allOperatorTerminals.createIterator;
	self.cmbCargoOper.clear();
	
	while iter.next(operTerm) do
		oper := operTerm.myOperator;
		self.cmbCargoOper.itemObject[self.cmbCargoOper.addItem(oper.code)] := oper;
	endwhile;
	
	self.cmbCargoTA.listCollection(self.myTerminal.allTerminalAreasByTypeId, false, 0);
	
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCargoSubTypes" id="56f18b67-f1cd-4d86-b46d-007a0967c903">
        <source>populateCargoSubTypes(_cargoType : CM_CargoType);
/*
Purpose:	

Date		Who		Reason
15 October 2024	navab1	JIRA 33006
*/

vars
	combo : CMUI_ComboBox;
	subType : CM_Product;
	collect : Collection;
	cbolType : CM_CargoBOLType;
	cargotype : CM_CargoType;
begin
	combo := self.cmbCargoSubType;
	
	combo.clear();
	combo.sorted := true;
	
	if _cargoType &lt;&gt; null then
		foreach subType in  _cargoType.allProducts discreteLock do

			combo.addItemObject(subType.code &amp; " - " &amp;subType.description,subType);
		endforeach;
	else
		foreach cbolType in self.myTerminal.allCargoBOLTypes do
			if cbolType.isCargoType then
				cargotype:= cbolType.CM_CargoType;
				foreach subType in  cargotype.allProducts discreteLock do
	
					combo.addItemObject(subType.code &amp; " - " &amp;subType.description,subType);
				endforeach;
			endif;
		endforeach;	
	
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="resizeTable" id="db8695c2-5427-4587-a3c9-80f1c2d93e9f">
        <updating/>
        <source>resizeTable(_table : CM_EntryTable) protected, updating;
/*

Purpose:			Resizes an Ent Table

Parameters:			_table	CM_EntryTable	The table to resize

Return Value:		NONE

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/
vars
	theTable	: CM_EntryTable;
	
begin
	theTable				:= _table;
	theTable.left			:= 0;
	theTable.top			:= 0;
	theTable.height			:= self.fldMain.clientHeight - 2;
	theTable.width			:= self.fldMain.clientWidth - 2;
	theTable.parentAspect	:= 3;
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable"/>
    </JadeMethod>
    <JadeMethod name="setMyBOL" id="7570a9e4-e2e0-4f73-9d9f-8093b5826c87">
        <updating/>
        <source>setMyBOL(_bol : CM_BOL) protected, updating;
/*

Purpose:			Sets the myBol reference on the form

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 October 2022	navpw1	Initial creation TFS: 54565 (54384)

