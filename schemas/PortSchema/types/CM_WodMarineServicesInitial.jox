    <JadeMethod name="setPxyMarineDetails" id="24e4cec5-b8ac-465c-a226-6c87d45a23b2">
        <updating/>
        <source>setPxyMarineDetails(_berth : HMS_Berth; _draftAft : Decimal; _draftFore : Decimal; _bowMarkTo : Decimal; _hasRamp : Boolean; _starborad : Boolean) updating;
/*

Purpose:	// TFS 40236		

Parameters:			

