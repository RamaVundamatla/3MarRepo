    <JadeMethod name="utlCreateVoyageWPJob" id="d2e7ab65-262c-46e2-b9e7-41bfbcb76d7e">
        <source>utlCreateVoyageWPJob(_pxyVoyageJob	: CM_VoyageWorkPointJob input;
					 _voyageJob		: CM_VoyageJob io;
					 _jobSheet		: CM_WorkPointJobSheet;
					 _job			: CM_Job;
					 _hold			: CM_GeneralCargoController;
					 _passport 		: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Nov 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
13 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
*/

vars

begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyVoyageJob, 'Voyage Work Point Job Proxy');
	
	_jobSheet.validateForJob(_job);													//18.12.2023 navhl20 #58400[61617]
	
	if not _passport.noErrors then													//18.12.2023 navhl20 #58400[61617]
		return;
	endif;
	
	_jobSheet.setForShipJob(_job,_pxyVoyageJob,_voyageJob,_hold);
	
	if _passport.noErrors then														//13.12.2023 navhl20 #58400[61617]
		_jobSheet.causeEvent(_jobSheet.myTerminal.getTerminalEvent(Event_JobSheet_WP_Update), false, null);
	endif;
epilog

end;</source>
        <Parameter name="_pxyVoyageJob" type="CM_VoyageWorkPointJob" usage="input"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob" usage="io"/>
        <Parameter name="_jobSheet" type="CM_WorkPointJobSheet"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_hold" type="CM_GeneralCargoController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateWLEfromTemplate" id="91373251-9164-499f-a3ea-68fd5d6284c4">
        <source>utlCreateWLEfromTemplate( _templateWle : CM_WorkListEntry input; _ti : CM_TrackedItem; _incompleteWle : CM_WorkListEntry output;  _passport : CM_Passport input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2010	cnwndl1	Initial creation	Par 26055

*/

vars

begin

	self.initialiseActivity();
	
	create _incompleteWle  as CM_YardWLE persistent;
	_incompleteWle.setBestPick( _templateWle.isBestPick );
	_incompleteWle.updateRequest( _templateWle.myRequest );
	_incompleteWle.setJob( _templateWle.job );
	_incompleteWle.setMyTrackedItem( _ti );

epilog

end;</source>
        <Parameter name="_templateWle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_incompleteWle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateWOBookingRef" id="2303a2df-e52e-4dda-9ced-9f8665d0a49a">
        <updating/>
        <source>utlCreateWOBookingRef(_proxyBookingRef 		: CM_BookingRef input; 
					_passport 				: CM_Passport input; 
					pGuiObject				: Object; 
					_newBookingRef 			: CM_BookingRef output;
					_bol					: CM_BOL;
					_objSet					: ObjectArray;
					_voyage					: CM_Voyage;
					_allNewBookingRefProxies: CM_ObjectArrayActual input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/
vars
	tmpEvent		: Integer;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valBookingRef(_proxyBookingRef, _passport, pGuiObject);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);

	create _newBookingRef persistent;
	
	_newBookingRef.setForCreate(_proxyBookingRef,null);
	
	if _passport.noErrors then
		_newBookingRef.setForUpdateBookingRefItems(_proxyBookingRef,_allNewBookingRefProxies);
	endif;
	
	if _passport.noErrors then
		_newBookingRef.getTIsOnSite();
		_newBookingRef.getTIsNotified();
	endif;
	if _passport.noErrors then
		tmpEvent := _newBookingRef.myTerminal.getTerminalEvent(Event_BookingRefAdd);
		_newBookingRef.causeEvent(tmpEvent, false, _newBookingRef);
		
		_newBookingRef.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_CREATE);
	endif;
end;</source>
        <Parameter name="_proxyBookingRef" type="CM_BookingRef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pGuiObject" type="Object"/>
        <Parameter name="_newBookingRef" type="CM_BookingRef" usage="output"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_objSet" type="ObjectArray"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_allNewBookingRefProxies" type="CM_ObjectArrayActual" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateWOForManifest" id="1f194b34-7ac1-4f5a-8bd0-9e9effb3a07f">
        <updating/>
        <source>utlCreateWOForManifest(_manifestNumber : String; 
						_mode : Integer; 
						_objArray : CM_ObjectArray; 
						_transportObject : CM_Object; 
						_tis : CM_TIByCargoTypeIdDict
						) updating;
/*

Purpose:			

Parameters:			
	_mode is WO_TASK_RECEIVE or WO_TASK_RELEASE
Return Value:		

Date		Who		Reason
10 Jul 2023	jlirs1	58884 (57807) Initial creation
19 Jul 2023	navdap1	TFS 58923 EUP CallOFf EDI Type / EDI Data Load
19 Jul 2023	navra1	57808 - EUP - Manifest Processing - Train - Create - Changed Requirements
24 Jul 2023	navdap1	Defect 59286 MTN - 1090 exception when loading a Prenote using the Cargo Group
25 Jul 2023	jlirs1	NFS 59324 (58026) Sea Manifest for non partial	EUP
15 Aug 2023	navdap1	TFS 59844 EUP FR | 53824 - Manifest EDI - Work order must have at least one tracked item error
15 Aug 2023 navsp1  TFS Bug 59677: EUP - Manifest Instructions for Rail not applied to cargo group and work order
16 Aug 2023	navdap1	TFS 59862 EUP FR | 53824 Manifest - DB Load creating multiple Cargo Receive tasks on Work Order
06 Sep 2023	navdap1	TFS 60378 EUP | QA 53842 - Ship Manifest - Work Order task have all cargo items 
22 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
02/02/2024	navcs2	Bug 62218: EUP - Transport Manifest (ship) - Incorrect Progress Status
06 Mar 2024 naviv1	Bug 61848 - EUP | CallOff - Create type file has only one Item, but there was a comma in the ID Masks field
*/

vars
	pxyWorkOrder : CM_WorkOrder;
	pxyWorkOrderDtl	: CM_WorkOrderDtl;
	realWorkOrder : CM_WorkOrder;
	currentBOL : CM_BOL;
	bol : CM_BOL;
	bolDetail : CM_BOLDtl;
	bookingRef : CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
	voyage : CM_Voyage;
	obj : Object;
	cargoGroup : CM_CargoGroup;
	allProxies : ObjectArray;
	requiredByDT : TimeStamp;
	startAtDT : TimeStamp;
	workOrderId : String;
	transportMode : Integer;
	cgInstructions, instructions, woInstructions  : CM_InstructionsIssued;
	reserveDetail : CM_ReserveDetail;		// TFS 58923
	release : CM_BulkRelease;				// TFS 58923
	now		: Date;		//navra1 - TFS 57808 - 19th July 2023 
	ti : CM_TrackedItem;
    isNew : Boolean;
	manifestLength : Integer;	// TFS 59862
	terminal : CM_Terminal;
begin
	self.initialiseActivity();
	
	app.myPassport.setWarningsIgnored(true);	//25 Jul 2023	jlirs1	NFS 59324 (58026) Sea Manifest for non partial	EUP
	app.setContinueCMExceptions(false);
	
	if _manifestNumber = null then
		//error
		return;
	endif;
	
	terminal := app.myPassport.myTerminal;//25.Oct.2023 navsp1 TFS 60913
	
	workOrderId := _manifestNumber;
	
	create allProxies transient;
	if _transportObject.isKindOf(CM_Voyage) then
		voyage := _transportObject.CM_Voyage;
		transportMode := TI_TRANSMODE_SHIP;
	elseif _transportObject.isKindOf(CM_Train) then
		transportMode := TI_TRANSMODE_RAIL;
		
	else
		transportMode := TI_TRANSMODE_ROAD;
	endif;

	realWorkOrder := terminal.allWorkOrders.getAtKey(workOrderId);//25.Oct.2023 navsp1 TFS 60913
	
	if realWorkOrder &lt;&gt; null then//25.Oct.2023 navsp1 TFS 60913
		beginLoad;
		pxyWorkOrder	:= realWorkOrder.pxyCreateUpdateProxy();
		endLoad;
	else
		create pxyWorkOrder as CM_WorkOrderTI transient;		
		pxyWorkOrder.setID(workOrderId);
	endif;
	allProxies.add(pxyWorkOrder);
	
	if _mode = WO_TASK_RECEIVE then
		cargoGroup := _objArray.first.CM_CargoGroup;
		if transportMode = TI_TRANSMODE_SHIP then //29.Jun.2023 navsp1 TFS 57805
			if voyage &lt;&gt; null then
				requiredByDT := voyage.departedDT;
				startAtDT := voyage.arrivedDT;
			endif;
		elseif transportMode = TI_TRANSMODE_RAIL then	//navra1 - TFS 57808 - 30th June 2023 - start
			requiredByDT := _transportObject.CM_Train.scheduledDepartureDT;
			//navra1 - TFS 57808 - 19th July 2023 - start
			if requiredByDT = null then
				//arbitrary future date - 1 week from now
				requiredByDT := (now + 7).TimeStamp;
			endif;
			//navra1 - TFS 57808 - 19th July 2023 - end
		endif;
		
	// TFS 58923 cater for release work orders as well
	elseif _mode = WO_TASK_RELEASE then
		reserveDetail := _objArray.first.CM_ReserveDetail;							//22 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
		if reserveDetail &lt;&gt; null then
			release := reserveDetail.myReserveHeader;
			if release.dateEstimatedRequired.isValid then
				requiredByDT := release.dateEstimatedRequired;
			endif;
			if release.type = BR_TYPE_ROAD then
				transportMode := TI_TRANSMODE_ROAD;
			elseif release.type = BR_TYPE_RAIL then
				transportMode := TI_TRANSMODE_RAIL;
			elseif release.type = BR_TYPE_SHIP then
				transportMode := TI_TRANSMODE_SHIP;
			elseif release.type = BR_TYPE_UNKNOWN then	//TFS 62295
				transportMode := TI_TRANSMODE_UNKNOWN;	//TFS 62295
			endif;										//TFS 62295
		endif;
	else
		app.raiseUnexpectedProgramError(self.class.name, method.qualifiedName, "Unexpected mode '" &amp; _mode.String &amp; "' for work order creation");
		return;
	// TFS 58923 end of this bit
	endif;
	if realWorkOrder = null then	//25.Oct.2023 navsp1 TFS 60913 - For create
		pxyWorkOrder.setProxy(		
				null, 							//_allEmailAddresses
				null, 							//_customerReference
				false, 							//_emailNotification
				app.actualTimeServer, 			//_enteredByDT
				app.getMyUser(), 				//_enteredByUser 
				'',								//_approvedBy
				app.getMyUser().myOrganisation, // _myOrganisation
				app.myPassport.myTerminal,			//_myTerminal
				'',  							//_remarks
				requiredByDT,					//_requiredByDT
				startAtDT, 						//_startAtDT
				WO_STATUS_PENDING 				//_taskStatus
				);
	endif;
	
	manifestLength := _manifestNumber.length;		// TFS 59862
	foreach obj in _objArray do		//17 Jul 2023	jlirs1	TFS 58884 (57807)
		if obj.isKindOf(CM_CargoGroup) then
			cargoGroup := obj.CM_CargoGroup;
			
			/*25.Oct.2023 navsp1 TFS 60913 - Commenting as we need to create new WO, if different manifest having same cargo group and operator.
			if cargoGroup.manifestNumber[1:manifestLength] &lt;&gt; _manifestNumber then		// TFS 59862
				continue;																// TFS 59862
			endif;																		// TFS 59862
			*/
			
			bookingRef := cargoGroup.myBookingRef;
			if bookingRef &lt;&gt; null then
				bookingRefItem := bookingRef.allBookingRefItems.first;
			endif;
			if transportMode = TI_TRANSMODE_SHIP or
			   transportMode = TI_TRANSMODE_RAIL then
				currentBOL := null;
				if voyage &lt;&gt; null and voyage.allBOLInByTypeStatusNumDT &lt;&gt; null then
					foreach bol in voyage.allBOLInByTypeStatusNumDT do
						if bol.number = cargoGroup.billOfLading then 
							currentBOL := bol;
							if bol.allBOLDtls.size &gt; 0 then
								bolDetail := bol.allBOLDtls.first;
							endif;
							break;
						endif;
					endforeach;
				endif;
			endif;
			
		// TFS 58923 cater for releases
		elseif obj.isKindOf(CM_ReserveDetail) then
			reserveDetail := obj.CM_ReserveDetail;
		// TFS 58923 end of this bit
		endif;
		
		if _mode = WO_TASK_RECEIVE then
			create pxyWorkOrderDtl as CM_WodReceive transient;
			pxyWorkOrderDtl.CM_WodReceive.setProxyWodReceival(bookingRef, bookingRefItem, currentBOL, bolDetail, null, _transportObject, transportMode);		// TFS 58923
		elseif _mode = WO_TASK_RELEASE then
			create pxyWorkOrderDtl as CM_WodRelease transient;
			pxyWorkOrderDtl.CM_WodRelease.setProxyWodRelease(release, transportMode, release.myVoyage, release.myAssignedTrain, null, null, reserveDetail);		// TFS 58923
			if not reserveDetail.isReserveSelection then				//06.03.2024 naviv1	#61848
				reserveDetail.allTrackedItems.copy(pxyWorkOrderDtl.CM_WodRelease.allSelectedTIs);
			endif;
		endif;
		
		allProxies.add(pxyWorkOrderDtl);
		pxyWorkOrderDtl.setStatus(WO_STATUS_USERENTRY);
		pxyWorkOrderDtl.setProxyForCreate(pxyWorkOrder, WO_TASK_HMSCANCEL);
		pxyWorkOrderDtl.setProxyReqByDT(requiredByDT);							//09.Nov.2023 navsp1 TFS 61157 - restored
		
		if _mode = WO_TASK_RECEIVE then
			if transportMode = TI_TRANSMODE_ROAD then	//29.Jun.2023 navsp1 TFS 57805
				//cargoGroup.allAssignedTrackedItems.copyNoDups(pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs);
				foreach ti in cargoGroup.allAssignedTrackedItems where ti.manifestNumber[1:manifestLength] = _manifestNumber do		// TFS 59862
					pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(ti, false);
				endforeach;
				pxyWorkOrderDtl.setTaskID(cargoGroup.id);
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Assigning tasskID " &amp; cargoGroup.id &amp; " to work order detail", LogDEBUG);
			elseif transportMode = TI_TRANSMODE_SHIP then	//29.Jun.2023 navsp1 TFS 57805
				//bol.allTrackedItems.copyNoDups(pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs);
				// TFS 59844 bol isn't set if there's no bols on the voyage
				// TFS 59844 and it could be the wrong bol anyway - currentBol is the one to use
				// TFS 59844 If we don't have a BOL though, TIs for the work order can't be derived from the cargo group
				// TFS 59844 or the voyage (because of deferred collection updates) so use the passed-in TIs
				//foreach ti in bol.allTrackedItems where ti.manifestNumber.startsWith(_manifestNumber) do					//26.Jul.2023 navsp1 TFS 59265
				if currentBOL &lt;&gt; null then
					foreach ti in currentBOL.allTrackedItems where ti.manifestNumber[1:manifestLength] = _manifestNumber do			// TFS 59862
						pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(ti, false);
					endforeach;
					pxyWorkOrderDtl.setTaskID(bol.number);
				elseif _tis &lt;&gt; null then
					foreach ti in _tis where ti.manifestNumber[1:manifestLength] = _manifestNumber and not ti.isCargoGroupItem		// TFS 59862
					and ti.myCargoGroup = cargoGroup do 																		// TFS 60378
						pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(ti, false);
					endforeach;
					//pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(cargoGroup, false);						// TFS 60378  // 02/02/2024	navcs	Bug 62218
				endif;
				// TFS 59844 end
			elseif transportMode = TI_TRANSMODE_RAIL then
				foreach ti in cargoGroup.allAssignedTrackedItems where ti.manifestNumber[1:manifestLength] = _manifestNumber do	    // TFS 59862
					pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(ti, false);
				endforeach;
				pxyWorkOrderDtl.setTaskID(_manifestNumber);																	//navra1 - TFS 58057 - 11th July 2023
			endif;
		endif;
		
	endforeach;
	
	if realWorkOrder &lt;&gt; null then	//25.Oct.2023 navsp1 TFS 60913
		app.myUtilityUA.utlUpdateWorkOrder(pxyWorkOrder, true, app.myPassport);		
	else
		app.myUtilityCA.utlCreateWorkOrder(pxyWorkOrder, realWorkOrder, app.myPassport);		
    endif;
	
    if realWorkOrder &lt;&gt; null then                                                       //15.Aug.2023 navsp1 TFS 59677 &gt;&gt;&gt;&gt;
        if _mode = WO_TASK_RECEIVE and cargoGroup.myInstructions &lt;&gt; null then
			cgInstructions := cargoGroup.myInstructions;
		elseif _mode = WO_TASK_RELEASE and reserveDetail.myInstructions &lt;&gt; null then
			cgInstructions := reserveDetail.myInstructions;
		endif;
		if cgInstructions &lt;&gt; null then
			
            create instructions transient;
			allProxies.add(instructions);
			instructions.setProxy(cgInstructions.internalInstructions, cgInstructions.externalInstruction, cgInstructions.myInstructionType, realWorkOrder);            
           
			if realWorkOrder.myInstructions = null then            
				create woInstructions persistent;
				isNew := true;
			else
				instructions := realWorkOrder.myInstructions.pxyCreateUpdateProxy().CM_InstructionsIssued;
				woInstructions := realWorkOrder.myInstructions;
			endif;
				
			if isNew then
				woInstructions.setForCreate(instructions);
			else
				woInstructions.setForUpdate(instructions);
			endif; 
			
		endif;
    endif;                                                                              //15.Aug.2023 navsp1 TFS 59677 &lt;&lt;&lt;&lt;
    
	if app.myPassport.noErrors then	
		self.myCreateAuditAgent.audCreateGeneric(realWorkOrder);
	endif;
	
epilog
	if allProxies &lt;&gt; null then	// Defect 59286
		allProxies.purge();
	endif;
	delete allProxies;
end;</source>
        <Parameter name="_manifestNumber" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_objArray" type="CM_ObjectArray"/>
        <Parameter name="_transportObject" type="CM_Object"/>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
    </JadeMethod>
    <JadeMethod name="utlCreateWOForRailManifest" id="3261447b-7b55-49aa-b3d5-a157db8fa969">
        <updating/>
        <source>utlCreateWOForRailManifest(_manifest : CM_EDIDataTransManifest; 
						_mode : Integer; 
						_objArray : CM_ObjectArray; 
						_transportObject : CM_Object; 
						_tis : CM_TIByCargoTypeIdDict) updating;
/*

Purpose:			

Parameters:			
	
Return Value:		

Date		Who		Reason
22/02/2024	navcs2	ChangeRequest 62250: EUP | FR 53824 - Transport Manifest - Multiple Manifests For a Single Wagon Need to be Possible. 
*/

vars
	pxyWorkOrder : CM_WorkOrder;
	pxyWorkOrderDtl,
	workOrderDtl,
	wodToDelete : CM_WorkOrderDtl;
	realWorkOrder : CM_WorkOrder;
	currentBOL : CM_BOL;
	bolDetail : CM_BOLDtl;
	bookingRef : CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
	train : CM_Train;
	obj : Object;
	cargoGroup : CM_CargoGroup;
	allProxies : ObjectArray;
	requiredByDT : TimeStamp;
	startAtDT : TimeStamp;
	workOrderId : String;
	transportMode : Integer;
	cgInstructions, instructions, woInstructions  : CM_InstructionsIssued;
	reserveDetail : CM_ReserveDetail;	
	release : CM_BulkRelease;				
	ti : CM_TrackedItem;
    isNew : Boolean;
	terminal : CM_Terminal;
	manifestNumber : String;
	wagon : CM_Wagon;
	now		: Date;
begin
	self.initialiseActivity();
	
	app.myPassport.setWarningsIgnored(true);	
	app.setContinueCMExceptions(false);
	
	manifestNumber := _manifest.manifestNumber;
	workOrderId := manifestNumber;
	if manifestNumber = null then
		//error
		return;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	create allProxies transient;
	if _transportObject.isKindOf(CM_Train) then
		train := _transportObject.CM_Train;
		if _manifest.myTrainConsist &lt;&gt; null then
			wagon := terminal.getLatestWagonByCode(_manifest.myTrainConsist.currentWagonCode);
		endif;
		transportMode := TI_TRANSMODE_RAIL;
		if wagon &lt;&gt; null then
			workOrderId := wagon.id;
		endif;
	else
		// Should only be rail manifests
		app.raiseUnexpectedProgramError(self.class.name, method.qualifiedName, "No Train found for work order creation");
		return;
	endif;
	
	realWorkOrder := terminal.allWorkOrders.getAtKey(workOrderId);
	
	if realWorkOrder &lt;&gt; null then
		beginLoad;
		pxyWorkOrder	:= realWorkOrder.pxyCreateUpdateProxy();
		endLoad;
	else
		create pxyWorkOrder as CM_WorkOrderTI transient;		
		pxyWorkOrder.setID(workOrderId);
	endif;
	allProxies.add(pxyWorkOrder);
	
	requiredByDT := _manifest.estimatedDateTimeOfDeparture;
	startAtDT := _manifest.estimatedDateTimeOfArrival;
	
	if requiredByDT = null then
		//arbitrary future date - 1 week from now
		requiredByDT := (now + 7).TimeStamp;
	endif;
	
	if _mode &lt;&gt; WO_TASK_RECEIVE then
		app.raiseUnexpectedProgramError(self.class.name, method.qualifiedName, "Unexpected mode '" &amp; _mode.String &amp; "' for work order creation");
		return;		
	endif;
	
	if realWorkOrder = null then	
		pxyWorkOrder.setProxy(		
				null, 							//_allEmailAddresses
				null, 							//_customerReference
				false, 							//_emailNotification
				app.actualTimeServer, 			//_enteredByDT
				app.getMyUser(), 				//_enteredByUser 
				'',								//_approvedBy
				app.getMyUser().myOrganisation, // _myOrganisation
				app.myPassport.myTerminal,		//_myTerminal
				'',  							//_remarks
				requiredByDT,					//_requiredByDT
				startAtDT, 						//_startAtDT
				WO_STATUS_PENDING 				//_taskStatus
				);
	endif;

	foreach obj in _objArray do		
		if obj.isKindOf(CM_CargoGroup) then
			cargoGroup := obj.CM_CargoGroup;
			bookingRef := cargoGroup.myBookingRef;
			if bookingRef &lt;&gt; null then
				bookingRefItem := bookingRef.allBookingRefItems.first;
			endif;
		elseif obj.isKindOf(CM_ReserveDetail) then
			reserveDetail := obj.CM_ReserveDetail;
		endif;
	endforeach;
	
	if _manifest.statusString = CMIF_JsonHeaderEUP.Status_Replace then
		foreach workOrderDtl in pxyWorkOrder.allWoDtls do
			if workOrderDtl.taskID = manifestNumber then
				wodToDelete := workOrderDtl;
			endif;
		endforeach;
		if wodToDelete &lt;&gt; null then
			pxyWorkOrder.allWoDtls.remove(wodToDelete);
		endif;
	endif;
	
	if _manifest.statusString &lt;&gt; CMIF_JsonHeaderEUP.Status_Cancel then
		if _mode = WO_TASK_RECEIVE then
			create pxyWorkOrderDtl as CM_WodReceive transient;
			pxyWorkOrderDtl.CM_WodReceive.setProxyWodReceival(bookingRef, bookingRefItem, currentBOL, bolDetail, null, _transportObject, transportMode);		

		endif;
		allProxies.add(pxyWorkOrderDtl);
		pxyWorkOrderDtl.setStatus(WO_STATUS_USERENTRY);
		pxyWorkOrderDtl.setProxyForCreate(pxyWorkOrder, WO_TASK_HMSCANCEL);
		pxyWorkOrderDtl.setProxyReqByDT(requiredByDT);							
		pxyWorkOrderDtl.setTaskID(manifestNumber);
	
		
		if _mode = WO_TASK_RECEIVE then
			if _tis &lt;&gt; null then
				foreach ti in _tis where not ti.isCargoGroupItem do 																						
					pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(ti, false);
				endforeach;
			endif;
		endif;
	endif;
	
	if realWorkOrder &lt;&gt; null then
		app.myUtilityUA.utlUpdateWorkOrderMani(pxyWorkOrder, true, app.myPassport);		
	else
		app.myUtilityCA.utlCreateWorkOrderMani(pxyWorkOrder, realWorkOrder, app.myPassport);		
    endif;
	
    if realWorkOrder &lt;&gt; null then                                                     
        if _mode = WO_TASK_RECEIVE and 
		   cargoGroup &lt;&gt; null and		
		   cargoGroup.myInstructions &lt;&gt; null then
			cgInstructions := cargoGroup.myInstructions;
		endif;
		if cgInstructions &lt;&gt; null then
            create instructions transient;
			allProxies.add(instructions);
			instructions.setProxy(cgInstructions.internalInstructions, cgInstructions.externalInstruction, cgInstructions.myInstructionType, realWorkOrder);            
           
			if realWorkOrder.myInstructions = null then            
				create woInstructions persistent;
				isNew := true;
			else
				instructions := realWorkOrder.myInstructions.pxyCreateUpdateProxy().CM_InstructionsIssued;
				woInstructions := realWorkOrder.myInstructions;
			endif;
				
			if isNew then
				woInstructions.setForCreate(instructions);
			else
				woInstructions.setForUpdate(instructions);
			endif; 
		endif;
    endif;
	    
	if app.myPassport.noErrors then	
		self.myCreateAuditAgent.audCreateGeneric(realWorkOrder);
	endif;
	
epilog
	if allProxies &lt;&gt; null then
		allProxies.purge();
	endif;
	delete allProxies;
	delete wodToDelete;					
end;</source>
        <Parameter name="_manifest" type="CM_EDIDataTransManifest"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_objArray" type="CM_ObjectArray"/>
        <Parameter name="_transportObject" type="CM_Object"/>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
    </JadeMethod>
    <JadeMethod name="utlCreateWOForRoadManifest" id="404715d2-416f-4c78-a71f-4b840d100fef">
        <updating/>
        <source>utlCreateWOForRoadManifest(_manifest : CM_EDIDataTransManifest; 
						_mode : Integer; 
						_objArray : CM_ObjectArray; 
						_transportObject : CM_Object; 
						_tis : CM_TIByCargoTypeIdDict) updating;
/*

Purpose:			

Parameters:			
	
Return Value:		

Date		Who		Reason
18/03/2024	navcs2	ChangeRequest 58059[58497]: EUP | Manifest - Change of Transport Mode
30/05/2024	navcs2	Defect 64352: MTN - Euroports Transport Manifest no longer working as expected
*/

vars
	pxyWorkOrder : CM_WorkOrder;
	pxyWorkOrderDtl : CM_WorkOrderDtl;
	realWorkOrder : CM_WorkOrder;
	currentBOL : CM_BOL;
	bolDetail : CM_BOLDtl;
	bookingRef : CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
	vehicle : CM_Vehicle;
	obj : Object;
	cargoGroup : CM_CargoGroup;
	allProxies : ObjectArray;
	requiredByDT : TimeStamp;
	startAtDT : TimeStamp;
	workOrderId : String;
	transportMode : Integer;
	cgInstructions, instructions, woInstructions  : CM_InstructionsIssued;
	reserveDetail : CM_ReserveDetail;	
	release : CM_BulkRelease;				
	ti : CM_TrackedItem;
    isNew : Boolean;
	terminal : CM_Terminal;
	manifestNumber : String;
	vehicleBookingTS : CM_VehicleBookingTimeSlot;
	vbsTerminal	: CM_VehicleBookingTerminal;
	manifestLength : Integer;
begin
	self.initialiseActivity();
	
	app.myPassport.setWarningsIgnored(true);	
	app.setContinueCMExceptions(false);
	
	manifestNumber := _manifest.manifestNumber;
	workOrderId := manifestNumber;
	if manifestNumber = null then
		//error
		return;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	create allProxies transient;
	if _manifest &lt;&gt; null then
		vbsTerminal		:= terminal.myVehicleBookingTerminal;	
		if _manifest.transportReferenceCustomer &lt;&gt; null then
			vehicleBookingTS := vbsTerminal.allVBTimeslotsByExtRef[_manifest.transportReferenceCustomer];
			workOrderId := _manifest.transportReferenceCustomer;
		elseif _manifest.transportReferenceInternal &lt;&gt; null then
			vehicleBookingTS := vbsTerminal.allVBTimeslotsById[_manifest.transportReferenceInternal];
			workOrderId := _manifest.transportReferenceInternal;
		endif;		
		if vehicleBookingTS &lt;&gt; null then
			vehicle := vehicleBookingTS.myVehicle;
			if vehicle &lt;&gt; null then
				workOrderId := vehicle.regNumber;
			endif;
		endif;
	else
		// Should only be Road manifests
		app.raiseUnexpectedProgramError(self.class.name, method.qualifiedName, "No Vehicle Booking found for work order creation");
		return;
	endif;
	
	realWorkOrder := terminal.allWorkOrders[workOrderId];
	
	if realWorkOrder &lt;&gt; null then
		pxyWorkOrder	:= app.createUpdateProxy(realWorkOrder).CM_WorkOrder;
	else
		create pxyWorkOrder as CM_WorkOrderTI transient;		
		pxyWorkOrder.setID(workOrderId);
	endif;
	allProxies.add(pxyWorkOrder);
	
	transportMode := TI_TRANSMODE_ROAD;		// 30/05/2024	navcs2	Defect 64352
	
	if _mode = WO_TASK_RECEIVE then
		cargoGroup := _objArray.first.CM_CargoGroup;
	elseif _mode = WO_TASK_RELEASE then
		reserveDetail := _objArray.first.CM_ReserveDetail;						
		if reserveDetail &lt;&gt; null then
			release := reserveDetail.myReserveHeader;
			if release.dateEstimatedRequired.isValid then
				requiredByDT := release.dateEstimatedRequired;
			endif;
		endif;
	else
		app.raiseUnexpectedProgramError(self.class.name, method.qualifiedName, "Unexpected mode '" &amp; _mode.String &amp; "' for work order creation");
		return;

	endif;
	if realWorkOrder = null then	
		pxyWorkOrder.setProxy(		
				null, 							//_allEmailAddresses
				null, 							//_customerReference
				false, 							//_emailNotification
				app.actualTimeServer, 			//_enteredByDT
				app.getMyUser(), 				//_enteredByUser 
				'',								//_approvedBy
				app.getMyUser().myOrganisation, // _myOrganisation
				app.myPassport.myTerminal,			//_myTerminal
				'',  							//_remarks
				requiredByDT,					//_requiredByDT
				startAtDT, 						//_startAtDT
				WO_STATUS_PENDING 				//_taskStatus
				);
	endif;
	
	manifestLength := manifestNumber.length;		
	foreach obj in _objArray do		
		if obj.isKindOf(CM_CargoGroup) then
			cargoGroup := obj.CM_CargoGroup;	
			bookingRef := cargoGroup.myBookingRef;
			if bookingRef &lt;&gt; null then
				bookingRefItem := bookingRef.allBookingRefItems.first;
			endif;
		elseif obj.isKindOf(CM_ReserveDetail) then
			reserveDetail := obj.CM_ReserveDetail;
		endif;
		
		if _mode = WO_TASK_RECEIVE then
			create pxyWorkOrderDtl as CM_WodReceive transient;
			pxyWorkOrderDtl.CM_WodReceive.setProxyWodReceival(bookingRef, bookingRefItem, currentBOL, bolDetail, null, _transportObject, transportMode);	
		elseif _mode = WO_TASK_RELEASE then
			create pxyWorkOrderDtl as CM_WodRelease transient;
			pxyWorkOrderDtl.CM_WodRelease.setProxyWodRelease(release, transportMode, release.myVoyage, release.myAssignedTrain, null, null, reserveDetail);	
			if not reserveDetail.isReserveSelection then				//06.03.2024 naviv1	#61848
				reserveDetail.allTrackedItems.copy(pxyWorkOrderDtl.CM_WodRelease.allSelectedTIs);
			endif;
		endif;
		
		allProxies.add(pxyWorkOrderDtl);
		pxyWorkOrderDtl.setStatus(WO_STATUS_USERENTRY);
		pxyWorkOrderDtl.setProxyForCreate(pxyWorkOrder, WO_TASK_HMSCANCEL);
		pxyWorkOrderDtl.setProxyReqByDT(requiredByDT);						
		
		if _mode = WO_TASK_RECEIVE then
			foreach ti in cargoGroup.allAssignedTrackedItems where ti.manifestNumber[1:manifestLength] = manifestNumber do		
				pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(ti, false);
			endforeach;
			pxyWorkOrderDtl.setTaskID(manifestNumber);
		endif;
		
	endforeach;
	
	if realWorkOrder &lt;&gt; null then
		app.myUtilityUA.utlUpdateWorkOrderMani(pxyWorkOrder, true, app.myPassport);		
	else
		app.myUtilityCA.utlCreateWorkOrderMani(pxyWorkOrder, realWorkOrder, app.myPassport);		
    endif;
	
    if realWorkOrder &lt;&gt; null then
        if _mode = WO_TASK_RECEIVE and cargoGroup.myInstructions &lt;&gt; null then
			cgInstructions := cargoGroup.myInstructions;
		elseif _mode = WO_TASK_RELEASE and reserveDetail.myInstructions &lt;&gt; null then
			cgInstructions := reserveDetail.myInstructions;
		endif;
		if cgInstructions &lt;&gt; null then
			
            create instructions transient;
			allProxies.add(instructions);
			instructions.setProxy(cgInstructions.internalInstructions, cgInstructions.externalInstruction, cgInstructions.myInstructionType, realWorkOrder);            
           
			if realWorkOrder.myInstructions = null then            
				create woInstructions persistent;
				isNew := true;
			else
				instructions := realWorkOrder.myInstructions.pxyCreateUpdateProxy().CM_InstructionsIssued;
				woInstructions := realWorkOrder.myInstructions;
			endif;
				
			if isNew then
				woInstructions.setForCreate(instructions);
			else
				woInstructions.setForUpdate(instructions);
			endif; 
			
		endif;
    endif;                                                                            
    
	if app.myPassport.noErrors then	
		self.myCreateAuditAgent.audCreateGeneric(realWorkOrder);
	endif;
	
epilog
	if allProxies &lt;&gt; null then
		allProxies.purge();
	endif;
	delete allProxies;
end;</source>
        <Parameter name="_manifest" type="CM_EDIDataTransManifest"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_objArray" type="CM_ObjectArray"/>
        <Parameter name="_transportObject" type="CM_Object"/>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
    </JadeMethod>
    <JadeMethod name="utlCreateWOForShipManifest" id="cb150256-d3c2-4b2b-9fcb-dc2e6b459a7d">
        <updating/>
        <source>utlCreateWOForShipManifest(_manifest : CM_EDIDataTransManifest; 
						_mode : Integer; 
						_objArray : CM_ObjectArray; 
						_transportObject : CM_Object; 
						_tis : CM_TIByCargoTypeIdDict) updating;
/*

Purpose:			

Parameters:			
	_mode is WO_TASK_RECEIVE or WO_TASK_RELEASE
Return Value:		

Date		Who		Reason
15/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
24/11/2023	navcs2	ChangeRequest 60874: MTN | Jade Upgrade - Unit Test Review (Fixing transient leaks for postManifest unit tests)
04/12/2023	jlirs1	TFS 59171 User Defined Transport Manifest 
02/02/2024	navcs	Bug 62218: EUP - Transport Manifest (ship) - Incorrect Progress Status
10/06/2024	navdap1	TFS 64508 MTN - Duplicate cargo items/tasks in work order after reprocessing Transport Manifest
13/08/2024	navmd1	TFS 64508 Additional changes to handle existing work order
*/

vars
	pxyWorkOrder : CM_WorkOrder;
	pxyWorkOrderDtl,
	workOrderDtl,
	wodToDelete : CM_WorkOrderDtl;
	realWorkOrder : CM_WorkOrder;
	currentBOL : CM_BOL;
	bol : CM_BOL;
	bolDetail : CM_BOLDtl;
	bookingRef : CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
	voyage : CM_Voyage;
	obj : Object;
	cargoGroup : CM_CargoGroup;
	allProxies : ObjectArray;
	requiredByDT : TimeStamp;
	startAtDT : TimeStamp;
	workOrderId : String;
	transportMode : Integer;
	cgInstructions, instructions, woInstructions  : CM_InstructionsIssued;
	reserveDetail : CM_ReserveDetail;	
	release : CM_BulkRelease;				
	ti : CM_TrackedItem;
    isNew : Boolean;
	terminal : CM_Terminal;
	manifestNumber : String;
	existingWODtl : CM_WorkOrderDtl;			// TFS 64508
begin
	self.initialiseActivity();
	
	app.myPassport.setWarningsIgnored(true);	
	app.setContinueCMExceptions(false);
	
	manifestNumber := _manifest.manifestNumber;
	
	if manifestNumber = null then
		//error
		return;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	create allProxies transient;
	if _transportObject.isKindOf(CM_Voyage) then
		voyage := _transportObject.CM_Voyage;
		transportMode := TI_TRANSMODE_SHIP;
		workOrderId := voyage.code;
	else
		// Should only be ship manifests
		return;
	endif;
	
	realWorkOrder := terminal.allWorkOrders.getAtKey(workOrderId);
	
	if realWorkOrder &lt;&gt; null then
		beginLoad;
		pxyWorkOrder	:= realWorkOrder.pxyCreateUpdateProxy();
		endLoad;
	else
		create pxyWorkOrder as CM_WorkOrderTI transient;		
		pxyWorkOrder.setID(workOrderId);
	endif;
	allProxies.add(pxyWorkOrder);
	
	if _mode = WO_TASK_RECEIVE then
		cargoGroup := _objArray.first.CM_CargoGroup;
		if voyage &lt;&gt; null then
			requiredByDT := voyage.departedDT;
			if not requiredByDT.isValid then
				requiredByDT := app.actualTimeServer();
			endif;
			startAtDT := voyage.arrivedDT;
		endif;
		
	elseif _mode = WO_TASK_RELEASE then
		release := _objArray.first.CM_ReserveDetail.myReserveHeader;
		if release.dateEstimatedRequired.isValid then
			requiredByDT := release.dateEstimatedRequired;
		endif;
	
		if release.type = BR_TYPE_SHIP then
			transportMode := TI_TRANSMODE_SHIP;
		else
			// Should only be ship releases
			return;
		endif;
	else
		app.raiseUnexpectedProgramError(self.class.name, method.qualifiedName, "Unexpected mode '" &amp; _mode.String &amp; "' for work order creation");
		return;
	endif;
	
	if realWorkOrder = null then	
		pxyWorkOrder.setProxy(		
				null, 							//_allEmailAddresses
				null, 							//_customerReference
				false, 							//_emailNotification
				app.actualTimeServer, 			//_enteredByDT
				app.getMyUser(), 				//_enteredByUser 
				'',								//_approvedBy
				app.getMyUser().myOrganisation, // _myOrganisation
				app.myPassport.myTerminal,			//_myTerminal
				'',  							//_remarks
				requiredByDT,					//_requiredByDT
				startAtDT, 						//_startAtDT
				WO_STATUS_PENDING 				//_taskStatus
				);
	endif;
	
	/*
	if _manifest.statusString = CMIF_JsonHeaderEUP.Status_Cancel then
		// Delete the TIs
		foreach ti in _tis do 																			
			if ti.manifestNumber = manifestNumber then
				app.myUtilityDA.utlDeleteTI(ti, true, app.myPassport);
			endif;
		endforeach;
		
		// find the matching workorderDtl to delete
		foreach workOrderDtl in pxyWorkOrder.allWoDtls do
			if workOrderDtl.taskID = manifestNumber then
				wodToDelete := workOrderDtl;
			endif;
		endforeach;
		
		// If the WorkorderDtl is empty then remove it from the work order
		if wodToDelete.CM_WorkOrderTIDtl.allSelectedTIs.isEmpty then
			pxyWorkOrder.allWoDtls.remove(workOrderDtl);
		endif;
		
		// If the workorder has no more tasks, delete it
		if pxyWorkOrder.allWoDtls.isEmpty then
			app.myUtilityDA.utlDeleteWorkOrder(realWorkOrder, app.myPassport);
		endif;
		
		return;
	endif;
	*/
		
	foreach obj in _objArray do		
		if obj.isKindOf(CM_CargoGroup) then
			cargoGroup := obj.CM_CargoGroup;
			bookingRef := cargoGroup.myBookingRef;
			if bookingRef &lt;&gt; null then
				bookingRefItem := bookingRef.allBookingRefItems.first;
			endif;
			currentBOL := null;
			if voyage &lt;&gt; null and voyage.allBOLInByTypeStatusNumDT &lt;&gt; null then
				foreach bol in voyage.allBOLInByTypeStatusNumDT do
					if bol.number = cargoGroup.billOfLading then 
						currentBOL := bol;
						if bol.allBOLDtls.size &gt; 0 then
							bolDetail := bol.allBOLDtls.first;
						endif;
						break;
					endif;
				endforeach;
			endif;
		elseif obj.isKindOf(CM_ReserveDetail) then
			reserveDetail := obj.CM_ReserveDetail;
		endif;
	endforeach;
	
	if _manifest.statusString = CMIF_JsonHeaderEUP.Status_Replace then
		foreach workOrderDtl in pxyWorkOrder.allWoDtls do
			if workOrderDtl.taskID = manifestNumber then
				wodToDelete := workOrderDtl;
			endif;
		endforeach;
		if wodToDelete &lt;&gt; null then
			pxyWorkOrder.allWoDtls.remove(wodToDelete);
		endif;
	endif;
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; "doing work order", LogDEBUG);
	if _mode = WO_TASK_RECEIVE then
		// TFS 64508 If there was any kind of exception when a BGP was processing us, and we're
		// partially loaded, we could already have a work order detail for this manifest
		existingWODtl := pxyWorkOrder.getWorkOrderDtlById(manifestNumber);
		if existingWODtl = null and realWorkOrder &lt;&gt; null then
			existingWODtl := realWorkOrder.getWorkOrderDtlById(manifestNumber);
		endif;
		// TFS 64508 Only create a work order detail if we need to, otherwise use a proxy
		if existingWODtl &lt;&gt; null then
			if _manifest.statusString = CMIF_JsonHeaderEUP.Status_Create then
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Found an already-existing work order detail - using that", LogDEBUG);
			endif;
			pxyWorkOrderDtl := existingWODtl.pxyCreateUpdateProxy();
		else
			create pxyWorkOrderDtl as CM_WodReceive transient;
		endif;
		pxyWorkOrderDtl.CM_WodReceive.setProxyWodReceival(bookingRef, bookingRefItem, currentBOL, bolDetail, null, _transportObject, transportMode);		
	elseif _mode = WO_TASK_RELEASE then
		create pxyWorkOrderDtl as CM_WodRelease transient;
		pxyWorkOrderDtl.CM_WodRelease.setProxyWodRelease(release, transportMode, release.myVoyage, release.myAssignedTrain, null, null, reserveDetail);		
	endif;
	allProxies.add(pxyWorkOrderDtl);
	pxyWorkOrderDtl.setStatus(WO_STATUS_USERENTRY);
	pxyWorkOrderDtl.setProxyForCreate(pxyWorkOrder, WO_TASK_HMSCANCEL);
	pxyWorkOrderDtl.setProxyReqByDT(requiredByDT);							//06.Dec.2023 navsp1 TFS 61157
	pxyWorkOrderDtl.setTaskID(manifestNumber);
	
	if _mode = WO_TASK_RECEIVE then
		if _tis &lt;&gt; null then
			foreach ti in _tis where not ti.isCargoGroupItem do 								// 	02/02/2024	navcs	Bug 62218																
				pxyWorkOrderDtl.CM_WorkOrderTIDtl.allSelectedTIs.addNoDuplicates(ti, false);
			endforeach;
		endif;
	endif;
		
	if realWorkOrder &lt;&gt; null then
		app.myUtilityUA.utlUpdateWorkOrderMani(pxyWorkOrder, true, app.myPassport);		
	else
		app.myUtilityCA.utlCreateWorkOrderMani(pxyWorkOrder, realWorkOrder, app.myPassport);		
    endif;
	
    if realWorkOrder &lt;&gt; null then                                                     
        if _mode = WO_TASK_RECEIVE and 
		   cargoGroup &lt;&gt; null and		//04 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		   cargoGroup.myInstructions &lt;&gt; null then
			cgInstructions := cargoGroup.myInstructions;
		elseif _mode = WO_TASK_RELEASE and reserveDetail.myInstructions &lt;&gt; null then
			cgInstructions := reserveDetail.myInstructions;
		endif;
		if cgInstructions &lt;&gt; null then
            create instructions transient;
			allProxies.add(instructions);
			instructions.setProxy(cgInstructions.internalInstructions, cgInstructions.externalInstruction, cgInstructions.myInstructionType, realWorkOrder);            
           
			if realWorkOrder.myInstructions = null then            
				create woInstructions persistent;
				isNew := true;
			else
				instructions := realWorkOrder.myInstructions.pxyCreateUpdateProxy();
				woInstructions := realWorkOrder.myInstructions;
			endif;
				
			if isNew then
				woInstructions.setForCreate(instructions);
			else
				woInstructions.setForUpdate(instructions);
			endif; 
		endif;
    endif;
	    
	if app.myPassport.noErrors then	
		self.myCreateAuditAgent.audCreateGeneric(realWorkOrder);
	endif;
	
epilog
	if allProxies &lt;&gt; null then
		allProxies.purge();
	endif;
	delete allProxies;
	delete wodToDelete;					//24/11/2023	navcs2	ChangeRequest 60874
end;</source>
        <Parameter name="_manifest" type="CM_EDIDataTransManifest"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_objArray" type="CM_ObjectArray"/>
        <Parameter name="_transportObject" type="CM_Object"/>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
    </JadeMethod>
