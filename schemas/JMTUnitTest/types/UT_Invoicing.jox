    <JadeMethod name="deleteServiceType" id="9f53bedf-f000-49a6-8fe3-17aa72f3d72e">
        <updating/>
        <source>deleteServiceType(_code : String; _bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2022	navkc1	Initial creation - ChangeRequest 54571: EUP - Inv Config - Service Type

To delete a Service Type of a Bank

*/

vars
	serviceType : CM_ServiceType;
	
begin
	
	foreach serviceType in CM_ServiceType.instances discreteLock do
		if serviceType.code = _code and
			serviceType.myBank = _bank then
			
			app.myTrxDA.trxDeleteServiceType(serviceType, app.myPassport);
