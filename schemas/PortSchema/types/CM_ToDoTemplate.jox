    <JadeMethod name="getAuditText" id="91e93eb5-2b2d-4034-9664-d4ec684ae3e6">
        <source>getAuditText(): String;

vars
	txt		: String;
	tmpStr	: String;
	grades	: CM_MTGrade;
	oper    : CM_Operator;
	isoType : CM_ISOType;
	isoGrp  : CM_ISOTypeGroup;
	toDoTask: CM_ToDoTaskDesc;
	deletedObj : Boolean;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach grades in self.availabilityGrades do
		if tmpStr = null then
			tmpStr := grades.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; grades.description;
		endif;
	endforeach;
	txt := txt &amp; 'Grades Selected' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	tmpStr := null;
	foreach oper in self.operators do
		if tmpStr = null then
			tmpStr := oper.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; oper.description;
		endif;
	endforeach;
	txt := txt &amp; 'Operators Selected ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	on Exception do app.handleDeletedObject(exception,isoType,deletedObj);
	foreach isoType in self.isoTypes do
		if tmpStr = null then
			tmpStr := isoType.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; isoType.description;
		endif;
	endforeach;
	txt := txt &amp; 'ISO Type Selected ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	foreach isoGrp in self.isoGroups do
		if tmpStr = null then
			tmpStr := isoGrp.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; isoGrp.description;
		endif;
	endforeach;
	txt := txt &amp; 'ISO Group Selected ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	foreach toDoTask in self.toDoTasks do
		if tmpStr = null then
			tmpStr := toDoTask.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; toDoTask.description;
		endif;
	endforeach;
	txt := txt &amp; 'Tasks Selected ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="9d3e9d7a-a0e8-4930-be7c-20a9eaa5cdd9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     17 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Apr 2014	cnwdb2		PAR #33977  
// ---------------------------------------------------------------------------

vars

begin
	if _attrName  = ETRow_AvailabilityGradeToApply then
		if availabilityGradeToApply &lt;&gt; null then
			return availabilityGradeToApply.description ; 
		endif ; 
		return "" ; 
	endif ;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraDataValueForTranships" id="64b6af2e-6174-49f1-b0ca-4ffd0f458dad">
        <source>getExtraDataValueForTranships() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 October 2010	cnwmh5	Initial creation #25602

*/

vars
	value 	: Boolean;
begin
	
	if self.myTerminal &lt;&gt; null then
		value := self.myTerminal.getExtraData(ToDoTaskTemplTranships &amp; "-" &amp; self.getOidAsString).Boolean;
	endif;
	
	return value;	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="09d4d757-1312-4310-b69e-5c059485cec8">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpToDoTemplate : CM_ToDoTemplate;
	completedOK		: Boolean;
begin

	tmpToDoTemplate :=  inheritMethod();
	self.availabilityGrades.copy(tmpToDoTemplate.availabilityGrades);
	self.isoGroups.copy(tmpToDoTemplate.isoGroups);
	self.isoTypes.copy(tmpToDoTemplate.isoTypes);
	self.operators.copy(tmpToDoTemplate.operators);
	self.toDoTasks.copy(tmpToDoTemplate.toDoTasks);
	tmpToDoTemplate.availabilityGradeToApply := self.availabilityGradeToApply;
	tmpToDoTemplate.myTerminal := self.myTerminal;//par 15420 15373

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpToDoTemplate;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpToDoTemplate;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setExtraDataValueForTranships" id="cb415614-2422-4e25-9211-16e95dddad54">
        <source>setExtraDataValueForTranships(_value : Boolean);

/*

Purpose:			

