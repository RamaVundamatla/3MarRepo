    <JadeMethod name="handleConsignee" id="d4923c7a-db57-4924-810c-f3d77b7060f5">
        <source>handleConsignee(_consigneeCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpConsignee	: CM_ConsigneeConsignor;
	theObject : Object;
begin

	trimCode := _consigneeCode.trimBlanks;

	if trimCode = null then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;

	theCode		:= null;
	theColor	:= NullColour;

	iter := self.myIterConsignee;
	self.allConsignees.startKeyGeq(trimCode, 0, iter);
	self.allConsignees.getIteratorKeys(codeKey, colorKey, iter);
	

	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		tmpConsignee := self.myRoot.allConsigneeConsignors[trimCode];
		if tmpConsignee &lt;&gt; null then
			self.allConsignees.addNoDuplicates(tmpConsignee, false);
			self.beginNotification(tmpConsignee, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:= trimCode;
			theColor	:= tmpConsignee.colour;
			theObject := tmpConsignee;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

end;</source>
        <access>protected</access>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
