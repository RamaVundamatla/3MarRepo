			if aClass.abstract then
				create subs transient;
				aClass.allSubclasses(subs); 
				foreach bClass in subs do
					if not bClass.abstract and
					   (bClass &lt;&gt; CM_MenuAction and
					    bClass &lt;&gt; CM_MenuAgent) then
						if bClass = CM_PackJob then
							bClass := bClass;
						endif;
						aClass := bClass;
