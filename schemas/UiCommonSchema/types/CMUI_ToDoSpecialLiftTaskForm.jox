    <JadeMethod name="doOK" id="da0e28ed-553c-4a4c-a2e7-4a09c9a3d1da">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

	index : Integer;
	specialLift : CM_SpecialLift;
	
begin

	self.allSelectedSpecLifts.clear();

	// add the current selections to the local dictionary.
	foreach index in 1 to self.lstSpecialLift.rows do
		if self.lstSpecialLift.rowChecked(index) then
			specialLift := self.lstSpecialLift.accessRow(index).itemObject.CM_SpecialLift;
			if specialLift &lt;&gt; null and not self.allSelectedSpecLifts.includes(specialLift) then
				self.allSelectedSpecLifts.add(specialLift);
			endif;
		endif;
	endforeach;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="928eb58c-9f9a-41a1-b7c8-d4be07f20768">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	self.lstSpecialLift.width := self.width - 23;
	self.lstSpecialLift.height := self.height - 100;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="b7b50ac7-2202-4366-9a52-5a195c3e27de">
        <updating/>
        <source>init(_ti : CM_TrackedItem; _toDoTaskDesc : CM_ToDoTaskDesc) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	self.myTrackedItem := _ti;
	self.myToDoTaskDesc := _toDoTaskDesc;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="lstSpecialLift_displayRow" id="7058909c-1015-4379-b24a-3758d0bfc9a2">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSpecialLift_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/


vars

	selected	: Boolean;
	specialLift : CM_SpecialLift;
	str : String;
	
begin

	if obj = null then
		return null;
	endif;
	
	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	
	specialLift := obj.CM_SpecialLift;
	if specialLift &lt;&gt; null then
		str := specialLift.description;
		if selected then
			return TableCheckBox_Selected &amp; Tab &amp; str;
		else
			return TableCheckBox_NotSelected &amp; Tab &amp; str;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="381dfcfb-4419-4964-887f-971f57cbd670">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

	count : Integer;
	
begin

	count := app.myRoot.allSpecialLifts.size;
	if count &gt; 6 then
		self.minimumHeight := 230;
	elseif count &gt; 2 then
		self.minimumHeight := ( count * 16 ) + 104;
	else
		self.minimumHeight := 150;
	endif;
	
	self.height := self.minimumHeight;

	inheritMethod();
	
	if self.myTrackedItem &lt;&gt; null then
		self.setCaption(app.getErrorString2(Complete_task_for, self.myToDoTaskDesc.description, self.myTrackedItem.id));
	else
		self.setCaption(app.getErrorString(Complete) &amp; " '" &amp; self.myToDoTaskDesc.description &amp; "'");
	endif;
	
	self.lstSpecialLift.displayCollection(app.myRoot.allSpecialLifts, false, Table.DisplayCollection_Forward, null);
	self.lstSpecialLift.clearSelected;
	
	if self.myTrackedItem &lt;&gt; null then
		self.lstSpecialLift.setSelected(self.myTrackedItem.allSpecialLifts);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e63c462e-c3b6-4502-835a-221c6bc02eef">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015082, locale);
	lblSelect.translateCaption(Xlat_0015083, locale);
end;</source>
    </JadeMethod>
</GUIClass>
