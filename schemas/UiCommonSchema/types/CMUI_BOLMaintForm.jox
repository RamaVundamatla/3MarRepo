    <JadeMethod name="addRowToOutturnRemarks" id="50dc9e85-a653-4138-8c02-eeeb8d157344">
        <updating/>
        <source>addRowToOutturnRemarks(_remark : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2022	navmv20	changeRequest 54095: EUP - Outturn Remarks on BOL
27 February 2023 navdp20 ChangeRequest 56847:[56848] EUP | Outturn Remarks on BOL - Predefined Text
*/

vars
	cell : JadeTableCell;
	combo : ComboBox;
	//remark : CM_PredefinedRemark; //27.02.2023 navdp20 #56847[56848] 
	remark : CM_DefinedText; 
	idx, idx2 : Integer;

begin
	self.comboIndex := self.comboIndex + 1;
	idx := self.tblOutturn.addItem(null);
	cell := self.tblOutturn.accessCell(idx, 1);
	combo := self.cmbRemarks.loadControl(self.comboIndex).ComboBox;
	combo.parent := self.tblOutturn;
	combo.form := self;
	cell.cellControl := combo;
	
	/*
	//27.02.2023 navdp20 TFS #56847[56848]
	foreach remark in app.myRoot.allPreDefinedRemarks do
		idx2 := combo.addItem(remark.description);
	endforeach;
	*/
	
	foreach remark in self.myTerminal.allTerminalDefinedText do //27.02.2023 navdp20 #56847[56848]
	    if app.getDefTextIntToStr(remark.context) = DefText_MTNDescBolOutturn then
			idx2 := combo.addItem(remark.text);
		endif;	
	endforeach;
	
	combo.automaticCellControl := true;
	combo.width := cell.getCellWidth-20;
	combo.style := ComboBox.Style_DropDown;
	if _remark &lt;&gt; null then
		cell.text := _remark;
	endif;

epilog

end;</source>
        <Parameter name="_remark" type="String"/>
    </JadeMethod>
    <JadeMethod name="btnAddRow_click" id="7302708a-b97a-41d2-a9e7-ef22df97dfec">
