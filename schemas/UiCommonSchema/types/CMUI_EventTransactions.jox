    <JadeMethod name="initFromUserWindow" id="ca484e3e-a32d-4e80-be4a-5cc69f688f66">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	tmpTypeStr	: String;
begin
	inheritMethod(_userWindow);
	
//	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblEvents.XMLTag_Table &amp; self.tblEvents.name);
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(ETDef_EventTransactions);
	self.xmlStrTblEvents := tmpTypeStr.trimCharacters(CrLf);

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTables" id="831d7a18-c39f-43ee-be4e-fb1df02cc589">
        <updating/>
        <source>initTables() updating, protected;
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR
23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events

*/

vars


	entTableDef		: EntTableDef;
	
begin
	
	if self.eventCategory = CM_EventType.TRAIN_EVENT then
		entTableDef := app.myController.getEntTableDef(ETDef_EventTransactionTrain);	//ChangeRequest 45575
	else
		entTableDef := app.myController.getEntTableDef(ETDef_EventTransactions);
	endif;
	
	if self.xmlStrTblEvents.trimBlanks &lt;&gt; null then
		self.tblEvents.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblEvents);
	else
		self.tblEvents.setTblDataEntRowsFromDef(entTableDef);
	endif;
		
	self.tblCharges.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_InvChargesTable));
	self.tblCharges.fixedRows := 1;
	self.tblCharges.fixedColumns := 0;
	self.tblCharges.accessColumn(1);
	self.tblCharges.sortColumn[1] := 1;
	self.tblCharges.sortAsc[1] := true;
	
	self.loadTblEvents();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTblEvents" id="af213279-a589-40be-81fa-6605edd03563">
        <updating/>
        <source>loadTblEvents()updating;
/*

Date		Who		Reason
22 Jan 2020	jlgma1	Bug 48324: ASPA - ASPA McDuffie - Request System Error Logs

*/

vars

	event     : CM_EventTransaction;
	il        : CM_InvoiceLine;
	edition   : Integer;
	invalid   : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myParent, invalid);
	
	self.tblCharges.rows := self.tblEvents.fixedRows;
	self.tblCharges.allSelectedObjects.clear();
	self.tblEvents.rows := self.tblEvents.fixedRows;
	self.tblEvents.allSelectedObjects.clear();
	
	
	if self.allTransactionsIter = null then
		return;
	endif;
	self.allTransactionsIter.reset;
	
	if self.myParent &lt;&gt; null  then           //22.01.2020 cnwma1 #48324
		edition := self.myParent.edition;
	endif;
	
	if invalid then                          //22.01.2020 cnwma1 #48324
		app.msgBox( app.getErrorString(ERR_DELETED_VOYAGE) ,'Voyage Deleted',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.unloadForm();
		return;
	endif;	
	
	while  self.allTransactionsIter.next(event) do
		self.tblEvents.addObject(event);
		foreach il in event.allInvoiceLines do
			self.tblCharges.addObject(il);
		endforeach;	
	endwhile;
	
	self.tblEvents.selectMode := Table.SelectMode_Row;
	self.tblCharges.selectMode := Table.SelectMode_WholeRows; // TFS 40620		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mnuAudits_click" id="4386074c-4b3a-4ac7-8839-5973fd11f81c">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAudits_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	form : CM_AuditViewForm;

begin

	if menuItem.userObject &lt;&gt; null then
	
		if self.myAssistant = null then
			create self.myAssistant transient;
		endif;
		
		form := app.loadForm(CM_AuditViewForm, self.myAssistant.class, false, false, false, null, null).CM_AuditViewForm;
		
		form.myAudittedObject := menuItem.userObject.CM_Object;
		
		form.show();
		
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
