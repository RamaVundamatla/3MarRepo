    <JadeMethod name="initTableExtractDef" id="045ab0a4-3e1c-4339-9a11-298e60c660ba">
        <updating/>
        <source>initTableExtractDef() updating, protected;
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	entTableDef : EntTableDef;
	theRow : Integer;
	ta : CM_TerminalAreaType;
	iter : Iterator;
	str : String;
	tbl : CM_EntryTable;
		
begin
	tbl := self.tblExtractDef;
	tbl.warningMethod := 'entTableWarning';
	
	tbl.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_ExtractDataMaint);
	tbl.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	tbl.top := 5;
	tbl.left := 5;
	tbl.parentTopMargin := tbl.top;
	tbl.parentLeftMargin := tbl.left;
	tbl.parentRightMargin := 15;
	tbl.parentBottomMargin := 10;

	tbl.lockBottom := false;
	tbl.lockRight := false;
	tbl.stretchHeight := true;
	tbl.stretchWidth := true;

	// Setup the Combo Boxes
	self.comboExtractFormatBuild();
	self.comboOIDFormatBuild();
	self.comboSQLVersionBuild();
	self.comboTerminalBuild();
//	self.comboIgnoreUserBuild();	//07 Jan 2014	NDL	Par 33264

	tbl.optimiseHeadingColumn();
	tbl.resetSize;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTableExtractHistory" id="98f45813-5ab7-4152-baef-5c660abad867">
