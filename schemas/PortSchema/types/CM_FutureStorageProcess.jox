    <JadeMethod name="getTerminalCode" id="c0a05e30-f99e-440d-8345-7f27daa53acc">
        <source>getTerminalCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/
vars
	invalid : Boolean;
	code : String;

begin
	on Exception do app.handleDeletedObject(exception, self.myTrackedItem, invalid);	
	
	code := self.myTrackedItem.myTerminal.code;
	
	if invalid then 
		return null;
	endif;
	
	return code;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isFutureStorageActor" id="ceb12bcc-b738-4d1d-b1d1-20053ce7aed2">
        <source>isFutureStorageActor(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsCOOResync" id="47f9be6a-49c6-486d-8e23-73d2bcd40944">
        <updating/>
        <source>setIsCOOResync(_value : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58259: Jade - COO Future Storage Resync

*/

vars

begin
	self.isCOOResync := _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="ea91f66d-c7e9-4cd1-81b9-11ea4727ef4f">
        <updating/>
        <source>setMyTrackedItem(_value : CM_TrackedItem) updating;

/*

Purpose:			CCMS DPH 2278
					Changes added to delay updating CM_root 
Parameters:			

Return Value:		


Date		Who		Reason
20 Jun 2013	cnwjre1	Initial creation
23 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars

begin
	self.myTrackedItem   := _value;
	self.myParentObject  := _value;
	
	if not app.myPassport.useOfflineFutureActorDeferUpd then		//23.05.2024 navma1 #64224
		self.myRoot 	     := app.myRoot;							//26 Feb 2019	NDL	TFS 43348
	else
		app.myPassport.addFutureActorsForDeferUpd(self);			//23.05.2024 navma1 #64224
	endif;
epilog

end;</source>
        <Parameter name="_value" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="a0e9c6a0-0f59-4071-80f3-d2c4a756eca5">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:		TFS 45464	

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2019	jlgab1	Initial creation

*/

vars

