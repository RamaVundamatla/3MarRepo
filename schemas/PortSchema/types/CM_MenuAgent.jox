    <JadeMethod name="trxSaveNavMenuAsJMTDefault" id="283a4d7a-ada4-482f-b68a-94e575b88c65">
        <updating/>
        <source>trxSaveNavMenuAsJMTDefault(_systemMenuRoot, _userMenuRoot : CM_MenuRoot input) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpValue,
	numChildren,
	idx			: Integer;
	rtnStr,
	constantStr	: String;
	tmpPermAgent: CM_PermissionAgent;
	permObj		: CM_PermissionObject;	
	deleteSet	: CM_MenuEntitySet;
	menuEntity	: CM_MenuEntity;
	menHdr		: CM_MenuHdrSystem;
	menDtl		: CM_MenuDtlSystem;
	menTrans	: CM_MenuHdrTransient;
begin
	app.writeStatement( 'Write to globals starting');

	beginTransaction;
	create deleteSet transient;
	
	app.processGlobalConstantGroup(PortSchemaName, MenuHdrConstants, CM_MenuAgent::loadSystemMenuHdrTransients.name, self);

	// Add all the existing menuHdrs into the a
	foreach menuEntity in _systemMenuRoot.allChildren do
		if menuEntity.isKindOf(CM_MenuHdr) then
			menuEntity.CM_MenuHdr.addToDeleteSet(deleteSet);
		endif;
	endforeach;
	
	numChildren := _userMenuRoot.allChildren.size;
	foreach idx in 1 to numChildren do
		menuEntity := _userMenuRoot.allChildren[idx];
		if (not menuEntity.isKindOf(CM_MenuUserItem)) then
			continue;
		endif;		
		menuEntity.CM_MenuUserItem.saveAsSystemEntity(_systemMenuRoot, idx, self, deleteSet, _systemMenuRoot, CM_MenuHdr.Prefix_NavHdr);
	endforeach;

	deleteSet.purge;	
	commitTransaction;
	
	create tmpPermAgent transient;
	tmpPermAgent.populatePermissionDict(true, true, 0);

	beginTransaction;

	// Save the root menu structure first (ok to use _systemMenuRoot at this point as
	// it has been setup above)
	menTrans := self.allMenuHdrTransients[null, MenuRootID].CM_MenuHdrTransient;
	if menTrans &lt;&gt; null and menTrans.myConstant &lt;&gt; null then
		// can just update text on constant
		menTrans.myConstant.setText(_systemMenuRoot.outputAsXML(CM_MenuEntity.XMLTag_MenuHdr));
	else
		tmpValue := self.getNextMenuHdrTransientValue();
		// constant does not exist so will need to create
		constantStr := constantStr &amp; CrLf &amp; 
			Tab &amp; 'MenuHdr_' &amp; tmpValue.String &amp; ':' &amp; Tab &amp; 
					"Integer = " &amp; tmpValue.String &amp; ";" &amp; CrLf &amp;
			Tab &amp; 'documentationText' &amp; CrLf &amp;
			'`' &amp;  _systemMenuRoot.outputAsXML(CM_MenuEntity.XMLTag_MenuHdr) &amp; '`' &amp; CrLf &amp; CrLf;
	endif;

	// now save all the menu headers

	foreach menuEntity in self.myJMTMenuRoot.allMenuItems do
		if menuEntity.isKindOf(CM_MenuDtlSystem) then
			menDtl := menuEntity.CM_MenuDtlSystem;
			permObj := tmpPermAgent.allPermissionsByConstValue[menDtl.constantValue];
			if permObj &lt;&gt; null then
				permObj.updateFromMenuDtlSystem(menDtl); 
			endif;
		
		elseif menuEntity.isKindOf(CM_MenuHdrSystem) then
			menHdr := menuEntity.CM_MenuHdrSystem;
			menTrans := self.allMenuHdrTransients[null, menHdr.menuId].CM_MenuHdrTransient;
			if menTrans &lt;&gt; null and menTrans.myConstant &lt;&gt; null then
				// can just update text on constant
//if menTrans.constantValue = 1 then
//	process.debug;
//endif;
				menTrans.myConstant.setText(menHdr.outputAsXML(CM_MenuEntity.XMLTag_MenuHdr));
			else
				// constant does not exist so will need to create
				constantStr := constantStr &amp; CrLf &amp; 
					Tab &amp; 'MenuHdr_' &amp; menHdr.constantValue.String &amp; ':' &amp; Tab &amp; "Integer = " &amp; menHdr.constantValue.String &amp; ";" &amp; CrLf &amp;
					Tab &amp; 'documentationText' &amp; CrLf &amp;
					'`' &amp;  menHdr.outputAsXML(CM_MenuEntity.XMLTag_MenuHdr) &amp; '`' &amp; CrLf &amp; CrLf;
			endif;
		endif;
	endforeach;
	
	if constantStr &lt;&gt; null then
		global.addConstantsServer('MenuHdrConstants', constantStr, rtnStr);
	endif;
	
	commitTransaction;
	
	app.writeStatement( 'Write to globals complete');
	self.trxLoadJMTNavMenu();

epilog
	delete deleteSet;
	delete tmpPermAgent;

end;</source>
        <Parameter name="_systemMenuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_userMenuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSaveReportMenuAsJMTDefault" id="52707b31-54f1-4c85-b799-d72997ba9f0e">
        <updating/>
        <source>trxSaveReportMenuAsJMTDefault(_systemMenuRoot, _userMenuRoot : CM_MenuRoot input) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpValue,
	idx			: Integer;
	rtnStr,
	constantStr	: String;
	tmpPermAgent: CM_PermissionAgent;
	permObj		: CM_PermissionObject;	
	deleteSet	: CM_MenuEntitySet;
	menuEntity	: CM_MenuEntity;
	menHdr		: CM_MenuHdrSystem;
	menDtl		: CM_QryReportSystem;
	menTrans	: CM_MenuHdrTransient;
begin

	beginTransaction;
	create deleteSet transient;
	
	app.processGlobalConstantGroup(PortSchemaName, MenuHdrReportConstants, CM_MenuAgent::loadReportMenuHdrTransients.name, self);

	// Add all the existing menuHdrs into the a
	foreach menuEntity in _systemMenuRoot.allChildren do
		if menuEntity.isKindOf(CM_MenuHdr) then
			menuEntity.CM_MenuHdr.addToDeleteSet(deleteSet);
		endif;
	endforeach;
	
	foreach idx in 1 to _userMenuRoot.allChildren.size do
		menuEntity := _userMenuRoot.allChildren[idx];
		if not menuEntity.isKindOf(CM_MenuUserItem) then
			continue;
		endif;		
		menuEntity.CM_MenuUserItem.saveAsSystemEntity(_systemMenuRoot, idx, self, deleteSet, _systemMenuRoot, CM_MenuHdr.Prefix_ReportHdr);
	endforeach;

	deleteSet.purge;	
	commitTransaction;
	
//	create tmpPermAgent transient;
//	tmpPermAgent.populatePermissionDict();

	// Save the root menu structure first (ok to use _systemMenuRoot at this point as
	// it has been setup above)
	menTrans := self.allMenuHdrTransients[null, MenuRootID].CM_MenuHdrTransient;
	if menTrans &lt;&gt; null and menTrans.myConstant &lt;&gt; null then
		// can just update text on constant
		menTrans.myConstant.setText(_systemMenuRoot.outputAsXML(CM_MenuEntity.XMLTag_MenuHdr));
	else
		tmpValue := self.getNextMenuHdrTransientValue();
		// constant does not exist so will need to create
		constantStr := constantStr &amp; CrLf &amp; 
			Tab &amp; 'MenuReportHdr_' &amp; tmpValue.String &amp; ':' &amp; Tab &amp; 
					"Integer = " &amp; tmpValue.String &amp; ";" &amp; CrLf &amp;
			Tab &amp; 'documentationText' &amp; CrLf &amp;
			'`' &amp;  _systemMenuRoot.outputAsXML(CM_MenuEntity.XMLTag_MenuHdr) &amp; '`' &amp; CrLf &amp; CrLf;
	endif;

	beginTransaction;
	foreach menuEntity in self.myJMTMenuReportRoot.allMenuItems do
		if menuEntity.isKindOf(CM_MenuHdrSystem) then
			menHdr := menuEntity.CM_MenuHdrSystem;
			menTrans := self.allMenuHdrTransients[null, menHdr.menuId].CM_MenuHdrTransient;
			if menTrans &lt;&gt; null and menTrans.myConstant &lt;&gt; null then
				// can just update text on constant
				menTrans.myConstant.setText(menHdr.outputAsXML(CM_MenuEntity.XMLTag_MenuReportHdr));
			else
				// constant does not exist so will need to create
				constantStr := constantStr &amp; CrLf &amp; 
					Tab &amp; 'MenuReportHdr_' &amp; menHdr.constantValue.String &amp; ':' &amp; Tab &amp; "Integer = " &amp; menHdr.constantValue.String &amp; ";" &amp; CrLf &amp;
					Tab &amp; 'documentationText' &amp; CrLf &amp;
					'`' &amp;  menHdr.outputAsXML(CM_MenuEntity.XMLTag_MenuReportHdr) &amp; '`' &amp; CrLf &amp; CrLf;
			endif;
		endif;
	endforeach;
	
	if constantStr &lt;&gt; null then
		global.addConstantsServer('MenuHdrReportConstants', constantStr, rtnStr);
	endif;
	
	commitTransaction;
	
	app.writeStatement( 'Write to globals complete. Starting trxLoadJMTReportMenu');
	self.trxLoadJMTReportMenu();

epilog
	delete deleteSet;
	delete tmpPermAgent;

end;</source>
        <Parameter name="_systemMenuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_userMenuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSaveSysEntMenuAsJMTDefault" id="8adb654e-8014-4848-8e10-e69ccf852d4d">
        <updating/>
        <source>trxSaveSysEntMenuAsJMTDefault(_systemMenuRoot, _userMenuRoot : CM_MenuRoot input) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
	rtnStr,
	constantStr	: String;
	tmpPermAgent: CM_PermissionAgent;
	permObj		: CM_PermissionObject;	
	deleteSet	: CM_MenuEntitySet;
	menuEntity	: CM_MenuEntity;
	menHdr		: CM_MenuHdrSystem;
	menDtl		: CM_MenuDtlSystem;
	menTrans	: CM_MenuHdrTransient;
	tmpValue	: Integer;
begin

	beginTransaction;
	create deleteSet transient;
	
	app.processGlobalConstantGroup(PortSchemaName, MenuHdrSystemConstants, CM_MenuAgent::loadMenuSysHdrTransients.name, self);

	// Add all the existing menuHdrs into the a
	foreach menuEntity in _systemMenuRoot.allChildren do
		if menuEntity.isKindOf(CM_MenuHdr) then
			menuEntity.CM_MenuHdr.addToDeleteSet(deleteSet);
		endif;
	endforeach;
	
	foreach idx in 1 to _userMenuRoot.allChildren.size do
		menuEntity := _userMenuRoot.allChildren[idx];
		if not menuEntity.isKindOf(CM_MenuUserItem) then
			continue;
		endif;		
		menuEntity.CM_MenuUserItem.saveAsSystemEntity(_systemMenuRoot, idx, self, deleteSet, _systemMenuRoot, CM_MenuHdr.Prefix_SysEntHdr);
	endforeach;

	deleteSet.purge;	
	commitTransaction;
	
	create tmpPermAgent transient;
	tmpPermAgent.populatePermissionDict(true, true, 0);

	beginTransaction;

	// Save the root menu structure first (ok to use _systemMenuRoot at this point as
	// it has been setup above)
	menTrans := self.allMenuHdrTransients[null, MenuRootID].CM_MenuHdrTransient;
	if menTrans &lt;&gt; null and menTrans.myConstant &lt;&gt; null then
		// can just update text on constant
		menTrans.myConstant.setText(_systemMenuRoot.outputAsXML(CM_MenuEntity.XMLTag_MenuSysHdr));
	else
		tmpValue := self.getNextMenuHdrTransientValue();
		// constant does not exist so will need to create
		constantStr := constantStr &amp; CrLf &amp; 
			Tab &amp; 'MenuSysHdr_' &amp; tmpValue.String &amp; ':' &amp; Tab &amp; 
					"Integer = " &amp; tmpValue.String &amp; ";" &amp; CrLf &amp;
			Tab &amp; 'documentationText' &amp; CrLf &amp;
			'`' &amp;  _systemMenuRoot.outputAsXML(CM_MenuEntity.XMLTag_MenuHdr) &amp; '`' &amp; CrLf &amp; CrLf;
	endif;

	foreach menuEntity in self.myJMTMenuRootForSysEntites.allMenuItems do
		if menuEntity.isKindOf(CM_MenuDtlSystem) then
			menDtl := menuEntity.CM_MenuDtlSystem;
			permObj := tmpPermAgent.allPermissionsByConstValue[menDtl.constantValue];
			if permObj &lt;&gt; null then
				permObj.updateFromMenuDtlSystem(menDtl); 
			endif;
		
		elseif menuEntity.isKindOf(CM_MenuHdrSystem) then
			menHdr := menuEntity.CM_MenuHdrSystem;
			menTrans := self.allMenuHdrTransients[null, menHdr.menuId].CM_MenuHdrTransient;
			if menTrans &lt;&gt; null and menTrans.myConstant &lt;&gt; null then
				// can just update text on constant
				menTrans.myConstant.setText(menHdr.outputAsXML(CM_MenuEntity.XMLTag_MenuSysHdr));
			else
				// constant does not exist so will need to create
				constantStr := constantStr &amp; CrLf &amp; 
					Tab &amp; 'MenuSysHdr_' &amp; menHdr.constantValue.String &amp; ':' &amp; Tab &amp; "Integer = " &amp; menHdr.constantValue.String &amp; ";" &amp; CrLf &amp;
					Tab &amp; 'documentationText' &amp; CrLf &amp;
					'`' &amp;  menHdr.outputAsXML(CM_MenuEntity.XMLTag_MenuSysHdr) &amp; '`' &amp; CrLf &amp; CrLf;
			endif;
		endif;
	endforeach;

	if constantStr &lt;&gt; null then
		global.addConstantsServer('MenuHdrSystemConstants', constantStr, rtnStr);
	endif;
	
	commitTransaction;
	
	app.writeStatement( 'Write to globals complete. Starting trxLoadJMTSysEntMenu');
	self.trxLoadJMTSysEntMenu();

epilog
	delete deleteSet;
	delete tmpPermAgent;

end;</source>
        <Parameter name="_systemMenuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_userMenuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSaveToSourceMenuRoot" id="8cc49ccb-54d3-4991-a4fd-85e12c45ba08">
        <source>trxSaveToSourceMenuRoot(_sourceRoot : CM_MenuRoot; 
							_targetRoot : CM_MenuRoot input;
							_user : CM_User;
							_clearFirst : Boolean);
// ---------------------------------------------------------------------------
// Created:     12 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	childEntity,
	newEntity,
	menuEntity			: CM_MenuEntity;
	terminal			: CM_Terminal;
	deleteSet			: CM_MenuEntitySet;
begin
	if _sourceRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null user root passed in.');
		return;
	endif;
	
	if _targetRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'admin root is null');
		return;
	endif;
	
	_targetRoot.allChildren.purge();
	
	if _targetRoot.isKindOf(CM_MenuRootUserTerminal) then
		terminal := _targetRoot.CM_MenuRootUserTerminal.myUserTerminal.getMyTerminal;
	endif;
	
	_targetRoot.cloneFromSource(null, _sourceRoot, terminal, _targetRoot, _user, _clearFirst, deleteSet);
	
	
end;</source>
        <Parameter name="_sourceRoot" type="CM_MenuRoot"/>
        <Parameter name="_targetRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxSaveToolbarMenuAsJMTDefault" id="11670be2-1aee-4232-91c7-4c6f1ce4d382">
        <source>trxSaveToolbarMenuAsJMTDefault(_toolbarMenuRoot : CM_MenuRoot);
// ---------------------------------------------------------------------------
// Created:     20 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	systemTool	: CM_MenuToolbar;
	menuEntity		: CM_MenuEntity;
	constantStr	: String;
	result		: Integer;
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
begin

	
	result := MenuHdrToolbar_1;//mentioned so it ships with an extract - just in case

	constantStr := '&lt;Children&gt;';
	foreach menuEntity in _toolbarMenuRoot.allChildren do
		if not menuEntity.isKindOf(CM_MenuUserToolbar) then
			continue;
		endif;
		
		systemTool := menuEntity.CM_MenuUserToolbar.mySystemToolbar;
		if systemTool = null then
			continue;
		endif;
		
		constantStr := constantStr &amp; CrLf &amp;
			'&lt;Id&gt;' &amp; systemTool.menuId &amp; '&lt;/Id&gt;';
		
	endforeach;
	
	constantStr := constantStr &amp; CrLf &amp; '&lt;/Children&gt;';

	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(MenuHdrToolbarConstants);
	constDict := category.getConstants();
	const := constDict.getAtKey('MenuHdrToolbar_1');
	
	if const = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Toolbar Header Constant not found');
		return;
	endif;
	
	beginTransaction;
	const.setPropertyValue('text', constantStr);
	commitTransaction;

	self.trxLoadJMTToolbarMenu();
	
end;</source>
        <Parameter name="_toolbarMenuRoot" type="CM_MenuRoot"/>
    </JadeMethod>
    <JadeMethod name="trxSaveToolbarMenuAsSysDefault" id="95fcc13d-3f22-4035-9b3c-ef6b1ae5ad17">
        <source>trxSaveToolbarMenuAsSysDefault(_userToolbarRoot : CM_MenuRoot);
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newTool				: CM_MenuUserToolbar;
	menuEntity			: CM_MenuEntity;

begin
	if _userToolbarRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User Toolbar Root was null');
		return;
	endif;
	
	beginTransaction;	
	self.mySystemToolbarRoot.allChildren.purge();

	foreach menuEntity in _userToolbarRoot.allChildren do
		if not menuEntity.isKindOf(CM_MenuUserToolbar) then
			continue;
		endif;
		create newTool persistent;
		newTool.setFromSystemToolbar(menuEntity.CM_MenuUserToolbar.mySystemToolbar);
		self.mySystemToolbarRoot.allChildren.add(newTool);
	endforeach;

	commitTransaction;

end;</source>
        <Parameter name="_userToolbarRoot" type="CM_MenuRoot"/>
    </JadeMethod>
    <JadeMethod name="utlLoadReportFromConstant" id="c857a1b9-951e-496a-b763-46549c5eff68">
        <source>utlLoadReportFromConstant(const: Constant);
//----------------------------------------------------------------
//	Created:	14 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	menuRoot : CM_MenuRootReportForRoot;
begin

	menuRoot := self.myJMTMenuReportRoot;
	
	if menuRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'menuRoot is null');
		return;
	endif;

	beginTransaction;
	self.loadJMTMenuReportDetails(const, menuRoot);
	commitTransaction;
end;</source>
        <Parameter name="const" type="Constant"/>
    </JadeMethod>
</Class>
