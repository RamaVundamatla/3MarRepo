    <JadeMethod name="lstTable_lostFocus" id="41cad500-a330-4725-accb-1cab080c1427">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTable_lostFocus(_table: Table input) updating;
//
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
//
vars
	object	: Object;
begin
	self.fieldTerminal.enabled := false;
	foreach object in _table.CMUI_ListTable.allSelectedObjects do
		if object = BGP_CamsRequest then
			self.fieldTerminal.enabled := true;
		endif;
	endforeach;
end;
</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
