	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS"&amp;method.name);
	self.assertNotNull(ediFile);
	tempStr	:= 'Load failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(ediFile.ediData, tempStr);
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf (CM_EDIBookingHeaderTI) then
			continue;
		endif;
		
		if ediTI.CM_EDIBookingItemTI.id = BookingId1 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "NAZA", BookingId1);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "NAZARD", BookingId1);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId2 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "FZFS", BookingId2);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "FZFS", BookingId2);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId3 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "FISH", BookingId3);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "COD", BookingId3);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId4 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "", BookingId4);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, null, BookingId4);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId5 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "", BookingId5);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, null, BookingId5);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId6 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "REEF", BookingId6);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "REEF", BookingId6);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId7 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "", BookingId7);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, null, BookingId7);
		elseif ediTI.CM_EDIBookingItemTI.id = BookingId8 then
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodity, "FZFS", BookingId8);
			self.assertEqualMsg (ediTI.CM_EDIBookingItemTI.commodityDescription, "COD", BookingId8);
		endif;
	endforeach;
