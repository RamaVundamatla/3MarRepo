    </JadeMethod>
    <JadeMethod name="setHasBeenUpdated" id="0daafeb0-d9c0-4ce8-8f47-4963e384ef6e">
        <updating/>
        <source>setHasBeenUpdated( _hasBeenUpdated : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation	Par 28896

*/

vars

	table : Table;

begin

	self.hasBeenUpdated := _hasBeenUpdated;
	
	if _hasBeenUpdated then
		self.myCCVoyAllocTableRoot.doQueueRefresh();
	endif;

epilog

end;</source>
        <Parameter name="_hasBeenUpdated" type="Boolean"/>
    </JadeMethod>
</Class>
