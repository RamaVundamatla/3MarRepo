<Class name="CMIF_TMCQuantityRangeGroup" id="03495136-b977-47d9-ae63-ed636b47453f">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

This transient class is used to represent the CM_DEBTOR MAP object's mappings.</text>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myQuantityRangeMap" id="4dd2ddfa-3b15-415d-8812-c43efdba7334">
        <embedded/>
        <type name="CM_QuantityRangeMap"/>
    </ImplicitInverseRef>
    <JadeMethod name="exportCargoCSV" id="fa10a498-93b0-4af3-8ab6-ac7a99e92915">
        <updating/>
        <source>exportCargoCSV(_file : File input; _line : String) updating;
// ---------------------------------------------------------------------------
// Created:		October 2009 By Andrew Bishop cnwab1
//
// 23659 add invoice mapping methods to extract, use extractName instead of itemName, add in contract column for voyage 
// 33095 Jan 2014 put quotes around invoice line description in case it contains commas
// 13/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// 24/05/2023	navkc1	CR 57927 Task 57923: Jade - Transaction Map Export Import
// ---------------------------------------------------------------------------

vars
	isVTMIS, isWO, isEvent	: Boolean;
	isBOL : Boolean;
	hasTranship,
	includesTranshipMethod : Boolean;
	currKey	: Integer;
	narration,
	voidString,
	inContract,
	groupString,
	mapString,
	wholeLine, tmpString : String;
	invLineDesc : CM_InvoiceLineDesc;
	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
	lineMapping		: CM_TranMapInvoiceLineMapping;
	groupType		: CM_TranMapInvoiceLineGroupType;
	groupTypeName,
	transTypeName,
	vesselCatName,
	cargotypeName,
	subtypeName,
	commodityName: String;
	tmctig : CMIF_TranMapController; //13/02/2017 cnwma1 TFS #2901
	transferType: CM_VoyageJobTransferType;
	vesselCategory: HMS_VesselCategory;
	parentObject : CM_Object;
	isToDoRsrc	: Boolean; // 24/05/2023	navkc1	CR 57927 Task 57923
	cargotype : CM_CargoType;
	subtype : CM_Product;
	comm : CM_Commodity;
begin
	self.myTMCController.getMappingHeaders();
	isVTMIS := self.isVTMIS();
	isWO := self.isWorkOrder(); // TFS 39518
	isEvent := self.isEvent(); // TFS 39518
	isBOL := self.isBOL();
	isToDoRsrc := self.isToDoResource(); // 24/05/2023	navkc1	CR 57927 Task 57923	
	
	tmpString := _line;
	tmpString := tmpString &amp; "," &amp; self.extractName.csvEncode();
	lineMapDict := self.myQuantityRangeMap.allTMInvoiceLineMappings;
	
	if self.myQuantityRangeMap.myChildQuantityMap &lt;&gt; null then    //13/02/2017 cnwma1 TFS #2901
		foreach tmctig in self.allGroupMembers do                 //13/02/2017 cnwma1 TFS #2901
			tmctig.exportCargoCSV(_file, tmpString);              //13/02/2017 cnwma1 TFS #2901
		endforeach;	
	else
		foreach lineMapping in lineMapDict do
			invLineDesc := lineMapping.myTMInvoiceLineDesc;
			groupType := lineMapping.myTMInvoiceLineGroupType;
			currKey := lineMapping.mapValue;
			vesselCategory := lineMapping.myVesselCategory;		// 19/6/18 MAP TFS38899
			transferType := lineMapping.myTransferType;			// 19/6/18 MAP TFS38899
		
			// ### TFS CR 65333 TASK 65334 08AUG2024 NAVAB1
			cargotype := lineMapping.myCargoType;
			subtype := lineMapping.myCargoSubtype;
			comm := lineMapping.myCommodity;

			if cargotype = null then	
				cargotypeName := CM_FinancialObject.Extract_Default;
			else
				cargotypeName := cargotype.abbreviation.String;
			endif;
			cargotypeName := cargotypeName &amp; Comma;

			if subtype = null then	
				subtypeName := CM_FinancialObject.Extract_Default;
			else
				subtypeName := subtype.code;
			endif;
			subtypeName := subtypeName &amp; Comma;

			if comm = null then	
				commodityName := CM_FinancialObject.Extract_Default;
			else
				commodityName := comm.code;
			endif;
			commodityName := commodityName &amp; Comma;
			
			
			mapString := self.getInvoiceMapping(currKey, invLineDesc, includesTranshipMethod);
			if isVTMIS then
				if currKey = CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT then
					inContract := "X,";
				else
					inContract := ",";
				endif;
			endif;

			
			
			
			
			if vesselCategory = null then						// 19/6/18 MAP TFS38899
				vesselCatName := Any_String;
			else
				vesselCatName := vesselCategory.code;
			endif;
			vesselCatName := vesselCatName &amp; Comma;
			if transferType = null then							// 19/6/18 MAP TFS38899
				transTypeName := Any_String;
			else
				transTypeName := transferType.id.String;
			endif;
			transTypeName := transTypeName &amp; Comma;
			/* PAR 34909 WAS
			groupString := groupType.name &amp; ",";
			wholeLine := tmpString &amp; "," &amp; inContract &amp; groupString &amp; invLineDesc.narration.csvEncode() &amp; mapString;
			NOW */
			if groupType = null then // PAR 34909
				groupTypeName:= "All"; // PAR 34909
			else
				groupTypeName:= groupType.name; // PAR 34909
			endif;
			groupString := groupTypeName &amp; ","; // PAR 34909
			narration := invLineDesc.narration.removeTabCrLfs();	// 36400 drop CrLf
			
			
			parentObject := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject; // TFS 41096
			
// TFS 41096			if self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_ServiceBroker) then	//13/02/2017 cnwma1 TFS #2901
			if parentObject.isKindOf(CM_ServiceBroker) then
				if parentObject.isKindOf(CM_ResourceServiceBroker) and isVTMIS then
					//wholeLine := tmpString &amp; Comma &amp; inContract &amp; vesselCatName &amp; transTypeName &amp; groupString &amp; narration.csvEncode() &amp; mapString;	// 19/6/18 MAP TFS38899
					wholeLine := tmpString &amp; Comma &amp; inContract &amp; cargotypeName &amp; subtypeName &amp; commodityName &amp;// ### TFS CR 65333 TASK 65334 08AUG2024 NAVAB1
														vesselCatName &amp; transTypeName &amp; groupString &amp; narration.csvEncode() &amp; mapString;	// 19/6/18 MAP TFS38899
				elseif isWO or isEvent or isBOL then // TFS 39518	//06 Nov 2019	NDL	TFS 47100
					wholeLine := tmpString &amp; "," &amp; groupString &amp; narration.csvEncode() &amp; mapString;  //13/02/2017 cnwma1 TFS #2901
				elseif parentObject.isKindOf(CM_TransServiceBroker) then // TFS 41096
					wholeLine := tmpString &amp; ",,," &amp; inContract &amp; transTypeName &amp; groupString &amp; narration.csvEncode() &amp; mapString;  // TFS 41096
				elseif parentObject.isKindOf(CM_MoveServiceBroker) then // TFS 41096
					wholeLine := tmpString &amp; ",,," &amp; inContract &amp; transTypeName &amp; groupString &amp; narration.csvEncode() &amp; mapString;  // TFS 41096
				elseif parentObject.isKindOf(CM_ToDoResourceServiceBroker) then // 24/05/2023	navkc1	CR 57927 Task 57923
					wholeLine := tmpString &amp; "," &amp; groupString &amp; narration.csvEncode() &amp; mapString;
				else
					//wholeLine := tmpString &amp; ",,," &amp; inContract &amp; vesselCatName &amp; transTypeName &amp; groupString &amp; narration.csvEncode() &amp; mapString;  //13/02/2017 cnwma1 TFS #2901
					wholeLine := tmpString &amp; ",,," &amp; inContract &amp; cargotypeName &amp; subtypeName &amp; commodityName &amp;// ### TFS CR 65333 TASK 65334 08AUG2024 NAVAB1
														vesselCatName &amp; transTypeName &amp; groupString &amp; narration.csvEncode() &amp; mapString;  //13/02/2017 cnwma1 TFS #2901
				endif;
// TFS 41096			elseif self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
			elseif parentObject.isKindOf(CM_DebtorMap) then
				if isWO or isEvent or isBOL then // TFS 39518	//06 Nov 2019	NDL	TFS 47100
					wholeLine := tmpString &amp; "," &amp; groupString &amp; narration.csvEncode() &amp; mapString; 
				elseif isVTMIS then // TFS 41096
					wholeLine := tmpString &amp; "," &amp; inContract &amp; cargotypeName &amp; subtypeName &amp; commodityName &amp;// ### TFS CR 65333 TASK 65334 08AUG2024 NAVAB1
														vesselCatName &amp; transTypeName &amp; groupString &amp; narration.csvEncode() &amp; mapString; // TFS 41096
				elseif isToDoRsrc then // 24/05/2023	navkc1	CR 57927 Task 57923
					wholeLine := tmpString &amp; "," &amp; groupString &amp; narration.csvEncode() &amp; mapString;
				else
					wholeLine := tmpString &amp; ",,," &amp; transTypeName &amp; groupString &amp; narration.csvEncode() &amp; mapString;  //13/02/2017 cnwma1 TFS #2901 TFS 41096added transfer type
				endif;
			else
				if isWO or isEvent or isVTMIS or isBOL then	//06 Nov 2019	NDL	TFS 47100
					wholeLine := tmpString &amp; "," &amp; inContract &amp; groupString &amp; narration.csvEncode() &amp; mapString;
				else
					wholeLine := tmpString &amp; "," &amp; transTypeName &amp; groupString &amp; narration.csvEncode() &amp; mapString;
				endif;
			endif;
			
			// internal option to extract tranship lines only
			if self.myTMCController.transhipOutputOnly then
				if includesTranshipMethod then
					hasTranship := true;
					_file.writeLine(wholeLine);
				elseif invLineDesc.narration = self.myTMCController.voidInvoiceLineDesc then
					voidString := wholeLine;
				endif;
			else
				_file.writeLine(wholeLine);
			endif;
		endforeach;
	endif;
	// write any VOID line as well for tranships, otherwise is lost on subsequent load
	if hasTranship and voidString &lt;&gt; null then
		_file.writeLine(voidString);
	endif;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_line" type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceMapping" id="537cbbae-ccad-4b36-8dfa-4b08108c1d7d">
        <source>getInvoiceMapping(i : Integer; _invLineDesc : CM_InvoiceLineDesc; _includesTranshipMethod : Boolean output) : String;
// 23659 add invoice mapping methods to extract
//  _includesTranshipMethod parameter added for internal extract of map entries affected by new tranship status
vars

	j, k, n, methodIdx : Integer;
	methodName : String;
	foundMethods,
	regMethodsArray : StringArray;
	str,
	result : String;
begin
	if i = 0 then
		return "";
	endif;

	regMethodsArray := self.myQuantityRangeMap.allRegisteredMethods;
	n := regMethodsArray.size;
	if n = 0 then
		return "";
	endif;

	create foundMethods transient;
	foreach j in 1 to self.myTMCController.maxMethods do
		foundMethods[j] := "";
	endforeach;

	foreach j in 1 to regMethodsArray.size do
		methodName := regMethodsArray[j];
		if i.bitAnd(2^(j-1)) &lt;&gt; 0 then
			k := self.getMethodOrder(methodName);
			if k &gt; 0 then
				foundMethods[k] := "X";
				if methodName = "isTranshipItem" then
					_includesTranshipMethod := true;
				endif;
			endif;
		endif;
	endforeach;

	foreach str in foundMethods do
		result := result &amp; "," &amp; str;
	endforeach;

	return result;
epilog
	delete foundMethods;
end;</source>
        <Parameter name="i" type="Integer"/>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <Parameter name="_includesTranshipMethod" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
