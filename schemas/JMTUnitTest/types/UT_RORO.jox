		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,RBK,RBK,DFBU,,,,DEBRV,DEBRV,D1131O,,0.0000,,OOTL0307378,Tranship,2063,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D1140O,,0.0000,,OOTL0307379,Remain On Board,2063,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add('C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D1141O,,0.0000,,OOTL0307380,Remain On Board,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,"SHSEAL101,SHSEAL103,SHSEAL105",,,12589,,,,0.000,VOYSHIP30738_1,,,0.0000,,,');
		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D1200OR,,0.0000,,OOTL0307370,Remain On Board,4262,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D1301OR,,0.0000,,OOTL0307393,Export,2200,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; utCreatedBy &amp; ",,,,4000,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D1901O,,0.0000,,OOTL0307390,Export,2200,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; utCreatedBy &amp; ",,,,4000,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D2100O,,0.0000,,OOTL0307397,Export,2200,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; utCreatedBy &amp; ",,,,4000,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D2101O,,0.0000,,OOTL0307398,Export,2200,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; utCreatedBy &amp; ",,,,4000,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D2101O,,0.0000,,OOTL0307399,Export,4262,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; utCreatedBy &amp; ",,,,4000,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D2238O,,0.0000,,OOTL0307400,Remain On Board,2063,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,14777,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D2708O,,0.0000,,OOTL0307401,Remain On Board,2063,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,14777,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		idx := 0;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
//			ediText :=	binaryMsg.uncompressToString();
			idx := idx + 1;
//			write ediText;
			self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error.");
		endforeach;

		foreach ediTI in ediDataActual.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName2);
				commitTransaction;
			elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName2);
				ediTI.setId(ediTI.id.replace('CANB', 'CANC'));
				ediTI.setId(ediTI.id.replace('OOTL0', 'OOTL2'));
				if ediTI.CM_EDICargoOnShipTI.imexStatus = "Tranship" then
					ediTI.CM_EDICargoOnShipTI.imexStatus := "Remain On Board";
				endif;	
				commitTransaction;
			endif;
		endforeach;
		beginTransaction;
		ediDataActual.setStatus(CM_EDIFile.EDI_STATUS_VERIFYING);
		commitTransaction;
		self.ediDBLoad(ediDataActual.ediFileArray.last);
		tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediDataActual.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr); //EDI_STATUS_VERIFIED_ERRORS, tempStr);

		foreach ediTI in ediDataProposed.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName3);
				commitTransaction;
			elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName3);
				ediTI.setId(ediTI.id.replace('CANB', 'CAND'));
				ediTI.setId(ediTI.id.replace('OOTL0', 'OOTL3'));
				if ediTI.CM_EDICargoOnShipTI.imexStatus = "Tranship" then
					ediTI.CM_EDICargoOnShipTI.imexStatus := "Remain On Board";
				endif;	
				commitTransaction;
			endif;
		endforeach;
		beginTransaction;
		ediDataProposed.setStatus(CM_EDIFile.EDI_STATUS_VERIFYING);
		commitTransaction;
		self.ediDBLoad(ediDataProposed.ediFileArray.last);
		tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediDataProposed.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	endif;
//return;
	// setup the add stowage advice twice here
	ediText := self.uROROStowAdvice30863(VoyageName2, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedStowAdvice[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);
	// setup the add stowage advice here
	ediText := self.uROROStowAdvice30863(VoyageName2, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedStowAdvice[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);
	
	// 14/09/2015 cnwmh5
	create tiSet transient;
	voyage1.getAllTrackedItems(tiSet);
	voyage2.getAllTrackedItems(tiSet);
	voyage3.getAllTrackedItems(tiSet);
	beginTransaction;
	foreach ti in tiSet do
		ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	endforeach;
	commitTransaction;
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete allTIs;
	delete theLCs;
	delete unloadArray;
	delete transhipController;
	delete theLines;
	delete tiSet;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;MichaelAllocChange&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tRORODeckPlanActulPrpsdRS" id="153f7e5b-23b9-4cd0-8f98-d132d007f4f4">
        <updating/>
        <source>tRORODeckPlanActulPrpsdRS() updating;
// cnwrs1
// Extract proposed and actual Deck Plan Par 29388
//07 Nov 2012	cnwrs1	Par 30688 OOTL layouts are missing for proposed
// cnwrs1 3 Dec 2012 - Par 30738 test for Ship RORO DECK PLAN check it 
//14 Dec 2012	cnwrs1	Par 30907	EDI RORO Proposed Deck Plan Location ID not position ID
//31 Dec 2012	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotaion 1X1
// 16/01/2013	cnwmh5	30863 - Add additional rotations
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
//
constants
	VoyageName1 = 'VOYSHIP30738_5';
	VoyageName2 = 'VOYSHIP30738_6';
	VoyageName3 = 'VOYSHIP30738_7';
	ShipName = 'JROSO';	//JROSO
	TestOperator = 'MSL';
	UserDefinedDeckPlan	= 'Unit Test Deck Plan';
	UserDefinedStowAdvice = 'Unit Test RORO Stow Advice';
	UserDefinedDeckPlanNoBOL	= 'Unit Test Deck Plan No BOL';
	ContainerId00 = "OOTL0307370";
	ContainerId01 = "OOTL0307371";
	ContainerId02 = "OOTL0307372";
	ContainerId03 = "OOTL0307373";
	ContainerId04 = "OOTL0307374";
	ContainerId05 = "OOTL0307375";
	ContainerId06 = "OOTL0307376";
	ContainerId07 = "OOTL0307377";
	ContainerId08 = "OOTL0307378";
	ContainerId09 = "OOTL0307379";
	ContainerId10 = "OOTL0307380";
	ContainerId11 = "OOTL0307381";
