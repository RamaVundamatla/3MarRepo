    <JadeMethod name="getDisplayString" id="5df1c1e5-f171-4d1a-a211-9d10fe5390e3">
        <source>getDisplayString() : String;
//10 March 2010	cnwml2
//+cnwml2 PAR22653

vars
	tmpStr : String;
begin
	//epr par 34935 29/9/14
	tmpStr := self.myBookingReference.bookingReference &amp; " " &amp; self.getAmountDisplay() &amp; " x ";
	if self.myCargoType.id = TI_CargoType_Container then
		if self.myISOType &lt;&gt; null then
			tmpStr := tmpStr &amp; self.myISOType.code;
		elseif self.isoTypeGroup &lt;&gt; null then
			tmpStr := tmpStr &amp; self.isoTypeGroup;
		endif;
	elseif self.myCargoType.isTrailer then  //epr par 33302 15/1/14
		tmpStr := tmpStr &amp; self.trailerType;
	else
		tmpStr := tmpStr &amp; self.cargoTypeDescr;
		if self.myProduct &lt;&gt; null then
			tmpStr := tmpStr &amp; " - " &amp; self.myProduct.code;
		endif;
	endif;
			
	return tmpStr;		
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="aa92a68c-874e-4f1e-9328-a57a53c12fef">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
	Created on 11 January 2008 by Debby Hutchison
	
	Purpose: Copied from CM_BookingRef for CCMS 1618

21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
18 Mar 2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
13 Jun 2013	cnwcs5		par 31670 - break bulk quantities (numOnsiteTIs)
10 Jul 2013	cnwcs5		par 31942 - add cargo remarks
09 Aug 2013	cnwdap1		PAR #32201 added Colour
04 Mar 2014	cnwdap1		PAR #33193 CCMS DPH 2285 Added purchaseOrder and serviceOrder
05 May 2016	cnwns1		TFS 488 - Multi Timezone Support
16 Jun 2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
26 Jul 2022 navtnr20 	ChangeRequest 54279: EUP - Extra Fields in the Road Gate Picker Screen
02 Nov 2022 navtnr20 	ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
28 Nov 2022	jlizm1		TFS 55280 Harmonized System Codes
28 Nov 2023 navma1		Defect 61553: MTN - Road Gate - Picker - Extra Criteria showing as ** not initialised **
18 Dec 2024 navbs1		Bug MTN-33650: CUX - Missing Additional Remarks pop up When Gated in Booking Item without reviewing cargo individually
*/
vars
	tmpStr			: String;
	grade 			: CM_MTGrade;
	iso				: CM_ISOType;
	book			: CM_BookingRef;
	str,
	type			: String;
	operator		: CM_Operator;
begin 
	if _attrName = ETRow_Grade 		   or 
		_attrName = ETRow_Grammage 		   or
	    _attrName = ETRow_ImexStatusString or
		_attrName = ETRow_RollingLength    or
		_attrName = ETRow_CargoGroup       or 
		_attrName = ETRow_ClientRef        or
		_attrName = ETRow_Diameter  	   or 
		_attrName = ETRow_Bol			   or
		_attrName = ETRow_CargoId		   or 
		_attrName = ETRow_ExtraCriteriaDisp or				//28.11.2023 navma1 #61553
		_attrName = ETRow_PickerRelReqRemarks1 or			//18.12.2024 navbs1 #33650
		_attrName = ETRow_PickerRelReqRemarks2 or			//18.12.2024 navbs1 #33650
		_attrName = ETRow_PickerCargoRemarks1 or			//18.12.2024 navbs1 #33650
		_attrName = ETRow_PickerCargoRemarks2 then			//18.12.2024 navbs1 #33650
		return null;
	
	elseif _attrName = ETRow_CargoRemarks then
		return self.remarks;
		
	elseif _attrName = ETRow_NumberPrenoted then
		return self.getPrenotedDisplay();
		
	elseif _attrName = ETRow_MyQuantity then
		if self.myProduct &lt;&gt; null then
			return self.productQuantity.asStringJMT;
		endif;
		return '0';
	
	elseif _attrName = ETRow_MyLengthString then
		return self.lengthString;
	
	elseif _attrName = ETRow_MyWidthString then
		return self.widthString;
		
	elseif _attrName = ETRow_MyHeightString then
		return self.heightString;	
		
	elseif _attrName = ETRow_MyLength or _attrName = ETRow_Length then			//28-07-2022 navtnr20 54279
		return self.length.roundedTo(0).asStringJMT;
		
	elseif _attrName = ETRow_MyWidth or _attrName = ETRow_Width then			//28-07-2022 navtnr20 54279
		return self.width.roundedTo(0).asStringJMT;
		
	elseif _attrName = ETRow_CarriageTempC or  _attrName = ETRow_TempC then
		return self.getTempString(false).asStringJMT;
		
	elseif _attrName = ETRow_CarriageTempF  or  _attrName = ETRow_TempF then
		return self.getTempString(true).asStringJMT;
		
	elseif _attrName = ETRow_Humidity then
		return self.getHumidityAsString();
		
	elseif _attrName = ETRow_Ventilation then
		return self.getVentilationAsString();							// PAR 17601. July 2008
		
	elseif _attrName = ETRow_MyHeight or _attrName = ETRow_Height  then	//28-07-2022 navtnr20 54279
		return self.height.roundedTo(0).asStringJMT;
		
	elseif _attrName = ETRow_MyVolume then
		return self.productVolume.roundedTo(0).asStringJMT;
		
	elseif _attrName = ETRow_MyDensity then
		return self.density.asStringJMT;
		
	elseif _attrName = ETRow_MyWeight then
		return self.productWeight.roundedTo(0).asStringJMT;	
		
	elseif _attrName = ETRow_Type then
		return self.typeString;
		
	elseif _attrName = ETRow_ShippingMarks then 
		return self.shippingMarks;
		
	elseif _attrName = ETRow_MarkNumber then		
		return self.markNumber;  
		
	elseif _attrName = ETRow_Humidity then
		return self.getHumidityAsString();
		
	elseif _attrName = ETRow_NumOnsiteTIs then  
		return self.getReceivedDisplay;		
		
	elseif _attrName = ETRow_Overunder then
		return self.getOverunderDisplay();		
	elseif _attrName = ETRow_AllTIHazards or _attrName = ETRow_AllTiHazards then		// 26.07.2022 navsrk20 54279
		return self.getTIHazardsDesc();

	elseif _attrName = ETRow_AllSpecialLifts then
		return self.getSpecialLiftDesc();
		
	elseif _attrName = ETRow_Mark then
		return self.shippingMarks;
		
	elseif _attrName = ETRow_TiRecieved then
		return self.getAssignedIDs();
		
	elseif _attrName = ETRow_MyProduct then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.description;
		endif;	
		return null;	
		
	elseif _attrName = ETRow_CreationDate then
		if self.createdTime &lt;&gt; null then
			return self.systemToLocalTime(self.createdTime).date().shortFormatJMT();// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		return null;	
		
	elseif _attrName = ETRow_CommodityEDI then
		return self.getEDICommodityDescription();
		
	elseif _attrName = ETRow_TotalWeight then
		if self.weight &lt;&gt; null then						
			return self.weight.roundedTo(0).asStringJMT;
		endif;
		return null;
		
	elseif _attrName = ETRow_IsControlledAtmosphere then	
		return self.getIsControlledAtmosphere.cnEcGetYesNo;
		
	elseif _attrName = ETRow_Oxygen then				
		return self.getOxygen.asNullOxygen;
		
	elseif _attrName = ETRow_CarbonDioxide then				
		return self.getCarbonDioxide.asNullCarbonDioxide;
		
	elseif _attrName = ETRow_CurtainsIn then				
		return self.getCurtainsIn.cnEcGetYesNo;
		
	elseif _attrName = ETRow_Quantity or _attrName = ETRow_QuantityTxt or
	       _attrName = ETRow_Expected then
		return self.getAmountDisplay();		
		
	elseif _attrName = ETRow_Released then
		return self.getReleasedDisplay();
		
	elseif _attrName = ETRow_MaxToRelease then
		return self.getResDetailMaxToRelease.asStringJMT;
		
	elseif _attrName = ETRow_Grade then
		grade:= self.getResDetailAvailGrade;
		
		if grade &lt;&gt; null then
			return grade.description;
		endif;
		return null;
	elseif _attrName = ETRow_IsoType then
		iso := app.myRoot.allISOTypes[self.isoType];
		
		if iso &lt;&gt; null then
			return iso.getTableDisplay;
		endif;
		return null;
	elseif _attrName = ETRow_IsoTypeCode then
		iso := app.myRoot.allISOTypes[self.isoType];
		
		if iso &lt;&gt; null then
			return iso.code.String;
		endif;
		return null;
	elseif _attrName = ETRow_IsoTypeGroup then
		return self.isoTypeGroup;
		
	elseif _attrName = ETRow_Clean then
		return self.clean.cnEcGetYesNo;
		
	elseif _attrName = ETRow_HeavyRated then
		if self.myReserveDetail &lt;&gt; null then
			return self.myReserveDetail.getHeavyRated.cnEcGetYesNo;
		endif;
		return null;
	elseif _attrName = ETRow_TrailerType then
		return self.trailerType;
		
	elseif _attrName = ETRow_GeneratorType then
		return self.generatorType;

	elseif _attrName = ETRow_SpecialStow then
		if self.mySpecialStow &lt;&gt; null then
			return self.mySpecialStow.description;
		endif;
		return "";
	
	elseif _attrName = ETRow_Summary then
		return self.summary;
		
	elseif _attrName = ETRow_Reconciled then
		return self.isComplete.getYes();		
	elseif _attrName = ETRow_ProductType then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.code;
		endif;
		return "";
	elseif _attrName = ETRow_CargoTypeDesc or  _attrName = ETRow_CargoType then
		return self.cargoTypeDescr;

	elseif _attrName = ETRow_BookingReference or				
		_attrName = ETRow_StatusDesc or
		_attrName = ETRow_IsStockBookingRef or
		_attrName = ETRow_IsStock or
		_attrName = ETRow_MyOperator or
		_attrName = ETRow_ConsigneeCode or
		_attrName = ETRow_ConsignorCode or
		_attrName = ETRow_DischargePort or
		_attrName = ETRow_DestinationPort or
		_attrName = ETRow_BookingRefRemarks or
		_attrName = ETRow_VesselCode or
		_attrName = ETRow_ShippingReference or
		_attrName = ETRow_CarrierReference or		// par 27460 cnwcs5
		_attrName = ETRow_FreightForwarderCode or	// par 31670
		_attrName = ETRow_EarliestRecLatestTS or	// par 31670
		_attrName = ETRow_CustomsAgent or			// par 31670
		_attrName = ETRow_AllLinkStkBookItemInfo or	// par 31670
		_attrName = ETRow_BookingStatus or
		_attrName = ETRow_CutoffEarliestTS or
		_attrName = ETRow_EarliestRecTS or
		_attrName = ETRow_VehicleBookingSlots or	//25 Nov 2014	NDL	Par 35284
		_attrName = ETRow_VoyageCode then																
		return self.myBookingReference.getDisplayStringForAttribute(_attrName, true);				

	elseif _attrName = ETRow_ReservedCount then
		return self.getReservedCount.asStringJMT();
		
	elseif _attrName = ETRow_AllLinkedExportBookings then
		return self.allLinkedExportBookings.size.String;
	
	elseif _attrName = ETRow_AllLinkedExpBookingsInfo then				
		foreach book in self.allLinkedExportBookings do
			if tmpStr = null then
				tmpStr := book.bookingReference;
			else
				tmpStr := tmpStr &amp; ", " &amp; book.bookingReference;
			endif;
		endforeach;
		
		return tmpStr;
		
	elseif _attrName = ETRow_PackAs then														
		return self.getPackAsString();
		
	elseif _attrName = ETRow_Tranship then													
		return self.myBookingReference.receiveAsTranship.getYesNo();
		
	elseif _attrName = ETRow_TranshipVoyage then										
		if self.myBookingReference.myTranshipVoyage &lt;&gt; null then
			return self.myBookingReference.myTranshipVoyage.code;
		endif;
		return null;
	elseif _attrName = ETRow_VolumeTotal then	
		return self.volume.asStringJMT;			
		
	elseif _attrName = ETRow_MyTranshipToPort then
		if self.myBookingReference.myTranshipToPort &lt;&gt; null then
			return self.myBookingReference.myTranshipToPort.code;
		endif;
		return null;
	elseif _attrName = ETRow_Colour then											// PAR #32201
		return self.colour;															// PAR #32201
		
	elseif _attrName = ETRow_PurchaseOrder then										// PAR #33193
		return self.purchaseOrder;													// PAR #33193
	elseif _attrName = ETRow_ServiceOrder then										// PAR #33193
		return self.serviceOrder;													// PAR #33193
		
	elseif _attrName = ETRow_StopsToApply then	//15 Sep 2016	NDL	TFS 2644 / 2001
		if self.myBookingRefItemActions &lt;&gt; null then
			return self.myBookingRefItemActions.getStopsList(", ",false);
		endif;
		return null;
		
	elseif _attrName = ETRow_TaskToApply then	//15 Sep 2016	NDL	TFS 2644 / 2001	
		if self.myBookingRefItemActions &lt;&gt; null then
			return self.myBookingRefItemActions.getTaskList(", ",false);
		endif;
		return null;
		
	elseif _attrName = ETRow_PickerType then	//15 Mar 2017	NDL	TFS 3758
		return 'Booking Item';
		
	elseif _attrName = ETRow_PickerDescription then	//15 Mar 2017	NDL	TFS 3758
		return self.getShortDisplay;
			
	elseif _attrName = ETRow_PickerId or _attrName = ETRow_ItemId then		//15 Mar 2017	NDL	TFS 3758
		return self.myBookingReference.bookingReference;
		
	elseif _attrName = ETRow_Operator then									//15 Mar 2017	NDL	TFS 3758
		operator := self.myBookingReference.myOperator;
		if operator &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then		// TFS 53362
				return operator.description;								// TFS 53362
			else															// TFS 53362
				return operator.code;
			endif;															// TFS 53362
		else
			return 'n/a';
		endif;
		
	elseif _attrName = ETRow_Voyage then	//15 Mar 2017	NDL	TFS 3758
		if self.myBookingReference.myVoyage &lt;&gt; null then
			return self.myBookingReference.myVoyage.code;
		endif;
		return 'N/A';
		
	elseif _attrName = ETRow_DateTime then	//15 Mar 2017	NDL	TFS 3758
		if self.myBookingReference.myVoyage &lt;&gt; null then
			return self.myBookingReference.myVoyage.departedDT.asStringJMT();
		endif;
		return null;
		
	elseif _attrName = ETRow_Booking then	//15 Mar 2017	NDL	TFS 3758	
		if self.myBookingReference &lt;&gt; null then
			return self.myBookingReference.bookingReference;
		endif;
		return null;
		
	elseif _attrName = ETRow_BookingItem then	//15 Mar 2017	NDL	TFS 3758																
		return self.getShortDisplay;
		
	elseif _attrName = ETRow_Received then	//15 Mar 2017	NDL	TFS 3758																
		return self.getReceivedDisplay;
	
	elseif _attrName = ETRow_Prenoted then	//15 Mar 2017	NDL	TFS 3758																
		return self.getPrenotedDisplay;
		
	elseif _attrName = ETRow_Released then	//15 Mar 2017	NDL	TFS 3758																
		return self.getReleasedDisplay;
		
	elseif _attrName = ETRow_Weight then	//15 Mar 2017	NDL	TFS 3758
		return self.weight.asStringWeightJMT;

	elseif _attrName = ETRow_Commodity then
		return self.commodity;
	elseif _attrName = ETRow_Destination then
		return self.myBookingReference.destinationPort;
	elseif _attrName = ETRow_DischargePort then
		return self.myBookingReference.dischargePort;
	elseif _attrName = ETRow_InstructionInternal then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.internalInstructions.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionExternal then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.externalInstruction.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionCode then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionCode();
		endif;
		return null;
	elseif _attrName = ETRow_InstructionDesc then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionDesc();
		endif;
		return null;

	elseif _attrName = ETRow_HsCode then				// TFS 55280
		return self.getHSCode();
	elseif _attrName = ETRow_HsCodeDescription then		// TFS 55280
		return self.getHSDescription();
	
	/*Always Add Before this one */
	elseif _attrName.isMeasurementType then											// PAR #31155
		_attrName.getRowNameMeasureType(str, type);									// PAR #31155
		
		return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #31155
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIBookingRefTI" id="f3a2d23a-58b3-4d0d-b5c0-6221576c7920">
        <source>getEDIBookingRefTI():CM_EDIBookingRefTI;
// --------------------------------------------------------------------------------
// Created:		30 May 2008 by cnwdad1
//
// Purpose:		Returns a reference to the EDI Booking Reference TI from which the
//				receiver (and it's parent) originated.
//
// Parameters:	None
//
// Returns:		A reference to the EDI Booking Reference TI, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	bookRefObj	: CM_BookingRef;
	
begin
	bookRefObj	:=	self.myBookingReference;
	
	if bookRefObj &lt;&gt; null then
		return bookRefObj.myEDIBookingRefTI;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_EDIBookingRefTI"/>
    </JadeMethod>
    <JadeMethod name="getEDICommodityDescription" id="ca24ae4e-2133-4bd9-a4a9-c78afb0c0525">
