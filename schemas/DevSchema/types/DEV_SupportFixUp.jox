    <JadeMethod name="clearContactDetails" id="df426f27-3ff5-4e77-b9f7-ca73a2637f32">
        <source>clearContactDetails();

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars

begin
	self.txtContact.text 		:= "";
	self.txtTFS.text	 		:= "";
	self.cmbCustomer.listIndex 	:= -1;
	self.txtDescription.text 	:= "";
	self.cmbTopic.listIndex 	:= -1;
	self.txtRelease.text 		:= "";
	self.cmbOwned.listIndex 	:= -1;
	self.txtOpened.text 		:= "";
	self.chkKPI1.value 	 		:= false;
	self.txtKPI1FailedBy.text	:= "";
	self.chkKPI2.value 	 		:= false;
	self.txtKPI2FailedBy.text	:= "";
	self.cmbState.clear;
	self.cmbState.listIndex 	:= -1;
	self.txtStateType.text 		:= "";
	self.txtStateStart.text 	:= "";
	self.txtStateEnd.text 		:= "";
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cmbContact_click" id="0217cbd8-56dc-4ec6-9b5d-61857984a76f">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbContact_click(combobox: ComboBox input) updating;

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	contactNum : String;
	
begin
	contactNum := combobox.text;
	if contactNum = "" or not contactNum.isInteger then
		return;
	endif;

	self.myCurrentContact := self.myRoot.allContacts.getAtKey(contactNum.Integer);
	if self.myCurrentContact = null then
		return;
	endif;
	
	self.loadContactDetails();
	
	self.cmbState.clear;
	self.cmbState.listCollection(self.myCurrentContact.allStates, true, 0);
	self.cmbState.listIndex := 1;
	
	self.statusLine1.caption := "";
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbState_click" id="e601da3f-5a7a-40a2-a45a-f932090e6505">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbState_click(combobox: ComboBox input) updating;

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	state : DEV_SupportState;
	dateString : String;
	
begin
	state := combobox.listObject.DEV_SupportState;
	if state = null then
		return;
	endif;
	
	self.txtStateType.text := state.type;
	dateString 	:= state.startTS.date.format("dd/MM/yyy") &amp; " " &amp; state.startTS.time.format("HH:mm");
	self.txtStateStart.text := dateString;
	
	if state.endTS.isValid then
		dateString 	:= state.endTS.date.format("dd/MM/yyy") &amp; " " &amp; state.endTS.time.format("HH:mm");
	else
		dateString 	:= "";
	endif;
	self.txtStateEnd.text := dateString;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbState_displayEntry" id="3b94090e-a67a-4542-893e-96b43534e0c5">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbState_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars

begin
	return obj.DEV_SupportState.type;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="035a6051-67ed-4f78-9a88-a595130c49b5">
        <source>doUpdate();

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	contact : DEV_SupportContact;
	state	: DEV_SupportState;
	error,
	kpiRemaining : String;
	
begin
	self.statusLine1.caption := '';
	error := self.doValidate;
	if error &lt;&gt; "" then
		self.statusLine1.caption := error;
		return;
	endif;
	
	contact := self.myCurrentContact;
	if contact = null then
		return;
	endif;
	
	beginTransaction;
		
	contact.number 			:= self.txtContact.text.Integer;
	contact.tfsNumber		:= self.txtTFS.text.Integer;
	contact.customer		:= self.cmbCustomer.text;
	contact.myTimezone		:= self.getTimezoneForCust(self.cmbCustomer.text);
	contact.description		:= self.txtDescription.text;
	contact.owner			:= self.cmbOwned.text;
	contact.releaseOpened	:= self.txtRelease.text;
	contact.topic			:= self.cmbTopic.text;
	contact.openedTS		:= self.txtOpened.text.TimeStamp;
	contact.kpi1Done		:= self.chkKPI1.value;
	contact.kpi2Done		:= self.chkKPI2.value;
	
	// recalculate kpiFailedBy
	if self.txtKPI1.text.TimeStamp.isValid then
		kpiRemaining := self.getKPIFailedBy(contact, self.txtKPI1.text.TimeStamp, 1);
		if kpiRemaining.Real &lt;= 0 then
			contact.kpi1FailedBy := kpiRemaining;
		endif;
	endif;
	if self.txtKPI2.text.TimeStamp.isValid then
		kpiRemaining := self.getKPIFailedBy(contact, self.txtKPI2.text.TimeStamp, 2);
		if kpiRemaining.Real &lt;= 0 then
			contact.kpi2FailedBy := kpiRemaining;
		endif;
	endif;
				
	state := self.cmbState.listObject.DEV_SupportState;
	if state &lt;&gt; null then
		state.type	 	:= self.txtStateType.text;
		state.startTS 	:= self.txtStateStart.text.TimeStamp;
		if self.txtStateEnd.text &lt;&gt; "" then
			state.endTS 	:= self.txtStateEnd.text.TimeStamp;
		endif;
	endif;
	
	commitTransaction;	
	
	self.statusLine1.caption := 'Update Successful';
end;</source>
    </JadeMethod>
    <JadeMethod name="doValidate" id="826282be-03df-4127-a805-d8f211fd5531">
        <source>doValidate(): String;

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	parsys, tfs, customer, description, owner, opened, startTS, endTS, type, topic, release : String;
	state : DEV_SupportState;

begin
	parsys := self.txtContact.text;
	if not (parsys.isInteger and parsys.Integer &gt; 30000 and parsys.Integer &lt; 100000) then
		return ("bad PAR number (" &amp; parsys &amp; ")");
	endif;
	
	tfs := self.txtTFS.text;
	if tfs &lt;&gt; "" and not (tfs.isInteger and tfs.Integer &gt; 1000 and tfs.Integer &lt; 10000) then
		return ("bad TFS number (" &amp; tfs &amp; ")");
	endif;
	
	customer := self.cmbCustomer.text;
	if customer.length &lt; 2 or customer.length &gt; 4 then
		return ("bad customer (" &amp; customer &amp; ")");
	else
		if self.getTimezoneForCust(customer) = null then
			return ("unknown customer (" &amp; customer &amp; ")");
		endif;
	endif;
	
	owner := self.cmbOwned.text;
	if owner.trimBlanks.length = 0 then
		return "owner required";
	endif;
	
	description := self.txtDescription.text;
	if description.trimBlanks.length = 0 then
		return "description required";
	endif;
	
	topic := self.cmbTopic.text;
	if topic.trimBlanks.length = 0 then
		return "topic required";
	endif;
	
	release := self.txtRelease.text;
	if release.trimBlanks.length = 0 then
		return "release required";
	endif;
	
	opened := self.txtOpened.text;
	if not opened.TimeStamp.isValid then
		return ("invalid timestamp (" &amp; opened &amp; ")");
	endif;
	
	state := self.cmbState.listObject.DEV_SupportState;
	if state &lt;&gt; null then
		type := self.txtStateType.text;
		if type.trimBlanks.length = 0 then
			return "state type required";
		endif;
		
		startTS := self.txtStateStart.text;
		if not startTS.TimeStamp.isValid then
			return ("invalid timestamp (" &amp; startTS &amp; ")");
		endif;
		
		endTS := self.txtStateEnd.text;
		if endTS &lt;&gt; "" and not endTS.TimeStamp.isValid then
			return ("invalid timestamp (" &amp; endTS &amp; ")");
		endif;
	endif;
	
	return "";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKPIFailedBy" id="9a9e1bee-792a-40fe-a5ba-2e01a27d4bce">
        <source>getKPIFailedBy(_contact : DEV_SupportContact; _endTS : TimeStamp; _kpi : Integer): String;

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	state 			: DEV_SupportState;
	duration		: Integer;
	timeRemaining	: Decimal[10,1];
	
begin
	// need to work out the business-hours active support time between opened and _endTS
	// if this exceeds the first KPI limit, return the amount the KPI failed by (in "1.1h" format)

	foreach state in _contact.allStates do
		if state.type = 'Active Support' or state.type = 'Architect/Dev Support' then
			duration := duration + state.getDurationInMinutes(_endTS);
		endif;
	endforeach;

	if _kpi = 1 then
		timeRemaining := (4*60) - duration;
	else
		timeRemaining := (48*60) - duration;
	endif;
	timeRemaining := timeRemaining/60;
	
	if timeRemaining &lt; 0 then
		return timeRemaining.String &amp; "h";
	else
		return "";
	endif;
end;</source>
        <Parameter name="_contact" type="DEV_SupportContact"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_kpi" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimezoneForCust" id="eb2f98b0-fda4-425d-8130-95e3bf7e0b3a">
        <source>getTimezoneForCust(_cust : String): DEV_SupportTimezone;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars
	root 		: DEV_SupportRoot;
	timezone 	: DEV_SupportTimezone;
	
begin
	root := DEV_SupportRoot.firstInstance;
	
	foreach timezone in root.allTimezones do
		if timezone.customers.pos(_cust,1) &gt; 0 then
			return timezone;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_cust" type="String"/>
        <ReturnType type="DEV_SupportTimezone"/>
    </JadeMethod>
    <JadeMethod name="load" id="92b6d276-70e8-4353-a3b6-b6cd494be845">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*
Date			Who		Reason
27 July 2016	cnwar2	Initial creation

*/
vars
	contact : DEV_SupportContact;
	
begin
	self.centreWindow();
	
	self.myRoot := DEV_SupportRoot.firstInstance();
	
	self.optOpen.value := true;
	foreach contact in self.myRoot.allContacts where contact.getCurrentState &lt;&gt; 'Closed' do
		self.cmbContact.addItem(contact.number.String);
