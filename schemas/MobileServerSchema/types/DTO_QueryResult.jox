    <JadeMethod name="cloningCriteriaHoldersForQuery" id="50e2d535-752d-4289-88f0-508e9dd7a178">
        <source>cloningCriteriaHoldersForQuery( _selectorQuery : CM_MenuUserQuery; _criteriaHoldersForExecQuery : ObjectArray input );
// ----------------------------------------------
// Created:	08 May 2008 by cnwvu1
// ----------------------------------------------

vars
	realCriteriaLineHolder,
	criteriaLineHolder		: CM_QueryCriteriaLineHolder;
	realCriteriaLine,
	criteriaLine			: CM_SelectorCriteriaLine;
	
begin

	_criteriaHoldersForExecQuery.clear();
	
	foreach realCriteriaLineHolder in _selectorQuery.allCriteriaLineHolders do
	
		criteriaLineHolder := realCriteriaLineHolder.cloneSelf(true);
		_criteriaHoldersForExecQuery.add( criteriaLineHolder );
		criteriaLineHolder.setForUpdate( realCriteriaLineHolder );	
		
		foreach realCriteriaLine in realCriteriaLineHolder.allCriteriaLines do
			create criteriaLine transient; 
			criteriaLine.setMyCriteriaLineHolder( criteriaLineHolder );
			criteriaLine.setForUpdateForRT( realCriteriaLine );	
		endforeach;	
		
	endforeach;
	
	
end;
</source>
        <Parameter name="_selectorQuery" type="CM_MenuUserQuery"/>
        <Parameter name="_criteriaHoldersForExecQuery" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getResultString" id="413cc4e8-6b9b-4d0f-a932-8cb1c7e8478d">
        <source>getResultString( _obj : Object; _selectorQuery : CM_MenuUserQuery) : String;
// ----------------------------------------------
// Created:	08 May 2008 by cnwvu1
// ----------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------------------
// 14/01/2013	cnwdap1		PAR #32731 Measurements not showing correctly in queries run in vehicle apps
vars
	propDict	: CM_QueryPropertyDict;
	attrName,
	propValStr,
	rowStr		: String;
	queryDef	: CM_QueryDefinition;
	propArray	: StringArray;
	queryProp	: CM_QueryProperty;
	propVal		: Any;
	oper 		: CM_QueryOperator;
	propName	: String;							// PAR #32731
	pos, 											// PAR #32731
	revPos		: Integer;							// PAR #32731
	measureStr	: String;							// PAR #32731
	measure,										// PAR #32731
	default		: CM_MeasurementType;				// PAR #32731
	
begin
	
	queryDef	:= app.myRoot.allQueryDefinitionObjects[_selectorQuery.getType, _selectorQuery.queryMode];
	propDict	:= queryDef.allQueryProperties;
	propArray	:= _selectorQuery.allVisibleColumns;

	foreach attrName in propArray do
		measureStr := null;														// PAR #32731
		measure := null;														// PAR #32731
		if attrName.isMeasurementType then										// PAR #32731
			pos := attrName.pos("_", 1);										// PAR #32731
			revPos := attrName.reversePos("_");									// PAR #32731
			measureStr := attrName[revPos+1:end];								// PAR #32731
			measure := app.myRoot.allMeasurementTypesByShortName[measureStr];	// PAR #32731
			propName := attrName[pos+1:revPos-pos-1];							// PAR #32731
		else																	// PAR #32731
			propName := attrName;												// PAR #32731
		endif;																	// PAR #32731
		//queryProp := propDict[attrName];										// PAR #32731
		queryProp := propDict[propName];										// PAR #32731
		
		if queryProp = null then
			propValStr := 'Could not retreive ' &amp; attrName;
		elseif (CM_QStringLookupProperty.hasInstance(queryProp)) then	//no need to translate
			propValStr := _obj.getPropertyValue(queryProp.propertyName).String;
		else
			oper := null;
			propVal := queryProp.getValueForObject(_obj,null);
			
			if propVal = null
			and (not queryProp.displayNull)
			then
				propValStr := null;
			else
				propValStr := queryProp.translateToDisplayValue(propVal);
				// For measurement types, propValStr is now in whatever unit the system default is.			// PAR #32731
				// We now need to convert that to whatever unit we're displaying here						// PAR #32731
				if measure &lt;&gt; null then																		// PAR #32731
					propValStr := propVal.String;															// PAR #32731
					default := app.getDefaultMeasurementForType(measure.measurementType);					// PAR #32731
					propValStr := app.convertMeasurementFromTo(default.shortName, measureStr, propValStr.Decimal).String;	// PAR #32731
					propValStr := measure.removeDecimalZeros(propValStr);									// PAR #32731
				endif;																						// PAR #32731
			endif;
		endif;
		
		rowStr := rowStr &amp; propValStr &amp; Tab;
	endforeach;
	
	return rowStr;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_selectorQuery" type="CM_MenuUserQuery"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="queryRun" id="80c28473-874f-43db-803b-0b7af99f2add">
        <updating/>
        <source>queryRun( _dtoQueryDef : DTO_QueryDefinitionRT; _querySelectorOid : String ) updating;
// ----------------------------------------------
// Created:	08 May 2008 by cnwvu1
// ----------------------------------------------

vars
	selectorQuery				: CM_MenuUserQuery;
	criteriaHoldersForQueryArr	: ObjectArray;
	dtoCriteriaLineHolder		: DTO_QueryCriteriaLineHolderRT;
	criteriaLineHolderForQuery	: CM_QueryCriteriaLineHolder;
	obj							: Object;
	enqController				: CM_EnquiryController;
	i 							: Integer;
	queryType					: Integer;
	
begin

	_dtoQueryDef.validateForQueryRun( _querySelectorOid, selectorQuery );
	if app.myPassport.hasErrors() then
		return;
	endif;

	create criteriaHoldersForQueryArr transient;	// for the query execute
	
	// enquiryController creation
	app.myQAFilter.createEnqControllerForMode( selectorQuery.queryMode, selectorQuery.getType, enqController );
	create enqController.allObjects as CM_ObjectSet transient;
	self.cloningCriteriaHoldersForQuery( selectorQuery, criteriaHoldersForQueryArr );
	// the limit for the number of result rows
	// checking max rows for RT Query 
	enqController.numItemsFoundLimit	:= app.getMyTerminalDO_NOT_USE.myRTVehicleConfig.maxNumberQueryResults; //epr CCMS 1099 25/5/10 getConfig( MaxRowsForRTQueries ).Integer;
	if enqController.numItemsFoundLimit = null then
		app.raiseCMException( ERR_SetupMaxRowsForRTQueries, null, null ); // need to setup Max Number of Rows for Queries in the Terminal Configuration
		return;
	endif;
	
	i := 0;
	foreach dtoCriteriaLineHolder in _dtoQueryDef.allQueryCriteriaLineHolders do
	
		i := i + 1;
		criteriaLineHolderForQuery := criteriaHoldersForQueryArr[i].CM_QueryCriteriaLineHolder;
		dtoCriteriaLineHolder.putSearchingValuesFromRT( criteriaLineHolderForQuery );

		if app.myPassport.hasErrors() then
			return;
		endif;
		
	endforeach;

	// execute query
	
	
	queryType := selectorQuery.getType; //23 Nov 2009	NDL	CCMS 1028
	foreach obj in criteriaHoldersForQueryArr do
	
		criteriaLineHolderForQuery := obj.CM_QueryCriteriaLineHolder;
		enqController.myCriteriaLineHolder := criteriaLineHolderForQuery;
		create enqController.allObjects as CM_ObjectSet transient;

		enqController.doQuery( app.myRoot.allQueryDefinitionObjects[queryType, selectorQuery.queryMode] );
		
	endforeach;
	
	// put query results into self
	self.setForCreate( selectorQuery, enqController );
	
epilog
	delete criteriaHoldersForQueryArr;
	delete enqController;
	
end;
</source>
        <Parameter name="_dtoQueryDef" type="DTO_QueryDefinitionRT"/>
        <Parameter name="_querySelectorOid" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="15dbcc59-6990-4523-a28d-7a6ff07131c3">
        <updating/>
        <source>setForCreate( _selectorQuery : CM_MenuUserQuery; _enqController : CM_EnquiryController ) updating;
// ----------------------------------------------
// Created:	08 May 2008 by cnwvu1
//
// Purpose:	Puts all query data into the object
// ----------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/01/2013	cnwdap1		PAR #32731 Measurements not showing correctly in queries run on the vehicle apps
vars

	headingStr		: String;
	any				: Any;
	terminal		: CM_Terminal;
	currentCol		: Integer;
	termStr,
	attrName		: String;
	queryProp		: CM_QueryProperty;
	propDict		: CM_QueryPropertyDict;
	theCargoBOLType	: CM_CargoBOLType;
	queryDef		: CM_QueryDefinition;
	i				: Integer;
	pos, revPos		: Integer;									// PAR #32731
	niceName		: String;									// PAR #32731
	measure			: String;									// PAR #32731
	
begin
	self.queryName := _selectorQuery.heading;
	
	terminal:= app.getMyTerminalDO_NOT_USE();
	theCargoBOLType := app.myRoot.allCargoTypesById[_selectorQuery.queryMode];
	queryDef	:= app.myRoot.allQueryDefinitionObjects[_selectorQuery.getType, _selectorQuery.queryMode];
	propDict	:= queryDef.allQueryProperties;
	
	// columnHeadings
	self.columns := _selectorQuery.allVisibleColumns.size();
	
	if self.columns = 0 then
		app.raiseCMException(ERR_NoColumnsInColumnOrganizer, null, null);
		return;
	endif;
	
	headingStr	:= null;
	i := 0;
	self.sortTypes[self.columns] := 0;	// 26/01/2012 cnwar2 #28914
	
	foreach attrName in _selectorQuery.allVisibleColumns do
		i := i + 1;		// 26/01/2012 cnwar2 #28914 - moved up so always incremented
		measure := null;										// PAR #32731
		if attrName.isMeasurementType then						// PAR #32731
			pos := attrName.pos("_", 1);						// PAR #32731
			revPos := attrName.reversePos("_");					// PAR #32731
			measure := attrName[revPos+1:end];					// PAR #32731
			attrName := attrName[pos+1:revPos-pos-1];			// PAR #32731
		endif;													// PAR #32731
		queryProp := propDict[attrName];
		
		if queryProp = null then
			continue;
		endif;
		
		termStr := app.getTerminologyAlternate(theCargoBOLType, terminal, queryProp.niceName, CM_TermExpressionSingular, queryProp.niceName);
		if measure &lt;&gt; null then									// PAR #32731
			termStr := termStr &amp; Space &amp; measure;				// PAR #32731
		endif;													// PAR #32731
		headingStr := headingStr &amp; termStr &amp; Tab;
		//i := i + 1;
		self.sortTypes[i] := queryProp.getSortType();
	endforeach;
	
	self.columnHeadings := headingStr;
	
	if _enqController.breakOutOfSearch then
		self.searchWarningMessage := app.getErrorString1(ERR_MaxRowsExceededForRTQuery, _enqController.numItemsFoundLimit.asStringJMT());
	endif;
	
	// allData
	foreach any in _enqController.allObjects do
		self.allData.add(self.getResultString(any.Object, _selectorQuery));
	endforeach;
end;</source>
        <Parameter name="_selectorQuery" type="CM_MenuUserQuery"/>
        <Parameter name="_enqController" type="CM_EnquiryController"/>
    </JadeMethod>
</Class>
