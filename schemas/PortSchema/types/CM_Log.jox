    <JadeMethod name="ageBlock" id="e03393b0-0533-4373-8274-e7f8e751910b">
        <methodInvocation>mapping</methodInvocation>
        <source>ageBlock(set: Boolean; _value: Integer io) mapping;

vars
	logAge					: Integer;
	jrwTrans				: CM_JRWTransient;
	referenceDate			: Date;		
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	//13 Sep 2018	NDL	- Clean-up for delete
	if app = null or app.myQAFilter = null then
		_value := null;
		return;
	endif;
	
	jrwTrans := app.myQAFilter.allJRWTransients.first;
	if jrwTrans =null then
		_value := null;
		return;
	endif;
	//avoid division by zero
	if jrwTrans.blockLength = null then
		_value := null;
		return;
	endif;
	
	if jrwTrans.ageType = TI_AGE_FELLDATE then
		referenceDate := self.fellDate;
	elseif jrwTrans.ageType = TI_AGE_MATCHDATE then
		if self.myReceivalBOL &lt;&gt; null then	//13 Sep 2018	NDL	- Clean-up for delete
			referenceDate := self.myReceivalBOL.matchTime.date;
		endif;
	else //default to TI_AGE_RECEIVEDDT
		referenceDate := self.receivedDT.date;	
	endif;
	
	logAge := (jrwTrans.baseDate - referenceDate) + jrwTrans.blockLength;
	_value := (logAge / jrwTrans.blockLength).Integer;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="beginUpdate" id="6f6ab478-3321-474e-8917-2d086f52fd1b">
        <updating/>
        <source>beginUpdate(_tiUpdateCntrlr: CMIF_TIUpdateController input; _passport : CM_Passport input) updating, protected;
//-----------------------------------------
//Created: November 2002 By: cnwgd1
//-----------------------------------------
vars

begin
	
	if self.isTransient then
		return;
	endif;
	
	inheritMethod(_tiUpdateCntrlr, _passport);
	_tiUpdateCntrlr.sedMean := self.sedMean;
end;</source>
        <access>protected</access>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
