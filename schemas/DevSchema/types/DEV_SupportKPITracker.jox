    <JadeMethod name="validateNew" id="6b4c00df-3516-4ce4-88f5-3384bffd0c15">
        <source>validateNew(): Boolean;

/*
Date			Who		Reason
08 July 2016	cnwar2	Initial creation

*/
vars
	parsys, tfs, customer, description, owner, opened, errorStr : String;
	returnValue : Boolean;

begin
	// check details on last row of table, if bad raise error and return false
	
	parsys 		:= self.tblContacts.accessCell(tblContacts.rows,1).text;
	tfs			:= self.tblContacts.accessCell(tblContacts.rows,2).text;
	customer	:= self.tblContacts.accessCell(tblContacts.rows,3).text;
	description	:= self.tblContacts.accessCell(tblContacts.rows,4).text;
	owner		:= self.tblContacts.accessCell(tblContacts.rows,5).text;
	opened		:= self.tblContacts.accessCell(tblContacts.rows,6).text;
	
	returnValue := true;
	
	if not (parsys.isInteger and parsys.Integer &gt; 30000 and parsys.Integer &lt; 100000) then
		errorStr	:= errorStr &amp; "bad PAR number (" &amp; parsys &amp; "), ";
		returnValue := false;
	endif;
	
	if tfs &lt;&gt; "" and not (tfs.isInteger and tfs.Integer &gt; 1000 and tfs.Integer &lt; 10000) then
		errorStr	:= errorStr &amp; "bad TFS number (" &amp; tfs &amp; "), ";
		returnValue := false;
	endif;
	
	if customer.length &lt; 2 or customer.length &gt; 4 then
		errorStr	:= errorStr &amp; "bad customer (" &amp; customer &amp; "), ";
		returnValue := false;
	else
		if self.getTimezoneForCust(customer) = null then
			errorStr	:= errorStr &amp; "unknown customer (" &amp; customer &amp; "), ";
			returnValue := false;
		endif;
	endif;
	
	if owner.trimBlanks.length = 0 then
		errorStr	:= errorStr &amp; "owner required, ";
		returnValue := false;
	endif;
	
	if description.trimBlanks.length = 0 then
		errorStr	:= errorStr &amp; "description required, ";
		returnValue := false;
	endif;
	
	if not opened.TimeStamp.isValid then
		errorStr	:= errorStr &amp; "invalid timestamp (" &amp; opened &amp; "), ";
		returnValue := false;
	endif;
	
	if not returnValue then
		app.msgBox(errorStr, 'Error', 48);
	endif;
	
	return returnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
