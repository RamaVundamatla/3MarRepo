<GUIClass name="MB_RTButton" id="8aeab3bb-a15d-4bc6-a10f-71ba2f1e1365">
    <superclass name="Button"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="windowCreated" id="98b7eb9a-512d-422b-9eae-663bc6e334a4">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		09 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	buttonColor	: Integer;
	
begin
	inheritMethod(cntrl, persistCntrl);
	
	buttonColor.mbSetColorFromRGB(172, 211, 115);
	self.backColor	:=	buttonColor;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
