    <JadeMethod name="setMvmntPilotDetails" id="18ea3564-d3b3-4ff0-a046-eea23b5eb803">
        <updating/>
        <source>setMvmntPilotDetails(_fromMovement : HMS_VoyageMovement; _fromWorkingMovement : CMIF_HMS_WorkingMovement) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
 	newMvmntPilotDetails,
 	tmpMvmntPilotDetails : HMS_MovementPilotDetails;
begin
	if _fromWorkingMovement &lt;&gt; null then
	 	foreach tmpMvmntPilotDetails in _fromWorkingMovement.allMovementPilotDetails do
	 		create newMvmntPilotDetails transient;
			newMvmntPilotDetails.setMyPilot(tmpMvmntPilotDetails.myPilot);
			newMvmntPilotDetails.setMyPilotLaunch(tmpMvmntPilotDetails.myPilotLaunch);
			self.allMovementPilotDetails.add(newMvmntPilotDetails);
		endforeach;
 	elseif _fromMovement &lt;&gt; null then
	 	foreach tmpMvmntPilotDetails in _fromMovement.allMovementPilotDetails do
			create newMvmntPilotDetails transient;
			newMvmntPilotDetails.setMyPilot(tmpMvmntPilotDetails.myPilot);
			newMvmntPilotDetails.setMyPilotLaunch(tmpMvmntPilotDetails.myPilotLaunch);
			self.allMovementPilotDetails.add(newMvmntPilotDetails);
		endforeach;	
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Movement Pilot Details created');
	endif;
epilog

end;</source>
        <Parameter name="_fromMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_fromWorkingMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="setMyBollards" id="a11e099c-d170-4a31-9c6b-2a006aa2f0b0">
        <updating/>
        <source>setMyBollards(_myBowBollard: HMS_Resource; _mySternBollard: HMS_Resource; _myBridgeBollard: HMS_Resource) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2022	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards


*/

vars

begin
	self.myBowBollard	:=	_myBowBollard;
	self.myBridgeBollard:=	_myBridgeBollard;
	self.mySternBollard	:=	_mySternBollard;

epilog

end;</source>
        <Parameter name="_myBowBollard" type="HMS_Resource"/>
        <Parameter name="_mySternBollard" type="HMS_Resource"/>
