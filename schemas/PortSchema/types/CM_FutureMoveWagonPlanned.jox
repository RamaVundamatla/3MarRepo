    <JadeMethod name="getPlannedLocation" id="dc86b95d-ca31-4fe2-a702-a095d9e515cf">
        <source>getPlannedLocation():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars

begin
	if self.myRailLine &lt;&gt; null then
		return self.myRailLine.myRailArea.id &amp; Space &amp;self.myRailLine.id;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
