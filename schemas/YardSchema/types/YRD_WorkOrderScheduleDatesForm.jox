    <JadeMethod name="create" id="e25fb640-9b9c-4b82-b05e-1d5aa753a627">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	self.permissionView		:= PmAdmWorkOrderEnquiry;
	self.permissionMaint	:= PmAdmWorkOrderEnquiry;	
	self.helpFileName 		:= HelpFile_Yard;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddTime" id="a5b77442-2e58-46cb-bcb8-83bb532455c0">
        <updating/>
        <source>doAddTime() updating;
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	newTime : Time;
	
begin
	newTime := self.tmTime.getTime;

	if not self.allTimes.includes( newTime ) then
		self.allTimes.add( newTime );
		lstTimes.listIndex := lstTimes.addItem( newTime.asStringJMT() );
	endif;
	
	self.tmTime.setTime(null);
	self.tmTime.setFocus();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangedEndDate" id="52ea36ad-08e2-4143-9da4-d6a0120f28a8">
        <source>doChangedEndDate();
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.dtStartDate.getDate() &gt; self.dtEndDate.getDate() then
		self.dtEndDate.setDate( self.dtStartDate.getDate() );
	elseif self.dtEndDate.getDate() - self.dtStartDate.getDate() &gt; 365 then
		self.dtEndDate.setDate( self.dtStartDate.getDate() + 365 );	
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangedStartDate" id="bcbdedd5-0fd7-4ec0-8a67-e2dd8d78105f">
        <source>doChangedStartDate();
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.minStartDate &gt; self.dtStartDate.getDate() then
		self.dtStartDate.setDate( self.minStartDate );	
	endif;
	
	if self.dtStartDate.getDate() &gt; self.dtEndDate.getDate() then
		self.dtEndDate.setDate( self.dtStartDate.getDate() );
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteTime" id="b30d86af-2d8b-44e9-b852-f0958b312c41">
        <updating/>
        <source>doDeleteTime() updating;
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	delTime : Time;
	
begin
	if self.lstTimes.listIndex &lt; 1 then
		return;
	endif;

	delTime := self.lstTimes.text.Time;

	if self.allTimes.includes( delTime ) then
		self.allTimes.remove( delTime );
		lstTimes.removeItem( self.lstTimes.listIndex );
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="99843d16-4c42-466a-87a3-9c6857c1e1eb">
        <updating/>
        <source>doOK() updating;
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
