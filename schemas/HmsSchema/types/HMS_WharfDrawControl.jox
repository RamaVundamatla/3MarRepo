    <JadeMethod name="doDragOverEvent" id="e2ff0995-8d23-476e-a142-c5dafc5f3545">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDragOverEvent(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
//--------------------------------------------------
// Created:	20 August 2004 By: cnwgd1
//--------------------------------------------------
vars
begin
	frame.setFocus();
	frame.zOrder(1);
	//Fault occurred when the Scrollable Labels Frame was not zOrdered, the label disappears behind the scrollable Wharf Frame
	self.myScrollableLabelFrame.zOrder(1);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
