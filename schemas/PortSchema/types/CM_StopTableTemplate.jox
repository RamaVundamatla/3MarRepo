    <JadeMethod name="actionEventRequestsForTi" id="6e26be05-6e41-4816-b046-346eedb4e458">
        <source>actionEventRequestsForTi( _ti : CM_TrackedItem input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	eventRequest : CM_EventRequest;
	eventRequestForStop : CM_EventRequestForStop;

begin

	foreach eventRequest in self.allEventRequests do
		eventRequestForStop := eventRequest.CM_EventRequestForStop;
		eventRequestForStop.actionCargoUpdateRequest( _ti, true, app.myPassport );
		if app.myPassport.hasErrors then
			break;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="auditId" id="2d8e6694-3ab6-4085-8825-60e221cc87ee">
