    <JadeMethod name="populateVBSSlotTable" id="9e8c99af-e0ab-44c6-8a4e-06d9d304adbc">
        <source>populateVBSSlotTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
26 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
*/
vars
	entTableDef 		: EntTableDef;
	tbl					: CM_DataTable;
	iter				: Iterator;
	vehicleBookingItem	: CM_VehicleBookingTimeSlot;
	idx					: Integer;
	theDataLine			: String;
	xmlStr				: String;
	index				: Integer;		// 26.12.2022 navak20 TFS 55979
	vbTerminal			: CM_VehicleBookingTerminal;	// 26.12.2022 navak20 TFS 55979
begin
	
	entTableDef := app.myController.getEntTableDef(ETDef_VBTimeslotSearch);	
	tbl			:= self.tblSlots;	
	
	xmlStr := self.enquiryTypeDef_Slots;
		
	if xmlStr &lt;&gt; null then
		self.tblSlots.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		tbl.setTblDataEntRowsFromDef(entTableDef);
	endif;

	tbl.setMyDataClass(CM_TrackedItem);
	tbl.fixedColumns    := 0;
	tbl.fixedRows 	    := 1;
	tbl.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	tbl.selectionType   := CM_DataTable.SelectionType_Row;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(tbl);
	
	vbTerminal := self.myTerminal.myVehicleBookingTerminal;		// 26.12.2022 navak20 TFS 55979
	//if self.myTerminal.myVehicleBookingTerminal.allVBTimeslotsById &lt;&gt; null then		// 26.12.2022 navak20 TFS 55979
	if vbTerminal.allVBTimeslotsById &lt;&gt; null then		// 26.12.2022 navak20 TFS 55979
		//foreach vehicleBookingItem in self.myTerminal.myVehicleBookingTerminal.allVBTimeslotsById do	// 26.12.2022 navak20 TFS 55979
		foreach vehicleBookingItem in vbTerminal.allVBTimeslotsById do	// 26.12.2022 navak20 TFS 55979
			if idx &gt;= JadeTableRowLimit then
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			theDataLine := vehicleBookingItem.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			index := tbl.addItem(theDataLine);		// 26.12.2022 navak20 TFS 55979
			//tbl.accessRow(tbl.addItem(theDataLine)).itemObject := vehicleBookingItem;		// 26.12.2022 navak20 TFS 55979
			tbl.accessRow(index).itemObject := vehicleBookingItem;		// 26.12.2022 navak20 TFS 55979
			idx := idx + 1;
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveXMLStrForTblColumns" id="eea5b92b-e895-47cb-9ba5-d6342095b4bd">
        <updating/>
        <source>saveXMLStrForTblColumns(table: CM_DataTable input) updating;
/*

Purpose:			

