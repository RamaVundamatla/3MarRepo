    <JadeMethod name="translateForm" id="ce663ee5-9e2c-4fb8-8185-572f4f527e0e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016867, locale);
	btnAddTab.translateCaption(Xlat_0016868, locale);
	btnAttrAdd.translateCaption(Xlat_0016869, locale);
	btnAttrRemove.translateCaption(Xlat_0016870, locale);
	btnCancel.translateCaption(Xlat_0016871, locale);
	btnClose.translateCaption(Xlat_0016872, locale);
	btnCopyFrom.translateCaption(Xlat_0016873, locale);
	btnCopyTo.translateCaption(Xlat_0016874, locale);
	btnDeleteTab.translateCaption(Xlat_0016875, locale);
	btnExtract.translateCaption(Xlat_0016876, locale);
	btnLoad.translateCaption(Xlat_0016877, locale);
	btnRenameTab.translateCaption(Xlat_0016878, locale);
	btnSave.translateCaption(Xlat_0016879, locale);
	chkUseDefault.translateCaption(Xlat_0016880, locale);
	lblCargoType.translateCaption(Xlat_0016881, locale);
	lblNotes1.translateCaption(Xlat_0016882, locale);
	lblNotes2.translateCaption(Xlat_0016883, locale);
	lblNotes3.translateCaption(Xlat_0016884, locale);
end;</source>
    </JadeMethod>
