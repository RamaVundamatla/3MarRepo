    <JadeMethod name="btnFind_click" id="1aed177d-35a0-4ade-a551-7090d9b9bff3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFind_click(btn: Button input) updating;

vars
	f : DEV_FindErrMsgFrm;

begin
	create f;
	f.showModal;

	tblData.selected := false;

	self.findTxt 		:= f.findTxt;
	self.caseSensitive	:= f.chkCaseSensitive.value;
	
	if (not self.caseSensitive) then
		// convert to lower case for searching
		self.findTxt := self.findTxt.toUpper;
	endif;
	
	if self.findText() then
		tblData.setFocus;
		btnNext.default := true;
	else
		btnFind.default := true;
	endif;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
