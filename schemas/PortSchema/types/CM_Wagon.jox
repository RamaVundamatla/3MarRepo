    <JadeMethod name="createRailReceiveJob" id="88c0488b-053e-4c25-adfe-1ad4250ff246">
        <source>createRailReceiveJob(_passport : CM_Passport input; _retrospectiveDT : TimeStamp) : CM_RailJob;
//--------------------------------------------------------------
//Created: 25 March 2003 By: cnwgd1
//--------------------------------------------------------------
// 19/03/2024 navpw1	TFS: 62857 (62858) - Set retrospective date time on Job
vars
	transAreaId	: String;
	proxyJob	: CM_RailJob;
	realJob 	: CM_Job;
		wle : CM_WorkListEntry;
begin

	//Check to see if receipt jobs have already been created
//	if (not self.confirmed) and (not self.allRailJobs.isEmpty) then
	if (not self.confirmed) and self.hasRailJobs(true) then
		return null;
	endif;
	
	transAreaId := self.myRailLine.myRailArea.id;
	
	//We need to create a rail receive job for this wagon
	exclusiveLock(self);

	create proxyJob transient;
	proxyJob.setProxy(self.id, null);
	proxyJob.setProxyRailJob(null, null,null,null, transAreaId, self, Rail_JSIO_Type_In, self.getTerminal(), null); // PAR 21182
	proxyJob.setRetrospectiveDT(_retrospectiveDT);
	
	app.myUtilityCA.utlCreateJob(proxyJob, realJob, _passport);

	if _passport.noErrors()  // ### TFS 51855 16MAY2022 NAVAB1
	and realJob &lt;&gt; null  then  // ### TFS 51855 16MAY2022 NAVAB1
		if _passport.isOpsViewEnabled(realJob.CM_RailJob.myTerminal) then // ### TFS 51855 06JAN2022 NAVAB1
			realJob.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB, realJob); // ### TFS 51855 06JAN2022 NAVAB1
		endif;
	endif;
	
	return realJob.CM_RailJob;
	
epilog
	delete proxyJob;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_retrospectiveDT" type="TimeStamp"/>
        <ReturnType type="CM_RailJob"/>
    </JadeMethod>
    <JadeMethod name="createToDoTask" id="3382e03b-e352-4d21-a45d-494cfe1b211c">
        <source>createToDoTask(taskDesc : Integer; _wod : CM_WorkOrderToDoDtl): CM_WagonToDoTask;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoTask 		: CM_WagonToDoTask;
	toDoDesc 		: CM_ToDoTaskDesc;
	found	 		: Boolean;
	passport 		: CM_Passport;
begin
	passport := app.myPassport;
	
	toDoDesc := app.myRoot.allToDoTaskDescriptions[taskDesc]; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	/* // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions where toDoDesc.description.trimBlanks = taskDesc do
		found := true;		//Found it
		break;
	endforeach;
	
	if found then 
	*/
	if toDoDesc &lt;&gt; null then  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		create toDoTask persistent;
		toDoTask.setForCreate(STATUS_TODO,	toDoDesc, null, passport, self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.updateObjectEdition(self);		
		
		return toDoTask;
	else
		return null;
	endif;
	
epilog

end;</source>
        <Parameter name="taskDesc" type="Integer"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CM_WagonToDoTask"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="161d2344-54d9-4e7f-aa3e-ca7476980258">
        <source>createTransaction(_effectiveDate : TimeStamp; _type : Integer; _target : CM_Object; _position : Integer; 
						_ti : CM_TrackedItem; _inward : Boolean; _resourceUsageProxys : CM_ResourceTypeUsageSet input; _task : CM_ToDoTask; _wod : CM_WorkOrderToDoDtl):CMEVT_WagonTransaction;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars

	trans : CMEVT_WagonTransaction;
	effectiveDate : TimeStamp;
	wod : CM_WorkOrderToDoDtl;
	cmifEventCtrl : CMIF_WagonEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin

	//23 Feb 2021	NDL	TFS 50837
	if _effectiveDate = null or not _effectiveDate.date.isValid then
		effectiveDate := app.actualTimeServer;
	else
		effectiveDate := _effectiveDate;
	endif;
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	trans := app.createEvent(_type, effectiveDate, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_WagonTransaction;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if trans  &lt;&gt; null then
		self.allTransactions.add(trans); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; INVERSE
		trans.initialise(_target, _position, _ti, _inward);
		trans.addResourcesFromProxys(_resourceUsageProxys); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
		trans.setToDoTask(_task); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		wod := _wod; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		if wod = null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			wod := trans.getWorkOrderDetail().CM_WorkOrderToDoDtl; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;
		if wod &lt;&gt; null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			trans.setFromWOD(wod);// ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1 // ### TFS CR 58083 Task 58552 06JUL2023 NAVAB1
			//trans.setContractId(wod.contractId); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;	
		//trans.createCharge(app.myPassport);
		app.myPassport.addEventTransactionForDeferUpd(trans,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
		return trans;	// 31 Aug 2009	NDL CCMS 1067
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := _type;
	cmifEventCtrl.dateTime := effectiveDate;
	cmifEventCtrl.myTerminal := self.getTerminal();
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myTargetObject := _target;
	cmifEventCtrl.position := _position;
	cmifEventCtrl.myTrackedItem := _ti;
	cmifEventCtrl.isInward := _inward;
	cmifEventCtrl.myWagon := self;
	cmifEventCtrl.isFromWagon := true;
	
	if _resourceUsageProxys &lt;&gt; null then
		_resourceUsageProxys.copy(cmifEventCtrl.allResourceUsages);
	endif;
	cmifEventCtrl.myToDoTask := _task;
	cmifEventCtrl.myWorkOrderDetail := wod;
	
	trans := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_WagonTransaction;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	return trans;

epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_effectiveDate" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_target" type="CM_Object"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CMEVT_WagonTransaction"/>
    </JadeMethod>
    <JadeMethod name="delete" id="df3a8b35-5c44-4073-a584-0688aa7a30fc">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2021	jlgndl1	Initial creation

*/

vars
	
begin

	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152

end;</source>
    </JadeMethod>
    <JadeMethod name="departureProcess" id="52ecadfa-d772-4301-909c-fe3d7a73d565">
        <updating/>
        <source>departureProcess(_moveController : CMIF_WagonMoveController; _trainDepartEvent : CMEVT_TrainTransaction output) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
// 02/06/2023	navkc1	Bug 58384: FR 53740 | EUP - Wagon Track Planning (part II)
// ---------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	lController : CM_LocationsController;
	invalidTI : Boolean;
	int : Integer;
	destTerm: CM_Terminal;
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837
	cmifRakeRegion : CMIF_RakeRegion; //25 Feb 2012	NDL	TFS 50837

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
		create cmifRakeRegion transient;
		cmifRakeRegion.setEffectiveTimeStampOverride( effectiveDate );
	endif;
	
	if self.myTerminalDeparted &lt;&gt; null then // already departed
		self.updateControllersTerminalArea(); //21 Mar 2013	- Belt and braces.
		self.setRailAllocation(null, app.myPassport);	//13 Nov 2014	NDL	Par 35164
		return;
	endif;
	
	//25 Feb 2009	NDL Par 22469
	if self.myTrainInwards.isNullTrain then
		app.raiseCMException2(Depart_wagon_NullTrain, self.id, self.myTrainInwards.getCodeDateString, null, null);
	elseif self.myTrainOutwards.isNullTrain then
		app.raiseCMException2(Depart_wagon_NullTrain, self.id, self.myTrainOutwards.getCodeDateString, null, null);
	endif;
	
	
	self.createTransaction( effectiveDate, EVT_WagonDeparted, self.myTrainOutwards, null, null, false, null, null, null);
	
	create tiArray transient;
	//self.getAllTrackedItems(false, tiArray, false);	//Don't use this we don't want the TIOutward check, 
	// If its on the wagon its going out, too bad.
	//17 Dec 2013	NDL	Par 33189
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);
	//foreach lController in self.allLocationsControllers discreteLock do
	foreach lController in self.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
		foreach ti in lController.allTrackedItems discreteLock do
			invalidTI := false;
			int := ti.edition;
			if invalidTI then
				continue;
			endif;
			if (not tiArray.includes(ti)) then
				tiArray.add(ti);
			endif;
		endforeach;
	endforeach;
	
	
	self.allTIsReleased.clear();
	
	foreach ti in tiArray discreteLock do
		if not self.allTIsReleased.includes(ti) then
			self.allTIsReleased.add(ti);
			self.createTransaction(effectiveDate,EVT_WagonCargoRelease, self.myTrainOutwards, null, ti, false, null, null, null);
		endif;
		if ti.isKindOf(CM_Log) then		// TFS 2533
			destTerm := ti.allLocations.first().CM_WagonController.myWagon.myDestinationTerminal;
			if destTerm &lt;&gt; null and ti.destinationTerminal &lt;&gt; destTerm.code then
				ti.setDestinationTerminal(destTerm.code);
			endif;
		else
			//30 Jun 2021	NDL	TFS 51421
			if ti.isPlannedToYard and ti.destinationTerminal = null then
				app.raiseCMWarning3(Tryin_depar_wagon_cargo_still, self.id, ti.id, ti.myPrimaryPlannedLocation.getFullId, null, null, null);
			endif;
		endif;
	endforeach;
	
	self.validateDepartureProcess(); //22/08/2023	navkc1	CR 59610 Task 59611
	
	// self.myTerminal is required above for transactions
	self.myTerminalDeparted := self.myTerminal;
	self.myTerminal := null;
	self.setRailAllocation(null, app.myPassport);	//13 Nov 2014	NDL	Par 35164
	
	if self.myTrainOutwards &lt;&gt; null then // IF Im the last wagon on this train to be departed AUTO depart the train
		if self.myTrainOutwards.areAllWagonsDeparted() then
			if not self.myTrainOutwards.isNullTrain then	//10 Dec 2009	NDL	Par 21923
				self.myTrainOutwards.departureProcess( cmifRakeRegion, _trainDepartEvent );
			endif;
		endif;
	endif;
	
	//30 Jun 2021	NDL	TFS 51421
	foreach ti in tiArray discreteLock do
		if not ti.isKindOf(CM_Log) then
			if ti.isPlannedToYard and ti.destinationTerminal = null then
				//They were warned above so must have accepted.
				//Clear them otherwise it will potentially cause grief (years) later when they try to change the terminal area
				ti.allPlannedFutureMoves.purge();
			endif;
		endif;
	endforeach;
	
	// 02/06/2023	navkc1	Bug 58384 - If wagon has departed, remove the future moves
	self.allPlannedFutureMoves.purge();
	self.updateControllersTerminalArea();// PAR 26923
	
epilog
	delete tiArray;
	delete cmifRakeRegion;
end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_trainDepartEvent" type="CMEVT_TrainTransaction" usage="output"/>
    </JadeMethod>
    <JadeMethod name="erase" id="b25d8c9e-0605-4645-bd61-ed480ef56c39">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

vars
	railAllocation			: CM_RailAllocation;
begin
	railAllocation := self.getRailAllocation();
	delete railAllocation;
	
	if app.isJMTUnitTest then
	else
		self.causeEvent(self.getTerminal().getTerminalEvent(Wagon_Delete_Event), false, self); // PAR 21182
	endif;
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="ffcbf429-2fa0-486f-aa0d-fd74f1304b1b">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
/*
 ------------------------------------------------------------------------
Created:			26 July 2001 by cnwdwq1
Purpose:			By here all we have in strs(1) is a single numeric of which LC in theLCArray
							we want to access.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	posOnWagon,
	sizeOfWagon		 : Integer;
	stackHeight : Integer;
	wc : CM_WagonController;
	str : String;
	passedInIdString : String;
	altPassedInIdString : String;
	idToCheck : String;
	ti : CM_TrackedItem;
begin
	//-----------------
	//Init
	//-----------------
	sizeOfWagon := self.allLocationsControllersArray.size;
	
	_foundLC := null;
	_foundHeight := NULLINDEX;
	if _strs.size = 0 or sizeOfWagon = 1 or _strs.size = 1 and _strs.first.toUpper = self.id.toUpper then
		//If nothing else supplied, default to 1st position
		_foundLC := self.allLocationsControllersArray.first();
		return;
	endif;
	
	//11 Dec 2014	NDL	Par 35346 - wagon controller ids can now be configured
	//Get a string representing the request with spaces removed.
	if _strs.first &lt;&gt; self.id.toUpper then
		passedInIdString := self.id.toUpper;
	endif;
	//31 Mar 2015	NDL	Par 35961
	if self.myRailLine &lt;&gt; null then
		altPassedInIdString := ( self.myRailLine.getFullId() &amp; self.getWagonPosition() ).toUpper.removeString(" ");
	elseif self.isDeparted() then
		altPassedInIdString := app.getErrorString(Departed).toUpper.removeString(" ");
	endif;
	
	foreach str in _strs do
		passedInIdString := passedInIdString &amp; str.toUpper.trimBlanks;
		altPassedInIdString := altPassedInIdString &amp; str.toUpper.trimBlanks;	//31 Mar 2015	NDL	Par 35961
	endforeach;

	sharedLock(self);
	//Par 35346 / CCMS 1408
	foreach wc in self.allLocationsControllersArray discreteLock do
		idToCheck := wc.getFullIdTI(null).toUpper.removeString(" ");

		if idToCheck = passedInIdString or idToCheck = altPassedInIdString then
			_foundLC := wc;
			return;
		endif;
		if wc.isBoxcarCont then
			continue;
		endif;
		foreach ti in wc.allTrackedItems discreteLock do
			idToCheck := wc.getFullIdTI(ti).toUpper.removeString(" ");
			if idToCheck = passedInIdString or idToCheck = altPassedInIdString then
				_foundLC := wc;
				_foundHeight := wc.allTrackedItems.indexOf(ti);
				return;
			endif;
		endforeach;
	endforeach;
	

epilog
	unlock(self);
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findTi" id="735183a0-8011-4198-84a0-fe3f28e1e5ee">
        <source>findTi(_tiId : String) : CM_TrackedItem;
// -------------------------------------------
// Created 22 October 2003 by cnwdvb1
// -------------------------------------------
vars
	lController	: CM_LocationsController;
	lTI			: CM_TrackedItem;
	
begin

	//foreach lController in self.allLocationsControllers do
	foreach lController in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
		foreach lTI in lController.allTrackedItems do
			if lTI.id = _tiId then
				return lTI;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_tiId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getActualLengthFor" id="dd11f0e2-2cc3-4268-b01f-53e286c1a277">
        <source>getActualLengthFor( _obj : CM_Object ) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

begin

	if _obj.isKindOf(CM_TrackedItem) then
		return _obj.CM_TrackedItem.getActualLength;
	elseif _obj.isKindOf(CM_ISOType) then
		return _obj.CM_ISOType.getLengthInFeet;
	elseif _obj.isKindOf(CM_ISOTypeGroup) then
		return _obj.CM_ISOTypeGroup.getLengthInFeet;
	else
		return 0;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getActualWidthAndHeight" id="9b668a9a-6755-496a-93bc-d2a37882a515">
        <source>getActualWidthAndHeight(_moveController : CMIF_MoveController; _moveMode : Integer; maxWidth : Decimal output; maxHeight : Decimal output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	iterTi : Iterator;
	tempCont : CM_LocationsController;
	locCont : CM_WagonController;
	noLocString : String;
	tiPosition : Integer;
	
	tiWidth : Decimal [12,2];	
	tiHeight : Decimal [12,2];
	deckHeight : Decimal [12,2];
	
	primary : CM_WagonController;
	tiBeingMoved : CM_TrackedItem;
	tiMovePosition : Integer;
	primWidth : Decimal [12,2];
	
	otherTi : CM_TrackedItem;
	
begin

	create tiArray transient;
	self.getAllTrackedItems(true, tiArray, false);
	
	if _moveController &lt;&gt; null then
		primary := _moveController.myToPrimaryLocation.CM_WagonController;
		deckHeight := primary.getDeckHeight;
	endif;
	
	if primary = null then
		if myWagonClass &lt;&gt; null then
			deckHeight := myWagonClass.deckHeight;
		elseif myWagonMaster &lt;&gt; null then
			if myWagonMaster.myWagonClass &lt;&gt; null then
				deckHeight := myWagonMaster.myWagonClass.deckHeight;
			endif;
		endif;
	endif;
	
	
	if _moveController &lt;&gt; null then
		// we are moving cargo onto a wagon.
		tiBeingMoved := _moveController.myTrackedItem;	// the cargo we are moving 
		tiMovePosition := (( tiBeingMoved.locationId[tiBeingMoved.locationId.length -1:end].Integer + 1 ) / 2 ).Integer;
		// set these up in case there is nothing else on the wagon yet.
		maxWidth := tiBeingMoved.getActualWidthRaw();
		maxHeight := tiBeingMoved.getActualHeightRaw() + deckHeight;
		if self.myWagonClass.maxNumInStack &gt; 1 then
			if not primary.allTrackedItems.isEmpty then
				foreach otherTi in primary.allTrackedItems do
					if otherTi &lt;&gt; tiBeingMoved then
						maxHeight := maxHeight + otherTi.getActualHeightRaw();
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	
	// check all the positions and get the widest and highest values
	iterTi := tiArray.createIterator;
	while iterTi.next( ti ) do
		tempCont := ti.getPrimaryLocation(_moveMode).CM_LocationsController;
		if tempCont = null or not tempCont.isWagon then//27 May 2013	NDL	Part of Boxcar conversion
			continue;
		endif;
		locCont := tempCont.CM_WagonController;
		
		tiPosition := (( ti.locationId[ti.locationId.length -1:end].Integer + 1 ) / 2 ).Integer;
		if tiMovePosition = tiPosition then
			tiWidth := ti.getActualWidthRaw();
			if primary &lt;&gt; null then // AKB
				primWidth := primary.getTotalWidthRaw;
				if primWidth &gt; tiWidth then	// Just in case we are stacking i.e this container and the one underneath.
					tiWidth := primWidth; 
				endif;
				tiHeight := ti.getActualHeightRaw() + primary.getTotalHeightRaw(); // Just in case we are stacking i.e this container and the one underneath.
			endif;
		else
			tiHeight := locCont.getTotalHeightRaw; // height of the stack of cargo off the deck at this position.
			tiWidth := locCont.getTotalWidthRaw;	// width of the widest cargo in the stack at this position.
		endif;
		
		tiHeight := tiHeight + deckHeight;
		
		if maxHeight &lt; tiHeight then
			maxHeight := tiHeight;
		endif;
		
		if maxWidth &lt; tiWidth then
			maxWidth := tiWidth;
		endif;

	endwhile;
	
epilog

	delete iterTi;
	delete tiArray;
	
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="maxWidth" type="Decimal" usage="output"/>
        <Parameter name="maxHeight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAllAssignedDelRequests" id="eecf5272-977d-4e24-8290-36ed82f05d61">
        <source>getAllAssignedDelRequests(_allRequests : CM_DeliveryRequestSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
04 November 2022		jlizm1	Initial creationTFS 54118 Assigning Releases to Wagons

*/

vars
	
	iter : Iterator;
	lc : CM_LocationsController;
	wc : CM_WagonController;
	tmpSet : CM_DeliveryRequestSet;

	
begin

	_allRequests.clear();
	iter := self.allLocationsControllers.createIterator;
	create tmpSet transient;

	while iter.next( lc ) do
		if not lc.isWagon then
			continue;
		endif;
		wc := lc.CM_WagonController;
		
		tmpSet.clear();
		wc.getAllAssignedDelRequests(tmpSet);
		tmpSet.copyNoDuplicates(_allRequests, false);
	endwhile;
	
epilog
	
	delete tmpSet;
	delete iter;

end;</source>
        <Parameter name="_allRequests" type="CM_DeliveryRequestSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItems" id="f23443ae-544e-4288-ad4a-0e1445ad2902">
        <source>getAllTrackedItems(_inward : Boolean; _tiArray : Collection input; _confirmed : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
24 April 2002		DWQ		Weird behaviour and resource leaks!
13 October 2023 	jlier1 	TFS 59948 changed _tiArray to collection
29 April 2024 		navma1	Bug 63868: MTN - 1081 from performance test QA-PerformanceTest-Dumps_20240424
21 October 2024		jlizm1	TFS 65987 Error 1308 when iterating collections

*/
vars
	lController : CM_LocationsController;
	ti			: CM_TrackedItem;
	wagonLcs    : CM_WagonControllerArray;
	tmpTICol	: CM_TIArray;
	
begin

	create wagonLcs transient;
	
	if _inward then
		if _confirmed then
			self.allTIsReceived.copyNoDups(_tiArray);
			_tiArray.removeInvalidObjects; //jlier1 JIRA#33496 5/12/24
		else
			self.allLocationsControllersArray.copy(wagonLcs);
			foreach lController in wagonLcs discreteLock do
				lController.allTrackedItems.tryCopy(_tiArray);
			endforeach;
		endif;
		 
	else
	
		if _confirmed then
			self.allTIsReleased.copyNoDups(_tiArray);
			_tiArray.removeInvalidObjects; //jlier1 JIRA#33496 5/12/24
		else
			self.allLocationsControllersArray.copy(wagonLcs);
			create tmpTICol transient;
			
			foreach lController in wagonLcs discreteLock do
				lController.allTrackedItems.tryCopy(tmpTICol);
			endforeach;
						
			foreach ti in tmpTICol discreteLock where self.isTIOutward(ti) do		
				_tiArray.tryAdd(ti);			
			endforeach;
			
			return;
		endif;
	endif;
	
	
	
epilog
	delete wagonLcs;
	delete tmpTICol;
	
end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_tiArray" type="Collection" usage="input"/>
        <Parameter name="_confirmed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItemsPlanned" id="0c6b85b3-f352-46e8-95ad-ca33563f39e7">
        <source>getAllTrackedItemsPlanned(_tis : CM_TIArray input; _clear : Boolean; _mode : Integer);
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// Outward only PAR 21977
//12 Feb 2025 		navbs1	  		Bug MTN-33685: NXL - Train Enquiry Screen - Error 1308 Encountered 
// ---------------------------------------------------------------------------

vars
	ti			: CM_TrackedItem;
	wlc 		: CM_WagonController;
	move 		: CM_FutureMove;
	fma 		: CM_FutureMoveArray;
	wagonLcs    : CM_WagonControllerArray;
begin

	create wagonLcs transient;											//12.02.2025 navbs1 #33685
	if _clear then
		_tis.clear;
	endif;
	
	self.allLocationsControllersArray.copy(wagonLcs);					//12.02.2025 navbs1 #33685
	//foreach wlc in self.allLocationsControllers discreteLock do
	//foreach wlc in self.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345		//12.02.2025 navbs1 #33685
	foreach wlc in wagonLcs discreteLock do								//12.02.2025 navbs1 #33685
		if _mode = PLANNING_MODE then
			fma := wlc.allPlannedFutureMoves;
		elseif _mode = QUEUE_MODE then
			fma := wlc.allQueuedFutureMoves;
		else
			return;
		endif;
		
		foreach move in fma discreteLock do
			if move.moveType &lt;&gt; TI_FutureMoveEDI then
				ti := move.getTrackedItem();

				if ti &lt;&gt; null then
					if not _tis.includes(ti) then
						_tis.add(ti);
					endif;
				endif;
			endif;
		endforeach;
	endforeach;
	


epilog
	
	delete wagonLcs;													//12.02.2025 navbs1 #33685

end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItemsString" id="54c9fe34-7f04-4fe7-abc9-e35fb515e186">
        <source>getAllTrackedItemsString(_inward : Boolean; _transit : Boolean; _confirmed : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     May 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lController : CM_LocationsController;
	lTI		: CM_TrackedItem;
	tis : CM_TIArray;
	str, tiStr : String;
	invalidObj : Boolean;
begin
	
	create tis transient;
	
	self.getAllTrackedItems(_inward, tis, _confirmed);
	
	on Exception do app.handleDeletedObject( exception, lTI, invalidObj );	//26 mar 2013	NDl	Par 31278
	
	foreach lTI in tis  discreteLock do
		invalidObj := false;
		tiStr := self.getTIString(lTI, _transit);
		if tiStr = null or invalidObj then
			continue;
		endif;
		
		if str = null then
			str := tiStr;
		else
			str := str &amp; ", " &amp; tiStr;
		endif;
	endforeach;

	return str;
epilog
	delete tis;
end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_transit" type="Boolean"/>
        <Parameter name="_confirmed" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="55e0b92b-bc53-4eb8-81d2-d5d40999f01d">
        <source>getAllWLEs(_wleArray : CM_WLEArray input);
//--------------------------------------------------------------
//Created: 17 March 2003 By: cnwgd1
// 06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
//--------------------------------------------------------------
vars
	job	: CM_Job;
begin
	foreach job in self.allRailJobs discreteLock do	//06.03.2025 navma1 #MTN-34179
		job.workListEntries.copy(_wleArray);
	endforeach;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAutoPlanLocationFor" id="ca2414bd-3e1d-4a13-ba01-422dc2ec46f6">
        <source>getAutoPlanLocationFor(	_ti : CM_TrackedItem;
						_yaAgent : CM_YAAutoplanAgent input;
						_cmifAutoPlan : CMIF_YAAutoPlan;
						_moveMode : Integer
						): CM_WagonController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2013	cnwndl1	Initial creation	Par 31692

*/

vars

	wagonController : CM_WagonController;
	noMatchReason : String;

begin

	if self.autoAllocationMatch(_ti, noMatchReason, _yaAgent, _cmifAutoPlan) then
		wagonController := self.getNextFreeWagonController(_ti, _moveMode, null, null, true);
		if wagonController &lt;&gt; null then
			if _yaAgent &lt;&gt; null then
				_yaAgent.addLogEntry(AP_Log_YA_Name, app.getErrorString(Wagon) &amp; ' ' &amp; self.id &amp; " @ " &amp; wagonController.getFullId, false);
			endif;
			return wagonController;
		else
			if _yaAgent &lt;&gt; null then
				_yaAgent.addLogEntry(AP_Log_YA_No_Space, app.getErrorString2(WagonAutoPlanError, self.id, app.getErrorString(NoSpace)), false);
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_moveMode" type="Integer"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="getBoxcarLengthAndDoorPosition" id="ac13f607-c623-47d1-aedd-9f0f8db9bb91">
        <source>getBoxcarLengthAndDoorPosition(_lengthUnits: Integer output; _doorArray : IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2013	cnwndl1	Initial creation

*/

vars

begin


epilog

end;</source>
        <Parameter name="_lengthUnits" type="Integer" usage="output"/>
        <Parameter name="_doorArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCCAllocationColor" id="ed4eb442-bf2e-46e2-878c-13935ac41aad">
        <source>getCCAllocationColor() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	railAllocation		: CM_RailAllocation;
begin
	railAllocation := self.getRailAllocation;
	
	if railAllocation &lt;&gt; null then
		return railAllocation.getAllocationColor();
	endif;
	
	//12 Feb 2014	NDL	Par 33439
	if not self.confirmed then
		//so we show colour coding on planning form before teh wagon arrives
		if self.hasMasterCargoRestriction then
			return self.getMasterCargoRestrictColour();
		endif;
	endif;
		
	return NullColour;
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCCConsignee" id="9292f723-c391-4bc8-89d6-dc5e1573fd52">
        <source>getCCConsignee() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2009	cnwmd1	Initial creation, CCMS 1067, Par 19710

*/

vars
	railAllocation		: CM_RailAllocation;
	consign				: CM_ConsigneeConsignor;
begin
	railAllocation := self.getRailAllocation;
	if railAllocation = null then
		return null;
	endif;
		
	consign := railAllocation.getConsignee;
	if consign = null then
		return null;
	endif;
	
	return consign.code;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCCDestination" id="1d398896-b705-4fd1-b826-9afbaa0f597c">
        <source>getCCDestination() : String;
/*
----------   ----------  --------------------------------------------------
Created:	04 December 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	railAllocation		: CM_RailAllocation;
	port				: CM_Port;
begin
	railAllocation := self.getRailAllocation;
	if railAllocation = null then
		return null;
	endif;
		
	port := railAllocation.getDestinationPort();
	if port = null then
		return null;
	endif;
	
	return port.code;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
