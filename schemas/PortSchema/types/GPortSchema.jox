    <JadeMethod name="getCAMSTraceLevelDescr" id="1ac7ed2c-cbe6-486c-88d9-2242d037c7ba">
        <source>getCAMSTraceLevelDescr(_level : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     04 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 14/03/2023	navmd1	TFS 57110 - Refactor CAMS Logging levels to match the new Log level formats
vars

begin

	if _level = LogERROR then
	 	return 'Level 1 - Optional Error Messages';	
	 elseif _level = LogWARN then
	  	return 'Level 2 - Optional Warning Messages';
	 elseif _level = LogTRACE then
	 	return 'Level 3 - Programming Debug Messages';	
	else
	 	return 'Level 0 - Compulsory System Messages Only';
	endif;
end;</source>
        <Parameter name="_level" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getClassForCargoBOLType" id="a2df68b7-61d3-42d6-baf8-a59f694dfd79">
        <source>getClassForCargoBOLType(_cargoBOLType : Integer) : Class;
// ---------------------------------------------------------------------------
// Created:     30 June 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars

begin
	if (_cargoBOLType &gt; BOLType_Min) and (_cargoBOLType &lt; BOLType_Max) then
		return CM_BOL;
	
	elseif (_cargoBOLType &gt; TI_CargoBOLType_Max and _cargoBOLType &lt; TI_CargoBOLType_JMTMax)		// TFS 49252
	or (_cargoBOLType &lt; TI_CargoBOLType_JMTMax and app.myRoot.isClientCentrePort) then			// TFS 49252
		return CM_BreakBulkGeneric;	
	
	elseif _cargoBOLType = TI_CargoType_BreakBulk then
		return CM_BreakBulk;
	
	elseif _cargoBOLType = TI_CargoType_Car then
		return CM_Car;

	elseif _cargoBOLType = TI_CargoType_COU then
		return CM_ClipOnUnit;

	elseif _cargoBOLType = TI_CargoType_Container then	
		return CM_Container;

	elseif _cargoBOLType = TI_CargoType_Generator then
		return CM_Generator;

	elseif _cargoBOLType = TI_CargoType_LCL then
		return CM_LCL;

	elseif _cargoBOLType = TI_CargoType_Log then
		return CM_Log;

	elseif _cargoBOLType = TI_CargoType_Tower then
		return CM_Tower;
	
	else
		return CM_TrackedItem;
	endif;
	

end;</source>
        <Parameter name="_cargoBOLType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getDataClass" id="1305d744-23c8-40ef-a3a9-7f8a7a3b2dae">
        <source>getDataClass(_value : Any) : Class;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
// 22/02/2012	cnwcs5	par 29158 - New CM_StateIntegerArray
vars
	cls	: Class;
begin

	if _value.isKindOf(Binary) then
		cls := CM_StateBinary;
		
	elseif _value.isKindOf(Decimal) then
		cls := CM_StateDecimal;
		
	elseif _value.isKindOf(Integer) then
		cls := CM_StateInteger;
		
	elseif _value.isKindOf(Sound) then
		cls := CM_StateSound;
		
	elseif _value.isKindOf(CM_Object) then
		cls := CM_StateReference;
		
	elseif _value.isKindOf(Dictionary) or		// from 29499 Nov 2012
		   _value.isKindOf(Set) then
		cls := CM_StateCollection;
		
	elseif _value.isKindOf(StringArrayStateData) then
		cls := CM_StateStringArray;
		
	elseif _value.isKindOf(IntegerArray) then	// par 29158 - Feb 2012
		cls := CM_StateIntegerArray;			// par 29158 - Feb 2012
		
	elseif _value.isKindOf(DateArray) then	//19 Jun 2020	NDL	TFS 49569
		cls := CM_StateDateArray;
		
	else
		// set to "String" - the default
		cls := CM_StateString;
	endif;
	
	return cls;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getExceptionText" id="888d7f94-0521-444d-bcea-d4e02d80148d">
        <source>getExceptionText(errorCode: Integer): String;

vars
	except:  Exception;
	str:     String;
begin
	create except transient;
	except.errorCode := errorCode;
	
	str := except.text();
	return str;
epilog
	delete except;
end;</source>
