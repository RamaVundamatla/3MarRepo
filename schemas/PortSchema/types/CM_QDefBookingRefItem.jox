	//create tmpProp as CM_QDecimalProperty persistent;																						// PAR #33235
	//tmpProp.set('Width', CM_BookingRefItem::width.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add(tmpProp);																									// PAR #33235
	self.createMeasurementProperties(CM_QDecimalProperty, Type_Linear, 'Width', CM_BookingRefItem::width.name, self.className, null);		// PAR #33235
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="derivedfromParent" id="b8edcf11-ebb2-4ca4-8438-2f235bae161e">
        <source>derivedfromParent(_queryProp : CM_QueryProperty): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwndl1	Initial creation	CCMS 1028

*/

vars

	propName : String;
	headerQDef : CM_QDefBookingRef;
	headerQueryProp : CM_QueryProperty;
	
begin

	if _queryProp &lt;&gt; null then
		propName := _queryProp.propertyName;
	endif;
	if propName = null then
		return false;
	endif;
	
	headerQDef := app.myRoot.allQueryDefinitionObjects.getAtKey(CM_QueryDefinition.BookRef_Query_Type, CM_QueryDefinition.BookRef_Query_Mode).CM_QDefBookingRef;
	if headerQDef &lt;&gt; null then
		headerQueryProp := headerQDef.allQueryProperties.getAtKey(propName);
		if headerQueryProp &lt;&gt; null then
			// parent does have one with the same property name,
			// most of these derive their values from the Booking Ref
			
			//exceptions to this rule need to return false...
			if propName = CM_BookingRefItem::numTIs.name
			or propName = CM_BookingRefItem::numOnsiteTIs.name
			or propName = CM_BookingRefItem::getOverunderCount.name
			or propName = CM_BookingRefItem::getPrenotedCount.name
			or propName = CM_BookingRefItem::getRecievedCount.name
			or propName = CM_BookingRefItem::getReleasedCount.name
			or propName = CM_BookingRefItem::getReservedCount.name
			or propName = CM_BookingRefItem::getCommodity.name
			or propName = CM_BookingRefItem::getCommodityGroupDesc.name
			or propName = CM_BookingRefItem::getSpecialLiftDesc.name
			or propName = CM_BookingRefItem::getVolume.name
			then	
				return false;
			endif;
		
			// it wasn't one of the exceptions, so it must be derived.
			return true;
			
		endif;
	endif;

	return false;

epilog

end;</source>
        <Parameter name="_queryProp" type="CM_QueryProperty"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
