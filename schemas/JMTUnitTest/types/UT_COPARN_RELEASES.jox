    <JadeMethod name="tCoparnRelease_CCMS2221" id="c5a68f1d-740a-4208-bc71-74fe56c3b019">
        <updating/>
        <source>tCoparnRelease_CCMS2221()updating;
// cnwrs1
/*
Date		Who		Reason
12 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants	
	VESSEL		= 'UT_X2221';
	VOYAGE		= 'UT_X2221A';
	OPERATOR	= 'MSK';
	SENDER1		= 'MSKCP';	SENDER2 = 'MAEUCP'; SENDER3 = 'CMSCP';
	PARTY		= 'Maersk Coparn Unit Tests'; PARTY2 = 'Christina Coparn Unit Tests';
	CONSIGNOR 	= 'UTCOP';
	CONSIGNEE	= 'UTCOE';
	MT = '4'; FULL = '5';
	BLOCKSTACK 	= 'BS_COPARN';
	YA 			= 'YA_COPARN';
vars
	operator			:CM_Operator;
	ediParty, ediParty2	:CM_EDIParty;
	consign				:CM_ConsigneeConsignor;
	rules, rules2		:CM_EDIPartyCoparnRules;
	code, vesselCode, voyageCode		:String;
	ts1, ts2			:TimeStamp;
	voyage	:CM_Voyage;
	ya		:CM_YardAllocation;
	array 	:CM_LCArray;
	bs		:CM_BlockStack;
	carrier1 : CM_Carrier;
	carrier2 : CM_Carrier;
	opCrit : CM_OperatorCarrierCriteria;
	opCrit1 : CM_OperatorCarrierCriteria;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	
	self.disableAllYA(true);
	self.deleteYA(YA);
	self.deleteTerminalArea (BLOCKSTACK);
	
	bs := self.addBlockStack (BLOCKSTACK, null, null);
	
	create array transient;
	array.add (bs.allLocationsControllers.first);
	
	code 		:= self.getTerminal.code;	
	vesselCode 	:= VESSEL &amp; code;
	voyageCode	:= VOYAGE &amp; code;
	
	self.deleteVoyage(voyageCode);
	self.deleteVessel(vesselCode);
	
	operator := self.getOperator (OPERATOR);
	self.assertNotNullMsg (operator, 'Operator '&amp;OPERATOR&amp;' does not exist');

	carrier1 := app.myRoot.allCarriers["UT_OTHER"];
	carrier2 := app.myRoot.allCarriers["DOUG"];
	foreach opCrit in operator.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit1 := opCrit;
		endif;
	endforeach;
	if opCrit1 &lt;&gt; null then
		if not opCrit1.allCarriers.includes(carrier1) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier1);
			commitTransaction;
		endif;
		if not opCrit1.allCarriers.includes(carrier2) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier2);
			commitTransaction;
		endif;
	endif;
	
	ya := self.addYA1(YA, YACriteriaType_OperatorItem, operator.code, array);

	// now make sure all the translations we need are there
	self.deleteEDIInwardXlation ('GP', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (0.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('DAIRY', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (1.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5049000221', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5046240346', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	
	
	self.createEDIXlation ('GP', 0.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	self.createEDIXlation ('DAIRY', 1.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	
	if not self.createEDIXlation ('5049000221', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;	
	 
	if not self.createEDIXlation ('5046240346', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;	

	// makes sure the operator can use ALL availability grades
	beginTransaction;
	self.clearOperatorCodeGroups (operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	
	// this voyage will be used in most files
	self.createVesselVoyage (voyageCode, vesselCode, operator);
	
	// we need one of these so create one
	consign := app.myRoot.allConsigneeConsignors [CONSIGNOR];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNOR, CONSIGNOR, true, true, true);
	endif;
	
	consign := app.myRoot.allConsigneeConsignors [CONSIGNEE];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNEE, CONSIGNEE, true, true, true);
	endif;
	
	// better create the EDI Party	
	self.deleteVoyage ('UT_HOLD' &amp; code);	// force voyage to be re-created without edi cutoffs
	// set up a party like MSK
	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, false);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	// this party has aDTM+133 rule for request date
	ediParty2 	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY2, PARTY2, SENDER3, null, operator, true);
	rules2		:= ediParty2.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	
	// change voyafge arrival/departure dates so we don't get cutoff errors
	voyage := self.getVoyage (voyageCode);
	
	if voyage &lt;&gt; null then
		ts1.setDate (ts1.date+7);
		beginTransaction;
		voyage.setArrivalDT (ts1);
		voyage.setDepartureDT (null);
		commitTransaction;
	endif;
	
	ts1 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts2 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	ts1.setDate (ts1.date-2);
	ts1.setTime ('09:00'.Time);
	ts2.setDate (ts1.date+1);
	ts2.setTime ('15:00'.Time);
	
	self.setTerminalConfig(EdiReleaseAllowPartial, false);
	self.setTerminalConfig(EdiBookingAllowPartial, false);
	
	self.doCoparn_UpdateChecksCCMS2221 (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, operator, bs, rules);
	self.doCoparn_Multi_CCMS2221 (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, operator, bs, rules);
	
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	
	self.doCoparn_UpdateChecksCCMS2221 (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, operator, bs, rules);	
	self.doCoparn_Multi_CCMS2221 (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, operator, bs, rules);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.disableAllYA(false);						// 02/02/2015 cnwmh5 - Add enabling of YA's
	if opCrit1 &lt;&gt; null then
		if opCrit1.allCarriers.includes(carrier1) then
			beginTransaction;
			opCrit1.allCarriers.remove(carrier1);
			commitTransaction;
		endif;
		if opCrit1.allCarriers.includes(carrier2) then
			beginTransaction;
			opCrit1.allCarriers.remove(carrier2);
			commitTransaction;
		endif;
	endif;
	delete array;
end;</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="tCoparn_ReleaseUpdates" id="340a2889-d0a3-40e6-8a77-5ff83bd2afd0">
        <updating/>
        <source>tCoparn_ReleaseUpdates()updating;
// cnwrs1
/*
Date		Who		Reason
14/05/2012	cnwcs5	par 29402 - Split unit test so quicker to run in testing
16/05/2012	cnws5	par 29575
03/09/2012	cnwcs5	par 30097 - configure update rules
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants	
	VESSEL		= 'UT_XCOPARN';
	VOYAGE		= 'UT_XCOPARN1';
	RELEASE1	= 'UT_COPARN_U001';
	RELEASE2	= 'UT_COPARN_U002';
	RELEASE3	= 'UT_COPARN_U003';
	RELEASE4	= 'UT_COPARN_U004';
	RELEASE5	= 'UT_COPARN_U005';
	RELEASE6	= 'UT_COPARN_U006';
	RELEASE7	= 'UT_COPARN_U007';
	RELEASE8	= 'UT_COPARN_U008';
	RELEASE9	= 'UT_COPARN_U009';
	RELEASE10	= 'UT_COPARN_U0010';
	RELEASE11	= 'UT_COPARN_U0011';

	OPERATOR	= 'MSK';
	SENDER1		= 'MSKCP';	SENDER2 = 'MAEUCP'; SENDER3 = 'CMSCP';
	PARTY		= 'Maersk Coparn Unit Tests'; PARTY2 = 'Christina Coparn Unit Tests';
	CONSIGNOR 	= 'UTCOP';
	CONSIGNEE	= 'UTCOE';
	MT = '4'; FULL = '5';
vars
	operator			:CM_Operator;
	ediParty, ediParty2	:CM_EDIParty;
	consign				:CM_ConsigneeConsignor;
	rules, rules2		:CM_EDIPartyCoparnRules;
	code, vesselCode, voyageCode		:String;
	ts1, ts2			:TimeStamp;
	voyage	:CM_Voyage;
	foundMatch	:Boolean;
	carrier1 : CM_Carrier;
	carrier2 : CM_Carrier;
	carrier3 : CM_Carrier;
	opCrit : CM_OperatorCarrierCriteria;
	opCrit1 : CM_OperatorCarrierCriteria;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	
	code := self.getTerminal.code;

	self.deleteReleaseRequest (RELEASE1); 
	self.deleteReleaseRequest (RELEASE2); 
	self.deleteReleaseRequest (RELEASE3); 
	self.deleteReleaseRequest (RELEASE4); 
	self.deleteReleaseRequest (RELEASE5); 
	
	vesselCode := VESSEL &amp; code;
	voyageCode	:= VOYAGE &amp; code;
	
	self.deleteVoyage(voyageCode);
	self.deleteVessel(vesselCode);
	
	operator := self.getOperator (OPERATOR);
	self.assertNotNullMsg (operator, 'Operator '&amp;OPERATOR&amp;' does not exist');

	carrier1 := app.myRoot.allCarriers["UTCAR2"];
	carrier2 := app.myRoot.allCarriers["UT_OTHER"];
	carrier3 := app.myRoot.allCarriers["DOUG"];
	foreach opCrit in operator.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit1 := opCrit;
		endif;
	endforeach;
	if opCrit1 &lt;&gt; null then
		if not opCrit1.allCarriers.includes(carrier1) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier1);
			commitTransaction;
		endif;
		if not opCrit1.allCarriers.includes(carrier2) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier2);
			commitTransaction;
		endif;
		if not opCrit1.allCarriers.includes(carrier3) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier3);
			commitTransaction;
		endif;
	endif;

	// now make sure all the translations we need are there
	self.deleteEDIInwardXlation ('GP', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (0.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('DAIRY', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (1.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5049000221', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5046240346', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	
	
	self.createEDIXlation ('GP', 0.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	self.createEDIXlation ('DAIRY', 1.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	
	if not self.createEDIXlation ('5049000221', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;	
	 
	if not self.createEDIXlation ('5046240346', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;	

	// makes sure the operator can use ALL availability grades
	beginTransaction;
	self.clearOperatorCodeGroups (operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	
	// this voyage will be used in most files
	self.createVesselVoyage ( voyageCode,vesselCode, operator);
	
	// we need one of these so create one
	consign := app.myRoot.allConsigneeConsignors [CONSIGNOR];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNOR, CONSIGNOR, true, true, true);
	endif;
	
	consign := app.myRoot.allConsigneeConsignors [CONSIGNEE];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNEE, CONSIGNEE, true, true, true);
	endif;
	
	// better create the EDI Party	
	self.deleteVoyage ('UT_HOLD' &amp; code);	// force voyage to be re-created without edi cutoffs
	// set up a party like MSK
	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, false);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	// this party has aDTM+133 rule for request date
	ediParty2 	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY2, PARTY2, SENDER3, null, operator, true);
	rules2		:= ediParty2.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	
	// change voyafge arrival/departure dates so we don't get cutoff errors
	voyage := self.getVoyage (voyageCode);
	
	if voyage &lt;&gt; null then
		ts1.setDate (ts1.date+7);
		beginTransaction;
		voyage.setArrivalDT (ts1);
		voyage.setDepartureDT (null);
		commitTransaction;
	endif;
	
	ts1 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts2 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	ts1.setDate (ts1.date-2);
	ts1.setTime ('09:00'.Time);
	ts2.setDate (ts1.date+1);
	ts2.setTime ('15:00'.Time);
	
	self.setTerminalConfig(EdiReleaseAllowPartial, false);
	self.setTerminalConfig(EdiBookingAllowPartial, false);
	self.setTerminalConfig(ShowRelReqOnRailLoadList, false);
	
	self.doCoparn_mtrel_DefaultUpdate(SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE7, MT, operator,rules);
	
	// no rule and no DTM segment (add)
	self.doCoparn_mtrel_dates (SENDER1, '9', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE8, null, ts2, MT, operator, rules, false);
	// no rule and no DTM segment (update)
	self.doCoparn_mtrel_dates (SENDER1, '5', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE8, null, ts2, MT, operator, rules, false);
	// no rule and has DTM segment (add)
	self.doCoparn_mtrel_dates (SENDER1, '9', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE9, ts1, ts2, MT, operator, rules, false);
	// no rule and has DTM segment (update)
	self.doCoparn_mtrel_dates (SENDER1, '5', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE9, ts1, ts2, MT, operator, rules, false);
	// has rule and no DTM segment (add)
	self.doCoparn_mtrel_dates (SENDER3, '9', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE10, null, ts2, MT, operator, rules2, true);
	// has rule and no DTM segment (update)
	self.doCoparn_mtrel_dates (SENDER3, '5', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE10, null, ts2, MT, operator, rules2, true);
	// has rule and has DTM segment (add)
	self.doCoparn_mtrel_dates (SENDER3, '9', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE11, ts1, ts2, MT, operator, rules2, true);
	// has rule and has DTM segment (update)
	self.doCoparn_mtrel_dates (SENDER3, '5', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE11, ts1, ts2, MT, operator, rules2, true);

	// CHECK UPDATES NOT POSSIBLE IF RELEASE IS ACTIONED/COMPLETE BLOCKED OR ARCHIVED
	self.doCoparn_UpdateChecks (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, operator, rules);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
/*	if opCrit1 &lt;&gt; null then
		if opCrit1.allCarriers.includes(carrier) then
			beginTransaction;
			opCrit1.allCarriers.remove(carrier);
			commitTransaction;
		endif;
	endif;*/
end;
</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="tCoparn_ReleaseUpdates_Partial" id="e80afec7-fce1-448d-ad0f-525d5191cc87">
        <updating/>
        <source>tCoparn_ReleaseUpdates_Partial()updating;
// cnwrs1
/*
Date		Who		Reason
14/05/2012	cnwcs5	par 29402 - Split unit test so quicker to run in testing
16/05/2012	cnwcs5	par 29575
03/09/2012	cnwcs5	par 30097
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants	
	VESSEL		= 'UT_XCOPARP';
	VOYAGE		= 'UT_XCOPARP1';
	RELEASE1	= 'UT_COPARN_UP01';
	RELEASE2	= 'UT_COPARN_UP02';
	RELEASE3	= 'UT_COPARN_UP03';
	RELEASE4	= 'UT_COPARN_UP04';
	RELEASE5	= 'UT_COPARN_UP05';
	RELEASE6	= 'UT_COPARN_UP06';
	RELEASE7	= 'UT_COPARN_UP07';
	RELEASE8	= 'UT_COPARN_UP08';
	RELEASE9	= 'UT_COPARN_UP09';
	RELEASE10	= 'UT_COPARN_UP010';
	RELEASE11	= 'UT_COPARN_UP011';

	OPERATOR	= 'MSK';
	SENDER1		= 'MSKCP';	SENDER2 = 'MAEUCP'; SENDER3 = 'CMSCP';
	PARTY		= 'Maersk Coparn Unit Tests'; PARTY2 = 'Christina Coparn Unit Tests';
	CONSIGNOR 	= 'UTCOP';
	CONSIGNEE	= 'UTCOE';
	MT = '4'; FULL = '5';
vars
	operator			:CM_Operator;
	ediParty, ediParty2	:CM_EDIParty;
	consign				:CM_ConsigneeConsignor;
	rules, rules2		:CM_EDIPartyCoparnRules;
	code, vesselCode, voyageCode		:String;
	ts1, ts2			:TimeStamp;
	voyage	:CM_Voyage;
	foundMatch	:Boolean;
	carrier : CM_Carrier;
	opCrit : CM_OperatorCarrierCriteria;
	opCrit1 : CM_OperatorCarrierCriteria;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	
	code := self.getTerminal.code;

	self.deleteReleaseRequest (RELEASE1); 
	self.deleteReleaseRequest (RELEASE2); 
	self.deleteReleaseRequest (RELEASE3); 
	self.deleteReleaseRequest (RELEASE4); 
	self.deleteReleaseRequest (RELEASE5); 
	
	vesselCode := VESSEL &amp; code;
	voyageCode	:= VOYAGE &amp; code;
	
	self.deleteVoyage(voyageCode);
	self.deleteVessel(vesselCode);
	
	operator := self.getOperator (OPERATOR);
	self.assertNotNullMsg (operator, 'Operator '&amp;OPERATOR&amp;' does not exist');

	carrier := app.myRoot.allCarriers["UTCAR2"];
	foreach opCrit in operator.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit1 := opCrit;
		endif;
	endforeach;
	if opCrit1 &lt;&gt; null then
		if not opCrit1.allCarriers.includes(carrier) then
			beginTransaction;
			opCrit1.allCarriers.add(carrier);
			commitTransaction;
		endif;
	endif;
	
	// now make sure all the translations we need are there
	self.deleteEDIInwardXlation ('GP', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (0.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('DAIRY', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (1.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5049000221', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5046240346', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	
	
	self.createEDIXlation ('GP', 0.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	self.createEDIXlation ('DAIRY', 1.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	
	if not self.createEDIXlation ('5049000221', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;	
	 
	if not self.createEDIXlation ('5046240346', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;	
	
	// makes sure the operator can use ALL availability grades
	beginTransaction;
	self.clearOperatorCodeGroups (operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	
	// this voyage will be used in most files
	self.createVesselVoyage (voyageCode,vesselCode,  operator);
	
	// we need one of these so create one
	consign := app.myRoot.allConsigneeConsignors [CONSIGNOR];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNOR, CONSIGNOR, true,  true, true);
	endif;
	
	consign := app.myRoot.allConsigneeConsignors [CONSIGNEE];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNEE, CONSIGNEE, true, true, true);
	endif;
	
	// better create the EDI Party	
	self.deleteVoyage ('UT_HOLD' &amp; code);	// force voyage to be re-created without edi cutoffs
	// set up a party like MSK
	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, false);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	// this party has aDTM+133 rule for request date
	ediParty2 	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY2, PARTY2, SENDER3, null, operator, true);
	rules2		:= ediParty2.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	
	// change voyafge arrival/departure dates so we don't get cutoff errors
	voyage := self.getVoyage (voyageCode);
	
	if voyage &lt;&gt; null then
		ts1.setDate (ts1.date+7);
		beginTransaction;
		voyage.setArrivalDT (ts1);
		voyage.setDepartureDT (null);
		commitTransaction;
	endif;
	
	ts1 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts2 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	ts1.setDate (ts1.date-2);
	ts1.setTime ('09:00'.Time);
	ts2.setDate (ts1.date+1);
	ts2.setTime ('15:00'.Time);
	
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(ShowRelReqOnRailLoadList, false);
	
	self.doCoparn_mtrel_DefaultUpdate(SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE7, MT, operator,rules);
	/*
	// no rule and no DTM segment (add)
	self.doCoparn_mtrel_dates (SENDER1, '9', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE8, null, ts2, MT, operator, rules, false);
	// no rule and no DTM segment (update)
	self.doCoparn_mtrel_dates (SENDER1, '5', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE8, null, ts2, MT, operator, rules, false);
	// no rule and has DTM segment (add)
	self.doCoparn_mtrel_dates (SENDER1, '9', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE9, ts1, ts2, MT, operator, rules, false);
	// no rule and has DTM segment (update)
	self.doCoparn_mtrel_dates (SENDER1, '5', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE9, ts1, ts2, MT, operator, rules, false);
	// has rule and no DTM segment (add)
	self.doCoparn_mtrel_dates (SENDER3, '9', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE10, null, ts2, MT, operator, rules2, true);
	// has rule and no DTM segment (update)
	self.doCoparn_mtrel_dates (SENDER3, '5', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE10, null, ts2, MT, operator, rules2, true);
	// has rule and has DTM segment (add)
	self.doCoparn_mtrel_dates (SENDER3, '9', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE11, ts1, ts2, MT, operator, rules2, true);
	// has rule and has DTM segment (update)
	self.doCoparn_mtrel_dates (SENDER3, '5', voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, RELEASE11, ts1, ts2, MT, operator, rules2, true);

	// CHECK UPDATES NOT POSSIBLE IF RELEASE IS ACTIONED/COMPLETE BLOCKED OR ARCHIVED
	self.doCoparn_UpdateChecks (SENDER1, voyageCode, vesselCode, CONSIGNOR, CONSIGNEE, operator, rules);*/
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
/*	if opCrit1 &lt;&gt; null then
		if opCrit1.allCarriers.includes(carrier) then
			beginTransaction;
			opCrit1.allCarriers.remove(carrier);
			commitTransaction;
		endif;
	endif;*/
end;
</source>
