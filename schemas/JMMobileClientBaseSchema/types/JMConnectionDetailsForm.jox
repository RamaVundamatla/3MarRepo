    <JadeMethod name="btnCancel_click" id="8e239f15-f5a3-4256-aeea-87bf0dd2a94b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doCancel();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="de9ae59c-9f5c-4b3a-b945-8e8f3e823647">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doSave();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="a50ea635-6724-44a3-a644-5dda60cd05f6">
        <updating/>
        <source>doCancel() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="8372b061-a345-43db-9cec-c1ba0c410b49">
        <updating/>
        <source>doSave():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.myRoot.setConnectionDetails(self.txtCMachineName.text,
									self.txtCPortNumber.text.Integer,
									self.txtSMachineName.text,
									self.txtSPortNumber.text.Integer);
	self.unloadForm();
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="e51ac3c3-412b-4403-a8b3-ed6bc56540e7">
        <source>init() protected;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tmpStr	: String;
	tmpNum	: Integer;
begin
	self.btnHelp.visible := false;
	
	app.myRoot.getServerConnectionDetails(self.txtSMachineName.text, tmpNum);
	if tmpNum &lt;&gt; null then
		self.txtSPortNumber.text := tmpNum.String;
	endif;

	app.myRoot.getClientConnectionDetails(self.txtCMachineName.text, tmpNum);
	if tmpNum &lt;&gt; null then
		self.txtCPortNumber.text := tmpNum.String;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="f3a5cc66-3180-4df4-ae39-b5c0ce4df532">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.init();
end;</source>
    </JadeMethod>
</GUIClass>
