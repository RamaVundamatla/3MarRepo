    <JadeMethod name="setupForm" id="c31f7b7b-f83e-40e9-967f-0ebd1e7c29f2">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	etDef : EntTableDef;

begin

	self.tblReeferWalkBlocks.columns := 1;
	self.tblReeferWalkBlocks.fixedColumns := 0;
	self.tblReeferWalkBlocks.rows := 1;
	self.tblReeferWalkBlocks.fixedRows := 1;
	self.tblReeferWalkBlocks.setCellText( 1, 1, app.getErrorString( Block_name ) );
	self.tblReeferWalkBlocks.selectMode := CM_DataTable.SelectMode_Single;

	etDef := app.myController.getEntTableDef(ETDef_ReeferTSMaint);
	self.tblReeferJobs.setColumnHeadingsFromDef(etDef.name, false);
	self.tblReeferJobs.setMyEntTableDef(etDef);
	self.tblReeferJobs.setTblDataEntRowsFromDef(etDef);
	
	self.tblReeferJobs.selectMode := CM_DataTable.SelectMode_CurrentRow;
	self.tblReeferJobs.selectionType := CM_DataTable.SelectionType_Row;
	self.tblReeferJobs.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblReeferJobs.autoSize := Table.AutoSize_Column;
	
	
	inheritMethod();
	
	self.minimumWidth := 575;
	self.minimumHeight := 600;
	
	self.populateCmbGriddedAreas();
	self.doClickCmbGriddedArea();
	
	self.clickSelection();
	
	self.btnOk.visible := false;
	self.btnCancel.caption := app.getErrorString( Close );

epilog

end;</source>
    </JadeMethod>
