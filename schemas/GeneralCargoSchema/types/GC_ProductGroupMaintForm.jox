end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="636e608b-a265-45d9-8d63-48582c2edd69">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	code,
	groupDescription	: String;
	lColour				: Integer;
	theProducts			: CM_ProductSet;
	isAvailForEntry		: Boolean;
	proxyGroupObj		: CM_ProductGroup;
	table				: CM_EntryTable;
	userResponse		: Integer;
//	theProducts			: CM_ProductByCodeDict;
	chgNum				: Integer;
	cargoTypeObj		: CM_CargoType;
	
begin
	table := self.tblEntDetail;

	if self.mode = Mode_Add then
		create proxyGroupObj transient;
	elseif self.mode = Mode_Update then
		proxyGroupObj	:=	self.myProxyObject.CM_ProductGroup;
	else
		return false;
	endif;
	
	create theProducts transient;
	self.msgProducts.getSelected(theProducts);
	
// cnwdad1 14/07/2006 - PAR #12098.
//	if self.cmbFiltCargoType.listIndex &gt; 0 then
//		chgNum	:=	self.cmbFiltCargoType.itemData[self.cmbFiltCargoType.listIndex];
//	endif;
	
	if self.myCurrentObject &lt;&gt; null then	// In the Edit mode, the cmbCargoType is disabled and listObject = null. 18296 April 2009
		cargoTypeObj := self.myCurrentObject.CM_ProductGroup.myCargoType;
	else		// when the mode = NEW, cargo Type is retrieved from the combobox
		cargoTypeObj :=	cmbCargoType.listObject.CM_CargoType;
	endif;
	code				:=	self.tblEntDetail.getValueByName(ETRow_Code).String;
	groupDescription	:=	self.tblEntDetail.getValueByName(ETRow_Description).String;
	lColour				:=	self.tblEntDetail.getValueByName(ETRow_Colour).Integer;
	isAvailForEntry		:=	self.tblEntDetail.getValueByName(ETRow_IsAvailableForEntry).Boolean;
//	proxyGroupObj.setProxy(code, groupDescription, lColour, isAvailForEntry, theProducts, self.aMyCurrentCargoType);
	proxyGroupObj.setProxy(code, groupDescription, lColour, isAvailForEntry, theProducts, cargoTypeObj);

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateProductGroup(proxyGroupObj,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateProductGroup(proxyGroupObj, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep();
			return true;
		else
			userResponse	:=	app.showErrorWarningDialog(	"Invoice Type",
															app.myPassport,
															ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors() 
			and userResponse = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:=	true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		
		break;
	endwhile;
epilog
	if self.mode = Mode_Add then
		delete proxyGroupObj;
	endif;
	
	delete theProducts;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableDisableControls" id="76869a85-7623-4ec9-9dd5-1b403ff7edfe">
        <source>enableDisableControls() protected;
/* ---------------------------------------------------------------------------
Created:	06 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	row: Integer;
begin

	if self.mode = Mode_Add then
		self.tblEntDetail.enableRowByName(ETRow_CargoType);
		self.tblEntDetail.goToRowByName(ETRow_CargoType);
		
	else
		//Par 18269. Disabling CargoType row when editing a current selected prod group.
		//Otherwise, if allow the change of the cargo type for this existing prod group,
		//the allProducts collection is left behind, and there is mess in data collection.	
		self.tblEntDetail.disableRowByName(ETRow_CargoType);	
		
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
