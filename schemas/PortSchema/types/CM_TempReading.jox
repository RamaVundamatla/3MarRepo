    <JadeMethod name="cloneForTrackedItemRefs" id="b26710ab-e7c4-4c95-b851-935d9b1b9c01">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti: CM_Container; _rawData : Binary) updating;
//--------------------------------------------------
// Created:	23 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myContainer := _ti;
	self.myReeferProperties := _ti.myReeferProperties;
	self.myRefConRawData := _rawData;
end;</source>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_rawData" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="cloneMe" id="edea040d-471b-4afa-8225-a3ad03859cd2">
        <source>cloneMe(_ti: CM_TrackedItem; _reeferProperties: CM_TIReeferProperties) : CM_TempReading;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2015	cnwdw1	Initial creation  36293
*/
vars
	clonedTemperatureReading: CM_TempReading;
begin
	clonedTemperatureReading := self.cloneSelf(false);
	clonedTemperatureReading.setMyTrackedItem(_ti);
	clonedTemperatureReading.setMyReeferProperties(_reeferProperties);
	return clonedTemperatureReading;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reeferProperties" type="CM_TIReeferProperties"/>
        <ReturnType type="CM_TempReading"/>
    </JadeMethod>
    <JadeMethod name="getAltDisplayTemp" id="d1bc54da-4c7a-49a4-ae00-49762044f315">
        <source>getAltDisplayTemp(_forceToCelcius: Boolean): String;
//----------------------------------------------------------------
//	Created:	July 2007 cnwrs1 CCMS 1551
//----------------------------------------------------------------
// 11/12/2009	cnwdap1		CCMS MES 1007 myContainer reference redundant, now use myReeferProperties
vars

begin
	if self.temperature = NULL_TEMPERATURE then
		return "No reading";
	elseif self.temperature = NULL_DEFROST_TEMPERATURE then //Aug 2007 cnwrs1 CCMS1551
		return "Defrost";
	//elseif self.myContainer &lt;&gt; null and 
	   //self.myContainer.myOperator &lt;&gt; null and
	   //self.myContainer.myOperator.displayTempFahrenheit and
	elseif self.myReeferProperties &lt;&gt; null and 
	   self.myReeferProperties.myParent.CM_TrackedItem.myOperator &lt;&gt; null and
	   self.myReeferProperties.myParent.CM_TrackedItem.myOperator.displayTempFahrenheit and
	   (not _forceToCelcius) then
		return app.temperatureDisplayString(app.myRoot.convCelsiusToFahrenheit(self.temperature)) &amp; Degrees_F;
	else
		return app.temperatureDisplayString(self.temperature) &amp; Degrees_C;
	endif;
end;
</source>
        <Parameter name="_forceToCelcius" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
