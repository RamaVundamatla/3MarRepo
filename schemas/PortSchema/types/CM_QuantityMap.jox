    <JadeMethod name="getAuditText" id="a4efc513-9406-4733-8b6c-92e582967062">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	txt,
	tmpStr	: String;
	invalidObject : Boolean;
	calcName : String;
	bank : CM_Bank;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	on Exception do app.handleDeletedObject(exception, self.myCalculationType, invalidObject);
	
	if self.myCalculationType &lt;&gt; null then
		calcName := self.myCalculationType.getName;
	endif;
	if not invalidObject then
		tmpStr := null;
		tmpStr := self.getTranMapBreadCrumb;
		txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;	
	tmpStr := null;
	if self.mappingType = CM_QuantityMap.MapType_Single then
		tmpStr :=  "Single";
		txt := txt &amp; app.getFormCaptionsString(Xlat_0006251) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	elseif self.mappingType = CM_QuantityMap.MapType_Escalate then
		tmpStr := "Escalating";
		txt := txt &amp;app.getFormCaptionsString(Xlat_0006251)&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := "Full";
		txt := txt &amp;app.getFormCaptionsString(Xlat_0006251)&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;

	endif;
	
	tmpStr := null;
	tmpStr := self.chargeZero.String;
	txt := txt &amp; app.getErrorString(Charge_zero_quantity) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	if not invalidObject then
		tmpStr :=null;
		if self.myCalculationType &lt;&gt; null then
			tmpStr :=self.getName;
			txt := txt &amp; app.getFormCaptionsString(Xlat_0006249) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;	
		endif;
	endif;
	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	// TFS 3509 if self.myParentFinancialObject.getBank &lt;&gt; null then
	bank := self.getBank(); // TFS 3509
	if bank &lt;&gt; null then // TFS 3509
		// TFS 3509 tmpStr := self.myParentFinancialObject.getBank.mailingName;
		tmpStr := bank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myParentFinancialObject.isKindOf(CM_DebtorMap) then
		if self.myParentFinancialObject.CM_DebtorMap.myDebtorNode &lt;&gt; null then 
			tmpStr := self.myParentFinancialObject.CM_DebtorMap.getDebtorDescription;  
			txt := txt &amp; app.getErrorString(Debtor_GC) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		endif;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="c0d49fea-0921-45d9-948e-2c557cb56982">
        <source>getBank() : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	bank : CM_Bank;
	invCargoAlloc : CM_InvoiceCargoAllocation;
	
begin
	
	//21 Aug 2017	NDL	TFS 5824
	if self.myParentFinancialObject &lt;&gt; null then
		bank := self.myParentFinancialObject.getBank();	
		if bank &lt;&gt; null then
			return bank;
		endif;
		
	endif;
	
	if self.myInvoiceAllocation &lt;&gt; null then
		if self.myInvoiceAllocation.myServiceBroker &lt;&gt; null then
			bank := self.myInvoiceAllocation.myServiceBroker.getBank();
			if bank &lt;&gt; null then
				return bank;
			endif;
		endif;
		
		if self.myInvoiceAllocation.isKindOf(CM_InvoiceCargoAllocation) then
			invCargoAlloc := self.myInvoiceAllocation.CM_InvoiceCargoAllocation;
			if invCargoAlloc.myTransactionMap &lt;&gt; null then
				bank := invCargoAlloc.myTransactionMap.getBank();
			endif;
			if bank &lt;&gt; null then
				return bank;
			endif;
		endif;
		
	endif;
		
	if self.myFutureStorageMap &lt;&gt; null then 
		bank := self.myFutureStorageMap.getBank();
		if bank &lt;&gt; null then
			return bank;
		endif;
		
	endif;
	
	return null;
	
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getCargoEndTime" id="3569bc1c-86b4-4ee5-93e7-13547866a1d1">
        <source>getCargoEndTime(_tran : CM_TITransaction) : TimeStamp;
//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
vars
	aCT		: CM_CalculationType;
	voyage	: CM_Voyage;
	endTime	: TimeStamp;
begin
	endTime := null;
	aCT := self.myCalculationType;
	if aCT &lt;&gt; null then
		if aCT.calculationType = INV_CALC_TYPE_DAYSINCE_SHIP_EN then
			endTime := null;
			// if the item is still on-site don't get the voyage date, code below will use the transaction date instead
			if _tran.myTrackedItem &lt;&gt; null and
			   _tran.myTrackedItem.isExport and
			   _tran.myTrackedItem.site = TI_SITE_ONSITE then
			// do nothing
			else
				voyage := _tran.getVoyage();
			endif;
			if voyage &lt;&gt; null then
				endTime := voyage.shipExchangeCompleteDT;
			endif;
		endif;
	endif;

	return endTime;
end;
</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDaysAlreadyChargedNew" id="21c9e192-b534-4322-a881-98e5525f5240">
        <source>getDaysAlreadyChargedNew(_tran : CM_TITransaction input) : Integer protected;
// ---------------------------------------------------------------------------
//   37718 but gives different results, incorrectly??, in unit tests such as tEscalatingStorageDays (0)
vars
	tran, prevTran : CM_TITransaction;
	bu : CM_Bank;
	startDateTime,
	endDateTime	: TimeStamp;
	daysAlreadyCharged	: Integer;
	calcType	: Integer;
	chargedDaysWorking	: Boolean;
	invalid		: Boolean;
	chargedDaysWorkingAndComp : Boolean;	//21 Sep 2017	NDL	TFS 7032
begin
	tran := _tran;
	chargedDaysWorking := tran.getChargedDaysWorking();
	chargedDaysWorkingAndComp := tran.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
	bu := self.getBank();
	if self.myCalculationType &lt;&gt; null then
		calcType := self.myCalculationType.calculationType;
	endif;
	prevTran := tran;
	while true do
		prevTran := prevTran.getStartTransaction();
		if prevTran = null then
			break;
		endif;
		on Exception do app.handleDeletedObject(exception, prevTran, invalid);
		endDateTime := prevTran.dateTime;
		if invalid then
			break;
		endif;
		on Exception do null;
		// 27229 Apr 2011 the days since ship start calculation type needs to use the ship exchange date here
		endDateTime := prevTran.dateTime;
		if tran.isKindOf(CM_Storage) and
		   prevTran.isKindOf(CM_ReceiveShip) and
		   calcType = INV_CALC_TYPE_DAYSINCE_SHIP_ST then
			endDateTime := tran.CM_Storage.getCargoStartTime(calcType, endDateTime);
		endif;
		// 33923  if the first storage transaction use the dateTime from it as it already has any additional free days included
		if prevTran.noCharge and
		   prevTran.isKindOf(CM_Storage) and not prevTran.CM_Storage.startTransaction.isKindOf(CM_Storage) then
			startDateTime := prevTran.dateTime;
		else
			startDateTime := prevTran.getStartDateTime(calcType);
		endif;
		daysAlreadyCharged := daysAlreadyCharged + bu.evaluateDaysCalendar(startDateTime, endDateTime, chargedDaysWorking, chargedDaysWorkingAndComp, tran ).Integer;
	endwhile;
	
	return daysAlreadyCharged;
end;</source>
        <access>protected</access>
        <Parameter name="_tran" type="CM_TITransaction" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getElapsedDays" id="3b08222f-9a1f-46f0-b55e-a8832a093c3b">
        <source>getElapsedDays(_tran : CM_TITransaction; _chargeByUnits : Integer; _chargedDaysWorking : Boolean; _storageConfig : CM_StorageConfig; _chargedDaysWorkingAndComp : Boolean) : Real protected;
/*

Purpose:		For 

Parameters:			

Return Value:		


Date			Who		Reason
04 October 2012	cnwjre1	Initial creation
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	chargeByUnitsStart,
	chargeByUnitsEnd	: Integer;
	value	: Real;
	startTime	: TimeStamp;
	endTime	: TimeStamp;
	bank	: CM_Bank;

begin
	bank := self.getBank();

	chargeByUnitsStart := _chargeByUnits;
	chargeByUnitsEnd := _chargeByUnits;
	startTime := _tran.getStartDateTimeFSD(chargeByUnitsStart, _storageConfig);
	endTime := _tran.getEndDateTimeFSD(chargeByUnitsEnd, _storageConfig);
	value := bank.evaluateDaysCalendar(startTime, endTime, _chargedDaysWorking, _chargedDaysWorkingAndComp, _tran);
	app.invLog(method.qualifiedName &amp; " startTime=" &amp; startTime.String &amp; " endTime=" &amp; endTime.String &amp; " value=" &amp; value.String, LogINFO.String);
	if value &lt; 0 then
		value := 0;
	endif;
	return value;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <Parameter name="_chargeByUnits" type="Integer"/>
        <Parameter name="_chargedDaysWorking" type="Boolean"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
        <Parameter name="_chargedDaysWorkingAndComp" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getExtractDetails" id="66cd0bd5-d845-4e57-aa1c-aab6bb357064">
        <source>getExtractDetails() : String;
// 23659 Apr 2010 invoice transaction map extract to use codes instead of descriptions
//  in this case, to extract enough to re-create the properties.  Keep the description but with no "Quantity by" prefix
vars
	details	: String;
	tmp : String;
	calcType	: CM_CalculationType;
begin
	if self.mappingType = CM_QuantityMap.MapType_Single then
		tmp := "›";
	elseif self.mappingType = CM_QuantityMap.MapType_Escalate then
		tmp := "»";
	else
		tmp := "†";
	endif;
	if self.chargeZero then
		tmp := tmp &amp; " …";
	endif;

	if self.myCalculationType = null then
		details := CM_FinancialObject.Extract_Default;
	else
		calcType := self.myCalculationType;
		// CCMS SFW 1279 May 2012 Storage Escalating Charges, user-defined calc type
		if calcType.isCargoCalcType 
		and not calcType.isStandardCargo() then
			details := "*" &amp; calcType.code &amp; "* " &amp; calcType.getCalcTypeDesc();
		else
			details := "|" &amp; calcType.code &amp; "|" &amp; calcType.getCalcTypeDesc(); // TFS 41096 add '|'
		endif;
	endif;
	
//	write details;
	return details &amp; " " &amp; tmp;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHealthCheckItemType" id="8723180b-415c-4146-8ddd-dd4b3785b039">
        <source>getHealthCheckItemType() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2017	jlgab1	Initial creation

*/

vars
	debtorMap : CM_DebtorMap;
	qrMap : CM_QuantityRangeMap;
begin
	if self.myParentFinancialObject &lt;&gt; null then
		if  self.myParentFinancialObject.isKindOf(CM_TransServiceBroker) 
		or  self.myParentFinancialObject.isKindOf(CM_TransResourceServiceBroker) 
		or  self.myParentFinancialObject.isKindOf(CM_MoveServiceBroker) then
			return CMIF_InvoiceHealthAgent.ItemType_TranMapCargo;
		endif;
		if  self.myParentFinancialObject.isKindOf(CM_EventServiceBroker)  then
			return CMIF_InvoiceHealthAgent.ItemType_TranMapEvent;
		endif;
		if  self.myParentFinancialObject.isKindOf(CM_ResourceServiceBroker)  then
			return CMIF_InvoiceHealthAgent.ItemType_TranMapHMS;
		endif;
		if  self.myParentFinancialObject.isKindOf(CM_CargoAllocServiceBroker)  then
			return CMIF_InvoiceHealthAgent.ItemType_TranMapAlloc;
		endif;
		
		
		if  self.myParentFinancialObject.isKindOf(CM_DebtorMap)  then
		
			debtorMap :=  self.myParentFinancialObject.CM_DebtorMap;
			if debtorMap &lt;&gt; null then
				if  debtorMap.myServiceBroker.isKindOf(CM_TransServiceBroker) 
				or  debtorMap.myServiceBroker.isKindOf(CM_TransResourceServiceBroker) 
				or  debtorMap.myServiceBroker.isKindOf(CM_MoveServiceBroker) then
					return CMIF_InvoiceHealthAgent.ItemType_TranMapCargo;
				endif;
				if  debtorMap.myServiceBroker.isKindOf(CM_EventServiceBroker)  then
					return CMIF_InvoiceHealthAgent.ItemType_TranMapEvent;
				endif;
				if  debtorMap.myServiceBroker.isKindOf(CM_ResourceServiceBroker)  then
					return CMIF_InvoiceHealthAgent.ItemType_TranMapHMS;
				endif;
			endif;
	
			
			return CMIF_InvoiceHealthAgent.ItemType_TranMapCargo;
		endif;
		
		// ### SUB QUANTITY RANGE
		if  self.myParentFinancialObject.isKindOf(CM_QuantityRangeMap)  then
			qrMap := self.myParentFinancialObject.CM_QuantityRangeMap;
			if qrMap&lt;&gt; null then
				if qrMap.myQuantityMap &lt;&gt; null then
					return qrMap.myQuantityMap.getHealthCheckItemType();
				endif;
			endif;
		endif;
	endif;
	
	if self.myInvoiceAllocation &lt;&gt; null then
			return CMIF_InvoiceHealthAgent.ItemType_TranMapSummary;
	
	endif;

	
	return 0;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getInvLineDescForEscalating" id="fd3ef7e5-dfc4-467f-8ec5-fa03a044ded3">
        <source>getInvLineDescForEscalating(_aSBController : CMIF_ServiceBroker input; _tranQty : Real);
// ---------------------------------------------------------------------------
// Created:		11 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 16/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
 // ### TFS 51219 28MAY2021 NAVAB1 removed unused ti variable and code
// 	23 Oct 2024	navlw1 JIRA-33107: Invoice Logging Use Levels
//	25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
// ---------------------------------------------------------------------------
vars
	qtyRangeMap, 
	qtyRubRangeMap	: CM_QuantityRangeMap;
	tiTrans 		: CM_TITransaction;
	tranQty 		:    Real;
	canLogExtra		: Boolean;	//27.02.2025 navah1	#34141
	childQM		    : CM_QuantityMap;
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141 
	tiTrans := _aSBController.myTransaction;
	
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("Escalating quantity range, quantity " &amp; _tranQty.String, LogINFO.String);
	endif;
	foreach qtyRangeMap in self.allQuantityRanges discreteLock do
		if _tranQty &gt;= qtyRangeMap.rangeStart then
			
			//15/02/2017 cnwma1 TFS #2901
			childQM := qtyRangeMap.myChildQuantityMap;
			
			if childQM &lt;&gt; null  and tiTrans &lt;&gt; null then  // Inventory does not have child maps // ### TFS 51219 01JUN2021 NAVAB1
			   
				tranQty := childQM.getQuantityForTransactionCargo(tiTrans);
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Finding Sub quantity, quantity " &amp; tranQty.String, LogINFO.String);
				endif;
				if childQM.mappingType = self.MapType_Single and not self.chargeZero then
					childQM.getInvLineDescForSingle(_aSBController, tranQty);
				else
					if tiTrans &lt;&gt; null and tiTrans.type = TRANS_TYPE_STORAGE then
						childQM.getInvLineDescForEscalatingStg(_aSBController);
					else
						childQM.getInvLineDescForEscalating(_aSBController, tranQty );
					endif;
				endif;
			else
				qtyRangeMap.getInvoiceLineDesc(_aSBController);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
        <Parameter name="_tranQty" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getInvLineDescForEscalatingStg" id="a512b338-3de8-4608-86a0-c0aeadea789f">
        <source>getInvLineDescForEscalatingStg(_aSBController : CMIF_ServiceBroker input);
// ---------------------------------------------------------------------------
// Created:		11 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		PAR 24160
//16/02/2017 	cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
//23/03/2018	jlgmd1	TFS 37764 STWO - Exception when processing a future storage request
//23 Oct 2024	navlw1 	JIRA-33107: Invoice Logging Use Levels
//25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
// ---------------------------------------------------------------------------
vars
	qtyRangeMap : CM_QuantityRangeMap;
	tran, prevTran : CM_TITransaction;
	bu : CM_Bank;
	startTime,
	endTime	: TimeStamp;
	daysToCharge, daysAlreadyCharged	: Integer;
	calcType	: Integer;
	chargedDaysWorking	: Boolean;
	found		: Boolean;
	invalidObject : Boolean;
	tranQty :    Real;
	chargedDaysWorkingAndComp : Boolean;	//21 Sep 2017	NDL	TFS 7032
	ed : Integer;
	term : CM_Terminal;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141 
	tran := _aSBController.myTransaction;
	chargedDaysWorking := tran.getChargedDaysWorking();
	chargedDaysWorkingAndComp := tran.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
	bu := self.getBank();
	if self.myCalculationType &lt;&gt; null then
		calcType := self.myCalculationType.calculationType;
	endif;
	startTime := tran.getStartDateTime(calcType);
	daysToCharge := bu.evaluateDaysCalendar(startTime, tran.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, tran).Integer;
	prevTran := tran;
	term := bu.getMyTerminal(); // TFS 43405
	
	// 23 Mar 2018 jlgmd1 TFS 37764 - Moved exception handler outside of the loop
	on Exception do app.handleDeletedObject(exception, prevTran, invalidObject);
	
	while true do
		invalidObject := false;
		
		prevTran := prevTran.getStartTransaction();
		if prevTran = null then
			break;
		endif;
		
		ed := prevTran.edition;
		if invalidObject then
			break;
		endif;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " prevTran=" &amp; prevTran.String, LogTRACE.String);
		endif;
		// Nov 2010 cnwjre1 par 26107 CCMS 2020 invoice storage by first/last voyage cargo, get the correct end time
		endTime := null;
		//invalidObject := false;
		// cnwjre1 Feb 2011 dmast has a number of CM_Storage instances with .startTransactions of invalid CM_ReceiveShip
		//on Exception do app.handleDeletedObject(exception, prevTran, invalidObject);		//-TFS 37764
		if prevTran.getStartTransaction() = null then
			endTime := self.getCargoEndTime(tran);
			if endTime &lt;&gt; null then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " endTime from getCargoEndTime=" &amp; endTime.String, LogINFO.String);
				endif;
			endif;
		endif;
		
		if endTime = null then
			endTime := prevTran.dateTime;
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " endTime from prevTran.dateTime=" &amp; endTime.String, LogINFO.String);
			endif;
		endif;
		
		// TFS 43405 JLGAB1 PEL1 cargo work orders can have storage transactions that are no charge because they are PREPAY
		if prevTran.isStorageWorkOrder() then 
			daysAlreadyCharged := daysAlreadyCharged + bu.evaluateDaysCalendar(prevTran.getStartDateTime(calcType), endTime, chargedDaysWorking, chargedDaysWorkingAndComp, prevTran).Integer;
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; "  PEL1 WO daysAlreadyCharged=" &amp; daysAlreadyCharged.String, LogINFO.String);
			endif;
			// TFS 3588 only count storage days actually charged, otherwise this can return the wrong quantity range maps below
		elseif prevTran.noCharge then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " prevTran noCharge so not included in daysAlreadyCharged", LogINFO.String);
			endif;
		else
			daysAlreadyCharged := daysAlreadyCharged + bu.evaluateDaysCalendar(prevTran.getStartDateTime(calcType), endTime, chargedDaysWorking, chargedDaysWorkingAndComp, prevTran).Integer;
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " daysAlreadyCharged=" &amp; daysAlreadyCharged.String, LogINFO.String);
			endif;
		endif;
		
	endwhile;
	
	on Exception do null;	// Clear our exception handler
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("Escalating storage quantity range, days already charged " &amp; daysAlreadyCharged.String &amp; ", days to charge " &amp; daysToCharge.String, LogINFO.String);
	endif;
	found := false;
	foreach qtyRangeMap in self.allQuantityRanges discreteLock do

		//if daysAlreadyCharged &lt;= qtyRangeMap.rangeEnd 	// original
		if daysAlreadyCharged &lt; qtyRangeMap.rangeEnd 		// cnwjre1 July 2010 par 24160 testing
		and (daysAlreadyCharged + daysToCharge) &gt;= qtyRangeMap.rangeStart then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " found ILD, daysAlreadyCharged=" &amp; daysAlreadyCharged.String &amp; " (daysAlreadyCharged + daysToCharge)=" &amp; (daysAlreadyCharged + daysToCharge).String
								&amp; " qrm.rangeEnd=" &amp; qtyRangeMap.rangeEnd.String &amp; " qrm.rangeStart=" &amp; qtyRangeMap.rangeStart.String, LogINFO.String);
			endif;
			//qtyRangeMap.getInvoiceLineDesc(_aSBController);  //15/02/2017 cnwma1 TFS #2901
			if qtyRangeMap.myChildQuantityMap &lt;&gt; null then     //15/02/2017 cnwma1 TFS #2901
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Finding Sub quantity, quantity " &amp; tranQty.String, LogINFO.String);
				endif;
				if self.mappingType = self.MapType_Single and not self.chargeZero then // TFS 2901 AB 22MAR17
					tranQty := qtyRangeMap.myChildQuantityMap.getQuantityForTransactionCargo(tran);
					qtyRangeMap.myChildQuantityMap.getInvLineDescForSingle(_aSBController,tranQty);
				
				else // TFS 2901 AB 22MAR17
					qtyRangeMap.myChildQuantityMap.getInvLineDescForEscalatingStg(_aSBController); // TFS 2901 AB 22MAR17
				endif; // TFS 2901 AB 22MAR17

			else
				if self.mappingType = self.MapType_Single and not self.chargeZero then // TFS 2901 AB 22MAR17
					tranQty := self.getQuantityForTransactionCargo(tran); // TFS 2901 AB 22MAR17
					self.getInvLineDescForSingle(_aSBController,tranQty); // TFS 2901 AB 22MAR17
					found := true;
					break; // TFS 2901 AB 22MAR17
				else
					qtyRangeMap.getInvoiceLineDesc(_aSBController);
				endif;
			endif;
			found := true;
		endif;
	endforeach;
	if not found then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No matching invoice line maps found", LogTRACE.String);
		endif;
	endif;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvLineDescForFutureStorage" id="778dac98-9afb-418f-82ad-cdf23cdf0130">
        <source>getInvLineDescForFutureStorage(_aSBController : CMIF_ServiceBroker input);
/*
Purpose:	// TFS 4271		
Date			Who			Reason
JUNE 2017		CNWAB1		Initial creation
23/03/2018		jlgmd1		TFS 37764 STWO - Exception when processing a future storage request
23 Oct 2024		navlw1 		JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	qtyRangeMap : CM_QuantityRangeMap;
	tran, prevTran : CM_TITransaction;
	bu : CM_Bank;
	daysToCharge, daysAlreadyCharged	: Integer;
	chargedDaysWorking	: Boolean;
	found		: Boolean;
	invalidObject : Boolean;
	tranQty :    Real;
	chargedDaysWorkingAndComp : Boolean;	//21 Sep 2017	NDL	TFS 7032
	ed : Integer;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141 
	tran := _aSBController.myTransaction;
	if tran.type &lt;&gt; TRANS_TYPE_FUTURE_STORAGE then
		return;
	endif;
	
	chargedDaysWorking := tran.getChargedDaysWorking();
	chargedDaysWorkingAndComp := tran.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
	bu := self.getBank();
	daysToCharge := tran.CM_FutureStorage.daysCharged; 
	
	prevTran := tran;
	
	// 23 Mar 2018 jlgmd1 TFS 37764 - Moved exception handler outside of the loop
	on Exception do app.handleDeletedObject(exception, prevTran, invalidObject);
	
	while true do
		invalidObject := false;
		prevTran := prevTran.getStartTransaction();
		
		if prevTran = null then
			break;
		endif;
		
		ed := prevTran.edition;
		if invalidObject then
			break;
		endif;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " prevTran=" &amp; prevTran.String, LogINFO.String);
		endif;
		if prevTran.noCharge then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " prevTran noCharge so not included in daysAlreadyCharged", LogINFO.String);
			endif;
		else
			if prevTran.type = TRANS_TYPE_FUTURE_STORAGE then // TFS 4271
				daysAlreadyCharged := daysAlreadyCharged + prevTran.CM_FutureStorage.daysCharged; // TFS 4271
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " FUTURE daysAlreadyCharged=" &amp; daysAlreadyCharged.String, LogINFO.String); // TFS 4271
				endif;
			endif;
		endif;
	endwhile;
	
	on Exception do null;	// Clear our exception handler
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("Escalating storage quantity range, days already charged " &amp; daysAlreadyCharged.String &amp; ", days to charge " &amp; daysToCharge.String, LogINFO.String);
	endif;
	found := false;
	foreach qtyRangeMap in self.allQuantityRanges discreteLock do

		if (daysAlreadyCharged &lt; qtyRangeMap.rangeEnd) 		
		and (daysAlreadyCharged + daysToCharge) &gt;= qtyRangeMap.rangeStart then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " found ILD, daysAlreadyCharged=" &amp; daysAlreadyCharged.String &amp; " (daysAlreadyCharged + daysToCharge)=" &amp; (daysAlreadyCharged + daysToCharge).String
								&amp; " qrm.rangeEnd=" &amp; qtyRangeMap.rangeEnd.String &amp; " qrm.rangeStart=" &amp; qtyRangeMap.rangeStart.String, LogINFO.String);
			endif;
			qtyRangeMap.getInvoiceLineDesc(_aSBController);
			
			found := true;
		endif;
	endforeach;
	if not found then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No matching invoice line maps found", LogTRACE.String);
		endif;
	endif;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvLineDescForResourceUsage" id="c49a8985-c3fb-4b2c-b6d3-aff29b28d355">
        <source>getInvLineDescForResourceUsage(_aSBController: CMIF_ServiceBroker input; resourceUsage: CM_ResourceTypeUsage);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	tranQty : Real;
	lineDescription : CM_InvoiceLineDesc;
	
begin

	if resourceUsage = null or resourceUsage.noCharge then
		lineDescription := self.getInvoiceLineVOID();
		_aSBController.allInvoiceLineTypes.add(lineDescription);
		return;
	endif;
	
	tranQty := resourceUsage.quantity;
	
	if self.mappingType = self.MapType_Single and not self.chargeZero then
		self.getInvLineDescForSingle(_aSBController, tranQty);
	else
		self.getInvLineDescForEscalating(_aSBController, tranQty );
	endif;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
        <Parameter name="resourceUsage" type="CM_ResourceTypeUsage"/>
    </JadeMethod>
    <JadeMethod name="getInvLineDescForSingle" id="ffb0a60f-a95e-412d-8fdc-a078b258fb55">
        <source>getInvLineDescForSingle(_aSBController : CMIF_ServiceBroker input; _tranQty : Real);
// ---------------------------------------------------------------------------
// Created:		11 October 2007 By Andrew Bishop cnwab1
//16/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// Purpose:		
//
// ---------------------------------------------------------------------------
//Date			Who			Reason
//23 Oct 2024	navlw1 		JIRA-33107: Invoice Logging Use Levels
//
vars
	qtyRangeMap 	 : CM_QuantityRangeMap;
	lineDescription	 : CM_InvoiceLineDesc;
	canLogExtra		 : Boolean;
	
begin
	
	canLogExtra	:= app.canLogExtraDetail();									//05.10.2022 navma1 #52967
	
	if not self.myParentFinancialObject.isKindOf(CM_QuantityRangeMap) then  //15/02/2017 cnwma1 TFS #2901
		_aSBController.allInvoiceLineTypes.clear;
	endif;

	qtyRangeMap := self.getQuantityRangeForValue(_tranQty,_aSBController);   //28/02/2017 cnwma1 TFS #2901
	
	if qtyRangeMap = null then
		lineDescription := self.getInvoiceLineVOID();
		if lineDescription &lt;&gt; null and canLogExtra then						 // 05.10.2022 navmd1 #52967
			app.invLog("Invoice line map " &amp; lineDescription.narration &amp; ", no quantity range found for " &amp; _tranQty.String, LogTRACE.String);
		endif;
		_aSBController.allInvoiceLineTypes.add(lineDescription);
		_aSBController.allQuantityRangeMaps.add(null);
		_aSBController.allLineGroups.add(TranMapInvLineGroupTypeAll);
		return;
	endif;
	

	if qtyRangeMap.myChildQuantityMap &lt;&gt; null then 								// TFS 2901 SUB RANGES
		if canLogExtra then													   // 05.10.2022 navmd1 #52967
			app.invLog("Finding quantity Sub range " &amp; qtyRangeMap.myChildQuantityMap.getName(), LogINFO.String);
		endif;
		qtyRangeMap.myChildQuantityMap.getInvoiceLineDesc(_aSBController); // TFS 2901 
	else
		qtyRangeMap.getInvoiceLineDesc(_aSBController);
	endif;

end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
        <Parameter name="_tranQty" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDEFAULT" id="25d83bbc-778e-4eaf-b06b-a77119374bce">
        <source>getInvoiceLineDEFAULT() : CM_InvoiceLineDesc;
// ---------------------------------------------------------------------------
// Created:		05 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars	

begin
	return self.allQuantityRanges.first.getDefaultInvoiceLine();

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="0ab656bf-d7a7-4c0c-af1d-e2a4d9c9969c">
        <source>getInvoiceLineDesc(_aSBController : CMIF_ServiceBroker input);
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		We need use out calctype to get the quantity, then get the quantity 
//					range map for that value and then get the invoice line type.
//
// ---------------------------------------------------------------------------
vars
	tiTrans : CM_TITransaction;
	qtyRangeMap : CM_QuantityRangeMap;
	tranQty : Real;
begin
	
	tiTrans := _aSBController.myTransaction;
	
	// TFS 4271 future storage transactions have a fixed quantity which is set from the storage configuration detail CM_StorageDetail.chargeDays
	// 				the quantity will always be this amount (the first future storage transaction could be 1 day more or less than this based 
	//				on including the first and last days options).
	//				This means that a lot of options on the mapping screen are meaningless, so they are disabled.
	if tiTrans &lt;&gt; null and tiTrans.type = TRANS_TYPE_FUTURE_STORAGE then // TFS 4271
		self.getInvLineDescForFutureStorage(_aSBController);
		return;
	endif;
	
	if tiTrans = null 
	and _aSBController.myVTMISTransaction = null 
	and _aSBController.myEventTransaction = null 
	and _aSBController.myTransactionWO = null // TFS 42161
	and _aSBController.myBOLTransaction = null	//01 Nov 2019	NDL	TFS 47100
	and _aSBController.myInventoryEvent = null	 // ### TFS 51219 01JUN2021 NAVAB1
	then
		// see CM_Bank::getSTorageTimes()
		// this is a speciial case for CARGO STORAGE transactions, at this point there is no transaction
		// so for the moment we will assume that there is only one quantity range, and use that.
		// need to think about using ranges for storage, problem is we need the storage transaction to get the quantity.
		qtyRangeMap := self.allQuantityRanges.first;
		qtyRangeMap.getInvoiceLineDesc(_aSBController);
		return;
	endif;
	if _aSBController.myVTMISTransaction &lt;&gt; null then
		tranQty := self.getQuantityForTransactionVTMIS(_aSBController.myVTMISTransaction);
	elseif _aSBController.myEventTransaction &lt;&gt; null then
		tranQty := self.getQuantityForTransactionEvent(_aSBController.myEventTransaction);
	elseif _aSBController.myTransactionWO &lt;&gt; null then // TFS 42161
		tranQty := self.getQuantityForTransactionWO(_aSBController.myTransactionWO); // TFS 42161
	elseif _aSBController.myBOLTransaction &lt;&gt; null then //01 Nov 2019	NDL	TFS 47100
		tranQty := self.getQuantityForTransactionBOL(_aSBController.myBOLTransaction); // TFS 42161
	elseif _aSBController.myInventoryEvent &lt;&gt; null then // ### TFS 51219 01JUN2021 NAVAB1
		tranQty := self.getQuantityForTransactionInvnt(_aSBController.myInventoryEvent);  // ### TFS 51219 01JUN2021 NAVAB1
	
	
	else
		tranQty := self.getQuantityForTransactionCargo(tiTrans);
	endif;
	if self.mappingType = self.MapType_Single and not self.chargeZero then
		self.getInvLineDescForSingle(_aSBController, tranQty);
	else
		// Storage transactions are linked so we need to do special processing for 
		// them when it comes to these quantity ranges
		// PAR 24160
		if tiTrans &lt;&gt; null and tiTrans.type = TRANS_TYPE_STORAGE then
			self.getInvLineDescForEscalatingStg(_aSBController);
		else
			self.getInvLineDescForEscalating(_aSBController, tranQty );
		endif;
	endif;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescVTMIS" id="0db597b8-5ab5-481b-9d30-ff0a4e552878">
        <source>getInvoiceLineDescVTMIS(_poc : Boolean): CM_InvoiceLineDesc;
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	lineDescription:   CM_InvoiceLineDesc;
	aQRM : CM_QuantityRangeMap;
	mapping : CM_TranMapInvoiceLineMapping;
begin

	aQRM := self.allQuantityRanges.first; //This method just wants the calulation type, but we do not have a QTY so we will have to take the first one.

	if _poc then
		// Unlike CARGO invoicing there are ONLY 2 QUESTIONS TO ASK AND THEY ARE ALWAYS MAPPED.
		// TFS 40620 lineDescription := aQRM.allInvoiceLineMaps[CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT]; 
		mapping := aQRM.allTMInvoiceLineMappings[CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT]; // TFS 40620
		lineDescription := mapping.myTMInvoiceLineDesc; // TFS 40620
	else
		// TFS 40620 lineDescription := aQRM.allInvoiceLineMaps[CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT]; 
		mapping := aQRM.allTMInvoiceLineMappings[CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT]; // TFS 40620
		lineDescription := mapping.myTMInvoiceLineDesc; // TFS 40620
	endif;
	return lineDescription;
end;</source>
        <Parameter name="_poc" type="Boolean"/>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineVOID" id="ddc13fb0-90ff-4198-93bb-a4097a10e7b1">
        <source>getInvoiceLineVOID() : CM_InvoiceLineDesc;
// ---------------------------------------------------------------------------
// Created:		05 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars	

	theBank : CM_Bank;
	lineDescription : CM_InvoiceLineDesc;
begin
	theBank := self.getBank();
	lineDescription := theBank.voidInvoiceLineDesc;
	return lineDescription;

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="getName" id="eafc6b61-9d33-4ac8-8866-e50876deabd9">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		02 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
//11/09/2017 cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
// ---------------------------------------------------------------------------
vars
	desc	: String;
	calcType	: CM_CalculationType;
begin

	if self.myCalculationType = null then
		return "Default (Quantity)";
	else
	
		desc := self.myCalculationType.description;  // TFS 39198
		
		if self.myParentFinancialObject.isKindOf (CM_QuantityRangeMap) then //27/02/2017 cnwma1 TFS #2901
			return "Sub Quantity by " &amp; desc;
		endif;
		return "Quantity by " &amp; desc;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForTranCargoByType" id="a7d90113-6def-430e-ac58-1d6debdfaec7">
        <source>getQuantityForTranCargoByType(_tran : CM_TITransaction; _chargeByUnit : Integer) : Real;
/*
Purpose:		// PAR 30681	
Date				Who			Reason
DECEMBER 2012		CNWAB1		Initial creation
23 Oct 2024			navlw1 		JIRA-33107: Invoice Logging Use Levels
*/

vars
	numTEU, value : Real;
	chargedDaysWorking	: Boolean;
	theBank : CM_Bank;
	terminal	: CM_Terminal;
	storageConfig	: CM_StorageConfig;
	chargedDaysWorkingAndComp : Boolean;	//21 Sep 2017	NDL	TFS 7032
begin
	theBank := self.getBank();

	if _tran &lt;&gt; null then 
		chargedDaysWorking := _tran.getChargedDaysWorking();
		chargedDaysWorkingAndComp := _tran.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
		if _chargeByUnit = INV_CALC_TYPE_UNITY then
			value := 1.0;
		elseif _chargeByUnit = INV_CALC_TYPE_QUANTITY then
			value := _tran.getChargeQuantity(); 
		elseif _chargeByUnit = INV_CALC_TYPE_TRANSQUANTITY then
			value := _tran.getChargeQuantity();
		elseif _chargeByUnit = INV_CALC_TYPE_WEIGHT then
			value := _tran.getChargeWeight(); 
		elseif _chargeByUnit = INV_CALC_TYPE_WEIGHT_TON then
			value := _tran.getChargeWeight()/1000;
		elseif _chargeByUnit = INV_CALC_TYPE_VOLUME then
			value := _tran.getChargeVolume(); 
			if value = 0 then
				value := _tran.totalVolume;
			endif;
		elseif _chargeByUnit = INV_CALC_TYPE_REVENUE_TONS then
		/*	if _tran.getChargeVolume() &gt; _tran.getChargeWeight() / 1000 then
				value := _tran.getChargeVolume();
			else
				value := _tran.getChargeWeight() / 1000;
			endif; */
			value := _tran.getRTvalue(); //08 May 2019	NDL	TFS 38525
		// per-day calculation types - refactored for CCMS 1295 free storage days
		elseif _chargeByUnit = INV_CALC_TYPE_DAYS_SINCE_RECVL or
			   _chargeByUnit = INV_CALC_TYPE_DAYSINCE_SUBTERM or 	//28 Jun 2018	NDL	TFS 39338
			   _chargeByUnit = INV_CALC_TYPE_DAYSINCE_REC_TEU or
			   _chargeByUnit = INV_CALC_TYPE_DAYSINCE_REC_RT or	//08 May 2018	NDL	TFS 38525
			   _chargeByUnit = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
			   _chargeByUnit = INV_CALC_TYPE_DAYSINCE_SHIP_EN or
			   _chargeByUnit = INV_CALC_TYPE_DAYSINCE_VOY_IN or
			   _chargeByUnit = INV_CALC_TYPE_DAYSINCE_VOY_OUT or
			   _chargeByUnit = INV_CALC_TYPE_DAYS_WEIGHT or
			   _chargeByUnit = INV_CALC_TYPE_DAYS_VOLUME
			   then
			terminal := theBank.terminal;
			if terminal &lt;&gt; null then
				storageConfig := terminal.myStorageConfig;
			endif;
			value := self.getElapsedDays(_tran, _chargeByUnit, chargedDaysWorking, storageConfig, chargedDaysWorkingAndComp);
			// now do the calculation-type specific processing
			if _chargeByUnit = INV_CALC_TYPE_DAYSINCE_REC_TEU then
				numTEU := _tran.myTrackedItem.getNumTEU();
				if numTEU &gt; 0 then
					value := (value * numTEU);
				endif;
			elseif _chargeByUnit = INV_CALC_TYPE_DAYSINCE_REC_RT then	//08 May 2018	NDL	TFS 38525
				if value &lt; 0 then
					value := 0;
				else
					value := value * _tran.getRTvalue;
				endif;
			elseif _chargeByUnit = INV_CALC_TYPE_DAYS_WEIGHT then
				value := value * _tran.getChargeWeight();
			elseif _chargeByUnit = INV_CALC_TYPE_DAYS_VOLUME then
				value := value * _tran.getChargeVolume();			
			endif;
		elseif _chargeByUnit = INV_CALC_TYPE_DAYS_ONSITE_AT then
			value := theBank.evaluateDaysOnsiteAtCalendar(_tran.getStartDateTime(_chargeByUnit), _tran.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, _tran );
		elseif _chargeByUnit = INV_CALC_TYPE_DAYS_CONNECTED then
			value := _tran.getChargeQuantity();
			
		elseif _chargeByUnit = INV_CALC_TYPE_DISCREPANCYVALUE then	//19 Mar 2018	NDL	TFS 37558
			value := _tran.getChargeQuantity();
			
		elseif _chargeByUnit = INV_CALC_TYPE_DISCREPANCYABS then	//21 Jun 2018	NDL	TFS 39217
			value := _tran.getChargeQuantity().abs;	
			
		elseif (_chargeByUnit = INV_CALC_TYPE_CARGOWEIGHTCONVT  // TFS 4709
			or _chargeByUnit = INV_CALC_TYPE_CARGOLENGTHCONVT  // TFS 4709
			or _chargeByUnit = INV_CALC_TYPE_CARGOVOLUMECONVT) then // TFS 4709
			
			value := self.quantityCARGObyMeasurement(_tran, _chargeByUnit); // TFS 4709
		elseif (_chargeByUnit = INV_CALC_TYPE_QUANTITY_ONBOARD) then //jlier1 TFS 63956 20/5/24
			value:=_tran.onboardQuantity; 
		endif;
	endif;

	app.invLog(method.qualifiedName &amp; " _chargeByUnit=" &amp; _chargeByUnit.String &amp; " value=" &amp; value.String, LogINFO.String);

	return value;

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <Parameter name="_chargeByUnit" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForTransaction" id="2edd1760-2277-4ffd-b6ef-7c20d861f078">
        <source>getQuantityForTransaction(_tran : CM_TITransaction) : Real;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		ANY CHANGES HERE NEED TO BE DONE IN CM_InvoiceLine::quantityCARGO
//	**** Oct 2012 CCMS 1295 - this method has no references - it is probably replaced by getQuantityForTransactionCargo ****
// ---------------------------------------------------------------------------
vars
	value : Real;
	chargedDaysWorking	: Boolean;
	aCT : CM_CalculationType;
	theBank : CM_Bank;
	theTI : CM_TrackedItem;
	endTime	: TimeStamp;
	numTEU : Real;
	chargedDaysWorkingAndComp : Boolean;	//21 Sep 2017	NDL	TFS 7032
begin
	aCT := self.myCalculationType;
	
	if aCT = null then // default
		return 1; // default;
	endif;
	theBank := self.getBank();

	if _tran &lt;&gt; null then 
		theTI := _tran.myTrackedItem;
		chargedDaysWorking := _tran.getChargedDaysWorking();
		chargedDaysWorkingAndComp := _tran.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
		if theTI = null then
			return 1;
		endif;
		if aCT.calculationType = INV_CALC_TYPE_UNITY then
			value := 1.0;
		elseif aCT.calculationType = INV_CALC_TYPE_QUANTITY then
			value := theTI.getChargeQuantity(); //self.trackedItemQuantity;
		elseif aCT.calculationType = INV_CALC_TYPE_TRANSQUANTITY then
			value := _tran.getChargeQuantity();
		elseif aCT.calculationType = INV_CALC_TYPE_WEIGHT then
			value := theTI.getChargeWeight(); //theTI.getChargeWeight();
		elseif aCT.calculationType = INV_CALC_TYPE_WEIGHT_TON then
			value := theTI.getChargeWeight()/1000;
		elseif aCT.calculationType = INV_CALC_TYPE_VOLUME then
			value := theTI.getChargeVolume(); //theTI.getChargeVolume();
			if value = 0 then
				value := _tran.totalVolume;
			endif;
		elseif aCT.calculationType = INV_CALC_TYPE_REVENUE_TONS then
		/*	if theTI.getChargeVolume() &gt; theTI.getChargeWeight() / 1000 then
				value := theTI.getChargeVolume();
			else
				value := theTI.getChargeWeight() / 1000;
			endif;*/
			value := _tran.getRTvalue;	//08 May 2018	NDL	TFS 38525
		elseif aCT.calculationType = INV_CALC_TYPE_DAYS_SINCE_RECVL then
			value := theBank.evaluateDaysCalendar(_tran.getStartDateTime(aCT.calculationType), _tran.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, _tran);
			if value &lt; 0 then // PAR 11255
				value := 0;
			endif;
		elseif aCT.calculationType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
			value := theBank.evaluateDaysCalendar(_tran.getStartDateTime(aCT.calculationType), _tran.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, _tran);
			if value &lt; 0 then 
				value := 0;
			endif;
		elseif aCT.calculationType = INV_CALC_TYPE_DAYSINCE_REC_TEU then
			value := theBank.evaluateDaysCalendar(_tran.getStartDateTime(aCT.calculationType), _tran.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, _tran);
			if value &lt; 0 then // PAR 11255
				value := 0;
			endif;
			numTEU := _tran.myTrackedItem.getNumTEU();
			if numTEU &gt; 0 then
				value := (value * numTEU);
			endif;
		elseif aCT.calculationType = INV_CALC_TYPE_DAYSINCE_REC_RT then	//08 May 2018	NDL	TFS 38525
			value := theBank.evaluateDaysCalendar(_tran.getStartDateTime(aCT.calculationType), _tran.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, _tran);
			if value &lt; 0 then
				value := 0;
			else
				value := value * _tran.getRTvalue;
			endif;
		//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
		elseif aCT.calculationType = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
			   aCT.calculationType = INV_CALC_TYPE_DAYSINCE_SHIP_EN then
			endTime := _tran.getEndDateTime(aCT.calculationType);
			value := theBank.evaluateDaysCalendar(_tran.getStartDateTime(aCT.calculationType), endTime, chargedDaysWorking, chargedDaysWorkingAndComp, _tran);
			if value &lt; 0 then
				value := 0;
			endif;
		elseif aCT.calculationType = INV_CALC_TYPE_DAYS_ONSITE_AT then
			value := theBank.evaluateDaysOnsite(_tran.getStartDateTime(aCT.calculationType), _tran.dateTime);
		elseif aCT.calculationType = INV_CALC_TYPE_DAYS_CONNECTED then
			value := _tran.getChargeQuantity();
			
		elseif aCT.calculationType = INV_CALC_TYPE_DISCREPANCYVALUE then	//19 Mar 2018	NDL	TFS 37558
			value := _tran.getChargeQuantity();	
			
		elseif aCT.calculationType = INV_CALC_TYPE_DISCREPANCYABS then	//21 Jun 2018	NDL	TFS 39217
			value := _tran.getChargeQuantity().abs;	
			
		elseif aCT.calculationType = INV_CALC_TYPE_DAYS_WEIGHT then
			value := theBank.evaluateDaysCalendar(_tran.getStartDateTime(aCT.calculationType), _tran.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, _tran);
			if value &lt; 0 then
				value := 0;
			endif;
			value := value * theTI.getChargeWeight();
		elseif aCT.calculationType = INV_CALC_TYPE_DAYS_VOLUME then
			value := theBank.evaluateDaysCalendar(_tran.getStartDateTime(aCT.calculationType), _tran.dateTime, chargedDaysWorking, chargedDaysWorkingAndComp, _tran);
			if value &lt; 0 then
				value := 0;
			endif;
			value := value * theTI.getChargeVolume();			
		endif;
	endif;
	
	return value;


end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForTransactionBOL" id="0e87468d-d397-4cb3-ab02-150663863b82">
        <source>getQuantityForTransactionBOL(_tran : CM_BOLTransaction) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100
23 Oct 2024			navlw1 	JIRA-33107: Invoice Logging Use Levels
*/

vars
	
	calcType : CM_CalculationType;
	value  : Real;
	cmifHook	: CMIF_CalcTypeQuantityHook;
	valueOut : Real;
	
begin
	if _tran &lt;&gt; null then
		calcType := self.myCalculationType;
		if calcType = null then
			app.invLog("BOL quantity 0 for DEFAULT (no calc type)", LogINFO.String);
			return 0;
		endif;
		
		value := _tran.getQuantityForCalcType( calcType );
			
	endif;
	
	
	if calcType &lt;&gt; null and calcType.myHookCodeQuantity &lt;&gt; null then
		create cmifHook transient;
		cmifHook.myTransaction := _tran;
		cmifHook.origQty := value;	
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, calcType, calcType, cmifHook).Real;
		value := valueOut;
	endif;

	app.invLog("BOL quantity " &amp; value.String &amp; ", for calculation type " &amp; calcType.description, LogINFO.String);
	return value;
	
epilog
	
end;</source>
        <Parameter name="_tran" type="CM_BOLTransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForTransactionCargo" id="33e6a0e1-7957-4d3c-92a8-77c1c5cc8359">
        <source>getQuantityForTransactionCargo(_tran : CM_TITransaction) : Real;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		ANY CHANGES HERE NEED TO BE DONE IN getQuantityForTransaction and CM_InvoiceLine::quantityCARGO
//					This moves away from using the TI  to get details to using the details on the transaction
//	Oct 2012	cnwjre1	CCMS 1295 free storage days, refactor for storage configuration processing
//	18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------
vars
	value,
	valueOut 	: Real;
	chargeByUnits	: Integer;
	blockUnit	: Integer;
	chargedDaysWorking	: Boolean;
	aCT : CM_CalculationType;
	theBank : CM_Bank;
	cmifHook	: CMIF_CalcTypeQuantityHook;
	chargedDaysWorkingAndComp : Boolean;	//21 Sep 2017	NDL	TFS 7032

begin
	aCT := self.myCalculationType;
	
	if aCT = null then // default
		app.invLog("Cargo quantity 1 for DEFAULT", LogINFO.String);
		return 1; // default;
	endif;
	theBank := self.getBank();
	blockUnit := aCT.theCalcTypeUnit;

	if _tran &lt;&gt; null then 
		chargedDaysWorking := _tran.getChargedDaysWorking();
		chargedDaysWorkingAndComp := _tran.getChargedDaysWorkingAndComp();	//21 Sep 2017	NDL	TFS 7032
		chargeByUnits := aCT.calculationType;
		
		if chargeByUnits = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
			value := self.getQuantityForTranCargoByType(_tran, blockUnit);
		else
			value := self.getQuantityForTranCargoByType(_tran, chargeByUnits);// PAR 30681
		endif;
/*		// PAR 30681
		if chargeByUnits = INV_CALC_TYPE_UNITY then
			value := 1.0;
		elseif chargeByUnits = INV_CALC_TYPE_QUANTITY then
			value := _tran.getChargeQuantity(); 
		elseif chargeByUnits = INV_CALC_TYPE_TRANSQUANTITY then
			value := _tran.getChargeQuantity();
		elseif chargeByUnits = INV_CALC_TYPE_WEIGHT then
			value := _tran.getChargeWeight(); 
		elseif chargeByUnits = INV_CALC_TYPE_WEIGHT_TON then
			value := _tran.getChargeWeight()/1000;
		elseif chargeByUnits = INV_CALC_TYPE_VOLUME then
			value := _tran.getChargeVolume(); 
			if value = 0 then
				value := _tran.totalVolume;
			endif;
		elseif chargeByUnits = INV_CALC_TYPE_REVENUE_TONS then
			if _tran.getChargeVolume() &gt; _tran.getChargeWeight() / 1000 then
				value := _tran.getChargeVolume();
			else
				value := _tran.getChargeWeight() / 1000;
			endif;
		// per-day calculation types - refactored for CCMS 1295 free storage days
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_SINCE_RECVL or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_TEU or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_ST or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_EN or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_VOY_IN or
			   chargeByUnits = INV_CALC_TYPE_DAYSINCE_VOY_OUT or
			   chargeByUnits = INV_CALC_TYPE_DAYS_WEIGHT or
			   chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME then
			terminal := theBank.terminal;
			if terminal &lt;&gt; null then
				storageConfig := terminal.myStorageConfig;
			endif;
			value := self.getElapsedDays(_tran, chargeByUnits, chargedDaysWorking, storageConfig);
			// now do the calculation-type specific processing
			if chargeByUnits = INV_CALC_TYPE_DAYSINCE_REC_TEU then
				numTEU := _tran.myTrackedItem.getNumTEU();
				if numTEU &gt; 0 then
					value := (value * numTEU);
				endif;
			elseif chargeByUnits = INV_CALC_TYPE_DAYS_WEIGHT then
				value := value * _tran.getChargeWeight();
			elseif chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME then
				value := value * _tran.getChargeVolume();
			endif;
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_ONSITE_AT then
			value := theBank.evaluateDaysOnsiteCalendar(_tran.getStartDateTime(chargeByUnits), _tran.dateTime, chargedDaysWorking);
		elseif chargeByUnits = INV_CALC_TYPE_DAYS_CONNECTED then
			value := _tran.getChargeQuantity();
			
		endif;
		*/
	endif;

	// TFS 2500 Aug 2016 do quantity hook code here as well as for invoice line quantity to get the correct invoice line type
	if aCT &lt;&gt; null and aCT.myHookCodeQuantity &lt;&gt; null then
		create cmifHook transient;
		cmifHook.myTransaction := _tran;
		cmifHook.origQty := value;
		///cmifHook.myResourceTypeUsage := _tran.allResourceUsages.first; ??
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, aCT, aCT, cmifHook).Real;
		value := valueOut;
	endif;
	app.invLog("Cargo quantity " &amp; value.String &amp; " for calculation type " &amp; aCT.description, LogINFO.String);
	return value;
epilog
	delete cmifHook;
end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForTransactionEvent" id="26dc9633-4273-4253-a03d-6663e29623df">
        <source>getQuantityForTransactionEvent(_tran : CM_EventTransaction) : Real;
// ---------------------------------------------------------------------------
// Created:		05 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		ANY CHANGES HERE NEED TO BE DONE IN CM_InvoiceLine::quantityEvent
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
23 Sep 2022	jlika1	TFS 54897 MTN - Days being charged is incorrect
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	theVoyage 		: CM_Voyage;
	theVessel 		: CM_Vessel;
	theHMSData 		: HMS_VesselData;
	theHMSVoyageData: HMS_VoyageData;
	theCalcType 	: CM_CalculationType;
	eventUsed 		: CM_EventType;
	theUnits 		: Integer;
	stTS, endTS 	: TimeStamp;
	value, diffTS 	: Real;
	invalid 		: Boolean;
	ed				: Integer;
	cmifHook		: CMIF_CalcTypeQuantityHook;
	valueOut 		: Real;
	blockAmount 	: Real;
	blockUnit		: Integer;		
	diffDays		: Integer;
begin
	if _tran &lt;&gt; null then
		theVoyage := _tran.getVoyage();
//		if not global.isValidObject(theVoyage) then
		if theVoyage = null then
			app.invLog("Event quantity 0 for DEFAULT (no voyage)", LogINFO.String);
			return 0;
		endif;
		on Exception do app.handleDeletedObject(exception, theVoyage, invalid);
		// Dereference voyage to check it is valid
		ed := theVoyage.edition();
		if invalid then
			app.invLog("Event quantity 0 for DEFAULT (Invalid Voyage)", LogINFO.String);
			return 0;
		endif;
		
		theCalcType := self.myCalculationType;
		if theCalcType = null then
			app.invLog("Event quantity 0 for DEFAULT (no calc type)", LogINFO.String);
			return 0;
		endif;
		
		eventUsed := _tran.myEventType;
		
//		if not global.isValidObject(eventUsed) then	- inversed, can't be invalid
		if eventUsed = null then
			app.invLog("Event quantity 0 for DEFAULT (no event type)",LogINFO.String);
			return 0;
		endif;

		theUnits := theCalcType.calculationType;
		stTS := _tran.getStartTS();
		endTS := _tran.getEndTS();
		diffTS := stTS.differenceInHoursReal(endTS);
		
		if isEventBlockUnit(theUnits) then
			blockUnit := theCalcType.theCalcTypeUnit;		
			if theVoyage &lt;&gt; null then
				theHMSVoyageData := theVoyage.myHMSVoyageData;				
			endif;
			
			if theHMSVoyageData &lt;&gt; null then
				blockAmount := self.quantityVoyageBlockUnits(blockUnit, theHMSVoyageData, theVoyage, null);
				if blockAmount = 0 then
					blockAmount := 1;
				endif;
			else 
				blockAmount := 1;
			endif;
		endif;
		
		if theUnits = INV_CALC_TYPE_EVENT_UNIT then
			value := _tran.getAmount(); // PAR 25719
			if value = 0 then
				value := 1;
			endif;
		elseif theUnits = INV_CALC_TYPE_EVENT_TIME_DAYS then
			value :=  (diffTS / 24) * blockAmount;
		elseif theUnits = INV_CALC_TYPE_EVENT_DAYS_FULL then
			diffDays := stTS.differenceInHoursFullDay(endTS);
			value :=  diffDays * blockAmount;
		elseif theUnits = INV_CALC_TYPE_EVENT_TIME_HOURS then 
			value := diffTS * blockAmount;
		elseif theUnits = INV_CALC_TYPE_EVENT_TIME_MINUT then
			value := (diffTS * 60) * blockAmount;
		elseif (theUnits = INV_CALC_TYPE_EVENT_LENGTH or theUnits = INV_CALC_TYPE_EVENT_GRT) then
			value := 1;
			if theVoyage &lt;&gt; null then
				theVessel := theVoyage.getMyVessel();
				if theVessel &lt;&gt; null then
					theHMSData := theVessel.myHMSVesselData;
					if theHMSData &lt;&gt; null then
						if theUnits = INV_CALC_TYPE_EVENT_LENGTH then
							value := theHMSData.dim_LengthOverall;
						elseif theUnits = INV_CALC_TYPE_EVENT_GRT then
							value := theHMSData.dim_GrossRegTonnes;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	// TFS 44739 do quantity hook code here as well as for invoice line quantity to get the correct invoice line type
	if theCalcType &lt;&gt; null and theCalcType.myHookCodeQuantity &lt;&gt; null then
		create cmifHook transient;
		cmifHook.myTransaction := _tran;
		cmifHook.origQty := value;
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, theCalcType, theCalcType, cmifHook).Real;

		value := valueOut;
	endif;

	app.invLog("Event quantity " &amp; value.String &amp; ", voyage " &amp; theVoyage.code &amp; " for calculation type " &amp; theCalcType.description, LogINFO.String);
	return value;
end;</source>
        <Parameter name="_tran" type="CM_EventTransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForTransactionInvnt" id="1d3f8b41-7deb-44c1-a1fe-99a1df707ad4">
        <source>getQuantityForTransactionInvnt(_tran : CMEVT_LocationActivity input) : Real;
/*
Purpose:			

Date		Who		Reason
01JUN2021	NAVAB1	TFS 51219
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/


vars
	value,
	valueOut, convRate, amount, blockvalue 	: Real;
	blockUnit	: Integer;
	chargedDaysWorking	: Boolean;
	aCT : CM_CalculationType;
	theBank : CM_Bank;
	cmifHook	: CMIF_CalcTypeQuantityHook;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	aCT := self.myCalculationType;
	
	if aCT = null then // default
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; ": Inventory quantity 1 for DEFAULT", LogINFO.String);
		endif;
		return 1; // default;
	endif;
	theBank := self.getBank();
	blockUnit := aCT.theCalcTypeUnit;

	if _tran &lt;&gt; null then 
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; ": Event Type - " &amp; _tran.getName, LogTRACE.String);
			app.invLog(method.qualifiedName &amp; ": Calculation Type - " &amp;  aCT.calculationType.String, LogTRACE.String);
		endif;
		
		if aCT.calculationType = INV_CALC_TYPE_INVENT_VALUE1 then
			value := 1.0;
		elseif aCT.calculationType = INV_CALC_TYPE_INVENT_QUANTITY 
		or aCT.calculationType = INV_CALC_TYPE_INVENT_VOLUME 
		or aCT.calculationType = INV_CALC_TYPE_INVENT_WEIGHT then
		
			if aCT.calculationType = INV_CALC_TYPE_INVENT_QUANTITY then
				value := _tran.quantity;
				convRate := 1;
			else
			
				// ### MEASUREMENT TYPE
				if aCT.myMeasurementType &lt;&gt; null then
					convRate := aCT.myMeasurementType.conversionRate;
				else
					convRate := 1;
				endif;
						
				// ### AMOUNT
				if aCT.calculationType = INV_CALC_TYPE_INVENT_WEIGHT then 
					amount := _tran.weight; // KG
				elseif aCT.calculationType = INV_CALC_TYPE_INVENT_VOLUME then 
					amount := _tran.volume;
				else
					amount := 1;
				endif;
				
				// ### CONVERT
				value := (amount / convRate);
			endif;
			
			blockvalue := 1; // default
			
			// ### BLOCK UNIT
			if blockUnit = INV_CALC_TYPE_INVENT_QUANTITY 
			or blockUnit = INV_CALC_TYPE_INVENT_VOLUME 
			or blockUnit = INV_CALC_TYPE_INVENT_WEIGHT then
				if blockUnit = INV_CALC_TYPE_INVENT_QUANTITY then
					blockvalue := _tran.quantity;
				elseif blockUnit = INV_CALC_TYPE_INVENT_VOLUME 
				or blockUnit = INV_CALC_TYPE_INVENT_WEIGHT then
				
					// ### AMOUNT
					if blockUnit = INV_CALC_TYPE_INVENT_WEIGHT then 
						blockvalue := _tran.weight; // KG
					elseif blockUnit = INV_CALC_TYPE_INVENT_VOLUME then 
						blockvalue := _tran.volume;
					else
						blockvalue := 1;
					endif;
				endif;
			endif;
			
			if blockvalue= 0 then
				blockvalue := 1;
			endif;
			
			value := value * blockvalue;
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " Raw Amount=" &amp; amount.String&amp;  " blockUnit=" &amp; blockUnit.String &amp; " amount=" &amp; amount.String 
									&amp; " convRate=" &amp; convRate.String &amp; ", convValue=" &amp; (amount / convRate).String &amp; ", rangeValue=" &amp; value.String, LogINFO.String);
			endif;
		endif;
	endif;

	if aCT &lt;&gt; null and aCT.myHookCodeQuantity &lt;&gt; null then
		create cmifHook transient;
		cmifHook.myTransaction := _tran;
		cmifHook.origQty := value;
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, aCT, aCT, cmifHook).Real;
		value := valueOut;
	endif;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("Inventory quantity " &amp; value.String &amp; " for calculation type " &amp; aCT.description, LogINFO.String);
	endif;
	return value;
epilog
	delete cmifHook;
end;</source>
        <Parameter name="_tran" type="CMEVT_LocationActivity" usage="input"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForTransactionVTMIS" id="d62d2d91-04f0-491b-961f-2d4141927dd4">
        <source>getQuantityForTransactionVTMIS(_tran : HMS_VTMISTransaction) : Real;
// ---------------------------------------------------------------------------
// Created:		05 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		ANY CHANGES HERE NEED TO BE DONE IN CM_InvoiceLine::quantityVoyage
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	theVoyage : CM_Voyage;
	theCalcType : CM_CalculationType;
	theHMSData : HMS_VoyageData;
	theResUsed : HMS_ResourceUsed;
	numHours, theUnits : Integer;
	diffMin		: Integer;
	blockUnit	: Integer;
	stTS, endTS : TimeStamp;
	numHourBlocks, value : Real;
	calcDesc	: String;
	invalid 		: Boolean;
	cmifHook	: CMIF_CalcTypeQuantityHook;
	valueOut : Real;
	hoursDec : Decimal[23,2];
begin
	if _tran &lt;&gt; null then
		theVoyage := _tran.myVoyage;
		if theVoyage = null then
			app.invLog("HMS quantity 0 for DEFAULT (no voyage)", LogINFO.String);
			return 0;
		endif;
		theCalcType := self.myCalculationType;
		if theCalcType = null then
			app.invLog("HMS quantity 0 for DEFAULT (no calc type", LogINFO.String);
			return 0;
		endif;
		calcDesc := theCalcType.description;
		blockUnit := theCalcType.theCalcTypeUnit;
		
		on Exception do app.handleDeletedObject(exception, theVoyage, invalid);
		theHMSData := theVoyage.myHMSVoyageData;
		if invalid or
		   theHMSData = null then
			app.invLog("HMS quantity 0 for " &amp; calcDesc &amp; " no hms data", LogINFO.String);
			return 0;
		endif;
		on Exception do null;
		
		theResUsed := _tran.myResourceUsed;
		
		if theResUsed = null then
			app.invLog("HMS quantity 0 for " &amp; calcDesc &amp; " no res used", LogINFO.String);
			return 0;
		endif;

		theUnits := theCalcType.calculationType;
		stTS := theResUsed.fromDateTime;
		endTS := theResUsed.toDateTime;
		
		if theCalcType.requiresADate 
		and not stTS.isValid() then
			app.invLog("HMS quantity 0 for " &amp; calcDesc &amp; " no start date", LogINFO.String);
			return 0;	
		endif;

		if theCalcType.requiresDateRange 
		and (not stTS.isValid() or not endTS.isValid()) then
			app.invLog("HMS quantity 0 for " &amp; calcDesc &amp; " no end date", LogINFO.String);
			return 0;
		endif;
		
		if theUnits = INV_CALC_TYPE_BUSINESS_HRS_QTY then
			value := theResUsed.unitsUsed;
			if value = 0 then
				value := 1;
			endif;
		elseif theUnits = INV_CALC_TYPE_BUSHRSVESELVALUE then // PAR 30681
			value := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, null);
			
		elseif theUnits = INV_CALC_TYPE_RESOURCE_QTY then
			value := theResUsed.unitsUsed;
			if value = 0 then
				value := 1;
			endif;
		elseif (theUnits = INV_CALC_TYPE_QUOTED_RATE or theUnits = INV_CALC_TYPE_VESSEL_TON_QTY1) then // PAR 10672
			value := 1;
		elseif (theUnits = INV_CALC_TYPE_TIMEBLCK_HRS 
			or theUnits = INV_CALC_TYPE_TIMEBLCK_HRS_UNT
			or theUnits = INV_CALC_TYPE_TIMEBLCK_HRS_ONE) then

			numHourBlocks := theResUsed.unitsUsed; // PAR 13208. Use this as it has already been worked out
			if numHourBlocks = 0 then
				numHourBlocks := 1;
				if theCalcType.requiresDateRange then		// 35339 date range processing
					diffMin := (stTS.cnEcDiff(endTS) / MillisecondsPerMinute).Integer;
					numHourBlocks := theCalcType.getNumHourBlocks(diffMin, true, null);
				endif;
			endif;
			
			if theUnits = INV_CALC_TYPE_TIMEBLCK_HRS_UNT  
			or theUnits = INV_CALC_TYPE_TIMEBLCK_HRS_ONE then
				value := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, null);
			
				value := numHourBlocks * value;
			
			else
				value := numHourBlocks;
			endif;
		elseif theUnits = INV_CALC_TYPE_TIME_PERIOD_HRS then
			numHours := stTS.differenceInHours(endTS);
			value := numHours;
		// ### TFS CR 65326 TASK 65327 06AUG2024 NAVAB1
		elseif theUnits = INV_CALC_TYPE_TIME_PERIOD_HRMN then
			hoursDec := stTS.differenceInHoursReal(endTS);
			value := hoursDec;
		elseif theUnits = INV_CALC_TYPE_VESSEL_TON then
			value := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, null);

		// 34489 Tidal Class
		elseif theUnits = INV_CALC_TYPE_TIDAL_CLASS then
			value := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, null);
		elseif theUnits = INV_CALC_TYPE_VESSEL_TON_RANGE then
			value := theResUsed.unitsUsed;
			if value = 0 then
				value := 1;
			endif;
		endif;
	endif;
	// TFS 44739 do quantity hook code here as well as for invoice line quantity to get the correct invoice line type
	if theCalcType &lt;&gt; null and theCalcType.myHookCodeQuantity &lt;&gt; null then
		create cmifHook transient;
		cmifHook.myTransaction := _tran;
		cmifHook.origQty := value;
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_HMSInvoiceQuantity, theCalcType, theCalcType, cmifHook).Real;

		value := valueOut;
	endif;

	app.invLog("HMS quantity " &amp; value.String &amp; ", voyage " &amp; theVoyage.code &amp; " for calculation type " &amp; theCalcType.description, LogINFO.String);
	return value;
epilog
	delete cmifHook;
end;</source>
        <Parameter name="_tran" type="HMS_VTMISTransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForTransactionWO" id="abce0852-de41-4f6f-851d-d2618e773dd9">
        <source>getQuantityForTransactionWO(_tran : CM_WOTransaction) : Real;
/*
Purpose:		TFS 39237 	ANY CHANGES HERE NEED TO BE DONE IN CM_InvoiceLine::quantityWorkOrder
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
23 Oct 2024		navlw1		JIRA-33107: Invoice Logging Use Levels
*/


vars
	theVoyage : CM_Voyage;
	theVessel : CM_Vessel;
	theHMSData : HMS_VoyageData;
	theCalcType : CM_CalculationType;
	eventUsed : CM_EventType;
	theUnits : Integer;
	stTS, endTS : TimeStamp;
	value,buValue, diffTS : Real;
	invalid 		: Boolean;
	ed				: Integer;
	lengthOfStay : Decimal[12,2];
	theWorkOrder : CM_WorkOrder;
	blockUnit : Integer;
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	cmifHook	: CMIF_CalcTypeQuantityHook;
	valueOut : Real;
begin
	if _tran &lt;&gt; null then
		theVoyage := _tran.getMyVoyageObject();
		if theVoyage = null then
			app.invLog("Work Order quantity 0 for DEFAULT (no voyage)", LogINFO.String);
			return 0;
		endif;
		on Exception do app.handleDeletedObject(exception, theVoyage, invalid);
		// Dereference voyage to check it is valid
		ed := theVoyage.edition();
		if invalid then
			app.invLog("Work Order quantity 0 for DEFAULT (Invalid Voyage)", LogINFO.String);
			return 0;
		endif;
		
		theCalcType := self.myCalculationType;
		if theCalcType = null then
			app.invLog("Work Order quantity 0 for DEFAULT (no calc type)", LogINFO.String);
			return 0;
		endif;
		
		theWorkOrder := _tran.getMyWorkOrder();
		if theWorkOrder = null then
			app.invLog("Work Order quantity 0 for DEFAULT (no work order)", LogINFO.String);
			return 0;
		endif;
		

		theUnits := theCalcType.calculationType;
		lengthOfStay := theWorkOrder.getInvLengthOfStay();
		
		theUnits := theCalcType.calculationType;
		
		if theUnits = INV_CALC_TYPE_WO_UNITS then
			value := _tran.getInvUnitsUsed(); 
			if value = 0 then
				value := 1;
			endif;
		elseif theUnits = INV_CALC_TYPE_WO_PERMIT then
			// this calc type was designed for the CM_WOCargoRequest transaction
			// the calc type allows 5 rates to be maintained and the quantity will be a cargo quantity via the block unit on the calc type
			
			if theCalcType &lt;&gt; null then
				blockUnit := theCalcType.theCalcTypeUnit;
			else
				blockUnit := INV_CALC_TYPE_UNITY; // value of 1
			endif;
			
			create tiSet transient;		//27 Jun 2018	NDL	TFS 39246
			theWorkOrder.getAllTIs( tiSet);
			
			foreach ti in tiSet	discreteLock do
				if blockUnit = INV_CALC_TYPE_UNITY then
					value := value + 1.0;
				elseif blockUnit = INV_CALC_TYPE_QUANTITY then
					value := value + ti.totalQuantity;
				elseif blockUnit = INV_CALC_TYPE_WEIGHT then
					value := value + ti.totalWeight;
				elseif blockUnit = INV_CALC_TYPE_WEIGHT_TON then
					value := value + (ti.totalWeight / 1000);
				elseif blockUnit = INV_CALC_TYPE_VOLUME then
					value := value + ti.totalVolume;
				elseif blockUnit = INV_CALC_TYPE_REVENUE_TONS then
					value := value + ti.freightTons;
			
				endif;
	
			endforeach;
			if value = 0 then
				value := 1;
			endif;
	
			
		elseif theUnits = INV_CALC_TYPE_WO_VALUEOF1 then
			value := 1;
		elseif theUnits = INV_CALC_TYPE_WO_ETMAL_DAYS then
			value := lengthOfStay;
		elseif theUnits = INV_CALC_TYPE_WO_ETMAL_HOURS then
			if lengthOfStay = 0 then
				return 0;
			endif;
			value := (lengthOfStay * 24);
			
		elseif theUnits = INV_CALC_TYPE_WO_ETMAL_MINUTES then
			if lengthOfStay = 0 then
				return 0;
			endif;
			
			value := ((lengthOfStay * 24) * 60);
		endif;
		
		if theUnits &lt;&gt; INV_CALC_TYPE_WO_PERMIT then
			// the block unit for all WO calc types are vessel dimensions like GRT,  except INV_CALC_TYPE_WO_PERMIT which are cargo based.
			if theCalcType &lt;&gt; null then
				blockUnit := theCalcType.theCalcTypeUnit;
			else
				blockUnit := INV_CALC_TYPE_UNITY; // value of 1
			endif;
			
			theHMSData := theVoyage.myHMSVoyageData;
			if theHMSData &lt;&gt; null then
				buValue := self.quantityVoyageBlockUnits(blockUnit, theHMSData, theVoyage, null);
				value := value * buValue;
			endif;
		endif;
	endif;
	
	// TFS 44739 do quantity hook code here as well as for invoice line quantity to get the correct invoice line type
	if theCalcType &lt;&gt; null and theCalcType.myHookCodeQuantity &lt;&gt; null then
		create cmifHook transient;
		cmifHook.myTransaction := _tran;
		cmifHook.origQty := value;
		
		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceQuantity, theCalcType, theCalcType, cmifHook).Real;

		value := valueOut;
	endif;

	app.invLog("Work Order quantity " &amp; value.String &amp; ", voyage " &amp; theVoyage.code &amp; " for calculation type " &amp; theCalcType.description, LogINFO.String);
	return value;
	
epilog

	delete tiSet;
	
end;</source>
        <Parameter name="_tran" type="CM_WOTransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getQuantityRangeForValue" id="e8057d38-2783-4850-ab82-4e32ae6a8c12">
        <source>getQuantityRangeForValue(_value : Real;_aSBController : CMIF_ServiceBroker) : CM_QuantityRangeMap;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
 // ### TFS 51219 28MAY2021 NAVAB1 removed unused ti and tiTrans variables and code
//
// ---------------------------------------------------------------------------
vars
	qrm : CM_QuantityRangeMap;
	value	: Integer;
	tranQty :    Real;
begin
	// 35909 if the quantity is from a weight etc and has a fractional value, round it up so it doesn't
	//		fall between the integral range start and end values.
	value := _value.Integer;
	if _value  - value &gt; 0 then		// has fractional value
		value := value + 1;			// round up
	endif;

	foreach qrm in self.allQuantityRanges discreteLock do
		if value &gt;= qrm.rangeStart and value &lt;= qrm.rangeEnd then
	/* TFS 2901
			if qrm.myChildQuantityMap &lt;&gt; null then   	//28/02/2017 cnwma1 TFS #2901
				tranQty := qrm.myChildQuantityMap.getQuantityForTransactionCargo(tiTrans);
				app.invLog("Finding quantity Sub range, quantity " &amp; tranQty.String);
				qrm := qrm.myChildQuantityMap.getQuantityRangeForValue(tranQty,_aSBController);
				return qrm;
			else
				return qrm;
			endif;
			*/
			return qrm;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_value" type="Real"/>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker"/>
        <ReturnType type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="getSpecificQuantityRange" id="cee7f288-8419-4591-bffd-2c6a3ccddcb6">
        <source>getSpecificQuantityRange(_start : Real; _end : Real) : CM_QuantityRangeMap;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars
	qrm : CM_QuantityRangeMap;
begin
	foreach qrm in self.allQuantityRanges discreteLock do
		if _start = qrm.rangeStart and _end = qrm.rangeEnd then
			return qrm;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_start" type="Real"/>
        <Parameter name="_end" type="Real"/>
        <ReturnType type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="getTranMapBreadCrumb" id="f28551c0-df4d-420f-a1e7-735ea634e60d">
        <source>getTranMapBreadCrumb() : String;
/*
Purpose:			
Date		Who		Reason
19 October 2016	cnwab1	Initial creation
*/

vars

begin
	if self.myParentFinancialObject &lt;&gt; null then
		return self.myParentFinancialObject.getTranMapBreadCrumb() &amp; "/" &amp; self.getName();
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="healthCheckIsValid" id="02c793a9-6a9b-4a36-b3d7-0959736cc32a">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date				Who			Reason
September 2017		CNWAB1		Initial creation
*/

vars
	message : String;
	resultType, itemType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
// TFS 40620	invLineDescs : CM_InvoiceLineDescMapDict;
	invLineDesc : CM_InvoiceLineDesc;
	paths : HugeStringArray;
	items : ObjectArray;
	calctype : CM_CalculationType;
	bu : CM_Bank;
begin
	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;
	
	// ### CARGO  Calculation Type
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_CalcType) then
		resultType := CMIF_InvoiceHealthAgent.ResultType_QuantityMap;
		if self.myParentFinancialObject.isKindOf(CM_QuantityRangeMap) then
			resultType := CMIF_InvoiceHealthAgent.ResultType_QuantityRangeMap;
		endif;
		
		if self.allQuantityRanges.size = 0 then
			return true;
		endif;
		
		if self.allQuantityRanges.size = 1 then
			if self.allQuantityRanges.first.rangeEnd = CM_QuantityRangeMap.MAX_RANGE
			and self.allQuantityRanges.first.rangeStart &lt;= 1 then // DEFAULT RANGE
				return true;
			endif;
		endif;
		calctype := self.myCalculationType.CM_CalculationType;
		if calctype &lt;&gt; null then
			if calctype.isUsingBlock then
					itemType := self.getHealthCheckItemType();
					create detail transient;
					detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType,"Calc Type: '" &amp; calctype.description &amp;  "'", itemType, self.getMyTerminal(), resultType, self);
			
			endif;
		endif;
		
		return false;
	endif;
	return true;
epilog
// TFS 40620	delete invLineDescs;
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
