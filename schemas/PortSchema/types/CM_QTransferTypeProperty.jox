    <JadeMethod name="translateToSearchValueForWeb" id="8db92e08-56e0-4e2b-ae22-8aade92b63b1">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(Integer) then
		return app.vesselAccessTypeEnumToStr(_value.Integer);
	elseif _value.isKindOf(String) then
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
