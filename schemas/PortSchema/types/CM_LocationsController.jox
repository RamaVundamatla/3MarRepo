    <JadeMethod name="createCargoAtLocation" id="f62a79f2-1042-4b0b-9c51-b000acd83159">
        <source>createCargoAtLocation(_cargoType: CM_CargoType; _product : CM_Product; _operator: CM_Operator; _id: String) : CM_TrackedItem;

vars
	realTI,
	pxyTI			: CM_TrackedItem;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
begin

	passport := app.myPassport;
	
	pxyTI := self.myTerminal.createTI(_cargoType, true);
	if _id = null then
		pxyTI.zSetPxyId(self.getTrackedItemID(_product));
	else
		pxyTI.zSetPxyId(_id);
	endif;
	
	//pxyTI.zSetPxyOperator(operator);
	pxyTI.zSetPxyTerminal(self.myTerminal);
	passport.setMyTerminal(self.myTerminal);
	pxyTI.setCargoType(_cargoType.id);
	pxyTI.setMyProduct(_product);
	pxyTI.setMyOperator(_operator);
	
	if app.isSubTerminalsOn(self.myTerminal) then
		pxyTI.setSubTerminalDefaultFromTerm(self.myTerminal);		// CCMS 1875
	endif;

	state := self.getStateForNewCargo();
	
	if state = 0 then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Invalid State', null, null);
		return null;
	endif;
	
	if state = TI_STATE_ONSHIP and self.isKindOf(CM_VoyageController) then
		pxyTI.setMyVoyage(self.CM_VoyageController.myVoyage, passport);
	endif;
	
	pxyTI.changeState(state, passport);
	
	//pxyTI.zSetPxyCompany(_terminal.companies.last);
	
	//pxyTI.changeISOType(self.isoType, null, app.myPassport);
	
	passport.warningsAcknowledged := true;
	passport.setIsBackgroundWarningsIgnored(true);
	
	create moveController transient;
	moveController.setMyToPrimaryLocation(self);
	
	if process.isInTransactionState then
		app.myUtilityCA.utlCreateTrackedItem(pxyTI, realTI, passport);
	
		if not passport.noErrors() then
			return null;
		endif;
		moveController.setMyTrackedItem(realTI);
	
		realTI.setMyLocationsPublic(moveController);
		return realTI;
	else
	//create the persistent TI
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport);
		if passport.trxCompletedOK() then
			return realTI;
		endif;
	endif;
	
	return null;
	
epilog
		
	delete moveController;
	// Don't need to delete proxy as trx above does it with delete of transaction controller.
	//delete pxyTI;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createLocationBalance" id="91e917bb-cf0d-477f-99a8-cbc9c4d95c4d">
        <source>createLocationBalance( _cargoType : CM_CargoType; _operator : CM_Operator; _endTS : TimeStamp; _reCalcBalanceSet : CMEVT_LocationActivityByDate input ):CMEVT_LocationActivity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2021	navndl1	Initial creation	TFS 50906 - Create a Location Balance starting at a balance and going forward
											for 24 hrs OR starting with no balance for the 24hrs ending @ _endTS.
											Time should be the equivalent of teh localised time for 23:59:59:999

*/

vars

	la : CMEVT_LocationActivity;
	lastBalance : CMEVT_LocationActivity;
	startObject : CMEVT_LocationActivity;
	prevTS : TimeStamp;
	pxyLa : CMEVT_LocationActivity;
	iter : Iterator;
	
	totQuantity : Integer;
	totWeight : Decimal[14,4];
	totVolume : Decimal[14,4];
	
	newLa : CMEVT_LocationActivity;
	summedLas : CMEVT_LocationActivityByDate;
	
begin

	if _cargoType = null or not _cargoType.saveLocationActivity then
		return null;
	endif;
	if _operator = null then
		return null;
	endif;
	if not _endTS.isValid then
		return null;
	endif;

	create summedLas transient;
	
	prevTS := _endTS.cnEcAddDays( -1 ); 
	lastBalance := self.getLocationActivity( _cargoType.id, _operator.code, EVT_LocationBalance, prevTS );
	
	if lastBalance &lt;&gt; null then
		totQuantity := lastBalance.quantity;
		totWeight := lastBalance.weight;
		totVolume := lastBalance.volume;	
	endif;
	
	iter := self.allLocationActivity.createIterator;
	if lastBalance &lt;&gt; null then
		iter.startAtObject( lastBalance );
		
	else
		startObject := self.allLocationActivity.getAtKeyGtr( prevTS ).CMEVT_LocationActivity;
		if startObject = null then
			return null;
		endif;
		iter.startAtObject( startObject );
	
	endif;
	
	while iter.next( la ) do //going forward oldest to newest
	
		if la.dateTime &gt; _endTS then
			break;
		endif;
		
		//must match on operator and cargo type
		if la.cargoType &lt;&gt; _cargoType.id then
			continue;
		endif;
		if la.operatorCode &lt;&gt; _operator.code then
			continue;
		endif;
		
		if la.isLocationDiscrepancyDecrease 
		or ( la.isLocationMove and la.mySourceLocation = self ) then
			totQuantity := totQuantity - la.quantity;
			totWeight := totWeight - la.weight;
			totVolume := totVolume - la.volume;
			summedLas.add( la );
		elseif la.isLocationDiscrepancyIncrease
		or ( la.isLocationMove and la.myTargetLocation = self ) then
			totQuantity := totQuantity + la.quantity;
			totWeight := totWeight + la.weight;
			totVolume := totVolume + la.volume;
			summedLas.add( la );
		endif;
		
	endwhile;
	
	//create and populate the proxy.
	if lastBalance &lt;&gt; null then
		newLa := lastBalance.createNextBalance( summedLas, totQuantity, totWeight, totVolume, _endTS, _reCalcBalanceSet );
		
	else
		create pxyLa transient;
		pxyLa.setNewBalanceProxy( totQuantity, totWeight, totVolume, _endTS, _cargoType, _operator, self );
		app.myTrxCA.trxCreateLocActBalance( pxyLa, newLa, summedLas, _reCalcBalanceSet, app.myPassport );
		
	endif;
	
	return newLa;

epilog

	delete iter;
	delete summedLas;
	delete pxyLa;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_reCalcBalanceSet" type="CMEVT_LocationActivityByDate" usage="input"/>
        <ReturnType type="CMEVT_LocationActivity"/>
    </JadeMethod>
    <JadeMethod name="createNewCargoForLCDetailed" id="15b934d0-febf-47bb-95dc-66ed1c9347fb">
        <source>createNewCargoForLCDetailed(_cargoType : CM_CargoType; _product : CM_Product; _id: String; _dPort : String; _imex : Integer; _voyage : CM_Voyage; _op : CM_Operator; _quantity : Integer; _cargoGroup : CM_CargoGroup input) : CM_TrackedItem;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	quantity : Integer;
begin

	//lets make cargo
	
	passport := app.myPassport;
	
	cargoType	:=_cargoType;
	
	if cargoType = null and _product &lt;&gt; null then
		cargoType	:= _product.myCargoType;
	endif;
	pxyTI := self.myTerminal.createTI(cargoType, true);
	if _id = null then
		pxyTI.zSetPxyId(self.getTrackedItemID(_product));
	else
		pxyTI.zSetPxyId(_id);
	endif;
	
	//pxyTI.zSetPxyOperator(operator);
	pxyTI.zSetPxyTerminal(self.myTerminal);
	passport.setMyTerminal(self.myTerminal);
	pxyTI.setCargoType(cargoType.id);
	pxyTI.setMyProduct(_product);
	//navsp1 17July2022 TFS#53956
	if cargoType.isCommodityRequired and pxyTI.commodity = null then
		pxyTI.setCommodity(cargoType.defaultCommodityCode);
	endif;
	pxyTI.setMyTotalVolume(1000); // cnwdw1 27868
	
	quantity := _quantity; // AKB PAR 37405
	if quantity = 0 then
		quantity := 1;
	endif;

	pxyTI.setQVW(quantity,1000, 1000); // AKB
	
	if _product &lt;&gt; null and _product.myOperator &lt;&gt; null then
		pxyTI.setMyOperator(_product.myOperator);
	else
		pxyTI.setMyOperator(_op);
	
	endif;
	pxyTI.setMyVoyage(_voyage, app.myPassport);
	pxyTI.setImExStatus(_imex);
	pxyTI.setDischargePort(_dPort);
	
	if app.isSubTerminalsOn(self.myTerminal) then
		pxyTI.setSubTerminalDefaultFromTerm(self.myTerminal);		// CCMS 1875
	endif;

	state := self.getStateForNewCargo();
	
	if state = 0 then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Invalid State', null, null);
		return null;
	endif;
	
	if state = TI_STATE_ONSHIP and self.isKindOf(CM_VoyageController) then
		pxyTI.setMyVoyage(self.CM_VoyageController.myVoyage, passport);
	endif;
	
	pxyTI.changeState(state, passport);
	
	pxyTI.setMyCargoGroup(_cargoGroup, passport); // ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
	
	//pxyTI.zSetPxyCompany(_terminal.companies.last);
	
	//pxyTI.changeISOType(self.isoType, null, app.myPassport);
	
	passport.warningsAcknowledged := true;
	passport.setIsBackgroundWarningsIgnored(true);
	
	create moveController transient;
	moveController.setMyToPrimaryLocation(self);
	
	if process.isInTransactionState then
		app.myUtilityCA.utlCreateTrackedItem(pxyTI, realTI, passport);
	
		if not passport.noErrors() then
			return null;
		endif;
		moveController.setMyTrackedItem(realTI);
	
		realTI.setMyLocationsPublic(moveController);
		return realTI;
	else
	//create the persistent TI
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport);
		if passport.trxCompletedOK() then
			return realTI;
		endif;
	endif;
	
	return null;
	
epilog
		
	delete moveController;
	// Don't need to delete proxy as trx above does it with delete of transaction controller.
	//delete pxyTI;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_dPort" type="String"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_op" type="CM_Operator"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createNewCargoForLocation" id="4864db8f-c790-4239-8662-8b227436967b">
        <source>createNewCargoForLocation(_cargoType: CM_CargoType; _product : CM_Product; _id: String; _operator: CM_Operator) : CM_TrackedItem;

// Created by cnwdvb1 on 08 November 2006

vars
	
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;

begin

	//lets make cargo
	
	passport := app.myPassport;
	
	cargoType	:= _cargoType;
	pxyTI := self.myTerminal.createTI(cargoType, true);
	if _id = null then
		pxyTI.zSetPxyId(self.getTrackedItemID(_product));
	else
		pxyTI.zSetPxyId(_id);
	endif;
	
	//pxyTI.zSetPxyOperator(operator);
	pxyTI.zSetPxyTerminal(self.myTerminal);
	passport.setMyTerminal(self.myTerminal);
	pxyTI.setCargoType(cargoType.id);
	pxyTI.setMyProduct(_product);
	pxyTI.setMyOperator(_operator);
	
	if app.isSubTerminalsOn(self.myTerminal) then
		pxyTI.setSubTerminalDefaultFromTerm(self.myTerminal);		// CCMS 1875
	endif;

	state := self.getStateForNewCargo();
	
	if state = 0 then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Invalid State', null, null);
		return null;
	endif;
	
	if state = TI_STATE_ONSHIP and self.isKindOf(CM_VoyageController) then
		pxyTI.setMyVoyage(self.CM_VoyageController.myVoyage, passport);
	endif;
	
	pxyTI.changeState(state, passport);
	
	if ( pxyTI.isKindOf(CM_Bulk) and pxyTI.myCargoType.isTrackByWeight )
	or pxyTI.isKindOf(CM_BreakBulkGeneric)	//03 Oct 2017	NDL	TFS 5744
	then
		pxyTI.setTotalWeightWithoutTrans(1);
	endif;
	//pxyTI.zSetPxyCompany(_terminal.companies.last);
	
	//pxyTI.changeISOType(self.isoType, null, app.myPassport);
	
	passport.warningsAcknowledged := true;
	passport.setIsBackgroundWarningsIgnored(true);
	
	create moveController transient;
	moveController.setMyToPrimaryLocation(self);
	
	if process.isInTransactionState then
		app.myUtilityCA.utlCreateTrackedItem(pxyTI, realTI, passport);
	
		if not passport.noErrors() then
			return null;
		endif;
		moveController.setMyTrackedItem(realTI);
	
		realTI.setMyLocationsPublic(moveController);
		return realTI;
	else
	//create the persistent TI
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport);
		if passport.trxCompletedOK() then
			return realTI;
		endif;
	endif;
	
	return null;
	
epilog
		
	delete moveController;
	// Don't need to delete proxy as trx above does it with delete of transaction controller.
	//delete pxyTI;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createNoChangeBalancesFor" id="0238a71b-0b6f-4133-913c-eff4edeabeb8">
        <source>createNoChangeBalancesFor( _endTS : TimeStamp; _startTS : TimeStamp; _reCalcBalanceSet : CMEVT_LocationActivityByDate input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	startTS : TimeStamp;
	iter : Iterator;
	startAtObject : CMEVT_LocationActivity;  
	la : CMEVT_LocationActivity;
	las : CMEVT_LocationActivitySet;
	newLa : CMEVT_LocationActivity;
	summedLas : CMEVT_LocationActivityByDate;

begin

	if not _endTS.isValid then
		return;
	endif;
	
	if _startTS &lt;&gt; null and _startTS.isValid then
		//'_start' &amp;' _reCalcBalanceSet' are only included when the agent is doing re-calculation of existing data
		startTS := _startTS;
	else
		// Current processing, i.e. building the ones for the last 24hr period.
		startTS := _endTS.cnEcAddDays( - 1 );
	endif;
	
	iter := self.allLocationActivity.createIterator;
	startAtObject := self.allLocationActivity.getAtKeyGeq( startTS );
	
	if startAtObject &lt;&gt; null then
		iter.startAtObject( startAtObject );
	else
		return;
	endif;
	
	create las transient;
	create summedLas transient;
	
	while iter.next( la ) do	 //going forward oldest to newest
		if la.dateTime &gt; _endTS then
			break;
		endif;
		if not la.isLocationBalance then
			continue;
		endif;
		if ( la.myNextBalance = null and la.dateTime &lt; _endTS )	then
			las.add( la );
		elseif not las.isEmpty then
			//we are creating some earlier than this, so anything following will need re-calculation
			if la.dateTime &lt; _endTS then
				if not la.needsRecalculation then
					app.myTrxUA.trxLocationActivityNeedsRecalc( la, _reCalcBalanceSet, app.myPassport );
				endif;
			endif;
		endif;
	endwhile;
	
	foreach la in las do
		if la.myNextBalance &lt;&gt; null then
			//its been created as a by-product of one of the previous Balance updates.
			//Can happen where there have been gaps created.
			continue;
		endif;
		newLa := la.createNextBalance( summedLas, la.quantity, la.weight, la.volume, _endTS, _reCalcBalanceSet );
	endforeach;

epilog

	delete iter;
	delete las;
	delete summedLas;

end;</source>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_reCalcBalanceSet" type="CMEVT_LocationActivityByDate" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createSOHAnalLocation" id="cd732c26-7487-4852-b55e-a0907e18bab7">
        <source>createSOHAnalLocation(_sohCode : CM_Product) : CM_SOHLocation;
// ---------------------------------------------------------------------------
