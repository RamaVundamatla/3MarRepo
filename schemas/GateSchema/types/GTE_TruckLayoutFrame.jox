    <JadeMethod name="setMoveBtnPositions" id="cfe73e63-dea2-4df2-88e6-e8d9d39eb0b4">
        <source>setMoveBtnPositions(pTop, pLeft : Integer);
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myMoveLeftBtn.top	:= pTop;
	self.myMoveLeftBtn.left	:= pLeft;
	
	self.myMoveRightBtn.top	:= pTop;
	self.myMoveRightBtn.left:= pLeft + self.myMoveLeftBtn.width + 5;

end;</source>
