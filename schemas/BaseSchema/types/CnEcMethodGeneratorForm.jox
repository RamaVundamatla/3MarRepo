    <JadeMethod name="btnNext_click" id="3564e93d-001c-471d-9d07-2f1d8a8d806e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNext_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;

	if self.aSheetVisible = 4
	and not chkObjectCreate.value
	and not chkCreateTrx.value
	then
		self.aSheetVisible := 5;
	endif;
	
	self.setSheetState(self.aSheetVisible + 1);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnToSelected_click" id="35cd6b85-3b95-4c5a-90ea-11ae88c203c3">
