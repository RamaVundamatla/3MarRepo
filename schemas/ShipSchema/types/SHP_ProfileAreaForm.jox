    <JadeMethod name="doMnuContext" id="de494f98-cf6c-45aa-8ee1-139eb5ce8c96">
        <updating/>
        <source>doMnuContext(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	bVisible			: Boolean;
	
begin
	self.doTurnOffContextMenus();
	
	// cnwrl1 13/03/2009 - PAR 18245 - start of coding
