        <source>setForUpdate( _proxy : CM_GCHoldLocationDefn ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
*/

vars

begin

	self.hatch := _proxy.hatch;
	self.name := _proxy.name;
	self.place := _proxy.place;
