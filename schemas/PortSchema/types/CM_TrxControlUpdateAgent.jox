    <JadeMethod name="trxUpdateVoyageStatus" id="71e1af8e-c0d0-4ab1-94d0-8876b215e6f8">
        <updating/>
        <source>trxUpdateVoyageStatus(_pxyVoyageStatus : CM_VoyageStatus; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

