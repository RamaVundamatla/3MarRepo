    <JadeMethod name="verifyVolume" id="cbab35e2-2873-40dc-9784-235c8e4b1e7a">
        <updating/>
        <source>verifyVolume() protected, updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
02 Feb 2018	jlgrs1	TFS 36951 	JMT Prenote Partial for GateDoc
12 Jun 2019	jlgka1	TFS 44416 	PNL Loading Default Cargo Type Settings via EDI.
============================================================================*/
vars
	calcVolume 	: Decimal[22,4];
	cargoType 	: CM_CargoType;
	product 	: CM_Product;
begin
	if self.length = null or self.height = null or self.width = null then
		return;
	endif;
	
	cargoType:= self.getCargoTypeObj();			// 14.8.2017 cnwma1 TFS #5695
	
	if cargoType &lt;&gt; null then
		product := cargoType.allProducts[null,self.product];
	else
		//jlgka1 TFS 44416 --&gt;
		product := self.getProduct(self.operatorCode, self.product);  // 14.8.2017 cnwma1 TFS #5695
		//jlgka1 TFS 44416 &lt;--
	endif;
	
	if cargoType &lt;&gt; null and  			// 14.8.2017 cnwma1 TFS #5027
	 (cargoType.isBreakBulk or cargoType.isBulk) and 
	cargoType.allowAutoVolumeCalc and 
	(product &lt;&gt; null and not product.autoVolumeCalculate) then
		calcVolume := ((self.height/100) * (self.width/100) * (self.length/100)) * self.productQuantity.max(1) * self.totalQuantity.max(1);
	else
		
		calcVolume := ((self.height/100) * (self.width/100) * (self.length/100));
	endif;
	if self.volume &lt;&gt; null and calcVolume &lt;&gt; null and self.volume &lt;&gt; calcVolume then
		app.raiseCMWarning2(ERR_FIELD_VOLUME, self.volume.String, ' calculated volume differs from field value ', ETRow_Volume, self, self);
	elseif self.volume = null and calcVolume &lt;&gt; null then
		self.volume := calcVolume;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyVoyage" id="07b5cf5b-14a8-4a59-bc16-351e4a490d9f">
        <source>verifyVoyage(_terminal : CM_Terminal; _site : Integer) : CM_Voyage protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 01 Oct 2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
//
vars
	voyageCodeStr : String;
	voyage : CM_Voyage;
	port : CM_Port;
	isoTypeObj : CM_ISOType;	// MTN-36141
	terminal : CM_Terminal;		// MTN-36141
begin
//	if self.voyageCode = null then		// cnwrl1 09/06/2010 PAR 24299 - what it was
	voyageCodeStr	:= self.getVoyageCode();
	
	// MTN-36141 Check ISO Type - if it's rotatable, default the voyage to the terminal's "No Info" voyage
	if self.isoType &lt;&gt; null then
		if self.isISOTypeRotatable(isoTypeObj) then
			terminal := self.getMyTerminal;
			if terminal &lt;&gt; null and terminal.getConfig(DefVoyage) &lt;&gt; null then
				voyageCodeStr := terminal.getConfig(DefVoyage).CM_Voyage.code;
			endif;
		endif;
	endif;
	// MTN-36141 end
	
//cnwah9 par 33402 04/02/2014
	if voyageCodeStr = null then
		if _site = TI_SITE_ONSHIP then
		else
			return null;
		endif;
	endif;
	
//	voyage := _terminal.lookupVoyage(self.voyageCode, null, false);
	voyage := _terminal.lookupVoyage(voyageCodeStr, null, false);

	if voyage = null then
		
		//epr par 32677 13/11/13  was only raising error when on ship else warning now always an error as the load db errors.
		//if _site = TI_SITE_ONSHIP then
//			app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, ETRow_VoyageCode, null);	// cnwrl1 09/03/2010 PAR 23008 - what it was
			app.raiseCMException1(ERR_INVALID_VOYAGE, voyageCodeStr, ETRow_VoyageCode, self);
			return null;
		//else
//			app.raiseCMWarning1(ERR_INVALID_VOYAGE, self.voyageCode, ETRow_VoyageCode, null, self);	// cnwrl1 09/03/2010 PAR 23008 - what it was
		//	app.raiseCMWarning1(ERR_INVALID_VOYAGE, voyageCodeStr, ETRow_VoyageCode, self, self);
		//endif;
	endif;
	
	// cnwrl1 10/05/2010 PAR 24061 - start of coding
	// Need to make sure the the DischargePort (if entered) is valid for the Voyage selected.
	if voyage &lt;&gt; null and self.dischargePort &lt;&gt; null and not voyage.isNullVoyage then				// MTN-36141
		port := app.myRoot.allPorts[ self.dischargePort ];
		if port &lt;&gt; null and not voyage.allPorts.includes( port ) then
			// NOTE: The DischargePort should never be an invalid Port due to previous checks in method verifyPorts.
			app.raiseCMException2( ERR_DISCHARGE_VOYAGE, self.dischargePort, voyage.code, ETRow_DischargePort, self );
		endif;
	endif;
	// cnwrl1 10/05/2010 PAR 24061 - end of coding
	if voyage &lt;&gt; null and voyage.hasDeparted  and  self.getMyTerminal().getConfig(EdiAddVoyageDepartError).Boolean then
		app.raiseCMException1(Voyage_departed, voyageCode, "Voyage Code", self);
	endif;
	
epilog
	return voyage;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_site" type="Integer"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="verifyWeight" id="51ee3e08-9aa9-4a5d-b61d-ba33a28b6d8b">
        <updating/>
        <source>verifyWeight() protected, updating;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 02 Aug 2019	jlgsl4	TFS 45766 - SNO - Inconsistent weight information
// 01 Oct 2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
//
vars
	isoTypeObj : CM_ISOType;	// TMN-36141

begin
	if self.weight = 0 then
		app.raiseCMWarning(Total_weight_should_not_zero, app.getString(Total_weight), self, self); // cnwdb2	PAR 35364
	endif;
	if self.tareWeight &gt; self.weight then // --&gt; TFS 45766
		app.raiseCMException(Tare_weight_more_than_total, app.getString(Tare_weight), self);
	endif; // &lt;-- TFS 45766 - could end up with tare &gt; total if edited in EDI Ops
	
	// MTN-36141 If this is a prenote for a rotatable container, default tare and cargo weight from the ISO type
	if self.isoType &lt;&gt; null then
		if self.isISOTypeRotatable(isoTypeObj) then
			if isoTypeObj.tareKilos &lt;&gt; null then
				self.tareWeight := isoTypeObj.tareKilos.Decimal;
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
