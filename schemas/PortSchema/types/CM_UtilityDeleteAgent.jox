    <JadeMethod name="utlDeletePort" id="06b650c8-7821-45dd-bc07-257d2da068cc">
        <source>utlDeletePort(pPort:CM_Port io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02 Aug 2016	cnwkpd1		Fix up YA criteria for other Port-type criteria than Discharge Port
// ---------------------------------------------------------------------------

vars
	classes		: ClassColl;
	cls			: Class;
	yaType 		: CM_YACriteriaType;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valPort(pPort);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pPort);
	endif;

	if _passport.noErrors then
		create classes transient;
		classes.add(CM_YATypeDestinationPort);
		classes.add(CM_YATypeDischargePort);
		classes.add(CM_YATypeTranshipDischargePort);
		classes.add(CM_YATypeLoadPort);
		classes.add(CM_YATypeTranshipToPort);
	
		foreach cls in classes do
			yaType := cls.firstInstance.CM_YACriteriaType;
			if yaType &lt;&gt; null then
				yaType.removeMyDataObject(pPort);
			endif;
		endforeach;
		
		pPort.erase(NORMAL_ERASE);
	endif;

epilog
	delete classes;

end;</source>
        <Parameter name="pPort" type="CM_Port" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
