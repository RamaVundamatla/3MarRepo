    <JadeMethod name="shouldAuditProperty" id="383ecd14-2439-425c-910c-bc1d8b717b41">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2018	jlgns1	Initial creation
//6/08/2018 	JLGNS1	Bug 39748: Release Request change not audited
*/

vars
	propName	: String;
begin

	propName := _property.name;

	if	propName = CM_ReserveDetail::weightRequested.name then	//Bug 39748	- This value is now audited in CM_BulkRelease
		return false;											//Bug 39748
	endif;
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
