    <JadeMethod name="action" id="b58aba8d-3595-40a0-98c8-a727dc91547f">
        <updating/>
        <source>action(_passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2022	navpw1	Initial creation TFS: 55215
06 Apr 2023	navdap1	TFS 57362 CUX - Changes to Outgoing Message Formats;
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
*/

vars
	voyage				: CM_Voyage;
	train				: CM_Train;
	vehicleVisit		: CM_VehicleVisitRecord;
	
begin
	if app.isJMTUnitTest then
		return;
	endif;
	
	voyage			:= self.myVoyage;
	train			:= self.myTrain;
	vehicleVisit	:= self.myVehicleVisit;
	
	if voyage &lt;&gt; null and self.type = self.ProcessVoyageDeparture then				// TFS 57362
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing Voyage Departure - Voyage is " &amp; voyage.code, LogDEBUG);
		self.processVoyageDeparture();
	elseif voyage &lt;&gt; null and self.type = self.ProcessVoyageArrival then			// TFS 57362
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing Voyage Arrival - Voyage is " &amp; voyage.code, LogDEBUG);
		self.processVoyageArrival();
	elseif vehicleVisit &lt;&gt; null and self.type = self.ProcessTruckArrival then		// TFS 57362
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing Truck Arrival - Visit is " &amp; vehicleVisit.visitNumber, LogDEBUG);
		self.processTruckArrival();
	elseif vehicleVisit &lt;&gt; null and self.type = self.ProcessTruckDeparture then		// TFS 57362
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing Truck Departure - Visit is " &amp; vehicleVisit.visitNumber, LogDEBUG);
		self.processTruckDeparture();
	elseif train &lt;&gt; null and self.type = self.ProcessTrainDeparture then	// TFS 57362
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing Train Departure - Train is " &amp; train.code, LogDEBUG);
		self.processTrainDeparture();										// TFS 57362
	endif;
	
epilog
	
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createAction" id="cbb48a8d-5c12-4dd4-bf96-277c26d11ce7">
        <options>4</options>
        <source>createAction(_voyage : CM_Voyage; _train : CM_Train; _vehicleVisit : CM_VehicleVisitRecord; _type : Integer; _passport : CM_Passport input) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2022	navpw1	Initial creation TFS: 55215
01/07/2025	navcs2	MTN-35166 MTN - Prevent Unnecessary Alerts for Missing EDBIC External Interface
*/

vars
	voyage					: CM_Voyage;
	train					: CM_Train;
	vehicleVisit			: CM_VehicleVisitRecord;
	trxPA					: CMIF_TrxPostAction;
	transportTrxAction		: CMIF_TrxActionTransport; 
	exist					: Boolean;
	hasEndpoint				: Boolean;
	date					: Date;								// 01/07/2025	navcs2	MTN-35166
begin
	date :=  app.actualTimeServer.date;							// 01/07/2025	navcs2	MTN-35166
	
	if not app.myRoot.canDoEWSType(EWS_Type_EDBIC, date) then	// 01/07/2025	navcs2	MTN-35166	
		return;													// 01/07/2025	navcs2	MTN-35166
	endif;														// 01/07/2025	navcs2	MTN-35166
	
	if (_voyage = null and _train = null and _vehicleVisit = null) or not _passport.noErrors() then
		return;
	endif;
	
	voyage := _voyage;
	train := _train;
	vehicleVisit := _vehicleVisit;
	
	if voyage &lt;&gt; null or train &lt;&gt; null or vehicleVisit &lt;&gt; null then
		foreach trxPA in _passport.allTrxPostActions where trxPA.isTransport() do
			if trxPA.CMIF_TrxActionTransport.myVoyage = voyage or
				trxPA.CMIF_TrxActionTransport.myTrain = train or
				trxPA.CMIF_TrxActionTransport.myVehicleVisit = vehicleVisit
			then
				exist := true;
				break;
			endif;
		endforeach;
		
		hasEndpoint := CMIF_TrxActionTransport@hasCorrectEndpoint(_type);  												// 01/07/2025	navcs2	MTN-35166
		
		if not exist then
			if not hasEndpoint then																						// 01/07/2025	navcs2	MTN-35166
				app.writeLog(method.qualifiedName &amp; Tab &amp; "No Active Cuxport Interface defined", LogERROR);				// 01/07/2025	navcs2	MTN-35166
				app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Active Cuxport EWS Interface defined");				// 01/07/2025	navcs2	MTN-35166
			else																										// 01/07/2025	navcs2	MTN-35166
				create transportTrxAction transient;
				transportTrxAction.myVoyage := voyage;
				transportTrxAction.myTrain := train;
				transportTrxAction.myVehicleVisit := vehicleVisit;
				transportTrxAction.myTerminal := _passport.myTerminal;
				transportTrxAction.type := _type;
				_passport.addTrxPostAction(transportTrxAction);	
			endif;
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getActiveCuxportInterface" id="5957a224-5ee6-47e9-98b6-83d84756ea40">
        <source>getActiveCuxportInterface() : CM_CuxportServiceDef protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2022	navpw1	Initial creation TFS: 55215

*/

vars
	extDef,
	activeCuxportExtDef : CM_CuxportServiceDef;
	
begin
	foreach extDef in CM_CuxportServiceDef.instances discreteLock do   
		if not extDef.active then
			continue;
		endif;
			
		activeCuxportExtDef := extDef;
		break;
	endforeach;
	
	return activeCuxportExtDef;
	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_CuxportServiceDef"/>
    </JadeMethod>
    <JadeMethod name="hasCorrectEndpoint" id="c3ae56c2-a4f2-4daa-abad-f50b6f1aa225">
        <options>4</options>
        <source>hasCorrectEndpoint(_type : Integer): Boolean protected, typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/07/2025	navcs2	MTN-35166 MTN - Prevent Unnecessary Alerts for Missing EDBIC External Interface

*/

vars

begin
	if _type = CMIF_TrxActionTransport.ProcessTrainDeparture then
		return app.myRoot.getFirstActiveEWSForEndpoint( ETRow_TrainDepartureEDBIC ) &lt;&gt; null;
	elseif _type = CMIF_TrxActionTransport.ProcessTruckArrival then
		return app.myRoot.getFirstActiveEWSForEndpoint( ETRow_TruckArrivalEDBIC ) &lt;&gt; null;
	elseif _type = CMIF_TrxActionTransport.ProcessTruckDeparture then
		return app.myRoot.getFirstActiveEWSForEndpoint( ETRow_TruckDepartureEDBIC ) &lt;&gt; null;
	elseif _type = CMIF_TrxActionTransport.ProcessVoyageArrival then		
		return app.myRoot.getFirstActiveEWSForEndpoint( ETRow_VoyageArrivalEDBIC ) &lt;&gt; null;
	elseif _type = CMIF_TrxActionTransport.ProcessVoyageDeparture then		
		return app.myRoot.getFirstActiveEWSForEndpoint( ETRow_VoyageDepartureEDBIC ) &lt;&gt; null;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTransport" id="a2595694-10be-46ae-878d-5bae7299aeb0">
        <source>isTransport(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2022	navpw1	Initial creation TFS: 55215

*/

begin
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processTrainDeparture" id="e6c498bb-ccaa-40ac-af1f-cee240dbe660">
        <updating/>
        <source>processTrainDeparture() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022	navpw1	Initial creation TFS: 55215
06 Apr 2023	navdap1	TFS 57362 CUX - Changes to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
01/07/2025	navcs2	MTN-35166 MTN - Prevent Unnecessary Alerts for Missing EDBIC External Interface

*/

vars
	extWebService 			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	pxyRequest				: BGP_EDBICWSRequest;
	request					: BGP_ExternalWSRequest;
	
begin

	// to send data for all cargo on a train when the train is departed (user story 140)
	// create a BGP request and let the BGP handle all the processing
	create pxyRequest transient;
	pxyRequest.setDetails(null, null, self.myTrain, null, self.myTerminal, BGP_EDBICWSRequest.Type_TrainDeparture);
	if process.isInTransactionState then
		app.myUtilityCA.utlCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	else
		app.myTrxCA.trxCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	endif;
	
epilog
	delete pxyRequest;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processTruckArrival" id="a9ae89a3-0c1b-4353-b792-3488f8bb9f8a">
        <updating/>
        <source>processTruckArrival() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022	navpw1	Initial creation TFS: 55215
06 Apr 2023	navdap1	TFS 57362 CUX - Changes to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
01/07/2025	navcs2	MTN-35166 MTN - Prevent Unnecessary Alerts for Missing EDBIC External Interface

*/

vars
	activeCuxPortInterface	: CM_CuxportServiceDef;
	pxyRequest				: BGP_EDBICWSRequest;
	request					: BGP_ExternalWSRequest;
	eWs						: CM_ExternalWebServiceDef;
	
begin
	
	// to send data for a truck and all cargo being received and released when a truck is gated in through the Road Gate (user story 170)
	// create a BGP request and let the BGP handle all the processing
	create pxyRequest transient;
	pxyRequest.setDetails(null, self.myVehicleVisit, null, null, self.myTerminal, BGP_EDBICWSRequest.Type_TruckArrival);
	if process.isInTransactionState then
		app.myUtilityCA.utlCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	else
		app.myTrxCA.trxCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	endif;
	
epilog
	delete pxyRequest;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processTruckDeparture" id="2e8e0001-fb64-40bf-bf7e-b5e982dc828b">
        <updating/>
        <source>processTruckDeparture() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022	navpw1	Initial creation TFS: 55215
12 Apr 2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
01/07/2025	navcs2	MTN-35166 MTN - Prevent Unnecessary Alerts for Missing EDBIC External Interface
*/

vars
	activeCuxPortInterface	: CM_CuxportServiceDef;
	pxyRequest				: BGP_EDBICWSRequest;
	request 				: BGP_ExternalWSRequest;
	eWs						: CM_ExternalWebServiceDef;
	
begin
	
	// to send data for a truck and all import cargo being released when a truck is gated out through the Road Gate (user story 130)
	// create a BGP request and let the BGP handle all the processing
	create pxyRequest transient;
	pxyRequest.setDetails(null, self.myVehicleVisit, null, null, self.myTerminal, BGP_EDBICWSRequest.Type_TruckDeparture);
	if process.isInTransactionState then
		app.myUtilityCA.utlCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	else
		app.myTrxCA.trxCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	endif;
	
epilog
	delete pxyRequest;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processVoyageArrival" id="a1c54a62-b7eb-441d-97eb-bb6e2c8a51f7">
        <updating/>
        <source>processVoyageArrival() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022	navpw1	Initial creation TFS: 55215
12 Apr 2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
01/07/2025	navcs2	MTN-35166 MTN - Prevent Unnecessary Alerts for Missing EDBIC External Interface
*/

vars
	extWebService			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	pxyRequest				: BGP_EDBICWSRequest;
	request					: BGP_ExternalWSRequest;
	
begin
	
	// to send data for all import cargo on ship to EDBIC on voyage arrival (user story 120). Data to be sent will be all cargo on ship with an imex status of Import. See appendix for data format.
	// create a BGP request, and let the BGP handle all the processing
	create pxyRequest transient;
	pxyRequest.setDetails(null, null, null, self.myVoyage, self.myTerminal, BGP_EDBICWSRequest.Type_VoyageArrival);
	if process.isInTransactionState then
		app.myUtilityCA.utlCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	else
		app.myTrxCA.trxCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	endif;
	
epilog
	delete pxyRequest;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processVoyageDeparture" id="34fed44f-d670-4bd4-bda1-8e06e2a96642">
        <updating/>
        <source>processVoyageDeparture() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022	navpw1	Initial creation TFS: 55215
06 Apr 2023	navdap1	TFS 57362 CUX - Changs to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
01/07/2025	navcs2	MTN-35166 MTN - Prevent Unnecessary Alerts for Missing EDBIC External Interface

*/

vars
	extWebService			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	pxyRequest				: BGP_EDBICWSRequest;
	request					: BGP_ExternalWSRequest;
	
begin
	
	// to send data for all cargo on ship to EDBIC on voyage departure (user story 060). Data to be sent will be all cargo on ship with a load port of &lt;this port&gt;. See appendix for data format.
	// create a BGP request and let the BGP handle all the processing
	create pxyRequest transient;
	pxyRequest.setDetails(null, null, null, self.myVoyage, self.myTerminal, BGP_EDBICWSRequest.Type_VoyageDeparture);
	if process.isInTransactionState then
		app.myUtilityCA.utlCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	else
		app.myTrxCA.trxCreateBGPRequestExtWS(pxyRequest, request, app.myPassport);
	endif;
	
epilog
	delete pxyRequest;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
