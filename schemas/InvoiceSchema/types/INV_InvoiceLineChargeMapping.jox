        <updating/>
        <source>doCmbChargeTypeClick() updating;
// ---------------------------------------------------------------------------
// Created:		19 February 2008 By Andrew Bishop cnwab1
// Modified:    18 April 2008 By Graeme Black cnwgb1 for CCMS CP 1047
// 				31 May 2019 by Dave Patrick TFS 44554 AAT Stevedore Data Access
// 07 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	combo : CMUI_ComboBox;
	lstIdx : Integer;
begin
	// Get the value selected in the Searcher Charge Type Combo
	combo := self.cmbChargeType;
	lstIdx := combo.listIndex;
	self.myCurrentDebtorType := combo.itemObject[lstIdx].CM_DebtorType;
	
	// Populate the combo that will be used if the user edits a mapping entry
	self.doCmbChargesBuild(self.cmbChargeTypeMap);
	self.doCmbDebtorTypeRemove(self.cmbChargeTypeMap, self.myCurrentDebtorType);
	
	// Populate the combo that allows them to select the Debtor etc the mapping is for
	self.lblParentObject.caption := "Maintain Mappings For " &amp; self.cmbChargeType.text &amp; " :";
	self.cmbParentObject.clear();
	if self.myCurrentDebtorType.code     = CM_DebtorType.DT_CARGO_OPERATOR
		or self.myCurrentDebtorType.code = CM_DebtorType.DT_BOL_OPERATOR	//31 Oct 2019	NDL	TFS 47100
		then
		self.doCmbOperatorBuild();
	elseif self.myCurrentDebtorType.code = CM_DebtorType.DT_SHIP_OPERATOR
		or self.myCurrentDebtorType.code = CM_DebtorType.DT_BOL_VOY_OPERATOR	//31 Oct 2019	NDL	TFS 47100
		then
		self.doCmbOperatorBuild();
	elseif self.myCurrentDebtorType.code = CM_DebtorType.DT_CONSIGNOR
		or self.myCurrentDebtorType.code = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSOR	//31 Oct 2019	NDL	TFS 47100
		then
		self.doCmbConsignorBuild();
	elseif self.myCurrentDebtorType.code = CM_DebtorType.DT_CONSIGNEE
		or self.myCurrentDebtorType.code = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSEE	//31 Oct 2019	NDL	TFS 47100
		then
		self.doCmbConsigneeBuild();
	elseif self.myCurrentDebtorType.code = CM_DebtorType.DT_CUSTOMS_AGENT then
		self.doCmbCustomsAgentBuild();
	elseif self.myCurrentDebtorType.code = CM_DebtorType.DT_FREIGHT_FORWARDER then
		self.doCmbFreightForwarderBuild();
	elseif self.myCurrentDebtorType.code = CM_DebtorType.DT_BUSINESS_UNIT then
		self.doCmbBusinessUnitBuild();
	elseif self.myCurrentDebtorType.code = CM_DebtorType.DT_CARRIER then	// 24094 add Carrier
		self.doCmbCarrierBuild();
	elseif self.myCurrentDebtorType.code = CM_DebtorType.DT_STEVEDORE_VOYAGE then		// TFS 44554
		self.doCmbStevedoreBuild();												// TFS 44554
	elseif self.myCurrentDebtorType.code = CM_DebtorType.DT_SHIPPING_LINE then	// 07-06-2022 navak20 TFS 53204 
		self.doCmbShippingLine();
	else
		//User defined Debtor Type
		self.doCmbDebtorTypeBuild( self.myCurrentDebtorType );
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbChargesBuild" id="7cabdddc-898f-48d4-a219-de3ccd2e4e6d">
        <source>doCmbChargesBuild(_combo : CMUI_ComboBox input);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aDebtorType : CM_DebtorType;
begin
	
	_combo.clear;
	_combo.sorted := true;// PAR 18362
	
	// Centreport ccms 1047 Par 16666 cnwgb1 18 April 2008
	foreach aDebtorType in app.myRoot.allDebtorTypes where not aDebtorType.isNotAvailableForEntry do
		if aDebtorType.code = CM_DebtorType.DT_EVENT_TYPE  then // PAR 17557
			continue;
		endif;
		
		if aDebtorType.isSystemGenerated or aDebtorType.allDebtors.size &gt; 0 then
			_combo.addItem(aDebtorType.description);
			_combo.itemObject[_combo.newIndex] := aDebtorType;
		endif;
	endforeach;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbChargesListIndex" id="54154cea-9925-412b-b818-05a1f82a982e">
        <source>doCmbChargesListIndex(_combo : CMUI_ComboBox; _type : CM_DebtorType);
// ---------------------------------------------------------------------------
// Created:		19 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	combo : CMUI_ComboBox;
	endItm, lstIdx : Integer;
begin
	combo := _combo;
	endItm := combo.listCount();
	
	// Centreport ccms 1047 Par 16666 cnwgb1 18 April 2008
	foreach lstIdx in 1 to endItm do
		if combo.itemObject[lstIdx] =  _type then
			combo.listIndex := lstIdx;
			break;
		endif;
	endforeach;
	

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox"/>
        <Parameter name="_type" type="CM_DebtorType"/>
    </JadeMethod>
    <JadeMethod name="doCmbChargesRemove" id="784ac8a6-8b8a-4162-a283-53d2fc7c66aa">
