    <JadeMethod name="valTActivityCreate" id="2b593aae-a94d-45f8-a5a1-9cea42f89afd">
        <updating/>
        <source>valTActivityCreate(	pAction				: String;
					pAfterControlName	: String;
					pAfterText			: String;
					pControlName		: String;
					pErrorText			: String;
					pMyLesson		 	: CnEcTLesson;
					pName				: String;
					pOnErrorDoAction 	: Boolean;
					pOnErrorStop		: Boolean;
					pUseExistingValue	: Boolean;
					pText			 	: String	):String updating;

// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		Validation for creating an Activity.
//
// Parameters:	The object's properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if app.myBaseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	if pName.length = 0 then
		return self.agentSetError("Update Activity: no name supplied.");
	endif;

	trimmedName := pText.trimBlanks;
	if trimmedName.length &gt; 0 then
		if pControlName.length = 0 then
			return self.agentSetError("Activity error: action supplied with no control.");
		endif;
	else
		if pControlName.length &gt; 0 then
			return self.agentSetError("Activity error: no action supplied with control: " &amp; pControlName &amp; ".");
		endif;
	endif;

	trimmedName := pAfterText.trimBlanks;
	if trimmedName.length &lt; 1 then
		if pAfterControlName.length &gt; 0 then
			return self.agentSetError("Activity error: no text supplied with after control: " &amp; pAfterControlName &amp; ".");
		endif;
	endif;

	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	return null;
end;</source>
        <Parameter name="pAction" type="String"/>
        <Parameter name="pAfterControlName" type="String"/>
        <Parameter name="pAfterText" type="String"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pErrorText" type="String"/>
        <Parameter name="pMyLesson" type="CnEcTLesson"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pOnErrorDoAction" type="Boolean"/>
        <Parameter name="pOnErrorStop" type="Boolean"/>
        <Parameter name="pUseExistingValue" type="Boolean"/>
        <Parameter name="pText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valTActivityUpdate" id="6f755330-d36e-4bab-a84d-50d52ba542c8">
        <updating/>
        <source>valTActivityUpdate(	pActivityToUpdate	: CnEcTActivity;
					pRequiredEdition	: Integer;
					pAction				: String;
					pAfterControlName	: String;
					pAfterText			: String;
					pControlName		: String;
					pErrorText			: String;
					pMyLesson		 	: CnEcTLesson;
					pName				: String;
					pOnErrorDoAction 	: Boolean;
					pOnErrorStop		: Boolean;
					pUseExistingValue	: Boolean;
					pText			 	: String	):String updating;
// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		Validation for updating an Activity.
//
// Parameters:	The object's (changeable) properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
	lesson		: CnEcTLesson;
begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pActivityToUpdate = null then
		return self.agentSetError("The Activity being updated is either null or is not valid.");
	endif;

	// If object is invalid, we want our handlers to return an invalid object message.
	self.agentRegisterObjectAndError(pActivityToUpdate, "The Activity being updated is either null or is not valid.");

	sharedLock(pActivityToUpdate);

	if app.myBaseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	if pMyLesson = null then
		return self.agentSetError("Update Activity: no associated lesson.");
	endif;	

	if pName.length = 0 then
		return self.agentSetError("Update Activity: no name supplied.");
	endif;

	trimmedName := pText.trimBlanks;
	if trimmedName.length &gt; 0 then
		if pControlName.length = 0 then
			return self.agentSetError("Activity error: action supplied with no control.");
		endif;
	else
		if pControlName.length &gt; 0 then
			return self.agentSetError("Activity error: no action supplied with control: " &amp; pControlName &amp; ".");
		endif;
	endif;

	trimmedName := pAfterText.trimBlanks;
	if trimmedName.length &lt; 1 then
		if pAfterControlName.length &gt; 0 then
			return self.agentSetError("Activity error: no text supplied with after control: " &amp; pAfterControlName &amp; ".");
		endif;
	endif;

	// If the above operation gets an exception, our handler will resume to here
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pActivityToUpdate &lt;&gt; null then
		unlock(pActivityToUpdate);
	endif;
end;</source>
