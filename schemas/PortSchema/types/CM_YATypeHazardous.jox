        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2024 navra1 - BUG 63499 - FR | 53383 - Cargo Group Reservation - part III
04 July 2024 navrv30 - Bug 63499: FR | 53383 - Cargo Group Reservation - part III
*/

vars

begin
