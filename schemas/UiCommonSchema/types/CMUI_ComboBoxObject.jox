    <JadeMethod name="getMyTerminal" id="05c5ac9e-fd28-4f8b-8b61-0e3996439671">
        <source>getMyTerminal() : CM_Terminal;
//--------------------------------------------------
// Created:	15 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	term : CM_Terminal;
begin
	term := app.getMyTerminalDO_NOT_USE();
	if term = null then
		if CM_BaseForm.hasInstance(self.form) then
			term := self.form.CM_BaseForm.myTerminal;
		endif;
	endif;
	return term;
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="5adaf9ee-334b-4a7e-852e-efd208fdac06">
        <updating/>
        <source>gotFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpParent	: Window;

begin
	tmpParent := self.parent;
	if CM_EntryTable.hasInstance(tmpParent) then
		self.entTableRow := tmpParent.CM_EntryTable.row;
	endif;
	
	if self.style = ComboBox.Style_DropDownComboList then
		// select all the text
		self.selStart := 0;
		self.selLength := 1000;
	endif;

	if (not self.amInitialised) then
		self.zInit();
	endif;
	
	inheritMethod(combobox);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="init" id="1cdd9716-80f7-4b37-90ea-651dd91f4fbe">
        <updating/>
        <source>init() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	coll		: Collection;
	idx			: Integer;
	saveText	: String;
		
begin

	coll := self.getCollectionJMT();
	if coll = null then
		self.amInitialised := false;
		return;
	endif;

	// save the current text as calling listCollection
	// clears the current text
	saveText := self.text;
	
	//cnwmc5 - PAR 30834
	if not self.isPopulated then
		if self.useDisplayCollection then
			// allows for situation where a string value has been stored and
			// the object deleted.  We can show the string and retain but
			// not allow them to change to another object
			if self.myObject = null then
				self.displayCollection(coll, true, DisplayCollection_Forward + DisplayCollection_Prior, self.myObject, saveText);
			else
				self.displayCollection(coll, true, DisplayCollection_Forward + DisplayCollection_Prior, self.myObject, null);
			endif;
			
		else
			//self.listCollection(coll, true, 0);					//-cnwml2 PAR22371
			self.listCollection(coll, self.getListUpdateStatus, 0); //+cnwml2 PAR22371
		endif;
	endif;
	
	self.selLength := 1000;			

	idx := self.findString(1, saveText);

	if idx &gt; 0 then
		self.listIndex := idx;
		self.setEntryTableCell();
		self.text := saveText;
	else
		self.text := null;
	endif;
		
	self.amInitialised := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialise" id="7ddafb5b-74fa-46cd-a2ee-4efd901f585a">
        <updating/>
        <source>initialise(_isForced:Boolean)updating;
//--------------------------------------------------
// Created:	01 December 2004 By: cnwgd1
//--------------------------------------------------
begin
	if _isForced then
		self.clear();
	endif;
	
	self.zInit();
end;</source>
        <Parameter name="_isForced" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="13d8e1ef-93bc-4131-8213-7baa51003de5">
        <updating/>
        <source>keyDown(combobox: ComboBox input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	/*ArrowDown	: Integer = 40;
	ArrowUp		: Integer = 38;*/
	
vars

begin
	/*Par 9435 now done on the gotFocus event
	if keyCode = ArrowUp or keyCode = ArrowDown then
		if (not self.amInitialised) then
			self.zInit();
		endif;
	endif;*/
	//inheritMethod(combobox, keyCode, shift);
	
	inheritMethod(combobox, keyCode, shift); // ### TFS 55105 07NOV2022 NAVAB1

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="f1b2ee57-a76a-4617-9ec7-239ddcc6ff6f">
        <updating/>
        <source>lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	keyValue	: String;
	tmpParent	: Window;
	updateTbl	: Boolean;
	tmpStr		: String;

begin
	tmpParent := self.parent;

	if combobox.text = null then
		self.myObject := null;
		if CM_EntryTable.hasInstance(tmpParent) then
			tmpParent.CM_EntryTable.setValue(self.entTableRow, combobox.text);
		endif;
		inheritMethod(combobox);
		return;
	endif;

	if self.amInitialised and self.listIndex &gt; 0 then
		self.myObject := self.listObject;
		if self.myObject = null then
			// must be using displayCollection and user has selected the
			// extra entry so
		else
			// need to do this as text in combo does not get updated
			//self.text := self.displayEntry(self, self.listObject, self.listIndex);
			
			//tmpStr := self.displayEntry(self, self.listObject, self.listIndex);
			if tmpStr = null and self.text = null then
				// This is because if you do not implement the displayEntry method on your form the text of the combo gets set
				// to null, even thouggh you have an object selected
				app.raiseUnexpectedProgramError(class.name, method.name, 'need to implement displayEntry method on your combobox');
				return;
			elseif tmpStr &lt;&gt; null then
				self.text := tmpStr;
			endif;
			
		endif;
		updateTbl := true;
	elseif self.amInitialised  then
		self.myObject := null;
		self.listIndex := -1;
	elseif self.myObject &lt;&gt; null then
		updateTbl := true;
	else
		self.myObject := null;
		self.listIndex := -1;
		keyValue := self.getKeyValue();
		if (not self.validate(keyValue, combobox.text)) then
			global.beep;
			if self.style = ComboBox.Style_DropDownComboList then
				// select all the text
				self.selStart := 0;
				self.selLength := 1000;
			endif;			
			//self.selStart := 0;
			//self.selLength := 1000;
			if CM_EntryTable.hasInstance(tmpParent) then
				tmpParent.CM_EntryTable.clearAllSelected();
				if self.entTableRow &gt; 0 
				and self.entTableRow &lt;= tmpParent.CM_EntryTable.rows then
					tmpParent.CM_EntryTable.row := self.entTableRow;
				endif;
				tmpParent.setFocus();
			else
				self.setFocus();
			endif;
		else
			updateTbl := true;
		endif;
	endif;
	
	if updateTbl then
		self.setEntryTableCell();
	   //CM_EntryTable.hasInstance(tmpParent) then
		//tmpParent.CM_EntryTable.setValue(self.entTableRow, combobox.text);
	endif;
		
	inheritMethod(combobox);
	

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setEntryTableCell" id="382bf1fc-b394-426d-ba05-03558358289a">
        <source>setEntryTableCell() protected;

// Created by cnwdvb1 on 30 January 2007

vars

	tmpParent : Window;
	entRowTrans			: EntTableRowTransient;
	rows : Integer;	//28 Jan 2011	NDL	Par 26313
begin
	tmpParent := self.parent;
	if CM_EntryTable.hasInstance(tmpParent) then
		rows := tmpParent.CM_EntryTable.rows;	//28 Jan 2011	NDL	Par 26313
		//+cnwml2 PAR24259
		//if self.entTableRow &gt; 0 then
		if self.entTableRow &gt; 0 and self.entTableRow &lt;= rows then	//28 Jan 2011	NDL	Par 26313
			entRowTrans := tmpParent.CM_EntryTable.accessRow(self.entTableRow).itemObject.EntTableRowTransient;
			entRowTrans.hasChanged := true;
			tmpParent.CM_EntryTable.setValue(self.entTableRow, self.text);
		endif;
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setInitialised" id="cfb07a2a-2d74-47aa-8310-d3b4c1460c17">
        <updating/>
        <source>setInitialised(_value : Boolean) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.amInitialised :=_value;

end;


</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObject" id="334df7d4-9f63-4cb8-b6b1-504e2b999617">
        <updating/>
        <source>setObject(_value: Object) updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
	
begin
	if (not self.canUserAccessObject(_value)) then
		// need to give an exception here
	endif;

	// PAR 9435 must be initialised when prefilling tables
	// otherwise data is lost when clicking into field.
	if _value &lt;&gt; null
	and (not self.amInitialised)
	then
		// must call this BEFORE call to zInit() as the myObject reference
		// is used to determine if the object is dirty or not
		self.myObject := _value;
		self.zInit();

		// following code to stop error if collection does not include object that is being set.
		if self.findObject(_value) &gt; 0 then
			self.listObject := _value;
		else
			self.clear();
		endif;
		
//		self.listObject := _value;

	elseif self.amInitialised then
		if self.hasDirtyObject then
			// need to reset table to remove unavailable obj from collection
			self.clear();
		elseif self.findObject(_value) &gt; 0 then
			self.listObject := _value;
		else
			// need to clear the combobox
			// this sets self.amInitialised to false
			self.clear();
		endif;
		// need to do this after the above call to clear() as it
		// will set self.myObject to null
		self.myObject := _value;
	endif;

	// as the clear above can reset this value
	if (not self.amInitialised) then
		if _value = null then
			self.text		:=	null;
			self.myObject	:=	null;
		else
			self.text := self.displayEntry(self, _value, idx);
		endif;
		
		self.setEntryTableCell();
	endif;
end;</source>
        <Parameter name="_value" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setPopulated" id="2b3ff342-394a-4919-8ec7-d110fe21e6d6">
