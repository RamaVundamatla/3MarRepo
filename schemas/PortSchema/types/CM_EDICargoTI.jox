    <JadeMethod name="getDisplayStringForAttribute" id="5e986ddf-8d2c-4239-854a-86f8d604b3fe">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	01 February 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
28/11/2013	cnwdap1		PAR #33019 CCMS DPH 2285 New BOL Fields
23/04/2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
04/05/2016	cnwdap1		TFS #1699 Verified Gross Mass changes
19/05/2022	jlika1		TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
21 Nov 2022	navma1		ChangeRequest 55424: MTN - Improve the performance of Edi file loading
19 Jul 2023	jlirs1		TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
06 Mar 2024	navhn30		Bug 62299: EUP | FR 53824 - Transport Manifest - Ship Add Fields Users Will Need to Update On Screen
*/
vars
	rowName, type	: String;									// PAR #33005
begin
	
	if _attrName = ETRow_IsWaterCooled
	or _attrName = ETRow_WaterCooled
	or _attrName = ETRow_OutOfGauge
	or _attrName = ETRow_State
	or _attrName = ETRow_Ignore 									//30.11.2022 navma1 #55424
	or _attrName = ETRow_YardLocation								//30.11.2022 navma1 #55424
	then
		return null;
	
	//30.11.2022 navma1 #55424
	elseif _attrName = ETRow_HasChanged then
		return false.String;
	elseif _attrName = ETRow_Id then											
		return self.id;		
	elseif _attrName = ETRow_OperatorCode then									
		return self.operatorCode;
	elseif _attrName = ETRow_AlternativeId then									
		return self.alternativeId;	
	elseif _attrName = ETRow_Voyage or _attrName = ETRow_VoyageCode then		
		return self.voyageCode;
	elseif _attrName = ETRow_Colour then										
		return self.colour;
	elseif _attrName = ETRow_Bol then										
		return self.bol;
	elseif _attrName = ETRow_ImexStatus then										
		return self.imexStatus;
	elseif _attrName = ETRow_ServiceOrder then										
		return self.serviceOrder;
	elseif _attrName = ETRow_DischargePort then										
		return self.dischargePort;	
	elseif _attrName = ETRow_LoadPort then										
		return self.loadPort;	
	elseif _attrName = ETRow_Product then										
		return self.product;	
	elseif _attrName = ETRow_MessageMode then										
		return self.messageMode;
	elseif _attrName = ETRow_Commodity then										
		return self.commodity;	
	elseif _attrName = ETRow_CommodityDescription then										
		return self.commodityDescription;	
	elseif _attrName = ETRow_LocationId then										
		return self.locationId;	
	elseif _attrName = ETRow_CarrierCode then										
		return self.carrierCode;	
	elseif _attrName = ETRow_ReceiveStevedore then										
		return self.receiveStevedore;
	elseif _attrName = ETRow_ReleaseStevedore then										
		return self.releaseStevedore;
	elseif _attrName = ETRow_IsExternallyMonitored then										
		return  app.getYesNo(self.isExternallyMonitored);
	elseif _attrName = ETRow_TotalQuantity then										
		return self.totalQuantity.String;	
	elseif _attrName = ETRow_IsoType then										
		return self.isoType;		
	elseif _attrName = ETRow_DestinationPort then										
		return self.destinationPort;	
	elseif _attrName = ETRow_BookingRef then										
		return self.bookingRef;	
	elseif _attrName = ETRow_AvailabilityGrade then										
		return self.availabilityGrade.String;
	elseif _attrName = ETRow_CompanyCode then										
		return self.companyCode;	
	elseif _attrName = ETRow_Consignee then										
		return self.consignee;	
	elseif _attrName = ETRow_Consignor then										
		return self.consignor;	
	elseif _attrName = ETRow_CustomsReference then										
		return self.customsReference;	
		elseif _attrName = ETRow_BreakBulkType then										
		return self.breakBulkType;	
	elseif _attrName = ETRow_HeightString then										
		return self.heightString;	
	elseif _attrName = ETRow_LengthString then										
		return self.lengthString;		
	elseif _attrName = ETRow_WidthString then										
		return self.widthString;
	elseif _attrName = ETRow_IsoTypeGroup then										
		return self.isoTypeGroup;
	elseif _attrName = ETRow_Mark then										
		return self.mark;
	elseif _attrName = ETRow_MarkNumber then										
		return self.markNumber;
	elseif _attrName = ETRow_PreSlung then										
		return app.getYesNo(self.preSlung);
	elseif _attrName = ETRow_HasRadio then										
		return app.getYesNo(self.hasRadio);	
	elseif _attrName = ETRow_SelfPropelled then										
		return app.getYesNo(self.selfPropelled);	
	elseif _attrName = ETRow_Wet then										
		return app.getYesNo(self.selfPropelled);
	elseif _attrName = ETRow_GeneratorType then										
		return self.generatorType;
	elseif _attrName = ETRow_GeneratorID then										
		return self.generatorID;
	elseif _attrName = ETRow_TrailerType then										
		return self.trailerType;
	elseif _attrName = ETRow_ParentCargoID then										
		return self.parentCargoID;
	elseif _attrName = ETRow_ParentCargoType then										
		return self.parentCargoType;
	elseif _attrName = ETRow_Year then										
		return self.year.String;
	elseif _attrName = ETRow_Vin then										
		return self.vin;	
	elseif _attrName = ETRow_CarType then										
		return self.carType;	
	elseif _attrName = ETRow_Model then										
		return self.model;		
	elseif _attrName = ETRow_Make then										
		return self.make;			
	elseif _attrName = ETRow_TrackingNumber1 then										
		return self.trackingNumber1;		
	elseif _attrName = ETRow_TrackingNumber2 then										
		return self.trackingNumber2;
	elseif _attrName = ETRow_DocsSent then	
		if self.docsSent.isValid then
			return self.docsSent.shortFormatJMT();
		endif;
		return null;
	elseif _attrName = ETRow_DocsCleared then		
		if self.docsCleared.isValid then
			return self.docsCleared.shortFormatJMT();
		endif;
		return null;
	elseif _attrName = ETRow_DocsReceived then		
		if self.docsReceived.isValid then
			return self.docsReceived.shortFormatJMT();
		endif;
		return null;	
	elseif _attrName = ETRow_DocsReturned then		
		if self.docsReturned.isValid then
			return self.docsReturned.shortFormatJMT();
		endif;
		return null;	
	elseif _attrName = ETRow_Doors then										
		return self.doors.String;
	elseif _attrName = ETRow_IsNew then										
		return app.getYesNo(self.isNew);
	elseif _attrName = ETRow_RemarksAdditional1 then										
		return self.remarksAdditional1;	
	elseif _attrName = ETRow_RemarksAdditional2 then										
		return self.remarksAdditional2;
	elseif _attrName = ETRow_Registration then										
		return self.registration;	
	elseif _attrName = ETRow_ReceiptTransportMode then										
		return self.receiptTransportMode.String;	
	elseif _attrName = ETRow_PurchaseOrder then										
		return self.purchaseOrder;	
	elseif _attrName = ETRow_OrderNumber then										
		return self.orderNumber;
	elseif _attrName = ETRow_InvoiceNumber then										
		return self.invoiceNumber;
	elseif _attrName = ETRow_ExpiryDate then										
		if self.expiryDate.Date.isValid then
			return self.expiryDate.shortFormatJMT();
		endif;
		return null;
	elseif _attrName = ETRow_EngineNo then										
		return self.engineNo;
	elseif _attrName = ETRow_Description then										
		return self.description;
	elseif _attrName = ETRow_CustomsAgent then										
		return self.customsAgent;
	elseif _attrName = ETRow_FreightForwarder then										
		return self.freightForwarder;
	elseif _attrName = ETRow_ChassisNo then										
		return self.chassisNo;
	elseif _attrName = ETRow_Certificate1Expiry then										
		if self.certificate1Expiry.Date.isValid then
			return self.certificate1Expiry.shortFormatJMT();
		endif;
		return null;
	elseif _attrName = ETRow_Certificate2Expiry then										
		if self.certificate2Expiry.Date.isValid then
			return self.certificate2Expiry.shortFormatJMT();
		endif;
		return null;
	elseif _attrName = ETRow_Certificate1 then										
		return self.certificate1;
	elseif _attrName = ETRow_Certificate2 then										
		return self.certificate2;
	elseif _attrName = ETRow_ShippingLineCodeForTI then										
		return self.shippingLineCodeForTI;
	elseif _attrName = ETRow_Remarks then										
		return self.remarks;
	elseif _attrName = ETRow_ReceiveDate then										
		if self.receiveDate.TimeStamp.isValid then
			return self.systemToLocalTime(self.receiveDate.TimeStamp).shortCurrentLocaleFormat();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
		endif;
		return null;
	elseif _attrName = ETRow_CountryOfOriginCode then								
		return self.countryOfOriginCode;
	elseif _attrName = ETRow_Quantity then								
		return self.quantity.String;
	elseif _attrName = ETRow_DirectDelivery then								
		return app.getYesNo(self.directDelivery);
		elseif _attrName = ETRow_ImCodes or _attrName = ETRow_Hazards or _attrName = ETRow_Hazardous then
		if self.imCodes.isNotEmpty then									
			return self.getHazardsAsString();
		endif;
		return null;
		
	elseif _attrName = ETRow_SealNumberVent then							
		if self.myAttachedItems.isNotEmpty then
			return self.sealNumberVent;
		endif;
		return null;
	elseif _attrName = ETRow_SealShipper then								
		if self.myAttachedItems.isNotEmpty then
			return self.sealShipper;
		endif;
		return null;
	elseif _attrName = ETRow_SealTerminalOperator then						
		if self.myAttachedItems.isNotEmpty then
			return self.sealTerminalOperator;
		endif;
		return null;
	elseif _attrName = ETRow_SealCustoms then								
		if self.myAttachedItems.isNotEmpty then
			return self.sealCustoms;
		endif;
		return null;
	elseif _attrName = ETRow_SealUnknown then								
		if self.myAttachedItems.isNotEmpty then
			return self.sealUnknown;
		endif;
		return null;
	elseif _attrName = ETRow_SealNum then									
		if self.myAttachedItems.isNotEmpty then
			return self.sealNum;
		endif;
		return null;
	//30.11.2022 navma1 #55424
	
	elseif _attrName = ETRow_Temperature then
		if self.temperature = NULL_TEMPERATURE then
			return null;
		else
			return self.temperature.String;
		endif;
	elseif _attrName = ETRow_Vent then
		return self.vent.asNullDecimal;
	elseif _attrName = ETRow_Humidity then
		return self.getHumidity.asNullHumidity;
	elseif _attrName = ETRow_CarbonDioxide then
		return self.getCarbonDioxide.asNullCarbonDioxide;
	elseif _attrName = ETRow_Oxygen then
		return self.getOxygen.asNullOxygen;
	elseif _attrName = ETRow_WeightTons then
		return (self.weight * .001).asStringWeightJMT();
	elseif _attrName = ETRow_CargoTypeDescr then 										//cnwrd1 for par 19189
		return cargoTypeDescr.String;
	elseif _attrName = ETRow_TotalWeight then											//+cnwml2 MSL CCMS 1017
		return self.weight.asStringWeightJMT();
	elseif _attrName = ETRow_Height then
		return self.height.asStringMeasurementJMT();
	elseif _attrName = ETRow_Width then
		return self.width.asStringMeasurementJMT();
	elseif _attrName = ETRow_Length then
		return self.length.asStringMeasurementJMT();
		
	elseif _attrName = ETRow_SalesOrderNbr then											// PAR #33019
		return self.getSalesOrderNbr();													// PAR #33019
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverHeight then
		if self.overHeight = NULL_INTEGER then
			return null;
		else
			return self.overHeight.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverLengthBack then
		if self.overLengthBack = NULL_INTEGER then
			return null;
		else
			return self.overLengthBack.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverLengthFront then
		if self.overLengthFront = NULL_INTEGER then
			return null;
		else
			return self.overLengthFront.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverWidthLeft then
		if self.overWidthLeft = NULL_INTEGER then
			return null;
		else
			return self.overWidthLeft.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverWidthRight then
		if self.overWidthRight = NULL_INTEGER then
			return null;
		else
			return self.overWidthRight.String;
		endif;
		
	elseif _attrName = ETRow_CargoGroupId then	//15 Sep 2015	NDL	Par 36906
		return self.cargoGroupId;
		
	elseif _attrName = ETRow_IsCertifiedWeight then					// TFS #1699
		return self.isWeightCertified.getYes;						// TFS #1699
	elseif _attrName = ETRow_WeightCertifiedName then				// TFS #1699
		return self.weightCertifiedName;							// TFS #1699
	elseif _attrName = ETRow_WeightCertifiedReference then			// TFS #1699
		return self.weightCertifiedReference;						// TFS #1699
		
	elseif _attrName = ETRow_HeatTreated then	//24 Apr 2017	NDL	TFS 3414
		return self.heatTreated;
		
	elseif _attrName = ETRow_StoreOnPallet then	//24 Apr 2017	NDL	TFS 3414
		return self.storeOnPallet;
		
	elseif _attrName = ETRow_PalletType then	//24 Apr 2017	NDL	TFS 3414
		return self.palletType;
	elseif _attrName = ETRow_Grade then		
		return self.grade;
	elseif _attrName = ETRow_Grammage then
		if self.grammage &gt; 0 then
			return self.grammage.asStringJMT;
		endif;	
		return null;
	elseif _attrName = ETRow_ShippingLineCode then										
		return self.shippingLineCodeForTI;
	elseif _attrName = ETRow_ShipperDescription then //jlier1 TFS 57452 14/4/23
		return self.getShipperDescription; 
	elseif _attrName = ETRow_ManifestNumber then
		return self.getManifestNumber;
	elseif	_attrName = ETRow_ContainerNumberText then						//19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		return self.getContainerNumberText();
	elseif	_attrName = ETRow_PortOfOrigin then								//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
		return self.getPortOfOrigin();
	elseif _attrName = ETRow_VesselCodeForManifest then						//	06.03.24		navhn30		TFS # 62299
		if self.getVoyage &lt;&gt; null then 
			return self.getVoyage.vesselName;
		endif;
		return null;
	elseif _attrName.isMeasurementType then									// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);						// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);	// PAR #33005
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHazardsAsString" id="b4f38eca-503a-4259-b75a-5f56bdb21ef7">
        <source>getHazardsAsString(): String;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
vars
	tmpHazards : ObjectArray;
	hazards : CM_HazardByCodeDict;
	haz : CM_Hazard;
	str : String;
begin
	create tmpHazards transient;
	create hazards transient;
	if self.imCodes.isEmpty then
		return null;
	endif;
	self.getProxyHazards(self.imCodes, tmpHazards, false);
	tmpHazards.copy(hazards);
	if hazards.isEmpty then
		return null;
	endif;
	foreach haz in hazards do
		str := str &amp; haz.getTableDisplay(false, true) &amp; ", ";
	endforeach;
	str := str[1:str.length - 2];
	return str;
epilog
	tmpHazards.purge();
	delete tmpHazards;
	delete hazards;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHumidity" id="d12f22a2-cdd1-4733-8fd4-6f19f5199928">
