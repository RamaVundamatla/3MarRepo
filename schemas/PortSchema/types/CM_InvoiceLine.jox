    <JadeMethod name="setTaxCodes" id="cbeb6771-3ec0-455e-b372-5629d58251e6">
        <updating/>
        <source>setTaxCodes(_taxCode : String) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 21MAR2024
ADO -  CR 62992 TASK 62994 
*/

vars
begin
	if _taxCode= null then
		return;
	endif;
	/*
	if self.taxCode.pos(_taxCode, 1) = 0 then
		if self.taxCode = null then
			self.taxCode := _taxCode;
		else	
			self.taxCode := self.taxCode &amp; "," &amp; _taxCode;
		endif;
	endif;
	*/
	
	self.taxCode.addStringToList(_taxCode, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
	
	if self.invoice &lt;&gt; null then
		self.invoice.setTaxCodes(_taxCode);
	endif;
epilog

end;</source>
        <Parameter name="_taxCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTaxDescriptions" id="a0a81372-ca55-4c30-ac8b-e85359ea8b6a">
        <updating/>
        <source>setTaxDescriptions(_taxDesc : String) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 21MAR2024
ADO -  CR 62992 TASK 62994 
*/

vars

begin
	if _taxDesc= null then
		return;
	endif;
	
	/*
	if self.taxDescription.pos(_taxDesc, 1) = 0 then
		if self.taxDescription = null then
			self.taxDescription := _taxDesc;
		else	
			self.taxDescription := self.taxDescription &amp; "," &amp; _taxDesc;
		endif;
		if self.invoice &lt;&gt; null then
			self.invoice.setTaxDescriptions(_taxDesc);
		endif;
	endif;
	*/
	self.taxDescription.addStringToList(_taxDesc, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
	if self.invoice &lt;&gt; null then
		self.invoice.setTaxDescriptions(_taxDesc);
	endif;
epilog

end;</source>
        <Parameter name="_taxDesc" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTaxDetails" id="d7a8f8bb-716d-43cb-9303-bd29b1c6256b">
        <updating/>
        <source>setTaxDetails() updating;
/*
Purpose:			

Date		Who		Reason
21 March 2024	navab1	CR 62992 TASK 62994 
*/

vars
	taxCodeObj : CM_TaxCode;
	charge : CM_Charge;
	taxStr, extRefStr : String;
	lineAmount, taxValue, chargeTaxValue : Decimal[23,4];
begin

	self.taxCode := "";
	self.taxDescription := "";
	self.taxGLCode := "";
	self.taxRates := ""; // ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1
	self.taxRate := 0;
	self.taxTotal := 0;
	self.taxValue := 0;
	self.taxExtRef := ""; // ### TFS BUG 63997 07MAY2024 NAVAB1

	if self.status = CM_InvoiceLine.STATUS_VOIDED then // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
		return;
	endif;
	
	foreach charge in self.charges do
	
		// ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1
		charge.setTaxDetails(); // this sets the invoice line as well.
		
		/* // ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1
		// ### CODE
		taxStr:= charge.getTaxDescription(false);
		if taxStr &lt;&gt; null then 
			self.setTaxCodes(taxStr);
		endif;
		
		// ### DESC
		taxStr:= charge.getTaxDescription(true);
		if taxStr &lt;&gt; null then 
			self.setTaxDescriptions(taxStr);
		endif;
		
		// ### GL CODE
		taxStr:= charge.getTaxGLCode();
		if taxStr &lt;&gt; null then 
			self.setTaxGLCodes(taxStr);
		endif;
		
		// ### RATE
		self.setTaxRates(charge.getTaxRateForCharge());


		*/
		
		
		// ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1
		chargeTaxValue := (charge.total  * (charge.taxRate / 100));
		taxValue := taxValue +  chargeTaxValue;
		
		// ### TFS BUG 63997 07MAY2024 NAVAB1
		taxCodeObj := charge.getTaxCodeObject();
		if taxCodeObj &lt;&gt; null then
			extRefStr := taxCodeObj.externalReference1;
			/*
			if extRefStr &lt;&gt; null then
				if taxStr.pos(extRefStr, 1) = 0 then	
					taxStr := extRefStr;
				else	
					taxStr := taxStr &amp; "," &amp; extRefStr;
				endif;
			endif;
			*/
			taxStr.addStringToList(extRefStr, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
		endif;

	endforeach;
	
	self.taxExtRef := taxStr; // ### TFS BUG 63997 07MAY2024 NAVAB1

	// ### TFS BUG 62926 02APR2024 NAVAB1
	lineAmount := self.lineTotal; // this is derived and uses terminal configurations so put in local

	// ### VALUE
	// ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1self.setTaxValues(lineAmount * (self.taxRate / 100)); // use the  tax rate already calculated above
	self.setTaxValues(taxValue);

	// ### TOTAL WITH TAX
	self.setTaxTotals(self.taxValue + lineAmount); // use the tax value calculated above
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTaxGLCodes" id="b56ab843-9731-4609-9eb2-83d256762939">
        <updating/>
        <source>setTaxGLCodes(_taxGLCode : String) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 21MAR2024
ADO -  CR 62992 TASK 62994 
*/

vars
begin
	if _taxGLCode= null then
		return;
	endif;
	
	/*
	if self.taxGLCode.pos(_taxGLCode, 1) = 0 then
		if self.taxGLCode = null then
			self.taxGLCode := _taxGLCode;
		else	
			self.taxGLCode := self.taxGLCode &amp; "," &amp; _taxGLCode;
		endif;
	endif;
	*/
	
	self.taxGLCode.addStringToList(_taxGLCode, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
epilog

end;</source>
        <Parameter name="_taxGLCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTaxRates" id="c1210b7d-6c47-4de5-9aaf-974b79e6b8ea">
        <updating/>
        <source>setTaxRates(_taxRate : Decimal) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 21MAR2024
ADO -  CR 62992 TASK 62994 
*/

vars
	taxStr : String;
begin
	if _taxRate= null then
		return;
	endif;
	
	self.taxRate := _taxRate; // this is inaccurate as it will always be base ONLY on the  last charge, so if 2 or more charges this 'rate' will be wrong.
	
	taxStr := _taxRate.asStringJMTWithPrecision(2,false);
	
	/*
	// ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
	if self.taxRates.pos(taxStr, 1) = 0 then
		if self.taxRates = null then
			self.taxRates := taxStr;
		else	
			self.taxRates := self.taxRates &amp; "," &amp; taxStr;
		endif;
	endif;
	*/
	
	self.taxRates.addStringToList(taxStr, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
	
	if self.invoice &lt;&gt; null then
		self.invoice.setTaxRates(taxStr);
	endif;

epilog

end;</source>
        <Parameter name="_taxRate" type="Decimal"/>
    </JadeMethod>
