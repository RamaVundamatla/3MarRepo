    <JadeMethod name="updateMe" id="3d3fa7b7-4508-4d20-80cf-c18a92e69470">
        <updating/>
        <source>updateMe(	pComputerName:String;
			pEmailClientName:String;
			pEmailReturnAddress:String;
			pEmailServerName:String;
			pLdapBase:String;
			pLdapHost:String;
			pMyEmailBaseRoot:CnEcEmailRoot)  : String updating; 

// This method created by JediMethodGenerator at 15:53:23 on 14 March 2001
// Please add any validation required then delete this comment.

vars
	errorMessage	: String;

begin
	// Validation

	errorMessage := self.validateMe(
				pComputerName,
				pEmailClientName,
				pEmailReturnAddress,
				pEmailServerName,
				pLdapBase,
				pLdapHost,
				pMyEmailBaseRoot);  

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Attributes (Non Keys)

	if self.emailClientName &lt;&gt; pEmailClientName then
		self.emailClientName := 	pEmailClientName;
	endif;
	if self.emailReturnAddress &lt;&gt; pEmailReturnAddress then
		self.emailReturnAddress := 	pEmailReturnAddress;
	endif;
	if self.emailServerName &lt;&gt; pEmailServerName then
		self.emailServerName := 	pEmailServerName;
	endif;
	if self.ldapBase &lt;&gt; pLdapBase then
		self.ldapBase := pLdapBase;
	endif;
	if self.ldapHost &lt;&gt; pLdapHost then
		self.ldapHost := pLdapHost;
	endif;

	// Attributes (Keys)

	if self.computerName &lt;&gt; pComputerName then
		self.computerName := 	pComputerName;
	endif;

	// Singleton References

	if self.myEmailBaseRoot &lt;&gt; pMyEmailBaseRoot then
		self.myEmailBaseRoot := 	pMyEmailBaseRoot;
	endif;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pComputerName" type="String"/>
        <Parameter name="pEmailClientName" type="String"/>
        <Parameter name="pEmailReturnAddress" type="String"/>
        <Parameter name="pEmailServerName" type="String"/>
        <Parameter name="pLdapBase" type="String"/>
        <Parameter name="pLdapHost" type="String"/>
        <Parameter name="pMyEmailBaseRoot" type="CnEcEmailRoot"/>
