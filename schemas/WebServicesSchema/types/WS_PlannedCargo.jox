    <JadeMethod name="delete" id="37d15283-e136-430d-a869-a9f2faecb823">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if not self.allCargoCheckItems.isEmpty then	//17 Oct 2011	NDL	Par 28303
		self.allCargoCheckItems.purge;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCargoCheckItems" id="822b2a09-d4c1-4e10-b250-eb70b2ec9fbc">
        <source>setCargoCheckItems( _ti: CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars

	cargoCheckItems : CM_CargoCheckItemArray;
	cargoCheckItem : CM_CargoCheckItem;
	wscargoCheck : WS_CargoCheck;
	sealType : CM_SealType;
	allSealTypes : CM_SealTypeSet;

begin

	create cargoCheckItems transient;
	_ti.getCargoCheckItemsForTallyman( cargoCheckItems, true, true );
	
	if cargoCheckItems.isEmpty then
		return;
	endif;
	
	foreach cargoCheckItem in cargoCheckItems discreteLock do
		if cargoCheckItem.requiredExtraInfo &lt;&gt; EXTRA_INFO_SEALS then
			create wscargoCheck transient;
			wscargoCheck.setProxyFromObject( cargoCheckItem );
			self.allCargoCheckItems.add( wscargoCheck );
		endif;
	endforeach;
	
	if _ti.myCargoType = null or _ti.myCargoType.allSealTypes.isEmpty then
		return;
	endif;
	
	create allSealTypes transient;
	foreach cargoCheckItem in cargoCheckItems discreteLock do
		if cargoCheckItem.requiredExtraInfo = EXTRA_INFO_SEALS then
		
			allSealTypes.clear();
			foreach sealType in _ti.myCargoType.allSealTypes do
				if sealType.notAvailableForEntry then
					continue;
				endif;
				allSealTypes.add(sealType);
			endforeach;
			
			foreach sealType in allSealTypes do
				create wscargoCheck transient;
				wscargoCheck.setProxyFromObjectAndSeals( _ti, sealType, cargoCheckItem );
				self.allCargoCheckItems.add( wscargoCheck );
			endforeach;
			
		endif;
	endforeach;

epilog

	delete cargoCheckItems;
	delete allSealTypes;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromTrackedItem" id="075f2140-18b3-495a-b003-90f337c12290">
        <updating/>
        <source>setDetailsFromTrackedItem(_ti : CM_TrackedItem) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28/10/2011	cnwer1	Initial creation CCMS MES 1033
19/05/2017	cnwdap1	TFS 4464 protect from 1035 errors
12/04/2021  navma1	Bug 50647: MTN - Tallyman RORO Deck Load Details
*/

vars
	cargoType 	 : CM_CargoType;
	str 		 : String;								// TFS 4464
begin

	if _ti = null then
		return;
	endif;
	
	cargoType:=_ti.myCargoType;
	
	if cargoType &lt;&gt; null then
		self.cargoTypeDesc	:= cargoType.abbreviation;
		self.cargoTypeId 	:= cargoType.id;			// 16/10/19 MAP TFS44959
	endif;
	
	self.id:=_ti.id;
	// PAR 31352 add some extra fields for Reefer and OutofGauge
	str :=  _ti.getHazardsAsString &amp; " &lt;" &amp;									// TFS 4464
			_ti.isReefer.getYesNo()[1] &amp; 									// TFS 4464
			_ti.isOverDimensions.getYesNo()[1] &amp; "&gt;";						// TFS 4464
	
	str 		 := str[1:30];												// TFS 4464
	self.hazards := str;													// TFS 4464
	
	self.dischargePort	 := _ti.dischargePort;
	self.isoGroup 		 := _ti.isoTypeGroup;
	self.isoType		 := _ti.getISOType;
	self.commodityCode	 := _ti.commodity;
	self.operatorCode 	 := _ti.operatorCode;
	self.weight 		 := _ti.totalWeight.asStringWeightForWebInterface();	//26 Oct 2012	NDL	Par 30622

	//epr par 32749 29/4/14 changes to display 45, 30 and 53s
	//if _ti.is20() or not _ti.isContainer then     //12.04.2021 cnwma1 #50647
	if _ti.isContainer then                         //12.04.2021 cnwma1 #50647
		if _ti.is20() then
			self.length:="20";
		elseif _ti.is45 then
			self.length := "45";
		elseif _ti.is30 then
			self.length := "30";
		elseif _ti.is53 then
			self.length := "53";
		else
			self.length:="40";
		endif;
	else
		self.length:="";
	endif;
	self.setCargoCheckItems( _ti );					//17 Oct 2011	NDL	Par 28303
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromVoyageRequest" id="335eb4e3-0468-452d-b5af-77c58475bbf9">
        <updating/>
        <source>setDetailsFromVoyageRequest(_voyageRequest : CM_Request) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Sep 2011	cnwer1	Initial creation CCMS MES 1033
11 Jul 2012 cnwer1  PAR 29962 - Work with LOLO
*/

vars
	isoType		: CM_ISOType;
	isoGroup 	: CM_ISOTypeGroup;
	cargoType 	: CM_CargoType;
	tmpPort 	: CM_Port;
	criteria : CM_YACriteria;	
	theCommodity : CM_Commodity;
	operator 	: CM_Operator;
	imexStatus : CM_IMEXStatus;
	locationController 	: CM_VoyageROROController;
	voyAllocation : CM_VoyageAllocation;
begin

	cargoType:=_voyageRequest.getAttrCargoType;
	if cargoType &lt;&gt; null then
		self.cargoTypeDesc:=cargoType.abbreviation;
		self.cargoTypeId := cargoType.id;		// 16/10/19 MAP TFS44959
	endif;
	
	//cnwmc5 - PAR 32206 - 5 Sep 2013
	self.hazards:= _voyageRequest.getAttrHazardous.String;	//_voyageRequest.getAttrHazardous.getYesNo();
	
	tmpPort:=_voyageRequest.getAttrDischargePort;
	if tmpPort &lt;&gt; null then
		self.dischargePort:=tmpPort.code;
	endif;
	
	voyAllocation := _voyageRequest.getFirstAllocation;
	if voyAllocation &lt;&gt; null then
		self.colourCode:=voyAllocation.color.cnEcGetHexColor;
		self.loadAllocaction:=voyAllocation.code;
	else
		if tmpPort &lt;&gt; null then
			if tmpPort.colour &lt;&gt; 0 then
				self.colourCode:=tmpPort.colour.cnEcGetHexColor;
			endif;
		endif;
	endif;
	
	if 	self.colourCode = null then
		self.colourCode:=White.cnEcGetHexColor;
	endif;
	
	criteria := _voyageRequest.getAttrByType(YACriteriaType_ImexStatus);
	if criteria &lt;&gt; null then
		imexStatus := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_IMEXStatus;
		if imexStatus &lt;&gt; null then
			self.imex:=imexStatus.description;
		endif;
	endif;
	
	criteria := _voyageRequest.getAttrByType(YACriteriaType_ISOGroup);
	if criteria &lt;&gt; null then
		isoGroup := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup;
		if isoGroup &lt;&gt; null then
			self.isoGroup:=isoGroup.code;
		endif;
	endif;
	
	criteria := _voyageRequest.getAttrByType(YACriteriaType_ISO);
	if criteria &lt;&gt; null then
		isoType := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType;
		if isoType &lt;&gt; null then
			self.isoType:=isoType.code;
		endif;
	endif;
	
	criteria := _voyageRequest.getAttrByType(YACriteriaType_Commodity);
	if criteria &lt;&gt; null then
		theCommodity := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Commodity;
		if theCommodity &lt;&gt; null then
			self.commodityCode := theCommodity.code;
		endif;
	endif;
	
	criteria  :=	 _voyageRequest.getAttrByType(YACriteriaType_OperatorItem);
	if criteria &lt;&gt; null then
		operator := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Operator;
		if operator &lt;&gt; null then
			self.operatorCode := operator.code;
		endif;
	endif;
	
	//self.weight :=_voyageRequest.getRequestWeight.asStringJMT;
	self.weight := _voyageRequest.getRequestWeight.asStringWeightForWebInterface();	//26 Oct 2012	NDL	Par 30622
	
	//or _voyageRequest.isRehandle
	if (_voyageRequest.isSOB ) and _voyageRequest.myRequestLinkedDischarge &lt;&gt; null then
		if _voyageRequest.myRequestLinkedDischarge.myJob &lt;&gt; null then
			self.jobID:= _voyageRequest.myRequestLinkedDischarge.myJob.id;
		endif;
	
	endif;
	if _voyageRequest.myJob &lt;&gt; null then
		self.jobID:=_voyageRequest.myJob.id;
	endif;
	//self.sequenceNum:=_voyageRequest.getNumSeqPort.xasStringJMT;
	self.sequenceNum:=_voyageRequest.getNumSeqPort.String;	//26 Oct 2012	NDL	Par 30622
	
	if self.length = null then
		if _voyageRequest.getAttrIs20() then
			self.length:="20";
		elseif _voyageRequest.getAttrIs40() or	
			_voyageRequest.getAttrIs30 or
			_voyageRequest.getAttrIs45 or 
			_voyageRequest.getAttrIs53 then //TFS 50658 jlier1 need to be explicit we don't want to return a length if it is a car or general cargo
			self.length:="40";	
		endif;
	endif;
		
	if _voyageRequest.isKindOf(CM_RORORequest) then
		locationController:=_voyageRequest.CM_RORORequest.myROROController;
		if locationController &lt;&gt; null then
			if locationController &lt;&gt; null and locationController.isKindOf(CM_ROROSlotController) then
				self.tierPosition :=locationController.CM_ROROSlotController.ordinalSlot;
			endif;
		endif;
	else
	//its a slot request only ever 1 cargo in 1 slot unlike roro
		self.tierPosition :=1;
	endif;
		
	if _voyageRequest.getIsRehandle then
		//self.transitStatus := TI_TransitStatusDLR.xasStringJMT;
		self.transitStatus := TI_TransitStatusDLR.String;	//26 Oct 2012	NDL	Par 30622
	endif;
	
	if _voyageRequest.isSOB then
		if _voyageRequest.getAttrIsLoad then
			// need to signify if it is a SOB LOAD don't have constant in JMT yet
			self.transitStatus := "6";
		else
			//self.transitStatus := TI_TransitStatusSOB.xasStringJMT;
			self.transitStatus := TI_TransitStatusSOB.String;	//26 Oct 2012	NDL	Par 30622
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyageRequest" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="19a5ff94-e2ba-40ee-8d67-328a61258f9d">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if _object.isKindOf(CM_Request) then
		self.setDetailsFromVoyageRequest(_object.CM_Request);
	elseif _object.isKindOf(CM_TrackedItem) then
		self.setDetailsFromTrackedItem(_object.CM_TrackedItem);
	endif;

epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
