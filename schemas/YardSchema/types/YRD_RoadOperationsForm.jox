    <JadeMethod name="mnuGateLane_click" id="aa59acd9-feb8-4361-a8bf-d9eeb2896a80">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGateLane_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		28 April 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
