    <JadeMethod name="getAuditText" id="3e247a5c-3238-4bd9-804b-b0571f0fe785">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     13 June 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt,str 		: String;
	tmpStr	: String;
    termExpr    : CM_TerminologyExpression;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach termExpr in self.allTerminologyExpressions do
		if termExpr &lt;&gt; null then
			str :=termExpr.expressionDescr&amp;' (' &amp;termExpr.systemExpression&amp; ')';
			txt := txt &amp; str &amp; AuditStringSeparator &amp; termExpr.userExpression.length.String &amp; AuditStringSeparator &amp; termExpr.userExpression &amp; AuditStringSeparator;
		endif;	
	endforeach;
	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="393ff39d-8c18-46cb-900b-b82267cf442a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _attrName = ETRow_TermHdrName then
		return self.name;
	elseif _attrName = ETRow_TermType then
		return self.myTerminologyType.name;
	endif;

	return inheritMethod(_attrName, _short);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processUserHeadings" id="ef22be22-e06b-4987-9782-3928593a5641">
        <updating/>
        <source>processUserHeadings() updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	termDtl								: CM_TerminologyDtl;
	terminologyExpression				: CM_TerminologyExpression;
begin
	//set them all back to system default for re-processing
	foreach termDtl in self.allTerminologyDtls do
		termDtl.resetUserHeading();
	endforeach;
	
	foreach terminologyExpression in self.allTerminologyExpressions do
		foreach termDtl in self.allTerminologyDtls do
			termDtl.processUserHeadings(terminologyExpression);
		endforeach;
	endforeach;
	
	self.pxyHeadingsHaveBeenProcessed := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="335d4e7d-756f-4b21-80ba-d782e3f4df5b">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	pxyTermDef		: CM_TerminologyDef;
	termExp,
	pxyTermExp		: CM_TerminologyExpression;
	termDtl,
	pxyTermDtl		: CM_TerminologyDtl;
	pxyCTTerminal,
	termCTTerminal	: CM_TerminologyHdr;
	completedOK		: Boolean;
begin

	pxyTermDef := inheritMethod();
	pxyTermDef.myTerminologyType := self.myTerminologyType;
	foreach termExp in self.allTerminologyExpressions do
		pxyTermExp := termExp.pxyCreateUpdateProxy();
		pxyTermExp.setMyTermTypeExpression(termExp.myTermTypeExpression);
		pxyTermExp.setMyTerminologyHdr(pxyTermDef);
	endforeach;
	
	foreach termDtl in self.allTerminologyDtls do
		pxyTermDtl := termDtl.pxyCreateUpdateProxy();
		pxyTermDtl.setMyTermTypeDtl(termDtl.myTerminologyTypeDtl);
		pxyTermDtl.setMyTerminologyHdr(pxyTermDef);
	endforeach;
	
	foreach termCTTerminal in self.allTerminologyHdrs do
		pxyCTTerminal := termCTTerminal.pxyCreateUpdateProxy();
		pxyCTTerminal.setMyTerminologyDef(pxyTermDef);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyTermDef;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyTermDef;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e9672be6-acbf-44ba-816f-67f55a418b41">
        <updating/>
        <source>setForCreate(_pxyTermDef : CM_TerminologyDef) updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.setForUpdate(_pxyTermDef);
	
end;</source>
        <Parameter name="_pxyTermDef" type="CM_TerminologyDef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4e276348-3f49-43ce-a07d-bacb49916642">
        <updating/>
        <source>setForUpdate(_pxyTermDef : CM_TerminologyDef) updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pxyTermDtl,
	realTermDtl				: CM_TerminologyDtl;
	pxyExp,
	realExp					: CM_TerminologyExpression;
	realTermHdr,
	pxyTermHdr				: CM_TerminologyHdr;
begin
	self.name 			:= _pxyTermDef.name;
	self.myTerminologyType := _pxyTermDef.myTerminologyType;
	
	foreach pxyExp in _pxyTermDef.allTerminologyExpressions do
		realExp := self.allTerminologyExpressions[_pxyTermDef.name, pxyExp.expressionType];
		if realExp = null then
			create realExp persistent;
		endif;
		
		realExp.setForUpdate(pxyExp, self);
	endforeach;
	
	foreach pxyTermDtl in _pxyTermDef.allTerminologyDtls do
		realTermDtl := self.allTerminologyDtls[pxyTermDtl.groupName, pxyTermDtl.rowName];
		if realTermDtl = null then
			create realTermDtl persistent;
		endif;
		
		realTermDtl.setForUpdate(pxyTermDtl, self);
	endforeach;
	
	//should always be false on persistents - in this way pxy have this value always false
	self.pxyHeadingsHaveBeenProcessed := false;
	
	
	self.allTerminologyHdrs.purge();
	foreach pxyTermHdr in _pxyTermDef.allTerminologyHdrs do
		create realTermHdr persistent;
		realTermHdr.setForUpdate(pxyTermHdr, self);
	endforeach;
	
end;</source>
        <Parameter name="_pxyTermDef" type="CM_TerminologyDef"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="220343b6-a58e-45fe-a4c8-eb1e5dd32e69">
        <updating/>
        <source>setProxy(_name : String;
		_termType : CM_TerminologyType) updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	termExp : CM_TerminologyExpression;
	termTypeExp : CM_TerminologyTypeExpression;

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.name := _name;
	
	if _termType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'terminlogy Type passed in is null');
		return;
	endif;
	
	self.myTerminologyType := _termType;
	
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_termType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="c53fcecc-976c-4199-aaff-7cf99a3645c8">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myTerminologyType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminology type is null');
		return;
	endif;
	
	self.validateForUpdate();

end;</source>
    </JadeMethod>
