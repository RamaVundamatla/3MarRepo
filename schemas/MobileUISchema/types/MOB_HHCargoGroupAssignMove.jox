    <JadeMethod name="cmbNotifyCGroup_click" id="dfaee580-c054-4ef1-8e61-482f7e4d5034">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbNotifyCGroup_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars
	
//	notifyCG : CM_NotifiedCargoGroup;
	cargoGroup : CM_CargoGroup;
	
begin

	cargoGroup := self.cmbNotifyCGroup.listObject.CM_CargoGroup; 

	if cargoGroup = null then
		self.setMyCargoGroup( null );
	else
		
		if ( self.myCargoGroup &lt;&gt; null and self.myCargoGroup.id &lt;&gt; cargoGroup.id )
		or self.myCargoGroup = null
		then
			self.setMyCargoGroup( cargoGroup );
		endif;
		if self.myCargoGroup &lt;&gt; null and self.myCargoGroup.getLastOnsiteLocation() &lt;&gt; null then
			//pre-populate with the last location actually used if possible
			self.txtLocation.text := self.myCargoGroup.getLastOnsiteLocation().getFullId;
			self.txtLocation_lostFocus( self.txtLocation );
		endif;
		
	endif;

	
	self.setWeightAndCount();


epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOverviewClick" id="68c4a502-f3f2-4f7a-8a88-9fd7b0b5bcd8">
        <updating/>
        <source>doOverviewClick()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

//	cgn : CM_NotifiedCargoGroup;
	cg : CM_CargoGroup;

begin

	if self.cmbNotifyCGroup.listIndex &gt; 0 then
		cg := self.cmbNotifyCGroup.listObject.CM_CargoGroup;
	endif;
	
//	self.myMobileGenericAgent.setMyNotifiedCargoGroup( cgn );
	//02 Oct 2018	NDL	TFS 39186
	self.myMobileGenericAgent.setMyCargoGroup( cg );
	self.myMobileGenericAgent.setMyCargoGroupAssignment( self.myCargoGroupAssignment );
	
	self.gotoForm(MOB_HHCargoGroupAssignView, false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="ece3cfb1-6f6a-4550-815b-66cd76f1afe6">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	tabIndex : Integer;

begin
	
	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin; //- self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.txtCGAssign.setAndIncrementTabIndex( tabIndex );
		self.txtCGAssign.visible := true;
	endif;
	self.txtCGAssign.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.txtCGAssign.top + self.txtCGAssign.height; // + self.resizedMargin;
	if _initialSetup then
		self.lblProgress.visible := true;
		self.lblProgress.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblProgress.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	top := top + self.lblProgress.height;	// + self.resizedMargin;
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move(	stdLeft,
							 top,
							 stdWidth,
							 stdHeight );
						 
	top := top + self.txtCargoId.height; // + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.visible := true;
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoType.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							 
	top := top + self.lblCargoType.height - 2;	// + self.resizedMargin;
	if _initialSetup then
		self.lblCargoDesc.visible := true;
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoDesc.move( stdLeft,
							top,
							stdWidth,
							stdHeight );
	
	top := self.lblCargoDesc.top + self.lblCargoDesc.height; // + self.resizedMargin;
	if _initialSetup then
		self.cmbNotifyCGroup.setAndIncrementTabIndex( tabIndex );
		self.cmbNotifyCGroup.visible := true;
	endif;
	self.cmbNotifyCGroup.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.cmbNotifyCGroup.top + self.cmbNotifyCGroup.height; // + self.resizedMargin;	
	if _initialSetup then
		self.lblCGroupDesc.visible := true;
		self.lblCGroupDesc.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCGroupDesc.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
							
	top := top + self.lblCGroupDesc.height - 2;	// + self.resizedMargin; 
	if _initialSetup then
		self.lblWeightValue.visible := true;
		self.lblWeightValue.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblWeightValue.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
								
	top := top + self.lblWeightValue.height - 2;	// + self.resizedMargin;
	if _initialSetup then
		self.lblWeightRange.visible := true;
		self.lblWeightRange.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblWeightRange.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	
	top := top + self.lblWeightRange.height - 2;	// + self.resizedMargin;
	if _initialSetup then
		self.lblCountValue.visible := true;
		self.lblCountValue.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCountValue.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	
	top := top + self.lblCountValue.height + self.resizedMargin; // + self.resizedMargin;
	if _initialSetup then
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.txtLocation.top + self.txtLocation.height + self.resizedMargin + stdHeight;
	
	inheritMethod(_initialSetup);
	
							
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="209e2faa-5fec-4c4b-96fc-5d2f251f15a6">
        <updating/>
        <source>doSave():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2015	cnwndl1	Initial creation	Par 36338
19/01/2018	jlgdap1	TFS 36658 STWR Cargo Scanning Enhancements
10 July 2018	NDL	TFS 39186 - A complete new set of rules... the third set......
03 Oct 2018	NDL	4th set...
13 Nov 2019	NDL 5th refinement
*/

vars

	errMsg : String;
	location : CM_LocationsController;
	cgId : String;
	success : Boolean;
	isAdd : Boolean;
	completeTrx : Boolean;
	ok : Integer;
	cgNewTotalWeight : Decimal [16,4];
	errMsg2 : String;
	str1 : String;
	str2 : String;
	isPreAssigned : Boolean;
	isSelectable : Boolean;
	strArray : StringArray;
	isLastPreAssignedTI : Boolean;
	cgsToComplete : CM_TISet;
	nextCargoGroup : CM_CargoGroup;
	isLastSelectableTI : Boolean;
	completeAssignment : CM_CargoGroupAssignment;
	nextAssignment : CM_CargoGroupAssignment;
	msg : String;
	thisAssignment : CM_CargoGroupAssignment;
	cg : CM_CargoGroup;
	
	cargoGroup : CM_CargoGroup;	//02 Oct 2018	NDL	TFS 39186
	allCargoGroupsByIdDict : CM_TIByIdCargoTypeDict;	//02 Oct 2018	NDL	TFS 39186
	ti : CM_TrackedItem;	//02 Oct 2018	NDL	TFS 39186
	isLastAssignableTi : Boolean;
	
	locationChanged : Boolean;
	newLocation : CM_LocationsController;
	tmpFoundHeight : Integer;
	
begin

	create allCargoGroupsByIdDict transient;
	cargoGroup := self.cmbNotifyCGroup.listObject.CM_CargoGroup;
	thisAssignment := self.myCargoGroupAssignment;
	
	location := self.txtLocation.userObject.CM_LocationsController;
	if location = null then
		self.findLocationToMoveTo( location );
		if location = null then
			errMsg := app.getErrorString(Input_required_field_locn);
			return success;
		endif;
	endif;
	
	if self.myAssignCargoItem = null then
		errMsg := app.getErrorString(Please_select_cargo_itemPOP);
		return success;
	endif;
	
	if cargoGroup &lt;&gt; null and self.myCargoGroup &lt;&gt; null then	//22 Oct 2015	NDL	Par 36338
		cgId := cargoGroup.id;
		//10 July 2018	NDL	TFS 39186
		isPreAssigned := cargoGroup.isPreAssigned;
		isSelectable := cargoGroup.isSelectable;
		
		create strArray transient;
		if isPreAssigned then
			if cargoGroup.getPreAssignedToScan( strArray ) = 1
			and self.myAssignCargoItem.id = strArray.first
			then
				isLastPreAssignedTI := true;
			endif;
			
		elseif isSelectable then
			if thisAssignment.getNotYetScanned( strArray, false ) = 1
			and self.myAssignCargoItem.id = strArray.first
			then
				isLastSelectableTI := true;
			endif;
			
		endif;
		
		strArray.clear();
		if thisAssignment.getNotYetScanned( strArray, true ) = 1 then
			isLastAssignableTi := true;
		endif;
		
	else
		errMsg := app.getErrorString(Cargo_group_required);
		return success;
		
	endif;
	
	if isLastAssignableTi then
		// this is the last ti, we must be all complete
		completeAssignment := thisAssignment;
	endif;
	
	
	create cgsToComplete transient;
	
	//10 July 2018	NDL	TFS 39186 - A complete new set of rules... the third set......
	//03 Oct 2018 NDL TFS 39186 - And some more.... Make that 4th.
	
	if isPreAssigned then
		if isLastPreAssignedTI then
			//Preassigned and this is the last preassigned one from this cargo group
			cgsToComplete.add( self.myCargoGroup );
			str1 := app.getErrorString2( Last_cargo_item, self.myAssignCargoItem.id, self.myCargoGroup.id );
			app.msgBox(str1, app.getErrorString(Complete), MsgBox_OK_Only); // warn and continue.
		endif;
		
	elseif isSelectable then
		if isLastSelectableTI then
			//Last available item on the assignment, complete the group
			cgsToComplete.addNoDuplicates( self.myCargoGroup, false );
			str1 := app.getErrorString3( Last_avail_item_been_scann_com, self.myCargoGroupAssignment.id, self.myCargoGroup.id, self.myCargoGroupAssignment.id );
			app.msgBox(str1, app.getErrorString(Complete), MsgBox_OK_Only); //warn and continue
			
		else
			cgNewTotalWeight := self.myCargoGroup.totalWeight + self.myAssignCargoItem.totalWeight;
			if cgNewTotalWeight &gt; self.myCargoGroup.maxWeight and self.myCargoGroup.maxWeight &lt;&gt; null then
				//current cargo group would exceed max weight, auto complete it and auto select the next available in order
				nextCargoGroup := self.myCargoGroupAssignment.getNextCargoGroup( self.myCargoGroup, self.myAssignCargoItem );
				
				if nextCargoGroup = null then
					str1 := app.getErrorString1(Weigh_would_excee_cargo_group_, self.myCargoGroup.id );
					app.msgBox(str1, app.getErrorString(Complete), MsgBox_OK_Only); // warn and continue
					while true do
						app.myTrxUA.trxCargoGroupComplete( self.myCargoGroup, app.myPassport );
						
						if app.myPassport.trxCompletedOK then
							app.myPassport.clearErrorsWarnings;
							success := true;
							break;
						else
							ok := app.showErrorWarningDialog(app.getErrorString(Complete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
							if app.myPassport.noErrors and ok = IDOK then
								app.myPassport.warningsAcknowledged	:= true;
								continue;
							endif;
							break;	
						endif;	
					endwhile;
					
					self.setMyCargoGroup( null );
					return success;
					
				elseif nextCargoGroup &lt;&gt; null then
					//12 Nov 2019	NDL	TFS 47298 -  5th refinement of the rules - pre populate with next planned location
					newLocation := nextCargoGroup.getLastOnsiteLocation;
					if newLocation &lt;&gt; null then
						// OK we are changing Cargo Groups AND going to use the pre-planned location for the new CG one and carry on as usual;
						locationChanged := location &lt;&gt; newLocation;
						location := newLocation;
						self.txtLocation.text := location.getFullId;
						self.txtLocation.userObject := location;
						
						cgsToComplete.add( self.myCargoGroup );
						if locationChanged then
							str1 := app.getErrorString4( Excee_max_weigh_chg_Loc, self.myCargoGroup.id, self.myAssignCargoItem.id, nextCargoGroup.id, newLocation.getFullId );
						else
							str1 := app.getErrorString3( Have_excee_maxim_weigh_been_co, self.myCargoGroup.id, self.myAssignCargoItem.id, nextCargoGroup.id );
						endif;
						self.setMyCargoGroup( nextCargoGroup );
						app.msgBox(str1, app.getErrorString(Complete), MsgBox_OK_Only); // warn and continue
					
					elseif newLocation = null then
						//Warn that they need to enter a location, complete the old CG and re-present the form ready to enter
						// re-populating the selected cargo item and the new cargo group so they can enter the new location.
						
						while true do
							app.myTrxUA.trxCargoGroupComplete( self.myCargoGroup, app.myPassport );
							
							if app.myPassport.trxCompletedOK then
								app.myPassport.clearErrorsWarnings;
								success := true;
								break;
							else
								ok := app.showErrorWarningDialog(app.getErrorString(Complete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
								if app.myPassport.noErrors and ok = IDOK then
									app.myPassport.warningsAcknowledged	:= true;
									continue;
								endif;
								break;	
							endif;	
						endwhile;
						
						if success then
							str1 := app.getErrorString3( Excee_max_weigh_needs_Loc, self.myCargoGroup.id, self.myAssignCargoItem.id, nextCargoGroup.id );
							app.msgBox(str1, app.getErrorString(Complete), MsgBox_OK_Only); // warn and continue
							self.setMyCargoGroup( nextCargoGroup );
							self.txtCGAssign_lostFocus( self.txtCGAssign );
							self.txtCargoId.text := self.myAssignCargoItem.id;
							self.txtCargoId_lostFocus( self.txtCargoId );
							location := null;
							self.txtLocation.text := null;
							self.txtLocation.userObject := null;
							self.txtLocation_lostFocus( self.txtLocation );
						endif;
						
						self.setWeightAndCount();
						
						if self.myCargoGroupAssignment &lt;&gt; null then
							self.lblProgress.caption := self.myCargoGroupAssignment.getProgressCount;
						else
							self.lblProgress.caption := null;
						endif;
						
						return false;  //i.e we don't want to rebuild the form beyond what we have already done.
						
					endif;
				endif;
				
			endif;
		
		endif;
		
	endif;
		
	
	while true do
	
		app.myTrxUA.trxAddToCargoGroup( self.myCargoGroup, self.myAssignCargoItem, location, cgsToComplete, completeAssignment, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings;
			success := true;
			break;
			
		elseif app.myPassport.hasErrors then
			app.showErrorWarningDialog(app.getErrorString(Complete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			return success;
		
		elseif app.myPassport.noErrors then
			ok := app.showErrorWarningDialog(app.getErrorString(Complete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			app.myPassport.warningsAcknowledged	:=	true;
		
			if not ok = IDOK then
				break;
			endif;
			continue;
			
		endif;
		
		break;
	
	endwhile;
	
	if success then	//21 Sep 2015	NDL	Par 36338
		if completeAssignment &lt;&gt; null then
			//30 Jul 2018	NDL	TFS 39186
			nextAssignment := completeAssignment.getNextAvailAssignment();
			if nextAssignment = null then
				//msg := "The last available item for '%1' has been scanned completing the last Cargo Group and Assignment.  No further Assignments found to process.";
				msg := app.getErrorString1(Last_avail_item_been_com_a, completeAssignment.id);
				self.txtCGAssign.text := null;
			else
				//msg := "The last available item for '%1' has been scanned completing the last Cargo Group and Assignment.  Next Assignment Selected.";
				msg := app.getErrorString1(Last_avail_item_been_com_b, completeAssignment.id);
				self.txtCGAssign.text := nextAssignment.id;
			endif;
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
			self.setMyCargoGroupAssignmentObj( nextAssignment );
		else
			self.populateCmbNotifiedCargoGroups( null, self.myCargoGroup );
		endif;
	endif;
	
	self.txtCGAssign_lostFocus( self.txtCGAssign );
	self.txtCargoId_lostFocus( self.txtCargoId );
	self.txtLocation_lostFocus( self.txtLocation );
	
	self.setWeightAndCount();
	
	if self.myCargoGroupAssignment &lt;&gt; null then
		self.lblProgress.caption := self.myCargoGroupAssignment.getProgressCount;
	else
		self.lblProgress.caption := null;
	endif;
	
	return success;

epilog

	if errMsg &lt;&gt; null then
		self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
	endif;
	delete strArray;
	delete allCargoGroupsByIdDict;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findCargoGroupAssign" id="99346dd8-7977-4f79-b62c-d2eba804e83f">
        <source>findCargoGroupAssign( cgAssign : CM_CargoGroupAssignment output): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	dataString : String;
	errMess : String;
	
begin

	dataString := self.txtCGAssign.text.trimBlanks;
	
	if dataString = null then
		errMess := app.getErrorString1( Gate_Error14, "Cargo Group Assignment" );
	else
	
		if self.txtCGAssign.text = self.lblCGAssign.caption.toUpper then
			return false;
		endif;
		
		cgAssign:= self.myTerminal.findCargoGroupAssignment( dataString );
		
		if cgAssign = null then
			errMess := "Cargo Group Assignment for '" &amp; dataString &amp; "' not found";
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif; 
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="cgAssign" type="CM_CargoGroupAssignment" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="86d729b7-5859-442b-8c77-afa84ec8657a">
        <updating/>
        <source>findLocationToMoveTo(tmpFoundLC: CM_LocationsController output): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	dataString : String;
	tmpFoundHeight : Integer;
	errMess : String;

begin

	dataString := self.txtLocation.text.trimBlanks;
	
	if dataString = null then
		errMess := app.getErrorString( No_Location_entered );
	else
	
		if self.txtLocation.text = self.lblLocation.caption.toUpper then
			return false;
		endif;
		
		self.myTerminal.findLocationFromString(dataString, true, tmpFoundLC, tmpFoundHeight);
		
		if tmpFoundLC = null then
			errMess := app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		if not self.locnWarningIssued then
			self.locnWarningIssued := true;
			self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		endif;
		return false;
	endif; 
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
