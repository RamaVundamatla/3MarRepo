    <JadeMethod name="useEditTriggers" id="bb984ca8-3f07-43e7-9232-f4feef5048c4">
        <source>useEditTriggers() : Boolean;
/*

Date		Who		Reason
20 July 2016	cnwer1	Initial creation TFS 2395

*/

vars
	cc :  ClassColl;
begin
	if isEventType then
		return false;
	endif;
	
	create cc transient;
	self.availableTransactions(cc);
	if cc.includes(CM_Edit) then
		return true;
	endif;
	
	return false;
epilog
	delete cc;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
