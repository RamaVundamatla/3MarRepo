        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="mode" id="5b44ca11-4077-4b3b-b567-15ce26eabdcf">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
