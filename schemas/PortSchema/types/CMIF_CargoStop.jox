    <JadeMethod name="setForCargoStopUpdate" id="2b9ae901-54a0-4b64-8fb8-36283fd4d0ad">
        <updating/>
        <source>setForCargoStopUpdate(_id : Integer; _isSet : Boolean; _requiredInfo : String) updating;
/*

Date		Who		Reason
17 June 2016	cnwer1	Initial creation TFS

*/

vars

begin
	self.id:=_id;
	self.isSet:=_isSet;
	self.requiredInfo :=_requiredInfo;
epilog

end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_isSet" type="Boolean"/>
        <Parameter name="_requiredInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCargoAndStop" id="d0bb7041-b870-41d5-9d47-f009e8654ed8">
        <updating/>
        <source>setFromCargoAndStop(	_cargo : CM_TrackedItem;
						_stop : CM_StopsTable) updating;
/*

Date		Who		Reason
15 June 2016	cnwer1	Initial creation TFS 1013

*/

vars

begin
	self.myTrackedItem:=_cargo;
	self.heading:=_stop.heading;
	self.id:= _stop.id;
	self.requiredInfoDescription:=app.myRoot.getTranslatedRequiredInfoType(_stop.requiresInfoType);
	self.canClear:=_stop.userCanModify (_cargo.myTerminal);
	self.isSet := _cargo.isStopSet(_stop.id);
	self.hasRequiredInfo:=_stop.requiresInfo and not self.isSet and _cargo.hasStopInfo(_stop.requiresInfoType);
	
epilog

end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_stop" type="CM_StopsTable"/>
    </JadeMethod>
</Class>
