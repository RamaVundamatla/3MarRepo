    <JadeMethod name="btnClose_click" id="069865ac-51a9-461f-98d9-88b455eaeb6a">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if self.isFormChanged then
		if app.msgBox("Unsaved changes exist on this screen." &amp; CrLf &amp; "Do you want to save these changes?", app.getErrorString(Continue), MsgBox_Yes_No ) = MsgBox_Return_Yes then
			if self.fldTerminal.topSheet = self.shtVesselProforma then
				self.doSaveVesselProforma();
			else
				self.doSave();
			endif;
		endif;
	endif;

	self.unloadForm();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
