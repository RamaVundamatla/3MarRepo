epilog

end;</source>
        <Parameter name="_cmifSummaries" type="CMIF_InvoiceExtRefSummaries"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f36059bb-e941-408d-927a-bff3442c7349">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

