	self.enableDisableAttributePens(true);

	self.btnSaveBase.visible		:= false;
	self.btnDelete.visible			:= false;
	self.btnEdit.visible			:= false;	
	
	self.btnPenDischarge.enabled	:= false;
	self.btnPenLoad.enabled			:= false;
	self.btnPenRehandle.enabled		:= false;
	self.btnPenSOB.enabled			:= false;
	self.btnPenEraser.enabled		:= false;
	self.btnMakeActual.enabled		:= false;
	self.btnAutoDischCC.enabled		:= false;
	self.btnImportTasks.enabled		:= false;
	self.btnCustomsEDI.enabled		:= false;

	self.cmbCargoType.visible		:=	false;
	self.cmbCommodity.visible		:=	false;
	self.cmbPortDis.visible			:=	false;
	self.txtWeight.visible			:=	false;		// cnwdad1 30/07/2010 - PAR #24045.
	self.chkIgnoreWeightV.visible 	:=	false;	// cnwdad1 30/07/2010 - PAR #24045.

	self.cmbCrane.visible := false;
	self.cmbJob.visible := false;
	self.txtJobLinkLoad.visible := false;

	self.frmStatusLine.myFrameDisplayMode.clearGraphics;
	self.frmStatusLine.myFrameDisplayMode.enabled := false;
	self.frmStatusLine.myFrameMoveMode.clearGraphics;
	self.frmStatusLine.myFrameMoveMode.enabled := false;

	self.doResize();
