    <JadeMethod name="doShowError" id="5432f399-240c-455b-81c4-816ca2b0ae25">
        <updating/>
        <source>doShowError():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Generic method to display an error message for a database transaction.
//
// Parameters:	None
//
// Returns:		A boolean flag to indicate whether an error message was found to show.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	errorMessage	:=	self.aError;

	if errorMessage &lt;&gt; null then
		app.msgBox(errorMessage, $CNEC_ERROR, MsgBox_Stop_Icon + MsgBox_OK_Only);
	endif;
epilog
	self.aError	:=	null;
	
	return (errorMessage = null);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="3ac4c782-a970-4425-8710-1650afc7ce75">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		27 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	create self.aMyTA transient;
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="resynchObjAndSetEdition" id="a5ebfe86-d4b5-4c9e-80d8-88b6b9ab9da4">
        <updating/>
        <source>resynchObjAndSetEdition(pTheObject:Object) updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2000 by cnwdad2
//
// Purpose:		Resynchronizes the target object and stores its edition
//
// Parameters:	theObject - The object for which to resynch and store the edition
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
/*
	Use of "resynchObject" is preferable to "resynch" as it uses an object that
	is already	resident in cache (self) to resynchronize another object.  This
	is preferable to sending resynch to the object to be resynchronized, as if
	it is not in cache, it will have to be fetched from the server to dispatch
	the resynch method, whereupon it will be marked as obsolete.  If the object
	passed to resynchObject is not in cache, it does nothing.
*/
begin
	if pTheObject &lt;&gt; null then
		self.aObjectEdition	:=	pTheObject.edition();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setErrorMessage" id="085f48a8-5b34-4f35-a961-1d7d022a9a96">
        <updating/>
        <source>setErrorMessage(pErrorMessage:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Set's the "aErrorMessage" property inherited by all subclass forms.
//				Note that this method shoul donly be used for message that are
//				raised with a form, not for errors returned by transactions.
//
// Parameters:	pErrorMessage (String) - The error message.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aError &lt;&gt; pErrorMessage then
		self.aError	:=	pErrorMessage;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="unload" id="75c97b92-16e1-423a-ba9b-58b68a6aeabe">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
