begin
	return "Do not use " &amp; self.class().name;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcReportPVDestructor" id="dee40bb1-e0f6-4bda-b859-3cef34860689">
        <updating/>
        <source>cnEcReportPVDestructor() updating;
// --------------------------------------------------------------------------------
// Created:		22 September 2004 by cnwdad1
//
// Purpose:		This method is called against a BaseSchema Report Parameter object
//				whenever the Report Parameter Value object is deleted.  To perform
//				any additional operations against the value object, reimplement
//				this method on the class of the parameter value object.
//
