<CollClass name="CM_HazardByCodeDict">
    <JadeMethod name="getDescription" id="fef54071-7386-4c69-9123-d890f2884cbe">
        <source>getDescription() : String;

vars
	h:	CM_Hazard;
	str:	String;
begin
	foreach h in self do
		str := str &amp; h.description &amp; ",";
	endforeach;
	
	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
