    <JadeMethod name="isChassis" id="9ee1e031-2e06-436d-92ad-2ec7e76db801">
        <source>isChassis() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


 cnwjk3 CCMS1035 04/10/09
 Code added to move cargo to chassis when chassis is moved


*/

vars
	ti      : CM_TrackedItem;
