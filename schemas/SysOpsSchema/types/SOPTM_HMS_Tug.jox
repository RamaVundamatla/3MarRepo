    <JadeMethod name="doSave" id="424f0e2a-622b-44e1-8022-ef78e0588e4d">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyTug		:	HMS_Tug;
	theForm		:	SOP_HMS_TableMaintForm;
	theHarbour: HMS_Harbour;
begin
//	return inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_Tug transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
	pxyTug := theForm.myProxyObject.HMS_Tug;
	theForm.tblInput1.setObjectFromTable(pxyTug, 'setObjectFromTableSpecial', false);
	theHarbour := theForm.cmbHarbour.listObject.HMS_Harbour;
	pxyTug.setProxy(app.myRoot);
	self.doSaveResourcesTbl(pxyTug);
	
	
	//Are we adding or updating
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyTug, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyTug, app.myPassport );
	else
		app.raiseUnexpectedProgramError(class.name,
										method.name, 
										'  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveResourcesTbl" id="e78a84c7-f1ba-435a-a03c-7153074a3bf3">
        <source>doSaveResourcesTbl(_pxyTug : HMS_Tug);
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	
	theForm 	: SOP_TableMaintForm;
	idx			: Integer;
	tmpDataTable	: CM_DataTable;
	obj			: Object;
	harbour	: HMS_Harbour;
	prxyResourceForTug	: HMS_ResourceForTug;
	arrResource,
	depResource,
	shiftResource :	HMS_Resource;
begin

	theForm := self.myForm; 

	tmpDataTable := self.myForm.tblData1;
	foreach idx in 2 to tmpDataTable.rows do
		harbour 			:= tmpDataTable.accessRow(idx).itemObject.HMS_Harbour;
		arrResource 		:= tmpDataTable.accessCell(idx, 2).itemObject.HMS_Resource;
		depResource 		:= tmpDataTable.accessCell(idx, 3).itemObject.HMS_Resource;
		shiftResource 		:= tmpDataTable.accessCell(idx, 4).itemObject.HMS_Resource;		

		prxyResourceForTug := _pxyTug.allResourcesForTug[harbour,_pxyTug];
		
		if prxyResourceForTug = null then
				create prxyResourceForTug transient;
		endif;
		prxyResourceForTug.setProxy(_pxyTug,harbour,arrResource,depResource,shiftResource);

	endforeach;

end;</source>
        <Parameter name="_pxyTug" type="HMS_Tug"/>
    </JadeMethod>
