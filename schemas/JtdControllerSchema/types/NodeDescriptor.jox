    <JadeMethod name="getAvailableMemoryMegabytes" id="ada07e44-4228-44cb-872e-90fbbe100ce5">
        <source>getAvailableMemoryMegabytes() : Real;

begin
	if self.myMachineDescriptor = null then
		return 0;
	endif;
	return self.myMachineDescriptor.availableMemory.asMegabytes;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCommandTarget" id="42dab8ed-9207-4348-a22e-e395bfcd9914">
        <source>getCommandTarget() : Object;

begin
	return self.myNode;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getTableString" id="20bcdd6c-c1ff-42bd-ac9a-7df138011251">
        <source>getTableString() : String;

vars
	ns, ms : String;
	
begin
	if self.isDatabaseServer then
		ns := " (Server) [";
	elseif self.isAppServer then
		ns := " (App Server) [";
	else
		ns := " (Node) [";
	endif;

	if self.myMachineDescriptor &lt;&gt; null then
		ms := self.myMachineDescriptor.getAvailableMemoryString;
	endif;
	
	return self.nodeName &amp;
		   ns &amp;
		   self.allProcessDescriptors.size.String &amp;
		   ']' &amp;
		   Tab &amp;
		   self.getTableStringFromSummary &amp;
		   Tab &amp;
		   ms;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isRunning" id="4ae0c707-887b-478e-841c-b2f20b68cdfc">
        <source>isRunning() : Boolean;

begin
	return self.allRunningProcessDescsByName.size &gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsAppServerFromNode" id="423e7a6b-3647-4404-adba-0589114a8cae">
        <updating/>
        <source>setIsAppServerFromNode(_node : Node) updating, protected;

begin
	if _node = null then
		self.isAppServer := false;
		return;
	endif;

	self.isAppServer := _node.isApplicationServer;
end;</source>
        <access>protected</access>
        <Parameter name="_node" type="Node"/>
    </JadeMethod>
    <JadeMethod name="setIsDatabaseServerFromNode" id="77545bbd-70d6-4fa3-a8ee-5bd01002bf83">
        <updating/>
        <source>setIsDatabaseServerFromNode(_node : Node) updating, protected;

begin
	if _node = null then
		self.isDatabaseServer := false;
		return;
	endif;

	self.isDatabaseServer := _node.isServerNode;
end;</source>
        <access>protected</access>
        <Parameter name="_node" type="Node"/>
    </JadeMethod>
    <JadeMethod name="setNameFromNode" id="9d350400-c47f-4af8-a83e-ad5df5f9d70b">
        <updating/>
        <source>setNameFromNode(_node : Node) updating, protected;

begin
	if _node = null then
		self.nodeName := "*** Null Node ***";
		return;
	endif;

	self.nodeName := _node.name;
end;</source>
        <access>protected</access>
        <Parameter name="_node" type="Node"/>
    </JadeMethod>
    <JadeMethod name="start" id="4da6ad96-d2d0-4a59-8a7f-1fb9a8689c47">
        <updating/>
        <source>start() updating;

vars
	pd : ProcessDescriptor;
	
begin
	self.startClock;

	foreach pd in self.allProcessDescriptors do
		pd.start;
	endforeach;
	
	if self.mySessionDescriptor &lt;&gt; null then
		self.mySessionDescriptor.startClock;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="stop" id="9789352f-362f-4084-85a3-50facf587d36">
        <updating/>
        <source>stop() updating;

vars
	pd : ProcessDescriptor;
	sd : SessionDescriptor;
	
begin
	foreach pd in self.allProcessDescriptors do
		pd.stop;
	endforeach;
	
	self.stopClock;

	sd := self.mySessionDescriptor;
		
	if sd &lt;&gt; null and (not sd.isRunning) then
		sd.stopClock;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateForCreate" id="2ba43ee2-32ca-4896-a42d-84e09950bacf">
        <updating/>
        <source>updateForCreate(_node : Node; _machine : MachineDescriptor;
	_session : SessionDescriptor) updating;

begin
	self.myNode := _node;
	
	self.updateNodeDetails;
	
	self.mySessionDescriptor := _session;
	
	self.myMachineDescriptor := _machine;
end;</source>
        <Parameter name="_node" type="Node"/>
        <Parameter name="_machine" type="MachineDescriptor"/>
        <Parameter name="_session" type="SessionDescriptor"/>
    </JadeMethod>
    <JadeMethod name="updateNodeDetails" id="556f3497-72f7-4dad-ac66-299e63c4d345">
        <updating/>
        <source>updateNodeDetails() updating, protected;

vars
	errNo : Integer;
	errTxt : String;
	
begin
	errNo := 0;
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	self.setNameFromNode(self.myNode);
	if errNo &lt;&gt; 0 then
		self.nodeName := "*** Unknown ***";
		errNo := 0;
	endif;
	
	self.setIsDatabaseServerFromNode(self.myNode);
	if errNo &lt;&gt; 0 then
		self.isDatabaseServer := false;
		errNo := 0;
	endif;

	self.setIsAppServerFromNode(self.myNode);
	if errNo &lt;&gt; 0 then
		self.isAppServer := false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
