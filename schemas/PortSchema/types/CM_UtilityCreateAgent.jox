    </JadeMethod>
    <JadeMethod name="utlCreateBay" id="ecdf56d3-22de-4dd1-b0b0-efebad93d584">
        <source>utlCreateBay(_proxyBay:CM_Bay; _newBay:CM_Bay output; _realVesselVoyage : CM_Object; 
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1 		MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if _realVesselVoyage.isKindOf(CM_CellularVesselStructure) then
		app.myValCA.valBay(_proxyBay,_realVesselVoyage.CM_CellularVesselStructure);
	endif;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if CM_CellularVesselStructure.hasInstance(_realVesselVoyage) then
		create _newBay as CM_BayDefn persistent;
	else
		create _newBay as CM_BayVoyage persistent;
	endif;	
	_newBay.setForCreate(_proxyBay, _realVesselVoyage, _passport);
	
	/*
	31 Mar 2025 navma1 MTN-34387 MTN - Removing Unnecessary Audits
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newBay);
	endif;
	*/

end;</source>
        <Parameter name="_proxyBay" type="CM_Bay"/>
        <Parameter name="_newBay" type="CM_Bay" usage="output"/>
        <Parameter name="_realVesselVoyage" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBayItemLayout" id="c1dbd1a2-e588-48a3-9523-b73e1e2a860e">
        <source>utlCreateBayItemLayout(_proxyBayLayout : CM_BayItemLayout;
						_newBayLayout  : CM_BayItemLayout output; 
						_realBayItem   : CM_BayItem; 
						_passport      : CM_Passport input);
/*

Date		Who		Reason
19 Aug 2013	cnwer1	Initial creation PAR
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_proxyBayLayout, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	create _newBayLayout  persistent;

	_newBayLayout.setForCreate(_proxyBayLayout);
	_newBayLayout.setMyBayItem(_realBayItem);
	
	/*
	31.03.2025 navma1 #MTN-34387
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newBayLayout);
	endif;
	*/
epilog

end;</source>
        <Parameter name="_proxyBayLayout" type="CM_BayItemLayout"/>
        <Parameter name="_newBayLayout" type="CM_BayItemLayout" usage="output"/>
        <Parameter name="_realBayItem" type="CM_BayItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBerth" id="02a1ae0e-0f73-42d0-96ce-eef425e42e6f">
        <updating/>
        <source>utlCreateBerth(_pxyBerth : HMS_Berth input; _realBerth : HMS_Berth output; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
//-----------------------------------------
vars
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	app.myValCA.valBerth(_pxyBerth, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _realBerth persistent;
	_realBerth.setForCreate(_pxyBerth, _passport);
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.noErrors then
		if _passport.isOpsViewEnabled(null) then
			_realBerth.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
											   BGP_OpsViewWSRequest.OPS_TYPE_BERTH,
											   _realBerth);
		endif;
	endif;
	//21.09.2020 cnwma1 TFS #49906

end;</source>
        <Parameter name="_pxyBerth" type="HMS_Berth" usage="input"/>
        <Parameter name="_realBerth" type="HMS_Berth" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBestPickPriority" id="45ce1af7-f946-421a-8660-2a6971cd5702">
        <source>utlCreateBestPickPriority(_pxyBestPickCriteria : CM_BestPickPriority input;
							_allTransientCriteriaObj : CMIF_Array;
							_realBestPickCriteria : CM_BestPickPriority output; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation

*/

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	app.myValCA.valBestPickPriority(_pxyBestPickCriteria, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _realBestPickCriteria persistent;
	_realBestPickCriteria.setForCreate(_pxyBestPickCriteria, _passport);
	
	if _passport.noErrors() and _realBestPickCriteria &lt;&gt; null then
		_realBestPickCriteria.persistCriteria(_allTransientCriteriaObj, _passport);
	endif;
	
	if _passport.noErrors and _realBestPickCriteria &lt;&gt; null then	// par 22762 - could be null if there were warnings
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_realBestPickCriteria);
	endif;
epilog

end;</source>
        <Parameter name="_pxyBestPickCriteria" type="CM_BestPickPriority" usage="input"/>
