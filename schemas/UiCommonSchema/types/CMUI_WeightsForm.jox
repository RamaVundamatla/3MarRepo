    <JadeMethod name="allowManualScaleEntry" id="684eb305-985c-47b9-8fc2-dc24ebc1afb0">
        <source>allowManualScaleEntry(_enable: Boolean; _reason: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

begin

	self.tblScaleWeight.enabled := _enable;
	if _enable then
		self.tblScaleWeight.column := 1;
		self.tblScaleWeight.row := 1;
		
		//_if enabling, we have had an exception during the 'weigh' from the weigh bridge
		executeWhen JMTDevelopmentEnvironment;
		if self.myWeighBridge &lt;&gt; null and self.myWeighBridge.isTwoReadings then
			if self.myTrackedItem = null or not self.myTrackedItem.isOnTruck then
				self.tblScaleWeight.setValue( 15900 );
			else
				self.tblScaleWeight.setValue( 22400 );
			endif;	
		else
			self.tblScaleWeight.setValue( 22400 );
		endif;
		endExecuteWhen;
	
	else
		self.tblScaleWeight.setValueDefault( '0' );
		
	endif;
	
	self.txtReason.text := _reason;
	self.txtReason.visible := _enable;
	self.lblReason.visible := _enable;

epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="btnUpdCargo_click" id="41fb9a94-14a3-43d3-b338-49d4b9ff84c4">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdCargo_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/03/2014	cnwndl1	Initial creation	Par 33268
08/08/2016	cnwdap1	PEN TFS #2494 - default Weight Certified By and Authorised Person
01/08/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/

vars

	totalWeightKgs : Decimal [16,4];
	weightType : CM_MeasurementType;
	theReturn : Integer;
	pxyWeighing :CM_VehicleVisitWeighing;
	weightCert, authBy : String;					// TFS #2494
	weighAuth : CM_WeighAuthority;				// TFS 4492
	authTerm : CM_WeighAuthTerminal;			// TFS 4492
	rtsContainer : CM_Container;	//11 May 2020	NDL	TFS	49296
	int: Integer;
	wasAdjusted : Boolean;	//03 Feb 2021	NDL	TFS 50251

begin

	totalWeightKgs := self.tblCargoTotalW.getConvertedValue;
	
	//11 May 2020	NDL	TFS	49296
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isContainer and self.myTrackedItem.readyToShip then
		if self.myWeighBridge &lt;&gt; null and self.myWeighBridge.canUpdateRTS then
			rtsContainer := self.myTrackedItem.CM_Container;
		endif;
	endif;
	
	if self.chkCertified.value or rtsContainer &lt;&gt; null then															// TFS #2494
		authTerm := self.myTerminal.getDefaultWeighAuthority();						// TFS 4492
		if authTerm &lt;&gt; null then													// TFS 4492
			weightCert := authTerm.myWeighAuthority.certifiedName;					// TFS 4492
			authBy := authTerm.myWeighAuthority.authorisedName;						// TFS 4492
		else																		// TFS 4492
			weightCert := self.myTerminal.getConfig(DefaultWeightCertifiedBy).String;		// TFS #2494
			authBy := self.myTerminal.getConfig(DefaultAuthPersonWeight).String;			// TFS #2494
		endif;																		// TFS 4492
	endif;																					// TFS #2494
	
	if self.myParentForm.isKindOf( CMUI_ReceiveCargoForm ) then
		if self.myTrackedItem &lt;&gt; null then
			weightType := self.myTrackedItem.myCargoType.getDefaultMeasurementForType(Type_Weight);
		elseif self.myCargoType &lt;&gt; null then
			weightType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
		elseif self.myProduct &lt;&gt; null then
			weightType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
		endif;
		self.myParentForm.CMUI_ReceiveCargoForm.tblTotalWeight.setValues(app.convertMeasurementForDisplay(weightType.shortName, totalWeightKgs) &amp; Space &amp; weightType.shortName);
		//epr par 36584 16/7/15
		self.myParentForm.CMUI_ReceiveCargoForm.tblTotalWeight_hasLostFocus( self.myParentForm.CMUI_ReceiveCargoForm.tblTotalWeight );
		self.myParentForm.CMUI_ReceiveCargoForm.setIsWeightCertified(self.chkCertified.value);
		self.myParentForm.CMUI_ReceiveCargoForm.setWeightByAuthPerson(weightCert, authBy);	// TFS #2494
		
		self.myParentForm.CMUI_ReceiveCargoForm.showHideWeighButton();
		
		if self.myVehicleVisitRecord &lt;&gt; null then
	
			create pxyWeighing transient;
			self.setVVRWeighingProxy( pxyWeighing );
			
			while true do
				app.myTrxUA.trxAddVVRWeighing(self.myVehicleVisitRecord, pxyWeighing, rtsContainer, weightCert, authBy, app.myPassport);
	
				if app.myPassport.trxCompletedOK then
					if rtsContainer &lt;&gt; null then	//13 May 2020	NDL	TFS 49296
						self.myParentForm.CMUI_ReceiveCargoForm.incrementPrenoteEdition();
					endif;
					self.clearErrorWarnings();
					break;
				else
					theReturn := app.showErrorWarningDialog(app.getErrorString(Weigh_vehicle), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   theReturn = IDOK then
						app.myPassport.warningsAcknowledged     := true;
						continue;
					endif;
					break;
				endif;
				break;
			endwhile;
		endif;
		self.updateGateScanRecord();
		self.modalResult := theReturn;
		self.unloadForm;
		
	elseif self.myParentForm.isKindOf( CMUI_ToDoWeighTask ) then
		if self.myTrackedItem &lt;&gt; null then
			weightType := self.myTrackedItem.myCargoType.getDefaultMeasurementForType(Type_Weight);
		elseif self.myCargoType &lt;&gt; null then
			weightType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
		elseif self.myProduct &lt;&gt; null then
			weightType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
		endif;
		self.myParentForm.CMUI_ToDoWeighTask.txtWeight.setValues(app.convertMeasurementForDisplay(weightType.shortName, totalWeightKgs) &amp; Space &amp; weightType.shortName);
		self.myParentForm.CMUI_ToDoWeighTask.chkCertified.value := self.chkCertified.value;
		//self.myParentForm.CMUI_ToDoWeighTask.txtWeightBy.text := null;	//03 Jun 2016	NDL TFS 2099	// TFS #2494 taken out
		//self.myParentForm.CMUI_ToDoWeighTask.txtAuthor.text := null;	//03 Jun 2016	NDL TFS 2099		// TFS #2494 taken out
		self.doOK;
		return;
		
	elseif self.myTrackedItem &lt;&gt; null then
		if totalWeightKgs &gt; 0 then
		
			//12 May 2020	NDL	TFS 49296
			if rtsContainer &lt;&gt; null then
				while true do
					app.myTrxUA.trxUpdateRTSWeight(	self.myWeighBridge,
													rtsContainer,
													totalWeightKgs,
													weightCert,
													authBy,
													app.myPassport
													);
				
					if app.myPassport.trxCompletedOK then
						self.btnUpdCargo.visible := false;
						break;
						
					else
						int := app.showErrorWarningDialog("Updating Weight on RTS Container", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
						if app.myPassport.noErrors and
						   int = IDOK then
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
						return;
					endif;
					
					break;
				
				endwhile;
			else
				wasAdjusted := totalWeightKgs &lt;&gt; self.tblScaleWeight.getConvertedValue;	//03 Feb 2021	NDL	TFS 50152
				//self.updateCargoTotalWeight( self.myTrackedItem, totalWeightKgs );							// TFS #2494 
				self.updateCargoTotalWeight( self.myTrackedItem, totalWeightKgs, weightCert, authBy, wasAdjusted );			// TFS #2494 
			endif;
			
		endif;
		
	endif;
	
	self.closeIfNoUpdateButtonsVisible();

epilog

	delete pxyWeighing;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdChassis_click" id="4bb5076a-1a76-4e6e-9a45-42f731a66bfd">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdChassis_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	newTareWeightKgs : Decimal [16,4];
	obj : Object;

begin

	newTareWeightKgs := self.tblChassisTareW.getConvertedValue;
	if newTareWeightKgs &gt; 0 then
		if self.myChassis &lt;&gt; null then
			self.updateChassisTareWeight( self.myChassis, newTareWeightKgs );
		else
			obj := self.cmbChassis.listObject;
			if obj &lt;&gt; null and obj.isKindOf( CM_TILCType ) then
				self.updateChassisTypeTareWeight( obj.CM_TILCType, newTareWeightKgs );
			endif;
		endif;
	endif;
	
	self.closeIfNoUpdateButtonsVisible();
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdGenny_click" id="482cb5dc-0062-474d-98e1-820497596a76">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdGenny_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	newWeightKgs : Decimal [16,4];
	obj : Object;

begin

	newWeightKgs := self.tblGennyTareW.getConvertedValue;
	if newWeightKgs &gt; 0 then
		if self.myGenerator &lt;&gt; null then
			self.updateGeneratorTotalWeight( self.myGenerator, newWeightKgs );
		else
			obj := self.cmbGenny.listObject;
			if obj &lt;&gt; null then
				if obj.isKindOf( CM_GeneratorType ) then
					self.updateGeneratorTypeDefWeight( obj.CM_GeneratorType, newWeightKgs );
				elseif obj.isKindOf( CM_ISOType ) then
					self.updateISOTypeTareWeight( obj.CM_ISOType, newWeightKgs );
				endif;
			endif;
		endif;
	endif;
	
	self.closeIfNoUpdateButtonsVisible();
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdMachine_click" id="3adfe11f-21e5-4cb7-8744-175c7b0e47c8">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdMachine_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	newWeightKgs : Decimal [16,4];
	obj : Object;

begin

	newWeightKgs := self.tblMachineTareW.getConvertedValue;
	if newWeightKgs &gt; 0 then
		if self.myMachine &lt;&gt; null then
			self.updateMachineTareWeight( self.myMachine, newWeightKgs );
		endif;
	endif;
	
	self.closeIfNoUpdateButtonsVisible();
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdTruck_click" id="41cfbed2-b0de-4127-98e0-8d4e40765dbf">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdTruck_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	newWeightKgs : Decimal [16,4];
	obj : Object;

begin
	newWeightKgs := self.tblTruckTareW.getConvertedValue;
	if newWeightKgs &gt; 0 then
		if self.myTruck &lt;&gt; null then
			self.updateTruckTareWeight( self.myTruck, newWeightKgs );
		endif;
	endif;
	
	self.closeIfNoUpdateButtonsVisible();
	
epilog

end;</source>
