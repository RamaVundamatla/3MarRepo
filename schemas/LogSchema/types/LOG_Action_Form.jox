    <JadeMethod name="selectdocketLocation" id="64b4fae1-844a-472a-870a-21a4034323a8">
        <updating/>
        <source>selectdocketLocation(_row : Integer) protected, updating;

vars
	row, row2, tblRows 		: Integer;
	count		: Integer;
	docketDef	: CMIF_DocketLogDef;
	tblData		: CM_DataTable;
	str			: String;

begin
	tblData := self.tblSelectData;
	// Select group of logs from  select data table.
	row := (_row - 1).max(1);	
	if row &lt;= self.allDocketLogDef.size then
		self.tblSelectData.accessRow(_row).selected := true;
//		docketDef := self.tblSelectData.accessedRow.itemObject.CMIF_DocketLogDef;
//		if docketDef &lt;&gt; null then
//			self.displaySelectedDocketLocation(docketDef);
//		endif;
		
		/*tblRows := tblData.rows;
		row2 := tblData.fixedRows + 1;
		while row2 &lt;= tblRows do 
			if 	tblData.accessRow(row2).selected = true then 
				docketDef := self.tblSelectData.accessRow(row2).itemObject.CMIF_DocketLogDef;	
				str := str &amp; self.displaySelectedDocketLocation(docketDef) &amp; CrLf;
			endif;
			row2 := row2 + 1;
		endwhile;
		self.txtDetails.text := str;*/
		// 22/09/2008 cnwar2 #17984 - replaced above
		docketDef 			 := self.tblSelectData.accessRow(_row).itemObject.CMIF_DocketLogDef;	
		self.txtDetails.text := self.displaySelectedDocketLocation(docketDef);		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
