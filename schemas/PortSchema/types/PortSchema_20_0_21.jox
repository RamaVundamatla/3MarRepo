    <JadeMethod name="updateBookingRefField" id="0c0749f1-4074-405b-a0a5-c7412565f950">
        <source>updateBookingRefField(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2022	navhl20	ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?

*/

vars
	bookRefField	: CM_BookingRefDiscrepFieldValue;
	desc : String;
	isAvail : Boolean;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog( method.qualifiedName &amp; 'Update Booking Ref Field ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Booking Ref Field ") ;
	endif;
	
	beginTransaction;
	foreach bookRefField in CM_BookingRefDiscrepFieldValue.instances do
		if bookRefField.fieldName = "Controlled Atmosphere and Curtains In" then
			bookRefField.setFieldName("Curtains In");
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Update Booking Ref Field", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Update Booking Ref Field") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
