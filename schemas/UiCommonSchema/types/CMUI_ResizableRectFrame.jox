    <JadeMethod name="paint" id="d40930b3-4a0c-4d31-bd3f-cef6021ed0bd">
        <controlMethod name="Frame::paint"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>paint(frame: Frame input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Jan 2009	cnwjk3	Initial creation
28 Aug 2009 cnwer1 CCMS 1076 the interface now does the paint
*/

vars

begin
	inheritMethod(frame);
	if   self.isInPainter() then
		return;
	endif;
	self.form.IF_CMUI_RectangleHandler.onRectPaint(self);
	
epilog

end;</source>
