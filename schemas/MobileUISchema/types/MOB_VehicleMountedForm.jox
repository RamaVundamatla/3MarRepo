        <updating/>
        <source>hideGFXFrames() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwjk3	Initial creation

*/

vars

begin
	self.myDrawingController.hideSelectedLocationHighlight();
	self.frmDrawing.visible := false;
	
	//04/112010 cnwdz2 26196
	if  self.frmTopHLabels &lt;&gt; null then
		self.frmTopHLabels.visible := false; //22/09/2010 cnwdz2 25642
