    <JadeMethod name="makeAvail" id="1c7623a0-da8c-4442-b05c-1b1ffcfaaed6">
        <source>makeAvail() protected;

vars
	listPointer	: Integer;
	
begin
	listPointer := 1;
	
	while listPointer &lt;= lstUnavailClasses.listCount and lstUnavailClasses.selectedCount &gt; 0 do
		if lstUnavailClasses.itemSelected[listPointer] then
			lstAvailClasses.addItem(lstUnavailClasses.itemText[listPointer]);
			lstUnavailClasses.removeItem(listPointer);
			listPointer := listPointer - 1;
		endif;
		
		listPointer := listPointer + 1;
	endwhile;
	
	btnMakeAvail.enabled := false;
	
	if lstUnavailClasses.listCount &gt; 0 then
		btnUpdate.enabled := true;
	else
		btnUpdate.enabled := false;		
	endif;
	
	self.applyColour();   
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="makeUnavail" id="b30d18c3-fcc6-4292-9f95-894a5f711b75">
        <source>makeUnavail() protected;

vars
	listPointer	: Integer;
	
begin
	listPointer := 1;
	
	while listPointer &lt;= lstAvailClasses.listCount and lstAvailClasses.selectedCount &gt; 0 do
		if lstAvailClasses.itemSelected[listPointer] then
			lstUnavailClasses.addItem(lstAvailClasses.itemText[listPointer]);
			lstAvailClasses.removeItem(listPointer);
			listPointer := listPointer - 1;
		endif;
		
		listPointer := listPointer + 1;
	endwhile;
	
	btnMakeUnavail.enabled := false;
	
	if lstUnavailClasses.listCount &gt; 0 then
		btnUpdate.enabled := true;
	else
		btnUpdate.enabled := false;		
	endif;
	
	self.applyColour();  
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="unload" id="1c99092e-64cc-47f8-96cb-07bf8e44c439">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars
	formObj	: Form;
	
begin
	app.mousePointer	:=	Busy;

	if aRebuildDefaultFormatsRequired then
		formObj := app.getForm(CnEcXMLUtilityForm.name);
		
		if formObj &lt;&gt; null then 
			formObj.CnEcXMLUtilityForm.setRebuildIsRequired(true);
		endif;
	endif;			
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="update" id="11de07c1-18dc-4c99-9de0-ff72d77b1a8a">
        <updating/>
        <source>update()updating, protected;

vars
	listPointer	: Integer;
	classObj	: Class;
	baseRootObj	: CnEcBaseRoot;
	
begin
	listPointer	:=	1;
	baseRootObj	:=	app.myBaseRoot;

	beginTransaction;
		//baseRoot.allXmlExcludedClasses.clear;
		if baseRootObj.getAllXmlExcludedClasses() &lt;&gt; null then
			baseRootObj.getAllXmlExcludedClasses().clear();
		endif;
		
		while listPointer &lt;= lstUnavailClasses.listCount do
			classObj	:=	app.myCnEcXmlSchema.getClass(lstUnavailClasses.itemText[listPointer]);
    		//baseRootObj.allXmlExcludedClasses.add(classObj.name);
    		baseRootObj.getAllXmlExcludedClasses().add(classObj.name);
    		listPointer := listPointer + 1;
		endwhile;
	commitTransaction;
	
	btnMakeAvail.enabled				:= false;
	btnUpdate.enabled					:= false;
	self.aRebuildDefaultFormatsRequired	:= true;
	self.applyColour();
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
