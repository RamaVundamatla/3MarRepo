<CollClass name="CM_TerminalSet" id="a8f1e1c4-155c-4415-83fa-8902845c86c6">
    <memberType name="CM_Terminal"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="getCommaDelimitedList" id="3c393c9a-8123-43c0-840d-7c94ffc081cd">
        <source>getCommaDelimitedList():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2015	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	term : CM_Terminal;
	str : String;

begin

	iter := self.createIterator;
	while iter.next( term ) do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; term.code;
	endwhile;
	
	return str;

epilog

	delete iter;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
