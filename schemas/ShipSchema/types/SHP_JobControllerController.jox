    <JadeMethod name="getNewJobEndTimeForCrane" id="1949ad92-d5f6-4a38-9779-1860a9590dd9">
        <source>getNewJobEndTimeForCrane(	_voyageJob : CM_VoyageJob;
							_crane : CM_Crane;
							_startTime : TimeStamp ) : TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	jobTime : Integer;
	jobEnd : TimeStamp;
begin
	jobTime:=_voyageJob.getEstJobTimeUsingCraneRates(_crane);
	jobEnd:=_startTime.addMinutes(jobTime);
	jobEnd:=_voyageJob.CM_VoyageJob.getEndTsWithDelays(_startTime,jobEnd,_crane,self.myVoyageStats.allVoyageDelays );
	
	return jobEnd;

epilog

end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_startTime" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getRealVoyageJob" id="33986052-02e5-4aa9-9807-afd2d118aed0">
        <source>getRealVoyageJob(_voyageJob : CM_VoyageJob) : CM_VoyageJob;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _voyageJob.isTransient then
		return app.myProxyManager.getRealObject(_voyageJob).CM_VoyageJob;
	else
		return _voyageJob;
	endif;

epilog

end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
