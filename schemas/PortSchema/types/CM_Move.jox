    <JadeMethod name="isCraneMove" id="8367db1d-52c0-44c8-90ad-defd432a7eba">
        <source>isCraneMove() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2012	cnwdw1	Initial creation
*/
vars
	machine: CM_Machine;
begin
	machine := self.getCraneForMove();  // ### TFS 51855 28JAN2022 NAVAB1
	
	return machine &lt;&gt; null;  // ### TFS 51855 28JAN2022 NAVAB1

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFirstMoveInSequence" id="fe323c69-1f04-4fe7-b1c1-c340d341f3b2">
        <source>isFirstMoveInSequence() : Boolean;
/*
Purpose:	OPSVIEW		

Date		Who		Reason
13 January 2022	navab1	TFS 51855
*/

vars
	moves : CM_TITransactionByDateOrdDict;
	ti : CM_TrackedItem;
begin
	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		create moves transient;
		ti.getAllMovesForMove(self, moves);
		if not moves.includes(self) then
			moves.add(self);
		endif;
		
		return moves.indexOf(self) = 1;
	endif;
	

epilog
	delete moves;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLanderLoadMove" id="2bbc295c-b9d6-42cf-8e52-ca0253432957">
        <source>isLanderLoadMove() : Boolean;
/*
Purpose:			

Date		Who		Reason
28 January 2022	navab1	TFS 51855
*/

vars
	sourceLC, targetLC : CM_LocationsController;
	mach : CM_Machine;
begin
	sourceLC := self.getSourceLocationsController();
	targetLC := self.getTargetLocationsController();
	
	// LOAD FROM AN IMV using LANDER APP
	if sourceLC.isMachineController() 
	and targetLC.isSlotController() then
		mach := sourceLC.CM_MachineController.myMachine;
		if mach &lt;&gt; null
		and mach.isIMV() then
			return true;
		endif;
	endif;
	
	// LOAD FROM CTA using LANDER APP
	if sourceLC.isCraneLaneController()  // ### TFS 52925 21FEB2022 NAVAB1
	and targetLC.isSlotController() then  // ### TFS 52925 21FEB2022 NAVAB1
		return true; // ### TFS 52925 21FEB2022 NAVAB1
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
