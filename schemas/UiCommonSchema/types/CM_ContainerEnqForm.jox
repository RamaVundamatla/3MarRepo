    <JadeMethod name="cmbFiltTAType_lostFocus" id="4fca4c1b-cf1b-4f4b-afea-24ca13cd7831">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFiltTAType_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     17 June 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cargoType,
	areaTypeCode 	: Integer;
	areaType 	 	: CM_TerminalAreaType;
	
begin
	self.tblSearch.setValueByControlName(combobox.name, combobox.text);	

	if self.origValueStr &lt;&gt; combobox.text then
		areaTypeCode := TA_TYPE_NULL; 
		if combobox.listObject &lt;&gt; null then		
			areaTypeCode := combobox.listObject.CM_TerminalAreaType.type; 
		endif;

		if areaTypeCode = TA_TYPE_GENERATOR_STORE_AREA then
			cargoType := TI_CargoType_Generator;
		elseif areaTypeCode = TA_TYPE_COU_STORE_AREA then
			cargoType := TI_CargoType_COU;			
		else
			cargoType := TI_CargoType_Null;			
		endif;

		// DVB changed so auto setting of terminal area in click event will work.
	/*	cmbFiltTermArea.gotFocus(cmbFiltTermArea);
		myAssistant.comboBoxTerminalArea(cmbFiltTermArea,areaTypeCode, null);
		cmbFiltTermArea.lostFocus(cmbFiltTermArea);*/
		
		cmbFiltTiType.gotFocus(cmbFiltTiType);
		self.myAssistant.comboBoxCargoBolType(cmbFiltTiType, cargoType, true, true, true, true);		
		cmbFiltTiType.lostFocus(cmbFiltTiType);		
	endif;
	
	
	
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
