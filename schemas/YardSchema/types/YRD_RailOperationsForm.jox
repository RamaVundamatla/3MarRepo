    <JadeMethod name="addToolbarControls" id="71d89e36-214c-4269-b8a6-a244f7c5f45f">
        <source>addToolbarControls() protected;
//--------------------------------------------------
// Created:	10 September 2003 By: cnwgd1
// 29 Aug 2024 navhl20	ChangeRequest 65898: MTN - Add Text Filter to Rail operations screen
// 14 Apr 2025 navnk30	JIRA 34157: MTN | Rail Operations - Handle Notifications
//--------------------------------------------------
vars

	toolbar		: CMUI_Toolbar;
begin

	toolbar := self.frmToolbar;
	
	
	toolbar.addButton(self.btnPrintPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectAreas, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTrainDir, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	


	toolbar.addButton(self.btnDeleteJob, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAddRequest, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnClearRake, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	

	toolbar.addButton(self.btnTrainMaint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTrainEnq, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnWagonEnq, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveIt, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);		//29.08.2024 navhl20 #65898
	self.frmTableFilter.visible := true;											//29.08.2024 navhl20 #65898
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);						//29.08.2024 navhl20 #65898
	
	toolbar.addFrame(self.frmRetroTop, CMUI_Toolbar.Control_Alignment_Left);	//23 Feb 2021	NDL	TFS 50837
	
	self.btnNotifications.visible := true;												//14.04.2025 navnk30 JIRA 34157
	toolbar.addButton(self.btnNotifications, CMUI_Toolbar.Control_Alignment_Left);		//14.04.2025 navnk30 JIRA 34157
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;	
	self.btnEdit.visible := false;
	//self.btnMoveIt.visible := false;
	
	toolbar := self.frmRakeToolbar;
	toolbar.isPositionsCalculated := false;
	toolbar.allLeftControls.purge();
	toolbar.allRightControls.purge();
	
//	toolbar.addButton(self.btnNewWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAddWagon, CMUI_Toolbar.Control_Alignment_Left);//par 23258
	toolbar.addButton(self.btnEditWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCCWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRailAllocRem, CMUI_Toolbar.Control_Alignment_Left); //+ cnwmd1, Par 20211
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnViewJob, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewVoyage, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewCommodity, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewConsignee, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewDischarge, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewDest,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewISOGroup, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewOperator, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewStatus, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewTempRange, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnMoveTopLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveTopRight, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotRight, CMUI_Toolbar.Control_Alignment_Left);			
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnFlipH, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.positionToolbarControls();
	toolbar.zOrder(1);	
	toolbar.visible := self.xmlShowGraphic;
	
	toolbar := self.frmToolbarPrint;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintCancel, CMUI_Toolbar.Control_Alignment_Right);

	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowCargoPositionSwap" id="f3bef9ea-1579-42db-a288-8b349b37bab7">
        <source>allowCargoPositionSwap(_caption : String output):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwndl1	Initial creation	CCMS 1094

*/

vars

	selectedCargo : CM_TIArray;
	dataArray : ObjectArray;
	obj : Object;
	addComma : Boolean;
	firstString : String;
	secondString : String;
	
begin

	create selectedCargo transient;
	create dataArray transient;
	self.mySDF.getAllSelectedTIs( selectedCargo );
	if not self.myAssistant.YRD_Assistant.allowCargoPositionSwap( selectedCargo, self.moveModeForm, dataArray ) then
		return false;
	endif;

	foreach obj in dataArray do
		if CM_TrackedItem.hasInstance(obj) then
			if firstString = null then
				firstString := obj.CM_TrackedItem.id;
			elseif not addComma then
				addComma := true;
				secondString := secondString &amp; obj.CM_TrackedItem.id;
			elseif addComma then
				secondString := secondString &amp; ", " &amp; obj.CM_TrackedItem.id;
			endif;
		endif;
	endforeach;
	_caption := app.getErrorString2(Cargo_swap_with, firstString, secondString); 
	return true;
	
epilog

	delete selectedCargo;
	delete dataArray;
	
end;</source>
        <Parameter name="_caption" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="assignTIToTransport" id="2267475e-dcc3-4a22-a5c7-cff743e20db7">
        <updating/>
        <source>assignTIToTransport(_toLocationsController : CM_LocationsController)updating;
// ---------------------------------------------------------------------------
//Created: February 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/07/2009	consw1		PAR 20070 - Move multiple containers
// 10/07/2009	consw1		PAR 20213 - Unable to plan outward rail while inward cargo still on wagon
// 16/07/2009	consw1		Par 20293 - UE 1090
// 27/08/2009	consw1		PAR 20538 - Unable to select containers following drag/drop from another form
// 20/12/2010	cnwdap1		PAR 26621 - Prevent TAB Tis from being drag-dropped on a wagon
// 05/07/2019	jlgzm1		TFS 42863 MSL Direct Release between Voyages and Rail - BreakBulk
// ---------------------------------------------------------------------------
vars
	tiColl : CM_TIArray;
	tmpTi : CM_TrackedItem;
	result : Integer;
	moveController : CMIF_MoveController;
	tranArea : String;
	wagon : CM_Wagon;
	wagons : CM_WagonArray;
	msg : String;
begin

	if _toLocationsController = null then
		return;
	endif;
	
	if app.myMoveController = null then
		return;
	endif;
	
	if not _toLocationsController.isWagon() then
		app.raiseCMException(VB_MOVE_INVALID, null, null);
		return;	
	endif;

	wagon := _toLocationsController.CM_WagonController.myWagon;

	moveController := app.myMoveController;
	
	tmpTi := moveController.myTrackedItem;
	if tmpTi = null then
		return;
	endif;
	if tmpTi.myTerminal &lt;&gt; self.myTerminal then
		app.raiseCMException2(ERR_TERMINAL_TRANSFER, tmpTi.myTerminal.code, self.myTerminal.code, null, null);
		return;	
	endif;
	// PAR #26621 TBA TIs cannot be drag-dropped to a wagon, they must be assigned using "Assign Release to Wagon" menu item
	if tmpTi.isRRPforRail then
		app.raiseCMException1(Canno_drag_cargo_item_wagon_pl, tmpTi.id, null, tmpTi);
		return;
	endif;
	// PAR #26621 end

	if moveController.allOtherTrackedItems.size = 1 and moveController.allOtherTrackedItems.includes(tmpTi) then
		moveController.allOtherTrackedItems.clear();
	endif;

	if moveController.allOtherTrackedItems.isEmpty() then
		moveController.setMyToPrimaryLocation(_toLocationsController);
	else
		create tiColl transient;
		moveController.allOtherTrackedItems.copy(tiColl);
		moveController.allOtherTrackedItems.clear();
		if not tiColl.includes(tmpTi) then
			tiColl.insert(1,tmpTi);
		endif;
		// CCMS 1067 PAR 19913
		create wagons transient;
		self.getSelectedWagons(wagons, null);
		if wagons.isEmpty() then
			wagons.add(wagon);
		endif;
	endif;
	
	// tfs42863 start
	// If this form has been passed a WLE, we must be a Direct Release
	if moveController.myWorkListEntry &lt;&gt; null then
		moveController.isDirectReleaseMove := true;
	endif;
	
	// if ti is splittable then need to determine how much to move
	if tmpTi.canMergeBreakBulk then
		if not self.myAssistant.showMoveAmountForm(moveController) then //tfs42863
			return;
		endif;
		
		if moveController.isDirectReleaseMove and
		   moveController.myWorkListEntry.isDRLinkedByFM then
			moveController.isReplan := true;
			moveController.setMoveIndex(tmpTi.allPlannedFutureMoves.indexOf(moveController.myWorkListEntry.getDRFutureMove()));
			moveController.setMyOriginatingLocation(tmpTi.myPrimaryPlannedLocation);
		endif;
	// tfs42863 end
	else
		// PAR 20681
		if tmpTi.myPrimaryPlannedLocation &lt;&gt; null 
		and self.moveModeForm = PLANNING_MODE then
			moveController.isReplan := true;
			moveController.setMoveIndex(tmpTi.allPlannedFutureMoves.indexOf(tmpTi.getFMforLC(tmpTi.myPrimaryPlannedLocation, PLANNING_MODE)));
			moveController.setMyOriginatingLocation(tmpTi.myPrimaryPlannedLocation);
		endif;
	endif;
	
	//23 Feb 2021	NDL	TFS 50837
	if not validateRetrospectiveTS(null) then
		return;
	elseif self.chkRetrospect.value and self.retrospectiveDate.date.isValid then
		moveController.setEffectiveTimeStampOverride( self.retrospectiveDate );
	endif;

	while true do
		if tiColl = null then
			app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		else
			app.myTrxUA.trxMoveTrackedItemsNewRailJob(wagons, tiColl, moveController, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			//result := app.showErrorWarningDialog('Assign To Transport', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings); //- cnwmd1, CCMS 1067, Par 19710
			result := app.showErrorWarningDialog(app.getErrorString(Assign_Transport), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings); //+ cnwmd1, CCMS 1067, Par 19710
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			break;
		endif;
		//break;
	endwhile;
	
epilog
	delete tiColl;
	app.isDragging := false;
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;		
	delete wagons;
end;</source>
        <Parameter name="_toLocationsController" type="CM_LocationsController"/>
    </JadeMethod>
