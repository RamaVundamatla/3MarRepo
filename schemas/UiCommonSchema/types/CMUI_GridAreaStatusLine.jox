    <JadeMethod name="createGraphics" id="19b00c70-2b1e-4f4f-a3cb-7ca9f4048c58">
        <source>createGraphics() protected;
/*
------------------------------------------------------------------------
Created:			17 September 2003 by cnwdwq1
Purpose:			
Parameters:			None
Returns:			Nothing

Date		Who		Reason
16 Dec 2008	cnwkpd1	PAR #18664 - remove unnecessary Picture create

*/

vars
	moveMode	: Integer;
//	lPicture 	: Picture;
	aPicture	: Binary;
	root 		: CM_Root;
	lCaption 	: String;
	slf 		: CMUI_StatusLineFrame;
	slg 		: Frame;
	apStr, 
	logStr,
	chgStr 		: String;
	
begin
	root := app.myRoot;
//	create lPicture transient;
	
	//self.displayOtherGraphics();	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
/*	
	slf := self.myFrameOther;
	slf.clearGraphics;
	slf.autoRedraw := true;
	//Draw the 3 graphics, autoplanning, logging and charge
	if app.getMyTerminalConfig(AutoPlanEnabled).Boolean then
		aPicture := root.getConfig(PicAutoPlanOn).Binary;
		apStr := "AutoPlanning On, ";
	else
		aPicture := root.getConfig(PicAutoPlanOff).Binary;
		apStr := "AutoPlanning Off, ";
	endif;
	slf.drawPictureAt(aPicture,1,1);

	if app.verboseLogging then
		aPicture := root.getConfig(PicLogOn).Binary;
		logStr := "Logging On, ";
	else
		aPicture := root.getConfig(PicLogOff).Binary;
		logStr := "Logging Off, ";
	endif;
	slf.drawPictureAt(aPicture,19,1);

	if app.chargeForMove then
		aPicture := root.getConfig(PicChgMoveOn).Binary;
		chgStr := "Charge On.";
	else
		aPicture := root.getConfig(PicChgMoveOff).Binary;
		chgStr := "Charge Off.";
	endif;
	slf.drawPictureAt(aPicture,37,1);
	slf.bubbleHelp := apStr &amp; logStr &amp; chgStr;
*/
	self.myFrameMoveMode.clearGraphics;
	
	moveMode := REAL_MODE ;
	//moveMode := self.myParent.sendMsg("getMoveMode").Integer;
	
	if moveMode = REAL_MODE or moveMode = self.MENU_MOVE_INSTANT_ONLY then
		aPicture := root.getConfig(PicMoveModeI).Binary;
		lCaption := MOVE_MODE_INSTANT_CAPTION;
	elseif moveMode = QUEUE_MODE then
		aPicture := root.getConfig(PicMoveModeQ).Binary;
		lCaption := MOVE_MODE_QUEUED_CAPTION;
	else
		aPicture := root.getConfig(PicMoveModeP).Binary;
		lCaption := MOVE_MODE_PLANNED_CAPTION;
	endif;

	slf := self.myFrameMoveMode;
	slf.clearGraphics();
	slf.drawPictureAt(aPicture,1,1);
	slf.drawTextAt(lCaption,18,1, Black);

	slf := self.myFrameDisplayMode;
	slf.clearGraphics;
	if self.displayMode = DISPLAY_MODE_PLAN then
		aPicture := root.getConfig(PicDisplayModeP).Binary;
		lCaption := DISPLAY_MODE_PLAN_CAPTION;
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		aPicture := root.getConfig(PicDisplayModeQ).Binary;
		lCaption := DISPLAY_MODE_QUEUE_CAPTION;
	else
		aPicture := root.getConfig(PicDisplayModeI).Binary;
		lCaption := DISPLAY_MODE_ACTUAL_CAPTION;
	endif;
	
	slf.drawPictureAt(aPicture,1,1);
	slf.drawTextAt(lCaption,18,1, Black);
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
