    <JadeMethod name="initTblEDITIError" id="37c272f3-73f3-4ad3-81c0-dd6a0d67e8de">
        <source>initTblEDITIError();
// ---------------------------------------------------------------------------
// Created:		01 August 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 07/08/2012	cnwcs5	par 30136
vars
	table	:CM_DataTable;
begin
	table := self.tblEDITIError;
	
	table.clear;
