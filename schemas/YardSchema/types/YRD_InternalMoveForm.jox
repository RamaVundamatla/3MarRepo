/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwrd1	Initial creation

*/

vars

begin
//cnwrd1 par 26395 23.11.2010 --

/*
	self.doBuildComboRTQ();
	// 23098 set best pick visible plus move other code from .click
	if self.cmbSourceArea.listIndex &gt; 0 then
		self.myCurrentSourceTA := self.cmbSourceArea.getObject().CM_TerminalArea;
	endif;

	if myCurrentSourceTA &lt;&gt; null then
		self.txtSourceRestric.setValue(self.myCurrentSourceTA.getTAEnqRestrictionLocString() ) ;
		self.chkBestPick.visible := (self.myCurrentSourceTA.isGridArea());
	else
		self.txtSourceRestric.setValue(null ) ;
	endif;
	*/
epilog

end;</source>
        <Parameter name="frame" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="cmbSourceArea_click" id="1f58ca27-6853-4e19-8351-b9dc5e479093">
        <controlMethod name="Frame::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSourceArea_click(frame: Frame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwrd1	Initial creation

*/

vars
	obj : Object;
	aTA : CM_TerminalArea;
	aGO : CM_GridObject;
begin

	
	if self.cmbSourceArea.listIndex &gt; 0 then//cnwrd1 par 28628 4.11.11 
		obj := self.cmbSourceArea.getObject();
		if obj.isKindOf(CM_TerminalArea) then
			aTA := obj.CM_TerminalArea;
		else
			aGO := obj.CM_GridObject;
			aTA := aGO.getGridArea();
		endif;
		self.myCurrentSourceTA := aTA;
	endif;

	if myCurrentSourceTA &lt;&gt; null then
// cnwdad1 28/06/2006 - PAR #11900.
//		self.tblMain.setValueByName(ETRow_IsoSourceRestrict, self.myCurrentSourceTA.getRestrictionLocationString(" "));
		//self.tblMain.setValueByName(ETRow_IsoSourceRestrict, self.myCurrentSourceTA.getTAEnqRestrictionLocString());
		self.txtSourceRestric.setValue(self.myCurrentSourceTA.getTAEnqRestrictionLocString() ) ;
	else
		//self.tblMain.setValueByName(ETRow_IsoSourceRestrict, null);	
		self.txtSourceRestric.setValue(null ) ;
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
