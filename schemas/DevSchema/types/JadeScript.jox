    <JadeMethod name="storageBGPRun" id="727687dd-ca47-4469-9bd4-df911a4370e8">
        <source>storageBGPRun();

constants
	Terminal1 : String = 'CASH';
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_StorageProcessorRequest;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);
	create bgpRequest transient;
	bgpRequest.setPropertyValue(BGP_CamsRequest::myTerminal.name, terminal);
	bgpRequest.setPropertyValue(BGP_CamsRequest::myUser.name, app.myPassport.myUser);
	bgpRequest.action();
epilog
	delete bgpRequest;
end;
</source>
    </JadeMethod>
    <JadeMethod name="sysCorruption" id="d8fdec00-55e6-4029-a31c-2bcb9a97f5d5">
        <source>sysCorruption();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theBank : CM_Bank;
	aTerm : CM_Terminal;
	aService : CM_Service;
	aRate : CM_Rate;
	aRateEntry : CM_RateEntry;
	anInvoice : CM_Invoice;
	anInvLine : CM_InvoiceLine;
	aCharge : CM_Charge;
begin
	app.initialize();
	app.niceName := CM_Charge.OVERRIDEAPPNAME;	
	
	foreach aTerm in app.myRoot.allTerminals do
		foreach theBank in aTerm.companies do
			app.writeStatement( "BANK : " &amp; theBank.code);
			foreach aService in theBank.services do
				app.writeStatement( "   " &amp; aService.name);
				beginTransaction;
				foreach aRate in aService.debtorNodeRates do
					foreach aRateEntry in aRate.rateEntries do
						//aRateEntry.costPerUnit := 0.1;
						aRateEntry.setCostPerUnit( 0.1 );
					endforeach;
				endforeach;
				foreach aRate in aService.lineGroupDebtorRates do
					foreach aRateEntry in aRate.rateEntries do
						//aRateEntry.costPerUnit := 0.05;
						aRateEntry.setCostPerUnit( 0.05 );
					endforeach;
				endforeach;
				commitTransaction;
			 endforeach; 
			
			foreach anInvoice in theBank.allInvoices do
				app.writeStatement( "   INV: " &amp; anInvoice.sequenceNum.String);
				beginTransaction;
				foreach anInvLine in anInvoice.invoiceLines do
					foreach aCharge in anInvLine.charges do
						aCharge.total := 0.02;
						aCharge.overrideRate(0.03);
					endforeach;
				endforeach;
				commitTransaction;
			endforeach;
		endforeach;
		
	endforeach;
	app.writeStatement( "Finished");
end;</source>
    </JadeMethod>
    <JadeMethod name="test" id="be2ceb2f-dab9-44af-9690-48c4e8cad1e1">
        <source>test();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

vars
	entities		: ObjectArray;
	schemaEntity	: SchemaEntity;
	iter			: Iterator;
	displayString	: String;
	errors			: StringArray512;	
	schemaName		: String;
	
begin
	create errors transient;

	create entities transient;
	SchemaEntity.allInstances(entities, 0, true);
	
	
	
	iter := entities.createIterator();
	while iter.next(schemaEntity) do
		if schemaEntity.name.length() &gt; 30 then
			schemaName := null;
			displayString := schemaEntity.String &amp; ' ';
			if schemaEntity.isKindOf(Type) then
				schemaName := schemaEntity.Type.schema.name;
				displayString := schemaName &amp; '::';
			elseif schemaEntity.isKindOf(Feature) then
				if schemaEntity.Feature.schemaType.schema = null then
					schemaEntity.Feature.schemaType.inspectModal();
				endif;
				schemaName := schemaEntity.Feature.schemaType.schema.name;
				displayString := schemaName &amp; '::' &amp; schemaEntity.Feature.schemaType.name &amp; '::';
			endif;
			displayString := displayString &amp; schemaEntity.name;
			
			if schemaName = "CardSchema" or
			   schemaName = "WebServiceTestSchema" then
				continue;
			endif;
			
		
			
			errors.add(displayString);
		endif;
	endwhile;
	
	
epilog
	delete errors;
	delete entities;
	delete iter;
	
end;</source>
    </JadeMethod>
