    <JadeMethod name="createNullVessel" id="a2b68a4b-e11d-41cc-b644-6d66ce3b8d18">
        <source>createNullVessel(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlgndl1	Initial creation	TFS 38914

*/

vars

begin
	//epr TFS 42454 8/12/18
	if app.myRoot.getNullVessel &lt;&gt; null then
		if _controller &lt;&gt; null then
			_controller.logEntry("&gt;&gt;&gt;&gt;&gt;  Null Vessel already created") ;	
		endif;
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Null Vessel", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Creating Null Vessel") ;	
	endif;
	
	beginTransaction;
	app.myRoot.createNullVessel();
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Null Vessel created",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Null Vessel created") ;	
	endif;
	

epilog

end;</source>
