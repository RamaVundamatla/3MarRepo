    <JadeMethod name="selectRectFrame" id="18b1c3a5-b70a-4f63-b194-abe50c8038fe">
        <updating/>
        <source>selectRectFrame(_rect: CMUI_ResizableRectFrame input; updateLocationText : Boolean) updating;
/*
Purpose:			

Date		Who		Reason
04 February 2009	cnwjk3	Initial creation
18/04/11	cnwdw1	POL 2059
*/

vars
	x1, y1, x2, y2 : Integer;
	yaBlock: CM_YABlock;
begin
	yaBlock := self.allYABlocksByRectFrame[_rect];
	if yaBlock &lt;&gt; null then
		self.form.YRD_SatelliteViewForm.doSelectYABlock(yaBlock);
		self.setCurrentEditYardAllocation(yaBlock.myYardAllocationIn);
		self.clearSelectedRectFrame();
		self.form.YRD_SatelliteViewForm.cmbYA.text := yaBlock.myYardAllocationIn.code;
	endif;
	_rect.isSelected := true;
	_rect.getIntPoints(x1, y1, x2, y2);
	if updateLocationText then
		self.form.YRD_SatelliteViewForm.txtYALocation.foreColor := Black;
		self.showLocationAndNumberOfSlots(x1-2, y1-2, x2+2, y2+2, true, _rect);
		self.selectAllYALocationText();
	endif; 
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
        <Parameter name="updateLocationText" type="Boolean"/>
    </JadeMethod>
