epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cancelStops" id="d6fe7f72-f636-4109-8356-3c2d7a97362c">
        <updating/>
        <source>cancelStops(_proxyTI : CM_TrackedItem input;  _stopsToClear : CM_StopsTableSet) updating;
/*
Purpose - 	incoming proxy TIs, add proxy stops to clear.
Who - NAVAB1
Date - 29AUG2023
ADO - CR 60052 TASK 60054 
*/


vars
	stop : CM_StopsTable;
	docType : CM_CustomDocumentType;
	ti, cgti : CM_TrackedItem;
	cg : CM_CargoGroup;
	pxyStop : CM_Stops;
	expiryDate : Date;
begin

	foreach stop in _stopsToClear discreteLock do
		pxyStop	:= _proxyTI.getStop( stop.id );
		// stop not set for this ti so can't clear it
		if pxyStop = null then
			continue;
		endif;
		pxyStop.setClearanceExpiryDate( null );
		
		pxyStop.pxySetCancelStop();
	
	endforeach;
epilog

end;</source>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_stopsToClear" type="CM_StopsTableSet"/>
    </JadeMethod>
    <JadeMethod name="clearStops" id="022692a2-f1b6-4bc2-8556-f68a3934f847">
        <updating/>
        <source>clearStops(_proxyTI : CM_TrackedItem input;  _stopsToClear : CM_StopsTableSet) updating;
/*
Purpose - 	incoming proxy TIs, add proxy stops to clear.
Who - NAVAB1
Date - 25AUG2023
ADO - CR 60052 TASK 60054 
*/


vars
	stop : CM_StopsTable;
	docType : CM_CustomDocumentType;
	ti, cgti : CM_TrackedItem;
	cg : CM_CargoGroup;
	pxyStop : CM_Stops;
	expiryDate : Date;
	custDoc : CM_CustomDocument;
begin
	expiryDate := expiryDate + CM_Stops.CheckDate_No_Of_Days;
	
	foreach stop in _stopsToClear discreteLock do
		pxyStop	:= _proxyTI.getStop( stop.id );
		// stop not set for this ti so can't clear it
		if pxyStop = null then
			continue;
		endif;
		// record any information that must be captured to clear the stop
		if stop.requiresInfo then
			custDoc:= self.getCustomDocumentHeader();// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
			_proxyTI.setRequiresInformation( stop.requiresInfoType, custDoc.code );
		endif;
		// record expiry date if set and relevant
		if stop.allowClearanceExpiryDate and expiryDate &lt;&gt; null then
			// don't delete - just set the clearance date (what if date is null - we won't be able to tell);
			pxyStop.setClearanceExpiryDate(expiryDate );
			pxyStop.setProxyCustDocCleared(self); // ### TFS CR 59942 TASK 59943 29AUG2023 NAVAB1
		else
			// we need to delete the stop 
			delete pxyStop;
		endif;
	
	endforeach;
epilog

end;</source>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_stopsToClear" type="CM_StopsTableSet"/>
    </JadeMethod>
    <JadeMethod name="cloneForSplit" id="3dba3c9c-7f5f-4478-9d3d-22d7d75c1c31">
        <updating/>
        <source>cloneForSplit(_ti : CM_TrackedItem input) : CM_CustomDocumentDetail updating;
/*
Purpose:			

Date		Who		Reason
29 August 2023	navab1	CR 59942 TASK 59943 
*/

vars
	txnParams 			: CMIF_TITransactionController;
	tmpTransaction		: CM_TITransaction;
	newCDD, subCDD : CM_CustomDocumentDetail;
	newStop, appliedStop : CM_Stops;
	custDoc : CM_CustomDocument;
begin
	create newCDD persistent;
	newCDD.myTrackedItem := _ti;
	newCDD.included := self.included;
	newCDD.myParentCustomDocument := self.myParentCustomDocument;
	newCDD.myParentCustomDocumentDetail := self.myParentCustomDocumentDetail;
	newCDD.setAmountsFromTI();

	custDoc := newCDD.getCustomDocumentHeader();
	
	// ### new stop has already been cloned, set on new CDD
	foreach appliedStop in self.allStopsApplied discreteLock do
		newStop := _ti.getStopByIDAsAtDate(appliedStop.myStopsTable.id,null);
		newCDD.allStopsApplied.tryAdd(newStop); // ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1 - tryAdd
		
		newStop.handleSplitStopCustDocsDetails(custDoc);
	endforeach;

	// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
	foreach appliedStop in self.allStopsCleared discreteLock do
		newStop := _ti.getStop(appliedStop.myStopsTable.id); // ### TFS CR 60424 TASK 60549 13OCT2023 NAVAB1   getStopByIDAsAtDate(appliedStop.myStopsTable.id,null);
		newStop.setClearanceExpiryDate(appliedStop.clearanceExpiryDate);// ### TFS CR 60424 TASK 60549 12OCT2023 NAVAB1
		newCDD.allStopsCleared.tryAdd(newStop); // ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1 - tryAdd
		
		newStop.handleSplitStopCustDocsDetails(custDoc);
	endforeach;

	self.clearedQuantity := self.clearedQuantity - _ti.totalQuantity;
	self.clearedWeight := self.clearedWeight -  _ti.totalWeight;
	self.clearedVolume := self.clearedVolume - _ti.totalVolume;
	
	// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
	if self.clearedQuantity &lt; 0 then
		// reduce the cleared amount on the split off TI by the negative amount so that the remaining full clearance amount is transferred to the new split off TI.
		// EG item A is qty 1000, cleared is 500. Item A has 600 split off. The original item A has cleared of zero and the new item A has a quantity of 600 but only 500 is cleared.
		newCDD.clearedQuantity := newCDD.clearedQuantity + self.clearedQuantity;
		self.clearedQuantity := 0;
	endif;
	if self.clearedWeight &lt; 0 then
		newCDD.clearedWeight := newCDD.clearedWeight + self.clearedWeight;
		self.clearedWeight := 0;
	endif;	
	if self.clearedVolume &lt; 0 then
		newCDD.clearedVolume := newCDD.clearedVolume + self.clearedVolume;
		self.clearedVolume := 0;
	endif;	
	
	custDoc.addTI(_ti);
	
	// ### TFS CR 60424 TASK 60549 16OCT2023 NAVAB1 - put a cleared stop transaction on the 'new' TI
	if _ti.getCustDocsClearedQuantity() = _ti.totalQuantity then
	
		foreach newStop in newCDD.allStopsCleared discreteLock do
			create txnParams transient;
			txnParams.type			:= TRANS_TYPE_STOPCLEAR;	
			txnParams.myStop			:= newStop;
			txnParams.myTrackedItem		:= _ti;
			txnParams.userId			:= app.myPassport.userCode;
			txnParams.systemGenerated	:= true;
			txnParams.remarks			:= "Auto Created For Split (CUST DOCS)";
			tmpTransaction				:= _ti.createTransaction( txnParams, app.myPassport );
			delete txnParams;
		endforeach;

	endif;
	
	return newCDD;
epilog
	delete txnParams;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="CM_CustomDocumentDetail"/>
    </JadeMethod>
    <JadeMethod name="createSubDetailForTI" id="ceedc0b0-7aad-48de-b3e8-bbbbd45b7e4d">
        <source>createSubDetailForTI(_ti : CM_TrackedItem) : CM_CustomDocumentDetail;
/*
Purpose:			

Date		Who		Reason
25 August 2023	navab1	CR 59942 TASK 59943 
*/

vars
	subDetail : CM_CustomDocumentDetail;
begin
	create subDetail;
	subDetail.included := true;
	subDetail.myTrackedItem := _ti;
	subDetail.myParentCustomDocumentDetail := self;
	subDetail.setAmountsFromTI();
	
	
	return subDetail;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_CustomDocumentDetail"/>
    </JadeMethod>
    <JadeMethod name="createTransactionForTI" id="c28f2ee7-2876-40d3-a41e-d354b0028db4">
        <source>createTransactionForTI(_type : Integer);
/*
Purpose - 	
Who - NAVAB1
Date - 25SEP2023
ADO - CR 60424 TASK 60549  
*/

vars
	ti 			: CM_TrackedItem;
	txnParams	: CMIF_TITransactionController;
	transaction	: CM_CustomDocTransaction;
begin
	
	ti := self.myTrackedItem;
	if ti.isZombie() then
		return;
	endif;
	
	create txnParams transient;
	txnParams.type := _type;
	transaction := ti.createTransaction(txnParams, app.myPassport).CM_CustomDocTransaction;
	transaction.setDetailsFromCusDoc(self.getCustomDocumentHeader());
	delete txnParams;
	if ti.isCargoGroupItem() then
		CMIF_TrxActionCargoGroup@createAction(null, ti.CM_CargoGroup, app.myPassport);
	else
		CMIF_TrxActionCargoGroup@createAction(ti, null, app.myPassport);
	endif;
	
	
epilog
	delete txnParams;
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
