    <JadeMethod name="actionForCreateInternal" id="e8489ac1-ba92-4ac6-9a3d-fc1bce5c9560">
        <updating/>
        <source>actionForCreateInternal(_vvRec : CM_VehicleVisitRecord input; _passport: CM_Passport input; _pxyTI : CM_TrackedItem): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2009	cnwjk3	Initial creation
11/01/2022	navpw1	TFS: 52631 Added Backdating for VVR transactions

*/

vars
begin		
	// Should be called on a persistent instance
	if self.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'persisent method called for transient object');
		return false;
	endif;
	
	// PAR 26482 If dont have a ti (probably becuase we are to do a bestpick) then treat as By Type		
	if self.isReleaseById and self.id &lt;&gt; null and not self.getBestPick() then  
	//if self.isReleaseById then  
		// ### TFS 52631 11Jan2022 NAVPW1 Adde VVR tracking
		return actionForCreateInternalById(_vvRec, _passport, _pxyTI); //so we do this if we are not best pick
	else
		return actionForCreateInternalByType(_passport);  // do this if we are a release by type or best pick
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreateInternalById" id="13e6dc9d-3b48-43e5-9a4e-df6608dfd357">
        <updating/>
        <source>actionForCreateInternalById(_vvRec : CM_VehicleVisitRecord input; _passport: CM_Passport input; _pxyTI : CM_TrackedItem): Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/06/2009	cnwjk3	Initial creation
23/03/2012	cnwdap1	CCMS SFW 1250 PAR #26287 rationalise TI myBookingRefItem update methods
11/09/2019	jlgzm1	TFS 42878 Direct Release Between Road and Voyage
11/01/2022	navpw1	TFS: 52631 Added Backdating for VVR transactions
17/06/2024	jlier1 TFS 64018
*/

vars
	roadJob 		: CM_RoadJob;
	pxyTI,
	realTI 			: CM_TrackedItem;
	wle 			: CM_WorkListEntry;
	theCargoType	: CM_CargoType;
	tiUpdateCntrlr 	: CMIF_TIUpdateController;
	chassis			: CM_TILC;
	moveLC : CM_LocationsController;
	gteEntity : CMGTE_Entity;
	aspaRoadProcess : Boolean;
	
begin

	aspaRoadProcess := self.getVehicleVisitRecord.myTerminal.roadProcessIsASPA;	//14 Oct 2020	NDL	TFS 49189
	
	roadJob := self.myVehicleVisitRecord.myRoadJob;
//	if roadJob = null then
	if not aspaRoadProcess and roadJob = null then //14 Oct 2020	NDL	TFS 49189
	//	app.raiseCMException1(REQUIRED_FIELD, 'road Job', 'road Job', null);
		app.raiseCMException(Input_required_field_roadJob, 'road Job', null); // cnwdb2	PAR 35364
		return false;
	endif;
	
	realTI:=self.myTrackedItem;
	
	if realTI = null then	
		// Get hold of the TI
		realTI := self.findCargo(self.id, self.cargoType);
		if realTI = null then
			if self.imexStatus = TI_IMEX_STATUS_REMAINONBOARD then			
				foreach gteEntity in self.myVehicleVisitRecord.allGateEntities where gteEntity.isKindOf(CMGTE_Receival)   do
					if gteEntity.CMGTE_Receival.imexStatus = TI_IMEX_STATUS_REMAINONBOARD and
						gteEntity.CMGTE_Receival.myTrackedItem &lt;&gt; null and 
						gteEntity.CMGTE_Receival.id = self.id then
						
						if self.isChassisOut then
							if not gteEntity.isKindOf(CMGTE_TILC) then
								continue;
							endif;
						endif;
						
						realTI:=gteEntity.CMGTE_Receival.myTrackedItem ;
						break;
					endif;		
				endforeach;						
			endif;
			
			if realTI = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'cargo Item', 'cargo Item', null);
				app.raiseCMException(Input_required_field_cargoItem, 'cargo Item', null); // cnwdb2	PAR 35364
				return false;
			endif;
		endif;
	endif;
	
	// Create a proxy TI, update it's attributes from self, validate and then update the real TI
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if theCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'cargo type', 'cargoType', null);
		app.raiseCMException(Input_required_field_cargoType, 'cargoType', null); // cnwdb2	PAR 35364
		return _passport.noErrors();
	endif;

	if  self.imexStatus &lt;&gt;  TI_IMEX_STATUS_REMAINONBOARD then
		tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_RELEASE, app.myPassport.userCode, null);
		
		// ### TFS 52631 11Jan2022 NAVPW1
		if _vvRec &lt;&gt; null and _vvRec.isRoadJobAutoComplete then
			tiUpdateCntrlr.dateTime := _vvRec.timeIn;
		endif;
		// ### TFS 52631 11Jan2022 NAVPW1
		
		if _pxyTI = null then
			pxyTI := app.createUpdateProxy(realTI).CM_TrackedItem;
			pxyTI.setPxyFromCMGTE_Release(self);
			pxyTI.validateTrackedItem(tiUpdateCntrlr, app.myPassport);	
			realTI.setForUpdate(pxyTI, tiUpdateCntrlr, null, true, _passport);	 //cnwrd1 28.8.09 par 20545
		else	
			// TI has already been validated
			realTI.setForUpdate(_pxyTI, tiUpdateCntrlr, null, true, _passport);	 //cnwrd1 28.8.09 par 20545
			
			//epr par 35759 3/3/15
			if self.isReleaseOfSameBBCargo() then
				app.myProxyManager.allReals[realTI].originalRealEdition:=realTI.edition;
			endif;
		endif;
	endif;
	self.myTrackedItem := realTI;
	
	//self.myTrackedItem.setMyBookingRefItem(self.myBookingRefItem);	// PAR #26287
	self.myTrackedItem.setMyBookRefItemActual(self.myBookingRefItem);	// PAR #26287
		
	if aspaRoadProcess then	//14 Oct 2020	NDL	TFS 49189
		return true;
	endif;
	
	// create the request
	if _passport.noErrors then
		if not self.createRequestById(_passport) then
			return false;
		endif;
	endif;
	
	if _passport.noErrors then	
		if self.myParent = null and self.myTrackedItem.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then // do not Q attachments
			
			if self.myVehicleVisitRecord.myOutCMGTE_Chassis &lt;&gt; null and self &lt;&gt; self.myVehicleVisitRecord.myOutCMGTE_Chassis then
				chassis:=self.myVehicleVisitRecord.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem.CM_TILC;
				if chassis &lt;&gt; null then
					if chassis.hasTIonChassis(self.myTrackedItem) then	//17 Nov 2014	NDL	found while testing Par 33342
						// don't need to move the item anywhere, it is already on the chassis, ready to release.
						moveLC := null;
					else
						//get first free lc controller
						moveLC:=chassis.getNextFreeLC();
					endif;
				else
					moveLC:=roadJob.myVehicle.myUnknownChassis; //epr 34216 23/5/14
				endif;
			else
				moveLC:=roadJob.myVehicle.locationsController;
			endif;
					
			if moveLC &lt;&gt; null then
				//epr par 35759 3/3/15
				wle:= self.myYardRequest.allWorkListEntries.first;
				//wle := roadJob.getWLEForTI(self.myTrackedItem);
				
				if roadJob.autoComplete or self.myTrackedItem.directDelivery or roadJob.canBeAutoCompleted(self.myTrackedItem,self,true)   then  //jlier1 TFS 64018 13/6/24 &amp; jlier1 TFS 65028 11/7/24
					//self.myTrackedItem.moveToLocation(moveLC, roadJob, wle, null, PLANNING_MODE, false, true, false, false, false,   false, self.totalQuantity,null,_passport);		// TFS 2651
					self.myTrackedItem.moveToLocation(moveLC, roadJob, wle, null, PLANNING_MODE, false, true, false, false, false,   false, self.totalQuantity,null,null,null,self.myVehicleVisitRecord,_passport);	// TFS 2651
				elseif self.myTerminal.isAutoPlanningEnabled() then  
					if not self.myTrackedItem.isAlreadyQueuedTo(moveLC) then //jlier1 TFS 59732 6/9/23 
						self.myTrackedItem.moveToLocation(moveLC, roadJob, wle, null, QUEUE_MODE, false, true, false, false, false,   false,self.totalQuantity,null,null,null,self.myVehicleVisitRecord, _passport);		// TFS 2651
					endif;	
					// Attempt to set for direct release
					if wle &lt;&gt; null then
						if wle.isDRLinkedByFM and self.myTrackedItem.isOnShip then
							// need to queue it from the voyage end
							// unqueue and requeue
							app.myUtilityUA.utlUpdateWLEUnqueue(wle, _passport);
							self.myTrackedItem.moveToLocation(moveLC, roadJob, wle, null, PLANNING_MODE, false, true, false, false, false,   false, self.totalQuantity,null,null,null,self.myVehicleVisitRecord,_passport);
							self.myTrackedItem.autoSetDirectReleaseWLE(wle, null, false);
							self.myTrackedItem.moveToLocation(moveLC, roadJob, wle.getDRLinkedWLE, null, QUEUE_MODE, false, true, false, false, false, false,self.totalQuantity,null,null, null,self.myVehicleVisitRecord,_passport);
						endif;
					endif;
				endif;
				
			endif;
		endif;
	endif;
	
	//05 Apr 2013	NDL	Par 31102
	if _passport.noErrors then
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.directDelivery then
			app.raiseCMWarning1(Is_Direct_delivery, self.myTrackedItem.id, null, null, null);
		endif;
	endif;

	return true;

epilog
	delete pxyTI;
	//epr 21011 7/10/09
	delete tiUpdateCntrlr;

end;</source>
        <access>protected</access>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreateInternalByType" id="1ce11179-f1f2-4027-93c8-5528a7b9d85e">
        <updating/>
        <source>actionForCreateInternalByType(_passport: CM_Passport input): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Jun 2009	cnwjk3	Initial creation
06 Oct 2025 navhl20 Story MTN-36133: MTN - Optimize Saving Road Jobs to Avoid Redundant Yard Allocation Checks when auto plan is failed
*/

vars
	roadJob : CM_RoadJob;
	subItem : CMGTE_Entity;
	wle : CM_WorkListEntry;
	arbiter	: CM_RTQueueArbiter;
begin
	roadJob := self.myVehicleVisitRecord.myRoadJob;
	
	if roadJob = null then
		if self.myTerminal.roadProcessIsASPA then	//06 Oct 2020	NDL	TFS 49189
			return true;
		endif;
		return false;
	endif;
		
	// ###################
	// ### CREATE MY REQUEST
	// ###################
	if _passport.noErrors then
		if not self.createRequestByType(_passport) then
			return false;
		endif;
	endif;

	if _passport.noErrors then
		
		//if this is an update i.e. there is already cargo moved status will be part complete or complete then queue the wle
		if  not self.myVehicleVisitRecord.isUpdatable then
			create arbiter;
			arbiter.job := roadJob;
			foreach wle in self.myYardRequest.allWorkListEntries do
				
					if wle.allRTQueueEntries.isEmpty then
						if wle.shouldQueueForRoadJob then
							arbiter.reset;
							arbiter.job:=roadJob;
							//wle.enqueueWLE(	arbiter);			//06.10.2025 navhl20 #36133 Doing this from job level
						endif;
					endif;
			endforeach;
		endif;
	endif;
	
	return true;
epilog
	delete arbiter;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeAllowsDuplicates" id="14a153a2-6028-4c33-85df-e149b0020c7a">
        <source>cargoTypeAllowsDuplicates(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2013	cnwrd1	Initial creation

*/

vars

	ct : CM_CargoType;
begin
	ct :=  self.myCargoType;
	if ct = null and self.myTrackedItem &lt;&gt; null then
		ct:=self.myTrackedItem.myCargoType;
	endif;
	
	if ct = null then
		return false;
	endif;
	
	return ct.allowDuplicates;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRequestById" id="fd622b3e-8772-47b7-9b43-5aa56412465f">
        <updating/>
        <source>createRequestById(_passport : CM_Passport input) : Boolean updating ;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 26/03/2014		cnwdap1			PAR #33606 CCMS SFW 1366 Bulk
// ---------------------------------------------------------------------------

vars
	tmpConsignorVoyageCode, tmpEirNumber, tmpConsignee : String;
	theTI : CM_TrackedItem;
	roadJob : CM_RoadJob;
	proxyTIRequest,realTIRequest : CM_TIRequest;
begin

	roadJob := self.myVehicleVisitRecord.myRoadJob;

	// The real onsite TI
	theTI := self.myTrackedItem;
	//jlier1 TFS 59732 6/9/23 
	if self.myYardRequest &lt;&gt; null and self.myYardRequest.isKindOf(CM_TIRequest) then
		realTIRequest:=self.myYardRequest.CM_TIRequest;
		beginLoad;
		proxyTIRequest:=self.myYardRequest.pxyCreateUpdateProxy.CM_TIRequest;
		endLoad;
	else
		create proxyTIRequest transient;
	endif;
	// Allow update of these TI members...
	
	if self.consignorVoyageCode &lt;&gt; null then
		tmpConsignorVoyageCode := self.consignorVoyageCode;
	else
		tmpConsignorVoyageCode := theTI.consignorVoyageCode;
	endif;
	
	if self.eirNumber &lt;&gt; null then
		tmpEirNumber := self.eirNumber;
	else
		tmpEirNumber := theTI.eirNumber;
	endif;
	
	if self.consigneeCode &lt;&gt; null then
		tmpConsignee := self.consigneeCode;
	else
		tmpConsignee := theTI.consignee;
	endif;

	proxyTIRequest.setProxyFromFlexiGate(false, tmpConsignorVoyageCode, tmpEirNumber, // lClean, lconsignorVoyageCode, leirNumber
							tmpConsignee, self.doorsDirection, 
							//null, self.freightForwarderCode, null, false, 			//pDeliveryNumber,lFreightForwarderCode, lFreightPayer, lisReceipt
							self.deliveryReleaseNumber, self.freightForwarderCode, null, false, // 01/12/2010 cnwmh5 #26400	//pDeliveryNumber,lFreightForwarderCode, lFreightPayer, lisReceipt
							null,null, app.deliveryReasonStringToEnum(self.deliveryReason),null, false, null, false, 				// lISOType, lOperator, lNumRequested, lreasonCode, lHeavy, lMask, lneedCOU,
							false, null, null, false, null, null, null,				// lneedGenerator, lDate, lvoyageCode, lCheckISO, pJob, pinNo, pAVG
							false, null, self.remarks, self.myTrackedItem, // pRemoveStops, pReasonCodeDescr,pRemarks,pTI		//cnwmc5 - 19 May 2014 - PAR 34173
							_passport.userCode, self.myTransferToTerminal,
							
							// New flexi gate fields
							self.customEntryNumber, self.myBulkRelease, self.myReserveDetail
							);
						
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myCargoType.isBulkMulti then	// PAR #33606
		proxyTIRequest.setWeightRequested(self.weight);									// PAR #33606
	endif;																				// PAR #33606
	
	if _passport.noErrors() then	
		//Validate the request (TI is already validated)
		proxyTIRequest.validate(_passport.myUser);
	endif;
	
	if _passport.hasErrors() then
		return false;
	endif;
	//jlier1 TFS 59732 6/9/23 
	if realTIRequest = null or not roadJob.allRequests.includes(realTIRequest) then
		//Add the request to the job	
		self.myYardRequest := roadJob.addRequest(proxyTIRequest, _passport).CM_YardRequest;
	else
		self.myYardRequest.setForUpdate(proxyTIRequest);
	endif;
	if _passport.hasErrors() then
		return false;
	endif;
	// 10/02/2010 cnwjre1	CCMS 1101
	if self.yardLocationTxt &lt;&gt; null then
		self.myYardRequest.setNominatedTA(self.yardLocationTxt, null, null);
	endif;
	
	if self.myTrackedItem.isKindOf(CM_BreakBulkGeneric) then
		if self.myYardRequest.allWorkListEntries.first &lt;&gt; null then
			self.myYardRequest.allWorkListEntries.first.setQuantity(self.totalQuantity);
		endif;
	endif;

	//Add the TI to the job
	roadJob.addTI(self.myTrackedItem, proxyTIRequest);

	return true;
epilog
	delete proxyTIRequest;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRequestByType" id="5020dee8-6030-4495-a387-6776faafd3da">
        <updating/>
        <source>createRequestByType(_passport : CM_Passport input) : Boolean updating ;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// 15/10/12		cnwer1				par 32445 removed allContainer lengths
// 07/04/2014	cnwdap1				PAR #33606 CCMS SFW 1366 Bulk
// 08 Feb 2019	jlgrs1				TFS 43312 - More Deadlocking in Multiuser EDI
// 02 Apr 2024  navhl20 			ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
// 25 Sep 2024	navpw1				TFS: 65623 (65624) - Added code to set isAnyAmount from the gate entity 
// 30 Jun 2025  navma1				MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
// ---------------------------------------------------------------------------

vars
	tmpPinNo, 
	tmpDeliveryNumber : String;
	roadJob 		  : CM_RoadJob;
	proxyTIRequest,
	realRequest 	  : CM_DeliveryRequest;
	bulkRelease 	  : CM_BulkRelease;
	wle				  : CM_WorkListEntry;
	ids				  : StringArray;
	isBestPick		  : Boolean;
begin

	if self.myOperatorGroup = null then
		if self.operatorGroupCode &lt;&gt; null then
			self.myOperatorGroup := app.myRoot.allOperatorGroups[self.operatorGroupCode];
		endif;
	endif;

	tmpDeliveryNumber := self.deliveryReleaseNumber;
	if tmpDeliveryNumber = null then
		// Par8380 use BR system code if there is one as a system BR is created if one is not found
		// all subsequent requests that dont have a BR will be attached to the system generated BR
		tmpDeliveryNumber := self.systemBulkReleaseCode;
	endif;

	if self.myBulkRelease &lt;&gt; null then
		tmpPinNo := self.myBulkRelease.getPinNumber();
	else
		tmpPinNo := null;
	endif;
	
	roadJob := self.myVehicleVisitRecord.myRoadJob;
	//jlier1 TFS 59732 6/9/23 
	if self.myYardRequest &lt;&gt; null and self.myYardRequest.isKindOf(CM_DeliveryRequest) then
		realRequest := self.myYardRequest.CM_DeliveryRequest;
		beginLoad;
		proxyTIRequest := self.myYardRequest.pxyCreateUpdateProxy.CM_DeliveryRequest;
		endLoad;
	else
		create proxyTIRequest transient;	
	endif;
	proxyTIRequest.setFromFlexiGate(self.consigneeCode, self.consignorVoyageCode, tmpDeliveryNumber, 
					   self.eirNumber, self.isoType, self.operatorCode,
					   self.myOperatorGroup,
					   self.myCargoType,
					   self.myTILCType,
					   self.clean, self.doISOGroupCheck, self.doorsDirection, 
					   self.heavyRated,
					   false, 	/* isReceipt */
					   self.needCOU, self.needGenerator,
					   self.removeStops, self.numItems,
					   null,	/* reasonCode */
					   self.allAvailabilityGrades, self.deliveryReason, null, 				//cnwmc5 - 19 May 2014 - PAR 34173
					   null,	/* ids */
					   tmpPinNo,//for par13816
					   self.myTransferToTerminal,
					   self.myBulkRelease,
					   self.mySubTerminalSource,// cnwdad1 02/07/2009 - CCMS 1735.				   
					   // New fields for flexi-gate 					 
					   self.customEntryNumber,
					   self.isoGroup,
					   self.voyageCode,
					   self.billOfLading,
					   self.myProduct,
					   self.mark,
					   self.markNumber,
					   self.description,
					   self.weight,
					   self.length,
					   self.getMyVolume,
					   self.width,
					   self.height,
					   self.widthString,
					   self.heightString,
					   self.lengthString,
					   self.density,
					   self.quantity,
					   self.colour,
					   self.yardInstructions,
					   self.type,
					   self.commodity,
					   self.myReserveDetail,
					   self.imexStatus,
					   self.getIsAnyAmount()										// ### TFS 65623 (65624) 25Sep2024 NAVPW1
					   ); 	
	
	if self.myCargoType &lt;&gt; null and self.myCargoType.isBulkMulti then				// PAR #33606
		proxyTIRequest.setWeightRequested(self.weight);								// PAR #33606
	endif;																			// PAR #33606
	
	if self.idMask &lt;&gt; null then
		create ids transient;
		self.idMask.convertToDelimitedArray(",", ids);
		proxyTIRequest.setIds(ids);
	endif;
	
	//Add the request to the job	
	//jlier1 TFS 59732 6/9/23 
	if realRequest = null or not roadJob.allRequests.includes(realRequest) then
		self.myYardRequest := roadJob.addRequest(proxyTIRequest, _passport).CM_YardRequest;
		//roadJob.setJobPlannedLocation();																	//02.04.2024 navhl20 #63251
		roadJob.setJobPlannedLocation(false); //26/08/2024	navkc1 CR 63588 Task 63589
	else
		self.myYardRequest.setForUpdate(proxyTIRequest);
	endif;
	if _passport.hasErrors() then
		return false;
	endif;

	
	if not self.allSourceTAs.isEmpty then // cnwrd1 par 24169
		// 10/02/2010 cnwjre1	CCMS 1101
		self.myYardRequest.CM_DeliveryRequest.setNominatedTAs(self.allSourceTAs, allSourceTAGridObjs);  //cnwrd1 2098 allgridobjects
	elseif self.yardLocationTxt &lt;&gt; null then
		self.myYardRequest.setNominatedTA(self.yardLocationTxt, null, null); 	
	endif;
	
	isBestPick := self.getBestPick();
	
	self.myYardRequest.setIsFIFO(self.isFIFO);		 //cnwrd1 par 24169 9.6.2010
	self.myYardRequest.setBestPick(isBestPick);  		// PAR 26443
	// CCMS 1101 carry best-pick option down to auto-plan code
	foreach wle in self.myYardRequest.allWorkListEntries do
		wle.setBestPick(isBestPick);
	endforeach;
	
	self.myYardRequest.CM_DeliveryRequest.validateForCreate(null); // the passed in object is the GUI object
	if _passport.hasErrors() then
		return false;
	endif;

	if (not self.myTerminal.getConfig(DoNotCreateBulkRelease).Boolean) then
		//th2 added 22/01/07 - deadlocks in CM_BulkRelease::setFromTIRequest(2167)
		//setting CM_BulkRelease::myTerminal reference
		/*
		Collections Should be locked in the right Oid Order
		30.06.2025 navma1 #MTN-34090
		*/
		self.exclusiveLock(self.myTerminal.allBulkReleasesByCodeDate);    //004 - CM_BulkReleaseByCodeDict
		self.exclusiveLock(self.myTerminal.allBulkReleasesByDelRelNo);    //021 - CM_BulkReleaseByDelRelNoDict
		self.exclusiveLock(self.myTerminal.allBulkReleaseByTypeByStByCd); //159 - CM_BulkReleaseByTypeStCodeDict
		
		// Par8380 - add bulk release if needed
		bulkRelease := self.myYardRequest.myOriginatingBulkRelease;
		if bulkRelease = null then
			if self.deliveryReleaseNumber = null then
				//See if one has been created for system code
				bulkRelease := self.myTerminal.getBulkReleaseFromCode(self.systemBulkReleaseCode);
				
			endif;
			if bulkRelease &lt;&gt; null then
				//Set bulk release and adjust total requested
				self.myYardRequest.setMyOriginatingBulkRelease(bulkRelease);
				//epr 11/9/17 TFS 6723 deleted reference to method that did nothing
			else//create bulk release for gate out request
				self.myYardRequest.createBulkReleaseFromSelf(_passport);
				self.systemBulkReleaseCode := self.myYardRequest.myOriginatingBulkRelease.code;
			endif;
		else
			//determine whether the bulk release totals need adjusting
			if bulkRelease.isSystemGenerated then
				self.systemBulkReleaseCode := bulkRelease.code;			
			endif;
		endif;
	endif;

	return true;
epilog
	delete ids;
	delete proxyTIRequest;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="defaultDetailsFromParentItem" id="11b723b2-713f-4f18-ae16-dbcdcc0fc7af">
        <updating/>
        <source>defaultDetailsFromParentItem(_parent: CMGTE_Entity) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2018	jlgma1	Initial creation
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars


begin
	inheritMethod(_parent);
	self.myVehicleVisitRecord := _parent.myVehicleVisitRecord;
	self.consigneeCode 		:= _parent.CMGTE_Release.consigneeCode;
	if self.operatorCode = null then
		self.operatorCode	:= _parent.CMGTE_Release.operatorCode;
	endif;


epilog

end;</source>
        <Parameter name="_parent" type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="findCargo" id="ca66f626-2798-49f4-bd1e-f7a16e577c22">
        <source>findCargo(_id: String; _cargoType: Integer): CM_TrackedItem;
/*
Purpose: CCMS 1267 Direct Deliveries		

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2012	cnwdw1	Initial creation
13/11/2012			cnwmh5	#30720 - Change so that if container isn't planned and in the discharge area return null
*/
vars

	ti: CM_TrackedItem;
	iterTa : Iterator;
	startTa : CM_TerminalArea;
	ta : CM_TerminalArea;
	iter : Iterator;
	futureMove : CM_FutureMove;
	tiToReturn : CM_TrackedItem;														// 13/11/2012 cnwmh5 #30720
	voyages : CM_VoyageSet;
	voyage : CM_Voyage;
	
begin

	tiToReturn := self.myTerminal.allOnsiteTIsByIdCargoType[_id, _cargoType];			// 13/11/2012 cnwmh5 #30720
	if tiToReturn = null then 															// 13/11/2012 cnwmh5 #30720
		//03 Jul 2012	NDL	Par 29707
		iterTa := self.myTerminal.allTerminalAreasByTypeId.createIterator;
		startTa := self.myTerminal.allTerminalAreasByTypeId.getAtKeyGeq(TA_TYPE_RELTRANS,null);//myTerminalArea.myType.type = TA_TYPE_RELTRANS
		if startTa = null then
			return null;
		endif;
		iterTa.startAtObject(startTa);
		while iterTa.next( ta ) do
			if ta.myType.type &lt;&gt; TA_TYPE_RELTRANS then
				break;
			endif;
			iter := ta.CM_BlockStack.myLocationsController.allPlannedFutureMoves.createIterator;
			while iter.next( futureMove ) do
				if futureMove.isFutureMovePlanned then
					ti := futureMove.getTrackedItem();
					if ti &lt;&gt; null and ti.id = _id then
						// 13/11/2012 cnwmh5 #30720
						//return ti;					
						tiToReturn := ti;
						break;
					endif;
				endif;
			endwhile;
			delete iter;
			if tiToReturn &lt;&gt; null then													// 13/11/2012 cnwmh5 #30720
				break;
			endif;
		endwhile;

	endif;
	
	//31 Jan 2013	NDL	Par 31102 - Check on prenotes and notified on voyages, in case its a Direct delivery
	if tiToReturn = null then
	
		tiToReturn := self.myTerminal.allNotifiedTIsByIdCargoType[_id, _cargoType];	//11 Feb 2013	NDL	Par 31102
		
		if tiToReturn = null then
			create voyages transient;
			self.myTerminal.getAllCurrentVoyages(voyages, true, false, false);
			foreach voyage in voyages discreteLock do
				ti := voyage.allOnshipTIsByIdCargoType[_id, _cargoType];
				if ti &lt;&gt; null and ti.directDelivery then
					tiToReturn := ti;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	
	return tiToReturn;																	// 13/11/2012 cnwmh5 #30720


epilog
	delete iterTa;
	delete iter;
	delete voyages;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getAspaMaxQty" id="49e69c2c-20aa-473e-95ee-f7399187f559">
        <source>getAspaMaxQty():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

//	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	releasedQty : Integer;

begin

//	if self.myBOLDtl &lt;&gt; null then
//		cargoType := self.myBOLDtl.myCargoType;
//	endif;
	if self.myCargoType = null or self.myCargoType.isBulkByVolume or self.myCargoType.isBulkByWeight then
		return self.totalQuantity;
	endif;
	
	foreach ti in self.myVehicleVisitRecord.allReleasedTrackedItems do
		if ti.myCargoType &lt;&gt; self.myCargoType then
			continue;
		endif;
		if ti.myBOLDtl = self.myBOLDtl then
			//This is one of ours and already released against this release
			releasedQty := releasedQty + ti.totalQuantity;
		elseif ti.billOfLading = self.myBOLDtl.myBOL.number then
			releasedQty := releasedQty + ti.totalQuantity;
		endif;
	endforeach;
	
	return self.totalQuantity - releasedQty;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAspaMaxWeight" id="49036729-0e66-4b19-932e-2d2d266ae426">
        <source>getAspaMaxWeight():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

//	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	releasedWeight : Decimal [14,4];

begin

//	if self.myBOLDtl &lt;&gt; null then
//		cargoType := self.myBOLDtl.myCargoType;
//	endif;
	if self.myCargoType = null or ( not self.myCargoType.isBulkByVolume and not self.myCargoType.isBulkByWeight ) then
		return self.weight;
	endif;
	
	foreach ti in self.myVehicleVisitRecord.allReleasedTrackedItems do
		if ti.myCargoType &lt;&gt; self.myCargoType then
			continue;
		endif;
		if ti.myBOLDtl = self.myBOLDtl then
			//This is one of ours and already released against this release
			if self.myCargoType.isBulkByVolume then
				releasedWeight := releasedWeight + ( ti.totalVolume * ti.getDensity );
			elseif self.myCargoType.isBulkByWeight then
				releasedWeight := releasedWeight + ti.totalWeight;
			endif;
		elseif ti.billOfLading = self.myBOLDtl.myBOL.number then
			if self.myCargoType.isBulkByVolume then
				releasedWeight := releasedWeight + ( ti.totalVolume * ti.getDensity );
			elseif self.myCargoType.isBulkByWeight then
				releasedWeight := releasedWeight + ti.totalWeight;
			endif;
		endif;
	endforeach;
	
	return self.weight - releasedWeight;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getBestPick" id="8075a690-4c01-48a1-b8c7-bc0935aa83f9">
