    <JadeMethod name="populateTrackedItem" id="d0c9e105-e6eb-496e-b084-fbf26ffc48c3">
        <source>populateTrackedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	desc1 : String;
	desc2 : String;

begin

	if self.myTrackedItem &lt;&gt; null then
		self.txtCargoId.text := self.myTrackedItem.id;
		self.myTrackedItem.getShortDescriptions( desc1, desc2 );
		self.lblCargoType.caption := desc1;
		self.lblCargoDesc.caption := desc2;		
		self.txtNewQuantity.text := self.myTrackedItem.totalQuantity.String; //27 Sep 2016	NDL	TFS 2753
	else
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		self.lblCargoType.caption := null;
		self.lblCargoDesc.caption := null;
		self.txtNewQuantity.text := null;
		self.lblQuantityChg.caption := null;
		self.tblNewWeight.setValueDefault(null);
		self.tblCargoWeight.setValueDefault(null);
		self.tblTareWeight.setValueDefault(null);
		self.lblTotalWtChg.caption := null;
		self.txtReason.text := null;	
		self.txtCargoId.setFocus;	
	endif;
	//epr tfs 1502 handle bulk 14/6/16
	self.setupTblNewWeight();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="2641bcd5-ffa1-402f-8e34-28328e68b288">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	
begin

	self.setMyTrackedItem( null );

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				if not ti.canMergeBreakBulk then
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				if not ti.canMergeBreakBulk then
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		self.populateTrackedItem();
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( true );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);
		app.myMobileCargoFindAgent.setCanMergeOnly(true);
		
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="e573993c-2b83-40c7-8c9b-df948950a1b7">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

begin
	
	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="ee9884f9-17e1-4e48-abfc-479e462b8486">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

begin

