    <JadeMethod name="addColumn" id="5e6046d6-def2-4c16-9461-41c7541416b1">
        <updating/>
        <source>addColumn(pHeading, pProperty : String; pInputType : Integer) updating;
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.allTblDataColHeadings.add(pHeading);
end;</source>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pProperty" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="fd4c5383-1dd7-46b2-b9e4-1391eea71ce8">
        <updating/>
        <source>addToolbarControls() updating, protected;

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNextT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
