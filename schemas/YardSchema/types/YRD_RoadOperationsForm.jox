        <source>doSelectRFIDTag() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	roadJob : CM_RoadJob;
begin

	if self.myCurrentRoadJob &lt;&gt;  null then

		self.myAssistant.showRFIDTagForm( self.myCurrentRoadJob, null, CMUI_RFIDTag.Mode_FromRoadOps);
	else
		app.msgBox("Select a Road Job","Road Job", MsgBox_OK_Only);
