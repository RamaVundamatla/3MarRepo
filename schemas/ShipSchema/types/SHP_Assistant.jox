    <JadeMethod name="showOOWCraneDetailsForm" id="98dcc815-b845-41ab-86a6-9f1f781996fc">
        <source>showOOWCraneDetailsForm(_workPoint : CM_Object; _voyage : CM_Voyage);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474

*/

vars

	form : SHP_OOWCWorkPointDetailsForm;
	jobSheet : CM_VoyageJobSheet;
	voyage : CM_Voyage;
	msg : String;
	
begin

	if _workPoint = null then
		msg := app.getErrorString1(Unable_to_proceed_not_passed,app.getErrorString(CM_Crane_GC));
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	voyage := _voyage;
	if voyage = null then
		msg := app.getErrorString1(Unable_to_proceed_not_passed,app.getErrorString(VoyageCapitalV));
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;

	jobSheet := voyage.allJobSheets[_workPoint.IF_VoyageWorkPoint.getID];
	if jobSheet = null then
		msg := app.getErrorString1(Unable_to_proceed_not_passed,app.getErrorString(Job_Sheet));
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;

	form := app.loadForm(SHP_OOWCWorkPointDetailsForm, self.class, false, false, false, self.myTerminal, null).SHP_OOWCWorkPointDetailsForm;
	if form = null then
		return;
	endif;
	
	form.setBaseData(_workPoint, voyage, jobSheet);
	form.showModal;
	
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_Object"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="showOOWCreationForm" id="fcb67533-7838-4439-93b1-5c18b157e064">
        <source>showOOWCreationForm();
/*

Purpose:			


