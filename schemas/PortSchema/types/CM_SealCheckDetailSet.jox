<CollClass name="CM_SealCheckDetailSet" id="fdbc90c8-3594-452e-ae0b-b8b72d0028e5">
    <loadFactor>98</loadFactor>
    <memberType name="CM_SealCheckDetail"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <JadeMethod name="displayAllAfterAsCSV" id="454298de-12ce-448f-9d00-44fd766f661c">
        <source>displayAllAfterAsCSV():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 July 2017	jlgndl1	Initial creation	TFS 5314

*/

vars

	retString : String;
	sealCheckDetail : CM_SealCheckDetail;
	afterStr : String;

begin

	foreach sealCheckDetail in self do
		afterStr := sealCheckDetail.sealAfter.trimBlanks;
		if afterStr &lt;&gt; null then
			if retString &lt;&gt; null then
				retString := retString &amp; ", ";
			endif;
			retString := retString &amp; afterStr;
		endif;
	endforeach;
	
	return retString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstOfSealType" id="a503aa00-6fb2-48a5-94d9-29e7198bf66f">
        <source>getFirstOfSealType(_sealType : String) : CM_SealCheckDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars

	detail : CM_SealCheckDetail;
	
begin

	foreach detail in self do
		if detail.sealType = _sealType then
			return detail;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_sealType" type="String"/>
        <ReturnType type="CM_SealCheckDetail"/>
    </JadeMethod>
</CollClass>
