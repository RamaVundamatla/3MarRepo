<Class name="CMQF_Train">
    <JadeMethod name="setFromAgent" id="bfee62f5-2d61-4eb8-8828-a6948b31fd1a">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
// -----------------------------------------------------------------------------
// Created:		14 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 14/07/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// -----------------------------------------------------------------------------

vars
	
begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_ProcessDate) then
		return;
	endif;

	if _agent.isRowIncluded(ETRow_Train) then
		self.setMyTrain( _agent.getSelectedTrain() );
	endif;

	if _agent.isRowIncluded(ETRow_TrainCode) then
		self.trainCode := _agent.getValueByNameIfVisible(ETRow_TrainCode).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_ArrivalsDateFrom) then// Actually called "Scheduled Arrival Date From"
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ArrivalsDateFrom), 
								self.scheduledArrivalDateFromType, self.scheduledArrivalDateFromFactor, ETRow_ArrivalsDateFrom);
		else
			self.scheduledArrivalDateFrom := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateFrom).Date;
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_ArrivalsDateTo) then// Actually called "Scheduled Arrival Date To"
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ArrivalsDateTo), 
								self.scheduledArrivalDateToType, self.scheduledArrivalDateToFactor, ETRow_ArrivalsDateTo);
		else
			self.scheduledArrivalDateTo := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateTo).Date;
		endif;
	endif;
	
	//29 Oct 2012	NDL	Par 30394
	if _agent.isRowIncluded(ETRow_ActDepartedDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ActDepartedDateFrom), 
								self.departDateFromType, self.departDateFromFactor, ETRow_ActDepartedDateFrom);
		else
			self.departDateFrom := _agent.getValueByNameIfVisible(ETRow_ActDepartedDateFrom).Date;
		endif;
	endif;
	if _agent.isRowIncluded(ETRow_ActDepartedDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ActDepartedDateTo), 
								self.departDateToType, self.departDateToFactor, ETRow_ActDepartedDateTo);
		else
			self.departDateTo := _agent.getValueByNameIfVisible(ETRow_ActDepartedDateTo).Date;
		endif;
	endif;
	
	//30 Oct 2012	NDL	Par 30394
	if _agent.isRowIncluded(ETRow_SchedDepartedDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_SchedDepartedDateFrom), 
								self.scheduledDepartDateFromType, self.scheduledDepartDateFromFactor, ETRow_SchedDepartedDateFrom);
		else
			self.scheduledDepartDateFrom := _agent.getValueByNameIfVisible(ETRow_SchedDepartedDateFrom).Date;
		endif;
	endif;
	if _agent.isRowIncluded(ETRow_SchedDepartedDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_SchedDepartedDateTo), 
								self.scheduledDepartDateToType, self.scheduledDepartDateToFactor, ETRow_SchedDepartedDateTo);
		else
			self.scheduledDepartDateTo := _agent.getValueByNameIfVisible(ETRow_SchedDepartedDateTo).Date;
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_ActArrivedDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ActArrivedDateFrom), 
								self.arrivalDateFromType, self.arrivalDateFromFactor, ETRow_ActArrivedDateFrom);
		else
			self.arrivalDateFrom := _agent.getValueByNameIfVisible(ETRow_ActArrivedDateFrom).Date;
		endif;
	endif;
	if _agent.isRowIncluded(ETRow_ActArrivedDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ActArrivedDateTo), 
								self.arrivalDateToType, self.arrivalDateToFactor, ETRow_ActArrivedDateTo);
		else
			self.arrivalDateTo := _agent.getValueByNameIfVisible(ETRow_ActArrivedDateTo).Date;
		endif;
	endif;
	
	
	
	if _agent.isRowIncluded(ETRow_IncludeDeparted) then
		self.includeDeparted := _agent.getValueByNameIfVisible(ETRow_IncludeDeparted).Boolean;
	endif;

epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
