begin

	if _attribute = ETRow_ArrivalsTimeFrom or _attribute = ETRow_MovementTimeFrom then
		return self.arriveTFrom;
	elseif _attribute = ETRow_ArrivalsTimeTo or _attribute = ETRow_MovementTimeTo then
		return self.arriveTTo;
	elseif _attribute = ETRow_DepartedTimeFrom then
		return self.departTFrom;
	elseif _attribute = ETRow_DepartedTimeTo then
		return self.departTTo;
	elseif _attribute = ETRow_InPortTimeFrom then
		return self.inPortTFrom;
	elseif _attribute = ETRow_InPortTimeTo then
		return self.inPortTTo;
	endif;

end;</source>
        <Parameter name="_attribute" type="String"/>
        <ReturnType type="Time"/>
