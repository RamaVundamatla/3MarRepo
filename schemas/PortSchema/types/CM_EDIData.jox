    <JadeMethod name="canBeReprocessedByBGP" id="85cb00b1-431e-4a07-a2c7-4a821186cc44">
        <source>canBeReprocessedByBGP():Boolean;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
//18 Sep 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
//13 May 2015	cnwrs1	Par 36099 - never reprocess a delete EDI booking ref
//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
//14 May 2025 	naviv1    MTN-19104 - MTN - Transport Manifest Handling of locking in EDI Operations
*/
vars
	result : Boolean;
	actionResult : String;
begin
	result := self.status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL or
	       self.status = CM_EDIFile.EDI_STATUS_LOCKERROR or
		   self.status = CM_EDIFile.EDI_STATUS_QUEUED_FOR_BGP;		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
	if result and not self.isTransportManifest() then  // MTN-19104 -- Skip EDI_ACTION_DELETE check for Transport Manifest files, as Cancel Transport files need to be reprocessed by BGP but were previously being excluded. 
		actionResult := self.getEDIAction();
		if actionResult = null or 
		   actionResult = CM_EDITrackedItem.EDI_ACTION_DELETE then
			result := false;
		endif;
	endif;
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeRevoked" id="c0b10e6c-c8fa-4b35-add3-99f47943f910">
        <source>canBeRevoked() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/11/2022	navdap1		Initial creation TFS 55084 EUP - EDI Administration Usability Requirements
//
vars

begin
	return self.status = CM_EDIFile.EDI_STATUS_CANCELLED;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeVerified" id="cb69fbd4-e0e7-4446-bf0d-844f75ebc9dc">
        <source>canBeVerified():Boolean;
/*
Date		Who		Reason
07 Aug 2012	cnwcs5	Initial creation - par 30136
*/
//18 Sep 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
//16 Jan 2014	cnwrs1	par 33309 - looks like the EDI Status DBLoading has run its course and needs to be removed
//20 Mar 2023 	navra1 	TFS 57125 - A revoked EDI should be verifiable
//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
vars
	status	:Integer;
begin

	//04 Dec 2017	NDL	TFS 8174
	if self.allEDITrackedItems.isEmpty then
		return false;
	endif;
	
	status := self.status;
	
	return status = CM_EDIFile.EDI_STATUS_LOADED or
			status = CM_EDIFile.EDI_STATUS_LOCKERROR or					// cnwrs1 18 mar 2010 so you can still continue
			status = CM_EDIFile.EDI_STATUS_VERIFYING or					// cnwrs1 18 mar 2010 so you can still continue
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or
			status = CM_EDIFile.EDI_STATUS_VERIFIED or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or
			status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS or
			status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL or
			status = CM_EDIFile.EDI_STATUS_REVOKED or					//navra1 - TFS 57125 - 20th Mar 2023
			status = CM_EDIFile.EDI_STATUS_QUEUED_FOR_BGP;				//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
