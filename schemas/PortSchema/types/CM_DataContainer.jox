<Class name="CM_DataContainer" id="bfd38324-7dd4-4e4f-b878-458595c94cc6">
    <superclass name="CM_DataContainerEntity"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allBlocks" id="e1c51238-2ceb-4a92-80ea-3950fbfe8f6f">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="CM_DataContainerBlockArray"/>
        <access>readonly</access>
        <Inverse name="CM_DataContainerBlock::myDataContainer"/>
    </ExplicitInverseRef>
    <PrimAttribute name="displayMode" id="513bc272-fe03-42bb-a6f1-24cfcad7bfd0">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="headerColour" id="2e4b6877-1baf-4aaf-944b-c8767d46115b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="valueColour" id="f00c5326-28d1-4823-9e09-309895c52ad1">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="addMultipleBlocks" id="3b812ab5-671e-447b-b604-eae20052c4b7">
        <source>addMultipleBlocks(blockArray : CM_DataContainerBlockArray);
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	blockArray.copy(self.allBlocks);
end;</source>
        <Parameter name="blockArray" type="CM_DataContainerBlockArray"/>
    </JadeMethod>
    <JadeMethod name="addNewBlock" id="a2111146-36c5-462a-bbe9-23747a5c61ad">
        <source>addNewBlock() : CM_DataContainerBlock;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	block : CM_DataContainerBlock;

begin
	create block transient;
	self.allBlocks.add(block);
	return block;
end;</source>
        <ReturnType type="CM_DataContainerBlock"/>
    </JadeMethod>
    <JadeMethod name="create" id="66869233-b3fd-4054-a93a-d329236d3e44">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.headerColour := Gray;
	self.valueColour := White;
end;</source>
    </JadeMethod>
    <JadeMethod name="insertNewBlock" id="0cd0d26a-0fcb-4c9b-b01b-ece226dccd63">
        <source>insertNewBlock(_index : Integer) : CM_DataContainerBlock;
/*
Purpose - 	
Who - NAVAB1
Date - 13FEB2024
ADO -  CR 61579 TASK 62453
*/

vars
	block : CM_DataContainerBlock;

begin
	create block transient;
	self.allBlocks.insert(_index, block);
	return block;
end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="CM_DataContainerBlock"/>
    </JadeMethod>
</Class>
