    <JadeMethod name="cloneReferences" id="06f1a7f4-d870-45dd-bbd2-9c8caf8c9828">
        <updating/>
        <source>cloneReferences(_obj: CMQF_BulkRelease; _transient: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
17 July 2018		jlgmd1	Initial creation - TFS 39407 SNO - Fixed Bulk Release criteria not saving on the template

*/

vars

begin
	inheritMethod(_obj, _transient);

	self.allQryAvaGrades.clear();
	_obj.allQryAvaGrades.copy(self.allQryAvaGrades);
	
	self.setMyISOTypeGroup( _obj.getMyISOTypeGroup );
	self.setMyMTPoolParty( _obj.getMyMTPoolParty );
	self.setMyOperatorGroup( _obj.getMyOperatorGroup );
	
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_BulkRelease"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="8a022cbc-3571-4a7e-84bf-5bceaef59a84">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	30 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

vars
	bulkRel		: CM_BulkRelease;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
begin

	foreach terminal in self.allTerminals do : terminalLoop
		
		foreach bulkRel in terminal.allBulkReleaseByTypeByStByCd discreteLock where bulkRel.status = BR_ACTIVE do
			if self.checkStatusIncludesObject(bulkRel, _passport, breakOut) then
				if not _collection.includes(bulkRel) then
					_collection.add(bulkRel);
				endif;
			endif;
		endforeach;
		
	endforeach;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyISOTypeGroup" id="e0fcc10b-54f6-48fa-8af2-2d0192866dbd">
        <source>getMyISOTypeGroup():CM_ISOTypeGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_ISOTypeGroup;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myISOTypeGroup;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="getMyMTPoolParty" id="fb68a818-4a20-4e9c-b210-7ac4881d0f8b">
        <source>getMyMTPoolParty() : CM_MTPoolingParty;
//
// Purpose:			
//
