    <JadeMethod name="updateBOLCargo" id="6d07c7e0-289f-4e6b-982b-237937191ed9">
        <updating/>
        <source>updateBOLCargo(_bol : CM_BOLIn) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2014	cnwmc5	Initial creation	PAR 34134

*/

vars

	ti : CM_TrackedItem;
	
begin

	foreach ti in _bol.allTrackedItems do
		self.updateObject(ti);
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="updateBillsOfLadingTblFrmNotif" id="9e860823-3dd0-4ceb-92f1-dd6b28e56547">
        <updating/>
        <source>updateBillsOfLadingTblFrmNotif(_theObject : CM_Object) updating, protected;

/*

Purpose:		Updates tblBOL when a Event_BOLAdd / Event_BOLUpdate notification is received	

Parameters:			

Return Value:		


Date		Who		Reason
11 Jan 2011	cnwmh5	Initial creation #26710
13 Dec 2012	PJS		PAR #30787

*/

vars
	bolCount : Integer;
	idx	: Integer;
	obj : CM_Object;
	bolDetail : CM_BOLDtl;
begin
	
	if _theObject.CM_BOLIn.myVoyage = self.myCurrentVoyage then
		if self.isBOLDetailMode then
		
		
			// the notificaton only knows about the affected BOL itself, and not the individual details so 
			// a bit limited in terms of options.... hence simplest approach is to simply relaod the table
		
			showBOLsForVoyage;		//30787
		
			/*
			foreach bolDetail in _theObject.CM_BOLIn.allBOLDtls do
				bolCount := bolCount + 1;
				if self.includeBOLDetails(bolDetail) then
					obj := bolDetail;
					self.addItemObjectToTable(obj, self.tblBOL);
				endif;
			endforeach;
			*/
			
		else
			if not self.tblBOL.findObjectInRow(_theObject.CM_BOLIn, idx) then
				obj := _theObject.CM_BOLIn;
				self.addItemObjectToTable(obj, self.tblBOL);
			endif;
		endif;
	endif;
	
	// handle first BOL being added this way
	if not self.hasBOLs then
		self.hasBOLs := (bolCount &gt; 0);
	endif;
	self.btnBOLSearch.enabled := self.hasBOLs;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="updateObject" id="0a93f3cd-1b24-44e0-b514-50f713489117">
        <updating/>
        <source>updateObject(_obj : CM_Object) updating, protected;

vars
	tmpTbl : CM_DataTable;
	oldBOLDetail : CM_BOLDtl;
	idx : Integer;
	handled : Boolean;
	
	ti : CM_TrackedItem;							//cnwmc5 - 13 May 2014 - PAR 34134
begin

	if (not self.allNotableObjects.includes(_obj)) then
		return;
	endif;
	
	if self.myCurrentVoyage = null then
		return;
	endif;

	if self.tblCargo.findObjectInRow(_obj, idx) then
		tmpTbl := self.tblCargo;
	elseif self.tblBOL.findObjectInRow(_obj, idx) then
		tmpTbl := self.tblBOL;
	elseif self.tblBOLItems.findObjectInRow(_obj, idx) then
		tmpTbl := self.tblBOLItems;
	elseif self.tblStowageItems.findObjectInRow(_obj, idx) then
		tmpTbl := self.tblStowageItems;
	endif;		

	if tmpTbl = null then
		return;
	endif;
	
//	handle tracked item change of voyage, BOL, ...
	if _obj.isKindOf(CM_TrackedItem) then
		ti := _obj.CM_TrackedItem;					//cnwmc5 - 13 May 2014 - PAR 34134
		if self.myCurrentVoyage &lt;&gt; null and
		   ti.myVoyage &lt;&gt; self.myCurrentVoyage then	//cnwmc5 - 13 May 2014 - PAR 34134
			tmpTbl.removeItem(idx);
			handled := true;
		elseif self.myCurrentBOLDetail &lt;&gt; null and
		   ti.myBOLDtl &lt;&gt; self.myCurrentBOLDetail and	//cnwmc5 - 13 May 2014 - PAR 34134
		   tmpTbl = tblBOLItems then		// don't remove from tblCargo after unlink
			tmpTbl.removeItem(idx);
			oldBOLDetail := ti.myBOLDtl;			//cnwmc5 - 13 May 2014 - PAR 34134
			handled := true;
		endif;
		if ti.isChild then
			self.updateObject(ti.myParent);			//cnwmc5 - 13 May 2014 - PAR 34134
		endif;
	endif;
	
	if _obj.isKindOf(CM_BOLIn) then					//cnwmc5 - 13 May 2014 - PAR 34134
		self.updateBOLCargo(_obj.CM_BOLIn);			//cnwmc5 - 13 May 2014 - PAR 34134
	endif;											//cnwmc5 - 13 May 2014 - PAR 34134

	if not handled then
		tmpTbl.accessCell(idx, 1).text := _obj.getAttributeStringForDefArray(tmpTbl.allTblDataEntRows);
	endif;	
	// for a TrackedItem in the BOL item list, refresh the associated BOL detail table line in case the quantity or number of items has changed
	if tmpTbl = self.tblBOLItems then
		self.refreshBOLDetailEntry(oldBOLDetail);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="updateTableColumnFilters" id="a92eb3b7-ad0f-4f15-8279-a2c6afedefb2">
        <updating/>
        <source>updateTableColumnFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2014	cnwmc5	Initial creation		PAR 34074

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	self.allColumnFilters.replaceAllFiltersForTable( _table, _allFilterColumns );

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict"/>
    </JadeMethod>
