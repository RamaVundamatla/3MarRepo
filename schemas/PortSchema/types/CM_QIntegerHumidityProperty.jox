<Class name="CM_QIntegerHumidityProperty" id="d668c447-3471-44a4-9962-223512250068">
    <superclass name="CM_QIntegerProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="displayNull" id="5f141159-5a80-404d-9682-1fc50b9ec05f">
        <methodInvocation>mapping</methodInvocation>
        <source>displayNull(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	07 May 2009 cnwjo3
//----------------------------------------------------------------
begin
	_value := true;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="c4634dc7-3ca6-40cb-b105-deab570c3395">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     07 May 2009 cnwjo3
//
vars

begin
	if _value.Decimal &lt;&gt; NULL_HUMIDITY then
		return _value.String;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
