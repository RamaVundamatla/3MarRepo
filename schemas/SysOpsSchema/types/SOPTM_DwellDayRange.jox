    <JadeMethod name="setupThumbnailDetails" id="9eb11c5a-646f-47d7-a3dc-ebab4036ee10">
        <updating/>
        <source>setupThumbnailDetails() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars
	theForm : SOP_TableMaintForm;
	percentColumn : Integer;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_WeightRangeTbl);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_WeightRangeMain);
	theForm.tblInput1.hideRowByName( ETRow_Percentage, false );
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);
	
	//18 Oct 2013	NDL	Par 32629	
	percentColumn := theForm.tblData.getColumnByRowName(ETRow_Percentage);
	if percentColumn &gt; theForm.tblData.fixedColumns and percentColumn &lt;= theForm.tblData.columns then
		theForm.tblData.accessColumn(percentColumn).visible := false;
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="0422d4f5-b1bf-4104-93b4-be4f8e9585d7">
        <updating/>
        <source>showThumbnail( pDwellDayRange: CM_DwellDayRange ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Colour, pDwellDayRange.colour);
	theForm.tblInput1.setValueByName(ETRow_Lower, pDwellDayRange.lower);
	theForm.tblInput1.setValueByName(ETRow_Upper, pDwellDayRange.upper);

epilog

end;</source>
        <Parameter name="pDwellDayRange" type="CM_DwellDayRange"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="ffb2f9de-2b90-48dd-a1ff-59ef8a32478e">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars
	dwellDayRange :	CM_DwellDayRange;
	cell : JadeTableCell;
begin

	dwellDayRange := _obj.CM_DwellDayRange;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := dwellDayRange.colour;
		endif;
	endif;

	epilog
	
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
