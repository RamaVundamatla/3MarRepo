    <JadeMethod name="handleBtnOne" id="fb4c370c-e59d-4b6c-ab1e-57e80371e8d5">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	inheritMethod();

	if self.myMobileGenericAgent.myTruck &lt;&gt; null then

		self.gotoForm( MOB_HHTruckUnloaderAllCargo, false );
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="725ef9c9-6c09-45d6-90ed-89e129143608">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014436, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
