        <Parameter name="_isSystemDetail" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setReportWebPages" id="2821790e-469e-41e2-add2-b9955b3cbc6a">
        <updating/>
        <source>setReportWebPages() updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDef				: EntTableDef;
	tmpGroup			: EntTableGroup;
	tmpRow				: EntTableRow;
	tmpAttr,
	tmpDependOn			: String;
	thisPageRows		: StringArray;
	tmpPage				: CM_QryReportWebPage;
	hasAddedTerminal	: Boolean;

begin

	tmpDef := self.getETDef();
	self.allQryReportWebPages.purge();
	if tmpDef = null then
		// this is ok as selector reports do not have this *** NEED TO DO SOMETHING DIFFERENT ***
		//app.raiseUnexpectedProgramError(class.name, method.name, 'No EntTableDef found for ' &amp; self.String);
		return;
	endif;
	tmpGroup := tmpDef.myEntTableGroup;
	if tmpGroup = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No EntTableGroup for def ' &amp; tmpDef.String);
		return;
	endif;
	
	create thisPageRows transient;
	
	foreach tmpAttr in self.allVisibleRows do
		tmpRow := tmpGroup.allEntTableRowsByName[tmpAttr];
		if tmpRow = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableRow (' &amp; tmpAttr &amp; ') not found in group (' &amp; tmpGroup.name &amp; ')');
			return;
		endif;
		
		foreach tmpDependOn in tmpRow.allDependencies do
			if (tmpDependOn = ETRow_Terminal and not hasAddedTerminal) then
				hasAddedTerminal := true;
			elseif thisPageRows.includes(tmpDependOn) then
			else
				continue;
			endif;
			// need a new page
			create tmpPage persistent;
			tmpPage.setForCreate(thisPageRows, self);
			thisPageRows.clear();
		endforeach;
		
		thisPageRows.add(tmpRow.name);	
	endforeach;


	if (not thisPageRows.isEmpty) then
		create tmpPage persistent;
		tmpPage.setForCreate(thisPageRows, self);
	endif;
	
	if self.allQryReportWebPages.isEmpty then
	// if no web page added add a blank one as needed for report to run with web (allows user to select terminal for report)
	// if no page then teminal choice is not loaded and report wont run  // HJG 26/04/05
		create tmpPage persistent;
		thisPageRows.clear();
		tmpPage.setForCreate(thisPageRows, self);
	endif;
		
epilog
	delete thisPageRows;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setUserReportProxy" id="a9cf41eb-aa89-4092-817c-a8823356274f">
        <updating/>
        <source>setUserReportProxy(_reportName,
					_reportDesc 		: String; 
					_reportType 		: Integer;
					_viewName			: String;
					_viewRows,
					_visibleRows,
					_jrwReports,
					_jrwProfiles 		: StringArray;
					_reportProcessType	: Integer;
					_selectorEnabled 	: Boolean;
					_reportAvailability	: Integer;
					_allFormats			: IntegerArray;
					_menuUserQuery : CM_MenuUserQuery) updating;
/// ---------------------------------------------------------------------------
// Created:     03 December 2002		cnwth2	
//
// Purpose:     MenuUserQuery is a user created selector query pased in for reports
//				of ReportType_Selector
// ----------   ----------  --------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.heading				:= _reportName;
	self.reportName 			:= _reportName;
	self.reportDescription		:= _reportDesc;
	self.reportType				:= _reportType;
	self.jrwViewName			:= _viewName;
	self.isSelectorAvailable 	:= _selectorEnabled;
	self.reportAvailability		:= _reportAvailability;
//	self.canBeRunInBackground	:= _canBeRunInBackground;
	self.reportProcessType		:= _reportProcessType;
	
	self.viewRows.clear;
	_viewRows.copy(self.viewRows);
	
	self.allVisibleRows.clear;
	_visibleRows.copy(self.allVisibleRows);
	
	self.jrwReportName.clear;
	_jrwReports.copy(self.jrwReportName);

	self.jrwReportProfileName.clear;
	_jrwProfiles.copy(self.jrwReportProfileName);
	
	self.reportFormats.clear();
	_allFormats.copy(self.reportFormats);

	if self.reportType = self.ReportType_Selector then
		self.mySelectorQuery := _menuUserQuery;
	endif;
	
	//this call will enable us to create a proxy myFilterObject of the correct class
	self.assignFilterClassName();
end;</source>
        <Parameter name="_reportName" type="String"/>
        <Parameter name="_reportDesc" type="String"/>
        <Parameter name="_reportType" type="Integer"/>
        <Parameter name="_viewName" type="String"/>
        <Parameter name="_viewRows" type="StringArray"/>
        <Parameter name="_visibleRows" type="StringArray"/>
        <Parameter name="_jrwReports" type="StringArray"/>
        <Parameter name="_jrwProfiles" type="StringArray"/>
        <Parameter name="_reportProcessType" type="Integer"/>
        <Parameter name="_selectorEnabled" type="Boolean"/>
        <Parameter name="_reportAvailability" type="Integer"/>
        <Parameter name="_allFormats" type="IntegerArray"/>
        <Parameter name="_menuUserQuery" type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f812d58c-34fc-482d-96fc-236b043e8cad">
        <source>validateForCreate();
// -----------------------------------------------------------------------------
// Created:		17 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	report			: CM_QryReport;
begin
	//26/08/2011 CNWDZ2 27635
	report := app.myRoot.getQryReport(self.reportName);
	if report &lt;&gt; null then
		app.raiseCMException1(Report_Name_Exists, self.reportName, null,  null);
	endif;
		
	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="527adc9c-16ce-40f5-af3d-512ed2e9ff6f">
        <source>validateForUpdate();
// -----------------------------------------------------------------------------
// Created:		17 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
