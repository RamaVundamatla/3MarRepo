    <JadeMethod name="getExtraInfo" id="36d91713-669f-4b2e-9ea8-6be225896d63">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	block : CM_DataContainerBlock;
	tmpTS : TimeStamp;

begin
	inheritMethod(_dataContainer);
	
	if self.myWorkOrderToUpdate &lt;&gt; null then 
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Work_order_update), DC_Label, 1, null);
		block.addNewItem(self.myWorkOrderToUpdate.getDisplayString() , DC_Data, 1, null);
	endif;
	if self.occursOnDT.isValid() then 
		tmpTS := self.systemToLocalTime(self.getOccursDT); // PEL UAT WP testing 30SEP18
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Occurs_datetime), DC_Label, 1, null);
		block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null);
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
