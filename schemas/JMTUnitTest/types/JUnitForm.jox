        <updating/>
        <source>fldTestResults_sheetChg(folder: Folder input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwndl1	Initial creation

*/

vars

begin

	self.btnInspect.enabled := self.fldTestResults.topSheet = self.shtDetails;
	if self.fldTestResults.topSheet = self.shtDetails then
		self.showTestDetails();
		
