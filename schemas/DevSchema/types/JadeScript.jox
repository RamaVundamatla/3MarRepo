    <JadeMethod name="rh_searchGlobalConstant" id="ee4e7e3f-d945-46d2-85ff-2e84e6a9ff5f">
        <source>rh_searchGlobalConstant();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 December 2017	jlgrh7	Initial creation

*/

vars
allConstants : ConstantNDict;
theConstant : Constant;
theCategory : ConstantCategory;
categoryName : String;
lookFor : String;
startTime : Integer;

begin
startTime := app.clock();
lookFor := "114";
write "Searching for " &amp; lookFor &amp; "...";

foreach theCategory in ConstantCategory.instances do
allConstants := theCategory.getConstants();

foreach theConstant in allConstants do
if theConstant.getSource = lookFor then
write "Category: " &amp; theCategory.name &amp; ", Constant: " &amp; theConstant.name &amp; " = " &amp; theConstant.getSource();
break;
endif;
endforeach;
endforeach;
epilog
write "Search completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
