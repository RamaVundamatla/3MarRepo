    <JadeMethod name="initSelectedFeatures" id="c357345b-5070-4818-afb7-e4a8435dbd70">
        <source>initSelectedFeatures(_allFeatures:CM_DataDumpFeatureArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 April 2010	#cnwdz2	 24641

*/
vars
	idx : Integer;
	lineStr : String;
	feature : CM_DataDumpFeature;
	
	rowPointer	: Integer;
	startRow	: Integer;
	maxRow		: Integer;
	itemObj     : CM_DataDumpFeature;
	
	sqlType,
	sqlTypeLength,
	sqlTypes :String;
	isMaxLength : Boolean;
	scaleFactor : String;
	extractClass : CM_DataDumpExtractClass;
	realSQLColumn: CM_DataDumpSQLColumn;
	tmpNiceName,
	defaultValue : String;
begin
	rowPointer	:=	self.tblExtFeatures.fixedRows + 1;
	while true do
		if rowPointer &gt; self.tblExtFeatures.rows then
			break;
		endif;
		
		itemObj := self.tblExtFeatures.accessRow(rowPointer).itemObject.CM_DataDumpFeature;
		if _allFeatures.includes(itemObj) then
			_allFeatures.remove(itemObj);
			rowPointer := rowPointer + 1;
		else
			self.tblExtFeatures.removeItem(rowPointer);
		endif;
	endwhile;

	foreach feature in _allFeatures do		
		sqlTypes := feature.getSQLTypes(self.myDelegate.getOIDFormat(),self.sqlVersion,defaultValue);
		sqlType := null;
		sqlTypeLength := null;
		isMaxLength := false;
		scaleFactor := null;
		if sqlTypes &lt;&gt; null then
			if sqlTypes.containsOneOf(Tab) then
				sqlType := defaultValue;
			else
				sqlType := sqlTypes;
			endif;
			sqlTypeLength := feature.getSQLTypeLengthDesc(sqlType, isMaxLength,scaleFactor);	
		endif;	
		
		if feature.featureNiceName &lt;&gt; null then
			tmpNiceName := feature.featureNiceName;
		else
			tmpNiceName := feature.featureName;
		endif;
		
		lineStr := 	feature.featureName &amp; Tab &amp; 
					feature.getFeatureTypeName() &amp; Tab &amp; "" &amp; Tab &amp;
					//feature.featureName &amp; Tab &amp; 
					tmpNiceName &amp; Tab &amp;
					sqlType &amp; Tab &amp; isMaxLength.cnEcGetTableCheckBoxValue() &amp; Tab &amp; sqlTypeLength &amp; Tab &amp; scaleFactor;

		idx := self.tblExtFeatures.addItem(lineStr);
		self.tblExtFeatures.accessRow(idx).itemObject := feature;
		self.tblExtFeatures.colourRows(self.colorRow1, self.colorRow2);			
	endforeach;
epilog

end;</source>
        <Parameter name="_allFeatures" type="CM_DataDumpFeatureArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initTblExtFeatures" id="05374c87-09de-48d3-9a00-f13dbb9638a9">
        <source>initTblExtFeatures();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 April 2010	#cnwdz2	 24641

*/

vars
	entTableDef		: EntTableDef;
	pxyExtractClass : CM_DataDumpExtractClass;
begin
	self.tblExtFeatures.rows := self.tblExtFeatures.fixedRows;
	self.tblExtFeatures.fixedColumns := 0;
	self.tblExtFeatures.leftColumn := 1;
	entTableDef := app.myController.getEntTableDef(ETDef_ExtractFeature_SQLNative);
	self.tblExtFeatures.setTblDataEntRowsFromDef(entTableDef);
	
	self.tblExtFeatures.selectionType := CM_EntryTable.SelectionType_Row;
	self.tblExtFeatures.multiSelect := CM_DataTable.MultiSelect_Simple;
	
	self.tblExtFeatures.userInputEnabled := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadFeaturesForExtractClass" id="2bad081d-6a3a-47a1-80ef-0fbcf7389bc8">
        <source>loadFeaturesForExtractClass(_extracClass : CM_DataDumpExtractClass);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	#cnwdz2	 24641

*/

vars
	sqlColumn : CM_DataDumpSQLColumn;
	feature : CM_DataDumpFeature;
	lineStr : String;
	idx : Integer;
	sqlTypeLength : String;
	sqlDecimalDigits : String;
	sqlColumnPos  : String;
begin
	foreach sqlColumn in _extracClass.allDataDumpSQLColumns do	
		feature := sqlColumn.myDataDumpFeature;
		if sqlColumn.length &gt; 0 then
			sqlTypeLength := sqlColumn.length.String;
		elseif sqlColumn.isMaximumLength then
			sqlTypeLength := CM_DataDumpFeature.SQLTypeLength_Max;
		else
			sqlTypeLength := null;
		endif;
		
		if sqlColumn.decimalDigits &gt; 0 then
			sqlDecimalDigits := sqlColumn.decimalDigits.String;
		else
			sqlDecimalDigits := null;
		endif;
		
		if sqlColumn.sqlColumnOrdinalPosition &gt; 0 then
			sqlColumnPos := sqlColumn.sqlColumnOrdinalPosition.String;
		else
			sqlColumnPos := null;
		endif;
		lineStr := 	feature.featureName &amp; Tab &amp; 
					feature.getFeatureTypeName() &amp; Tab &amp; sqlColumnPos &amp; Tab &amp;
					sqlColumn.name &amp; Tab &amp; 
					sqlColumn.myDataDumpSQLDataType.name &amp; Tab &amp; sqlColumn.isMaximumLength.cnEcGetTableCheckBoxValue() &amp; Tab &amp; sqlTypeLength &amp; Tab &amp; sqlDecimalDigits;

		idx := self.tblExtFeatures.addItem(lineStr);
		self.tblExtFeatures.accessRow(idx).itemObject := feature;
		self.tblExtFeatures.colourRows(self.colorRow1, self.colorRow2);			
	endforeach;
epilog

end;</source>
        <Parameter name="_extracClass" type="CM_DataDumpExtractClass"/>
    </JadeMethod>
    <JadeMethod name="openFeatureSelectForm" id="f1561033-012c-4359-83ff-4427f9c8f7bd">
        <updating/>
        <source>openFeatureSelectForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	#cnwdz2	 24641

*/

vars
	featureSelectForm : SOP_FeatureSelectForm;
	rowPointer	: Integer;
	startRow	: Integer;
	maxRow		: Integer;
	feature     : CM_DataDumpFeature;
	
	columnPosArray : IntegerArray;
	sqlColNamearray : HugeStringArray; //25/06/2010 cnwdz2 24504
	
	proxySQLColumn: CM_DataDumpSQLColumn;
	dataDumpClass : CM_DataDumpClass;
	
	prof		: JadeProfiler;
	now			: TimeStamp;
begin	
	if process.isMPD then
		prof := process.profiler;
		prof.methodCount := 200;
		prof.fileName := "JadeProfiler_" &amp; class.name &amp; "_" &amp; method.name &amp; "_" &amp; now.fileNameFormat &amp; ".log";
		prof.start;
	endif;
	
	if self.mode = self.Mode_Add then
		dataDumpClass := self.cmbJadeClass.listObject.CM_DataDumpClass;
		if dataDumpClass = null then
			app.msgBox(app.getErrorString(ERR_NullJADEClass), app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	featureSelectForm := app.loadForm(SOP_FeatureSelectForm, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							self.myMasterMenuAction).SOP_FeatureSelectForm;	
	if featureSelectForm = null then
		return;
	endif;
	featureSelectForm.myDataDumpExtractClass := self.myProxyObject.CM_DataDumpExtractClass;
	
	create columnPosArray transient;
	create sqlColNamearray transient;
	startRow	:=	self.tblExtFeatures.fixedRows + 1;
	maxRow		:=	self.tblExtFeatures.rows;
	featureSelectForm.myDataDumpExtractClass.allDataDumpFeatures.clear();
	foreach rowPointer in startRow to maxRow do
		feature	:=	self.tblExtFeatures.accessRow(rowPointer).itemObject.CM_DataDumpFeature;
		if feature &lt;&gt; null then
			featureSelectForm.myDataDumpExtractClass.allDataDumpFeatures.add(feature);
		endif;
		self.createSQLColumnPxyFromRow(feature, false, rowPointer, columnPosArray, sqlColNamearray, null, null, proxySQLColumn);
	endforeach;
	
	featureSelectForm.myDataDumpClass := dataDumpClass;
	featureSelectForm.myDelegate := self;
	
	if prof &lt;&gt; null then
		prof.report();
	endif;
	
	featureSelectForm.showModal();	
epilog
	delete columnPosArray;
	delete sqlColNamearray;
	
	if prof &lt;&gt; null and prof.isProfiling then
		prof.report();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetExtractClassCollations" id="3117856c-315c-428a-b981-fb2d966befbe">
        <source>resetExtractClassCollations(_extractClass:CM_DataDumpExtractClass input);

/*

Purpose:			

Parameters:			

Return Value:		


