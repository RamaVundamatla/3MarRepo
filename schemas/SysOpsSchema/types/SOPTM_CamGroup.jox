end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="45165f4a-2f19-44f0-a79a-ca82c9641de4">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 june 2008 concms1		par 17268 - CAMs messages by greight forwarder
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CamGroupTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CamGroupMaint);
	theForm.shtTblInput1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="4c9d40b4-c080-4194-a759-252fc34e1762">
        <updating/>
        <source>showThumbnail(pCamGroup: CM_CamGroup) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 June 2008 concms1		par 17268 - CAMs message by freight forwarder
// ---------------------------------------------------------------------------
vars

	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pCamGroup.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pCamGroup.description);
	theForm.tblInput1.setValueByName(ETRow_Recipient,	pCamGroup.recipient);
	theForm.tblInput1.setValueByName(ETRow_SenderCode,	pCamGroup.senderCode);
	theForm.tblInput1.setValueByName(ETRow_ShippersCode,	pCamGroup.shippersCode);
	theForm.tblInput1.setValueByName(ETRow_SenderCodeDepot,	pCamGroup.senderCodeDepot);
	theForm.tblInput1.setValueByName(ETRow_FacilityCode,	pCamGroup.facilityCode);
	theForm.tblInput1.setValueByName(ETRow_UseCallSign,	pCamGroup.useCallSign);
	theForm.tblInput1.setValueByName(ETRow_UseDailyFileName, pCamGroup.useDailyFileName);
//	theForm.tblInput1.setValueByName(ETRow_UseVoyageOperator, pCamGroup.useVoyageOperator);
	theForm.tblInput1.setValueByName(ETRow_MaxSealLength, pCamGroup.maxSealLength);
	
	theForm.mulSelect1.setSelected(pCamGroup.operators);
	theForm.mulSelect2.setSelected(pCamGroup.allFreightForwarders);	// par 17268
end;</source>
        <Parameter name="pCamGroup" type="CM_CamGroup"/>
    </JadeMethod>
</Class>
