    <JadeMethod name="getVesselName" id="f7f39ae1-5b9e-4404-87a0-7d174bfb0060">
        <source>getVesselName() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 April 2025		jlizm1	Initial creation MTN 34568 PEN Expose vessel fields to event stream

*/

vars
	tmpVoyage : CM_Voyage;
	tmpVessel : CM_Vessel;
	
begin
	tmpVoyage := self.getVoyage;
	if tmpVoyage = null then
		return null;
	endif;
	
	tmpVessel := tmpVoyage.getMyVessel;
