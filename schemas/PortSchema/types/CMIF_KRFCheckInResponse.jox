<Class name="CMIF_KRFCheckInResponse" id="7c50b4ff-0568-47ab-a891-89033dacc499">
    <superclass name="CMIF_KRFWSResponse"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>TFS 40360</text>
    <DbClassMap file="backgroundprocess"/>
    <CompAttribute name="messages" id="6ba1b8d2-4ffa-44ec-b3be-51875573c0a6">
        <type name="StringArray512"/>
        <access>readonly</access>
        <text>TFS 40360</text>
    </CompAttribute>
    <PrimAttribute name="status" id="e993d3b8-ebbf-466f-bede-2e54e830ee03">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
