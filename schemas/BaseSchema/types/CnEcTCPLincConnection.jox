    <JadeMethod name="advertiseConnectionClose" id="edc68263-b12a-4292-81b6-f0dcef26f99a">
        <updating/>
        <source>advertiseConnectionClose()updating;

begin
	if myLincSystemDef.diagnosticLogOptions[2] then
    	writeLogFile("Connection Closed", null);
    endif;

  	self.processState := HCS_Closed;
	myLincSystemDef.createConnectionEvent(HCS_Connection_State_Change, self.processState);
	myLincSystemDef.createConnectionEvent (HCS_Connection_Event, HCS_Closed);
end;</source>
    </JadeMethod>
    <JadeMethod name="buildNOFString" id="faebb93b-8388-4539-9b77-0da5cbdda855">
        <source>buildNOFString( dataIn : String; dialog : Integer; messageType : String): String;
/*******************************************************
*
* Description : Build string including a 'NOF' header to go to the NOF
* 				program
*
* Parameters :	DataIn - string of ispec data to be sent
*				dialog  - psuedo station id
*				messageType - type of request being sent
*
* Return :		None
*
* History :		pjs	27/02/97	Initial version
*
*******************************************************/

vars
	intDataLength	: Integer;
	strHeader		: String;

begin
	// need to include the header length (includes STX ) and also 
	// an additional character for the ETX

	intDataLength := dataIn.length + NOF_Header_Length + 1 ;

	// now set up the header

	strHeader[1:1] := STX;
	strHeader[2:4] := self.integerToString(intDataLength,4);
	strHeader[6:2] := self.integerToString(Protocol_Version,2);
	strHeader[8:6] :=  myLincSystemDef.applicationId;   
	strHeader[14:4] := self.integerToString(dialog,4);
	strHeader[18:2] := messageType;

	return strHeader &amp; dataIn &amp; ETX;
end;</source>
        <Parameter name="dataIn" type="String"/>
        <Parameter name="dialog" type="Integer"/>
        <Parameter name="messageType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkForMessage" id="cd009602-a0f8-425f-a093-efc4a8a6831a">
        <updating/>
        <source>checkForMessage() : String updating;
/*******************************************************
*
* Description : check to see if we have a valid message
*
* Parameters :	None
*
* Return :		message string (or null if there is no valid message)
*
* History :		pjs	26/02/97	Initial version
*
*******************************************************/

vars
	blnCheckForETX	:	 Boolean;
	blnCheckForMessage : Boolean;
	blnCheckForSTX 	: Boolean;

	strMessage		: String;
	strHoldBuffer	: String;
	intETXpos		: Integer;
	intSTXpos		: Integer;	
	intMsgLength	: Integer;	

begin
    blnCheckForMessage := true;

	while blnCheckForMessage do
		blnCheckForSTX := true;

		while blnCheckForSTX do

        	// find out where the first STX is in the buffer

        	intSTXpos := self.readBuffer.pos(STX,1);

			// if there is no STX then hop out of here       	

        	if intSTXpos =  0 then

        		// we have no STX, but presumably, we have data	
        		// we wont let this build up indefinitely 

        		if readBuffer.length &gt; 2000 then 
        			if myLincSystemDef.diagnosticLogOptions[8] then
    					writeLogFile("Data received before STX", self.readBuffer[1:readBuffer.length]);
   					endif;

					self.readBuffer := null;
				endif;  // of readBuffer &gt; 2000

        		return null;
      		elseif intSTXpos =  1 then
      			break;   // we have found our STX
      		else 

      			// this means that there is data here before the STX
      			// so we will log and drop this data

				if myLincSystemDef.diagnosticLogOptions[8] then
    				writeLogFile("Data received before STX", self.readBuffer[1:(intSTXpos -1)]);
   				endif;

				strHoldBuffer := self.readBuffer[intSTXpos : end];
				self.readBuffer := strHoldBuffer;
				break;

			endif;
		endwhile; // of checking for an STX

		// so now we have an STX .....if this is the only character then its not worth
		// doing any more 

		if self.readBuffer.length &lt; 2 then 
			return null;
		endif;

		blnCheckForETX  := true;

		while blnCheckForETX do
			intETXpos := self.readBuffer.pos(ETX,1);
			intSTXpos := self.readBuffer.pos(STX,2);  	// skip over the first one 

			// check here to see if we have another STX  (before the ETX if one exists)

			if ( (intETXpos &lt;&gt; 0) and ((intSTXpos &lt;&gt; 0) and (intSTXpos &lt; intETXpos)) )
			or ( (intETXpos = 0) and (intSTXpos &lt;&gt; 0))     then

				// we have another STX  ... we need to log, drop and start again

				if myLincSystemDef.diagnosticLogOptions[8] then
   					writeLogFile("STX with no ETX", self.readBuffer[1:(intSTXpos -1)]);
   				endif;

				strHoldBuffer := self.readBuffer[intSTXpos : end];
				self.readBuffer := strHoldBuffer;
				break;

			endif;  // of having another STX  

            // if we have an ETX then we have a 'message' as such .... otherwise
            // we have nothing more than the original STX... so we return with 
            // no message 

			if intETXpos  = 0 then 
				return null;
			else

				// we have a message as such

				strMessage := self.readBuffer[1:intETXpos];

				if self.readBuffer.length &gt; intETXpos then
					strHoldBuffer := self.readBuffer[(intETXpos + 1) : end];
					self.readBuffer := strHoldBuffer;
				else
					self.readBuffer := null;
					blnCheckForMessage := false;  // no point checking any more if there is a problem
				endif;                           // with this message

				if strMessage.length &lt; 6 then 
					// we dont even have enough here for a valid message length

					if myLincSystemDef.diagnosticLogOptions[8] then
   						writeLogFile("Message too short to include header", strMessage);
   					endif;

					break; // so we can start again looking for another message
   				endif;

   				// now check to see that the data length matches that in the header


   				if strMessage.length &lt;&gt; strMessage[2:4].Integer  then 

					if myLincSystemDef.diagnosticLogOptions[8] then
   						writeLogFile("Length doesnt match header Length", strMessage);
   						strMessage := null;
   					endif;

					break; // so we can start again looking for another message
   				endif;
   					// okay  ... so we have a valid length message .......so lets return this
       				// 

       				return strMessage;

			endif; // of having an ETX

		endwhile;  // of checking for an ETX 
	endwhile;	// of checking for a message

	// if we are here then we havent had a valid message and there is no more
	// data to process

	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearAllDialogs" id="ccd46ee4-32c5-47d0-8e84-a307e75e907d">
        <updating/>
        <source>clearAllDialogs() updating;

begin
	// simply clear all the dialogs by removing all entrys from the arrays.

 	logonState.clear();
 	lincHeader.clear();
 	queueItemSent.clear();
 	queueItemSentStartTime.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="clearAllStats" id="705ac96d-cd06-4c12-b4d9-606fb7be5100">
        <updating/>
        <source>clearAllStats() updating;

begin
	newBatch := 0;
	batchStartTime := 0;
	batchEndTime := 0;
	ispecsSent := 0;
	ispecsCompleted := 0;
	batchItemsProcessed := 0;
	lostConnection := 0;
	msgsReceived := 0;
	packetsReceived := 0;
	timeOuts := 0;
	responseTime := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="closeConnection" id="7356408b-70e9-4553-8504-f08032de626a">
        <updating/>
        <source>closeConnection() updating;

begin
	if self.state &lt;&gt; Connection.Disconnected then
 		self.closeAsynch(self, "closeReturn");
        return; 
    else
        self.advertiseConnectionClose;
    endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="closeReturn" id="a066db80-c7b1-460c-98e0-d2857ff6916e">
        <updating/>
        <source>closeReturn(connection : CnEcTCPLincConnection) updating;

begin
	// close has now been actioned

	advertiseConnectionClose;
end;</source>
        <Parameter name="connection" type="CnEcTCPLincConnection"/>
    </JadeMethod>
    <JadeMethod name="create" id="1d382e59-7b20-4283-8f50-e9048db06945">
        <updating/>
        <source>create() updating;

begin
	// arm  the global excpetion handler here

	on ConnectionException do globalExceptionHandler(exception) global;

	newBatch := 0;
	retryTimerSet	:=	false;

	create queueItemSent transient;
end;</source>
    </JadeMethod>
    <JadeMethod name="createNewDialog" id="c989e917-bc18-4a03-a4c2-562e505d95fe">
        <updating/>
        <source>createNewDialog( ) :Integer updating;

begin
 	// simply go through and make all the entries in the arrays for the new dialog being 
 	// created 

 	logonState.add(null);
 	lincHeader.add(null);
 	queueItemSent.add(null);
 	queueItemSentStartTime.add(null);

 	return logonState.size();
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="643954c5-576f-44a6-85a8-bf0990b182e4">
        <updating/>
        <source>delete() updating;

begin
	logFile.close();

	delete logFile;	

	endNotificationForSubscriber(self);  // ps 07/04/98	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteQueueItem" id="f61a31aa-4452-4057-946e-7296b8c2af29">
        <updating/>
        <source>deleteQueueItem(queuedItem : CnEcIspecToHost io) updating;

begin
 	// we must be able to delete any queued item  .... so we will 
 	// try continuously until we can get an appropriate lock on it.

 	while not tryLock(queuedItem, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) do
 		// wait 10 seconds and try again
 		// changed syntax as at per Jade 4.0

 		process.sleep(10000); 
 	endwhile; 

  	delete queuedItem;
end;</source>
        <Parameter name="queuedItem" type="CnEcIspecToHost" usage="io"/>
    </JadeMethod>
    <JadeMethod name="exceptionHandler" id="d11c87f2-b0da-454f-960b-d49baf321b96">
        <updating/>
        <source>exceptionHandler(exObj : Exception) : Integer updating;

vars
	intIndex : Integer;
	queueItem : CnEcIspecToHost;
	decResponse	: Decimal [7,3];

begin
	if myLincSystemDef.diagnosticLogOptions[8] then
  	 	writeLogFile("TCP Exception  ", (exObj.errorCode.String &amp; " - " &amp; exObj.text() ));
  	endif; 

	if myLincSystemDef.diagnosticLogOptions[2] then
    	writeLogFile(("Packets Received  = "  &amp; packetsReceived.String),null);
    	writeLogFile(("Messages Received = "  &amp; msgsReceived.String),null);
    	writeLogFile(("Ispecs Sent	     = "  &amp; ispecsSent.String),null);
    	writeLogFile(("Ispecs Completed  = "  &amp; ispecsCompleted.String),null);
    	decResponse := self.getAverageIspecResponse;
    	writeLogFile(("Avg HCS response  = "  &amp; decResponse.String &amp; " secs"),null);
   	endif;

	if self.processState =  HCS_Terminating then 
		// firstly close the connection
		lostConnection := lostConnection + 1;
		closeConnection;

      	return Ex_Abort_Action;
    else
     	// record the fact that we have lost connectivity

       	if self.processState = HCS_Processing then
      		lostConnection := lostConnection + 1;
      	endif;

		// if we've set the timer for retry then the connection will already be closed

		if self.retryTimerSet	&lt;&gt;	true	then
			closeConnection;

			// we need to retry the connection again - set the relevant attributes
			// and start the timer that will do this

			setupForRetry;
   		endif;

		return Ex_Abort_Action; 
	endif;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatAndReturnPing" id="d7edda9b-93c9-45f4-ae86-25a862ee906b">
        <updating/>
        <source>formatAndReturnPing(dataToHost : String; dialog : Integer) updating;

vars
	strReturnData	:	String;
	ispecdata		:	CnEcIspecToHost;
begin
	ispecdata		:= queueItemSent[dialog].CnEcIspecToHost;
	strReturnData	:= dataToHost &amp; " PING Response OK";

	if myLincSystemDef.diagnosticLogOptions[4] then

 		writeLogFile("PING data being returned from HCS", ispecdata.noformsData);
   	endif;
   	
	beginTransaction;
		ispecdata.setState(HCS_Sent_To_Host);  
	commitTransaction;

	if ispecdata.priority &lt;&gt; 0 then 
		allIspecsToSend.remove(ispecdata);
  	endif; 

  	queueItemSentStartTime[dialog] := app.clock();

	beginTransaction;
		ispecdata.notifyMyCreator(strReturnData);

		// need to remove from the timeout dictionary here

		if (ispecdata.timeoutValue &lt;&gt; 0)  and (not ispecdata.timeoutNotified) then 
			allLincQueueTimeouts.remove(ispecdata);
		endif;

		if ispecdata.deleteAfterReceivingResponse = true then
			deleteQueueItem(ispecdata);
		endif;
	commitTransaction;		

	queueItemSent[dialog] :=null;

	if processState = HCS_Processing then 
		processQueue;	
 	elseif processState = HCS_Terminating then 
 		// need to check and see whether or not there are still queue entries
 		// active out there 

 		if not stillProcessingQueueItems then 
 			closeConnection;
 		endif;
 	endif;
end;</source>
        <Parameter name="dataToHost" type="String"/>
        <Parameter name="dialog" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatIspecToHost" id="853f072c-026e-4957-a458-b34a6e4b4748">
        <updating/>
        <source>formatIspecToHost(ispecdata : CnEcIspecToHost; dialog:Integer) updating;

// setup the ispoec details to the host by inserting the ispec name into the held LINC header and 
// then firing that off through a WRITE ASYNC 

vars
	dataToHost	: String;

begin
	dataToHost:= ispecdata.noformsData;  

    // if this is the initial sending of data to kick things off then dont add the Linc header

	if logonState[dialog] = No_Data_Sent then 
		dataToHost[1:23] := "                    ";
	else
		dataToHost[1:23] := lincHeader[dialog];
 	endif;

	// and lastly the ispec from the queue record

	dataToHost[1:5] := ispecdata.ispec.toUpper;

	//  if we're doing a PING on HCS then a message is NOT to be written
	if dataToHost[1:5]	=	'*PNG1'	then
    	queueItemSent[dialog] := ispecdata;
  		formatAndReturnPing (dataToHost, dialog);
	elseif dataToHost[1:5]	=	'*PNG2'	then
  		queueItemSent[dialog] := ispecdata;
		writewithAsync(self.buildNOFString(dataToHost,dialog,Echo_Data), dialog);
	else
		queueItemSent[dialog] := ispecdata;
		writewithAsync(self.buildNOFString(dataToHost,dialog,Linc_Data), dialog);
	endif;
end;</source>
        <Parameter name="ispecdata" type="CnEcIspecToHost"/>
        <Parameter name="dialog" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAverageBatchResponse" id="46b2c6d5-57b7-44c7-ba08-89827c604b38">
        <source>getAverageBatchResponse() : Decimal;

vars
	dec :Decimal [15,3];		

begin
	// all the time values that we are holding are in milliseconds so 
	//  we convert this to a decinal value

	//	write "start of gett avg batch response";
	//	write ("start time=" &amp; batchStartTime.String &amp; "endtime=" &amp; batchEndTime.String &amp; "items=" &amp; batchItemsProcessed.String);
	if  (batchItemsProcessed &gt; 0) and
		    (batchEndTime &gt; 0)  then
		dec:= ( ( (batchEndTime - batchStartTime)/batchItemsProcessed) / 1000); 
		return dec;
	else
		return 0.0;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAverageIspecResponse" id="11fdabae-5d20-4c02-8743-949af33725e6">
        <source>getAverageIspecResponse() : Decimal ;
/*******************************************************
*
* Description : return the average time for completed transactions
*
* Parameters :	None
*
* Return :		Decimal Value
*
* History :		pjs	20/03/97	Initial version
*
*******************************************************/

vars
	dec :Decimal [15,3];		

begin
	// all the time values that we are holding are in milliseconds so 
	//  we convert this to a decinal value

	if ispecsCompleted &gt; 0 then
		dec:= ( (responseTime/ispecsCompleted) / 1000); 
		return dec;
	else
		return 0.0;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
