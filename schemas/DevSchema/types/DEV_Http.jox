<Class name="DEV_Http" id="9a595b9f-3306-4819-b152-e8aa0cb548eb">
    <superclass name="CnHttp"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="ebpCloseConnect" id="c8ce109e-3c98-43bb-a00f-ecded840c278">
        <updating/>
        <source>ebpCloseConnect() updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
	// for http connection to ebp
vars

begin
	emCloseHandle(requestHandle);
	requestHandle := null;

end;</source>
    </JadeMethod>
    <JadeMethod name="ebpPostConnect" id="6f639393-729e-434f-987c-6b92f304ab0e">
        <updating/>
        <source>ebpPostConnect(cmd : String; parms : Binary; headers : String):String updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
  	// allows http to Post large data block to a server
	// Connect to server already done, this allows POST to be reused for the same connection
	//	set up Post command
	// send and receive data
	// cmd = path for jadehttp.dll
	// parms = post data

vars
	result	: Integer;
	str		: String;
	bin		: Binary;
	outfile	: File;
	bytesRead : Integer;
//	cc		: CnCntrl;
	attributes : String;					// not applicable for HTTP
begin

	if connectionHandle = null then 
		return "CnHttp::cnGetFile : no current connection," ;
	else
    	result := emHttpOpenRequest(requestHandle, connectionHandle, "POST" , cmd, self.secure);		// prepare request
    	if result &lt;&gt; 0 then
    		return "CnHttp::cnGetFile failed : httpOpenRequest error : " &amp; cnGetInternetError(result);
    	endif;
    endif;


//  	result := emHttpSendRequestEX(requestHandle, headers, parms);												// send request
  	if result &lt;&gt; 0 then
    	return "CnHttp::cnGetFile failed : httpSendRequest error : " &amp; result.String &amp; ' '&amp; cnGetInternetError(result);
  	endif;

//   	result := emHttpQueryInfo(requestHandle, All_Info, str);

   	result := emHttpQueryInfo(requestHandle, Status_Code, str);
   	if result &lt;&gt; 0 then
   		return "CnHttp::cnGetFile failed : httpQueryInfo #1 error : " &amp; cnGetInternetError(result);
	elseif str &lt;&gt; "200" then																		// 200=OK
	   	result := emHttpQueryInfo(requestHandle, All_Info, str);
 	  	app.writeStatement('QueryInfo&gt;' &amp; str);
	   	result := emHttpQueryInfo(requestHandle, Status_Code, str);
		return "CnHttp::cnGetFile : file not found, status=" &amp; cnGetHttpQueryStatus(str);
   	endif;

	return ebpReceiveData;

epilog
//	emCloseHandle(requestHandle);
//	requestHandle := 0;
end;</source>
        <Parameter name="cmd" type="String"/>
        <Parameter name="parms" type="Binary"/>
        <Parameter name="headers" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="ebpReceiveData" id="34002436-dd8b-4cfb-9fb3-b2c102ea8cb0">
        <updating/>
        <source>ebpReceiveData():String updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
	// handle data returned from http post or get

vars
	result	: Integer;
	str		: String;
	bin		: Binary;
	outfile	: File;
	bytesRead : Integer;
//	cc		: CnCntrl;
	attributes : String;					// not applicable for HTTP

begin

	while true do // receive data until bytes read = 0
      	result := emInternetReadFile(requestHandle, bin, HTTP_Block_Size, bytesRead);
       	if result &lt;&gt; 0 then
       		return "CnHttp::cnGetFile failed read : " &amp; cnGetInternetError(result);

       	elseif bytesRead = 0 then
       		str := str &amp; bin.String;

			return str;
		else
       		str := str &amp; bin.String;

           	fileBytesTransferred 	:= fileBytesTransferred + bytesRead;
           	totalBytesTransferred	:= totalBytesTransferred + bytesRead;
        endif;

   	endwhile;



end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
