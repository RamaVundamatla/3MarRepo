    <JadeMethod name="setupComboList" id="6f53b295-6617-458f-a25a-0ab1d84fcbf3">
        <source>setupComboList();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2010	cnwndl1	Initial creation

*/

vars
	term : CM_Terminal;
	iter : Iterator;
	ta : CM_TerminalArea;
	index : Integer;
	point : Point;
begin

	cmbTA.clear();
	self.mapLocations.clear();
	
	term := app.myPassport.myTerminal;
	iter := term.allTerminalAreas.createIterator;
	while iter.next( ta ) do
		if not ta.isYardInterchangeArea then
			continue;
		endif;
		index := cmbTA.addItem( ta.id );
		cmbTA.itemObject[index] := ta;
	endwhile;
	
	foreach index in 1 to cmbTA.listCount do
		point.set(0,0);
		self.mapLocations.add( point );
	endforeach;
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
