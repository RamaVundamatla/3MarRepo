//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	loadList 	: SHP_LoadList;
	menuAction 	: CMUI_MenuAction;
begin
	menuAction := app.myController.createMenuAction(PmAdmLoadlistView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	loadList := menuAction.goToObject(null, null, false, null).SHP_LoadList;

	if loadList = null then
		return;
	endif;
	
	loadList.myCurrentVoyage := self.myCurrentVoyage;
	loadList.show();
	loadList.doQuery();
end;</source>
