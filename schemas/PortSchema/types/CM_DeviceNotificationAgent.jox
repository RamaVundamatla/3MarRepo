    <JadeMethod name="calculateCraneRates" id="08dd5a5a-804d-4b5b-a6de-8b0fffb516d6">
        <source>calculateCraneRates(controller : CMIF_KPIShipMove);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2013	cnwmc5	Initial creation

*/
vars
	crane 		: CM_Crane;
	js			: CM_VoyageJobSheet;
	now			: TimeStamp;
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	now := now.addMinutes(-10);
	
	js := controller.myJobSheet;
	crane := js.getMyCrane();
	
	if crane &lt;&gt; null then
		//app.createAlert("Crane " &amp; crane.CM_Crane.code &amp; ". Rate = " &amp; crane.CM_Crane.getCraneRate(js).String &amp; ". Target = " &amp; crane.CM_Crane.targetRatePH.String, true);
		if 	js.myVoyage.shipExchangeDate &lt;= now and
			crane.CM_Crane.getCraneRate(js) &gt; (crane.CM_Crane.targetRatePH + CRANE_THRESHOLD) or 
			crane.CM_Crane.getCraneRate(js) &lt; (crane.CM_Crane.targetRatePH - CRANE_THRESHOLD) then
				//self.sendNotificationToAll('Crane: ' &amp; crane.CM_Crane.code &amp; ' has an issue!', 'crane_' &amp; crane.CM_Crane.code &amp; '_issues');
		endif;
	endif;
epilog

end;</source>
        <Parameter name="controller" type="CMIF_KPIShipMove"/>
    </JadeMethod>
