    <JadeMethod name="canUserViewMyChildren" id="a6eb87f2-e248-4b96-a98a-1f4f98632ae3">
        <source>canUserViewMyChildren(_user: CM_User; _passport: CM_Passport; checkOperator: Boolean; checkConsignor: Boolean; checkConsignee: Boolean; checkCarrier: Boolean; checkCarrierRelease: Boolean; _dacFailedOn: CM_DataAccessController output): Boolean;
/*

Purpose:			

Parameters:		Check whether the user can access the onboard cargo, if they can, then the user can access me as well		

Return Value:		

Date		Who		Reason
22 May 2025	navsp1	Initial creation JIRA-34864 CUX | Data Access Groups for MAFIs and Trailers - Development

*/

vars
	locationController	: CM_LocationsController;
	trackedItem			: CM_TrackedItem;
begin
	foreach locationController in self.allLCs do
		foreach trackedItem in locationController.allTrackedItems do
			if trackedItem.canUserViewMe(_user, _passport, checkOperator, checkConsignor, checkConsignee, checkCarrier, checkCarrierRelease, _dacFailedOn) then
                return true;
            endif;
        endforeach;
    endforeach;
    return false;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="checkOperator" type="Boolean"/>
        <Parameter name="checkConsignor" type="Boolean"/>
        <Parameter name="checkConsignee" type="Boolean"/>
        <Parameter name="checkCarrier" type="Boolean"/>
        <Parameter name="checkCarrierRelease" type="Boolean"/>
        <Parameter name="_dacFailedOn" type="CM_DataAccessController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeState" id="c4e70133-e380-4ea2-a75b-36314bda9eea">
        <updating/>
        <source>changeState(newState: Integer; _passport: CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     09 May 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpLC	: CM_LocationsController;
	tmpTI	: CM_TrackedItem;
	control : CMIF_MoveController;
	allTIs  : CM_TIArray;
begin

	if not self.myTerminal.roadProcessIsASPA then //21 Oct 2020	NDL	TFS 49189
		//Not required in ASPA road process, as it is handled in CM_VehicleVisitRecord.departureProcess with the correct effective date.
	

		create control transient;
		create allTIs transient;	// TFS 39788 jlgmd1 10/10/18
		
		// Get all our 'child' TIs
		foreach tmpLC in self.allLCs do
			tmpLC.allTrackedItems.copy(allTIs);
		endforeach;
		
		// And tell them they are moving offsite
		foreach tmpTI in allTIs do
			if tmpTI.state &lt;&gt; newState then
				tmpTI.changeState(newState, _passport);
			
				//if moving offsite need to created transactions for the cargo on the chassis
				if newState = TI_STATE_OFFSITE then
					control.setIsUndoMove(false);
					control.setMoveMode(REAL_MODE);
					control.isForcedMove := true;
					control.setMyTrackedItem(tmpTI);
					tmpTI.createControlMoveTransactions(control,_passport);
					// Also change our locationId to null/offsite
					tmpTI.setMyLocations(control);	// TFS 39788 jlgmd1 10/10/18
				endif;
			endif;
		endforeach;
	
	endif;

	return inheritMethod(newState, _passport);

epilog
	delete control;
	delete allTIs;
end;</source>
        <Parameter name="newState" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeVoyage" id="cea2e635-ccb4-414e-a1cf-6a3c9f585575">
        <updating/>
        <source>changeVoyage(aVoyage: CM_Voyage; _passport: CM_Passport input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 12 June 2024
TFS#		: 64453
Function	:

*** Changes ***
Date			Name		TFS#		Description
02/07/2024		jlizm1		64940		VOL Cargo table not updating with mafi voyage update
24 July 24		jlier1 		65290 		- changed now done in updateMAFIForVoyageChange
****************************************************/
vars
	
begin
	inheritMethod(aVoyage, _passport);
	
		
	
epilog

end;</source>
        <Parameter name="aVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkStopsToBePrevented" id="858f1aa2-c588-4f2b-9ce2-d188055f13f2">
        <source>checkStopsToBePrevented(_stopType: Integer; _originalTI: CM_TrackedItem; _warningsAsErrors: Boolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 July 2024		jlizm1	Initial creation TFS 65083 Stops not enforced for onboard cargo	

*/

vars
	result 		: Boolean;
	onboardTis 	: CM_TISet;
	childTIs	: CM_TISet;
	ti			: CM_TrackedItem;
	child		: CM_TrackedItem;
	stop		: CM_Stops;
	stopTable 	: CM_StopsTable;
	allStops	: CM_StopsByIdDict;
	errWarnStr	: String;
	
begin
	result := inheritMethod(_stopType, _originalTI, _warningsAsErrors);
	
	if _warningsAsErrors then
		errWarnStr := app.getErrorString(Error) &amp; ": ";
	else
		errWarnStr := app.getErrorString(Warning) &amp; ": ";
	endif;
	
	create allStops transient;
	create onboardTis transient;
	create childTIs transient;
	self.getAllOnboardTIs(onboardTis);
	
	foreach ti in onboardTis discreteLock do
		ti.getAllActiveStops( allStops );
		foreach stop in allStops do
			stopTable := stop.myStopsTable;
			if stopTable = null
			or (not stopTable.isToBePrevented(_stopType, ti)) then
				continue;
			endif;
			result := true;
			if _warningsAsErrors then	
				app.raiseCMException3(Onboard_has_stop, errWarnStr, ti.id, stopTable.heading, "id", null);
			else
				app.raiseCMWarning3(Onboard_has_stop, errWarnStr, ti.id, stopTable.heading, "id", null, self);
			endif;
			stopTable := null;
		endforeach;
		
		if ti.myReceivalBOL &lt;&gt; null then
			foreach stop in ti.myReceivalBOL.allStops do
				stopTable := stop.myStopsTable;
				if stopTable = null
				or (not stopTable.isToBePreventedBOLStop(_stopType, ti.myReceivalBOL, ti.myTerminal)) then
					continue;
				endif;
				result := true;
				if _warningsAsErrors then	
					app.raiseCMException3(Onboard_has_stop, errWarnStr, ti.id, stopTable.heading, "id", null);
				else
					app.raiseCMWarning3(Onboard_has_stop, errWarnStr, ti.id, stopTable.heading, "id", null, self);
				endif;
				stopTable := null;
			endforeach;
		endif;	
		
		if not ti.hasChildren then
			continue;
		endif;
		
		childTIs.clear();
		ti.allChildren.copy(childTIs);
		
		foreach child in childTIs do
	
			child.getAllActiveStops( allStops );
			foreach stop in allStops do
				stopTable := stop.myStopsTable;
				if stopTable = null
				or (not stopTable.isToBePrevented(_stopType, child)) then
					continue;
				endif;
				result := true;
				if _warningsAsErrors then	
					app.raiseCMException3(CHILD_HAS_STOP, errWarnStr, child.id, stopTable.heading, "id", null);
				else
					app.raiseCMWarning3(CHILD_HAS_STOP, errWarnStr, child.id, stopTable.heading, "id", null, self);
				endif;
				stopTable := null;
			endforeach;
			
			if child.myReceivalBOL &lt;&gt; null then
				foreach stop in child.myReceivalBOL.allStops do
					stopTable := stop.myStopsTable;
					if stopTable = null
					or (not stopTable.isToBePreventedBOLStop(_stopType, child.myReceivalBOL, child.myTerminal)) then
						continue;
					endif;
					result := true;
					if _warningsAsErrors then	
						app.raiseCMException3(CHILD_HAS_STOP, errWarnStr, child.id, stopTable.heading, "id", null);
					else
						app.raiseCMWarning3(CHILD_HAS_STOP, errWarnStr, child.id, stopTable.heading, "id", null, self);
					endif;
					stopTable := null;
				endforeach;
			endif;
		endforeach;
		
	endforeach;
	
	return result;

epilog
	delete onboardTis;
	delete allStops;
	delete childTIs;
	
end;</source>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_originalTI" type="CM_TrackedItem"/>
        <Parameter name="_warningsAsErrors" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
