    <JadeMethod name="logLength" id="e57e7073-863e-43d2-93c1-5f0833d4db58">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>logLength(set: Boolean; _value: Decimal io) mapping, updating;
// -----------------------------------------------------------------------------
// Created:		18 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	newVal	: Integer;
	
begin
	if set then
		newVal := (_value * 100).Integer;
		exclusiveLock(self);
		if self.length &lt;&gt; newVal then
			self.length := newVal;
			self.recalcJASVolume();
		endif;
	else
		_value := (self.length / 100).roundedTo(2);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
