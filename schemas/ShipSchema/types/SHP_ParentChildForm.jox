    <JadeMethod name="initDetails" id="6e91b46d-0495-44cd-a735-e966e2e28eb0">
        <updating/>
        <source>initDetails(	_parent : CM_Object;
				_child : CM_Object;
				_mode : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	
begin
	self.mode:=_mode;
		
	self.loadParentCombo(_parent);
	self.initComboBoxes();
	
	self.doChangeParent(_parent,_child);
	
	
	self.doChangeMode(self.mode);
epilog

end;</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_child" type="CM_Object"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
