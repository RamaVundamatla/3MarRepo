<Class name="CMIF_TMCMoveGroup" id="84fcc6ab-76c0-44e2-847b-6668ba2a04a1">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myCommodityMap" id="68b94018-ebfa-4df5-b4ed-df8070c995f8">
        <embedded/>
        <type name="CM_CommodityMap"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myContentMap" id="ab811a6d-1c9b-4d05-b1b7-2a182b355ac8">
