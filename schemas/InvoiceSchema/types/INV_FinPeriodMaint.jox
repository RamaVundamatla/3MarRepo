    <JadeMethod name="doLstDataDblClick" id="17c0f0f0-8a4c-4022-b2cd-dd20fcd55c76">
        <updating/>
        <source>doLstDataDblClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
//	inheritMethod(listbox);		// cnwrl1 06/11/2009 PAR 19278 - what it was
	
	app.mousePointer	:=	Busy;
	// if the transaction map is already expanded then collapse it else expand it and child branches.
	if listbox.itemExpanded[ listbox.listIndex ] then
		listbox.itemExpanded[ listbox.listIndex ]	:= false;
	else
		listbox.cnEcExpandItem( listbox.listIndex, true );
	endif;
	
	self.doLstDataClick( listbox );
	
epilog
	app.mousePointer	:=	Idle;
	
end;</source>
