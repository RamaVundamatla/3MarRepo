    <JadeMethod name="makeMessages" id="59d79520-ff62-410c-b48c-7ca0a2211224">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
// 10 May 2011	cnwcs5	CCMS SCT 2058/par 27460 - user defined special characters
// 27/05/2016	cnwdap1	TFS #2061 BAPLIE/EDI VGM Updates
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
vars
	theTI : CM_TrackedItem;
	contentsStatus : String;
	isoCode : String;
	fIsoCode : String;
	includeVGM : Boolean;
begin
// UN
	theTI := _transaction.myTrackedItem;
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus,_camMessage.activity, _transaction.type);
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   theTI &lt;&gt; null and 
	   theTI.isWeightCertified and 
	   not theTI.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	// EQD segment
	if theTI.isKindOf(CM_Container) then //23/08/2017 cnwma1 TFS #5834
		isoCode := theTI.CM_Container.isoType;
		fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
		self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", theTI.id.trimRight, fIsoCode, '102', '5', null, self.imExStatusToString(theTI), contentsStatus); // par 27460 09/05/2011 cnwcs5 	//23/08/2017 cnwma1 TFS #5834
	else
		self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", theTI.id.trimRight, theTI.getISOType(), '102', '5', null, self.imExStatusToString(theTI), contentsStatus); //23/08/2017 cnwma1 TFS #5834
	endif;
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	// RFF+BN
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group3,  theTI);	// par 27460 cnwcs5

	// RFF+CN
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group3, theTI);	// par 27460 cnwcs

	// RFF+ABT- CCMS 1220 //CCMS 1755 cnwrs1 Sept 2008
	self.makeMessageRFF_ABT (_camProtocol, _camMessage.group3,  _camMessage.activity, theTI);	// par 27460 cnwcs5

	// DTM - transaction date/time
	//epr par 37551 18/2/16 refactored
	self.makeDTMSegment (_camProtocol, _camMessage.group3, self.getDTMFormatQualifier(_camProtocol), _transaction.dateTime, "203");
	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group3, theTI);					// TFS 4492
	endif;

	// LOC segments
	self.makeMessageLOC (_camProtocol, _camMessage.group3, _camMessage.activity, theTI);	// par 27460 cnwcs5

	// MEA - weight
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group3,theTI,null); //epr par 37551 TFS 1429 16/2/16

	// DIM+ segment
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group3, theTI);		// par 27460 09/05/2011 cnwcs5

	// TMP Segment
	self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, theTI.getTemperature, "CEL");	// par 27460 09/05/2011 cnwcs5 				

	//the SEL for the seal number
	self.makeMessageSealsData( theTI, _camMessage, _camMessage.group3, _camProtocol, contentsStatus);	//15 Sep 2010	NDL	Par 25608
	
	// ie Dangerous Goods
	self.makeMessageHazardsData (theTI, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
	
	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment (_camProtocol, _camMessage.group3, 'RG', theTI);	// par 27460 09/05/2011 cnwcs5

	// NDA+CF
	self.makeMessageNAD_CF (_camProtocol, _camMessage.group3, theTI);	// par 27460 cnwcs5
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then		// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group3, theTI);								// TFS #2061
	endif;																								// TFS #2061
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="da3d14a0-f738-41f2-bb2b-8f0dbf28927b">
        <updating/>
        <source>outputFile(_protocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent; _camFile : CM_CamFile input; _runDateTime : TimeStamp; _camTaskHistory : CM_CamTaskHistory input;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 11/05/2011	cnwcs5	CCMS SCT 2058/par 27460 - user dfined special characters
// 21/05/2011	cnwcs5	CCMS SCT 2058 / PAR 27460 - user defined special characters
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 19 Dec 2012	cnwcs5	CCMS SFW 1294 /par 30855
// 29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
// 25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
// 09 Jan 2020 	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
vars
	camVoyage 				: CM_CamVoyage;
	camMessage 				: CM_CamMessage;
	una, unb				: String;
	headerColl, trailerColl	: HugeStringArray;	
	strLine : String;
begin // UN
/*============================================================
  Columbus Values for element 1001
  Refer to Harald Schuelde 06NOV97

  Ship discharge   BGM+44
  Ship load        BGM+46
--------------------------------------------------------------*/

	app.writeLog("===================================", LogWARN);
	
	// UNA Segment
	una := self.outputHeader_UNA (_protocol, _camTaskHistory);
	strLine := strLine &amp; una;
	//UNB header
//	strLine := strLine &amp; self.outputHeader_UNB (_protocol, _camTaskHistory, _seqNumber, null);
	//06 Dec 2017	NDL	TFS 7900
	unb := self.outputHeader_UNB (_protocol, _camTaskHistory, _seqNumber, null);
	strLine := strLine &amp; unb;

	if _camFile.camVoyages.size &gt; 0 then
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				headerColl 	:= camMessage.header;
				trailerColl	:= camMessage.trailer;
				
				if una &lt;&gt; null then
					headerColl.add (una);
				endif;
				
				if unb &lt;&gt; null then
					headerColl.add (unb);
				endif;	
				
				//BGM header
				strLine := strLine &amp; self.outputHeader_UNH_BGM (_camFile, _camTaskHistory, camMessage.activity, _unhSeqNumber, camMessage.segmentCount, headerColl);

				//TDT header
				strLine := strLine &amp; self.outputHeader_TDT (_camTaskHistory, _protocol, camVoyage, camMessage.segmentCount, headerColl);

				//RFF header
				strLine := strLine &amp; self.outputHeader_RFF (_protocol, _camTaskHistory, camMessage, headerColl);

				//LOC1 header
				// do they want seperate LOC+9 and LOC+11 for each container ?
				// what is the layout of the LOC for cell position on the shipload.
				strLine := strLine &amp; self.outputHeader_LOC (_camTaskHistory, _protocol, camMessage.activity, camMessage.segmentCount, headerColl);

				//DTM header for arrival and departue date/times
				strLine := strLine &amp; self.outputHeader_DTM_ArriveDepart (_camTaskHistory, _protocol, camVoyage, camMessage.segmentCount, headerColl);

				//NAD header
				strLine := strLine &amp; self.outputHeader_NAD (_protocol, _camTaskHistory, camMessage, headerColl);
								
				//now give them all of the messages
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group3, camMessage.segmentCount);
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group5, camMessage.segmentCount);

				//CNT segment for message
				strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeCNTSegment (_protocol, 16, camMessage.eqdCount), trailerColl);
				
				camMessage.segmentCount := camMessage.segmentCount + 2;
				
				// UNT segment
				strLine := strLine &amp; self.outputTrailer_UNT (_protocol, _camTaskHistory, camMessage.segmentCount, _unhSeqNumber, trailerColl);
				
				camMessage.segmentCount := 0;
			endforeach;
		endforeach;
		
		//set unhSeq here
		_protocol.setUNHSeqNum(_unhSeqNumber);
	endif;
	
	//UNZ segement for file
	strLine := strLine &amp; self.outputTrailer_UNZ (_protocol, _camTaskHistory, _camFile.messageCount, _seqNumber, null);

	app.writeLog(_protocol.code &amp; " File contains " &amp; _camFile.messageCount.String &amp; " messages.", LogWARN);
	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
