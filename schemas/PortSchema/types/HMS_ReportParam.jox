    <JadeMethod name="pxyCreateUpdateProxy" id="3ef98077-40c5-4b9a-b125-2feb0729b231">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 30 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_ReportParam;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myHarbour := self.myHarbour;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="560b15ce-62eb-4e41-a653-d6e314805774">
        <updating/>
        <source>setForUpdate(_pxyReportParam : HMS_ReportParam; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 30 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyReportParam, _passport);
	self.myHarbour 					:= _pxyReportParam.myHarbour;
	self.reportParam_Launchmaster 	:= _pxyReportParam.reportParam_Launchmaster;
	self.reportParam_Pilot 			:= _pxyReportParam.reportParam_Pilot;
	self.reportParam_Supervisor 	:= _pxyReportParam.reportParam_Supervisor;
	self.reportParam_TugMaster 		:= _pxyReportParam.reportParam_TugMaster;
	self.userCode 					:= _pxyReportParam.userCode;
end;</source>
        <Parameter name="_pxyReportParam" type="HMS_ReportParam"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6452e9d2-f0ea-4d58-894e-181c6befeaf8">
        <updating/>
        <source>setProxy(_harbour : HMS_Harbour; _launchmaster, _pilot, _supervisor, _tugMaster, _userCode : String)updating;
//--------------------------------------------------
// Created:	07 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myHarbour := _harbour;
	self.reportParam_Launchmaster := _launchmaster;
	self.reportParam_Pilot := _pilot;
	self.reportParam_Supervisor := _supervisor;
	self.reportParam_TugMaster := _tugMaster;
	self.userCode := _userCode;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_launchmaster" type="String"/>
        <Parameter name="_pilot" type="String"/>
        <Parameter name="_supervisor" type="String"/>
        <Parameter name="_tugMaster" type="String"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="fb9cc95b-d9aa-4c68-8515-749647f378c7">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	07 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);
	if self.myHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbour, null);
		app.raiseCMException(Input_required_field_harbour, ETRow_MyHarbour, null); // cnwdb2	PAR 35364
	endif;
	if self.userCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User Code', ETRow_UserCode, null);
		app.raiseCMException(Input_required_field_userCode, ETRow_UserCode, null); // cnwdb2	PAR 35364
	endif;	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
