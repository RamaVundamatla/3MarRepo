    <JadeMethod name="init_MarineServOrderLocations" id="25c05197-5a52-4a6c-b546-24c8d18bb73e">
        <updating/>
        <source>init_MarineServOrderLocations() updating, protected;
//-----------------------------------------
// Created: March 2004 By: cnwgd1
//-----------------------------------------
/*
*** Changes ***
Date			Name		TFS#		Description
10/01/2022		jlika1		55722		MTN - 1090 Error on Running Qships BGP. String too long in Country Code.
*/
vars
begin

	if self.moveType = HMSMovementTypeArrival then
		self.locationPilotLaunch := AlongSide;
		self.locationTug := OnStation;
	elseif self.moveType = HMSMovementTypeDeparture then
		self.locationPilotLaunch := OnStation;
		self.locationTug := AlongSide;
	elseif self.moveType = HMSMovementTypeShift then		
		if self.getMyBerth() &lt;&gt; null and self.getMyBerth().noMarineServices then 
			self.locationPilotLaunch := AlongSide;
			self.locationTug := OnStation;
		else
			self.locationPilotLaunch := AlongSide;
			self.locationTug := AlongSide;
		endif;
	else
		self.locationPilotLaunch := AlongSide;
		self.locationTug := AlongSide;				
	endif;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init_MarineServOrderTimes" id="c046d371-32e4-4fa6-997a-14a5f316b9c6">
        <updating/>
        <source>init_MarineServOrderTimes() updating, protected;
//-----------------------------------------
// Created: March 2004 By: cnwgd1
//-----------------------------------------
vars
	timePilot,
	timeTugs,
	timeLines : Integer;
begin
	self.myHarbour.getOrderTimesForMoveType(self.moveType, null, null, timePilot, timeTugs, timeLines);

	self.relativeOrderTimeLines := timeLines;
	self.relativeOrderTimePlaunch := timePilot;
	self.relativeOrderTimeTugs := timeTugs;
				
	/*if self.moveType = HMSMovementTypeArrival then
		if self.myHarbour.defaultOrderTimesArrive.size &gt; 2 then
			self.relativeOrderTimeLines := self.myHarbour.defaultOrderTimesArrive[1];
			self.relativeOrderTimePlaunch := self.myHarbour.defaultOrderTimesArrive[2];
			self.relativeOrderTimeTugs := self.myHarbour.defaultOrderTimesArrive[3];
		endif;

	elseif self.moveType = HMSMovementTypeShift then
		if self.myHarbour.defaultOrderTimesShift.size &gt; 1 then
			self.relativeOrderTimeLines := self.myHarbour.defaultOrderTimesShift[1];
			self.relativeOrderTimeTugs := self.myHarbour.defaultOrderTimesShift[2];
		endif;

	elseif self.moveType = HMSMovementTypeDeparture then
		if self.myHarbour.defaultOrderTimesDepart.size &gt; 2 then
			self.relativeOrderTimeLines := self.myHarbour.defaultOrderTimesDepart[1];
			self.relativeOrderTimePlaunch := self.myHarbour.defaultOrderTimesDepart[2];
			self.relativeOrderTimeTugs := self.myHarbour.defaultOrderTimesDepart[3];
		endif;
	endif;*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init_MoveTidalClass" id="8d862f60-5247-4b65-a261-1a1e59fd7f48">
        <updating/>
        <source>init_MoveTidalClass():HMS_TidalClass updating, protected;

vars
	vessel:	CM_Vessel;
	tmpData : HMS_VesselDataHarbour;	
begin
	// Returns initialise value for 'DEFAULT TIDAL CLASS FOR A MOVEMENT'
	if self.myHMSVoyageData &lt;&gt; null then
		if moveType = HMSMovementTypeDeparture then
			return self.myHMSVoyageData.myTidalClassDept;			
		else
			return self.myHMSVoyageData.myTidalClass;
		endif;
	endif;

	vessel:=self.getMyVessel();
	
	if vessel.myHMSVesselData = null then
		return null;
	endif;
	
	tmpData := vessel.myHMSVesselData.allVesselDataForHarbour[self.myHarbour];
	
	if tmpData = null then
		return null;
	endif;
	
	if moveType = HMSMovementTypeDeparture then
		if tmpData.myTidalClassDeparture &lt;&gt; null then
			return tmpData.myTidalClassDeparture;
		else
			return tmpData.myTidalClassArrival;
		endif;
	else
		return tmpData.myTidalClassArrival;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="HMS_TidalClass"/>
    </JadeMethod>
