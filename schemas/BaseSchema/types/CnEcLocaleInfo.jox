    <JadeMethod name="create" id="179a8e7b-e07a-4532-b4d6-27b94263bac8">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Instantiates the receiver's format references.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.isTransient() then
		create self.myCurrencyFormat transient;
		create self.myDateFormat transient;
		create self.myNumberFormat transient;
		create self.myTimeFormat transient;
	else
		create self.myCurrencyFormat;
		create self.myDateFormat;
		create self.myNumberFormat;
		create self.myTimeFormat;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="a8e7d90c-0189-4114-90c7-4e19a6ebbc85">
        <updating/>
        <source>delete() updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	delete self.myCurrencyFormat;
	delete self.myDateFormat;
	delete self.myNumberFormat;
	delete self.myTimeFormat;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLocaleFullInfo" id="1a0ffbd1-e904-44a6-b1e6-72282d1e8618">
        <source>getLocaleFullInfo(pLocaleFullInfoObj:LocaleFullInfo io);
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the receiver to the specified
//				LocaleFullInfo object.
//
// Parameters:	pLocaleFullInfoObj - The LocaleFullInfo to update.
//
// Returns:		The LocaleFullInfo object as an IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	currencyFormatObj	: CurrencyFormat;
	dateFormatObj		: DateFormat;
	numberFormatObj		: NumberFormat;
	timeFormatObj		: TimeFormat;
	
begin
	create currencyFormatObj transient;
	create dateFormatObj transient;
	create numberFormatObj transient;
	create timeFormatObj transient;
	
	self.myCurrencyFormat.getCurrencyFormat(currencyFormatObj);
	self.myDateFormat.getDateFormat(dateFormatObj);
	self.myNumberFormat.getNumberFormat(numberFormatObj);
	self.myTimeFormat.getTimeFormat(timeFormatObj);
	
	// Set the locale's properties.
	
	pLocaleFullInfoObj.cnEcUpdateMe(self.abbreviatedCountryName,
									self.abbreviatedLangName,
									self.countryCode,
									self.englishCountryName,
									self.englishLangName,
									self.languageId,
									self.localeId,
									self.localizedCountryName,
									self.localizedLangName,
									self.nativeCountryName,
									self.nativeLangName,
									currencyFormatObj,
									dateFormatObj,
									self.defaultCodePage,
									self.defaultCountryCode,
									self.defaultLanguageId,
									self.listSeparator,
									self.measurementSystem,
									self.nativeDigits,
									numberFormatObj,
									timeFormatObj);
epilog
	delete currencyFormatObj;
	delete dateFormatObj;
	delete numberFormatObj;
	delete timeFormatObj;
end;</source>
        <Parameter name="pLocaleFullInfoObj" type="LocaleFullInfo" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="518bd98c-b152-4b5f-b89e-64c673e40de8">
        <updating/>
        <source>updateMe(pLocaleFullInfoObj:LocaleFullInfo) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the specified LocaleFullInfo to
//				the receiver.
//
// Parameters:	pLocaleFullInfoObj - The LocaleFullInfo, who's property values
//					to copy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	// Set the locale's properties.
	
	self.abbreviatedCountryName	:=	pLocaleFullInfoObj.abbreviatedCountryName;
	self.abbreviatedLangName	:=	pLocaleFullInfoObj.abbreviatedLangName;
	self.countryCode			:=	pLocaleFullInfoObj.countryCode;
	self.defaultCodePage		:=	pLocaleFullInfoObj.defaultCodePage;
	self.defaultCountryCode		:=	pLocaleFullInfoObj.defaultCountryCode;
	self.defaultLanguageId		:=	pLocaleFullInfoObj.defaultLanguageId;
	self.englishCountryName		:=	pLocaleFullInfoObj.englishCountryName;
	self.englishLangName		:=	pLocaleFullInfoObj.englishLangName;
	self.languageId				:=	pLocaleFullInfoObj.languageId;
	self.listSeparator			:=	pLocaleFullInfoObj.listSeparator;
	self.localeId				:=	pLocaleFullInfoObj.localeId;
	self.localizedCountryName	:=	pLocaleFullInfoObj.localizedCountryName;
	self.localizedLangName		:=	pLocaleFullInfoObj.localizedLangName;
	self.measurementSystem		:=	pLocaleFullInfoObj.measurementSystem;
	self.nativeCountryName		:=	pLocaleFullInfoObj.nativeCountryName;
	self.nativeDigits			:=	pLocaleFullInfoObj.nativeDigits;
	self.nativeLangName			:=	pLocaleFullInfoObj.nativeLangName;
	
	// Set the locale's format information.
	
	self.myCurrencyFormat.updateMe(pLocaleFullInfoObj.currencyInfo);
	self.myDateFormat.updateMe(pLocaleFullInfoObj.dateInfo);
	self.myNumberFormat.updateMe(pLocaleFullInfoObj.numericInfo);
	self.myTimeFormat.updateMe(pLocaleFullInfoObj.timeInfo);
end;</source>
        <Parameter name="pLocaleFullInfoObj" type="LocaleFullInfo"/>
    </JadeMethod>
</Class>
