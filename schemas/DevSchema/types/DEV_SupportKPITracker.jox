    <JadeMethod name="cmbTimezone_click" id="4b016bd8-33cd-496b-91d4-7afcc30ff7a8">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTimezone_click(combobox: ComboBox input) updating;

/*
Date			Who		Reason
28 July 2016	cnwar2	Initial creation

*/
vars
	tz : DEV_SupportTimezone;
	sa : StringArray;
	i  : Integer;
	s  : String;
	
begin
	cmbCustomerRpt.clear();
	cmbCustomerRpt.addItem('*ALL*');
	
	if combobox.text = "*ALL*" then
		cmbCustomerRpt.addItem('ADP');
		cmbCustomerRpt.addItem('AST');
		cmbCustomerRpt.addItem('C3');
		cmbCustomerRpt.addItem('CIG');
		cmbCustomerRpt.addItem('CPL');
		cmbCustomerRpt.addItem('DPH');
		cmbCustomerRpt.addItem('DUQ');
		cmbCustomerRpt.addItem('GHPA');
		cmbCustomerRpt.addItem('GUQ');
		cmbCustomerRpt.addItem('HAT');
		cmbCustomerRpt.addItem('MSL');
		cmbCustomerRpt.addItem('PEN');
		cmbCustomerRpt.addItem('PNL');
		cmbCustomerRpt.addItem('POL');
		cmbCustomerRpt.addItem('PTL');
		cmbCustomerRpt.addItem('QNS');
		cmbCustomerRpt.addItem('RUW');
		cmbCustomerRpt.addItem('SPL');
		cmbCustomerRpt.addItem('STWR');
		cmbCustomerRpt.addItem('STWO');
		cmbCustomerRpt.listIndex := 1;
		return;
	endif;
	
	tz := self.myRoot.allTimezones.getAtKey(combobox.text);
	sa := tz.customers.getTokens;
	
	foreach i in 1 to sa.size do
		s := sa[i];
		s.replaceChar(","," ");
		cmbCustomerRpt.addItem(s);
	endforeach;
	
	cmbCustomerRpt.listIndex := 1;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
