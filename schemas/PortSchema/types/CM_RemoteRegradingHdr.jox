<Class name="CM_RemoteRegradingHdr" id="278cb78f-3f51-456b-8048-86c00008382a">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Regrading GUI&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <JadeMethod name="getDescription" id="b7c7bc07-1749-4ebf-b79f-6395b34a9aa9">
        <source>getDescription(): String;

// cnwdvb1 21 November 2002 

vars

begin
	return 'Regrading GUI';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processInternal" id="517bf73d-c714-47d6-a853-3e650566dd1f">
        <updating/>
        <source>processInternal(_cmif: CMIF_Remote; _passport : CM_Passport input) : Boolean updating;

// cnwdvb1 21 November 2002 

vars

	regrade 		: CM_RemoteRegradingDtl;
	myRegrade		: CMIF_LogRegrade;
	realRemoteHdr	: CM_RemoteDataHdr;

begin
	
	inheritMethod(_cmif, _passport);
	myRegrade := _cmif.myRegradeDetail;
	create regrade transient;
	regrade.setProxyForRegrading(self, myRegrade.myOperator.code, myRegrade.species, myRegrade.gradeCode, myRegrade.type,
								myRegrade.treatment, myRegrade.length, myRegrade.allTrackedItems.asCSV(), _cmif.terminalAreaTo,
								 _cmif.location, myRegrade.sedMin, myRegrade.sedMax, myRegrade.isLogId, _cmif.isMove,myRegrade.myRegradeCode);
								 
	app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, _passport);

	return _passport.trxCompletedOK;

end;</source>
        <Parameter name="_cmif" type="CMIF_Remote"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="f46fb495-4022-42af-a98d-4a6533321091">
        <source>runProcess(_errorSet: CM_ErrorSet input; _isBackGround: Boolean): Boolean;

// cnwdvb1 21 November 2002 

vars

	regradeDetail	: CM_RemoteDataDtl;

begin

	//PAR 21218  23/02/2010. This par touches BGP Internal mode only, when the Background button is turned on in the LOG_RegradingMaintForm and a user presses the Save button.
	if _isBackGround and (self.messageId = self.MessageIdInternal) then	// It means, if there are some validation warnings, a system allert is created to show this warnings and logs are not processed.
		app.myPassport.setIsBackgroundWarningsIgnored(false);	// For example, to stop moving logs, when Inspected/Fumigated status to be changed on a log row or on the logs.
	endif;

	foreach regradeDetail in self.allRemoteDataDtl do
		regradeDetail.CM_RemoteRegradingDtl.doRegrading(_errorSet);
	endforeach;
	return inheritMethod(_errorSet, _isBackGround);

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
