    <JadeMethod name="addToolbarControls" id="3a36d2b0-4045-417b-a9c5-556a5281dd90">
        <source>addToolbarControls();
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	toolbar : CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	self.btnPrint.visible:=true;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	//self.btnPrint.visible:=false;
	
	toolbar.alignContainer := Frame.AlignContainer_Top; 

epilog

end;</source>
