    <JadeMethod name="getMatchingItem" id="146a147b-d0a7-4a07-90e5-854ff308dd3d">
        <source>getMatchingItem(_cargo : CM_CargoBOLType; _commodCode : String) : CM_BOLDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2022	navhl20 ChangeRequest 54979: EUP - Cargo Work Orders Enhancements

*/

vars
	bolDtl		: CM_BOLDtl;
	checkedAll	: Boolean;				
begin					
	foreach bolDtl in self.allBOLDtls do
		if bolDtl.doesCargoMatch(_cargo ,_commodCode) then
			return bolDtl;
		endif;
	endforeach;									
	
	return null;
epilog

end;</source>
        <Parameter name="_cargo" type="CM_CargoBOLType"/>
        <Parameter name="_commodCode" type="String"/>
        <ReturnType type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="ea6b250e-08f3-4b16-ad76-e83a55d32d2f">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars

begin
	if _attrName = ETRow_LengthCode then
		if self.myExtension &lt;&gt; null then
			return self.myExtension.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.weightTotal);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
