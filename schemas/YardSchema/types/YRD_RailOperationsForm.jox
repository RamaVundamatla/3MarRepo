    <JadeMethod name="showRakeRailArea" id="3c8353b6-c727-4324-9dc3-b4b194e4dd3f">
        <updating/>
        <source>showRakeRailArea(pRake : CM_Rail; pInOutRake : CM_RailJSInOutRake) updating;
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	lRailLine	: CM_RailLine;
	lRail	: CM_Rail;
begin

	if pInOutRake &lt;&gt; null then
		lRail := pInOutRake.myRail;
	else
		lRail := pRake;
	endif;

	//lRail can be null as Build Priority Rake does not have a rail area
	if lRail &lt;&gt; null then
		foreach lRailLine in lRail.allRailLines do
			showRakeRailLine(lRailLine);
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="pRake" type="CM_Rail"/>
        <Parameter name="pInOutRake" type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="showRakeRailLine" id="e88db6c1-b63f-4cef-9461-6f65dd9c2637">
        <updating/>
        <source>showRakeRailLine(pRailLine : CM_RailLine) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	lWagon	: CM_Wagon;
	maxWagons,
	numWagons,
	lineIdx,
	maxStackHeight,
	idx		: Integer;
begin
	if pRailLine = null then
		return;
	endif;
	
	//lineIdx := pRailLine.myRailArea.allRailLinesByIndex.indexOf(pRailLine);
	lineIdx := pRailLine.myRailArea.allRailLines.indexOf(pRailLine);
	numWagons := pRailLine.allWagons.size;	
	pRailLine.getMaxStackHeight(maxStackHeight);
	maxWagons := pRailLine.maximumWagons;
	
	foreach idx in 1 to maxWagons do
		if idx &lt;= numWagons then
			lWagon := pRailLine.allWagons[idx];
			//lWagon := wa[idx];
		else
			lWagon := null;
		endif;
		self.showRakeWagon(lineIdx, idx, lWagon, pRailLine, maxStackHeight, maxWagons);
	endforeach;
end;</source>
        <Parameter name="pRailLine" type="CM_RailLine"/>
    </JadeMethod>
    <JadeMethod name="showRakeWagon" id="8bd44b94-7071-4863-bc4d-52e8117e14d1">
        <updating/>
        <source>showRakeWagon(pRow, pCol : Integer; pWagon : CM_Wagon; pRailLine : CM_RailLine; maxStackHeight : Integer; _maxWagons : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	aWagonArea	: YRD_WagonArea;
	wagonFrame	: CMUI_GridAreaFrame;
	col			: Integer;
	showUnconfirmed : Boolean;
	train : CM_Train;
begin

	create aWagonArea transient;

	if self.flipHorizontal then
		aWagonArea.setFlips( true, false );
		col := _maxWagons + 1 - pCol;
	else
		col := pCol;
	endif;

	showUnconfirmed := true; // AKB 2009 AUG (pRailLine = null);

	if self.myCurrentTrain &lt;&gt; null then // TRAIN MODE
		train := self.myCurrentTrain;
	elseif self.myCurrentRailArea &lt;&gt; null then // RAIL MODE
		train := self.cmbSelectedTrain.listObject.CM_Train;
	endif;
	
	aWagonArea.setForCreate(pWagon, self.optDirOutTB.value, null, pRailLine,train, pRow, col,
							self.clrWagon.backColor,
							self.mySDF.myHLabels.backColor,
							self.clrLocation.backColor,
							maxStackHeight, showUnconfirmed, false,
							self.mySDF.myDrawingAttrController);
	
	self.maxWagonFrames := maxWagonFrames + 1;
	wagonFrame := frmGridArea.loadControl(maxWagonFrames).CMUI_GridAreaFrame;
//	wagonFrame.width := aWagonArea.WagonAreaWidth;
//	wagonFrame.height := aWagonArea.WagonAreaHeight;

	self.mySDF.addGridAreaAndFrame(aWagonArea, wagonFrame);
	wagonFrame.doAutoScrolling := false;
	aWagonArea.updatePictures();
	
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <Parameter name="pWagon" type="CM_Wagon"/>
        <Parameter name="pRailLine" type="CM_RailLine"/>
        <Parameter name="maxStackHeight" type="Integer"/>
        <Parameter name="_maxWagons" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showReleaseRequestForm" id="badaba45-4f68-447c-b82f-10dbb3de99a0">
        <source>showReleaseRequestForm(_job : CM_Job);
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
//-----------------------------------------
vars
	request			: CM_Request;
	br			: CM_BulkRelease;
begin
	app.mousePointer := MousePointer_HourGlass;
	/*
	//th2 02/01/07 CCMS 1408 - Build priority obsolete
	if not app.getMyTerminal.getConfig(RailUseBuildPriority).Boolean then
		app.msgBox("This terminal is not configured to use Rail Build Prioirty. You should use the 'Release Request' screen to maintain rail releases and assign them to rail lines etc.",'Build Priority not available.',MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.myAssistant.YRD_Assistant.showBuildPriorityForm(_job, self.myMasterMenuAction);
	*/
	
	if _job &lt;&gt; null then
		request := _job.allRequests.first;
		if request &lt;&gt; null then
			br := request.myOriginatingBulkRelease;
			if br = null then
				br := request.bulkRelease;
			endif;
			if br &lt;&gt; null then
				self.myAssistant.releaseRequestUpdate(br, self.myMasterMenuAction,null);					//14.6.2023 navhl20 #58634
			endif;
		else
			//app.msgBox('There is no longer any rail release associated with this rail job','No release request', MsgBox_Exclamation_Mark_Icon); //- cnwmd1, CCMS 1067, Par 19710
			app.msgBox(app.getErrorString(No_rail_relea_assoc_with_job),app.getErrorString(No_Release_request), MsgBox_Exclamation_Mark_Icon); //+ cnwmd1, CCMS 1067, Par 19710
		endif;
		return;
	else
		create br transient;//form cleans up
		self.myAssistant.releaseRequestAdd(br, BR_TYPE_RAIL, self.myMasterMenuAction,null);				//14.6.2023 navhl20 #58634
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="showTrain" id="8bba8af0-7e68-49ce-8ea2-6250ffcc1ddf">
        <updating/>
        <source>showTrain( _train : CM_Train ) updating;

/*

Purpose:		Show wagons for given train

Parameters:			

Return Value:		


Date		Who		Reason
11 Jun 2009	consw1	Initial creation

*/

vars
	lWagon	: CM_Wagon;
	maxWagons,
	lineIdx,
	maxStackHeight,
	idx		: Integer;
begin

	if _train = null then
		return;
	endif;
	
	lineIdx := 1;

	if self.optDirOutTB.value then
		//  Outwards train
		maxWagons := _train.allWagonsByOrderOutward.size;
		foreach lWagon in _train.allWagonsByOrderOutward do
			maxStackHeight := maxStackHeight.max(lWagon.myWagonClass.maxNumInStack);
		endforeach;
		foreach lWagon in _train.allWagonsByOrderOutward do
			idx := idx + 1;
			self.showRakeWagon(lineIdx, idx, lWagon, null, maxStackHeight, maxWagons);
		endforeach;
	else
		//  Inwards train
		maxWagons := _train.allWagonsByOrderInward.size;
		foreach lWagon in _train.allWagonsByOrderInward do
			maxStackHeight := maxStackHeight.max(lWagon.myWagonClass.maxNumInStack);
		endforeach;
		foreach lWagon in _train.allWagonsByOrderInward do
			idx := idx + 1;
			self.showRakeWagon(lineIdx, idx, lWagon, null, maxStackHeight, maxWagons);
		endforeach;
	endif;

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="showTrainQueryContext" id="a2b43215-9a30-4afe-a2bb-bc2ce1ab687a">
        <updating/>
        <source>showTrainQueryContext(cntrl : Table input; conwin : Window input; mouse : Boolean; x : Integer; y : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	xLeft 	: Real;
	yTop	: Real;
	
begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.mnuTrainQuery, xLeft.Integer, yTop.Integer);
	
	return false;

epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWagonEnquiryForm" id="1a8600e5-964f-46bf-95e7-a622cf50d3a5">
        <updating/>
        <source>showWagonEnquiryForm( _wagon : CM_Wagon ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Jun 2009	consw1	Initial creation

*/

vars
	wagonColl : ObjectSet;
	
begin
	create wagonColl transient; // deleted by assistant
	
	if _wagon = null then
		self.getSelectedWagons(wagonColl, null);
	else
		wagonColl.add(_wagon);
	endif;
	
	self.myAssistant.YRD_Assistant.showWagonEnquiry(wagonColl, self.myCurrentTrain, self.optDirInTB.value, false, self.myMasterMenuAction, self);


end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="showWagonMaintForm" id="3de65933-017a-48e5-9819-f81045afdf2f">
        <updating/>
        <source>showWagonMaintForm(_object : CM_Object; _mode, _position : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	heading : String;
	wagonForm : YRD_TrainWagonForm;
	wagon : CM_Wagon;
	trainForWagonCombo : CM_Train;
	mode : Integer;
	rake : CM_RailLine;
begin

	app.mousePointer := MousePointer_HourGlass;

	if _object.isKindOf(CM_RailLine) then
		rake := _object.CM_RailLine;
		wagon := rake.getWagonAtPosition(_position);
	elseif _object.isKindOf(CM_Wagon) then
		wagon := _object.CM_Wagon;
		rake := wagon.myRailLine;
	else
		return;
	endif;

	
	if wagon = null then
		mode := YRD_TrainWagonForm.Mode_Add;
	else
		mode := _mode;
		trainForWagonCombo := wagon.myTrainInwards;
		if trainForWagonCombo = null then
			trainForWagonCombo := wagon.myTrainOutwards;
		endif;	
	endif;
	
	

	
	app.mousePointer := MousePointer_HourGlass;
	
	wagonForm := app.getForm(YRD_TrainWagonForm.name).YRD_TrainWagonForm;
	if wagonForm = null then
		wagonForm := app.loadForm(YRD_TrainWagonForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonForm;
	endif;
	
	if wagonForm = null then
		return;
	endif;
	
	self.setNavigatorHeading(app.getErrorString(Wagon_maintenance)); 
	wagonForm.setParentForm(self);
	wagonForm.setMyTerminal(self.myTerminal);
	wagonForm.setMyTrainForWagonCombo(trainForWagonCombo);
	wagonForm.initialiseForm(self.myCurrentTrain, wagon, mode);
	if rake &lt;&gt; null then
		wagonForm.myRailRake := rake;
		wagonForm.myRailArea := rake.myRailArea;
		wagonForm.rakePos := _position;
	endif;
	wagonForm.show;
		
epilog
	app.mousePointer := MousePointer_Default;


end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_position" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="switchParents" id="275eae41-1f69-4b50-8bc6-92c2988d2559">
        <source>switchParents();
// ---------------------------------------------------------------------------
