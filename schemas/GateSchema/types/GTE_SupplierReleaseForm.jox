    <JadeMethod name="initForm" id="205a6257-ae50-4850-a042-1947f7a4ba7d">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	
	self.initTblInput(self.tblInput1, ETDef_SupplierReleaseTbl);
	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.allowPrint  	:= false;
