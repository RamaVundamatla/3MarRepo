<Class name="CMEVT_VehicleBookingEvent" id="250fae2e-c4bc-42aa-bb44-412095592c83">
    <superclass name="CM_EventTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myVehicleBookingSlot" id="ecd90d46-4457-4347-a71c-ff37789e4686">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_VehicleBookingTimeSlot"/>
        <access>readonly</access>
        <Inverse name="CM_VehicleBookingTimeSlot::allEventTransactions"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVehicleVisit" id="6d12b808-2aed-4433-82b4-74850d49d304">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
        <access>readonly</access>
        <Inverse name="CM_VehicleVisitRecord::allEventTransactions"/>
    </ExplicitInverseRef>
    <JadeMethod name="hasTaskThatIsComplete" id="625d35b4-b0a3-49b1-996f-78ca8b116612">
        <source>hasTaskThatIsComplete(): Boolean;
/*
Purpose:			

Date		Who		Reason
16JUN2023	NAVAB1	 CR 54345 TASK 58281 
05 Dec 2024 navma1	 MTN-33567 MTN - Charges Are Not Created When adding Events
*/


vars
	taskDesc  : CM_ToDoTaskDesc;
	task 	  : CM_ToDoTask;
	myWodToDo : CM_WodToDo;
	vbsSlot	  : CM_VehicleBookingTimeSlot;
begin

	if self.myToDoTask = null then
		return false;
	endif;
	
	vbsSlot := self.myVehicleBookingSlot;
	
	if vbsSlot = null then
		return null;
	endif;
	
	return vbsSlot.allToDoTasksCompleted.includes(self.myToDoTask);
	
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCMIF" id="dc1a5439-be2d-4600-a3e7-e25214b29240">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_VehicleBookingCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	resourceUsages : CM_ResourceTypeUsageSet;
	wod : CM_WorkOrderToDoDtl;
begin
	self.setMyVehicleBookingSlot(_cmifEventTrx.myVehicleBookingSlot);
	if _cmifEventTrx.myVehicleVisitRecord &lt;&gt; null then
		self.setMyVehicleVisit(_cmifEventTrx.myVehicleVisitRecord);
	endif;
	
	if _cmifEventTrx.allResourceUsages.isNotEmpty() then
		create resourceUsages transient;
		_cmifEventTrx.allResourceUsages.copy(resourceUsages);
		self.addResourcesFromProxys(resourceUsages);
	endif;
	
	self.setToDoTask(_cmifEventTrx.myToDoTask);
	
	wod := _cmifEventTrx.myWorkOrderDetail;
	
	if wod = null then
		wod := self.getWorkOrderDetail().CM_WorkOrderToDoDtl;
	endif;
	
	if wod &lt;&gt; null then
		self.setFromWOD(wod);
	endif;
	
	inheritMethod(_eventType, _cmifEventTrx);

epilog
	delete resourceUsages;
end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_VehicleBookingCtrl"/>
    </JadeMethod>
    <JadeMethod name="setMyVehicleBookingSlot" id="8cd6ac18-697f-4569-b367-e98b9c58c7d0">
        <updating/>
        <source>setMyVehicleBookingSlot(_vbsSlot: CM_VehicleBookingTimeSlot) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 March 2023	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars

begin
	self.myVehicleBookingSlot := _vbsSlot;
epilog

end;</source>
        <Parameter name="_vbsSlot" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="setMyVehicleVisit" id="f6471185-7922-444c-90a9-0f5775b73d38">
        <updating/>
        <source>setMyVehicleVisit(_vvr: CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 March 2023	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars

begin
	self.myVehicleVisit := _vvr;
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
</Class>
