    <JadeMethod name="getLoggingLevelString" id="6d75c1a4-2b6d-408a-923f-f49455f1a2eb">
        <source>getLoggingLevelString( _index : Integer ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

	logLevelStr : String;

begin

	if _index = LogINFO then	//0
		logLevelStr := "INFO";
	elseif _index = LogFATAL then	//1
		logLevelStr := "FATAL";
	elseif _index = LogERROR then	//2
		logLevelStr := "ERROR";
	elseif _index = LogWARN then	//3
		logLevelStr := "WARN";
	elseif _index = LogDEBUG then	//4
		logLevelStr := "DEBUG";
	elseif _index = LogTRACE then	//5
		logLevelStr := "TRACE";
	else
		logLevelStr := "*** UNKNOWN ***";
	endif;
	
	return logLevelStr;

epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementPrefixFromType" id="fa2c145e-56b6-488b-813d-073132290797">
        <source>getMeasurementPrefixFromType(_type : String) : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin

	if _type = Type_Weight then
		return Prefix_Weight;
	elseif _type = Type_Volume then
		return Prefix_Volume;
	elseif _type = Type_Linear then
		return Prefix_Linear;
	elseif _type = Type_Length then
		return Prefix_Linear;
	elseif _type = Type_Width then
		return Prefix_Linear;
	elseif _type = Type_Height then
		return Prefix_Linear;
	elseif _type = Type_Displacement then
		return Prefix_Displacement;
	elseif _type = Type_Density then
		return Prefix_Density;
	else
		return null;
	endif;
	
epilog

end;</source>
