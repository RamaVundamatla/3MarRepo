<CollClass name="ObjectArray">
    <JadeMethod name="jssGetMemberClass" id="d00ebea7-5c39-4287-b074-b80f2787ee19">
        <source>jssGetMemberClass():Class;
// --------------------------------------------------------------------------------
// Created:		15 March 2001 by cnwdad1
//
// Purpose:		Returns the Class of the receiver's membership.
//
// Parameters:	None
//
// Returns:		The Class of the receiver's membership.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.jssGetMemberType().Class;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="jssSort" id="0e3040f8-a401-4860-811e-69aaccd3f9f1">
        <lockReceiver/>
        <updating/>
        <source>jssSort(pIsDescending: Boolean) updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		Reimplementation to prevent an attaempt to sort non-primitive arrays.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <Parameter name="pIsDescending" type="Boolean"/>
    </JadeMethod>
</CollClass>
