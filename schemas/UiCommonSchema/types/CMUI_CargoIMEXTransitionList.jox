    <JadeMethod name="doDelete" id="ccb54d8b-0d37-4339-a481-60aedf92c02c">
        <updating/>
        <source>doDelete() updating;
/*
----------   ----------  --------------------------------------------------
Created: 28 March 2018 by jlgsl4

Purpose:	

Changed On   	Changed By  Reason	
----------  	----------  --------------------------------------------------
28 March 2018	jlgsl4		TFS 37410 Import MTs IMEX transition status

*/
vars
	result : Integer;
	msgStr : String;
	transitionIMEX : CM_Object;
	
begin

	transitionIMEX := self.tblData.accessRow(self.tblData.row).itemObject.CM_Object;

	if transitionIMEX &lt;&gt; null then
		msgStr := app.getErrorString2(ConfirmDelete, 'the selected', 'transition');
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;	
	
	while true do
		app.myTrxDA.trxDeleteCMObject(transitionIMEX, app.myPassport ); //trxDeleteDelay(selectedObj.CM_Delay, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="d004f063-efb0-4f8a-9ad7-8e790d720653">
        <updating/>
        <source>doEditItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	transitionIMEX : CM_IMEXTransitionCriteria;
	loadState : Boolean;
begin
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;

	transitionIMEX := self.tblData.accessRow(self.tblData.row).itemObject.CM_IMEXTransitionCriteria;
	if transitionIMEX = null then
		return;
	endif;
	
	self.setNavigatorHeading(transitionIMEX.name);
	
	app.cmsBeginLoad(loadState);
		self.myCurrentTransition := transitionIMEX.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadState);
	self.isUpdate := true;
	self.doUpdateOrNew();
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNew" id="9fc4f89f-aa31-4142-86d5-17125b367670">
        <updating/>
        <source>doNew() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 April 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	transitionNew : CM_IMEXTransitionCriteria;
begin
	create transitionNew transient;
	self.myCurrentTransition := transitionNew;
	isUpdate := false; // false means new
	self.doUpdateOrNew();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="28ab9e6d-cc37-4566-beb7-b6cd669d7cfa">
        <updating/>
        <source>doQueryAddItem(_detail : CM_IMEXTransitionCriteria) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	theDataLine : String;
	idx, colNumber : Integer;
begin
	theDataLine := _detail.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);

	idx := self.tblData.addItem(theDataLine);
	self.tblData.accessRow(idx).itemObject := _detail;
	
epilog

end;</source>
        <Parameter name="_detail" type="CM_IMEXTransitionCriteria"/>
    </JadeMethod>
    <JadeMethod name="doUpdateOrNew" id="35eea338-ac6e-4521-9a53-24c4d211ebf0">
        <updating/>
        <source>doUpdateOrNew() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	newIMEXTransitionForm : CMUI_CargoIMEXTransitionEdit;
begin
	newIMEXTransitionForm := app.loadForm(CMUI_CargoIMEXTransitionEdit,
		CMUI_Assistant, false, false, false, self.getMyTerminal, null).CMUI_CargoIMEXTransitionEdit;	
	if newIMEXTransitionForm = null then
		return;
	endif;
	newIMEXTransitionForm.myProxyObject := self.myCurrentTransition;
	newIMEXTransitionForm.myParentForm := self;
	newIMEXTransitionForm.isUpdate := self.isUpdate;
	newIMEXTransitionForm.setMyTerminal(self.myTerminal);
	newIMEXTransitionForm.showModal;
	
	self.setNavigatorHeading(self.MenuCaption);

epilog
	delete self.myCurrentTransition; // delete the proxy
end;</source>
    </JadeMethod>
