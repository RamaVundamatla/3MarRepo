    <JadeMethod name="bookingRefStatusEnumToString" id="aa218248-6a70-4f55-8ac0-4d532d1d2c0c">
        <source>bookingRefStatusEnumToString(_statusCode:Integer):String;
// --------------------------------------------------------------------------------
// Created:		27 May 2009 by cnwdad1
//
// Purpose:		Taking a Booking Reference Status constants, return the corresponding
//				description.
//
// Parameters:	_statusCode - The Booking Reference Status code.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _statusCode = BOOKING_REF_ACTIVE then
		return app.getErrorString(Active);
	elseif _statusCode = BOOKING_REF_ARCHIVED then
		return app.getErrorString(Archived);
	elseif _statusCode = BOOKING_REF_CLOSED then
		return app.getErrorString(Closed);
	elseif _statusCode = BOOKING_REF_PENDING then
		return app.getErrorString(Pending);
	else
		return null;
	endif;
end;</source>
        <Parameter name="_statusCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="bookingRefStatusStringToEnum" id="9e6cd312-9487-4e7a-b0f6-e25d546572b0">
        <source>bookingRefStatusStringToEnum(_description:String):Integer;
// --------------------------------------------------------------------------------
// Created:		27 May 2009 by cnwdad1
//
// Purpose:		Taking a Booking Reference Status description, return the corresponding
//				constant code.
//
// Parameters:	_description - The Booking Reference Status description.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------


//	28 Feb 2011	NDL	Par 27104 - _description can be passed in having had 
//								trimBlanks applied by framework.
vars
	desc : String;
begin
	desc := _description.trimBlanks;
	if desc = app.getErrorString(Active).trimBlanks then
		return BOOKING_REF_ACTIVE;
	elseif desc = app.getErrorString(Archived).trimBlanks then
		return BOOKING_REF_ARCHIVED;
	elseif desc = app.getErrorString(Closed).trimBlanks then
		return BOOKING_REF_CLOSED;
	elseif desc = app.getErrorString(Pending).trimBlanks then
		return BOOKING_REF_PENDING;
	else
		return -1;
	endif;
end;</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
