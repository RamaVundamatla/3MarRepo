    <JadeMethod name="loadEntTableDetails" id="47c0b10a-4ed5-4d69-a1d7-1d907d77816c">
        <source>loadEntTableDetails() : String protected;
// ---------------------------------------------------------------------------
// Created:     13 August 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTblAgent	: EntTableAgent;
	rtnValue	: Boolean;
	str, rtnStr	: String;

begin

	create entTblAgent transient;
	if app.myRoot.myEntTableDataRoot = null then
		beginTransaction;
		// createEntTableDataRoot();
		rtnValue := entTblAgent.utlCreateDataRoot(CM_EntTableDataRoot,
								  'JMT', '',
								  PortSchemaName,
								  'EntTableGroups',
								  'EntTableDefs',
								  'EntTableRows',
								  rtnStr,
								  entTblAgent.myEntTableDataRoot);
		entTblAgent.myEntTableDataRoot.CM_EntTableDataRoot.myRoot := app.myRoot;
		commitTransaction;
	endif;
	entTblAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;

	// RBarr Aug 2006 - update, rather than purge/create the data
//	rtnValue := entTblAgent.trxLoadFromGlobalConstants();
	rtnValue := entTblAgent.trxUpdateFromGlobalConstants();

	// If we have true then we will only have warnings.
	if rtnValue then
		foreach str in entTblAgent.allErrorStrings do
			rtnStr := rtnStr &amp; str &amp; CrLf;
		endforeach;
	else
		rtnStr := 'Fatal Error';
	endif;
	
	
epilog
	delete entTblAgent;
	return rtnStr;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
