<Class name="CMIF_JobSheetStats">
    <JadeMethod name="getWorkETCActualNew" id="9f8cc4d2-1ddd-4383-b36f-645053eb3478">
        <source>getWorkETCActualNew() : TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 March 2007	cnwer1	Initial creation - PAR#13669
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	shpJobDrawController: 	SHP_JobControllerController;
	allJobsStartEndTime : ObjectArray ;
	currentEnd : TimeStamp;
begin
	create shpJobDrawController transient;
	shpJobDrawController.setMyVoyage(self.myJobSheet.CM_VoyageJobSheet.myVoyage);
	shpJobDrawController.setCurrentTime(app.actualTimeServer);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create allJobsStartEndTime transient;
	currentEnd:=shpJobDrawController.getStartTime;
	shpJobDrawController.getAllCraneJobs(self.myJobSheet.CM_VoyageJobSheet,allJobsStartEndTime,currentEnd);
	return currentEnd;

epilog
	delete shpJobDrawController;
	allJobsStartEndTime.purge;
	delete allJobsStartEndTime;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</Class>
