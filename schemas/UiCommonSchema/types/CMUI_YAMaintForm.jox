    <JadeMethod name="locateControlForCriteriaType" id="26b1938e-4cf6-474d-8bd7-5503ae3100a4">
        <source>locateControlForCriteriaType( _criteriaType : CM_YACriteriaType ) : CMUI_YACriteriaCntl;
/*
Date		Who		Reason
09 January 2009	cnwjk3	SFW1030

*/
vars
	i 					: Integer;
	criteriaCtrl 		: CMUI_YACriteriaCntl;
	ctrlCriteriaType 	: CM_YACriteriaType;
begin
	criteriaCtrl := null;
	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		ctrlCriteriaType := criteriaCtrl.getCriteriaType();
		if ctrlCriteriaType &lt;&gt; null then
			if ctrlCriteriaType = _criteriaType then
				return criteriaCtrl;
			endif;
		endif;
	endwhile;
	return null;
epilog

end;</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <ReturnType type="CMUI_YACriteriaCntl"/>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFrames" id="f1524f79-5724-4fd6-b84a-33585483045b">
        <updating/>
        <source>populateCriteriaFrames(_autoSetFocus : Boolean) updating; // PAR 21746

/*

Purpose:		Populate criteria frames from current yard allocation

Parameters:			

Return Value:		


Date			Who		Reason
20 August 2008	consw1	Initial creation
03/11/2009		cnwmh5	PAR20740 - Set the tabIndex starting value so that
						tab sequence works correctly and set focus correctly
*/
vars
	i: Integer;
	criteria: CM_YACriteria;
	criteriaFrame: CMUI_YACriteriaCntl;
	saveChangeMethod: String;
	cmifObject: CMIF_Object;
	tabIndex: Integer;
	adjustment: Real;
	new: Boolean;
begin
	self.width := 415; // PAR 35325

	tabIndex := self.frmCriteria.tabIndex;					// 03/11/2009 cnwmh5 PAR20740		

	// If this YA is not based on a Template, then add frame for any criteria
	// that have not already been added
	self.hideAllOpCriteriaFrames();
	foreach cmifObject in self.allOperationalCriteria do
		i := i + 1;
		criteria := cmifObject.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		criteriaFrame := self.addCriteriaFrame(i, criteria.myYACriteriaType, tabIndex);
		saveChangeMethod := criteriaFrame.formCriteriaChangeMethodName;
		criteriaFrame.formCriteriaChangeMethodName := null;  // prevent invoke of criteria change method
		criteriaFrame.setCriteria( criteria );
		criteriaFrame.setMasterControl(self.frmCriteria);	//cnwmc5 - PAR 31255	
		criteriaFrame.formCriteriaChangeMethodName := saveChangeMethod;
		// 04/11/2009 cnwmh5 PAR20740
		// Set the focus to the first item for entry
		if _autoSetFocus and i = 1 then
			criteriaFrame.CMUI_YACriteriaCntl.txtCriteriaValue.setFocus();
		endif;
	endforeach;
epilog
end;</source>
        <Parameter name="_autoSetFocus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateExpiryType" id="c193933e-802d-4059-b9a7-42e6b6b5cbaa">
        <source>populateExpiryType( _expiryType : Integer );

/*

Purpose:		Set the expiry option controls for the given YA Expiry Type value.

Parameters:			

Return Value:		


Date			Who		Reason
07 August 2008	consw1	Initial creation
18 March 2021	navdap1	TFS 50946 PRP Auto Delete of Yard Allocations
*/

vars

begin
	self.optExpiryNever.cnEcSet(_expiryType = YAExpiryType_Never);
	self.optExpiryVoyage.cnEcSet(_expiryType = YAExpiryType_VoyageDepart);
	self.optExpiryEmpty.cnEcSet(_expiryType = YAExpiryType_WhenEmpty);
	self.optExpiryDate.cnEcSet(_expiryType = YAExpiryType_SpecifiedDate);
	self.optExpiryClear.cnEcSet(_expiryType = YAExpiryType_VoyageClear);	//29 Jun 2011	NDL	Par 27786
	self.optExpiryNoCargo.cnEcSet(_expiryType = YAExpiryType_NoCargo);		// TFS 50946
epilog

end;</source>
        <Parameter name="_expiryType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="d8f16e6a-2b89-406a-8127-3f4b03df2a5d">
        <updating/>
        <source>populateForm() updating;
// adm 080609 Par 19637 defaultYACodeChanged
//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
//25 Oct 2022 navrk21 Bug 55148: MTN - Delete button appears in any Selection criteria screen
vars
	criteria : CM_YACriteria;
	expiryTS : TimeStamp;
begin
	on Exception do self.handleBadCriteriaValue(exception);  //cnwrd1 par  19084 18.3.09
	
	defaultYACodeChanged	:= false;
	self.populateIMEX();
	self.populateOptions();
	
	if self.myYardAllocation &lt;&gt; null then
		self.populateCriteriaFrames(true);
		self.showTblGCQuantity( self.myYardAllocation );
	endif;

	self.formatName(false);	// 04/03/2015 cnwar2 #33493
	
	if self.myProxyYA = null then
		return;
	endif;
	
	self.cmbYATemplate.setIndexFromObject( self.myProxyYA.myYATemplate );
	//self.doTemplateSelected( self.myProxyYA.myYATemplate ); //cnwrd1 par 19062 17.3.09 --  // purging trmplate critera after loading above??
	self.displayCriteriaDesc(); //cnwrd1 par 19062 17.3.09 ++
	
	if self.myProxyYA.checkIfDefaultYACode(self.txtYACode.text) then	
		defaultYACodeChanged	:= false;
	else
		defaultYACodeChanged	:= true;
	endif;
	self.txtYACode.text		:= self.myProxyYA.code;
	self.txtYADescription.text		:= self.myProxyYA.description;
	self.txtRemarks.text			:= self.myProxyYA.remarks;
	self.populateExpiryType( self.myProxyYA.expiryType );
	
	//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	expiryTS.cnEcSetDateAndTime(self.myProxyYA.expiryDate,TimeEndOfDay);
	self.dateExpiryDate.setDate(self.systemToLocalTime( expiryTS).date());
	//self.dateExpiryDate.setDate( self.myProxyYA.expiryDate );
	
	// cnwjk3 SFW1030
	//self.clrYAColour.setColor( self.myProxyYA.color );
	self.setIMEXDefaultColour();
	
	self.chkDisableYA.value			:= self.myProxyYA.isDisabled;

	if self.myProxyYA.remarks &lt;&gt; null then
		shtRemarks.caption := shtRemarks.caption &amp; " (*)";
	endif;
	
	if not self.isBulkEdit() then
		self.shtLocation.visible := true;
		self.populateLocations();
	endif;
	self.btnDelete.visible := true;		//25.10.2022 navrk21 TFS 55148
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateIMEX" id="13087f6d-9096-4e06-8778-f8abf27c8d6a">
        <updating/>
        <source>populateIMEX() updating;

/*

Purpose:		Populate IMEX combo from yard allocation (or set default value).

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation
20 May 2010		cnwdap1	CCMS 1116 Tranship changes
14 Sep 2022	navak20	TFS ChangeRequest 54628: MTN - Default IMEX for New Yard Allocations Forecast on Voyage and Train
*/

vars
	criteria : CM_YACriteria;
	imex: Integer;
	obj : Object;
	str : String;
	imexObj : CM_IMEXStatus;		// 15.09.2022 navak20 TFS 54628
begin
	self.cmbIMEX.listIndex := -1;
	self.txtImex.visible := false;

	if self.myYardAllocation = null then
		//imex := TI_IMEX_STATUS_EXPORT;		// 14.09.2022 navak20 TFS 54628
		//Start 14.09.2022 navak20 TFS 54628
		imexObj := self.myTerminal.getConfig(DefaultIMEXStatusForYA).CM_IMEXStatus;
		if imexObj &lt;&gt; null and imexObj.code &lt;&gt; null then
			imex := imexObj.code;
		else
			imex := TI_IMEX_STATUS_EXPORT;
		endif;
		//End 14.09.2022 navak20 TFS 54628
		if self.myTrackedItem &lt;&gt; null then
			//imex := self.myTrackedItem.getImExStatus;//cnwrd1 --
			imex := self.myTrackedItem.getReceivalIMEXStatus(); // cnwrd1 par 25272 03.08.2010 - get the receival IMEX status, if on ship MT Import its intended to be storage and autoplaned as such
		endif;
		self.cmbIMEX.setIndexFromObject(app.myRoot.allImexStatuses[imex]);
	else
		criteria := self.myYardAllocation.getCriteriaOfTypeValue(YACriteriaType_ImexStatus);
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
				self.txtImex.visible := true;
				self.cmbIMEX.visible := false;
				foreach obj in criteria.myYAData.CM_YADataObjects.allObjects do					//+cnwml PAR22042
					if obj.CM_IMEXStatus.code = TI_IMEX_STATUS_EXPORT then
						str := obj.CM_IMEXStatus.abbreviation;
					elseif obj.CM_IMEXStatus.code = TI_IMEX_STATUS_IMPORT then
						str := obj.CM_IMEXStatus.abbreviation;
					elseif obj.CM_IMEXStatus.code = TI_IMEX_STATUS_REMAINONBOARD then
						str := obj.CM_IMEXStatus.abbreviation;
					elseif obj.CM_IMEXStatus.code = TI_IMEX_STATUS_STORAGE then
						str := obj.CM_IMEXStatus.abbreviation;
					elseif obj.CM_IMEXStatus.code = TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
						str := obj.CM_IMEXStatus.abbreviation;						// PAR #23645 CCMS 1116
					endif;
					
					if self.txtImex.text = null then
						self.txtImex.text := str;
					else	
						self.txtImex.text := self.txtImex.text &amp; ", " &amp; str;
					endif;
				endforeach;
				
			else
				self.cmbIMEX.setIndexFromObject(criteria.myYAData.CM_YADataObjects.getFirstObject());
			endif;
		else
			//cnwrd1 par 19062 17.3.09
			// no IMEX
			imex := TI_IMEX_STATUS_NULL;
			self.cmbIMEX.setIndexFromObject(app.myRoot.allImexStatuses[imex]);
		endif;
	endif;
	
	self.doIMEXSelected();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateLocations" id="b5e855b4-9a25-4ddd-957a-9b6dea49d1c3">
        <updating/>
        <source>populateLocations() updating;
//12 February 2009	cnwdw1	
//
vars
	yaBlock: CM_YABlock;
	cell : JadeTableCell;
	index: Integer;
begin
	self.tblLocation.rows := 0;
	self.tblLocation.columns := 1;
	
	if self.myProxyYA = null then
		return;
	endif;
	
	self.tblLocation.rows := self.myProxyYA.allYABlocksIn.size;
	index := 1;
	foreach yaBlock in self.myProxyYA.allYABlocksIn do
		cell := self.tblLocation.accessCell(index, 1);
		cell.text := yaBlock.getYAMDisplay(true);
		cell.itemObject := yaBlock;
		index := index + 1;
	endforeach;
	
	//epr par 28388 11/10/11
	if self.tblLocation.rows = 0 and self.initLocation &lt;&gt; null then
		self.doAddLocation(self.initLocation);
		self.setInitLocation(null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateOptions" id="a785dbe3-8e2d-4286-9165-12b7bd7a872e">
        <source>populateOptions();
//13 February 2009	cnwdw1	
//
vars
	fillOption			: Integer;
begin
	if self.myYardAllocation = null then
		self.cmbAllowOthers.setIndexForItemData(YAOverlap_Always);
		self.cmbNoLocation.setIndexForItemData(YANoLocation_Continue);
		self.cmbOverstowRule.setIndexFromObject(null);
		fillOption := app.getMyTerminalDO_NOT_USE().getFillOption;
		self.cmbFillOptionIn.setIndexForItemData(fillOption);
		self.cmbFillOptionOut.setIndexForItemData(fillOption);
		self.cmbDisplayHatche.setIndexForItemData(false.Integer);  //cnwjo3 par 24145
		self.cmbMultiRange.setIndexForItemData(false.Integer);	//15 Jun 2016	NDL	TFS 2172
	elseif self.myProxyYA &lt;&gt; null then
		self.cmbAllowOthers.setIndexForItemData( self.myProxyYA.allowOthersOption );
		self.cmbNoLocation.setIndexForItemData( self.myProxyYA.noLocationOption );
		self.cmbOverstowRule.setIndexFromObject( self.myProxyYA.myYAOverstowRule );
		self.cmbDisplayHatche.setIndexForItemData(self.myProxyYA.displayHatched.Integer);  //cnwjo3 par 24145
		self.txtPriorityAdj.text		:= self.myProxyYA.priorityAdjustment.String;
		self.chkTestOverstow.value		:= self.myProxyYA.isTestOverstowWeight;
		self.cmbFillOptionIn.setIndexForItemData( self.myProxyYA.fillOptionIn );
		self.cmbFillOptionOut.setIndexForItemData( self.myProxyYA.fillOptionOut);
		self.txtProjected20.text := self.myProxyYA.projected20.String;
		self.txtProjected30.text := self.myProxyYA.projected30.String;
		self.txtProjected40.text := self.myProxyYA.projected40.String;
		self.txtProjected45.text := self.myProxyYA.projected45.String;
		self.txtProjected53.text := self.myProxyYA.projected53.String;
		self.cmbMultiRange.setIndexForItemData( self.myProxyYA.allowMultiRangeSplit );	//15 Jun 2016	NDL	TFS 2172
	endif;
	
	self.showTblGCQuantity( self.myProxyYA );	//31 Mar 2021	NDL	TFS 49912
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTemplates" id="59b6349f-3418-4b8a-abd2-d1cce9adb250">
        <source>populateTemplates();
//30 January 2009	cnwdw1	
//
vars

begin
	self.cmbYATemplate.clear();
	self.cmbYATemplate.listCollection(self.allYATemplates, false, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeForCriteria" id="19c2a1f9-b3af-46dd-b2f4-32163ac156bd">
        <updating/>
        <source>resizeForCriteria( _adjustment : Real ) updating;
/*
Purpose:		Resize form to fit criteria
Date			Who		Reason
20 August 2008	consw1	Initial creation

*/
constants
	MinimumDisplayIndex = 4;		// Minimum number of criteria frames to allow space for.
vars
	adjustment		: Real;
	maxOpCriteria	: Integer;
	imex			: CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
begin

	//08 Oct 2013	NDL	Par 32456
	self.picCriteria.visible := true;
	maxOpCriteria := self.getNumCriteriaToDisplay();
	self.picCriteria.height := ( _adjustment * maxOpCriteria );
	self.picCriteria.width := self.shtCriteria.width - 8; //TFS 1766 cnwns1
	
	/*
	// PAR 19462 Find the imex with the largest number of operational criteria
	// and then resize the form to be ablew to display them
	foreach imex in app.myRoot.allImexStatuses do
		//cnwjo3, par 20306, lots more conditions
		if self.myTerminal &lt;&gt; null then
			if self.myTerminal.myYAConfig &lt;&gt; null then
				if self.myTerminal.myYAConfig.allYAIMEXConfigs.size &gt; 0 then
					yaIMEXConfig := self.myTerminal.myYAConfig.allYAIMEXConfigs[imex.code];
					
					if yaIMEXConfig &lt;&gt; null and yaIMEXConfig.allOpCriteria.size &gt; maxOpCriteria then
						maxOpCriteria := yaIMEXConfig.allOpCriteria.size;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	//par 19758 cnwjo3, if the user only has a maximum of 3 criteria
	//was cutting off fields in the 'Options' tab.
	if maxOpCriteria &lt; 4 then
		maxOpCriteria := 4;
	endif;
	*/

	adjustment := _adjustment * (maxOpCriteria - MinimumDisplayIndex);

	self.height					:= self.height + adjustment;
	//self.fldYardAlloc.height	:= self.fldYardAlloc.height + adjustment;
	//self.txtRemarks.height		:= self.txtRemarks.height + adjustment;

	self.lblGroupName.top		:= self.lblGroupName.top + adjustment;
	self.txtGroupName.top		:= self.txtGroupName.top + adjustment;
	self.grpTemplate.top		:= self.grpTemplate.top + adjustment;

	// cnwjk3 SFW1030
	self.clrYAColour.top 		:= self.clrYAColour.top + adjustment; 
	self.lblYAColour.top 		:= self.lblYAColour.top + adjustment;
epilog

end;</source>
        <Parameter name="_adjustment" type="Real"/>
    </JadeMethod>
    <JadeMethod name="saveData" id="97e1c70b-3f61-406d-b435-cc9905121b12">
        <updating/>
        <source>saveData(_saveAs: Boolean) : Boolean updating;

/*

Purpose:		Standard method to perform a "Save" operation.

Parameters:		None	

Return Value:	True if the save ws successful, otherwise false.


Date			Who		Reason
05 August 2008	consw1	Initial creation
//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	terminalObj				: CM_Terminal;
	yardAllocationObj		: CM_YardAllocation;
	proxyYAObj				: CM_YardAllocation;
	fillOptionIn			: Integer;
	fillOptionOut			: Integer;
	yaCode					: String;
	yaDescription			: String;
	yaRemarks				: String;
	expiryType				: Integer;
	expiryDate				: Date;
	allowOthers				: Integer;
	noLocation				: Integer;
	priorityAdj				: Integer;
	isTestOverstowWeight	: Boolean;
	isDisabled				: Boolean;
	allTransientCriteriaObj	: CMIF_Array;
	yaColor					: Integer;
	overstowRule			: CM_YAOverstowRule;
	blockGroupsInColl		: CM_YABlockGroupArray;
	blockGroupsOutColl		: CM_YABlockGroupArray;
	result					: Integer;
	createYA				: Boolean;
	mode					: Integer;
	displayHatched			: Boolean;
	expiryTS				: TimeStamp;

begin
	
	if _saveAs then
		self.myYardAllocation := null;
	endif;


	
	proxyYAObj			:=	self.myProxyYA;
	yardAllocationObj	:=	self.myYardAllocation;
	
	//if self.myYardAllocation is null then its a new Yard Allocation (cnwjo3)
	createYA := (yardAllocationObj = null);  
	
	//par 20290 cnwjo3, if this has been created during warning/error loop then purge and recrete below
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
	endif;
	
	create allTransientCriteriaObj transient;
	self.getCriteriaAllCMIF( allTransientCriteriaObj );

	self.saveDataRanges();
	create blockGroupsInColl transient;
	proxyYAObj.allYABlockGroupsIn.copy( blockGroupsInColl );

	create blockGroupsOutColl transient;
	proxyYAObj.allYABlockGroupsOut.copy( blockGroupsOutColl );

	terminalObj				:=	self.getTerminal();
	fillOptionIn			:=	self.cmbFillOptionIn.getCurrentItemData();
	fillOptionOut			:=	self.cmbFillOptionOut.getCurrentItemData();
	yaCode					:=	self.txtYACode.cnEcString();
	yaDescription			:=	self.txtYADescription.cnEcString();
	if yaDescription = "" then
		yaDescription := yaCode;
	endif;
	yaRemarks				:=	self.txtRemarks.cnEcString();
	expiryType				:=	self.getExpiryType();
	//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	expiryTS.cnEcSetDateAndTime(self.dateExpiryDate.getDate(),TimeEndOfDay);
	expiryDate				:= self.localToSystemTime(expiryTS).date();
//	expiryDate				:=	self.dateExpiryDate.getDate();

	yaColor					:=	self.clrYAColour.getColor();
	displayHatched			:=	self.cmbDisplayHatche.getCurrentItemData().Boolean;  //cnwjo3 par 24145
	allowOthers				:=	self.cmbAllowOthers.getCurrentItemData();
	noLocation				:=	self.cmbNoLocation.getCurrentItemData();
	overstowRule			:=  self.cmbOverstowRule.listObject.CM_YAOverstowRule;
	priorityAdj				:=	self.txtPriorityAdj.cnEcInteger();
	isTestOverstowWeight	:=	self.chkTestOverstow.value;
	isDisabled				:=	self.chkDisableYA.value;

	proxyYAObj.setProxy(yaCode,
						yaDescription,
						yaRemarks,
						fillOptionIn,
						fillOptionOut,
						expiryType,
						expiryDate,
						yaColor,
						displayHatched,  //cnwjo3 par 24145
						allowOthers,
						noLocation,
						overstowRule,
						priorityAdj,
						isTestOverstowWeight,
						isDisabled,
						blockGroupsInColl,
						blockGroupsOutColl,
						false,
						terminalObj);
	proxyYAObj.setProxyProjectedValues(txtProjected20.text.Integer, txtProjected30.text.Integer, txtProjected40.text.Integer, txtProjected45.text.Integer, txtProjected53.text.Integer, self.getTblGCQuantity); 
	
	self.setAdditional(proxyYAObj); // PAR 32308
	
	proxyYAObj.setYATemplate( cmbYATemplate.listObject.CM_YATemplate, self.isTemplateModified );
	
	//epr par 28388 only loop after the proxy is creeted if we got warnings and was creating proxy in loop would end up leaking transients
	while true do
		if createYA then
			app.myTrxCA.trxCreateYardAllocation(proxyYAObj, allTransientCriteriaObj, yardAllocationObj, app.myPassport);
		else
			app.myTrxUA.trxUpdateYardAllocation(proxyYAObj, allTransientCriteriaObj, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			//cnwjo3 par 23253
			//set YA so we can select item in table on CMUI_YAMForm
			self.myYardAllocation := yardAllocationObj;
			return true;
		else
			if app.myPassport.hasErrors then
				mode := ErrWarnMode_Update;  //do allow save if there are errors
			else
				mode := ErrWarnMode_Update+ErrWarnMode_CanAckWarnSkipErr;  //need a Save if only warnings
			endif;
			
			result := app.showErrorWarningDialog("Yard Allocation", app.myPassport, mode);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			else
				return false;
			endif;
		endif;
	endwhile;
	
	return true;
	
epilog
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
	endif;
	delete allTransientCriteriaObj;
	delete blockGroupsInColl;
	delete blockGroupsOutColl;
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveDataBulk" id="f9dc5c4a-70d1-4ff9-8b10-583b86a3891a">
        <updating/>
        <source>saveDataBulk(_saveAs: Boolean) : Boolean updating;
vars
	ya, proxyYA: CM_YardAllocation;
	criteria, proxyCriteria: CM_YACriteria;
	criteriaCtrl: CMUI_YACriteriaCntl;
	cmifCriteria: CMIF_YACriteriaPriority;
	yaCode					: String;
	yaRemarks				: String;
	yaColor					: Integer;
	allTransientCriteriaObj	: CMIF_Array;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	//par 19363, clear out any invalid objects
	self.allBulkEditYAs.removeInvalidObjects();
	
	foreach ya in self.allBulkEditYAs do
		proxyYA :=	app.createUpdateProxy(ya).CM_YardAllocation;
		
		yaCode := ya.code;
		create allTransientCriteriaObj transient;
		foreach criteria in ya.allCriteria do
			criteriaCtrl := self.locateControlForCriteriaType(criteria.myYACriteriaType);
			proxyCriteria := null;
			if criteriaCtrl &lt;&gt; null and criteriaCtrl.enabled then
				if criteriaCtrl.getDisplayForGroupName &lt;&gt; criteriaCtrl.getOldGroupName then
					cmifCriteria := criteria.getTransient();
					// set new criteria value
					proxyCriteria := cmifCriteria.myProxy.CM_YACriteria;
					proxyCriteria.setProxy(proxyCriteria.myYACriteriaType, criteriaCtrl.getValue(), proxyCriteria.code);
					if _saveAs then
						cmifCriteria.setFlag(true, false, false);	// New
					else
						cmifCriteria.setFlag(false, true, false);	// Edit
					endif;
					allTransientCriteriaObj.add(cmifCriteria);
					// update the ya code
					yaCode := yaCode.replace(criteriaCtrl.getOldGroupName, criteriaCtrl.getDisplayForGroupName);
				endif;
			endif;
			if _saveAs and proxyCriteria = null then
				cmifCriteria := criteria.getTransient();
				// set new criteria value
				proxyCriteria := cmifCriteria.myProxy.CM_YACriteria;
				cmifCriteria.setFlag(true, false, false);	// Create
				allTransientCriteriaObj.add(cmifCriteria);
			endif;
		endforeach;
		proxyYA.setCode(yaCode);
		proxyYA.setRemarks(self.txtRemarks.cnEcString());
		if self.clrYAColour.visible then
			proxyYA.setColor(self.clrYAColour.getColor());
		endif;
		proxyYA.setDisabled(self.chkDisableYA.value);
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			if _saveAs then
				app.myTrxCA.trxCreateYardAllocation(proxyYA, allTransientCriteriaObj, ya, app.myPassport);
			else
				app.myTrxUA.trxUpdateYardAllocation(proxyYA, allTransientCriteriaObj, app.myPassport);
			endif;
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog("Yard Allocation", app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return false;
			
		endwhile;
	
		if allTransientCriteriaObj &lt;&gt; null then
			allTransientCriteriaObj.purge;
		endif;
		delete allTransientCriteriaObj;
		delete proxyYA;
	endforeach;
	
	return true;
	
epilog
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
	endif;
	delete allTransientCriteriaObj;
	delete proxyYA;
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveDataRanges" id="8093efab-7412-4f0c-9dd2-567ffaa6606b">
        <updating/>
        <source>saveDataRanges() updating;
//13 February 2009	cnwdw1	
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------
// 16/11/2011	cnwdap1		PAR #28514 Correct the conflict between PARs 28388 and 28503
// 02/12/2011	cnwdap1		PAR #28779 save off decking rules for the YA blocks in the table
//							so we can re-instate them later when the YA block proxies are re-created
// 03/07/2012	cnwer1		PAR 29889 - Decking rules were being removed when range was changed - because any
//							update was removing the row and adding a new row
// 22/12/2015   cnwma1      PAR #37100 Failed to autoplan, no space
// 06/11/2024	navdap1		MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
vars
	yaAgent: CM_YAAgent;
	row: Integer;
	yaBlock: CM_YABlock;
	range: String;
	pos : Integer;				// PAR #28514
	taStr : String;				// PAR #28514
	ta : CM_TerminalArea;		// PAR #28514
	invalidYABlock : Boolean;
	edition : Integer;
	firstBlock : CM_YAIrregularBlock;	// MTN-18897
	blockTa : CM_TerminalArea;			// MTN-18897

begin	
	create yaAgent transient;
	yaBlock := null;// PAR #28779
	
	on Exception do app.handleDeletedObject(exception,yaBlock,invalidYABlock);	//23 Jul 2014	NDL	Par 34393
	
	self.myProxyYA.setIsFullGCArea(false);		// MTN-18897
	
	foreach row in 1 to self.tblLocation.rows do
		invalidYABlock := false;	//23 Jul 2014	NDL	Par 34393
		// So, in order to check whether this is still a valid terminal area,
		// get the description of the terminal area from the table, and see if it's still valid
		range := self.tblLocation.accessCell(row, 1).text;
		
		if range = null
		and self.tblLocation.accessRow(row).visible	//20 Aug 2019	NDL	TFS 46172 - no range and invisible ones need to be deleted later in the code
		then // TFS 43424 test team got a dump becase range was null. Could not reproduce and this is nothing to do with changes made for this TFS.
			continue;
		endif;
		
		if self.tblLocation.accessRow(row).visible then
			pos := 1;
			taStr := range.scanUntil(" ", pos);
			if taStr &lt;&gt; null then
				ta := self.myTerminal.allTerminalAreas[taStr];
			endif;
			if ta = null then
				app.raiseCMException1(Err_InvalidYARange, range, null, null);
			endif;
		endif;
		yaBlock := self.tblLocation.accessCell(row, 1).itemObject.CM_YABlock;
				
		if self.tblLocation.accessRow(row).visible then
			if yaBlock = null then
				// New so add it
				// on the newly created proxy YA block with the saved decking rule
				yaBlock:=yaAgent.addRange(self.myProxyYA, range);
				self.tblLocation.accessCell(row, 1).itemObject:=yaBlock;
			else
				// existing, so update
				yaAgent.updateRange(yaBlock,range);  //cnwjo3 par 24293.  see method comments before using this
				yaBlock.updateProxyDeckingOptions();    //cnwma1 22/12/2015 PAR #37100
			endif;
			// MTN-18897 start
			if yaBlock.isKindOf(CM_YAIrregularBlock) then
				if yaBlock.CM_YAIrregularBlock.myYABlockGroupIn &lt;&gt; null 
				and yaBlock.CM_YAIrregularBlock.myYABlockGroupIn.allYABlocksIn.isNotEmpty then
					firstBlock := yaBlock.CM_YAIrregularBlock.myYABlockGroupIn.allYABlocksIn.first.CM_YAIrregularBlock;
					blockTa := firstBlock.myTerminalArea;
					if blockTa &lt;&gt; null and (firstBlock.description = blockTa.id &amp; ";" or firstBlock.getDisplayDetails(false) = blockTa.id) then
						self.myProxyYA.setIsFullGCArea(true);
					endif;
				endif;
			endif;
			// MTN-18897 end
		else
			if yaBlock &lt;&gt; null then
			
				//23 Jul 2014	NDL	Par 34393
				edition := yaBlock.edition;
				if invalidYABlock then
					continue;
				endif;
				
				// Has been deleted
				yaAgent.deleteYABlock(self.myProxyYA, yaBlock);
			endif;
		endif;
	endforeach;
epilog
	delete yaAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAdditional" id="0fdf4595-275f-40fc-be3c-959964568b2a">
        <source>setAdditional(proxyYAObj				: CM_YardAllocation input);
