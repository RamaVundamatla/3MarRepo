    <JadeMethod name="setForUpdate" id="c73e1b97-e129-487c-ae75-a64c32ffd8e9">
        <updating/>
        <source>setForUpdate(proxy: CM_PalletType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin
	inheritMethod(proxy);
	
	self.heatTreated := proxy.heatTreated;

epilog

end;</source>
        <Parameter name="proxy" type="CM_PalletType"/>
    </JadeMethod>
