    <JadeMethod name="translateForm" id="bdc3d085-3a8b-4de6-8320-9e7460d8b371">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006969, locale);
	btnAbort.translateBubbleHelp(Xlat_0003778, locale);
	btnAbort.translateCaption(Xlat_0003781, locale);
	btnBackup.translateBubbleHelp(Xlat_0003779, locale);
	btnBackup.translateCaption(Xlat_0003782, locale);
	btnEdit.translateBubbleHelp(Xlat_0003780, locale);
	btnEdit.translateCaption(Xlat_0003783, locale);
	btnReset.translateBubbleHelp(Xlat_0016844, locale);
	btnReset.translateCaption(Xlat_0016845, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0006970, locale);
	mnuContext.translateCaption(Xlat_0006971, locale);
	shtBackup.translateCaption(Xlat_0003784, locale);
	shtDBHistory.translateCaption(Xlat_0003785, locale);
	shtJournalHist.translateCaption(Xlat_0003786, locale);
end;</source>
    </JadeMethod>
