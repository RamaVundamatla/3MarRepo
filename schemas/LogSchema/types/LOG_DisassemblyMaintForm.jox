    <JadeMethod name="getAvailableLocations" id="ed0e3601-4d45-4f0b-b8e2-a7e48f8e1fa1">
        <source>getAvailableLocations() protected;

vars

	grade			: CM_LogGrade;
	type			: CM_LogType;
	treatment		: CM_LogTreatment;
	length			: CM_LogLength;
	operator		: CM_Operator;
	species			: CM_LogSpecies;
	logArea			: CM_LogArea;
	logController	: CM_LogController;
	tmpLCSearch		: CMIF_SearchTypes;
	listObj			: Object;

begin

	listObj := self.cmbNewLocation.listObject;
	
	self.allToLocations.clear;
	self.cmbNewLocation.clear;
	self.tblActionData.setValueByName(ETRow_Location, null);
	//Par10284	
	if self.myLog = null then
		return;
	endif;	
	operator := self.myLog.myOperator;
	species := self.myLog.myLogSpecies;
	
	// Get currently selected specs.
	grade		:= self.cmbNewGrade.listObject.CM_LogGrade;
	length		:= self.cmbNewLength.listObject.CM_LogLength;
	type		:= self.cmbNewType.listObject.CM_LogType;	
	treatment	:= self.cmbNewTreatment.listObject.CM_LogTreatment;

	create tmpLCSearch transient;
	tmpLCSearch.myOperator := operator;
	tmpLCSearch.mySpecies := species;
	tmpLCSearch.myGrade := grade;
	tmpLCSearch.myType := type;
	tmpLCSearch.myTreatment := treatment;
	tmpLCSearch.myLength := length;

	self.myTerminal.availableLocationsForType(tmpLCSearch, self.allToLocations, TA_TYPE_LOGAREA);
	self.myAssistant.comboBoxAddLocationsWithNull(self.cmbNewLocation, self.allToLocations);
	self.tblNewLogDetail.setValueByName(ETRow_NewLocn, null);
	
	// Par 9820
	if self.cmbNewLocation.findObject(listObj) &lt;&gt; 0 then
		self.cmbNewLocation.listObject := listObj;
	endif;


epilog
	
	delete tmpLCSearch;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getId" id="d54f0bbc-42b9-4dbf-852a-5c222de8afd7">
        <updating/>
        <source>getId() updating, protected;

vars

	logId						: String;
	log							: CM_Log;
	display,
	terminologyOperator 		: String;
	location					: CM_LocationsController;
	failedDAC  :CM_DataAccessController;

begin

	if self.selection = LOGID then
		logId := self.tblSelection.getValueByName(ETRow_LogId).String;
	else
		logId := self.tblSelection.getValueByName(ETRow_LogIdMulti).String;
	endif;
	if self.myLog = null or (self.myLog &lt;&gt; null and self.myLog.id &lt;&gt; logId) then
		clearDisplay();
		self.tblActionData.userInputEnabled := true;
		self.allNewLogs.purge;
		// Turn off split container.
		splitContainer.hideLeftControl(true);
		self.txtDetails.text := null;
		if logId &lt;&gt; null then
			// Try and find appropriate log.
			log := self.myTerminal.lookupTrackedItem(logId, TI_CargoType_Log, TI_STATE_NORMAL, null, false).CM_Log;
			if log &lt;&gt; null and log.canUserAccessSelf(null, failedDAC, app.myPassport) then
				terminologyOperator := self.terminologyForOperatorLog;
				self.txtDetails.text := log.displayLogDetail(terminologyOperator , self.getTextExtent(terminologyOperator));
				self.myLog := log;
				self.tblSelectData.tabStop := false;
				loadGradeCombo();
				self.tblNewLogDetail.userInputEnabled := true;
				self.setButtons(true);
				return;
			endif;
			// Try again.
			if logId &lt;&gt; self.prevLogSearch then
				self.tblSelection.goToRowByName(ETRow_LogId);
				self.tblSelection.setFocus;
				app.raiseCMException1(LogNotFound, logId, null, null);
			endif;
		endif;
	endif;
epilog
	self.prevLogSearch := logId;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getNewLogDetail" id="90ca9443-196e-48ad-8c64-7bac178cc34f">
        <source>getNewLogDetail(_newId, _newGrade, _newLength, _newType, _newTreatment, _newMin, _newMax, _newLoc : String output) : Boolean protected;


begin

	_newId 			:= self.tblNewLogDetail.getValueByName(ETRow_NewLogId).String;
	_newGrade		:= self.tblNewLogDetail.getValueByName(ETRow_Grade).String;
	_newLength		:= self.tblNewLogDetail.getValueByName(ETRow_Length).String;
	_newMin			:= self.tblNewLogDetail.getValueByName(ETRow_SedMin).String;
	_newMax			:= self.tblNewLogDetail.getValueByName(ETRow_SedMax).String;
	_newLoc			:= self.tblNewLogDetail.getValueByName(ETRow_NewLocn).String;
	_newTreatment	:= self.tblNewLogDetail.getValueByName(ETRow_Treatment).String;
	_newType		:= self.tblNewLogDetail.getValueByName(ETRow_Type).String;
	
	
	self.tblNewLogDetail.setFocus;
	if _newId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'New ID', null, null);
		app.raiseCMException(Input_required_field_newID,  null, null); // cnwdb2	PAR 35364
		
	elseif _newGrade = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'New Grade', null, null);
		app.raiseCMException(Input_required_field_gradeFld, null, null); // cnwdb2	PAR 35364

	elseif _newLength = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'New Length', null, null);
		app.raiseCMException(Input_required_field_newlgth, null, null); // cnwdb2	PAR 35364

	elseif _newMin = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'New SEDMin', null, null);
		app.raiseCMException(Input_required_field_sedMin, null, null);// cnwdb2	PAR 35364

	elseif _newMax = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'New SEDMax', null, null);
		app.raiseCMException(Input_required_field_sedMax, null, null); // cnwdb2	PAR 35364


	elseif _newLoc = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'New Location', null, null);
		app.raiseCMException(Input_required_field_newLocn, null, null); // cnwdb2	PAR 35364

	endif;
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_newId" type="String" usage="output"/>
        <Parameter name="_newGrade" type="String" usage="output"/>
        <Parameter name="_newLength" type="String" usage="output"/>
        <Parameter name="_newType" type="String" usage="output"/>
        <Parameter name="_newTreatment" type="String" usage="output"/>
        <Parameter name="_newMin" type="String" usage="output"/>
        <Parameter name="_newMax" type="String" usage="output"/>
        <Parameter name="_newLoc" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDisplayTable" id="142651cb-79aa-45d0-be13-21024d033d77">
        <source>initDisplayTable() protected;

vars

begin

	self.tblDisplayDetail.rows := self.tblDisplayDetail.fixedRows;
	// If we have something to display then build table.
	self.tblDisplayDetail.columns := 6;
	self.tblDisplayDetail.accessCell(1,1).text := 'ID' &amp; Tab &amp; 'Grade' &amp; Tab &amp; 'Length' &amp; Tab &amp; 'Type' &amp; Tab &amp; 'Treatment' &amp; Tab &amp; 'Location';
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTables" id="9c983e62-c031-4a33-8192-3ee283e7e6b5">
        <updating/>
        <source>initTables() updating, protected;

vars

	entTableControl	: EntTableDef;

begin

	self.tblNewLogDetail.width := self.tblSelection.width;

	// A little different from superclass so re write of initTables.
	entTableControl := app.myController.getEntTableDef(ETDef_TADisassembly);
	self.tblNewLogDetail.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblNewLogDetail.optimiseHeadingColumn();
	self.tblNewLogDetail.resetSize();
//	self.tblNewLogDetail.optimiseHeadingColumn();

	// Setup selection table.
	// Need this to set form height correctly with new Jade 6 resize.
	self.splitterFrame.height := 180;
	self.txtDetails.height := self.splitContainer.height - self.txtDetails.top;
	entTableControl := app.myController.getEntTableDef(ETDef_TALogSelection);
	self.tblSelection.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblSelection.resetSize();
	self.tblSelection.optimiseHeadingColumn();
	
		// Setup action table.
	entTableControl := app.myController.getEntTableDef(ETDef_TADisassemblyAction);
	self.tblActionData.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblActionData.optimiseHeadingColumn();
	self.tblActionData.resetSize();
	self.setActionTableView();

	// Do resizing stuff.		
	self.tblSelection.setDistanceFromRight(23);
	self.tblSelection.lockBottom := false;
	self.tblSelection.lockRight := false;
	self.tblSelection.stretchHeight := false;
	self.tblSelection.stretchWidth := true;
	self.tblSelection.optimiseRowHeight := true;
	self.tblSelection.cnEcResizeContents();
	
	// Setup New log details table.	
	self.tblNewLogDetail.left := self.tblSelection.left;
	self.tblNewLogDetail.setDistanceFromBottom(200);
	self.tblNewLogDetail.setDistanceFromRight(22);
	self.tblNewLogDetail.lockBottom := true;
	self.tblNewLogDetail.lockRight := false;
	self.tblNewLogDetail.stretchHeight := false;
	self.tblNewLogDetail.stretchWidth := true;
	self.tblNewLogDetail.cnEcResizeContents();
		
	// Setup Display table.
	
	self.tblDisplayDetail.left := self.tblSelection.left;
	self.tblDisplayDetail.height := 65;
	self.tblDisplayDetail.setDistanceFromBottom(90);
	self.tblDisplayDetail.setDistanceFromRight(22);
	self.tblDisplayDetail.lockBottom := true;
	self.tblDisplayDetail.lockRight := true;
	self.tblDisplayDetail.stretchHeight := false;
	self.tblDisplayDetail.stretchWidth := true;
	
	

	// Setup action table.
	self.tblActionData.setDistanceFromBottom(43);
	self.tblActionData.setDistanceFromRight(22);
	self.tblActionData.lockBottom := true;
	self.tblActionData.lockRight := true;
	self.tblActionData.stretchHeight := false;
	self.tblActionData.stretchWidth := true;
	
	self.splitterFrame.distanceFromRight := 23;
	centreWindow;
	self.allNewLogs.purge;
	self.tblNewLogDetail.userInputEnabled := false;
	self.setButtons(false);
	
	self.doOptTicketClick();
	self.optLogId.value := true;
	if app.myRoot.getConfig(BackgroundReportsAvailable).Boolean then
		self.btnBackground.enabled := true;
	else
		self.btnBackground.enabled := false;
	endif;
	self.lblResidualH.left	:= self.tblSelection.left;
	self.lblResidual.left := self.lblResidualH.left + self.lblResidualH.width + 5;
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="650ffe56-de81-4295-872a-9912c3270c8b">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars
	theActiveControl	: Control;
	
begin

	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	if keyCode = J_key_Tab then
		tblSelection.handleFormTab(keyCode, shift, optLocation, self.tblNewLogDetail);
		tblNewLogDetail.handleFormTab(keyCode, shift, tblSelection, self.btnAdd);
		if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	else
		inheritMethod(keyCode, shift);		
	endif;
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="d55f24ff-a201-4069-bb98-ce4025f0fa9c">
        <source>loadCombos() protected;

vars

begin
	inheritMethod();
	self.cmbNewLocation.listCollection(allLocations, false, 0);
	// CMUI_ComboObjects used - populated on gotfocus
//	self.myAssistant.comboBoxGeneral(self.cmbReason, app.myRoot.allLogRejectCodes);
//	self.myAssistant.comboBoxGeneral(self.cmbRecovery, app.myRoot.allLogRejectRecoveryCodes);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadGradeCombo" id="347cc515-343d-4bcf-bd54-79dc97f329df">
        <source>loadGradeCombo() protected;

vars

	species 	: CM_LogSpecies;
	location	: CM_LocationsController;
	
begin

	if self.myLog &lt;&gt; null then
		species := self.myLog.myLogSpecies;
		if species &lt;&gt; null then
//		self.myAssistant.comboBoxGeneral(self.cmbNewGrade, species.allLogGrades);	
			self.cmbNewGrade.setObjectAndSpecies(null,species);
		endif;
		if self.myLog.myLogGrade &lt;&gt; null then
	//		self.tblNewLogDetail.setValueByName(ETRow_Grade, self.myLog.myLogGrade.code);
		//	self.cmbNewGrade.listObject := self.myLog.myLogGrade;
			loadSpecCombos(self.myLog.myLogGrade);
		endif;
		self.tblNewLogDetail.setValueByName(ETRow_SedMin, self.myLog.sedMin.String);
		self.tblNewLogDetail.setValueByName(ETRow_SedMax, self.myLog.sedMax.String);
//		self.tblNewLogDetail.setValueByName(ETRow_Length, self.myLog.lengthCode);
		self.myAssistant.setLogGradeComboObjects(species, self.myLog.myLogGrade, self.myLog.myLogType, self.myLog.myLogTreatment, self.myLog.myLogLength,
					tblNewLogDetail, self.cmbNewGrade, self.cmbNewType, self.cmbNewTreatment, self.cmbNewLength);

//		self.tblNewLogDetail.setValueByName(ETRow_Type, self.myLog.typeCode);
//		self.cmbNewType.listObject := self.myLog.myLogType;
//		self.tblNewLogDetail.setValueByName(ETRow_Treatment, self.myLog.treatmentCode);
//		self.cmbNewTreatment.listObject := self.myLog.myLogTreatment;
		location := self.myLog.getPrimaryLocation(REAL_MODE);
		self.reselectToCombo(self.cmbNewLocation, self.tblNewLogDetail);
		if location &lt;&gt; null then
			self.getAvailableLocations();
			if self.cmbNewLocation.findObject(location) &lt;&gt; -1 then
				self.tblNewLogDetail.setValueByName(ETRow_NewLocn, location.getID);
				self.cmbNewLocation.listObject := location;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadLogsForLocation" id="035c108b-835b-4856-b2b7-31e78ae4f0bf">
        <source>loadLogsForLocation(_location : CM_LogController) protected;


begin

	self.cmbIds.listCollection(_location.allTrackedItems, false, 0);

end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_LogController"/>
    </JadeMethod>
    <JadeMethod name="loadNewLog" id="0c9c8ac5-f1e7-4924-b7af-780e0c3b1a0f">
        <source>loadNewLog() protected;

vars

	grade 	: CM_LogGrade;
	length	: CM_LogLength;

begin

	if self.myLog &lt;&gt; null and self.mySelectedNewLog &lt;&gt; null then
		if self.myLog.myOperator &lt;&gt; null then
			grade :=  self.myLog.myOperator.getLogGrade(self.myLog.myLogSpecies.code, self.mySelectedNewLog.gradeCode);
		endif;
		if grade &lt;&gt; null then
			loadSpecCombos(grade);
			self.tblNewLogDetail.setValueByName(ETRow_Grade, grade.code);
//			self.cmbNewGrade.listObject := grade;
			self.cmbNewGrade.setObject(grade);
			self.tblNewLogDetail.setValueByName(ETRow_NewLogId, self.mySelectedNewLog.id);
			self.tblNewLogDetail.setValueByName(ETRow_Length, self.mySelectedNewLog.length);
//			self.cmbNewLength.listObject := grade.getAvailableLogLengthsForGrade[self.mySelectedNewLog.length];
			self.cmbNewLength.setObject(grade.getAvailableLogLengthsForGrade[self.mySelectedNewLog.length]);
			self.tblNewLogDetail.setValueByName(ETRow_Type, self.mySelectedNewLog.type);
//			self.cmbNewType.listObject := grade.getAvailableTypesForGrade[self.mySelectedNewLog.type];
			self.cmbNewType.setObject(grade.getAvailableTypesForGrade[self.mySelectedNewLog.type]);
			self.tblNewLogDetail.setValueByName(ETRow_Treatment, self.mySelectedNewLog.treatment);
//			self.cmbNewTreatment.listObject := grade.getAvailableTreatmentsForGrade[self.mySelectedNewLog.treatment];
			self.cmbNewTreatment.setObject(grade.getAvailableTreatmentsForGrade[self.mySelectedNewLog.treatment]);
			self.tblNewLogDetail.setValueByName(ETRow_SedMin, self.mySelectedNewLog.sedMin.String);
			self.tblNewLogDetail.setValueByName(ETRow_SedMax, self.mySelectedNewLog.sedMax.String);
			self.tblNewLogDetail.setValueByName(ETRow_NewLocn, self.mySelectedNewLog.location);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
