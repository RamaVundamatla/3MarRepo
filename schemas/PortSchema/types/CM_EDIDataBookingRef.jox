    <JadeMethod name="getStatusAfterVerifyOrDBLoad" id="a1b3bf65-b9fc-41dd-8704-51799143bc44">
        <source>getStatusAfterVerifyOrDBLoad(_verifyOnly :Boolean; _passport :CM_Passport):Integer;
/*
Date		Who		Reason
26/06/012	cnwcs5	Initial creation - par 29747:2 (not included in 8.1.1 patch)
13/08/2012	cnwcs5	par 29124 - included in 8.1.1.patch
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 17 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
*/
vars
	status	:Integer;
begin
	if self.canGetStatusFromEDITrackedItem then
		status := self.getStatusFromEDITrackedItems(_verifyOnly);
	else
		if _verifyOnly then	
			if _passport.noErrors and _passport.noWarnings then
				status := CM_EDIFile.EDI_STATUS_VERIFIED;
			else
				if _passport.hasErrors then
					//epr par 37090 23/10/15
					if _passport.allErrors.includesErrorCode(Voyage_departed) then
						status := CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X;
					else
						status := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
					endif;
				else
					status := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
				endif;
			endif;
		else	// db loading
			if _passport.hasErrors() then
				//epr par 37090 23/10/15
				if _passport.allErrors.includesErrorCode(Voyage_departed) then
					status := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X;
				else
					status := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
				endif;
			else
				status := CM_EDIFile.EDI_STATUS_DBLOADED;
			endif;
		endif;
	endif;
	return status;
epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStatusFromEDITrackedItems" id="f5a50786-031f-4806-a131-6af1d7af1fd9">
        <source>getStatusFromEDITrackedItems(_verifyOnly: Boolean): Integer;
//
// 09 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
//
vars
	ediTI : CM_EDITrackedItem;
	newStatus, oldStatus, total, skipped, 
	dbLoaded, verified, warnings, errors, 
	todo : Integer;
	isToBePartiallyLoaded : Boolean;
begin
	if not self.canGetStatusFromEDITrackedItem then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for invalid EDI data type");
		return null;
	endif;
	isToBePartiallyLoaded := self.canBePartiallyLoaded();	
	total		:= self.allEDITrackedItems.size;
	newStatus 	:= CM_EDIFile.EDI_STATUS_UNPROCESSED;
	
	if total &gt; 0 then
		// it is a shame we have to go through all the EDI TIs but 
		// generally (MSK) there is only 1 per file
		foreach ediTI in self.allEDITrackedItems discreteLock do
			if not ediTI.isKindOf(CM_EDIBookingRefTI) then
				total := total - 1;
				continue;
			endif;
			oldStatus := ediTI.status;
			
			if oldStatus = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED then
				todo := todo + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
				dbLoaded := dbLoaded + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
				// we are ignoring this one
				total := total - 1;
			
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
				skipped := skipped + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED then
				verified := verified + 1;
				
			elseif oldStatus = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
				if _verifyOnly then
					warnings := warnings + 1;
				else
					dbLoaded := dbLoaded +1;
				endif;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS or 
				oldStatus = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS then
			
				errors := errors + 1;				
			endif;
		endforeach;
	
		if todo = total then
			// nothing processed
			if todo &gt; 0 then
				newStatus := CM_EDIFile.EDI_STATUS_LOADED;
			else
				// probably ignored everything
				if _verifyOnly then
					newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
				else
					newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
				endif;
			endif;
		elseif dbLoaded = total then 
			// everything loaded
			if _verifyOnly then
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
			else
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
			endif;
		elseif dbLoaded &gt; 0 then
			// file is partially loaded
			if skipped + dbLoaded = total then
				// all either loaded or skipped
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X;
			else
				// some skipped, some loaded, some yet to be loaded
				if isToBePartiallyLoaded then
					newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
				else
					newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
				endif;
			endif;
		else	
			// nothing loaded
			if _verifyOnly then
				if skipped &gt; 0 then
					if skipped = total then
						// everything has been skipped
						newStatus := CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X;
					elseif skipped + verified = total then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
					elseif skipped + verified + warnings = total then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
					else
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
					endif;
				else
					// still some stuff that has not loaded
					if errors &gt; 0 then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
					elseif warnings &gt; 0 then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
					else
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
					endif;
				endif;
			else	//dbloaded
				if skipped &gt; 0 then
					if skipped = total then
						// everything has been skipped
						newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X;
//					elseif skipped + verified = total then
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
//					elseif skipped + verified + warnings = total then
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
					else
						if isToBePartiallyLoaded then
							newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
						else
							newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
						endif;
					endif;
				else
					// still some stuff that has not loaded
//					if errors &gt; 0 then
						if isToBePartiallyLoaded then
							newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
						else
							newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
						endif;
//					elseif warnings &gt; 0 then
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
//					else
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
//					endif;
				endif;
			endif;
		endif;
	endif;
//write class.name&amp;'::'&amp;method.name&amp;' 145 '&amp;self.String&amp;' '&amp;newStatus.String;

	
	return newStatus;
epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIProperties" id="94d9cc07-ef93-426c-bedb-3e628b9febcd">
        <source>getTIProperties(_propArray: ObjectArray io);

vars
	popColl: PropertyNDict;
	property: Property;
begin
	inheritMethod(_propArray);
