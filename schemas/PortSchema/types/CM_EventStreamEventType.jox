    <JadeMethod name="setForUpdate" id="f57867a0-146f-4511-8b29-f416dcc33ecb">
        <updating/>
        <source>setForUpdate(_pxyESEventType : CM_EventStreamEventType; _eventStreamDef : CM_EventStreamDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	// This method should be used only to update persistents
	self.raiseExceptionIfTransient(method);
	if not _pxyESEventType.isTransient then
		self.raiseExceptionIfNotTransient(method);
		return;
	endif;
	
	self.category 	:= _pxyESEventType.category;
	self.name 		:= _pxyESEventType.name;
	self.myEventStreamDefinition := _eventStreamDef;
	self.myObject := _pxyESEventType.myObject;	//06 Jul 2020	NDL	TFS 495990
	self.type := _pxyESEventType.type;	//06 Jul 2020	NDL	TFS 495990
	
epilog

end;</source>
        <Parameter name="_pxyESEventType" type="CM_EventStreamEventType"/>
        <Parameter name="_eventStreamDef" type="CM_EventStreamDefinition"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="bffb14dd-a000-4cd7-a491-634c1fe8c3d0">
        <updating/>
        <source>setProxy(_name : String; _category : Integer; _myObject : CM_Object; _type : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	// This method should be used only to update transient
	self.raiseExceptionIfNotTransient(method);
	
	self.name := _name;
	self.category := _category;
	self.myObject := _myObject;	//06 Jul 2020	NDL	TFS 495990
	self.type := _type;	//06 Jul 2020	NDL	TFS 495990
	
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_category" type="Integer"/>
        <Parameter name="_myObject" type="CM_Object"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRootKeys" id="7cbca225-0df3-414f-a818-d82a37ecf7fd">
        <updating/>
        <source>setRootKeys( _myObject : CM_Object; _type : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2020	jlgndl1	Initial creation	TFS 49590

*/

vars

begin

	self.myObject := _myObject;
	self.type := _type;
	
	if self.myObject &lt;&gt; null and self.myRoot = null then
		self.myRoot := CM_Root.firstInstance;
	endif;

epilog

end;</source>
        <Parameter name="_myObject" type="CM_Object"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
