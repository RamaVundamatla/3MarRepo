    <JadeMethod name="escapeJsonForEmbedding" id="fd4ab733-085f-4ff6-b319-18db4703f81d">
        <source>escapeJsonForEmbedding(_jsonStr : String io) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2025	navnk30	JIRA 35197: CUX - API PUT /voyage response with invalid escaped double quote text

*/

constants
	EscapeChar	= '\';
vars
	escapedJson	: String;
begin
	escapedJson := _jsonStr.replace__(DoubleQuote, EscapeChar &amp; DoubleQuote, true);
	
	escapedJson := escapedJson.replace__(CrLf, "\r\n", true);
	
	_jsonStr := escapedJson;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_jsonStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="eventReqFormatActivityString" id="a33e56e2-3e51-4429-86bb-9c50dd9f5d0d">
        <source>eventReqFormatActivityString(_eventType, _eventName : String) : String;
//--------------------------------------------------
// Created:	31 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	// This format is used for adding activities to the list table
	// setting the selected list table activity
	// and to determine the event type in CMIF_EventRequestController::actionNotify();
	if _eventType = app.getErrorString(ClearUpper)
	or _eventType = app.getErrorString(AddUpper) then
		return  _eventType.trimBlanks &amp; ': ' &amp; _eventName.trimBlanks  ;
	else
		return app.myRoot.eventReqFormatActivityString(_eventName);
	endif;
end;</source>
        <Parameter name="_eventType" type="String"/>
        <Parameter name="_eventName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="eventRequestStatusENumToString" id="0a6613e7-0eff-4ac7-88c8-934695a191ff">
        <source>eventRequestStatusENumToString(_status : Integer):String;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// 13/12/2010	cnwcs5	ccms mes 1112 / par 24464 - stop request for prenotes
vars

begin

	if _status = EventRequestPending then
		return EventRequestPendingStr;
	elseif _status = EventRequestMatched then
		return EventRequestMatchedStr;
	elseif _status = EventRequestActioned then
		return EventRequestActionedStr;		
	elseif _status = EventRequestEmailed then
		return EventRequestEmailedStr;		
	elseif _status = EventRequestCargoDeleted then	// 13/12/2010 cnwcs5 ccms mes 1112 / par 24464
		return EventRequestCargoDeletedStr;
	else
		return app.getErrorString(Unknown);
	endif;		

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
