    <JadeMethod name="setupForm" id="b01276d6-b925-4731-beb0-c4b35bc56a5b">
        <updating/>
        <source>setupForm() updating;

vars

	country	: CM_Country;

begin

	inheritMethod();
	
	if self.isPort then
		self.caption := 'Port Code Finder';
	else
		self.caption := 'Destination Code Finder';
	endif;
	
	self.autoRedraw := true;
	
	self.tblLocodes.columns := 4;
	self.tblLocodes.row := 1;
	self.tblLocodes.text := 'Port Code' &amp; Tab &amp; 'Location' &amp; Tab &amp; 'Country Code' &amp;  Tab &amp; 'Is A Port';
	
	self.frmToolbarBtns.visible := false;
	
	self.tblLocodes.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblLocodes.selectionType := CM_DataTable.SelectionType_Row;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tblLocodes_dblClick" id="1f9a9498-c7d9-49b7-8b93-a1a4edd680dc">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocodes_dblClick(table: Table input) updating;

// Created by cnwdvb1 on 07 April 2006

vars

begin

	if table.row = table.fixedRows then
		table.sortColumn[1] := table.column;
		table.sortType[1] := table.SortType_Alpha;
		table.sortAsc[1] := not table.sortAsc[1];
		table.resort();
		return;
	endif;


	self.makeActive();

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a12a7797-9b37-4978-b683-2b84585ef093">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007947, locale);
	btnSearch.translateCaption(Xlat_0014585, locale);
	lblCountry.translateCaption(Xlat_0000642, locale);
	lblDesc.translateCaption(Xlat_0000643, locale);
	lblPortCode.translateCaption(Xlat_0000644, locale);
	lblPortDesc.translateCaption(Xlat_0000645, locale);
	lblResults.translateCaption(Xlat_0000646, locale);
end;</source>
    </JadeMethod>
</GUIClass>
