    <JadeMethod name="utlDeleteISOType" id="35647682-a05e-4911-a9b5-0a9cec3e0fff">
        <source>utlDeleteISOType(pISOType:CM_ISOType io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	yaType : CM_YATypeISO;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valISOType(pISOType);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pISOType);
	endif;

	if _passport.noErrors then
		yaType := CM_YATypeISO.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(pISOType);
		endif;
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(null) then
			pISOType.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
										   BGP_OpsViewWSRequest.OPS_TYPE_ISOTYPE,
										   pISOType.getOidString
										   );
		endif;
		//21.09.2020 cnwma1 TFS #49906
		
		pISOType.erase(NORMAL_ERASE);
	endif;
epilog
	return;

end;</source>
        <Parameter name="pISOType" type="CM_ISOType" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
