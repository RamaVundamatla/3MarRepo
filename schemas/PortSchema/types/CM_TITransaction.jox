//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Dec 2016	cnwrs1	TFS #3086 Delay for Codeco not working correctly
// ---------------------------------------------------------------------------
vars
	type :Integer;
begin
	type := self.type;
	
	return type = TRANS_TYPE_REC_ST_DEPOT_INT or
