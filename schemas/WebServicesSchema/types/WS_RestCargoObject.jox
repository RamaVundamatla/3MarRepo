    <JadeMethod name="delete" id="8126eb1c-e335-4506-91a0-27f218b78738">
        <updating/>
        <source>delete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/03/2024	navdap1		Initial creation TFS 56853 CUX | POST /findCargo - EDBIC 190 - Cargo Details Query
// 12/07/2024	navdap1		TFS 64905 CUX | EDBIC - Stop information in cargo APIs
//
vars

begin
	self.customsReferences.purge;
	delete self.dimensions;
	self.hazards.purge;
	delete self.receivalDetails;
	delete self.releaseDetails;
	delete self.reeferProperties;
	delete self.weights;
	// TFS 64905
	if self.stops &lt;&gt; null then
		self.stops.purge;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoTranslations" id="985da89a-3b71-4fd9-bf6c-3c80222c3984">
        <updating/>
        <source>doCargoTranslations(_scopeOperator : String; _inward: Boolean) updating;
/*

Purpose:			Does some 'EDI' Translations on incoming/outgoing /Cargo requests.
					This should really *NOT* be added too... ever. It goes against the whole REST/API concept
					of what you send in is what you get. Doing this is very much hidden to anyone who can't see the code!
					
					*** Anything updated in here should also be updated on WS_RestCargoResponse (at least until is moved and we can refactor this) ***

Parameters:			

Return Value:		

Date				Who		Reason
04 July 2024		navmd1	Initial creation TFS 65034 CUX Support EDI Translations for Customer Priority

*/

vars
	operator	: CM_Operator;
	found		: Boolean;
	xlatedCode	: String;
	length		: Integer;
begin
	// This is not for everyone, only allow certain operators to do this!
	if _scopeOperator &lt;&gt; CMIF_WSClaimsObj.OPERATOR_CUX then
		length := CM_CustomerPriority::code.getLengthForString();
		if self.customerPriority.length &gt; length then
			app.raiseCMException3(Data_Too_Long, self.customerPriority, "customerPriority", length.String, null, null);		// This shouldn't be an XLAT, as the customer can't change it
		endif;
		return;
	endif;
	
	app.writeLog(method.qualifiedName, LogTRACE);
	
	operator := app.myRoot.allOperators[self.operatorId];
	if operator = null then
		app.writeLog(method.qualifiedName &amp; " OperatorId not found, skipping translations for cargo " &amp; self.id, LogDEBUG);
		return;
	endif;
	
	if _inward then
		// Incoming, turn this into the System Code
		xlatedCode := operator.getXlationSystemCode(self.customerPriority, XLATION_TYPE_CUSTPRIORITY_BYOP, found);	
	else
		// Outgoing, turn this into the Foreign Code
		xlatedCode := operator.getXlationForeignCode(self.customerPriority, XLATION_TYPE_CUSTPRIORITY_BYOP, found);
	endif;

	if found then
		app.writeLog(method.qualifiedName &amp; " [" &amp; self.id &amp; " (" &amp; self.operatorId &amp; ")] Operator Translation found for Customer Priority [" &amp; self.customerPriority &amp; "], using Translation value instead [" &amp; xlatedCode &amp; "]", LogINFO);
		self.customerPriority := xlatedCode;
	endif;
	
epilog

end;</source>
        <Parameter name="_scopeOperator" type="String"/>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="ecf9f2e4-86a1-410d-9235-4101244e6ca9">
        <updating/>
        <source>setProxyFromObject(_realTrackedItem : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
13 April 2023	navpw1		Initial creation TFS: 56851
07 Dec 2023	 	navhn30  	Bug 57867: CUX - EDBIC - Process Cargo - The POST request does not include validation for an invalid location ID.
07 Feb 2024  	navsaa30 	ChangeRequest 62323: CUX | POST cargo to allow bookingId
11 Mar 2024  	naviv1	 	Bug 62829 : CUX | PUT CargoUpdate Issue on Prenotified Cargos
22/03/2024		navcs2		ChangeRequest 63087: CUX FR* | Tk62873 CARGO APIs POST/PUT/GET - Additional Fields requested - GoLCrit - 01
08/05/2024		naviv1		Bug 63943 : CUX - Code 88778 when trying to create a Rail Prenote for a Wagon with the "Default" Train via POST /Cargo endpoint
10 June 2024	navhn30 	ChangeRequest 64067: CUX | Include additional fields in APIs (Free Text)
26 Jun 2024		navlw1		Bug 64489: CUX - Onboard(child) cargo details missing from GET /Cargo or POST /find/cargo responses, which results in error 75766 on PUT /Cargo
04 Jul 2024		navlw1		Bug 65030: CUX | Cargo sitting on a MAFI seams not to be possible through the API, as the location gets rejected for rail
04 Jul 2024	    navhn30 	ChangeRequest 64905: CUX | EDBIC - Stop information in cargo APIs
23 Sep 2024		navhn30		Bug 66239: CUX - API POST cargo with reefer Code 89407
17 Mar 2025		navah1		Bug 34269: CUX - API postfindCargo query is missing receiveDetail-type
07 Oct 2025		navdap1		MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
*/

vars
	cargoType				: CM_CargoType;
	cargoSubType			: CM_Product;
	operator				: CM_Operator;
	hazard					: CM_TIHazard;
	consignee				: CM_ConsigneeConsignor;
	allCustomsReferences	: CM_CustomsReferenceDict;
	customsReference		: CM_CustomsReference;
	allHazards				: CM_HazardByCodeDict;
	
	wsWeights				: WS_RestWeightObject;
	wsDimensions			: WS_RestDimensionsObject;
	wsHazard				: WS_RestHazardObject;
	wsReeferProperties		: WS_RestReeferObject;
	wsReceivalDetails		: WS_RestReceivalDetailObject;
	wsReleaseDetails		: WS_RestReleaseDetailObject;
	wsCustomsReference		: WS_RestCustomsReferenceObject;
	
	receivedDTTso			: TimeStampOffset;
	releasedDTTso			: TimeStampOffset;
	
	train					: CM_Train;
	wagon					: CM_Wagon;
	allStops				: CM_StopsByIdDict;
	stop					: CM_Stops;
	wsStop					: WS_RestStopObject;
	theStopTable			: CM_StopsTable;
	
begin
	self.id := _realTrackedItem.id;
	
	cargoType := _realTrackedItem.myCargoType;
	if cargoType &lt;&gt; null then
		self.cargoTypeId := cargoType.abbreviation;
	endif;
	
	self.bookingId := _realTrackedItem.bookingReference;   //07/02/2024  navsaa30 #62323
	
	cargoSubType := _realTrackedItem.myProduct;
	if cargoSubType &lt;&gt; null then
		self.cargoSubTypeId := cargoSubType.code;
	endif;
	
	self.commodityId := _realTrackedItem.commodity;
	
	if _realTrackedItem.isContainer then
		self.isoTypeId := _realTrackedItem.CM_Container.isoType;
	endif;
	
	self.density	:= _realTrackedItem.density;
	self.volume		:= _realTrackedItem.totalVolume;
	
	//Set weights
	create wsWeights transient;
	wsWeights.gross	:= _realTrackedItem.totalWeight;
	wsWeights.net	:= _realTrackedItem.weightCargo;
	wsWeights.tare	:= _realTrackedItem.weightTare;
	self.weights	:= wsWeights; 
	
	//Set dimensions
	create wsDimensions transient;
	wsDimensions.height	:= _realTrackedItem.height;
	wsDimensions.length	:= _realTrackedItem.length;
	wsDimensions.width	:= _realTrackedItem.width;
	self.dimensions		:= wsDimensions;
	
	self.alternativeId	:= _realTrackedItem.alternativeId;
	self.voyageId		:= _realTrackedItem.voyageCode;
	self.vesselId		:= _realTrackedItem.vesselCode;
	self.locationId		:= _realTrackedItem.locationId;
	self.prenotified	:= _realTrackedItem.isPreNote();		//	07.12.23	navhn30		TFS #57867
	
	self.secondaryBarcodeId	:= _realTrackedItem.secondaryBarcodeId;
	
	// check stops exist first									// 04.07.24		navhn30		TFS #64905
	allStops	:= _realTrackedItem.getAllStops;
	if allStops.isNotEmpty then
		foreach stop in allStops do
			create wsStop transient;
			theStopTable := app.myRoot.allStopsTable[stop.id];
			wsStop.setProxyFromObject(theStopTable);
			self.stops.add(wsStop);
		endforeach;
	endif;
	// stops end
	operator := _realTrackedItem.myOperator;
	if operator &lt;&gt; null then
		self.operatorId := operator.code;
	endif;
	
	consignee := _realTrackedItem.myConsignee;
	if consignee &lt;&gt; null then
		self.consigneeId := consignee.code;
	endif;
	
	self.consignorId		:= _realTrackedItem.consignor;
	self.contentsStatusId	:= app.contentStatusEnumToString(_realTrackedItem.getContentsStatus);
	self.imexStatus			:= app.imexStatusEnumToString(_realTrackedItem.getImExStatus());
	
	self.trailerTypeId 		:= _realTrackedItem.getTrailerType(); // navlw1 #64489
	
	//check this has hazards first
	allHazards := _realTrackedItem.allTIHazards;
	if allHazards &lt;&gt; null and allHazards.isNotEmpty then
		foreach hazard in allHazards as CM_TIHazard do
			create wsHazard transient;
			wsHazard.setProxyFromObject(hazard);
			self.hazards.add(wsHazard);
		endforeach;
		
	endif;
	
	//check this is a reefer first
	if _realTrackedItem.isReefer then
		create wsReeferProperties transient;
		wsReeferProperties.carbonDioxide	:= _realTrackedItem.getCarbonDioxide();
		wsReeferProperties.humidity			:= _realTrackedItem.getHumidity();
		wsReeferProperties.oxygen			:= _realTrackedItem.getOxygen();
		wsReeferProperties.vent				:= _realTrackedItem.getVentilation();
		wsReeferProperties.temperature		:= _realTrackedItem.getTemperature();
		wsReeferProperties.fahrenheit		:= false;								// 23.09.24	 navhn30  TFS 66239
		wsReeferProperties.ventUnits		:= 1;									// m3/hr
		self.reeferProperties				:= wsReeferProperties;
	endif;
	
	self.dischargePortId	:= _realTrackedItem.dischargePort;
	self.destinationPortId	:= _realTrackedItem.destinationPort;
	self.loadPortId			:= _realTrackedItem.loadPort;
	self.shipmentNumber 	:= _realTrackedItem.shipmentNumber;								// 10/06/2024 navhn30 TFS #64067
	if _realTrackedItem.myCustomerPriority &lt;&gt; null then
		self.customerPriority 	:= _realTrackedItem.myCustomerPriority.code;				// 10/06/2024 navhn30 TFS #64067
	endif;
	if _realTrackedItem.receivedDT &lt;&gt; null then
		receivedDTTso.setFromLocalTimeStamp(_realTrackedItem.receivedDT, receivedDTTso.getUTCBias);
	endif;
	
	//check receival info exists first
	if _realTrackedItem.receiptTransportMode = TI_TRANSMODE_ROAD then
		create wsReceivalDetails transient;
		wsReceivalDetails.id		:= _realTrackedItem.vehicle;
		wsReceivalDetails.type		:= wsReceivalDetails.Receival_Truck;		//08-May-2024 naviv1 #63943
		wsReceivalDetails.carrierId	:= _realTrackedItem.carrier;
		wsReceivalDetails.dateTime	:= receivedDTTso;
		self.receivalDetails		:= wsReceivalDetails;
		
	elseif _realTrackedItem.receiptTransportMode = TI_TRANSMODE_RAIL then
		create wsReceivalDetails transient;
		wsReceivalDetails.id		:= _realTrackedItem.wagon;
		
		// start navlw1 #65030
		train :=_realTrackedItem.myTrainAssigned;
		wagon := _realTrackedItem.getMyWagonReceive();
	
		//if train &lt;&gt; null and wagon = null then // 17.03.2025 navah1 #34269
		if (train &lt;&gt; null and wagon = null) or _realTrackedItem.getReceiveTrainCode() &lt;&gt; null then // 17.03.2025 navah1 #34269
			wsReceivalDetails.type	:= wsReceivalDetails.Receival_Train;		//08-May-2024 naviv1 #63943
		endif;
		if wagon &lt;&gt; null then
			wsReceivalDetails.type	:= wsReceivalDetails.Receival_Wagon;		//08-May-2024 naviv1 #63943
		endif;
		// end navlw1 #65030
		
		wsReceivalDetails.carrierId	:= _realTrackedItem.carrier;
		wsReceivalDetails.dateTime	:= receivedDTTso;
		self.receivalDetails		:= wsReceivalDetails;
		
	elseif _realTrackedItem.receiptTransportMode = TI_TRANSMODE_SHIP then
		create wsReceivalDetails transient;
		wsReceivalDetails.id		:= _realTrackedItem.voyageCode;
		wsReceivalDetails.type		:= wsReceivalDetails.Receival_Ship;			//08-May-204 naviv1 #63943
		wsReceivalDetails.carrierId	:= _realTrackedItem.carrier;
		wsReceivalDetails.dateTime	:= receivedDTTso;
		self.receivalDetails		:= wsReceivalDetails;
	endif;
	
	if _realTrackedItem.releasedDT &lt;&gt; null then
		releasedDTTso.setFromLocalTimeStamp(_realTrackedItem.releasedDT, releasedDTTso.getUTCBias);
	endif;
	
	//check release info exists first
	if _realTrackedItem.releasedTransportMode = TI_TRANSMODE_ROAD then
		create wsReleaseDetails transient;
		wsReleaseDetails.id			:= _realTrackedItem.releaseVehicle;
		wsReleaseDetails.type		:= wsReleaseDetails.Release_Truck;			//10-May-2024 naviv1 #63943
		wsReleaseDetails.carrierId	:= _realTrackedItem.releaseCarrier;
		wsReleaseDetails.dateTime	:= releasedDTTso;
		self.releaseDetails := wsReleaseDetails;
		
	elseif _realTrackedItem.releasedTransportMode = TI_TRANSMODE_RAIL then
		create wsReleaseDetails transient;
		wsReleaseDetails.id			:= _realTrackedItem.wagon;
		
		// start navlw1 #65030
		wsReleaseDetails.type	:= wsReleaseDetails.Release_Wagon;		//08-May-2024 naviv1 #63943
		// end navlw1 #65030
		
		wsReleaseDetails.carrierId	:= _realTrackedItem.releaseCarrier;
		wsReleaseDetails.dateTime	:= releasedDTTso;
		self.releaseDetails := wsReleaseDetails;
		
	elseif _realTrackedItem.releasedTransportMode = TI_TRANSMODE_SHIP then
		create wsReleaseDetails transient;
		wsReleaseDetails.id			:= _realTrackedItem.voyageCode;
		wsReleaseDetails.type		:= wsReleaseDetails.Release_Ship;			//10-May-2024 naviv1 #63943
		wsReleaseDetails.carrierId	:= _realTrackedItem.releaseCarrier;
		wsReleaseDetails.dateTime	:= releasedDTTso;
		self.releaseDetails := wsReleaseDetails;
	endif;
	
	self.remarks := _realTrackedItem.remarks;
	
	//check customs references exists first
	allCustomsReferences := _realTrackedItem.allCustomsReferences;
	if allCustomsReferences &lt;&gt; null and allCustomsReferences.isNotEmpty then
		foreach customsReference in allCustomsReferences do
			create wsCustomsReference transient;
			wsCustomsReference.setProxyFromObject(customsReference);
			self.customsReferences.add(wsCustomsReference);
		endforeach;
		
	endif;
	
	self.state 					:= _realTrackedItem.state;  			//11.03.2024 naviv1 #62829
	self.orderNumber 			:= _realTrackedItem.orderNumber;		//22/03/2024	navcs2	ChangeRequest 63087
	self.description		:= _realTrackedItem.description;		//22/03/2024	navcs2	ChangeRequest 63087
	self.secondaryBarcodeId		:= _realTrackedItem.secondaryBarcodeId;	//22/03/2024	navcs2	ChangeRequest 63087
	self.diameter 				:= _realTrackedItem.getDiameter;  		//22/03/2024	navcs2	ChangeRequest 63087
	self.grade 					:= _realTrackedItem.getGrade;  			//22/03/2024	navcs2	ChangeRequest 63087
	self.totalQuantity	 		:= _realTrackedItem.totalQuantity;  	//22/03/2024	navcs2	ChangeRequest 63087
	self.rollingLength 			:= _realTrackedItem.getRollingLength;  	//22/03/2024	navcs2	ChangeRequest 63087
	self.grammage 				:= _realTrackedItem.getGrammage;  		//22/03/2024	navcs2	ChangeRequest 63087
	
	// MTN-36141 RotaBox and cargo type for contents
	if _realTrackedItem.isContainer and _realTrackedItem.getISOTypeObject.isRotatable() then
		self.contentsCargoTypeId := _realTrackedItem.getCargoTypeCodeForContents();
	endif;
	
epilog												// TFS 64905	navhn30		07.07.24
	
end;</source>
        <Parameter name="_realTrackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateRequest" id="53a0ec88-4294-4cd7-8440-7fe89dcd8622">
        <source>validateRequest(_isChild : Boolean; _isPost : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 June 2024		navmd1	Initial creation TFS 64176 Move common Cargo validation to one method
09 July 2024		navdap1	TFS 64390 CUX - Stowage Position Error when creating onship cargo via POST /Cargo
25 July 2024 		navhn30	Bug 65220: CUX FR | CARGO - Allow updates to parent prenoted trailer in Cargo API - GoLCrit - 02
11 Sep  2024		navhn30 Bug 65980: CUX | PUT /cargo locationId should be read only
07 Oct 2024			navhn30 MTN-12526: CUX | API error issues
06 Oct 2025			navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
*/

vars
	wsHazard			: WS_RestHazardObject;
	wsCustomReference	: WS_RestCustomsReferenceObject;
	cargoType			: CM_CargoType;
	foundLocation		: CM_LocationsController;
	foundHeight			: Integer;
	realCargo			: CM_TrackedItem;
	pos					: Integer;
	trailerLocation		: String;
	isoType				: CM_ISOType;
	terminal			: CM_Terminal;		// MTN-36141
begin
	app.writeLog(method.qualifiedName, LogTRACE);

	if self.id = null then
		app.raiseCMException(Input_required_field_id, null, null);
		return false;
	endif;
		
	if self.cargoTypeId = null then 
		app.raiseCMException(Input_required_field_cargoType, null, null);
		return false;
	endif;
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(self.cargoTypeId);
	if cargoType = null then
		app.raiseCMException1(Cargo_Type_Not_Found, self.cargoTypeId, null, null);
		return false;
	endif;
	
//07.10.24	 navhn30	MTN 12526	 start
	if cargoType.id = TI_CargoType_Container or			
		   cargoType.id = TI_CargoType_COU or
		   cargoType.id = TI_CargoType_Generator or
		   cargoType.id = TI_CargoType_Tower then	
		if self.isoTypeId = null then
			app.raiseCMException(Input_required_field_IsoType, null, null);
			return false;
		else
			isoType := app.myRoot.allISOTypes[self.isoTypeId];
			if isoType = null then
				app.raiseCMException1(Invalid_ISOType, self.isoTypeId, null, null);
				return false;
			endif;
		endif;
	endif;
//07.10.24	 navhn30	MTN 12526  end	
	// TFS 61948 - Trailer Type validation
	if self.trailerTypeId &lt;&gt; null then
		if self.cargoSubTypeId &lt;&gt; null then
			app.raiseCMException(Canno_suppl_both_trail_type_ca, null, null);
			return false;
		endif;
		if not cargoType.isTrailer then
			app.raiseCMException1(Cargo_type_suppl_not_trail_typ, self.cargoTypeId, null, null);
			return false;
		endif;
	endif;
	
	foreach wsHazard in self.hazards do
		if wsHazard.id = null then
			app.raiseCMException(Input_Required_Hazard_Code, null, null);
			return false;
		endif;
	endforeach;
	
	foreach wsCustomReference in self.customsReferences do
		if wsCustomReference.id = null then
			app.raiseCMException1(Custom_refere_field_requir_car, self.id, null, null);
			return false;
		endif;
		
		if wsCustomReference.typeId = null then
			app.raiseCMException1(Custom_ref_type_id_required, self.id, null, null);
			return false;
		endif;
		
		if wsCustomReference.position = null then
			app.raiseCMException1(Custom_ref_position_required, self.id, null, null);
			return false;
		endif;
	endforeach;
	
	if _isPost and not self.prenotified and (not _isChild or self.locationId &lt;&gt; null) then	// 11.09.24	 navhn30	TFS 65980
		app.myPassport.myTerminal.findLocationFromString(self.locationId, false, foundLocation, foundHeight);
		if self.state = TI_STATE_ONSHIP and _isChild then			//25.07.24	 navhn30	 TFS #65220
			pos := self.locationId.pos(" ",1);
			if pos&gt;0 then
				trailerLocation := self.locationId[1:pos -1];
				realCargo := app.myPassport.myTerminal.lookupTrailerOnShip(trailerLocation, cargoType.id);
			endif;
		endif;
		if foundLocation = null and realCargo = null then
			app.raiseCMException1(ERR_INVALID_LOCN, self.locationId, null, null);
			return false;
		endif;
	endif;
	
	if self.receivalDetails &lt;&gt; null then
		if not self.receivalDetails.validateRequest() then
			return false;
		endif;
	endif;
	
	if self.releaseDetails &lt;&gt; null then
		if not self.releaseDetails.validateRequest() then
			return false;
		endif;
	endif;
	
	// MTN-36141 Validate contentsCargoTypeId
	if isoType &lt;&gt; null and isoType.isRotatable() then
		terminal := app.myPassport.myTerminal;
		if app.contentStatusStringToEnum(self.contentsStatusId) &lt;&gt; TI_CONTENTS_STATUS_EMPTY or self.commodityId &lt;&gt; terminal.getConfig(DefCommodity).String then
			// Need a contents cargo type if iso type is rotatable
			if self.contentsCargoTypeId = null then
				app.raiseCMException(Cargo_Type_Contents_Required, null, null);
				return false;
			endif;
			
			// Contents cargo type must be valid
			cargoType := app.myRoot.getCargoTypeFromAbbrev(self.contentsCargoTypeId);
			if cargoType = null then
				app.raiseCMException1(Cargo_Type_Not_Found, self.contentsCargoTypeId, null, null);
				return false;
			endif;
			
			// The cargo subtype must be supplied if the cargo type requires cargo sub types
			if cargoType.isSubCargoTypeRequired and self.cargoSubTypeId = null then
				app.raiseCMException(Must_select_cargo_subtype, null, null);
				return false;
			endif;
			
			// The cargo subtype must be valid for the Cargo Type for Contents
			if self.cargoSubTypeId &lt;&gt; null then
				if cargoType.allProducts[null, self.cargoSubTypeId] = null then
					if cargoType.allProducts[self.operatorId, self.cargoSubTypeId] = null then
						app.raiseCMException2(CargoSubtype_Invalid, cargoType.description, self.cargoSubTypeId, null, null);
						return false;
					endif;
				endif;
			endif;
		endif;
	endif;
	// MTN-36141 end
	
	return true;
epilog

end;</source>
        <Parameter name="_isChild" type="Boolean"/>
        <Parameter name="_isPost" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
