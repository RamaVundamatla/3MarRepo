    <JadeMethod name="xCreatePlannedROROCargo" id="3e0d9612-e7e4-4703-be67-386d99805fad">
        <updating/>
        <source>xCreatePlannedROROCargo(_voyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	vessel : CM_Vessel;
	vesselName: String;
	tradeName: String;
	operatorCode: String;
	deckContName, deckGCName, deckRehandleName: String;
	voyage : CM_Voyage;
	voyageCode : String;
	trade		: CM_Trade;
	portRotation : CM_PortRotation;
	port 		: CM_Port;
	voyAlloc20s 	: ObjectArray;
	voyAlloc40s		: ObjectArray;
	deckCont, deckGC, deckRehandle: CM_DeckVoyage;
	all40FrontSlotDefn,
	all20SlotDefns		 : CM_ROROSlotLCsByOrdDict;
	iter				: Iterator;
	slotController 	: CM_ROROSlotController;
	slotDefn			: CM_ROROSlotDefn;
	locnDefn			: CM_ROROLocnDefn;
	ccSize, ccIndex				: Integer;
	allJobSlots ,altSlots	: CM_LCArray;
	voyAlloc		: CM_VoyageAllocation;
	deckItem			: CM_DeckItem;
	workPoints : ObjectArray;
	wpA,
	wpB,
	wpC: CM_WorkPoint;
	oowController : CMIF_OOWCreationAutoUpdate;
	jobController : CMIF_VoyageJobParams;
	request : CM_RORORequest;
	i, c : Integer;
	operator : CM_Operator;
	ti : CM_TrackedItem;
	bs 	: CM_BlockStack;
	lcs, lcSet : CM_LCSet;
	theJobParams : CMIF_VoyageJobParams;
	job : CM_Job;
	lc : CM_LocationsController;
	ct: CM_CargoType;
	sobSlots,
	altSOBSlots, 
	altDLRSlots,
	dlrSlots : CM_LCArray;
	vc, vc2 : CM_VoyageROROController;
	editions : CM_ObjectByOidEditionDict;
	gcDischargePort: CM_Port;
	deckOrd: Integer;
	jobSheet: CM_VoyageJobSheet;
begin
	
	voyageCode := _voyage.code;

	tradeName := _voyage.myTrade.code;
	operatorCode :=_voyage.myOperator.code;
	deckContName := "CONT1";
	deckGCName := "GC";
    deckRehandleName := "REHANDLE";

	trade:= app.myRoot.allTradesByDescription[tradeName];
	if trade = null then
		return;
	endif;

	operator := voyage.myOperator;

	
	create voyAlloc20s transient;
	create voyAlloc40s transient;
	
	// create voyage allocations for each port in the trade	
	foreach portRotation in trade.allPortRotations discreteLock do
		port := portRotation.myPort;
		if port = self.getTerminal.getDefaultPort then
			continue;
		endif;
		voyAlloc20s.add(self.addVoyageAllocation(voyage, port.code,"GEN2",null,1,false,false));
		voyAlloc40s.add(self.addVoyageAllocation(voyage, port.code,"GEN4",null,1,false,false));
	endforeach;
	
	// Blocks Stack for exports
	bs := self.addBlockStack(voyageCode, 10000, null);	

	// create the work points
	wpA := self.addWorkPoint("WPA", true);
	self.addWorkPointTransferArea("WPA_IC", wpA);
		self.assertNotNull(wpA.myWorkPointInterchangeArea);
	wpB := self.addWorkPoint("WPB", true);
	self.addWorkPointTransferArea("WPB_IC", wpB);
		self.assertNotNull(wpB.myWorkPointInterchangeArea);
	wpC := self.addWorkPoint("WPC", true);
	self.addWorkPointTransferArea("WPC_IC", wpC);
		self.assertNotNull(wpC.myWorkPointInterchangeArea);
	
	create workPoints transient;
	workPoints.add(wpA);
	workPoints.add(wpB);
	workPoints.add(wpC);
	
	app.myTrxUA.trxUpdateVoyageJobSheet(workPoints,voyage,CM_VoyageDeckJobSheet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	// Container
	create all40FrontSlotDefn  transient;
	create all20SlotDefns	transient;

	self.logMessage("Get 20/40ft slots");
	deckCont := voyage.myROROStructure.allDecksByCode[deckContName];
	deckGC := voyage.myROROStructure.allDecksByCode[deckGCName];
	
	iter := deckCont.allROROSlotControllers.createIterator;
	while iter.next(slotController) do
		locnDefn:=slotController.mySlotDefn.myROROLocnDen;
		if locnDefn.myAdjacentSlotAft &lt;&gt; null or locnDefn.myAdjacentSlotFwd &lt;&gt; null then
			if locnDefn.myAdjacentSlotAft &lt;&gt; null then
				if not all40FrontSlotDefn.includes(locnDefn.myAdjacentSlotAft.allROROSlotDefnByOrdinal.first.CM_ROROSlotDefnVoyage.mySlotController) then
					all40FrontSlotDefn.add(slotController);
				endif;
			endif;
		else
			all20SlotDefns.add(slotController);
		endif;	
	endwhile;
	delete iter;
	
	//do all 20ft slots hoping that because they are ordered by ordinal the slots will be positioned close to each other
	self.logMessage("CC 20ft slots");
	create allJobSlots transient;
	create altSlots transient;
	ccSize:=(all20SlotDefns.size/(voyAlloc20s.size)).roundedUp;
	
	self.ignoreTrxWarnings(true);
	
	ccIndex:=1;
	delete iter;
	iter:=all20SlotDefns.createIterator;
	c := 0;
	while iter.next(slotController) do
        c := c + 1;				
		if (c mod 3) = 0 and slotController.getOrdinalSlot = slotController.myDeck.numTier then
			continue;
		endif;
		allJobSlots.add(slotController);
		// once we get size for color coding CC the sucker
		if allJobSlots.size = ccSize then
			voyAlloc:=voyAlloc20s[ccIndex].CM_VoyageAllocation;
			self.ignoreTrxWarnings(true);
			slotDefn:=slotController.mySlotDefn;
			locnDefn:=slotDefn.myROROLocnDen;
			while true do
				slotDefn:=slotController.mySlotDefn;
				if slotDefn &lt;&gt; locnDefn.allROROSlotDefnByOrdinal.last then
					iter.next(slotController);
					allJobSlots.add(slotController);
				else
					break;
				endif;
			endwhile;
			
			self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
			allJobSlots.clear;
			ccIndex:=ccIndex+1;
		endif;
	endwhile;
	
	if allJobSlots.size &gt; 0 then
		voyAlloc:=voyAlloc20s[ccIndex].CM_VoyageAllocation;
		self.ignoreTrxWarnings(true);
		self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
		allJobSlots.clear;
	endif;
	
	self.logMessage("CC 40ft slots");
	allJobSlots.clear;
	ccSize:=(all40FrontSlotDefn.size/voyAlloc40s.size).roundedUp;
	ccIndex:=1;

	delete iter;
	iter:=all40FrontSlotDefn.createIterator;
	c := 0;
	while iter.next(slotController) do
        c := c + 1;				
		if (c mod 3) = 0 and slotController.getOrdinalSlot = slotController.myDeck.numTier then
			continue;
		endif;

		allJobSlots.add(slotController);
		
		// once we get size for color coding CC the sucker
		if allJobSlots.size = ccSize then
			voyAlloc:=voyAlloc40s[ccIndex].CM_VoyageAllocation;
			self.ignoreTrxWarnings(true);
			slotDefn:=slotController.mySlotDefn;
			locnDefn:=slotDefn.myROROLocnDen;
			while true do
				slotDefn:=slotController.mySlotDefn;
				if slotDefn &lt;&gt; locnDefn.allROROSlotDefnByOrdinal.last then
					iter.next(slotController);
					allJobSlots.add(slotController);
				else
					break;
				endif;
			endwhile;	
			self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
			allJobSlots.clear;
			ccIndex:=ccIndex+1;
		endif;
	endwhile;
	
	if allJobSlots.size &gt; 0 then
		voyAlloc:=voyAlloc40s[ccIndex].CM_VoyageAllocation;
		self.ignoreTrxWarnings(true);
		self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
		allJobSlots.clear;
	endif;
	

	// create the oowCreations for the Voyage
	self.logMessage("Create OOW");
	app.myTrxCA.trxCreateVoyageOOWCreationRORO(voyage.myROROStructure,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	// Allocate OOWCreations to Voyage Allocations slots
	create oowController transient;
	oowController.myCellularStructure :=voyage.myCellularVoyageStructure;
	oowController.myROROStructure:=voyage.myROROStructure;
	app.myTrxUA.trxUpdateVoyageOOWAuto(false,oowController,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	create jobController transient;
	app.myTrxCA.trxCreateVoyageJobOOW(voyage.allJobSheets,app.myPassport,jobController);
	self.assertNoTrxErrorsOrWarnings;
	
	self.logMessage("Create OnShip Container Cargo");
	self.ignoreTrxWarnings(true);
	self.addROROVoyageContainers(deckCont,true, 0);
	self.xAddROROVoyageGC(deckGC);
	
	// take some of the on board cargo created and set aside for sob and dlr
	self.logMessage("Create Disch CC");
	create lcSet transient;
	deckCont.allROROSlotControllers.copy(lcSet);
	deckGC.allROROGCControllers.copy(lcSet);
	app.myTrxCA.trxCreateRORODischargeCCs(lcSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.logMessage("Create Disch Jobs");
	self.createDischJobsForRORO(voyage, deckCont, wpA, wpB);
	self.createGCDischJobsForRORO( deckGC, wpA);

	// Rehandles
	self.logMessage("CC Rehandles");
	create sobSlots transient;
	create dlrSlots transient;
	create altSOBSlots transient;
	create altDLRSlots transient;
	
	// DLRs
	create editions transient;
	deckRehandle := voyage.myROROStructure.allDecksByCode[deckRehandleName];
	voyAlloc := voyAlloc20s.first.CM_VoyageAllocation;
	dlrSlots.clear();
	altDLRSlots.clear();

	self.logMessage("Create DLR Discharge Jobs");
	deckOrd := deckRehandle.ordinal;
	foreach i in 1 to 4 do
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 1, i];
		dlrSlots.add(slotController);
		//deckRehandle.myVoyageStructure.createQuickCargo(
		deckItem := slotController.getDefn();
		self.createQuickCargoRORO(deckRehandle.myVoyageStructure, deckItem, false, false, voyAlloc.getDischargePort().code, "GENL");  // Cargo ondhip
	endforeach;
	editions.clear;
	foreach lc in dlrSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);	
	endforeach;
	altDLRSlots.clear;
	//create some DLR  Discharge jobs
	app.myTrxUA.doRORORequestDLRSoB(dlrSlots, altDLRSlots, false, DLR_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	self.addVoyageROROJob(voyage, deckRehandle, wpC.code, dlrSlots, true);
	self.assertNoTrxErrorsOrWarnings;
	dlrSlots.clear();

	self.logMessage("Create DLR Load Jobs");
	foreach i in 1 to 4 do
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 2, i];
		dlrSlots.add(slotController);
	endforeach;
	//create some DLR Load jobs
	self.addLCsToROROAllocation(true, voyAlloc, dlrSlots, altSlots,1);
	editions.clear;
	foreach lc in dlrSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);	
	endforeach;
	altDLRSlots.clear;
	app.myTrxUA.doRORORequestDLRSoB(dlrSlots, altDLRSlots, true, DLR_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	self.addVoyageROROJob(voyage, deckRehandle, wpC.code, dlrSlots, false);
	self.assertNoTrxErrorsOrWarnings;
	
	// Plna the discharged ti's back on to ship
	foreach i in 1 to 4 do
		ti := deckRehandle.allROROSlotControllers[deckOrd, 1, i].allTrackedItems.first;
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 2, i];
		self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad);
	endforeach;

	dlrSlots.clear();
		
	self.logMessage("Create SOB Jobs");
	foreach i in 1 to 4 do
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 3, i];
		//deckRehandle.myVoyageStructure.createQuickCargo(
		deckItem := slotController.getDefn();
		self.createQuickCargoRORO(deckRehandle.myVoyageStructure, deckItem, false, false, voyAlloc.getDischargePort().code, "MT");  // Cargo ondhip
		dlrSlots.add(slotController);
	endforeach;
	
	altDLRSlots.clear();
	foreach i in 1 to 4 do
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 4, i];
		altDLRSlots.add(slotController);
	endforeach;

	editions.clear;
	foreach lc in dlrSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);	
	endforeach;
	foreach lc in altDLRSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);	
	endforeach;
	app.myTrxUA.doRORORequestDLRSoB(dlrSlots, altDLRSlots, false, SOB_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	//altDLRSlots.copy(dlrSlots);
	self.addVoyageROROJob(voyage, deckRehandle, wpC.code, dlrSlots, true);
	self.assertNoTrxErrorsOrWarnings;
	dlrSlots.clear();

	// Create a Terminal Area and fill with cargo based on the Voyage Allocations
	// Will just for this example create a unlimited Block Stack the DIAM block stack
	self.logMessage("Create Onsite 20ft Cargo in BS");
	delete iter;
	iter:=all20SlotDefns.createIterator;
	self.opts.addAssoc(UTTI_VoyageCode,voyageCode);
	self.opts.addAssoc("CENum","1234");
	i:=1;
	while iter.next(slotController) do
		request := slotController.myRORORequestLoad;
		if request = null then
			continue;
		endif;
		self.opts.addAssoc(UTTI_DischargePort,request.getDischargePort);
		ti :=self.addContainerOpts(operatorCode &amp; i.padLeadingWith("0",7), "2200", "GENL",operator);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.move(ti,bs.myLocationsController);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.deleteStops(ti);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad);
		self.assertNoTrxErrorsOrWarnings;
		i:=i+1;
	endwhile;
	
	self.logMessage("Create Onsite 40ft Cargo in BS");
	delete iter;
	iter:=all40FrontSlotDefn.createIterator;

	while iter.next(slotController) do
		request := slotController.myRORORequestLoad;
		if request = null then
			continue;
		endif;
		self.opts.addAssoc(UTTI_DischargePort,request.getDischargePort);
		ti :=self.addContainerOpts(operatorCode &amp; i.padLeadingWith("0",7), "4200", "GENL",operator);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.move(ti,bs.myLocationsController);
		self.assertNoTrxErrorsOrWarnings;
		
		self.ignoreTrxWarnings(true);
		self.deleteStops(ti);
		self.assertNoTrxErrorsOrWarnings;
		
		self.ignoreTrxWarnings(true);
		self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad);
		self.assertNoTrxErrorsOrWarnings;
		i:=i+1;
	endwhile;
	
	// GC
	self.logMessage("Create Load Job for GC");

	ct := self.getCargoType("CANNONBALL");				// 10047								// 28/06/2013 cnwmh5
	gcDischargePort :=  trade.allPortRotations.first.myPort;
	if gcDischargePort = self.getTerminal.getDefaultPort then
		gcDischargePort :=  trade.allPortRotations.last.myPort;
	endif;

	createGCLoadJobForRORO(voyage, wpC, deckGC, 20, -10, gcDischargePort.code, ct, operator,"CANB", 10, 20, bs, null);
	createGCLoadJobForRORO(voyage, wpC, deckGC, 45, -10, gcDischargePort.code, ct, operator, "CANB", 50, 70, bs, null);

	self.logMessage("Release all Jobs");

	// Release all jobs to ops
	foreach job in voyage.allVoyageJobs discreteLock do
		beginTransaction;
		job.CM_VoyageJob.setShipOpsLoad();
		commitTransaction;
	endforeach;
	
	// Check stuff
	foreach jobSheet in voyage.allJobSheets do
		assertNotNullMsg(jobSheet.CM_VoyageDeckJobSheet.myWorkPoint, "Job sheet missing workpoint reference");
	endforeach;
	
epilog
	delete voyAlloc20s;
	delete voyAlloc40s;
	delete all40FrontSlotDefn;
	delete all20SlotDefns;
	delete allJobSlots;
	delete altSlots;
	delete workPoints;
	delete oowController;
	delete jobController;
	delete iter;
	delete lcSet;
	delete theJobParams;
	delete lcs;
	delete sobSlots;
	delete dlrSlots;
	delete editions;
	delete altSOBSlots;
	delete altDLRSlots;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xCreatePlannedROROVoyage" id="8b57941d-4efc-481f-8369-e14172d22d19">
        <updating/>
        <source>xCreatePlannedROROVoyage(_voyageCode: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	vessel : CM_Vessel;
	vesselName: String;
	tradeName: String;
	operatorCode: String;
	deckContName, deckGCName, deckRehandleName: String;
	voyage : CM_Voyage;
	voyageCode : String;
	trade		: CM_Trade;
	portRotation : CM_PortRotation;
	port 		: CM_Port;
	voyAlloc20s 	: ObjectArray;
	voyAlloc40s		: ObjectArray;
	deckCont, deckGC, deckRehandle: CM_DeckVoyage;
	all40FrontSlotDefn,
	all20SlotDefns		 : CM_ROROSlotLCsByOrdDict;
	iter				: Iterator;
	slotController 	: CM_ROROSlotController;
	slotDefn			: CM_ROROSlotDefn;
	locnDefn			: CM_ROROLocnDefn;
	ccSize, ccIndex				: Integer;
	allJobSlots ,altSlots	: CM_LCArray;
	voyAlloc		: CM_VoyageAllocation;
	workPoints : ObjectArray;
	wpA,
	wpB,
	wpC: CM_WorkPoint;
	oowController : CMIF_OOWCreationAutoUpdate;
	jobController : CMIF_VoyageJobParams;
	request : CM_RORORequest;
	i, c : Integer;
	operator : CM_Operator;
	ti : CM_TrackedItem;
	bs 	: CM_BlockStack;
	lcs, lcSet : CM_LCSet;
	theJobParams : CMIF_VoyageJobParams;
	job : CM_Job;
	lc : CM_LocationsController;
	ct: CM_CargoType;
	sobSlots,
	altSOBSlots, 
	altDLRSlots,
	dlrSlots : CM_LCArray;
	vc, vc2 : CM_VoyageROROController;
	editions : CM_ObjectByOidEditionDict;
	gcDischargePort: CM_Port;
	deckOrd: Integer;
	jobSheet: CM_VoyageJobSheet;
	deckItem	: CM_DeckItem;
begin
	
	voyageCode := _voyageCode;

	vesselName := "DOUGRORO";
	tradeName := "Doug World";
	operatorCode := "DOUG";
	deckContName := "CONT1";
	deckGCName := "GC";
    deckRehandleName := "REHANDLE";

	vessel	:= self.getVessel( vesselName );
	if vessel = null then
		return;
	endif;
	
	trade:= app.myRoot.allTradesByDescription[tradeName];
	if trade = null then
		return;
	endif;

	self.deleteVoyage(voyageCode);
	self.assertNull( self.getVoyage(voyageCode));
	
	voyage := self.addVoyageWithConRORO(voyageCode, vessel.code, operatorCode, operatorCode, null, 0, false, true);
	operator := voyage.myOperator;

	beginTransaction;
	voyage.setMyTrade(trade);
	commitTransaction;
	
	create voyAlloc20s transient;
	create voyAlloc40s transient;
	
	// create voyage allocations for each port in the trade	
	foreach portRotation in trade.allPortRotations discreteLock do
		port := portRotation.myPort;
		if port = self.getTerminal.getDefaultPort then
			continue;
		endif;
		voyAlloc20s.add(self.addVoyageAllocation(voyage, port.code,"GEN2",null,1,false,false));
		voyAlloc40s.add(self.addVoyageAllocation(voyage, port.code,"GEN4",null,1,false,false));
	endforeach;
	
	// Blocks Stack for exports
	bs := self.addBlockStack(voyageCode, 10000, null);	

	// create the work points
	wpA := self.addWorkPoint("WPA", true);
		self.assertEqual(wpA.myTerminal, self.getTerminal);
	self.addWorkPointTransferArea("WPA_IC", wpA);
		self.assertNotNull(wpA.myWorkPointInterchangeArea);
	wpB := self.addWorkPoint("WPB", true);
	self.addWorkPointTransferArea("WPB_IC", wpB);
		self.assertNotNull(wpB.myWorkPointInterchangeArea);
	wpC := self.addWorkPoint("WPC", true);
	self.addWorkPointTransferArea("WPC_IC", wpC);
		self.assertNotNull(wpC.myWorkPointInterchangeArea);
	
	create workPoints transient;
	workPoints.add(wpA);
	workPoints.add(wpB);
	workPoints.add(wpC);
	
	app.myTrxUA.trxUpdateVoyageJobSheet(workPoints,voyage,CM_VoyageDeckJobSheet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	// Container
	create all40FrontSlotDefn  transient;
	create all20SlotDefns	transient;

	self.logMessage("Get 20/40ft slots");
	deckCont := voyage.myROROStructure.allDecksByCode[deckContName];
	deckGC := voyage.myROROStructure.allDecksByCode[deckGCName];
	
	iter := deckCont.allROROSlotControllers.createIterator;
	while iter.next(slotController) do
		locnDefn:=slotController.mySlotDefn.myROROLocnDen;
		if locnDefn.myAdjacentSlotAft &lt;&gt; null or locnDefn.myAdjacentSlotFwd &lt;&gt; null then
			if locnDefn.myAdjacentSlotAft &lt;&gt; null then
				if not all40FrontSlotDefn.includes(locnDefn.myAdjacentSlotAft.allROROSlotDefnByOrdinal.first.CM_ROROSlotDefnVoyage.mySlotController) then
					all40FrontSlotDefn.add(slotController);
				endif;
			endif;
		else
			all20SlotDefns.add(slotController);
		endif;	
	endwhile;
	delete iter;
	
	//do all 20ft slots hoping that because they are ordered by ordinal the slots will be positioned close to each other
	self.logMessage("CC 20ft slots");
	create allJobSlots transient;
	create altSlots transient;
	ccSize:=(all20SlotDefns.size/(voyAlloc20s.size)).roundedUp;
	
	self.ignoreTrxWarnings(true);
	
	ccIndex:=1;
	delete iter;
	iter:=all20SlotDefns.createIterator;
	c := 0;
	while iter.next(slotController) do
        c := c + 1;				
		if (c mod 3) = 0 and slotController.getOrdinalSlot = slotController.myDeck.numTier then
			continue;
		endif;
		allJobSlots.add(slotController);
		// once we get size for color coding CC the sucker
		if allJobSlots.size = ccSize then
			voyAlloc:=voyAlloc20s[ccIndex].CM_VoyageAllocation;
			self.ignoreTrxWarnings(true);
			slotDefn:=slotController.mySlotDefn;
			locnDefn:=slotDefn.myROROLocnDen;
			while true do
				slotDefn:=slotController.mySlotDefn;
				if slotDefn &lt;&gt; locnDefn.allROROSlotDefnByOrdinal.last then
					iter.next(slotController);
					allJobSlots.add(slotController);
				else
					break;
				endif;
			endwhile;
			
			self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
			allJobSlots.clear;
			ccIndex:=ccIndex+1;
		endif;
	endwhile;
	
	if allJobSlots.size &gt; 0 then
		voyAlloc:=voyAlloc20s[ccIndex].CM_VoyageAllocation;
		self.ignoreTrxWarnings(true);
		self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
		allJobSlots.clear;
	endif;
	
	self.logMessage("CC 40ft slots");
	allJobSlots.clear;
	ccSize:=(all40FrontSlotDefn.size/voyAlloc40s.size).roundedUp;
	ccIndex:=1;

	delete iter;
	iter:=all40FrontSlotDefn.createIterator;
	c := 0;
	while iter.next(slotController) do
        c := c + 1;				
		if (c mod 3) = 0 and slotController.getOrdinalSlot = slotController.myDeck.numTier then
			continue;
		endif;

		allJobSlots.add(slotController);
		
		// once we get size for color coding CC the sucker
		if allJobSlots.size = ccSize then
			voyAlloc:=voyAlloc40s[ccIndex].CM_VoyageAllocation;
			self.ignoreTrxWarnings(true);
			slotDefn:=slotController.mySlotDefn;
			locnDefn:=slotDefn.myROROLocnDen;
			while true do
				slotDefn:=slotController.mySlotDefn;
				if slotDefn &lt;&gt; locnDefn.allROROSlotDefnByOrdinal.last then
					iter.next(slotController);
					allJobSlots.add(slotController);
				else
					break;
				endif;
			endwhile;	
			self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
			allJobSlots.clear;
			ccIndex:=ccIndex+1;
		endif;
	endwhile;
	
	if allJobSlots.size &gt; 0 then
		voyAlloc:=voyAlloc40s[ccIndex].CM_VoyageAllocation;
		self.ignoreTrxWarnings(true);
		self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
		allJobSlots.clear;
	endif;
	

	// create the oowCreations for the Voyage
	self.logMessage("Create OOW");
	app.myTrxCA.trxCreateVoyageOOWCreationRORO(voyage.myROROStructure,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	// Allocate OOWCreations to Voyage Allocations slots
	create oowController transient;
	oowController.myCellularStructure :=voyage.myCellularVoyageStructure;
	oowController.myROROStructure:=voyage.myROROStructure;
	app.myTrxUA.trxUpdateVoyageOOWAuto(false,oowController,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	create jobController transient;
	app.myTrxCA.trxCreateVoyageJobOOW(voyage.allJobSheets,app.myPassport,jobController);
	self.assertNoTrxErrorsOrWarnings;
	
	self.logMessage("Create OnShip Container Cargo");
	self.ignoreTrxWarnings(true);
	self.addROROVoyageContainers(deckCont,true, 0);
	self.xAddROROVoyageGC(deckGC);
	
	// take some of the on board cargo created and set aside for sob and dlr
	self.logMessage("Create Disch CC");
	create lcSet transient;
	deckCont.allROROSlotControllers.copy(lcSet);
	deckGC.allROROGCControllers.copy(lcSet);
	app.myTrxCA.trxCreateRORODischargeCCs(lcSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.logMessage("Create Disch Jobs");
	self.createDischJobsForRORO(voyage, deckCont, wpA, wpB);
	self.createGCDischJobsForRORO( deckGC, wpA);

	// Rehandles
	self.logMessage("CC Rehandles");
	create sobSlots transient;
	create dlrSlots transient;
	create altSOBSlots transient;
	create altDLRSlots transient;
	
	// DLRs
	create editions transient;
	deckRehandle := voyage.myROROStructure.allDecksByCode[deckRehandleName];
	voyAlloc := voyAlloc20s.first.CM_VoyageAllocation;
	dlrSlots.clear();
	altDLRSlots.clear();

	self.logMessage("Create DLR Discharge Jobs");
	deckOrd := deckRehandle.ordinal;
	foreach i in 1 to 4 do
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 1, i];
		dlrSlots.add(slotController);
		//deckRehandle.myVoyageStructure.createQuickCargo(
		deckItem := slotController.getDefn();
		self.createQuickCargoRORO(deckRehandle.myVoyageStructure, deckItem, false, false, voyAlloc.getDischargePort().code, "GENL");  // Cargo ondhip
	endforeach;
	editions.clear;
	foreach lc in dlrSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);	
	endforeach;
	altDLRSlots.clear;
	//create some DLR  Discharge jobs
	app.myTrxUA.doRORORequestDLRSoB(dlrSlots, altDLRSlots, false, DLR_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	self.addVoyageROROJob(voyage, deckRehandle, wpC.code, dlrSlots, true);
	self.assertNoTrxErrorsOrWarnings;
	dlrSlots.clear();

	self.logMessage("Create DLR Load Jobs");
	foreach i in 1 to 4 do
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 2, i];
		dlrSlots.add(slotController);
	endforeach;
	//create some DLR Load jobs
	self.addLCsToROROAllocation(true, voyAlloc, dlrSlots, altSlots,1);
	editions.clear;
	foreach lc in dlrSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);	
	endforeach;
	altDLRSlots.clear;
	app.myTrxUA.doRORORequestDLRSoB(dlrSlots, altDLRSlots, true, DLR_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	self.addVoyageROROJob(voyage, deckRehandle, wpC.code, dlrSlots, false);
	self.assertNoTrxErrorsOrWarnings;
	
	// Plna the discharged ti's back on to ship
	foreach i in 1 to 4 do
		ti := deckRehandle.allROROSlotControllers[deckOrd, 1, i].allTrackedItems.first;
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 2, i];
		self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad);
	endforeach;

	dlrSlots.clear();
		
	self.logMessage("Create SOB Jobs");
	foreach i in 1 to 4 do
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 3, i];
		//deckRehandle.myVoyageStructure.createQuickCargo(
		deckItem := slotController.getDefn();
		self.createQuickCargoRORO(deckRehandle.myVoyageStructure, deckItem, false, false, voyAlloc.getDischargePort().code, "MT");  // Cargo ondhip
		dlrSlots.add(slotController);
	endforeach;
	
	altDLRSlots.clear();
	foreach i in 1 to 4 do
		slotController := deckRehandle.allROROSlotControllers[deckOrd, 4, i];
		altDLRSlots.add(slotController);
	endforeach;

	editions.clear;
	foreach lc in dlrSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);	
	endforeach;
	foreach lc in altDLRSlots do
		vc := lc.CM_VoyageROROController;
		editions.add(vc);	
	endforeach;
	app.myTrxUA.doRORORequestDLRSoB(dlrSlots, altDLRSlots, false, SOB_MOVETYPE, editions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
	//altDLRSlots.copy(dlrSlots);
	self.addVoyageROROJob(voyage, deckRehandle, wpC.code, dlrSlots, true);
	self.assertNoTrxErrorsOrWarnings;
	dlrSlots.clear();

	// Create a Terminal Area and fill with cargo based on the Voyage Allocations
	// Will just for this example create a unlimited Block Stack the DIAM block stack
	self.logMessage("Create Onsite 20ft Cargo in BS");
	delete iter;
	iter:=all20SlotDefns.createIterator;
	self.opts.addAssoc(UTTI_VoyageCode,voyageCode);
	self.opts.addAssoc("CENum","1234");
	i:=1;
	while iter.next(slotController) do
		request := slotController.myRORORequestLoad;
		if request = null then
			continue;
		endif;
		self.opts.addAssoc(UTTI_DischargePort,request.getDischargePort);
		ti :=self.addContainerOpts(operatorCode &amp; i.padLeadingWith("0",7), "2200", "GENL",operator);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.move(ti,bs.myLocationsController);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.deleteStops(ti);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad);
		self.assertNoTrxErrorsOrWarnings;
		i:=i+1;
	endwhile;
	
	self.logMessage("Create Onsite 40ft Cargo in BS");
	delete iter;
	iter:=all40FrontSlotDefn.createIterator;

	while iter.next(slotController) do
		request := slotController.myRORORequestLoad;
		if request = null then
			continue;
		endif;
		self.opts.addAssoc(UTTI_DischargePort,request.getDischargePort);
		ti :=self.addContainerOpts(operatorCode &amp; i.padLeadingWith("0",7), "4200", "GENL",operator);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.move(ti,bs.myLocationsController);
		self.assertNoTrxErrorsOrWarnings;
		
		self.ignoreTrxWarnings(true);
		self.deleteStops(ti);
		self.assertNoTrxErrorsOrWarnings;
		
		self.ignoreTrxWarnings(true);
		self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad);
		self.assertNoTrxErrorsOrWarnings;
		i:=i+1;
	endwhile;
	
	// GC
	self.logMessage("Create Load Job for GC");

	ct := self.getCargoType("CANNONBALL");					// 10047									// 28/06/2013 cnwmh5
	gcDischargePort :=  trade.allPortRotations.first.myPort;
	if gcDischargePort = self.getTerminal.getDefaultPort then
		gcDischargePort :=  trade.allPortRotations.last.myPort;
	endif;

	createGCLoadJobForRORO(voyage, wpC, deckGC, 20, -10, gcDischargePort.code, ct, operator,"CANB", 10, 20, bs, null);
	createGCLoadJobForRORO(voyage, wpC, deckGC, 45, -10, gcDischargePort.code, ct, operator, "CANB", 50, 70, bs, null);

	self.logMessage("Release all Jobs");

	// Release all jobs to ops
	foreach job in voyage.allVoyageJobs discreteLock do
		beginTransaction;
		job.CM_VoyageJob.setShipOpsLoad();
		commitTransaction;
	endforeach;
	
	// Check stuff
	foreach jobSheet in voyage.allJobSheets do
		assertNotNullMsg(jobSheet.CM_VoyageDeckJobSheet.myWorkPoint, "Job sheet missing workpoint reference");
	endforeach;
	
epilog
	delete voyAlloc20s;
	delete voyAlloc40s;
	delete all40FrontSlotDefn;
	delete all20SlotDefns;
	delete allJobSlots;
	delete altSlots;
	delete workPoints;
	delete oowController;
	delete jobController;
	delete iter;
	delete lcSet;
	delete theJobParams;
	delete lcs;
	delete sobSlots;
	delete dlrSlots;
	delete editions;
	delete altSOBSlots;
	delete altDLRSlots;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="xCreateROROVoyageStructure" id="68133238-bd32-4e04-986c-619559dfd635">
        <source>xCreateROROVoyageStructure() : CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	vesselName 	, voyageName: String;
	vessel 		: CM_Vessel;	 
	voyage 		: CM_Voyage;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure 	: CM_ROROVoyageStructure;
	voyageDeck 				: CM_DeckVoyage;
begin
	vesselName:="UT_RORO";
	voyageName:="UT_RORO001";
	self.deleteVessel(vesselName);
	self.deleteVoyage(voyageName);
	self.assertNull(self.getVessel(vesselName));
	
	vessel:=self.xCreateROROVesselStructure(vesselName);
	
	//self.addVesselDecks(vesselName);
	// AKB MOVED THIS TO DSL Layer 	self.xCreateROROVesselDeck();
	
	voyage:=self.addVoyageWithConRORO(voyageName, vesselName, "ANL", "ANZ", null, 0, false, true);
	
	voyageCellularStructure:=voyage.myCellularVoyageStructure;
	//check cellularStructure created
	self.assertNotNullMsg(voyageCellularStructure,"has cellular structure");
	voyageROROStructure:=voyage.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure,"has roro structure");
	
	// AKB ADDED
	voyageDeck:=voyageROROStructure.allDecksByCode[DECK1];
	if voyageDeck &lt;&gt; null then
		self.addROROVoyageContainers(voyageDeck,false, 0);
		self.addROROVoyageGC(voyageDeck);
	//	self.xCreateROROVoyageOOTL(voyageDeck);
	endif;
	
	return voyage;
	
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="zCreateROROVesselDeck" id="0b5879c4-e60f-4f7e-8efb-5d24095640be">
        <source>zCreateROROVesselDeck();

/// ###### DO NOT USE - use 	UT_DSL addVesselDecks






/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	vessel : CM_Vessel;
	vesselName : String;
	pxyDeck  : CM_DeckVessel;
	realDeck : CM_Deck;
	code : String;
	description : String;
	remarks : String;
	maxClearHeight,
	totalArea : Decimal[12,2];
	ordinal: Integer;
	totalVolume : Decimal[12,2];
	totalTEU : Integer;
	totalLM,
	maxLoadStack20,
	maxLoadStack40,
	maxLoadAxel,
	maxLoadM2   : Decimal[12,2];
	numTier : Integer;
	heightFromBL : Decimal[12,2];
	newDeckItems : ObjectArray;
	pxyLayerLayout : CM_DeckLayerLayout;
begin
	vesselName:="UT_RORO" ;	
	vessel	:= self.getVessel( vesselName );

	assertNotNull(vessel);
	
	create pxyDeck transient;
	
	code:=DECK1;
	description:="DECK1 Description";
	remarks:="Some decking remarks";
	maxClearHeight:=20.5;
	totalArea:=30000.67;
	totalVolume:=234.89;
	totalTEU:=10000;
	totalLM:=23423.45;
	maxLoadStack20:=12342.67;
	maxLoadStack40:=62423.56;
	maxLoadAxel:=87534.45;
	maxLoadM2:=234.56;
	numTier:=3;
	heightFromBL:=63455.67;
	ordinal:=1;
	
	pxyDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	pxyDeck.setMyROROStructure(vessel.myROROVesselStructure);
	
	
	
	app.myTrxCA.trxCreateRORODeck(pxyDeck,realDeck,false,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Real deck = null");
	self.assertTrueMsg(realDeck.isKindOf(CM_DeckVessel),"real deck created class not CM_DeckVessel"); 
	self.assertEqualMsg(realDeck.CM_DeckVessel.myROROStructure, vessel.myROROVesselStructure, " myROROStructure ref = null");
	self.assertEqualMsg(realDeck.code, code,"code !=");
	self.assertEqualMsg(realDeck.description, description,"description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"totalTEU !=");
	self.assertEqualMsg(realDeck.totalLM, totalLM,"totalLM !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"heightFromBL !=");
	
	delete pxyDeck;
	
	// AKB added this - 17/6/11
	pxyDeck := app.createUpdateProxy(realDeck).CM_DeckVessel;
	
	self.xCreateDeckLayerLayoutCargo(pxyDeck.CM_DeckVessel);
 	
	
	delete pxyDeck;
	
	create pxyDeck transient;
	code:=DECK2;
	description:="DECK2 Description";
	ordinal:=2;
	pxyDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	pxyDeck.setMyROROStructure(vessel.myROROVesselStructure);
	
	app.myTrxCA.trxCreateRORODeck(pxyDeck,realDeck,false,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Real deck2 = null");
	self.assertEqualMsg(realDeck.CM_DeckVessel.myROROStructure, vessel.myROROVesselStructure, "d2 myROROStructure ref = null");
	self.assertEqualMsg(realDeck.code, code,"d2 code !=");
	self.assertEqualMsg(realDeck.description, description,"d2 description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"d2 remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"d2 maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"d2 totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"d2 ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"d2 totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"d2 totalTEU !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"d2 maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"d2 maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"d2 maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"d2 maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"d2 numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"d2 heightFromBL !=");
	
epilog
	delete pxyDeck;
	delete newDeckItems;
	
end;</source>
    </JadeMethod>
</Class>
