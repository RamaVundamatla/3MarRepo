    <JadeWebServicesMethod name="getUserStateData" id="bb62fd47-04fa-4471-8aaf-f870a48f44b5">
        <source>getUserStateData(_key : String) : WS_StateDataResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2015	cnwmc5	Initial creation

*/

vars
	response		: WS_StateDataResponse;
	completedOK		: Boolean;
	
	stateData		: WS_StateData;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(99999);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if _key = null then
		//app.raiseCMException(null, null, null);
		completedOK := true;
		return response;
	endif;
	
	create stateData transient;
	stateData.key := _key;
	stateData.value := app.getMyUser().getStateData(ConfigGrp_Web, _key).String;
	
	response.myStateData := stateData;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="WS_StateDataResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getUserTransacitonTypes" id="536695fe-1834-4938-9b44-aeacdbb3834b">
        <source>getUserTransacitonTypes() :WS_TransactionTypeResponse  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlger1	Initial creation 47319

*/

vars
	response			: WS_TransactionTypeResponse;
	completedOK			: Boolean;
	ws_TransactionType	: WS_TransactionType;
	cm_TransactionType	: CM_TransactionType;
	iter  : Iterator;
	tmpRole : CM_SecurityRole;
	
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	tmpRole := app.getMySecurityRole();
	if tmpRole = null then
		completedOK := true;
		return response;
	endif;	
	
	// Populate response with all of the allowed transaction types
	iter	:= tmpRole.allTransactionTypesForEvents.createIterator;
	while iter.next( cm_TransactionType ) do 
		if cm_TransactionType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_TI then		// ie not Cargo
			continue;
		endif;
		
		create ws_TransactionType transient;
		ws_TransactionType.setFromTransactionType( cm_TransactionType.description );
		response.allTransactionTypes.add( ws_TransactionType );
	endwhile;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_TransactionTypeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getUsers" id="704725eb-a37c-4c23-90a9-67428ca39b2e">
        <usesRPC>default</usesRPC>
        <source>getUsers() : WS_UsersResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_UsersResponse;
	completedOK		: Boolean;
	user			: CM_User;
	proxyUser		: WS_User;
	failedDAC  		: CM_DataAccessController;	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Populate response - cloned from CMUI_ComboUser
	foreach user in app.myRoot.allUsers discreteLock do
		if user.code.trimBlanks.toUpper = 'SUPERUSER' then
			continue;
		endif;
		
		//06/10/2010 cnwdz2 24537
		if not user.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		if user.isNotAvailableForEntry then
			continue;
		endif;
		
		create proxyUser transient;
		proxyUser.setProxyFromObject(user);
		response.allUsers.add(proxyUser);
		
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getUsers</wsdlName>
        <ReturnType type="WS_UsersResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVehicleBookingTimeslotTypes" id="9e4ea221-74ea-4f6b-8ce6-12a51651b915">
        <source>getVehicleBookingTimeslotTypes() : WS_VBTimeSlotTypeResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwmc5	Initial creation	PAR 35008

*/

vars
	response		: WS_VBTimeSlotTypeResponse;
	completedOK		: Boolean;
	timeSlotType	: CM_VehicleBookingTimeSlotType;
	wsTimeSlotType	: WS_VehicleBookingTimeSlotType;
	terminal	    : CM_Terminal;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	terminal := app.myPassport.myTerminal;	// ### TFS 56678 23Feb2023 NAVPW1
	// Create the response
	create response transient;
	
	foreach timeSlotType in terminal.allTerminalVBSSlotTypes do		//21.06.2022 navma1 #53697
		create wsTimeSlotType transient;
		wsTimeSlotType.setProxyFromObject(timeSlotType);
		response.allVehicleBookingTimeSlotTypes.add(wsTimeSlotType);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_VBTimeSlotTypeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVehicleMake" id="d351099c-e2e5-4ec7-8056-d604b0214a22">
        <source>getVehicleMake() : WS_VehicleMakeResponse webService;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
24/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
*/
vars
	response 		: WS_VehicleMakeResponse;
	pxyVehicleMake	: WS_VehicleMake;
	vehicleMake		: CM_VehicleMake;
	completedOK 	: Boolean;
	obj				: Object;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	if app.myDutyDocRoot &lt;&gt; null then
