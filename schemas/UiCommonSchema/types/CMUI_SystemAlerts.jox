end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPrintX" id="05fefc48-34b6-4359-98fb-d4b9d7e67cd8">
        <source>doBtnPrintX(pTable: Table input );
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lRow, lCol, idx, lLeft : Integer;
	lLine : String;
	lControl : Control;
begin
	self.frmReport.width := 690;
	self.frmReport.height := 25;
	self.frmReport.top := 5;
	self.frmReport.left := 5;
	self.frmReport.visible := true;
	foreach lCol in 1 to pTable.columns do
		lControl :=  lblReport.getControl(lCol);
		if lControl = null then
			lControl := lblReport.loadControl(lCol);
		endif;
		lControl.width := pTable.accessColumn(lCol).width;
		lControl.left := lLeft;
		lLeft := lLeft + lControl.width.Integer;
		lControl.height := 20; //pTable.accessRow(1).height;
		lControl.top := 1;
		lControl.fontName := pTable.fontName;
		lControl.fontSize := pTable.fontSize;
		lControl.visible := true;
		lControl.enabled := true;
		
	endforeach;
	foreach lRow in 1 to pTable.rows do
		lLine := null;
		foreach lCol in 1 to pTable.columns do
			lControl := lblReport.getControl(lCol);
			lControl.Label.caption := pTable.accessCell(lRow,lCol).text;
		endforeach;
		app.printer.print(self.frmReport);
	endforeach;
	app.printer.close;

end;</source>
        <Parameter name="pTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doClear" id="e5d318e1-f5d2-4816-9ac9-f46de0dbeadf">
        <updating/>
        <source>doClear() updating;

// cnwdvb1 29 October 2002 

vars

	allAlerts	: CM_SystemAlertByDateTime;
	rtnValue	: Boolean;
	alert		: CM_SystemAlert;
	idx			: Integer;
	numRows		: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	if app.msgBox(app.getErrorString2(ConfirmDelete, 'all','alerts'), 'Delete', MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_Second	) = MsgBox_Return_Yes then
		create allAlerts transient;
		numRows := self.tblAlerts.rows;
		foreach idx in 2 to numRows do
			alert := self.tblAlerts.accessRow(idx).itemObject.CM_SystemAlert;
			allAlerts.add(alert);
		endforeach;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteSystemAlert(allAlerts,app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				self.displayAlerts();
				break;
			else
				theResult := app.showErrorWarningDialog('System Alerts', app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	endif;
	
epilog

	delete allAlerts;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="e9e7c7bd-16d9-4733-878a-f4eff26fbe1b">
        <updating/>
        <source>doDelete() updating;

vars
	obj			: Object;
	allAlerts	: CM_SystemAlertByDateTime;
	msg : String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	create allAlerts transient;
	
	foreach obj in	self.tblAlerts.allSelectedObjects do
		allAlerts.add(obj.CM_SystemAlert);
	endforeach;

	if not allAlerts.isEmpty then
	
		if allAlerts.size = 1 then
			msg := app.getErrorString2(ConfirmDelete, 'this', 'alert');
		else
			msg := app.getErrorString2(ConfirmDelete, 'these ' &amp; allAlerts.size.String, ' Alerts');
		endif;
		
		if app.msgBox(msg, 'Delete System Alert', MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteSystemAlert(allAlerts,app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					self.tblAlerts.selectRow(self.tblAlerts.fixedRows + 1, false);
					break;
				else
					theResult := app.showErrorWarningDialog('YRD System Alerts', app.myPassport, ErrWarnMode_Delete);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
	
			
		endif;
	endif;
	
epilog

	delete allAlerts;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayRemoteData" id="4f614a3a-33c6-4135-9548-3aff9c23321b">
        <source>doDisplayRemoteData();

vars

	alert 		: CM_SystemAlert;
	editForm	: CMUI_RemoteDataEditForm;
	remoteHdr	: CM_RemoteDataHdr;
	

begin

	alert := self.tblAlerts.accessRow(self.tblAlerts.row).itemObject.CM_SystemAlert;
	if alert &lt;&gt; null and alert.myRemoteDataHdr &lt;&gt; null then
		remoteHdr := alert.myRemoteDataHdr;
		create editForm transient;
		editForm.initialize(remoteHdr);
		editForm.openWithSavedSettings();//4 sep 2008 cnwdz2 par17846
		editForm.show();
	endif;
epilog
//	delete editForm;
end;</source>
