    <JadeMethod name="fixupPinNumberStatus" id="27bf6904-8bfc-431e-b6da-1c6297ff63bc">
        <source>fixupPinNumberStatus();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/12/2011	cnwdap1	Initial creation PAR #28826 Fix up PIN status on non-embargoed CM_PinNo objects
*/
vars
	pin 		: CM_PinNo;
	ti 			: CM_TrackedItem;
	
begin
	beginTransaction;
	foreach pin in CM_PinNo.instances do
		if pin.status = PIN_InProcess and not pin.isEmbargoed then 
			if pin.allItems.first.isKindOf(CM_TrackedItem) then
				ti := pin.allItems.first.CM_TrackedItem;
				if ti.isOnSite then
					pin.setPropertyValue(CM_PinNo::status.name, PIN_Normal);
				endif;
			elseif pin.allItems.first.isKindOf(CM_BulkRelease) then
				pin.setPropertyValue(CM_PinNo::status.name, PIN_Normal);
			endif;
		endif;
	endforeach;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="fixupRoRoLocations" id="ca591f4b-5924-45a8-b798-307c34e48f71">
        <source>fixupRoRoLocations();

/*

Purpose:	fix locationID properties on tracked items in roro lanes which could be wrong, part of par 28940		

Parameters:			

Return Value:		


Date		Who		Reason
21 February 2012	cnwrd1	Initial creation

*/

vars
	roroLane 	: CM_RoRoController;
	aTI 		: CM_TrackedItem;
begin
	app.initialize();
	
	beginTransaction;
	foreach roroLane in CM_RoRoController.instances do	
		foreach  aTI in roroLane.allTrackedItems do
			aTI.refreshLocationId(REAL_MODE);
		endforeach;
	endforeach;
	
	commitTransaction;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetTIBehaviourTypeGraphics" id="8a6f7769-b34a-413d-9bd1-d73e69bf3989">
        <source>resetTIBehaviourTypeGraphics();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2012	cnwer1	PAR 29300 - Graphics changed to fit text in

*/

vars
	allBehaviourTypes : ObjectArray;
	  obj : Object;
begin
	create allBehaviourTypes transient;
	CM_TIBehaviourType.allInstances(allBehaviourTypes,null,true);
	
	foreach obj in allBehaviourTypes do
		beginTransaction;
		if obj.CM_TIBehaviourType.myGraphic &lt;&gt; null then
			obj.CM_TIBehaviourType.myGraphic.allCommands.purge;
		endif;
		obj.CM_TIBehaviourType.createDefaultGraphic();
		commitTransaction;
	endforeach;
	
epilog
	delete allBehaviourTypes;

end;</source>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="d946b93e-fe8c-473f-a085-0eba9ce6433e">
        <updating/>
        <source>specificPostStandard(_controllerObj: CnEcReleaseController) updating;

vars
	fileObj	: File;
	tempStr	: String;
	
begin
	create fileObj transient;
	fileObj.usePresentationFileSystem	:= false;
	//fileObj.kind						:= File.Kind_ANSI;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	fileObj.mode						:= File.Mode_Output;
	fileObj.fileName					:= app.myCnCntrl.logPath &amp; '\app_upgrade.log';
	if fileObj.isAvailable then
		fileObj.purge();
	endif;
	
	tempStr	:= 'Performing Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage( tempStr, _controllerObj, fileObj );
	
	inheritMethod(_controllerObj);
	
	tempStr	:= 'Check and fix system seal types';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.fixSystemSealTypes();
	
	tempStr	:= 'Check for and convert remaining old seal data';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.convertRemainingSealData();

	tempStr	:= 'Fix the status on unembargoed PIN objects';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.fixupPinNumberStatus();
	
	tempStr	:= 'Fix the Im Codes on EDI Cargo Tracked Items';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.fixEDICargoTIImCodes();

	tempStr	:= 'Fix the locationID values on cargo in RoRo Lanes'; //cnwrd1 par 28940
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.fixupRoRoLocations();

	tempStr	:= 'Fix Rotated RORO Locations'; // PAR 28990 AKB
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.convertRORORotation();
	
	tempStr := 'Set Harbour Timez0ne';	//20 Mar 2012	NDL	Par 28251
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.convertHarbourTimezone();

	tempStr	:= 'Fix EDI StowAdvice';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.fixupEDIStowAdvice();
	
	tempStr	:= 'Convert Voyage cutoffs';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.convertVoyageCutoffs();
	
	tempStr	:= 'Convert Sailing packages';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.convertSailingPackages();

	tempStr	:= 'Reset SU PW';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.resetSUPassword();
	
	tempStr	:= 'Convert EDI Party, EDI Release Request TI and Release Requests';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.convertEDITempFields();

	tempStr	:= 'Reseting Cargo Behaiour graphics';
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.resetTIBehaviourTypeGraphics();
	
	tempStr	:= 'Create Termimal Job Sheets if not there';	//17 May 2012	NDL	Par 28193
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.fixTerminalJobSheets();
	
	tempStr	:= 'Repair YA Location Cell arrays in Gridded Block Stacks';	//29 May 2012	NDL	Par 29604
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.fixForkListTaCells();
	
	tempStr	:= 'Convert non-posted invoice lines';			// 18 June 2012	JRE par 29698
	self.logMessage(tempStr, _controllerObj, fileObj);
	self.convertInvoiceLines();

//	tempStr	:= 'Fix Something';
//	self.logMessage(tempStr, _controllerObj, fileObj);
//	self.fixSample();
	
	//*************** this is the last thing that should happen
	tempStr	:= 'Finished Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage(tempStr, _controllerObj, fileObj);
epilog

end;
</source>
        <Parameter name="_controllerObj" type="CnEcReleaseController"/>
    </JadeMethod>
</Class>
