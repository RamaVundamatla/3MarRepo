    <JadeMethod name="setInvalidReference" id="7b8c1e03-a04d-4a60-9122-c8b36450b2c6">
        <updating/>
        <source>setInvalidReference(_pName:String; _fixit:Boolean) updating;//serverExecution,
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs1
//
// Purpose:     To allow serialisation of properties of each class     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 Mar 2008	conks1a		PAR #16047 - remove unnecessary serverExecution for performance
// ---------------------------------------------------------------------------

vars
	object: Object;
	size: Integer;
	test : Integer;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, object, invalid);
	object := self.getPropertyValue(_pName).Object;
	if object &lt;&gt; null then
		test := object.edition;
		if invalid then
			app.writeLog("&lt;"&amp;self.String&amp;"&gt;"&amp;"&lt;"&amp;_pName&amp;"&gt;",0);
			if _fixit then
				self.setPropertyValue(_pName, null);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_pName" type="String"/>
        <Parameter name="_fixit" type="Boolean"/>
    </JadeMethod>
