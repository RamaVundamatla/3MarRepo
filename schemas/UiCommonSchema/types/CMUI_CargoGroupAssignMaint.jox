    <JadeMethod name="populateCargoIdsTbl" id="ebc0bbd1-62e6-40b6-b70a-af4f930f80d6">
        <source>populateCargoIdsTbl( cg : CM_CargoGroup );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 39186
13 Aug 2018		NDL		TFS 40116

*/

vars

	cargoId : String;
	obj : Object;
	iter : Iterator;
	heading : String;
	scannedStr : String;
	notScannedStr : String;
	rowIndex : Integer;
	cargoGroupId : String;
	
	allPreAssignedCargoIdsDict : CM_ObjectByStringDict;
	allPreAssignedCargoIds : StringArray;
	assignment : CM_CargoGroupAssignment;
	
	edition : Integer;
	inValid : Boolean;

begin

	self.tblCGNid.rows := 1;
	self.tblCGNid.columns := 2;
	self.tblCGNid.fixedRows := 1;
	self.tblCGNid.fixedColumns := 0;
	
	scannedStr := app.getErrorString(Scanned);
	notScannedStr := app.getErrorString(Not_scanned);
	
	heading := app.getErrorString(Cargo_Id_s) &amp; Tab &amp; app.getErrorString(Status);
	
	
	if cg &lt;&gt; null then
	
		on Exception do app.handleDeletedObject( exception, cg, inValid );
		edition := cg.edition;
		if inValid then
			self.tblCGNid.setCellText( 1, 1, heading );
			return;
		endif;
	
		create allPreAssignedCargoIdsDict transient;
		create allPreAssignedCargoIds transient;
		
		cg.getAllPreAssignedCargoIdsDict( allPreAssignedCargoIdsDict );
		if allPreAssignedCargoIdsDict.isEmpty then
			cg.getAllPreAssignedCargoIds( allPreAssignedCargoIds );
		endif;
		
		assignment := cg.getMyCargoGroupAssignment();

		if not allPreAssignedCargoIdsDict.isEmpty then
			heading := app.getErrorString(Preassigned) &amp; " " &amp; app.getErrorString(Cargo_Id_s) &amp; Tab &amp; app.getErrorString(Status);
			iter := allPreAssignedCargoIdsDict.createIterator;
		elseif cg.isTransient and not allPreAssignedCargoIds.isEmpty then
			heading := app.getErrorString(Preassigned) &amp; " " &amp; app.getErrorString(Cargo_Id_s) &amp; Tab &amp; app.getErrorString(Status);
			foreach cargoId in allPreAssignedCargoIds do
				if cargoId &lt;&gt; null then
					self.tblCGNid.addItem( cargoId );
				endif;
			endforeach;
		elseif assignment &lt;&gt; null and not assignment.allCargoIdsDict.isEmpty then
			heading := app.getErrorString(Selectable) &amp; " " &amp; app.getErrorString(Cargo_Id_s) &amp; Tab &amp; app.getErrorString(Status);
			iter := assignment.allCargoIdsDict.createIterator;
		endif;
		
	endif;
	
	self.tblCGNid.setCellText( 1, 1, heading );
		
	
	if iter &lt;&gt; null then
		while iter.next( obj ) do
			cargoId := iter.getCurrentKey( 1 ).String;
			if cargoId &lt;&gt; null then
				rowIndex := self.tblCGNid.addItem( cargoId );
				if assignment &lt;&gt; null and assignment.tiHasBeenScanned( null, cargoId, cargoGroupId ) then
					self.tblCGNid.setCellText( rowIndex, 2, scannedStr &amp; " - " &amp; cargoGroupId);
				else
					self.tblCGNid.setCellText( rowIndex, 2, notScannedStr );
				endif;
			endif;
		endwhile;
	endif;
	
	self.tblCGNid.colourRows(self.colorRow1, self.colorRow2);

epilog

	delete iter;
	delete allPreAssignedCargoIdsDict;
	delete allPreAssignedCargoIds;

end;</source>
        <Parameter name="cg" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="populateFilterCombos" id="d87f82e8-82d1-44e1-bee6-7949fba75bc3">
        <source>populateFilterCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	bolType : CM_CargoBOLType;
	cargoType : CM_CargoType;
	index : Integer;

begin

	self.cmbCargoType.clear();
	
	self.cmbCargoType.sorted := true;
	self.cmbCargoType.addItem( app.getErrorString(AnyString) );
	
	//these are the cargo type of teh cargo on the cargo group associated with the notified cargo groups on teh cargo group assignment
	foreach bolType in self.myTerminal.allCargoBOLTypes do
		if not bolType.isCargoType then
			continue;
		endif;
		if bolType.isCargoGroup then	 
			continue;
		endif;
		cargoType := bolType.CM_CargoType;
		index := self.cmbCargoType.addItem( cargoType.description );
		self.cmbCargoType.itemObject[index] := cargoType;
	endforeach;
	
	self.cmbCargoType.listIndex := 1;
	self.cmbCargoType.lostFocus( self.cmbSubCargoType );
	
	
	self.populateProducts( null );
	
	
	self.cmbStatus.clear();
	self.cmbStatus.sorted := false;
	index := self.cmbStatus.addItem( app.getErrorString(AnyString) );
	self.cmbStatus.itemData[index] := 0;
	index := self.cmbStatus.addItem( app.getErrorString(Not_completed) );
	self.cmbStatus.itemData[index] := 1;
	index := self.cmbStatus.addItem( app.getErrorString(Completed) );
	self.cmbStatus.itemData[index] := 2;
	index := self.cmbStatus.addItem( app.getErrorString(Not_started) );
	self.cmbStatus.itemData[index] := 3;
	self.cmbStatus.listIndex := 1;
	self.cmbStatus.lostFocus( self.cmbSubCargoType );
	
	
	self.cmbCGAType.clear();
	self.cmbCGAType.sorted := false;	
	index := self.cmbCGAType.addItem( app.getErrorString(AnyString) );
	self.cmbCGAType.itemData[index] := 0;
	index := self.cmbCGAType.addItem( app.getErrorString(Selectable) );
	self.cmbCGAType.itemData[index] := 1;
	index := self.cmbCGAType.addItem( app.getErrorString(Preassigned) );
	self.cmbCGAType.itemData[index] := 2;
	self.cmbCGAType.listIndex := 1;
	self.cmbCGAType.lostFocus( self.cmbSubCargoType );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateProducts" id="63792eb4-2bc2-4688-9c34-c7edf961573e">
        <source>populateProducts( _cargoType : CM_CargoType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	prod : CM_Product;
	index : Integer;

begin

	self.cmbSubCargoType.clear();
	if _cargoType = null or _cargoType.allProducts.isEmpty then
		self.cmbSubCargoType.enabled := false;
		
	else
		self.cmbSubCargoType.enabled := true;
		self.cmbSubCargoType.sorted := true;
		self.cmbSubCargoType.addItem( app.getErrorString(AnyString) );
		
		foreach prod in _cargoType.allProducts do
			index := self.cmbSubCargoType.addItem( prod.description );
			self.cmbSubCargoType.itemObject[index] := prod;
		endforeach;
		
		self.cmbSubCargoType.listIndex := 1;
		
	endif;
	
	self.cmbSubCargoType.lostFocus( self.cmbSubCargoType );

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
