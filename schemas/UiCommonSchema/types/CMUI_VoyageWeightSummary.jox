    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myJRWVoyageSummary" id="2799f264-86b3-4194-8065-0b0b3bcb1bb7">
        <embedded/>
        <type name="CM_JRWVoyageSummary"/>
        <access>readonly</access>
