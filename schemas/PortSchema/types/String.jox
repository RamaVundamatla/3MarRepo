    <JadeMethod name="isValidFeetAndInches" id="d906e301-711d-4460-aa1e-4274779d0b4e">
        <source>isValidFeetAndInches() : Boolean;
//
// Purpose:			Validate the inches portion of an entered decimal value for feet and inches
//					First character after the decimal place 
//
// Parameters:			
//
// Return Value:	True if valid, false if not
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2013	cnwdap1		Initial creation PAR #31754 CCMS SFW 1321 Imperial Measurements
//
vars
	pos 		: Integer;
	decimalSep 	: String;
	firstChar,
	secondChar	: String;

begin
	decimalSep := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	pos := self.pos(decimalSep, 1);
	if pos = null then
		return true;
	endif;
	
	// first character after the decimal palce can be anything, but if it's a zero then the next character can't be non-zero
	// if there's two characters after the decimal place, theey must be &lt; 12
	if self.length &gt; pos then
		firstChar := self[pos+1:1];
		if self.length &gt; pos+1 then
			secondChar := self[pos+2:1];
			if firstChar = "0" and secondChar.Integer &gt; 0 then
				return false;
			elseif firstChar.Integer = 1 and secondChar.Integer &gt; 1 then
				return false;
			elseif firstChar.Integer &gt; 1 then
				return false;
			endif;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidKey" id="3912f6da-2135-4bb5-88f1-5ce3d2998678">
        <source>isValidKey() : Boolean;

vars
	value : Boolean;

begin

	if length &gt; 0 then
		if self[1].isNumeric or self[1].isAlpha then
			value := true;
		endif;
	endif;

	return value;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyOutOfRange" id="75013e67-23f3-4bac-b118-d1aec52b6673">
        <source>keyOutOfRange(_startValue: String; _keyAscending: Boolean): Boolean;
// ---------------------------------------------------------------------------
// Created:     10 November 2004	cnwth2
//
/* Purpose:
	This method is provided to determine whether an iteration over a dictionary should be stopped.
	It checks whether keyValue has run over the end of the range by comparing the shorter of the
	two strings with the same number of leading characters of the other.

	keyValue is the value from the current key from the iterator.
	startValue is the value at which the iterator started (i.e. the original value up to but not including the
		first wildcard character).

	Out of range means that keyValue &gt; startValue if keyAscending is true, and keyValue &lt; startValue
	if keyAscending is false.

	This method is not invoked from the abstract class methods, but is provided as a utility for the
	subclass method checkMatch.

Return Value:
	True if keyValue has overrun the range of startValue.


Date		Who		Reason
14 Sep 99	JDB		Initial creation


*/
vars
	useLength	: Integer;
	value		: Boolean;
begin

	if self.length &lt; _startValue.length then
		useLength:= self.length;
	else
		useLength:= _startValue.length;
	endif;
	
	if useLength &lt;= 0 then
		return false;
	endif;

	if _keyAscending then
		return self[1:useLength] &gt; _startValue[1:useLength];
	else
		return self[1:useLength] &lt; _startValue[1:useLength];
	endif;

end;</source>
        <Parameter name="_startValue" type="String"/>
        <Parameter name="_keyAscending" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lengthInBytes" id="7471f68c-0ed0-4da9-b465-58c2b8516c24">
        <source>lengthInBytes() : Integer;
/*

Purpose:			Return the length of the receiver in bytes, to be used when converting
					to Binary for both ANSI and Unicode

Parameters:			None

Return Value:		Length of the receiver in bytes

Date		Who		Reason
03 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

vars
	returnLength	: Integer;
	
begin
	returnLength := self.length();
	
	if app.isUnicode then
		returnLength := returnLength * 2;
	endif;
	
	return returnLength;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="like" id="d397aa36-0a1a-4102-83af-e7d08406d1dc">
        <source>like(pattern : String; oneWild, flexiWild : Character) : Boolean;

/*

Purpose:			Pattern matching - test to see if the receiver matches the passed in 
					pattern, using the passed in characters as wildcards in the pattern


Return Value:		True if the receiver matches the passed in string, using
					the passed in wildcard characters


Date		Who		Reason
04 May 2004	KPD		Initial creation - PAR #4105 - Rewrite of old recursive routine to use new
					non-recursive algorithm

*/

vars
	selfLen,
	patternLen,
	selfPos,
	patternPos,
	selfSave,
	patternSave		: Integer;
	patternChar		: Character;
	
begin
	// Handle simplest case as an exception
	if self = pattern then
		return true;
	endif;
	
	// If the pattern has no wildcards, then just compare strings
	if pattern.pos(flexiWild, 1) = 0 and pattern.pos(oneWild, 1) = 0 then
		return self = pattern;
	endif;
	
	// Have to compare character by character
	selfLen := self.length;
	patternLen := pattern.length;
	
	selfPos := 1;
	patternPos := 1;

	// Match until first flexiWild in the pattern, or the end of the receiver
	while selfPos &lt;= selfLen do
	
		// If we're still processing the receiver, but have exceeded the pattern, then no match
		if patternPos &gt; patternLen then
			return false;
		endif;
		
		patternChar := pattern[patternPos:1].Character;
		if patternChar = flexiWild then
			break;
		endif;
		
		// Pattern character is not oneWild, and characters don't match, then no match
		if patternChar &lt;&gt; oneWild and self[selfPos:1] &lt;&gt; patternChar then
			return false;
		endif;
		
		selfPos := selfPos + 1;
		patternPos := patternPos + 1;
	
	endwhile;
	
	// Now match wildcard possibilities
	while selfPos &lt;= selfLen do
		
		// We're at a flexiWild in the pattern
		if patternPos &lt;= patternLen and pattern[patternPos:1] = flexiWild then
			// and we're at the end of the pattern, then return true
			if patternPos = patternLen then
				return true;
			endif;
			
			// Step over the flexiWild in the pattern
			patternPos := patternPos + 1;
			
			// Save current positions for backtracking
			patternSave := patternPos;
			selfSave := selfPos + 1;
		
		else
			// If we have a match, then step forward through both receiver and pattern
			if patternPos &lt;= patternLen and (pattern[patternPos:1] = oneWild or self[selfPos:1] = pattern[patternPos:1]) then

				patternPos := patternPos + 1;
				selfPos := selfPos + 1;

			// Otherwise, restore and backtrack to next position in receiver
			else
				patternPos := patternSave;
				selfPos := selfSave;
				selfSave := selfSave + 1;
			endif;
		
		endif;
			
	endwhile;

	// Finally skip over any trailing flexiWilds in the pattern
	while patternPos &lt;= patternLen do
		if pattern[patternPos:1] = flexiWild then
			patternPos := patternPos + 1;
		else
			break;
		endif;
	endwhile;
	
	// If we have processed the whole pattern, then we have a match
	return patternPos &gt; patternLen;
	
	
epilog

end;</source>
        <Parameter name="pattern" type="String"/>
        <Parameter name="oneWild" type="Character"/>
        <Parameter name="flexiWild" type="Character"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeUniqueCodeForDict" id="41debf96-a910-46db-b7eb-a16813c8112b">
        <source>makeUniqueCodeForDict(_dict : MemberKeyDictionary) : String;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	if self is used as a key in _dict, then
			this method will progressivly bastardize it until it's unique
			(starting with the last character)
			
			Currently will only work for single key member key dictionary

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	workString			: String;
	charPos,
	len				: Integer;
	consign			: CM_ConsigneeConsignor;
	char			: Character;
		
begin
	workString := self.trimBlanks.toUpper;
	if _dict[workString] = null then//nothing to do - it's unused
		return workString;
	endif;
	
	len := workString.length;
	foreach charPos in len to 1 step -1 do : charLoop
		char := workString[charPos];
		if (not char.isAlpha) or char = 'A' then
			continue;
		endif;
		
		while true do //65 ascii = 'A'
			char := (char.Integer -1).Character;
			if char.Integer &lt; 'A'.Character.Integer then
				continue charLoop;
			endif;
			
			workString[charPos] := char;
			if _dict[workString] = null then//unused
				return workString;
			endif;
		endwhile;
	endforeach;
	
	return null;
	
end;


</source>
        <Parameter name="_dict" type="MemberKeyDictionary"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="normaliseDirectory" id="f07f43b0-f943-4161-a528-9718259a2d73">
        <source>normaliseDirectory() : String;
// replace any '/' characters with '\' and ensure that there is a trailing '\'
vars
	str	: String;
begin
	if self = null then
		return null;
	endif;
	str := self;
	str.replaceChar('/', '\');
	if str[str.length:1] &lt;&gt; '\' then
		str := str &amp; '\';
	endif;
	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
