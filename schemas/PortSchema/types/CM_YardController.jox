        <source>getVehicleCount() : Integer;
/*

Date		Who		Reason
20 January 2016	cnwer1	Initial creation PAR 37060

*/

vars
	vm : CM_VehicleMachine;
	count : Integer;
begin 
	foreach vm in  self.allVehicleMachines do
		if vm.isKindOf(CM_Vehicle) then
			count:=count + 1;
